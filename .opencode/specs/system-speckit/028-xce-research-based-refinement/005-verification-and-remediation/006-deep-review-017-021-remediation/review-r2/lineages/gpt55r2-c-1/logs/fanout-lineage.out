{"type":"tool_use","timestamp":1781761628793,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_VoyUtrvQ53Ic9Z2j7tUDioii","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","offset":180,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts</path>\n<type>file</type>\n<content>\n180:       const parsed = JSON.parse(rawMetadata);\n181:       return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n182:         ? parsed as Record<string, unknown>\n183:         : {};\n184:     } catch (_error: unknown) {\n185:       return {};\n186:     }\n187:   }\n188: \n189:   return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n190:     ? rawMetadata as Record<string, unknown>\n191:     : {};\n192: }\n193: \n194: function validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n195:   const validateValue = (\n196:     value: string | undefined,\n197:     field: keyof CheckpointScopeArgs,\n198:     options: { trim?: boolean } = {},\n199:   ): string | undefined => {\n200:     if (value === undefined) {\n201:       return undefined;\n202:     }\n203:     if (typeof value !== 'string') {\n204:       throw new Error(`${field} must be a string`);\n205:     }\n206:     return options.trim ? value.trim() : value;\n207:   };\n208: \n209:   const tenantId = validateValue(args.tenantId, 'tenantId', { trim: true });\n210:   const userId = validateValue(args.userId, 'userId');\n211:   const agentId = validateValue(args.agentId, 'agentId');\n212:   const hasActorScope = userId !== undefined || agentId !== undefined;\n213: \n214:   if (\n215:     hasActorScope\n216:     && tenantId !== undefined\n217:     && tenantId.trim().length === 0\n218:   ) {\n219:     throw new Error('tenantId must be a non-empty string when userId or agentId is provided');\n220:   }\n221: \n222:   return {\n223:     tenantId: tenantId && tenantId.length > 0 ? tenantId : undefined,\n224:     userId,\n225:     agentId,\n226:   };\n227: }\n228: \n229: function hasCheckpointScope(scope: CheckpointScopeArgs): boolean {\n230:   return (\n231:     scope.tenantId !== undefined\n232:     || scope.userId !== undefined\n233:     || scope.agentId !== undefined\n234:   );\n235: }\n236: \n237: function requiresCheckpointTenant(scope: CheckpointScopeArgs): boolean {\n238:   return scope.tenantId === undefined && (\n239:     scope.userId !== undefined\n240:     || scope.agentId !== undefined\n241:   );\n242: }\n243: \n244: function mergeCheckpointScopeMetadata(\n245:   metadata: Record<string, unknown> | undefined,\n246:   scope: CheckpointScopeArgs,\n247: ): Record<string, unknown> {\n248:   return {\n249:     ...(metadata ?? {}),\n250:     ...(scope.tenantId !== undefined ? { tenantId: scope.tenantId } : {}),\n251:     ...(scope.userId !== undefined ? { userId: scope.userId } : {}),\n252:     ...(scope.agentId !== undefined ? { agentId: scope.agentId } : {}),\n253:   };\n254: }\n255: \n256: function checkpointMatchesScope(rawMetadata: unknown, scope: CheckpointScopeArgs): boolean {\n257:   const metadata = parseCheckpointMetadata(rawMetadata);\n258:   const matchesScopeField = (field: keyof CheckpointScopeArgs): boolean => {\n259:     const expected = scope[field];\n260:     if (expected === undefined) {\n261:       return true;\n262:     }\n263:     const actual = metadata[field];\n264:     return actual === undefined || actual === expected;\n265:   };\n266: \n267:   return (\n268:     matchesScopeField('tenantId') &&\n269:     matchesScopeField('userId') &&\n270:     matchesScopeField('agentId')\n271:   );\n272: }\n273: \n274: function checkpointScopeDetails(scope: CheckpointScopeArgs): Record<string, string> {\n275:   const details: Record<string, string> = {};\n276:   if (scope.tenantId !== undefined) {\n277:     details.tenantId = scope.tenantId;\n278:   }\n279:   if (scope.userId !== undefined) {\n280:     details.userId = scope.userId;\n281:   }\n282:   if (scope.agentId !== undefined) {\n283:     details.agentId = scope.agentId;\n284:   }\n285:   return details;\n286: }\n287: \n288: function createCheckpointScopeValidationError(\n289:   tool: 'checkpoint_create' | 'checkpoint_list' | 'checkpoint_restore' | 'checkpoint_delete',\n290: ): MCPResponse {\n291:   return createMCPErrorResponse({\n292:     tool,\n293:     error: 'tenantId is required when userId or agentId is provided.',\n294:     code: 'CHECKPOINT_SCOPE_TENANT_REQUIRED',\n295:     details: {\n296:       reason: 'checkpoint_scope_tenant_required',\n297:     },\n298:     recovery: {\n299:       hint: 'Retry with tenantId included for governed checkpoint access.',\n300:     },\n301:   });\n302: }\n303: \n304: function createCheckpointCreateFailureResponse(\n305:   error: unknown,\n306:   context: { name: string; specFolder: string | null },\n307:   startTime: number,\n308: ): MCPResponse {\n309:   const typedError = error instanceof checkpoints.CheckpointCreateError ? error : null;\n310:   const code = typedError?.code ?? 'CHECKPOINT_CREATE_FAILED';\n311:   const message = typedError?.message ?? `Checkpoint creation failed: ${toErrorMessage(error)}`;\n312: \n313:   const recoveryByCode: Record<string, { hint: string; actions: string[]; severity: string }> = {\n314:     CHECKPOINT_CREATE_SQLITE_BUSY: {\n315:       hint: 'SQLite was busy while creating the checkpoint. Retry after active writes finish.',\n316:       actions: [\n317:         'Retry checkpoint_create after concurrent memory writes complete',\n318:         'For sweep harnesses, prefer specFolder-scoped checkpoints or includeEmbeddings=false when rollback semantics allow',\n319:         'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n320:       ],\n321:       severity: 'medium',\n322:     },\n323:     CHECKPOINT_CREATE_SQLITE_LOCKED: {\n324:       hint: 'SQLite was locked by another operation while creating the checkpoint.',\n325:       actions: [\n326:         'Wait for the active lifecycle operation to finish, then retry',\n327:         'Serialize global checkpoint_create calls in parallel sweep harnesses',\n328:         'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n329:       ],\n330:       severity: 'medium',\n331:     },\n332:     CHECKPOINT_CREATE_DUPLICATE_NAME: {\n333:       hint: 'A checkpoint with this name already exists.',\n334:       actions: [\n335:         'Use a unique checkpoint name',\n336:         'Run checkpoint_list() to inspect existing names',\n337:         'Delete the existing checkpoint only if rollback policy allows it',\n338:       ],\n339:       severity: 'low',\n340:     },\n341:     CHECKPOINT_CREATE_PERMISSION_DENIED: {\n342:       hint: 'The checkpoint database path is not writable.',\n343:       actions: [\n344:         'Verify database directory permissions',\n345:         'Confirm the MCP server has write access to the SQLite database',\n346:         'Run node dist/cli.js stats to check startup/database access',\n347:       ],\n348:       severity: 'high',\n349:     },\n350:     CHECKPOINT_CREATE_FAILED: {\n351:       hint: 'Checkpoint creation failed before a row was persisted.',\n352:       actions: [\n353:         'Inspect the underlying error details',\n354:         'Run memory_health() or node dist/cli.js stats to check database availability',\n355:         'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n356:       ],\n357:       severity: 'medium',\n358:     },\n359:   };\n360:   const recovery = recoveryByCode[code] ?? recoveryByCode.CHECKPOINT_CREATE_FAILED;\n361: \n362:   return createMCPErrorResponse({\n363:     tool: 'checkpoint_create',\n364:     error: message,\n365:     code,\n366:     details: {\n367:       name: context.name,\n368:       specFolder: context.specFolder,\n369:       ...(typedError?.originalCode ? { underlyingCode: typedError.originalCode } : {}),\n370:       ...(typedError?.details ? { storage: typedError.details } : {}),\n371:     },\n372:     recovery,\n373:     startTime,\n374:   });\n375: }\n376: \n377: /* ───────────────────────────────────────────────────────────────\n378:    3. CHECKPOINT CREATE HANDLER\n379: ──────────────────────────────────────────────────────────────── */\n380: \n381: /** Handle checkpoint_create tool — snapshots the current memory state for rollback.\n382:  * @param args - Checkpoint creation arguments (name, note)\n383:  * @returns MCP response with checkpoint metadata\n384:  */\n385: async function handleCheckpointCreate(args: CheckpointCreateArgs): Promise<MCPResponse> {\n386:   await ensureMemoryRuntimeInitialized('handler:checkpoint_create');\n387:   const startTime = Date.now();\n388:   await checkDatabaseUpdated();\n389:   const { name, specFolder: spec_folder, metadata } = args;\n390:   const scope = validateCheckpointScope(args);\n391:   if (requiresCheckpointTenant(scope)) {\n392:     return createCheckpointScopeValidationError('checkpoint_create');\n393:   }\n394: \n395:   if (!name || typeof name !== 'string') {\n396:     throw new Error('name is required and must be a string');\n397:   }\n398: \n399:   if (spec_folder !== undefined && typeof spec_folder !== 'string') {\n400:     throw new Error('specFolder must be a string');\n401:   }\n402: \n403:   // Global embedding-inclusive checkpoints are expensive serialized lifecycle\n404:   // operations. Parallel sweep harnesses should prefer specFolder-scoped\n405:   // checkpoints or includeEmbeddings=false when rollback semantics allow it.\n406:   let result: checkpoints.CheckpointInfo | null;\n407:   try {\n408:     result = checkpoints.createCheckpoint({\n409:       name,\n410:       specFolder: spec_folder,\n411:       ...(args.includeEmbeddings !== undefined ? { includeEmbeddings: args.includeEmbeddings } : {}),\n412:       metadata: mergeCheckpointScopeMetadata(metadata, scope),\n413:       scope,\n414:     });\n415:   } catch (error: unknown) {\n416:     return createCheckpointCreateFailureResponse(\n417:       error,\n418:       { name, specFolder: spec_folder ?? null },\n419:       startTime,\n420:     );\n421:   }\n422: \n423:   if (!result) {\n424:     return createMCPErrorResponse({\n425:       tool: 'checkpoint_create',\n426:       error: 'Checkpoint creation failed',\n427:       code: 'CHECKPOINT_CREATE_FAILED',\n428:       details: {\n429:         name,\n430:         specFolder: spec_folder ?? null,\n431:       },\n432:       recovery: {\n433:         hint: 'Verify database availability and retry checkpoint_create.',\n434:         actions: ['Run checkpoint_list() to confirm checkpoint state before destructive operations'],\n435:       },\n436:       startTime,\n437:     });\n438:   }\n439: \n440:   return createMCPSuccessResponse({\n441:     tool: 'checkpoint_create',\n442:     summary: `Checkpoint \"${name}\" created successfully`,\n443:     data: {\n444:       success: true,\n445:       checkpoint: result\n446:     },\n447:     hints: [\n448:       `Restore with: checkpoint_restore({ name: \"${name}\" })`,\n449:       `Delete with: checkpoint_delete({ name: \"${name}\", confirmName: \"${name}\" })`\n450:     ],\n451:     startTime: startTime\n452:   });\n453: }\n454: \n455: /* ───────────────────────────────────────────────────────────────\n456:    4. CHECKPOINT LIST HANDLER\n457: ──────────────────────────────────────────────────────────────── */\n458: \n459: /** Handle checkpoint_list tool - returns available checkpoints filtered by spec folder */\n460: async function handleCheckpointList(args: CheckpointListArgs): Promise<MCPResponse> {\n461:   await ensureMemoryRuntimeInitialized('handler:checkpoint_list');\n462:   const startTime = Date.now();\n463:   await checkDatabaseUpdated();\n464:   const { specFolder: spec_folder, limit: raw_limit = 50 } = args;\n465:   const scope = validateCheckpointScope(args);\n466:   if (requiresCheckpointTenant(scope)) {\n467:     return createCheckpointScopeValidationError('checkpoint_list');\n468:   }\n469: \n470:   if (spec_folder !== undefined && typeof spec_folder !== 'string') {\n471:     throw new Error('specFolder must be a string');\n472:   }\n473: \n474:   const limit = (typeof raw_limit === 'number' && Number.isFinite(raw_limit) && raw_limit > 0)\n475:     ? Math.min(Math.floor(raw_limit), 100)\n476:     : 50;\n477: \n478:   const results = checkpoints.listCheckpoints(spec_folder ?? null, limit, scope);\n479:   const filteredResults = hasCheckpointScope(scope)\n480:     ? results.filter((checkpoint) => checkpointMatchesScope(checkpoint.metadata, scope))\n481:     : results;\n482: \n483:   const summary = filteredResults.length > 0\n484:     ? `Found ${filteredResults.length} checkpoint(s)`\n485:     : 'No checkpoints found';\n486: \n487:   return createMCPSuccessResponse({\n488:     tool: 'checkpoint_list',\n489:     summary,\n490:     data: {\n491:       count: filteredResults.length,\n492:       checkpoints: filteredResults\n493:     },\n494:     hints: filteredResults.length === 0\n495:       ? ['Create a checkpoint with checkpoint_create({ name: \"my-checkpoint\" })']\n496:       : [],\n497:     startTime: startTime\n498:   });\n499: }\n500: \n501: /* ───────────────────────────────────────────────────────────────\n502:    5. CHECKPOINT RESTORE HANDLER\n503: ──────────────────────────────────────────────────────────────── */\n504: \n505: /** Handle checkpoint_restore tool - restores memory state from a named checkpoint */\n506: async function handleCheckpointRestore(args: CheckpointRestoreArgs): Promise<MCPResponse> {\n507:   await ensureMemoryRuntimeInitialized('handler:checkpoint_restore');\n508:   const startTime = Date.now();\n509:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n510:   if (restoreBarrier) {\n511:     return createMCPErrorResponse({\n512:       tool: 'checkpoint_restore',\n513:       error: restoreBarrier.message,\n514:       code: restoreBarrier.code,\n515:       details: {\n516:         name: args.name ?? null,\n517:       },\n518:       recovery: {\n519:         hint: 'Retry checkpoint_restore after the active restore maintenance window completes.',\n520:         actions: ['Wait for the current restore to finish', 'Retry the restore request'],\n521:         severity: 'warning',\n522:       },\n523:       startTime,\n524:     });\n525:   }\n526: \n527:   await checkDatabaseUpdated();\n528:   const { name, clearExisting: clear_existing = false } = args;\n529:   const scope = validateCheckpointScope(args);\n530:   if (requiresCheckpointTenant(scope)) {\n531:     return createCheckpointScopeValidationError('checkpoint_restore');\n532:   }\n533: \n534:   if (!name || typeof name !== 'string') {\n535:     throw new Error('name is required and must be a string');\n536:   }\n537: \n538:   if (hasCheckpointScope(scope)) {\n539:     const checkpoint = checkpoints.getCheckpoint(name, scope);\n540:     if (checkpoint && !checkpointMatchesScope(checkpoint.metadata, scope)) {\n541:       return createMCPErrorResponse({\n542:         tool: 'checkpoint_restore',\n543:         error: `Checkpoint \"${name}\" scope mismatch`,\n544:         code: 'CHECKPOINT_SCOPE_MISMATCH',\n545:         details: {\n546:           name,\n547:           scope: checkpointScopeDetails(scope),\n548:         },\n549:         recovery: {\n550:           hint: 'Retry with matching scope values or omit optional scope parameters if you intend to access an unscoped checkpoint.',\n551:           actions: ['Use checkpoint_list() with the same scope parameters to discover accessible checkpoints'],\n552:         },\n553:         startTime,\n554:       });\n555:     }\n556:   }\n557: \n558:   const result = checkpoints.restoreCheckpoint(name, clear_existing, scope);\n559:   const hasRestoreErrors = result.errors.length > 0;\n560:   const hasRestoredData = result.restored > 0 || result.workingMemoryRestored > 0;\n561:   const hasPartialFailure = result.partialFailure === true;\n562:   const hasPartialSuccess = !hasPartialFailure && (result.skipped > 0 || hasRestoreErrors);\n563: \n564:   // Rebuild search indexes after checkpoint restore — without this, restored\n565:   // memories are invisible to search until server restart. The BM25 rebuild\n566:   // uses the same engine-routing gate as boot warmup: when FTS5 serves lexical\n567:   // search (or BM25 is disabled), restore must not warm an in-memory index the\n568:   // runtime would never query.\n569:   if (result.restored > 0 || result.workingMemoryRestored > 0) {\n570:     try {\n571:       vectorIndex.clearConstitutionalCache(null);\n572:       vectorIndex.clearSearchCache(null);\n573: \n574:       const database = vectorIndex.getDb();\n575:       if (database && bm25Index.shouldWarmInMemoryBm25(database)) {\n576:         bm25Index.getIndex().rebuildFromDatabase(database);\n577:       }\n578: \n579:       triggerMatcher.refreshTriggerCache();\n580:     } catch (rebuildErr: unknown) {\n581:       // Index rebuild failure is non-fatal — indexes will self-heal on next query or restart\n582:       console.error('[T102] Index rebuild after checkpoint restore failed:', toErrorMessage(rebuildErr));\n583:     }\n584:   }\n585: \n586:   if (hasRestoreErrors && !hasRestoredData) {\n587:     return createMCPErrorResponse({\n588:       tool: 'checkpoint_restore',\n589:       error: `Checkpoint \"${name}\" restore failed`,\n590:       code: 'CHECKPOINT_RESTORE_FAILED',\n591:       details: {\n592:         name,\n593:         clearExisting: clear_existing,\n594:         restored: result.restored,\n595:         workingMemoryRestored: result.workingMemoryRestored,\n596:         errors: result.errors,\n597:       },\n598:       recovery: {\n599:         hint: 'Use checkpoint_list() to confirm checkpoint name and retry.',\n600:         actions: ['Inspect checkpoint integrity', 'Create a fresh checkpoint before retrying restore'],\n601:       },\n602:       startTime,\n603:     });\n604:   }\n605: \n606:   if (hasPartialFailure && hasRestoredData) {\n607:     return createMCPErrorResponse({\n608:       tool: 'checkpoint_restore',\n609:       error: `Checkpoint \"${name}\" restore completed with partial failure`,\n610:       code: 'CHECKPOINT_RESTORE_PARTIAL_FAILURE',\n611:       details: {\n612:         name,\n613:         clearExisting: clear_existing,\n614:         restored: result.restored,\n615:         skipped: result.skipped,\n616:         workingMemoryRestored: result.workingMemoryRestored,\n617:         rolledBackTables: result.rolledBackTables ?? [],\n618:         errors: result.errors,\n619:       },\n620:       recovery: {\n621:         hint: 'Review the reported table failures before retrying restore.',\n622:         actions: [\n623:           'Inspect restored.errors and restored.rolledBackTables for the failed merge-replace tables',\n624:           'Retry with a narrower scope or clearExisting=true if you intend to replace current state',\n625:         ],\n626:       },\n627:       startTime,\n628:     });\n629:   }\n630: \n631:   if (hasPartialSuccess) {\n632:     return createMCPSuccessResponse({\n633:       tool: 'checkpoint_restore',\n634:       summary: result.errors.length > 0\n635:         ? `Checkpoint \"${name}\" restored with warnings (${result.errors.length})`\n636:         : `Checkpoint \"${name}\" restored partially`,\n637:       data: {\n638:         success: true,\n639:         partial: true,\n640:         warningCount: result.errors.length,\n641:         restored: result,\n642:       },\n643:       hints: [\n644:         'Restore applied partially; review restored.errors and restored.skipped before retrying',\n645:         'Avoid immediate retry with clearExisting=true unless you intend to replace current state',\n646:       ],\n647:       startTime,\n648:     });\n649:   }\n650: \n651:   return createMCPSuccessResponse({\n652:     tool: 'checkpoint_restore',\n653:     summary: `Checkpoint \"${name}\" restored successfully`,\n654:     data: {\n655:       success: true,\n656:       restored: result\n657:     },\n658:     hints: clear_existing\n659:       ? ['Previous data was cleared before restore', 'Search indexes rebuilt']\n660:       : ['Restore merged with existing data - duplicates may exist', 'Search indexes rebuilt'],\n661:     startTime: startTime\n662:   });\n663: }\n664: \n665: /* ───────────────────────────────────────────────────────────────\n666:    6. CHECKPOINT DELETE HANDLER\n667: ──────────────────────────────────────────────────────────────── */\n668: \n669: /** Handle checkpoint_delete tool - permanently removes a named checkpoint */\n670: async function handleCheckpointDelete(args: CheckpointDeleteArgs): Promise<MCPResponse> {\n671:   await ensureMemoryRuntimeInitialized('handler:checkpoint_delete');\n672:   const startTime = Date.now();\n673:   await checkDatabaseUpdated();\n674:   const { name, confirmName } = args;\n675:   const scope = validateCheckpointScope(args);\n676:   if (requiresCheckpointTenant(scope)) {\n677:     return createCheckpointScopeValidationError('checkpoint_delete');\n678:   }\n679: \n680:   if (!name || typeof name !== 'string') {\n681:     throw new Error('name is required and must be a string');\n682:   }\n683:   if (!confirmName || typeof confirmName !== 'string') {\n684:     throw new Error('confirmName is required and must be a string');\n685:   }\n686:   if (confirmName !== name) {\n687:     throw new Error('confirmName must exactly match name to delete checkpoint');\n688:   }\n689: \n690:   if (hasCheckpointScope(scope)) {\n691:     const checkpoint = checkpoints.getCheckpoint(name, scope);\n692:     if (checkpoint && !checkpointMatchesScope(checkpoint.metadata, scope)) {\n693:       return createMCPErrorResponse({\n694:         tool: 'checkpoint_delete',\n695:         error: `Checkpoint \"${name}\" scope mismatch`,\n696:         code: 'CHECKPOINT_SCOPE_MISMATCH',\n697:         details: {\n698:           name,\n699:           scope: checkpointScopeDetails(scope),\n\n(Showing lines 180-699 of 918. Use offset=700 to continue.)\n</content>","metadata":{"preview":"      const parsed = JSON.parse(rawMetadata);\n      return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n        ? parsed as Record<string, unknown>\n        : {};\n    } catch (_error: unknown) {\n      return {};\n    }\n  }\n\n  return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n    ? rawMetadata as Record<string, unknown>\n    : {};\n}\n\nfunction validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n  const validateValue = (\n    value: string | undefined,\n    field: keyof CheckpointScopeArgs,\n    options: { trim?: boolean } = {},\n  ): string | undefined => {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","text":"      const parsed = JSON.parse(rawMetadata);\n      return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n        ? parsed as Record<string, unknown>\n        : {};\n    } catch (_error: unknown) {\n      return {};\n    }\n  }\n\n  return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n    ? rawMetadata as Record<string, unknown>\n    : {};\n}\n\nfunction validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n  const validateValue = (\n    value: string | undefined,\n    field: keyof CheckpointScopeArgs,\n    options: { trim?: boolean } = {},\n  ): string | undefined => {\n    if (value === undefined) {\n      return undefined;\n    }\n    if (typeof value !== 'string') {\n      throw new Error(`${field} must be a string`);\n    }\n    return options.trim ? value.trim() : value;\n  };\n\n  const tenantId = validateValue(args.tenantId, 'tenantId', { trim: true });\n  const userId = validateValue(args.userId, 'userId');\n  const agentId = validateValue(args.agentId, 'agentId');\n  const hasActorScope = userId !== undefined || agentId !== undefined;\n\n  if (\n    hasActorScope\n    && tenantId !== undefined\n    && tenantId.trim().length === 0\n  ) {\n    throw new Error('tenantId must be a non-empty string when userId or agentId is provided');\n  }\n\n  return {\n    tenantId: tenantId && tenantId.length > 0 ? tenantId : undefined,\n    userId,\n    agentId,\n  };\n}\n\nfunction hasCheckpointScope(scope: CheckpointScopeArgs): boolean {\n  return (\n    scope.tenantId !== undefined\n    || scope.userId !== undefined\n    || scope.agentId !== undefined\n  );\n}\n\nfunction requiresCheckpointTenant(scope: CheckpointScopeArgs): boolean {\n  return scope.tenantId === undefined && (\n    scope.userId !== undefined\n    || scope.agentId !== undefined\n  );\n}\n\nfunction mergeCheckpointScopeMetadata(\n  metadata: Record<string, unknown> | undefined,\n  scope: CheckpointScopeArgs,\n): Record<string, unknown> {\n  return {\n    ...(metadata ?? {}),\n    ...(scope.tenantId !== undefined ? { tenantId: scope.tenantId } : {}),\n    ...(scope.userId !== undefined ? { userId: scope.userId } : {}),\n    ...(scope.agentId !== undefined ? { agentId: scope.agentId } : {}),\n  };\n}\n\nfunction checkpointMatchesScope(rawMetadata: unknown, scope: CheckpointScopeArgs): boolean {\n  const metadata = parseCheckpointMetadata(rawMetadata);\n  const matchesScopeField = (field: keyof CheckpointScopeArgs): boolean => {\n    const expected = scope[field];\n    if (expected === undefined) {\n      return true;\n    }\n    const actual = metadata[field];\n    return actual === undefined || actual === expected;\n  };\n\n  return (\n    matchesScopeField('tenantId') &&\n    matchesScopeField('userId') &&\n    matchesScopeField('agentId')\n  );\n}\n\nfunction checkpointScopeDetails(scope: CheckpointScopeArgs): Record<string, string> {\n  const details: Record<string, string> = {};\n  if (scope.tenantId !== undefined) {\n    details.tenantId = scope.tenantId;\n  }\n  if (scope.userId !== undefined) {\n    details.userId = scope.userId;\n  }\n  if (scope.agentId !== undefined) {\n    details.agentId = scope.agentId;\n  }\n  return details;\n}\n\nfunction createCheckpointScopeValidationError(\n  tool: 'checkpoint_create' | 'checkpoint_list' | 'checkpoint_restore' | 'checkpoint_delete',\n): MCPResponse {\n  return createMCPErrorResponse({\n    tool,\n    error: 'tenantId is required when userId or agentId is provided.',\n    code: 'CHECKPOINT_SCOPE_TENANT_REQUIRED',\n    details: {\n      reason: 'checkpoint_scope_tenant_required',\n    },\n    recovery: {\n      hint: 'Retry with tenantId included for governed checkpoint access.',\n    },\n  });\n}\n\nfunction createCheckpointCreateFailureResponse(\n  error: unknown,\n  context: { name: string; specFolder: string | null },\n  startTime: number,\n): MCPResponse {\n  const typedError = error instanceof checkpoints.CheckpointCreateError ? error : null;\n  const code = typedError?.code ?? 'CHECKPOINT_CREATE_FAILED';\n  const message = typedError?.message ?? `Checkpoint creation failed: ${toErrorMessage(error)}`;\n\n  const recoveryByCode: Record<string, { hint: string; actions: string[]; severity: string }> = {\n    CHECKPOINT_CREATE_SQLITE_BUSY: {\n      hint: 'SQLite was busy while creating the checkpoint. Retry after active writes finish.',\n      actions: [\n        'Retry checkpoint_create after concurrent memory writes complete',\n        'For sweep harnesses, prefer specFolder-scoped checkpoints or includeEmbeddings=false when rollback semantics allow',\n        'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n      ],\n      severity: 'medium',\n    },\n    CHECKPOINT_CREATE_SQLITE_LOCKED: {\n      hint: 'SQLite was locked by another operation while creating the checkpoint.',\n      actions: [\n        'Wait for the active lifecycle operation to finish, then retry',\n        'Serialize global checkpoint_create calls in parallel sweep harnesses',\n        'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n      ],\n      severity: 'medium',\n    },\n    CHECKPOINT_CREATE_DUPLICATE_NAME: {\n      hint: 'A checkpoint with this name already exists.',\n      actions: [\n        'Use a unique checkpoint name',\n        'Run checkpoint_list() to inspect existing names',\n        'Delete the existing checkpoint only if rollback policy allows it',\n      ],\n      severity: 'low',\n    },\n    CHECKPOINT_CREATE_PERMISSION_DENIED: {\n      hint: 'The checkpoint database path is not writable.',\n      actions: [\n        'Verify database directory permissions',\n        'Confirm the MCP server has write access to the SQLite database',\n        'Run node dist/cli.js stats to check startup/database access',\n      ],\n      severity: 'high',\n    },\n    CHECKPOINT_CREATE_FAILED: {\n      hint: 'Checkpoint creation failed before a row was persisted.',\n      actions: [\n        'Inspect the underlying error details',\n        'Run memory_health() or node dist/cli.js stats to check database availability',\n        'Run checkpoint_list() to confirm checkpoint state before destructive operations',\n      ],\n      severity: 'medium',\n    },\n  };\n  const recovery = recoveryByCode[code] ?? recoveryByCode.CHECKPOINT_CREATE_FAILED;\n\n  return createMCPErrorResponse({\n    tool: 'checkpoint_create',\n    error: message,\n    code,\n    details: {\n      name: context.name,\n      specFolder: context.specFolder,\n      ...(typedError?.originalCode ? { underlyingCode: typedError.originalCode } : {}),\n      ...(typedError?.details ? { storage: typedError.details } : {}),\n    },\n    recovery,\n    startTime,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CHECKPOINT CREATE HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle checkpoint_create tool — snapshots the current memory state for rollback.\n * @param args - Checkpoint creation arguments (name, note)\n * @returns MCP response with checkpoint metadata\n */\nasync function handleCheckpointCreate(args: CheckpointCreateArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:checkpoint_create');\n  const startTime = Date.now();\n  await checkDatabaseUpdated();\n  const { name, specFolder: spec_folder, metadata } = args;\n  const scope = validateCheckpointScope(args);\n  if (requiresCheckpointTenant(scope)) {\n    return createCheckpointScopeValidationError('checkpoint_create');\n  }\n\n  if (!name || typeof name !== 'string') {\n    throw new Error('name is required and must be a string');\n  }\n\n  if (spec_folder !== undefined && typeof spec_folder !== 'string') {\n    throw new Error('specFolder must be a string');\n  }\n\n  // Global embedding-inclusive checkpoints are expensive serialized lifecycle\n  // operations. Parallel sweep harnesses should prefer specFolder-scoped\n  // checkpoints or includeEmbeddings=false when rollback semantics allow it.\n  let result: checkpoints.CheckpointInfo | null;\n  try {\n    result = checkpoints.createCheckpoint({\n      name,\n      specFolder: spec_folder,\n      ...(args.includeEmbeddings !== undefined ? { includeEmbeddings: args.includeEmbeddings } : {}),\n      metadata: mergeCheckpointScopeMetadata(metadata, scope),\n      scope,\n    });\n  } catch (error: unknown) {\n    return createCheckpointCreateFailureResponse(\n      error,\n      { name, specFolder: spec_folder ?? null },\n      startTime,\n    );\n  }\n\n  if (!result) {\n    return createMCPErrorResponse({\n      tool: 'checkpoint_create',\n      error: 'Checkpoint creation failed',\n      code: 'CHECKPOINT_CREATE_FAILED',\n      details: {\n        name,\n        specFolder: spec_folder ?? null,\n      },\n      recovery: {\n        hint: 'Verify database availability and retry checkpoint_create.',\n        actions: ['Run checkpoint_list() to confirm checkpoint state before destructive operations'],\n      },\n      startTime,\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'checkpoint_create',\n    summary: `Checkpoint \"${name}\" created successfully`,\n    data: {\n      success: true,\n      checkpoint: result\n    },\n    hints: [\n      `Restore with: checkpoint_restore({ name: \"${name}\" })`,\n      `Delete with: checkpoint_delete({ name: \"${name}\", confirmName: \"${name}\" })`\n    ],\n    startTime: startTime\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. CHECKPOINT LIST HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle checkpoint_list tool - returns available checkpoints filtered by spec folder */\nasync function handleCheckpointList(args: CheckpointListArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:checkpoint_list');\n  const startTime = Date.now();\n  await checkDatabaseUpdated();\n  const { specFolder: spec_folder, limit: raw_limit = 50 } = args;\n  const scope = validateCheckpointScope(args);\n  if (requiresCheckpointTenant(scope)) {\n    return createCheckpointScopeValidationError('checkpoint_list');\n  }\n\n  if (spec_folder !== undefined && typeof spec_folder !== 'string') {\n    throw new Error('specFolder must be a string');\n  }\n\n  const limit = (typeof raw_limit === 'number' && Number.isFinite(raw_limit) && raw_limit > 0)\n    ? Math.min(Math.floor(raw_limit), 100)\n    : 50;\n\n  const results = checkpoints.listCheckpoints(spec_folder ?? null, limit, scope);\n  const filteredResults = hasCheckpointScope(scope)\n    ? results.filter((checkpoint) => checkpointMatchesScope(checkpoint.metadata, scope))\n    : results;\n\n  const summary = filteredResults.length > 0\n    ? `Found ${filteredResults.length} checkpoint(s)`\n    : 'No checkpoints found';\n\n  return createMCPSuccessResponse({\n    tool: 'checkpoint_list',\n    summary,\n    data: {\n      count: filteredResults.length,\n      checkpoints: filteredResults\n    },\n    hints: filteredResults.length === 0\n      ? ['Create a checkpoint with checkpoint_create({ name: \"my-checkpoint\" })']\n      : [],\n    startTime: startTime\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. CHECKPOINT RESTORE HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle checkpoint_restore tool - restores memory state from a named checkpoint */\nasync function handleCheckpointRestore(args: CheckpointRestoreArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:checkpoint_restore');\n  const startTime = Date.now();\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'checkpoint_restore',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        name: args.name ?? null,\n      },\n      recovery: {\n        hint: 'Retry checkpoint_restore after the active restore maintenance window completes.',\n        actions: ['Wait for the current restore to finish', 'Retry the restore request'],\n        severity: 'warning',\n      },\n      startTime,\n    });\n  }\n\n  await checkDatabaseUpdated();\n  const { name, clearExisting: clear_existing = false } = args;\n  const scope = validateCheckpointScope(args);\n  if (requiresCheckpointTenant(scope)) {\n    return createCheckpointScopeValidationError('checkpoint_restore');\n  }\n\n  if (!name || typeof name !== 'string') {\n    throw new Error('name is required and must be a string');\n  }\n\n  if (hasCheckpointScope(scope)) {\n    const checkpoint = checkpoints.getCheckpoint(name, scope);\n    if (checkpoint && !checkpointMatchesScope(checkpoint.metadata, scope)) {\n      return createMCPErrorResponse({\n        tool: 'checkpoint_restore',\n        error: `Checkpoint \"${name}\" scope mismatch`,\n        code: 'CHECKPOINT_SCOPE_MISMATCH',\n        details: {\n          name,\n          scope: checkpointScopeDetails(scope),\n        },\n        recovery: {\n          hint: 'Retry with matching scope values or omit optional scope parameters if you intend to access an unscoped checkpoint.',\n          actions: ['Use checkpoint_list() with the same scope parameters to discover accessible checkpoints'],\n        },\n        startTime,\n      });\n    }\n  }\n\n  const result = checkpoints.restoreCheckpoint(name, clear_existing, scope);\n  const hasRestoreErrors = result.errors.length > 0;\n  const hasRestoredData = result.restored > 0 || result.workingMemoryRestored > 0;\n  const hasPartialFailure = result.partialFailure === true;\n  const hasPartialSuccess = !hasPartialFailure && (result.skipped > 0 || hasRestoreErrors);\n\n  // Rebuild search indexes after checkpoint restore — without this, restored\n  // memories are invisible to search until server restart. The BM25 rebuild\n  // uses the same engine-routing gate as boot warmup: when FTS5 serves lexical\n  // search (or BM25 is disabled), restore must not warm an in-memory index the\n  // runtime would never query.\n  if (result.restored > 0 || result.workingMemoryRestored > 0) {\n    try {\n      vectorIndex.clearConstitutionalCache(null);\n      vectorIndex.clearSearchCache(null);\n\n      const database = vectorIndex.getDb();\n      if (database && bm25Index.shouldWarmInMemoryBm25(database)) {\n        bm25Index.getIndex().rebuildFromDatabase(database);\n      }\n\n      triggerMatcher.refreshTriggerCache();\n    } catch (rebuildErr: unknown) {\n      // Index rebuild failure is non-fatal — indexes will self-heal on next query or restart\n      console.error('[T102] Index rebuild after checkpoint restore failed:', toErrorMessage(rebuildErr));\n    }\n  }\n\n  if (hasRestoreErrors && !hasRestoredData) {\n    return createMCPErrorResponse({\n      tool: 'checkpoint_restore',\n      error: `Checkpoint \"${name}\" restore failed`,\n      code: 'CHECKPOINT_RESTORE_FAILED',\n      details: {\n        name,\n        clearExisting: clear_existing,\n        restored: result.restored,\n        workingMemoryRestored: result.workingMemoryRestored,\n        errors: result.errors,\n      },\n      recovery: {\n        hint: 'Use checkpoint_list() to confirm checkpoint name and retry.',\n        actions: ['Inspect checkpoint integrity', 'Create a fresh checkpoint before retrying restore'],\n      },\n      startTime,\n    });\n  }\n\n  if (hasPartialFailure && hasRestoredData) {\n    return createMCPErrorResponse({\n      tool: 'checkpoint_restore',\n      error: `Checkpoint \"${name}\" restore completed with partial failure`,\n      code: 'CHECKPOINT_RESTORE_PARTIAL_FAILURE',\n      details: {\n        name,\n        clearExisting: clear_existing,\n        restored: result.restored,\n        skipped: result.skipped,\n        workingMemoryRestored: result.workingMemoryRestored,\n        rolledBackTables: result.rolledBackTables ?? [],\n        errors: result.errors,\n      },\n      recovery: {\n        hint: 'Review the reported table failures before retrying restore.',\n        actions: [\n          'Inspect restored.errors and restored.rolledBackTables for the failed merge-replace tables',\n          'Retry with a narrower scope or clearExisting=true if you intend to replace current state',\n        ],\n      },\n      startTime,\n    });\n  }\n\n  if (hasPartialSuccess) {\n    return createMCPSuccessResponse({\n      tool: 'checkpoint_restore',\n      summary: result.errors.length > 0\n        ? `Checkpoint \"${name}\" restored with warnings (${result.errors.length})`\n        : `Checkpoint \"${name}\" restored partially`,\n      data: {\n        success: true,\n        partial: true,\n        warningCount: result.errors.length,\n        restored: result,\n      },\n      hints: [\n        'Restore applied partially; review restored.errors and restored.skipped before retrying',\n        'Avoid immediate retry with clearExisting=true unless you intend to replace current state',\n      ],\n      startTime,\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'checkpoint_restore',\n    summary: `Checkpoint \"${name}\" restored successfully`,\n    data: {\n      success: true,\n      restored: result\n    },\n    hints: clear_existing\n      ? ['Previous data was cleared before restore', 'Search indexes rebuilt']\n      : ['Restore merged with existing data - duplicates may exist', 'Search indexes rebuilt'],\n    startTime: startTime\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. CHECKPOINT DELETE HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle checkpoint_delete tool - permanently removes a named checkpoint */\nasync function handleCheckpointDelete(args: CheckpointDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:checkpoint_delete');\n  const startTime = Date.now();\n  await checkDatabaseUpdated();\n  const { name, confirmName } = args;\n  const scope = validateCheckpointScope(args);\n  if (requiresCheckpointTenant(scope)) {\n    return createCheckpointScopeValidationError('checkpoint_delete');\n  }\n\n  if (!name || typeof name !== 'string') {\n    throw new Error('name is required and must be a string');\n  }\n  if (!confirmName || typeof confirmName !== 'string') {\n    throw new Error('confirmName is required and must be a string');\n  }\n  if (confirmName !== name) {\n    throw new Error('confirmName must exactly match name to delete checkpoint');\n  }\n\n  if (hasCheckpointScope(scope)) {\n    const checkpoint = checkpoints.getCheckpoint(name, scope);\n    if (checkpoint && !checkpointMatchesScope(checkpoint.metadata, scope)) {\n      return createMCPErrorResponse({\n        tool: 'checkpoint_delete',\n        error: `Checkpoint \"${name}\" scope mismatch`,\n        code: 'CHECKPOINT_SCOPE_MISMATCH',\n        details: {\n          name,\n          scope: checkpointScopeDetails(scope),","lineStart":180,"lineEnd":699,"totalLines":918,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","time":{"start":1781761628787,"end":1781761628791}},"metadata":{"openai":{"itemId":"fc_0de400dc031cc386016a33865c54008191b45a34373a9b7a66"}},"id":"prt_ed944d8ad001NMdTmPE10eGBNu","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed944c49a001QcHoDTeAqImhrQ"}}
