{"type":"tool_use","timestamp":1783487874222,"sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","part":{"type":"tool","tool":"read","callID":"call_SLD575i6vFdUBSvkPw0eiGA5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Deep-Loop Fallback Router\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: // ───────────────────────────────────────────────────────────────────\n6: // 1. TYPE DEFINITIONS\n7: // ───────────────────────────────────────────────────────────────────\n8: \n9: export type FallbackAction = 'fallback' | 'fail-fast';\n10: \n11: /** Executor result category used by typed fallback route selection. */\n12: export type FallbackRouteOutcome = 'success' | 'failure';\n13: \n14: /** Failure classes that can select a targeted fallback route. */\n15: export type FallbackFailureKind =\n16:   | 'timeout'\n17:   | 'auth-failure'\n18:   | 'quota-exceeded'\n19:   | 'executor-error'\n20:   | (string & {});\n21: \n22: /** Per-failure target map for typed fallback routes. */\n23: export interface FallbackFailureTargets {\n24:   readonly default?: string;\n25:   readonly [failureKind: string]: string | undefined;\n26: }\n27: \n28: /** Fallback decision returned to dispatch callers. */\n29: export type FallbackRoute = {\n30:   readonly action: FallbackAction;\n31:   readonly target?: string;\n32:   readonly reason: string;\n33:   readonly failureKind?: FallbackFailureKind;\n34:   readonly routeGroupId?: string;\n35:   readonly hopIndex?: number;\n36: };\n37: \n38: /** Runtime context attached to a routed fallback decision. */\n39: export interface FallbackRouteContext {\n40:   readonly outcome?: FallbackRouteOutcome;\n41:   readonly failureKind?: FallbackFailureKind;\n42:   readonly routeGroupId?: string;\n43:   readonly hopIndex?: number;\n44: }\n45: \n46: /** Model routing profile used by fallback graph resolution. */\n47: export type ModelProfile = {\n48:   readonly id: string;\n49:   readonly quota_pool: string;\n50:   readonly fallback_target: string | null;\n51:   readonly failureKind?: FallbackFailureKind;\n52:   readonly onSuccessTarget?: string | null;\n53:   readonly onFailureTarget?: string | FallbackFailureTargets | null;\n54:   readonly routeScope?: string;\n55: };\n56: \n57: /** Registry of model profiles available to the fallback router. */\n58: export type ModelRegistry = {\n59:   readonly models: readonly ModelProfile[];\n60: };\n61: \n62: /** Configuration for validating fallback graph edges before dispatch. */\n63: export interface FallbackGraphValidationOptions {\n64:   readonly maxHops?: number;\n65: }\n66: \n67: /** Validated router that binds a registry after graph preflight. */\n68: export interface FallbackRouter {\n69:   resolve(\n70:     failedModelId: string,\n71:     approvedModelIds?: readonly string[],\n72:     context?: FallbackRouteContext,\n73:   ): FallbackRoute;\n74: }\n75: \n76: type TargetKind = 'legacy' | 'success' | 'failure';\n77: \n78: interface TargetSelection {\n79:   readonly target: string | null;\n80:   readonly kind: TargetKind;\n81:   readonly failureKind?: FallbackFailureKind;\n82: }\n83: \n84: interface FallbackEdge {\n85:   readonly source: ModelProfile;\n86:   readonly targetId: string;\n87:   readonly kind: TargetKind;\n88:   readonly failureKind?: string;\n89: }\n90: \n91: const DEFAULT_MAX_HOPS = 1;\n92: \n93: // ───────────────────────────────────────────────────────────────────\n94: // 2. HELPERS\n95: // ───────────────────────────────────────────────────────────────────\n96: \n97: function findModel(registry: ModelRegistry, modelId: string): ModelProfile | undefined {\n98:   return registry.models.find((model) => model.id === modelId);\n99: }\n100: \n101: function isFailureTargets(\n102:   value: string | FallbackFailureTargets | null | undefined,\n103: ): value is FallbackFailureTargets {\n104:   return typeof value === 'object' && value !== null;\n105: }\n106: \n107: function selectFailureTarget(\n108:   failedModel: ModelProfile,\n109:   failureKind: FallbackFailureKind | undefined,\n110: ): TargetSelection {\n111:   const configuredTarget = failedModel.onFailureTarget;\n112:   const effectiveFailureKind = failureKind ?? failedModel.failureKind;\n113: \n114:   if (typeof configuredTarget === 'string') {\n115:     return { target: configuredTarget, kind: 'failure', failureKind: effectiveFailureKind };\n116:   }\n117: \n118:   if (isFailureTargets(configuredTarget)) {\n119:     const mappedTarget =\n120:       effectiveFailureKind === undefined\n121:         ? configuredTarget.default ?? null\n122:         : configuredTarget[effectiveFailureKind] ?? configuredTarget.default ?? null;\n123: \n124:     return {\n125:       target: mappedTarget,\n126:       kind: 'failure',\n127:       failureKind: effectiveFailureKind,\n128:     };\n129:   }\n130: \n131:   return {\n132:     target: failedModel.fallback_target,\n133:     kind: 'legacy',\n134:     failureKind: effectiveFailureKind,\n135:   };\n136: }\n137: \n138: function selectTarget(failedModel: ModelProfile, context: FallbackRouteContext | undefined): TargetSelection {\n139:   if (context?.outcome === 'success' && failedModel.onSuccessTarget !== undefined) {\n140:     return {\n141:       target: failedModel.onSuccessTarget,\n142:       kind: 'success',\n143:       failureKind: context.failureKind ?? failedModel.failureKind,\n144:     };\n145:   }\n146: \n147:   return selectFailureTarget(failedModel, context?.failureKind);\n148: }\n149: \n150: function createTrace(\n151:   failedModelId: string,\n152:   context: FallbackRouteContext | undefined,\n153: ): Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined {\n154:   if (context === undefined) return undefined;\n155: \n156:   return {\n157:     routeGroupId: context.routeGroupId ?? `${failedModelId}:${context.failureKind ?? context.outcome ?? 'fallback'}`,\n158:     hopIndex: context.hopIndex ?? 0,\n159:   };\n160: }\n161: \n162: function withRouteMetadata(\n163:   route: FallbackRoute,\n164:   trace: Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined,\n165:   failureKind: FallbackFailureKind | undefined,\n166: ): FallbackRoute {\n167:   if (trace === undefined && failureKind === undefined) return route;\n168: \n169:   return {\n170:     ...route,\n171:     ...(failureKind === undefined ? {} : { failureKind }),\n172:     ...trace,\n173:   };\n174: }\n175: \n176: function describeTargetKind(selection: TargetSelection): string {\n177:   if (selection.kind === 'success') return 'success target';\n178:   if (selection.kind === 'failure') return 'failure target';\n179:   return 'fallback';\n180: }\n181: \n182: function collectTargets(profile: ModelProfile): readonly FallbackEdge[] {\n183:   const edges: FallbackEdge[] = [];\n184: \n185:   if (profile.fallback_target !== null) {\n186:     edges.push({ source: profile, targetId: profile.fallback_target, kind: 'legacy' });\n187:   }\n188: \n189:   if (profile.onSuccessTarget !== undefined && profile.onSuccessTarget !== null) {\n190:     edges.push({ source: profile, targetId: profile.onSuccessTarget, kind: 'success' });\n191:   }\n192: \n193:   if (typeof profile.onFailureTarget === 'string') {\n194:     edges.push({\n195:       source: profile,\n196:       targetId: profile.onFailureTarget,\n197:       kind: 'failure',\n198:       failureKind: profile.failureKind,\n199:     });\n200:   } else if (isFailureTargets(profile.onFailureTarget)) {\n201:     for (const [failureKind, targetId] of Object.entries(profile.onFailureTarget)) {\n202:       if (targetId !== undefined) {\n203:         edges.push({ source: profile, targetId, kind: 'failure', failureKind });\n204:       }\n205:     }\n206:   }\n207: \n208:   return edges;\n209: }\n210: \n211: function buildEdges(registry: ModelRegistry): readonly FallbackEdge[] {\n212:   return registry.models.flatMap((profile) => collectTargets(profile));\n213: }\n214: \n215: function assertKnownTargets(registry: ModelRegistry, edges: readonly FallbackEdge[]): void {\n216:   for (const edge of edges) {\n217:     if (findModel(registry, edge.targetId) === undefined) {\n218:       throw new Error(`fallback graph references missing ${edge.kind} target ${edge.targetId} from ${edge.source.id}`);\n219:     }\n220:   }\n221: }\n222: \n223: function assertScopesDoNotWiden(registry: ModelRegistry, edges: readonly FallbackEdge[]): void {\n224:   for (const edge of edges) {\n225:     const target = findModel(registry, edge.targetId);\n226:     if (target === undefined) continue;\n227: \n228:     const hasScopedEdge = edge.source.routeScope !== undefined || target.routeScope !== undefined;\n229:     if (hasScopedEdge && edge.source.routeScope !== target.routeScope) {\n230:       throw new Error(`fallback graph cross-scope route rejected from ${edge.source.id} to ${target.id}`);\n231:     }\n232:   }\n233: }\n234: \n235: function assertNoCycles(edges: readonly FallbackEdge[]): void {\n236:   const adjacency = new Map<string, readonly string[]>();\n237:   for (const edge of edges) {\n238:     adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n239:   }\n240: \n241:   const visiting = new Set<string>();\n242:   const visited = new Set<string>();\n243: \n244:   function visit(modelId: string, path: readonly string[]): void {\n245:     if (visiting.has(modelId)) {\n246:       throw new Error(`fallback graph cycle detected: ${[...path, modelId].join(' -> ')}`);\n247:     }\n248: \n249:     if (visited.has(modelId)) return;\n250: \n251:     visiting.add(modelId);\n252:     for (const targetId of adjacency.get(modelId) ?? []) {\n253:       visit(targetId, [...path, modelId]);\n254:     }\n255:     visiting.delete(modelId);\n256:     visited.add(modelId);\n257:   }\n258: \n259:   for (const sourceId of adjacency.keys()) {\n260:     visit(sourceId, []);\n\n(Showing lines 1-260 of 431. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Fallback Router\n// ───────────────────────────────────────────────────────────────────\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport type FallbackAction = 'fallback' | 'fail-fast';\n\n/** Executor result category used by typed fallback route selection. */\nexport type FallbackRouteOutcome = 'success' | 'failure';\n\n/** Failure classes that can select a targeted fallback route. */\nexport type FallbackFailureKind =\n  | 'timeout'\n  | 'auth-failure'\n  | 'quota-exceeded'\n  | 'executor-error'\n  | (string & {});","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Fallback Router\n// ───────────────────────────────────────────────────────────────────\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport type FallbackAction = 'fallback' | 'fail-fast';\n\n/** Executor result category used by typed fallback route selection. */\nexport type FallbackRouteOutcome = 'success' | 'failure';\n\n/** Failure classes that can select a targeted fallback route. */\nexport type FallbackFailureKind =\n  | 'timeout'\n  | 'auth-failure'\n  | 'quota-exceeded'\n  | 'executor-error'\n  | (string & {});\n\n/** Per-failure target map for typed fallback routes. */\nexport interface FallbackFailureTargets {\n  readonly default?: string;\n  readonly [failureKind: string]: string | undefined;\n}\n\n/** Fallback decision returned to dispatch callers. */\nexport type FallbackRoute = {\n  readonly action: FallbackAction;\n  readonly target?: string;\n  readonly reason: string;\n  readonly failureKind?: FallbackFailureKind;\n  readonly routeGroupId?: string;\n  readonly hopIndex?: number;\n};\n\n/** Runtime context attached to a routed fallback decision. */\nexport interface FallbackRouteContext {\n  readonly outcome?: FallbackRouteOutcome;\n  readonly failureKind?: FallbackFailureKind;\n  readonly routeGroupId?: string;\n  readonly hopIndex?: number;\n}\n\n/** Model routing profile used by fallback graph resolution. */\nexport type ModelProfile = {\n  readonly id: string;\n  readonly quota_pool: string;\n  readonly fallback_target: string | null;\n  readonly failureKind?: FallbackFailureKind;\n  readonly onSuccessTarget?: string | null;\n  readonly onFailureTarget?: string | FallbackFailureTargets | null;\n  readonly routeScope?: string;\n};\n\n/** Registry of model profiles available to the fallback router. */\nexport type ModelRegistry = {\n  readonly models: readonly ModelProfile[];\n};\n\n/** Configuration for validating fallback graph edges before dispatch. */\nexport interface FallbackGraphValidationOptions {\n  readonly maxHops?: number;\n}\n\n/** Validated router that binds a registry after graph preflight. */\nexport interface FallbackRouter {\n  resolve(\n    failedModelId: string,\n    approvedModelIds?: readonly string[],\n    context?: FallbackRouteContext,\n  ): FallbackRoute;\n}\n\ntype TargetKind = 'legacy' | 'success' | 'failure';\n\ninterface TargetSelection {\n  readonly target: string | null;\n  readonly kind: TargetKind;\n  readonly failureKind?: FallbackFailureKind;\n}\n\ninterface FallbackEdge {\n  readonly source: ModelProfile;\n  readonly targetId: string;\n  readonly kind: TargetKind;\n  readonly failureKind?: string;\n}\n\nconst DEFAULT_MAX_HOPS = 1;\n\n// ───────────────────────────────────────────────────────────────────\n// 2. HELPERS\n// ───────────────────────────────────────────────────────────────────\n\nfunction findModel(registry: ModelRegistry, modelId: string): ModelProfile | undefined {\n  return registry.models.find((model) => model.id === modelId);\n}\n\nfunction isFailureTargets(\n  value: string | FallbackFailureTargets | null | undefined,\n): value is FallbackFailureTargets {\n  return typeof value === 'object' && value !== null;\n}\n\nfunction selectFailureTarget(\n  failedModel: ModelProfile,\n  failureKind: FallbackFailureKind | undefined,\n): TargetSelection {\n  const configuredTarget = failedModel.onFailureTarget;\n  const effectiveFailureKind = failureKind ?? failedModel.failureKind;\n\n  if (typeof configuredTarget === 'string') {\n    return { target: configuredTarget, kind: 'failure', failureKind: effectiveFailureKind };\n  }\n\n  if (isFailureTargets(configuredTarget)) {\n    const mappedTarget =\n      effectiveFailureKind === undefined\n        ? configuredTarget.default ?? null\n        : configuredTarget[effectiveFailureKind] ?? configuredTarget.default ?? null;\n\n    return {\n      target: mappedTarget,\n      kind: 'failure',\n      failureKind: effectiveFailureKind,\n    };\n  }\n\n  return {\n    target: failedModel.fallback_target,\n    kind: 'legacy',\n    failureKind: effectiveFailureKind,\n  };\n}\n\nfunction selectTarget(failedModel: ModelProfile, context: FallbackRouteContext | undefined): TargetSelection {\n  if (context?.outcome === 'success' && failedModel.onSuccessTarget !== undefined) {\n    return {\n      target: failedModel.onSuccessTarget,\n      kind: 'success',\n      failureKind: context.failureKind ?? failedModel.failureKind,\n    };\n  }\n\n  return selectFailureTarget(failedModel, context?.failureKind);\n}\n\nfunction createTrace(\n  failedModelId: string,\n  context: FallbackRouteContext | undefined,\n): Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined {\n  if (context === undefined) return undefined;\n\n  return {\n    routeGroupId: context.routeGroupId ?? `${failedModelId}:${context.failureKind ?? context.outcome ?? 'fallback'}`,\n    hopIndex: context.hopIndex ?? 0,\n  };\n}\n\nfunction withRouteMetadata(\n  route: FallbackRoute,\n  trace: Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined,\n  failureKind: FallbackFailureKind | undefined,\n): FallbackRoute {\n  if (trace === undefined && failureKind === undefined) return route;\n\n  return {\n    ...route,\n    ...(failureKind === undefined ? {} : { failureKind }),\n    ...trace,\n  };\n}\n\nfunction describeTargetKind(selection: TargetSelection): string {\n  if (selection.kind === 'success') return 'success target';\n  if (selection.kind === 'failure') return 'failure target';\n  return 'fallback';\n}\n\nfunction collectTargets(profile: ModelProfile): readonly FallbackEdge[] {\n  const edges: FallbackEdge[] = [];\n\n  if (profile.fallback_target !== null) {\n    edges.push({ source: profile, targetId: profile.fallback_target, kind: 'legacy' });\n  }\n\n  if (profile.onSuccessTarget !== undefined && profile.onSuccessTarget !== null) {\n    edges.push({ source: profile, targetId: profile.onSuccessTarget, kind: 'success' });\n  }\n\n  if (typeof profile.onFailureTarget === 'string') {\n    edges.push({\n      source: profile,\n      targetId: profile.onFailureTarget,\n      kind: 'failure',\n      failureKind: profile.failureKind,\n    });\n  } else if (isFailureTargets(profile.onFailureTarget)) {\n    for (const [failureKind, targetId] of Object.entries(profile.onFailureTarget)) {\n      if (targetId !== undefined) {\n        edges.push({ source: profile, targetId, kind: 'failure', failureKind });\n      }\n    }\n  }\n\n  return edges;\n}\n\nfunction buildEdges(registry: ModelRegistry): readonly FallbackEdge[] {\n  return registry.models.flatMap((profile) => collectTargets(profile));\n}\n\nfunction assertKnownTargets(registry: ModelRegistry, edges: readonly FallbackEdge[]): void {\n  for (const edge of edges) {\n    if (findModel(registry, edge.targetId) === undefined) {\n      throw new Error(`fallback graph references missing ${edge.kind} target ${edge.targetId} from ${edge.source.id}`);\n    }\n  }\n}\n\nfunction assertScopesDoNotWiden(registry: ModelRegistry, edges: readonly FallbackEdge[]): void {\n  for (const edge of edges) {\n    const target = findModel(registry, edge.targetId);\n    if (target === undefined) continue;\n\n    const hasScopedEdge = edge.source.routeScope !== undefined || target.routeScope !== undefined;\n    if (hasScopedEdge && edge.source.routeScope !== target.routeScope) {\n      throw new Error(`fallback graph cross-scope route rejected from ${edge.source.id} to ${target.id}`);\n    }\n  }\n}\n\nfunction assertNoCycles(edges: readonly FallbackEdge[]): void {\n  const adjacency = new Map<string, readonly string[]>();\n  for (const edge of edges) {\n    adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n  }\n\n  const visiting = new Set<string>();\n  const visited = new Set<string>();\n\n  function visit(modelId: string, path: readonly string[]): void {\n    if (visiting.has(modelId)) {\n      throw new Error(`fallback graph cycle detected: ${[...path, modelId].join(' -> ')}`);\n    }\n\n    if (visited.has(modelId)) return;\n\n    visiting.add(modelId);\n    for (const targetId of adjacency.get(modelId) ?? []) {\n      visit(targetId, [...path, modelId]);\n    }\n    visiting.delete(modelId);\n    visited.add(modelId);\n  }\n\n  for (const sourceId of adjacency.keys()) {\n    visit(sourceId, []);","lineStart":1,"lineEnd":260,"totalLines":431,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","time":{"start":1783487874211,"end":1783487874218}},"metadata":{"openai":{"itemId":"fc_0107759b0c9b86e6016a4ddd81fc508191aa78f01cb237f635"}},"id":"prt_f40294479001DTWjJf2O4ZjZym","sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","messageID":"msg_f402913d3001nywLNRbhgdQWS4"}}
{"type":"tool_use","timestamp":1783487874386,"sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","part":{"type":"tool","tool":"read","callID":"call_2COusUqk1iv6kWwqyeFCN1Vv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","offset":261,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts</path>\n<type>file</type>\n<content>\n261:   }\n262: }\n263: \n264: function assertMaxHops(edges: readonly FallbackEdge[], maxHops: number): void {\n265:   const adjacency = new Map<string, readonly string[]>();\n266:   for (const edge of edges) {\n267:     adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n268:   }\n269: \n270:   function walk(sourceId: string, hopCount: number): void {\n271:     if (hopCount > maxHops) {\n272:       throw new Error(`fallback graph max-hop violation from ${sourceId}; allowed ${maxHops} hops`);\n273:     }\n274: \n275:     for (const targetId of adjacency.get(sourceId) ?? []) {\n276:       walk(targetId, hopCount + 1);\n277:     }\n278:   }\n279: \n280:   for (const sourceId of adjacency.keys()) {\n281:     walk(sourceId, 0);\n282:   }\n283: }\n284: \n285: // ───────────────────────────────────────────────────────────────────\n286: // 3. CORE LOGIC\n287: // ───────────────────────────────────────────────────────────────────\n288: \n289: /**\n290:  * Validate fallback graph edges before any dispatch uses them.\n291:  *\n292:  * Checks missing targets, cycles, cross-scope edges, and configured hop limits\n293:  * without mutating the registry.\n294:  *\n295:  * @param registry - The model registry with fallback configurations.\n296:  * @param options - Validation limits for graph traversal.\n297:  * @throws Error when the fallback graph is unsafe to dispatch.\n298:  */\n299: export function validateFallbackGraph(\n300:   registry: ModelRegistry,\n301:   options: FallbackGraphValidationOptions = {},\n302: ): void {\n303:   const edges = buildEdges(registry);\n304:   const maxHops = options.maxHops ?? DEFAULT_MAX_HOPS;\n305: \n306:   assertKnownTargets(registry, edges);\n307:   assertScopesDoNotWiden(registry, edges);\n308:   assertNoCycles(edges);\n309:   assertMaxHops(edges, maxHops);\n310: }\n311: \n312: /**\n313:  * Create a router after validating configured fallback edges.\n314:  *\n315:  * @param registry - The model registry with fallback configurations.\n316:  * @param options - Validation limits for graph traversal.\n317:  * @returns A router bound to the validated registry.\n318:  * @throws Error when the fallback graph is unsafe to dispatch.\n319:  */\n320: export function createFallbackRouter(\n321:   registry: ModelRegistry,\n322:   options: FallbackGraphValidationOptions = {},\n323: ): FallbackRouter {\n324:   validateFallbackGraph(registry, options);\n325: \n326:   return {\n327:     resolve(\n328:       failedModelId: string,\n329:       approvedModelIds?: readonly string[],\n330:       context?: FallbackRouteContext,\n331:     ): FallbackRoute {\n332:       return resolveFallback(failedModelId, registry, approvedModelIds, context);\n333:     },\n334:   };\n335: }\n336: \n337: /**\n338:  * Resolve the fallback route when a model exhausts its quota pool.\n339:  *\n340:  * Checks whether the failed model has a configured fallback target in a\n341:  * different quota pool and returns the appropriate route.\n342:  *\n343:  * The optional approval set closes the substitution gap: routing only ever\n344:  * resolves to a model the caller approved. The configured `fallback_target` is\n345:  * the approved route by definition, so the guard rejects only a target the\n346:  * caller never sanctioned, and never the legitimate cross-pool fallback. When\n347:  * the set is omitted, the configured target is treated as approved (existing\n348:  * behavior), so this is additive.\n349:  *\n350:  * @param failedModelId - The model ID that failed.\n351:  * @param registry - The model registry with fallback configurations.\n352:  * @param approvedModelIds - Optional set of model IDs the caller approved; when\n353:  *   provided, a target outside the set returns fail-fast instead of routing.\n354:  * @param context - Optional typed route context for failure kind and trace data.\n355:  * @returns A route indicating whether to fallback or fail-fast, with a reason.\n356:  */\n357: export function resolveFallback(\n358:   failedModelId: string,\n359:   registry: ModelRegistry,\n360:   approvedModelIds?: readonly string[],\n361:   context?: FallbackRouteContext,\n362: ): FallbackRoute {\n363:   const trace = createTrace(failedModelId, context);\n364:   const failedModel = findModel(registry, failedModelId);\n365:   if (failedModel === undefined) {\n366:     return withRouteMetadata(\n367:       {\n368:         action: 'fail-fast',\n369:         reason: `unknown model ${failedModelId}; no quota pool available for fallback routing`,\n370:       },\n371:       trace,\n372:       context?.failureKind,\n373:     );\n374:   }\n375: \n376:   const selection = selectTarget(failedModel, context);\n377:   if (selection.target === null) {\n378:     return withRouteMetadata(\n379:       {\n380:         action: 'fail-fast',\n381:         reason: `${failedModel.quota_pool} pool exhausted, no separate-pool fallback configured for ${failedModel.id}`,\n382:       },\n383:       trace,\n384:       selection.failureKind,\n385:     );\n386:   }\n387: \n388:   const targetModel = findModel(registry, selection.target);\n389:   if (targetModel === undefined) {\n390:     return withRouteMetadata(\n391:       {\n392:         action: 'fail-fast',\n393:         reason: `${failedModel.quota_pool} pool exhausted, configured ${describeTargetKind(selection)} ${selection.target} is not in the registry`,\n394:       },\n395:       trace,\n396:       selection.failureKind,\n397:     );\n398:   }\n399: \n400:   if (targetModel.quota_pool === failedModel.quota_pool) {\n401:     return withRouteMetadata(\n402:       {\n403:         action: 'fail-fast',\n404:         reason: `${failedModel.quota_pool} pool exhausted, fallback target ${targetModel.id} shares the same pool; same-pool fallback rejected`,\n405:       },\n406:       trace,\n407:       selection.failureKind,\n408:     );\n409:   }\n410: \n411:   if (approvedModelIds !== undefined && !approvedModelIds.includes(targetModel.id)) {\n412:     return withRouteMetadata(\n413:       {\n414:         action: 'fail-fast',\n415:         reason: `${failedModel.quota_pool} pool exhausted, fallback target ${targetModel.id} is not in the caller-approved model set; unapproved substitution rejected`,\n416:       },\n417:       trace,\n418:       selection.failureKind,\n419:     );\n420:   }\n421: \n422:   return withRouteMetadata(\n423:     {\n424:       action: 'fallback',\n425:       target: targetModel.id,\n426:       reason: `${failedModel.quota_pool} pool exhausted, routing ${failedModel.id} to separate ${targetModel.quota_pool} pool target ${targetModel.id}`,\n427:     },\n428:     trace,\n429:     selection.failureKind,\n430:   );\n431: }\n\n(End of file - total 431 lines)\n</content>","metadata":{"preview":"  }\n}\n\nfunction assertMaxHops(edges: readonly FallbackEdge[], maxHops: number): void {\n  const adjacency = new Map<string, readonly string[]>();\n  for (const edge of edges) {\n    adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n  }\n\n  function walk(sourceId: string, hopCount: number): void {\n    if (hopCount > maxHops) {\n      throw new Error(`fallback graph max-hop violation from ${sourceId}; allowed ${maxHops} hops`);\n    }\n\n    for (const targetId of adjacency.get(sourceId) ?? []) {\n      walk(targetId, hopCount + 1);\n    }\n  }\n\n  for (const sourceId of adjacency.keys()) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","text":"  }\n}\n\nfunction assertMaxHops(edges: readonly FallbackEdge[], maxHops: number): void {\n  const adjacency = new Map<string, readonly string[]>();\n  for (const edge of edges) {\n    adjacency.set(edge.source.id, [...(adjacency.get(edge.source.id) ?? []), edge.targetId]);\n  }\n\n  function walk(sourceId: string, hopCount: number): void {\n    if (hopCount > maxHops) {\n      throw new Error(`fallback graph max-hop violation from ${sourceId}; allowed ${maxHops} hops`);\n    }\n\n    for (const targetId of adjacency.get(sourceId) ?? []) {\n      walk(targetId, hopCount + 1);\n    }\n  }\n\n  for (const sourceId of adjacency.keys()) {\n    walk(sourceId, 0);\n  }\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 3. CORE LOGIC\n// ───────────────────────────────────────────────────────────────────\n\n/**\n * Validate fallback graph edges before any dispatch uses them.\n *\n * Checks missing targets, cycles, cross-scope edges, and configured hop limits\n * without mutating the registry.\n *\n * @param registry - The model registry with fallback configurations.\n * @param options - Validation limits for graph traversal.\n * @throws Error when the fallback graph is unsafe to dispatch.\n */\nexport function validateFallbackGraph(\n  registry: ModelRegistry,\n  options: FallbackGraphValidationOptions = {},\n): void {\n  const edges = buildEdges(registry);\n  const maxHops = options.maxHops ?? DEFAULT_MAX_HOPS;\n\n  assertKnownTargets(registry, edges);\n  assertScopesDoNotWiden(registry, edges);\n  assertNoCycles(edges);\n  assertMaxHops(edges, maxHops);\n}\n\n/**\n * Create a router after validating configured fallback edges.\n *\n * @param registry - The model registry with fallback configurations.\n * @param options - Validation limits for graph traversal.\n * @returns A router bound to the validated registry.\n * @throws Error when the fallback graph is unsafe to dispatch.\n */\nexport function createFallbackRouter(\n  registry: ModelRegistry,\n  options: FallbackGraphValidationOptions = {},\n): FallbackRouter {\n  validateFallbackGraph(registry, options);\n\n  return {\n    resolve(\n      failedModelId: string,\n      approvedModelIds?: readonly string[],\n      context?: FallbackRouteContext,\n    ): FallbackRoute {\n      return resolveFallback(failedModelId, registry, approvedModelIds, context);\n    },\n  };\n}\n\n/**\n * Resolve the fallback route when a model exhausts its quota pool.\n *\n * Checks whether the failed model has a configured fallback target in a\n * different quota pool and returns the appropriate route.\n *\n * The optional approval set closes the substitution gap: routing only ever\n * resolves to a model the caller approved. The configured `fallback_target` is\n * the approved route by definition, so the guard rejects only a target the\n * caller never sanctioned, and never the legitimate cross-pool fallback. When\n * the set is omitted, the configured target is treated as approved (existing\n * behavior), so this is additive.\n *\n * @param failedModelId - The model ID that failed.\n * @param registry - The model registry with fallback configurations.\n * @param approvedModelIds - Optional set of model IDs the caller approved; when\n *   provided, a target outside the set returns fail-fast instead of routing.\n * @param context - Optional typed route context for failure kind and trace data.\n * @returns A route indicating whether to fallback or fail-fast, with a reason.\n */\nexport function resolveFallback(\n  failedModelId: string,\n  registry: ModelRegistry,\n  approvedModelIds?: readonly string[],\n  context?: FallbackRouteContext,\n): FallbackRoute {\n  const trace = createTrace(failedModelId, context);\n  const failedModel = findModel(registry, failedModelId);\n  if (failedModel === undefined) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `unknown model ${failedModelId}; no quota pool available for fallback routing`,\n      },\n      trace,\n      context?.failureKind,\n    );\n  }\n\n  const selection = selectTarget(failedModel, context);\n  if (selection.target === null) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `${failedModel.quota_pool} pool exhausted, no separate-pool fallback configured for ${failedModel.id}`,\n      },\n      trace,\n      selection.failureKind,\n    );\n  }\n\n  const targetModel = findModel(registry, selection.target);\n  if (targetModel === undefined) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `${failedModel.quota_pool} pool exhausted, configured ${describeTargetKind(selection)} ${selection.target} is not in the registry`,\n      },\n      trace,\n      selection.failureKind,\n    );\n  }\n\n  if (targetModel.quota_pool === failedModel.quota_pool) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `${failedModel.quota_pool} pool exhausted, fallback target ${targetModel.id} shares the same pool; same-pool fallback rejected`,\n      },\n      trace,\n      selection.failureKind,\n    );\n  }\n\n  if (approvedModelIds !== undefined && !approvedModelIds.includes(targetModel.id)) {\n    return withRouteMetadata(\n      {\n        action: 'fail-fast',\n        reason: `${failedModel.quota_pool} pool exhausted, fallback target ${targetModel.id} is not in the caller-approved model set; unapproved substitution rejected`,\n      },\n      trace,\n      selection.failureKind,\n    );\n  }\n\n  return withRouteMetadata(\n    {\n      action: 'fallback',\n      target: targetModel.id,\n      reason: `${failedModel.quota_pool} pool exhausted, routing ${failedModel.id} to separate ${targetModel.quota_pool} pool target ${targetModel.id}`,\n    },\n    trace,\n    selection.failureKind,\n  );\n}","lineStart":261,"lineEnd":431,"totalLines":431,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","time":{"start":1783487874381,"end":1783487874385}},"metadata":{"openai":{"itemId":"fc_0107759b0c9b86e6016a4ddd81fc5c8191a982d8ce3efa8e57"}},"id":"prt_f402944d2001fa7MH1KIYIxEms","sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","messageID":"msg_f402913d3001nywLNRbhgdQWS4"}}
{"type":"tool_use","timestamp":1783487874479,"sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","part":{"type":"tool","tool":"read","callID":"call_vQKGJ7UiSAG14pIkSSzufL9y","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/fallback-router.vitest.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/fallback-router.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Fallback Router Unit Tests\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: import { describe, expect, it } from 'vitest';\n6: \n7: import {\n8:   createFallbackRouter,\n9:   type ModelProfile,\n10:   type ModelRegistry,\n11:   resolveFallback,\n12: } from '../../lib/deep-loop/fallback-router';\n13: \n14: const requiredProfiles: readonly ModelProfile[] = [\n15:   { id: 'swe-1.6', quota_pool: 'cognition-free', fallback_target: null },\n16:   { id: 'deepseek-v4-pro', quota_pool: 'cognition-pro', fallback_target: null },\n17:   { id: 'kimi-k2.6', quota_pool: 'cognition-pro', fallback_target: null },\n18:   { id: 'qwen3.6', quota_pool: 'cognition-pro', fallback_target: null },\n19: ] as const;\n20: \n21: const optionalProfiles: readonly ModelProfile[] = [\n22:   { id: 'haiku', quota_pool: 'anthropic', fallback_target: null },\n23: ] as const;\n24: \n25: /**\n26:  * Builds a ModelRegistry with a fallback target set for the given source model.\n27:  */\n28: function registryWithFallback(sourceId: string, targetId: string | null): ModelRegistry {\n29:   return {\n30:     models: [...requiredProfiles, ...optionalProfiles].map((profile) =>\n31:       profile.id === sourceId ? { ...profile, fallback_target: targetId } : profile,\n32:     ),\n33:   };\n34: }\n35: \n36: describe('fallback-router', () => {\n37:   it('fails fast for the default SWE-1.6 registry state', () => {\n38:     expect(resolveFallback('swe-1.6', registryWithFallback('swe-1.6', null))).toEqual({\n39:       action: 'fail-fast',\n40:       reason: 'cognition-free pool exhausted, no separate-pool fallback configured for swe-1.6',\n41:     });\n42:   });\n43: \n44:   it('fails fast for the default Cognition Pro registry state', () => {\n45:     expect(resolveFallback('deepseek-v4-pro', registryWithFallback('deepseek-v4-pro', null))).toEqual({\n46:       action: 'fail-fast',\n47:       reason: 'cognition-pro pool exhausted, no separate-pool fallback configured for deepseek-v4-pro',\n48:     });\n49:   });\n50: \n51:   it('evaluates every required source and required target pool combination', () => {\n52:     for (const source of requiredProfiles) {\n53:       for (const target of requiredProfiles) {\n54:         const result = resolveFallback(source.id, registryWithFallback(source.id, target.id));\n55: \n56:         if (source.quota_pool === target.quota_pool) {\n57:           expect(result).toMatchObject({\n58:             action: 'fail-fast',\n59:           });\n60:           expect(result.reason).toContain('same-pool fallback rejected');\n61:         } else {\n62:           expect(result).toEqual({\n63:             action: 'fallback',\n64:             target: target.id,\n65:             reason: `${source.quota_pool} pool exhausted, routing ${source.id} to separate ${target.quota_pool} pool target ${target.id}`,\n66:           });\n67:         }\n68:       }\n69:     }\n70:   });\n71: \n72:   it('routes SWE-1.6 to Haiku when the optional separate-pool target is populated', () => {\n73:     expect(resolveFallback('swe-1.6', registryWithFallback('swe-1.6', 'haiku'))).toEqual({\n74:       action: 'fallback',\n75:       target: 'haiku',\n76:       reason: 'cognition-free pool exhausted, routing swe-1.6 to separate anthropic pool target haiku',\n77:     });\n78:   });\n79: \n80:   it('rejects same-pool Cognition Pro sibling fallback', () => {\n81:     expect(resolveFallback('kimi-k2.6', registryWithFallback('kimi-k2.6', 'qwen3.6'))).toEqual({\n82:       action: 'fail-fast',\n83:       reason: 'cognition-pro pool exhausted, fallback target qwen3.6 shares the same pool; same-pool fallback rejected',\n84:     });\n85:   });\n86: \n87:   it('routes an Anthropic source to a separate-pool target when populated', () => {\n88:     expect(resolveFallback('haiku', registryWithFallback('haiku', 'swe-1.6'))).toEqual({\n89:       action: 'fallback',\n90:       target: 'swe-1.6',\n91:       reason: 'anthropic pool exhausted, routing haiku to separate cognition-free pool target swe-1.6',\n92:     });\n93:   });\n94: \n95:   it('fails fast when the configured target is absent from the registry', () => {\n96:     expect(resolveFallback('swe-1.6', registryWithFallback('swe-1.6', 'missing-model'))).toEqual({\n97:       action: 'fail-fast',\n98:       reason: 'cognition-free pool exhausted, configured fallback missing-model is not in the registry',\n99:     });\n100:   });\n101: \n102:   it('fails fast for unknown failed models', () => {\n103:     expect(resolveFallback('missing-model', registryWithFallback('swe-1.6', null))).toEqual({\n104:       action: 'fail-fast',\n105:       reason: 'unknown model missing-model; no quota pool available for fallback routing',\n106:     });\n107:   });\n108: \n109:   it('routes typed timeout failures with trace metadata', () => {\n110:     const registry: ModelRegistry = {\n111:       models: [\n112:         {\n113:           id: 'swe-1.6',\n114:           quota_pool: 'cognition-free',\n115:           fallback_target: null,\n116:           onFailureTarget: { timeout: 'haiku' },\n117:           routeScope: 'executor',\n118:         },\n119:         {\n120:           id: 'haiku',\n121:           quota_pool: 'anthropic',\n122:           fallback_target: null,\n123:           routeScope: 'executor',\n124:         },\n125:       ],\n126:     };\n127: \n128:     const router = createFallbackRouter(registry);\n129: \n130:     expect(router.resolve('swe-1.6', ['swe-1.6', 'haiku'], {\n131:       failureKind: 'timeout',\n132:       routeGroupId: 'executor-fallback-1',\n133:     })).toEqual({\n134:       action: 'fallback',\n135:       target: 'haiku',\n136:       reason: 'cognition-free pool exhausted, routing swe-1.6 to separate anthropic pool target haiku',\n137:       failureKind: 'timeout',\n138:       routeGroupId: 'executor-fallback-1',\n139:       hopIndex: 0,\n140:     });\n141:   });\n142: \n143:   it('rejects cyclic fallback graphs before routing can dispatch', () => {\n144:     const registry: ModelRegistry = {\n145:       models: [\n146:         {\n147:           id: 'swe-1.6',\n148:           quota_pool: 'cognition-free',\n149:           fallback_target: null,\n150:           onFailureTarget: { timeout: 'haiku' },\n151:           routeScope: 'executor',\n152:         },\n153:         {\n154:           id: 'haiku',\n155:           quota_pool: 'anthropic',\n156:           fallback_target: null,\n157:           onFailureTarget: { timeout: 'swe-1.6' },\n158:           routeScope: 'executor',\n159:         },\n160:       ],\n161:     };\n162: \n163:     expect(() => createFallbackRouter(registry)).toThrow(\n164:       'fallback graph cycle detected: swe-1.6 -> haiku -> swe-1.6',\n165:     );\n166:   });\n167: });\n\n(End of file - total 167 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Fallback Router Unit Tests\n// ───────────────────────────────────────────────────────────────────\n\nimport { describe, expect, it } from 'vitest';\n\nimport {\n  createFallbackRouter,\n  type ModelProfile,\n  type ModelRegistry,\n  resolveFallback,\n} from '../../lib/deep-loop/fallback-router';\n\nconst requiredProfiles: readonly ModelProfile[] = [\n  { id: 'swe-1.6', quota_pool: 'cognition-free', fallback_target: null },\n  { id: 'deepseek-v4-pro', quota_pool: 'cognition-pro', fallback_target: null },\n  { id: 'kimi-k2.6', quota_pool: 'cognition-pro', fallback_target: null },\n  { id: 'qwen3.6', quota_pool: 'cognition-pro', fallback_target: null },\n] as const;\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/fallback-router.vitest.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Fallback Router Unit Tests\n// ───────────────────────────────────────────────────────────────────\n\nimport { describe, expect, it } from 'vitest';\n\nimport {\n  createFallbackRouter,\n  type ModelProfile,\n  type ModelRegistry,\n  resolveFallback,\n} from '../../lib/deep-loop/fallback-router';\n\nconst requiredProfiles: readonly ModelProfile[] = [\n  { id: 'swe-1.6', quota_pool: 'cognition-free', fallback_target: null },\n  { id: 'deepseek-v4-pro', quota_pool: 'cognition-pro', fallback_target: null },\n  { id: 'kimi-k2.6', quota_pool: 'cognition-pro', fallback_target: null },\n  { id: 'qwen3.6', quota_pool: 'cognition-pro', fallback_target: null },\n] as const;\n\nconst optionalProfiles: readonly ModelProfile[] = [\n  { id: 'haiku', quota_pool: 'anthropic', fallback_target: null },\n] as const;\n\n/**\n * Builds a ModelRegistry with a fallback target set for the given source model.\n */\nfunction registryWithFallback(sourceId: string, targetId: string | null): ModelRegistry {\n  return {\n    models: [...requiredProfiles, ...optionalProfiles].map((profile) =>\n      profile.id === sourceId ? { ...profile, fallback_target: targetId } : profile,\n    ),\n  };\n}\n\ndescribe('fallback-router', () => {\n  it('fails fast for the default SWE-1.6 registry state', () => {\n    expect(resolveFallback('swe-1.6', registryWithFallback('swe-1.6', null))).toEqual({\n      action: 'fail-fast',\n      reason: 'cognition-free pool exhausted, no separate-pool fallback configured for swe-1.6',\n    });\n  });\n\n  it('fails fast for the default Cognition Pro registry state', () => {\n    expect(resolveFallback('deepseek-v4-pro', registryWithFallback('deepseek-v4-pro', null))).toEqual({\n      action: 'fail-fast',\n      reason: 'cognition-pro pool exhausted, no separate-pool fallback configured for deepseek-v4-pro',\n    });\n  });\n\n  it('evaluates every required source and required target pool combination', () => {\n    for (const source of requiredProfiles) {\n      for (const target of requiredProfiles) {\n        const result = resolveFallback(source.id, registryWithFallback(source.id, target.id));\n\n        if (source.quota_pool === target.quota_pool) {\n          expect(result).toMatchObject({\n            action: 'fail-fast',\n          });\n          expect(result.reason).toContain('same-pool fallback rejected');\n        } else {\n          expect(result).toEqual({\n            action: 'fallback',\n            target: target.id,\n            reason: `${source.quota_pool} pool exhausted, routing ${source.id} to separate ${target.quota_pool} pool target ${target.id}`,\n          });\n        }\n      }\n    }\n  });\n\n  it('routes SWE-1.6 to Haiku when the optional separate-pool target is populated', () => {\n    expect(resolveFallback('swe-1.6', registryWithFallback('swe-1.6', 'haiku'))).toEqual({\n      action: 'fallback',\n      target: 'haiku',\n      reason: 'cognition-free pool exhausted, routing swe-1.6 to separate anthropic pool target haiku',\n    });\n  });\n\n  it('rejects same-pool Cognition Pro sibling fallback', () => {\n    expect(resolveFallback('kimi-k2.6', registryWithFallback('kimi-k2.6', 'qwen3.6'))).toEqual({\n      action: 'fail-fast',\n      reason: 'cognition-pro pool exhausted, fallback target qwen3.6 shares the same pool; same-pool fallback rejected',\n    });\n  });\n\n  it('routes an Anthropic source to a separate-pool target when populated', () => {\n    expect(resolveFallback('haiku', registryWithFallback('haiku', 'swe-1.6'))).toEqual({\n      action: 'fallback',\n      target: 'swe-1.6',\n      reason: 'anthropic pool exhausted, routing haiku to separate cognition-free pool target swe-1.6',\n    });\n  });\n\n  it('fails fast when the configured target is absent from the registry', () => {\n    expect(resolveFallback('swe-1.6', registryWithFallback('swe-1.6', 'missing-model'))).toEqual({\n      action: 'fail-fast',\n      reason: 'cognition-free pool exhausted, configured fallback missing-model is not in the registry',\n    });\n  });\n\n  it('fails fast for unknown failed models', () => {\n    expect(resolveFallback('missing-model', registryWithFallback('swe-1.6', null))).toEqual({\n      action: 'fail-fast',\n      reason: 'unknown model missing-model; no quota pool available for fallback routing',\n    });\n  });\n\n  it('routes typed timeout failures with trace metadata', () => {\n    const registry: ModelRegistry = {\n      models: [\n        {\n          id: 'swe-1.6',\n          quota_pool: 'cognition-free',\n          fallback_target: null,\n          onFailureTarget: { timeout: 'haiku' },\n          routeScope: 'executor',\n        },\n        {\n          id: 'haiku',\n          quota_pool: 'anthropic',\n          fallback_target: null,\n          routeScope: 'executor',\n        },\n      ],\n    };\n\n    const router = createFallbackRouter(registry);\n\n    expect(router.resolve('swe-1.6', ['swe-1.6', 'haiku'], {\n      failureKind: 'timeout',\n      routeGroupId: 'executor-fallback-1',\n    })).toEqual({\n      action: 'fallback',\n      target: 'haiku',\n      reason: 'cognition-free pool exhausted, routing swe-1.6 to separate anthropic pool target haiku',\n      failureKind: 'timeout',\n      routeGroupId: 'executor-fallback-1',\n      hopIndex: 0,\n    });\n  });\n\n  it('rejects cyclic fallback graphs before routing can dispatch', () => {\n    const registry: ModelRegistry = {\n      models: [\n        {\n          id: 'swe-1.6',\n          quota_pool: 'cognition-free',\n          fallback_target: null,\n          onFailureTarget: { timeout: 'haiku' },\n          routeScope: 'executor',\n        },\n        {\n          id: 'haiku',\n          quota_pool: 'anthropic',\n          fallback_target: null,\n          onFailureTarget: { timeout: 'swe-1.6' },\n          routeScope: 'executor',\n        },\n      ],\n    };\n\n    expect(() => createFallbackRouter(registry)).toThrow(\n      'fallback graph cycle detected: swe-1.6 -> haiku -> swe-1.6',\n    );\n  });\n});","lineStart":1,"lineEnd":167,"totalLines":167,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/tests/unit/fallback-router.vitest.ts","time":{"start":1783487874474,"end":1783487874478}},"metadata":{"openai":{"itemId":"fc_0107759b0c9b86e6016a4ddd81fc64819182d638941c049270"}},"id":"prt_f40294568001QeFrCR54ZmaJkg","sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","messageID":"msg_f402913d3001nywLNRbhgdQWS4"}}
