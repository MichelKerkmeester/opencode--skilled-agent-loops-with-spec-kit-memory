./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:113:        ".opencode/skills/sk-deep-review/scripts/reduce-state.cjs:1128",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:114:        ".opencode/skills/sk-deep-research/references/state_format.md:15",
./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:115:        ".opencode/skills/sk-deep-review/references/loop_protocol.md:150",
