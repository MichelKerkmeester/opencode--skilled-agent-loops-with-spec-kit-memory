{"type":"text","timestamp":1782925245935,"sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","part":{"id":"prt_f1ea01f57001n4ECT4fU9Ji02G","messageID":"msg_f1e9ff2e5001LrDYraMXgtjlyN","sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","type":"text","text":"The lineage directory exists and currently only has executor bookkeeping. I’m gathering the concrete evidence requested: plugin hook shape, command/agent dispatch contracts, and phase 012 benchmark results.","time":{"start":1782925238103,"end":1782925245931},"metadata":{"openai":{"itemId":"msg_085cc95c84976a09016a4547b616508191ae69ba26304b51c7","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1782925245977,"sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","part":{"type":"tool","tool":"read","callID":"call_WDcIu5O9r3bQjwiA1QLchgkz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n5: // ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n6: // ║          declared mode disagrees with mode-registry.json's entry for    ║\n7: // ║          the actual subagent_type being dispatched.                     ║\n8: // ╚══════════════════════════════════════════════════════════════════════════╝\n9: 'use strict';\n10: \n11: // ─────────────────────────────────────────────────────────────────────────────\n12: // 1. IMPORTS\n13: // ─────────────────────────────────────────────────────────────────────────────\n14: \n15: import { readFileSync } from 'node:fs';\n16: import { join } from 'node:path';\n17: \n18: // ─────────────────────────────────────────────────────────────────────────────\n19: // 2. CONSTANTS\n20: // ─────────────────────────────────────────────────────────────────────────────\n21: \n22: const REGISTRY_RELATIVE_PATH = '.opencode/skills/deep-loop-workflows/mode-registry.json';\n23: const REJECT_MODE_ENV = 'MK_DEEP_LOOP_GUARD_REJECT';\n24: \n25: // ─────────────────────────────────────────────────────────────────────────────\n26: // 3. HELPERS\n27: // ─────────────────────────────────────────────────────────────────────────────\n28: \n29: function loadRegistryAgents(registryPath) {\n30:   try {\n31:     const raw = readFileSync(registryPath, 'utf8');\n32:     const data = JSON.parse(raw);\n33:     const map = new Map();\n34:     for (const mode of data.modes || []) {\n35:       if (mode.agent) map.set(mode.agent, mode);\n36:     }\n37:     return map;\n38:   } catch (_) {\n39:     return null;\n40:   }\n41: }\n42: \n43: function declaredModeFromPrompt(promptText) {\n44:   const match = /mode=([a-z0-9-]+)/i.exec(promptText || '');\n45:   return match ? match[1] : null;\n46: }\n47: \n48: function mismatchDetail(subagentType, registryMode, declaredMode) {\n49:   return [\n50:     'mk-deep-loop-guard: Deep Route mode mismatch --',\n51:     `dispatch targets subagent_type=\"${subagentType}\"`,\n52:     `(registry mode=\"${registryMode}\")`,\n53:     `but the prompt declares mode=\"${declaredMode}\"`,\n54:   ].join(' ');\n55: }\n56: \n57: // ─────────────────────────────────────────────────────────────────────────────\n58: // 4. PLUGIN FACTORY\n59: // ─────────────────────────────────────────────────────────────────────────────\n60: \n61: /**\n62:  * Create the mk-deep-loop-guard OpenCode plugin hooks.\n63:  *\n64:  * Hard limits (by design, not oversight):\n65:  * - Cannot create hard runtime identity; that remains host/FIX-5 territory.\n66:  * - Does not catch a schema-valid, route-matched artifact that internally\n67:  *   does semantically wrong-mode work.\n68:  * - Fails open on its own errors (missing/unreadable registry, unexpected\n69:  *   arg shapes) so a bug here never blocks unrelated, correctly-routed work.\n70:  *\n71:  * @param {{ directory?: string } | undefined} ctx - OpenCode plugin context.\n72:  * @returns {Promise<object>} Hooks object for the OpenCode plugin loader.\n73:  */\n74: export default async function MkDeepLoopGuardPlugin(ctx) {\n75:   const projectDir = ctx?.directory || process.cwd();\n76:   const registryPath = join(projectDir, REGISTRY_RELATIVE_PATH);\n77: \n78:   return {\n79:     async 'tool.execute.before'(input, output) {\n80:       try {\n81:         if (!input || input.tool !== 'task') return;\n82:         const args = output && output.args;\n83:         if (!args || typeof args !== 'object') return;\n84: \n85:         const subagentType = args.subagent_type || args.subagentType;\n86:         if (!subagentType) return;\n87: \n88:         const registry = loadRegistryAgents(registryPath);\n89:         if (!registry) return;\n90: \n91:         const entry = registry.get(subagentType);\n92:         if (!entry) return;\n93: \n94:         const declaredMode = declaredModeFromPrompt(args.prompt);\n95:         if (!declaredMode || declaredMode === entry.workflowMode) return;\n96: \n97:         const detail = mismatchDetail(subagentType, entry.workflowMode, declaredMode);\n98: \n99:         if (process.env[REJECT_MODE_ENV] === '1') {\n100:           throw new Error(detail);\n101:         }\n102:         console.error(`[mk-deep-loop-guard] WARN: ${detail}`);\n103:       } catch (err) {\n104:         if (err instanceof Error && err.message.startsWith('mk-deep-loop-guard:')) throw err;\n105:         // Fail open on any unexpected internal error -- never block unrelated dispatches.\n106:       }\n107:     },\n108:   };\n109: }\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n// ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n// ║          declared mode disagrees with mode-registry.json's entry for    ║\n// ║          the actual subagent_type being dispatched.                     ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nimport { readFileSync } from 'node:fs';\nimport { join } from 'node:path';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Detection-layer enforcement for Task-tool dispatches targeting  ║\n// ║          deep-loop sub-agents -- flags/blocks a Deep Route header whose  ║\n// ║          declared mode disagrees with mode-registry.json's entry for    ║\n// ║          the actual subagent_type being dispatched.                     ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nimport { readFileSync } from 'node:fs';\nimport { join } from 'node:path';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst REGISTRY_RELATIVE_PATH = '.opencode/skills/deep-loop-workflows/mode-registry.json';\nconst REJECT_MODE_ENV = 'MK_DEEP_LOOP_GUARD_REJECT';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction loadRegistryAgents(registryPath) {\n  try {\n    const raw = readFileSync(registryPath, 'utf8');\n    const data = JSON.parse(raw);\n    const map = new Map();\n    for (const mode of data.modes || []) {\n      if (mode.agent) map.set(mode.agent, mode);\n    }\n    return map;\n  } catch (_) {\n    return null;\n  }\n}\n\nfunction declaredModeFromPrompt(promptText) {\n  const match = /mode=([a-z0-9-]+)/i.exec(promptText || '');\n  return match ? match[1] : null;\n}\n\nfunction mismatchDetail(subagentType, registryMode, declaredMode) {\n  return [\n    'mk-deep-loop-guard: Deep Route mode mismatch --',\n    `dispatch targets subagent_type=\"${subagentType}\"`,\n    `(registry mode=\"${registryMode}\")`,\n    `but the prompt declares mode=\"${declaredMode}\"`,\n  ].join(' ');\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. PLUGIN FACTORY\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Create the mk-deep-loop-guard OpenCode plugin hooks.\n *\n * Hard limits (by design, not oversight):\n * - Cannot create hard runtime identity; that remains host/FIX-5 territory.\n * - Does not catch a schema-valid, route-matched artifact that internally\n *   does semantically wrong-mode work.\n * - Fails open on its own errors (missing/unreadable registry, unexpected\n *   arg shapes) so a bug here never blocks unrelated, correctly-routed work.\n *\n * @param {{ directory?: string } | undefined} ctx - OpenCode plugin context.\n * @returns {Promise<object>} Hooks object for the OpenCode plugin loader.\n */\nexport default async function MkDeepLoopGuardPlugin(ctx) {\n  const projectDir = ctx?.directory || process.cwd();\n  const registryPath = join(projectDir, REGISTRY_RELATIVE_PATH);\n\n  return {\n    async 'tool.execute.before'(input, output) {\n      try {\n        if (!input || input.tool !== 'task') return;\n        const args = output && output.args;\n        if (!args || typeof args !== 'object') return;\n\n        const subagentType = args.subagent_type || args.subagentType;\n        if (!subagentType) return;\n\n        const registry = loadRegistryAgents(registryPath);\n        if (!registry) return;\n\n        const entry = registry.get(subagentType);\n        if (!entry) return;\n\n        const declaredMode = declaredModeFromPrompt(args.prompt);\n        if (!declaredMode || declaredMode === entry.workflowMode) return;\n\n        const detail = mismatchDetail(subagentType, entry.workflowMode, declaredMode);\n\n        if (process.env[REJECT_MODE_ENV] === '1') {\n          throw new Error(detail);\n        }\n        console.error(`[mk-deep-loop-guard] WARN: ${detail}`);\n      } catch (err) {\n        if (err instanceof Error && err.message.startsWith('mk-deep-loop-guard:')) throw err;\n        // Fail open on any unexpected internal error -- never block unrelated dispatches.\n      }\n    },\n  };\n}","lineStart":1,"lineEnd":109,"totalLines":109,"truncated":false}},"title":".opencode/plugins/mk-deep-loop-guard.js","time":{"start":1782925245968,"end":1782925245976}},"metadata":{"openai":{"itemId":"fc_085cc95c84976a09016a4547bde29081918c50fcc942c10b73"}},"id":"prt_f1ea03ded001K9Y20d3gvRutVz","sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","messageID":"msg_f1e9ff2e5001LrDYraMXgtjlyN"}}
{"type":"tool_use","timestamp":1782925246078,"sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","part":{"type":"tool","tool":"read","callID":"call_M26p2bhmI7K0mgc9ovJFO41f","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/mode-registry.json","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/mode-registry.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"skill\": \"deep-loop-workflows\",\n3:   \"version\": \"1.1.0\",\n4:   \"description\": \"Declarative mode registry: the single source of truth for the three-tier discriminator (workflowMode/runtimeLoopType/backendKind) PLUS the advisorRouting projection. The advisor keeps its hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry via a CI drift-guard test (maps == registry projection); the advisor does NOT read this file at runtime, which avoids cross-skill import coupling on the advisor hot path.\",\n5:   \"discriminator\": {\n6:     \"workflowMode\": \"Public command/advisor/mode key. Stable identity used in commands, advisor aliases, and this registry. Carried by every mode.\",\n7:     \"runtimeLoopType\": \"The graph-backed convergence loop key consumed by deep-loop-runtime/scripts/convergence.cjs. Validated against exactly research|review|council|context. Explicit null for improvement-host and external-adapter modes; NEVER inferred from workflowMode.\",\n8:     \"backendKind\": \"Which backend actually runs the mode: runtime-loop-type (deep-loop-runtime convergence), improvement-host (deep-improvement/scripts/shared/loop-host.cjs --mode), or external-adapter (loop owned by external packaging).\"\n9:   },\n10:   \"advisorRoutingContract\": {\n11:     \"routingClass\": \"How the advisor finds the mode. 'lexical' = weighted-regex scoring in skill_advisor.py AND present in both projection maps. 'alias-fold' = TS DEEP_MODE_BY_CANONICAL only (alias projection, not lexically scored). 'metadata' = resolved by skill membership; no advisor map entry. 'command-bridge' = routed by its /deep:* command, not an advisor map entry.\",\n12:     \"legacyAdvisorId\": \"The legacy deep-* skill id the projection maps key on (present for lexical + alias-fold modes only).\",\n13:     \"advisorDefaultMode\": \"Marks the default mode a multi-mode legacy id folds to (deep-improvement -> agent-improvement). Never inferred from array order.\",\n14:     \"legacyAliases\": \"The TypeScript scorer alias set (aliases.ts SKILL_ALIAS_GROUPS[legacyAdvisorId]) the merged-identity layer keys on; the drift-guard asserts these match it order-insensitive. The Python deep-router uses its own alias set + regex patterns by design (same keys, different values), so the guard only cross-checks that each legacyAdvisorId key also exists in the Python SKILL_ALIAS_GROUPS.\",\n15:     \"packetSkillName\": \"The packet's SKILL.md name. Standard for all parent skills: folder == packetSkillName == deep-<mode>; deep-ai-council follows this (folder 'deep-ai-council', packetSkillName 'deep-ai-council'). The legacy public key 'ai-council' is preserved only on the command/agent surfaces, not on the packet folder/name.\",\n16:     \"driftGuard\": \".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts asserts the hardcoded Python + TS maps equal this registry's projection.\"\n17:   },\n18:   \"modes\": [\n19:     {\n20:       \"workflowMode\": \"context\",\n21:       \"runtimeLoopType\": \"context\",\n22:       \"backendKind\": \"runtime-loop-type\",\n23:       \"packet\": \"deep-context\",\n24:       \"command\": \"/deep:context\",\n25:       \"agent\": \"deep-context\",\n26:       \"artifactRoot\": \"context/\",\n27:       \"aliases\": [\"deep-context\", \"context loop\", \"gather context\", \"gather codebase context\", \"context sweep\", \"reuse catalog\", \"pre-plan context\", \"context-gathering-loop\"],\n28:       \"advisorRouting\": {\n29:         \"routingClass\": \"metadata\",\n30:         \"packetSkillName\": \"deep-context\"\n31:       }\n32:     },\n33:     {\n34:       \"workflowMode\": \"research\",\n35:       \"runtimeLoopType\": \"research\",\n36:       \"backendKind\": \"runtime-loop-type\",\n37:       \"packet\": \"deep-research\",\n38:       \"command\": \"/deep:research\",\n39:       \"agent\": \"deep-research\",\n40:       \"artifactRoot\": \"research/\",\n41:       \"aliases\": [\"deep-research\", \"research loop\", \"iterative investigation workflow\", \"research convergence detection\", \"autoresearch\", \"iterative-research\"],\n42:       \"advisorRouting\": {\n43:         \"routingClass\": \"lexical\",\n44:         \"legacyAdvisorId\": \"deep-research\",\n45:         \"legacyAliases\": [\"command-spec-kit-deep-research\", \"/deep:start-research-loop\", \"spec_kit:deep-research\", \"deep-research\", \"sk-deep-research\"],\n46:         \"packetSkillName\": \"deep-research\"\n47:       }\n48:     },\n49:     {\n50:       \"workflowMode\": \"review\",\n51:       \"runtimeLoopType\": \"review\",\n52:       \"backendKind\": \"runtime-loop-type\",\n53:       \"packet\": \"deep-review\",\n54:       \"command\": \"/deep:review\",\n55:       \"agent\": \"deep-review\",\n56:       \"artifactRoot\": \"review/\",\n57:       \"aliases\": [\"deep-review\", \"review loop\", \"iterative code audit\", \"severity weighted findings\", \"code-audit\", \"release-readiness\"],\n58:       \"advisorRouting\": {\n59:         \"routingClass\": \"lexical\",\n60:         \"legacyAdvisorId\": \"deep-review\",\n61:         \"legacyAliases\": [\"command-spec-kit-deep-review\", \"/deep:start-review-loop\", \"spec_kit:deep-review\", \"deep-review\", \"sk-deep-review\"],\n62:         \"packetSkillName\": \"deep-review\"\n63:       }\n64:     },\n65:     {\n66:       \"workflowMode\": \"ai-council\",\n67:       \"runtimeLoopType\": \"council\",\n68:       \"backendKind\": \"runtime-loop-type\",\n69:       \"packet\": \"deep-ai-council\",\n70:       \"command\": \"/deep:ai-council\",\n71:       \"agent\": \"ai-council\",\n72:       \"artifactRoot\": \"ai-council/\",\n73:       \"aliases\": [\"deep-ai-council\", \"ai council deliberation\", \"multi-seat planning council\", \"council convergence\", \"planning council\"],\n74:       \"advisorRouting\": {\n75:         \"routingClass\": \"lexical\",\n76:         \"legacyAdvisorId\": \"deep-ai-council\",\n77:         \"legacyAliases\": [\"@deep-ai-council\", \"deep-ai-council\", \"deep ai council\", \"ai council\", \"planning council\", \"council deliberation\", \"multi-ai-council\"],\n78:         \"packetSkillName\": \"deep-ai-council\"\n79:       }\n80:     },\n81:     {\n82:       \"workflowMode\": \"agent-improvement\",\n83:       \"runtimeLoopType\": null,\n84:       \"backendKind\": \"improvement-host\",\n85:       \"packet\": \"deep-improvement\",\n86:       \"loopHostMode\": \"agent-improvement\",\n87:       \"command\": \"/deep:agent-improvement\",\n88:       \"agent\": \"deep-improvement\",\n89:       \"artifactRoot\": \"improvement/\",\n90:       \"mutating\": true,\n91:       \"aliases\": [\"improve agent\", \"evaluate agent\", \"agent scoring\", \"score agent candidate\", \"promote or rollback agent change\", \"agent-improvement\"],\n92:       \"advisorRouting\": {\n93:         \"routingClass\": \"alias-fold\",\n94:         \"legacyAdvisorId\": \"deep-improvement\",\n95:         \"advisorDefaultMode\": true,\n96:         \"legacyAliases\": [\"command-spec-kit-deep-agent-improvement\", \"/deep:start-agent-improvement-loop\", \"deep-agent-improvement\", \"sk-deep-agent-improvement\"],\n97:         \"packetSkillName\": \"deep-improvement\"\n98:       }\n99:     },\n100:     {\n101:       \"workflowMode\": \"model-benchmark\",\n102:       \"runtimeLoopType\": null,\n103:       \"backendKind\": \"improvement-host\",\n104:       \"packet\": \"deep-improvement\",\n105:       \"loopHostMode\": \"model-benchmark\",\n106:       \"command\": \"/deep:model-benchmark\",\n107:       \"agent\": \"deep-improvement\",\n108:       \"artifactRoot\": \"improvement/\",\n109:       \"aliases\": [\"model benchmark\", \"benchmark a model\", \"prompt framework benchmark\", \"benchmark-harness\"],\n110:       \"advisorRouting\": {\n111:         \"routingClass\": \"command-bridge\",\n112:         \"packetSkillName\": \"deep-improvement\"\n113:       }\n114:     },\n115:     {\n116:       \"workflowMode\": \"skill-benchmark\",\n117:       \"runtimeLoopType\": null,\n118:       \"backendKind\": \"improvement-host\",\n119:       \"packet\": \"deep-improvement\",\n120:       \"loopHostMode\": \"skill-benchmark\",\n121:       \"command\": \"/deep:skill-benchmark\",\n122:       \"agent\": \"deep-improvement\",\n123:       \"artifactRoot\": \"improvement/\",\n124:       \"aliases\": [\"skill benchmark\", \"benchmark a skill\", \"skill routing benchmark\"],\n125:       \"advisorRouting\": {\n126:         \"routingClass\": \"command-bridge\",\n127:         \"packetSkillName\": \"deep-improvement\"\n128:       }\n129:     },\n130:     {\n131:       \"workflowMode\": \"ai-system-improvement\",\n132:       \"runtimeLoopType\": null,\n133:       \"backendKind\": \"external-adapter\",\n134:       \"packet\": \"deep-improvement\",\n135:       \"loopHostMode\": \"non-dev-ai-system-refine\",\n136:       \"command\": \"/deep:ai-system-improvement\",\n137:       \"agent\": \"deep-improvement\",\n138:       \"artifactRoot\": \"improvement/\",\n139:       \"externalLoopOwner\": \"external packaging (e.g. Barter Copywriter) owns the Python loop, gates, scoring, and kill-switches\",\n140:       \"aliases\": [\"non-dev ai system\", \"non-dev-ai-system\", \"package ai system benchmark\"],\n141:       \"advisorRouting\": {\n142:         \"routingClass\": \"command-bridge\",\n143:         \"packetSkillName\": \"deep-improvement\"\n144:       }\n145:     }\n146:   ]\n147: }\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"{\n  \"skill\": \"deep-loop-workflows\",\n  \"version\": \"1.1.0\",\n  \"description\": \"Declarative mode registry: the single source of truth for the three-tier discriminator (workflowMode/runtimeLoopType/backendKind) PLUS the advisorRouting projection. The advisor keeps its hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry via a CI drift-guard test (maps == registry projection); the advisor does NOT read this file at runtime, which avoids cross-skill import coupling on the advisor hot path.\",\n  \"discriminator\": {\n    \"workflowMode\": \"Public command/advisor/mode key. Stable identity used in commands, advisor aliases, and this registry. Carried by every mode.\",\n    \"runtimeLoopType\": \"The graph-backed convergence loop key consumed by deep-loop-runtime/scripts/convergence.cjs. Validated against exactly research|review|council|context. Explicit null for improvement-host and external-adapter modes; NEVER inferred from workflowMode.\",\n    \"backendKind\": \"Which backend actually runs the mode: runtime-loop-type (deep-loop-runtime convergence), improvement-host (deep-improvement/scripts/shared/loop-host.cjs --mode), or external-adapter (loop owned by external packaging).\"\n  },\n  \"advisorRoutingContract\": {\n    \"routingClass\": \"How the advisor finds the mode. 'lexical' = weighted-regex scoring in skill_advisor.py AND present in both projection maps. 'alias-fold' = TS DEEP_MODE_BY_CANONICAL only (alias projection, not lexically scored). 'metadata' = resolved by skill membership; no advisor map entry. 'command-bridge' = routed by its /deep:* command, not an advisor map entry.\",\n    \"legacyAdvisorId\": \"The legacy deep-* skill id the projection maps key on (present for lexical + alias-fold modes only).\",\n    \"advisorDefaultMode\": \"Marks the default mode a multi-mode legacy id folds to (deep-improvement -> agent-improvement). Never inferred from array order.\",\n    \"legacyAliases\": \"The TypeScript scorer alias set (aliases.ts SKILL_ALIAS_GROUPS[legacyAdvisorId]) the merged-identity layer keys on; the drift-guard asserts these match it order-insensitive. The Python deep-router uses its own alias set + regex patterns by design (same keys, different values), so the guard only cross-checks that each legacyAdvisorId key also exists in the Python SKILL_ALIAS_GROUPS.\",\n    \"packetSkillName\": \"The packet's SKILL.md name. Standard for all parent skills: folder == packetSkillName == deep-<mode>; deep-ai-council follows this (folder 'deep-ai-council', packetSkillName 'deep-ai-council'). The legacy public key 'ai-council' is preserved only on the command/agent surfaces, not on the packet folder/name.\",\n    \"driftGuard\": \".opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts asserts the hardcoded Python + TS maps equal this registry's projection.\"\n  },\n  \"modes\": [\n    {\n      \"workflowMode\": \"context\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/mode-registry.json","text":"{\n  \"skill\": \"deep-loop-workflows\",\n  \"version\": \"1.1.0\",\n  \"description\": \"Declarative mode registry: the single source of truth for the three-tier discriminator (workflowMode/runtimeLoopType/backendKind) PLUS the advisorRouting projection. The advisor keeps its hardcoded projection maps (Python DEEP_ROUTING_MODE_BY_KEY, TypeScript DEEP_MODE_BY_CANONICAL) in sync with this registry via a CI drift-guard test (maps == registry projection); the advisor does NOT read this file at runtime, which avoids cross-skill import coupling on the advisor hot path.\",\n  \"discriminator\": {\n    \"workflowMode\": \"Public command/advisor/mode key. Stable identity used 