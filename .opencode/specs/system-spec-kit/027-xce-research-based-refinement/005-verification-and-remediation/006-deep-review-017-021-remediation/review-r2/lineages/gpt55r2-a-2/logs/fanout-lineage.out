{"type":"tool_use","timestamp":1781761472553,"sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","part":{"type":"tool","tool":"read","callID":"call_3XRUKJaw5iYVsq36ILJYISP4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-types.ts","offset":1,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-types.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Types\n3: // ───────────────────────────────────────────────────────────────\n4: // SCHEMA_VERSION is now canonical in vector-index-schema.ts\n5: /** Maximum trigger phrases stored for each memory. */\n6: export const MAX_TRIGGERS_PER_MEMORY = 10;\n7: \n8: /** Supported embedding input shapes for vector search and mutation operations. */\n9: export type EmbeddingInput = Float32Array | number[];\n10: \n11: /** Stable error codes emitted by vector-index modules. */\n12: export const VectorIndexErrorCode = {\n13:   EMBEDDING_VALIDATION: 'EMBEDDING_VALIDATION',\n14:   QUERY_FAILED: 'QUERY_FAILED',\n15:   INTEGRITY_ERROR: 'INTEGRITY_ERROR',\n16:   MUTATION_FAILED: 'MUTATION_FAILED',\n17:   STORE_ERROR: 'STORE_ERROR',\n18:   DB_LOCK_HELD: 'DB_LOCK_HELD',\n19: } as const;\n20: \n21: /** Enumerates the string codes used by {@link VectorIndexError}. */\n22: export type VectorIndexErrorCode = typeof VectorIndexErrorCode[keyof typeof VectorIndexErrorCode];\n23: \n24: /**\n25:  * Escapes SQL LIKE metacharacters so a folder name containing % or _\n26:  * cannot widen a scoped query. Every scope clause built from this MUST\n27:  * pair with `ESCAPE '\\'` in the SQL.\n28:  */\n29: export function escapeLikePattern(value: string): string {\n30:   return value.replace(/\\\\/g, '\\\\\\\\').replace(/%/g, '\\\\%').replace(/_/g, '\\\\_');\n31: }\n32: \n33: /** Builds the escaped `<folder>/%` LIKE pattern for spec-folder scoping. */\n34: export function specFolderLikePattern(specFolder: string): string {\n35:   return `${escapeLikePattern(specFolder)}/%`;\n36: }\n37: \n38: /** Structured error used by vector-index query, mutation, and store helpers. */\n39: export class VectorIndexError extends Error {\n40:   code: VectorIndexErrorCode;\n41: \n42:   constructor(message: string, code: VectorIndexErrorCode) {\n43:     super(message);\n44:     this.name = 'VectorIndexError';\n45:     this.code = code;\n46:     Object.setPrototypeOf(this, new.target.prototype);\n47:   }\n48: }\n49: \n50: /** Represents a row from the memory index table. */\n51: export interface MemoryIndexRow {\n52:   id: number;\n53:   spec_folder?: string;\n54:   file_path?: string;\n55:   anchor_id?: string | null;\n56:   title?: string | null;\n57:   trigger_phrases?: string | string[] | null;\n58:   triggerPhrases?: string | string[];\n59:   importance_weight?: number;\n60:   created_at?: string;\n61:   updated_at?: string;\n62:   embedding_model?: string | null;\n63:   embedding_generated_at?: string | null;\n64:   embedding_status?: string;\n65:   retry_count?: number;\n66:   last_retry_at?: string | null;\n67:   failure_reason?: string | null;\n68:   importance_tier?: string;\n69:   access_count?: number;\n70:   last_accessed?: number;\n71:   confidence?: number;\n72:   validation_count?: number;\n73:   is_pinned?: number;\n74:   stability?: number;\n75:   difficulty?: number;\n76:   last_review?: string | null;\n77:   review_count?: number;\n78:   content_hash?: string | null;\n79:   related_memories?: string | null;\n80:   document_type?: string;\n\n(Showing lines 1-80 of 255. Use offset=81 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Types\n// ───────────────────────────────────────────────────────────────\n// SCHEMA_VERSION is now canonical in vector-index-schema.ts\n/** Maximum trigger phrases stored for each memory. */\nexport const MAX_TRIGGERS_PER_MEMORY = 10;\n\n/** Supported embedding input shapes for vector search and mutation operations. */\nexport type EmbeddingInput = Float32Array | number[];\n\n/** Stable error codes emitted by vector-index modules. */\nexport const VectorIndexErrorCode = {\n  EMBEDDING_VALIDATION: 'EMBEDDING_VALIDATION',\n  QUERY_FAILED: 'QUERY_FAILED',\n  INTEGRITY_ERROR: 'INTEGRITY_ERROR',\n  MUTATION_FAILED: 'MUTATION_FAILED',\n  STORE_ERROR: 'STORE_ERROR',\n  DB_LOCK_HELD: 'DB_LOCK_HELD',\n} as const;\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-types.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Types\n// ───────────────────────────────────────────────────────────────\n// SCHEMA_VERSION is now canonical in vector-index-schema.ts\n/** Maximum trigger phrases stored for each memory. */\nexport const MAX_TRIGGERS_PER_MEMORY = 10;\n\n/** Supported embedding input shapes for vector search and mutation operations. */\nexport type EmbeddingInput = Float32Array | number[];\n\n/** Stable error codes emitted by vector-index modules. */\nexport const VectorIndexErrorCode = {\n  EMBEDDING_VALIDATION: 'EMBEDDING_VALIDATION',\n  QUERY_FAILED: 'QUERY_FAILED',\n  INTEGRITY_ERROR: 'INTEGRITY_ERROR',\n  MUTATION_FAILED: 'MUTATION_FAILED',\n  STORE_ERROR: 'STORE_ERROR',\n  DB_LOCK_HELD: 'DB_LOCK_HELD',\n} as const;\n\n/** Enumerates the string codes used by {@link VectorIndexError}. */\nexport type VectorIndexErrorCode = typeof VectorIndexErrorCode[keyof typeof VectorIndexErrorCode];\n\n/**\n * Escapes SQL LIKE metacharacters so a folder name containing % or _\n * cannot widen a scoped query. Every scope clause built from this MUST\n * pair with `ESCAPE '\\'` in the SQL.\n */\nexport function escapeLikePattern(value: string): string {\n  return value.replace(/\\\\/g, '\\\\\\\\').replace(/%/g, '\\\\%').replace(/_/g, '\\\\_');\n}\n\n/** Builds the escaped `<folder>/%` LIKE pattern for spec-folder scoping. */\nexport function specFolderLikePattern(specFolder: string): string {\n  return `${escapeLikePattern(specFolder)}/%`;\n}\n\n/** Structured error used by vector-index query, mutation, and store helpers. */\nexport class VectorIndexError extends Error {\n  code: VectorIndexErrorCode;\n\n  constructor(message: string, code: VectorIndexErrorCode) {\n    super(message);\n    this.name = 'VectorIndexError';\n    this.code = code;\n    Object.setPrototypeOf(this, new.target.prototype);\n  }\n}\n\n/** Represents a row from the memory index table. */\nexport interface MemoryIndexRow {\n  id: number;\n  spec_folder?: string;\n  file_path?: string;\n  anchor_id?: string | null;\n  title?: string | null;\n  trigger_phrases?: string | string[] | null;\n  triggerPhrases?: string | string[];\n  importance_weight?: number;\n  created_at?: string;\n  updated_at?: string;\n  embedding_model?: string | null;\n  embedding_generated_at?: string | null;\n  embedding_status?: string;\n  retry_count?: number;\n  last_retry_at?: string | null;\n  failure_reason?: string | null;\n  importance_tier?: string;\n  access_count?: number;\n  last_accessed?: number;\n  confidence?: number;\n  validation_count?: number;\n  is_pinned?: number;\n  stability?: number;\n  difficulty?: number;\n  last_review?: string | null;\n  review_count?: number;\n  content_hash?: string | null;\n  related_memories?: string | null;\n  document_type?: string;","lineStart":1,"lineEnd":80,"totalLines":255,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-types.ts","time":{"start":1781761472535,"end":1781761472551}},"metadata":{"openai":{"itemId":"fc_06bc64f77484a205016a3385c06f708191bb210be5e77b6784"}},"id":"prt_ed9427