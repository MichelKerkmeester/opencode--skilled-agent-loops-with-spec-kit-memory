/cheerio/blob/main/biome.json \"biome.json\")\n\n[eslint.config.js](/cheeriojs/cheerio/blob/main/eslint.config.js \"eslint.config.js\")\n\n[eslint.config.js](/cheeriojs/cheerio/blob/main/eslint.config.js \"eslint.config.js\")\n\n[package-lock.json](/cheeriojs/cheerio/blob/main/package-lock.json \"package-lock.json\")\n\n[package-lock.json](/cheeriojs/cheerio/blob/main/package-lock.json \"package-lock.json\")\n\n[package.json](/cheeriojs/cheerio/blob/main/package.json \"package.json\")\n\n[package.json](/cheeriojs/cheerio/blob/main/package.json \"package.json\")\n\n[tsconfig.json](/cheeriojs/cheerio/blob/main/tsconfig.json \"tsconfig.json\")\n\n[tsconfig.json](/cheeriojs/cheerio/blob/main/tsconfig.json \"tsconfig.json\")\n\n[tsconfig.typedoc.json](/cheeriojs/cheerio/blob/main/tsconfig.typedoc.json \"tsconfig.typedoc.json\")\n\n[tsconfig.typedoc.json](/cheeriojs/cheerio/blob/main/tsconfig.typedoc.json \"tsconfig.typedoc.json\")\n\n[vitest.config.ts](/cheeriojs/cheerio/blob/main/vitest.config.ts \"vitest.config.ts\")\n\n[vitest.config.ts](/cheeriojs/cheerio/blob/main/vitest.config.ts \"vitest.config.ts\")\n\nView all files\n\n## Repository files navigation\n\n-   [README](#)\n-   [Contributing](#)\n-   [MIT license](#)\n-   [Security](#)\n\nMore items\n\n# cheerio\n\n[](#cheerio)\n\n##### The fast, flexible, and elegant library for parsing and manipulating HTML and XML.\n\n[](#the-fast-flexible-and-elegant-library-for-parsing-and-manipulating-html-and-xml)\n\n [![Build Status](https://github.com/cheeriojs/cheerio/actions/workflows/ci.yml/badge.svg)](https://github.com/cheeriojs/cheerio/actions/workflows/ci.yml)[![Coverage](https://camo.githubusercontent.com/390fd59a52f294046a6067c7b096b2237e165f3c5f1aadfdb068747289acfa61/68747470733a2f2f696d672e736869656c64732e696f2f636f766572616c6c732f6769746875622f6368656572696f6a732f6368656572696f2f6d61696e) ](https://coveralls.io/github/cheeriojs/cheerio)[![OpenCollective backers](https://camo.githubusercontent.com/668b65d29d064f5fc9a2fc32e37de415cc6200fbc2386d12b3d7066050fad46c/68747470733a2f2f696d672e736869656c64732e696f2f6f70656e636f6c6c6563746976652f6261636b6572732f6368656572696f) ](#backers)[![OpenCollective sponsors](https://camo.githubusercontent.com/56fae6f971459ac67392dc4cadf8378890240451a0cbac21a1ef721ee5cbc404/68747470733a2f2f696d672e736869656c64732e696f2f6f70656e636f6c6c6563746976652f73706f6e736f72732f6368656572696f) ](#sponsors)[![OpenSSF Scorecard](https://camo.githubusercontent.com/d6c376da6f92da14b37a0e9b7db4ec69969cd18f27288a1e663e0455654217f6/68747470733a2f2f6170692e73636f7265636172642e6465762f70726f6a656374732f6769746875622e636f6d2f6368656572696f6a732f6368656572696f2f6261646765)](https://scorecard.dev/viewer/?uri=github.com/cheeriojs/cheerio)\n\n  \n\n[中文文档 (Chinese Readme)](https://github.com/cheeriojs/cheerio/wiki/Chinese-README)\n\nimport \\* as cheerio from 'cheerio';\nconst $ \\= cheerio.load('<h2 class=\"title\">Hello world</h2>');\n\n$('h2.title').text('Hello there!');\n$('h2').addClass('welcome');\n\n$.html();\n//=> <html><head></head><body><h2 class=\"title welcome\">Hello there!</h2></body></html>\n\n## Installation\n\n[](#installation)\n\nInstall Cheerio using a package manager like npm, yarn, or bun.\n\nnpm install cheerio\n# or\nbun add cheerio\n\n## Features\n\n[](#features)\n\n**❤ Proven syntax:** Cheerio implements a subset of core jQuery. Cheerio removes all the DOM inconsistencies and browser cruft from the jQuery library, revealing its truly gorgeous API.\n\n**ϟ Blazingly fast:** Cheerio works with a very simple, consistent DOM model. As a result parsing, manipulating, and rendering are incredibly efficient.\n\n**❁ Incredibly flexible:** Cheerio wraps around [parse5](https://github.com/inikulin/parse5) for parsing HTML and can optionally use the forgiving [htmlparser2](https://github.com/fb55/htmlparser2/). Cheerio can parse nearly any HTML or XML document. Cheerio works in both browser and server environments.\n\n## API\n\n[](#api)\n\n### Loading\n\n[](#loading)\n\nFirst you need to load in the HTML. This step in jQuery is implicit, since jQuery operates on the one, baked-in DOM. With Cheerio, we need to pass in the HTML document.\n\n// ESM or TypeScript:\nimport \\* as cheerio from 'cheerio';\n\n// In other environments:\nconst cheerio \\= require('cheerio');\n\nconst $ \\= cheerio.load('<ul id=\"fruits\">...</ul>');\n\n$.html();\n//=> <html><head></head><body><ul id=\"fruits\">...</ul></body></html>\n\n### Selectors\n\n[](#selectors)\n\nOnce you've loaded the HTML, you can use jQuery-style selectors to find elements within the document.\n\n#### $( selector, \\[context\\], \\[root\\] )\n\n[](#-selector-context-root-)\n\n`selector` searches within the `context` scope which searches within the `root` scope. `selector` and `context` can be a string expression, DOM Element, array of DOM elements, or cheerio object. `root`, if provided, is typically the HTML document string.\n\nThis selector method is the starting point for traversing and manipulating the document. Like in jQuery, it's the primary method for selecting elements in the document.\n\n$('.apple', '#fruits').text();\n//=> Apple\n\n$('ul .pear').attr('class');\n//=> pear\n\n$('li\\[class=orange\\]').html();\n//=> Orange\n\n### Rendering\n\n[](#rendering)\n\nWhen you're ready to render the document, you can call the `html` method on the \"root\" selection:\n\n$.root().html();\n//=>  <html>\n//      <head></head>\n//      <body>\n//        <ul id=\"fruits\">\n//          <li class=\"apple\">Apple</li>\n//          <li class=\"orange\">Orange</li>\n//          <li class=\"pear\">Pear</li>\n//        </ul>\n//      </body>\n//    </html>\n\nIf you want to render the [`outerHTML`](https://developer.mozilla.org/en-US/docs/Web/API/Element/outerHTML) of a selection, you can use the `outerHTML` prop:\n\n$('.pear').prop('outerHTML');\n//=> <li class=\"pear\">Pear</li>\n\nYou may also render the text content of a Cheerio object using the `text` method:\n\nconst $ \\= cheerio.load('This is <em>content</em>.');\n$('body').text();\n//=> This is content.\n\n### The \"DOM Node\" object\n\n[](#the-dom-node-object)\n\nCheerio collections are made up of objects that bear some resemblance to [browser-based DOM nodes](https://developer.mozilla.org/en-US/docs/Web/API/Node). You can expect them to define the following properties:\n\n-   `tagName`\n-   `parentNode`\n-   `previousSibling`\n-   `nextSibling`\n-   `nodeValue`\n-   `firstChild`\n-   `childNodes`\n-   `lastChild`\n\n## Screencasts\n\n[](#screencasts)\n\n[https://vimeo.com/31950192](https://vimeo.com/31950192)\n\n> This video tutorial is a follow-up to Nettut's \"How to Scrape Web Pages with Node.js and jQuery\", using cheerio instead of JSDOM + jQuery. This video shows how easy it is to use cheerio and how much faster cheerio is than JSDOM + jQuery.\n\n## Cheerio in the real world\n\n[](#cheerio-in-the-real-world)\n\nAre you using cheerio in production? Add it to the [wiki](https://github.com/cheeriojs/cheerio/wiki/Cheerio-in-Production)!\n\n## Sponsors\n\n[](#sponsors)\n\nDoes your company use Cheerio in production? Please consider [sponsoring this project](https://github.com/cheeriojs/cheerio?sponsor=1)! Your help will allow maintainers to dedicate more time and resources to its development and support.\n\n**Headlining Sponsors**\n\n [![Github](https://camo.githubusercontent. \"Github\")](https://github.com/)[![AirBnB](https://camo.githubusercontent. \"AirBnB\") ](https://www.airbnb.com/)[![HasData](https://camo.githubusercontent. \"HasData\")](https://hasdata.com)\n\n**Other Sponsors**\n\n [![OnlineCasinosSpelen](https://camo.githubusercontent. \"OnlineCasinosSpelen\")](https://onlinecasinosspelen.com)[![Nieuwe-Casinos.net](https://camo.githubusercontent. \"Nieuwe-Casinos.net\")](https://Nieuwe-Casinos.net)\n\n## Backers\n\n[](#backers)\n\n[Become a backer](https://github.com/cheeriojs/cheerio?sponsor=1) to show your support for Cheerio and help us maintain and improve this open source project.\n\n[![Vasy Kafidoff](https://camo.githubusercontent. \"Vasy Kafidoff\")](https://kafidoff.com)\n\n## License\n\n[](#license)\n\nMIT\n\n## About\n\nThe fast, flexible, and elegant library for parsing and manipulating HTML and XML.\n\n[cheerio.js.org](https://cheerio.js.org \"https://cheerio.js.org\")\n\n### Topics\n\n[html](/topics/html \"Topic: html\") [jquery](/topics/jquery \"Topic: jquery\") [parser](/topics/parser \"Topic: parser\") [scraper](/topics/scraper \"Topic: scraper\") [dom](/topics/dom \"Topic: dom\") [cheerio](/topics/cheerio \"Topic: cheerio\") [selector](/topics/selector \"Topic: selector\") [hacktoberfest](/topics/hacktoberfest \"Topic: hacktoberfest\") [htmlparser2](/topics/htmlparser2 \"Topic: htmlparser2\") [htmlparser](/topics/htmlparser \"Topic: htmlparser\")\n\n### Resources\n\n[Readme](#readme-ov-file)\n\n### License\n\n[MIT license](#MIT-1-ov-file)\n\n### Contributing\n\n[Contributing](#contributing-ov-file)\n\n### Security policy\n\n[Security policy](#security-ov-file)\n\n### Uh oh!\n\nThere was an error while loading. Please reload this page.\n\n[Activity](/cheeriojs/cheerio/activity)\n\n[Custom properties](/cheeriojs/cheerio/custom-properties)\n\n### Stars\n\n**30.4k** stars\n\n### Watchers\n\n**343** watching\n\n### Forks\n\n[**1.7k** forks](/cheeriojs/cheerio/forks)\n\n[Report repository](/contact/report-content?content_url=https%3A%2F%2Fgithub.com%2Fcheeriojs%2Fcheerio&report=cheeriojs+%28user%29)\n\n## [Releases 62](/cheeriojs/cheerio/releases)\n\n[\n\nv1.2.0 Latest\n\nJan 23, 2026\n\n\n\n](/cheeriojs/cheerio/releases/tag/v1.2.0)\n\n[\\+ 61 releases](/cheeriojs/cheerio/releases)\n\n## Sponsor this project\n\n  ### Uh oh!\n\nThere was an error while loading. Please reload this page.\n\n-    ![open_collective](https://github.githubassets.com/assets/open_collective-0a706523753d.svg)[opencollective.com/**cheerio**](https://opencollective.com/cheerio)\n\n[Learn more about GitHub Sponsors](/sponsors)\n\n## [Used by 1.8m](/