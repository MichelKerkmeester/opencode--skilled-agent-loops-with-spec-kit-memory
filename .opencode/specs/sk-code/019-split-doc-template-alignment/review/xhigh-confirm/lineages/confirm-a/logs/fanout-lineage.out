onfig.json','deep-review-state.jsonl','deep-review-findings-registry.json','deep-review-strategy.md','deep-review-dashboard.md','review-report.md','resource-map.md']) if(!existsSync(root+'/'+f)) fail.push('missing '+f); console.log(JSON.stringify({ok:fail.length===0,failures:fail,status:registry.status,iterations:iterations.length,findings:registry.findingsBySeverity,searchDebt:registry.searchDebt.length,lockReleased:!existsSync(root+'/.deep-review.lock')})); process.exit(fail.length?2:0);\"","timeout":120000,"workdir":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public"},"output":"{\"ok\":true,\"failures\":[],\"status\":\"COMPLETE\",\"iterations\":4,\"findings\":{\"P0\":0,\"P1\":0,\"P2\":3},\"searchDebt\":1,\"lockReleased\":true}\n","metadata":{"output":"{\"ok\":true,\"failures\":[],\"status\":\"COMPLETE\",\"iterations\":4,\"findings\":{\"P0\":0,\"P1\":0,\"P2\":3},\"searchDebt\":1,\"lockReleased\":true}\n","exit":0,"truncated":false},"title":"bun -e \"import { existsSync, readFileSync } from 'node:fs'; const root='.opencode/specs/sk-code/019-split-doc-template-alignment/review/xhigh-confirm/lineages/confirm-a'; const fail=[]; const config=JSON.parse(readFileSync(root+'/deep-review-config.json','utf8')); const records=readFileSync(root+'/deep-review-state.jsonl','utf8').trim().split(/\\n/).map((line,i)=>{try{return JSON.parse(line)}catch{fail.push('bad jsonl line '+(i+1));return null}}).filter(Boolean); const iterations=records.filter(r=>r.type==='iteration'); const registry=JSON.parse(readFileSync(root+'/deep-review-findings-registry.json','utf8')); if(config.status!=='complete'||config.stopReason!=='maxIterationsReached'||config.releaseReadinessState!=='converged') fail.push('config'); if(iterations.length!==4) fail.push('iterations'); if(!Object.values(registry.dimensionCoverage).every(Boolean)||registry.openFindingsCount!==3||registry.corruptionWarnings.length!==0) fail.push('registry'); if(!records.some(r=>r.event==='synthesis_complete'&&r.verdict==='CONDITIONAL')) fail.push('synthesis'); if(!records.some(r=>r.event==='lock_released')) fail.push('release event'); if(existsSync(root+'/.deep-review.lock')) fail.push('lock remains'); for(let n=1;n<=4;n++){const r=iterations.find(x=>x.iteration===n); const d=JSON.parse(readFileSync(root+'/deltas/iter-'+String(n).padStart(3,'0')+'.jsonl','utf8').split(/\\n/)[0]); const s={...r}; for(const k of ['logOffset','logSize','logPath']) delete s[k]; if(JSON.stringify(s)!==JSON.stringify(d)) fail.push('delta '+n); const final=readFileSync(root+'/iterations/iteration-'+String(n).padStart(3,'0')+'.md','utf8').trimEnd().split(/\\n/).at(-1); if(!/^Review verdict: (PASS|CONDITIONAL|FAIL)$/.test(final)) fail.push('verdict '+n)} for(const f of ['deep-review-config.json','deep-review-state.jsonl','deep-review-findings-registry.json','deep-review-strategy.md','deep-review-dashboard.md','review-report.md','resource-map.md']) if(!existsSync(root+'/'+f)) fail.push('missing '+f); console.log(JSON.stringify({ok:fail.length===0,failures:fail,status:registry.status,iterations:iterations.length,findings:registry.findingsBySeverity,searchDebt:registry.searchDebt.length,lockReleased:!existsSync(root+'/.deep-review.lock')})); process.exit(fail.length?2:0);\"","time":{"start":1783924894370,"end":1783924894372}},"metadata":{"openai":{"itemId":"fc_0ab486f276423bb7016a54889df87c8191bdc2c84c98bcb925"}},"id":"prt_f5a35a9be001zik3S0ZSY9EvWu","sessionID":"ses_0a6050605ffekKPL0ZIbz84Q5J","messageID":"msg_f5a353f59001eV0XBktQ3PwHwa"}}
