{"type":"tool_use","timestamp":1781762513105,"sessionID":"ses_126b15e64ffeXip2YXWt9pDpCA","part":{"type":"tool","tool":"read","callID":"call_zbogvjFATmVsluf8x2IuIEtK","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","offset":1830,"limit":40},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts</path>\n<type>file</type>\n<content>\n1830:     // tier rather than by deletion, and constitutional rows are exempt so always-\n1831:     // surfaced rules can carry intentional duplicates. COALESCE keeps NULL-tier rows\n1832:     // (treated as active everywhere else) inside the guard and groups unscoped rows\n1833:     // together. A pre-existing DB may already hold duplicate active logical keys (created\n1834:     // before this guard existed). The pre-pass below retires those duplicates first —\n1835:     // deprecate, never delete — so the UNIQUE index can be built; otherwise the CREATE\n1836:     // would throw and roll back the whole shared migration transaction, wedging the upgrade.\n1837:     deprecateDuplicateActiveLogicalKeysBeforeUniqueIndex(database);\n1838:     createRequiredIndex(\n1839:       database,\n1840:       'idx_memory_logical_key_active_unique',\n1841:       `CREATE UNIQUE INDEX IF NOT EXISTS idx_memory_logical_key_active_unique\n1842:          ON memory_index (\n1843:            spec_folder,\n1844:            COALESCE(NULLIF(canonical_file_path, ''), file_path),\n1845:            COALESCE(NULLIF(TRIM(anchor_id), ''), '_'),\n1846:            COALESCE(tenant_id, ''),\n1847:            COALESCE(user_id, ''),\n1848:            COALESCE(agent_id, ''),\n1849:            COALESCE(session_id, '')\n1850:          )\n1851:          WHERE COALESCE(importance_tier, 'normal') NOT IN ('constitutional', 'deprecated')