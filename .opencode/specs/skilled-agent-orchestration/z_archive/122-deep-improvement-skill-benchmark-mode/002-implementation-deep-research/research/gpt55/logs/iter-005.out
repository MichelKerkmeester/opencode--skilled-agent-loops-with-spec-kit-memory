   237	function aggregateFailureModes(fixtures) {
   238	  const counts = {};
   239	  for (const fixture of fixtures) {
   240	    for (const mode of fixture.failureModes || []) {
   241	      counts[mode] = (counts[mode] || 0) + 1;
