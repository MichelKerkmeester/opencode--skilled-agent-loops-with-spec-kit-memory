{"type":"tool_use","timestamp":1780925673688,"sessionID":"ses_158903c24ffeYh4HmE3B8vB3CW","part":{"type":"tool","tool":"read","callID":"call_eIlKFb1nYwYtewnLxMJQm4tf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/lib/writeQueue.ts","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/lib/writeQueue.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * writeQueue.ts — Serialises all DB writes through a promise-chain queue.\n3:  * Prevents concurrent write corruption (W12).\n4:  */\n5: import type { Database } from \"bun:sqlite\";\n6: \n7: export class WriteQueue {\n8:   private tail: Promise<unknown> = Promise.resolve();\n9: \n10:   enqueue<T>(fn: () => T | Promise<T>, db?: Database): Promise<T> {\n11:     const next = this.tail.then(async () => {\n12:       if (!db) return fn();\n13:       db.exec(\"BEGIN IMMEDIATE\");\n14:       try {\n15:         const result = await Promise.resolve(fn());\n16:         db.exec(\"COMMIT\");\n17:         return result;\n18:       } catch (err) {\n19:         try { db.exec(\"ROLLBACK\"); } catch {}\n20:         throw err;\n21:       }\n22:     });\n23:     this.tail = next.catch(() => {}); // prevent unhandled rejection on queue\n24:     return next as Promise<T>;\n25:   }\n26: }\n27: \n28: export const writeQueue = new WriteQueue();\n\n(End of file - total 28 lines)\n</content>","metadata":{"preview":"/**\n * writeQueue.ts — Serialises all DB writes through a promise-chain queue.\n * Prevents concurrent write corruption (W12).\n */\nimport type { Database } from \"bun:sqlite\";\n\nexport class WriteQueue {\n  private tail: Promise<unknown> = Promise.resolve();\n\n  enqueue<T>(fn: () => T | Promise<T>, db?: Database): Promise<T> {\n    const next = this.tail.then(async () => {\n      if (!db) return fn();\n      db.exec(\"BEGIN IMMEDIATE\");\n      try {\n        const result = await Promise.resolve(fn());\n        db.exec(\"COMMIT\");\n        return result;\n      } catch (err) {\n        try { db.exec(\"ROLLBACK\"); } catch {}\n        throw err;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/lib/writeQueue.ts","text":"/**\n * writeQueue.ts — Serialises all DB writes through a promise-chain queue.\n * Prevents concurrent write corruption (W12).\n */\nimport type { Database } from \"bun:sqlite\";\n\nexport class WriteQueue {\n  private tail: Promise<unknown> = Promise.resolve();\n\n  enqueue<T>(fn: () => T | Promise<T>, db?: Database): Promise<T> {\n    const next = this.tail.then(async () => {\n      if (!db) return fn();\n      db.exec(\"BEGIN IMMEDIATE\");\n      try {\n        const result = await Promise.resolve(fn());\n        db.exec(\"COMMIT\");\n        return result;\n      } catch (err) {\n        try { db.exec(\"ROLLBACK\"); } catch {}\n        throw err;\n      }\n    });\n    this.tail = next.catch(() => {}); // prevent unhandled rejection on queue\n    return next as Promise<T>;\n  }\n}\n\nexport const writeQueue = new WriteQueue();","lineStart":1,"lineEnd":28,"totalLines":28,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/lib/writeQueue.ts","time":{"start":1780925673672,"end":1780925673685}},"metadata":{"openai":{"itemId":"fc_02e049c83abea259016a26c4e98e108198b0b54f006e7c251f"}},"id":"prt_ea77130bc001TagdNTNeBupeUL","sessionID":"ses_158903c24ffeYh4HmE3B8vB3CW","messageID":"msg_ea771132e001W6FBrXrN5939Wj"}}
