     2	title: "Advisor Scorer: Lane Attribution and Confidence Calibration"
     3	description: "Reference for the skill advisor's 5-lane scoring system, lane attribution assembly, confidence thresholds and prompt-safety boundaries."
     4	trigger_phrases:
     5	  - "advisor scorer lanes"
     6	  - "lane attribution"
