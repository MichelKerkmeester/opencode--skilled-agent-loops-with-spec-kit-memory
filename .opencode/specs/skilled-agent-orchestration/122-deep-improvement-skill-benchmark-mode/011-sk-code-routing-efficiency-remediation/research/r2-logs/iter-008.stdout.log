ad Hit@k/Recall@k/MRR\"\n162:         },\n163:         \"d3\": {\n164:           \"score\": 0.3125,\n165:           \"routedCount\": 16,\n166:           \"wastedCount\": 11,\n167:           \"proxy\": \"router-overload\",\n168:           \"note\": \"Mode A proxy; live-mode replaces with calls/tokens-to-first-expected\"\n169:         },\n170:         \"d1inter\": {\n171:           \"score\": null,\n172:           \"unscored\": \"no advisor probe (run with --advisor-mode=python)\"\n173:         },\n174:         \"d4\": {\n175:           \"score\": null,\n176:           \"unscored\": \"requires skill-on/off ablation (live mode)\"\n177:         }\n178:       },\n179:       \"firstFailingStage\": null,\n180:       \"modeAScore\": 79,\n181:       \"applicable\": true,\n182:       \"classKind\": \"routing\",\n183:       \"expectedSurface\": \"OPENCODE\",\n184:       \"observedSurface\": \"OPENCODE\",\n185:       \"surfaceMatch\": true,\n186:       \"traceMode\": \"live\",\n187:       \"liveEvidence\": {\n188:         \"eventCount\": 21,\n189:         \"activated\": true,\n190:         \"toolCalls\": [\n191:           \"mk-spec-memory_memory_match_triggers\",\n192:           \"skill\",\n193:           \"read\",\n194:           \"read\",\n195:           \"glob\",\n196:           \"glob\",\n197:           \"glob\",\n198:           \"glob\",\n199:           \"glob\",\n200:           \"read\"\n201:         ],\n202:         \"observedReads\": [\n203:           \"references/smart_routing.md\",\n204:           \"references/stack_detection.md\",\n205:           \"assets/opencode/**/*.md\",\n206:           \"references/opencode/**/*.md\",\n207:           \"references/universal/**/*.md\",\n208:           \"assets/scripts/*\",\n209:           \"references/universal/*.md\",\n210:           \"references/phase_detection.md\"\n211:         ],\n212:         \"statedRoutingParsed\": true,\n213:         \"responseHead\": \"```json\\n{\\\"surface\\\":\\\"OPENCODE\\\",\\\"subLanguage\\\":\\\"T