ceKind') return normalized === 'feedback';\n713:   if (field === 'artifact_type' || field === 'artifactType') return reservedFeedbackArtifactTypes.has(normalized);\n714:   return reservedFeedbackEventTypes.has(normalized) || reservedFeedbackArtifactTypes.has(normalized);\n715: }\n716: \n717: function findReservedFeedbackWrite(rawInput: Record<string, unknown>): { field: string; value: unknown } | null {\n718:   for (const [field, value] of Object.entries(rawInput)) {\n719:     if (reservedFeedbackFields.has(field) && isReservedFeedbackValue(field, value)) {\n720:       return { field, value };\n721:     }\n722: \n723:     if (field === '__provenanceContext' && value && typeof value === 'object' && !Array.isArray(value)) {\n724:       const provenance = value as Record<string, unknown>;\n725:       for (const provenanceField of ['source_kind', 'sourceKind', 'provenanceSource', 'provenance_source']) {\n726:         if (isReservedFeedbackValue(provenanceField, provenance[provenanceField])) {\n727:           return { field: `__provenanceContext.${provenanceField}`, value: provenance[provenanceField] };\n728:         }\n729:       }\n730:     }\n731:   }\n732:   return null;\n733: }\n734: \n735: function rejectReservedFeedbackWrites(toolName: string, rawInput: Record<string, unknown>): void {\n736:   if (!publicMemoryWriteTools.has(toolName)) return;\n737:   const reserved = findReservedFeedbackWrite(rawInput);\n738:   if (!reserved) return;\n739:   throw new ReservedFeedbackTypeValidationError(toolName, reserved.field, reserved.value);\n740: }\n741: \n742: export function formatZodError(toolName: string, error: ZodError): ToolSchemaValidationError {\n743:   const allowed = ALLOWED_PARAMETERS[toolName] ?? [];\n744:   const lines: string[] = [];\n745:   const unknownKeys = new Set<string>();\n746:   const issueSummaries: string[] = [];\n747: \n748:   for (const issue of error.issues) {\n749:     const path = issue.path.length > 0 ? issue.path.join('.') : '<root>';\n750:  