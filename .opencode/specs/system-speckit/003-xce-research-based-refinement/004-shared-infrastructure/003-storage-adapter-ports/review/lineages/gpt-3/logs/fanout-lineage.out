\"scripts\": {\n    \"clean\": \"node -e \\\"require('node:fs').rmSync('dist', { recursive: true, force: true })\\\"\",\n    \"build\": \"tsc --build && node scripts/finalize-dist.mjs\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/package.json","text":"{\n  \"name\": \"@spec-kit/mcp-server\",\n  \"version\": \"1.8.0\",\n  \"description\": \"Semantic Memory MCP Server - provides 37 tools for semantic search, memory management, validation, embedder control, checkpoints, causal graphs, session learning, and auto-indexing\",\n  \"type\": \"module\",\n  \"main\": \"dist/api/index.js\",\n  \"exports\": {\n    \".\": \"./dist/api/index.js\",\n    \"./server\": \"./dist/context-server.js\",\n    \"./api\": \"./dist/api/index.js\",\n    \"./api/*\": \"./dist/api/*.js\"\n  },\n  \"bin\": {\n    \"context-server\": \"./dist/context-server.js\",\n    \"spec-kit-cli\": \"./dist/cli.js\",\n    \"spec-memory\": \"./dist/spec-memory-cli.js\"\n  },\n  \"scripts\": {\n    \"clean\": \"node -e \\\"require('node:fs').rmSync('dist', { recursive: true, force: true })\\\"\",\n    \"build\": \"tsc --build && node scripts/finalize-dist.mjs\",\n    \"rebuild\": \"npm run clean && npm run build\",\n    \"typecheck\": \"tsc --noEmit --composite false -p tsconfig.json\",\n    \"start\": \"node dist/context-server.js\",\n    \"check\": \"npm run lint && npx tsc --noEmit\",\n    \"check:full\": \"npm run check && npm run test\",\n    \"lint\": \"eslint . --ext .ts\",\n    \"test\": \"node scripts/run-tests.mjs\",\n    \"test:core\": \"vitest run\",\n    \"test:file-watcher\": \"vitest run tests/file-watcher.vitest.ts\",\n    \"test:council\": \"vitest run tests/multi-ai-council-runtime-parity.vitest.ts tests/multi-ai-council-permission-scope.vitest.ts tests/multi-ai-council-audit-trail.vitest.ts tests/multi-ai-council-rollback.vitest.ts ../../deep-loop-runtime/tests/integration/council-graph-script.vitest.ts ../../deep-loop-runtime/tests/integration/council-graph-value-scenarios.vitest.ts tests/council-playbook-anchor-integrity.vitest.ts tests/council-helpers-smoke.vitest.ts ../scripts/tests/multi-ai-council-persist-artifacts.vitest.ts skill_advisor/tests/scorer/native-scorer.vitest.ts\",\n    \"test:council:full\": \"bash ../scripts/test-council-matrix.sh\",\n    \"hook-tests\": \"node --import ../scripts/node_modules/tsx/dist/loader.mjs ../../../../specs/system-spec-kit/026-graph-and-context-optimization/000-release-and-program-cleanup/003-cross-cutting-cleanup-pass/016-runtime-hook-plugin-testing/runners/run-all-runtime-hooks.ts\",\n    \"stress\": \"vitest run --config vitest.stress.config.ts\",\n    \"stress:harness\": \"vitest run --config vitest.stress.config.ts mcp_server/stress_test/search-quality\",\n    \"stress:matrix\": \"vitest run --config vitest.stress.config.ts mcp_server/stress_test/matrix\",\n    \"stress:substrate\": \"vitest run --config vitest.stress.config.ts mcp_server/stress_test/substrate\",\n    \"stress:durability\": \"vitest run --config vitest.stress.config.ts mcp_server/stress_test/durability\",\n    \"test:task-enrichment\": \"echo 'Task-enrichment tests run in @spec-kit/scripts workspace'\",\n    \"test:hydra:phase1\": \"vitest run tests/memory-roadmap-flags.vitest.ts tests/memory-state-baseline.vitest.ts tests/migration-checkpoint-scripts.vitest.ts tests/vector-index-schema-compatibility.vitest.ts\",\n    \"test:watch\": \"vitest\",\n    \"bench:watcher\": \"node dist/skill_advisor/bench/watcher-benchmark.js\",\n    \"setup:codex-policy\": \"node dist/hooks/codex/setup.js\"\n  },\n  \"keywords\": [\n    \"mcp\",\n    \"claude\",\n    \"semantic-memory\",\n    \"vector-search\",\n    \"auto-indexing\"\n  ],\n  \"author\": \"Michel Kerkmeester\",\n  \"license\": \"MIT\",\n  \"engines\": {\n    \"node\": \">=20.11.0\"\n  },\n  \"dependencies\": {\n    \"@huggingface/transformers\": \"^3.8.1\",\n    \"@modelcontextprotocol/sdk\": \"^1.24.3\",\n    \"@spec-kit/shared\": \"file:../shared\",\n    \"better-sqlite3\": \"^12.6.2\",\n    \"chokidar\": \"^4.0.3\",\n    \"ignore\": \"^5.3.2\",\n    \"sqlite-vec\": \"^0.1.7-alpha.2\",\n    \"tree-sitter-wasms\": \"^0.1.13\",\n    \"web-tree-sitter\": \"^0.24.7\",\n    \"zod\": \"^4.1.12\",\n    \"zod-to-json-schema\": \"^3.25.2\"\n  },\n  \"optionalDependencies\": {\n    \"sqlite-vec-darwin-arm64\": \"^0.1.7-alpha.2\"\n  },\n  \"devDependencies\": {\n    \"@types/better-sqlite3\": \"^7.6.13\",\n    \"@vitest/coverage-v8\": \"^4.1.2\",\n    \"eslint\": \"^9.39.1\",\n    \"globals\": \"^16.4.0\",\n    \"typescript\": \"^5.9.3\",\n    \"typescript-eslint\": \"^8.46.3\",\n    \"vitest\": \"^4.0.18\"\n  }\n}","lineStart":1,"lineEnd":81,"totalLines":81,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/package.json","time":{"start":1781144334002,"end":1781144334005}},"metadata":{"openai":{"itemId":"fc_09160ba3f6693847016a2a1b0d89bc819184d35c5e93750c49"}},"id":"prt_eb479ace8001N24lSaBck89Neu","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb479921a001ecjSGKOyAPyZZT"}}
