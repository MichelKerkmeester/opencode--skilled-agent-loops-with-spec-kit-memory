{"type":"text","timestamp":1781763110632,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"id":"prt_ed95b5d18001H5Ssh6OzTjJvtw","messageID":"msg_ed95b516a001WOShyKIceSyVWM","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","type":"text","text":"The IPC wrapper re-exports the shared socket implementation, so the evidence pass follows that canonical shared file plus the CLI/launcher shims that bind to it.","time":{"start":1781763104024,"end":1781763110629},"metadata":{"openai":{"itemId":"msg_08430863c6a3580e016a338c1fff0081919b7d3fde4304d8d3","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781763110700,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_bBYtuRwrGj7yRXC4qMdEjYYd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","offset":180,"limit":340},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts</path>\n<type>file</type>\n<content>\n180:   return candidate.startsWith(prefix);\n181: }\n182: \n183: // Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n184: // The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n185: // `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n186: // `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n187: // the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n188: // `canUnlinkExistingSocket` preserves the unlink-hardening intent.\n189: function allowedSocketRoots(): string[] {\n190:   const roots = new Set<string>();\n191:   roots.add(canonicalizePath(process.cwd()));\n192:   roots.add(canonicalizePath(os.tmpdir()));\n193:   roots.add(canonicalizePath('/tmp'));\n194:   return [...roots];\n195: }\n196: \n197: function isWithinAllowedSocketRoot(candidate: string): boolean {\n198:   return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n199: }\n200: \n201: function resolveIpcSocketPath(dbDir: string): string {\n202:   const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n203:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n204:     : path.resolve(dbDir);\n205:   const socketDir = canonicalizePath(rawSocketDir);\n206:   if (!isWithinAllowedSocketRoot(socketDir)) {\n207:     throw new Error(\n208:       `IPC socket directory must stay within the workspace root or a system temp dir: ${socketDir}`,\n209:     );\n210:   }\n211:   return path.join(socketDir, SOCKET_FILE_NAME);\n212: }\n213: \n214: // Only remove a stale socket at `socketPath` when it is provably ours: the parent dir resolves\n215: // inside an allowed root, the path is an actual socket, and it is owned by the current uid.\n216: // Guards against socket-hijack on shared hosts where an attacker plants a non-socket file or a\n217: // socket they own at the bind path.\n218: function canUnlinkExistingSocket(socketPath: string): boolean {\n219:   let parent: string;\n220:   try {\n221:     parent = fs.realpathSync.native(path.dirname(socketPath));\n222:   } catch (error: unknown) {\n223:     // A racing peer can remove the socket directory between the EADDRINUSE failure and this\n224:     // resolve; a vanished node is safe to reclaim, so never abort the bind on a missing path.\n225:     if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n226:       return true;\n227:     }\n228:     throw error;\n229:   }\n230:   if (!isWithinAllowedSocketRoot(parent)) {\n231:     return false;\n232:   }\n233:   try {\n234:     const stat = fs.lstatSync(socketPath);\n235:     if (!stat.isSocket()) {\n236:       return false;\n237:     }\n238:     if (typeof process.getuid === 'function' && stat.uid !== process.getuid()) {\n239:       return false;\n240:     }\n241:     return true;\n242:   } catch (error: unknown) {\n243:     // Same race on the socket node itself: if it is already gone the prior EADDRINUSE was\n244:     // transient, so treat the path as reclaimable instead of throwing and orphaning the bind.\n245:     if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n246:       return true;\n247:     }\n248:     throw error;\n249:   }\n250: }\n251: \n252: function getIpcBridgeStats(): IpcBridgeStats {\n253:   return {\n254:     socket_path: activeSocketPath,\n255:     secondary_clients_count: activeSockets.size,\n256:     total_secondary_messages_in: totalSecondaryMessagesIn,\n257:     total_secondary_messages_out: totalSecondaryMessagesOut,\n258:   };\n259: }\n260: \n261: async function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n262:   await new Promise<void>((resolve, reject) => {\n263:     const onError = (error: NodeJS.ErrnoException) => {\n264:       server.off('listening', onListening);\n265:       reject(error);\n266:     };\n267:     const onListening = () => {\n268:       server.off('error', onError);\n269:       resolve();\n270:     };\n271:     server.once('error', onError);\n272:     server.once('listening', onListening);\n273:     if (socketPath.startsWith('tcp://')) {\n274:       const url = new URL(socketPath);\n275:       server.listen(Number.parseInt(url.port, 10), url.hostname);\n276:       return;\n277:     }\n278:     server.listen(socketPath);\n279:   });\n280: }\n281: \n282: // TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n283: // unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n284: // few times before giving up. Returns true once a retry binds, false if the port stays in use.\n285: async function retryTcpListenAfterEaddrInUse(\n286:   server: net.Server,\n287:   socketPath: string,\n288:   log: (message: string) => void,\n289: ): Promise<boolean> {\n290:   for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n291:     log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n292:     await sleep(delayMs);\n293:     try {\n294:       await listenOnce(server, socketPath);\n295:       return true;\n296:     } catch (error: unknown) {\n297:       const err = error as NodeJS.ErrnoException;\n298:       if (err.code !== 'EADDRINUSE') {\n299:         throw err;\n300:       }\n301:     }\n302:   }\n303:   return false;\n304: }\n305: \n306: // Tear down any server still registered in the module-global slots before a new bind reuses them.\n307: // startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n308: // dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n309: // shared stats. Re-entrancy must close the prior server first.\n310: async function disposeActiveServer(): Promise<void> {\n311:   const priorServer = activeServer;\n312:   for (const socket of activeSockets) {\n313:     socket.destroy();\n314:   }\n315:   activeSockets.clear();\n316:   activeTransports.clear();\n317:   if (priorServer) {\n318:     await new Promise<void>((resolve) => {\n319:       priorServer.close(() => resolve());\n320:     });\n321:   }\n322:   activeServer = null;\n323:   activeSocketPath = null;\n324: }\n325: \n326: async function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n327:   if (activeServer) {\n328:     await disposeActiveServer();\n329:   }\n330:   const socketPath = options.socketPath.startsWith('tcp://')\n331:     ? options.socketPath\n332:     : path.resolve(options.socketPath);\n333:   const log = options.log ?? ((message: string) => console.error(message));\n334:   const maxClients = options.maxClients ?? parseMaxClients();\n335:   const onActivity = options.onActivity ?? (() => undefined);\n336:   if (!socketPath.startsWith('tcp://')) {\n337:     const socketDir = path.dirname(socketPath);\n338:     fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n339:     // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n340:     // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n341:     // so refuse to bind under a dir not owned by us or that is group/world-writable.\n342:     try {\n343:       const st = fs.statSync(socketDir);\n344:       const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n345:       if (uid !== null && st.uid !== uid) {\n346:         throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n347:       }\n348:       if ((st.mode & 0o022) !== 0) {\n349:         throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n350:       }\n351:     } catch (error: unknown) {\n352:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n353:       if (code !== 'ENOENT') throw error;\n354:     }\n355:     // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n356:     // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n357:     // protection so a symlink whose target we would later chmod cannot be used to redirect the\n358:     // permission change onto an arbitrary file.\n359:     try {\n360:       const linkStat = fs.lstatSync(socketPath);\n361:       if (linkStat.isSymbolicLink()) {\n362:         throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n363:       }\n364:     } catch (error: unknown) {\n365:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n366:       if (code !== 'ENOENT') throw error;\n367:     }\n368:   }\n369: \n370:   const server = net.createServer((socket) => {\n371:     if (activeSockets.size >= maxClients) {\n372:       // A bare close here is indistinguishable from a dead daemon to a liveness\n373:       // probe, which makes a sibling launcher reap a healthy-but-cap-saturated\n374:       // daemon. Give the connection a brief window to send its first frame: if it\n375:       // is a liveness probe, answer it (proving the daemon alive) and close WITHOUT\n376:       // occupying a durable slot; only refuse genuine bridge clients at the cap.\n377:       answerProbeOrRefuseAtCap(socket, maxClients, log);\n378:       return;\n379:     }\n380: \n381:     activeSockets.add(socket);\n382:     onActivity();\n383:     log('[ipc-bridge] secondary connected pid=?');\n384: \n385:     const originalWrite = socket.write.bind(socket);\n386:     socket.write = ((chunk: unknown, ...args: unknown[]) => {\n387:       onActivity();\n388:       totalSecondaryMessagesOut += countJsonRpcFrames(chunk);\n389:       return originalWrite(chunk as string | Uint8Array, ...(args as [BufferEncoding?, (() => void)?]));\n390:     }) as typeof socket.write;\n391: \n392:     socket.on('data', (chunk) => {\n393:       onActivity();\n394:       totalSecondaryMessagesIn += countJsonRpcFrames(chunk);\n395:     });\n396: \n397:     const transport = new StdioServerTransport(socket, socket);\n398:     activeTransports.set(socket, transport);\n399:     const secondaryServer = options.createServer();\n400:     secondaryServer.connect(transport).catch((error: unknown) => {\n401:       const message = error instanceof Error ? error.message : String(error);\n402:       log(`[ipc-bridge] secondary connect error: ${message}`);\n403:       socket.destroy();\n404:     });\n405: \n406:     socket.once('close', () => {\n407:       activeSockets.delete(socket);\n408:       activeTransports.delete(socket);\n409:       void transport.close();\n410:       log('[ipc-bridge] disconnect');\n411:     });\n412:     socket.once('error', (error) => {\n413:       log(`[ipc-bridge] socket error: ${error.message}`);\n414:     });\n415:   });\n416: \n417:   try {\n418:     await listenOnce(server, socketPath);\n419:   } catch (error: unknown) {\n420:     const err = error as NodeJS.ErrnoException;\n421:     if (err.code !== 'EADDRINUSE') {\n422:       throw err;\n423:     }\n424:     if (socketPath.startsWith('tcp://')) {\n425:       // A TCP port in use cannot be reclaimed by unlinking; back off and retry a few times. If it\n426:       // never frees, run without the secondary bridge rather than aborting the whole daemon.\n427:       const listened = await retryTcpListenAfterEaddrInUse(server, socketPath, log);\n428:       if (!listened) {\n429:         log(`[ipc-bridge] tcp socket remained in use at ${socketPath}; secondary bridge disabled`);\n430:         return {\n431:           socketPath,\n432:           close: async () => {\n433:             for (const socket of activeSockets) {\n434:               socket.destroy();\n435:             }\n436:             activeSockets.clear();\n437:             activeTransports.clear();\n438:           },\n439:         };\n440:       }\n441:     } else {\n442:       // Unix socket path: only reclaim a stale node that is provably ours (the fence). On a benign\n443:       // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n444:       // as reclaimable, so we re-bind instead of aborting; a foreign-owned node still refuses.\n445:       if (!canUnlinkExistingSocket(socketPath)) {\n446:         throw err;\n447:       }\n448:       try {\n449:         fs.unlinkSync(socketPath);\n450:       } catch (unlinkError: unknown) {\n451:         const unlinkErr = unlinkError as NodeJS.ErrnoException;\n452:         if (unlinkErr.code !== 'ENOENT') {\n453:           throw unlinkErr;\n454:         }\n455:       }\n456:       await listenOnce(server, socketPath);\n457:     }\n458:   }\n459: \n460:   const address = server.address();\n461:   const listenedPath = typeof address === 'object' && address\n462:     ? `tcp://${address.address}:${address.port}`\n463:     : socketPath;\n464:   if (!socketPath.startsWith('tcp://')) {\n465:     // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n466:     // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n467:     const boundStat = fs.lstatSync(socketPath);\n468:     if (boundStat.isSymbolicLink() || !boundStat.isSocket()) {\n469:       throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n470:     }\n471:     fs.chmodSync(socketPath, 0o600);\n472:   }\n473:   activeServer = server;\n474:   activeSocketPath = listenedPath;\n475:   log(`[ipc-bridge] socket listening at ${listenedPath}`);\n476: \n477:   return {\n478:     socketPath: listenedPath,\n479:     close: async () => {\n480:       for (const socket of activeSockets) {\n481:         socket.destroy();\n482:       }\n483:       activeSockets.clear();\n484:       activeTransports.clear();\n485:       await new Promise<void>((resolve) => {\n486:         server.close(() => resolve());\n487:       });\n488:       if (activeServer === server) {\n489:         activeServer = null;\n490:         activeSocketPath = null;\n491:       }\n492:       if (!socketPath.startsWith('tcp://')) {\n493:         try {\n494:           fs.unlinkSync(socketPath);\n495:         } catch (error: unknown) {\n496:           const err = error as NodeJS.ErrnoException;\n497:           if (err.code !== 'ENOENT') {\n498:             throw err;\n499:           }\n500:         }\n501:       }\n502:     },\n503:   };\n504: }\n505: \n506: export {\n507:   canUnlinkExistingSocket,\n508:   getIpcBridgeStats,\n509:   parseMaxClients,\n510:   resolveIpcSocketPath,\n511:   startIpcSocketServer,\n512: };\n513: \n514: export type {\n515:   IpcBridgeStats,\n516:   IpcSocketServerHandle,\n517:   IpcSocketServerOptions,\n518: };\n\n(End of file - total 518 lines)\n</content>","metadata":{"preview":"  return candidate.startsWith(prefix);\n}\n\n// Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n// The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n// `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n// `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n// the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n// `canUnlinkExistingSocket` preserves the unlink-hardening intent.\nfunction allowedSocketRoots(): string[] {\n  const roots = new Set<string>();\n  roots.add(canonicalizePath(process.cwd()));\n  roots.add(canonicalizePath(os.tmpdir()));\n  roots.add(canonicalizePath('/tmp'));\n  return [...roots];\n}\n\nfunction isWithinAllowedSocketRoot(candidate: string): boolean {\n  return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","text":"  return candidate.startsWith(prefix);\n}\n\n// Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n// The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n// `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n// `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n// the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n// `canUnlinkExistingSocket` preserves the unlink-hardening intent.\nfunction allowedSocketRoots(): string[] {\n  const roots = new Set<string>();\n  roots.add(canonicalizePath(process.cwd()));\n  roots.add(canonicalizePath(os.tmpdir()));\n  roots.add(canonicalizePath('/tmp'));\n  return [...roots];\n}\n\nfunction isWithinAllowedSocketRoot(candidate: string): boolean {\n  return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n}\n\nfunction resolveIpcSocketPath(dbDir: string): string {\n  const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(dbDir);\n  const socketDir = canonicalizePath(rawSocketDir);\n  if (!isWithinAllowedSocketRoot(socketDir)) {\n    throw new Error(\n      `IPC socket directory must stay within the workspace root or a system temp dir: ${socketDir}`,\n    );\n  }\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\n// Only remove a stale socket at `socketPath` when it is provably ours: the parent dir resolves\n// inside an allowed root, the path is an actual socket, and it is owned by the current uid.\n// Guards against socket-hijack on shared hosts where an attacker plants a non-socket file or a\n// socket they own at the bind path.\nfunction canUnlinkExistingSocket(socketPath: string): boolean {\n  let parent: string;\n  try {\n    parent = fs.realpathSync.native(path.dirname(socketPath));\n  } catch (error: unknown) {\n    // A racing peer can remove the socket directory between the EADDRINUSE failure and this\n    // resolve; a vanished node is safe to reclaim, so never abort the bind on a missing path.\n    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n      return true;\n    }\n    throw error;\n  }\n  if (!isWithinAllowedSocketRoot(parent)) {\n    return false;\n  }\n  try {\n    const stat = fs.lstatSync(socketPath);\n    if (!stat.isSocket()) {\n      return false;\n    }\n    if (typeof process.getuid === 'function' && stat.uid !== process.getuid()) {\n      return false;\n    }\n    return true;\n  } catch (error: unknown) {\n    // Same race on the socket node itself: if it is already gone the prior EADDRINUSE was\n    // transient, so treat the path as reclaimable instead of throwing and orphaning the bind.\n    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n      return true;\n    }\n    throw error;\n  }\n}\n\nfunction getIpcBridgeStats(): IpcBridgeStats {\n  return {\n    socket_path: activeSocketPath,\n    secondary_clients_count: activeSockets.size,\n    total_secondary_messages_in: totalSecondaryMessagesIn,\n    total_secondary_messages_out: totalSecondaryMessagesOut,\n  };\n}\n\nasync function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n  await new Promise<void>((resolve, reject) => {\n    const onError = (error: NodeJS.ErrnoException) => {\n      server.off('listening', onListening);\n      reject(error);\n    };\n    const onListening = () => {\n      server.off('error', onError);\n      resolve();\n    };\n    server.once('error', onError);\n    server.once('listening', onListening);\n    if (socketPath.startsWith('tcp://')) {\n      const url = new URL(socketPath);\n      server.listen(Number.parseInt(url.port, 10), url.hostname);\n      return;\n    }\n    server.listen(socketPath);\n  });\n}\n\n// TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n// unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n// few times before giving up. Returns true once a retry binds, false if the port stays in use.\nasync function retryTcpListenAfterEaddrInUse(\n  server: net.Server,\n  socketPath: string,\n  log: (message: string) => void,\n): Promise<boolean> {\n  for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n    log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n    await sleep(delayMs);\n    try {\n      await listenOnce(server, socketPath);\n      return true;\n    } catch (error: unknown) {\n      const err = error as NodeJS.ErrnoException;\n      if (err.code !== 'EADDRINUSE') {\n        throw err;\n      }\n    }\n  }\n  return false;\n}\n\n// Tear down any server still registered in the module-global slots before a new bind reuses them.\n// startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n// dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n// shared stats. Re-entrancy must close the prior server first.\nasync function disposeActiveServer(): Promise<void> {\n  const priorServer = activeServer;\n  for (const socket of activeSockets) {\n    socket.destroy();\n  }\n  activeSockets.clear();\n  activeTransports.clear();\n  if (priorServer) {\n    await new Promise<void>((resolve) => {\n      priorServer.close(() => resolve());\n    });\n  }\n  activeServer = null;\n  activeSocketPath = null;\n}\n\nasync function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n  if (activeServer) {\n    await disposeActiveServer();\n  }\n  const socketPath = options.socketPath.startsWith('tcp://')\n    ? options.socketPath\n    : path.resolve(options.socketPath);\n  const log = options.log ?? ((message: string) => console.error(message));\n  const maxClients = options.maxClients ?? parseMaxClients();\n  const onActivity = options.onActivity ?? (() => undefined);\n  if (!socketPath.startsWith('tcp://')) {\n    const socketDir = path.dirname(socketPath);\n    fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n    // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n    // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n    // so refuse to bind under a dir not owned by us or that is group/world-writable.\n    try {\n      const st = fs.statSync(socketDir);\n      const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n      if (uid !== null && st.uid !== uid) {\n        throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n      }\n      if ((st.mode & 0o022) !== 0) {\n        throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n    // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n    // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n    // protection so a symlink whose target we would later chmod cannot be used to redirect the\n    // permission change onto an arbitrary file.\n    try {\n      const linkStat = fs.lstatSync(socketPath);\n      if (linkStat.isSymbolicLink()) {\n        throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n  }\n\n  const server = net.createServer((socket) => {\n    if (activeSockets.size >= maxClients) {\n      // A bare close here is indistinguishable from a dead daemon to a liveness\n      // probe, which makes a sibling launcher reap a healthy-but-cap-saturated\n      // daemon. Give the connection a brief window to send its first frame: if it\n      // is a liveness probe, answer it (proving the daemon alive) and close WITHOUT\n      // occupying a durable slot; only refuse genuine bridge clients at the cap.\n      answerProbeOrRefuseAtCap(socket, maxClients, log);\n      return;\n    }\n\n    activeSockets.add(socket);\n    onActivity();\n    log('[ipc-bridge] secondary connected pid=?');\n\n    const originalWrite = socket.write.bind(socket);\n    socket.write = ((chunk: unknown, ...args: unknown[]) => {\n      onActivity();\n      totalSecondaryMessagesOut += countJsonRpcFrames(chunk);\n      return originalWrite(chunk as string | Uint8Array, ...(args as [BufferEncoding?, (() => void)?]));\n    }) as typeof socket.write;\n\n    socket.on('data', (chunk) => {\n      onActivity();\n      totalSecondaryMessagesIn += countJsonRpcFrames(chunk);\n    });\n\n    const transport = new StdioServerTransport(socket, socket);\n    activeTransports.set(socket, transport);\n    const secondaryServer = options.createServer();\n    secondaryServer.connect(transport).catch((error: unknown) => {\n      const message = error instanceof Error ? error.message : String(error);\n      log(`[ipc-bridge] secondary connect error: ${message}`);\n      socket.destroy();\n    });\n\n    socket.once('close', () => {\n      activeSockets.delete(socket);\n      activeTransports.delete(socket);\n      void transport.close();\n      log('[ipc-bridge] disconnect');\n    });\n    socket.once('error', (error) => {\n      log(`[ipc-bridge] socket error: ${error.message}`);\n    });\n  });\n\n  try {\n    await listenOnce(server, socketPath);\n  } catch (error: unknown) {\n    const err = error as NodeJS.ErrnoException;\n    if (err.code !== 'EADDRINUSE') {\n      throw err;\n    }\n    if (socketPath.startsWith('tcp://')) {\n      // A TCP port in use cannot be reclaimed by unlinking; back off and retry a few times. If it\n      // never frees, run without the secondary bridge rather than aborting the whole daemon.\n      const listened = await retryTcpListenAfterEaddrInUse(server, socketPath, log);\n      if (!listened) {\n        log(`[ipc-bridge] tcp socket remained in use at ${socketPath}; secondary bridge disabled`);\n        return {\n          socketPath,\n          close: async () => {\n            for (const socket of activeSockets) {\n              socket.destroy();\n            }\n            activeSockets.clear();\n            activeTransports.clear();\n          },\n        };\n      }\n    } else {\n      // Unix socket path: only reclaim a stale node that is provably ours (the fence). On a benign\n      // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n      // as reclaimable, so we re-bind instead of aborting; a foreign-owned node still refuses.\n      if (!canUnlinkExistingSocket(socketPath)) {\n        throw err;\n      }\n      try {\n        fs.unlinkSync(socketPath);\n      } catch (unlinkError: unknown) {\n        const unlinkErr = unlinkError as NodeJS.ErrnoException;\n        if (unlinkErr.code !== 'ENOENT') {\n          throw unlinkErr;\n        }\n      }\n      await listenOnce(server, socketPath);\n    }\n  }\n\n  const address = server.address();\n  const listenedPath = typeof address === 'object' && address\n    ? `tcp://${address.address}:${address.port}`\n    : socketPath;\n  if (!socketPath.startsWith('tcp://')) {\n    // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n    // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n    const boundStat = fs.lstatSync(socketPath);\n    if (boundStat.isSymbolicLink() || !boundStat.isSocket()) {\n      throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n    }\n    fs.chmodSync(socketPath, 0o600);\n  }\n  activeServer = server;\n  activeSocketPath = listenedPath;\n  log(`[ipc-bridge] socket listening at ${listenedPath}`);\n\n  return {\n    socketPath: listenedPath,\n    close: async () => {\n      for (const socket of activeSockets) {\n        socket.destroy();\n      }\n      activeSockets.clear();\n      activeTransports.clear();\n      await new Promise<void>((resolve) => {\n        server.close(() => resolve());\n      });\n      if (activeServer === server) {\n        activeServer = null;\n        activeSocketPath = null;\n      }\n      if (!socketPath.startsWith('tcp://')) {\n        try {\n          fs.unlinkSync(socketPath);\n        } catch (error: unknown) {\n          const err = error as NodeJS.ErrnoException;\n          if (err.code !== 'ENOENT') {\n            throw err;\n          }\n        }\n      }\n    },\n  };\n}\n\nexport {\n  canUnlinkExistingSocket,\n  getIpcBridgeStats,\n  parseMaxClients,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n};\n\nexport type {\n  IpcBridgeStats,\n  IpcSocketServerHandle,\n  IpcSocketServerOptions,\n};","lineStart":180,"lineEnd":518,"totalLines":518,"truncated":false}},"title":".opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","time":{"start":1781763110686,"end":1781763110697}},"metadata":{"openai":{"itemId":"fc_08430863c6a3580e016a338c26976081918d1f31a21fbf9aa3"}},"id":"prt_ed95b76f2001dwCbb6CQeSaGE8","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95b516a001WOShyKIceSyVWM"}}
{"type":"tool_use","timestamp":1781763110719,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_4OGMHxBzqfHkOj777TNXmoXb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs</path>\n<type>file</type>\n<content>\n1: 'use strict';\n2: \n3: const fs = require('fs');\n4: const net = require('net');\n5: const path = require('path');\n6: const { StringDecoder } = require('string_decoder');\n7: \n8: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n9: const DEFAULT_PROBE_TIMEOUT_MS = 5000;\n10: const MAX_PROBE_TIMEOUT_MS = 6999;\n11: const DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\n12: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n13: const MODEL_SERVER_HEALTH_PATH = '/api/health';\n14: let nextProbeId = 1;\n15: \n16: function parsePositiveInteger(value, fallback) {\n17:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n18:   const parsed = Number.parseInt(String(value).trim(), 10);\n19:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n20: }\n21: \n22: function clampProbeTimeoutMs(value) {\n23:   return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n24: }\n25: \n26: function resolveProbeTimeoutMs(options = {}) {\n27:   if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n28:     return clampProbeTimeoutMs(options.timeoutMs);\n29:   }\n30:   return clampProbeTimeoutMs(parsePositiveInteger(\n31:     (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n32:     DEFAULT_PROBE_TIMEOUT_MS,\n33:   ));\n34: }\n35: \n36: function parseNonNegativeInteger(value, fallback) {\n37:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n38:   const parsed = Number.parseInt(String(value).trim(), 10);\n39:   return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n40: }\n41: \n42: // A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n43: // daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n44: // consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n45: // its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n46: // the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\n47: function resolveLeaseProbeAttempts(env = process.env) {\n48:   return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n49: }\n50: function resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n51:   return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n52: }\n53: function resolveLeaseProbeRetryBackoffMs(env = process.env) {\n54:   return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n55: }\n56: \n57: function repoRoot() {\n58:   return path.resolve(__dirname, '..', '..', '..');\n59: }\n60: \n61: function defaultDbDirForService(serviceName) {\n62:   const root = repoRoot();\n63:   if (serviceName === 'mk-spec-memory') {\n64:     return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n65:   }\n66:   if (serviceName === 'mk-code-index') {\n67:     return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n68:       ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n69:       : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n70:   }\n71:   if (serviceName === 'mk-skill-advisor') {\n72:     const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n73:     return advisorOverride\n74:       ? path.resolve(advisorOverride)\n75:       : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n76:   }\n77:   throw new Error(`Unknown MCP service name: ${serviceName}`);\n78: }\n79: \n80: function getIpcSocketPath(serviceName, options = {}) {\n81:   if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n82:     return process.env.SPECKIT_IPC_SOCKET_DIR;\n83:   }\n84:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n85:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n86:     : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n87:   return path.join(socketDir, SOCKET_FILE_NAME);\n88: }\n89: \n90: function toConnectionOptions(socketPath) {\n91:   if (!socketPath.startsWith('tcp://')) {\n92:     return socketPath;\n93:   }\n94:   const url = new URL(socketPath);\n95:   return {\n96:     host: url.hostname,\n97:     port: Number.parseInt(url.port, 10),\n98:   };\n99: }\n100: \n101: function bridgeStdioToSocket(socketPath, options = {}) {\n102:   const input = options.stdin ?? process.stdin;\n103:   const output = options.stdout ?? process.stdout;\n104:   const exit = options.exit ?? ((code) => process.exit(code));\n105:   const socket = net.createConnection(toConnectionOptions(socketPath));\n106:   let closed = false;\n107: \n108:   const closeOnce = (code = 0) => {\n109:     if (closed) return;\n110:     closed = true;\n111:     input.unpipe(socket);\n112:     socket.unpipe(output);\n113:     socket.destroy();\n114:     exit(code);\n115:   };\n116: \n117:   socket.once('connect', () => {\n118:     options.onConnect?.(socket);\n119:     input.pipe(socket);\n120:     socket.pipe(output);\n121:   });\n122: \n123:   socket.once('error', (error) => {\n124:     options.onError?.(error);\n125:     closeOnce(0);\n126:   });\n127: \n128:   socket.once('close', () => {\n129:     closeOnce(0);\n130:   });\n131: \n132:   input.once('end', () => {\n133:     socket.end();\n134:   });\n135:   input.once('close', () => {\n136:     closeOnce(0);\n137:   });\n138:   output.once('error', () => {\n139:     closeOnce(0);\n140:   });\n141: \n142:   return socket;\n143: }\n144: \n145: function probeDaemon(socketPath, options = {}) {\n146:   const timeoutMs = resolveProbeTimeoutMs(options);\n147:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n148:   // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n149:   // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n150:   // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n151:   // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n152:   const deepProbe = options.deepProbe === true;\n153:   const id = nextProbeId++;\n154:   const request = `${JSON.stringify({\n155:     jsonrpc: '2.0',\n156:     id,\n157:     method: 'initialize',\n158:     params: {\n159:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n160:       capabilities: {},\n161:       clientInfo: { name: 'liveness-probe', version: '0' },\n162:     },\n163:   })}\\n`;\n164: \n165:   return new Promise((resolve) => {\n166:     let socket;\n167:     let settled = false;\n168:     let buffer = '';\n169:     let timer;\n170:     // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n171:     // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n172:     const decoder = new StringDecoder('utf8');\n173: \n174:     const finish = (status, reason) => {\n175:       if (settled) return;\n176:       settled = true;\n177:       if (timer) clearTimeout(timer);\n178:       if (socket) socket.destroy();\n179:       resolve({ status, reason });\n180:     };\n181: \n182:     try {\n183:       socket = connect(toConnectionOptions(socketPath));\n184:     } catch (error) {\n185:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n186:       return;\n187:     }\n188: \n189:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n190:     timer.unref?.();\n191: \n192:     socket.once('connect', () => {\n193:       if (!deepProbe) {\n194:         finish('alive', 'connect-ok');\n195:         return;\n196:       }\n197:       socket.write(request);\n198:     });\n199:     socket.on('data', (chunk) => {\n200:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n201:       let newlineIndex = buffer.indexOf('\\n');\n202:       while (newlineIndex !== -1) {\n203:         const line = buffer.slice(0, newlineIndex).trim();\n204:         buffer = buffer.slice(newlineIndex + 1);\n205:         newlineIndex = buffer.indexOf('\\n');\n206:         if (!line) continue;\n207:         try {\n208:           const parsed = JSON.parse(line);\n209:           if (\n210:             parsed &&\n211:             parsed.jsonrpc === '2.0' &&\n212:             parsed.id === id &&\n213:             (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n214:               Object.prototype.hasOwnProperty.call(parsed, 'error'))\n215:           ) {\n216:             finish('alive', 'json-rpc-reply');\n217:             return;\n218:           }\n219:         } catch {\n220:           // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n221:         }\n222:       }\n223:     });\n224:     socket.once('error', (error) => {\n225:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n226:     });\n227:     socket.once('close', () => {\n228:       finish('dead', 'closed-before-reply');\n229:     });\n230:   });\n231: }\n232: \n233: function parseHttpJsonResponse(buffer) {\n234:   const raw = buffer.toString('utf8');\n235:   const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n236:   if (headerEnd === -1) return null;\n237:   const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n238:   const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n239:   if (!statusMatch) return null;\n240:   const statusCode = Number.parseInt(statusMatch[1], 10);\n241:   const bodyRaw = raw.slice(headerEnd + 4).trim();\n242:   let body = null;\n243:   try {\n244:     body = bodyRaw ? JSON.parse(bodyRaw) : null;\n245:   } catch {\n246:     return { statusCode, body: null };\n247:   }\n248:   return { statusCode, body };\n249: }\n250: \n251: function probeModelServer(socketPath, options = {}) {\n252:   const timeoutMs = resolveProbeTimeoutMs(options);\n253:   const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n254:     ? options.loadingMaxMs\n255:     : parsePositiveInteger(\n256:       (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n257:       DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n258:     );\n259:   const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n260:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n261:   // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n262:   // without spawning a model server. Genuine embed consumers do not send this header, so their\n263:   // wake-on-demand path is unchanged.\n264:   const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n265: \n266:   return new Promise((resolve) => {\n267:     let socket;\n268:     let settled = false;\n269:     let chunks = [];\n270:     let timer;\n271: \n272:     // Carry the parsed health body so callers (the idle-eviction tick) can read\n273:     // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n274:     const finish = (status, reason, health) => {\n275:       if (settled) return;\n276:       settled = true;\n277:       if (timer) clearTimeout(timer);\n278:       if (socket) socket.destroy();\n279:       resolve({ status, reason, health });\n280:     };\n281: \n282:     try {\n283:       socket = connect(toConnectionOptions(socketPath));\n284:     } catch (error) {\n285:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n286:       return;\n287:     }\n288: \n289:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n290:     timer.unref?.();\n291: \n292:     socket.once('connect', () => {\n293:       socket.write(request);\n294:     });\n295:     socket.on('data', (chunk) => {\n296:       chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n297:     });\n298:     socket.once('end', () => {\n299:       const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n300:       const state = parsed && parsed.body && typeof parsed.body === 'object'\n301:         ? parsed.body.state\n302:         : null;\n303:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n304:         finish('alive', `health-${state}`, parsed.body);\n305:         return;\n306:       }\n307:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n308:         const loadStartedAt = parsed.body.loadStartedAt;\n309:         const loadProgressAt = parsed.body.loadProgressAt;\n310:         // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n311:         const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n312:           ? loadProgressAt\n313:           : loadStartedAt;\n314:         if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n315:           finish('dead', 'loading-wedged');\n316:           return;\n317:         }\n318:         finish('alive', 'health-loading', parsed.body);\n319:         return;\n320:       }\n321:       finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n322:     });\n323:     socket.once('error', (error) => {\n324:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n325:     });\n326:     socket.once('close', () => {\n327:       if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n328:     });\n329:   });\n330: }\n331: \n332: // Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n333: // only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n334: // sleep are injectable so the retry decision is unit-testable without real sockets or timers.\n335: async function probeLeaseHolderWithRetries(socketPath, options = {}) {\n336:   const {\n337:     probe = probeDaemon,\n338:     firstTimeoutMs,\n339:     retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n340:     retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n341:     attempts = resolveLeaseProbeAttempts(),\n342:     connect,\n343:     sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n344:     onRetry,\n345:   } = options;\n346:   const totalAttempts = Math.max(1, attempts);\n347:   let result = { status: 'dead', reason: 'no-probe-attempted' };\n348:   for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n349:     const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n350:     result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n351:     if (result.status === 'alive') return result;\n352:     if (attempt < totalAttempts) {\n353:       if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n354:       await sleepFn(retryBackoffMs);\n355:     }\n356:   }\n357:   return result;\n358: }\n359: \n360: async function maybeBridgeLeaseHolder(options) {\n\n(Showing lines 1-360 of 451. Use offset=361 to continue.)\n</content>","metadata":{"preview":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","text":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction clampProbeTimeoutMs(value) {\n  return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n}\n\nfunction resolveProbeTimeoutMs(options = {}) {\n  if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n    return clampProbeTimeoutMs(options.timeoutMs);\n  }\n  return clampProbeTimeoutMs(parsePositiveInteger(\n    (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n    DEFAULT_PROBE_TIMEOUT_MS,\n  ));\n}\n\nfunction parseNonNegativeInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n}\n\n// A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n// daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n// consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n// its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n// the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\nfunction resolveLeaseProbeAttempts(env = process.env) {\n  return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n}\nfunction resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n  return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n}\nfunction resolveLeaseProbeRetryBackoffMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n}\n\nfunction repoRoot() {\n  return path.resolve(__dirname, '..', '..', '..');\n}\n\nfunction defaultDbDirForService(serviceName) {\n  const root = repoRoot();\n  if (serviceName === 'mk-spec-memory') {\n    return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n  }\n  if (serviceName === 'mk-code-index') {\n    return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n      ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n      : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n  }\n  if (serviceName === 'mk-skill-advisor') {\n    const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n    return advisorOverride\n      ? path.resolve(advisorOverride)\n      : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n  }\n  throw new Error(`Unknown MCP service name: ${serviceName}`);\n}\n\nfunction getIpcSocketPath(serviceName, options = {}) {\n  if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n    return process.env.SPECKIT_IPC_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\nfunction toConnectionOptions(socketPath) {\n  if (!socketPath.startsWith('tcp://')) {\n    return socketPath;\n  }\n  const url = new URL(socketPath);\n  return {\n    host: url.hostname,\n    port: Number.parseInt(url.port, 10),\n  };\n}\n\nfunction bridgeStdioToSocket(socketPath, options = {}) {\n  const input = options.stdin ?? process.stdin;\n  const output = options.stdout ?? process.stdout;\n  const exit = options.exit ?? ((code) => process.exit(code));\n  const socket = net.createConnection(toConnectionOptions(socketPath));\n  let closed = false;\n\n  const closeOnce = (code = 0) => {\n    if (closed) return;\n    closed = true;\n    input.unpipe(socket);\n    socket.unpipe(output);\n    socket.destroy();\n    exit(code);\n  };\n\n  socket.once('connect', () => {\n    options.onConnect?.(socket);\n    input.pipe(socket);\n    socket.pipe(output);\n  });\n\n  socket.once('error', (error) => {\n    options.onError?.(error);\n    closeOnce(0);\n  });\n\n  socket.once('close', () => {\n    closeOnce(0);\n  });\n\n  input.once('end', () => {\n    socket.end();\n  });\n  input.once('close', () => {\n    closeOnce(0);\n  });\n  output.once('error', () => {\n    closeOnce(0);\n  });\n\n  return socket;\n}\n\nfunction probeDaemon(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n  // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n  // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n  // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n  const deepProbe = options.deepProbe === true;\n  const id = nextProbeId++;\n  const request = `${JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    method: 'initialize',\n    params: {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'liveness-probe', version: '0' },\n    },\n  })}\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let buffer = '';\n    let timer;\n    // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n    // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n    const decoder = new StringDecoder('utf8');\n\n    const finish = (status, reason) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      if (!deepProbe) {\n        finish('alive', 'connect-ok');\n        return;\n      }\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const line = buffer.slice(0, newlineIndex).trim();\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (!line) continue;\n        try {\n          const parsed = JSON.parse(line);\n          if (\n            parsed &&\n            parsed.jsonrpc === '2.0' &&\n            parsed.id === id &&\n            (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n              Object.prototype.hasOwnProperty.call(parsed, 'error'))\n          ) {\n            finish('alive', 'json-rpc-reply');\n            return;\n          }\n        } catch {\n          // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n        }\n      }\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\nfunction parseHttpJsonResponse(buffer) {\n  const raw = buffer.toString('utf8');\n  const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n  if (headerEnd === -1) return null;\n  const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n  const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n  if (!statusMatch) return null;\n  const statusCode = Number.parseInt(statusMatch[1], 10);\n  const bodyRaw = raw.slice(headerEnd + 4).trim();\n  let body = null;\n  try {\n    body = bodyRaw ? JSON.parse(bodyRaw) : null;\n  } catch {\n    return { statusCode, body: null };\n  }\n  return { statusCode, body };\n}\n\nfunction probeModelServer(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n    ? options.loadingMaxMs\n    : parsePositiveInteger(\n      (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n      DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n    );\n  const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n  // without spawning a model server. Genuine embed consumers do not send this header, so their\n  // wake-on-demand path is unchanged.\n  const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let chunks = [];\n    let timer;\n\n    // Carry the parsed health body so callers (the idle-eviction tick) can read\n    // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n    const finish = (status, reason, health) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason, health });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n    });\n    socket.once('end', () => {\n      const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n      const state = parsed && parsed.body && typeof parsed.body === 'object'\n        ? parsed.body.state\n        : null;\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n        finish('alive', `health-${state}`, parsed.body);\n        return;\n      }\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n        const loadStartedAt = parsed.body.loadStartedAt;\n        const loadProgressAt = parsed.body.loadProgressAt;\n        // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n        const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n          ? loadProgressAt\n          : loadStartedAt;\n        if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n          finish('dead', 'loading-wedged');\n          return;\n        }\n        finish('alive', 'health-loading', parsed.body);\n        return;\n      }\n      finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\n// Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n// only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n// sleep are injectable so the retry decision is unit-testable without real sockets or timers.\nasync function probeLeaseHolderWithRetries(socketPath, options = {}) {\n  const {\n    probe = probeDaemon,\n    firstTimeoutMs,\n    retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n    retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n    attempts = resolveLeaseProbeAttempts(),\n    connect,\n    sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n    onRetry,\n  } = options;\n  const totalAttempts = Math.max(1, attempts);\n  let result = { status: 'dead', reason: 'no-probe-attempted' };\n  for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n    const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n    result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n    if (result.status === 'alive') return result;\n    if (attempt < totalAttempts) {\n      if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n      await sleepFn(retryBackoffMs);\n    }\n  }\n  return result;\n}\n\nasync function maybeBridgeLeaseHolder(options) {","lineStart":1,"lineEnd":360,"totalLines":451,"truncated":true}},"title":".opencode/bin/lib/launcher-ipc-bridge.cjs","time":{"start":1781763110709,"end":1781763110718}},"metadata":{"openai":{"itemId":"fc_08430863c6a3580e016a338c26976c8191b3a3bb21e1bcea03"}},"id":"prt_ed95b7721001VtCZeHpiWsSYCe","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95b516a001WOShyKIceSyVWM"}}
{"type":"tool_use","timestamp":1781763110722,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_SF6UPQ8AiBOgi5EajTKXnNM0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs</path>\n<type>file</type>\n<content>\n1: // [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n2: 'use strict';\n3: \n4: const net = require('net');\n5: const { StringDecoder } = require('string_decoder');\n6: const {\n7:   probeDaemon,\n8:   toConnectionOptions,\n9: } = require('./launcher-ipc-bridge.cjs');\n10: \n11: const PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\n12: const DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n13: // Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n14: // seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n15: // daemon answers the deep probe within the first few attempts; the only thing this shortens is\n16: // the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\n17: const DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\n18: const INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\n19: const DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\n20: const DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;\n21: const DEFAULT_MAX_QUEUED_CLIENT_FRAMES = 1000;\n22: const PROXY_PRIVATE_ID_PREFIX = '__launcher_session_proxy_keepalive__';\n23: const RETRYABLE_RECYCLE_ERROR = Object.freeze({\n24:   code: -32001,\n25:   message: 'backend recycled; retry',\n26:   data: { retryable: true },\n27: });\n28: const PROTOCOL_MISMATCH_ERROR = Object.freeze({\n29:   code: -32002,\n30:   message: 'backend protocol version changed; client reconnect required',\n31:   data: { retryable: false },\n32: });\n33: const REPLAYABLE_TOOL_NAMES = new Set([\n34:   'memory_search',\n35:   'memory_context',\n36:   'memory_match_triggers',\n37:   'memory_quick_search',\n38:   'memory_save',\n39:   'session_bootstrap',\n40:   'session_health',\n41:   'session_resume',\n42:   'session_status',\n43:   'memory_stats',\n44:   'memory_status',\n45:   'checkpoint_list',\n46:   'embedder_health',\n47: ]);\n48: const UNSAFE_TOOL_NAMES = new Set([\n49:   'memory_delete',\n50:   'memory_bulk_delete',\n51:   'memory_update',\n52:   'checkpoint_restore',\n53:   'checkpoint_delete',\n54:   'embedder_set',\n55:   'memory_retention_sweep',\n56:   'memory_ingest_start',\n57:   'memory_ingest_cancel',\n58: ]);\n59: const REPLAYABLE_PROTOCOL_METHODS = new Set([\n60:   'initialize',\n61:   'ping',\n62: ]);\n63: \n64: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n65: \n66: function defaultConnect(connectionOptions) {\n67:   return net.createConnection(connectionOptions);\n68: }\n69: \n70: function defaultLog(message) {\n71:   process.stderr.write(`[launcher-session-proxy] ${message}\\n`);\n72: }\n73: \n74: function createFrameSplitter(onFrame) {\n75:   let buffer = '';\n76:   // A multibyte UTF-8 char (CJK/emoji) can straddle a socket-chunk boundary; the\n77:   // StringDecoder holds the incomplete tail until the next chunk completes it, instead\n78:   // of emitting U+FFFD replacement chars on the partial sequence.\n79:   const decoder = new StringDecoder('utf8');\n80:   return {\n81:     push(chunk) {\n82:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n83:       let newlineIndex = buffer.indexOf('\\n');\n84:       while (newlineIndex !== -1) {\n85:         const frame = buffer.slice(0, newlineIndex);\n86:         buffer = buffer.slice(newlineIndex + 1);\n87:         newlineIndex = buffer.indexOf('\\n');\n88:         if (frame.trim().length === 0) continue;\n89:         onFrame(frame);\n90:       }\n91:     },\n92:     discard() {\n93:       buffer = '';\n94:       decoder.end();\n95:     },\n96:     buffered() {\n97:       return buffer;\n98:     },\n99:   };\n100: }\n101: \n102: function parseFrame(frame) {\n103:   try {\n104:     const parsed = JSON.parse(String(frame).trim());\n105:     return parsed && typeof parsed === 'object' ? parsed : null;\n106:   } catch {\n107:     return null;\n108:   }\n109: }\n110: \n111: function hasOwn(object, key) {\n112:   return Object.prototype.hasOwnProperty.call(object, key);\n113: }\n114: \n115: function hasRequestId(parsed) {\n116:   return parsed !== null && hasOwn(parsed, 'id');\n117: }\n118: \n119: function isResponseFrame(parsed) {\n120:   return hasRequestId(parsed) && (hasOwn(parsed, 'result') || hasOwn(parsed, 'error'));\n121: }\n122: \n123: // Build a frame classifier for a given replayable/unsafe tool set. The protocol-method rules\n124: // (initialize/ping/notifications) and the parse/unsafe/replayable order are identical across MCP\n125: // servers; only the tools/call replayability set differs per server (memory tools vs code-graph\n126: // tools). Each launcher passes its own sets so the reattach/replay machinery stays one implementation.\n127: function createClassifyFrame(options = {}) {\n128:   const replayable = options.replayableToolNames instanceof Set ? options.replayableToolNames : REPLAYABLE_TOOL_NAMES;\n129:   const unsafe = options.unsafeToolNames instanceof Set ? options.unsafeToolNames : UNSAFE_TOOL_NAMES;\n130:   return function classify(frame) {\n131:     const parsed = typeof frame === 'string' ? parseFrame(frame) : frame;\n132:     if (!parsed || typeof parsed.method !== 'string') return false;\n133:     if (parsed.method !== 'tools/call') {\n134:       return REPLAYABLE_PROTOCOL_METHODS.has(parsed.method) || parsed.method.startsWith('notifications/');\n135:     }\n136:     const toolName = parsed.params && typeof parsed.params === 'object'\n137:       ? parsed.params.name\n138:       : undefined;\n139:     if (typeof toolName !== 'string') return false;\n140:     if (unsafe.has(toolName)) return false;\n141:     if (replayable.has(toolName)) return true;\n142:     return false;\n143:   };\n144: }\n145: \n146: // Default classifier uses the mk-spec-memory tool sets. memory_save is replayable on a\n147: // commit-then-die backend because its primary row is protected by content-hash dedup AND the v28\n148: // active-row partial unique index (idx_memory_logical_key_active_unique): an identical-content replay\n149: // collapses to the same logical key and writes no new primary row. The KNOWN GAP is the secondary\n150: // index — a commit-then-die that finished the primary insert but not the secondary-index write can,\n151: // on replay, append duplicate secondary-index rows because that path is not yet keyed by an\n152: // idempotency token. Closing it requires a request-id/dedup key threaded into the save handler, which\n153: // lives behind the daemon IPC and is out of scope for this proxy-layer frame classifier.\n154: const classifyFrame = createClassifyFrame();\n155: \n156: function createPendingRequestsTracker(classify = classifyFrame) {\n157:   const pendingRequests = new Map();\n158:   let cachedInitialize = null;\n159:   let cachedInitializeId = null;\n160:   let negotiatedProtocolVersion = null;\n161:   let protocolVersionObserved = false;\n162: \n163:   function handleClientFrame(frame) {\n164:     const parsed = parseFrame(frame);\n165:     if (!parsed) return;\n166:     if (parsed.method === 'initialize') {\n167:       cachedInitialize = frame;\n168:       cachedInitializeId = hasRequestId(parsed) ? parsed.id : null;\n169:     }\n170:     if (!hasRequestId(parsed)) return;\n171:     pendingRequests.set(parsed.id, {\n172:       frame,\n173:       replayable: classify(frame),\n174:     });\n175:   }\n176: \n177:   function handleBackendFrame(frame) {\n178:     const parsed = parseFrame(frame);\n179:     if (!parsed || !isResponseFrame(parsed)) return;\n180:     pendingRequests.delete(parsed.id);\n181:   }\n182: \n183:   return {\n184:     pendingRequests,\n185:     handleClientFrame,\n186:     handleBackendFrame,\n187:     getCachedInitialize() {\n188:       return cachedInitialize;\n189:     },\n190:     getCachedInitializeId() {\n191:       return cachedInitializeId;\n192:     },\n193:     getNegotiatedProtocolVersion() {\n194:       return negotiatedProtocolVersion;\n195:     },\n196:     hasObservedProtocolVersion() {\n197:       return protocolVersionObserved;\n198:     },\n199:     recordNegotiatedProtocolVersion(version) {\n200:       if (protocolVersionObserved) return;\n201:       protocolVersionObserved = true;\n202:       negotiatedProtocolVersion = typeof version === 'string' ? version : null;\n203:     },\n204:   };\n205: }\n206: \n207: function resolveColdStartAttempts() {\n208:   const fromEnv = Number.parseInt(process.env.SPECKIT_PROXY_COLD_START_ATTEMPTS ?? '', 10);\n209:   return Number.isInteger(fromEnv) && fromEnv > 0 ? fromEnv : DEFAULT_MAX_COLD_START_ATTEMPTS;\n210: }\n211: \n212: async function waitForDaemonReady(socketPath, probe, connect, log, options = {}) {\n213:   const maxAttempts = Number.isInteger(options.maxAttempts) && options.maxAttempts > 0\n214:     ? options.maxAttempts\n215:     : Infinity;\n216:   for (let attempt = 0; attempt < maxAttempts; attempt += 1) {\n217:     const result = await probe(socketPath, { connect, deepProbe: true });\n218:     if (result.status === 'alive') return result;\n219:     if (attempt + 1 >= maxAttempts) return result;\n220:     const delayMs = PROBE_BACKOFF_MS[Math.min(attempt, PROBE_BACKOFF_MS.length - 1)];\n221:     log(`daemon socket not ready (${result.reason}); retrying in ${delayMs}ms`);\n222:     await sleep(delayMs);\n223:   }\n224:   return { status: 'dead', reason: 'reattach-attempts-exhausted' };\n225: }\n226: \n227: function writeFrame(stream, frame) {\n228:   return stream.write(`${frame}\\n`);\n229: }\n230: \n231: function retryableErrorFrame(id) {\n232:   return JSON.stringify({\n233:     jsonrpc: '2.0',\n234:     id,\n235:     error: RETRYABLE_RECYCLE_ERROR,\n236:   });\n237: }\n238: \n239: function protocolMismatchErrorFrame(id) {\n240:   return JSON.stringify({\n241:     jsonrpc: '2.0',\n242:     id,\n243:     error: PROTOCOL_MISMATCH_ERROR,\n244:   });\n245: }\n246: \n247: function connectSocket(connect, socketPath) {\n248:   return new Promise((resolve, reject) => {\n249:     let socket;\n250:     try {\n251:       socket = connect(toConnectionOptions(socketPath));\n252:     } catch (error) {\n253:       reject(error);\n254:       return;\n255:     }\n256: \n257:     const cleanup = () => {\n258:       socket.off?.('connect', onConnect);\n259:       socket.off?.('error', onError);\n260:     };\n261:     const onConnect = () => {\n262:       cleanup();\n263:       resolve(socket);\n264:     };\n265:     const onError = (error) => {\n266:       cleanup();\n267:       socket.destroy?.();\n268:       reject(error);\n269:     };\n270: \n271:     socket.once('connect', onConnect);\n272:     socket.once('error', onError);\n273:   });\n274: }\n275: \n276: function internalHandshake(socket, initializeFrame) {\n277:   if (!initializeFrame) return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n278: \n279:   const initialize = parseFrame(initializeFrame);\n280:   if (!initialize || !hasRequestId(initialize)) {\n281:     return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n282:   }\n283: \n284:   return new Promise((resolve, reject) => {\n285:     let buffer = '';\n286:     let residual = '';\n287:     let negotiatedVersion;\n288:     let initializeResponse = null;\n289:     // Hold a multibyte char split across chunk boundaries until complete, so a CJK/emoji\n290:     // payload in the residual (post-handshake) stream is not corrupted to U+FFFD.\n291:     const decoder = new StringDecoder('utf8');\n292:     const timer = setTimeout(() => {\n293:       cleanup();\n294:       reject(new Error('timed out waiting for internal initialize'));\n295:     }, INTERNAL_HANDSHAKE_TIMEOUT_MS);\n296:     timer.unref?.();\n297:     const cleanup = () => {\n298:       clearTimeout(timer);\n299:       socket.off?.('data', onData);\n300:       socket.off?.('error', onError);\n301:       socket.off?.('close', onClose);\n302:     };\n303:     const onData = (chunk) => {\n304:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n305:       let initialized = false;\n306:       let newlineIndex = buffer.indexOf('\\n');\n307:       while (newlineIndex !== -1) {\n308:         const frame = buffer.slice(0, newlineIndex);\n309:         buffer = buffer.slice(newlineIndex + 1);\n310:         newlineIndex = buffer.indexOf('\\n');\n311:         if (frame.trim().length === 0) continue;\n312:         const parsed = parseFrame(frame);\n313:         if (parsed && isResponseFrame(parsed) && parsed.id === initialize.id) {\n314:           initialized = true;\n315:           initializeResponse = frame;\n316:           negotiatedVersion = parsed.result && typeof parsed.result === 'object'\n317:             ? parsed.result.protocolVersion\n318:             : undefined;\n319:           continue;\n320:         }\n321:         residual += `${frame}\\n`;\n322:       }\n323:       if (!initialized) return;\n324:       const remainder = residual + buffer;\n325:       buffer = '';\n326:       residual = '';\n327:       cleanup();\n328:       resolve({ residual: remainder, protocolVersion: negotiatedVersion, handshakeObserved: true, initializeResponse });\n329:     };\n330:     const onError = (error) => {\n331:       cleanup();\n332:       reject(error);\n333:     };\n334:     const onClose = () => {\n335:       cleanup();\n336:       reject(new Error('socket closed during internal initialize'));\n337:     };\n338: \n339:     socket.on('data', onData);\n340:     socket.once('error', onError);\n341:     socket.once('close', onClose);\n342:     writeFrame(socket, initializeFrame);\n343:   });\n344: }\n345: \n346: function createSessionProxy(options) {\n347:   const socketPath = options?.socketPath;\n348:   const input = options?.stdin ?? process.stdin;\n349:   const output = options?.stdout ?? process.stdout;\n350:   const probe = options?.probe ?? probeDaemon;\n351:   const connect = options?.connect ?? defaultConnect;\n352:   const log = options?.log ?? defaultLog;\n353:   const classify = options?.classify ?? classifyFrame;\n354:   const maxReattachAttempts = Number.isInteger(options?.maxReattachAttempts) && options.maxReattachAttempts > 0\n355:     ? options.maxReattachAttempts\n356:     : DEFAULT_MAX_REATTACH_ATTEMPTS;\n357:   const maxColdStartAttempts = Number.isInteger(options?.maxColdStartAttempts) && options.maxColdStartAttempts > 0\n358:     ? options.maxColdStartAttempts\n359:     : resolveColdStartAttempts();\n360:   const keepaliveIntervalMs = Number.isInteger(options?.keepaliveIntervalMs) && options.keepaliveIntervalMs > 0\n361:     ? options.keepaliveIntervalMs\n362:     : DEFAULT_KEEPALIVE_INTERVAL_MS;\n363:   const keepaliveTimeoutMs = Number.isInteger(options?.keepaliveTimeoutMs) && options.keepaliveTimeoutMs > 0\n364:     ? options.keepaliveTimeoutMs\n365:     : DEFAULT_KEEPALIVE_TIMEOUT_MS;\n366:   const maxQueuedClientFrames = Number.isInteger(options?.maxQueuedClientFrames) && options.maxQueuedClientFrames > 0\n367:     ? options.maxQueuedClientFrames\n368:     : DEFAULT_MAX_QUEUED_CLIENT_FRAMES;\n369: \n370:   let socket = null;\n371:   let state = 'REATTACHING';\n372:   let stopped = false;\n373:   let clientEnded = false;\n374:   let reattachRunning = false;\n375:   let backendSplitter = createFrameSplitter(handleBackendFrame);\n376:   let socketHalfClosed = false;\n377:   let keepaliveInterval = null;\n378:   let keepaliveTimer = null;\n379:   let keepaliveId = 0;\n380:   let pendingKeepaliveId = null;\n381:   let lastBackendActivity = Date.now();\n382:   let socketDrainWaiting = false;\n383:   let outputDrainWaiting = false;\n384:   let outputEndRequested = false;\n385:   const queuedClientFrames = [];\n386:   const socketWriteQueue = [];\n387:   const outputWriteQueue = [];\n388:   const tracker = createPendingRequestsTracker(classify);\n389:   const clientSplitter = createFrameSplitter(handleClientFrame);\n390: \n391:   if (typeof socketPath !== 'string' || socketPath.length === 0) {\n392:     throw new Error('createSessionProxy requires a non-empty socketPath');\n393:   }\n394: \n395:   function pauseClientInput() {\n396:     input.pause?.();\n397:   }\n398: \n399:   function resumeClientInputIfReady() {\n400:     if (!clientEnded && !stopped && state === 'CONNECTED') input.resume?.();\n401:   }\n402: \n403:   function stopKeepalive() {\n404:     if (keepaliveInterval !== null) {\n405:       clearInterval(keepaliveInterval);\n406:       keepaliveInterval = null;\n407:     }\n408:     if (keepaliveTimer !== null) {\n409:       clearTimeout(keepaliveTimer);\n410:       keepaliveTimer = null;\n411:     }\n412:     pendingKeepaliveId = null;\n413:   }\n414: \n415:   function detachSocket(destroy = true) {\n416:     stopKeepalive();\n417:     if (!socket) return;\n418:     const oldSocket = socket;\n419:     socket = null;\n420:     socketHalfClosed = false;\n\n(Showing lines 1-420 of 853. Use offset=421 to continue.)\n</content>","metadata":{"preview":"// [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n'use strict';\n\nconst net = require('net');\nconst { StringDecoder } = require('string_decoder');\nconst {\n  probeDaemon,\n  toConnectionOptions,\n} = require('./launcher-ipc-bridge.cjs');\n\nconst PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\nconst DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n// Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n// seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n// daemon answers the deep probe within the first few attempts; the only thing this shortens is\n// the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\nconst DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\nconst INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\nconst DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\nconst DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","text":"// [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n'use strict';\n\nconst net = require('net');\nconst { StringDecoder } = require('string_decoder');\nconst {\n  probeDaemon,\n  toConnectionOptions,\n} = require('./launcher-ipc-bridge.cjs');\n\nconst PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\nconst DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n// Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n// seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n// daemon answers the deep probe within the first few attempts; the only thing this shortens is\n// the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\nconst DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\nconst INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\nconst DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\nconst DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;\nconst DEFAULT_MAX_QUEUED_CLIENT_FRAMES = 1000;\nconst PROXY_PRIVATE_ID_PREFIX = '__launcher_session_proxy_keepalive__';\nconst RETRYABLE_RECYCLE_ERROR = Object.freeze({\n  code: -32001,\n  message: 'backend recycled; retry',\n  data: { retryable: true },\n});\nconst PROTOCOL_MISMATCH_ERROR = Object.freeze({\n  code: -32002,\n  message: 'backend protocol version changed; client reconnect required',\n  data: { retryable: false },\n});\nconst REPLAYABLE_TOOL_NAMES = new Set([\n  'memory_search',\n  'memory_context',\n  'memory_match_triggers',\n  'memory_quick_search',\n  'memory_save',\n  'session_bootstrap',\n  'session_health',\n  'session_resume',\n  'session_status',\n  'memory_stats',\n  'memory_status',\n  'checkpoint_list',\n  'embedder_health',\n]);\nconst UNSAFE_TOOL_NAMES = new Set([\n  'memory_delete',\n  'memory_bulk_delete',\n  'memory_update',\n  'checkpoint_restore',\n  'checkpoint_delete',\n  'embedder_set',\n  'memory_retention_sweep',\n  'memory_ingest_start',\n  'memory_ingest_cancel',\n]);\nconst REPLAYABLE_PROTOCOL_METHODS = new Set([\n  'initialize',\n  'ping',\n]);\n\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nfunction defaultConnect(connectionOptions) {\n  return net.createConnection(connectionOptions);\n}\n\nfunction defaultLog(message) {\n  process.stderr.write(`[launcher-session-proxy] ${message}\\n`);\n}\n\nfunction createFrameSplitter(onFrame) {\n  let buffer = '';\n  // A multibyte UTF-8 char (CJK/emoji) can straddle a socket-chunk boundary; the\n  // StringDecoder holds the incomplete tail until the next chunk completes it, instead\n  // of emitting U+FFFD replacement chars on the partial sequence.\n  const decoder = new StringDecoder('utf8');\n  return {\n    push(chunk) {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const frame = buffer.slice(0, newlineIndex);\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (frame.trim().length === 0) continue;\n        onFrame(frame);\n      }\n    },\n    discard() {\n      buffer = '';\n      decoder.end();\n    },\n    buffered() {\n      return buffer;\n    },\n  };\n}\n\nfunction parseFrame(frame) {\n  try {\n    const parsed = JSON.parse(String(frame).trim());\n    return parsed && typeof parsed === 'object' ? parsed : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction hasOwn(object, key) {\n  return Object.prototype.hasOwnProperty.call(object, key);\n}\n\nfunction hasRequestId(parsed) {\n  return parsed !== null && hasOwn(parsed, 'id');\n}\n\nfunction isResponseFrame(parsed) {\n  return hasRequestId(parsed) && (hasOwn(parsed, 'result') || hasOwn(parsed, 'error'));\n}\n\n// Build a frame classifier for a given replayable/unsafe tool set. The protocol-method rules\n// (initialize/ping/notifications) and the parse/unsafe/replayable order are identical across MCP\n// servers; only the tools/call replayability set differs per server (memory tools vs code-graph\n// tools). Each launcher passes its own sets so the reattach/replay machinery stays one implementation.\nfunction createClassifyFrame(options = {}) {\n  const replayable = options.replayableToolNames instanceof Set ? options.replayableToolNames : REPLAYABLE_TOOL_NAMES;\n  const unsafe = options.unsafeToolNames instanceof Set ? options.unsafeToolNames : UNSAFE_TOOL_NAMES;\n  return function classify(frame) {\n    const parsed = typeof frame === 'string' ? parseFrame(frame) : frame;\n    if (!parsed || typeof parsed.method !== 'string') return false;\n    if (parsed.method !== 'tools/call') {\n      return REPLAYABLE_PROTOCOL_METHODS.has(parsed.method) || parsed.method.startsWith('notifications/');\n    }\n    const toolName = parsed.params && typeof parsed.params === 'object'\n      ? parsed.params.name\n      : undefined;\n    if (typeof toolName !== 'string') return false;\n    if (unsafe.has(toolName)) return false;\n    if (replayable.has(toolName)) return true;\n    return false;\n  };\n}\n\n// Default classifier uses the mk-spec-memory tool sets. memory_save is replayable on a\n// commit-then-die backend because its primary row is protected by content-hash dedup AND the v28\n// active-row partial unique index (idx_memory_logical_key_active_unique): an identical-content replay\n// collapses to the same logical key and writes no new primary row. The KNOWN GAP is the secondary\n// index — a commit-then-die that finished the primary insert but not the secondary-index write can,\n// on replay, append duplicate secondary-index rows because that path is not yet keyed by an\n// idempotency token. Closing it requires a request-id/dedup key threaded into the save handler, which\n// lives behind the daemon IPC and is out of scope for this proxy-layer frame classifier.\nconst classifyFrame = createClassifyFrame();\n\nfunction createPendingRequestsTracker(classify = classifyFrame) {\n  const pendingRequests = new Map();\n  let cachedInitialize = null;\n  let cachedInitializeId = null;\n  let negotiatedProtocolVersion = null;\n  let protocolVersionObserved = false;\n\n  function handleClientFrame(frame) {\n    const parsed = parseFrame(frame);\n    if (!parsed) return;\n    if (parsed.method === 'initialize') {\n      cachedInitialize = frame;\n      cachedInitializeId = hasRequestId(parsed) ? parsed.id : null;\n    }\n    if (!hasRequestId(parsed)) return;\n    pendingRequests.set(parsed.id, {\n      frame,\n      replayable: classify(frame),\n    });\n  }\n\n  function handleBackendFrame(frame) {\n    const parsed = parseFrame(frame);\n    if (!parsed || !isResponseFrame(parsed)) return;\n    pendingRequests.delete(parsed.id);\n  }\n\n  return {\n    pendingRequests,\n    handleClientFrame,\n    handleBackendFrame,\n    getCachedInitialize() {\n      return cachedInitialize;\n    },\n    getCachedInitializeId() {\n      return cachedInitializeId;\n    },\n    getNegotiatedProtocolVersion() {\n      return negotiatedProtocolVersion;\n    },\n    hasObservedProtocolVersion() {\n      return protocolVersionObserved;\n    },\n    recordNegotiatedProtocolVersion(version) {\n      if (protocolVersionObserved) return;\n      protocolVersionObserved = true;\n      negotiatedProtocolVersion = typeof version === 'string' ? version : null;\n    },\n  };\n}\n\nfunction resolveColdStartAttempts() {\n  const fromEnv = Number.parseInt(process.env.SPECKIT_PROXY_COLD_START_ATTEMPTS ?? '', 10);\n  return Number.isInteger(fromEnv) && fromEnv > 0 ? fromEnv : DEFAULT_MAX_COLD_START_ATTEMPTS;\n}\n\nasync function waitForDaemonReady(socketPath, probe, connect, log, options = {}) {\n  const maxAttempts = Number.isInteger(options.maxAttempts) && options.maxAttempts > 0\n    ? options.maxAttempts\n    : Infinity;\n  for (let attempt = 0; attempt < maxAttempts; attempt += 1) {\n    const result = await probe(socketPath, { connect, deepProbe: true });\n    if (result.status === 'alive') return result;\n    if (attempt + 1 >= maxAttempts) return result;\n    const delayMs = PROBE_BACKOFF_MS[Math.min(attempt, PROBE_BACKOFF_MS.length - 1)];\n    log(`daemon socket not ready (${result.reason}); retrying in ${delayMs}ms`);\n    await sleep(delayMs);\n  }\n  return { status: 'dead', reason: 'reattach-attempts-exhausted' };\n}\n\nfunction writeFrame(stream, frame) {\n  return stream.write(`${frame}\\n`);\n}\n\nfunction retryableErrorFrame(id) {\n  return JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    error: RETRYABLE_RECYCLE_ERROR,\n  });\n}\n\nfunction protocolMismatchErrorFrame(id) {\n  return JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    error: PROTOCOL_MISMATCH_ERROR,\n  });\n}\n\nfunction connectSocket(connect, socketPath) {\n  return new Promise((resolve, reject) => {\n    let socket;\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      reject(error);\n      return;\n    }\n\n    const cleanup = () => {\n      socket.off?.('connect', onConnect);\n      socket.off?.('error', onError);\n    };\n    const onConnect = () => {\n      cleanup();\n      resolve(socket);\n    };\n    const onError = (error) => {\n      cleanup();\n      socket.destroy?.();\n      reject(error);\n    };\n\n    socket.once('connect', onConnect);\n    socket.once('error', onError);\n  });\n}\n\nfunction internalHandshake(socket, initializeFrame) {\n  if (!initializeFrame) return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n\n  const initialize = parseFrame(initializeFrame);\n  if (!initialize || !hasRequestId(initialize)) {\n    return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n  }\n\n  return new Promise((resolve, reject) => {\n    let buffer = '';\n    let residual = '';\n    let negotiatedVersion;\n    let initializeResponse = null;\n    // Hold a multibyte char split across chunk boundaries until complete, so a CJK/emoji\n    // payload in the residual (post-handshake) stream is not corrupted to U+FFFD.\n    const decoder = new StringDecoder('utf8');\n    const timer = setTimeout(() => {\n      cleanup();\n      reject(new Error('timed out waiting for internal initialize'));\n    }, INTERNAL_HANDSHAKE_TIMEOUT_MS);\n    timer.unref?.();\n    const cleanup = () => {\n      clearTimeout(timer);\n      socket.off?.('data', onData);\n      socket.off?.('error', onError);\n      socket.off?.('close', onClose);\n    };\n    const onData = (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let initialized = false;\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const frame = buffer.slice(0, newlineIndex);\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (frame.trim().length === 0) continue;\n        const parsed = parseFrame(frame);\n        if (parsed && isResponseFrame(parsed) && parsed.id === initialize.id) {\n          initialized = true;\n          initializeResponse = frame;\n          negotiatedVersion = parsed.result && typeof parsed.result === 'object'\n            ? parsed.result.protocolVersion\n            : undefined;\n          continue;\n        }\n        residual += `${frame}\\n`;\n      }\n      if (!initialized) return;\n      const remainder = residual + buffer;\n      buffer = '';\n      residual = '';\n      cleanup();\n      resolve({ residual: remainder, protocolVersion: negotiatedVersion, handshakeObserved: true, initializeResponse });\n    };\n    const onError = (error) => {\n      cleanup();\n      reject(error);\n    };\n    const onClose = () => {\n      cleanup();\n      reject(new Error('socket closed during internal initialize'));\n    };\n\n    socket.on('data', onData);\n    socket.once('error', onError);\n    socket.once('close', onClose);\n    writeFrame(socket, initializeFrame);\n  });\n}\n\nfunction createSessionProxy(options) {\n  const socketPath = options?.socketPath;\n  const input = options?.stdin ?? process.stdin;\n  const output = options?.stdout ?? process.stdout;\n  const probe = options?.probe ?? probeDaemon;\n  const connect = options?.connect ?? defaultConnect;\n  const log = options?.log ?? defaultLog;\n  const classify = options?.classify ?? classifyFrame;\n  const maxReattachAttempts = Number.isInteger(options?.maxReattachAttempts) && options.maxReattachAttempts > 0\n    ? options.maxReattachAttempts\n    : DEFAULT_MAX_REATTACH_ATTEMPTS;\n  const maxColdStartAttempts = Number.isInteger(options?.maxColdStartAttempts) && options.maxColdStartAttempts > 0\n    ? options.maxColdStartAttempts\n    : resolveColdStartAttempts();\n  const keepaliveIntervalMs = Number.isInteger(options?.keepaliveIntervalMs) && options.keepaliveIntervalMs > 0\n    ? options.keepaliveIntervalMs\n    : DEFAULT_KEEPALIVE_INTERVAL_MS;\n  const keepaliveTimeoutMs = Number.isInteger(options?.keepaliveTimeoutMs) && options.keepaliveTimeoutMs > 0\n    ? options.keepaliveTimeoutMs\n    : DEFAULT_KEEPALIVE_TIMEOUT_MS;\n  const maxQueuedClientFrames = Number.isInteger(options?.maxQueuedClientFrames) && options.maxQueuedClientFrames > 0\n    ? options.maxQueuedClientFrames\n    : DEFAULT_MAX_QUEUED_CLIENT_FRAMES;\n\n  let socket = null;\n  let state = 'REATTACHING';\n  let stopped = false;\n  let clientEnded = false;\n  let reattachRunning = false;\n  let backendSplitter = createFrameSplitter(handleBackendFrame);\n  let socketHalfClosed = false;\n  let keepaliveInterval = null;\n  let keepaliveTimer = null;\n  let keepaliveId = 0;\n  let pendingKeepaliveId = null;\n  let lastBackendActivity = Date.now();\n  let socketDrainWaiting = false;\n  let outputDrainWaiting = false;\n  let outputEndRequested = false;\n  const queuedClientFrames = [];\n  const socketWriteQueue = [];\n  const outputWriteQueue = [];\n  const tracker = createPendingRequestsTracker(classify);\n  const clientSplitter = createFrameSplitter(handleClientFrame);\n\n  if (typeof socketPath !== 'string' || socketPath.length === 0) {\n    throw new Error('createSessionProxy requires a non-empty socketPath');\n  }\n\n  function pauseClientInput() {\n    input.pause?.();\n  }\n\n  function resumeClientInputIfReady() {\n    if (!clientEnded && !stopped && state === 'CONNECTED') input.resume?.();\n  }\n\n  function stopKeepalive() {\n    if (keepaliveInterval !== null) {\n      clearInterval(keepaliveInterval);\n      keepaliveInterval = null;\n    }\n    if (keepaliveTimer !== null) {\n      clearTimeout(keepaliveTimer);\n      keepaliveTimer = null;\n    }\n    pendingKeepaliveId = null;\n  }\n\n  function detachSocket(destroy = true) {\n    stopKeepalive();\n    if (!socket) return;\n    const oldSocket = socket;\n    socket = null;\n    socketHalfClosed = false;","lineStart":1,"lineEnd":420,"totalLines":853,"truncated":true}},"title":".opencode/bin/lib/launcher-session-proxy.cjs","time":{"start":1781763110713,"end":1781763110721}},"metadata":{"openai":{"itemId":"fc_08430863c6a3580e016a338c2697748191a842b5cb59f3af5f"}},"id":"prt_ed95b7736001dmA0di6ttEw4KO","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95b516a001WOShyKIceSyVWM"}}
{"type":"tool_use","timestamp":1781763110727,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_dDQjprFcMqcKr65VehnqSzko","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ COMPONENT: Model Server Supervision                                      ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n5: // ╚══════════════════════════════════════════════════════════════════════════╝\n6: \n7: 'use strict';\n8: \n9: const fs = require('fs');\n10: const http = require('http');\n11: const path = require('path');\n12: const { spawn, spawnSync } = require('child_process');\n13: \n14: const defaultRoot = path.resolve(__dirname, '..', '..', '..');\n15: const defaultOpencodeDir = path.join(defaultRoot, '.opencode');\n16: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n17: \n18: const SHUTDOWN_DEADLINE_MS = 5000;\n19: const RESPAWN_REAP_GRACE_MS = 7000;\n20: const RESPAWN_LOCK_STALE_MS = 60000;\n21: const DEFAULT_WATCHDOG_GRACE_MS = 7000;\n22: const DEFAULT_WATCHDOG_INTERVAL_MS = 15000;\n23: const DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES = 3;\n24: const DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS = 30000;\n25: const DEFAULT_CRASH_LOOP_MAX_DEATHS = 3;\n26: const DEFAULT_CRASH_LOOP_WINDOW_MS = 60000;\n27: const DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS = 250;\n28: const DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS = 5000;\n29: const HF_MODEL_SERVER_SOCKET_FILE_NAME = 'hf-embed.sock';\n30: const HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME = 'hf-embed-respawn.lock';\n31: const HF_MODEL_SERVER_PID_FILE_NAME = 'hf-embed.pid';\n32: const HF_MODEL_SERVER_GIVEUP_FILE_NAME = 'hf-embed-giveup.json';\n33: const MODEL_SERVER_DEMAND_STATUS = 503;\n34: const DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS = 60000;\n35: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n36: const durableWriteWarnings = new Set();\n37: \n38: function defaultLog(message) {\n39:   process.stderr.write(`[model-server-supervision] ${message}\\n`);\n40: }\n41: \n42: function parsePositiveInteger(value, fallback) {\n43:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n44:   const parsed = Number.parseInt(String(value).trim(), 10);\n45:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n46: }\n47: \n48: function isPermissionError(error) {\n49:   const code = error && typeof error === 'object' ? error.code : undefined;\n50:   if (code === 'EPERM' || code === 'EACCES') return true;\n51:   const message = error instanceof Error ? error.message : String(error ?? '');\n52:   return /operation not permitted|permission denied/i.test(message);\n53: }\n54: \n55: function isDurableWriteUnavailable(error) {\n56:   const code = error && typeof error === 'object' ? error.code : undefined;\n57:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n58: }\n59: \n60: function logDurableWriteUnavailableOnce(logger, operation, targetPath, error, rel = (p) => p) {\n61:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n62:   const key = `${operation}:${targetPath}:${code}`;\n63:   if (durableWriteWarnings.has(key)) return;\n64:   durableWriteWarnings.add(key);\n65:   const detail = error instanceof Error ? error.message : String(error ?? code);\n66:   logger(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n67: }\n68: \n69: function cleanupTmpFile(tmpPath, fsApi = fs) {\n70:   try {\n71:     fsApi.unlinkSync(tmpPath);\n72:   } catch (error) {\n73:     if (error.code !== 'ENOENT') {\n74:       // Best-effort cleanup only; the original durable-write failure is more useful.\n75:     }\n76:   }\n77: }\n78: \n79: function parseProcessRows(input) {\n80:   if (Array.isArray(input)) {\n81:     return input\n82:       .map((row) => ({\n83:         pid: Number(row.pid),\n84:         ppid: Number(row.ppid),\n85:         rss: Number(row.rss),\n86:       }))\n87:       .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n88:   }\n89: \n90:   return String(input ?? '')\n91:     .split(/\\r?\\n/)\n92:     .map((line) => line.trim())\n93:     .filter(Boolean)\n94:     .map((line) => {\n95:       const [pid, ppid, rss] = line.split(/\\s+/).map((value) => Number.parseInt(value, 10));\n96:       return { pid, ppid, rss };\n97:     })\n98:     .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n99: }\n100: \n101: function defaultProcessRowsRunner() {\n102:   const result = spawnSync('ps', ['-eo', 'pid=,ppid=,rss='], {\n103:     encoding: 'utf8',\n104:     stdio: ['ignore', 'pipe', 'pipe'],\n105:   });\n106:   if (result.error) throw result.error;\n107:   if (result.status !== 0) {\n108:     const error = new Error(result.stderr || `ps exited ${result.status}`);\n109:     error.code = result.status === 1 && /operation not permitted|permission denied/i.test(result.stderr || '') ? 'EPERM' : 'PS_FAILED';\n110:     throw error;\n111:   }\n112:   return result.stdout;\n113: }\n114: \n115: function resolveProcessTreeRows(childPid, runner = defaultProcessRowsRunner) {\n116:   if (!Number.isInteger(childPid) || childPid <= 0) return null;\n117: \n118:   let rows;\n119:   try {\n120:     rows = parseProcessRows(runner());\n121:   } catch (error) {\n122:     if (isPermissionError(error)) return null;\n123:     throw error;\n124:   }\n125: \n126:   const byPid = new Map();\n127:   const childrenByPpid = new Map();\n128:   for (const row of rows) {\n129:     byPid.set(row.pid, row);\n130:     const children = childrenByPpid.get(row.ppid) || [];\n131:     children.push(row);\n132:     childrenByPpid.set(row.ppid, children);\n133:   }\n134:   if (!byPid.has(childPid)) return null;\n135: \n136:   const subtree = [];\n137:   const stack = [childPid];\n138:   const seen = new Set();\n139:   while (stack.length > 0) {\n140:     const pid = stack.pop();\n141:     if (seen.has(pid)) continue;\n142:     seen.add(pid);\n143:     const row = byPid.get(pid);\n144:     if (row) subtree.push(row);\n145:     for (const child of childrenByPpid.get(pid) || []) {\n146:       stack.push(child.pid);\n147:     }\n148:   }\n149: \n150:   return subtree;\n151: }\n152: \n153: function sampleProcessTreeRssMb(childPid, runner = defaultProcessRowsRunner) {\n154:   const rows = resolveProcessTreeRows(childPid, runner);\n155:   if (!rows) return null;\n156:   const rssKb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0);\n157:   return rssKb / 1024;\n158: }\n159: \n160: function normalizeWatchdogGraceMs(rawGraceMs, warn = defaultLog, envName = 'SPECKIT_LAUNCHER_RSS_GRACE_MS') {\n161:   const parsed = parsePositiveInteger(rawGraceMs, DEFAULT_WATCHDOG_GRACE_MS);\n162:   if (parsed > SHUTDOWN_DEADLINE_MS) return parsed;\n163:   warn(`${envName}=${JSON.stringify(rawGraceMs)} is <= ${SHUTDOWN_DEADLINE_MS}; using ${DEFAULT_WATCHDOG_GRACE_MS}ms`);\n164:   return DEFAULT_WATCHDOG_GRACE_MS;\n165: }\n166: \n167: function getWatchdogConfig(env = process.env, warn = defaultLog, options = {}) {\n168:   const envNames = {\n169:     maxRssMb: options.maxRssMbEnv || 'SPECKIT_CONTEXT_SERVER_MAX_RSS_MB',\n170:     selfExit: options.selfExitEnv || 'SPECKIT_LAUNCHER_RSS_SELF_EXIT',\n171:     intervalMs: options.intervalMsEnv || 'SPECKIT_LAUNCHER_RSS_WATCHDOG_INTERVAL_MS',\n172:     consecutiveBreaches: options.consecutiveBreachesEnv || 'SPECKIT_LAUNCHER_RSS_CONSECUTIVE_BREACHES',\n173:     graceMs: options.graceMsEnv || 'SPECKIT_LAUNCHER_RSS_GRACE_MS',\n174:   };\n175:   const rawMaxRssMb = env[envNames.maxRssMb];\n176:   const maxRssMb = rawMaxRssMb === undefined || rawMaxRssMb === null || String(rawMaxRssMb).trim() === ''\n177:     ? null\n178:     : Number.parseFloat(String(rawMaxRssMb).trim());\n179:   const enabled = Number.isFinite(maxRssMb) && maxRssMb > 0 && env[envNames.selfExit] === '1';\n180:   return {\n181:     enabled,\n182:     maxRssMb,\n183:     intervalMs: parsePositiveInteger(env[envNames.intervalMs], DEFAULT_WATCHDOG_INTERVAL_MS),\n184:     consecutiveBreaches: parsePositiveInteger(env[envNames.consecutiveBreaches], DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES),\n185:     graceMs: normalizeWatchdogGraceMs(env[envNames.graceMs], warn, envNames.graceMs),\n186:     maxRssMbEnv: envNames.maxRssMb,\n187:     selfExitEnv: envNames.selfExit,\n188:   };\n189: }\n190: \n191: function getModelServerWatchdogConfig(env = process.env, warn = defaultLog) {\n192:   return getWatchdogConfig(env, warn, {\n193:     maxRssMbEnv: 'SPECKIT_HF_MODEL_SERVER_MAX_RSS_MB',\n194:     selfExitEnv: 'SPECKIT_HF_MODEL_SERVER_RSS_SELF_EXIT',\n195:   });\n196: }\n197: \n198: function getModelServerIdleConfig(env = process.env) {\n199:   const rawIdleMin = env.SPECKIT_HF_MODEL_SERVER_IDLE_TIMEOUT_MIN;\n200:   const idleMin = rawIdleMin === undefined || rawIdleMin === null || String(rawIdleMin).trim() === ''\n201:     ? 0\n202:     : Number.parseFloat(String(rawIdleMin).trim());\n203:   const enabled = Number.isFinite(idleMin) && idleMin > 0;\n204:   return {\n205:     enabled,\n206:     timeoutMs: enabled ? idleMin * 60000 : 0,\n207:   };\n208: }\n209: \n210: function computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs) {\n211:   const exponent = Math.max(0, deathsInWindow - 1);\n212:   return Math.min(maxBackoffMs, initialBackoffMs * (2 ** exponent));\n213: }\n214: \n215: function createCrashLoopGuard(options = {}) {\n216:   const maxDeaths = parsePositiveInteger(options.maxDeaths, DEFAULT_CRASH_LOOP_MAX_DEATHS);\n217:   const windowMs = parsePositiveInteger(options.windowMs, DEFAULT_CRASH_LOOP_WINDOW_MS);\n218:   const initialBackoffMs = parsePositiveInteger(options.initialBackoffMs, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS);\n219:   const maxBackoffMs = parsePositiveInteger(options.maxBackoffMs, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS);\n220:   const nowMs = typeof options.now === 'function' ? options.now : () => Date.now();\n221:   const deaths = [];\n222: \n223:   return {\n224:     recordDeath() {\n225:       const current = nowMs();\n226:       deaths.push(current);\n227:       while (deaths.length > 0 && current - deaths[0] > windowMs) deaths.shift();\n228:       const deathsInWindow = deaths.length;\n229:       return {\n230:         deathsInWindow,\n231:         giveUp: deathsInWindow >= maxDeaths,\n232:         backoffMs: computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs),\n233:       };\n234:     },\n235:   };\n236: }\n237: \n238: function getCrashLoopConfig(env = process.env) {\n239:   return {\n240:     maxDeaths: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_DEATHS, DEFAULT_CRASH_LOOP_MAX_DEATHS),\n241:     windowMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_WINDOW_MS, DEFAULT_CRASH_LOOP_WINDOW_MS),\n242:     initialBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_INITIAL_BACKOFF_MS, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS),\n243:     maxBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_BACKOFF_MS, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS),\n244:   };\n245: }\n246: \n247: function getModelServerGiveUpCooldownMs(env = process.env) {\n248:   return parsePositiveInteger(env.SPECKIT_HF_MODEL_SERVER_GIVEUP_COOLDOWN_MS, DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS);\n249: }\n250: \n251: function superviseChildExit(event, actions) {\n252:   if (event.intentional) {\n253:     actions.clearLease();\n254:     actions.exit(event.code ?? 0);\n255:     return { action: 'intentional-exit' };\n256:   }\n257: \n258:   const decision = actions.crashLoopGuard.recordDeath();\n259:   if (decision.giveUp) {\n260:     actions.clearLease();\n261:     actions.reapProcessGroup(event.childPid);\n262:     if (event.signal) {\n263:       actions.mirrorSignal(event.signal);\n264:     } else {\n265:       actions.exit(event.code ?? 1);\n266:     }\n267:     return { action: 'give-up', deathsInWindow: decision.deathsInWindow };\n268:   }\n269: \n270:   actions.scheduleRelaunch(decision.backoffMs);\n271:   return { action: 'relaunch', deathsInWindow: decision.deathsInWindow, backoffMs: decision.backoffMs };\n272: }\n273: \n274: function processLiveness(pid) {\n275:   if (!Number.isInteger(pid) || pid <= 0) return 'dead';\n276:   try {\n277:     process.kill(pid, 0);\n278:     return 'alive';\n279:   } catch (error) {\n280:     if (error.code === 'ESRCH') return 'dead';\n281:     if (error.code === 'EPERM') return 'unknown-eperm';\n282:     return 'alive';\n283:   }\n284: }\n285: \n286: async function waitForPidExit(pid, timeoutMs) {\n287:   const deadline = Date.now() + timeoutMs;\n288:   while (Date.now() <= deadline) {\n289:     if (processLiveness(pid) === 'dead') return true;\n290:     await sleep(100);\n291:   }\n292:   return processLiveness(pid) === 'dead';\n293: }\n294: \n295: function signalProcess(pid, signal) {\n296:   try {\n297:     process.kill(pid, signal);\n298:     return true;\n299:   } catch (error) {\n300:     if (error.code === 'ESRCH' || error.code === 'EPERM') return false;\n301:     throw error;\n302:   }\n303: }\n304: \n305: function isChildRunning(child) {\n306:   return child && child.exitCode === null && child.signalCode === null;\n307: }\n308: \n309: function shouldSkipLaunch(child) {\n310:   return Boolean(child && isChildRunning(child));\n311: }\n312: \n313: // A scheduled daemon relaunch must be ABORTED when its backoff fires under a dying owner.\n314: // The MCP host spawns the launcher directly, so a parent pid that no longer matches the value\n315: // captured at startup (or has reparented to the init/subreaper pid 1) means the owning session\n316: // disposed; respawning then would only flap the daemon under a runtime that is going away and\n317: // drop every bridged transport. Crash-recovery and RSS-recycle fire with the owner alive and a\n318: // matching ppid, so this stays a no-op for them.\n319: function shouldAbortRelaunchOnFire({ shuttingDown, currentPpid, initialPpid } = {}) {\n320:   return Boolean(shuttingDown) || currentPpid !== initialPpid || currentPpid === 1;\n321: }\n322: \n323: function refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner, options = {}) {\n324:   const snapshot = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n325:   const rows = resolveProcessTreeRows(childPid, runner);\n326:   if (rows === null) return snapshot;\n327:   const pids = rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1);\n328:   if (options.snapshot && typeof options.snapshot.set === 'function') {\n329:     options.snapshot.set(pids);\n330:   }\n331:   return pids;\n332: }\n333: \n334: function reapProcessTreeGroups(childPid, options = {}) {\n335:   const runner = options.runner || defaultProcessRowsRunner;\n336:   const signal = options.signal || signalProcess;\n337:   const snapshotPids = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n338: \n339:   const liveRows = resolveProcessTreeRows(childPid, runner);\n340:   const liveDescendants = liveRows ? liveRows.map((row) => row.pid).filter((pid) => pid !== childPid) : [];\n341: \n342:   const candidates = [...new Set([...liveDescendants, ...snapshotPids])].filter(\n343:     (pid) => Number.isInteger(pid) && pid > 1 && pid !== childPid && pid !== process.pid && signal(pid, 0),\n344:   );\n345:   if (candidates.length === 0) return;\n346: \n347:   for (const pid of candidates) {\n348:     if (process.platform !== 'win32') signal(-pid, 'SIGTERM');\n349:     signal(pid, 'SIGTERM');\n350:   }\n351:   setTimeout(() => {\n352:     for (const pid of candidates) {\n353:       if (process.platform !== 'win32') signal(-pid, 'SIGKILL');\n354:       signal(pid, 'SIGKILL');\n355:     }\n356:   }, 1000).unref();\n357: }\n358: \n359: function startRssWatchdog(childPid, options = {}) {\n360:   let fallbackTimer = null;\n361:   const timerState = options.timerState || {\n362:     get: () => fallbackTimer,\n363:     set: (timer) => {\n364:       fallbackTimer = timer;\n365:     },\n366:   };\n367:   const existingTimer = timerState.get();\n368:   if (existingTimer) {\n369:     clearInterval(existingTimer);\n370:     timerState.set(null);\n371:   }\n372:   const logger = options.log || defaultLog;\n373:   const label = options.label || 'context-server';\n374:   const runner = options.runner || defaultProcessRowsRunner;\n375:   let fallbackSnapshotPids = [];\n376:   const snapshot = options.snapshot || {\n377:     set: (pids) => {\n378:       fallbackSnapshotPids = pids;\n379:     },\n380:     get: () => fallbackSnapshotPids,\n381:   };\n382:   const config = options.config || getWatchdogConfig(process.env, logger);\n383:   if (!config.enabled && config.maxRssMb !== null && Number.isFinite(config.maxRssMb) && config.maxRssMb > 0) {\n384:     logger(`RSS watchdog ceiling configured but ${config.selfExitEnv}=1 is not set; breach self-exit remains disabled (descendant tracking still active for crash-loop reap)`);\n385:   }\n386: \n387:   const tickMs = config.enabled ? config.intervalMs : DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS;\n388:   let consecutiveBreaches = 0;\n389:   const timer = setInterval(() => {\n390:     const rows = resolveProcessTreeRows(childPid, runner);\n391:     if (rows === null) {\n392:       consecutiveBreaches = 0;\n393:       return;\n394:     }\n395:     snapshot.set(rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1));\n396:     if (!config.enabled) return;\n397:     const rssMb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0) / 1024;\n398:     if (rssMb <= config.maxRssMb) {\n399:       consecutiveBreaches = 0;\n400:       return;\n401:     }\n402:     consecutiveBreaches++;\n403:     logger(`${label} process tree RSS ${rssMb.toFixed(1)} MB exceeds ${config.maxRssMb} MB (${consecutiveBreaches}/${config.consecutiveBreaches})`);\n404:     if (consecutiveBreaches >= config.consecutiveBreaches) {\n405:       const onBreach = options.onBreach || (() => undefined);\n406:       void onBreach(config);\n407:     }\n408:   }, tickMs);\n409:   timer.unref?.();\n410:   timerState.set(timer);\n411:   return timer;\n412: }\n413: \n414: function canonicalizePath(pathValue) {\n415:   const resolvedPath = path.resolve(pathValue);\n416:   try {\n417:     return fs.realpathSync.native(resolvedPath);\n418:   } catch (error) {\n419:     if (error.code === 'ENOENT') return resolvedPath;\n420:     throw error;\n\n(Showing lines 1-420 of 1474. Use offset=421 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: Model Server Supervision                                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\n\nconst defaultRoot = path.resolve(__dirname, '..', '..', '..');\nconst defaultOpencodeDir = path.join(defaultRoot, '.opencode');\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nconst SHUTDOWN_DEADLINE_MS = 5000;\nconst RESPAWN_REAP_GRACE_MS = 7000;\nconst RESPAWN_LOCK_STALE_MS = 60000;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: Model Server Supervision                                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\n\nconst defaultRoot = path.resolve(__dirname, '..', '..', '..');\nconst defaultOpencodeDir = path.join(defaultRoot, '.opencode');\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nconst SHUTDOWN_DEADLINE_MS = 5000;\nconst RESPAWN_REAP_GRACE_MS = 7000;\nconst RESPAWN_LOCK_STALE_MS = 60000;\nconst DEFAULT_WATCHDOG_GRACE_MS = 7000;\nconst DEFAULT_WATCHDOG_INTERVAL_MS = 15000;\nconst DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES = 3;\nconst DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS = 30000;\nconst DEFAULT_CRASH_LOOP_MAX_DEATHS = 3;\nconst DEFAULT_CRASH_LOOP_WINDOW_MS = 60000;\nconst DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS = 250;\nconst DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS = 5000;\nconst HF_MODEL_SERVER_SOCKET_FILE_NAME = 'hf-embed.sock';\nconst HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME = 'hf-embed-respawn.lock';\nconst HF_MODEL_SERVER_PID_FILE_NAME = 'hf-embed.pid';\nconst HF_MODEL_SERVER_GIVEUP_FILE_NAME = 'hf-embed-giveup.json';\nconst MODEL_SERVER_DEMAND_STATUS = 503;\nconst DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS = 60000;\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n\nfunction defaultLog(message) {\n  process.stderr.write(`[model-server-supervision] ${message}\\n`);\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isPermissionError(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  if (code === 'EPERM' || code === 'EACCES') return true;\n  const message = error instanceof Error ? error.message : String(error ?? '');\n  return /operation not permitted|permission denied/i.test(message);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(logger, operation, targetPath, error, rel = (p) => p) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  logger(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\nfunction cleanupTmpFile(tmpPath, fsApi = fs) {\n  try {\n    fsApi.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction parseProcessRows(input) {\n  if (Array.isArray(input)) {\n    return input\n      .map((row) => ({\n        pid: Number(row.pid),\n        ppid: Number(row.ppid),\n        rss: Number(row.rss),\n      }))\n      .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n  }\n\n  return String(input ?? '')\n    .split(/\\r?\\n/)\n    .map((line) => line.trim())\n    .filter(Boolean)\n    .map((line) => {\n      const [pid, ppid, rss] = line.split(/\\s+/).map((value) => Number.parseInt(value, 10));\n      return { pid, ppid, rss };\n    })\n    .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n}\n\nfunction defaultProcessRowsRunner() {\n  const result = spawnSync('ps', ['-eo', 'pid=,ppid=,rss='], {\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n  if (result.error) throw result.error;\n  if (result.status !== 0) {\n    const error = new Error(result.stderr || `ps exited ${result.status}`);\n    error.code = result.status === 1 && /operation not permitted|permission denied/i.test(result.stderr || '') ? 'EPERM' : 'PS_FAILED';\n    throw error;\n  }\n  return result.stdout;\n}\n\nfunction resolveProcessTreeRows(childPid, runner = defaultProcessRowsRunner) {\n  if (!Number.isInteger(childPid) || childPid <= 0) return null;\n\n  let rows;\n  try {\n    rows = parseProcessRows(runner());\n  } catch (error) {\n    if (isPermissionError(error)) return null;\n    throw error;\n  }\n\n  const byPid = new Map();\n  const childrenByPpid = new Map();\n  for (const row of rows) {\n    byPid.set(row.pid, row);\n    const children = childrenByPpid.get(row.ppid) || [];\n    children.push(row);\n    childrenByPpid.set(row.ppid, children);\n  }\n  if (!byPid.has(childPid)) return null;\n\n  const subtree = [];\n  const stack = [childPid];\n  const seen = new Set();\n  while (stack.length > 0) {\n    const pid = stack.pop();\n    if (seen.has(pid)) continue;\n    seen.add(pid);\n    const row = byPid.get(pid);\n    if (row) subtree.push(row);\n    for (const child of childrenByPpid.get(pid) || []) {\n      stack.push(child.pid);\n    }\n  }\n\n  return subtree;\n}\n\nfunction sampleProcessTreeRssMb(childPid, runner = defaultProcessRowsRunner) {\n  const rows = resolveProcessTreeRows(childPid, runner);\n  if (!rows) return null;\n  const rssKb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0);\n  return rssKb / 1024;\n}\n\nfunction normalizeWatchdogGraceMs(rawGraceMs, warn = defaultLog, envName = 'SPECKIT_LAUNCHER_RSS_GRACE_MS') {\n  const parsed = parsePositiveInteger(rawGraceMs, DEFAULT_WATCHDOG_GRACE_MS);\n  if (parsed > SHUTDOWN_DEADLINE_MS) return parsed;\n  warn(`${envName}=${JSON.stringify(rawGraceMs)} is <= ${SHUTDOWN_DEADLINE_MS}; using ${DEFAULT_WATCHDOG_GRACE_MS}ms`);\n  return DEFAULT_WATCHDOG_GRACE_MS;\n}\n\nfunction getWatchdogConfig(env = process.env, warn = defaultLog, options = {}) {\n  const envNames = {\n    maxRssMb: options.maxRssMbEnv || 'SPECKIT_CONTEXT_SERVER_MAX_RSS_MB',\n    selfExit: options.selfExitEnv || 'SPECKIT_LAUNCHER_RSS_SELF_EXIT',\n    intervalMs: options.intervalMsEnv || 'SPECKIT_LAUNCHER_RSS_WATCHDOG_INTERVAL_MS',\n    consecutiveBreaches: options.consecutiveBreachesEnv || 'SPECKIT_LAUNCHER_RSS_CONSECUTIVE_BREACHES',\n    graceMs: options.graceMsEnv || 'SPECKIT_LAUNCHER_RSS_GRACE_MS',\n  };\n  const rawMaxRssMb = env[envNames.maxRssMb];\n  const maxRssMb = rawMaxRssMb === undefined || rawMaxRssMb === null || String(rawMaxRssMb).trim() === ''\n    ? null\n    : Number.parseFloat(String(rawMaxRssMb).trim());\n  const enabled = Number.isFinite(maxRssMb) && maxRssMb > 0 && env[envNames.selfExit] === '1';\n  return {\n    enabled,\n    maxRssMb,\n    intervalMs: parsePositiveInteger(env[envNames.intervalMs], DEFAULT_WATCHDOG_INTERVAL_MS),\n    consecutiveBreaches: parsePositiveInteger(env[envNames.consecutiveBreaches], DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES),\n    graceMs: normalizeWatchdogGraceMs(env[envNames.graceMs], warn, envNames.graceMs),\n    maxRssMbEnv: envNames.maxRssMb,\n    selfExitEnv: envNames.selfExit,\n  };\n}\n\nfunction getModelServerWatchdogConfig(env = process.env, warn = defaultLog) {\n  return getWatchdogConfig(env, warn, {\n    maxRssMbEnv: 'SPECKIT_HF_MODEL_SERVER_MAX_RSS_MB',\n    selfExitEnv: 'SPECKIT_HF_MODEL_SERVER_RSS_SELF_EXIT',\n  });\n}\n\nfunction getModelServerIdleConfig(env = process.env) {\n  const rawIdleMin = env.SPECKIT_HF_MODEL_SERVER_IDLE_TIMEOUT_MIN;\n  const idleMin = rawIdleMin === undefined || rawIdleMin === null || String(rawIdleMin).trim() === ''\n    ? 0\n    : Number.parseFloat(String(rawIdleMin).trim());\n  const enabled = Number.isFinite(idleMin) && idleMin > 0;\n  return {\n    enabled,\n    timeoutMs: enabled ? idleMin * 60000 : 0,\n  };\n}\n\nfunction computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs) {\n  const exponent = Math.max(0, deathsInWindow - 1);\n  return Math.min(maxBackoffMs, initialBackoffMs * (2 ** exponent));\n}\n\nfunction createCrashLoopGuard(options = {}) {\n  const maxDeaths = parsePositiveInteger(options.maxDeaths, DEFAULT_CRASH_LOOP_MAX_DEATHS);\n  const windowMs = parsePositiveInteger(options.windowMs, DEFAULT_CRASH_LOOP_WINDOW_MS);\n  const initialBackoffMs = parsePositiveInteger(options.initialBackoffMs, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS);\n  const maxBackoffMs = parsePositiveInteger(options.maxBackoffMs, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS);\n  const nowMs = typeof options.now === 'function' ? options.now : () => Date.now();\n  const deaths = [];\n\n  return {\n    recordDeath() {\n      const current = nowMs();\n      deaths.push(current);\n      while (deaths.length > 0 && current - deaths[0] > windowMs) deaths.shift();\n      const deathsInWindow = deaths.length;\n      return {\n        deathsInWindow,\n        giveUp: deathsInWindow >= maxDeaths,\n        backoffMs: computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs),\n      };\n    },\n  };\n}\n\nfunction getCrashLoopConfig(env = process.env) {\n  return {\n    maxDeaths: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_DEATHS, DEFAULT_CRASH_LOOP_MAX_DEATHS),\n    windowMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_WINDOW_MS, DEFAULT_CRASH_LOOP_WINDOW_MS),\n    initialBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_INITIAL_BACKOFF_MS, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS),\n    maxBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_BACKOFF_MS, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS),\n  };\n}\n\nfunction getModelServerGiveUpCooldownMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_HF_MODEL_SERVER_GIVEUP_COOLDOWN_MS, DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS);\n}\n\nfunction superviseChildExit(event, actions) {\n  if (event.intentional) {\n    actions.clearLease();\n    actions.exit(event.code ?? 0);\n    return { action: 'intentional-exit' };\n  }\n\n  const decision = actions.crashLoopGuard.recordDeath();\n  if (decision.giveUp) {\n    actions.clearLease();\n    actions.reapProcessGroup(event.childPid);\n    if (event.signal) {\n      actions.mirrorSignal(event.signal);\n    } else {\n      actions.exit(event.code ?? 1);\n    }\n    return { action: 'give-up', deathsInWindow: decision.deathsInWindow };\n  }\n\n  actions.scheduleRelaunch(decision.backoffMs);\n  return { action: 'relaunch', deathsInWindow: decision.deathsInWindow, backoffMs: decision.backoffMs };\n}\n\nfunction processLiveness(pid) {\n  if (!Number.isInteger(pid) || pid <= 0) return 'dead';\n  try {\n    process.kill(pid, 0);\n    return 'alive';\n  } catch (error) {\n    if (error.code === 'ESRCH') return 'dead';\n    if (error.code === 'EPERM') return 'unknown-eperm';\n    return 'alive';\n  }\n}\n\nasync function waitForPidExit(pid, timeoutMs) {\n  const deadline = Date.now() + timeoutMs;\n  while (Date.now() <= deadline) {\n    if (processLiveness(pid) === 'dead') return true;\n    await sleep(100);\n  }\n  return processLiveness(pid) === 'dead';\n}\n\nfunction signalProcess(pid, signal) {\n  try {\n    process.kill(pid, signal);\n    return true;\n  } catch (error) {\n    if (error.code === 'ESRCH' || error.code === 'EPERM') return false;\n    throw error;\n  }\n}\n\nfunction isChildRunning(child) {\n  return child && child.exitCode === null && child.signalCode === null;\n}\n\nfunction shouldSkipLaunch(child) {\n  return Boolean(child && isChildRunning(child));\n}\n\n// A scheduled daemon relaunch must be ABORTED when its backoff fires under a dying owner.\n// The MCP host spawns the launcher directly, so a parent pid that no longer matches the value\n// captured at startup (or has reparented to the init/subreaper pid 1) means the owning session\n// disposed; respawning then would only flap the daemon under a runtime that is going away and\n// drop every bridged transport. Crash-recovery and RSS-recycle fire with the owner alive and a\n// matching ppid, so this stays a no-op for them.\nfunction shouldAbortRelaunchOnFire({ shuttingDown, currentPpid, initialPpid } = {}) {\n  return Boolean(shuttingDown) || currentPpid !== initialPpid || currentPpid === 1;\n}\n\nfunction refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner, options = {}) {\n  const snapshot = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n  const rows = resolveProcessTreeRows(childPid, runner);\n  if (rows === null) return snapshot;\n  const pids = rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1);\n  if (options.snapshot && typeof options.snapshot.set === 'function') {\n    options.snapshot.set(pids);\n  }\n  return pids;\n}\n\nfunction reapProcessTreeGroups(childPid, options = {}) {\n  const runner = options.runner || defaultProcessRowsRunner;\n  const signal = options.signal || signalProcess;\n  const snapshotPids = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n\n  const liveRows = resolveProcessTreeRows(childPid, runner);\n  const liveDescendants = liveRows ? liveRows.map((row) => row.pid).filter((pid) => pid !== childPid) : [];\n\n  const candidates = [...new Set([...liveDescendants, ...snapshotPids])].filter(\n    (pid) => Number.isInteger(pid) && pid > 1 && pid !== childPid && pid !== process.pid && signal(pid, 0),\n  );\n  if (candidates.length === 0) return;\n\n  for (const pid of candidates) {\n    if (process.platform !== 'win32') signal(-pid, 'SIGTERM');\n    signal(pid, 'SIGTERM');\n  }\n  setTimeout(() => {\n    for (const pid of candidates) {\n      if (process.platform !== 'win32') signal(-pid, 'SIGKILL');\n      signal(pid, 'SIGKILL');\n    }\n  }, 1000).unref();\n}\n\nfunction startRssWatchdog(childPid, options = {}) {\n  let fallbackTimer = null;\n  const timerState = options.timerState || {\n    get: () => fallbackTimer,\n    set: (timer) => {\n      fallbackTimer = timer;\n    },\n  };\n  const existingTimer = timerState.get();\n  if (existingTimer) {\n    clearInterval(existingTimer);\n    timerState.set(null);\n  }\n  const logger = options.log || defaultLog;\n  const label = options.label || 'context-server';\n  const runner = options.runner || defaultProcessRowsRunner;\n  let fallbackSnapshotPids = [];\n  const snapshot = options.snapshot || {\n    set: (pids) => {\n      fallbackSnapshotPids = pids;\n    },\n    get: () => fallbackSnapshotPids,\n  };\n  const config = options.config || getWatchdogConfig(process.env, logger);\n  if (!config.enabled && config.maxRssMb !== null && Number.isFinite(config.maxRssMb) && config.maxRssMb > 0) {\n    logger(`RSS watchdog ceiling configured but ${config.selfExitEnv}=1 is not set; breach self-exit remains disabled (descendant tracking still active for crash-loop reap)`);\n  }\n\n  const tickMs = config.enabled ? config.intervalMs : DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS;\n  let consecutiveBreaches = 0;\n  const timer = setInterval(() => {\n    const rows = resolveProcessTreeRows(childPid, runner);\n    if (rows === null) {\n      consecutiveBreaches = 0;\n      return;\n    }\n    snapshot.set(rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1));\n    if (!config.enabled) return;\n    const rssMb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0) / 1024;\n    if (rssMb <= config.maxRssMb) {\n      consecutiveBreaches = 0;\n      return;\n    }\n    consecutiveBreaches++;\n    logger(`${label} process tree RSS ${rssMb.toFixed(1)} MB exceeds ${config.maxRssMb} MB (${consecutiveBreaches}/${config.consecutiveBreaches})`);\n    if (consecutiveBreaches >= config.consecutiveBreaches) {\n      const onBreach = options.onBreach || (() => undefined);\n      void onBreach(config);\n    }\n  }, tickMs);\n  timer.unref?.();\n  timerState.set(timer);\n  return timer;\n}\n\nfunction canonicalizePath(pathValue) {\n  const resolvedPath = path.resolve(pathValue);\n  try {\n    return fs.realpathSync.native(resolvedPath);\n  } catch (error) {\n    if (error.code === 'ENOENT') return resolvedPath;\n    throw error;","lineStart":1,"lineEnd":420,"totalLines":1474,"truncated":true}},"title":".opencode/bin/lib/model-server-supervision.cjs","time":{"start":1781763110716,"end":1781763110725}},"metadata":{"openai":{"itemId":"fc_08430863c6a3580e016a338c26977c8191a83ddaa54530f04b"}},"id":"prt_ed95b773a001jUHgpD9uTO5bUb","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95b516a001WOShyKIceSyVWM"}}
{"type":"tool_use","timestamp":1781763110734,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_xvE87ESpb6WSg8mimmBzK2jV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Tool Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: // All MCP tool definitions (names, descriptions, input schemas).\n5: // Extracted from context-server.ts for maintainability.\n6: import {\n7:   MAX_INGEST_PATHS,\n8:   MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n9: } from './schemas/tool-input-schemas.js';\n10: \n11: /**\n12:  * Re-export schema validation helpers used by the MCP tool entry points.\n13:  */\n14: export {\n15:   ToolSchemaValidationError,\n16:   formatZodError,\n17:   getToolSchema,\n18:   validateToolArgs,\n19:   getSchema,\n20: } from './schemas/tool-input-schemas.js';\n21: \n22: // ───────────────────────────────────────────────────────────────\n23: // 1. TYPES\n24: \n25: // ───────────────────────────────────────────────────────────────\n26: /**\n27:  * Normalized definition for a single MCP tool and its JSON schema.\n28:  */\n29: export interface ToolDefinition {\n30:   name: string;\n31:   description: string;\n32:   inputSchema: Record<string, unknown>;\n33:   outputSchema?: Record<string, unknown>;\n34: }\n35: \n36: export type ToolOwnershipStability = 'stable' | 'deprecated';\n37: \n38: export interface ToolOwnershipEntry {\n39:   name: string;\n40:   owner: string;\n41:   stability: ToolOwnershipStability;\n42:   level: string;\n43:   category: string;\n44: }\n45: \n46: export interface ToolOwnershipMap {\n47:   schemaVersion: 1;\n48:   generatedFrom: 'TOOL_DEFINITIONS';\n49:   tools: ToolOwnershipEntry[];\n50: }\n51: \n52: export interface ToolOwnershipDriftReport {\n53:   ok: boolean;\n54:   missingFromCommitted: string[];\n55:   extraInCommitted: string[];\n56:   changed: Array<{\n57:     name: string;\n58:     field: keyof Omit<ToolOwnershipEntry, 'name'>;\n59:     expected: string;\n60:     actual: string;\n61:   }>;\n62:   expectedMap: ToolOwnershipMap;\n63: }\n64: \n65: const TOOL_OWNER_BY_CATEGORY: Record<string, string> = Object.freeze({\n66:   Orchestration: 'memory-orchestration',\n67:   Core: 'memory-core',\n68:   Discovery: 'memory-discovery',\n69:   Mutation: 'memory-mutation',\n70:   Lifecycle: 'memory-lifecycle',\n71:   Analysis: 'memory-analysis',\n72:   Maintenance: 'memory-maintenance',\n73: });\n74: \n75: function readToolContract(definition: ToolDefinition): { level: string; category: string } {\n76:   const match = /^\\[([^:\\]]+):([^\\]]+)\\]/.exec(definition.description);\n77:   if (!match) {\n78:     return { level: 'unclassified', category: 'unclassified' };\n79:   }\n80:   return {\n81:     level: match[1] ?? 'unclassified',\n82:     category: match[2] ?? 'unclassified',\n83:   };\n84: }\n85: \n86: function deriveToolOwnershipEntry(definition: ToolDefinition): ToolOwnershipEntry {\n87:   const contract = readToolContract(definition);\n88:   return {\n89:     name: definition.name,\n90:     owner: TOOL_OWNER_BY_CATEGORY[contract.category] ?? 'memory-unclassified',\n91:     stability: /^\\[deprecated\\]/i.test(definition.description) ? 'deprecated' : 'stable',\n92:     level: contract.level,\n93:     category: contract.category,\n94:   };\n95: }\n96: \n97: function normalizeToolOwnershipMap(map: ToolOwnershipMap): ToolOwnershipMap {\n98:   return {\n99:     schemaVersion: 1,\n100:     generatedFrom: 'TOOL_DEFINITIONS',\n101:     tools: [...map.tools].sort((a, b) => a.name.localeCompare(b.name)),\n102:   };\n103: }\n104: \n105: function isToolOwnershipEntry(value: unknown): value is ToolOwnershipEntry {\n106:   if (!value || typeof value !== 'object' || Array.isArray(value)) return false;\n107:   const record = value as Record<string, unknown>;\n108:   return (\n109:     typeof record.name === 'string' &&\n110:     typeof record.owner === 'string' &&\n111:     (record.stability === 'stable' || record.stability === 'deprecated') &&\n112:     typeof record.level === 'string' &&\n113:     typeof record.category === 'string'\n114:   );\n115: }\n116: \n117: function parseToolOwnershipMap(value: unknown): ToolOwnershipMap | null {\n118:   let parsed: unknown;\n119:   try {\n120:     parsed = typeof value === 'string' ? JSON.parse(value) as unknown : value;\n121:   } catch (_error: unknown) {\n122:     return null;\n123:   }\n124:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;\n125:   const record = parsed as Record<string, unknown>;\n126:   if (record.schemaVersion !== 1 || record.generatedFrom !== 'TOOL_DEFINITIONS') return null;\n127:   if (!Array.isArray(record.tools) || !record.tools.every(isToolOwnershipEntry)) return null;\n128:   return normalizeToolOwnershipMap({\n129:     schemaVersion: 1,\n130:     generatedFrom: 'TOOL_DEFINITIONS',\n131:     tools: record.tools,\n132:   });\n133: }\n134: \n135: /** Derive the deterministic tool ownership map from live tool definitions. */\n136: export function deriveToolOwnershipMap(\n137:   toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n138: ): ToolOwnershipMap {\n139:   return normalizeToolOwnershipMap({\n140:     schemaVersion: 1,\n141:     generatedFrom: 'TOOL_DEFINITIONS',\n142:     tools: toolDefinitions.map(deriveToolOwnershipEntry),\n143:   });\n144: }\n145: \n146: /** Serialize a derived ownership map for byte-identical generated output. */\n147: export function serializeToolOwnershipMap(map: ToolOwnershipMap = deriveToolOwnershipMap()): string {\n148:   return `${JSON.stringify(normalizeToolOwnershipMap(map), null, 2)}\\n`;\n149: }\n150: \n151: /** Compare a committed ownership map with a fresh derivation. */\n152: export function lintToolOwnershipMapDrift(\n153:   committedMap: unknown,\n154:   toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n155: ): ToolOwnershipDriftReport {\n156:   const expectedMap = deriveToolOwnershipMap(toolDefinitions);\n157:   const parsed = parseToolOwnershipMap(committedMap);\n158:   if (!parsed) {\n159:     return {\n160:       ok: false,\n161:       missingFromCommitted: expectedMap.tools.map((tool) => tool.name),\n162:       extraInCommitted: [],\n163:       changed: [],\n164:       expectedMap,\n165:     };\n166:   }\n167: \n168:   const expectedByName = new Map(expectedMap.tools.map((tool) => [tool.name, tool]));\n169:   const actualByName = new Map(parsed.tools.map((tool) => [tool.name, tool]));\n170:   const missingFromCommitted = expectedMap.tools\n171:     .filter((tool) => !actualByName.has(tool.name))\n172:     .map((tool) => tool.name);\n173:   const extraInCommitted = parsed.tools\n174:     .filter((tool) => !expectedByName.has(tool.name))\n175:     .map((tool) => tool.name);\n176:   const changed: ToolOwnershipDriftReport['changed'] = [];\n177:   const fields: Array<keyof Omit<ToolOwnershipEntry, 'name'>> = ['owner', 'stability', 'level', 'category'];\n178: \n179:   for (const expected of expectedMap.tools) {\n180:     const actual = actualByName.get(expected.name);\n181:     if (!actual) continue;\n182:     for (const field of fields) {\n183:       if (expected[field] !== actual[field]) {\n184:         changed.push({\n185:           name: expected.name,\n186:           field,\n187:           expected: expected[field],\n188:           actual: actual[field],\n189:         });\n190:       }\n191:     }\n192:   }\n193: \n194:   return {\n195:     ok: missingFromCommitted.length === 0 && extraInCommitted.length === 0 && changed.length === 0,\n196:     missingFromCommitted,\n197:     extraInCommitted,\n198:     changed,\n199:     expectedMap,\n200:   };\n201: }\n202: \n203: // ───────────────────────────────────────────────────────────────\n204: // 2. TOOL DEFINITIONS\n205: \n206: // ───────────────────────────────────────────────────────────────\n207: // L1 Orchestration - Unified entry point (Token Budget: 3500)\n208: const memoryContext: ToolDefinition = {\n209:   name: 'memory_context',\n210:   description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n211:   inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n212: };\n213: \n214: // L2: Core - Primary operations (Token Budget: 3500)\n215: const memorySearch: ToolDefinition = {\n216:   name: 'memory_search',\n217:   description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n218:   inputSchema: {\n219:     type: 'object',\n220:     additionalProperties: false,\n221:     'x-requiredAnyOf': [['query'], ['concepts'], ['cursor']],\n222:     properties: {\n223:       cursor: {\n224:         type: 'string',\n225:         minLength: 1,\n226:         description: 'Opaque continuation cursor returned by progressive disclosure. When provided, resolves the next page without requiring a new query.'\n227:       },\n228:       query: { type: 'string', minLength: 2, maxLength: 1000, description: 'Natural language search query' },\n229:       concepts: {\n230:         type: 'array',\n231:         items: { type: 'string', minLength: 1 },\n232:         minItems: 2,\n233:         maxItems: 5,\n234:         description: 'Multiple concepts for AND search (requires 2-5 concepts). Results must match ALL concepts.'\n235:       },\n236:       specFolder: { type: 'string', description: 'Limit search to a specific spec folder (e.g., \"011-spec-kit-memory-upgrade\")' },\n237:       tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval. When provided with scope enforcement, results are isolated to this tenant.' },\n238:       userId: { type: 'string', description: 'User boundary for governed retrieval. Filters private user-scoped spec-doc records.' },\n239:       agentId: { type: 'string', description: 'Agent boundary for governed retrieval. Filters agent-scoped spec-doc records.' },\n240:       limit: { type: 'number', default: 10, minimum: 1, maximum: 100, description: 'Maximum number of results to return (1-100)' },\n241:       sessionId: {\n242:         type: 'string',\n243:         description: 'Session identifier for working memory and session deduplication (REQ-001). When provided with enableDedup=true, prevents duplicate spec-doc records from being returned in the same session (~50% token savings on follow-up queries).'\n244:       },\n245:       enableDedup: {\n246:         type: 'boolean',\n247:         default: true,\n248:         description: 'Enable session deduplication (REQ-001). When true and sessionId provided, filters out already-sent spec-doc records.'\n249:       },\n250:       tier: { type: 'string', description: 'Filter by importance tier (constitutional, critical, important, normal, temporary, deprecated)' },\n251:       contextType: { type: 'string', description: 'Filter by context type (decision, implementation, research, etc.)' },\n252:       useDecay: { type: 'boolean', default: true, description: 'Apply temporal decay scoring to results' },\n253:       includeContiguity: { type: 'boolean', default: false, description: 'Include adjacent/contiguous spec-doc records (from the same packet, neighboring sections) in results' },\n254:       includeConstitutional: {\n255:         type: 'boolean',\n256:         default: true,\n257:         description: 'Include constitutional tier rules at top of results (default: true)'\n258:       },\n259:       enableSessionBoost: {\n260:         type: 'boolean',\n\n(Showing lines 1-260 of 955. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Normalized definition for a single MCP tool and its JSON schema.\n */\nexport interface ToolDefinition {\n  name: string;\n  description: string;\n  inputSchema: Record<string, unknown>;\n  outputSchema?: Record<string, unknown>;\n}\n\nexport type ToolOwnershipStability = 'stable' | 'deprecated';\n\nexport interface ToolOwnershipEntry {\n  name: string;\n  owner: string;\n  stability: ToolOwnershipStability;\n  level: string;\n  category: string;\n}\n\nexport interface ToolOwnershipMap {\n  schemaVersion: 1;\n  generatedFrom: 'TOOL_DEFINITIONS';\n  tools: ToolOwnershipEntry[];\n}\n\nexport interface ToolOwnershipDriftReport {\n  ok: boolean;\n  missingFromCommitted: string[];\n  extraInCommitted: string[];\n  changed: Array<{\n    name: string;\n    field: keyof Omit<ToolOwnershipEntry, 'name'>;\n    expected: string;\n    actual: string;\n  }>;\n  expectedMap: ToolOwnershipMap;\n}\n\nconst TOOL_OWNER_BY_CATEGORY: Record<string, string> = Object.freeze({\n  Orchestration: 'memory-orchestration',\n  Core: 'memory-core',\n  Discovery: 'memory-discovery',\n  Mutation: 'memory-mutation',\n  Lifecycle: 'memory-lifecycle',\n  Analysis: 'memory-analysis',\n  Maintenance: 'memory-maintenance',\n});\n\nfunction readToolContract(definition: ToolDefinition): { level: string; category: string } {\n  const match = /^\\[([^:\\]]+):([^\\]]+)\\]/.exec(definition.description);\n  if (!match) {\n    return { level: 'unclassified', category: 'unclassified' };\n  }\n  return {\n    level: match[1] ?? 'unclassified',\n    category: match[2] ?? 'unclassified',\n  };\n}\n\nfunction deriveToolOwnershipEntry(definition: ToolDefinition): ToolOwnershipEntry {\n  const contract = readToolContract(definition);\n  return {\n    name: definition.name,\n    owner: TOOL_OWNER_BY_CATEGORY[contract.category] ?? 'memory-unclassified',\n    stability: /^\\[deprecated\\]/i.test(definition.description) ? 'deprecated' : 'stable',\n    level: contract.level,\n    category: contract.category,\n  };\n}\n\nfunction normalizeToolOwnershipMap(map: ToolOwnershipMap): ToolOwnershipMap {\n  return {\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: [...map.tools].sort((a, b) => a.name.localeCompare(b.name)),\n  };\n}\n\nfunction isToolOwnershipEntry(value: unknown): value is ToolOwnershipEntry {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) return false;\n  const record = value as Record<string, unknown>;\n  return (\n    typeof record.name === 'string' &&\n    typeof record.owner === 'string' &&\n    (record.stability === 'stable' || record.stability === 'deprecated') &&\n    typeof record.level === 'string' &&\n    typeof record.category === 'string'\n  );\n}\n\nfunction parseToolOwnershipMap(value: unknown): ToolOwnershipMap | null {\n  let parsed: unknown;\n  try {\n    parsed = typeof value === 'string' ? JSON.parse(value) as unknown : value;\n  } catch (_error: unknown) {\n    return null;\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;\n  const record = parsed as Record<string, unknown>;\n  if (record.schemaVersion !== 1 || record.generatedFrom !== 'TOOL_DEFINITIONS') return null;\n  if (!Array.isArray(record.tools) || !record.tools.every(isToolOwnershipEntry)) return null;\n  return normalizeToolOwnershipMap({\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: record.tools,\n  });\n}\n\n/** Derive the deterministic tool ownership map from live tool definitions. */\nexport function deriveToolOwnershipMap(\n  toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n): ToolOwnershipMap {\n  return normalizeToolOwnershipMap({\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: toolDefinitions.map(deriveToolOwnershipEntry),\n  });\n}\n\n/** Serialize a derived ownership map for byte-identical generated output. */\nexport function serializeToolOwnershipMap(map: ToolOwnershipMap = deriveToolOwnershipMap()): string {\n  return `${JSON.stringify(normalizeToolOwnershipMap(map), null, 2)}\\n`;\n}\n\n/** Compare a committed ownership map with a fresh derivation. */\nexport function lintToolOwnershipMapDrift(\n  committedMap: unknown,\n  toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n): ToolOwnershipDriftReport {\n  const expectedMap = deriveToolOwnershipMap(toolDefinitions);\n  const parsed = parseToolOwnershipMap(committedMap);\n  if (!parsed) {\n    return {\n      ok: false,\n      missingFromCommitted: expectedMap.tools.map((tool) => tool.name),\n      extraInCommitted: [],\n      changed: [],\n      expectedMap,\n    };\n  }\n\n  const expectedByName = new Map(expectedMap.tools.map((tool) => [tool.name, tool]));\n  const actualByName = new Map(parsed.tools.map((tool) => [tool.name, tool]));\n  const missingFromCommitted = expectedMap.tools\n    .filter((tool) => !actualByName.has(tool.name))\n    .map((tool) => tool.name);\n  const extraInCommitted = parsed.tools\n    .filter((tool) => !expectedByName.has(tool.name))\n    .map((tool) => tool.name);\n  const changed: ToolOwnershipDriftReport['changed'] = [];\n  const fields: Array<keyof Omit<ToolOwnershipEntry, 'name'>> = ['owner', 'stability', 'level', 'category'];\n\n  for (const expected of expectedMap.tools) {\n    const actual = actualByName.get(expected.name);\n    if (!actual) continue;\n    for (const field of fields) {\n      if (expected[field] !== actual[field]) {\n        changed.push({\n          name: expected.name,\n          field,\n          expected: expected[field],\n          actual: actual[field],\n        });\n      }\n    }\n  }\n\n  return {\n    ok: missingFromCommitted.length === 0 && extraInCommitted.length === 0 && changed.length === 0,\n    missingFromCommitted,\n    extraInCommitted,\n    changed,\n    expectedMap,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. TOOL DEFINITIONS\n\n// ───────────────────────────────────────────────────────────────\n// L1 Orchestration - Unified entry point (Token Budget: 3500)\nconst memoryContext: ToolDefinition = {\n  name: 'memory_context',\n  description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n};\n\n// L2: Core - Primary operations (Token Budget: 3500)\nconst memorySearch: ToolDefinition = {\n  name: 'memory_search',\n  description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: {\n    type: 'object',\n    additionalProperties: false,\n    'x-requiredAnyOf': [['query'], ['concepts'], ['cursor']],\n    properties: {\n      cursor: {\n        type: 'string',\n        minLength: 1,\n        description: 'Opaque continuation cursor returned by progressive disclosure. When provided, resolves the next page without requiring a new query.'\n      },\n      query: { type: 'string', minLength: 2, maxLength: 1000, description: 'Natural language search query' },\n      concepts: {\n        type: 'array',\n        items: { type: 'string', minLength: 1 },\n        minItems: 2,\n        maxItems: 5,\n        description: 'Multiple concepts for AND search (requires 2-5 concepts). Results must match ALL concepts.'\n      },\n      specFolder: { type: 'string', description: 'Limit search to a specific spec folder (e.g., \"011-spec-kit-memory-upgrade\")' },\n      tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval. When provided with scope enforcement, results are isolated to this tenant.' },\n      userId: { type: 'string', description: 'User boundary for governed retrieval. Filters private user-scoped spec-doc records.' },\n      agentId: { type: 'string', description: 'Agent boundary for governed retrieval. Filters agent-scoped spec-doc records.' },\n      limit: { type: 'number', default: 10, minimum: 1, maximum: 100, description: 'Maximum number of results to return (1-100)' },\n      sessionId: {\n        type: 'string',\n        description: 'Session identifier for working memory and session deduplication (REQ-001). When provided with enableDedup=true, prevents duplicate spec-doc records from being returned in the same session (~50% token savings on follow-up queries).'\n      },\n      enableDedup: {\n        type: 'boolean',\n        default: true,\n        description: 'Enable session deduplication (REQ-001). When true and sessionId provided, filters out already-sent spec-doc records.'\n      },\n      tier: { type: 'string', description: 'Filter by importance tier (constitutional, critical, important, normal, temporary, deprecated)' },\n      contextType: { type: 'string', description: 'Filter by context type (decision, implementation, research, etc.)' },\n      useDecay: { type: 'boolean', default: true, description: 'Apply temporal decay scoring to results' },\n      includeContiguity: { type: 'boolean', default: false, description: 'Include adjacent/contiguous spec-doc records (from the same packet, neighboring sections) in results' },\n      includeConstitutional: {\n        type: 'boolean',\n        default: true,\n        description: 'Include constitutional tier rules at top of results (default: true)'\n      },\n      enableSessionBoost: {\n        type: 'boolean',","lineStart":1,"lineEnd":260,"totalLines":955,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","time":{"start":1781763110730,"end":1781763110733}},"metadata":{"openai":{"itemId":"fc_08430863c6a3580e016a338c269788819194d51ff48eb91cf2"}},"id":"prt_ed95b7749001rL83Oq5tIntztM","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95b516a001WOShyKIceSyVWM"}}
{"type":"tool_use","timestamp":1781763110736,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_60BqBfQfzP2RFvhb7jZdy7jj","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Retry Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Embedding retry orchestrator\n5: // Node stdlib\n6: import * as fsPromises from 'fs/promises';\n7: \n8: // Internal modules\n9: import * as vectorIndex from '../search/vector-index.js';\n10: import { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\n11: import { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\n12: import { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\n13: import { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\n14: import { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n15: import { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n16: \n17: // Type imports\n18: import type { MemoryDbRow } from '@spec-kit/shared/types';\n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. TYPES\n22: ──────────────────────────────────────────────────────────────── */\n23: \n24: interface BackgroundJobConfig {\n25:   intervalMs: number;\n26:   batchSize: number;\n27:   enabled: boolean;\n28: }\n29: \n30: interface RetryStats {\n31:   pending: number;\n32:   retry: number;\n33:   failed: number;\n34:   success: number;\n35:   total: number;\n36:   queue_size: number;\n37: }\n38: \n39: /** In-memory-only snapshot of embedding retry health — no DB access. */\n40: export interface EmbeddingRetryStats {\n41:   pending: number;\n42:   failed: number;\n43:   retryAttempts: number;\n44:   circuitBreakerOpen: boolean;\n45:   lastRun: string | null;\n46:   queueDepth: number;\n47: }\n48: \n49: interface RetryResult {\n50:   success: boolean;\n51:   id?: number;\n52:   dimensions?: number;\n53:   error?: string;\n54:   permanent?: boolean;\n55: }\n56: \n57: interface BatchResult {\n58:   processed: number;\n59:   succeeded: number;\n60:   failed: number;\n61:   details?: RetryDetailEntry[];\n62: }\n63: \n64: interface RetryDetailEntry {\n65:   id: number;\n66:   success: boolean;\n67:   error?: string;\n68:   dimensions?: number;\n69: }\n70: \n71: interface BackgroundJobResult {\n72:   processed?: number;\n73:   succeeded?: number;\n74:   failed?: number;\n75:   details?: RetryDetailEntry[];\n76:   skipped?: boolean;\n77:   reason?: string;\n78:   queue_empty?: boolean;\n79:   error?: string;\n80: }\n81: \n82: /**\n83:  * Retry-specific memory row with required id and file_path.\n84:  * Uses MemoryDbRow as the base type with Record<string, unknown>\n85:  * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n86:  */\n87: type RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n88:   id: number;\n89:   file_path: string;\n90: };\n91: \n92: type ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\n93: type RetryQueueStatus = 'pending' | 'retry';\n94: \n95: type EmbeddingFailureCode =\n96:   | 'EMBEDDING_PROVIDER_ERROR'\n97:   | 'EMBEDDING_TIMEOUT'\n98:   | 'EMBEDDING_RATE_LIMIT';\n99: \n100: interface SanitizeEmbeddingFailureOptions {\n101:   provider?: string | null;\n102:   force?: boolean;\n103: }\n104: \n105: interface SanitizedEmbeddingFailure {\n106:   code: EmbeddingFailureCode | null;\n107:   provider: string | null;\n108:   errorType: string | null;\n109:   publicMessage: string;\n110:   sanitized: boolean;\n111: }\n112: \n113: interface RetryClaimResult {\n114:   claimed: boolean;\n115:   previousStatus: RetryQueueStatus | null;\n116: }\n117: \n118: function getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n119:   const status = typeof memory.embedding_status === 'string'\n120:     ? memory.embedding_status\n121:     : typeof memory.embeddingStatus === 'string'\n122:       ? memory.embeddingStatus\n123:       : null;\n124: \n125:   return status === 'pending' || status === 'retry' ? status : null;\n126: }\n127: \n128: function getRetryCountValue(memory: RetryMemoryRow): number {\n129:   return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n130: }\n131: \n132: function getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n133:   const value = typeof memory.last_retry_at === 'string'\n134:     ? memory.last_retry_at\n135:     : typeof memory.lastRetryAt === 'string'\n136:       ? memory.lastRetryAt\n137:       : null;\n138:   return value && value.trim().length > 0 ? value : null;\n139: }\n140: \n141: function detectEmbeddingProviderName(source: string | null | undefined): string | null {\n142:   if (typeof source !== 'string' || source.trim().length === 0) {\n143:     return null;\n144:   }\n145: \n146:   const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n147:   if (explicitProvider?.[1]) {\n148:     return explicitProvider[1].toLowerCase();\n149:   }\n150: \n151:   const lower = source.toLowerCase();\n152:   if (lower.includes('voyage')) return 'voyage';\n153:   if (lower.includes('azure')) return 'azure-openai';\n154:   if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n155:   if (lower.includes('system')) return 'system';\n156: \n157:   return null;\n158: }\n159: \n160: function shouldSanitizeEmbeddingFailure(message: string): boolean {\n161:   const lower = message.toLowerCase();\n162:   return (\n163:     /^embedding_[a-z_]+/.test(lower) ||\n164:     lower.includes('openai') ||\n165:     lower.includes('voyage') ||\n166:     lower.includes('azure') ||\n167:     lower.includes('text-embedding') ||\n168:     lower.includes('rate limit') ||\n169:     lower.includes('too many requests') ||\n170:     lower.includes('429') ||\n171:     lower.includes('timeout') ||\n172:     lower.includes('timed out') ||\n173:     lower.includes('api key') ||\n174:     lower.includes('unauthorized') ||\n175:     lower.includes('forbidden') ||\n176:     lower.includes('quota') ||\n177:     lower.includes('embedding provider')\n178:   );\n179: }\n180: \n181: function inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n182:   const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n183:   const lower = message.toLowerCase();\n184: \n185:   if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n186:     return {\n187:       code: 'EMBEDDING_TIMEOUT',\n188:       errorType: explicitType ?? 'timeout',\n189:     };\n190:   }\n191: \n192:   if (\n193:     lower.includes('embedding_rate_limit') ||\n194:     lower.includes('rate limit') ||\n195:     lower.includes('too many requests') ||\n196:     lower.includes('429')\n197:   ) {\n198:     return {\n199:       code: 'EMBEDDING_RATE_LIMIT',\n200:       errorType: explicitType ?? 'rate_limit',\n201:     };\n202:   }\n203: \n204:   if (\n205:     explicitType === 'auth' ||\n206:     lower.includes('api key') ||\n207:     lower.includes('unauthorized') ||\n208:     lower.includes('forbidden')\n209:   ) {\n210:     return {\n211:       code: 'EMBEDDING_PROVIDER_ERROR',\n212:       errorType: 'auth',\n213:     };\n214:   }\n215: \n216:   return {\n217:     code: 'EMBEDDING_PROVIDER_ERROR',\n218:     errorType: explicitType ?? 'provider_error',\n219:   };\n220: }\n221: \n222: function sanitizeEmbeddingFailure(\n223:   raw: unknown,\n224:   options: SanitizeEmbeddingFailureOptions = {},\n225: ): SanitizedEmbeddingFailure {\n226:   const publicMessage = raw instanceof Error\n227:     ? raw.message.trim()\n228:     : String(raw ?? '').trim();\n229: \n230:   if (publicMessage.length === 0) {\n231:     return {\n232:       code: null,\n233:       provider: null,\n234:       errorType: null,\n235:       publicMessage,\n236:       sanitized: false,\n237:     };\n238:   }\n239: \n240:   if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n241:     return {\n242:       code: null,\n243:       provider: null,\n244:       errorType: null,\n245:       publicMessage,\n246:       sanitized: false,\n247:     };\n248:   }\n249: \n250:   const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n251:   const { code, errorType } = inferEmbeddingFailure(publicMessage);\n252: \n253:   return {\n254:     code,\n255:     provider,\n256:     errorType,\n257:     publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n258:     sanitized: true,\n259:   };\n260: }\n261: \n262: export function sanitizeEmbeddingFailureMessage(\n263:   raw: unknown,\n264:   options: SanitizeEmbeddingFailureOptions = {},\n265: ): string | null {\n266:   const failure = sanitizeEmbeddingFailure(raw, options);\n267:   return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n268: }\n269: \n270: export function sanitizeAndLogEmbeddingFailure(\n271:   context: string,\n272:   raw: unknown,\n273:   options: SanitizeEmbeddingFailureOptions = {},\n274: ): string | null {\n275:   const failure = sanitizeEmbeddingFailure(raw, options);\n276:   if (failure.publicMessage.length === 0) {\n277:     return null;\n278:   }\n279: \n280:   if (failure.sanitized) {\n281:     console.error(context, {\n282:       sanitized: {\n283:         code: failure.code,\n284:         provider: failure.provider,\n285:         errorType: failure.errorType,\n286:       },\n287:       redacted: true,\n288:     });\n289:   }\n290: \n291:   return failure.publicMessage;\n292: }\n293: \n294: function claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n295:   const db = vectorIndex.getDb();\n296:   const previousStatus = getRetryStatus(memory);\n297:   if (!db || previousStatus === null) {\n298:     return { claimed: false, previousStatus };\n299:   }\n300: \n301:   const now = new Date().toISOString();\n302:   const retryCount = getRetryCountValue(memory);\n303:   const lastRetryAt = getLastRetryAtValue(memory);\n304:   // Concurrency: atomic claim prevents double-processing of retry jobs\n305:   const result = previousStatus === 'pending'\n306:     ? db.prepare(`\n307:         UPDATE memory_index\n308:         SET embedding_status = 'retry',\n309:             last_retry_at = ?,\n310:             updated_at = ?\n311:         WHERE id = ?\n312:           AND embedding_status = 'pending'\n313:           AND retry_count = ?\n314:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n315:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n316:     : db.prepare(`\n317:         UPDATE memory_index\n318:         SET last_retry_at = ?,\n319:             updated_at = ?\n320:         WHERE id = ?\n321:           AND embedding_status = 'retry'\n322:           AND retry_count = ?\n323:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n324:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n325: \n326:   return {\n327:     claimed: result.changes > 0,\n328:     previousStatus,\n329:   };\n330: }\n331: \n332: /* ───────────────────────────────────────────────────────────────\n333:    2. CONFIGURATION\n334: ──────────────────────────────────────────────────────────────── */\n335: \n336: // Backoff delays in milliseconds (1min, 5min, 15min)\n337: const BACKOFF_DELAYS: number[] = [\n338:   60 * 1000,\n339:   5 * 60 * 1000,\n340:   15 * 60 * 1000,\n341: ];\n342: \n343: const MAX_RETRIES = 3;\n344: const MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n345: const MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n346: \n347: // 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n348: // applies to a long-lived daemon without depending on the exact restart sequence. The\n349: // module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\n350: function getMaxRetryQueuePending(): number {\n351:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n352: }\n353: \n354: function getMaxRetryQueueAgeMs(): number {\n355:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n356: }\n357: \n358: // Background retry job configuration\n359: // Env-overrideable\n360: //   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)\n\n(Showing lines 1-360 of 1141. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BackgroundJobConfig {\n  intervalMs: number;\n  batchSize: number;\n  enabled: boolean;\n}\n\ninterface RetryStats {\n  pending: number;\n  retry: number;\n  failed: number;\n  success: number;\n  total: number;\n  queue_size: number;\n}\n\n/** In-memory-only snapshot of embedding retry health — no DB access. */\nexport interface EmbeddingRetryStats {\n  pending: number;\n  failed: number;\n  retryAttempts: number;\n  circuitBreakerOpen: boolean;\n  lastRun: string | null;\n  queueDepth: number;\n}\n\ninterface RetryResult {\n  success: boolean;\n  id?: number;\n  dimensions?: number;\n  error?: string;\n  permanent?: boolean;\n}\n\ninterface BatchResult {\n  processed: number;\n  succeeded: number;\n  failed: number;\n  details?: RetryDetailEntry[];\n}\n\ninterface RetryDetailEntry {\n  id: number;\n  success: boolean;\n  error?: string;\n  dimensions?: number;\n}\n\ninterface BackgroundJobResult {\n  processed?: number;\n  succeeded?: number;\n  failed?: number;\n  details?: RetryDetailEntry[];\n  skipped?: boolean;\n  reason?: string;\n  queue_empty?: boolean;\n  error?: string;\n}\n\n/**\n * Retry-specific memory row with required id and file_path.\n * Uses MemoryDbRow as the base type with Record<string, unknown>\n * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n */\ntype RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n  id: number;\n  file_path: string;\n};\n\ntype ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\ntype RetryQueueStatus = 'pending' | 'retry';\n\ntype EmbeddingFailureCode =\n  | 'EMBEDDING_PROVIDER_ERROR'\n  | 'EMBEDDING_TIMEOUT'\n  | 'EMBEDDING_RATE_LIMIT';\n\ninterface SanitizeEmbeddingFailureOptions {\n  provider?: string | null;\n  force?: boolean;\n}\n\ninterface SanitizedEmbeddingFailure {\n  code: EmbeddingFailureCode | null;\n  provider: string | null;\n  errorType: string | null;\n  publicMessage: string;\n  sanitized: boolean;\n}\n\ninterface RetryClaimResult {\n  claimed: boolean;\n  previousStatus: RetryQueueStatus | null;\n}\n\nfunction getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n  const status = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof memory.embeddingStatus === 'string'\n      ? memory.embeddingStatus\n      : null;\n\n  return status === 'pending' || status === 'retry' ? status : null;\n}\n\nfunction getRetryCountValue(memory: RetryMemoryRow): number {\n  return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n}\n\nfunction getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n  const value = typeof memory.last_retry_at === 'string'\n    ? memory.last_retry_at\n    : typeof memory.lastRetryAt === 'string'\n      ? memory.lastRetryAt\n      : null;\n  return value && value.trim().length > 0 ? value : null;\n}\n\nfunction detectEmbeddingProviderName(source: string | null | undefined): string | null {\n  if (typeof source !== 'string' || source.trim().length === 0) {\n    return null;\n  }\n\n  const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n  if (explicitProvider?.[1]) {\n    return explicitProvider[1].toLowerCase();\n  }\n\n  const lower = source.toLowerCase();\n  if (lower.includes('voyage')) return 'voyage';\n  if (lower.includes('azure')) return 'azure-openai';\n  if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n  if (lower.includes('system')) return 'system';\n\n  return null;\n}\n\nfunction shouldSanitizeEmbeddingFailure(message: string): boolean {\n  const lower = message.toLowerCase();\n  return (\n    /^embedding_[a-z_]+/.test(lower) ||\n    lower.includes('openai') ||\n    lower.includes('voyage') ||\n    lower.includes('azure') ||\n    lower.includes('text-embedding') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429') ||\n    lower.includes('timeout') ||\n    lower.includes('timed out') ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden') ||\n    lower.includes('quota') ||\n    lower.includes('embedding provider')\n  );\n}\n\nfunction inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n  const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n  const lower = message.toLowerCase();\n\n  if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n    return {\n      code: 'EMBEDDING_TIMEOUT',\n      errorType: explicitType ?? 'timeout',\n    };\n  }\n\n  if (\n    lower.includes('embedding_rate_limit') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429')\n  ) {\n    return {\n      code: 'EMBEDDING_RATE_LIMIT',\n      errorType: explicitType ?? 'rate_limit',\n    };\n  }\n\n  if (\n    explicitType === 'auth' ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden')\n  ) {\n    return {\n      code: 'EMBEDDING_PROVIDER_ERROR',\n      errorType: 'auth',\n    };\n  }\n\n  return {\n    code: 'EMBEDDING_PROVIDER_ERROR',\n    errorType: explicitType ?? 'provider_error',\n  };\n}\n\nfunction sanitizeEmbeddingFailure(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): SanitizedEmbeddingFailure {\n  const publicMessage = raw instanceof Error\n    ? raw.message.trim()\n    : String(raw ?? '').trim();\n\n  if (publicMessage.length === 0) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n  const { code, errorType } = inferEmbeddingFailure(publicMessage);\n\n  return {\n    code,\n    provider,\n    errorType,\n    publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n    sanitized: true,\n  };\n}\n\nexport function sanitizeEmbeddingFailureMessage(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n}\n\nexport function sanitizeAndLogEmbeddingFailure(\n  context: string,\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  if (failure.publicMessage.length === 0) {\n    return null;\n  }\n\n  if (failure.sanitized) {\n    console.error(context, {\n      sanitized: {\n        code: failure.code,\n        provider: failure.provider,\n        errorType: failure.errorType,\n      },\n      redacted: true,\n    });\n  }\n\n  return failure.publicMessage;\n}\n\nfunction claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n  const db = vectorIndex.getDb();\n  const previousStatus = getRetryStatus(memory);\n  if (!db || previousStatus === null) {\n    return { claimed: false, previousStatus };\n  }\n\n  const now = new Date().toISOString();\n  const retryCount = getRetryCountValue(memory);\n  const lastRetryAt = getLastRetryAtValue(memory);\n  // Concurrency: atomic claim prevents double-processing of retry jobs\n  const result = previousStatus === 'pending'\n    ? db.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'retry',\n            last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'pending'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n    : db.prepare(`\n        UPDATE memory_index\n        SET last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'retry'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n\n  return {\n    claimed: result.changes > 0,\n    previousStatus,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n// Backoff delays in milliseconds (1min, 5min, 15min)\nconst BACKOFF_DELAYS: number[] = [\n  60 * 1000,\n  5 * 60 * 1000,\n  15 * 60 * 1000,\n];\n\nconst MAX_RETRIES = 3;\nconst MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\nconst MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n\n// 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n// applies to a long-lived daemon without depending on the exact restart sequence. The\n// module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\nfunction getMaxRetryQueuePending(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n}\n\nfunction getMaxRetryQueueAgeMs(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n}\n\n// Background retry job configuration\n// Env-overrideable\n//   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)","lineStart":1,"lineEnd":360,"totalLines":1141,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781763110729,"end":1781763110735}},"metadata":{"openai":{"itemId":"fc_08430863c6a3580e016a338c2697848191b90e32035ea2d2ce"}},"id":"prt_ed95b773c001PGFVfgFfwJXQ75","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95b516a001WOShyKIceSyVWM"}}
