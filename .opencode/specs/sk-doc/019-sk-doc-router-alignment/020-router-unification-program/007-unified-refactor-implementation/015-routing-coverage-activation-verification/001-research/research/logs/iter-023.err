/bin/zsh -lc "nl -ba .opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/run-skill-benchmark.cjs | sed -n '1,430p'" in /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover
 succeeded in 0ms:
     1	#!/usr/bin/env node
     2	// ╔══════════════════════════════════════════════════════════════════════════╗
     3	// ║ run-skill-benchmark — Lane C orchestrator                                ║
     4	// ╚══════════════════════════════════════════════════════════════════════════╝
     5	'use strict';
     6	
     7	/**
     8	 * run-skill-benchmark.cjs — Lane C orchestrator (loop-host --mode=skill-benchmark).
     9	 *
    10	 * Post-run join: private gold never crosses the dispatch boundary. Sequence:
    11	 *   1. resolve the target skill root (path or bare id under .opencode/skills/)
    12	 *   2. D5 static connectivity scan (the hard gate) — runs first, before any dispatch
    13	 *   3. load public/private fixture pairs
    14	 *   4. per scenario: contamination-lint the PUBLIC prompt (a leak is a fixture
    15	 *      failure), then router-replay (Mode A), then join with private gold to score
    16	 *   5. aggregate -> write report.json, then render report.md FROM it
    17	 *
    18	 * Mode A (router-replay) is the deterministic default and the CI gate. Live
    19	 * dispatch (Mode B) + D1-inter advisor scoring + D4 ablation are follow-on; this
    20	 * orchestrator emits a complete, honest Mode A report today.
    21	 */
    22	
    23	// ─────────────────────────────────────────────────────────────────────────────
    24	// 1. IMPORTS
    25	// ─────────────────────────────────────────────────────────────────────────────
    26	
    27	const fs = require('fs');
    28	const path = require('path');
    29	const crypto = require('crypto');
    30	const { routeSkillResources } = require('./router-replay.cjs');
    31	const { buildBannedVocab, lintFixture } = require('./contamination-lint.cjs');
    32	const { scanConnectivity, scanHubRegistry } = require('./d5-connectivity.cjs');
    33	const { scoreScenario, aggregate, evaluateRouteGold } = require('./score-skill-benchmark.cjs');
    34	const { probeAdvisor } = require('./advisor-probe.cjs');
    35	const { renderReport } = require('./build-report.cjs');
    36	const { loadPlaybookScenarios } = require('./load-playbook-scenarios.cjs');
    37	const { dispatchScenario } = require('./executor-dispatch.cjs');
    38	
    39	// ─────────────────────────────────────────────────────────────────────────────
    40	// 2. CONSTANTS
    41	// ─────────────────────────────────────────────────────────────────────────────
    42	
    43	const SKILLS_DIR = path.resolve(__dirname, '..', '..', '..', '..'); // .opencode/skills
    44	
    45	// ─────────────────────────────────────────────────────────────────────────────
    46	// 3. HELPERS
    47	// ─────────────────────────────────────────────────────────────────────────────
    48	
    49	/**
    50	 * Resolve a skill argument to an absolute root: a path/relative arg resolves
    51	 * as-is, a bare id resolves under .opencode/skills/.
    52	 *
    53	 * @param {string} skillArg - Skill path or bare id.
    54	 * @returns {string} Absolute skill root dir.
    55	 */
    56	function resolveSkillRoot(skillArg) {
    57	  if (skillArg.includes('/') || skillArg.startsWith('.')) return path.resolve(skillArg);
    58	  return path.join(SKILLS_DIR, skillArg);
    59	}
    60	
    61	function resolveSkillId(skillRoot) {
    62	  return path.basename(skillRoot);
    63	}
    64	
    65	// Hub-type detection for the route-gold gate default: a skill that ships a
    66	// hub-router.json routes between packets by contract, so its route gold is
    67	// enforced by default; flat skills opt in per run.
    68	function isHubTypeSkill(skillRoot) {
    69	  return fs.existsSync(path.join(skillRoot, 'hub-router.json'));
    70	}
    71	
    72	/**
    73	 * Resolve the route-gold gate flag: `--route-gold on|off|auto` (default auto).
    74	 * `auto` derives from the target: ON for hub-type skills, OFF otherwise.
    75	 * Gate ON means any route-gold violation (including a gold parse failure)
    76	 * fails the run verdict; the report records flag state and row count either way.
    77	 *
    78	 * @param {Object} args - Parsed CLI args.
    79	 * @param {string} skillRoot - Target skill root dir.
    80	 * @returns {{mode:'on'|'off'|'auto', enabled:boolean}} Gate configuration.
    81	 */
    82	function resolveRouteGold(args, skillRoot) {
    83	  const raw = args['route-gold'] == null ? 'auto' : String(args['route-gold']).toLowerCase();
    84	  if (!['on', 'off', 'auto'].includes(raw)) {
    85	    throw new Error(`invalid --route-gold value "${raw}" (expected on|off|auto)`);
    86	  }
    87	  const enabled = raw === 'on' || (raw === 'auto' && isHubTypeSkill(skillRoot));
    88	  return { mode: raw, enabled };
    89	}
    90	
    91	/**
    92	 * Digest a skill's committed leaf-manifest.json, when it has one. Used to
    93	 * detect a manifest edited out from under a run in progress; a skill with no
    94	 * manifest at all always digests to null and never engages the abort below.
    95	 *
    96	 * @param {string} skillRoot - Skill root dir.
    97	 * @returns {string|null} Hex sha256 digest, or null when no manifest exists.
    98	 */
    99	function readManifestDigest(skillRoot) {
   100	  const manifestPath = path.join(skillRoot, 'leaf-manifest.json');
   101	  if (!fs.existsSync(manifestPath)) return null;
   102	  return crypto.createHash('sha256').update(fs.readFileSync(manifestPath)).digest('hex');
   103	}
   104	
   105	/**
   106	 * Load public/private fixture pairs from a fixtures dir
   107	 * (assets/skill-benchmark/fixtures/<skill-id>/ with <id>.public.json +
   108	 * <id>.private.json pairs). Falls back to the --fixtures-dir override.
   109	 *
   110	 * @param {string} fixturesDir - Directory containing fixture pairs.
   111	 * @returns {Array<Object>} Loaded fixture rows (malformed pairs carry loadError).
   112	 */
   113	function loadFixtures(fixturesDir) {
   114	  const out = [];
   115	  if (!fs.existsSync(fixturesDir)) return out;
   116	  const publics = fs.readdirSync(fixturesDir).filter((f) => f.endsWith('.public.json'));
   117	  for (const pf of publics) {
   118	    const id = pf.replace(/\.public\.json$/, '');
   119	    // A malformed fixture is operator error this tool exists to surface, not a
   120	    // reason to crash the whole run. Degrade: record a load error and skip.
   121	    let pub; let priv;
   122	    try {
   123	      pub = JSON.parse(fs.readFileSync(path.join(fixturesDir, pf), 'utf8'));
   124	      const privPath = path.join(fixturesDir, `${id}.private.json`);
   125	      priv = fs.existsSync(privPath) ? JSON.parse(fs.readFileSync(privPath, 'utf8')) : { expected: {} };
   126	    } catch (err) {
   127	      out.push({ scenarioId: id, loadError: err.message });
   128	      continue;
   129	    }
   130	    out.push({ scenarioId: pub.scenarioId || id, tier: pub.tier || 'T1', public: pub.public || {}, expected: priv.expected || {}, rubric: priv.rubric });
   131	  }
   132	  return out;
   133	}
   134	
   135	// Legacy synthetic-fixture loop (kept for back-compat + malformed-fixture
   136	// surfacing). Used only when --fixtures-dir is given explicitly.
   137	function runLegacyFixtures({ fixturesDir, skillRoot, skillId, advisorMode, scenarioRows }) {
   138	  for (const fx of loadFixtures(fixturesDir)) {
   139	    if (fx.loadError) {
   140	      scenarioRows.push({
   141	        scenarioId: fx.scenarioId, tier: 'unknown', modeAScore: 0,
   142	        firstFailingStage: 'unparseable-fixture',
   143	        dims: { d1intra: { score: 0 }, d2: { score: 0 }, d3: { score: 0 }, d1inter: { score: null }, d4: { score: null } },
   144	        loadError: fx.loadError,
   145	      });
   146	      continue;
   147	    }
   148	    const bannedVocab = buildBannedVocab({ skillRoot, skillId, privateExpected: fx.expected });
   149	    const lint = lintFixture({ publicText: fx.public.prompt || '', bannedVocab });
   150	    if (!lint.passed) {
   151	      scenarioRows.push({
   152	        scenarioId: fx.scenarioId, tier: fx.tier, modeAScore: 0,
   153	        firstFailingStage: 'contaminated-fixture',
   154	        dims: { d1intra: { score: 0 }, d2: { score: 0 }, d3: { score: 0 }, d1inter: { score: null }, d4: { score: null } },
   155	        contamination: lint.hardLeaks,
   156	      });
   157	      continue;
   158	    }
   159	    const routerResult = routeSkillResources({ skillRoot, taskText: fx.public.prompt || '' });
   160	    const advisorResult = advisorMode === 'python'
   161	      ? probeAdvisor({ prompt: fx.public.prompt || '' }) : undefined;
   162	    scenarioRows.push(scoreScenario({ scenarioId: fx.scenarioId, tier: fx.tier, routerResult, expected: fx.expected, advisorResult }));
   163	  }
   164	}
   165	
   166	function filterScenarios(scenarios, filter) {
   167	  if (!filter) return scenarios;
   168	  const f = String(filter).toLowerCase();
   169	  if (f === 'critical') return scenarios.filter((s) => s.critical);
   170	  const ids = new Set(f.split(',').map((x) => x.trim().toUpperCase()));
   171	  return scenarios.filter((s) => ids.has(s.scenarioId.toUpperCase()));
   172	}
   173	
   174	// Default corpus: the skill's manual_testing_playbook. Each scenario routes to
   175	// the executor for its classKind; browser scenarios are routed out of the text
   176	// executors. Contamination-lint is a drift FINDING in router mode (the playbook
   177	// intentionally carries trigger words) and is skipped entirely in live mode.
   178	function runPlaybook({ skillRoot, skillId, traceMode, advisorMode, executor, playbookDir, scenariosFilter, scenarioRows, lintFindings, warningsOut }) {
   179	  let scenarios;
   180	  let warnings;
   181	  try {
   182	    ({ scenarios, warnings } = loadPlaybookScenarios({ skillRoot, playbookDir }));
   183	  } catch (err) {
   184	    // A skill with no playbook corpus at all scores zero scenarios rather than
   185	    // aborting: the structural/registry connectivity gate is evaluated upstream
   186	    // and independently, so an absent corpus must not preempt its verdict. A
   187	    // legacy underscore playbook root stays fail-closed — only the genuinely
   188	    // empty case is absorbed here; every other load error re-throws.
   189	    if (!err || err.code !== 'MISSING_PLAYBOOK_ROOT') throw err;
   190	    scenarios = [];
   191	    warnings = [];
   192	  }
   193	  if (warningsOut) warningsOut.push(...warnings);
   194	  for (const sc of filterScenarios(scenarios, scenariosFilter)) {
   195	    const observed = dispatchScenario({ scenario: sc, skillRoot, traceMode, executor });
   196	    if (sc.classKind === 'browser') {
   197	      if (observed.routedOut || observed.error) {
   198	        // Router/CI mode, or the browser harness was unavailable.
   199	        scenarioRows.push({
   200	          scenarioId: sc.scenarioId, classKind: 'browser', routedOut: true,
   201	          reason: observed.reason || observed.error || 'browser scenario — routed to browser harness',
   202	        });
   203	      } else {
   204	        // Live mode: browser-executor returned a full scenario row (with a verdict).
   205	        scenarioRows.push(observed);
   206	      }
   207	      continue;
   208	    }
   209	    if (traceMode === 'router' && sc.prompt) {
   210	      const bannedVocab = buildBannedVocab({ skillRoot, skillId, privateExpected: { resources: sc.expectedResources } });
   211	      const lint = lintFixture({ publicText: sc.prompt, bannedVocab });
   212	      if (!lint.passed) lintFindings.push({ scenarioId: sc.scenarioId, leaks: lint.hardLeaks.map((h) => h.term) });
   213	    }
   214	    const advisorResult = (advisorMode === 'python' && sc.classKind === 'advisor' && sc.prompt)
   215	      ? probeAdvisor({ prompt: sc.prompt }) : undefined;
   216	    const row = scoreScenario({ scenario: sc, skillId, observed, advisorResult, traceMode });
   217	    // Route-gold lane: evaluated on every row that carries authored gold so
   218	    // the report always shows the counts; the gate flag decides enforcement.
   219	    row.routeGold = evaluateRouteGold({ scenario: sc, observed });
   220	    scenarioRows.push(row);
   221	  }
   222	}
   223	
   224	// ─────────────────────────────────────────────────────────────────────────────
   225	// 4. CORE LOGIC
   226	// ─────────────────────────────────────────────────────────────────────────────
   227	
   228	/**
   229	 * Run the Lane C benchmark: resolve skill, D5 connectivity gate, score scenarios
   230	 * (legacy fixtures or playbook), aggregate, and write report.{json,md}.
   231	 *
   232	 * @param {Object} args - Parsed CLI args.
   233	 * @returns {number} Process exit code (0 success, 2 on missing SKILL.md,
   234	 *   3 when the D5 structural/registry gate blocked the verdict).
   235	 */
   236	function run(args) {
   237	  const skillRoot = resolveSkillRoot(args.skill);
   238	  const skillId = resolveSkillId(skillRoot);
   239	  const outputsDir = path.resolve(args['outputs-dir']);
   240	  fs.mkdirSync(outputsDir, { recursive: true });
   241	  const advisorMode = args['advisor-mode'] || 'off';
   242	  // The internal fallback stays 'router' so direct run() calls (the test suite)
   243	  // are deterministic; the live default is injected by loop-host for operators.
   244	  const traceMode = args['trace-mode'] || 'router';
   245	
   246	  if (!fs.existsSync(path.join(skillRoot, 'SKILL.md'))) {
   247	    process.stderr.write(`run-skill-benchmark: no SKILL.md at ${skillRoot}\n`);
   248	    return 2;
   249	  }
   250	
   251	  let routeGold;
   252	  try {
   253	    routeGold = resolveRouteGold(args, skillRoot);
   254	  } catch (err) {
   255	    process.stderr.write(`run-skill-benchmark: ${err.message}\n`);
   256	    return 2;
   257	  }
   258	
   259	  // Topology digest snapshot: a manifest-bearing skill's leaf-manifest.json
   260	  // must not change while a run is scoring against it, or the scored rows and
   261	  // the committed gold would silently drift apart mid-run. A skill with no
   262	  // manifest digests to null and never reaches the abort check below.
   263	  const topologyDigestBefore = readManifestDigest(skillRoot);
   264	
   265	  // D5 hard gate first.
   266	  const connectivity = scanConnectivity({ skillRoot });
   267	  const hubRegistry = scanHubRegistry({ skillRoot });
   268	
   269	  const scenarioRows = [];
   270	  const lintFindings = [];
   271	  const warnings = [];
   272	  if (args['fixtures-dir']) {
   273	    runLegacyFixtures({ fixturesDir: path.resolve(args['fixtures-dir']), skillRoot, skillId, advisorMode, scenarioRows });
   274	  } else {
   275	    runPlaybook({
   276	      skillRoot, skillId, traceMode, advisorMode, executor: args.executor,
   277	      playbookDir: args['playbook-dir'],
   278	      scenariosFilter: args.scenarios, scenarioRows, lintFindings, warningsOut: warnings,
   279	    });
   280	  }
   281	
   282	  const topologyDigestAfter = readManifestDigest(skillRoot);
   283	  if (topologyDigestBefore !== null && topologyDigestBefore !== topologyDigestAfter) {
   284	    process.stderr.write(
   285	      `run-skill-benchmark: topology_changed_during_run — leaf-manifest.json changed while scoring ${skillId} `
   286	      + `(before=${topologyDigestBefore} after=${topologyDigestAfter}); aborting rather than scoring against a shifted manifest\n`,
   287	    );
   288	    return 4;
   289	  }
   290	
   291	  // aggregate + emit.
   292	  const report = aggregate({ skillId, skillRoot, scenarioRows, connectivity, hubRegistry, traceMode, lintFindings, routeGold });
   293	  if (topologyDigestBefore !== null) report.topologyDigest = topologyDigestBefore;
   294	  if (warnings.length) report.parseWarnings = warnings;
   295	  const reportJsonPath = args.output ? path.resolve(args.output) : path.join(outputsDir, 'skill-benchmark-report.json');
   296	  const reportMdPath = reportJsonPath.replace(/\.json$/, '.md');
   297	  fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));
   298	  fs.writeFileSync(reportMdPath, renderReport(report));
   299	
   300	  process.stdout.write(`skill-benchmark: ${skillId} verdict=${report.verdict} aggregate=${report.aggregateScore} scenarios=${scenarioRows.length}\n`);
   301	  process.stdout.write(`  report.json -> ${reportJsonPath}\n  report.md   -> ${reportMdPath}\n`);
   302	  // The D5 gate exists to make a structurally-broken skill (dead router, broken
   303	  // hub registry) unusable regardless of weighted score. An exit code that stays
   304	  // 0 on that verdict lets a CI caller treat "blocked" the same as "passed" —
   305	  // reports still write either way, but the process signal must disagree. The
   306	  // route-gold gate carries the same contract: an enforced route-contract
   307	  // violation must be a non-zero process signal, not just report text.
   308	  if (report.verdict === 'BLOCKED-BY-STRUCTURE'
   309	      || report.verdict === 'BLOCKED-BY-REGISTRY'
   310	      || report.verdict === 'BLOCKED-BY-ROUTE-GOLD') return 3;
   311	  return 0;
   312	}
   313	
   314	// Opt-in D4-R pass (live + paid). Kept OUT of the synchronous run() so the
   315	// deterministic test suite (which calls run() and reads the report immediately)
   316	// stays sync. Re-reads the report run() wrote, runs the task-outcome ablation on
   317	// the explicitly selected scenarios, attaches each row's d4TaskOutcome, recomputes
   318	// the advisory D4_task_outcome aggregate, and re-writes report.{json,md}. D4-R runs
   319	// only on target-owned scenarios named via --d4-scenarios (or --scenarios); there
   320	// are no cross-target defaults, which would silently borrow another skill's ids.
   321	
   322	/**
   323	 * Opt-in D4-R pass: re-read the written report, run the task-outcome ablation on
   324	 * the chosen scenarios, attach each row's d4TaskOutcome, recompute the advisory
   325	 * D4_task_outcome aggregate, and re-write report.{json,md}.
   326	 *
   327	 * @param {Object} args - Parsed CLI args.
   328	 * @returns {Promise<number>} Process exit code (0 on success).
   329	 */
   330	async function augmentWithD4R(args) {
   331	  const { runD4RAblation } = require('./d4-ablation.cjs');
   332	  const skillRoot = resolveSkillRoot(args.skill);
   333	  const outputsDir = path.resolve(args['outputs-dir']);
   334	  const reportJsonPath = args.output ? path.resolve(args.output) : path.join(outputsDir, 'skill-benchmark-report.json');
   335	  const report = JSON.parse(fs.readFileSync(reportJsonPath, 'utf8'));
   336	  const { scenarios } = loadPlaybookScenarios({ skillRoot, playbookDir: args['playbook-dir'] });
   337	  const explicit = args['d4-scenarios'] || args.scenarios;
   338	  const wanted = explicit
   339	    ? String(explicit).split(',').map((s) => s.trim().toUpperCase()).filter(Boolean)
   340	    : [];
   341	  if (!wanted.length) {
   342	    report.advisorySignals = report.advisorySignals || {};
   343	    report.advisorySignals.D4_task_outcome = {
   344	      score: null,
   345	      status: 'not-run-no-target-scenarios',
   346	      note: 'D4-R needs explicit target-owned --d4-scenarios (or --scenarios); no cross-target defaults',
   347	    };
   348	    fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));
   349	    fs.writeFileSync(reportJsonPath.replace(/\.json$/, '.md'), renderReport(report));
   350	    process.stdout.write('  D4-R: not run — pass explicit --d4-scenarios (target-owned ids)\n');
   351	    return 0;
   352	  }
   353	  const byId = new Map((report.scenarioRows || []).map((r) => [(r.scenarioId || '').toUpperCase(), r]));
   354	  const graderMode = args['grader-mode'] || 'real';
   355	  const model = process.env.SKILL_BENCH_OPENCODE_MODEL;
   356	  const variant = process.env.SKILL_BENCH_OPENCODE_VARIANT;
   357	  let scored = 0;
   358	  for (const sc of scenarios) {
   359	    if (!wanted.includes((sc.scenarioId || '').toUpperCase())) continue;
   360	    process.stdout.write(`  D4-R ablation: ${sc.scenarioId} ...\n`);
   361	    const res = await runD4RAblation({ scenario: sc, skillRoot, model, variant, graderMode });
   362	    const row = byId.get((sc.scenarioId || '').toUpperCase());
   363	    if (row) { row.d4TaskOutcome = res.d4r; if (typeof res.d4r.score === 'number') scored += 1; }
   364	  }
   365	  const vals = (report.scenarioRows || [])
   366	    .map((r) => (r.d4TaskOutcome && typeof r.d4TaskOutcome.score === 'number' ? Math.round(r.d4TaskOutcome.score * 100) : null))
   367	    .filter((v) => typeof v === 'number');
   368	  const d4TaskAvg = vals.length ? Math.round(vals.reduce((a, b) => a + b, 0) / vals.length) : null;
   369	  report.advisorySignals = report.advisorySignals || {};
   370	  report.advisorySignals.D4_task_outcome = d4TaskAvg === null
   371	    ? { score: null, status: 'no D4-R rows scored', note: 'task-outcome usefulness delta; separate from D4 hallucination' }
   372	    : { score: d4TaskAvg, scoredCount: scored, attribution: 'approximate', note: 'task-outcome usefulness delta (skill-on vs off), separate from D4 hallucination' };
   373	  fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));
   374	  fs.writeFileSync(reportJsonPath.replace(/\.json$/, '.md'), renderReport(report));
   375	  process.stdout.write(`  D4-R: ${scored} scenario(s) scored; advisory D4_task_outcome=${d4TaskAvg == null ? 'null' : d4TaskAvg}\n`);
   376	  return 0;
   377	}
   378	
   379	// ─────────────────────────────────────────────────────────────────────────────
   380	// 5. EXPORTS
   381	// ─────────────────────────────────────────────────────────────────────────────
   382	
   383	module.exports = { run, augmentWithD4R, resolveSkillRoot, loadFixtures, isHubTypeSkill, resolveRouteGold };
   384	
   385	if (require.main === module) {
   386	  const args = require('./_args.cjs').parse(process.argv.slice(2));
   387	  if (!args.skill || !args['outputs-dir']) {
   388	    process.stderr.write('usage: run-skill-benchmark.cjs --skill <root-or-id> --outputs-dir <path> [--fixtures-dir <path>] [--playbook-dir <path>] [--scenarios <ids>] [--output <report.json>] [--trace-mode router|live] [--route-gold on|off|auto] [--d4 [--d4-scenarios <ids>] [--grader-mode real|mock]]\n');
   389	    process.exit(2);
   390	  }
   391	  const code = run(args);
   392	  if (code === 0 && args.d4 && (args['trace-mode'] === 'live')) {
   393	    augmentWithD4R(args).then((c) => process.exit(c)).catch((err) => {
   394	      process.stderr.write(`D4-R pass failed: ${err && err.message}\n`);
   395	      process.exit(1);
   396	    });
   397	  } else {
   398	    if (args.d4 && args['trace-mode'] !== 'live') process.stderr.write('note: --d4 requires --trace-mode live; skipped.\n');
   399	    process.exit(code);
   400	  }
   401	}

