\n49:     \"overlay\": [\n50:       \"skill_agent\",\n51:       \"agent_cross_runtime\",\n52:       \"feature_catalog_code\",\n53:       \"playbook_capability\"\n54:     ]\n55:   },\n56:   \"qualityGateThreshold\": true,\n57:   \"runtimeCapabilityResolver\": \".opencode/skills/system-deep-loop/deep-review/scripts/runtime-capabilities.cjs\",\n58:   \"reducerScriptPath\": \".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs\",\n59:   \"fileProtection\": {\n60:     \"deep-review-config.json\": \"immutable\",\n61:     \"deep-review-state.jsonl\": \"append-only\",\n62:     \"deep-review-findings-registry.json\": \"auto-generated\",\n63:     \"deep-review-strategy.md\": \"mutable\",\n64:     \"deep-review-dashboard.md\": \"auto-generated\",\n65:     \".deep-review-pause\": \"operator-controlled\",\n66:     \"review-report.md\": \"mutable\",\n67:     \"review-report-v*.md\": \"write-once\",\n68:     \"iteration-*.md\": \"write-once\"\n69:   },\n70:   \"reducer\": {\n71:     \"enabled\": true,\n72:     \"inputs\": [\n73:       \"latestJSONLDelta\",\n74:       \"newIterationFile\",\n75:       \"priorReducedState\"\n76:     ],\n77:     \"outputs\": [\n78:       \"findingsRegistry\",\n79:       \"dashboardMetrics\",\n80:       \"strategyUpdates\"\n81:     ],\n82:     \"metrics\": [\n83:       \"dimensionsCovered\",\n84:       \"findingsBySeverity\",\n85:       \"openFindings\",\n86:       \"resolvedFindings\",\n87:       \"convergenceScore\"\n88:     ]\n89:   },\n90:   \"_optimizerManaged\": {\n91:     \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n92:     \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n93:     \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n94:     \"lockedFields\": [\"lineageMode\", \"reducer\", \"fileProtection\", \"sessionId\", \"mode\", \"reviewDimensions\", \"antiConvergence.convergenceMode\", \"antiConvergence.stopPolicy\"],\n95:     \"promotionMode\": \"advisory-only\"\n96:   }\n97: }\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"{\n  \"topic\": \"\",\n  \"sessionId\": \"\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"migrationWindowEndsAt\": \"\",\n  \"maxIterations\": 7,\n  \"convergenceThreshold\": 0.10,\n  \"antiConvergence\": {\n    \"minIterations\": 2,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"fail-closed\"\n  },\n  \"stuckThreshold\": 2,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": false,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json","text":"{\n  \"topic\": \"\",\n  \"sessionId\": \"\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"migrationWindowEndsAt\": \"\",\n  \"maxIterations\": 7,\n  \"convergenceThreshold\": 0.10,\n  \"antiConvergence\": {\n    \"minIterations\": 2,\n    \"convergenceMode\": \"default\",\n    \"stopPolicy\": \"fail-closed\"\n  },\n  \"stuckThreshold\": 2,\n  \"maxDurationMinutes\": 120,\n  \"maxToolCallsPerIteration\": 12,\n  \"maxMinutesPerIteration\": 10,\n  \"progressiveSynthesis\": false,\n  \"specFolder\": \"\",\n  \"createdAt\": \"\",\n  \"status\": \"initialized\",\n  \"releaseReadinessState\": \"in-progress\",\n  \"executionMode\": \"auto\",\n  \"executor\": {\n    \"kind\": \"native\",\n    \"model\": null,\n    \"reasoningEffort\": null,\n    \"serviceTier\": null,\n    \"sandboxMode\": null,\n    \"timeoutSeconds\": 900\n  },\n  \"mode\": \"review\",\n  \"reviewTarget\": \"\",\n  \"reviewTargetType\": \"spec-folder\",\n  \"reviewDimensions\": [\n    \"correctness\",\n    \"security\",\n    \"traceability\",\n    \"maintainability\"\n  ],\n  \"severityThreshold\": \"P2\",\n  \"crossReference\": {\n    \"core\": [\n      \"spec_code\",\n      \"checklist_evidence\"\n    ],\n    \"overlay\": [\n      \"skill_agent\",\n      \"agent_cross_runtime\",\n      \"feature_catalog_code\",\n      \"playbook_capability\"\n    ]\n  },\n  \"qualityGateThreshold\": true,\n  \"runtimeCapabilityResolver\": \".opencode/skills/system-deep-loop/deep-review/scripts/runtime-capabilities.cjs\",\n  \"reducerScriptPath\": \".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs\",\n  \"fileProtection\": {\n    \"deep-review-config.json\": \"immutable\",\n    \"deep-review-state.jsonl\": \"append-only\",\n    \"deep-review-findings-registry.json\": \"auto-generated\",\n    \"deep-review-strategy.md\": \"mutable\",\n    \"deep-review-dashboard.md\": \"auto-generated\",\n    \".deep-review-pause\": \"operator-controlled\",\n    \"review-report.md\": \"mutable\",\n    \"review-report-v*.md\": \"write-once\",\n    \"iteration-*.md\": \"write-once\"\n  },\n  \"reducer\": {\n    \"enabled\": true,\n    \"inputs\": [\n      \"latestJSONLDelta\",\n      \"newIterationFile\",\n      \"priorReducedState\"\n    ],\n    \"outputs\": [\n      \"findingsRegistry\",\n      \"dashboardMetrics\",\n      \"strategyUpdates\"\n    ],\n    \"metrics\": [\n      \"dimensionsCovered\",\n      \"findingsBySeverity\",\n      \"openFindings\",\n      \"resolvedFindings\",\n      \"convergenceScore\"\n    ]\n  },\n  \"_optimizerManaged\": {\n    \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n    \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n    \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n    \"lockedFields\": [\"lineageMode\", \"reducer\", \"fileProtection\", \"sessionId\", \"mode\", \"reviewDimensions\", \"antiConvergence.convergenceMode\", \"antiConvergence.stopPolicy\"],\n    \"promotionMode\": \"advisory-only\"\n  }\n}","lineStart":1,"lineEnd":97,"totalLines":97,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/assets/deep_review_config.json","time":{"start":1784385657988,"end":1784385658012}},"metadata":{"openai":{"itemId":"fc_0469c5d15e3d3615016a5b9079c8e48191900b36b38f10d18d"}},"id":"prt_f75ac5c82001WRzvHXnVLpJ6Mp","sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","messageID":"msg_f75ac246b001CTHIZaoIVyzeUk"}}
{"type":"tool_use","timestamp":1784385658020,"sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","part":{"type":"tool","tool":"read","callID":"call_ThmGNV1ITgbo8kI2Ds6RgaYD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","offset":1,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep Review State Reducer                                                ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const fs = require('node:fs');\n12: const path = require('node:path');\n13: const { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\n14: const { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\n15: const { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n16: \n17: // ─────────────────────────────────────────────────────────────────────────────\n18: // 2. CONSTANTS\n19: // ─────────────────────────────────────────────────────────────────────────────\n20: \n21: const REQUIRED_DIMENSIONS = ['correctness', 'security', 'traceability', 'maintainability'];\n22: const SEVERITY_KEYS = ['P0', 'P1', 'P2'];\n23: const SEVERITY_WEIGHTS = { P0: 10.0, P1: 5.0, P2: 1.0 };\n24: const LIVE_LINEAGE_MODES = new Set(['new', 'resume', 'restart']);\n25: \n26: // ─────────────────────────────────────────────────────────────────────────────\n27: // 3. HELPERS\n28: // ─────────────────────────────────────────────────────────────────────────────\n29: \n30: function readUtf8(filePath) {\n31:   return fs.readFileSync(filePath, 'utf8');\n32: }\n33: \n34: function writeUtf8(filePath, content) {\n35:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n36:   fs.writeFileSync(filePath, content, 'utf8');\n37: }\n38: \n39: function readJson(filePath) {\n40:   return JSON.parse(readUtf8(filePath));\n41: }\n42: \n43: function getResourceMapEmitSetting(config) {\n44:   const nested = config && typeof config === 'object'\n45:     ? (config.resource_map || config.resourceMap || null)\n46:     : null;\n47:   if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n48:     return nested.emit;\n49:   }\n50:   return true;\n51: }\n52: \n53: function slugify(value) {\n54:   return value\n55:     .toLowerCase()\n56:     .replace(/[^a-z0-9]+/g, '-')\n57:     .replace(/^-+|-+$/g, '')\n58:     .slice(0, 80) || 'entry';\n59: }\n60: \n61: function normalizeText(value) {\n62:   if (value === null || value === undefined) return '';\n63:   if (typeof value !== 'string') {\n64:     try { return String(value).replace(/\\s+/g, ' ').trim(); }\n65:     catch { return ''; }\n66:   }\n67:   return value.replace(/\\s+/g, ' ').trim();\n68: }\n69: \n70: function escapeRegExp(value) {\n71:   return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n72: }\n73: \n74: function zeroSeverityMap() {\n75:   return { P0: 0, P1: 0, P2: 0 };\n76: }\n77: \n78: function isFiniteNumber(value) {\n79:   return typeof value === 'number' && Number.isFinite(value);\n80: }\n81: \n82: function normalizeSeverity(value) {\n83:   return SEVERITY_KEYS.includes(value) ? value : null;\n84: }\n85: \n86: function normalizeLineageMode(value) {\n87:   const normalized = normalizeText(value).toLowerCase();\n88:   return LIVE_LINEAGE_MODES.has(normalized) ? normalized : null;\n89: }\n90: \n91: function getNestedField(record, fieldName) {\n92:   if (!record || typeof record !== 'object') {\n93:     return undefined;\n94:   }\n95:   if (record[fieldName] !== undefined) {\n96:     return record[fieldName];\n97:   }\n98:   if (record.details && typeof record.details === 'object' && record.details[fieldName] !== undefined) {\n99:     return record.details[fieldName];\n100:   }\n101:   return undefined;\n102: }\n103: \n104: // ─────────────────────────────────────────────────────────────────────────────\n105: // 4. PARSERS\n106: // ─────────────────────────────────────────────────────────────────────────────\n107: \n108: /**\n109:  * Parse JSONL content into an array of records, preserving both iteration and\n110:  * event rows. Backward-compatible array return.\n111:  *\n112:  * @param {string} jsonlContent - Newline-delimited JSON string\n113:  * @returns {Array<Object>} Parsed records (corrupt lines silently dropped — use parseJsonlDetailed for fail-closed behavior)\n114:  */\n115: function parseJsonl(jsonlContent) {\n116:   return parseJsonlDetailed(jsonlContent).records;\n117: }\n118: \n119: /**\n120:  * Parse JSONL content and report malformed lines (fail-closed pathway).\n121:  *\n122:  * Returns both the parsed records and a corruption warning list. The reducer\n123:  * exit code is non-zero when warnings are present unless `--lenient` is passed.\n124:  *\n125:  * @param {string} jsonlContent - Newline-delimited JSON string\n126:  * @returns {{records: Array<Object>, corruptionWarnings: Array<{line: number, raw: string, error: string}>}}\n127:  */\n128: function parseJsonlDetailed(jsonlContent) {\n129:   const records = [];\n130:   const corruptionWarnings = [];\n131:   let lineNumber = 0;\n132: \n133:   for (const rawLine of jsonlContent.split('\\n')) {\n134:     lineNumber += 1;\n135:     const line = rawLine.trim();\n136:     if (!line) {\n137:       continue;\n138:     }\n139: \n140:     try {\n141:       records.push(JSON.parse(line));\n142:     } catch (error) {\n143:       corruptionWarnings.push({\n144:         line: lineNumber,\n145:         raw: rawLine.length > 200 ? `${rawLine.slice(0, 200)}...` : rawLine,\n146:         error: error instanceof Error ? error.message : String(error),\n147:       });\n148:     }\n149:   }\n150: \n151:   return { records, corruptionWarnings };\n152: }\n153: \n154: function loadDeltaPayloads(deltaDir) {\n155:   if (!fs.existsSync(deltaDir)) {\n156:     return [];\n157:   }\n158: \n159:   return fs.readdirSync(deltaDir)\n160:     .filter((fileName) => /^iter-\\d+\\.jsonl$/.test(fileName))\n161:     .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }))\n162:     .map((fileName) => {\n163:       const { records, corruptionWarnings } = parseJsonlDetailed(readUtf8(path.join(deltaDir, fileName)));\n164:       if (!corruptionWarnings.length) {\n165:         return records;\n166:       }\n167:       console.warn(\n168:         `[deep-review] resource-map extractor skipped ${corruptionWarnings.length} malformed delta row(s) from ${fileName}`,\n169:       );\n170:       return records.concat(new Array(corruptionWarnings.length).fill(null));\n171:     });\n172: }\n173: \n174: function extractSection(markdown, heading) {\n175:   const pattern = new RegExp(`(?:^|\\\\n)##\\\\s+${escapeRegExp(heading)}\\\\s*\\\\n([\\\\s\\\\S]*?)(?=\\\\n##\\\\s|$)`, 'i');\n176:   const match = markdown.match(pattern);\n177:   return match ? match[1].trim() : '';\n178: }\n179: \n180: function extractSubsection(sectionText, subheading) {\n181:   const pattern = new RegExp(`(?:^|\\\\n)###\\\\s+${escapeRegExp(subheading)}[^\\\\n]*\\\\n([\\\\s\\\\S]*?)(?=\\\\n###\\\\s|\\\\n##\\\\s|$)`, 'i');\n182:   const match = sectionText.match(pattern);\n183:   return match ? match[1].trim() : '';\n184: }\n185: \n186: function extractListItems(sectionText) {\n187:   return sectionText\n188:     .split('\\n')\n189:     .map((line) => line.trim())\n190:     .filter((line) => /^([-*]|\\d+\\.)\\s+/.test(line))\n191:     .map((line) => normalizeText(line.replace(/^([-*]|\\d+\\.)\\s+/, '')))\n192:     .filter(Boolean);\n193: }\n194: \n195: /**\n196:  * Parse a finding line of the form: `- **F001**: Title — file:line — Description`\n197:  *\n198:  * @param {string} line - Raw finding bullet\n199:  * @param {string} severity - P0, P1, or P2 context\n200:  * @returns {Object|null} Structured finding or null when the line is not a finding\n201:  */\n202: function parseFindingLine(line, severity) {\n203:   const match = line.match(/^\\*\\*(F\\d+)\\*\\*\\s*:\\s*(.+?)(?:\\s+[—-]\\s+`?([^`]+?)`?)?(?:\\s+[—-]\\s+(.+))?$/);\n204:   if (!match) {\n205:     return null;\n206:   }\n207: \n208:   const [, findingId, title, evidenceRaw, description] = match;\n209:   let file = null;\n210:   let lineNumber = null;\n211: \n212:   if (evidenceRaw) {\n213:     const evidenceMatch = evidenceRaw.trim().match(/^(.+?):(\\d+)(?:[:-].*)?$/);\n214:     if (evidenceMatch) {\n215:       file = evidenceMatch[1];\n216:       lineNumber = Number(evidenceMatch[2]);\n217:     } else {\n218:       file = evidenceRaw.trim();\n219:     }\n220:   }\n221: \n222:   return {\n223:     findingId,\n224:     severity,\n225:     title: normalizeText(title),\n226:     file,\n227:     line: lineNumber,\n228:     description: normalizeText(description || ''),\n229:   };\n230: }\n231: \n232: function parseFindingsBlock(sectionText, severity) {\n233:   if (!sectionText) {\n234:     return [];\n235:   }\n236: \n237:   return sectionText\n238:     .split('\\n')\n239:     .map((line) => line.trim())\n240:     .filter((line) => /^-\\s+\\*\\*F\\d+\\*\\*/.test(line))\n241:     .map((line) => parseFindingLine(line.replace(/^-\\s+/, ''), severity))\n242:     .filter(Boolean);\n243: }\n244: \n245: /**\n246:  * Parse a single iteration markdown file into a structured review record.\n247:  *\n248:  * @param {string} iterationPath - Absolute path to an iteration-NNN.md file\n249:  * @returns {Object} Parsed iteration with focus, findings, cross-reference, and reflection fields\n250:  */\n251: function parseIterationFile(iterationPath) {\n252:   const markdown = readUtf8(iterationPath);\n253:   const runMatch = iterationPath.match(/iteration-(\\d+)\\.md$/);\n254:   const headingMatch = markdown.match(/^#\\s+Iteration\\s+\\d+\\s*[-:]\\s+(.+)$/m);\n255: \n256:   // Support both old schema (Focus/Findings/Ruled Out/Dead Ends/Assessment)\n257:   // and live schema (Dispatcher/Files Reviewed/Findings - New/Traceability Checks/\n258:   // Confirmed-Clean/Next Focus).\n259:   const focusSection = extractSection(markdown, 'Focus') || extractSection(markdown, 'Dispatcher');\n260:   const findingsSection = extractSection(markdown, 'Findings') || extractSection(markdown, 'Findings - New');\n261:   const ruledOutSection = extractSection(markdown, 'Ruled Out') || extractSection(markdown, 'Confirmed-Clean Surfaces') || extractSection(markdown, 'Confirmed-Clean');\n262:   const deadEndsSection = extractSection(markdown, 'Dead Ends') || extractSection(markdown, 'Traceability Checks');\n263:   const nextFocusSection = extractSection(markdown, 'Recommended Next Focus') || extractSection(markdown, 'Next Focus (recommendation)') || extractSection(markdown, 'Next Focus');\n264:   const assessmentSection = extractSection(markdown, 'Assessment');\n265:   const filesReviewedSection = extractSection(markdown, 'Files Reviewed');\n266: \n267:   const p0Block = extractSubsection(findingsSection, 'P0') || extractSubsection(findingsSection, 'P0 Findings');\n268:   const p1Block = extractSubsection(findingsSection, 'P1') || extractSubsection(findingsSection, 'P1 Findings');\n269:   const p2Block = extractSubsection(findingsSection, 'P2') || extractSubsection(findingsSection, 'P2 Findings');\n270: \n271:   const findings = [\n272:     ...parseFindingsBlock(p0Block, 'P0'),\n273:     ...parseFindingsBlock(p1Block, 'P1'),\n274:     ...parseFindingsBlock(p2Block, 'P2'),\n275:   ];\n276: \n277:   const dimensionsAddressed = (assessmentSection.match(/Dimensions addressed:\\s*(.+)/i) || [])[1];\n278: \n279:   return {\n280:     path: iterationPath,\n281:     run: runMatch ? Number(runMatch[1]) : 0,\n282:     focus: normalizeText(focusSection || (headingMatch ? headingMatch[1] : 'Unknown focus')),\n283:     findings,\n284:     ruledOut: extractListItems(ruledOutSection),\n285:     deadEnds: extractListItems(deadEndsSection),\n286:     nextFocus: normalizeText(nextFocusSection),\n287:     dimensionsAddressed: dimensionsAddressed\n288:       ? dimensionsAddressed.split(/[,;]/).map((value) => normalizeText(value).toLowerCase()).filter(Boolean)\n289:       : [],\n290:   };\n291: }\n292: \n293: function parseStrategyDimensions(strategyContent) {\n294:   const section = extractSection(strategyContent, '3. REVIEW DIMENSIONS (remaining)')\n295:     || extractSection(strategyContent, '3. KEY QUESTIONS (remaining)');\n296:   return section\n297:     .split('\\n')\n298:     .map((line) => line.trim())\n299:     .filter((line) => /^- \\[[ xX]\\]\\s+/.test(line))\n300:     .map((line) => {\n\n(Showing lines 1-300 of 2235. Use offset=301 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Review State Reducer                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\nconst { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Review State Reducer                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../runtime/lib/deep-loop/artifact-root.cjs');\nconst { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst REQUIRED_DIMENSIONS = ['correctness', 'security', 'traceability', 'maintainability'];\nconst SEVERITY_KEYS = ['P0', 'P1', 'P2'];\nconst SEVERITY_WEIGHTS = { P0: 10.0, P1: 5.0, P2: 1.0 };\nconst LIVE_LINEAGE_MODES = new Set(['new', 'resume', 'restart']);\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction readUtf8(filePath) {\n  return fs.readFileSync(filePath, 'utf8');\n}\n\nfunction writeUtf8(filePath, content) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.writeFileSync(filePath, content, 'utf8');\n}\n\nfunction readJson(filePath) {\n  return JSON.parse(readUtf8(filePath));\n}\n\nfunction getResourceMapEmitSetting(config) {\n  const nested = config && typeof config === 'object'\n    ? (config.resource_map || config.resourceMap || null)\n    : null;\n  if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n    return nested.emit;\n  }\n  return true;\n}\n\nfunction slugify(value) {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .slice(0, 80) || 'entry';\n}\n\nfunction normalizeText(value) {\n  if (value === null || value === undefined) return '';\n  if (typeof value !== 'string') {\n    try { return String(value).replace(/\\s+/g, ' ').trim(); }\n    catch { return ''; }\n  }\n  return value.replace(/\\s+/g, ' ').trim();\n}\n\nfunction escapeRegExp(value) {\n  return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\nfunction zeroSeverityMap() {\n  return { P0: 0, P1: 0, P2: 0 };\n}\n\nfunction isFiniteNumber(value) {\n  return typeof value === 'number' && Number.isFinite(value);\n}\n\nfunction normalizeSeverity(value) {\n  return SEVERITY_KEYS.includes(value) ? value : null;\n}\n\nfunction normalizeLineageMode(value) {\n  const normalized = normalizeText(value).toLowerCase();\n  return LIVE_LINEAGE_MODES.has(normalized) ? normalized : null;\n}\n\nfunction getNestedField(record, fieldName) {\n  if (!record || typeof record !== 'object') {\n    return undefined;\n  }\n  if (record[fieldName] !== undefined) {\n    return record[fieldName];\n  }\n  if (record.details && typeof record.details === 'object' && record.details[fieldName] !== undefined) {\n    return record.details[fieldName];\n  }\n  return undefined;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. PARSERS\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Parse JSONL content into an array of records, preserving both iteration and\n * event rows. Backward-compatible array return.\n *\n * @param {string} jsonlContent - Newline-delimited JSON string\n * @returns {Array<Object>} Parsed records (corrupt lines silently dropped — use parseJsonlDetailed for fail-closed behavior)\n */\nfunction parseJsonl(jsonlContent) {\n  return parseJsonlDetailed(jsonlContent).records;\n}\n\n/**\n * Parse JSONL content and report malformed lines (fail-closed pathway).\n *\n * Returns both the parsed records and a corruption warning list. The reducer\n * exit code is non-zero when warnings are present unless `--lenient` is passed.\n *\n * @param {string} jsonlContent - Newline-delimited JSON string\n * @returns {{records: Array<Object>, corruptionWarnings: Array<{line: number, raw: string, error: string}>}}\n */\nfunction parseJsonlDetailed(jsonlContent) {\n  const records = [];\n  const corruptionWarnings = [];\n  let lineNumber = 0;\n\n  for (const rawLine of jsonlContent.split('\\n')) {\n    lineNumber += 1;\n    const line = rawLine.trim();\n    if (!line) {\n      continue;\n    }\n\n    try {\n      records.push(JSON.parse(line));\n    } catch (error) {\n      corruptionWarnings.push({\n        line: lineNumber,\n        raw: rawLine.length > 200 ? `${rawLine.slice(0, 200)}...` : rawLine,\n        error: error instanceof Error ? error.message : String(error),\n      });\n    }\n  }\n\n  return { records, corruptionWarnings };\n}\n\nfunction loadDeltaPayloads(deltaDir) {\n  if (!fs.existsSync(deltaDir)) {\n    return [];\n  }\n\n  return fs.readdirSync(deltaDir)\n    .filter((fileName) => /^iter-\\d+\\.jsonl$/.test(fileName))\n    .sort((left, right) => left.localeCompare(right, undefined, { numeric: true }))\n    .map((fileName) => {\n      const { records, corruptionWarnings } = parseJsonlDetailed(readUtf8(path.join(deltaDir, fileName)));\n      if (!corruptionWarnings.length) {\n        return records;\n      }\n      console.warn(\n        `[deep-review] resource-map extractor skipped ${corruptionWarnings.length} malformed delta row(s) from ${fileName}`,\n      );\n      return records.concat(new Array(corruptionWarnings.length).fill(null));\n    });\n}\n\nfunction extractSection(markdown, heading) {\n  const pattern = new RegExp(`(?:^|\\\\n)##\\\\s+${escapeRegExp(heading)}\\\\s*\\\\n([\\\\s\\\\S]*?)(?=\\\\n##\\\\s|$)`, 'i');\n  const match = markdown.match(pattern);\n  return match ? match[1].trim() : '';\n}\n\nfunction extractSubsection(sectionText, subheading) {\n  const pattern = new RegExp(`(?:^|\\\\n)###\\\\s+${escapeRegExp(subheading)}[^\\\\n]*\\\\n([\\\\s\\\\S]*?)(?=\\\\n###\\\\s|\\\\n##\\\\s|$)`, 'i');\n  const match = sectionText.match(pattern);\n  return match ? match[1].trim() : '';\n}\n\nfunction extractListItems(sectionText) {\n  return sectionText\n    .split('\\n')\n    .map((line) => line.trim())\n    .filter((line) => /^([-*]|\\d+\\.)\\s+/.test(line))\n    .map((line) => normalizeText(line.replace(/^([-*]|\\d+\\.)\\s+/, '')))\n    .filter(Boolean);\n}\n\n/**\n * Parse a finding line of the form: `- **F001**: Title — file:line — Description`\n *\n * @param {string} line - Raw finding bullet\n * @param {string} severity - P0, P1, or P2 context\n * @returns {Object|null} Structured finding or null when the line is not a finding\n */\nfunction parseFindingLine(line, severity) {\n  const match = line.match(/^\\*\\*(F\\d+)\\*\\*\\s*:\\s*(.+?)(?:\\s+[—-]\\s+`?([^`]+?)`?)?(?:\\s+[—-]\\s+(.+))?$/);\n  if (!match) {\n    return null;\n  }\n\n  const [, findingId, title, evidenceRaw, description] = match;\n  let file = null;\n  let lineNumber = null;\n\n  if (evidenceRaw) {\n    const evidenceMatch = evidenceRaw.trim().match(/^(.+?):(\\d+)(?:[:-].*)?$/);\n    if (evidenceMatch) {\n      file = evidenceMatch[1];\n      lineNumber = Number(evidenceMatch[2]);\n    } else {\n      file = evidenceRaw.trim();\n    }\n  }\n\n  return {\n    findingId,\n    severity,\n    title: normalizeText(title),\n    file,\n    line: lineNumber,\n    description: normalizeText(description || ''),\n  };\n}\n\nfunction parseFindingsBlock(sectionText, severity) {\n  if (!sectionText) {\n    return [];\n  }\n\n  return sectionText\n    .split('\\n')\n    .map((line) => line.trim())\n    .filter((line) => /^-\\s+\\*\\*F\\d+\\*\\*/.test(line))\n    .map((line) => parseFindingLine(line.replace(/^-\\s+/, ''), severity))\n    .filter(Boolean);\n}\n\n/**\n * Parse a single iteration markdown file into a structured review record.\n *\n * @param {string} iterationPath - Absolute path to an iteration-NNN.md file\n * @returns {Object} Parsed iteration with focus, findings, cross-reference, and reflection fields\n */\nfunction parseIterationFile(iterationPath) {\n  const markdown = readUtf8(iterationPath);\n  const runMatch = iterationPath.match(/iteration-(\\d+)\\.md$/);\n  const headingMatch = markdown.match(/^#\\s+Iteration\\s+\\d+\\s*[-:]\\s+(.+)$/m);\n\n  // Support both old schema (Focus/Findings/Ruled Out/Dead Ends/Assessment)\n  // and live schema (Dispatcher/Files Reviewed/Findings - New/Traceability Checks/\n  // Confirmed-Clean/Next Focus).\n  const focusSection = extractSection(markdown, 'Focus') || extractSection(markdown, 'Dispatcher');\n  const findingsSection = extractSection(markdown, 'Findings') || extractSection(markdown, 'Findings - New');\n  const ruledOutSection = extractSection(markdown, 'Ruled Out') || extractSection(markdown, 'Confirmed-Clean Surfaces') || extractSection(markdown, 'Confirmed-Clean');\n  const deadEndsSection = extractSection(markdown, 'Dead Ends') || extractSection(markdown, 'Traceability Checks');\n  const nextFocusSection = extractSection(markdown, 'Recommended Next Focus') || extractSection(markdown, 'Next Focus (recommendation)') || extractSection(markdown, 'Next Focus');\n  const assessmentSection = extractSection(markdown, 'Assessment');\n  const filesReviewedSection = extractSection(markdown, 'Files Reviewed');\n\n  const p0Block = extractSubsection(findingsSection, 'P0') || extractSubsection(findingsSection, 'P0 Findings');\n  const p1Block = extractSubsection(findingsSection, 'P1') || extractSubsection(findingsSection, 'P1 Findings');\n  const p2Block = extractSubsection(findingsSection, 'P2') || extractSubsection(findingsSection, 'P2 Findings');\n\n  const findings = [\n    ...parseFindingsBlock(p0Block, 'P0'),\n    ...parseFindingsBlock(p1Block, 'P1'),\n    ...parseFindingsBlock(p2Block, 'P2'),\n  ];\n\n  const dimensionsAddressed = (assessmentSection.match(/Dimensions addressed:\\s*(.+)/i) || [])[1];\n\n  return {\n    path: iterationPath,\n    run: runMatch ? Number(runMatch[1]) : 0,\n    focus: normalizeText(focusSection || (headingMatch ? headingMatch[1] : 'Unknown focus')),\n    findings,\n    ruledOut: extractListItems(ruledOutSection),\n    deadEnds: extractListItems(deadEndsSection),\n    nextFocus: normalizeText(nextFocusSection),\n    dimensionsAddressed: dimensionsAddressed\n      ? dimensionsAddressed.split(/[,;]/).map((value) => normalizeText(value).toLowerCase()).filter(Boolean)\n      : [],\n  };\n}\n\nfunction parseStrategyDimensions(strategyContent) {\n  const section = extractSection(strategyContent, '3. REVIEW DIMENSIONS (remaining)')\n    || extractSection(strategyContent, '3. KEY QUESTIONS (remaining)');\n  return section\n    .split('\\n')\n    .map((line) => line.trim())\n    .filter((line) => /^- \\[[ xX]\\]\\s+/.test(line))\n    .map((line) => {","lineStart":1,"lineEnd":300,"totalLines":2235,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs","time":{"start":1784385657985,"end":1784385658016}},"metadata":{"openai":{"itemId":"fc_0469c5d15e3d3615016a5b9079c8d88191ac164156fae99727"}},"id":"prt_f75ac5c7f001SpKHm30YfLAdXk","sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","messageID":"msg_f75ac246b001CTHIZaoIVyzeUk"}}
{"type":"tool_use","timestamp":1784385658021,"sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","part":{"type":"tool","tool":"read","callID":"call_ctYlJsYdyfMyfu3wwM4gqsoH","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts","limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Deep-Loop Post-Dispatch Validator\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: import { existsSync, readFileSync, renameSync, rmSync, statSync, truncateSync, writeFileSync } from 'node:fs';\n6: import { join, resolve } from 'node:path';\n7: \n8: import { validateEvidenceContract } from './evidence-contract.js';\n9: import { appendJsonlRecord } from './jsonl-repair.js';\n10: import { deriveReceiptKeyForDispatch } from './executor-audit.js';\n11: import { canonicalReceiptJson, verifyReceipt } from './receipt-crypto.js';\n12: import type { ExecutorKind } from './executor-config.js';\n13: \n14: // ───── 1. TYPE DEFINITIONS ─────\n15: \n16: export type VerificationLanguage = 'python' | 'typescript' | 'javascript' | 'rust' | 'go';\n17: \n18: export type PostDispatchRecipeConfig = {\n19:   verification_enabled?: boolean;\n20:   verification_languages?: VerificationLanguage[];\n21:   verification_threshold?: number;\n22:   judge_quarantine_enabled?: boolean;\n23: };\n24: \n25: export type RouteProofExpectation = {\n26:   mode: string;\n27:   targetAgent: string;\n28:   resolvedRoute: string;\n29:   requireAgentDefinitionLoaded?: boolean;\n30: };\n31: \n32: export type DispatchReceiptExpectation = {\n33:   receiptDir: string;\n34:   dispatchId: string;\n35: };\n36: \n37: export type PostDispatchValidateInput = {\n38:   iterationFile: string;\n39:   stateLogPath: string;\n40:   previousStateLogSize: number;\n41:   requiredJsonlFields: string[];\n42:   executorKind?: ExecutorKind;\n43:   deltaFilePath?: string;\n44:   routeProof?: RouteProofExpectation;\n45:   recipeConfig?: PostDispatchRecipeConfig;\n46:   // When set, the validator requires a structurally intact, intent-bound\n47:   // dispatch receipt pair (intent + completion) before accepting the\n48:   // state-log append; a mac that fails to cryptographically correlate is\n49:   // reported as a warning, not a blocking failure (see\n50:   // validateDispatchReceipt). Dispatches that did not opt into receipts omit\n51:   // it and keep legacy behavior.\n52:   dispatchReceipt?: DispatchReceiptExpectation;\n53: };\n54: \n55: /** Failure class recorded for a hardened judge attempt. */\n56: export type JudgeFailureKind = 'model_error' | 'parse_error' | 'slow_timeout' | 'unknown';\n57: \n58: /** Persistence destinations protected by judge-card quarantine. */\n59: export type JudgePersistenceSurface = 'persistence' | 'convergence' | 'coverage';\n60: \n61: /** A failed judge attempt with retry and timeout diagnostics. */\n62: export interface JudgeAttemptFailure {\n63:   attempt: number;\n64:   kind: JudgeFailureKind;\n65:   message: string;\n66:   fastTimedOut: boolean;\n67:   formatStripRetried: boolean;\n68: }\n69: \n70: /** Retry, timeout, and parser configuration for a hardened judge call. */\n71: export interface JudgeHardeningConfig {\n72:   maxAttempts?: number;\n73:   backoffMs?: number | ((attempt: number) => number);\n74:   fastTimeoutMs?: number;\n75:   slowTimeoutMs?: number;\n76:   now?: () => string;\n77:   sleep?: (ms: number) => Promise<void>;\n78: }\n79: \n80: /** Input for running one model-backed judge call through hardening layers. */\n81: export interface JudgeHardeningInput<TCard extends Record<string, unknown>> extends JudgeHardeningConfig {\n82:   invoke: () => Promise<string>;\n83:   parse?: (record: Record<string, unknown>) => TCard;\n84:   fallbackReason?: string;\n85: }\n86: \n87: /** Metadata attached to neutral judge fallback cards. */\n88: export interface JudgeFallbackMetadata {\n89:   attempts: number;\n90:   maxAttempts: number;\n91:   failureKind: JudgeFailureKind;\n92:   failures: JudgeAttemptFailure[];\n93:   formatStripRetries: number;\n94:   fastTimeouts: number;\n95:   slowTimeouts: number;\n96:   generatedAt: string;\n97: }\n98: \n99: /** Input for constructing a neutral quarantined judge fallback card. */\n100: export interface JudgeFallbackInput {\n101:   reason: string;\n102:   failures: JudgeAttemptFailure[];\n103:   maxAttempts: number;\n104:   formatStripRetries: number;\n105:   fastTimeouts: number;\n106:   slowTimeouts: number;\n107:   now?: () => string;\n108: }\n109: \n110: /** Neutral card emitted when judge retries cannot produce a parseable score. */\n111: export interface NeutralJudgeFallbackCard extends Record<string, unknown> {\n112:   type: 'judge_fallback_card';\n113:   fallback: true;\n114:   quarantined: true;\n115:   score: 0.5;\n116:   confidence: 0;\n117:   reason: string;\n118:   metadata: JudgeFallbackMetadata;\n119: }\n120: \n121: /** Result from a hardened judge call. */\n122: export type JudgeHardeningResult<TCard extends Record<string, unknown>> =\n123:   | {\n124:       ok: true;\n125:       card: TCard;\n126:       attempts: number;\n127:       failures: JudgeAttemptFailure[];\n128:       formatStripRetries: number;\n129:       fastTimeouts: number;\n130:       slowTimeouts: number;\n131:     }\n132:   | {\n133:       ok: false;\n134:       card: NeutralJudgeFallbackCard;\n135:       attempts: number;\n136:       failures: JudgeAttemptFailure[];\n137:       formatStripRetries: number;\n138:       fastTimeouts: number;\n139:       slowTimeouts: number;\n140:     };\n141: \n142: /** Writer callback for a judge card persistence surface. */\n143: export type JudgePersistenceWriter<TCard extends Record<string, unknown>> = (\n144:   card: TCard,\n145:   surface: JudgePersistenceSurface,\n146: ) => void | Promise<void>;\n147: \n148: /** Persistence writers guarded by the quarantine boundary. */\n149: export type JudgePersistenceWriters<TCard extends Record<string, unknown>> = Partial<\n150:   Record<JudgePersistenceSurface, JudgePersistenceWriter<TCard>>\n151: >;\n152: \n153: /** Summary of judge-card persistence after quarantine checks. */\n154: export interface JudgePersistenceResult {\n155:   persisted: boolean;\n156:   writtenSurfaces: JudgePersistenceSurface[];\n157:   skippedSurfaces: JudgePersistenceSurface[];\n158:   reason?: 'quarantined' | 'no_writer';\n159: }\n160: \n161: export type VerificationStageScores = {\n162:   compiled: boolean;\n163:   executed: boolean;\n164:   testsPassed: boolean;\n165:   lintClean: boolean;\n166:   autoFixed: boolean;\n167: };\n168: \n169: export type VerificationPassResult =\n170:   | { ok: true; skipped: true; reason: 'verification_disabled' | 'no_code_output' }\n171:   | {\n172:       ok: true;\n173:       skipped: false;\n174:       confidence: number;\n175:       threshold: number;\n176:       language: VerificationLanguage;\n177:       stages: VerificationStageScores;\n178:     }\n179:   | {\n180:       ok: false;\n181:       reason: 'verification_degraded';\n182:       confidence: number;\n183:       threshold: number;\n184:       language: VerificationLanguage;\n185:       details: string;\n186:       stages: VerificationStageScores;\n187:     };\n188: \n189: export type PostDispatchAdvisory = { code: string; detail: string; fieldPath?: string };\n190: \n191: type PostDispatchFailureReason =\n192:   | 'iteration_file_missing'\n193:   | 'iteration_file_empty'\n194:   | 'jsonl_not_appended'\n195:   | 'jsonl_missing_fields'\n196:   | 'jsonl_parse_error'\n197:   | 'jsonl_wrong_type'\n198:   | 'delta_file_missing'\n199:   | 'delta_file_empty'\n200:   | 'delta_file_missing_iteration_record'\n201:   | 'executor_missing'\n202:   | 'dispatch_failure_logged'\n203:   | 'verification_degraded'\n204:   | 'route_proof_missing'\n205:   | 'route_proof_mismatch'\n206:   | 'dispatch_receipt_missing'\n207:   | 'dispatch_receipt_invalid_mac'\n208:   | 'dispatch_receipt_intent_mismatch'\n209:   | 'v2_missing_ledger'\n210:   | 'v2_uncited_ledger_row'\n211:   | 'v2_broken_linked_finding'\n212:   | 'v2_shallow_finding_details'\n213:   | 'delta_iteration_id_mismatch'\n214:   | 'state_delta_iteration_mismatch';\n215: \n216: export type PostDispatchValidateResult =\n217:   | { ok: true; warnings?: PostDispatchAdvisory[] }\n218:   | {\n219:       ok: false;\n220:       reason: PostDispatchFailureReason;\n221:       details: string;\n222:       warnings?: PostDispatchAdvisory[];\n223:     };\n224: \n225: // ───── 2. DOMAIN ERRORS ─────\n226: \n227: export class PostDispatchValidationError extends Error {\n228:   result: PostDispatchValidateResult;\n229: \n230:   constructor(result: PostDispatchValidateResult) {\n231:     super(result.ok ? 'Post-dispatch validation unexpectedly succeeded' : `${result.reason}: ${result.details}`);\n232:     this.name = 'PostDispatchValidationError';\n233:     this.result = result;\n234:   }\n235: }\n236: \n237: class JudgeTimeoutError extends Error {\n238:   kind: 'slow_timeout';\n239: \n240:   constructor(message: string) {\n241:     super(message);\n242:     this.name = 'JudgeTimeoutError';\n243:     this.kind = 'slow_timeout';\n244:   }\n245: }\n246: \n247: // ───── 3. CONSTANTS ─────\n248: \n249: const CANONICAL_ITERATION_TYPE = 'iteration' as const;\n250: const DEFAULT_VERIFICATION_THRESHOLD = 0.5;\n251: const DEFAULT_JUDGE_MAX_ATTEMPTS = 1;\n252: const DEFAULT_JUDGE_BACKOFF_MS = 0;\n253: const DEFAULT_JUDGE_FAST_TIMEOUT_MS = 10_000;\n254: const DEFAULT_JUDGE_SLOW_TIMEOUT_MS = 60_000;\n255: const JUDGE_PERSISTENCE_SURFACES = ['persistence', 'convergence', 'coverage'] as const;\n256: const SUPPORTED_VERIFICATION_LANGUAGES = new Set<VerificationLanguage>([\n257:   'python',\n258:   'typescript',\n259:   'javascript',\n260:   'rust',\n261:   'go',\n262: ]);\n263: const REVIEW_ITERATION_FIELDS = [\n264:   'type',\n265:   'iteration',\n266:   'mode',\n267:   'run',\n268:   'status',\n269:   'focus',\n270:   'dimensions',\n271:   'filesReviewed',\n272:   'findingsCount',\n273:   'findingsSummary',\n274:   'findingsNew',\n275:   'newFindingsRatio',\n276:   'sessionId',\n277:   'generation',\n278:   'lineageMode',\n279:   'timestamp',\n280:   'durationMs',\n281: ] as const;\n282: const V2_SCOPE_CLASSES = new Set(['trivial', 'standard', 'complex']);\n283: const V2_ENFORCEMENT_MODES = new Set(['strict', 'warn', 'skip']);\n284: const V2_GRAPH_COVERAGE_MODES = new Set(['graph', 'graphless_fallback', 'unavailable_blocked']);\n285: \n286: type V2EnforcementMode = 'warn' | 'strict' | 'off';\n287: type V2ValidationFailure = {\n288:   reason: PostDispatchFailureReason;\n289:   details: string;\n290:   fieldPath?: string;\n291: };\n292: type IterationRecordWithLogRegion = Record<string, unknown> & {\n293:   logOffset?: number;\n294:   logSize?: number;\n295:   logPath?: string;\n296: };\n297: type JsonlLineRegion = {\n298:   rawLine: string;\n299:   startOffset: number;\n300:   nextOffset: number;\n301:   parsed: unknown;\n302: };\n303: \n304: // ───── 4. HELPERS ─────\n305: \n306: type JudgeParseResult =\n307:   | { ok: true; record: Record<string, unknown>; formatStripRetried: boolean }\n308:   | { ok: false; error: string; formatStripRetried: boolean };\n309: \n310: function normalizePositiveInteger(value: number | undefined, fallback: number): number {\n311:   if (value === undefined || !Number.isFinite(value)) {\n312:     return fallback;\n313:   }\n314:   return Math.max(1, Math.floor(value));\n315: }\n316: \n317: function normalizeNonNegativeInteger(value: number | undefined, fallback: number): number {\n318:   if (value === undefined || !Number.isFinite(value)) {\n319:     return fallback;\n320:   }\n321:   return Math.max(0, Math.floor(value));\n322: }\n323: \n324: function errorMessage(error: unknown): string {\n325:   return error instanceof Error ? error.message : String(error);\n326: }\n327: \n328: function defaultSleep(ms: number): Promise<void> {\n329:   return new Promise((resolveSleep) => {\n330:     setTimeout(resolveSleep, ms);\n331:   });\n332: }\n333: \n334: function resolveJudgeBackoffMs(backoff: JudgeHardeningConfig['backoffMs'], attempt: number): number {\n335:   if (typeof backoff === 'function') {\n336:     return normalizeNonNegativeInteger(backoff(attempt), DEFAULT_JUDGE_BACKOFF_MS);\n337:   }\n338:   return normalizeNonNegativeInteger(backoff, DEFAULT_JUDGE_BACKOFF_MS);\n339: }\n340: \n341: function parseJsonObject(text: string): { ok: true; record: Record<string, unknown> } | { ok: false; error: string } {\n342:   try {\n343:     const parsed: unknown = JSON.parse(text);\n344:     if (!isObjectRecord(parsed)) {\n345:       return { ok: false, error: 'judge response JSON is not an object' };\n346:     }\n347:     return { ok: true, record: parsed };\n348:   } catch (error: unknown) {\n349:     return { ok: false, error: errorMessage(error) };\n350:   }\n351: }\n352: \n353: function stripMarkdownJsonFence(text: string): string {\n354:   const trimmed = text.trim();\n355:   const match = trimmed.match(/^```(?:json)?\\s*\\r?\\n?([\\s\\S]*?)\\r?\\n?```\\s*$/i);\n356:   return match?.[1]?.trim() ?? trimmed;\n357: }\n358: \n359: function parseJudgeJsonWithFormatStrip(text: string): JudgeParseResult {\n360:   const trimmed = text.trim();\n361:   if (trimmed === '') {\n362:     return { ok: false, error: 'judge response was empty', formatStripRetried: false };\n363:   }\n364: \n365:   const direct = parseJsonObject(trimmed);\n366:   if (direct.ok) {\n367:     return { ok: true, record: direct.record, formatStripRetried: false };\n368:   }\n369: \n370:   const stripped = stripMarkdownJsonFence(trimmed);\n371:   if (stripped !== trimmed) {\n372:     const strippedParse = parseJsonObject(stripped);\n373:     if (strippedParse.ok) {\n374:       return { ok: true, record: strippedParse.record, formatStripRetried: true };\n375:     }\n376:     return { ok: false, error: strippedParse.error, formatStripRetried: true };\n377:   }\n378: \n379:   return { ok: false, error: direct.error, formatStripRetried: false };\n380: }\n381: \n382: async function callJudgeWithDualTimeouts(\n383:   invoke: () => Promise<string>,\n384:   fastTimeoutMs: number,\n385:   slowTimeoutMs: number,\n386: ): Promise<{ text: string; fastTimedOut: boolean }> {\n387:   const normalizedSlowTimeoutMs = Math.max(fastTimeoutMs, slowTimeoutMs);\n388:   const operation = invoke();\n389:   let fastTimer: ReturnType<typeof setTimeout> | undefined;\n390: \n391:   const fastResult = await (async (): Promise<\n392:     | { kind: 'response'; text: string }\n393:     | { kind: 'fast_timeout' }\n394:   > => {\n395:     try {\n396:       return await Promise.race<\n397:         | { kind: 'response'; text: string }\n398:         | { kind: 'fast_timeout' }\n399:       >([\n400:         operation.then((text) => ({ kind: 'response', text })),\n401:         new Promise<{ kind: 'fast_timeout' }>((resolveTimeout) => {\n402:           fastTimer = setTimeout(() => resolveTimeout({ kind: 'fast_timeout' }), fastTimeoutMs);\n403:         }),\n404:       ]);\n405:     } finally {\n406:       if (fastTimer !== undefined) {\n407:         clearTimeout(fastTimer);\n408:       }\n409:     }\n410:   })();\n411: \n412:   if (fastResult.kind === 'response') {\n413:     return { text: fastResult.text, fastTimedOut: false };\n414:   }\n415: \n416:   let slowTimer: ReturnType<typeof setTimeout> | undefined;\n417:   const remainingTimeoutMs = Math.max(0, normalizedSlowTimeoutMs - fastTimeoutMs);\n418:   try {\n419:     const text = await Promise.race([\n420:       operation,\n421:       new Promise<never>((_, reject) => {\n422:         slowTimer = setTimeout(() => {\n423:           reject(new JudgeTimeoutError(`judge slow timeout after ${normalizedSlowTimeoutMs}ms`));\n424:         }, remainingTimeoutMs);\n425:       }),\n426:     ]);\n427:     return { text, fastTimedOut: true };\n428:   } catch (error: unknown) {\n429:     operation.catch(() => undefined);\n430:     throw error;\n431:   } finally {\n432:     if (slowTimer !== undefined) {\n433:       clearTimeout(slowTimer);\n434:     }\n435:   }\n436: }\n437: \n438: function clampByteOffset(value: number, contentLength: number): number {\n439:   if (!Number.isFinite(value)) {\n440:     return 0;\n441:   }\n442:   return Math.max(0, Math.min(Math.floor(value), contentLength));\n443: }\n444: \n445: function isObjectRecord(value: unknown): value is Record<string, unknown> {\n446:   return value !== null && !Array.isArray(value) && typeof value === 'object';\n447: }\n448: \n449: function isStringArray(value: unknown): value is string[] {\n450:   return Array.isArray(value) && value.every((entry) => typeof entry === 'string');\n451: }\n452: \n453: function isNonEmptyStringArray(value: unknown): value is string[] {\n454:   return isStringArray(value) && value.length > 0;\n455: }\n456: \n457: function isVerificationLanguage(value: string): value is VerificationLanguage {\n458:   return SUPPORTED_VERIFICATION_LANGUAGES.has(value as VerificationLanguage);\n459: }\n460: \n461: function normalizeFenceLanguage(language: string): VerificationLanguage | null {\n462:   const normalized = language.trim().toLowerCase();\n463:   if (normalized === 'py' || normalized === 'python') return 'python';\n464:   if (normalized === 'ts' || normalized === 'tsx' || normalized === 'typescript') return 'typescript';\n465:   if (normalized === 'js' || normalized === 'mjs' || normalized === 'javascript') return 'javascript';\n466:   if (normalized === 'rs' || normalized === 'rust') return 'rust';\n467:   if (normalized === 'go' || normalized === 'golang') return 'go';\n468:   return null;\n469: }\n470: \n471: function extractCodeBlocks(\n472:   content: string,\n473:   allowedLanguages: VerificationLanguage[],\n474: ): Array<{ language: VerificationLanguage; code: string }> {\n475:   const blocks: Array<{ language: VerificationLanguage; code: string }> = [];\n476:   const fencePattern = /```([a-zA-Z0-9_-]+)\\n([\\s\\S]*?)```/g;\n477:   let match: RegExpExecArray | null;\n478: \n479:   while ((match = fencePattern.exec(content)) !== null) {\n480:     const language = normalizeFenceLanguage(match[1] ?? '');\n481:     if (language && (allowedLanguages.length === 0 || allowedLanguages.includes(language))) {\n482:       blocks.push({ language, code: match[2] ?? '' });\n483:     }\n484:   }\n485: \n486:   return blocks;\n487: }\n488: \n489: function bracesBalanced(code: string): boolean {\n490:   let balance = 0;\n491:   for (const char of code) {\n492:     if (char === '{') balance += 1;\n493:     if (char === '}') balance -= 1;\n494:     if (balance < 0) return false;\n495:   }\n496:   return balance === 0;\n497: }\n498: \n499: function hasPlaceholderOrTruncation(code: string): boolean {\n500:   return /TODO|NotImplementedError|pass\\s+#\\s*placeholder|\\[\\.\\.\\. truncated|\\.\\.\\. rest of|\\.\\.\\. more/i.test(code);\n\n(Showing lines 1-500 of 1840. Use offset=501 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Post-Dispatch Validator\n// ───────────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, renameSync, rmSync, statSync, truncateSync, writeFileSync } from 'node:fs';\nimport { join, resolve } from 'node:path';\n\nimport { validateEvidenceContract } from './evidence-contract.js';\nimport { appendJsonlRecord } from './jsonl-repair.js';\nimport { deriveReceiptKeyForDispatch } from './executor-audit.js';\nimport { canonicalReceiptJson, verifyReceipt } from './receipt-crypto.js';\nimport type { ExecutorKind } from './executor-config.js';\n\n// ───── 1. TYPE DEFINITIONS ─────\n\nexport type VerificationLanguage = 'python' | 'typescript' | 'javascript' | 'rust' | 'go';\n\nexport type PostDispatchRecipeConfig = {\n  verification_enabled?: boolean;\n  verification_languages?: VerificationLanguage[];","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Post-Dispatch Validator\n// ───────────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, renameSync, rmSync, statSync, truncateSync, writeFileSync } from 'node:fs';\nimport { join, resolve } from 'node:path';\n\nimport { validateEvidenceContract } from './evidence-contract.js';\nimport { appendJsonlRecord } from './jsonl-repair.js';\nimport { deriveReceiptKeyForDispatch } from './executor-audit.js';\nimport { canonicalReceiptJson, verifyReceipt } from './receipt-crypto.js';\nimport type { ExecutorKind } from './executor-config.js';\n\n// ───── 1. TYPE DEFINITIONS ─────\n\nexport type VerificationLanguage = 'python' | 'typescript' | 'javascript' | 'rust' | 'go';\n\nexport type PostDispatchRecipeConfig = {\n  verification_enabled?: boolean;\n  verification_languages?: VerificationLanguage[];\n  verification_threshold?: number;\n  judge_quarantine_enabled?: boolean;\n};\n\nexport type RouteProofExpectation = {\n  mode: string;\n  targetAgent: string;\n  resolvedRoute: string;\n  requireAgentDefinitionLoaded?: boolean;\n};\n\nexport type DispatchReceiptExpectation = {\n  receiptDir: string;\n  dispatchId: string;\n};\n\nexport type PostDispatchValidateInput = {\n  iterationFile: string;\n  stateLogPath: string;\n  previousStateLogSize: number;\n  requiredJsonlFields: string[];\n  executorKind?: ExecutorKind;\n  deltaFilePath?: string;\n  routeProof?: RouteProofExpectation;\n  recipeConfig?: PostDispatchRecipeConfig;\n  // When set, the validator requires a structurally intact, intent-bound\n  // dispatch receipt pair (intent + completion) before accepting the\n  // state-log append; a mac that fails to cryptographically correlate is\n  // reported as a warning, not a blocking failure (see\n  // validateDispatchReceipt). Dispatches that did not opt into receipts omit\n  // it and keep legacy behavior.\n  dispatchReceipt?: DispatchReceiptExpectation;\n};\n\n/** Failure class recorded for a hardened judge attempt. */\nexport type JudgeFailureKind = 'model_error' | 'parse_error' | 'slow_timeout' | 'unknown';\n\n/** Persistence destinations protected by judge-card quarantine. */\nexport type JudgePersistenceSurface = 'persistence' | 'convergence' | 'coverage';\n\n/** A failed judge attempt with retry and timeout diagnostics. */\nexport interface JudgeAttemptFailure {\n  attempt: number;\n  kind: JudgeFailureKind;\n  message: string;\n  fastTimedOut: boolean;\n  formatStripRetried: boolean;\n}\n\n/** Retry, timeout, and parser configuration for a hardened judge call. */\nexport interface JudgeHardeningConfig {\n  maxAttempts?: number;\n  backoffMs?: number | ((attempt: number) => number);\n  fastTimeoutMs?: number;\n  slowTimeoutMs?: number;\n  now?: () => string;\n  sleep?: (ms: number) => Promise<void>;\n}\n\n/** Input for running one model-backed judge call through hardening layers. */\nexport interface JudgeHardeningInput<TCard extends Record<string, unknown>> extends JudgeHardeningConfig {\n  invoke: () => Promise<string>;\n  parse?: (record: Record<string, unknown>) => TCard;\n  fallbackReason?: string;\n}\n\n/** Metadata attached to neutral judge fallback cards. */\nexport interface JudgeFallbackMetadata {\n  attempts: number;\n  maxAttempts: number;\n  failureKind: JudgeFailureKind;\n  failures: JudgeAttemptFailure[];\n  formatStripRetries: number;\n  fastTimeouts: number;\n  slowTimeouts: number;\n  generatedAt: string;\n}\n\n/** Input for constructing a neutral quarantined judge fallback card. */\nexport interface JudgeFallbackInput {\n  reason: string;\n  failures: JudgeAttemptFailure[];\n  maxAttempts: number;\n  formatStripRetries: number;\n  fastTimeouts: number;\n  slowTimeouts: number;\n  now?: () => string;\n}\n\n/** Neutral card emitted when judge retries cannot produce a parseable score. */\nexport interface NeutralJudgeFallbackCard extends Record<string, unknown> {\n  type: 'judge_fallback_card';\n  fallback: true;\n  quarantined: true;\n  score: 0.5;\n  confidence: 0;\n  reason: string;\n  metadata: JudgeFallbackMetadata;\n}\n\n/** Result from a hardened judge call. */\nexport type JudgeHardeningResult<TCard extends Record<string, unknown>> =\n  | {\n      ok: true;\n      card: TCard;\n      attempts: number;\n      failures: JudgeAttemptFailure[];\n      formatStripRetries: number;\n      fastTimeouts: number;\n      slowTimeouts: number;\n    }\n  | {\n      ok: false;\n      card: NeutralJudgeFallbackCard;\n      attempts: number;\n      failures: JudgeAttemptFailure[];\n      formatStripRetries: number;\n      fastTimeouts: number;\n      slowTimeouts: number;\n    };\n\n/** Writer callback for a judge card persistence surface. */\nexport type JudgePersistenceWriter<TCard extends Record<string, unknown>> = (\n  card: TCard,\n  surface: JudgePersistenceSurface,\n) => void | Promise<void>;\n\n/** Persistence writers guarded by the quarantine boundary. */\nexport type JudgePersistenceWriters<TCard extends Record<string, unknown>> = Partial<\n  Record<JudgePersistenceSurface, JudgePersistenceWriter<TCard>>\n>;\n\n/** Summary of judge-card persistence after quarantine checks. */\nexport interface JudgePersistenceResult {\n  persisted: boolean;\n  writtenSurfaces: JudgePersistenceSurface[];\n  skippedSurfaces: JudgePersistenceSurface[];\n  reason?: 'quarantined' | 'no_writer';\n}\n\nexport type VerificationStageScores = {\n  compiled: boolean;\n  executed: boolean;\n  testsPassed: boolean;\n  lintClean: boolean;\n  autoFixed: boolean;\n};\n\nexport type VerificationPassResult =\n  | { ok: true; skipped: true; reason: 'verification_disabled' | 'no_code_output' }\n  | {\n      ok: true;\n      skipped: false;\n      confidence: number;\n      threshold: number;\n      language: VerificationLanguage;\n      stages: VerificationStageScores;\n    }\n  | {\n      ok: false;\n      reason: 'verification_degraded';\n      confidence: number;\n      threshold: number;\n      language: VerificationLanguage;\n      details: string;\n      stages: VerificationStageScores;\n    };\n\nexport type PostDispatchAdvisory = { code: string; detail: string; fieldPath?: string };\n\ntype PostDispatchFailureReason =\n  | 'iteration_file_missing'\n  | 'iteration_file_empty'\n  | 'jsonl_not_appended'\n  | 'jsonl_missing_fields'\n  | 'jsonl_parse_error'\n  | 'jsonl_wrong_type'\n  | 'delta_file_missing'\n  | 'delta_file_empty'\n  | 'delta_file_missing_iteration_record'\n  | 'executor_missing'\n  | 'dispatch_failure_logged'\n  | 'verification_degraded'\n  | 'route_proof_missing'\n  | 'route_proof_mismatch'\n  | 'dispatch_receipt_missing'\n  | 'dispatch_receipt_invalid_mac'\n  | 'dispatch_receipt_intent_mismatch'\n  | 'v2_missing_ledger'\n  | 'v2_uncited_ledger_row'\n  | 'v2_broken_linked_finding'\n  | 'v2_shallow_finding_details'\n  | 'delta_iteration_id_mismatch'\n  | 'state_delta_iteration_mismatch';\n\nexport type PostDispatchValidateResult =\n  | { ok: true; warnings?: PostDispatchAdvisory[] }\n  | {\n      ok: false;\n      reason: PostDispatchFailureReason;\n      details: string;\n      warnings?: PostDispatchAdvisory[];\n    };\n\n// ───── 2. DOMAIN ERRORS ─────\n\nexport class PostDispatchValidationError extends Error {\n  result: PostDispatchValidateResult;\n\n  constructor(result: PostDispatchValidateResult) {\n    super(result.ok ? 'Post-dispatch validation unexpectedly succeeded' : `${result.reason}: ${result.details}`);\n    this.name = 'PostDispatchValidationError';\n    this.result = result;\n  }\n}\n\nclass JudgeTimeoutError extends Error {\n  kind: 'slow_timeout';\n\n  constructor(message: string) {\n    super(message);\n    this.name = 'JudgeTimeoutError';\n    this.kind = 'slow_timeout';\n  }\n}\n\n// ───── 3. CONSTANTS ─────\n\nconst CANONICAL_ITERATION_TYPE = 'iteration' as const;\nconst DEFAULT_VERIFICATION_THRESHOLD = 0.5;\nconst DEFAULT_JUDGE_MAX_ATTEMPTS = 1;\nconst DEFAULT_JUDGE_BACKOFF_MS = 0;\nconst DEFAULT_JUDGE_FAST_TIMEOUT_MS = 10_000;\nconst DEFAULT_JUDGE_SLOW_TIMEOUT_MS = 60_000;\nconst JUDGE_PERSISTENCE_SURFACES = ['persistence', 'convergence', 'coverage'] as const;\nconst SUPPORTED_VERIFICATION_LANGUAGES = new Set<VerificationLanguage>([\n  'python',\n  'typescript',\n  'javascript',\n  'rust',\n  'go',\n]);\nconst REVIEW_ITERATION_FIELDS = [\n  'type',\n  'iteration',\n  'mode',\n  'run',\n  'status',\n  'focus',\n  'dimensions',\n  'filesReviewed',\n  'findingsCount',\n  'findingsSummary',\n  'findingsNew',\n  'newFindingsRatio',\n  'sessionId',\n  'generation',\n  'lineageMode',\n  'timestamp',\n  'durationMs',\n] as const;\nconst V2_SCOPE_CLASSES = new Set(['trivial', 'standard', 'complex']);\nconst V2_ENFORCEMENT_MODES = new Set(['strict', 'warn', 'skip']);\nconst V2_GRAPH_COVERAGE_MODES = new Set(['graph', 'graphless_fallback', 'unavailable_blocked']);\n\ntype V2EnforcementMode = 'warn' | 'strict' | 'off';\ntype V2ValidationFailure = {\n  reason: PostDispatchFailureReason;\n  details: string;\n  fieldPath?: string;\n};\ntype IterationRecordWithLogRegion = Record<string, unknown> & {\n  logOffset?: number;\n  logSize?: number;\n  logPath?: string;\n};\ntype JsonlLineRegion = {\n  rawLine: string;\n  startOffset: number;\n  nextOffset: number;\n  parsed: unknown;\n};\n\n// ───── 4. HELPERS ─────\n\ntype JudgeParseResult =\n  | { ok: true; record: Record<string, unknown>; formatStripRetried: boolean }\n  | { ok: false; error: string; formatStripRetried: boolean };\n\nfunction normalizePositiveInteger(value: number | undefined, fallback: number): number {\n  if (value === undefined || !Number.isFinite(value)) {\n    return fallback;\n  }\n  return Math.max(1, Math.floor(value));\n}\n\nfunction normalizeNonNegativeInteger(value: number | undefined, fallback: number): number {\n  if (value === undefined || !Number.isFinite(value)) {\n    return fallback;\n  }\n  return Math.max(0, Math.floor(value));\n}\n\nfunction errorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction defaultSleep(ms: number): Promise<void> {\n  return new Promise((resolveSleep) => {\n    setTimeout(resolveSleep, ms);\n  });\n}\n\nfunction resolveJudgeBackoffMs(backoff: JudgeHardeningConfig['backoffMs'], attempt: number): number {\n  if (typeof backoff === 'function') {\n    return normalizeNonNegativeInteger(backoff(attempt), DEFAULT_JUDGE_BACKOFF_MS);\n  }\n  return normalizeNonNegativeInteger(backoff, DEFAULT_JUDGE_BACKOFF_MS);\n}\n\nfunction parseJsonObject(text: string): { ok: true; record: Record<string, unknown> } | { ok: false; error: string } {\n  try {\n    const parsed: unknown = JSON.parse(text);\n    if (!isObjectRecord(parsed)) {\n      return { ok: false, error: 'judge response JSON is not an object' };\n    }\n    return { ok: true, record: parsed };\n  } catch (error: unknown) {\n    return { ok: false, error: errorMessage(error) };\n  }\n}\n\nfunction stripMarkdownJsonFence(text: string): string {\n  const trimmed = text.trim();\n  const match = trimmed.match(/^```(?:json)?\\s*\\r?\\n?([\\s\\S]*?)\\r?\\n?```\\s*$/i);\n  return match?.[1]?.trim() ?? trimmed;\n}\n\nfunction parseJudgeJsonWithFormatStrip(text: string): JudgeParseResult {\n  const trimmed = text.trim();\n  if (trimmed === '') {\n    return { ok: false, error: 'judge response was empty', formatStripRetried: false };\n  }\n\n  const direct = parseJsonObject(trimmed);\n  if (direct.ok) {\n    return { ok: true, record: direct.record, formatStripRetried: false };\n  }\n\n  const stripped = stripMarkdownJsonFence(trimmed);\n  if (stripped !== trimmed) {\n    const strippedParse = parseJsonObject(stripped);\n    if (strippedParse.ok) {\n      return { ok: true, record: strippedParse.record, formatStripRetried: true };\n    }\n    return { ok: false, error: strippedParse.error, formatStripRetried: true };\n  }\n\n  return { ok: false, error: direct.error, formatStripRetried: false };\n}\n\nasync function callJudgeWithDualTimeouts(\n  invoke: () => Promise<string>,\n  fastTimeoutMs: number,\n  slowTimeoutMs: number,\n): Promise<{ text: string; fastTimedOut: boolean }> {\n  const normalizedSlowTimeoutMs = Math.max(fastTimeoutMs, slowTimeoutMs);\n  const operation = invoke();\n  let fastTimer: ReturnType<typeof setTimeout> | undefined;\n\n  const fastResult = await (async (): Promise<\n    | { kind: 'response'; text: string }\n    | { kind: 'fast_timeout' }\n  > => {\n    try {\n      return await Promise.race<\n        | { kind: 'response'; text: string }\n        | { kind: 'fast_timeout' }\n      >([\n        operation.then((text) => ({ kind: 'response', text })),\n        new Promise<{ kind: 'fast_timeout' }>((resolveTimeout) => {\n          fastTimer = setTimeout(() => resolveTimeout({ kind: 'fast_timeout' }), fastTimeoutMs);\n        }),\n      ]);\n    } finally {\n      if (fastTimer !== undefined) {\n        clearTimeout(fastTimer);\n      }\n    }\n  })();\n\n  if (fastResult.kind === 'response') {\n    return { text: fastResult.text, fastTimedOut: false };\n  }\n\n  let slowTimer: ReturnType<typeof setTimeout> | undefined;\n  const remainingTimeoutMs = Math.max(0, normalizedSlowTimeoutMs - fastTimeoutMs);\n  try {\n    const text = await Promise.race([\n      operation,\n      new Promise<never>((_, reject) => {\n        slowTimer = setTimeout(() => {\n          reject(new JudgeTimeoutError(`judge slow timeout after ${normalizedSlowTimeoutMs}ms`));\n        }, remainingTimeoutMs);\n      }),\n    ]);\n    return { text, fastTimedOut: true };\n  } catch (error: unknown) {\n    operation.catch(() => undefined);\n    throw error;\n  } finally {\n    if (slowTimer !== undefined) {\n      clearTimeout(slowTimer);\n    }\n  }\n}\n\nfunction clampByteOffset(value: number, contentLength: number): number {\n  if (!Number.isFinite(value)) {\n    return 0;\n  }\n  return Math.max(0, Math.min(Math.floor(value), contentLength));\n}\n\nfunction isObjectRecord(value: unknown): value is Record<string, unknown> {\n  return value !== null && !Array.isArray(value) && typeof value === 'object';\n}\n\nfunction isStringArray(value: unknown): value is string[] {\n  return Array.isArray(value) && value.every((entry) => typeof entry === 'string');\n}\n\nfunction isNonEmptyStringArray(value: unknown): value is string[] {\n  return isStringArray(value) && value.length > 0;\n}\n\nfunction isVerificationLanguage(value: string): value is VerificationLanguage {\n  return SUPPORTED_VERIFICATION_LANGUAGES.has(value as VerificationLanguage);\n}\n\nfunction normalizeFenceLanguage(language: string): VerificationLanguage | null {\n  const normalized = language.trim().toLowerCase();\n  if (normalized === 'py' || normalized === 'python') return 'python';\n  if (normalized === 'ts' || normalized === 'tsx' || normalized === 'typescript') return 'typescript';\n  if (normalized === 'js' || normalized === 'mjs' || normalized === 'javascript') return 'javascript';\n  if (normalized === 'rs' || normalized === 'rust') return 'rust';\n  if (normalized === 'go' || normalized === 'golang') return 'go';\n  return null;\n}\n\nfunction extractCodeBlocks(\n  content: string,\n  allowedLanguages: VerificationLanguage[],\n): Array<{ language: VerificationLanguage; code: string }> {\n  const blocks: Array<{ language: VerificationLanguage; code: string }> = [];\n  const fencePattern = /```([a-zA-Z0-9_-]+)\\n([\\s\\S]*?)```/g;\n  let match: RegExpExecArray | null;\n\n  while ((match = fencePattern.exec(content)) !== null) {\n    const language = normalizeFenceLanguage(match[1] ?? '');\n    if (language && (allowedLanguages.length === 0 || allowedLanguages.includes(language))) {\n      blocks.push({ language, code: match[2] ?? '' });\n    }\n  }\n\n  return blocks;\n}\n\nfunction bracesBalanced(code: string): boolean {\n  let balance = 0;\n  for (const char of code) {\n    if (char === '{') balance += 1;\n    if (char === '}') balance -= 1;\n    if (balance < 0) return false;\n  }\n  return balance === 0;\n}\n\nfunction hasPlaceholderOrTruncation(code: string): boolean {\n  return /TODO|NotImplementedError|pass\\s+#\\s*placeholder|\\[\\.\\.\\. truncated|\\.\\.\\. rest of|\\.\\.\\. more/i.test(code);","lineStart":1,"lineEnd":500,"totalLines":1840,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts","time":{"start":1784385657982,"end":1784385658018}},"metadata":{"openai":{"itemId":"fc_0469c5d15e3d3615016a5b9079c8cc81919b00129d412cd30a"}},"id":"prt_f75ac5c7c001ozo7K6Vz4hpEtp","sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","messageID":"msg_f75ac246b001CTHIZaoIVyzeUk"}}
