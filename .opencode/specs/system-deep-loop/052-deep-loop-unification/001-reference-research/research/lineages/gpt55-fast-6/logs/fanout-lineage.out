(!Number.isFinite(n) || n <= 0) {\n164:     return fallback;\n165:   }\n166:   return Math.floor(n);\n167: }\n168: \n169: function normalizeAttemptLiveness(value) {\n170:   if (!isRecord(value)) {\n171:     return { alive: true };\n172:   }\n173: \n174:   if (value.alive === false || value.exited === true || value.status === 'exited') {\n175:     const exitedAtMs = Number(value.exitedAtMs ?? value.exited_at_ms ?? value.exitedAt);\n176:     const pid = Number(value.pid);\n177:     return {\n178:       alive: false,\n179:       ...(Number.isFinite(exitedAtMs) ? { exitedAtMs } : {}),\n180:       ...(Number.isInteger(pid) && pid > 0 ? { pid } : {}),\n181:     };\n182:   }\n183: \n184:   return { alive: true };\n185: }\n186: \n187: function buildPostExitOrphanError({ label, graceMs, liveness }) {\n188:   const error = new Error(\n189:     `lineage ${label} subprocess exited but worker did not settle within ${graceMs}ms`,\n190:   );\n191:   error.name = 'OrphanedAfterSubprocessExitError';\n192:   error.exitCode = null;\n193:   error.timedOut = false;\n194:   error.reason = POST_EXIT_ORPHAN_REASON;\n195:   if (Number.isInteger(liveness?.pid) && liveness.pid > 0) {\n196:     error.pid = liveness.pid;\n197:   }\n198:   return error;\n199: }\n200: \n201: function buildLagCeilingTimeoutError({ label, lagMs, lagCeilingMs }) {\n202:   const error = new Error(\n203:     `lineage ${label} exceeded lag ceiling ${lagCeilingMs}ms after ${Math.max(0, Math.floor(lagMs))}ms without pool progress`,\n204:   );\n205:   error.name = 'AbortError';\n206:   error.timedOut = true;\n207:   error.exitCode = null;\n208:   return error;\n209: }\n210: \n211: function throwDormantWavePlannerError() {\n212:   throw new Error(WAVE_PLANNER_DORMANT_MESSAGE);\n213: }\n214: \n215: /**\n216:  * Create the dormant wave-planner contract for future dependency-aware dispatch.\n217:  *\n218:  * The methods name the future planning phases without routing production traffic\n219:  * through them. Runtime dispatch stays on `runCappedPool` until conflict safety\n220:  * can make overlapping write domains unrepresentable.\n221:  *\n222:  * @returns {Object} Dormant planner interface.\n223:  */\n224: function createWavePlannerInterface() {\n225:   return Object.freeze({\n226:     assignmentModel: WAVE_ASSIGNMENT_MODEL,\n227:     status: WAVE_PLANNER_STATUS_DORMANT,\n228:     selectEligibleAssignments: throwDormantWavePlannerError,\n229:     packDisjointGroups: throwDormantWavePlannerError,\n230:     capConcurrentGroups: throwDormantWavePlannerError,\n231:     planWave: throwDormantWavePlannerError,\n232:   });\n233: }\n234: \n235: function readLedgerRecords(ledgerPath) {\n236:   if (!ledgerPath || !fs.existsSync(ledgerPath)) {\n237:     return [];\n238:   }\n239: \n240:   let content;\n241:   try {\n242:     content = fs.readFileSync(ledgerPath, 'utf8');\n243:   } catch {\n244:     return [];\n245:   }\n246: \n247:   const records = [];\n248:   for (const line of content.split('\\n')) {\n249:     const trimmed = line.trim();\n250:     if (!trimmed) {\n251:       continue;\n252:     }\n253:     try {\n254:       const parsed = JSON.parse(trimmed);\n255:       if (isRecord(parsed)) {\n256:         records.push(parsed);\n257:       }\n258:     } catch {\n259:       // A malformed status row cannot safely create retry credit.\n260:     }\n261:   }\n262:   return records;\n263: }\n264: \n265: function readRetryCountsFromLedger(ledgerPath) {\n266:   const counts = {};\n267:   for (const record of readLedgerRecords(ledgerPath)) {\n268:     if (record.event !== 'retry_scheduled' || typeof record.label !== 'string') {\n269:       continue;\n270:     }\n271:     counts[record.label] = (counts[record.label] || 0) + 1;\n272:   }\n273:   return counts;\n274: }\n275: \n276: function detectOrphanedLineages(records) {\n277:   const open = new Map();\n278:   for (const record of records) {\n279:     if (!isRecord(record) || typeof record.label !== 'string' || !record.label) {\n280:       continue;\n281:     }\n282:     if (record.event === 'started') {\n283:       open.set(record.label, record);\n284:     } else if (\n285:       record.event === 'completed'\n286:       || record.event === 'failed'\n287:       || record.event === 'orphan_requeued'\n288:     ) {\n289:       open.delete(record.label);\n290:     }\n291:   }\n292:   return Array.from(open.values()).map((record) => ({\n293:     label: record.label,\n294:     index: Number.isFinite(Number(record.index)) ? Number(record.index) : null,\n295:     started_at_iso: typeof record.at === 'string' ? record.at : null,\n296:   }));\n297: }\n298: \n299: function markOrphanedLineages(ledgerPath, options = {}) {\n300:   const orphans = detectOrphanedLineages(readLedgerRecords(ledgerPath));\n301:   if (!orphans.length) {\n302:     return [];\n303:   }\n304:   const now = typeof options.now === 'function' ? options.now : () => new Date();\n305:   for (const orphan of orphans) {\n306:     appendStatusLedger(ledgerPath, {\n307:       event: 'orphan_requeued',\n308:       label: orphan.label,\n309:       index: orphan.index,\n310:       started_at_iso: orphan.started_at_iso,\n311:       at: normalizeTimestamp(now()),\n312:       status: 'requeued',\n313:     });\n314:   }\n315:   return orphans;\n316: }\n317: \n318: // ─────────────────────────────────────────────────────────────────────────────\n319: // 4. CORE LOGIC\n\n(Showing lines 120-319 of 902. Use offset=320 to continue.)\n</content>","metadata":{"preview":"    const n = Number(count);\n    if (typeof label === 'string' && label && Number.isFinite(n) && n > 0) {\n      counts.set(label, Math.floor(n));\n    }\n  }\n  return counts;\n}\n\nfunction buildFailureClassRollup(results) {\n  const rollup = {\n    timeout: 0,\n    exit: 0,\n    salvage_miss: 0,\n  };\n  for (const result of results) {\n    if (!result || result.status !== 'rejected') {\n      continue;\n    }\n    const failureClass = result.error && typeof result.error.failure_class === 'string'\n      ? result.error.failure_class","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","text":"    const n = Number(count);\n    if (typeof label === 'string' && label && Number.isFinite(n) && n > 0) {\n      counts.set(label, Math.floor(n));\n    }\n  }\n  return counts;\n}\n\nfunction buildFailureClassRollup(results) {\n  const rollup = {\n    timeout: 0,\n    exit: 0,\n    salvage_miss: 0,\n  };\n  for (const result of results) {\n    if (!result || result.status !== 'rejected') {\n      continue;\n    }\n    const failureClass = result.error && typeof result.error.failure_class === 'string'\n      ? result.error.failure_class\n      : 'exit';\n    if (Object.prototype.hasOwnProperty.call(rollup, failureClass)) {\n      rollup[failureClass] += 1;\n    }\n  }\n  return rollup;\n}\n\nfunction normalizeError(error) {\n  const classification = classifyLineageFailure(error);\n  const reason = error && typeof error === 'object' && typeof error.reason === 'string'\n    ? error.reason\n    : undefined;\n  return {\n    name: error && error.name ? String(error.name) : 'Error',\n    message: error && error.message ? String(error.message) : String(error),\n    ...classification,\n    ...(reason ? { reason } : {}),\n  };\n}\n\nfunction normalizePositiveDuration(value, fallback) {\n  const n = Number(value);\n  if (!Number.isFinite(n) || n <= 0) {\n    return fallback;\n  }\n  return Math.floor(n);\n}\n\nfunction normalizeAttemptLiveness(value) {\n  if (!isRecord(value)) {\n    return { alive: true };\n  }\n\n  if (value.alive === false || value.exited === true || value.status === 'exited') {\n    const exitedAtMs = Number(value.exitedAtMs ?? value.exited_at_ms ?? value.exitedAt);\n    const pid = Number(value.pid);\n    return {\n      alive: false,\n      ...(Number.isFinite(exitedAtMs) ? { exitedAtMs } : {}),\n      ...(Number.isInteger(pid) && pid > 0 ? { pid } : {}),\n    };\n  }\n\n  return { alive: true };\n}\n\nfunction buildPostExitOrphanError({ label, graceMs, liveness }) {\n  const error = new Error(\n    `lineage ${label} subprocess exited but worker did not settle within ${graceMs}ms`,\n  );\n  error.name = 'OrphanedAfterSubprocessExitError';\n  error.exitCode = null;\n  error.timedOut = false;\n  error.reason = POST_EXIT_ORPHAN_REASON;\n  if (Number.isInteger(liveness?.pid) && liveness.pid > 0) {\n    error.pid = liveness.pid;\n  }\n  return error;\n}\n\nfunction buildLagCeilingTimeoutError({ label, lagMs, lagCeilingMs }) {\n  const error = new Error(\n    `lineage ${label} exceeded lag ceiling ${lagCeilingMs}ms after ${Math.max(0, Math.floor(lagMs))}ms without pool progress`,\n  );\n  error.name = 'AbortError';\n  error.timedOut = true;\n  error.exitCode = null;\n  return error;\n}\n\nfunction throwDormantWavePlannerError() {\n  throw new Error(WAVE_PLANNER_DORMANT_MESSAGE);\n}\n\n/**\n * Create the dormant wave-planner contract for future dependency-aware dispatch.\n *\n * The methods name the future planning phases without routing production traffic\n * through them. Runtime dispatch stays on `runCappedPool` until conflict safety\n * can make overlapping write domains unrepresentable.\n *\n * @returns {Object} Dormant planner interface.\n */\nfunction createWavePlannerInterface() {\n  return Object.freeze({\n    assignmentModel: WAVE_ASSIGNMENT_MODEL,\n    status: WAVE_PLANNER_STATUS_DORMANT,\n    selectEligibleAssignments: throwDormantWavePlannerError,\n    packDisjointGroups: throwDormantWavePlannerError,\n    capConcurrentGroups: throwDormantWavePlannerError,\n    planWave: throwDormantWavePlannerError,\n  });\n}\n\nfunction readLedgerRecords(ledgerPath) {\n  if (!ledgerPath || !fs.existsSync(ledgerPath)) {\n    return [];\n  }\n\n  let content;\n  try {\n    content = fs.readFileSync(ledgerPath, 'utf8');\n  } catch {\n    return [];\n  }\n\n  const records = [];\n  for (const line of content.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed) {\n      continue;\n    }\n    try {\n      const parsed = JSON.parse(trimmed);\n      if (isRecord(parsed)) {\n        records.push(parsed);\n      }\n    } catch {\n      // A malformed status row cannot safely create retry credit.\n    }\n  }\n  return records;\n}\n\nfunction readRetryCountsFromLedger(ledgerPath) {\n  const counts = {};\n  for (const record of readLedgerRecords(ledgerPath)) {\n    if (record.event !== 'retry_scheduled' || typeof record.label !== 'string') {\n      continue;\n    }\n    counts[record.label] = (counts[record.label] || 0) + 1;\n  }\n  return counts;\n}\n\nfunction detectOrphanedLineages(records) {\n  const open = new Map();\n  for (const record of records) {\n    if (!isRecord(record) || typeof record.label !== 'string' || !record.label) {\n      continue;\n    }\n    if (record.event === 'started') {\n      open.set(record.label, record);\n    } else if (\n      record.event === 'completed'\n      || record.event === 'failed'\n      || record.event === 'orphan_requeued'\n    ) {\n      open.delete(record.label);\n    }\n  }\n  return Array.from(open.values()).map((record) => ({\n    label: record.label,\n    index: Number.isFinite(Number(record.index)) ? Number(record.index) : null,\n    started_at_iso: typeof record.at === 'string' ? record.at : null,\n  }));\n}\n\nfunction markOrphanedLineages(ledgerPath, options = {}) {\n  const orphans = detectOrphanedLineages(readLedgerRecords(ledgerPath));\n  if (!orphans.length) {\n    return [];\n  }\n  const now = typeof options.now === 'function' ? options.now : () => new Date();\n  for (const orphan of orphans) {\n    appendStatusLedger(ledgerPath, {\n      event: 'orphan_requeued',\n      label: orphan.label,\n      index: orphan.index,\n      started_at_iso: orphan.started_at_iso,\n      at: normalizeTimestamp(now()),\n      status: 'requeued',\n    });\n  }\n  return orphans;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC","lineStart":120,"lineEnd":319,"totalLines":902,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","time":{"start":1783487635647,"end":1783487635654}},"metadata":{"openai":{"itemId":"fc_0a9859a12945f501016a4ddc92fc4c819196eeb78c246bb152"}},"id":"prt_f40259e3f001W9nUd46ynJRQmn","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f40257f5e00194ZZZMyPFLF46Y"}}
