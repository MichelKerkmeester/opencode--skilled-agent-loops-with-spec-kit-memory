{"type":"tool_use","timestamp":1780373204661,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"read","callID":"call_2V54rxQr3jMCcjNODDi1J4eZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/run-skill-benchmark.cjs","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/run-skill-benchmark.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * run-skill-benchmark.cjs — Lane C orchestrator (loop-host --mode=skill-benchmark).\n6:  *\n7:  * Post-run join: private gold never crosses the dispatch boundary. Sequence:\n8:  *   1. resolve the target skill root (path or bare id under .opencode/skills/)\n9:  *   2. D5 static connectivity scan (the hard gate) — runs first, before any dispatch\n10:  *   3. load public/private fixture pairs\n11:  *   4. per scenario: contamination-lint the PUBLIC prompt (a leak is a fixture\n12:  *      failure), then router-replay (Mode A), then join with private gold to score\n13:  *   5. aggregate -> write report.json, then render report.md FROM it\n14:  *\n15:  * Mode A (router-replay) is the deterministic default and the CI gate. Live\n16:  * dispatch (Mode B) + D1-inter advisor scoring + D4 ablation are follow-on; this\n17:  * orchestrator emits a complete, honest Mode A report today.\n18:  */\n19: \n20: const fs = require('fs');\n21: const path = require('path');\n22: const { routeSkillResources } = require('./router-replay.cjs');\n23: const { buildBannedVocab, lintFixture } = require('./contamination-lint.cjs');\n24: const { scanConnectivity } = require('./d5-connectivity.cjs');\n25: const { scoreScenario, aggregate } = require('./score-skill-benchmark.cjs');\n26: const { probeAdvisor } = require('./advisor-probe.cjs');\n27: const { renderReport } = require('./build-report.cjs');\n28: const { loadPlaybookScenarios } = require('./load-playbook-scenarios.cjs');\n29: const { dispatchScenario } = require('./executor-dispatch.cjs');\n30: \n31: const SKILLS_DIR = path.resolve(__dirname, '..', '..', '..'); // .opencode/skills\n32: \n33: function resolveSkillRoot(skillArg) {\n34:   if (skillArg.includes('/') || skillArg.startsWith('.')) return path.resolve(skillArg);\n35:   return path.join(SKILLS_DIR, skillArg);\n36: }\n37: \n38: function resolveSkillId(skillRoot) {\n39:   return path.basename(skillRoot);\n40: }\n41: \n42: // Fixtures: assets/skill-benchmark/fixtures/<skill-id>/ with <id>.public.json +\n43: // <id>.private.json pairs. Falls back to the --fixtures-dir override.\n44: function loadFixtures(fixturesDir) {\n45:   const out = [];\n46:   if (!fs.existsSync(fixturesDir)) return out;\n47:   const publics = fs.readdirSync(fixturesDir).filter((f) => f.endsWith('.public.json'));\n48:   for (const pf of publics) {\n49:     const id = pf.replace(/\\.public\\.json$/, '');\n50:     // A malformed fixture is operator error this tool exists to surface, not a\n51:     // reason to crash the whole run. Degrade: record a load error and skip.\n52:     let pub; let priv;\n53:     try {\n54:       pub = JSON.parse(fs.readFileSync(path.join(fixturesDir, pf), 'utf8'));\n55:       const privPath = path.join(fixturesDir, `${id}.private.json`);\n56:       priv = fs.existsSync(privPath) ? JSON.parse(fs.readFileSync(privPath, 'utf8')) : { expected: {} };\n57:     } catch (err) {\n58:       out.push({ scenarioId: id, loadError: err.message });\n59:       continue;\n60:     }\n61:     out.push({ scenarioId: pub.scenarioId || id, tier: pub.tier || 'T1', public: pub.public || {}, expected: priv.expected || {}, rubric: priv.rubric });\n62:   }\n63:   return out;\n64: }\n65: \n66: // Legacy synthetic-fixture loop (kept for back-compat + malformed-fixture\n67: // surfacing). Used only when --fixtures-dir is given explicitly.\n68: function runLegacyFixtures({ fixturesDir, skillRoot, skillId, advisorMode, scenarioRows }) {\n69:   for (const fx of loadFixtures(fixturesDir)) {\n70:     if (fx.loadError) {\n71:       scenarioRows.push({\n72:         scenarioId: fx.scenarioId, tier: 'unknown', modeAScore: 0,\n73:         firstFailingStage: 'unparseable-fixture',\n74:         dims: { d1intra: { score: 0 }, d2: { score: 0 }, d3: { score: 0 }, d1inter: { score: null }, d4: { score: null } },\n75:         loadError: fx.loadError,\n76:       });\n77:       continue;\n78:     }\n79:     const bannedVocab = buildBannedVocab({ skillRoot, skillId, privateExpected: fx.expected });\n80:     const lint = lintFixture({ publicText: fx.public.prompt || '', bannedVocab });\n81:     if (!lint.passed) {\n82:       scenarioRows.push({\n83:         scenarioId: fx.scenarioId, tier: fx.tier, modeAScore: 0,\n84:         firstFailingStage: 'contaminated-fixture',\n85:         dims: { d1intra: { score: 0 }, d2: { score: 0 }, d3: { score: 0 }, d1inter: { score: null }, d4: { score: null } },\n86:         contamination: lint.hardLeaks,\n87:       });\n88:       continue;\n89:     }\n90:     const routerResult = routeSkillResources({ skillRoot, taskText: fx.public.prompt || '' });\n91:     const advisorResult = advisorMode === 'python'\n92:       ? probeAdvisor({ prompt: fx.public.prompt || '' }) : undefined;\n93:     scenarioRows.push(scoreScenario({ scenarioId: fx.scenarioId, tier: fx.tier, routerResult, expected: fx.expected, advisorResult }));\n94:   }\n95: }\n96: \n97: function filterScenarios(scenarios, filter) {\n98:   if (!filter) return scenarios;\n99:   const f = String(filter).toLowerCase();\n100:   if (f === 'critical') return scenarios.filter((s) => s.critical);\n101:   const ids = new Set(f.split(',').map((x) => x.trim().toUpperCase()));\n102:   return scenarios.filter((s) => ids.has(s.scenarioId.toUpperCase()));\n103: }\n104: \n105: // Default corpus: the skill's manual_testing_playbook. Each scenario routes to\n106: // the executor for its classKind; browser scenarios are routed out of the text\n107: // executors. Contamination-lint is a drift FINDING in router mode (the playbook\n108: // intentionally carries trigger words) and is skipped entirely in live mode.\n109: function runPlaybook({ skillRoot, skillId, traceMode, advisorMode, executor, playbookDir, scenariosFilter, scenarioRows, lintFindings, warningsOut }) {\n110:   const { scenarios, warnings } = loadPlaybookScenarios({ skillRoot, playbookDir });\n111:   if (warningsOut) warningsOut.push(...warnings);\n112:   for (const sc of filterScenarios(scenarios, scenariosFilter)) {\n113:     const observed = dispatchScenario({ scenario: sc, skillRoot, traceMode, executor });\n114:     if (sc.classKind === 'browser') {\n115:       if (observed.routedOut || observed.error) {\n116:         // Router/CI mode, or the browser harness was unavailable.\n117:         scenarioRows.push({\n118:           scenarioId: sc.scenarioId, classKind: 'browser', routedOut: true,\n119:           reason: observed.reason || observed.error || 'browser scenario — routed to browser harness',\n120:         });\n121:       } else {\n122:         // Live mode: browser-executor returned a full scenario row (with a verdict).\n123:         scenarioRows.push(observed);\n124:       }\n125:       continue;\n126:     }\n127:     if (traceMode === 'router' && sc.prompt) {\n128:       const bannedVocab = buildBannedVocab({ skillRoot, skillId, privateExpected: { resources: sc.expectedResources } });\n129:       const lint = lintFixture({ publicText: sc.prompt, bannedVocab });\n130:       if (!lint.passed) lintFindings.push({ scenarioId: sc.scenarioId, leaks: lint.hardLeaks.map((h) => h.term) });\n131:     }\n132:     const advisorResult = (advisorMode === 'python' && sc.classKind === 'advisor' && sc.prompt)\n133:       ? probeAdvisor({ prompt: sc.prompt }) : undefined;\n134:     scenarioRows.push(scoreScenario({ scenario: sc, observed, advisorResult, traceMode }));\n135:   }\n136: }\n137: \n138: function run(args) {\n139:   const skillRoot = resolveSkillRoot(args.skill);\n140:   const skillId = resolveSkillId(skillRoot);\n141:   const outputsDir = path.resolve(args['outputs-dir']);\n142:   fs.mkdirSync(outputsDir, { recursive: true });\n143:   const advisorMode = args['advisor-mode'] || 'off';\n144:   // The internal fallback stays 'router' so direct run() calls (the test suite)\n145:   // are deterministic; the live default is injected by loop-host for operators.\n146:   const traceMode = args['trace-mode'] || 'router';\n147: \n148:   if (!fs.existsSync(path.join(skillRoot, 'SKILL.md'))) {\n149:     process.stderr.write(`run-skill-benchmark: no SKILL.md at ${skillRoot}\\n`);\n150:     return 2;\n151:   }\n152: \n153:   // D5 hard gate first.\n154:   const connectivity = scanConnectivity({ skillRoot });\n155: \n156:   const scenarioRows = [];\n157:   const lintFindings = [];\n158:   const warnings = [];\n159:   if (args['fixtures-dir']) {\n160:     runLegacyFixtures({ fixturesDir: path.resolve(args['fixtures-dir']), skillRoot, skillId, advisorMode, scenarioRows });\n161:   } else {\n162:     runPlaybook({\n163:       skillRoot, skillId, traceMode, advisorMode, executor: args.executor,\n164:       playbookDir: args['playbook-dir'],\n165:       scenariosFilter: args.scenarios, scenarioRows, lintFindings, warningsOut: warnings,\n166:     });\n167:   }\n168: \n169:   // aggregate + emit.\n170:   const report = aggregate({ skillId, skillRoot, scenarioRows, connectivity, traceMode, lintFindings });\n171:   if (warnings.length) report.parseWarnings = warnings;\n172:   const reportJsonPath = args.output ? path.resolve(args.output) : path.join(outputsDir, 'skill-benchmark-report.json');\n173:   const reportMdPath = reportJsonPath.replace(/\\.json$/, '.md');\n174:   fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));\n175:   fs.writeFileSync(reportMdPath, renderReport(report));\n176: \n177:   process.stdout.write(`skill-benchmark: ${skillId} verdict=${report.verdict} aggregate=${report.aggregateScore} scenarios=${scenarioRows.length}\\n`);\n178:   process.stdout.write(`  report.json -> ${reportJsonPath}\\n  report.md   -> ${reportMdPath}\\n`);\n179:   return 0;\n180: }\n181: \n182: module.exports = { run, resolveSkillRoot, loadFixtures };\n183: \n184: if (require.main === module) {\n185:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n186:   if (!args.skill || !args['outputs-dir']) {\n187:     process.stderr.write('usage: run-skill-benchmark.cjs --skill <root-or-id> --outputs-dir <path> [--fixtures-dir <path>] [--playbook-dir <path>] [--scenarios <ids>] [--output <report.json>] [--trace-mode router|live]\\n');\n188:     process.exit(2);\n189:   }\n190:   process.exit(run(args));\n191: }\n\n(End of file - total 191 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * run-skill-benchmark.cjs — Lane C orchestrator (loop-host --mode=skill-benchmark).\n *\n * Post-run join: private gold never crosses the dispatch boundary. Sequence:\n *   1. resolve the target skill root (path or bare id under .opencode/skills/)\n *   2. D5 static connectivity scan (the hard gate) — runs first, before any dispatch\n *   3. load public/private fixture pairs\n *   4. per scenario: contamination-lint the PUBLIC prompt (a leak is a fixture\n *      failure), then router-replay (Mode A), then join with private gold to score\n *   5. aggregate -> write report.json, then render report.md FROM it\n *\n * Mode A (router-replay) is the deterministic default and the CI gate. Live\n * dispatch (Mode B) + D1-inter advisor scoring + D4 ablation are follow-on; this\n * orchestrator emits a complete, honest Mode A report today.\n */\n\nconst fs = require('fs');","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/run-skill-benchmark.cjs","time":{"start":1780373204634,"end":1780373204659}},"metadata":{"openai":{"itemId":"fc_09a26801a09b079e016a1e56d496b48191b2b67086fb619de3"}},"id":"prt_e86832e8a001jIrG8rLl4SiSDD","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e868313ac001BJF417Kh1c54Ek"}}
{"type":"tool_use","timestamp":1780373204687,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"read","callID":"call_TCdxObir3S63SLKa2jcWAw5M","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/manual_testing_playbook.md","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/manual_testing_playbook.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"sk-code: Manual Testing Playbook\"\n3: description: \"Operator-facing reference combining the manual testing directory, integrated review/orchestration guidance, execution expectations, and per-feature validation files for the sk-code skill.\"\n4: ---\n5: \n6: # sk-code: Manual Testing Playbook\n7: \n8: > **EXECUTION POLICY**: Every scenario MUST be executed against the live sk-code skill — no mocks, no stubs, no \"unautomatable\" verdicts. Scenarios verify the AI's actual routing behavior: which surface it detects, which references/assets it loads, which agent it dispatches. Acceptable verdicts are PASS, PARTIAL, FAIL, or SKIP (with a documented sandbox blocker).\n9: \n10: This document combines the full manual-validation contract for the `sk-code` skill into a single reference. The root playbook acts as the operator directory, review protocol, and orchestration guide. Per-feature files provide the deeper execution contract for each scenario, including the user request, expected detection markers, expected resource loading paths, and validation criteria.\n11: \n12: ---\n13: \n14: This playbook package adopts the Feature Catalog split-document pattern. The root document acts as the directory, review surface, and orchestration guide; per-feature execution detail lives in the numbered category folders at the playbook root.\n15: \n16: Canonical package artifacts:\n17: - `manual_testing_playbook.md`\n18: - `01--surface-detection/`\n19: - `02--language-sub-detection/`\n20: - `03--routing-disambiguation/`\n21: - `04--skill-advisor-integration/`\n22: - `05--motion-dev-and-animation-regression/`\n23: - `06--cross-browser-and-performance-gates/`\n24: - `07--cross-stack-routing/`\n25: \n26: ---\n27: \n28: ## 1. OVERVIEW\n29: \n30: This playbook provides 24 deterministic scenarios across 7 categories validating the `sk-code` skill surface. Each feature keeps its stable `{PREFIX}-NNN` ID and links to a dedicated feature file with the full execution contract.\n31: \n32: Coverage note (2026-05-04): the playbook covers sk-code's two-axis routing (Code Surface → Intent → Resource Loading) at SKILL.md head-of-main. It exercises:\n33: - WEBFLOW surface detection (vanilla HTML/CSS/JS frontend with motion.dev / GSAP / Lenis / HLS / Swiper / FilePond markers, `wrangler.toml`, `src/2_javascript/`).\n34: - OPENCODE surface detection (CWD or target path under `.opencode/`).\n35: - UNKNOWN fallback (Go / Swift / React Native markers — disambiguation expected).\n36: - OPENCODE language sub-detection (TypeScript, Python, Shell, JSON/JSONC) with correct sub-language reference loading.\n37: - Routing disambiguation under mixed-marker conditions and the sk-code vs sk-doc anti-pattern.\n38: - Skill advisor integration: confidence ≥ 0.80 win for positive controls, no false positives on doc-edit prompts.\n39: - Motion.dev integration checks: pinned CDN/API smoke, reduced-motion behavior, animation regression baselines.\n40: - Cross-browser and performance gates: Chrome/Safari/Firefox behavior, LCP/CLS/INP thresholds, and compositor-friendly animation checks.\n41: - Cross-stack routing checks: Webflow plus Motion.dev, non-Webflow Motion.dev, OpenCode plus Motion.dev, decision-matrix use, snippet reuse, CWV dual loading, and reduced-motion guidance.\n42: \n43: ### Realistic Test Model\n44: \n45: 1. A realistic user request is given to an orchestrator that has the sk-code skill registered.\n46: 2. The orchestrator (Claude Code, OpenCode, Codex, Gemini, or Copilot) consults the skill advisor and decides whether to invoke sk-code, route to another skill, or ask for disambiguation.\n47: 3. The operator captures: which skill won the advisor vote, which surface sk-code detected, which references/assets the AI loaded, which agent (if any) was dispatched, and what the AI's response actually was.\n48: 4. The scenario passes only when the routing is correct, the resource-loading is exact (matches expected paths), and the user-visible outcome is sound.\n49: \n50: ### What Each Feature File Should Explain\n51: \n52: - The realistic user request that should trigger the behavior.\n53: - The expected detection markers (verbatim from `references/stack_detection.md`).\n54: - The expected references and assets the AI MUST load (exact relative paths under `references/` and `assets/`).\n55: - The expected agent dispatch (if any — typically `@code` for write work, or none for read-only).\n56: - The pass/fail criteria with binary grading.\n57: - Failure triage steps.\n58: \n59: ---\n60: \n61: ## 2. GLOBAL PRECONDITIONS\n62: \n63: Motion peer-resource folders must be present before MR/CB scenarios run: `references/motion_dev/` and `assets/motion_dev/`.\n64: \n65: 1. Working directory is project root and has `.git/`.\n66: 2. The sk-code skill is present at `.opencode/skills/sk-code/` with surface and peer-resource subfolders intact: `references/{router,opencode,webflow,universal,motion_dev}/` and `assets/{opencode,webflow,universal,motion_dev}/`.\n67: 3. The skill advisor at `.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py` is callable and `skill-graph.json` includes the `sk-code` entry with `signals` array intact.\n68: 4. The orchestrator runtime has a Skill Advisor Hook OR can invoke `skill_advisor.py` via Bash.\n69: 5. The operator uses sandboxed scratch paths under `/tmp/skc-NNN-sandbox/` for any file fixtures the scenarios need (e.g. fake `wrangler.toml` to trigger WEBFLOW detection).\n70: 6. **Concurrency cap**: When running multi-scenario waves, cap at 5 parallel scenarios. Scenarios that invoke `skill_advisor.py` are CPU-light and can run concurrently; scenarios that dispatch `@code` (write work) MUST run serially to avoid scope-collision on the working tree.\n71: 7. Destructive scenarios (currently none in this playbook — all scenarios are READ-ONLY against the skill surface) MUST verify recovery is possible if added in future.\n72: \n73: ---\n74: \n75: ## 3. GLOBAL EVIDENCE REQUIREMENTS\n76: \n77: - The exact user prompt that was tested.\n78: - The skill advisor output (top-1 skill, confidence score, gap to second, advisorStatus).\n79: - The detected code surface (WEBFLOW / OPENCODE / UNKNOWN) reported by sk-code.\n80: - The exact list of references/assets the AI loaded (verbatim relative paths under `.opencode/skills/sk-code/`).\n81: - The agent dispatched (if any) with name and runtime (e.g. `@code` via `.opencode/agents/code.md`).\n82: - The AI's user-visible response (the answer it produced or the action it took).\n83: - The scenario verdict (PASS / PARTIAL / FAIL / SKIP) with one-line rationale.\n84: - Output transcripts saved under `/tmp/skc-NNN*.txt` per scenario.\n85: \n86: ---\n87: \n88: ## 4. DETERMINISTIC COMMAND NOTATION\n89: \n90: - Skill advisor probe: `python3 .opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py \"<prompt>\" --threshold 0.8`.\n91: - Bash commands: `bash: <command>`.\n92: - AI agent prompts: `As @<agent>: <instruction>`.\n93: - Resource path notation: paths shown relative to `.opencode/skills/sk-code/` (e.g. `references/stack_detection.md`).\n94: - `→` separates sequential steps inside a scenario's Exact Command Sequence.\n95: - All evidence files live under `/tmp/skc-NNN*`. The playbook never writes to project paths outside `/tmp/` sandboxes.\n96: \n97: ---\n98: \n99: ## 5. REVIEW PROTOCOL AND RELEASE READINESS\n100: \n101: ### Inputs Required\n102: \n103: 1. `manual_testing_playbook.md` (this file).\n104: 2. Per-feature files under `manual_testing_playbook/{NN--category-name}/`.\n105: 3. Scenario execution evidence (advisor outputs, surface-detection logs, resource-loading transcripts).\n106: 4. Feature-to-scenario coverage map (§15 FEATURE CATALOG CROSS-REFERENCE INDEX).\n107: 5. Triage notes for all PARTIAL / FAIL outcomes.\n108: \n109: ### Scenario Acceptance Rules\n110: \n111: For each executed scenario, check:\n112: 1. Preconditions (§2) were satisfied.\n113: 2. Exact prompt was used verbatim.\n114: 3. Skill advisor returned the expected top-1 skill at the expected confidence band.\n115: 4. sk-code detected the expected surface (or correctly returned UNKNOWN).\n116: 5. The AI loaded EXACTLY the expected references/assets (no extra loads, no missed loads).\n117: 6. The agent dispatch (if any) matched the expected dispatch.\n118: 7. The user-visible outcome would satisfy a real user with the originating request.\n119: \n120: ### Verdict Rules\n121: \n122: - `PASS`: all 7 acceptance checks true.\n123: - `PARTIAL`: routing correct (advisor + surface + agent) but resource-loading set has minor drift (e.g. extra universal/ load).\n124: - `FAIL`: any of (advisor lost, wrong surface, wrong agent, missing required reference) is true.\n125: - `SKIP`: a documented external blocker (e.g. advisor binary unavailable in sandbox).\n126: \n127: ### Feature Verdict Rules\n128: \n129: - `PASS`: all mapped scenarios for the feature are PASS.\n130: - `PARTIAL`: at least one mapped scenario is PARTIAL, none are FAIL.\n131: - `FAIL`: any mapped scenario is FAIL.\n132: \n133: Hard rule: any critical-path scenario FAIL forces feature verdict to FAIL. Critical-path scenarios are SD-001, SD-002, SD-003 (the three primary surface-detection paths) plus CS-001, CS-002, and CS-003 for the cross-stack Motion.dev routing path.\n134: \n135: ### Release Readiness Rule\n136: \n137: Release is READY only when:\n138: 1. No feature verdict is FAIL.\n139: 2. All critical scenarios (SD-001, SD-002, SD-003, RD-002, SA-001) are PASS.\n140: 3. Coverage is 100% of playbook scenarios (24 / 24).\n141: 4. No unresolved blocking triage item remains.\n142: \n143: ### Root-vs-Feature Rule\n144: \n145: Keep global verdict logic and routing-architecture explanations in this root playbook. Put scenario-specific acceptance caveats and resource-path expectations in the matching per-feature files.\n146: \n147: ---\n148: \n149: ## 6. SUB-AGENT ORCHESTRATION AND WAVE PLANNING\n150: \n151: ### Purpose\n152: \n153: This section records wave planning and capacity guidance for the manual testing package.\n154: \n155: ### Operational Rules\n156: \n157: 1. Probe runtime capacity at start (`pgrep -f \"python3 .*skill_advisor\" | wc -l`).\n158: 2. Reserve one operator (you) as coordinator.\n159: 3. Saturate remaining worker slots up to 5 for advisor probes; 1 for `@code` dispatches.\n160: 4. Pre-assign explicit scenario IDs to each wave before execution.\n161: 5. Run the SA-001 advisor-probe wave LAST so it can reference outputs from SD-* and LS-* scenarios.\n162: 6. After each wave, save evidence under `/tmp/skc-wave-NN/`, then begin the next wave.\n163: 7. Record utilization, per-feature file references, and evidence paths in the final report.\n164: \n165: ### What Belongs in Per-Feature Files\n166: \n167: - Real user request (the human-language ask the operator simulates).\n168: - Exact prompt to feed into the orchestrator's prompt entry.\n169: - Expected detection markers (cite `references/stack_detection.md` line numbers).\n170: - Expected reference/asset load list (exact relative paths).\n171: - Expected agent dispatch (or no-dispatch with rationale).\n172: - Pass/fail criteria.\n173: - Failure triage steps (e.g. \"if WEBFLOW not detected, verify markers in code_surface_detection.md:30-37\").\n174: \n175: ---\n176: \n177: ## 7. SURFACE DETECTION (`SD-001..SD-003`)\n178: \n179: | Feature ID | Feature Name | Scenario Name / Objective | Exact Prompt | Exact Command Sequence | Expected Signals | Evidence | Pass/Fail Criteria | Failure Triage |\n180: |---|---|---|---|---|---|---|---|---|\n181: | `SD-001` | WEBFLOW Detection | Verify sk-code routes a vanilla-JS animation request to WEBFLOW surface | `Add a Lenis smooth-scroll initializer to src/2_javascript/scroll.js and gate it behind an IntersectionObserver so it only runs once the hero section is visible.` | advisor probe → invoke sk-code → inspect surface + loaded refs | advisor: sk-code top-1, score ≥ 0.80; surface: WEBFLOW; refs: webflow/* + router/* + universal/code_quality_standards.md | `/tmp/skc-SD001-advisor.txt`, `/tmp/skc-SD001-loaded-refs.txt` | PASS iff advisor wins sk-code AND surface == WEBFLOW AND `references/webflow/implementation/*` is in load set | If WEBFLOW not detected, verify `Lenis`, `src/2_javascript/`, `IntersectionObserver` markers in `references/stack_detection.md:30-37` |\n182: | `SD-002` | OPENCODE Detection | Verify sk-code routes a system-code task to OPENCODE surface | `Add a console.error fallback to .opencode/skills/system-spec-kit/mcp_server/lib/scorer/lanes/explicit.ts when the input prompt is empty.` | advisor probe → invoke sk-code → inspect surface + loaded refs | advisor: sk-code top-1, score ≥ 0.80; surface: OPENCODE; sub-language: TYPESCRIPT; refs: opencode/typescript/* + opencode/shared/* + router/* | `/tmp/skc-SD002-advisor.txt`, `/tmp/skc-SD002-loaded-refs.txt` | PASS iff surface == OPENCODE AND sub-language detected as TYPESCRIPT AND `references/opencode/typescript/*` in load set | If OPENCODE not detected, verify CWD/target check at `references/stack_detection.md:39-40` |\n183: | `SD-003` | UNKNOWN Fallback | Verify sk-code asks for disambiguation on unsupported stacks (Go) | `Add a request-ID middleware to my Go HTTP server in cmd/api/main.go and return it in the X-Request-ID response header.` | advisor probe → invoke sk-code → inspect surface | advisor: sk-code top-1 with caveat OR no win; surface: UNKNOWN; AI asks \"which runtime / verification commands?\" | `/tmp/skc-SD003-advisor.txt`, `/tmp/skc-SD003-response.txt` | PASS iff surface == UNKNOWN AND AI explicitly asks for runtime/verification disambiguation AND no surface-specific refs are loaded | If sk-code silently proceeds, verify the disambiguation rule in SKILL.md \"Unsupported / Unknown\" row |\n184: \n185: Per-feature files: see `01--surface-detection/`.\n186: \n187: ---\n188: \n189: ## 8. LANGUAGE SUB-DETECTION (`LS-001..LS-004`)\n190: \n191: | Feature ID | Feature Name | Scenario Name / Objective | Exact Prompt | Exact Command Sequence | Expected Signals | Evidence | Pass/Fail Criteria | Failure Triage |\n192: |---|---|---|---|---|---|---|---|---|\n193: | `LS-001` | OPENCODE/TypeScript | Verify TypeScript sub-language detection within OPENCODE | `Refactor the parseExecutorConfig function in .opencode/skills/system-spec-kit/mcp_server/lib/deep-loop/executor-config.ts to throw on missing model when type is cli-codex.` | advisor probe → invoke sk-code → inspect surface + sub-language + refs | surface: OPENCODE; sub-language: TYPESCRIPT; refs: opencode/typescript/{style_guide,quality_standards,quick_reference}.md + opencode/shared/* | `/tmp/skc-LS001-loaded-refs.txt` | PASS iff sub-language == TYPESCRIPT AND all 3 typescript/* refs loaded AND no python/shell refs loaded | Verify extension list in SKILL.md sub-detection table; check `.ts` is in TS extensions |\n194: | `LS-002` | OPENCODE/Python | Verify Python sub-language detection within OPENCODE | `Update the skill_advisor.py argparse block at .opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py to add a --json-output flag that emits results as JSON.` | advisor probe → invoke sk-code → inspect surface + sub-language + refs | surface: OPENCODE; sub-language: PYTHON; refs: opencode/python/{style_guide,quality_standards,quick_reference}.md + opencode/shared/* | `/tmp/skc-LS002-loaded-refs.txt` | PASS iff sub-language == PYTHON AND all 3 python/* refs loaded AND no typescript/shell refs loaded | Verify `.py` extension mapping; check `argparse` keyword is a Python signal |\n195: | `LS-003` | OPENCODE/Shell | Verify Shell sub-language detection within OPENCODE | `Add set -euo pipefail and a trap to .opencode/skills/system-spec-kit/scripts/spec/validate.sh to clean up the temp dir on exit.` | advisor probe → invoke sk-code → inspect surface + sub-language + refs | surface: OPENCODE; sub-language: SHELL; refs: opencode/shell/{style_guide,quality_standards,quick_reference}.md + opencode/shared/* | `/tmp/skc-LS003-loaded-refs.txt` | PASS iff sub-language == SHELL AND all 3 shell/* refs loaded AND no python/typescript refs loaded | Verify `.sh` and shebang signals in SKILL.md sub-detection table |\n196: | `LS-004` | OPENCODE/Config | Verify JSON/JSONC sub-language detection within OPENCODE | `Add a derived.last_active_child_id field to the <spec-folder> file with value \"001-spec\".` | advisor probe → invoke sk-code → inspect surface + sub-language + refs | surface: OPENCODE; sub-language: CONFIG; refs: opencode/config/{style_guide,quality_standards,quick_reference}.md + opencode/shared/* | `/tmp/skc-LS004-loaded-refs.txt` | PASS iff sub-language == CONFIG AND all 3 config/* refs loaded | Verify `.json`/`.jsonc` extensions and `schema`/`descriptor` keywords are config signals |\n197: \n198: Per-feature files: see `02--language-sub-detection/`.\n199: \n200: ---\n201: \n202: ## 9. ROUTING DISAMBIGUATION (`RD-001..RD-002`)\n203: \n204: | Feature ID | Feature Name | Scenario Name / Objective | Exact Prompt | Exact Command Sequence | Expected Signals | Evidence | Pass/Fail Criteria | Failure Triage |\n205: |---|---|---|---|---|---|---|---|---|\n206: | `RD-001` | Mixed-Marker Ambiguity | Verify sk-code asks for clarification when WEBFLOW + OPENCODE markers co-occur | `I want to add a Lenis smooth-scroll initializer to my .opencode/skills/sk-doc/scripts/preview-server.js so the local preview server has smooth-scroll on its index page.` | advisor probe → invoke sk-code → inspect surface | advisor: sk-code top-1; surface: ambiguous (BOTH OPENCODE path AND WEBFLOW library marker); AI asks \"is this an OpenCode internal tool or a Webflow shipping artifact?\" | `/tmp/skc-RD001-response.txt` | PASS iff AI explicitly asks for surface clarification AND does not silently pick one | If AI silently picks OPENCODE (because of `.opencode/` path), document as a known-limitation finding |\n207: | `RD-002` | sk-code vs sk-doc Anti-Pattern | Verify skill advisor routes doc-edit prompts to sk-doc, NOT sk-code | `Update the sk-code SKILL.md headline section to clarify the two-axis routing model and add a one-line summary at the top.` | advisor probe → inspect top-1 + score | advisor: sk-doc top-1, score ≥ 0.70; sk-code score lower | `/tmp/skc-RD002-advisor.txt` | PASS iff advisor top-1 != sk-code AND sk-doc is in the top-3 | If sk-code wins despite this being a doc-edit, propose anti-signal in skill-graph.json (Phase E5) |\n208: \n209: Per-feature files: see `03--routing-disambiguation/`.\n210: \n211: ---\n212: \n213: ## 10. SKILL ADVISOR INTEGRATION (`SA-001`)\n214: \n215: | Feature ID | Feature Name | Scenario Name / Objective | Exact Prompt | Exact Command Sequence | Expected Signals | Evidence | Pass/Fail Criteria | Failure Triage |\n216: |---|---|---|---|---|---|---|---|---|\n217: | `SA-001` | Advisor Probe Battery | Verify sk-code wins ≥80% of positive controls and loses 100% of negative controls | (multi-prompt battery — see per-feature file) | run `skill_advisor.py` for each prompt at threshold 0.8; tabulate top-1 and score | sk-code wins ≥12 of 15 positives at score ≥ 0.80; sk-code loses all 5 negatives | `/tmp/skc-SA001-advisor-results.jsonl` | PASS iff positive accuracy ≥ 0.80 AND negative-control false-positive rate == 0 | If positive accuracy < 0.80, propose `signals` array additions to skill-graph.json (Phase E5) |\n218: \n219: Per-feature file: see `04--skill-advisor-integration/010-advisor-probe-battery.md`.\n220: \n\n(Showing lines 1-220 of 322. Use offset=221 to continue.)\n</content>","metadata":{"preview":"---\ntitle: \"sk-code: Manual Testing Playbook\"\ndescription: \"Operator-facing reference combining the manual testing directory, integrated review/orchestration guidance, execution expectations, and per-feature validation files for the sk-code skill.\"\n---\n\n# sk-code: Manual Testing Playbook\n\n> **EXECUTION POLICY**: Every scenario MUST be executed against the live sk-code skill — no mocks, no stubs, no \"unautomatable\" verdicts. Scenarios verify the AI's actual routing behavior: which surface it detects, which references/assets it loads, which agent it dispatches. Acceptable verdicts are PASS, PARTIAL, FAIL, or SKIP (with a documented sandbox blocker).\n\nThis document combines the full manual-validation contract for the `sk-code` skill into a single reference. The root playbook acts as the operator directory, review protocol, and orchestration guide. Per-feature files provide the deeper execution contract for each scenario, including the user request, expected detection markers, expected resource loading paths, and validation criteria.\n\n---\n\nThis playbook package adopts the Feature Catalog split-document pattern. The root document acts as the directory, review surface, and orchestration guide; per-feature execution detail lives in the numbered category folders at the playbook root.\n\nCanonical package artifacts:\n- `manual_testing_playbook.md`\n- `01--surface-detection/`\n- `02--language-sub-detection/`\n- `03--routing-disambiguation/`","truncated":true,"loaded":[]},"title":".opencode/skills/sk-code/manual_testing_playbook/manual_testing_playbook.md","time":{"start":1780373204681,"end":1780373204686}},"metadata":{"openai":{"itemId":"fc_09a26801a09b079e016a1e56d496d08191a92dee6774eac2a5"}},"id":"prt_e86832ec7001xsPbKDAI3Hs7At","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"m