{"type":"tool_use","timestamp":1780727787509,"sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","part":{"type":"tool","tool":"read","callID":"call_vPSEausP88Ztaz9AgRqszBIH","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py","offset":375,"limit":70},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py</path>\n<type>file</type>\n<content>\n375: \n376:     # ── Path 3: Standalone mode (no key required) ──\n377:     if settings.is_standalone:\n378:         from core_api.standalone import get_standalone_tenant_id\n379: \n380:         tenant_id = get_standalone_tenant_id()\n381:         await _block_if_suppressed(tenant_id)\n382:         set_current_tenant(tenant_id)\n383:         return AuthContext(tenant_id=tenant_id, org_role=\"admin\")\n384: \n385:     # ── Path 4: X-Tenant-ID header (set by enterprise nginx / ingress) ──\n386:     tenant_id = request.headers.get(\"x-tenant-id\")\n387:     if tenant_id:\n388:         # Perimeter check: this path TRUSTS the X-Tenant-ID / X-Agent-ID /\n389:         # X-Readable-Tenant-IDs headers with no credential of its own — safe\n390:         # only when the request came through the gateway. When a shared secret\n391:         # is configured, require the gateway-injected ``X-Gateway-Secret`` so a\n392:         # caller hitting core-api directly (e.g. its public run.app URL) cannot\n393:         # impersonate a tenant by setting the identity headers itself. No-op\n394:         # when unset (OSS / standalone / dev).\n395:         gw_secret = settings.gateway_shared_secret\n396:         if gw_secret and not hmac.compare_digest(request.headers.get(\"x-gateway-secret\") or \"\", gw_secret):\n397:             raise HTTPException(\n398:                 status_code=401,\n399:                 detail=\"Direct access to this service is not permitted.\",\n400:             )\n401:         await _block_if_suppressed(tenant_id)\n402:         # Cross-tenant credentials carry a list of readable tenants via\n403:         # ``X-Readable-Tenant-IDs``. The home tenant was just checked\n404:         # above; verify each additional readable tenant is also live\n405:         # so a partner key whose readable set spans a suppressed org\n406:         # can't reach that org's data. Bot review round 2 on PR #244.\n407:         await _block_if_any_readable_suppressed(tenant_id, readable_tenants)\n408:         # The gateway's /_auth subrequest plumbs the api_key's ``kind``\n409:         # so this layer can branch on credential provenance without\n410:         # an extra DB hop. ``install_credential`` is what memclawd\n411:         # uses; ``user_api_key`` (the default) is the dashboard /\n412:         # SDK path.\n413:         credential_kind = (request.headers.get(\"x-caura-credential-kind\") or \"\").lower()\n414:         is_install_credential = credential_kind == \"install_credential\"\n415:         install_uuid = request.headers.get(\"x-install-uuid\") or None\n416:         set_current_tenant(tenant_id)\n417:         # When the gateway plumbs a multi-tenant read set, expose it to the\n418:         # DB layer so reads (and downstream RLS policies, when configured)\n419:         # can widen. The home tenant is prepended to keep the set complete.\n420:         if readable_tenants:\n421:             combined: list[str] = [tenant_id]\n422:             for t in readable_tenants:\n423:                 if t != tenant_id:\n424:                     combined.append(t)\n425:             set_readable_tenants(combined)\n426:         else:\n427:             set_readable_tenants(None)\n428:         return AuthContext(\n429:             tenant_id=tenant_id,\n430:             agent_id=agent_id,\n431:             is_read_only=is_read_only,\n432:             is_install_credential=is_install_credential,\n433:             install_uuid=install_uuid,\n434:             readable_tenant_ids=readable_tenants or None,\n435:             capabilities=capabilities,\n436:         )\n437: \n438:     # No tenant header + no admin key configured = reject.\n439:     # Unscoped access without authentication is not allowed.\n440:     raise HTTPException(\n441:         status_code=401,\n442:         detail=\"Missing API key or X-Tenant-ID header.\",\n443:     )\n\n(End of file - total 443 lines)\n</content>","metadata":{"preview":"\n    # ── Path 3: Standalone mode (no key required) ──\n    if settings.is_standalone:\n        from core_api.standalone import get_standalone_tenant_id\n\n        tenant_id = get_standalone_tenant_id()\n        await _block_if_suppressed(tenant_id)\n        set_current_tenant(tenant_id)\n        return AuthContext(tenant_id=tenant_id, org_role=\"admin\")\n\n    # ── Path 4: X-Tenant-ID header (set by enterprise nginx / ingress) ──\n    tenant_id = request.headers.get(\"x-tenant-id\")\n    if tenant_id:\n        # Perimeter check: this path TRUSTS the X-Tenant-ID / X-Agent-ID /\n        # X-Readable-Tenant-IDs headers with no credential of its own — safe\n        # only when the request came through the gateway. When a shared secret\n        # is configured, require the gateway-injected ``X-Gateway-Secret`` so a\n        # caller hitting core-api directly (e.g. its public run.app URL) cannot\n        # impersonate a tenant by setting the identity headers itself. No-op\n        # when unset (OSS / standalone / dev).","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py","text":"\n    # ── Path 3: Standalone mode (no key required) ──\n    if settings.is_standalone:\n        from core_api.standalone import get_standalone_tenant_id\n\n        tenant_id = get_standalone_tenant_id()\n        await _block_if_suppressed(tenant_id)\n        set_current_tenant(tenant_id)\n        return AuthContext(tenant_id=tenant_id, org_role=\"admin\")\n\n    # ── Path 4: X-Tenant-ID header (set by enterprise nginx / ingress) ──\n    tenant_id = request.headers.get(\"x-tenant-id\")\n    if tenant_id:\n        # Perimeter check: this path TRUSTS the X-Tenant-ID / X-Agent-ID /\n        # X-Readable-Tenant-IDs headers with no credential of its own — safe\n        # only when the request came through the gateway. When a shared secret\n        # is configured, require the gateway-injected ``X-Gateway-Secret`` so a\n        # caller hitting core-api directly (e.g. its public run.app URL) cannot\n        # impersonate a tenant by setting the identity headers itself. No-op\n        # when unset (OSS / standalone / dev).\n        gw_secret = settings.gateway_shared_secret\n        if gw_secret and not hmac.compare_digest(request.headers.get(\"x-gateway-secret\") or \"\", gw_secret):\n            raise HTTPException(\n                status_code=401,\n                detail=\"Direct access to this service is not permitted.\",\n            )\n        await _block_if_suppressed(tenant_id)\n        # Cross-tenant credentials carry a list of readable tenants via\n        # ``X-Readable-Tenant-IDs``. The home tenant was just checked\n        # above; verify each additional readable tenant is also live\n        # so a partner key whose readable set spans a suppressed org\n        # can't reach that org's data. Bot review round 2 on PR #244.\n        await _block_if_any_readable_suppressed(tenant_id, readable_tenants)\n        # The gateway's /_auth subrequest plumbs the api_key's ``kind``\n        # so this layer can branch on credential provenance without\n        # an extra DB hop. ``install_credential`` is what memclawd\n        # uses; ``user_api_key`` (the default) is the dashboard /\n        # SDK path.\n        credential_kind = (request.headers.get(\"x-caura-credential-kind\") or \"\").lower()\n        is_install_credential = credential_kind == \"install_credential\"\n        install_uuid = request.headers.get(\"x-install-uuid\") or None\n        set_current_tenant(tenant_id)\n        # When the gateway plumbs a multi-tenant read set, expose it to the\n        # DB layer so reads (and downstream RLS policies, when configured)\n        # can widen. The home tenant is prepended to keep the set complete.\n        if readable_tenants:\n            combined: list[str] = [tenant_id]\n            for t in readable_tenants:\n                if t != tenant_id:\n                    combined.append(t)\n            set_readable_tenants(combined)\n        else:\n            set_readable_tenants(None)\n        return AuthContext(\n            tenant_id=tenant_id,\n            agent_id=agent_id,\n            is_read_only=is_read_only,\n            is_install_credential=is_install_credential,\n            install_uuid=install_uuid,\n            readable_tenant_ids=readable_tenants or None,\n            capabilities=capabilities,\n        )\n\n    # No tenant header + no admin key configured = reject.\n    # Unscoped access without authentication is not allowed.\n    raise HTTPException(\n        status_code=401,\n        detail=\"Missing API key or X-Tenant-ID header.\",\n    )","lineStart":375,"lineEnd":443,"totalLines":443,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py","time":{"start":1780727787494,"end":1780727787506}},"metadata":{"openai":{"itemId":"fc_0d39b06b97341b57016a23bfea05d8819182d369e035eb4f46"}},"id":"prt_e9ba5aa3b001BU1iQsmBQaILgg","sessionID":"ses_1645cad25ffe4Zj0121cwP5hrZ","messageID":"msg_e9ba59dfc0018vDKBTY365Sc9a"}}
