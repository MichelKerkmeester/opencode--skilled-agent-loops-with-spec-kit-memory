{"type":"tool_use","timestamp":1781459253900,"sessionID":"ses_138c2bb01ffeUjkBZZt6lKZbis","part":{"type":"tool","tool":"read","callID":"call_980b1f16ca2d4f458fb33383","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/graph-metadata.json"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/mcp-figma/graph-metadata.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"schema_version\": 2,\n3:   \"skill_id\": \"mcp-figma\",\n4:   \"family\": \"mcp\",\n5:   \"category\": \"mcp-tool\",\n6:   \"edges\": {\n7:     \"depends_on\": [\n8:       {\n9:         \"target\": \"sk-interface-design\",\n10:         \"weight\": 0.7,\n11:         \"context\": \"When a Figma read or export feeds a design decision, apply sk-interface-design's anti-default judgment before deciding\"\n12:       },\n13:       {\n14:         \"target\": \"mcp-code-mode\",\n15:         \"weight\": 0.45,\n16:         \"context\": \"The optional Figma MCP (Framelink figma manual) is invoked through Code Mode when MCP context is needed\"\n17:       }\n18:     ],\n19:     \"enhances\": [\n20:       {\n21:         \"target\": \"sk-code\",\n22:         \"weight\": 0.4,\n23:         \"context\": \"Figma exports, DESIGN.md, variables, and screenshots feed application implementation that sk-code governs and verifies\"\n24:       }\n25:     ],\n26:     \"siblings\": [\n27:       {\n28:         \"target\": \"mcp-open-design\",\n29:         \"weight\": 0.55,\n30:         \"context\": \"Sibling terminal-driven design tool with a daemon model, gated mutating verbs, and an sk-interface-design handoff\"\n31:       },\n32:       {\n33:         \"target\": \"mcp-chrome-devtools\",\n34:         \"weight\": 0.5,\n35:         \"context\": \"Sibling CLI-primary plus MCP-via-Code-Mode skill sharing the same router and gating pattern\"\n36:       }\n37:     ],\n38:     \"conflicts_with\": [],\n39:     \"prerequisite_for\": []\n40:   },\n41:   \"manual\": {\n42:     \"depends_on\": [],\n43:     \"related_to\": [\"sk-interface-design\", \"sk-code\", \"mcp-code-mode\", \"mcp-open-design\", \"mcp-chrome-devtools\"]\n44:   },\n45:   \"domains\": [\"figma\", \"design-to-code\", \"design-systems\", \"cli\", \"mcp\", \"figma-desktop\"],\n46:   \"intent_signals\": [\n47:     \"figma cli\",\n48:     \"figma-ds-cli\",\n49:     \"figma desktop\",\n50:     \"render in figma\",\n51:     \"figma tokens\",\n52:     \"figma variables\",\n53:     \"extract DESIGN.md\",\n54:     \"export from figma\",\n55:     \"connect to figma\",\n56:     \"figma daemon\",\n57:     \"figma mcp\"\n58:   ],\n59:   \"derived\": {\n60:     \"trigger_phrases\": [\n61:       \"figma cli\",\n62:       \"figma-ds-cli\",\n63:       \"figma desktop\",\n64:       \"render in figma\",\n65:       \"figma tokens\",\n66:       \"extract design.md\",\n67:       \"connect to figma\",\n68:       \"figma mcp\"\n69:     ],\n70:     \"key_topics\": [\n71:       \"figma-ds-cli binary (and the unrelated figma-cli npm collision)\",\n72:       \"Figma Desktop session + local daemon (HTTP 127.0.0.1:3456)\",\n73:       \"safe (plugin) vs yolo (app.asar patch) connect modes\",\n74:       \"read-only / mutating / destructive command gating\",\n75:       \"design-system extract (DESIGN.md) and import (tailwind/css/tokens/storybook)\",\n76:       \"tokens, variables, var:name binding\",\n77:       \"optional Framelink figma MCP via Code Mode\",\n78:       \"sk-interface-design handoff for design judgment\"\n79:     ],\n80:     \"intent_signals\": [\n81:       \"figma\",\n82:       \"figma-ds-cli\",\n83:       \"figma desktop\",\n84:       \"design tokens\",\n85:       \"figma export\",\n86:       \"figma mcp\",\n87:       \"code mode figma\"\n88:     ],\n89:     \"key_files\": [\n90:       \".opencode/skills/mcp-figma/SKILL.md\",\n91:       \".opencode/skills/mcp-figma/README.md\",\n92:       \".opencode/skills/mcp-figma/INSTALL_GUIDE.md\",\n93:       \".opencode/skills/mcp-figma/references/figma_cli_reference.md\",\n94:       \".opencode/skills/mcp-figma/references/tool_surface.md\",\n95:       \".opencode/skills/mcp-figma/references/mcp_wiring.md\",\n96:       \".opencode/skills/mcp-figma/references/troubleshooting.md\",\n97:       \".opencode/skills/mcp-figma/feature_catalog/feature_catalog.md\",\n98:       \".opencode/skills/mcp-figma/manual_testing_playbook/manual_testing_playbook.md\",\n99:       \".opencode/skills/mcp-figma/changelog/v0.1.0.0.md\"\n100:     ],\n101:     \"entities\": [\n102:       {\"name\": \"mcp-figma\", \"kind\": \"skill\", \"path\": \".opencode/skills/mcp-figma/SKILL.md\", \"source\": \"derived\"},\n103:       {\"name\": \"README\", \"kind\": \"reference\", \"path\": \".opencode/skills/mcp-figma/README.md\", \"source\": \"derived\"},\n104:       {\"name\": \"figma_cli_reference\", \"kind\": \"reference\", \"path\": \".opencode/skills/mcp-figma/references/figma_cli_reference.md\", \"source\": \"derived\"},\n105:       {\"name\": \"tool_surface\", \"kind\": \"reference\", \"path\": \".opencode/skills/mcp-figma/references/tool_surface.md\", \"source\": \"derived\"},\n106:       {\"name\": \"mcp_wiring\", \"kind\": \"reference\", \"path\": \".opencode/skills/mcp-figma/references/mcp_wiring.md\", \"source\": \"derived\"},\n107:       {\"name\": \"troubleshooting\", \"kind\": \"reference\", \"path\": \".opencode/skills/mcp-figma/references/troubleshooting.md\", \"source\": \"derived\"}\n108:     ],\n109:     \"causal_summary\": \"mcp-figma teaches a terminal agent to drive Figma Desktop through the silships figma-cli, published to npm as figma-ds-cli (the npm package literally named figma-cli is an unrelated tool by unic, bin 'figma' - never install it). figma-cli has no MCP of its own; it drives the live Figma Desktop session via a local daemon (HTTP 127.0.0.1:3456, X-Daemon-Token). Connect is either safe (FigCli plugin, no patch - the default) or yolo (patches Figma app.asar, CDP 9222 - gated, rollback via unpatch). The CLI is primary for authoring/modifying/exporting in Figma; an optional Figma MCP (the community Framelink figma manual already in this repo's Code Mode) is opt-in for pulling design data into the agent for codegen. Commands are gated read-only / mutating / destructive, with eval/raw/run treated as arbitrary mutation and local exports requiring explicit no-overwrite paths. Pairs with sk-interface-design (design judgment) and sk-code (adapting exports into an app). Modeled on mcp-chrome-devtools and mcp-open-design.\",\n110:     \"source_docs\": [\n111:       \"SKILL.md\",\n112:       \"README.md\",\n113:       \"INSTALL_GUIDE.md\",\n114:       \"references/figma_cli_reference.md\",\n115:       \"references/tool_surface.md\",\n116:       \"references/mcp_wiring.md\",\n117:       \"references/troubleshooting.md\",\n118:       \"feature_catalog/feature_catalog.md\",\n119:       \"manual_testing_playbook/manual_testing_playbook.md\",\n120:       \"changelog/v0.1.0.0.md\"\n121:     ],\n122:     \"created_at\": \"2026-06-14T16:00:00Z\",\n123:     \"last_updated_at\": \"2026-06-14T16:00:00Z\"\n124:   }\n125: }\n\n(End of file - total 125 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 2,\n  \"skill_id\": \"mcp-figma\",\n  \"family\": \"mcp\",\n  \"category\": \"mcp-tool\",\n  \"edges\": {\n    \"depends_on\": [\n      {\n        \"target\": \"sk-interface-design\",\n        \"weight\": 0.7,\n        \"context\": \"When a Figma read or export feeds a design decision, apply sk-interface-design's anti-default judgment before deciding\"\n      },\n      {\n        \"target\": \"mcp-code-mode\",\n        \"weight\": 0.45,\n        \"context\": \"The optional Figma MCP (Framelink figma manual) is invoked through Code Mode when MCP context is needed\"\n      }\n    ],\n    \"enhances\": [\n      {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Dev