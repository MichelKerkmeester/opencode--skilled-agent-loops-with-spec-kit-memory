tate record with the route-proof fields present — \\`target_agent: \"${leaf}\"\\`, \\`resolved_route\\`, \\`agent_definition_loaded: true\\`, and \\`mode: \"${mode}\"\\`. A completed run whose iteration state records omit these fields is an incomplete delegation and does not pass.`,\n\n  Line 481:   const directiveOpening = `You were invoked via \\`opencode run --command ${definition.id}\\` with the \\`:auto\\` suffix and a bound spec_folder and target in your message. The \\`:auto\\` suffix plus the bound spec_folder mean setup is ALREADY resolved. Therefore:`;\n\n  Line 549:     ...(definition.promptPackPath ? [`promptPackPath: ${definition.promptPackPath}`] : []),\n\n  Line 578:     '  - \"Native and CLI executors must produce only the required prompt-pack artifacts inside the resolved boundary.\"',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs:\n  Line 934:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n\n  Line 936:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n\n  Line 938: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n\n  Line 967:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n\n  Line 1011:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n\n  Line 1017:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n\n  Line 1055:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n\n  Line 1299: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n\n  Line 1305:       prompt,\n\n  Line 1320:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n\n  Line 1346:     // specific agent profile can be requested in the prompt body instead.\n\n  Line 1361:     // lineage's lineageDir-only