{"type":"tool_use","timestamp":1781764158672,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_kArFDEF79ry6dCjFfWlJ47RV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","offset":780,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts</path>\n<type>file</type>\n<content>\n780: /** Handle memory_search tool — performs hybrid vector/BM25 search with intent-aware ranking.\n781:  * @param args - Search arguments (query, concepts, mode, specFolder, etc.)\n782:  * @returns MCP response with ranked search results\n783:  */\n784: async function handleMemorySearch(args: SearchArgs): Promise<MCPResponse> {\n785:   await ensureMemoryRuntimeInitialized('handler:memory_search');\n786:   const _searchStartTime = Date.now();\n787:   resetLastLexicalCapabilitySnapshot();\n788:   // Check for external database updates before processing\n789:   await checkDatabaseUpdated();\n790: \n791:   const {\n792:     cursor,\n793:     query,\n794:     concepts,\n795:     specFolder,\n796:     folderBoost,\n797:     tenantId,\n798:     userId,\n799:     agentId,\n800:     limit: rawLimit = 10,\n801:     tier,\n802:     contextType,\n803:     useDecay: useDecay = true,\n804:     includeContiguity: includeContiguity = false,\n805:     includeConstitutional: includeConstitutional = true,\n806:     includeContent: includeContent = false,\n807:     anchors,\n808:     bypassCache: bypassCache = false,\n809:     sessionId: rawSessionId,\n810:     enableDedup: enableDedup = true,\n811:     intent: explicitIntent,\n812:     autoDetectIntent: autoDetectIntent = true,\n813:     minState,  // No default — memoryState column not yet in schema; defaulting to 'WARM' filters all rows\n814:     applyStateLimits: applyStateLimits = false,\n815:     rerank = true, // Enable reranking by default for better result quality\n816:     applyLengthPenalty: applyLengthPenalty = true,\n817:     trackAccess: trackAccess = false, // opt-in, off by default\n818:     includeArchived: includeArchivedRequested = false, // compatibility-only after Gate B cleanup\n819:     enableSessionBoost: enableSessionBoost = isSessionBoostEnabled(),\n820:     enableCausalBoost: enableCausalBoost = isCausalBoostEnabled(),\n821:     minQualityScore,\n822:     min_quality_score,\n823:     mode,\n824:     includeTrace: includeTraceArg = false,\n825:     sessionTransition,\n826:     profile,\n827:     retrievalLevel: retrievalLevel = 'auto',\n828:   } = args;\n829:   const includeTraceByFlag = process.env.SPECKIT_RESPONSE_TRACE === 'true';\n830:   const includeTrace = includeTraceByFlag || includeTraceArg === true;\n831:   const includeArchived = false;\n832: \n833:   // Validate any caller-supplied sessionId through the server-side session\n834:   // manager to prevent IDOR: a caller must not read or mutate another\n835:   // session's sent-memory dedup state by forging an arbitrary session id.\n836:   // Omitting sessionId stays unchanged (downstream treats it as no-session).\n837:   let sessionId: string | undefined = rawSessionId;\n838:   if (rawSessionId) {\n839:     const trustedSession = sessionManager.resolveTrustedSession(rawSessionId, {\n840:       tenantId,\n841:       userId,\n842:       agentId,\n843:     });\n844:     if (trustedSession.error) {\n845:       return createMCPErrorResponse({\n846:         tool: 'memory_search',\n847:         error: trustedSession.error,\n848:         code: 'E_SESSION_SCOPE',\n849:         details: { requestedSessionId: rawSessionId },\n850:         recovery: {\n851:           hint: 'Omit sessionId to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.',\n852:         },\n853:       });\n854:     }\n855:     sessionId = trustedSession.effectiveSessionId;\n856:   }\n857: \n858:   const normalizedScope = normalizeScopeContext({ tenantId, userId, agentId, sessionId });\n859:   const progressiveScopeKey = JSON.stringify({\n860:     tenantId: normalizedScope.tenantId ?? null,\n861:     userId: normalizedScope.userId ?? null,\n862:     agentId: normalizedScope.agentId ?? null,\n863:     sessionId: normalizedScope.sessionId ?? null,\n864:   });\n865: \n866:   // Validate at least one search input is provided (moved from schema superRefine for GPT compatibility)\n867:   const hasCursor = typeof cursor === 'string' && cursor.trim().length > 0;\n868:   const hasQuery = typeof query === 'string' && query.trim().length > 0;\n869:   const hasConcepts = Array.isArray(concepts) && concepts.length >= 2;\n870:   if (!hasCursor && !hasQuery && !hasConcepts) {\n871:     return { content: [{ type: 'text', text: JSON.stringify({ error: 'Either \"query\" (string), \"concepts\" (array with 2-5 items), or \"cursor\" (string) is required.' }) }] };\n872:   }\n873: \n874:   if (hasCursor) {\n875:     const resolved = resolveCursor(cursor.trim(), undefined, { scopeKey: progressiveScopeKey });\n876:     if (!resolved) {\n877:       return createMCPErrorResponse({\n878:         tool: 'memory_search',\n879:         error: 'Cursor is invalid, expired, or out of scope',\n880:         code: 'E_VALIDATION',\n881:         details: { parameter: 'cursor' },\n882:         recovery: {\n883:           hint: 'Retry the original search to generate a fresh continuation cursor',\n884:         },\n885:       });\n886:     }\n887: \n888:     const snippetResults = extractSnippets(resolved.results);\n889:     return createMCPSuccessResponse({\n890:       tool: 'memory_search',\n891:       summary: `Returned ${snippetResults.length} continuation results`,\n892:       data: {\n893:         count: snippetResults.length,\n894:         results: snippetResults,\n895:         continuation: resolved.continuation,\n896:       },\n897:       startTime: _searchStartTime,\n898:       cacheHit: false,\n899:     });\n900:   }\n901: \n902:   const qualityThreshold = resolveQualityThreshold(minQualityScore, min_quality_score);\n903: \n904:   // Validate numeric limit parameter\n905:   const limit = (typeof rawLimit === 'number' && Number.isFinite(rawLimit) && rawLimit > 0)\n906:     ? Math.min(Math.floor(rawLimit), 100)\n907:     : 10;\n908: \n909:   // Validate query first with proper error handling\n910:   let normalizedQuery: string | null = null;\n911:   if (query !== undefined) {\n912:     try {\n913:       normalizedQuery = validateQuery(query);\n914:     } catch (validationError: unknown) {\n915:       if (!concepts || !Array.isArray(concepts) || concepts.length < 2) {\n916:         const message = toErrorMessage(validationError);\n917:         return createMCPErrorResponse({\n918:           tool: 'memory_search',\n919:           error: message,\n920:           code: 'E_VALIDATION',\n921:           details: { parameter: 'query' },\n922:           recovery: {\n923:             hint: 'Provide a valid query string or use concepts array instead'\n924:           }\n925:         });\n926:       }\n927:       normalizedQuery = null;\n928:     }\n929:   }\n930: \n931:   const hasValidQuery = normalizedQuery !== null;\n932:   const hasValidConcepts = Array.isArray(concepts) && concepts.length >= 2;\n933:   const effectiveQuery = normalizedQuery ?? (hasValidConcepts ? concepts.join(', ') : '');\n934:   const searchDecisionRequestId = `memory_search-${_searchStartTime}`;\n935:   let searchDecisionEnvelope: SearchDecisionEnvelope | null = null;\n936: \n937:   if (!hasValidQuery && !hasValidConcepts) {\n938:     return createMCPErrorResponse({\n939:       tool: 'memory_search',\n940:       error: 'Either query (string), concepts (array of 2-5 strings), or cursor (string) is required',\n941:       code: 'E_VALIDATION',\n942:       details: { parameter: 'query' },\n943:       recovery: {\n944:         hint: 'Provide a query string, concepts array with 2-5 entries, or a continuation cursor'\n945:       }\n946:     });\n947:   }\n948: \n949:   if (specFolder !== undefined && typeof specFolder !== 'string') {\n950:     return createMCPErrorResponse({\n951:       tool: 'memory_search',\n952:       error: 'specFolder must be a string',\n953:       code: 'E_VALIDATION',\n954:       details: { parameter: 'specFolder' },\n955:       recovery: {\n956:         hint: 'Provide specFolder as a string path'\n957:       }\n958:     });\n959:   }\n960: \n961:   // Eval logger — capture query at pipeline entry (fail-safe)\n962:   let _evalQueryId = 0;\n963:   let _evalRunId = 0;\n964:   try {\n965:     const evalEntry = logSearchQuery({\n966:       query: effectiveQuery,\n967:       intent: explicitIntent ?? null,\n968:       specFolder: specFolder ?? null,\n969:     });\n970:     _evalQueryId = evalEntry.queryId;\n971:     _evalRunId = evalEntry.evalRunId;\n972:   } catch (_error: unknown) { /* eval logging must never break search */ }\n973: \n974:   const artifactRoutingQuery = resolveArtifactRoutingQuery(\n975:     normalizedQuery,\n976:     hasValidConcepts ? concepts : undefined\n977:   );\n978:   let artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder);\n979:   let queryPlan: QueryPlan;\n980:   try {\n981:     queryPlan = routeQuery(effectiveQuery).queryPlan;\n982:   } catch (_error: unknown) {\n983:     queryPlan = createEmptyQueryPlan({\n984:       complexity: 'unknown',\n985:       selectedChannels: ['vector', 'fts', 'bm25', 'graph', 'degree'],\n986:       fallbackPolicy: {\n987:         mode: 'telemetry_only',\n988:         reason: 'QueryPlan telemetry fallback after routeQuery failure',\n989:       },\n990:     });\n991:   }\n992: \n993:   // Intent-aware retrieval\n994:   let detectedIntent: string | null = null;\n995:   let intentConfidence = 0;\n996:   let intentWeights: IntentWeights | null = null;\n997: \n998:   if (explicitIntent) {\n999:     if (intentClassifier.isValidIntent(explicitIntent)) {\n1000:       detectedIntent = explicitIntent;\n1001:       intentConfidence = 1.0;\n1002:       intentWeights = intentClassifier.getIntentWeights(explicitIntent);\n1003:     } else {\n1004:       console.warn(`[memory-search] Invalid intent '${explicitIntent}', using auto-detection`);\n1005:     }\n1006:   }\n1007: \n1008:   if (!detectedIntent && autoDetectIntent && hasValidQuery) {\n1009:     const classification: IntentClassification = intentClassifier.classifyIntent(normalizedQuery!);\n1010:     detectedIntent = classification.intent;\n1011:     intentConfidence = classification.confidence;\n1012:     intentWeights = intentClassifier.getIntentWeights(classification.intent as IntentType);\n1013: \n1014:     if (classification.fallback) {\n1015:       console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (fallback: ${classification.reason})`);\n1016:     } else {\n1017:       console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (confidence: ${intentConfidence.toFixed(2)})`);\n1018:     }\n1019:   }\n1020: \n1021:   // FIX RC3-B: Intent confidence floor — override low-confidence auto-detections to \"understand\"\n1022:   const INTENT_CONFIDENCE_FLOOR = parseFloat(process.env.SPECKIT_INTENT_CONFIDENCE_FLOOR || '0.25');\n1023:   if (detectedIntent && intentConfidence < INTENT_CONFIDENCE_FLOOR && !explicitIntent) {\n1024:     console.error(`[memory-search] Intent confidence ${intentConfidence.toFixed(3)} below floor ${INTENT_CONFIDENCE_FLOOR}, overriding '${detectedIntent}' → 'understand'`);\n1025:     detectedIntent = 'understand';\n1026:     intentConfidence = 1.0;\n1027:     intentWeights = intentClassifier.getIntentWeights('understand' as IntentType);\n1028:   }\n1029: \n1030:   // Phase C: Intent-to-profile auto-routing.\n1031:   // Explicit caller `profile` always takes precedence; auto-detect fills in when absent.\n1032:   let effectiveProfile: string | undefined = profile;\n1033:   if (!effectiveProfile && detectedIntent && isIntentAutoProfileEnabled()) {\n1034:     try {\n1035:       const autoProfile = intentClassifier.getProfileForIntent(detectedIntent as IntentType);\n1036:       if (autoProfile) {\n1037:         effectiveProfile = autoProfile;\n1038:         console.error(`[memory-search] Intent-to-profile auto-routing: '${detectedIntent}' → profile '${autoProfile}'`);\n1039:       }\n1040:     } catch (_autoProfileErr: unknown) {\n1041:       // Auto-profile is best-effort — never breaks search\n1042:     }\n1043:   }\n1044:   const adaptiveFusionIntent = effectiveProfile === 'resume'\n1045:     ? 'continuity'\n1046:     : detectedIntent;\n1047: \n1048:   // Re-run artifact routing with detected intent for fallback coverage\n1049:   if (detectedIntent && artifactRouting?.detectedClass === 'unknown' && artifactRouting?.confidence === 0) {\n1050:     artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder, detectedIntent);\n1051:   }\n1052: \n1053:   // Create retrieval trace at pipeline entry\n1054:   const trace = createTrace(\n1055:     effectiveQuery,\n1056:     sessionId,\n1057:     detectedIntent || undefined\n1058:   );\n1059: \n1060:   // When causal boost is enabled, fold the causal-edges generation\n1061:   // counter into the cache key so causal-edge mutations naturally invalidate\n1062:   // the affected memory_search entries on the next lookup. We deliberately\n1063:   // keep the generation OFF the key when the caller has not opted into causal\n1064:   // boost — otherwise unrelated callers would suffer needless cache misses.\n1065:   const causalEdgesGenerationForCache = enableCausalBoost\n1066:     ? causalEdges.getCausalEdgesGeneration()\n1067:     : undefined;\n1068: \n1069:   // Build cache key args\n1070:   const cacheArgs = buildCacheArgs({\n1071:     normalizedQuery,\n1072:     hasValidConcepts,\n1073:     concepts,\n1074:     specFolder,\n1075:     tenantId: normalizedScope.tenantId,\n1076:     userId: normalizedScope.userId,\n1077:     agentId: normalizedScope.agentId,\n1078:     limit,\n1079:     mode,\n1080:     tier,\n1081:     contextType,\n1082:     useDecay,\n1083:     includeArchived,\n1084:     qualityThreshold,\n1085:     applyStateLimits,\n1086:     includeContiguity,\n1087:     includeConstitutional,\n1088:     includeContent,\n1089:     anchors,\n1090:     detectedIntent,\n1091:     adaptiveFusionIntent,\n1092:     minState: minState ?? '',\n1093:     rerank,\n1094:     applyLengthPenalty,\n1095:     sessionId,\n1096:     enableSessionBoost,\n1097:     enableCausalBoost,\n1098:     includeTrace,\n1099:     cacheVersion: CANONICAL_READER_CACHE_VERSION,\n1100:     causalEdgesGeneration: causalEdgesGenerationForCache,\n1101:   });\n1102: \n1103:   let _evalChannelPayloads: EvalChannelPayload[] = [];\n1104:   const cacheKey = toolCache.generateCacheKey('memory_search', cacheArgs);\n1105:   const cacheEnabled = toolCache.isEnabled() && !bypassCache;\n1106:   const cachedPayload = cacheEnabled\n1107:     ? toolCache.get<SearchCachePayload>(cacheKey)\n1108:     : null;\n1109: \n1110:   let responseToReturn: MCPResponse;\n1111:   let goalRefinementPayload: Record<string, unknown> | null = null;\n1112: \n1113:   if (cachedPayload) {\n1114:     responseToReturn = buildSearchResponseFromPayload(cachedPayload, _searchStartTime, true);\n1115:   } else {\n1116:     // V2 pipeline is the only path (legacy V1 removed from the runtime pipeline)\n1117:     const pipelineConfig: PipelineConfig = {\n1118:       query: effectiveQuery,\n1119:       concepts: hasValidConcepts ? concepts : undefined,\n1120:       searchType: (hasValidConcepts && concepts!.length >= 2)\n1121:         ? 'multi-concept'\n1122:         : 'hybrid',\n1123:       mode,\n1124:       limit,\n1125:       specFolder,\n1126:       tenantId: normalizedScope.tenantId,\n1127:       userId: normalizedScope.userId,\n1128:       agentId: normalizedScope.agentId,\n1129:       tier,\n1130:       contextType,\n1131:       includeArchived,\n1132:       includeConstitutional,\n1133:       includeContent,\n1134:       anchors,\n1135:       qualityThreshold,\n1136:       minState: minState ?? '',\n1137:       applyStateLimits,\n1138:       useDecay,\n1139:       rerank,\n1140:       applyLengthPenalty,\n1141:       sessionId,\n1142:       enableDedup,\n1143:       enableSessionBoost,\n1144:       enableCausalBoost,\n1145:       trackAccess,\n1146:       detectedIntent,\n1147:       adaptiveFusionIntent,\n1148:       intentConfidence,\n1149:       intentWeights: toIntentWeightsConfig(intentWeights),\n1150:       artifactRouting: artifactRouting as unknown as PipelineConfig['artifactRouting'],\n1151:       queryPlan,\n1152:       trace,\n1153:     };\n1154: \n1155:     const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n1156:     let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n1157: \n1158:     // Community search fallback — inject community members on weak results\n1159:     let communityFallbackApplied = false;\n\n(Showing lines 780-1159 of 1788. Use offset=1160 to continue.)\n</content>","metadata":{"preview":"/** Handle memory_search tool — performs hybrid vector/BM25 search with intent-aware ranking.\n * @param args - Search arguments (query, concepts, mode, specFolder, etc.)\n * @returns MCP response with ranked search results\n */\nasync function handleMemorySearch(args: SearchArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_search');\n  const _searchStartTime = Date.now();\n  resetLastLexicalCapabilitySnapshot();\n  // Check for external database updates before processing\n  await checkDatabaseUpdated();\n\n  const {\n    cursor,\n    query,\n    concepts,\n    specFolder,\n    folderBoost,\n    tenantId,\n    userId,\n    agentId,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"/** Handle memory_search tool — performs hybrid vector/BM25 search with intent-aware ranking.\n * @param args - Search arguments (query, concepts, mode, specFolder, etc.)\n * @returns MCP response with ranked search results\n */\nasync function handleMemorySearch(args: SearchArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_search');\n  const _searchStartTime = Date.now();\n  resetLastLexicalCapabilitySnapshot();\n  // Check for external database updates before processing\n  await checkDatabaseUpdated();\n\n  const {\n    cursor,\n    query,\n    concepts,\n    specFolder,\n    folderBoost,\n    tenantId,\n    userId,\n    agentId,\n    limit: rawLimit = 10,\n    tier,\n    contextType,\n    useDecay: useDecay = true,\n    includeContiguity: includeContiguity = false,\n    includeConstitutional: includeConstitutional = true,\n    includeContent: includeContent = false,\n    anchors,\n    bypassCache: bypassCache = false,\n    sessionId: rawSessionId,\n    enableDedup: enableDedup = true,\n    intent: explicitIntent,\n    autoDetectIntent: autoDetectIntent = true,\n    minState,  // No default — memoryState column not yet in schema; defaulting to 'WARM' filters all rows\n    applyStateLimits: applyStateLimits = false,\n    rerank = true, // Enable reranking by default for better result quality\n    applyLengthPenalty: applyLengthPenalty = true,\n    trackAccess: trackAccess = false, // opt-in, off by default\n    includeArchived: includeArchivedRequested = false, // compatibility-only after Gate B cleanup\n    enableSessionBoost: enableSessionBoost = isSessionBoostEnabled(),\n    enableCausalBoost: enableCausalBoost = isCausalBoostEnabled(),\n    minQualityScore,\n    min_quality_score,\n    mode,\n    includeTrace: includeTraceArg = false,\n    sessionTransition,\n    profile,\n    retrievalLevel: retrievalLevel = 'auto',\n  } = args;\n  const includeTraceByFlag = process.env.SPECKIT_RESPONSE_TRACE === 'true';\n  const includeTrace = includeTraceByFlag || includeTraceArg === true;\n  const includeArchived = false;\n\n  // Validate any caller-supplied sessionId through the server-side session\n  // manager to prevent IDOR: a caller must not read or mutate another\n  // session's sent-memory dedup state by forging an arbitrary session id.\n  // Omitting sessionId stays unchanged (downstream treats it as no-session).\n  let sessionId: string | undefined = rawSessionId;\n  if (rawSessionId) {\n    const trustedSession = sessionManager.resolveTrustedSession(rawSessionId, {\n      tenantId,\n      userId,\n      agentId,\n    });\n    if (trustedSession.error) {\n      return createMCPErrorResponse({\n        tool: 'memory_search',\n        error: trustedSession.error,\n        code: 'E_SESSION_SCOPE',\n        details: { requestedSessionId: rawSessionId },\n        recovery: {\n          hint: 'Omit sessionId to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.',\n        },\n      });\n    }\n    sessionId = trustedSession.effectiveSessionId;\n  }\n\n  const normalizedScope = normalizeScopeContext({ tenantId, userId, agentId, sessionId });\n  const progressiveScopeKey = JSON.stringify({\n    tenantId: normalizedScope.tenantId ?? null,\n    userId: normalizedScope.userId ?? null,\n    agentId: normalizedScope.agentId ?? null,\n    sessionId: normalizedScope.sessionId ?? null,\n  });\n\n  // Validate at least one search input is provided (moved from schema superRefine for GPT compatibility)\n  const hasCursor = typeof cursor === 'string' && cursor.trim().length > 0;\n  const hasQuery = typeof query === 'string' && query.trim().length > 0;\n  const hasConcepts = Array.isArray(concepts) && concepts.length >= 2;\n  if (!hasCursor && !hasQuery && !hasConcepts) {\n    return { content: [{ type: 'text', text: JSON.stringify({ error: 'Either \"query\" (string), \"concepts\" (array with 2-5 items), or \"cursor\" (string) is required.' }) }] };\n  }\n\n  if (hasCursor) {\n    const resolved = resolveCursor(cursor.trim(), undefined, { scopeKey: progressiveScopeKey });\n    if (!resolved) {\n      return createMCPErrorResponse({\n        tool: 'memory_search',\n        error: 'Cursor is invalid, expired, or out of scope',\n        code: 'E_VALIDATION',\n        details: { parameter: 'cursor' },\n        recovery: {\n          hint: 'Retry the original search to generate a fresh continuation cursor',\n        },\n      });\n    }\n\n    const snippetResults = extractSnippets(resolved.results);\n    return createMCPSuccessResponse({\n      tool: 'memory_search',\n      summary: `Returned ${snippetResults.length} continuation results`,\n      data: {\n        count: snippetResults.length,\n        results: snippetResults,\n        continuation: resolved.continuation,\n      },\n      startTime: _searchStartTime,\n      cacheHit: false,\n    });\n  }\n\n  const qualityThreshold = resolveQualityThreshold(minQualityScore, min_quality_score);\n\n  // Validate numeric limit parameter\n  const limit = (typeof rawLimit === 'number' && Number.isFinite(rawLimit) && rawLimit > 0)\n    ? Math.min(Math.floor(rawLimit), 100)\n    : 10;\n\n  // Validate query first with proper error handling\n  let normalizedQuery: string | null = null;\n  if (query !== undefined) {\n    try {\n      normalizedQuery = validateQuery(query);\n    } catch (validationError: unknown) {\n      if (!concepts || !Array.isArray(concepts) || concepts.length < 2) {\n        const message = toErrorMessage(validationError);\n        return createMCPErrorResponse({\n          tool: 'memory_search',\n          error: message,\n          code: 'E_VALIDATION',\n          details: { parameter: 'query' },\n          recovery: {\n            hint: 'Provide a valid query string or use concepts array instead'\n          }\n        });\n      }\n      normalizedQuery = null;\n    }\n  }\n\n  const hasValidQuery = normalizedQuery !== null;\n  const hasValidConcepts = Array.isArray(concepts) && concepts.length >= 2;\n  const effectiveQuery = normalizedQuery ?? (hasValidConcepts ? concepts.join(', ') : '');\n  const searchDecisionRequestId = `memory_search-${_searchStartTime}`;\n  let searchDecisionEnvelope: SearchDecisionEnvelope | null = null;\n\n  if (!hasValidQuery && !hasValidConcepts) {\n    return createMCPErrorResponse({\n      tool: 'memory_search',\n      error: 'Either query (string), concepts (array of 2-5 strings), or cursor (string) is required',\n      code: 'E_VALIDATION',\n      details: { parameter: 'query' },\n      recovery: {\n        hint: 'Provide a query string, concepts array with 2-5 entries, or a continuation cursor'\n      }\n    });\n  }\n\n  if (specFolder !== undefined && typeof specFolder !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_search',\n      error: 'specFolder must be a string',\n      code: 'E_VALIDATION',\n      details: { parameter: 'specFolder' },\n      recovery: {\n        hint: 'Provide specFolder as a string path'\n      }\n    });\n  }\n\n  // Eval logger — capture query at pipeline entry (fail-safe)\n  let _evalQueryId = 0;\n  let _evalRunId = 0;\n  try {\n    const evalEntry = logSearchQuery({\n      query: effectiveQuery,\n      intent: explicitIntent ?? null,\n      specFolder: specFolder ?? null,\n    });\n    _evalQueryId = evalEntry.queryId;\n    _evalRunId = evalEntry.evalRunId;\n  } catch (_error: unknown) { /* eval logging must never break search */ }\n\n  const artifactRoutingQuery = resolveArtifactRoutingQuery(\n    normalizedQuery,\n    hasValidConcepts ? concepts : undefined\n  );\n  let artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder);\n  let queryPlan: QueryPlan;\n  try {\n    queryPlan = routeQuery(effectiveQuery).queryPlan;\n  } catch (_error: unknown) {\n    queryPlan = createEmptyQueryPlan({\n      complexity: 'unknown',\n      selectedChannels: ['vector', 'fts', 'bm25', 'graph', 'degree'],\n      fallbackPolicy: {\n        mode: 'telemetry_only',\n        reason: 'QueryPlan telemetry fallback after routeQuery failure',\n      },\n    });\n  }\n\n  // Intent-aware retrieval\n  let detectedIntent: string | null = null;\n  let intentConfidence = 0;\n  let intentWeights: IntentWeights | null = null;\n\n  if (explicitIntent) {\n    if (intentClassifier.isValidIntent(explicitIntent)) {\n      detectedIntent = explicitIntent;\n      intentConfidence = 1.0;\n      intentWeights = intentClassifier.getIntentWeights(explicitIntent);\n    } else {\n      console.warn(`[memory-search] Invalid intent '${explicitIntent}', using auto-detection`);\n    }\n  }\n\n  if (!detectedIntent && autoDetectIntent && hasValidQuery) {\n    const classification: IntentClassification = intentClassifier.classifyIntent(normalizedQuery!);\n    detectedIntent = classification.intent;\n    intentConfidence = classification.confidence;\n    intentWeights = intentClassifier.getIntentWeights(classification.intent as IntentType);\n\n    if (classification.fallback) {\n      console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (fallback: ${classification.reason})`);\n    } else {\n      console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (confidence: ${intentConfidence.toFixed(2)})`);\n    }\n  }\n\n  // FIX RC3-B: Intent confidence floor — override low-confidence auto-detections to \"understand\"\n  const INTENT_CONFIDENCE_FLOOR = parseFloat(process.env.SPECKIT_INTENT_CONFIDENCE_FLOOR || '0.25');\n  if (detectedIntent && intentConfidence < INTENT_CONFIDENCE_FLOOR && !explicitIntent) {\n    console.error(`[memory-search] Intent confidence ${intentConfidence.toFixed(3)} below floor ${INTENT_CONFIDENCE_FLOOR}, overriding '${detectedIntent}' → 'understand'`);\n    detectedIntent = 'understand';\n    intentConfidence = 1.0;\n    intentWeights = intentClassifier.getIntentWeights('understand' as IntentType);\n  }\n\n  // Phase C: Intent-to-profile auto-routing.\n  // Explicit caller `profile` always takes precedence; auto-detect fills in when absent.\n  let effectiveProfile: string | undefined = profile;\n  if (!effectiveProfile && detectedIntent && isIntentAutoProfileEnabled()) {\n    try {\n      const autoProfile = intentClassifier.getProfileForIntent(detectedIntent as IntentType);\n      if (autoProfile) {\n        effectiveProfile = autoProfile;\n        console.error(`[memory-search] Intent-to-profile auto-routing: '${detectedIntent}' → profile '${autoProfile}'`);\n      }\n    } catch (_autoProfileErr: unknown) {\n      // Auto-profile is best-effort — never breaks search\n    }\n  }\n  const adaptiveFusionIntent = effectiveProfile === 'resume'\n    ? 'continuity'\n    : detectedIntent;\n\n  // Re-run artifact routing with detected intent for fallback coverage\n  if (detectedIntent && artifactRouting?.detectedClass === 'unknown' && artifactRouting?.confidence === 0) {\n    artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder, detectedIntent);\n  }\n\n  // Create retrieval trace at pipeline entry\n  const trace = createTrace(\n    effectiveQuery,\n    sessionId,\n    detectedIntent || undefined\n  );\n\n  // When causal boost is enabled, fold the causal-edges generation\n  // counter into the cache key so causal-edge mutations naturally invalidate\n  // the affected memory_search entries on the next lookup. We deliberately\n  // keep the generation OFF the key when the caller has not opted into causal\n  // boost — otherwise unrelated callers would suffer needless cache misses.\n  const causalEdgesGenerationForCache = enableCausalBoost\n    ? causalEdges.getCausalEdgesGeneration()\n    : undefined;\n\n  // Build cache key args\n  const cacheArgs = buildCacheArgs({\n    normalizedQuery,\n    hasValidConcepts,\n    concepts,\n    specFolder,\n    tenantId: normalizedScope.tenantId,\n    userId: normalizedScope.userId,\n    agentId: normalizedScope.agentId,\n    limit,\n    mode,\n    tier,\n    contextType,\n    useDecay,\n    includeArchived,\n    qualityThreshold,\n    applyStateLimits,\n    includeContiguity,\n    includeConstitutional,\n    includeContent,\n    anchors,\n    detectedIntent,\n    adaptiveFusionIntent,\n    minState: minState ?? '',\n    rerank,\n    applyLengthPenalty,\n    sessionId,\n    enableSessionBoost,\n    enableCausalBoost,\n    includeTrace,\n    cacheVersion: CANONICAL_READER_CACHE_VERSION,\n    causalEdgesGeneration: causalEdgesGenerationForCache,\n  });\n\n  let _evalChannelPayloads: EvalChannelPayload[] = [];\n  const cacheKey = toolCache.generateCacheKey('memory_search', cacheArgs);\n  const cacheEnabled = toolCache.isEnabled() && !bypassCache;\n  const cachedPayload = cacheEnabled\n    ? toolCache.get<SearchCachePayload>(cacheKey)\n    : null;\n\n  let responseToReturn: MCPResponse;\n  let goalRefinementPayload: Record<string, unknown> | null = null;\n\n  if (cachedPayload) {\n    responseToReturn = buildSearchResponseFromPayload(cachedPayload, _searchStartTime, true);\n  } else {\n    // V2 pipeline is the only path (legacy V1 removed from the runtime pipeline)\n    const pipelineConfig: PipelineConfig = {\n      query: effectiveQuery,\n      concepts: hasValidConcepts ? concepts : undefined,\n      searchType: (hasValidConcepts && concepts!.length >= 2)\n        ? 'multi-concept'\n        : 'hybrid',\n      mode,\n      limit,\n      specFolder,\n      tenantId: normalizedScope.tenantId,\n      userId: normalizedScope.userId,\n      agentId: normalizedScope.agentId,\n      tier,\n      contextType,\n      includeArchived,\n      includeConstitutional,\n      includeContent,\n      anchors,\n      qualityThreshold,\n      minState: minState ?? '',\n      applyStateLimits,\n      useDecay,\n      rerank,\n      applyLengthPenalty,\n      sessionId,\n      enableDedup,\n      enableSessionBoost,\n      enableCausalBoost,\n      trackAccess,\n      detectedIntent,\n      adaptiveFusionIntent,\n      intentConfidence,\n      intentWeights: toIntentWeightsConfig(intentWeights),\n      artifactRouting: artifactRouting as unknown as PipelineConfig['artifactRouting'],\n      queryPlan,\n      trace,\n    };\n\n    const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n    let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n\n    // Community search fallback — inject community members on weak results\n    let communityFallbackApplied = false;","lineStart":780,"lineEnd":1159,"totalLines":1788,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781764158656,"end":1781764158670}},"metadata":{"openai":{"itemId":"fc_06a6ceb9babd4f72016a33903e39f88191b056cb1b6a98ff16"}},"id":"prt_ed96b74a6001jthyQrVpDBpJXO","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b4d52001fPF5m5pgFcGFHj"}}
{"type":"tool_use","timestamp":1781764158679,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_idF3ToZSER3mQPKChvtZP6Nk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","offset":120,"limit":110},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts</path>\n<type>file</type>\n<content>\n120:   });\n121: }\n122: \n123: /**\n124:  * Resolve the quality threshold from camelCase or snake_case parameter.\n125:  */\n126: function resolveQualityThreshold(minQualityScore?: number, minQualityScoreSnake?: number): number | undefined {\n127:   if (typeof minQualityScore === 'number' && Number.isFinite(minQualityScore)) {\n128:     return minQualityScore;\n129:   }\n130: \n131:   if (typeof minQualityScoreSnake === 'number' && Number.isFinite(minQualityScoreSnake)) {\n132:     return minQualityScoreSnake;\n133:   }\n134: \n135:   return undefined;\n136: }\n137: \n138: /**\n139:  * Build a cache key arguments object from search parameters.\n140:  */\n141: function buildCacheArgs({\n142:   normalizedQuery,\n143:   hasValidConcepts,\n144:   concepts,\n145:   specFolder,\n146:   tenantId,\n147:   userId,\n148:   agentId,\n149:   limit,\n150:   mode,\n151:   tier,\n152:   contextType,\n153:   useDecay,\n154:   includeArchived,\n155:   qualityThreshold,\n156:   applyStateLimits,\n157:   includeContiguity,\n158:   includeConstitutional,\n159:   includeContent,\n160:   anchors,\n161:   detectedIntent,\n162:   adaptiveFusionIntent,\n163:   minState,\n164:   rerank,\n165:   applyLengthPenalty,\n166:   sessionId,\n167:   enableSessionBoost,\n168:   enableCausalBoost,\n169:   includeTrace = false,\n170:   cacheVersion,\n171:   causalEdgesGeneration,\n172: }: CacheArgsInput): Record<string, unknown> {\n173:   const resolvedFusionIntent = resolveFusionIntentContract({\n174:     detectedIntent,\n175:     adaptiveFusionIntent,\n176:     query: normalizedQuery,\n177:   });\n178:   // Only include causal-edges generation in the cache key when the\n179:   // caller has actually opted into causal boost; otherwise cache keys remain\n180:   // stable for callers that do not consume the causal graph.\n181:   const includeCausalGeneration = enableCausalBoost === true\n182:     && typeof causalEdgesGeneration === 'number'\n183:     && Number.isFinite(causalEdgesGeneration);\n184:   return {\n185:     query: normalizedQuery,\n186:     concepts: hasValidConcepts ? concepts : undefined,\n187:     specFolder,\n188:     tenantId,\n189:     userId,\n190:     agentId,\n191:     limit,\n192:     mode,\n193:     tier,\n194:     contextType,\n195:     useDecay,\n196:     includeArchived,\n197:     qualityThreshold,\n198:     applyStateLimits,\n199:     includeContiguity,\n200:     includeConstitutional,\n201:     includeContent,\n202:     anchors,\n203:     intent: resolvedFusionIntent ?? detectedIntent,\n204:     fusionIntent: resolvedFusionIntent,\n205:     minState,\n206:     rerank,\n207:     applyLengthPenalty,\n208:     sessionId,\n209:     enableSessionBoost,\n210:     enableCausalBoost,\n211:     includeTrace,\n212:     cacheVersion,\n213:     causalEdgesGeneration: includeCausalGeneration ? causalEdgesGeneration : undefined,\n214:   };\n215: }\n216: \n217: /**\n218:  * Resolve the best available query string for artifact routing.\n219:  * Falls back to joining concepts if no query string is provided.\n220:  */\n221: function resolveArtifactRoutingQuery(query: string | null, concepts?: string[]): string {\n222:   if (typeof query === 'string' && query.trim().length > 0) {\n223:     return query;\n224:   }\n225: \n226:   if (Array.isArray(concepts) && concepts.length > 0) {\n227:     return concepts.join(' ');\n228:   }\n229: \n\n(Showing lines 120-229 of 266. Use offset=230 to continue.)\n</content>","metadata":{"preview":"  });\n}\n\n/**\n * Resolve the quality threshold from camelCase or snake_case parameter.\n */\nfunction resolveQualityThreshold(minQualityScore?: number, minQualityScoreSnake?: number): number | undefined {\n  if (typeof minQualityScore === 'number' && Number.isFinite(minQualityScore)) {\n    return minQualityScore;\n  }\n\n  if (typeof minQualityScoreSnake === 'number' && Number.isFinite(minQualityScoreSnake)) {\n    return minQualityScoreSnake;\n  }\n\n  return undefined;\n}\n\n/**\n * Build a cache key arguments object from search parameters.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","text":"  });\n}\n\n/**\n * Resolve the quality threshold from camelCase or snake_case parameter.\n */\nfunction resolveQualityThreshold(minQualityScore?: number, minQualityScoreSnake?: number): number | undefined {\n  if (typeof minQualityScore === 'number' && Number.isFinite(minQualityScore)) {\n    return minQualityScore;\n  }\n\n  if (typeof minQualityScoreSnake === 'number' && Number.isFinite(minQualityScoreSnake)) {\n    return minQualityScoreSnake;\n  }\n\n  return undefined;\n}\n\n/**\n * Build a cache key arguments object from search parameters.\n */\nfunction buildCacheArgs({\n  normalizedQuery,\n  hasValidConcepts,\n  concepts,\n  specFolder,\n  tenantId,\n  userId,\n  agentId,\n  limit,\n  mode,\n  tier,\n  contextType,\n  useDecay,\n  includeArchived,\n  qualityThreshold,\n  applyStateLimits,\n  includeContiguity,\n  includeConstitutional,\n  includeContent,\n  anchors,\n  detectedIntent,\n  adaptiveFusionIntent,\n  minState,\n  rerank,\n  applyLengthPenalty,\n  sessionId,\n  enableSessionBoost,\n  enableCausalBoost,\n  includeTrace = false,\n  cacheVersion,\n  causalEdgesGeneration,\n}: CacheArgsInput): Record<string, unknown> {\n  const resolvedFusionIntent = resolveFusionIntentContract({\n    detectedIntent,\n    adaptiveFusionIntent,\n    query: normalizedQuery,\n  });\n  // Only include causal-edges generation in the cache key when the\n  // caller has actually opted into causal boost; otherwise cache keys remain\n  // stable for callers that do not consume the causal graph.\n  const includeCausalGeneration = enableCausalBoost === true\n    && typeof causalEdgesGeneration === 'number'\n    && Number.isFinite(causalEdgesGeneration);\n  return {\n    query: normalizedQuery,\n    concepts: hasValidConcepts ? concepts : undefined,\n    specFolder,\n    tenantId,\n    userId,\n    agentId,\n    limit,\n    mode,\n    tier,\n    contextType,\n    useDecay,\n    includeArchived,\n    qualityThreshold,\n    applyStateLimits,\n    includeContiguity,\n    includeConstitutional,\n    includeContent,\n    anchors,\n    intent: resolvedFusionIntent ?? detectedIntent,\n    fusionIntent: resolvedFusionIntent,\n    minState,\n    rerank,\n    applyLengthPenalty,\n    sessionId,\n    enableSessionBoost,\n    enableCausalBoost,\n    includeTrace,\n    cacheVersion,\n    causalEdgesGeneration: includeCausalGeneration ? causalEdgesGeneration : undefined,\n  };\n}\n\n/**\n * Resolve the best available query string for artifact routing.\n * Falls back to joining concepts if no query string is provided.\n */\nfunction resolveArtifactRoutingQuery(query: string | null, concepts?: string[]): string {\n  if (typeof query === 'string' && query.trim().length > 0) {\n    return query;\n  }\n\n  if (Array.isArray(concepts) && concepts.length > 0) {\n    return concepts.join(' ');\n  }\n","lineStart":120,"lineEnd":229,"totalLines":266,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","time":{"start":1781764158663,"end":1781764158678}},"metadata":{"openai":{"itemId":"fc_06a6ceb9babd4f72016a33903e3a048191a4211fa3625cae2c"}},"id":"prt_ed96b74c5001RbSrXqEEPf1FQW","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b4d52001fPF5m5pgFcGFHj"}}
{"type":"tool_use","timestamp":1781764158680,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_4DaknItqvQR5mvrEXuMwcyCc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","offset":630,"limit":60},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts</path>\n<type>file</type>\n<content>\n630:  * (a stable sort, so ties keep their fused RRF order). RRF fusion stays the\n631:  * ordering baseline; only the head is rebalanced toward the strongest absolute\n632:  * semantic signal, which matters now that downstream consumers treat position 1\n633:  * as decisive. Near-zero latency and no model/LLM involved — a pure reorder.\n634:  * Default: TRUE (graduated, low-risk lift). Set SPECKIT_COSINE_TOPN_REORDER=false to disable.\n635:  */\n636: export function isCosineTopnReorderEnabled(): boolean {\n637:   return isFeatureEnabled('SPECKIT_COSINE_TOPN_REORDER');\n638: }\n639: \n640: /** Filesystem path to a fitted CalibrationModel JSON, or undefined when unset. */\n641: export function getConfidenceCalibrationModelPath(): string | undefined {\n642:   const raw = process.env.SPECKIT_CONFIDENCE_CALIBRATION_MODEL?.trim();\n643:   return raw && raw.length > 0 ? raw : undefined;\n644: }\n645: \n646: /**\n647:  * Include archived/cold (deprecated-tier) memories in retrieval for everyone,\n648:  * instead of hard-excluding them. The FSRS temperature system already ranks\n649:  * memories by retrievability (deprecated decays at 0.25x → coldest), so a hard\n650:  * exclusion is redundant and hides legitimately-cold-but-relevant history (e.g.\n651:  * z_archive specs). Cold rows are included and naturally rank below hot ones.\n652:  * Applies to the query-time channels (lexical FTS/BM25, trigger); the vector lane\n653:  * filters via the active_memory_projection and is included separately when that\n654:  * projection is rebuilt. Constitutional rows stay on their own injected path.\n655:  * Default: TRUE (graduated). Set SPECKIT_INCLUDE_ARCHIVED_DEFAULT=false to restore\n656:  * the hard exclusion.\n657:  */\n658: export function isArchivedRetrievalIncludedByDefault(): boolean {\n659:   return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_DEFAULT');\n660: }\n661: \n662: /**\n663:  * Extend cold/archived (deprecated-tier) inclusion to the VECTOR (semantic) lane.\n664:  * The vector lane joins `active_memory_projection`, which holds one active row per\n665:  * logical key, so cold rows are admitted to the projection (option A: only rows\n666:  * whose logical key has no active winner) by a boot-time backfill, and the\n667:  * query-time deprecated filter is relaxed. Graduated to default ON alongside the\n668:  * other cold-tier channels; the backfill is idempotent and preserves the\n669:  * one-active-per-key UNIQUE invariant. Set SPECKIT_INCLUDE_ARCHIVED_VECTOR=false\n670:  * to restore the vector-lane exclusion.\n671:  */\n672: export function isArchivedVectorInclusionEnabled(): boolean {\n673:   return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_VECTOR');\n674: }\n675: \n676: /**\n677:  * Weekly batch feedback learning pipeline.\n678:  * Default: TRUE (graduated). Set SPECKIT_BATCH_LEARNED_FEEDBACK=false to disable.\n679:  */\n680: export function isBatchLearnedFeedbackEnabled(): boolean {\n681:   return isFeatureEnabled('SPECKIT_BATCH_LEARNED_FEEDBACK');\n682: }\n683: \n684: /**\n685:  * Assistive reconsolidation for near-duplicate detection.\n686:  * Default: TRUE (graduated). Set SPECKIT_ASSISTIVE_RECONSOLIDATION=false to disable.\n687:  */\n688: export function isAssistiveReconsolidationEnabled(): boolean {\n689:   return isFeatureEnabled('SPECKIT_ASSISTIVE_RECONSOLIDATION');\n\n(Showing lines 630-689 of 800. Use offset=690 to continue.)\n</content>","metadata":{"preview":" * (a stable sort, so ties keep their fused RRF order). RRF fusion stays the\n * ordering baseline; only the head is rebalanced toward the strongest absolute\n * semantic signal, which matters now that downstream consumers treat position 1\n * as decisive. Near-zero latency and no model/LLM involved — a pure reorder.\n * Default: TRUE (graduated, low-risk lift). Set SPECKIT_COSINE_TOPN_REORDER=false to disable.\n */\nexport function isCosineTopnReorderEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COSINE_TOPN_REORDER');\n}\n\n/** Filesystem path to a fitted CalibrationModel JSON, or undefined when unset. */\nexport function getConfidenceCalibrationModelPath(): string | undefined {\n  const raw = process.env.SPECKIT_CONFIDENCE_CALIBRATION_MODEL?.trim();\n  return raw && raw.length > 0 ? raw : undefined;\n}\n\n/**\n * Include archived/cold (deprecated-tier) memories in retrieval for everyone,\n * instead of hard-excluding them. The FSRS temperature system already ranks\n * memories by retrievability (deprecated decays at 0.25x → coldest), so a hard","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","text":" * (a stable sort, so ties keep their fused RRF order). RRF fusion stays the\n * ordering baseline; only the head is rebalanced toward the strongest absolute\n * semantic signal, which matters now that downstream consumers treat position 1\n * as decisive. Near-zero latency and no model/LLM involved — a pure reorder.\n * Default: TRUE (graduated, low-risk lift). Set SPECKIT_COSINE_TOPN_REORDER=false to disable.\n */\nexport function isCosineTopnReorderEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COSINE_TOPN_REORDER');\n}\n\n/** Filesystem path to a fitted CalibrationModel JSON, or undefined when unset. */\nexport function getConfidenceCalibrationModelPath(): string | undefined {\n  const raw = process.env.SPECKIT_CONFIDENCE_CALIBRATION_MODEL?.trim();\n  return raw && raw.length > 0 ? raw : undefined;\n}\n\n/**\n * Include archived/cold (deprecated-tier) memories in retrieval for everyone,\n * instead of hard-excluding them. The FSRS temperature system already ranks\n * memories by retrievability (deprecated decays at 0.25x → coldest), so a hard\n * exclusion is redundant and hides legitimately-cold-but-relevant history (e.g.\n * z_archive specs). Cold rows are included and naturally rank below hot ones.\n * Applies to the query-time channels (lexical FTS/BM25, trigger); the vector lane\n * filters via the active_memory_projection and is included separately when that\n * projection is rebuilt. Constitutional rows stay on their own injected path.\n * Default: TRUE (graduated). Set SPECKIT_INCLUDE_ARCHIVED_DEFAULT=false to restore\n * the hard exclusion.\n */\nexport function isArchivedRetrievalIncludedByDefault(): boolean {\n  return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_DEFAULT');\n}\n\n/**\n * Extend cold/archived (deprecated-tier) inclusion to the VECTOR (semantic) lane.\n * The vector lane joins `active_memory_projection`, which holds one active row per\n * logical key, so cold rows are admitted to the projection (option A: only rows\n * whose logical key has no active winner) by a boot-time backfill, and the\n * query-time deprecated filter is relaxed. Graduated to default ON alongside the\n * other cold-tier channels; the backfill is idempotent and preserves the\n * one-active-per-key UNIQUE invariant. Set SPECKIT_INCLUDE_ARCHIVED_VECTOR=false\n * to restore the vector-lane exclusion.\n */\nexport function isArchivedVectorInclusionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_VECTOR');\n}\n\n/**\n * Weekly batch feedback learning pipeline.\n * Default: TRUE (graduated). Set SPECKIT_BATCH_LEARNED_FEEDBACK=false to disable.\n */\nexport function isBatchLearnedFeedbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_BATCH_LEARNED_FEEDBACK');\n}\n\n/**\n * Assistive reconsolidation for near-duplicate detection.\n * Default: TRUE (graduated). Set SPECKIT_ASSISTIVE_RECONSOLIDATION=false to disable.\n */\nexport function isAssistiveReconsolidationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ASSISTIVE_RECONSOLIDATION');","lineStart":630,"lineEnd":689,"totalLines":800,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","time":{"start":1781764158665,"end":1781764158680}},"metadata":{"openai":{"itemId":"fc_06a6ceb9babd4f72016a33903e3a0c8191b4157a8971261ab7"}},"id":"prt_ed96b74c8001NEbim6UraHHQrx","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b4d52001fPF5m5pgFcGFHj"}}
{"type":"tool_use","timestamp":1781764158682,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_olfMRxIvgdpHHQesXm9MuwX3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Bm25 Index\n3: // ───────────────────────────────────────────────────────────────\n4: import type Database from 'better-sqlite3';\n5: import { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\n6: import {\n7:   normalizeLexicalQueryTokens,\n8:   sanitizeFTS5Query,\n9:   sanitizeQueryTokens,\n10:   simpleStem,\n11:   STOP_WORDS,\n12:   tokenize,\n13: } from './lexical-normalizer.js';\n14: import type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\n15: import { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n16: \n17: // ───────────────────────────────────────────────────────────────\n18: // 1. INTERFACES\n19: \n20: // ───────────────────────────────────────────────────────────────\n21: interface BM25SearchResult {\n22:   id: string;\n23:   /**\n24:    * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n25:    * Higher = better lexical match. Not directly comparable to vector similarity\n26:    * scores; use min-max normalization or RRF when combining with other methods.\n27:    */\n28:   score: number;\n29: }\n30: \n31: interface BM25Stats {\n32:   documentCount: number;\n33:   termCount: number;\n34:   avgDocLength: number;\n35: }\n36: \n37: interface BM25DocumentSource {\n38:   title?: string | null;\n39:   content_text?: string | null;\n40:   trigger_phrases?: string | string[] | null;\n41:   file_path?: string | null;\n42: }\n43: \n44: /* ───────────────────────────────────────────────────────────────\n45:    1B. CONSTANTS & FEATURE FLAG\n46:    ──────────────────────────────────────────────────────────────── */\n47: \n48: const DEFAULT_K1 = 1.2;\n49: const DEFAULT_B = 0.75;\n50: const BM25_WARMUP_BATCH_SIZE = 250;\n51: const PACKED_POSTING_CHUNK_SIZE = 128;\n52: const PACKED_POSTING_FIELD_WIDTH = 4;\n53: const PACKED_POSTING_MAX_BYTE_TF = 0xff;\n54: const PACKED_POSTING_MAX_NARROW_TF = 0xffff;\n55: const PACKED_POSTING_MAX_NARROW_DOC_ID = 0xffff;\n56: const PACKED_POSTING_MAX_NARROW_TERM_ID = 0xffff;\n57: const PACKED_POSTING_TITLE_OFFSET = 0;\n58: const PACKED_POSTING_TRIGGER_OFFSET = 1;\n59: const PACKED_POSTING_PATH_OFFSET = 2;\n60: const PACKED_POSTING_BODY_OFFSET = 3;\n61: const BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n62: const BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\n63: const BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\n64: type Bm25Engine = typeof BM25_ENGINE_VALUES[number];\n65: type InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\n66: type BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n67: \n68: const BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\n69: const BM25_ENGINE_LOGGED = new Set<string>();\n70: \n71: /**\n72:  * Field weight multipliers for weighted BM25 scoring.\n73:  * When indexing a document composed of multiple fields, multiply\n74:  * each field's token scores by the appropriate weight before\n75:  * accumulating the total document score.\n76:  *\n77:  * These weights are shared by the FTS5 path and the packed in-memory\n78:  * fallback so both lexical lanes preserve the same field-priority intent.\n79:  *\n80:  * title:           10.0 — exact title matches are the strongest signal\n81:  * trigger_phrases:  5.0 — curated keywords next most important\n82:  * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n83:  * body:             1.0 — baseline weight for full body / content_text\n84:  */\n85: const BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n86: \n87: const BM25_FIELD_WEIGHTS: Record<string, number> = {\n88:   title: BM25_FTS5_WEIGHTS[0],\n89:   trigger_phrases: BM25_FTS5_WEIGHTS[1],\n90:   content_generic: BM25_FTS5_WEIGHTS[2],\n91:   body: BM25_FTS5_WEIGHTS[3],\n92: };\n93: \n94: type BM25FieldWeights = Record<BM25FieldName, number>;\n95: \n96: interface BM25DocumentFields {\n97:   title?: string | null;\n98:   trigger_phrases?: string | string[] | null;\n99:   content_generic?: string | null;\n100:   body?: string | null;\n101: }\n102: \n103: interface BM25SearchOptions {\n104:   fieldWeights?: Partial<BM25FieldWeights>;\n105: }\n106: \n107: interface LegacyDocumentRecord {\n108:   tokens: string[];\n109:   termFreq: Map<string, number>;\n110: }\n111: \n112: interface PackedDocumentRecord {\n113:   numericId: number;\n114:   id: string;\n115:   length: number;\n116:   termIds: Uint16Array | Uint32Array;\n117: }\n118: \n119: type PackedFieldTfWidth = 1 | 2 | 4;\n120: \n121: interface PackedPostingStore {\n122:   docIdChunks: Array<Uint16Array | Uint32Array>;\n123:   fieldTfChunks: Array<Uint8Array | Uint16Array | Uint32Array>;\n124:   length: number;\n125:   sorted: boolean;\n126:   wideDocIds: boolean;\n127:   fieldTfWidth: PackedFieldTfWidth;\n128: }\n129: \n130: type PackedPostingMutable = PackedPostingStore;\n131: type PackedPostingList = PackedPostingStore;\n132: \n133: interface PackedPostingEntry {\n134:   docId: number;\n135:   titleTf: number;\n136:   triggerTf: number;\n137:   pathTf: number;\n138:   bodyTf: number;\n139: }\n140: \n141: type Bm25TokenInterns = Map<number, string[]>;\n142: \n143: /**\n144:  * Check whether the in-memory BM25 index is enabled.\n145:  *\n146:  * @returns `true` when BM25 indexing/search is enabled for the current process.\n147:  * @example\n148:  * ```ts\n149:  * if (isBm25Enabled()) {\n150:  *   getIndex();\n151:  * }\n152:  * ```\n153:  */\n154: function isBm25Enabled(): boolean {\n155:   const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n156:   if (!value) return true; // enabled by default\n157:   if (BM25_DISABLED_VALUES.has(value)) return false;\n158:   return BM25_ENABLED_VALUES.has(value);\n159: }\n160: \n161: // ───────────────────────────────────────────────────────────────\n162: // 2. HELPERS\n163: \n164: // ───────────────────────────────────────────────────────────────\n165: /**\n166:  * Count token frequency occurrences for BM25 scoring.\n167:  *\n168:  * @param tokens - Normalized tokens produced by {@link tokenize}.\n169:  * @returns A frequency map keyed by token text.\n170:  * @example\n171:  * ```ts\n172:  * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n173:  * // 2\n174:  * ```\n175:  */\n176: function getTermFrequencies(tokens: string[]): Map<string, number> {\n177:   const freq = new Map<string, number>();\n178:   for (const token of tokens) {\n179:     freq.set(token, (freq.get(token) || 0) + 1);\n180:   }\n181:   return freq;\n182: }\n183: \n184: function stemNormalizedToken(word: string): string {\n185:   let stem = word;\n186:   let suffixRemoved = false;\n187: \n188:   if (stem.endsWith('ing') && stem.length > 5) { stem = stem.slice(0, -3); suffixRemoved = true; }\n189:   else if (stem.endsWith('tion') && stem.length > 6) { stem = stem.slice(0, -4); suffixRemoved = true; }\n190:   else if (stem.endsWith('ed') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n191:   else if (stem.endsWith('ly') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n192:   else if (stem.endsWith('es') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n193:   else if (stem.endsWith('s') && stem.length > 3) { stem = stem.slice(0, -1); suffixRemoved = true; }\n194: \n195:   if (suffixRemoved && stem.length >= 3) {\n196:     const last = stem[stem.length - 1];\n197:     if (last === stem[stem.length - 2] && !/[aeiou]/.test(last)) {\n198:       stem = stem.slice(0, -1);\n199:     }\n200:   }\n201: \n202:   return stem;\n203: }\n204: \n205: function bm25ContentNeedsNormalization(content: string): boolean {\n206:   return (\n207:     content.trim() !== content ||\n208:     content.startsWith('---') ||\n209:     content.includes('<!--') ||\n210:     content.includes('```') ||\n211:     content.includes('|') ||\n212:     /(?:^|\\n)\\s*(?:[-*]\\s+|\\d+\\.\\s+|#{1,6}\\s+)/.test(content) ||\n213:     /\\n{3,}/.test(content)\n214:   );\n215: }\n216: \n217: function normalizeContentForBM25IfNeeded(content: string): string {\n218:   return bm25ContentNeedsNormalization(content) ? normalizeContentForBM25(content) : content;\n219: }\n220: \n\n(Showing lines 1-220 of 1558. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Bm25 Index\n// ───────────────────────────────────────────────────────────────\nimport type Database from 'better-sqlite3';\nimport { normalizeContentForBM25 } from '../parsing/content-normalizer.js';\nimport {\n  normalizeLexicalQueryTokens,\n  sanitizeFTS5Query,\n  sanitizeQueryTokens,\n  simpleStem,\n  STOP_WORDS,\n  tokenize,\n} from './lexical-normalizer.js';\nimport type { NormalizedLexicalQueryTokens } from './lexical-normalizer.js';\nimport { clearRegisteredTimer, registerTimeout } from '../runtime/timer-registry.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface BM25SearchResult {\n  id: string;\n  /**\n   * BM25 term-frequency relevance score (unbounded, typically 0-25+).\n   * Higher = better lexical match. Not directly comparable to vector similarity\n   * scores; use min-max normalization or RRF when combining with other methods.\n   */\n  score: number;\n}\n\ninterface BM25Stats {\n  documentCount: number;\n  termCount: number;\n  avgDocLength: number;\n}\n\ninterface BM25DocumentSource {\n  title?: string | null;\n  content_text?: string | null;\n  trigger_phrases?: string | string[] | null;\n  file_path?: string | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1B. CONSTANTS & FEATURE FLAG\n   ──────────────────────────────────────────────────────────────── */\n\nconst DEFAULT_K1 = 1.2;\nconst DEFAULT_B = 0.75;\nconst BM25_WARMUP_BATCH_SIZE = 250;\nconst PACKED_POSTING_CHUNK_SIZE = 128;\nconst PACKED_POSTING_FIELD_WIDTH = 4;\nconst PACKED_POSTING_MAX_BYTE_TF = 0xff;\nconst PACKED_POSTING_MAX_NARROW_TF = 0xffff;\nconst PACKED_POSTING_MAX_NARROW_DOC_ID = 0xffff;\nconst PACKED_POSTING_MAX_NARROW_TERM_ID = 0xffff;\nconst PACKED_POSTING_TITLE_OFFSET = 0;\nconst PACKED_POSTING_TRIGGER_OFFSET = 1;\nconst PACKED_POSTING_PATH_OFFSET = 2;\nconst PACKED_POSTING_BODY_OFFSET = 3;\nconst BM25_ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\nconst BM25_DISABLED_VALUES = new Set(['0', 'false', 'no', 'off']);\nconst BM25_ENGINE_VALUES = ['auto', 'sqlite', 'packed-inmemory', 'legacy-inmemory'] as const;\ntype Bm25Engine = typeof BM25_ENGINE_VALUES[number];\ntype InMemoryBm25Engine = Extract<Bm25Engine, 'packed-inmemory' | 'legacy-inmemory'>;\ntype BM25FieldName = 'title' | 'trigger_phrases' | 'content_generic' | 'body';\n\nconst BM25_FIELD_NAMES = ['title', 'trigger_phrases', 'content_generic', 'body'] as const;\nconst BM25_ENGINE_LOGGED = new Set<string>();\n\n/**\n * Field weight multipliers for weighted BM25 scoring.\n * When indexing a document composed of multiple fields, multiply\n * each field's token scores by the appropriate weight before\n * accumulating the total document score.\n *\n * These weights are shared by the FTS5 path and the packed in-memory\n * fallback so both lexical lanes preserve the same field-priority intent.\n *\n * title:           10.0 — exact title matches are the strongest signal\n * trigger_phrases:  5.0 — curated keywords next most important\n * content_generic:  2.0 — generic textual content (file_path, tags, etc.)\n * body:             1.0 — baseline weight for full body / content_text\n */\nconst BM25_FTS5_WEIGHTS = [10.0, 5.0, 2.0, 1.0] as const;\n\nconst BM25_FIELD_WEIGHTS: Record<string, number> = {\n  title: BM25_FTS5_WEIGHTS[0],\n  trigger_phrases: BM25_FTS5_WEIGHTS[1],\n  content_generic: BM25_FTS5_WEIGHTS[2],\n  body: BM25_FTS5_WEIGHTS[3],\n};\n\ntype BM25FieldWeights = Record<BM25FieldName, number>;\n\ninterface BM25DocumentFields {\n  title?: string | null;\n  trigger_phrases?: string | string[] | null;\n  content_generic?: string | null;\n  body?: string | null;\n}\n\ninterface BM25SearchOptions {\n  fieldWeights?: Partial<BM25FieldWeights>;\n}\n\ninterface LegacyDocumentRecord {\n  tokens: string[];\n  termFreq: Map<string, number>;\n}\n\ninterface PackedDocumentRecord {\n  numericId: number;\n  id: string;\n  length: number;\n  termIds: Uint16Array | Uint32Array;\n}\n\ntype PackedFieldTfWidth = 1 | 2 | 4;\n\ninterface PackedPostingStore {\n  docIdChunks: Array<Uint16Array | Uint32Array>;\n  fieldTfChunks: Array<Uint8Array | Uint16Array | Uint32Array>;\n  length: number;\n  sorted: boolean;\n  wideDocIds: boolean;\n  fieldTfWidth: PackedFieldTfWidth;\n}\n\ntype PackedPostingMutable = PackedPostingStore;\ntype PackedPostingList = PackedPostingStore;\n\ninterface PackedPostingEntry {\n  docId: number;\n  titleTf: number;\n  triggerTf: number;\n  pathTf: number;\n  bodyTf: number;\n}\n\ntype Bm25TokenInterns = Map<number, string[]>;\n\n/**\n * Check whether the in-memory BM25 index is enabled.\n *\n * @returns `true` when BM25 indexing/search is enabled for the current process.\n * @example\n * ```ts\n * if (isBm25Enabled()) {\n *   getIndex();\n * }\n * ```\n */\nfunction isBm25Enabled(): boolean {\n  const value = process.env.ENABLE_BM25?.trim().toLowerCase();\n  if (!value) return true; // enabled by default\n  if (BM25_DISABLED_VALUES.has(value)) return false;\n  return BM25_ENABLED_VALUES.has(value);\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. HELPERS\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Count token frequency occurrences for BM25 scoring.\n *\n * @param tokens - Normalized tokens produced by {@link tokenize}.\n * @returns A frequency map keyed by token text.\n * @example\n * ```ts\n * getTermFrequencies(['memory', 'memory', 'search']).get('memory');\n * // 2\n * ```\n */\nfunction getTermFrequencies(tokens: string[]): Map<string, number> {\n  const freq = new Map<string, number>();\n  for (const token of tokens) {\n    freq.set(token, (freq.get(token) || 0) + 1);\n  }\n  return freq;\n}\n\nfunction stemNormalizedToken(word: string): string {\n  let stem = word;\n  let suffixRemoved = false;\n\n  if (stem.endsWith('ing') && stem.length > 5) { stem = stem.slice(0, -3); suffixRemoved = true; }\n  else if (stem.endsWith('tion') && stem.length > 6) { stem = stem.slice(0, -4); suffixRemoved = true; }\n  else if (stem.endsWith('ed') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('ly') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('es') && stem.length > 4) { stem = stem.slice(0, -2); suffixRemoved = true; }\n  else if (stem.endsWith('s') && stem.length > 3) { stem = stem.slice(0, -1); suffixRemoved = true; }\n\n  if (suffixRemoved && stem.length >= 3) {\n    const last = stem[stem.length - 1];\n    if (last === stem[stem.length - 2] && !/[aeiou]/.test(last)) {\n      stem = stem.slice(0, -1);\n    }\n  }\n\n  return stem;\n}\n\nfunction bm25ContentNeedsNormalization(content: string): boolean {\n  return (\n    content.trim() !== content ||\n    content.startsWith('---') ||\n    content.includes('<!--') ||\n    content.includes('```') ||\n    content.includes('|') ||\n    /(?:^|\\n)\\s*(?:[-*]\\s+|\\d+\\.\\s+|#{1,6}\\s+)/.test(content) ||\n    /\\n{3,}/.test(content)\n  );\n}\n\nfunction normalizeContentForBM25IfNeeded(content: string): string {\n  return bm25ContentNeedsNormalization(content) ? normalizeContentForBM25(content) : content;\n}\n","lineStart":1,"lineEnd":220,"totalLines":1558,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/bm25-index.ts","time":{"start":1781764158669,"end":1781764158681}},"metadata":{"openai":{"itemId":"fc_06a6ceb9babd4f72016a33903e3a1881919c0fa47952bbfa70"}},"id":"prt_ed96b74cc0012aOzFWy5dHkZjn","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b4d52001fPF5m5pgFcGFHj"}}
{"type":"tool_use","timestamp":1781764158682,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_rFZYGodSBuuBWWLmJlu5XfFV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":350,"limit":110},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n350:  * @param options - Search options.\n351:  * @returns The matching memory rows.\n352:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n353:  * @example\n354:  * ```ts\n355:  * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n356:  * ```\n357:  */\n358: export function vector_search(\n359:   query_embedding: EmbeddingInput,\n360:   options: VectorSearchOptions = {},\n361:   database: Database.Database = initialize_db(),\n362: ): MemoryRow[] {\n363:   const sqlite_vec = get_sqlite_vec_available();\n364:   if (!sqlite_vec) {\n365:     console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n366:     return [];\n367:   }\n368: \n369:   const {\n370:     limit = 10,\n371:     specFolder = null,\n372:     minSimilarity = 0,\n373:     useDecay = true,\n374:     tier = null,\n375:     contextType = null,\n376:     includeConstitutional = true,\n377:     includeArchived = false\n378:   } = options;\n379: \n380:   const vectorSource = getActiveVectorSourceForQuery(database);\n381:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n382:     throw new VectorIndexError(\n383:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n384:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n385:     );\n386:   }\n387: \n388:   const query_buffer = to_embedding_buffer(query_embedding);\n389:   const max_distance = 2 * (1 - minSimilarity / 100);\n390: \n391:   // FSRS-preferred decay with half-life fallback\n392:   const decay_expr = useDecay\n393:     ? `CASE\n394:          WHEN m.is_pinned = 1 THEN m.importance_weight\n395:          WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n396:            m.importance_weight * POWER(\n397:              1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n398:              -0.5\n399:            )\n400:          ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n401:        END`\n402:     : 'm.importance_weight';\n403: \n404:   let constitutional_results: MemoryRow[] = [];\n405: \n406:   if (includeConstitutional && tier !== 'constitutional') {\n407:     constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n408:   }\n409: \n410:   const where_clauses = ['m.embedding_status = \\'success\\''];\n411:   const params: unknown[] = [query_buffer];\n412: \n413:   where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n414: \n415:   if (tier === 'deprecated') {\n416:     where_clauses.push('m.importance_tier = ?');\n417:     params.push('deprecated');\n418:   } else if (tier === 'constitutional') {\n419:     where_clauses.push('m.importance_tier = ?');\n420:     params.push('constitutional');\n421:   } else if (tier) {\n422:     where_clauses.push('m.importance_tier = ?');\n423:     params.push(tier);\n424:   } else if (isArchivedVectorInclusionEnabled()) {\n425:     // Cold/archived rows admitted to the projection (option A) must not be re-excluded\n426:     // here; still keep constitutional on its own injected path.\n427:     where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier != \\'constitutional\\')');\n428:   } else {\n429:     where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n430:   }\n431: \n432:   appendSpecFolderScope(where_clauses, params, specFolder);\n433: \n434:   if (contextType) {\n435:     where_clauses.push('m.context_type = ?');\n436:     params.push(contextType);\n437:   }\n438: \n439:   // If constitutional results already satisfy limit, return them directly.\n440:   if (constitutional_results.length >= limit) {\n441:     return constitutional_results.slice(0, limit);\n442:   }\n443:   const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n444:   params.push(max_distance, adjusted_limit);\n445: \n446:   const sql = `\n447:     SELECT sub.*,\n448:            ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n449:     FROM (\n450:       SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n451:              ${decay_expr} as effective_importance\n452:       FROM memory_index m\n453:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n454:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n455:       WHERE ${where_clauses.join(' AND ')}\n456:     ) sub\n457:     WHERE sub.distance <= ?\n458:     ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n459:     LIMIT ?\n\n(Showing lines 350-459 of 1742. Use offset=460 to continue.)\n</content>","metadata":{"preview":" * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function vector_search(\n  query_embedding: EmbeddingInput,\n  options: VectorSearchOptions = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":" * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function vector_search(\n  query_embedding: EmbeddingInput,\n  options: VectorSearchOptions = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const {\n    limit = 10,\n    specFolder = null,\n    minSimilarity = 0,\n    useDecay = true,\n    tier = null,\n    contextType = null,\n    includeConstitutional = true,\n    includeArchived = false\n  } = options;\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const query_buffer = to_embedding_buffer(query_embedding);\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  // FSRS-preferred decay with half-life fallback\n  const decay_expr = useDecay\n    ? `CASE\n         WHEN m.is_pinned = 1 THEN m.importance_weight\n         WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n           m.importance_weight * POWER(\n             1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n             -0.5\n           )\n         ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n       END`\n    : 'm.importance_weight';\n\n  let constitutional_results: MemoryRow[] = [];\n\n  if (includeConstitutional && tier !== 'constitutional') {\n    constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n  }\n\n  const where_clauses = ['m.embedding_status = \\'success\\''];\n  const params: unknown[] = [query_buffer];\n\n  where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n\n  if (tier === 'deprecated') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('deprecated');\n  } else if (tier === 'constitutional') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('constitutional');\n  } else if (tier) {\n    where_clauses.push('m.importance_tier = ?');\n    params.push(tier);\n  } else if (isArchivedVectorInclusionEnabled()) {\n    // Cold/archived rows admitted to the projection (option A) must not be re-excluded\n    // here; still keep constitutional on its own injected path.\n    where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier != \\'constitutional\\')');\n  } else {\n    where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n  }\n\n  appendSpecFolderScope(where_clauses, params, specFolder);\n\n  if (contextType) {\n    where_clauses.push('m.context_type = ?');\n    params.push(contextType);\n  }\n\n  // If constitutional results already satisfy limit, return them directly.\n  if (constitutional_results.length >= limit) {\n    return constitutional_results.slice(0, limit);\n  }\n  const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n  params.push(max_distance, adjusted_limit);\n\n  const sql = `\n    SELECT sub.*,\n           ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n    FROM (\n      SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n             ${decay_expr} as effective_importance\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE ${where_clauses.join(' AND ')}\n    ) sub\n    WHERE sub.distance <= ?\n    ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n    LIMIT ?","lineStart":350,"lineEnd":459,"totalLines":1742,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781764158667,"end":1781764158682}},"metadata":{"openai":{"itemId":"fc_06a6ceb9babd4f72016a33903e3a1481918a4bd4191fd3d679"}},"id":"prt_ed96b74ca001T2aohP6WKCxPtH","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96b4d52001fPF5m5pgFcGFHj"}}
