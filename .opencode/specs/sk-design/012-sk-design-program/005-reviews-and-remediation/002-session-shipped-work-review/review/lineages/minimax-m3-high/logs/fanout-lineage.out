{"type":"tool_use","timestamp":1784606379905,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d44eff79608eafd867","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/operator.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/operator.mjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ╔══════════════════════════════════════════════════════════════════════════╗\n3: // ║ Persistent Style Database Operator                                       ║\n4: // ╚══════════════════════════════════════════════════════════════════════════╝\n5: \n6: import { existsSync } from 'node:fs';\n7: import { readdir, rm, stat } from 'node:fs/promises';\n8: import path from 'node:path';\n9: import { pathToFileURL } from 'node:url';\n10: \n11: import {\n12:   buildStyleDatabase,\n13:   rollbackStyleDatabase,\n14: } from './indexer.mjs';\n15: import {\n16:   manifestArtifactFiles,\n17:   readManifest,\n18: } from './generation-manifest.mjs';\n19: import {\n20:   DEFAULT_STYLE_DATABASE_PATH,\n21:   STYLE_DATABASE_POINTER_SUFFIX,\n22:   openPublishedStyleDatabase,\n23:   resolvePublishedDatabasePath,\n24: } from './schema.mjs';\n25: import { rebuildVectorProjection } from './vectors.mjs';\n26: \n27: /**\n28:  * Read the published manifest's artifact roles and absolute file paths.\n29:  *\n30:  * @param {string} databasePath - Logical database path.\n31:  * @returns {Promise<{roles:string[], paths:string[]}>} Current-manifest artifacts.\n32:  */\n33: async function currentManifestArtifacts(databasePath) {\n34:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n35:   if (!existsSync(pointerPath)) return { roles: [], paths: [] };\n36:   try {\n37:     const manifest = await readManifest(pointerPath);\n38:     const directory = path.dirname(databasePath);\n39:     return {\n40:       roles: Object.keys(manifest.artifacts).sort(),\n41:       paths: manifestArtifactFiles({ artifacts: manifest.artifacts })\n42:         .map((file) => path.resolve(path.join(directory, file))),\n43:     };\n44:   } catch {\n45:     return { roles: [], paths: [] };\n46:   }\n47: }\n48: \n49: function optionValue(argumentsList, name) {\n50:   const index = argumentsList.indexOf(name);\n51:   return index === -1 ? null : argumentsList[index + 1] ?? null;\n52: }\n53: \n54: function writeJson(value, stream = process.stdout) {\n55:   stream.write(`${JSON.stringify(value, null, 2)}\\n`);\n56: }\n57: \n58: async function listGenerationPaths(databasePath) {\n59:   const directory = path.dirname(databasePath);\n60:   const prefix = `${path.basename(databasePath)}.sha256-`;\n61:   const entries = await readdir(directory, { withFileTypes: true });\n62:   const generations = [];\n63:   for (const entry of entries) {\n64:     if (!entry.isFile() || !entry.name.startsWith(prefix) || !entry.name.endsWith('.sqlite')) {\n65:       continue;\n66:     }\n67:     const generationPath = path.join(directory, entry.name);\n68:     const info = await stat(generationPath);\n69:     generations.push({ path: generationPath, modifiedAt: info.mtimeMs });\n70:   }\n71:   return generations.sort((left, right) => right.modifiedAt - left.modifiedAt\n72:     || left.path.localeCompare(right.path));\n73: }\n74: \n75: /**\n76:  * Report the published generation, rollback candidate, queues, and retained files.\n77:  *\n78:  * @param {Object} [options] - Logical database path.\n79:  * @returns {Promise<Object>} Persistent database status.\n80:  */\n81: export async function getStyleDatabaseStatus(options = {}) {\n82:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n83:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n84:   const generations = await listGenerationPaths(databasePath);\n85:   if (!existsSync(pointerPath)) {\n86:     return {\n87:       ok: true,\n88:       databasePath,\n89:       published: false,\n90:       currentGenerationPath: null,\n91:       rollbackGenerationPath: generations[0]?.path ?? null,\n92:       retainedGenerationPaths: generations.map((entry) => entry.path),\n93:       vectorJobs: {},\n94:     };\n95:   }\n96:   const currentGenerationPath = resolvePublishedDatabasePath(databasePath);\n97:   const manifestArtifacts = await currentManifestArtifacts(databasePath);\n98:   const database = openPublishedStyleDatabase(databasePath);\n99:   try {\n100:     const generationHash = database.prepare(`\n101:       SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n102:     `).get()?.generation_hash ?? null;\n103:     const vectorJobs = Object.fromEntries(database.prepare(`\n104:       SELECT status, COUNT(*) AS count FROM style_vector_jobs GROUP BY status ORDER BY status\n105:     `).all().map((row) => [row.status, Number(row.count)]));\n106:     return {\n107:       ok: true,\n108:       databasePath,\n109:       published: true,\n110:       generationHash,\n111:       currentGenerationPath,\n112:       manifestArtifacts: manifestArtifacts.roles,\n113:       rollbackGenerationPath: generations\n114:         .find((entry) => entry.path !== currentGenerationPath)?.path ?? null,\n115:       retainedGenerationPaths: generations.map((entry) => entry.path),\n116:       vectorJobs,\n117:     };\n118:   } finally {\n119:     database.close();\n120:   }\n121: }\n122: \n123: /**\n124:  * Remove generation files except the published file and one rollback target.\n125:  *\n126:  * @param {Object} options - Logical path and explicit retention set.\n127:  * @returns {Promise<Object>} Kept and removed generation paths.\n128:  */\n129: export async function pruneStyleDatabaseGenerations(options) {\n130:   const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n131:   const currentGenerationPath = options?.currentGenerationPath\n132:     ?? resolvePublishedDatabasePath(databasePath);\n133:   const rollbackGenerationPath = options?.rollbackGenerationPath ?? null;\n134:   const keep = new Set([currentGenerationPath, rollbackGenerationPath]\n135:     .filter(Boolean).map((value) => path.resolve(value)));\n136:   // Protect every artifact the published manifest references, so a generation is\n137:   // retained as a whole unit once it spans more than the SQLite file.\n138:   for (const artifactPath of (await currentManifestArtifacts(databasePath)).paths) {\n139:     keep.add(artifactPath);\n140:   }\n141:   const generations = await listGenerationPaths(databasePath);\n142:   const removed = [];\n143:   for (const generation of generations) {\n144:     if (keep.has(path.resolve(generation.path))) continue;\n145:     await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n146:       rm(`${generation.path}${suffix}`, { force: true })\n147:     )));\n148:     removed.push(generation.path);\n149:   }\n150:   return {\n151:     kept: generations.map((entry) => entry.path)\n152:       .filter((generationPath) => keep.has(path.resolve(generationPath))),\n153:     removed,\n154:   };\n155: }\n156: \n157: async function buildAndRetain(options) {\n158:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n159:   const before = await getStyleDatabaseStatus({ databasePath });\n160:   const result = await buildStyleDatabase({ ...options, databasePath });\n161:   const retention = await pruneStyleDatabaseGenerations({\n162:     databasePath,\n163:     currentGenerationPath: result.generationDatabasePath,\n164:     rollbackGenerationPath: before.currentGenerationPath,\n165:   });\n166:   return { ...result, action: 'build', retention };\n167: }\n168: \n169: async function switchGeneration(action, options) {\n170:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n171:   const before = await getStyleDatabaseStatus({ databasePath });\n172:   const generationDatabasePath = options.generationDatabasePath\n173:     ?? before.rollbackGenerationPath;\n174:   if (!generationDatabasePath) {\n175:     const error = new Error('No retained rollback generation is available.');\n176:     error.code = 'rollback-generation-unavailable';\n177:     throw error;\n178:   }\n179:   const result = await rollbackStyleDatabase({ databasePath, generationDatabasePath });\n180:   const retention = await pruneStyleDatabaseGenerations({\n181:     databasePath,\n182:     currentGenerationPath: generationDatabasePath,\n183:     rollbackGenerationPath: before.currentGenerationPath,\n184:   });\n185:   return { ...result, action, retention };\n186: }\n187: \n188: async function repairVectors(options) {\n189:   if (!options.profileId) {\n190:     const error = new Error('Vector repair requires an embedding profile.');\n191:     error.code = 'invalid-arguments';\n192:     throw error;\n193:   }\n194:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n195:   const database = openPublishedStyleDatabase(databasePath);\n196:   try {\n197:     return {\n198:       ok: true,\n199:       action: 'repair',\n200:       ...rebuildVectorProjection(database, options.profileId),\n201:     };\n202:   } finally {\n203:     database.close();\n204:   }\n205: }\n206: \n207: /**\n208:  * Dispatch the persistent style database operator command surface.\n209:  *\n210:  * @param {string[]} argumentsList - Command and flags.\n211:  * @returns {Promise<Object>} Structured operator result.\n212:  */\n213: export async function runStyleDatabaseOperator(argumentsList = process.argv.slice(2)) {\n214:   const [command, ...commandArguments] = argumentsList;\n215:   const databasePath = optionValue(commandArguments, '--database')\n216:     ?? DEFAULT_STYLE_DATABASE_PATH;\n217:   if (command === 'status') return getStyleDatabaseStatus({ databasePath });\n218:   if (command === 'build') {\n219:     const corpusRoot = optionValue(commandArguments, '--corpus');\n220:     if (!corpusRoot) {\n221:       const error = new Error('Build requires --corpus.');\n222:       error.code = 'invalid-arguments';\n223:       throw error;\n224:     }\n225:     return buildAndRetain({ corpusRoot, databasePath, corpusWalkMode: 'migration' });\n226:   }\n227:   if (command === 'cutover') {\n228:     const generationDatabasePath = optionValue(commandArguments, '--generation');\n229:     if (!generationDatabasePath) {\n230:       const error = new Error('Cutover requires --generation.');\n231:       error.code = 'invalid-arguments';\n232:       throw error;\n233:     }\n234:     return switchGeneration('cutover', { databasePath, generationDatabasePath });\n235:   }\n236:   if (command === 'rollback') {\n237:     return switchGeneration('rollback', {\n238:       databasePath,\n239:       generationDatabasePath: optionValue(commandArguments, '--generation'),\n240:     });\n241:   }\n242:   if (command === 'repair') {\n243:     return repairVectors({\n244:       databasePath,\n245:       profileId: optionValue(commandArguments, '--profile'),\n246:     });\n247:   }\n248:   const error = new Error(\n249:     'Usage: operator.mjs <status|build|cutover|rollback|repair> [options]',\n250:   );\n251:   error.code = 'invalid-arguments';\n252:   throw error;\n253: }\n254: \n255: const isDirectExecution = process.argv[1]\n256:   && import.meta.url === pathToFileURL(path.resolve(process.argv[1])).href;\n257: if (isDirectExecution) {\n258:   try {\n259:     writeJson(await runStyleDatabaseOperator());\n260:   } catch (error) {\n261:     writeJson({\n262:       ok: false,\n263:       error: error.code ?? 'internal-error',\n264:       message: error.message,\n265:     }, process.stderr);\n266:     process.exitCode = 1;\n267:   }\n268: }\n\n(End of file - total 268 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Operator                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { existsSync } from 'node:fs';\nimport { readdir, rm, stat } from 'node:fs/promises';\nimport path from 'node:path';\nimport { pathToFileURL } from 'node:url';\n\nimport {\n  buildStyleDatabase,\n  rollbackStyleDatabase,\n} from './indexer.mjs';\nimport {\n  manifestArtifactFiles,\n  readManifest,\n} from './generation-manifest.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/operator.mjs","text":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Operator                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { existsSync } from 'node:fs';\nimport { readdir, rm, stat } from 'node:fs/promises';\nimport path from 'node:path';\nimport { pathToFileURL } from 'node:url';\n\nimport {\n  buildStyleDatabase,\n  rollbackStyleDatabase,\n} from './indexer.mjs';\nimport {\n  manifestArtifactFiles,\n  readManifest,\n} from './generation-manifest.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,\n  STYLE_DATABASE_POINTER_SUFFIX,\n  openPublishedStyleDatabase,\n  resolvePublishedDatabasePath,\n} from './schema.mjs';\nimport { rebuildVectorProjection } from './vectors.mjs';\n\n/**\n * Read the published manifest's artifact roles and absolute file paths.\n *\n * @param {string} databasePath - Logical database path.\n * @returns {Promise<{roles:string[], paths:string[]}>} Current-manifest artifacts.\n */\nasync function currentManifestArtifacts(databasePath) {\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  if (!existsSync(pointerPath)) return { roles: [], paths: [] };\n  try {\n    const manifest = await readManifest(pointerPath);\n    const directory = path.dirname(databasePath);\n    return {\n      roles: Object.keys(manifest.artifacts).sort(),\n      paths: manifestArtifactFiles({ artifacts: manifest.artifacts })\n        .map((file) => path.resolve(path.join(directory, file))),\n    };\n  } catch {\n    return { roles: [], paths: [] };\n  }\n}\n\nfunction optionValue(argumentsList, name) {\n  const index = argumentsList.indexOf(name);\n  return index === -1 ? null : argumentsList[index + 1] ?? null;\n}\n\nfunction writeJson(value, stream = process.stdout) {\n  stream.write(`${JSON.stringify(value, null, 2)}\\n`);\n}\n\nasync function listGenerationPaths(databasePath) {\n  const directory = path.dirname(databasePath);\n  const prefix = `${path.basename(databasePath)}.sha256-`;\n  const entries = await readdir(directory, { withFileTypes: true });\n  const generations = [];\n  for (const entry of entries) {\n    if (!entry.isFile() || !entry.name.startsWith(prefix) || !entry.name.endsWith('.sqlite')) {\n      continue;\n    }\n    const generationPath = path.join(directory, entry.name);\n    const info = await stat(generationPath);\n    generations.push({ path: generationPath, modifiedAt: info.mtimeMs });\n  }\n  return generations.sort((left, right) => right.modifiedAt - left.modifiedAt\n    || left.path.localeCompare(right.path));\n}\n\n/**\n * Report the published generation, rollback candidate, queues, and retained files.\n *\n * @param {Object} [options] - Logical database path.\n * @returns {Promise<Object>} Persistent database status.\n */\nexport async function getStyleDatabaseStatus(options = {}) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  const generations = await listGenerationPaths(databasePath);\n  if (!existsSync(pointerPath)) {\n    return {\n      ok: true,\n      databasePath,\n      published: false,\n      currentGenerationPath: null,\n      rollbackGenerationPath: generations[0]?.path ?? null,\n      retainedGenerationPaths: generations.map((entry) => entry.path),\n      vectorJobs: {},\n    };\n  }\n  const currentGenerationPath = resolvePublishedDatabasePath(databasePath);\n  const manifestArtifacts = await currentManifestArtifacts(databasePath);\n  const database = openPublishedStyleDatabase(databasePath);\n  try {\n    const generationHash = database.prepare(`\n      SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n    `).get()?.generation_hash ?? null;\n    const vectorJobs = Object.fromEntries(database.prepare(`\n      SELECT status, COUNT(*) AS count FROM style_vector_jobs GROUP BY status ORDER BY status\n    `).all().map((row) => [row.status, Number(row.count)]));\n    return {\n      ok: true,\n      databasePath,\n      published: true,\n      generationHash,\n      currentGenerationPath,\n      manifestArtifacts: manifestArtifacts.roles,\n      rollbackGenerationPath: generations\n        .find((entry) => entry.path !== currentGenerationPath)?.path ?? null,\n      retainedGenerationPaths: generations.map((entry) => entry.path),\n      vectorJobs,\n    };\n  } finally {\n    database.close();\n  }\n}\n\n/**\n * Remove generation files except the published file and one rollback target.\n *\n * @param {Object} options - Logical path and explicit retention set.\n * @returns {Promise<Object>} Kept and removed generation paths.\n */\nexport async function pruneStyleDatabaseGenerations(options) {\n  const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const currentGenerationPath = options?.currentGenerationPath\n    ?? resolvePublishedDatabasePath(databasePath);\n  const rollbackGenerationPath = options?.rollbackGenerationPath ?? null;\n  const keep = new Set([currentGenerationPath, rollbackGenerationPath]\n    .filter(Boolean).map((value) => path.resolve(value)));\n  // Protect every artifact the published manifest references, so a generation is\n  // retained as a whole unit once it spans more than the SQLite file.\n  for (const artifactPath of (await currentManifestArtifacts(databasePath)).paths) {\n    keep.add(artifactPath);\n  }\n  const generations = await listGenerationPaths(databasePath);\n  const removed = [];\n  for (const generation of generations) {\n    if (keep.has(path.resolve(generation.path))) continue;\n    await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n      rm(`${generation.path}${suffix}`, { force: true })\n    )));\n    removed.push(generation.path);\n  }\n  return {\n    kept: generations.map((entry) => entry.path)\n      .filter((generationPath) => keep.has(path.resolve(generationPath))),\n    removed,\n  };\n}\n\nasync function buildAndRetain(options) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const before = await getStyleDatabaseStatus({ databasePath });\n  const result = await buildStyleDatabase({ ...options, databasePath });\n  const retention = await pruneStyleDatabaseGenerations({\n    databasePath,\n    currentGenerationPath: result.generationDatabasePath,\n    rollbackGenerationPath: before.currentGenerationPath,\n  });\n  return { ...result, action: 'build', retention };\n}\n\nasync function switchGeneration(action, options) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const before = await getStyleDatabaseStatus({ databasePath });\n  const generationDatabasePath = options.generationDatabasePath\n    ?? before.rollbackGenerationPath;\n  if (!generationDatabasePath) {\n    const error = new Error('No retained rollback generation is available.');\n    error.code = 'rollback-generation-unavailable';\n    throw error;\n  }\n  const result = await rollbackStyleDatabase({ databasePath, generationDatabasePath });\n  const retention = await pruneStyleDatabaseGenerations({\n    databasePath,\n    currentGenerationPath: generationDatabasePath,\n    rollbackGenerationPath: before.currentGenerationPath,\n  });\n  return { ...result, action, retention };\n}\n\nasync function repairVectors(options) {\n  if (!options.profileId) {\n    const error = new Error('Vector repair requires an embedding profile.');\n    error.code = 'invalid-arguments';\n    throw error;\n  }\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const database = openPublishedStyleDatabase(databasePath);\n  try {\n    return {\n      ok: true,\n      action: 'repair',\n      ...rebuildVectorProjection(database, options.profileId),\n    };\n  } finally {\n    database.close();\n  }\n}\n\n/**\n * Dispatch the persistent style database operator command surface.\n *\n * @param {string[]} argumentsList - Command and flags.\n * @returns {Promise<Object>} Structured operator result.\n */\nexport async function runStyleDatabaseOperator(argumentsList = process.argv.slice(2)) {\n  const [command, ...commandArguments] = argumentsList;\n  const databasePath = optionValue(commandArguments, '--database')\n    ?? DEFAULT_STYLE_DATABASE_PATH;\n  if (command === 'status') return getStyleDatabaseStatus({ databasePath });\n  if (command === 'build') {\n    const corpusRoot = optionValue(commandArguments, '--corpus');\n    if (!corpusRoot) {\n      const error = new Error('Build requires --corpus.');\n      error.code = 'invalid-arguments';\n      throw error;\n    }\n    return buildAndRetain({ corpusRoot, databasePath, corpusWalkMode: 'migration' });\n  }\n  if (command === 'cutover') {\n    const generationDatabasePath = optionValue(commandArguments, '--generation');\n    if (!generationDatabasePath) {\n      const error = new Error('Cutover requires --generation.');\n      error.code = 'invalid-arguments';\n      throw error;\n    }\n    return switchGeneration('cutover', { databasePath, generationDatabasePath });\n  }\n  if (command === 'rollback') {\n    return switchGeneration('rollback', {\n      databasePath,\n      generationDatabasePath: optionValue(commandArguments, '--generation'),\n    });\n  }\n  if (command === 'repair') {\n    return repairVectors({\n      databasePath,\n      profileId: optionValue(commandArguments, '--profile'),\n    });\n  }\n  const error = new Error(\n    'Usage: operator.mjs <status|build|cutover|rollback|repair> [options]',\n  );\n  error.code = 'invalid-arguments';\n  throw error;\n}\n\nconst isDirectExecution = process.argv[1]\n  && import.meta.url === pathToFileURL(path.resolve(process.argv[1])).href;\nif (isDirectExecution) {\n  try {\n    writeJson(await runStyleDatabaseOperator());\n  } catch (error) {\n    writeJson({\n      ok: false,\n      error: error.code ?? 'internal-error',\n      message: error.message,\n    }, process.stderr);\n    process.exitCode = 1;\n  }\n}","lineStart":1,"lineEnd":268,"totalLines":268,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/operator.mjs","time":{"start":1784606379896,"end":1784606379904}},"id":"prt_f82d44f760018UdGcHbWOfwRUq","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d42d66001d2OWnLVXOkBe7u"}}
{"type":"tool_use","timestamp":1784606380164,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d44f00765286f9fba1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/stage-telemetry.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/stage-telemetry.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Residency-Honest Stage Telemetry                                        ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // Every recorded stage is tagged with where its wall time was spent: `native`\n6: // for work executed inside the node:sqlite / FTS5 boundary, `js-resident` for\n7: // work executed on the JS heap and event loop (fs orchestration, JSON decode,\n8: // cosine, sort, RRF, card assembly). There is no blended or opaque bucket — a\n9: // record without a valid residency cannot be created.\n10: //\n11: // Attribution is measured, not assumed: the summary compares a real elapsed\n12: // wall span (an explicit overall timer, or the first span start through the\n13: // last span end) against the sum of the recorded span durations and reports the\n14: // remainder as `unattributedMs`. Work that runs outside every span therefore\n15: // surfaces honestly instead of being silently folded into a residency bucket.\n16: \n17: import { performance } from 'node:perf_hooks';\n18: \n19: export const RESIDENCY = Object.freeze({\n20:   NATIVE: 'native',\n21:   JS_RESIDENT: 'js-resident',\n22: });\n23: \n24: const RESIDENCY_VALUES = new Set(Object.values(RESIDENCY));\n25: \n26: function assertResidency(residency) {\n27:   if (!RESIDENCY_VALUES.has(residency)) {\n28:     throw new TypeError(`Unknown telemetry residency: ${String(residency)}`);\n29:   }\n30: }\n31: \n32: /**\n33:  * Create a stage recorder with injectable clock and memory probes.\n34:  *\n35:  * @param {Object} [options] - Probe overrides for deterministic tests.\n36:  * @param {Function} [options.now] - Monotonic millisecond clock.\n37:  * @param {Function} [options.memory] - Resident-set byte probe.\n38:  * @returns {Object} Recorder with span/record/overall/summary access.\n39:  */\n40: export function createStageRecorder({ now, memory } = {}) {\n41:   const clock = typeof now === 'function' ? now : () => performance.now();\n42:   const readRss = typeof memory === 'function' ? memory : () => process.memoryUsage().rss;\n43:   const records = [];\n44:   let firstStartedAt = null;\n45:   let lastEndedAt = null;\n46:   let rootStartedAt = null;\n47:   let rootEndedAt = null;\n48: \n49:   function observeWindow(startedAt, endedAt) {\n50:     if (firstStartedAt === null || startedAt < firstStartedAt) firstStartedAt = startedAt;\n51:     if (lastEndedAt === null || endedAt > lastEndedAt) lastEndedAt = endedAt;\n52:   }\n53: \n54:   function record(stage, residency, startedAt, startedRss, items = 0) {\n55:     assertResidency(residency);\n56:     const endedAt = clock();\n57:     const latencyMs = endedAt - startedAt;\n58:     const rssDeltaBytes = readRss() - startedRss;\n59:     observeWindow(startedAt, endedAt);\n60:     records.push(Object.freeze({\n61:       stage,\n62:       residency,\n63:       latencyMs,\n64:       items,\n65:       throughputPerSecond: latencyMs > 0 ? (items / latencyMs) * 1_000 : null,\n66:       rssDeltaBytes,\n67:     }));\n68:   }\n69: \n70:   return {\n71:     clock,\n72:     memory: readRss,\n73:     record,\n74:     /**\n75:      * Open a bracketed span; call `end(items)` once the stage work completes.\n76:      *\n77:      * @param {string} stage - Stage label.\n78:      * @param {string} residency - `native` or `js-resident`.\n79:      * @returns {{end: Function}} Span handle.\n80:      */\n81:     span(stage, residency) {\n82:       assertResidency(residency);\n83:       const startedAt = clock();\n84:       const startedRss = readRss();\n85:       return { end(items = 0) { record(stage, residency, startedAt, startedRss, items); } };\n86:     },\n87:     /**\n88:      * Bracket the whole instrumented region so the summary can measure the wall\n89:      * time that no individual span accounted for.\n90:      *\n91:      * @returns {{end: Function}} Overall-timer handle.\n92:      */\n93:     overall() {\n94:       rootStartedAt = clock();\n95:       return { end() { rootEndedAt = clock(); } };\n96:     },\n97:     records: () => records.slice(),\n98:     /**\n99:      * Decompose recorded latency into native and JS-resident buckets and report\n100:      * the wall time that fell outside every span.\n101:      *\n102:      * @returns {Object} Bucketed totals plus measured elapsed and unattributed cost.\n103:      */\n104:     summary() {\n105:       const buckets = { [RESIDENCY.NATIVE]: 0, [RESIDENCY.JS_RESIDENT]: 0 };\n106:       let items = 0;\n107:       for (const entry of records) {\n108:         buckets[entry.residency] += entry.latencyMs;\n109:         items += entry.items;\n110:       }\n111:       const native = buckets[RESIDENCY.NATIVE];\n112:       const jsResident = buckets[RESIDENCY.JS_RESIDENT];\n113:       const total = native + jsResident;\n114:       const windowStart = rootStartedAt ?? firstStartedAt;\n115:       const windowEnd = rootEndedAt ?? lastEndedAt;\n116:       const elapsedMs = windowStart !== null && windowEnd !== null && windowEnd > windowStart\n117:         ? windowEnd - windowStart\n118:         : total;\n119:       const unattributedMs = Math.max(0, elapsedMs - total);\n120:       return {\n121:         native,\n122:         jsResident,\n123:         total,\n124:         elapsedMs,\n125:         unattributedMs,\n126:         stageCount: records.length,\n127:         items,\n128:       };\n129:     },\n130:   };\n131: }\n\n(End of file - total 131 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Residency-Honest Stage Telemetry                                        ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Every recorded stage is tagged with where its wall time was spent: `native`\n// for work executed inside the node:sqlite / FTS5 boundary, `js-resident` for\n// work executed on the JS heap and event loop (fs orchestration, JSON decode,\n// cosine, sort, RRF, card assembly). There is no blended or opaque bucket — a\n// record without a valid residency cannot be created.\n//\n// Attribution is measured, not assumed: the summary compares a real elapsed\n// wall span (an explicit overall timer, or the first span start through the\n// last span end) against the sum of the recorded span durations and reports the\n// remainder as `unattributedMs`. Work that runs outside every span therefore\n// surfaces honestly instead of being silently folded into a residency bucket.\n\nimport { performance } from 'node:perf_hooks';\n\nexport const RESIDENCY = Object.freeze({\n  NATIVE: 'native',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/stage-telemetry.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Residency-Honest Stage Telemetry                                        ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Every recorded stage is tagged with where its wall time was spent: `native`\n// for work executed inside the node:sqlite / FTS5 boundary, `js-resident` for\n// work executed on the JS heap and event loop (fs orchestration, JSON decode,\n// cosine, sort, RRF, card assembly). There is no blended or opaque bucket — a\n// record without a valid residency cannot be created.\n//\n// Attribution is measured, not assumed: the summary compares a real elapsed\n// wall span (an explicit overall timer, or the first span start through the\n// last span end) against the sum of the recorded span durations and reports the\n// remainder as `unattributedMs`. Work that runs outside every span therefore\n// surfaces honestly instead of being silently folded into a residency bucket.\n\nimport { performance } from 'node:perf_hooks';\n\nexport const RESIDENCY = Object.freeze({\n  NATIVE: 'native',\n  JS_RESIDENT: 'js-resident',\n});\n\nconst RESIDENCY_VALUES = new Set(Object.values(RESIDENCY));\n\nfunction assertResidency(residency) {\n  if (!RESIDENCY_VALUES.has(residency)) {\n    throw new TypeError(`Unknown telemetry residency: ${String(residency)}`);\n  }\n}\n\n/**\n * Create a stage recorder with injectable clock and memory probes.\n *\n * @param {Object} [options] - Probe overrides for deterministic tests.\n * @param {Function} [options.now] - Monotonic millisecond clock.\n * @param {Function} [options.memory] - Resident-set byte probe.\n * @returns {Object} Recorder with span/record/overall/summary access.\n */\nexport function createStageRecorder({ now, memory } = {}) {\n  const clock = typeof now === 'function' ? now : () => performance.now();\n  const readRss = typeof memory === 'function' ? memory : () => process.memoryUsage().rss;\n  const records = [];\n  let firstStartedAt = null;\n  let lastEndedAt = null;\n  let rootStartedAt = null;\n  let rootEndedAt = null;\n\n  function observeWindow(startedAt, endedAt) {\n    if (firstStartedAt === null || startedAt < firstStartedAt) firstStartedAt = startedAt;\n    if (lastEndedAt === null || endedAt > lastEndedAt) lastEndedAt = endedAt;\n  }\n\n  function record(stage, residency, startedAt, startedRss, items = 0) {\n    assertResidency(residency);\n    const endedAt = clock();\n    const latencyMs = endedAt - startedAt;\n    const rssDeltaBytes = readRss() - startedRss;\n    observeWindow(startedAt, endedAt);\n    records.push(Object.freeze({\n      stage,\n      residency,\n      latencyMs,\n      items,\n      throughputPerSecond: latencyMs > 0 ? (items / latencyMs) * 1_000 : null,\n      rssDeltaBytes,\n    }));\n  }\n\n  return {\n    clock,\n    memory: readRss,\n    record,\n    /**\n     * Open a bracketed span; call `end(items)` once the stage work completes.\n     *\n     * @param {string} stage - Stage label.\n     * @param {string} residency - `native` or `js-resident`.\n     * @returns {{end: Function}} Span handle.\n     */\n    span(stage, residency) {\n      assertResidency(residency);\n      const startedAt = clock();\n      const startedRss = readRss();\n      return { end(items = 0) { record(stage, residency, startedAt, startedRss, items); } };\n    },\n    /**\n     * Bracket the whole instrumented region so the summary can measure the wall\n     * time that no individual span accounted for.\n     *\n     * @returns {{end: Function}} Overall-timer handle.\n     */\n    overall() {\n      rootStartedAt = clock();\n      return { end() { rootEndedAt = clock(); } };\n    },\n    records: () => records.slice(),\n    /**\n     * Decompose recorded latency into native and JS-resident buckets and report\n     * the wall time that fell outside every span.\n     *\n     * @returns {Object} Bucketed totals plus measured elapsed and unattributed cost.\n     */\n    summary() {\n      const buckets = { [RESIDENCY.NATIVE]: 0, [RESIDENCY.JS_RESIDENT]: 0 };\n      let items = 0;\n      for (const entry of records) {\n        buckets[entry.residency] += entry.latencyMs;\n        items += entry.items;\n      }\n      const native = buckets[RESIDENCY.NATIVE];\n      const jsResident = buckets[RESIDENCY.JS_RESIDENT];\n      const total = native + jsResident;\n      const windowStart = rootStartedAt ?? firstStartedAt;\n      const windowEnd = rootEndedAt ?? lastEndedAt;\n      const elapsedMs = windowStart !== null && windowEnd !== null && windowEnd > windowStart\n        ? windowEnd - windowStart\n        : total;\n      const unattributedMs = Math.max(0, elapsedMs - total);\n      return {\n        native,\n        jsResident,\n        total,\n        elapsedMs,\n        unattributedMs,\n        stageCount: records.length,\n        items,\n      };\n    },\n  };\n}","lineStart":1,"lineEnd":131,"totalLines":131,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/stage-telemetry.mjs","time":{"start":1784606380152,"end":1784606380161}},"id":"prt_f82d44f79001FpIbqqBHf84KN2","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d42d66001d2OWnLVXOkBe7u"}}
