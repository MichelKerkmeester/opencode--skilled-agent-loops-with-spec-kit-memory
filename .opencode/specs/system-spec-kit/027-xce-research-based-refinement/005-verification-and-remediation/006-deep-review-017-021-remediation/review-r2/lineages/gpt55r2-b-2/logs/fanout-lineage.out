       return cancelledScanEnvelope(scanKey);\n\n  Line 1497: /** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n\n  Line 1498:  *  Without background the call is byte-for-byte identical to the prior synchronous path. */\n\n  Line 1499: async function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n\n  Line 1500:   if (!args.background) {\n\n  Line 1501:     return runIndexScan(args, {});\n\n  Line 1505:   await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  Line 1511:       // background-embedding queue draining this scan's deferred embeddings can\n\n  Line 1515:         await setJobState(jobId, 'running');\n\n  Line 1516:         const response = await runIndexScan(args, {\n\n  Line 1517:           isCancelled: () => isCancelRequestedFast(jobId),\n\n  Line 1532:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n\n  Line 1536:           await setJobState(jobId, 'failed');\n\n  Line 1538:           await completeJob(jobId, { state: 'complete', result: scanData });\n\n  Line 1543:           await setJobState(jobId, 'failed');\n\n  Line 1545:           // Best-effort failure record; never surface a background unhandled rejection.\n\n  Line 1550:         // background-embedding queue still holds it.\n\n  Line 1558:     summary: `Queued background index scan ${jobId}`,\n\n  Line 1559:     data: { jobId, state: 'queued', background: true },\n\n  Line 1572:   handleMemoryIndexScan,\n\n  Line 1582: const handle_memory_index_scan = handleMemoryIndexScan;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:\n  Line 2746:     // When enrichment is enabled and async (default), run the bundle in the background so the\n\n  Line 2748:     // transaction (markEnrichmentPending), so a crash before the background run completes is\n\n  Line 2754:       postInsertEnrichmentResult = buildDeferredEnrichmentResult('async-background');\n\n  Line 2916: // Concurrency cap so a save burst cannot schedule unbounded background enrichment (each run does\n\n  Line 2921: const backgroundEnrichmentQueue: Array<() => void> = [];\n\n  Line 2931:  * Fence the background-enrichment scheduler for shutdown: stop accepting/draining work and let any\n\n  Line 2938:   backgroundEnrichmentQueue.length = 0;\n\n  Line 2966:     queued: backgroundEnrichmentQueue.length,\n\n  Line 2977:  * Run post-insert enrichment for a just-saved row in the background, bounded and crash-safe:\n\n  Line 3033:           console.warn(`[memory-save] background enrichment failed for #${memoryId}: ${enrichmentLastError} (total=${enrichmentFailureTotal}${suppressed ? `, ${suppressed} suppressed since last log` : ''})`);\n\n  Line 3040:           const next = backgroundEnrichmentQueue.shift();\n\n  Line 3048:   } else if (backgroundEnrichmentQueue.length < MAX_QUEUED_ENRICHMENTS) {\n\n  Line 3049:     backgroundEnrichmentQueue.push(run);\n","metadata":{"matches":67,"truncated":false},"title":"background|createMaintenanceJob|runIndexScan|handleMemoryIndexScan|completeJob|setJobState\\(|isCancelRequestedFast|cancelledScanEnvelope","time":{"start":1781761651532,"end":1781761651551}},"metadata":{"openai":{"itemId":"fc_0324d67880409fc9016a338671e84c8191be08979d4259c176"}},"id":"prt_ed9452cf2001rmkf9W0NgD1Qze","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed94513980017NTeQWSD3WyTp7"}}
