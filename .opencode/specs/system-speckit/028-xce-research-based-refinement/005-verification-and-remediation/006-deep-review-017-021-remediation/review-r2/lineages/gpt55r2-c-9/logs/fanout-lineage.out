(value).trim(), 10);\n39:   return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n40: }\n41: \n42: // A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n43: // daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n44: // consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n45: // its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n46: // the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\n47: function resolveLeaseProbeAttempts(env = process.env) {\n48:   return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n49: }\n50: function resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n51:   return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n52: }\n53: function resolveLeaseProbeRetryBackoffMs(env = process.env) {\n54:   return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n55: }\n56: \n57: function repoRoot() {\n58:   return path.resolve(__dirname, '..', '..', '..');\n59: }\n60: \n61: function defaultDbDirForService(serviceName) {\n62:   const root = repoRoot();\n63:   if (serviceName === 'mk-spec-memory') {\n64:     return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n65:   }\n66:   if (serviceName === 'mk-code-index') {\n67:     return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n68:       ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n69:       : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n70:   }\n71:   if (serviceName === 'mk-skill-advisor') {\n72:     const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n73:     return advisorOverride\n74:       ? path.resolve(advisorOverride)\n75:       : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n76:   }\n77:   throw new Error(`Unknown MCP service name: ${serviceName}`);\n78: }\n79: \n80: function getIpcSocketPath(serviceName, options = {}) {\n81:   if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n82:     return process.env.SPECKIT_IPC_SOCKET_DIR;\n83:   }\n84:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n85:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n86:     : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n87:   return path.join(socketDir, SOCKET_FILE_NAME);\n88: }\n89: \n90: function toConnectionOptions(socketPath) {\n91:   if (!socketPath.startsWith('tcp://')) {\n92:     return socketPath;\n93:   }\n94:   const url = new URL(socketPath);\n95:   return {\n96:     host: url.hostname,\n97:     port: Number.parseInt(url.port, 10),\n98:   };\n99: }\n100: \n101: function bridgeStdioToSocket(socketPath, options = {}) {\n102:   const input = options.stdin ?? process.stdin;\n103:   const output = options.stdout ?? process.stdout;\n104:   const exit = options.exit ?? ((code) => process.exit(code));\n105:   const socket = net.createConnection(toConnectionOptions(socketPath));\n106:   let closed = false;\n107: \n108:   const closeOnce = (code = 0) => {\n109:     if (closed) return;\n110:     closed = true;\n111:     input.unpipe(socket);\n112:     socket.unpipe(output);\n113:     socket.destroy();\n114:     exit(code);\n115:   };\n116: \n117:   socket.once('connect', () => {\n118:     options.onConnect?.(socket);\n119:     input.pipe(socket);\n120:     socket.pipe(output);\n121:   });\n122: \n123:   socket.once('error', (error) => {\n124:     options.onError?.(error);\n125:     closeOnce(0);\n126:   });\n127: \n128:   socket.once('close', () => {\n129:     closeOnce(0);\n130:   });\n131: \n132:   input.once('end', () => {\n133:     socket.end();\n134:   });\n135:   input.once('close', () => {\n136:     closeOnce(0);\n137:   });\n138:   output.once('error', () => {\n139:     closeOnce(0);\n140:   });\n141: \n142:   return socket;\n143: }\n144: \n145: function probeDaemon(socketPath, options = {}) {\n146:   const timeoutMs = resolveProbeTimeoutMs(options);\n147:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n148:   // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n149:   // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n150:   // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n151:   // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n152:   const deepProbe = options.deepProbe === true;\n153:   const id = nextProbeId++;\n154:   const request = `${JSON.stringify({\n155:     jsonrpc: '2.0',\n156:     id,\n157:     method: 'initialize',\n158:     params: {\n159:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n160:       capabilities: {},\n161:       clientInfo: { name: 'liveness-probe', version: '0' },\n162:     },\n163:   })}\\n`;\n164: \n165:   return new Promise((resolve) => {\n166:     let socket;\n167:     let settled = false;\n168:     let buffer = '';\n169:     let timer;\n170:     // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n171:     // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n172:     const decoder = new StringDecoder('utf8');\n173: \n174:     const finish = (status, reason) => {\n175:       if (settled) return;\n176:       settled = true;\n177:       if (timer) clearTimeout(timer);\n178:       if (socket) socket.destroy();\n179:       resolve({ status, reason });\n180:     };\n181: \n182:     try {\n183:       socket = connect(toConnectionOptions(socketPath));\n184:     } catch (error) {\n185:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n186:       return;\n187:     }\n188: \n189:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n190:     timer.unref?.();\n191: \n192:     socket.once('connect', () => {\n193:       if (!deepProbe) {\n194:         finish('alive', 'connect-ok');\n195:         return;\n196:       }\n197:       socket.write(request);\n198:     });\n199:     socket.on('data', (chunk) => {\n200:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n201:       let newlineIndex = buffer.indexOf('\\n');\n202:       while (newlineIndex !== -1) {\n203:         const line = buffer.slice(0, newlineIndex).trim();\n204:         buffer = buffer.slice(newlineIndex + 1);\n205:         newlineIndex = buffer.indexOf('\\n');\n206:         if (!line) continue;\n207:         try {\n208:           const parsed = JSON.parse(line);\n209:           if (\n210:             parsed &&\n211:             parsed.jsonrpc === '2.0' &&\n212:             parsed.id === id &&\n213:             (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n214:               Object.prototype.hasOwnProperty.call(parsed, 'error'))\n215:           ) {\n216:             finish('alive', 'json-rpc-reply');\n217:             return;\n218:           }\n219:         } catch {\n220:           // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n221:         }\n222:       }\n223:     });\n224:     socket.once('error', (error) => {\n225:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n226:     });\n227:     socket.once('close', () => {\n228:       finish('dead', 'closed-before-reply');\n229:     });\n230:   });\n231: }\n232: \n233: function parseHttpJsonResponse(buffer) {\n234:   const raw = buffer.toString('utf8');\n235:   const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n236:   if (headerEnd === -1) return null;\n237:   const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n238:   const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n239:   if (!statusMatch) return null;\n240:   const statusCode = Number.parseInt(statusMatch[1], 10);\n241:   const bodyRaw = raw.slice(headerEnd + 4).trim();\n242:   let body = null;\n243:   try {\n244:     body = bodyRaw ? JSON.parse(bodyRaw) : null;\n245:   } catch {\n246:     return { statusCode, body: null };\n247:   }\n248:   return { statusCode, body };\n249: }\n250: \n251: function probeModelServer(socketPath, options = {}) {\n252:   const timeoutMs = resolveProbeTimeoutMs(options);\n253:   const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n254:     ? options.loadingMaxMs\n255:     : parsePositiveInteger(\n256:       (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n257:       DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n258:     );\n259:   const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n260:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n261:   // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n262:   // without spawning a model server. Genuine embed consumers do not send this header, so their\n263:   // wake-on-demand path is unchanged.\n264:   const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n265: \n266:   return new Promise((resolve) => {\n267:     let socket;\n268:     let settled = false;\n269:     let chunks = [];\n270:     let timer;\n271: \n272:     // Carry the parsed health body so callers (the idle-eviction tick) can read\n273:     // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n274:     const finish = (status, reason, health) => {\n275:       if (settled) return;\n276:       settled = true;\n277:       if (timer) clearTimeout(timer);\n278:       if (socket) socket.destroy();\n279:       resolve({ status, reason, health });\n280:     };\n281: \n282:     try {\n283:       socket = connect(toConnectionOptions(socketPath));\n284:     } catch (error) {\n285:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n286:       return;\n287:     }\n288: \n289:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n290:     timer.unref?.();\n291: \n292:     socket.once('connect', () => {\n293:       socket.write(request);\n294:     });\n295:     socket.on('data', (chunk) => {\n296:       chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n297:     });\n298:     socket.once('end', () => {\n299:       const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n300:       const state = parsed && parsed.body && typeof parsed.body === 'object'\n301:         ? parsed.body.state\n302:         : null;\n303:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n304:         finish('alive', `health-${state}`, parsed.body);\n305:         return;\n306:       }\n307:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n308:         const loadStartedAt = parsed.body.loadStartedAt;\n309:         const loadProgressAt = parsed.body.loadProgressAt;\n310:         // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n311:         const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n312:           ? loadProgressAt\n313:           : loadStartedAt;\n314:         if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n315:           finish('dead', 'loading-wedged');\n316:           return;\n317:         }\n318:         finish('alive', 'health-loading', parsed.body);\n319:         return;\n320:       }\n321:       finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n322:     });\n323:     socket.once('error', (error) => {\n324:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n325:     });\n326:     socket.once('close', () => {\n327:       if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n328:     });\n329:   });\n330: }\n\n(Showing lines 1-330 of 451. Use offset=331 to continue.)\n</content>","metadata":{"preview":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","text":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction clampProbeTimeoutMs(value) {\n  return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n}\n\nfunction resolveProbeTimeoutMs(options = {}) {\n  if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n    return clampProbeTimeoutMs(options.timeoutMs);\n  }\n  return clampProbeTimeoutMs(parsePositiveInteger(\n    (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n    DEFAULT_PROBE_TIMEOUT_MS,\n  ));\n}\n\nfunction parseNonNegativeInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n}\n\n// A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n// daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n// consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n// its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n// the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\nfunction resolveLeaseProbeAttempts(env = process.env) {\n  return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n}\nfunction resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n  return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n}\nfunction resolveLeaseProbeRetryBackoffMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n}\n\nfunction repoRoot() {\n  return path.resolve(__dirname, '..', '..', '..');\n}\n\nfunction defaultDbDirForService(serviceName) {\n  const root = repoRoot();\n  if (serviceName === 'mk-spec-memory') {\n    return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n  }\n  if (serviceName === 'mk-code-index') {\n    return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n      ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n      : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n  }\n  if (serviceName === 'mk-skill-advisor') {\n    const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n    return advisorOverride\n      ? path.resolve(advisorOverride)\n      : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n  }\n  throw new Error(`Unknown MCP service name: ${serviceName}`);\n}\n\nfunction getIpcSocketPath(serviceName, options = {}) {\n  if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n    return process.env.SPECKIT_IPC_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\nfunction toConnectionOptions(socketPath) {\n  if (!socketPath.startsWith('tcp://')) {\n    return socketPath;\n  }\n  const url = new URL(socketPath);\n  return {\n    host: url.hostname,\n    port: Number.parseInt(url.port, 10),\n  };\n}\n\nfunction bridgeStdioToSocket(socketPath, options = {}) {\n  const input = options.stdin ?? process.stdin;\n  const output = options.stdout ?? process.stdout;\n  const exit = options.exit ?? ((code) => process.exit(code));\n  const socket = net.createConnection(toConnectionOptions(socketPath));\n  let closed = false;\n\n  const closeOnce = (code = 0) => {\n    if (closed) return;\n    closed = true;\n    input.unpipe(socket);\n    socket.unpipe(output);\n    socket.destroy();\n    exit(code);\n  };\n\n  socket.once('connect', () => {\n    options.onConnect?.(socket);\n    input.pipe(socket);\n    socket.pipe(output);\n  });\n\n  socket.once('error', (error) => {\n    options.onError?.(error);\n    closeOnce(0);\n  });\n\n  socket.once('close', () => {\n    closeOnce(0);\n  });\n\n  input.once('end', () => {\n    socket.end();\n  });\n  input.once('close', () => {\n    closeOnce(0);\n  });\n  output.once('error', () => {\n    closeOnce(0);\n  });\n\n  return socket;\n}\n\nfunction probeDaemon(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n  // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n  // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n  // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n  const deepProbe = options.deepProbe === true;\n  const id = nextProbeId++;\n  const request = `${JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    method: 'initialize',\n    params: {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'liveness-probe', version: '0' },\n    },\n  })}\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let buffer = '';\n    let timer;\n    // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n    // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n    const decoder = new StringDecoder('utf8');\n\n    const finish = (status, reason) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      if (!deepProbe) {\n        finish('alive', 'connect-ok');\n        return;\n      }\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const line = buffer.slice(0, newlineIndex).trim();\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (!line) continue;\n        try {\n          const parsed = JSON.parse(line);\n          if (\n            parsed &&\n            parsed.jsonrpc === '2.0' &&\n            parsed.id === id &&\n            (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n              Object.prototype.hasOwnProperty.call(parsed, 'error'))\n          ) {\n            finish('alive', 'json-rpc-reply');\n            return;\n          }\n        } catch {\n          // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n        }\n      }\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\nfunction parseHttpJsonResponse(buffer) {\n  const raw = buffer.toString('utf8');\n  const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n  if (headerEnd === -1) return null;\n  const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n  const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n  if (!statusMatch) return null;\n  const statusCode = Number.parseInt(statusMatch[1], 10);\n  const bodyRaw = raw.slice(headerEnd + 4).trim();\n  let body = null;\n  try {\n    body = bodyRaw ? JSON.parse(bodyRaw) : null;\n  } catch {\n    return { statusCode, body: null };\n  }\n  return { statusCode, body };\n}\n\nfunction probeModelServer(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n    ? options.loadingMaxMs\n    : parsePositiveInteger(\n      (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n      DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n    );\n  const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n  // without spawning a model server. Genuine embed consumers do not send this header, so their\n  // wake-on-demand path is unchanged.\n  const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let chunks = [];\n    let timer;\n\n    // Carry the parsed health body so callers (the idle-eviction tick) can read\n    // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n    const finish = (status, reason, health) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason, health });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n    });\n    socket.once('end', () => {\n      const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n      const state = parsed && parsed.body && typeof parsed.body === 'object'\n        ? parsed.body.state\n        : null;\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n        finish('alive', `health-${state}`, parsed.body);\n        return;\n      }\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n        const loadStartedAt = parsed.body.loadStartedAt;\n        const loadProgressAt = parsed.body.loadProgressAt;\n        // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n        const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n          ? loadProgressAt\n          : loadStartedAt;\n        if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n          finish('dead', 'loading-wedged');\n          return;\n        }\n        finish('alive', 'health-loading', parsed.body);\n        return;\n      }\n      finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n    });\n  });\n}","lineStart":1,"lineEnd":330,"totalLines":451,"truncated":true}},"title":".opencode/bin/lib/launcher-ipc-bridge.cjs","time":{"start":1781763938614,"end":1781763938624}},"metadata":{"openai":{"itemId":"fc_04bdf27f9212786a016a338f624f508191b3c73008aedd209c"}},"id":"prt_ed9681933001oQNe7TuZM9UvoJ","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed967e59d001KKe7NFWBvYIMl7"}}
{"type":"tool_use","timestamp":1781763938627,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_u2TNqfylqNSOe4lJ0u5c0Sh9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n3: // Loads project-local env overrides, ensures dist artifacts are built and current,\n4: // serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n5: // context-server.js child. All stderr lines are tagged with the bracketed module\n6: // prefix for ops grepping.\n7: \n8: 'use strict';\n9: \n10: const fs = require('fs');\n11: const http = require('http');\n12: const path = require('path');\n13: const { spawn, spawnSync } = require('child_process');\n14: const mss = require('./lib/model-server-supervision.cjs');\n15: const { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n16: \n17: const {\n18:   RESPAWN_REAP_GRACE_MS,\n19:   HF_MODEL_SERVER_PID_FILE_NAME,\n20:   acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n21:   buildLeaseObject: buildSharedLeaseObject,\n22:   canonicalizePath,\n23:   computeBackoffMs,\n24:   createCrashLoopGuard,\n25:   createModelServerSupervisor: baseCreateModelServerSupervisor,\n26:   defaultProcessRowsRunner,\n27:   getCrashLoopConfig,\n28:   getModelServerWatchdogConfig,\n29:   getWatchdogConfig,\n30:   isChildRunning,\n31:   isRespawnLockStale,\n32:   ensureCanonicalDir,\n33:   normalizeWatchdogGraceMs,\n34:   parseProcessRows,\n35:   processLiveness,\n36:   readMaintenanceMarker,\n37:   shouldAdoptDespiteProbe,\n38:   releaseRespawnLockFile,\n39:   sampleProcessTreeRssMb,\n40:   shouldAbortRelaunchOnFire,\n41:   shouldSkipLaunch,\n42:   signalProcess,\n43:   superviseChildExit,\n44:   waitForPidExit,\n45: } = mss;\n46: \n47: const root = path.resolve(__dirname, '..', '..');\n48: const opencodeDir = path.join(root, '.opencode');\n49: \n50: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n51: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n52: // Minimal parser — no external dependency.\n53: function loadEnvFile(filePath) {\n54:   if (!fs.existsSync(filePath)) return 0;\n55:   let count = 0;\n56:   const raw = fs.readFileSync(filePath, 'utf8');\n57:   for (const line of raw.split('\\n')) {\n58:     const trimmed = line.trim();\n59:     if (!trimmed || trimmed.startsWith('#')) continue;\n60:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n61:     if (!m) continue;\n62:     const key = m[1];\n63:     let val = m[2];\n64:     // Strip matching outer quotes (single or double)\n65:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n66:       val = val.slice(1, -1);\n67:     }\n68:     if (!(key in process.env)) {\n69:       process.env[key] = val;\n70:       count++;\n71:     }\n72:   }\n73:   return count;\n74: }\n75: \n76: function isStrictModeDisabled(value) {\n77:   if (value === undefined || value === null) return false;\n78:   const v = String(value).trim().toLowerCase();\n79:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n80: }\n81: \n82: let skillsDir = path.join(opencodeDir, 'skills');\n83: let legacySkillDir = path.join(opencodeDir, 'skill');\n84: let kitDir = path.join(skillsDir, 'system-spec-kit');\n85: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n86: let lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n87: const PID_FILE_NAME = '.mk-spec-memory-launcher.json';\n88: const OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\n89: let stateFile = path.join(dbDir, PID_FILE_NAME);\n90: let canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n91: \n92: const rel = (p) => path.relative(root, p) || '.';\n93: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n94: const now = () => new Date().toISOString();\n95: // Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n96: // only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\n97: const BOOTSTRAP_LOCK_STALE_MS = 300000;\n98: let childProcess = null;\n99: let ownerLeasePid = null;\n100: let leaseStartedAt = null;\n101: let launcherShutdownInProgress = false;\n102: let rssBreachSelfExitInProgress = false;\n103: let rssWatchdogTimer = null;\n104: let crashLoopGuard = null;\n105: let supervisorRelaunchTimer = null;\n106: // The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n107: // launcher's parent. When the host disposes its session the launcher is orphaned and its\n108: // ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n109: // path can tell \"owning runtime went away\" apart from a genuine daemon crash.\n110: const LAUNCHER_INITIAL_PPID = process.ppid;\n111: let ownerLeaseHeartbeatTimer = null;\n112: let ownerLeaseRequired = true;\n113: // Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n114: // process-tree monitor while the child is alive; the give-up reap path uses this to find an\n115: // orphaned sidecar after the child has already exited.\n116: let lastKnownDescendantPids = [];\n117: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n118: const durableWriteWarnings = new Set();\n119: // Daemon exit code meaning \"another live process holds the database\n120: // single-writer lock\". Never counts toward the crash loop: the right move is\n121: // bridging to the live owner (or a bounded retry while a maintenance script\n122: // finishes), not relaunching a doomed second writer. Mirrored in\n123: // mcp_server context-server (EXIT_DB_LOCK_HELD).\n124: const EXIT_DB_LOCK_HELD = 86;\n125: const DB_LOCK_HELD_MAX_RETRIES = 3;\n126: let dbLockHeldRetries = 0;\n127: \n128: function log(message) {\n129:   process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n130:   persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n131: }\n132: \n133: function isDurableWriteUnavailable(error) {\n134:   const code = error && typeof error === 'object' ? error.code : undefined;\n135:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n136: }\n137: \n138: function logDurableWriteUnavailableOnce(operation, targetPath, error) {\n139:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n140:   const key = `${operation}:${targetPath}:${code}`;\n141:   if (durableWriteWarnings.has(key)) return;\n142:   durableWriteWarnings.add(key);\n143:   const detail = error instanceof Error ? error.message : String(error ?? code);\n144:   log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n145: }\n146: \n147: // Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n148: // ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n149: // durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n150: // launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n151: // grow without bound.\n152: function launcherLogIsEnabled(env = process.env) {\n153:   return env.SPECKIT_LAUNCHER_LOG !== '0';\n154: }\n155: function launcherLogMaxBytes(env = process.env) {\n156:   return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n157: }\n158: function resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n159:   const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n160:   return typeof override === 'string' && override.trim()\n161:     ? override.trim()\n162:     : path.join(baseDir, '.mk-spec-memory-launcher.log');\n163: }\n164: function shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n165:   return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n166: }\n167: function persistLauncherLogLine(line) {\n168:   if (!launcherLogIsEnabled()) return;\n169:   let target;\n170:   try {\n171:     target = resolveLauncherLogPath();\n172:     try {\n173:       const { size } = fs.statSync(target);\n174:       if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n175:         try {\n176:           // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n177:           // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n178:           // suffix still rotates instead of renaming the file onto itself and growing without bound.\n179:           const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n180:           fs.renameSync(target, rotated);\n181:         } catch {\n182:           // Best-effort rotation: if the rename fails, keep appending to the current file.\n183:         }\n184:       }\n185:     } catch (statErr) {\n186:       if (statErr.code !== 'ENOENT') throw statErr;\n187:     }\n188:     fs.appendFileSync(target, line, { mode: 0o600 });\n189:   } catch (error) {\n190:     if (target && isDurableWriteUnavailable(error)) {\n191:       logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n192:       return;\n193:     }\n194:     // Logging must never break the launcher.\n195:   }\n196: }\n197: \n198: // Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n199: // When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n200: // (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n201: // not tear the shared backend out from under other sessions. A fresh session that finds the released\n202: // daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n203: // it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n204: // writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n205: // killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n206: // sweeper bounds any leak.\n207: function daemonReelectionEnabled(env = process.env) {\n208:   return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n209: }\n210: function contextServerSpawnIo(reelectionEnabled) {\n211:   return reelectionEnabled\n212:     ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n213:     : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n214: }\n215: function shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n216:   return Boolean(enabled) && Boolean(hasLiveDaemon);\n217: }\n218: \n219: function cleanupTmpFile(tmpPath) {\n220:   try {\n221:     fs.unlinkSync(tmpPath);\n222:   } catch (error) {\n223:     if (error.code !== 'ENOENT') {\n224:       // Best-effort cleanup only; the original durable-write failure is more useful.\n225:     }\n226:   }\n227: }\n228: \n229: function writeAtomicJsonFile(targetPath, payload, operation) {\n230:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n231:   const tmp = `${currentPath}.tmp.${process.pid}`;\n232:   try {\n233:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n234:     fs.renameSync(tmp, currentPath);\n235:     return true;\n236:   } catch (error) {\n237:     cleanupTmpFile(tmp);\n238:     if (isDurableWriteUnavailable(error)) {\n239:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n240:       return false;\n241:     }\n242:     throw error;\n243:   }\n244: }\n245: \n246: function loadProjectEnvFiles() {\n247:   for (const fname of ['.env.local', '.env']) {\n248:     const p = path.join(root, fname);\n249:     if (fs.existsSync(p)) {\n250:       const n = loadEnvFile(p);\n251:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n252:     }\n253:   }\n254: }\n255: \n256: function parsePositiveInteger(value, fallback) {\n257:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n258:   const parsed = Number.parseInt(String(value).trim(), 10);\n259:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n260: }\n\n(Showing lines 1-260 of 1882. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"#!/usr/bin/env node\n// [mk-spec-memory-launcher] MCP child-process launcher for the mk-spec-memory server.\n// Loads project-local env overrides, ensures dist artifacts are built and current,\n// serializes concurrent starts via a filesystem bootstrap lock, then spawns the\n// context-server.js child. All stderr lines are tagged with the bracketed module\n// prefix for ops grepping.\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst mss = require('./lib/model-server-supervision.cjs');\nconst { createSessionProxy } = require('./lib/launcher-session-proxy.cjs');\n\nconst {\n  RESPAWN_REAP_GRACE_MS,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  acquireRespawnLockFileAt: acquireSharedRespawnLockFileAt,\n  buildLeaseObject: buildSharedLeaseObject,\n  canonicalizePath,\n  computeBackoffMs,\n  createCrashLoopGuard,\n  createModelServerSupervisor: baseCreateModelServerSupervisor,\n  defaultProcessRowsRunner,\n  getCrashLoopConfig,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  isChildRunning,\n  isRespawnLockStale,\n  ensureCanonicalDir,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  readMaintenanceMarker,\n  shouldAdoptDespiteProbe,\n  releaseRespawnLockFile,\n  sampleProcessTreeRssMb,\n  shouldAbortRelaunchOnFire,\n  shouldSkipLaunch,\n  signalProcess,\n  superviseChildExit,\n  waitForPidExit,\n} = mss;\n\nconst root = path.resolve(__dirname, '..', '..');\nconst opencodeDir = path.join(root, '.opencode');\n\n// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n// .env, both are gitignored. Existing process.env wins over file values (do not override).\n// Minimal parser — no external dependency.\nfunction loadEnvFile(filePath) {\n  if (!fs.existsSync(filePath)) return 0;\n  let count = 0;\n  const raw = fs.readFileSync(filePath, 'utf8');\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n    if (!m) continue;\n    const key = m[1];\n    let val = m[2];\n    // Strip matching outer quotes (single or double)\n    if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n      val = val.slice(1, -1);\n    }\n    if (!(key in process.env)) {\n      process.env[key] = val;\n      count++;\n    }\n  }\n  return count;\n}\n\nfunction isStrictModeDisabled(value) {\n  if (value === undefined || value === null) return false;\n  const v = String(value).trim().toLowerCase();\n  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n}\n\nlet skillsDir = path.join(opencodeDir, 'skills');\nlet legacySkillDir = path.join(opencodeDir, 'skill');\nlet kitDir = path.join(skillsDir, 'system-spec-kit');\nlet dbDir = path.join(kitDir, 'mcp_server', 'database');\nlet lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\nconst PID_FILE_NAME = '.mk-spec-memory-launcher.json';\nconst OWNER_LEASE_FILE_NAME = '.spec-memory-owner.json';\nlet stateFile = path.join(dbDir, PID_FILE_NAME);\nlet canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n\nconst rel = (p) => path.relative(root, p) || '.';\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\nconst now = () => new Date().toISOString();\n// Generously above any realistic cold-cache build (npm ci + 2 tsc workspace builds) so the reclaim\n// only fires for a genuinely abandoned lockdir, never a slow-but-live build holder.\nconst BOOTSTRAP_LOCK_STALE_MS = 300000;\nlet childProcess = null;\nlet ownerLeasePid = null;\nlet leaseStartedAt = null;\nlet launcherShutdownInProgress = false;\nlet rssBreachSelfExitInProgress = false;\nlet rssWatchdogTimer = null;\nlet crashLoopGuard = null;\nlet supervisorRelaunchTimer = null;\n// The MCP host (Claude Code / OpenCode) spawns this launcher directly, so the host is the\n// launcher's parent. When the host disposes its session the launcher is orphaned and its\n// ppid changes (reparents to 1 / a subreaper). Captured once at startup so the relaunch\n// path can tell \"owning runtime went away\" apart from a genuine daemon crash.\nconst LAUNCHER_INITIAL_PPID = process.ppid;\nlet ownerLeaseHeartbeatTimer = null;\nlet ownerLeaseRequired = true;\n// Last-known descendant pids of the daemon child (excluding the child itself), refreshed by the\n// process-tree monitor while the child is alive; the give-up reap path uses this to find an\n// orphaned sidecar after the child has already exited.\nlet lastKnownDescendantPids = [];\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n// Daemon exit code meaning \"another live process holds the database\n// single-writer lock\". Never counts toward the crash loop: the right move is\n// bridging to the live owner (or a bounded retry while a maintenance script\n// finishes), not relaunching a doomed second writer. Mirrored in\n// mcp_server context-server (EXIT_DB_LOCK_HELD).\nconst EXIT_DB_LOCK_HELD = 86;\nconst DB_LOCK_HELD_MAX_RETRIES = 3;\nlet dbLockHeldRetries = 0;\n\nfunction log(message) {\n  process.stderr.write(`[mk-spec-memory-launcher] ${message}\\n`);\n  persistLauncherLogLine(`${new Date().toISOString()} [pid ${process.pid}] ${message}\\n`);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(operation, targetPath, error) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  log(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\n// Persistent launcher log: log() writes to stderr, which the MCP host captures inconsistently; it\n// ALSO appends here so an owner-disposal race or daemon flap is attributable after the fact from a\n// durable file. The append is best-effort and size-bounded — a logging failure must never affect the\n// launcher, and the file rotates to a single previous generation once it crosses the cap so it cannot\n// grow without bound.\nfunction launcherLogIsEnabled(env = process.env) {\n  return env.SPECKIT_LAUNCHER_LOG !== '0';\n}\nfunction launcherLogMaxBytes(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LAUNCHER_LOG_MAX_BYTES, 1024 * 1024);\n}\nfunction resolveLauncherLogPath(env = process.env, baseDir = dbDir) {\n  const override = env.SPECKIT_LAUNCHER_LOG_PATH;\n  return typeof override === 'string' && override.trim()\n    ? override.trim()\n    : path.join(baseDir, '.mk-spec-memory-launcher.log');\n}\nfunction shouldRotateLauncherLog(currentSizeBytes, maxBytes) {\n  return Number.isFinite(currentSizeBytes) && Number.isFinite(maxBytes) && currentSizeBytes > maxBytes;\n}\nfunction persistLauncherLogLine(line) {\n  if (!launcherLogIsEnabled()) return;\n  let target;\n  try {\n    target = resolveLauncherLogPath();\n    try {\n      const { size } = fs.statSync(target);\n      if (shouldRotateLauncherLog(size, launcherLogMaxBytes())) {\n        try {\n          // Rotate to a DISTINCT sibling. A `.log` path keeps a `.prev.log` (still matched by the\n          // *.log gitignore); any other operator-overridden path appends `.prev` so a non-`.log`\n          // suffix still rotates instead of renaming the file onto itself and growing without bound.\n          const rotated = target.endsWith('.log') ? target.replace(/\\.log$/, '.prev.log') : `${target}.prev`;\n          fs.renameSync(target, rotated);\n        } catch {\n          // Best-effort rotation: if the rename fails, keep appending to the current file.\n        }\n      }\n    } catch (statErr) {\n      if (statErr.code !== 'ENOENT') throw statErr;\n    }\n    fs.appendFileSync(target, line, { mode: 0o600 });\n  } catch (error) {\n    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (on by default; set SPECKIT_DAEMON_REELECTION=0 or off to restore kill-on-disposal).\n// When enabled the owner spawns the daemon detached and, on its own shutdown, RELEASES the daemon\n// (leaves it running for a live secondary to bridge to) instead of killing it, so a session ending does\n// not tear the shared backend out from under other sessions. A fresh session that finds the released\n// daemon under a stale lease ADOPTS it through the bridge when the recorded child is alive and bridgeable;\n// it reaps and respawns only when that daemon is dead or unbridgeable, so the database keeps a single\n// writer either way. Disabling collapses every path below to the prior behavior (daemon tied to the owner,\n// killed on shutdown). A released daemon reparents to pid 1, bounded by its idle self-exit, so the orphan\n// sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION !== '0' && env.SPECKIT_DAEMON_REELECTION !== 'off';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {\n  return reelectionEnabled\n    ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n    : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n}\nfunction shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n  return Boolean(enabled) && Boolean(hasLiveDaemon);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","lineStart":1,"lineEnd":260,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781763938609,"end":1781763938626}},"metadata":{"openai":{"itemId":"fc_04bdf27f9212786a016a338f624f488191bda0b999846b4e0c"}},"id":"prt_ed96818d6001AmUE8dZAvS7w6F","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed967e59d001KKe7NFWBvYIMl7"}}
{"type":"tool_use","timestamp":1781763938629,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_FgiTQHQKqC2GGhaVREASbrrB","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","offset":430,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n430:   if (typeof value !== 'string' || value.trim() === '') return null;\n431:   const raw = value.trim();\n432:   if (raw.startsWith('tcp://')) return raw;\n433:   if (raw.startsWith('http://') || raw.startsWith('https://')) {\n434:     const url = new URL(raw);\n435:     return `tcp://${url.hostname}:${url.port || (url.protocol === 'https:' ? '443' : '80')}`;\n436:   }\n437:   if (raw.startsWith('unix://')) return path.resolve(raw.slice('unix://'.length));\n438:   return path.resolve(raw);\n439: }\n440: \n441: function resolveModelServerSocketPath(env = process.env, options = {}) {\n442:   const explicitTarget = normalizeModelServerTarget(options.listenTarget || env.HF_EMBED_SERVER_URL);\n443:   if (explicitTarget) return explicitTarget;\n444:   if (env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) return env.SPECKIT_IPC_SOCKET_DIR;\n445: \n446:   const rawDbDir = typeof options.dbDir === 'function' ? options.dbDir() : options.dbDir;\n447:   const socketDir = env.SPECKIT_IPC_SOCKET_DIR\n448:     ? path.resolve(env.SPECKIT_IPC_SOCKET_DIR)\n449:     : path.resolve(rawDbDir || path.join(defaultOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'));\n450:   return path.join(socketDir, HF_MODEL_SERVER_SOCKET_FILE_NAME);\n451: }\n452: \n453: function codedError(code, message) {\n454:   const error = new Error(message);\n455:   error.code = code;\n456:   return error;\n457: }\n458: \n459: function assertSunPathLimit(socketPath) {\n460:   if (socketPath.startsWith('tcp://')) return;\n461:   const byteLength = Buffer.byteLength(socketPath);\n462:   // sun_path is a 104-byte field on macOS INCLUDING the NUL terminator, so the longest path that\n463:   // actually binds is 103 bytes. Reject at 104 to avoid an EINVAL that would otherwise pass this guard.\n464:   if (byteLength <= 103) return;\n465:   throw codedError(\n466:     'ESUNPATHTOOLONG',\n467:     `hf-model-server socket path exceeds the conservative 104-byte sun_path limit (${byteLength} bytes): ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory.`,\n468:   );\n469: }\n470: \n471: function assertSocketDirOwnership(socketPath, options = {}) {\n472:   if (socketPath.startsWith('tcp://')) return;\n473:   const statApi = options.statApi || fs;\n474:   const getuid = options.getuid;\n475:   const socketDir = path.dirname(socketPath);\n476:   let dirStat = null;\n477:   try {\n478:     dirStat = statApi.lstatSync(socketDir);\n479:   } catch (error) {\n480:     if (error.code !== 'ENOENT') throw error;\n481:   }\n482: \n483:   if (dirStat) {\n484:     if (dirStat.isSymbolicLink()) {\n485:       throw codedError('ESOCKETDIRSYMLINK', `Refusing to use symlinked SPECKIT_IPC_SOCKET_DIR for hf-model-server socket: ${socketDir}`);\n486:     }\n487:     const uid = typeof getuid === 'function' ? getuid() : undefined;\n488:     if (Number.isInteger(uid) && Number.isInteger(dirStat.uid) && dirStat.uid !== uid) {\n489:       throw codedError('ESOCKETDIRFOREIGN', `Refusing to use hf-model-server socket directory owned by uid ${dirStat.uid}; current uid is ${uid}: ${socketDir}`);\n490:     }\n491:   }\n492: \n493:   try {\n494:     const socketStat = statApi.lstatSync(socketPath);\n495:     if (socketStat.isSymbolicLink()) {\n496:       throw codedError('ESOCKETSYMLINK', `Refusing to unlink or bind through symlinked hf-model-server socket node: ${socketPath}`);\n497:     }\n498:   } catch (error) {\n499:     if (error.code !== 'ENOENT') throw error;\n500:   }\n501: }\n502: \n503: function modelServerRespawnLockPath(socketPath = resolveModelServerSocketPath(), options = {}) {\n504:   const rawDbDir = typeof options.dbDir === 'function' ? options.dbDir() : options.dbDir;\n505:   const lockDirPath = socketPath.startsWith('tcp://')\n506:     ? path.resolve(rawDbDir || path.join(defaultOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'))\n507:     : path.dirname(socketPath);\n508:   return path.join(lockDirPath, HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME);\n509: }\n510: \n511: function modelServerGiveUpPath(socketPath = resolveModelServerSocketPath(), options = {}) {\n512:   const rawDbDir = typeof options.dbDir === 'function' ? options.dbDir() : options.dbDir;\n513:   const giveUpDirPath = socketPath.startsWith('tcp://')\n514:     ? path.resolve(rawDbDir || path.join(defaultOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'))\n515:     : path.dirname(socketPath);\n516:   return path.join(giveUpDirPath, HF_MODEL_SERVER_GIVEUP_FILE_NAME);\n517: }\n518: \n519: function writeModelServerGiveUpUntil(socketPath, giveUpUntilMs, options = {}) {\n520:   const logger = options.log || defaultLog;\n521:   const rel = options.rel || ((p) => p);\n522:   const fsApi = { ...fs, ...(options.fs || {}) };\n523:   const giveUpPath = path.join(ensureCanonicalDir(path.dirname(modelServerGiveUpPath(socketPath, options))), HF_MODEL_SERVER_GIVEUP_FILE_NAME);\n524:   if (!Number.isFinite(giveUpUntilMs) || giveUpUntilMs <= 0) {\n525:     try {\n526:       fsApi.unlinkSync(giveUpPath);\n527:     } catch (error) {\n528:       if (error.code === 'ENOENT') return true;\n529:       if (isDurableWriteUnavailable(error)) {\n530:         logDurableWriteUnavailableOnce(logger, 'hf-model-server give-up clear', giveUpPath, error, rel);\n531:         return false;\n532:       }\n533:       throw error;\n534:     }\n535:     return true;\n536:   }\n537: \n538:   const tmp = `${giveUpPath}.tmp.${process.pid}`;\n539:   try {\n540:     fsApi.writeFileSync(tmp, `${JSON.stringify({\n541:       giveUpUntil: giveUpUntilMs,\n542:       writtenAt: new Date().toISOString(),\n543:       pid: process.pid,\n544:     }, null, 2)}\\n`, { mode: 0o600 });\n545:     fsApi.renameSync(tmp, giveUpPath);\n546:     return true;\n547:   } catch (error) {\n548:     cleanupTmpFile(tmp, fsApi);\n549:     if (isDurableWriteUnavailable(error)) {\n550:       logDurableWriteUnavailableOnce(logger, 'hf-model-server give-up write', giveUpPath, error, rel);\n551:       return false;\n552:     }\n553:     throw error;\n554:   }\n555: }\n556: \n557: function nowMsFromOptions(options = {}) {\n558:   if (typeof options.nowMs === 'function') return options.nowMs();\n559:   if (typeof options.nowMs === 'number') return options.nowMs;\n560:   return Date.now();\n561: }\n562: \n563: function modelServerGiveUpStaleMs(options = {}) {\n564:   const giveUpCooldownMs = parsePositiveInteger(options.giveUpCooldownMs, getModelServerGiveUpCooldownMs(options.env || process.env));\n565:   const staleMs = parsePositiveInteger(options.staleMs, RESPAWN_LOCK_STALE_MS);\n566:   return Math.max(staleMs, giveUpCooldownMs);\n567: }\n568: \n569: function isModelServerGiveUpStale(parsed, options = {}) {\n570:   const liveness = options.liveness || processLiveness;\n571:   if (liveness(parsed?.pid) === 'dead') return true;\n572: \n573:   const writtenAtMs = parsed?.writtenAt ? Date.parse(parsed.writtenAt) : NaN;\n574:   if (!Number.isFinite(writtenAtMs)) return false;\n575:   return nowMsFromOptions(options) - writtenAtMs > modelServerGiveUpStaleMs(options);\n576: }\n577: \n578: function unlinkBestEffort(filePath, fsApi = fs) {\n579:   try {\n580:     fsApi.unlinkSync(filePath);\n581:   } catch {\n582:     // Best-effort stale-state cleanup.\n583:   }\n584: }\n585: \n586: function readModelServerGiveUpUntil(socketPath, options = {}) {\n587:   const fsApi = { ...fs, ...(options.fs || {}) };\n588:   const giveUpPath = modelServerGiveUpPath(socketPath, options);\n589:   try {\n590:     const parsed = JSON.parse(fsApi.readFileSync(giveUpPath, 'utf8'));\n591:     if (isModelServerGiveUpStale(parsed, options)) {\n592:       unlinkBestEffort(giveUpPath, fsApi);\n593:       return null;\n594:     }\n595:     return Number.isFinite(parsed?.giveUpUntil) && parsed.giveUpUntil > 0 ? parsed.giveUpUntil : null;\n596:   } catch {\n597:     return null;\n598:   }\n599: }\n600: \n601: // ── Maintenance-active marker ────────────────────────────────────────────────\n602: // A background index scan can legitimately keep the daemon's event loop busy for\n603: // stretches, so a competing launcher's deep liveness probe sees an unresponsive\n604: // socket and would reap+respawn the daemon mid-scan (killing the scan). The\n605: // daemon writes this marker beside its DB and refreshes it on a timer; the\n606: // launcher uses it to tell \"busy-by-design\" from \"wedged\": a fresh marker naming\n607: // the live daemon child means ADOPT, not reap. A genuinely wedged daemon cannot\n608: // fire its refresh timer, so the marker expires and normal reaping resumes.\n609: const MAINTENANCE_MARKER_FILE_NAME = '.maintenance-active.json';\n\n(Showing lines 430-609 of 1474. Use offset=610 to continue.)\n</content>","metadata":{"preview":"  if (typeof value !== 'string' || value.trim() === '') return null;\n  const raw = value.trim();\n  if (raw.startsWith('tcp://')) return raw;\n  if (raw.startsWith('http://') || raw.startsWith('https://')) {\n    const url = new URL(raw);\n    return `tcp://${url.hostname}:${url.port || (url.protocol === 'https:' ? '443' : '80')}`;\n  }\n  if (raw.startsWith('unix://')) return path.resolve(raw.slice('unix://'.length));\n  return path.resolve(raw);\n}\n\nfunction resolveModelServerSocketPath(env = process.env, options = {}) {\n  const explicitTarget = normalizeModelServerTarget(options.listenTarget || env.HF_EMBED_SERVER_URL);\n  if (explicitTarget) return explicitTarget;\n  if (env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) return env.SPECKIT_IPC_SOCKET_DIR;\n\n  const rawDbDir = typeof options.dbDir === 'function' ? options.dbDir() : options.dbDir;\n  const socketDir = env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(rawDbDir || path.join(defaultOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'));","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","text":"  if (typeof value !== 'string' || value.trim() === '') return null;\n  const raw = value.trim();\n  if (raw.startsWith('tcp://')) return raw;\n  if (raw.startsWith('http://') || raw.startsWith('https://')) {\n    const url = new URL(raw);\n    return `tcp://${url.hostname}:${url.port || (url.protocol === 'https:' ? '443' : '80')}`;\n  }\n  if (raw.startsWith('unix://')) return path.resolve(raw.slice('unix://'.length));\n  return path.resolve(raw);\n}\n\nfunction resolveModelServerSocketPath(env = process.env, options = {}) {\n  const explicitTarget = normalizeModelServerTarget(options.listenTarget || env.HF_EMBED_SERVER_URL);\n  if (explicitTarget) return explicitTarget;\n  if (env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) return env.SPECKIT_IPC_SOCKET_DIR;\n\n  const rawDbDir = typeof options.dbDir === 'function' ? options.dbDir() : options.dbDir;\n  const socketDir = env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(rawDbDir || path.join(defaultOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'));\n  return path.join(socketDir, HF_MODEL_SERVER_SOCKET_FILE_NAME);\n}\n\nfunction codedError(code, message) {\n  const error = new Error(message);\n  error.code = code;\n  return error;\n}\n\nfunction assertSunPathLimit(socketPath) {\n  if (socketPath.startsWith('tcp://')) return;\n  const byteLength = Buffer.byteLength(socketPath);\n  // sun_path is a 104-byte field on macOS INCLUDING the NUL terminator, so the longest path that\n  // actually binds is 103 bytes. Reject at 104 to avoid an EINVAL that would otherwise pass this guard.\n  if (byteLength <= 103) return;\n  throw codedError(\n    'ESUNPATHTOOLONG',\n    `hf-model-server socket path exceeds the conservative 104-byte sun_path limit (${byteLength} bytes): ${socketPath}. Set SPECKIT_IPC_SOCKET_DIR to a shorter directory.`,\n  );\n}\n\nfunction assertSocketDirOwnership(socketPath, options = {}) {\n  if (socketPath.startsWith('tcp://')) return;\n  const statApi = options.statApi || fs;\n  const getuid = options.getuid;\n  const socketDir = path.dirname(socketPath);\n  let dirStat = null;\n  try {\n    dirStat = statApi.lstatSync(socketDir);\n  } catch (error) {\n    if (error.code !== 'ENOENT') throw error;\n  }\n\n  if (dirStat) {\n    if (dirStat.isSymbolicLink()) {\n      throw codedError('ESOCKETDIRSYMLINK', `Refusing to use symlinked SPECKIT_IPC_SOCKET_DIR for hf-model-server socket: ${socketDir}`);\n    }\n    const uid = typeof getuid === 'function' ? getuid() : undefined;\n    if (Number.isInteger(uid) && Number.isInteger(dirStat.uid) && dirStat.uid !== uid) {\n      throw codedError('ESOCKETDIRFOREIGN', `Refusing to use hf-model-server socket directory owned by uid ${dirStat.uid}; current uid is ${uid}: ${socketDir}`);\n    }\n  }\n\n  try {\n    const socketStat = statApi.lstatSync(socketPath);\n    if (socketStat.isSymbolicLink()) {\n      throw codedError('ESOCKETSYMLINK', `Refusing to unlink or bind through symlinked hf-model-server socket node: ${socketPath}`);\n    }\n  } catch (error) {\n    if (error.code !== 'ENOENT') throw error;\n  }\n}\n\nfunction modelServerRespawnLockPath(socketPath = resolveModelServerSocketPath(), options = {}) {\n  const rawDbDir = typeof options.dbDir === 'function' ? options.dbDir() : options.dbDir;\n  const lockDirPath = socketPath.startsWith('tcp://')\n    ? path.resolve(rawDbDir || path.join(defaultOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'))\n    : path.dirname(socketPath);\n  return path.join(lockDirPath, HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME);\n}\n\nfunction modelServerGiveUpPath(socketPath = resolveModelServerSocketPath(), options = {}) {\n  const rawDbDir = typeof options.dbDir === 'function' ? options.dbDir() : options.dbDir;\n  const giveUpDirPath = socketPath.startsWith('tcp://')\n    ? path.resolve(rawDbDir || path.join(defaultOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'))\n    : path.dirname(socketPath);\n  return path.join(giveUpDirPath, HF_MODEL_SERVER_GIVEUP_FILE_NAME);\n}\n\nfunction writeModelServerGiveUpUntil(socketPath, giveUpUntilMs, options = {}) {\n  const logger = options.log || defaultLog;\n  const rel = options.rel || ((p) => p);\n  const fsApi = { ...fs, ...(options.fs || {}) };\n  const giveUpPath = path.join(ensureCanonicalDir(path.dirname(modelServerGiveUpPath(socketPath, options))), HF_MODEL_SERVER_GIVEUP_FILE_NAME);\n  if (!Number.isFinite(giveUpUntilMs) || giveUpUntilMs <= 0) {\n    try {\n      fsApi.unlinkSync(giveUpPath);\n    } catch (error) {\n      if (error.code === 'ENOENT') return true;\n      if (isDurableWriteUnavailable(error)) {\n        logDurableWriteUnavailableOnce(logger, 'hf-model-server give-up clear', giveUpPath, error, rel);\n        return false;\n      }\n      throw error;\n    }\n    return true;\n  }\n\n  const tmp = `${giveUpPath}.tmp.${process.pid}`;\n  try {\n    fsApi.writeFileSync(tmp, `${JSON.stringify({\n      giveUpUntil: giveUpUntilMs,\n      writtenAt: new Date().toISOString(),\n      pid: process.pid,\n    }, null, 2)}\\n`, { mode: 0o600 });\n    fsApi.renameSync(tmp, giveUpPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp, fsApi);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(logger, 'hf-model-server give-up write', giveUpPath, error, rel);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction nowMsFromOptions(options = {}) {\n  if (typeof options.nowMs === 'function') return options.nowMs();\n  if (typeof options.nowMs === 'number') return options.nowMs;\n  return Date.now();\n}\n\nfunction modelServerGiveUpStaleMs(options = {}) {\n  const giveUpCooldownMs = parsePositiveInteger(options.giveUpCooldownMs, getModelServerGiveUpCooldownMs(options.env || process.env));\n  const staleMs = parsePositiveInteger(options.staleMs, RESPAWN_LOCK_STALE_MS);\n  return Math.max(staleMs, giveUpCooldownMs);\n}\n\nfunction isModelServerGiveUpStale(parsed, options = {}) {\n  const liveness = options.liveness || processLiveness;\n  if (liveness(parsed?.pid) === 'dead') return true;\n\n  const writtenAtMs = parsed?.writtenAt ? Date.parse(parsed.writtenAt) : NaN;\n  if (!Number.isFinite(writtenAtMs)) return false;\n  return nowMsFromOptions(options) - writtenAtMs > modelServerGiveUpStaleMs(options);\n}\n\nfunction unlinkBestEffort(filePath, fsApi = fs) {\n  try {\n    fsApi.unlinkSync(filePath);\n  } catch {\n    // Best-effort stale-state cleanup.\n  }\n}\n\nfunction readModelServerGiveUpUntil(socketPath, options = {}) {\n  const fsApi = { ...fs, ...(options.fs || {}) };\n  const giveUpPath = modelServerGiveUpPath(socketPath, options);\n  try {\n    const parsed = JSON.parse(fsApi.readFileSync(giveUpPath, 'utf8'));\n    if (isModelServerGiveUpStale(parsed, options)) {\n      unlinkBestEffort(giveUpPath, fsApi);\n      return null;\n    }\n    return Number.isFinite(parsed?.giveUpUntil) && parsed.giveUpUntil > 0 ? parsed.giveUpUntil : null;\n  } catch {\n    return null;\n  }\n}\n\n// ── Maintenance-active marker ────────────────────────────────────────────────\n// A background index scan can legitimately keep the daemon's event loop busy for\n// stretches, so a competing launcher's deep liveness probe sees an unresponsive\n// socket and would reap+respawn the daemon mid-scan (killing the scan). The\n// daemon writes this marker beside its DB and refreshes it on a timer; the\n// launcher uses it to tell \"busy-by-design\" from \"wedged\": a fresh marker naming\n// the live daemon child means ADOPT, not reap. A genuinely wedged daemon cannot\n// fire its refresh timer, so the marker expires and normal reaping resumes.\nconst MAINTENANCE_MARKER_FILE_NAME = '.maintenance-active.json';","lineStart":430,"lineEnd":609,"totalLines":1474,"truncated":true}},"title":".opencode/bin/lib/model-server-supervision.cjs","time":{"start":1781763938621,"end":1781763938628}},"metadata":{"openai":{"itemId":"fc_04bdf27f9212786a016a338f624f588191838e530ec4ad362f"}},"id":"prt_ed9681937001omDgaWJAer9ZtJ","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed967e59d001KKe7NFWBvYIMl7"}}
