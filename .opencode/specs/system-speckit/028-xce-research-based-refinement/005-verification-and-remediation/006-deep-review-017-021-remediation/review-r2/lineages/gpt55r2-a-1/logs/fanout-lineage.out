ergenceBonus;\n278:   const convergenceBonus = typeof rawConvergenceBonus === 'number' && Number.isFinite(rawConvergenceBonus) && rawConvergenceBonus >= 0\n279:     ? rawConvergenceBonus\n280:     : CONVERGENCE_BONUS;\n281:   const rawGraphWeightBoost = options.graphWeightBoost;\n282:   const graphWeightBoost = typeof rawGraphWeightBoost === 'number' && Number.isFinite(rawGraphWeightBoost) && rawGraphWeightBoost >= 0\n283:     ? rawGraphWeightBoost\n284:     : GRAPH_WEIGHT_BOOST;\n285: \n286:   // REQ-D1-001: Resolve beta for calibrated overlap bonus\n287:   const rawBeta = options.calibratedOverlapBeta;\n288:   const beta = typeof rawBeta === 'number' && Number.isFinite(rawBeta) && rawBeta >= 0\n289:     ? rawBeta\n290:     : CALIBRATED_OVERLAP_BETA;\n291: \n292:   // Track per-candidate raw (pre-convergence) RRF scores per source for meanTopNormScore\n293:   // Maps canonical id -> Map<source, rawRrfScore>\n294:   const rawScoresBySource = new Map<string, Map<string, number>>();\n295:   const scoreMap = new Map<string, FusionResult>();\n296:   let activeChannelCount = 0;\n297: \n298:   for (const list of lists) {\n299:     // AI-WHY: Use ?? so explicit weight=0 is honoured (|| would treat 0 as falsy).\n300:     // Graph source gets GRAPH_WEIGHT_BOOST when no weight is given because curated\n301:     // causal edges are higher-signal than unweighted lexical/vector channels.\n302:     const rawWeight = list.weight ?? (list.source === SOURCE_TYPES.GRAPH ? graphWeightBoost : 1.0);\n303:     const weight = typeof rawWeight === 'number' && Number.isFinite(rawWeight) && rawWeight >= 0 ? rawWeight : 0;\n304:     if (weight <= 0 || list.results.length === 0) {\n305:       continue;\n306:     }\n307:     activeChannelCount += 1;\n308:     for (let i = 0; i < list.results.length; i++) {\n309:       const item = list.results[i];\n310:       const rrfScore = weight * (1 / (k + i + 1));\n311:       const key = canonicalRrfId(item.id);\n312:       const existing = scoreMap.get(k