${missing.join(', ') || 'none'}; `\n34:       + `unexpected=${unexpected.join(', ') || 'none'}`,\n35:     );\n36:   }\n37: }\n\n(End of file - total 37 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Code Index CLI Manifest\n// -------------------------------------------------------------------\n\nimport {\n  CODE_GRAPH_TOOL_SCHEMAS,\n  type ToolDefinition,\n} from './tool-schemas.js';\n\nconst EXPECTED_TOOL_NAMES = [\n  'code_graph_scan',\n  'code_graph_query',\n  'code_graph_status',\n  'code_graph_context',\n  'code_graph_classify_query_intent',\n  'code_graph_verify',\n  'code_graph_apply',\n  'detect_changes',\n] as const;\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/code-index-cli-manifest.ts","text":"// -------------------------------------------------------------------\n// MODULE: Code Index CLI Manifest\n// -------------------------------------------------------------------\n\nimport {\n  CODE_GRAPH_TOOL_SCHEMAS,\n  type ToolDefinition,\n} from './tool-schemas.js';\n\nconst EXPECTED_TOOL_NAMES = [\n  'code_graph_scan',\n  'code_graph_query',\n  'code_graph_status',\n  'code_graph_context',\n  'code_graph_classify_query_intent',\n  'code_graph_verify',\n  'code_graph_apply',\n  'detect_changes',\n] as const;\n\nexport const CODE_INDEX_CLI_TOOL_DEFINITIONS: readonly ToolDefinition[] = CODE_GRAPH_TOOL_SCHEMAS;\n\nexport function assertCodeIndexCliManifest(): void {\n  const actualNames = CODE_INDEX_CLI_TOOL_DEFINITIONS.map((tool) => tool.name);\n  const actualNameSet = new Set(actualNames);\n  const expectedNameSet = new Set<string>(EXPECTED_TOOL_NAMES);\n  const missing = EXPECTED_TOOL_NAMES.filter((name) => !actualNameSet.has(name));\n  const unexpected = actualNames.filter((name) => !expectedNameSet.has(name));\n\n  if (actualNames.length !== EXPECTED_TOOL_NAMES.length || missing.length > 0 || unexpected.length > 0) {\n    throw new Error(\n      `code-index CLI manifest mismatch: expected ${EXPECTED_TOOL_NAMES.length} tools; `\n      + `actual=${actualNames.length}; missing=${missing.join(', ') || 'none'}; `\n      + `unexpected=${unexpected.join(', ') || 'none'}`,\n    );\n  }\n}","lineStart":1,"lineEnd":37,"totalLines":37,"truncated":false}},"title":".opencode/skills/system-code-graph/mcp_server/code-index-cli-manifest.ts","time":{"start":1781128894732,"end":1781128894747}},"metadata":{"openai":{"itemId":"fc_04982ba3437ec52c016a29debe74588191a066883ff6a76823"}},"id":"prt_eb38e1900001ha5Tfok2cMsr9I","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38df1af001CMbl4y63THUwVq"}}
