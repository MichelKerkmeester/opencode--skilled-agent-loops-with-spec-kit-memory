  1258	// ─────────────────────────────────────────────────────────────────────────────
  1259	// 14. SERVER LAUNCH & SIGNAL HANDLING
  1260	// ─────────────────────────────────────────────────────────────────────────────
  1261	
  1262	function launchServer() {
