   419	  const surfaceM = /(?:Expected\s+)?Surface\*{0,2}:\s*`?([A-Za-z_]+)`?/i.exec(text);
   420	  const subLangM = /Sub-language:\s*`?([A-Za-z]+)`?/i.exec(text);
   421	  const refBlock = sectionAfter(text, /\*\*Expected references loaded\*\*/i);
   422	  const assetBlock = sectionAfter(text, /\*\*Expected assets loaded\*\*/i);
   423	  const passM = /###?\s*Pass\/Fail Criteria\s*([\s\S]*?)(?:\n###?\s|\n##\s|$)/i.exec(text);
   424	  const passCriteria = (passM ? passM[1].trim() : null) || (rootEntry && rootEntry.passCriteria) || null;
   425	
   426	  const KNOWN_SURFACES = new Set(['WEBFLOW', 'OPENCODE', 'UNKNOWN', 'MOTION_DEV', 'NONE']);
