   103	
   104	def benchmark_subprocess(prompts: List[str], runs: int, threshold: float, uncertainty: float) -> Dict[str, Any]:
   105	    """Benchmark one-shot subprocess execution for advisor prompts."""
   106	    latencies: List[float] = []
   107	    total_prompts = 0
   108	    run_env = os.environ.copy()
   109	    run_env[BENCH_ENV_FLAG] = "1"
   110	    t0 = time.perf_counter()
   111	    for _ in range(runs):
   112	        for prompt in prompts:
   113	            start = time.perf_counter()
   114	            subprocess.run(
   115	                [
   116	                    "python3",
   117	                    ADVISOR_PATH,
   118	                    "--threshold",
   119	                    str(threshold),
   120	                    "--uncertainty",
   121	                    str(uncertainty),
   122	                    "--",
   123	                    prompt,
   124	                ],
   125	                check=True,
   126	                stdout=subprocess.DEVNULL,
   127	                stderr=subprocess.DEVNULL,
   128	                env=run_env,
   129	            )
   130	            latencies.append((time.perf_counter() - start) * 1000)
   131	            total_prompts += 1
   132	    elapsed = time.perf_counter() - t0
   133	    summary = summarize(latencies)
   134	    summary["runtime_mode"] = "subprocess_one_shot"
   135	    summary["throughput_prompts_per_sec"] = round((total_prompts / elapsed) if elapsed else 0.0, 4)
   136	    summary["total_prompts"] = total_prompts
   137	    return summary
   138	
   139	
   140	def benchmark_inprocess(prompts: List[str], runs: int, threshold: float, uncertainty: float) -> Dict[str, Any]:
   141	    """Benchmark warm in-process advisor calls after module load."""
   142	    original_semantic = os.environ.get(BENCH_ENV_FLAG)
   143	    os.environ[BENCH_ENV_FLAG] = "1"
   144	    advisor = load_advisor_module()
   145	    latencies: List[float] = []
   146	    total_prompts = 0
   147	    t0 = time.perf_counter()
   148	    try:
   149	        for _ in range(runs):
   150	            for prompt in prompts:
   151	                start = time.perf_counter()
   152	                advisor.analyze_prompt(
   153	                    prompt=prompt,
   154	                    confidence_threshold=threshold,
   155	                    uncertainty_threshold=uncertainty,
   156	                    confidence_only=False,
   157	                    show_rejections=False,
   158	                )
   159	                latencies.append((time.perf_counter() - start) * 1000)
   160	                total_prompts += 1
   161	    finally:
   162	        if original_semantic is None:
   163	            os.environ.pop(BENCH_ENV_FLAG, None)
   164	        else:
   165	            os.environ[BENCH_ENV_FLAG] = original_semantic
   166	    elapsed = time.perf_counter() - t0
   167	    summary = summarize(latencies)
   168	    summary["runtime_mode"] = "python_inprocess"
   169	    summary["throughput_prompts_per_sec"] = round((total_prompts / elapsed) if elapsed else 0.0, 4)
   170	    summary["total_prompts"] = total_prompts
   171	    return summary
   172	
   173	
   174	def benchmark_batch_mode(prompts: List[str], runs: int, threshold: float, uncertainty: float) -> Dict[str, Any]:
   175	    """Benchmark batch-file execution to measure amortized throughput."""
   176	    batch_latencies: List[float] = []
   177	    total_prompts = 0
   178	    run_env = os.environ.copy()
   179	    run_env[BENCH_ENV_FLAG] = "1"
   180	    with tempfile.NamedTemporaryFile("w", encoding="utf-8", delete=False) as handle:
   181	        for prompt in prompts:
   182	            handle.write(prompt)
   183	            handle.write("\n")
   184	        batch_path = handle.name
   185	
   186	    try:
   187	        t0 = time.perf_counter()
   188	        for _ in range(runs):
   189	            start = time.perf_counter()
   190	            subprocess.run(
   191	                [
   192	                    "python3",
   193	                    ADVISOR_PATH,
   194	                    "--batch-file",
   195	                    batch_path,
   196	                    "--threshold",
   197	                    str(threshold),
   198	                    "--uncertainty",
   199	                    str(uncertainty),
   200	                ],
   201	                check=True,
   202	                stdout=subprocess.DEVNULL,
   203	                stderr=subprocess.DEVNULL,
   204	                env=run_env,
   205	            )
   206	            batch_latencies.append((time.perf_counter() - start) * 1000)
   207	            total_prompts += len(prompts)
   208	        elapsed = time.perf_counter() - t0
   209	    finally:
   210	        try:
   211	            os.unlink(batch_path)
   212	        except OSError:
   213	            pass
   214	
   215	    summary = summarize(batch_latencies)
   216	    summary["runtime_mode"] = "subprocess_batch"
   217	    summary["throughput_prompts_per_sec"] = round((total_prompts / elapsed) if elapsed else 0.0, 4)
   218	    summary["total_prompts"] = total_prompts
   219	    summary["batch_size"] = len(prompts)
