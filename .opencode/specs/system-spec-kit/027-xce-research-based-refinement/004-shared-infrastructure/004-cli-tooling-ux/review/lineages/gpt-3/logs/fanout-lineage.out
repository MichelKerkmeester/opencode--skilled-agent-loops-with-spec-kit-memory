{"type":"tool_use","timestamp":1781145109333,"sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","part":{"type":"tool","tool":"read","callID":"call_LJxUYvLRy3bniYHLoM73voVB","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/spec-memory-bridge-allowlist.vitest.ts","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/spec-memory-bridge-allowlist.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Spec Memory Bridge Allowlist Tests\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { resolve } from 'node:path';\n6: import { pathToFileURL } from 'node:url';\n7: \n8: import { describe, expect, it } from 'vitest';\n9: \n10: const bridgePath = resolve(import.meta.dirname, '../plugin_bridges/mk-spec-memory-bridge.mjs');\n11: \n12: interface BridgeModule {\n13:   readonly promptSafeSpecMemoryBridgePolicy: (input: { request: string; toolName: string }) => { allowed: boolean; reason: string };\n14:   readonly runCli: (input: Record<string, unknown>) => Promise<{ status: string; error?: string; metadata: Record<string, unknown> }>;\n15: }\n16: \n17: async function loadBridge(): Promise<BridgeModule> {\n18:   return await import(pathToFileURL(bridgePath).href) as BridgeModule;\n19: }\n20: \n21: describe('spec-memory prompt bridge allowlist', () => {\n22:   it('allows the prompt-time brief and status routes', async () => {\n23:     const bridge = await loadBridge();\n24: \n25:     expect(bridge.promptSafeSpecMemoryBridgePolicy({ request: 'brief', toolName: 'session_resume' })).toEqual({\n26:       allowed: true,\n27:       reason: 'prompt_safe',\n28:     });\n29:     expect(bridge.promptSafeSpecMemoryBridgePolicy({ request: 'status', toolName: 'memory_health' })).toEqual({\n30:       allowed: true,\n31:       reason: 'prompt_safe',\n32:     });\n33:   });\n34: \n35:   it('rejects direct mutation tool names before warm probing', async () => {\n36:     const bridge = await loadBridge();\n37:     const result = await bridge.runCli({ request: 'brief', toolName: 'memory_delete', timeoutMs: 1 });\n38: \n39:     expect(result).toMatchObject({\n40:       status: 'skipped',\n41:       error: 'PROMPT_TOOL_NOT_ALLOWED',\n42:       metadata: {\n43:         route: 'prompt_safe_policy',\n44:         toolName: 'memory_delete',\n45:         retryable: false,\n46:       },\n47:     });\n48:   });\n49: });\n\n(End of file - total 49 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Spec Memory Bridge Allowlist Tests\n// ───────────────────────────────────────────────────────────────\n\nimport { resolve } from 'node:path';\nimport { pathToFileURL } from 'node:url';\n\nimport { describe, expect, it } from 'vitest';\n\nconst bridgePath = resolve(import.meta.dirname, '../plugin_bridges/mk-spec-memory-bridge.mjs');\n\ninterface BridgeModule {\n  readonly promptSafeSpecMemoryBridgePolicy: (input: { request: string; toolName: string }) => { allowed: boolean; reason: string };\n  readonly runCli: (input: Record<string, unknown>) => Promise<{ status: string; error?: string; metadata: Record<string, unknown> }>;\n}\n\nasync function loadBridge(): Promise<BridgeModule> {\n  return await import(pathToFileURL(bridgePath).href) as BridgeModule;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/spec-memory-bridge-allowlist.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Spec Memory Bridge Allowlist Tests\n// ───────────────────────────────────────────────────────────────\n\nimport { resolve } from 'node:path';\nimport { pathToFileURL } from 'node:url';\n\nimport { describe, expect, it } from 'vitest';\n\nconst bridgePath = resolve(import.meta.dirname, '../plugin_bridges/mk-spec-memory-bridge.mjs');\n\ninterface BridgeModule {\n  readonly promptSafeSpecMemoryBridgePolicy: (input: { request: string; toolName: string }) => { allowed: boolean; reason: string };\n  readonly runCli: (input: Record<string, unknown>) => Promise<{ status: string; error?: string; metadata: Record<string, unknown> }>;\n}\n\nasync function loadBridge(): Promise<BridgeModule> {\n  return await import(pathToFileURL(bridgePath).href) as BridgeModule;\n}\n\ndescribe('spec-memory prompt bridge allowlist', () => {\n  it('allows the prompt-time brief and status routes', async () => {\n    const bridge = await loadBridge();\n\n    expect(bridge.promptSafeSpecMemoryBridgePolicy({ request: 'brief', toolName: 'session_resume' })).toEqual({\n      allowed: true,\n      reason: 'prompt_safe',\n    });\n    expect(bridge.promptSafeSpecMemoryBridgePolicy({ request: 'status', toolName: 'memory_health' })).toEqual({\n      allowed: true,\n      reason: 'prompt_safe',\n    });\n  });\n\n  it('rejects direct mutation tool names before warm probing', async () => {\n    const bridge = await loadBridge();\n    const result = await bridge.runCli({ request: 'brief', toolName: 'memory_delete', timeoutMs: 1 });\n\n    expect(result).toMatchObject({\n      status: 'skipped',\n      error: 'PROMPT_TOOL_NOT_ALLOWED',\n      metadata: {\n        route: 'prompt_safe_policy',\n        toolName: 'memory_delete',\n        retryable: false,\n      },\n    });\n  });\n});","lineStart":1,"lineEnd":49,"totalLines":49,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/spec-memory-bridge-allowlist.vitest.ts","time":{"start":1781145109326,"end":1781145109331}},"metadata":{"openai":{"itemId":"fc_0d70c300c1c6a813016a2a1e148098819185b2e19e137789b1"}},"id":"prt_eb4858027001nJKa3hZukVaE1i","sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","messageID":"msg_eb4857286001X3l5JZ6zrMMOGW"}}
