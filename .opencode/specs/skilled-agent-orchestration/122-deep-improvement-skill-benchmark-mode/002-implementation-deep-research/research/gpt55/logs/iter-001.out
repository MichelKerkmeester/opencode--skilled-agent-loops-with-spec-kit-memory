   185	function buildLaneScores(
   186	  prompt: string,
   187	  projection: AdvisorProjection,
   188	  disabled: Set<ScorerLane>,
   189	  affordances: readonly NormalizedAffordance[],
   190	): LaneScores {
   191	  const scores = emptyLaneScores();
   192	  if (!disabled.has('explicit_author')) scores.explicit_author = scoreExplicitLane(prompt, projection);
   193	  if (!disabled.has('lexical')) scores.lexical = scoreLexicalLane(prompt, projection);
   194	  if (!disabled.has('derived_generated')) scores.derived_generated = scoreDerivedLane(prompt, projection, new Date(), affordances);
   195	  if (!disabled.has('semantic_shadow')) scores.semantic_shadow = scoreSemanticShadowLane(prompt, projection);
   196	  if (!disabled.has('graph_causal')) {
   197	    scores.graph_causal = scoreGraphCausalLane([
   198	      ...scores.explicit_author,
   199	      ...scores.lexical,
   200	      ...scores.derived_generated,
   201	    ], projection, {}, affordances);
   202	  }
   203	  return scores;
   204	}
