.opencode/specs/sk-git/008-research-and-requirements/research/lineages/parallel-git-luna/deep-research-state.jsonl:2:{"type":"iteration","iteration":1,"run":1,"mode":"research","target_agent":"deep-research","agent_definition_loaded":true,"resolved_route":"Resolved route: mode=research target_agent=deep-research","newInfoRatio":0.95,"status":"complete","focus":"Git publication races and worktree-independent ref construction","findingsCount":5,"noveltyJustification":"First evidence pass established the primitive-level correctness boundary and ruled out blind force push.","keyQuestions":["Which integration strategy handles concurrent publication and push races with the strongest correctness and liveness properties?","Which workspace model prevents sessions from overwriting each other's files while keeping the shared branch current?","How can a local IDE checkout stay current without disturbing uncommitted changes?","Which invariants prevent orphaned autostashes, overwritten work, force-push loss, and make rollback reliable?"],"answeredQuestions":[],"ruledOut":[{"approach":"blind git push --force","reason":"Git documents that it can lose remote commits","evidence":"https://git-scm.com/docs/git-push"},{"approach":"scratch index as an automatic conflict solver","reason":"read-tree can leave conflicting paths unresolved","evidence":"https://git-scm.com/docs/git-read-tree"}],"graphEvents":[{"type":"node","id":"q-rq1","kind":"QUESTION","label":"RQ1 integration strategy"},{"type":"node","id":"q-rq2","kind":"QUESTION","label":"RQ2 workspace model"},{"type":"node","id":"q-rq3","kind":"QUESTION","label":"RQ3 current checkout"},{"type":"node","id":"f-cas-publisher","kind":"CLAIM","label":"Serialized publisher with explicit ref CAS"},{"type":"node","id":"f-scratch-index","kind":"CLAIM","label":"Scratch index keeps IDE worktree untouched"},{"type":"node","id":"f-linked-worktree","kind":"CLAIM","label":"Linked worktrees isolate index and files"},{"type":"node","id":"s-push","kind":