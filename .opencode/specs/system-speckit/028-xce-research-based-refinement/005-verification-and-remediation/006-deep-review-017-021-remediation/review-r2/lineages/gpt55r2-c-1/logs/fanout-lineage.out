{"type":"tool_use","timestamp":1781761488155,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_JjlL5CLXkUbWdkMwSMYJCUoS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","offset":1,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Retry Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Embedding retry orchestrator\n5: // Node stdlib\n6: import * as fsPromises from 'fs/promises';\n7: \n8: // Internal modules\n9: import * as vectorIndex from '../search/vector-index.js';\n10: import { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\n11: import { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\n12: import { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\n13: import { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\n14: import { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n15: import { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n16: \n17: // Type imports\n18: import type { MemoryDbRow } from '@spec-kit/shared/types';\n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. TYPES\n22: ──────────────────────────────────────────────────────────────── */\n23: \n24: interface BackgroundJobConfig {\n25:   intervalMs: number;\n26:   batchSize: number;\n27:   enabled: boolean;\n28: }\n29: \n30: interface RetryStats {\n31:   pending: number;\n32:   retry: number;\n33:   failed: number;\n34:   success: number;\n35:   total: number;\n36:   queue_size: number;\n37: }\n38: \n39: /** In-memory-only snapshot of embedding retry health — no DB access. */\n40: export interface EmbeddingRetryStats {\n41:   pending: number;\n42:   failed: number;\n43:   retryAttempts: number;\n44:   circuitBreakerOpen: boolean;\n45:   lastRun: string | null;\n46:   queueDepth: number;\n47: }\n48: \n49: interface RetryResult {\n50:   success: boolean;\n51:   id?: number;\n52:   dimensions?: number;\n53:   error?: string;\n54:   permanent?: boolean;\n55: }\n56: \n57: interface BatchResult {\n58:   processed: number;\n59:   succeeded: number;\n60:   failed: number;\n61:   details?: RetryDetailEntry[];\n62: }\n63: \n64: interface RetryDetailEntry {\n65:   id: number;\n66:   success: boolean;\n67:   error?: string;\n68:   dimensions?: number;\n69: }\n70: \n71: interface BackgroundJobResult {\n72:   processed?: number;\n73:   succeeded?: number;\n74:   failed?: number;\n75:   details?: RetryDetailEntry[];\n76:   skipped?: boolean;\n77:   reason?: string;\n78:   queue_empty?: boolean;\n79:   error?: string;\n80: }\n81: \n82: /**\n83:  * Retry-specific memory row with required id and file_path.\n84:  * Uses MemoryDbRow as the base type with Record<string, unknown>\n85:  * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n86:  */\n87: type RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n88:   id: number;\n89:   file_path: string;\n90: };\n91: \n92: type ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\n93: type RetryQueueStatus = 'pending' | 'retry';\n94: \n95: type EmbeddingFailureCode =\n96:   | 'EMBEDDING_PROVIDER_ERROR'\n97:   | 'EMBEDDING_TIMEOUT'\n98:   | 'EMBEDDING_RATE_LIMIT';\n99: \n100: interface SanitizeEmbeddingFailureOptions {\n101:   provider?: string | null;\n102:   force?: boolean;\n103: }\n104: \n105: interface SanitizedEmbeddingFailure {\n106:   code: EmbeddingFailureCode | null;\n107:   provider: string | null;\n108:   errorType: string | null;\n109:   publicMessage: string;\n110:   sanitized: boolean;\n111: }\n112: \n113: interface RetryClaimResult {\n114:   claimed: boolean;\n115:   previousStatus: RetryQueueStatus | null;\n116: }\n117: \n118: function getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n119:   const status = typeof memory.embedding_status === 'string'\n120:     ? memory.embedding_status\n121:     : typeof memory.embeddingStatus === 'string'\n122:       ? memory.embeddingStatus\n123:       : null;\n124: \n125:   return status === 'pending' || status === 'retry' ? status : null;\n126: }\n127: \n128: function getRetryCountValue(memory: RetryMemoryRow): number {\n129:   return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n130: }\n131: \n132: function getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n133:   const value = typeof memory.last_retry_at === 'string'\n134:     ? memory.last_retry_at\n135:     : typeof memory.lastRetryAt === 'string'\n136:       ? memory.lastRetryAt\n137:       : null;\n138:   return value && value.trim().length > 0 ? value : null;\n139: }\n140: \n141: function detectEmbeddingProviderName(source: string | null | undefined): string | null {\n142:   if (typeof source !== 'string' || source.trim().length === 0) {\n143:     return null;\n144:   }\n145: \n146:   const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n147:   if (explicitProvider?.[1]) {\n148:     return explicitProvider[1].toLowerCase();\n149:   }\n150: \n151:   const lower = source.toLowerCase();\n152:   if (lower.includes('voyage')) return 'voyage';\n153:   if (lower.includes('azure')) return 'azure-openai';\n154:   if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n155:   if (lower.includes('system')) return 'system';\n156: \n157:   return null;\n158: }\n159: \n160: function shouldSanitizeEmbeddingFailure(message: string): boolean {\n161:   const lower = message.toLowerCase();\n162:   return (\n163:     /^embedding_[a-z_]+/.test(lower) ||\n164:     lower.includes('openai') ||\n165:     lower.includes('voyage') ||\n166:     lower.includes('azure') ||\n167:     lower.includes('text-embedding') ||\n168:     lower.includes('rate limit') ||\n169:     lower.includes('too many requests') ||\n170:     lower.includes('429') ||\n171:     lower.includes('timeout') ||\n172:     lower.includes('timed out') ||\n173:     lower.includes('api key') ||\n174:     lower.includes('unauthorized') ||\n175:     lower.includes('forbidden') ||\n176:     lower.includes('quota') ||\n177:     lower.includes('embedding provider')\n178:   );\n179: }\n180: \n181: function inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n182:   const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n183:   const lower = message.toLowerCase();\n184: \n185:   if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n186:     return {\n187:       code: 'EMBEDDING_TIMEOUT',\n188:       errorType: explicitType ?? 'timeout',\n189:     };\n190:   }\n191: \n192:   if (\n193:     lower.includes('embedding_rate_limit') ||\n194:     lower.includes('rate limit') ||\n195:     lower.includes('too many requests') ||\n196:     lower.includes('429')\n197:   ) {\n198:     return {\n199:       code: 'EMBEDDING_RATE_LIMIT',\n200:       errorType: explicitType ?? 'rate_limit',\n201:     };\n202:   }\n203: \n204:   if (\n205:     explicitType === 'auth' ||\n206:     lower.includes('api key') ||\n207:     lower.includes('unauthorized') ||\n208:     lower.includes('forbidden')\n209:   ) {\n210:     return {\n211:       code: 'EMBEDDING_PROVIDER_ERROR',\n212:       errorType: 'auth',\n213:     };\n214:   }\n215: \n216:   return {\n217:     code: 'EMBEDDING_PROVIDER_ERROR',\n218:     errorType: explicitType ?? 'provider_error',\n219:   };\n220: }\n221: \n222: function sanitizeEmbeddingFailure(\n223:   raw: unknown,\n224:   options: SanitizeEmbeddingFailureOptions = {},\n225: ): SanitizedEmbeddingFailure {\n226:   const publicMessage = raw instanceof Error\n227:     ? raw.message.trim()\n228:     : String(raw ?? '').trim();\n229: \n230:   if (publicMessage.length === 0) {\n231:     return {\n232:       code: null,\n233:       provider: null,\n234:       errorType: null,\n235:       publicMessage,\n236:       sanitized: false,\n237:     };\n238:   }\n239: \n240:   if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n241:     return {\n242:       code: null,\n243:       provider: null,\n244:       errorType: null,\n245:       publicMessage,\n246:       sanitized: false,\n247:     };\n248:   }\n249: \n250:   const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n251:   const { code, errorType } = inferEmbeddingFailure(publicMessage);\n252: \n253:   return {\n254:     code,\n255:     provider,\n256:     errorType,\n257:     publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n258:     sanitized: true,\n259:   };\n260: }\n261: \n262: export function sanitizeEmbeddingFailureMessage(\n263:   raw: unknown,\n264:   options: SanitizeEmbeddingFailureOptions = {},\n265: ): string | null {\n266:   const failure = sanitizeEmbeddingFailure(raw, options);\n267:   return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n268: }\n269: \n270: export function sanitizeAndLogEmbeddingFailure(\n271:   context: string,\n272:   raw: unknown,\n273:   options: SanitizeEmbeddingFailureOptions = {},\n274: ): string | null {\n275:   const failure = sanitizeEmbeddingFailure(raw, options);\n276:   if (failure.publicMessage.length === 0) {\n277:     return null;\n278:   }\n279: \n280:   if (failure.sanitized) {\n281:     console.error(context, {\n282:       sanitized: {\n283:         code: failure.code,\n284:         provider: failure.provider,\n285:         errorType: failure.errorType,\n286:       },\n287:       redacted: true,\n288:     });\n289:   }\n290: \n291:   return failure.publicMessage;\n292: }\n293: \n294: function claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n295:   const db = vectorIndex.getDb();\n296:   const previousStatus = getRetryStatus(memory);\n297:   if (!db || previousStatus === null) {\n298:     return { claimed: false, previousStatus };\n299:   }\n300: \n\n(Showing lines 1-300 of 1141. Use offset=301 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BackgroundJobConfig {\n  intervalMs: number;\n  batchSize: number;\n  enabled: boolean;\n}\n\ninterface RetryStats {\n  pending: number;\n  retry: number;\n  failed: number;\n  success: number;\n  total: number;\n  queue_size: number;\n}\n\n/** In-memory-only snapshot of embedding retry health — no DB access. */\nexport interface EmbeddingRetryStats {\n  pending: number;\n  failed: number;\n  retryAttempts: number;\n  circuitBreakerOpen: boolean;\n  lastRun: string | null;\n  queueDepth: number;\n}\n\ninterface RetryResult {\n  success: boolean;\n  id?: number;\n  dimensions?: number;\n  error?: string;\n  permanent?: boolean;\n}\n\ninterface BatchResult {\n  processed: number;\n  succeeded: number;\n  failed: number;\n  details?: RetryDetailEntry[];\n}\n\ninterface RetryDetailEntry {\n  id: number;\n  success: boolean;\n  error?: string;\n  dimensions?: number;\n}\n\ninterface BackgroundJobResult {\n  processed?: number;\n  succeeded?: number;\n  failed?: number;\n  details?: RetryDetailEntry[];\n  skipped?: boolean;\n  reason?: string;\n  queue_empty?: boolean;\n  error?: string;\n}\n\n/**\n * Retry-specific memory row with required id and file_path.\n * Uses MemoryDbRow as the base type with Record<string, unknown>\n * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n */\ntype RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n  id: number;\n  file_path: string;\n};\n\ntype ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\ntype RetryQueueStatus = 'pending' | 'retry';\n\ntype EmbeddingFailureCode =\n  | 'EMBEDDING_PROVIDER_ERROR'\n  | 'EMBEDDING_TIMEOUT'\n  | 'EMBEDDING_RATE_LIMIT';\n\ninterface SanitizeEmbeddingFailureOptions {\n  provider?: string | null;\n  force?: boolean;\n}\n\ninterface SanitizedEmbeddingFailure {\n  code: EmbeddingFailureCode | null;\n  provider: string | null;\n  errorType: string | null;\n  publicMessage: string;\n  sanitized: boolean;\n}\n\ninterface RetryClaimResult {\n  claimed: boolean;\n  previousStatus: RetryQueueStatus | null;\n}\n\nfunction getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n  const status = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof memory.embeddingStatus === 'string'\n      ? memory.embeddingStatus\n      : null;\n\n  return status === 'pending' || status === 'retry' ? status : null;\n}\n\nfunction getRetryCountValue(memory: RetryMemoryRow): number {\n  return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n}\n\nfunction getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n  const value = typeof memory.last_retry_at === 'string'\n    ? memory.last_retry_at\n    : typeof memory.lastRetryAt === 'string'\n      ? memory.lastRetryAt\n      : null;\n  return value && value.trim().length > 0 ? value : null;\n}\n\nfunction detectEmbeddingProviderName(source: string | null | undefined): string | null {\n  if (typeof source !== 'string' || source.trim().length === 0) {\n    return null;\n  }\n\n  const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n  if (explicitProvider?.[1]) {\n    return explicitProvider[1].toLowerCase();\n  }\n\n  const lower = source.toLowerCase();\n  if (lower.includes('voyage')) return 'voyage';\n  if (lower.includes('azure')) return 'azure-openai';\n  if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n  if (lower.includes('system')) return 'system';\n\n  return null;\n}\n\nfunction shouldSanitizeEmbeddingFailure(message: string): boolean {\n  const lower = message.toLowerCase();\n  return (\n    /^embedding_[a-z_]+/.test(lower) ||\n    lower.includes('openai') ||\n    lower.includes('voyage') ||\n    lower.includes('azure') ||\n    lower.includes('text-embedding') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429') ||\n    lower.includes('timeout') ||\n    lower.includes('timed out') ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden') ||\n    lower.includes('quota') ||\n    lower.includes('embedding provider')\n  );\n}\n\nfunction inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n  const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n  const lower = message.toLowerCase();\n\n  if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n    return {\n      code: 'EMBEDDING_TIMEOUT',\n      errorType: explicitType ?? 'timeout',\n    };\n  }\n\n  if (\n    lower.includes('embedding_rate_limit') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429')\n  ) {\n    return {\n      code: 'EMBEDDING_RATE_LIMIT',\n      errorType: explicitType ?? 'rate_limit',\n    };\n  }\n\n  if (\n    explicitType === 'auth' ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden')\n  ) {\n    return {\n      code: 'EMBEDDING_PROVIDER_ERROR',\n      errorType: 'auth',\n    };\n  }\n\n  return {\n    code: 'EMBEDDING_PROVIDER_ERROR',\n    errorType: explicitType ?? 'provider_error',\n  };\n}\n\nfunction sanitizeEmbeddingFailure(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): SanitizedEmbeddingFailure {\n  const publicMessage = raw instanceof Error\n    ? raw.message.trim()\n    : String(raw ?? '').trim();\n\n  if (publicMessage.length === 0) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  const provider = detectEmbeddingProviderName(options.provider ?? publicMessage) ?? 'unknown';\n  const { code, errorType } = inferEmbeddingFailure(publicMessage);\n\n  return {\n    code,\n    provider,\n    errorType,\n    publicMessage: `${code} (provider=${provider}, type=${errorType})`,\n    sanitized: true,\n  };\n}\n\nexport function sanitizeEmbeddingFailureMessage(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  return failure.publicMessage.length > 0 ? failure.publicMessage : null;\n}\n\nexport function sanitizeAndLogEmbeddingFailure(\n  context: string,\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): string | null {\n  const failure = sanitizeEmbeddingFailure(raw, options);\n  if (failure.publicMessage.length === 0) {\n    return null;\n  }\n\n  if (failure.sanitized) {\n    console.error(context, {\n      sanitized: {\n        code: failure.code,\n        provider: failure.provider,\n        errorType: failure.errorType,\n      },\n      redacted: true,\n    });\n  }\n\n  return failure.publicMessage;\n}\n\nfunction claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n  const db = vectorIndex.getDb();\n  const previousStatus = getRetryStatus(memory);\n  if (!db || previousStatus === null) {\n    return { claimed: false, previousStatus };\n  }\n","lineStart":1,"lineEnd":300,"totalLines":1141,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781761488147,"end":1781761488154}},"metadata":{"openai":{"itemId":"fc_08e3615ea2db6f69016a3385cfffa48191bdbff82a45ed93cc"}},"id":"prt_ed942b512001pp3xHGAvC49xrl","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed942851a001JFEz8BJ53OvFdE"}}
