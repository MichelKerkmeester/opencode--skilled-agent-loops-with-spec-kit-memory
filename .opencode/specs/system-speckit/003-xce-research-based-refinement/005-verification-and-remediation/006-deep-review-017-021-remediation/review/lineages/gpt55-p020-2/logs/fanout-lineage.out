}\n1035: \n1036:     // The deferred-embedding burst keeps the daemon busy; mark it busy-by-design so\n1037:     // a competing launcher adopts it rather than reaping it mid-drain.\n1038:     maintenanceHandle = beginMaintenance('embedding-queue');\n1039:     console.error(`[retry-manager] Background job: Processing up to ${batchSize} of ${stats.queue_size} pending embeddings`);\n1040: \n1041:     const result = await processRetryQueue(batchSize);\n1042: \n1043:     if (result.processed > 0) {\n1044:       console.error(`[retry-manager] Background job complete: ${result.succeeded}/${result.processed} succeeded`);\n1045:     }\n1046: \n1047:     return result;\n1048:   } catch (error: unknown) {\n1049:     const message = error instanceof Error ? error.message : String(error);\n1050:     console.error('[retry-manager] Background job error:', message);\n1051:     return { error: message };\n1052:   } finally {\n1053:     // Release the busy mark on every exit (success, error). The empty-queue path\n1054:     // never set it, so this is a safe no-op there; end() is idempotent regardless.\n1055:     maintenanceHandle?.end();\n1056:     lastBackgroundRunAt = new Date().toISOString();\n1057:     retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n1058:     retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n1059:     retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n1060:     backgroundJobRunning = false;\n1061:   }\n1062: }\n1063: \n1064: registerShutdownHook(() => {\n1065:   stopBackgroundJob();\n1066: }, { timeoutMs: 250 });\n1067: \n1068: /* ───────────────────────────────────────────────────────────────\n1069:    7. UTILITIES\n1070: ──────────────────────────────────────────────────────────────── */\n1071: \n1072: function parseRow(row: RetryMemoryRow): RetryMemoryRow {\n1073:   if (row.triggerPhrases && typeof row.triggerPhrases === 'string') {\n1074:     try {\n1075:       return { ...row, triggerPhrases: JSON.parse(row.triggerPhrases) };\n1076:     } catch (_error: unknown) {\n1077:       return { ...row, triggerPhrases: [] };\n1078:     }\n1079:   }\n1080:   return { ...row };\n1081: }\n1082: \n1083: async function loadContentFromFile(filePath: string): Promise<string | null> {\n1084:   try {\n1085:     return await fsPromises.readFile(filePath, 'utf-8');\n1086:   } catch (_error: unknown) {\n1087:     return null;\n1088:   }\n1089: }\n1090: \n1091: async function claimAndRetryEmbedding(\n1092:   id: number,\n1093:   content: string,\n1094:   expectedStatus: RetryQueueStatus = 'pending',\n1095: ): Promise<RetryResult | null> {\n1096:   const memory = vectorIndex.getMemory(id) as RetryMemoryRow | undefined;\n1097:   if (!memory) {\n1098:     return { success: false, error: 'Memory not found' };\n1099:   }\n1100: \n1101:   const parsedMemory = parseRow(memory);\n1102:   if (getRetryStatus(parsedMemory) !== expectedStatus) {\n1103:     return null;\n1104:   }\n1105: \n1106:   const claim = claimRetryCandidate(parsedMemory);\n1107:   if (!claim.claimed) {\n1108:     return null;\n1109:   }\n1110: \n1111:   return retryEmbedding(id, content, claim.previousStatus);\n1112: }\n1113: \n1114: /* ───────────────────────────────────────────────────────────────\n1115:    8. EXPORTS\n1116: ──────────────────────────────────────────────────────────────── */\n1117: \n1118: export {\n1119:   getRetryQueue,\n1120:   getFailedEmbeddings,\n1121:   getRetryStats,\n1122:   getEmbeddingRetryStats,\n1123:   getCircuitFlapState,\n1124:   retryEmbedding,\n1125:   claimAndRetryEmbedding,\n1126:   markAsFailed,\n1127:   resetForRetry,\n1128:   processRetryQueue,\n1129:   startBackgroundJob,\n1130:   stopBackgroundJob,\n1131:   isBackgroundJobRunning,\n1132:   runBackgroundJob,\n1133:   enforceRetryRetentionLimits,\n1134:   BACKGROUND_JOB_CONFIG,\n1135:   BACKOFF_DELAYS,\n1136:   MAX_RETRIES,\n1137:   MAX_RETRY_QUEUE_PENDING,\n1138:   MAX_RETRY_QUEUE_AGE_MS,\n1139:   getMaxRetryQueuePending,\n1140:   getMaxRetryQueueAgeMs,\n1141: };\n\n(End of file - total 1141 lines)\n</content>","metadata":{"preview":"\n  clearRegisteredTimer(backgroundJobInterval);\n  backgroundJobInterval = null;\n  backgroundJobRunning = false;\n  console.error('[retry-manager] Background retry job stopped');\n  return true;\n}\n\nfunction isBackgroundJobRunning(): boolean {\n  return backgroundJobInterval !== null;\n}\n\nasync function runBackgroundJob(batchSize: number = BACKGROUND_JOB_CONFIG.batchSize): Promise<BackgroundJobResult> {\n  if (backgroundJobRunning) {\n    return { skipped: true, reason: 'Previous run still in progress' };\n  }\n\n  backgroundJobRunning = true;\n  if (!retryAbortController || retryAbortController.signal.aborted) {\n    retryAbortController = new AbortController();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"\n  clearRegisteredTimer(backgroundJobInterval);\n  backgroundJobInterval = null;\n  backgroundJobRunning = false;\n  console.error('[retry-manager] Background retry job stopped');\n  return true;\n}\n\nfunction isBackgroundJobRunning(): boolean {\n  return backgroundJobInterval !== null;\n}\n\nasync function runBackgroundJob(batchSize: number = BACKGROUND_JOB_CONFIG.batchSize): Promise<BackgroundJobResult> {\n  if (backgroundJobRunning) {\n    return { skipped: true, reason: 'Previous run still in progress' };\n  }\n\n  backgroundJobRunning = true;\n  if (!retryAbortController || retryAbortController.signal.aborted) {\n    retryAbortController = new AbortController();\n  }\n\n  // Held only while a tick has real work; the empty-queue path below never creates\n  // a handle, so an idle tick leaves the daemon reapable.\n  let maintenanceHandle: MaintenanceMarkerHandle | null = null;\n  try {\n    enforceRetryRetentionLimits();\n    if (shutdownRequested || retryAbortController.signal.aborted) {\n      return { skipped: true, reason: 'Shutdown requested' };\n    }\n    const stats = getRetryStats();\n\n    if (stats.queue_size === 0) {\n      return { processed: 0, queue_empty: true };\n    }\n\n    // The deferred-embedding burst keeps the daemon busy; mark it busy-by-design so\n    // a competing launcher adopts it rather than reaping it mid-drain.\n    maintenanceHandle = beginMaintenance('embedding-queue');\n    console.error(`[retry-manager] Background job: Processing up to ${batchSize} of ${stats.queue_size} pending embeddings`);\n\n    const result = await processRetryQueue(batchSize);\n\n    if (result.processed > 0) {\n      console.error(`[retry-manager] Background job complete: ${result.succeeded}/${result.processed} succeeded`);\n    }\n\n    return result;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error('[retry-manager] Background job error:', message);\n    return { error: message };\n  } finally {\n    // Release the busy mark on every exit (success, error). The empty-queue path\n    // never set it, so this is a safe no-op there; end() is idempotent regardless.\n    maintenanceHandle?.end();\n    lastBackgroundRunAt = new Date().toISOString();\n    retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n    retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n    retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n    backgroundJobRunning = false;\n  }\n}\n\nregisterShutdownHook(() => {\n  stopBackgroundJob();\n}, { timeoutMs: 250 });\n\n/* ───────────────────────────────────────────────────────────────\n   7. UTILITIES\n──────────────────────────────────────────────────────────────── */\n\nfunction parseRow(row: RetryMemoryRow): RetryMemoryRow {\n  if (row.triggerPhrases && typeof row.triggerPhrases === 'string') {\n    try {\n      return { ...row, triggerPhrases: JSON.parse(row.triggerPhrases) };\n    } catch (_error: unknown) {\n      return { ...row, triggerPhrases: [] };\n    }\n  }\n  return { ...row };\n}\n\nasync function loadContentFromFile(filePath: string): Promise<string | null> {\n  try {\n    return await fsPromises.readFile(filePath, 'utf-8');\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nasync function claimAndRetryEmbedding(\n  id: number,\n  content: string,\n  expectedStatus: RetryQueueStatus = 'pending',\n): Promise<RetryResult | null> {\n  const memory = vectorIndex.getMemory(id) as RetryMemoryRow | undefined;\n  if (!memory) {\n    return { success: false, error: 'Memory not found' };\n  }\n\n  const parsedMemory = parseRow(memory);\n  if (getRetryStatus(parsedMemory) !== expectedStatus) {\n    return null;\n  }\n\n  const claim = claimRetryCandidate(parsedMemory);\n  if (!claim.claimed) {\n    return null;\n  }\n\n  return retryEmbedding(id, content, claim.previousStatus);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  getRetryQueue,\n  getFailedEmbeddings,\n  getRetryStats,\n  getEmbeddingRetryStats,\n  getCircuitFlapState,\n  retryEmbedding,\n  claimAndRetryEmbedding,\n  markAsFailed,\n  resetForRetry,\n  processRetryQueue,\n  startBackgroundJob,\n  stopBackgroundJob,\n  isBackgroundJobRunning,\n  runBackgroundJob,\n  enforceRetryRetentionLimits,\n  BACKGROUND_JOB_CONFIG,\n  BACKOFF_DELAYS,\n  MAX_RETRIES,\n  MAX_RETRY_QUEUE_PENDING,\n  MAX_RETRY_QUEUE_AGE_MS,\n  getMaxRetryQueuePending,\n  getMaxRetryQueueAgeMs,\n};","lineStart":1000,"lineEnd":1141,"totalLines":1141,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781756795488,"end":1781756795497}},"metadata":{"openai":{"itemId":"fc_080dade757aea8bf016a33737b699c8191b70fadbb3d06d114"}},"id":"prt_ed8fb1a5d001fXmYlmMQlwErx0","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fafb23001judwXX2Out1RCs"}}
