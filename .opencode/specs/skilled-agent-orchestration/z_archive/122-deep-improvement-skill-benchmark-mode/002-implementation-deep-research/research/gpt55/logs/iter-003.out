.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1002:        for category, messages in topology_warnings.items():
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1017:        "topology_warnings": dict(sorted(serialized_warnings.items())),
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1025:def main() -> int:
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1026:    """Validate skill graph metadata and optionally compile the aggregated graph."""
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1028:        description="Compile skill graph-metadata.json files into skill-graph.json",
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1053:    all_metadata = discover_graph_metadata(SKILLS_DIR)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1054:    print(f"Discovered {len(all_metadata)} skill graph-metadata.json files")
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1057:        print("ERROR: No graph-metadata.json files found", file=sys.stderr)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1065:    topology_violations = 0
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1078:    # fail validation because the compiled graph is used as routing authority.
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1081:    topology_violations += len(symmetry_warnings)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1091:    topology_violations += len(zero_edge_warnings)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1093:    if total_errors > 0 or topology_violations > 0:
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1094:        total_failures = total_errors + topology_violations
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1103:    # Serialize advisory warnings into the compiled graph so
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1108:    topology_warnings_payload: Dict[str, List[str]] = {}
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1110:        topology_warnings_payload["weight_band"] = list(weight_band_warnings)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1112:        topology_warnings_payload["weight_parity"] = list(weight_parity_warnings)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1115:    graph = compile_graph(all_metadata, topology_warnings=topology_warnings_payload)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1120:        output_json = json.dumps(graph, indent=indent, ensure_ascii=False)
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1127:        print(f"Compiled skill-graph.json: {size_bytes} bytes ({graph['skill_count']} skills)")
.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_graph_compiler.py:1129:        print(f"Compiled skill graph in memory ({graph['skill_count']} skills)")
