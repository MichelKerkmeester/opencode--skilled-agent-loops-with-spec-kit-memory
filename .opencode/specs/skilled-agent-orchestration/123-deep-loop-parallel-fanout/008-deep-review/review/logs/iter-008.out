   273	  let db = null;
   274	
   275	  try {
   276	    const isCouncil = loopType === 'council';
   277	    db = isCouncil
   278	      ? await import('../lib/council/council-graph-db.ts')
   279	      : await import('../lib/coverage-graph/coverage-graph-db.ts');
   280	    installSignalHandlers(() => db?.closeDb());
   281	    maybeThrowTestFault();
   282	    if (isCouncil) {
   283	      const councilConvergence = require('../lib/council/convergence.cjs');
   284	      const data = await councilConvergence.evaluateCouncilConvergence(ns, {
   285	        roundId: args.roundId,
   286	        persistSnapshot: asBoolean(args.persistSnapshot),
   287	      });
   288	      jsonOut(councilConvergence.bridgePayload(data));
   289	      return;
   290	    }
   291	
   292	    const signalsLib = await import('../lib/coverage-graph/coverage-graph-signals.ts');
   293	    const queryLib = await import('../lib/coverage-graph/coverage-graph-query.ts');
   294	    const nodes = db.getNodes(ns);
   295	    const edges = db.getEdges(ns);
   296	    const snapshots = db.getSnapshots(specFolder, loopType, sessionId);
   297	    const stats = {
   298	      totalNodes: nodes.length,
   299	      totalEdges: edges.length,
   300	      nodesByKind: nodes.reduce((acc, node) => ({ ...acc, [node.kind]: (acc[node.kind] || 0) + 1 }), {}),
   301	      edgesByRelation: edges.reduce((acc, edge) => ({ ...acc, [edge.relation]: (acc[edge.relation] || 0) + 1 }), {}),
   302	      lastIteration: snapshots.length > 0 ? snapshots[snapshots.length - 1].iteration : null,
   303	    };
   304	
   305	    if (stats.totalNodes === 0) {
   306	      const data = {
   307	        decision: 'CONTINUE',
   308	        reason: 'Graph is empty; insufficient data for convergence assessment',
   309	        signals: null,
   310	        blockers: [],
   311	        trace: [],
   312	        namespace: ns,
   313	        scopeMode: 'session',
   314	        nodeCount: 0,
   315	        edgeCount: 0,
   316	      };
   317	      jsonOut({ status: 'ok', data, graph_decision: data.decision, graph_decision_json: JSON.stringify(data.decision), graph_signals_json: {}, graph_blockers_json: [], graph_blockers_csv: '', graph_stop_blocked: false, graph_trace_json: [], graph_convergence_score: 0 });
   318	      return;
   319	    }
   320	
   321	    const signals = loopType === 'research'
   322	      ? {
   323	          questionCoverage: signalsLib.computeResearchQuestionCoverageFromData(nodes, edges),
   324	          claimVerificationRate: signalsLib.computeResearchClaimVerificationRateFromData(nodes),
   325	          contradictionDensity: signalsLib.computeResearchContradictionDensityFromData(edges),
   326	          sourceDiversity: signalsLib.computeResearchSourceDiversityFromData(nodes, edges),
   327	          evidenceDepth: signalsLib.computeResearchEvidenceDepthFromData(nodes, edges),
   328	        }
   329	      : buildReviewSignals(nodes, edges);
   330	    const score = computeCompositeScore(signals, loopType);
   331	    const signalsWithScore = { ...signals, score };
   332	    const gaps = queryLib.findCoverageGaps(ns);
   333	    const contradictions = queryLib.findContradictions(ns);
   334	    const unverified = loopType === 'research' ? queryLib.findUnverifiedClaims(ns) : [];
   335	    const evaluated = loopType === 'research'
   336	      ? evaluateResearch(signals, gaps, contradictions, unverified)
   337	      : evaluateReview(signals, gaps, contradictions);
   338	    const blockingBlockers = evaluated.blockers.filter((blocker) => blocker.severity === 'blocking');
   339	    const decision = blockingBlockers.length > 0
   340	      ? 'STOP_BLOCKED'
   341	      : evaluated.trace.every((entry) => entry.passed) ? 'STOP_ALLOWED' : 'CONTINUE';
   342	    const momentum = snapshots.length < 2
   343	      ? null
   344	      : Object.fromEntries(Object.keys(snapshots[snapshots.length - 1].metrics || {}).flatMap((key) => {
   345	          const latest = snapshots[snapshots.length - 1].metrics[key];
   346	          const previous = snapshots[snapshots.length - 2].metrics[key];
   347	          return typeof latest === 'number' && typeof previous === 'number' ? [[key, latest - previous]] : [];
   348	        }));
   349	
   350	    if (asBoolean(args.persistSnapshot) && args.iteration !== undefined) {
   351	      db.createSnapshot({
   352	        specFolder,
   353	        loopType,
   354	        sessionId,
   355	        iteration: Number(args.iteration),
   356	        metrics: { ...signals, nodeCount: stats.totalNodes, edgeCount: stats.totalEdges },
   357	        nodeCount: stats.totalNodes,
   358	        edgeCount: stats.totalEdges,
   359	      });
   360	    }
   361	
   362	    const data = {
   363	      decision,
   364	      reason: decisionReason(decision, blockingBlockers, evaluated.trace),
   365	      score,
   366	      signals: signalsWithScore,
   367	      blockers: evaluated.blockers,
   368	      trace: evaluated.trace,
   369	      momentum,
   370	      namespace: ns,
   371	      scopeMode: 'session',
   372	      notes: ['Convergence signals were computed from the session-scoped subgraph only.'],
   373	      snapshotPersistence: asBoolean(args.persistSnapshot) ? 'persisted' : 'not_requested',
   374	      nodeCount: stats.totalNodes,
   375	      edgeCount: stats.totalEdges,
   376	      lastIteration: stats.lastIteration,
   377	    };
   378	    jsonOut({
   379	      status: 'ok',
   380	      data,
   381	      graph_decision: decision,
   382	      graph_decision_json: JSON.stringify(decision),
   383	      graph_signals_json: signalsWithScore,
   384	      graph_blockers_json: evaluated.blockers,
   385	      graph_blockers_csv: blockersCsv(evaluated.blockers),
   386	      graph_stop_blocked: decision === 'STOP_BLOCKED',
   387	      graph_trace_json: evaluated.trace,
   388	      graph_convergence_score: score,
   389	    });
   390	  } finally {
   391	    db?.closeDb();
   392	  }
   393	}
   394	
   395	main().catch((err) => {
   396	  const code = classifyExitCode(err);
   397	  jsonOut({ status: 'error', error: err instanceof Error ? err.message : String(err), code: err && err.code ? err.code : 'SCRIPT_ERROR' });
   398	  if (code === 1) {
   399	    process.stderr.write(JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\n');
   400	  }
   401	  process.exit(code);
   402	});

