{"type":"tool_use","timestamp":1783486588568,"sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","part":{"type":"tool","tool":"read","callID":"call_mu73KcbzMXf01pbMFn7iYT5I","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep Research State Reducer                                              ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const fs = require('node:fs');\n12: const path = require('node:path');\n13: const crypto = require('node:crypto');\n14: const { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\n15: const { resolveArtifactRoot } = require('../../../deep-loop-runtime/lib/deep-loop/artifact-root.cjs');\n16: const {\n17:   buildCarriedForwardOpenQuestions,\n18:   deriveNextFocusFromContinuity,\n19:   formatCarriedForwardOpenQuestions,\n20: } = require('../../../deep-loop-runtime/lib/deep-loop/continuity-thread.cjs');\n21: const { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n22: \n23: // ─────────────────────────────────────────────────────────────────────────────\n24: // 2. HELPERS\n25: // ─────────────────────────────────────────────────────────────────────────────\n26: \n27: const DEFAULT_SPARKLINE_WIDTH = 20;\n28: const DEFAULT_TREND_FLATLINE_WINDOW = 3;\n29: const DEFAULT_REJECTED_PATTERN_CATEGORY = 'general';\n30: const DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD = 0.85;\n31: const DEFAULT_MIN_IDEA_OBSERVATIONS = 2;\n32: const MIN_IDEA_OBSERVATIONS = 1;\n33: const MAX_IDEA_OBSERVATIONS = 10;\n34: const INBOX_FILE_NAME = 'inbox.jsonl';\n35: const DEFAULT_INBOX_SOURCE = 'research-inbox';\n36: const LEGACY_IMPORT_ORIGIN = 'legacy-import';\n37: const LEGACY_IMPORT_SOURCE = 'key-questions';\n38: const QUESTION_CONFLICT_EVENT = 'question_conflict';\n39: const DEFAULT_QUESTION_DECISION = 'needs_decision';\n40: const MAX_REJECTED_PATTERNS = 100;\n41: const REJECTED_PATTERN_CANDIDATE_FIELDS = ['text', 'focus', 'nextFocus', 'pattern', 'idea', 'title'];\n42: const REJECTED_PATTERN_EVENT_FIELDS = ['pattern', 'idea', 'text', 'candidate'];\n43: const IDEA_EVENT_TEXT_FIELDS = ['idea', 'text', 'title', 'pattern', 'candidate'];\n44: const IDEA_OBSERVED_EVENTS = new Set(['idea_observed', 'ideaObserved']);\n45: const IDEA_PROMOTED_EVENTS = new Set(['idea_promoted', 'ideaPromoted']);\n46: const IDEA_REJECTED_EVENTS = new Set(['idea_rejected', 'ideaRejected']);\n47: const IDEA_REJECTED_REMOVED_EVENTS = new Set(['idea_rejected_removed', 'ideaRejectedRemoved']);\n48: const IDEA_REJECTED_RESET_EVENTS = new Set(['idea_rejected_reset', 'ideaRejectedReset']);\n49: const VALID_QUESTION_ORIGINS = new Set([\n50:   'angle-bank',\n51:   'analyst-strategy',\n52:   'operator',\n53:   LEGACY_IMPORT_ORIGIN,\n54: ]);\n55: const VALID_QUESTION_DECISIONS = new Set([\n56:   'accepted',\n57:   'rejected',\n58:   'superseded',\n59:   DEFAULT_QUESTION_DECISION,\n60: ]);\n61: const SPARKLINE_BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];\n62: \n63: function readUtf8(filePath) {\n64:   return fs.readFileSync(filePath, 'utf8');\n65: }\n66: \n67: function writeUtf8(filePath, content) {\n68:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n69:   fs.writeFileSync(filePath, content, 'utf8');\n70: }\n71: \n72: function readJson(filePath) {\n73:   return JSON.parse(readUtf8(filePath));\n74: }\n75: \n76: function getResourceMapEmitSetting(config) {\n77:   const nested = config && typeof config === 'object'\n78:     ? (config.resource_map || config.resourceMap || null)\n79:     : null;\n80:   if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n81:     return nested.emit;\n82:   }\n83:   return true;\n84: }\n85: \n86: function slugify(value) {\n87:   return value\n88:     .toLowerCase()\n89:     .replace(/[^a-z0-9]+/g, '-')\n90:     .replace(/^-+|-+$/g, '')\n91:     .slice(0, 80) || 'entry';\n92: }\n93: \n94: function normalizeText(value) {\n95:   return value.replace(/\\s+/g, ' ').trim();\n96: }\n97: \n98: function normalizeOptionalText(value) {\n99:   return typeof value === 'string' ? normalizeText(value) : '';\n100: }\n101: \n102: function normalizeQuestionOrigin(value) {\n103:   const origin = normalizeOptionalText(value).toLowerCase();\n104:   return VALID_QUESTION_ORIGINS.has(origin) ? origin : 'operator';\n105: }\n106: \n107: function normalizeQuestionSource(value, fallback) {\n108:   return normalizeOptionalText(value) || fallback;\n109: }\n110: \n111: function normalizeQuestionIteration(value) {\n112:   return isFiniteNumber(value) && value >= 0 ? Math.floor(value) : 0;\n113: }\n114: \n115: function normalizeQuestionId(value) {\n116:   const normalized = normalizeOptionalText(value);\n117:   return normalized || null;\n118: }\n119: \n120: function normalizeQuestionDecision(value) {\n121:   const decision = normalizeOptionalText(value).toLowerCase();\n122:   return VALID_QUESTION_DECISIONS.has(decision) ? decision : null;\n123: }\n124: \n125: function contentHash(value) {\n126:   return crypto\n127:     .createHash('sha256')\n128:     .update(normalizeText(String(value)).toLowerCase())\n129:     .digest('hex')\n130:     .slice(0, 12);\n131: }\n132: \n133: function normalizeRejectedPatternKey(value) {\n134:   return normalizeText(String(value ?? ''))\n135:     .toLowerCase()\n136:     .replace(/[^a-z0-9]+/g, ' ')\n137:     .trim();\n138: }\n139: \n140: function normalizeRejectedPatternCategory(value) {\n141:   const normalized = normalizeOptionalText(value).toLowerCase();\n142:   return normalized || DEFAULT_REJECTED_PATTERN_CATEGORY;\n143: }\n144: \n145: function normalizeRejectedPatternId(value) {\n146:   const normalized = normalizeOptionalText(value);\n147:   return normalized || null;\n148: }\n149: \n150: function isNamedEvent(record, eventNames) {\n151:   return record\n152:     && record.type === 'event'\n153:     && typeof record.event === 'string'\n154:     && eventNames.has(record.event);\n155: }\n156: \n157: function readFirstTextField(record, fields) {\n158:   if (!record || typeof record !== 'object' || Array.isArray(record)) {\n159:     return '';\n160:   }\n161: \n162:   for (const field of fields) {\n163:     const value = normalizeOptionalText(record[field]);\n164:     if (value) {\n165:       return value;\n166:     }\n167:   }\n168:   return '';\n169: }\n170: \n171: function readRejectedPatternText(record) {\n172:   return readFirstTextField(record, REJECTED_PATTERN_EVENT_FIELDS);\n173: }\n174: \n175: function readCandidateText(candidate) {\n176:   if (typeof candidate === 'string') {\n177:     return normalizeOptionalText(candidate);\n178:   }\n179:   return readFirstTextField(candidate, REJECTED_PATTERN_CANDIDATE_FIELDS);\n180: }\n181: \n182: function readCandidateCategory(candidate, fallbackCategory) {\n183:   if (candidate && typeof candidate === 'object' && !Array.isArray(candidate)) {\n184:     return normalizeRejectedPatternCategory(candidate.category ?? fallbackCategory);\n185:   }\n186:   return normalizeRejectedPatternCategory(fallbackCategory);\n187: }\n188: \n189: function isRejectedPatternCategoryCompatible(rejectedCategory, candidateCategory) {\n190:   const rejected = normalizeRejectedPatternCategory(rejectedCategory);\n191:   const candidate = normalizeRejectedPatternCategory(candidateCategory);\n192:   return rejected === candidate\n193:     || rejected === DEFAULT_REJECTED_PATTERN_CATEGORY\n194:     || candidate === DEFAULT_REJECTED_PATTERN_CATEGORY;\n195: }\n196: \n197: function resolveRejectedPatternFuzzyThreshold(config) {\n198:   const rawThreshold =\n199:     config?.rejectedPatternFuzzyThreshold\n200:     ?? config?.rejectedPatterns?.fuzzyThreshold\n201:     ?? DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n202:   return typeof rawThreshold === 'number' && Number.isFinite(rawThreshold) && rawThreshold >= 0 && rawThreshold <= 1\n203:     ? rawThreshold\n204:     : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n205: }\n206: \n207: function normalizeRejectedPatternEvent(record) {\n208:   const pattern = readRejectedPatternText(record);\n209:   const normalizedPattern = normalizeRejectedPatternKey(pattern);\n210:   if (!normalizedPattern) {\n211:     return null;\n212:   }\n213: \n214:   const category = normalizeRejectedPatternCategory(record.category);\n215:   return {\n216:     id: normalizeRejectedPatternId(record.rejectedId ?? record.ideaId ?? record.id)\n217:       || `rejected-${category}-${contentHash(normalizedPattern)}`,\n218:     ideaId: normalizeRejectedPatternId(record.ideaId),\n219:     pattern,\n220:     normalizedPattern,\n221:     category,\n222:     reason: normalizeOptionalText(record.reason),\n223:     addedAtRun: isFiniteNumber(record.run) ? record.run : null,\n224:     timestamp: normalizeOptionalText(record.timestamp),\n225:     sessionId: normalizeRejectedPatternId(record.sessionId),\n226:     generation: isFiniteNumber(record.generation) ? record.generation : null,\n227:   };\n228: }\n229: \n230: function removeRejectedPatternEntries(entries, record) {\n231:   const rejectedId = normalizeRejectedPatternId(record.rejectedId ?? record.ideaId ?? record.id);\n232:   const patternKey = normalizeRejectedPatternKey(readRejectedPatternText(record));\n233:   const rawCategory = normalizeOptionalText(record.category);\n234:   const category = rawCategory ? normalizeRejectedPatternCategory(rawCategory) : null;\n235: \n236:   return entries.filter((entry) => {\n237:     if (rejectedId && (entry.id === rejectedId || entry.ideaId === rejectedId)) {\n238:       return false;\n239:     }\n240:     if (!patternKey || entry.normalizedPattern !== patternKey) {\n241:       return true;\n242:     }\n243:     return category ? entry.category !== category : false;\n244:   });\n245: }\n246: \n247: /**\n248:  * Derive the active rejected-pattern cache from append-only research events.\n249:  *\n250:  * @param {Array<Object>} eventRecords - Parsed JSONL event records.\n251:  * @param {Object} [options] - Index options.\n252:  * @param {number} [options.fuzzyThreshold=0.85] - Similarity threshold used by candidate checks.\n253:  * @returns {{entries: Array<Object>, maxEntries: number, fuzzyThreshold: number, warnings: string[]}} Bounded rejected-pattern index.\n254:  */\n255: function deriveRejectedPatternIndex(eventRecords, options = {}) {\n256:   const fuzzyThreshold = typeof options.fuzzyThreshold === 'number'\n257:     ? options.fuzzyThreshold\n258:     : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n259:   const entries = [];\n260:   const warnings = [];\n261: \n262:   for (const record of Array.isArray(eventRecords) ? eventRecords : []) {\n263:     if (!record || record.type !== 'event') {\n264:       continue;\n265:     }\n266: \n267:     if (isNamedEvent(record, IDEA_REJECTED_RESET_EVENTS)) {\n268:       entries.length = 0;\n269:       continue;\n270:     }\n271: \n272:     if (isNamedEvent(record, IDEA_REJECTED_REMOVED_EVENTS)) {\n273:       const nextEntries = removeRejectedPatternEntries(entries, record);\n274:       entries.length = 0;\n275:       entries.push(...nextEntries);\n276:       continue;\n277:     }\n278: \n279:     if (!isNamedEvent(record, IDEA_REJECTED_EVENTS)) {\n280:       continue;\n281:     }\n282: \n283:     const entry = normalizeRejectedPatternEvent(record);\n284:     if (!entry) {\n285:       continue;\n286:     }\n287: \n288:     const replacedEntries = entries.filter((existing) =>\n289:       existing.id !== entry.id\n290:       && !(existing.category === entry.category && existing.normalizedPattern === entry.normalizedPattern),\n291:     );\n292:     replacedEntries.push(entry);\n293:     entries.length = 0;\n294:     entries.push(...replacedEntries);\n295: \n296:     while (entries.length > MAX_REJECTED_PATTERNS) {\n297:       const evicted = entries.shift();\n298:       warnings.push(\n299:         `[deep-research] evicted rejected pattern \"${evicted.pattern}\" from bounded rejected-pattern cache (max ${MAX_REJECTED_PATTERNS})`,\n300:       );\n301:     }\n302:   }\n303: \n304:   return {\n305:     entries,\n306:     maxEntries: MAX_REJECTED_PATTERNS,\n307:     fuzzyThreshold,\n308:     warnings,\n309:   };\n310: }\n311: \n312: function calculateLevenshteinDistance(left, right) {\n313:   if (left === right) {\n314:     return 0;\n315:   }\n316:   if (!left.length) {\n317:     return right.length;\n318:   }\n319:   if (!right.length) {\n320:     return left.length;\n321:   }\n322: \n323:   const previous = Array.from({ length: right.length + 1 }, (_unused, index) => index);\n324:   const current = new Array(right.length + 1);\n325: \n326:   for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n327:     current[0] = leftIndex;\n328:     for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n329:       const substitutionCost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n330:       current[rightIndex] = Math.min(\n331:         previous[rightIndex] + 1,\n332:         current[rightIndex - 1] + 1,\n333:         previous[rightIndex - 1] + substitutionCost,\n334:       );\n335:     }\n336:     previous.splice(0, previous.length, ...current);\n337:   }\n338: \n339:   return previous[right.length];\n340: }\n341: \n342: function calculateRejectedPatternSimilarity(left, right) {\n343:   const normalizedLeft = normalizeRejectedPatternKey(left).slice(0, 500);\n344:   const normalizedRight = normalizeRejectedPatternKey(right).slice(0, 500);\n345:   if (!normalizedLeft || !normalizedRight) {\n346:     return 0;\n347:   }\n348:   if (normalizedLeft === normalizedRight) {\n349:     return 1;\n350:   }\n351: \n352:   const distance = calculateLevenshteinDistance(normalizedLeft, normalizedRight);\n353:   return 1 - (distance / Math.max(normalizedLeft.length, normalizedRight.length));\n354: }\n355: \n356: function readRejectedEntries(rejectedIndex) {\n357:   if (Array.isArray(rejectedIndex)) {\n358:     return rejectedIndex;\n359:   }\n360:   return Array.isArray(rejectedIndex?.entries) ? rejectedIndex.entries : [];\n361: }\n362: \n363: function resolveCandidateThreshold(rejectedIndex, options) {\n364:   const threshold = options?.fuzzyThreshold ?? rejectedIndex?.fuzzyThreshold ?? rejectedIndex?.threshold;\n365:   return typeof threshold === 'number' && Number.isFinite(threshold) && threshold >= 0 && threshold <= 1\n366:     ? threshold\n367:     : DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD;\n368: }\n369: \n370: /**\n371:  * Find the active rejected pattern that suppresses a candidate, if any.\n372:  *\n373:  * @param {string|Object} candidate - Candidate text or structured candidate.\n374:  * @param {Object|Array<Object>} rejectedIndex - Derived rejected-pattern index.\n375:  * @param {Object} [options] - Match options.\n376:  * @param {string} [options.category=\"general\"] - Candidate category.\n377:  * @returns {Object|null} Match metadata when the candidate is suppressed.\n378:  */\n379: function findRejectedPatternMatch(candidate, rejectedIndex, options = {}) {\n380:   const candidateText = readCandidateText(candidate);\n381:   const candidateKey = normalizeRejectedPatternKey(candidateText);\n382:   if (!candidateKey) {\n383:     return null;\n384:   }\n385: \n386:   const candidateCategory = readCandidateCategory(candidate, options.category);\n387:   const fuzzyThreshold = resolveCandidateThreshold(rejectedIndex