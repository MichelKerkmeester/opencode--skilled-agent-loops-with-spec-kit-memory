{"type":"tool_use","timestamp":1781151302183,"sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","part":{"type":"tool","tool":"read","callID":"call_ag0LRnL7PegmDgAWdd6i5X4s","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts</path>\n<type>file</type>\n<content>\n1: import * as fs from 'node:fs';\n2: import * as os from 'node:os';\n3: import * as path from 'node:path';\n4: import { randomUUID } from 'node:crypto';\n5: \n6: import Database from 'better-sqlite3';\n7: import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n8: \n9: const TEST_DIM = 4;\n10: const TEST_MODEL = 'test-vector-repair-embedder';\n11: const TEST_BACKEND = 'sentence-transformers' as const;\n12: \n13: type EmbedImpl = (texts: string[]) => Promise<Float32Array[]> | Float32Array[];\n14: let embedImpl: EmbedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n15: \n16: vi.mock('../lib/embedders/registry.js', () => ({\n17:   getManifest: (name: string) => (\n18:     name === TEST_MODEL ? { name: TEST_MODEL, backend: TEST_BACKEND, dim: TEST_DIM } : null\n19:   ),\n20: }));\n21: \n22: vi.mock('../lib/embedders/execution-router.js', () => ({\n23:   getEmbedderAdapter: () => ({\n24:     embed: async (texts: string[]) => embedImpl(texts),\n25:   }),\n26:   teardownEmbedderAfterSwap: async () => {},\n27: }));\n28: \n29: import { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\n30: import { setActiveEmbedder } from '../lib/embedders/schema.js';\n31: import * as core from '../core/index.js';\n32: import { handleMemoryHealth } from '../handlers/memory-crud-health.js';\n33: import {\n34:   attachActiveVectorShard,\n35:   closeDb,\n36:   detachActiveVectorShard,\n37:   initializeDb,\n38: } from '../lib/search/vector-index-store.js';\n39: import {\n40:   getDegradedVectorObservabilitySnapshot,\n41:   resetDegradedVectorObservabilityForTest,\n42: } from '../lib/observability/retrieval-observability.js';\n43: \n44: function parseResponse(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n45:   return JSON.parse(response.content[0]?.text ?? '{}') as Record<string, unknown>;\n46: }\n47: \n48: async function waitUntil(predicate: () => boolean, label: string): Promise<void> {\n49:   const deadline = Date.now() + 2000;\n50:   while (Date.now() < deadline) {\n51:     if (predicate()) return;\n52:     await new Promise<void>((resolve) => setImmediate(resolve));\n53:   }\n54:   throw new Error(`Timed out waiting for ${label}`);\n55: }\n56: \n57: function profile(): EmbeddingProfile {\n58:   return new EmbeddingProfile({\n59:     provider: TEST_BACKEND,\n60:     model: TEST_MODEL,\n61:     dim: TEST_DIM,\n62:     dtype: null,\n63:     baseUrl: null,\n64:   });\n65: }\n66: \n67: function vectorIds(shardPath: string): number[] {\n68:   const shard = new Database(shardPath, { readonly: true });\n69:   try {\n70:     return (shard.prepare(`SELECT id FROM vec_${TEST_DIM} ORDER BY id ASC`).all() as Array<{ id: number }>)\n71:       .map((row) => row.id);\n72:   } finally {\n73:     shard.close();\n74:   }\n75: }\n76: \n77: describe('vector shard read-path resilience', () => {\n78:   const originalMemoryDbPath = process.env.MEMORY_DB_PATH;\n79:   const originalAllowedPaths = process.env.MEMORY_ALLOWED_PATHS;\n80:   const originalBatchSize = process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n81:   let tempDir: string;\n82:   let dbPath: string;\n83: \n84:   beforeEach(() => {\n85:     tempDir = fs.mkdtempSync(path.join(os.tmpdir(), `vector-shard-resilience-${randomUUID().slice(0, 8)}-`));\n86:     dbPath = path.join(tempDir, 'context-index.sqlite');\n87:     process.env.MEMORY_DB_PATH = dbPath;\n88:     process.env.MEMORY_ALLOWED_PATHS = tempDir;\n89:     process.env.EMBEDDER_REINDEX_BATCH_SIZE = '50';\n90:     resetDegradedVectorObservabilityForTest();\n91:     embedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n92:     vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n93:   });\n94: \n95:   afterEach(() => {\n96:     vi.restoreAllMocks();\n97:     closeDb();\n98:     resetDegradedVectorObservabilityForTest();\n99:     if (originalMemoryDbPath === undefined) delete process.env.MEMORY_DB_PATH;\n100:     else process.env.MEMORY_DB_PATH = originalMemoryDbPath;\n101:     if (originalAllowedPaths === undefined) delete process.env.MEMORY_ALLOWED_PATHS;\n102:     else process.env.MEMORY_ALLOWED_PATHS = originalAllowedPaths;\n103:     if (originalBatchSize === undefined) delete process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n104:     else process.env.EMBEDDER_REINDEX_BATCH_SIZE = originalBatchSize;\n105:     fs.rmSync(tempDir, { recursive: true, force: true });\n106:   });\n107: \n108:   it('detects, quarantines, rebuilds, and returns healthy after a corrupted copied shard', async () => {\n109:     const db = initializeDb(dbPath);\n110:     const activeProfile = profile();\n111:     setActiveEmbedder(db, TEST_MODEL, TEST_DIM, TEST_BACKEND);\n112:     attachActiveVectorShard(db, activeProfile);\n113:     const now = new Date().toISOString();\n114:     db.prepare(`\n115:       INSERT INTO memory_index (spec_folder, file_path, title, content_text, embedding_status, created_at, updated_at, trigger_phrases)\n116:       VALUES (?, ?, ?, ?, 'pending', ?, ?, '[]'), (?, ?, ?, ?, 'pending', ?, ?, '[]')\n117:     `).run(\n118:       'specs/tmp', 'a.md', 'A', 'alpha', now, now,\n119:       'specs/tmp', 'b.md', 'B', 'beta', now, now,\n120:     );\n121: \n122:     const shardPath = activeProfile.getVectorShardPath(tempDir);\n123:     expect(shardPath.startsWith(tempDir)).toBe(true);\n124:     expect(shardPath).not.toContain('/mcp_server/database/');\n125:     detachActiveVectorShard(db);\n126: \n127:     const fixtureShardPath = path.join(tempDir, 'fixture-shard.sqlite');\n128:     fs.copyFileSync(shardPath, fixtureShardPath);\n129:     fs.copyFileSync(fixtureShardPath, shardPath);\n130:     fs.writeFileSync(shardPath, Buffer.from('not a sqlite database'));\n131: \n132:     let releaseEmbedding: (() => void) | null = null;\n133:     embedImpl = async (texts) => {\n134:       await new Promise<void>((resolve) => {\n135:         releaseEmbedding = resolve;\n136:       });\n137:       return texts.map(() => Float32Array.from([2, 2, 2, 2]));\n138:     };\n139: \n140:     attachActiveVectorShard(db, activeProfile);\n141:     await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'rebuilding', 'repair job to start');\n142: \n143:     const rebuildingHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n144:     const rebuildingDegradation = rebuildingHealth.recallDegradation as Record<string, unknown>;\n145:     expect((rebuildingDegradation.degradedVector as Record<string, unknown>).state).toBe('rebuilding');\n146:     expect(rebuildingDegradation.degraded).toBe(true);\n147:     expect(fs.readdirSync(path.dirname(shardPath)).some((name) => name.includes('.quarantined-'))).toBe(true);\n148: \n149:     releaseEmbedding?.();\n150:     await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'healthy', 'repair job to complete');\n151: \n152:     const finalHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n153:     const finalDegradation = finalHealth.recallDegradation as Record<string, unknown>;\n154:     const degradedVector = finalDegradation.degradedVector as Record<string, unknown>;\n155:     expect(degradedVector.state).toBe('healthy');\n156:     expect(degradedVector.detections).toBe(1);\n157:     expect(degradedVector.quarantines).toBe(1);\n158:     expect(degradedVector.rebuildsStarted).toBe(1);\n159:     expect(degradedVector.rebuildsCompleted).toBe(1);\n160:     expect(vectorIds(shardPath)).toEqual([1, 2]);\n161:   });\n162: });\n\n(End of file - total 162 lines)\n</content>","metadata":{"preview":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport Database from 'better-sqlite3';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nconst TEST_DIM = 4;\nconst TEST_MODEL = 'test-vector-repair-embedder';\nconst TEST_BACKEND = 'sentence-transformers' as const;\n\ntype EmbedImpl = (texts: string[]) => Promise<Float32Array[]> | Float32Array[];\nlet embedImpl: EmbedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n\nvi.mock('../lib/embedders/registry.js', () => ({\n  getManifest: (name: string) => (\n    name === TEST_MODEL ? { name: TEST_MODEL, backend: TEST_BACKEND, dim: TEST_DIM } : null\n  ),\n}));","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts","text":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport Database from 'better-sqlite3';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nconst TEST_DIM = 4;\nconst TEST_MODEL = 'test-vector-repair-embedder';\nconst TEST_BACKEND = 'sentence-transformers' as const;\n\ntype EmbedImpl = (texts: string[]) => Promise<Float32Array[]> | Float32Array[];\nlet embedImpl: EmbedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n\nvi.mock('../lib/embedders/registry.js', () => ({\n  getManifest: (name: string) => (\n    name === TEST_MODEL ? { name: TEST_MODEL, backend: TEST_BACKEND, dim: TEST_DIM } : null\n  ),\n}));\n\nvi.mock('../lib/embedders/execution-router.js', () => ({\n  getEmbedderAdapter: () => ({\n    embed: async (texts: string[]) => embedImpl(texts),\n  }),\n  teardownEmbedderAfterSwap: async () => {},\n}));\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport * as core from '../core/index.js';\nimport { handleMemoryHealth } from '../handlers/memory-crud-health.js';\nimport {\n  attachActiveVectorShard,\n  closeDb,\n  detachActiveVectorShard,\n  initializeDb,\n} from '../lib/search/vector-index-store.js';\nimport {\n  getDegradedVectorObservabilitySnapshot,\n  resetDegradedVectorObservabilityForTest,\n} from '../lib/observability/retrieval-observability.js';\n\nfunction parseResponse(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n  return JSON.parse(response.content[0]?.text ?? '{}') as Record<string, unknown>;\n}\n\nasync function waitUntil(predicate: () => boolean, label: string): Promise<void> {\n  const deadline = Date.now() + 2000;\n  while (Date.now() < deadline) {\n    if (predicate()) return;\n    await new Promise<void>((resolve) => setImmediate(resolve));\n  }\n  throw new Error(`Timed out waiting for ${label}`);\n}\n\nfunction profile(): EmbeddingProfile {\n  return new EmbeddingProfile({\n    provider: TEST_BACKEND,\n    model: TEST_MODEL,\n    dim: TEST_DIM,\n    dtype: null,\n    baseUrl: null,\n  });\n}\n\nfunction vectorIds(shardPath: string): number[] {\n  const shard = new Database(shardPath, { readonly: true });\n  try {\n    return (shard.prepare(`SELECT id FROM vec_${TEST_DIM} ORDER BY id ASC`).all() as Array<{ id: number }>)\n      .map((row) => row.id);\n  } finally {\n    shard.close();\n  }\n}\n\ndescribe('vector shard read-path resilience', () => {\n  const originalMemoryDbPath = process.env.MEMORY_DB_PATH;\n  const originalAllowedPaths = process.env.MEMORY_ALLOWED_PATHS;\n  const originalBatchSize = process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n  let tempDir: string;\n  let dbPath: string;\n\n  beforeEach(() => {\n    tempDir = fs.mkdtempSync(path.join(os.tmpdir(), `vector-shard-resilience-${randomUUID().slice(0, 8)}-`));\n    dbPath = path.join(tempDir, 'context-index.sqlite');\n    process.env.MEMORY_DB_PATH = dbPath;\n    process.env.MEMORY_ALLOWED_PATHS = tempDir;\n    process.env.EMBEDDER_REINDEX_BATCH_SIZE = '50';\n    resetDegradedVectorObservabilityForTest();\n    embedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n    vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n  });\n\n  afterEach(() => {\n    vi.restoreAllMocks();\n    closeDb();\n    resetDegradedVectorObservabilityForTest();\n    if (originalMemoryDbPath === undefined) delete process.env.MEMORY_DB_PATH;\n    else process.env.MEMORY_DB_PATH = originalMemoryDbPath;\n    if (originalAllowedPaths === undefined) delete process.env.MEMORY_ALLOWED_PATHS;\n    else process.env.MEMORY_ALLOWED_PATHS = originalAllowedPaths;\n    if (originalBatchSize === undefined) delete process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n    else process.env.EMBEDDER_REINDEX_BATCH_SIZE = originalBatchSize;\n    fs.rmSync(tempDir, { recursive: true, force: true });\n  });\n\n  it('detects, quarantines, rebuilds, and returns healthy after a corrupted copied shard', async () => {\n    const db = initializeDb(dbPath);\n    const activeProfile = profile();\n    setActiveEmbedder(db, TEST_MODEL, TEST_DIM, TEST_BACKEND);\n    attachActiveVectorShard(db, activeProfile);\n    const now = new Date().toISOString();\n    db.prepare(`\n      INSERT INTO memory_index (spec_folder, file_path, title, content_text, embedding_status, created_at, updated_at, trigger_phrases)\n      VALUES (?, ?, ?, ?, 'pending', ?, ?, '[]'), (?, ?, ?, ?, 'pending', ?, ?, '[]')\n    `).run(\n      'specs/tmp', 'a.md', 'A', 'alpha', now, now,\n      'specs/tmp', 'b.md', 'B', 'beta', now, now,\n    );\n\n    const shardPath = activeProfile.getVectorShardPath(tempDir);\n    expect(shardPath.startsWith(tempDir)).toBe(true);\n    expect(shardPath).not.toContain('/mcp_server/database/');\n    detachActiveVectorShard(db);\n\n    const fixtureShardPath = path.join(tempDir, 'fixture-shard.sqlite');\n    fs.copyFileSync(shardPath, fixtureShardPath);\n    fs.copyFileSync(fixtureShardPath, shardPath);\n    fs.writeFileSync(shardPath, Buffer.from('not a sqlite database'));\n\n    let releaseEmbedding: (() => void) | null = null;\n    embedImpl = async (texts) => {\n      await new Promise<void>((resolve) => {\n        releaseEmbedding = resolve;\n      });\n      return texts.map(() => Float32Array.from([2, 2, 2, 2]));\n    };\n\n    attachActiveVectorShard(db, activeProfile);\n    await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'rebuilding', 'repair job to start');\n\n    const rebuildingHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n    const rebuildingDegradation = rebuildingHealth.recallDegradation as Record<string, unknown>;\n    expect((rebuildingDegradation.degradedVector as Record<string, unknown>).state).toBe('rebuilding');\n    expect(rebuildingDegradation.degraded).toBe(true);\n    expect(fs.readdirSync(path.dirname(shardPath)).some((name) => name.includes('.quarantined-'))).toBe(true);\n\n    releaseEmbedding?.();\n    await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'healthy', 'repair job to complete');\n\n    const finalHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n    const finalDegradation = finalHealth.recallDegradation as Record<string, unknown>;\n    const degradedVector = finalDegradation.degradedVector as Record<string, unknown>;\n    expect(degradedVector.state).toBe('healthy');\n    expect(degradedVector.detections).toBe(1);\n    expect(degradedVector.quarantines).toBe(1);\n    expect(degradedVector.rebuildsStarted).toBe(1);\n    expect(degradedVector.rebuildsCompleted).toBe(1);\n    expect(vectorIds(shardPath)).toEqual([1, 2]);\n  });\n});","lineStart":1,"lineEnd":162,"totalLines":162,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts","time":{"start":1781151302163,"end":1781151302179}},"metadata":{"openai":{"itemId":"fc_04292186e1973d54016a2a3645f7508191924e2aad62e528ef"}},"id":"prt_eb4e4019e001m3Jc7NJ2iOMPLs","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","messageID":"msg_eb4e3ddff001DDPuOXXvV6VTl3"}}
{"type":"tool_use","timestamp":1781151302183,"sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","part":{"type":"tool","tool":"read","callID":"call_MBtkL4LTotb7zfd9nPYb5Gq8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts</path>\n<type>file</type>\n<content>\n1: import Database from 'better-sqlite3';\n2: import * as sqliteVec from 'sqlite-vec';\n3: import { afterEach, describe, expect, it, vi } from 'vitest';\n4: \n5: import { setActiveEmbedder } from '../lib/embedders/schema.js';\n6: import { __testables } from '../lib/search/vector-index-store.js';\n7: \n8: function makeMemoryDb(): Database.Database {\n9:   const db = new Database(':memory:');\n10:   sqliteVec.load(db);\n11:   db.exec(`\n12:     CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n13:     CREATE TABLE vec_metadata (key TEXT PRIMARY KEY, value TEXT NOT NULL);\n14:   `);\n15:   return db;\n16: }\n17: \n18: describe('vector dimension source precedence', () => {\n19:   afterEach(() => {\n20:     vi.restoreAllMocks();\n21:   });\n22: \n23:   it('uses the active embedder profile before vec_memories schema text', () => {\n24:     const db = makeMemoryDb();\n25:     try {\n26:       setActiveEmbedder(db, 'profile-model', 4, 'ollama');\n27:       db.exec(`CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[8])`);\n28: \n29:       const result = __testables.get_existing_embedding_dimension(db);\n30: \n31:       expect(result).toMatchObject({\n32:         existing_db: true,\n33:         stored_dim: 4,\n34:         source: 'active_embedder_profile',\n35:       });\n36:     } finally {\n37:       db.close();\n38:     }\n39:   });\n40: \n41:   it('demotes vec_memories schema parsing to a warning-only last resort', () => {\n42:     const db = new Database(':memory:');\n43:     sqliteVec.load(db);\n44:     const warn = vi.spyOn(console, 'warn').mockImplementation(() => {});\n45:     try {\n46:       db.exec(`\n47:         CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n48:         CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[6]);\n49:       `);\n50: \n51:       const result = __testables.get_existing_embedding_dimension(db, { allowProfileFallback: false });\n52: \n53:       expect(result).toMatchObject({\n54:         existing_db: true,\n55:         stored_dim: 6,\n56:         source: 'vec_memories',\n57:       });\n58:       expect(warn).toHaveBeenCalledWith(expect.stringContaining('Falling back to vec_memories schema text'));\n59:     } finally {\n60:       db.close();\n61:     }\n62:   });\n63: \n64:   it('reports absent schema without inventing a stored dimension', () => {\n65:     const db = new Database(':memory:');\n66:     try {\n67:       const result = __testables.get_existing_embedding_dimension(db);\n68: \n69:       expect(result).toMatchObject({\n70:         existing_db: false,\n71:         stored_dim: null,\n72:         source: null,\n73:       });\n74:     } finally {\n75:       db.close();\n76:     }\n77:   });\n78: });\n\n(End of file - total 78 lines)\n</content>","metadata":{"preview":"import Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { __testables } from '../lib/search/vector-index-store.js';\n\nfunction makeMemoryDb(): Database.Database {\n  const db = new Database(':memory:');\n  sqliteVec.load(db);\n  db.exec(`\n    CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n    CREATE TABLE vec_metadata (key TEXT PRIMARY KEY, value TEXT NOT NULL);\n  `);\n  return db;\n}\n\ndescribe('vector dimension source precedence', () => {\n  afterEach(() => {\n    vi.restoreAllMocks();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts","text":"import Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { __testables } from '../lib/search/vector-index-store.js';\n\nfunction makeMemoryDb(): Database.Database {\n  const db = new Database(':memory:');\n  sqliteVec.load(db);\n  db.exec(`\n    CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n    CREATE TABLE vec_metadata (key TEXT PRIMARY KEY, value TEXT NOT NULL);\n  `);\n  return db;\n}\n\ndescribe('vector dimension source precedence', () => {\n  afterEach(() => {\n    vi.restoreAllMocks();\n  });\n\n  it('uses the active embedder profile before vec_memories schema text', () => {\n    const db = makeMemoryDb();\n    try {\n      setActiveEmbedder(db, 'profile-model', 4, 'ollama');\n      db.exec(`CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[8])`);\n\n      const result = __testables.get_existing_embedding_dimension(db);\n\n      expect(result).toMatchObject({\n        existing_db: true,\n        stored_dim: 4,\n        source: 'active_embedder_profile',\n      });\n    } finally {\n      db.close();\n    }\n  });\n\n  it('demotes vec_memories schema parsing to a warning-only last resort', () => {\n    const db = new Database(':memory:');\n    sqliteVec.load(db);\n    const warn = vi.spyOn(console, 'warn').mockImplementation(() => {});\n    try {\n      db.exec(`\n        CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n        CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[6]);\n      `);\n\n      const result = __testables.get_existing_embedding_dimension(db, { allowProfileFallback: false });\n\n      expect(result).toMatchObject({\n        existing_db: true,\n        stored_dim: 6,\n        source: 'vec_memories',\n      });\n      expect(warn).toHaveBeenCalledWith(expect.stringContaining('Falling back to vec_memories schema text'));\n    } finally {\n      db.close();\n    }\n  });\n\n  it('reports absent schema without inventing a stored dimension', () => {\n    const db = new Database(':memory:');\n    try {\n      const result = __testables.get_existing_embedding_dimension(db);\n\n      expect(result).toMatchObject({\n        existing_db: false,\n        stored_dim: null,\n        source: null,\n      });\n    } finally {\n      db.close();\n    }\n  });\n});","lineStart":1,"lineEnd":78,"totalLines":78,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts","time":{"start":1781151302170,"end":1781151302180}},"metadata":{"openai":{"itemId":"fc_04292186e1973d54016a2a3645f768819189be04d8fea5a331"}},"id":"prt_eb4e40217001OIZ684c0fVbHIK","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","messageID":"msg_eb4e3ddff001DDPuOXXvV6VTl3"}}
{"type":"tool_use","timestamp":1781151302183,"sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","part":{"type":"tool","tool":"read","callID":"call_FxS5aabKEe40E1fj9dpzWufS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts</path>\n<type>file</type>\n<content>\n1: import * as fs from 'node:fs';\n2: import * as os from 'node:os';\n3: import * as path from 'node:path';\n4: \n5: import Database from 'better-sqlite3';\n6: import * as sqliteVec from 'sqlite-vec';\n7: import { afterEach, beforeEach, describe, expect, it } from 'vitest';\n8: \n9: import { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\n10: import { setActiveEmbedder } from '../lib/embedders/schema.js';\n11: import { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\n12: import {\n13:   benchmarkKnnQueryShapes,\n14:   shouldAdoptMatchQueryShape,\n15: } from '../lib/search/vector-index-queries.js';\n16: \n17: const DIM = 4;\n18: \n19: function embedding(value: number): Float32Array {\n20:   return Float32Array.from([value, value / 2, value / 3, value / 4]);\n21: }\n22: \n23: function embeddingBuffer(value: number): Buffer {\n24:   const vector = embedding(value);\n25:   return Buffer.from(vector.buffer, vector.byteOffset, vector.byteLength);\n26: }\n27: \n28: describe('vector KNN query-shape benchmark', () => {\n29:   let tempDir: string;\n30:   let db: Database.Database;\n31:   let profile: EmbeddingProfile;\n32: \n33:   beforeEach(() => {\n34:     tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-knn-benchmark-'));\n35:     db = new Database(path.join(tempDir, 'context-index.sqlite'));\n36:     sqliteVec.load(db);\n37:     profile = new EmbeddingProfile({ provider: 'ollama', model: 'knn-benchmark-model', dim: DIM, dtype: null, baseUrl: null });\n38:     setActiveEmbedder(db, profile.model, profile.dim, 'ollama');\n39:     attachActiveVectorShard(db, profile);\n40:     db.exec(`\n41:       CREATE TABLE memory_index (\n42:         id INTEGER PRIMARY KEY,\n43:         spec_folder TEXT,\n44:         file_path TEXT,\n45:         importance_tier TEXT DEFAULT 'normal',\n46:         importance_weight REAL DEFAULT 0.5,\n47:         embedding_status TEXT DEFAULT 'success',\n48:         expires_at TEXT,\n49:         is_pinned INTEGER DEFAULT 0,\n50:         last_review TEXT,\n51:         review_count INTEGER DEFAULT 0,\n52:         stability REAL,\n53:         updated_at TEXT DEFAULT (datetime('now'))\n54:       );\n55:       CREATE VIEW active_memory_projection AS SELECT id AS active_memory_id FROM memory_index;\n56:     `);\n57:     const memoryInsert = db.prepare(`\n58:       INSERT INTO memory_index (id, spec_folder, file_path, embedding_status)\n59:       VALUES (?, 'specs/knn', ?, 'success')\n60:     `);\n61:     const vecInsert = db.prepare(`INSERT INTO active_vec.vec_${DIM} (id, vec) VALUES (?, ?)`);\n62:     const knnInsert = db.prepare('INSERT INTO active_vec.vec_memories (rowid, embedding) VALUES (?, ?)');\n63:     const writeRows = db.transaction(() => {\n64:       for (let i = 1; i <= 32; i += 1) {\n65:         memoryInsert.run(i, `doc-${i}.md`);\n66:         vecInsert.run(i, embeddingBuffer(i));\n67:         knnInsert.run(BigInt(i), embeddingBuffer(i));\n68:       }\n69:     });\n70:     writeRows();\n71:   });\n72: \n73:   afterEach(() => {\n74:     try { detachActiveVectorShard(db); } catch { /* best-effort */ }\n75:     try { db.close(); } catch { /* best-effort */ }\n76:     fs.rmSync(tempDir, { recursive: true, force: true });\n77:   });\n78: \n79:   it('records scalar JOIN vs vec0 MATCH timings and gates adoption at >20 percent', () => {\n80:     const result = benchmarkKnnQueryShapes(embedding(1), { iterations: 2, limit: 8 }, db);\n81: \n82:     console.info(\n83:       `KNN query-shape benchmark: corpus=${result.corpusSize} scalar_ms=${result.scalarJoinAverageMs.toFixed(4)} ` +\n84:       `match_ms=${result.matchAverageMs?.toFixed(4) ?? 'n/a'} decision=${result.decision}`,\n85:     );\n86:     expect(result.corpusSize).toBe(32);\n87:     expect(result.scalarJoinAverageMs).toBeGreaterThanOrEqual(0);\n88:     expect(result.decision).toBe(\n89:       result.matchSupported && (result.matchImprovementPct ?? 0) > 20 ? 'adopt_match' : 'keep_scalar_join',\n90:     );\n91:     expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20 })).toBe(false);\n92:     expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20.1 })).toBe(true);\n93:   });\n94: });\n\n(End of file - total 94 lines)\n</content>","metadata":{"preview":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\nimport {\n  benchmarkKnnQueryShapes,\n  shouldAdoptMatchQueryShape,\n} from '../lib/search/vector-index-queries.js';\n\nconst DIM = 4;\n\nfunction embedding(value: number): Float32Array {\n  return Float32Array.from([value, value / 2, value / 3, value / 4]);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","text":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\nimport {\n  benchmarkKnnQueryShapes,\n  shouldAdoptMatchQueryShape,\n} from '../lib/search/vector-index-queries.js';\n\nconst DIM = 4;\n\nfunction embedding(value: number): Float32Array {\n  return Float32Array.from([value, value / 2, value / 3, value / 4]);\n}\n\nfunction embeddingBuffer(value: number): Buffer {\n  const vector = embedding(value);\n  return Buffer.from(vector.buffer, vector.byteOffset, vector.byteLength);\n}\n\ndescribe('vector KNN query-shape benchmark', () => {\n  let tempDir: string;\n  let db: Database.Database;\n  let profile: EmbeddingProfile;\n\n  beforeEach(() => {\n    tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-knn-benchmark-'));\n    db = new Database(path.join(tempDir, 'context-index.sqlite'));\n    sqliteVec.load(db);\n    profile = new EmbeddingProfile({ provider: 'ollama', model: 'knn-benchmark-model', dim: DIM, dtype: null, baseUrl: null });\n    setActiveEmbedder(db, profile.model, profile.dim, 'ollama');\n    attachActiveVectorShard(db, profile);\n    db.exec(`\n      CREATE TABLE memory_index (\n        id INTEGER PRIMARY KEY,\n        spec_folder TEXT,\n        file_path TEXT,\n        importance_tier TEXT DEFAULT 'normal',\n        importance_weight REAL DEFAULT 0.5,\n        embedding_status TEXT DEFAULT 'success',\n        expires_at TEXT,\n        is_pinned INTEGER DEFAULT 0,\n        last_review TEXT,\n        review_count INTEGER DEFAULT 0,\n        stability REAL,\n        updated_at TEXT DEFAULT (datetime('now'))\n      );\n      CREATE VIEW active_memory_projection AS SELECT id AS active_memory_id FROM memory_index;\n    `);\n    const memoryInsert = db.prepare(`\n      INSERT INTO memory_index (id, spec_folder, file_path, embedding_status)\n      VALUES (?, 'specs/knn', ?, 'success')\n    `);\n    const vecInsert = db.prepare(`INSERT INTO active_vec.vec_${DIM} (id, vec) VALUES (?, ?)`);\n    const knnInsert = db.prepare('INSERT INTO active_vec.vec_memories (rowid, embedding) VALUES (?, ?)');\n    const writeRows = db.transaction(() => {\n      for (let i = 1; i <= 32; i += 1) {\n        memoryInsert.run(i, `doc-${i}.md`);\n        vecInsert.run(i, embeddingBuffer(i));\n        knnInsert.run(BigInt(i), embeddingBuffer(i));\n      }\n    });\n    writeRows();\n  });\n\n  afterEach(() => {\n    try { detachActiveVectorShard(db); } catch { /* best-effort */ }\n    try { db.close(); } catch { /* best-effort */ }\n    fs.rmSync(tempDir, { recursive: true, force: true });\n  });\n\n  it('records scalar JOIN vs vec0 MATCH timings and gates adoption at >20 percent', () => {\n    const result = benchmarkKnnQueryShapes(embedding(1), { iterations: 2, limit: 8 }, db);\n\n    console.info(\n      `KNN query-shape benchmark: corpus=${result.corpusSize} scalar_ms=${result.scalarJoinAverageMs.toFixed(4)} ` +\n      `match_ms=${result.matchAverageMs?.toFixed(4) ?? 'n/a'} decision=${result.decision}`,\n    );\n    expect(result.corpusSize).toBe(32);\n    expect(result.scalarJoinAverageMs).toBeGreaterThanOrEqual(0);\n    expect(result.decision).toBe(\n      result.matchSupported && (result.matchImprovementPct ?? 0) > 20 ? 'adopt_match' : 'keep_scalar_join',\n    );\n    expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20 })).toBe(false);\n    expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20.1 })).toBe(true);\n  });\n});","lineStart":1,"lineEnd":94,"totalLines":94,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","time":{"start":1781151302172,"end":1781151302181}},"metadata":{"openai":{"itemId":"fc_04292186e1973d54016a2a3645f7748191bc672af7fa80f98f"}},"id":"prt_eb4e4021b001j5fWpMuTe2Gb7q","sessionID":"ses_14b1d6f10ffe46iC74jznEPrC4","messageID":"msg_eb4e3ddff001DDPuOXXvV6VTl3"}}
