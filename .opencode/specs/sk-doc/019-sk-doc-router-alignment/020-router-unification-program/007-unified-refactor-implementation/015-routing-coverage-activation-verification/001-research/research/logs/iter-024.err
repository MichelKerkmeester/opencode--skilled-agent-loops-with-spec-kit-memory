6:"""Lightweight recurring alignment checks for OpenCode codebases.
111:    parser = argparse.ArgumentParser(description="Verify recurring alignment drift across languages.")
522:        print("[alignment-drift] FAIL")
524:        print("[alignment-drift] PASS")
   429	    except json.JSONDecodeError as error:
   430	        findings.append(
   431	            Finding(
   432	                path=path,
   433	                line=error.lineno,
   434	                rule_id="JSONC-PARSE",
   435	                message=f"Invalid JSONC structure after comment stripping: {error.msg}",
   436	                fix_hint="Fix JSONC commas/braces/quotes while keeping comments JSONC-compatible.",
   437	            )
   438	        )
   439	    return findings
   440	
   441	
   442	def check_common(path: str, content: str) -> List[Finding]:
   443	    findings: List[Finding] = []
   444	    if "\r\n" in content:
   445	        findings.append(
   446	            Finding(
   447	                path=path,
   448	                line=1,
   449	                rule_id="COMMON-LINE-ENDINGS",
   450	                message="CRLF line endings detected.",
   451	                fix_hint="Normalize to LF line endings for deterministic cross-platform diffs.",
   452	            )
   453	        )
   454	    return findings
   455	
   456	
   457	def check_file(path: str) -> List[Finding]:
   458	    extension = os.path.splitext(path)[1].lower()
   459	    raw_findings: List[Finding] = []
   460	
   461	    try:
   462	        with open(path, "r", encoding="utf-8") as handle:
   463	            content = handle.read()
   464	    except UnicodeDecodeError:
   465	        return [
   466	            Finding(
   467	                path=path,
   468	                line=1,
   469	                rule_id="COMMON-UTF8",
   470	                message="File is not valid UTF-8 text.",
   471	                fix_hint="Re-encode the file as UTF-8.",
   472	            )
   473	        ]
   474	
   475	    lines = content.splitlines(keepends=True)
   476	    raw_findings.extend(check_common(path, content))
   477	
   478	    if extension in {".js", ".mjs", ".cjs"}:
   479	        raw_findings.extend(check_javascript(path, lines, extension))
   480	    elif extension in {".ts", ".tsx", ".mts"}:
   481	        raw_findings.extend(check_typescript(path, lines))
   482	    elif extension == ".py":
   483	        raw_findings.extend(check_python(path, lines))
   484	    elif extension == ".sh":
   485	        raw_findings.extend(check_shell(path, lines))
   486	    elif extension == ".rs":
   487	        raw_findings.extend(check_rust(path, lines, content))
   488	    elif extension == ".json":
   489	        raw_findings.extend(check_json(path, content))
   490	    elif extension == ".jsonc":
   491	        raw_findings.extend(check_jsonc(path, content))
   492	
   493	    findings: List[Finding] = []
   494	    for finding in raw_findings:
   495	        finding.severity = classify_severity(path, finding.rule_id)
   496	        findings.append(finding)
   497	    return findings
   498	
   499	
   500	def relpath(path: str) -> str:
   501	    try:
   502	        return os.path.relpath(path, os.getcwd())
   503	    except ValueError:
   504	        return path
   505	
   506	
   507	def main() -> int:
   508	    args = parse_args()
   509	    roots = args.root or [os.getcwd()]
   510	    findings: List[Finding] = []
   511	    scanned = 0
   512	
   513	    for file_path in sorted(iter_code_files(roots)):
   514	        scanned += 1
   515	        findings.extend(check_file(file_path))
   516	
   517	    error_count = sum(1 for item in findings if item.severity == "ERROR")
   518	    warning_count = sum(1 for item in findings if item.severity == "WARN")
   519	    should_fail = error_count > 0 or (args.fail_on_warn and warning_count > 0)
   520	
   521	    if should_fail:
   522	        print("[alignment-drift] FAIL")
   523	    else:
   524	        print("[alignment-drift] PASS")
   525	
   526	    print(f"Scanned files: {scanned}")
   527	    print(f"Findings: {len(findings)}")
   528	    print(f"Errors: {error_count}")
   529	    print(f"Warnings: {warning_count}")
   530	
   531	    if findings:
   532	        print("")
   533	        print("Actionable findings:")
   534	        for item in findings:
   535	            print(
   536	                f"- {relpath(item.path)}:{item.line} [{item.rule_id}] [{item.severity}] {item.message} "
   537	                f"Fix: {item.fix_hint}"
   538	            )
   539	    else:
   540	        print("Violations: 0")
   541	
   542	    if not should_fail and warning_count > 0 and not args.fail_on_warn:
   543	        print("")
   544	        print("Note: warnings are non-blocking by default. Use --fail-on-warn to make warnings fail.")
   545	
   546	    return 1 if should_fail else 0
   547	
   548	
   549	if __name__ == "__main__":
   550	    try:
   551	        sys.exit(main())
   552	    except BrokenPipeError:
   553	        # Support pipelines like `... | rg ...` without stack traces.
   554	        try:
   555	            sys.stdout.close()
   556	        except Exception:
   557	            pass
   558	        sys.exit(0)

