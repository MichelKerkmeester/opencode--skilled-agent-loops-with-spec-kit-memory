{"type":"tool_use","timestamp":1782750797058,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"type":"tool","tool":"read","callID":"call_e957d12e95674f3eadde3da3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/variant_parameter_check.py"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/variant_parameter_check.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"Deterministic schema gate for the design variant parameter contract.\n3: \n4: Variant transports can silently drift when a row looks complete but drops a\n5: renderer or leaves ownership vague. This checker reads the contract table and\n6: exits non-zero unless every variant knob has the required schema cells filled\n7: and names every canonical transport.\n8: \n9: Usage:\n10:   variant_parameter_check.py variant_parameter_contract.md\n11:   variant_parameter_check.py --json variant_parameter_contract.md\n12: \n13: Exit: 0 = rows present, complete, and transport-covered; 1 = violated;\n14: 2 = usage or read error.\n15: \"\"\"\n16: import json\n17: from pathlib import Path\n18: import re\n19: import sys\n20: from typing import Any\n21: \n22: TABLE_COLUMNS = [\n23:     \"knob\",\n24:     \"range/values\",\n25:     \"step\",\n26:     \"owner mode\",\n27:     \"transports\",\n28:     \"caveat\",\n29: ]\n30: REQUIRED_COLUMNS = [\n31:     \"knob\",\n32:     \"range/values\",\n33:     \"owner mode\",\n34:     \"transports\",\n35:     \"caveat\",\n36: ]\n37: CANONICAL_TRANSPORTS = [\"figma\", \"open-design\", \"live\"]\n38: KNOB_TABLE_HEADING = re.compile(r\"^#{1,6}\\s+(?:\\d+\\.\\s+)?Knob Schema\\s*$\", re.I)\n39: MARKDOWN_HEADING = re.compile(r\"^#{1,6}\\s+\")\n40: PLACEHOLDER = re.compile(r\"^(?:_+|TBD|TODO|-|N/A)$\", re.I)\n41: \n42: \n43: def _clean_cell(value: str) -> str:\n44:     value = value.strip()\n45:     if len(value) >= 2 and value[0] == \"`\" and value[-1] == \"`\":\n46:         value = value[1:-1].strip()\n47:     return value\n48: \n49: \n50: def _split_table_row(line: str) -> list[str]:\n51:     line = line.strip()\n52:     if not line.startswith(\"|\") or not line.endswith(\"|\"):\n53:         return []\n54:     return [cell.strip() for cell in line.strip(\"|\").split(\"|\")]\n55: \n56: \n57: def _is_separator_row(cells: list[str]) -> bool:\n58:     return bool(cells) and all(re.fullmatch(r\":?-{3,}:?\", cell.strip()) for cell in cells)\n59: \n60: \n61: def _is_placeholder(value: str) -> bool:\n62:     return not _clean_cell(value) or bool(PLACEHOLDER.fullmatch(_clean_cell(value)))\n63: \n64: \n65: def _normalized_header(cells: list[str]) -> list[str]:\n66:     normalized = []\n67:     for cell in cells:\n68:         cleaned = re.sub(r\"\\s+\", \" \", _clean_cell(cell).lower())\n69:         cleaned = cleaned.replace(\" / \", \"/\")\n70:         normalized.append(cleaned)\n71:     return normalized\n72: \n73: \n74: def _find_table_start(lines: list[str]) -> int:\n75:     for index, line in enumerate(lines):\n76:         if KNOB_TABLE_HEADING.match(line):\n77:             return index + 1\n78:     return 0\n79: \n80: \n81: def _find_rows(text: str) -> tuple[list[dict[str, Any]], list[str]]:\n82:     lines = text.splitlines()\n83:     start = _find_table_start(lines)\n84:     rows: list[dict[str, Any]] = []\n85:     errors: list[str] = []\n86:     in_table = False\n87:     saw_header = False\n88: \n89:     for line_number, line in enumerate(lines[start:], start + 1):\n90:         cells = _split_table_row(line)\n91:         if not cells:\n92:             if in_table:\n93:                 break\n94:             if MARKDOWN_HEADING.match(line) and start != 0:\n95:                 break\n96:             continue\n97: \n98:         if len(cells) != len(TABLE_COLUMNS):\n99:             errors.append(f\"line {line_number}: expected 6 columns, found {len(cells)}\")\n100:             in_table = True\n101:             continue\n102: \n103:         normalized = _normalized_header(cells)\n104:         if normalized == TABLE_COLUMNS:\n105:             in_table = True\n106:             saw_header = True\n107:             continue\n108:         if _is_separator_row(cells):\n109:             in_table = True\n110:             continue\n111:         if not saw_header:\n112:             continue\n113: \n114:         row = dict(zip(TABLE_COLUMNS, [_clean_cell(cell) for cell in cells]))\n115:         row[\"line\"] = line_number\n116:         rows.append(row)\n117: \n118:     if not saw_header:\n119:         errors.append(\"variant-parameter table header missing\")\n120:     return rows, errors\n121: \n122: \n123: def _transport_present(transports: str, transport: str) -> bool:\n124:     pattern = rf\"(?<![\\w-]){re.escape(transport)}(?![\\w-])\"\n125:     return bool(re.search(pattern, transports, re.I))\n126: \n127: \n128: def check(text: str) -> dict[str, Any]:\n129:     rows, errors = _find_rows(text)\n130:     incomplete: list[dict[str, str]] = []\n131:     missing_transports: list[dict[str, str]] = []\n132: \n133:     for index, row in enumerate(rows, 1):\n134:         knob = row[\"knob\"] if not _is_placeholder(row[\"knob\"]) else f\"row-{index}\"\n135:         for column in REQUIRED_COLUMNS:\n136:             if _is_placeholder(row[column]):\n137:                 incomplete.append({\"knob\": knob, \"column\": column})\n138: \n139:         if not _is_placeholder(row[\"transports\"]):\n140:             for transport in CANONICAL_TRANSPORTS:\n141:                 if not _transport_present(row[\"transports\"], transport):\n142:                     missing_transports.append({\"knob\": knob, \"transport\": transport})\n143: \n144:     missing = []\n145:     if not rows:\n146:         missing.append(\"variant-knob rows missing\")\n147: \n148:     ok = not errors and not missing and not incomplete and not missing_transports\n149:     return {\n150:         \"rows\": len(rows),\n151:         \"errors\": errors,\n152:         \"missing\": missing,\n153:         \"incomplete\": incomplete,\n154:         \"missing_transports\": missing_transports,\n155:         \"ok\": ok,\n156:     }\n157: \n158: \n159: def main(argv: list[str]) -> int:\n160:     as_json = \"--json\" in argv\n161:     paths = [arg for arg in argv if arg != \"--json\"]\n162:     if len(paths) != 1:\n163:         sys.stderr.write(\"usage: variant_parameter_check.py [--json] <variant_parameter_contract.md>\\n\")\n164:         return 2\n165: \n166:     path = Path(paths[0])\n167:     try:\n168:         text = path.read_text(encoding=\"utf-8\")\n169:     except OSError as exc:\n170:         sys.stderr.write(f\"cannot read {path}: {exc}\\n\")\n171:         return 2\n172: \n173:     result = check(text)\n174:     if as_json:\n175:         print(json.dumps({\"file\": str(path), **result}, indent=2))\n176:     else:\n177:         print(f\"Variant parameter schema gate - {path}\")\n178:         print(f\"  rows: {result['rows']}\")\n179:         if result[\"ok\"]:\n180:             print(\"PASS - all variant parameter rows are complete and transport-covered.\")\n181:         else:\n182:             for error in result[\"errors\"]:\n183:                 print(f\"FAIL - {error}\")\n184:             for missing in result[\"missing\"]:\n185:                 print(f\"FAIL - {missing}\")\n186:             for item in result[\"incomplete\"]:\n187:                 print(f\"FAIL - {item['knob']}: blank {item['column']}\")\n188:             for item in result[\"missing_transports\"]:\n189:                 print(f\"FAIL - {item['knob']}: missing transport {item['transport']}\")\n190: \n191:     return 0 if result[\"ok\"] else 1\n192: \n193: \n194: if __name__ == \"__main__\":\n195:     raise SystemExit(main(sys.argv[1:]))\n\n(End of file - total 195 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Deterministic schema gate for the design variant parameter contract.\n\nVariant transports can silently drift when a row looks complete but drops a\nrenderer or leaves ownership vague. This checker reads the contract table and\nexits non-zero unless every variant knob has the required schema cells filled\nand names every canonical transport.\n\nUsage:\n  variant_parameter_check.py variant_parameter_contract.md\n  variant_parameter_check.py --json variant_parameter_contract.md\n\nExit: 0 = rows present, complete, and transport-covered; 1 = violated;\n2 = usage or read error.\n\"\"\"\nimport json\nfrom pathlib import Path\nimport re\nimport sys\nfrom typing import Any","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/variant_parameter_check.py","text":"#!/usr/bin/env python3\n\"\"\"Deterministic schema gate for the design variant parameter contract.\n\nVariant transports can silently drift when a row looks complete but drops a\nrenderer or leaves ownership vague. This checker reads the contract table and\nexits non-zero unless every variant knob has the required schema cells filled\nand names every canonical transport.\n\nUsage:\n  variant_parameter_check.py variant_parameter_contract.md\n  variant_parameter_check.py --json variant_parameter_contract.md\n\nExit: 0 = rows present, complete, and transport-covered; 1 = violated;\n2 = usage or read error.\n\"\"\"\nimport json\nfrom pathlib import Path\nimport re\nimport sys\nfrom typing import Any\n\nTABLE_COLUMNS = [\n    \"knob\",\n    \"range/values\",\n    \"step\",\n    \"owner mode\",\n    \"transports\",\n    \"caveat\",\n]\nREQUIRED_COLUMNS = [\n    \"knob\",\n    \"range/values\",\n    \"owner mode\",\n    \"transports\",\n    \"caveat\",\n]\nCANONICAL_TRANSPORTS = [\"figma\", \"open-design\", \"live\"]\nKNOB_TABLE_HEADING = re.compile(r\"^#{1,6}\\s+(?:\\d+\\.\\s+)?Knob Schema\\s*$\", re.I)\nMARKDOWN_HEADING = re.compile(r\"^#{1,6}\\s+\")\nPLACEHOLDER = re.compile(r\"^(?:_+|TBD|TODO|-|N/A)$\", re.I)\n\n\ndef _clean_cell(value: str) -> str:\n    value = value.strip()\n    if len(value) >= 2 and value[0] == \"`\" and value[-1] == \"`\":\n        value = value[1:-1].strip()\n    return value\n\n\ndef _split_table_row(line: str) -> list[str]:\n    line = line.strip()\n    if not line.startswith(\"|\") or not line.endswith(\"|\"):\n        return []\n    return [cell.strip() for cell in line.strip(\"|\").split(\"|\")]\n\n\ndef _is_separator_row(cells: list[str]) -> bool:\n    return bool(cells) and all(re.fullmatch(r\":?-{3,}:?\", cell.strip()) for cell in cells)\n\n\ndef _is_placeholder(value: str) -> bool:\n    return not _clean_cell(value) or bool(PLACEHOLDER.fullmatch(_clean_cell(value)))\n\n\ndef _normalized_header(cells: list[str]) -> list[str]:\n    normalized = []\n    for cell in cells:\n        cleaned = re.sub(r\"\\s+\", \" \", _clean_cell(cell).lower())\n        cleaned = cleaned.replace(\" / \", \"/\")\n        normalized.append(cleaned)\n    return normalized\n\n\ndef _find_table_start(lines: list[str]) -> int:\n    for index, line in enumerate(lines):\n        if KNOB_TABLE_HEADING.match(line):\n            return index + 1\n    return 0\n\n\ndef _find_rows(text: str) -> tuple[list[dict[str, Any]], list[str]]:\n    lines = text.splitlines()\n    start = _find_table_start(lines)\n    rows: list[dict[str, Any]] = []\n    errors: list[str] = []\n    in_table = False\n    saw_header = False\n\n    for line_number, line in enumerate(lines[start:], start + 1):\n        cells = _split_table_row(line)\n        if not cells:\n            if in_table:\n                break\n            if MARKDOWN_HEADING.match(line) and start != 0:\n                break\n            continue\n\n        if len(cells) != len(TABLE_COLUMNS):\n            errors.append(f\"line {line_number}: expected 6 columns, found {len(cells)}\")\n            in_table = True\n            continue\n\n        normalized = _normalized_header(cells)\n        if normalized == TABLE_COLUMNS:\n            in_table = True\n            saw_header = True\n            continue\n        if _is_separator_row(cells):\n            in_table = True\n            continue\n        if not saw_header:\n            continue\n\n        row = dict(zip(TABLE_COLUMNS, [_clean_cell(cell) for cell in cells]))\n        row[\"line\"] = line_number\n        rows.append(row)\n\n    if not saw_header:\n        errors.append(\"variant-parameter table header missing\")\n    return rows, errors\n\n\ndef _transport_present(transports: str, transport: str) -> bool:\n    pattern = rf\"(?<![\\w-]){re.escape(transport)}(?![\\w-])\"\n    return bool(re.search(pattern, transports, re.I))\n\n\ndef check(text: str) -> dict[str, Any]:\n    rows, errors = _find_rows(text)\n    incomplete: list[dict[str, str]] = []\n    missing_transports: list[dict[str, str]] = []\n\n    for index, row in enumerate(rows, 1):\n        knob = row[\"knob\"] if not _is_placeholder(row[\"knob\"]) else f\"row-{index}\"\n        for column in REQUIRED_COLUMNS:\n            if _is_placeholder(row[column]):\n                incomplete.append({\"knob\": knob, \"column\": column})\n\n        if not _is_placeholder(row[\"transports\"]):\n            for transport in CANONICAL_TRANSPORTS:\n                if not _transport_present(row[\"transports\"], transport):\n                    missing_transports.append({\"knob\": knob, \"transport\": transport})\n\n    missing = []\n    if not rows:\n        missing.append(\"variant-knob rows missing\")\n\n    ok = not errors and not missing and not incomplete and not missing_transports\n    return {\n        \"rows\": len(rows),\n        \"errors\": errors,\n        \"missing\": missing,\n        \"incomplete\": incomplete,\n        \"missing_transports\": missing_transports,\n        \"ok\": ok,\n    }\n\n\ndef main(argv: list[str]) -> int:\n    as_json = \"--json\" in argv\n    paths = [arg for arg in argv if arg != \"--json\"]\n    if len(paths) != 1:\n        sys.stderr.write(\"usage: variant_parameter_check.py [--json] <variant_parameter_contract.md>\\n\")\n        return 2\n\n    path = Path(paths[0])\n    try:\n        text = path.read_text(encoding=\"utf-8\")\n    except OSError as exc:\n        sys.stderr.write(f\"cannot read {path}: {exc}\\n\")\n        return 2\n\n    result = check(text)\n    if as_json:\n        print(json.dumps({\"file\": str(path), **result}, indent=2))\n    else:\n        print(f\"Variant parameter schema gate - {path}\")\n        print(f\"  rows: {result['rows']}\")\n        if result[\"ok\"]:\n            print(\"PASS - all variant parameter rows are complete and transport-covered.\")\n        else:\n            for error in result[\"errors\"]:\n                print(f\"FAIL - {error}\")\n            for missing in result[\"missing\"]:\n                print(f\"FAIL - {missing}\")\n            for item in result[\"incomplete\"]:\n                print(f\"FAIL - {item['knob']}: blank {item['column']}\")\n            for item in result[\"missing_transports\"]:\n                print(f\"FAIL - {item['knob']}: missing transport {item['transport']}\")\n\n    return 0 if result[\"ok\"] else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main(sys.argv[1:]))","lineStart":1,"lineEnd":195,"totalLines":195,"truncated":false}},"title":".opencode/skills/sk-design/shared/scripts/variant_parameter_check.py","time":{"start":1782750797053,"end":1782750797057}},"id":"prt_f143a5cfc001m4CLsPfNCmm0RP","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f143a33f3001S2CFYBsC6VttBm"}}
