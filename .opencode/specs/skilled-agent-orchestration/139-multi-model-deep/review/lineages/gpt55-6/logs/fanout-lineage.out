{"type":"tool_use","timestamp":1780907816008,"sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","part":{"type":"tool","tool":"read","callID":"call_WUGaNudOUOjeRFxUiYWU1brW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","offset":1,"limit":600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs</path>\n<type>file</type>\n<content>\n1: 'use strict';\n2: \n3: const fs = require('fs');\n4: const net = require('net');\n5: const path = require('path');\n6: const { StringDecoder } = require('string_decoder');\n7: \n8: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n9: const DEFAULT_PROBE_TIMEOUT_MS = 5000;\n10: const MAX_PROBE_TIMEOUT_MS = 6999;\n11: const DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\n12: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n13: const MODEL_SERVER_HEALTH_PATH = '/api/health';\n14: let nextProbeId = 1;\n15: \n16: function parsePositiveInteger(value, fallback) {\n17:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n18:   const parsed = Number.parseInt(String(value).trim(), 10);\n19:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n20: }\n21: \n22: function clampProbeTimeoutMs(value) {\n23:   return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n24: }\n25: \n26: function resolveProbeTimeoutMs(options = {}) {\n27:   if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n28:     return clampProbeTimeoutMs(options.timeoutMs);\n29:   }\n30:   return clampProbeTimeoutMs(parsePositiveInteger(\n31:     (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n32:     DEFAULT_PROBE_TIMEOUT_MS,\n33:   ));\n34: }\n35: \n36: function parseNonNegativeInteger(value, fallback) {\n37:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n38:   const parsed = Number.parseInt(String(value).trim(), 10);\n39:   return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n40: }\n41: \n42: // A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n43: // daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n44: // consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n45: // its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n46: // the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\n47: function resolveLeaseProbeAttempts(env = process.env) {\n48:   return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n49: }\n50: function resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n51:   return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n52: }\n53: function resolveLeaseProbeRetryBackoffMs(env = process.env) {\n54:   return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n55: }\n56: \n57: function repoRoot() {\n58:   return path.resolve(__dirname, '..', '..', '..');\n59: }\n60: \n61: function defaultDbDirForService(serviceName) {\n62:   const root = repoRoot();\n63:   if (serviceName === 'mk-spec-memory') {\n64:     return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n65:   }\n66:   if (serviceName === 'mk-code-index') {\n67:     return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n68:       ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n69:       : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n70:   }\n71:   if (serviceName === 'mk-skill-advisor') {\n72:     const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n73:     return advisorOverride\n74:       ? path.resolve(advisorOverride)\n75:       : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n76:   }\n77:   throw new Error(`Unknown MCP service name: ${serviceName}`);\n78: }\n79: \n80: function getIpcSocketPath(serviceName, options = {}) {\n81:   if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n82:     return process.env.SPECKIT_IPC_SOCKET_DIR;\n83:   }\n84:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n85:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n86:     : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n87:   return path.join(socketDir, SOCKET_FILE_NAME);\n88: }\n89: \n90: function toConnectionOptions(socketPath) {\n91:   if (!socketPath.startsWith('tcp://')) {\n92:     return socketPath;\n93:   }\n94:   const url = new URL(socketPath);\n95:   return {\n96:     host: url.hostname,\n97:     port: Number.parseInt(url.port, 10),\n98:   };\n99: }\n100: \n101: function bridgeStdioToSocket(socketPath, options = {}) {\n102:   const input = options.stdin ?? process.stdin;\n103:   const output = options.stdout ?? process.stdout;\n104:   const exit = options.exit ?? ((code) => process.exit(code));\n105:   const socket = net.createConnection(toConnectionOptions(socketPath));\n106:   let closed = false;\n107: \n108:   const closeOnce = (code = 0) => {\n109:     if (closed) return;\n110:     closed = true;\n111:     input.unpipe(socket);\n112:     socket.unpipe(output);\n113:     socket.destroy();\n114:     exit(code);\n115:   };\n116: \n117:   socket.once('connect', () => {\n118:     options.onConnect?.(socket);\n119:     input.pipe(socket);\n120:     socket.pipe(output);\n121:   });\n122: \n123:   socket.once('error', (error) => {\n124:     options.onError?.(error);\n125:     closeOnce(0);\n126:   });\n127: \n128:   socket.once('close', () => {\n129:     closeOnce(0);\n130:   });\n131: \n132:   input.once('end', () => {\n133:     socket.end();\n134:   });\n135:   input.once('close', () => {\n136:     closeOnce(0);\n137:   });\n138:   output.once('error', () => {\n139:     closeOnce(0);\n140:   });\n141: \n142:   return socket;\n143: }\n144: \n145: function probeDaemon(socketPath, options = {}) {\n146:   const timeoutMs = resolveProbeTimeoutMs(options);\n147:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n148:   // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n149:   // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n150:   // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n151:   // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n152:   const deepProbe = options.deepProbe === true;\n153:   const id = nextProbeId++;\n154:   const request = `${JSON.stringify({\n155:     jsonrpc: '2.0',\n156:     id,\n157:     method: 'initialize',\n158:     params: {\n159:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n160:       capabilities: {},\n161:       clientInfo: { name: 'liveness-probe', version: '0' },\n162:     },\n163:   })}\\n`;\n164: \n165:   return new Promise((resolve) => {\n166:     let socket;\n167:     let settled = false;\n168:     let buffer = '';\n169:     let timer;\n170:     // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n171:     // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n172:     const decoder = new StringDecoder('utf8');\n173: \n174:     const finish = (status, reason) => {\n175:       if (settled) return;\n176:       settled = true;\n177:       if (timer) clearTimeout(timer);\n178:       if (socket) socket.destroy();\n179:       resolve({ status, reason });\n180:     };\n181: \n182:     try {\n183:       socket = connect(toConnectionOptions(socketPath));\n184:     } catch (error) {\n185:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n186:       return;\n187:     }\n188: \n189:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n190:     timer.unref?.();\n191: \n192:     socket.once('connect', () => {\n193:       if (!deepProbe) {\n194:         finish('alive', 'connect-ok');\n195:         return;\n196:       }\n197:       socket.write(request);\n198:     });\n199:     socket.on('data', (chunk) => {\n200:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n201:       let newlineIndex = buffer.indexOf('\\n');\n202:       while (newlineIndex !== -1) {\n203:         const line = buffer.slice(0, newlineIndex).trim();\n204:         buffer = buffer.slice(newlineIndex + 1);\n205:         newlineIndex = buffer.indexOf('\\n');\n206:         if (!line) continue;\n207:         try {\n208:           const parsed = JSON.parse(line);\n209:           if (\n210:             parsed &&\n211:             parsed.jsonrpc === '2.0' &&\n212:             parsed.id === id &&\n213:             (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n214:               Object.prototype.hasOwnProperty.call(parsed, 'error'))\n215:           ) {\n216:             finish('alive', 'json-rpc-reply');\n217:             return;\n218:           }\n219:         } catch {\n220:           // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n221:         }\n222:       }\n223:     });\n224:     socket.once('error', (error) => {\n225:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n226:     });\n227:     socket.once('close', () => {\n228:       finish('dead', 'closed-before-reply');\n229:     });\n230:   });\n231: }\n232: \n233: function parseHttpJsonResponse(buffer) {\n234:   const raw = buffer.toString('utf8');\n235:   const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n236:   if (headerEnd === -1) return null;\n237:   const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n238:   const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n239:   if (!statusMatch) return null;\n240:   const statusCode = Number.parseInt(statusMatch[1], 10);\n241:   const bodyRaw = raw.slice(headerEnd + 4).trim();\n242:   let body = null;\n243:   try {\n244:     body = bodyRaw ? JSON.parse(bodyRaw) : null;\n245:   } catch {\n246:     return { statusCode, body: null };\n247:   }\n248:   return { statusCode, body };\n249: }\n250: \n251: function probeModelServer(socketPath, options = {}) {\n252:   const timeoutMs = resolveProbeTimeoutMs(options);\n253:   const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n254:     ? options.loadingMaxMs\n255:     : parsePositiveInteger(\n256:       (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n257:       DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n258:     );\n259:   const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n260:   const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n261:   // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n262:   // without spawning a model server. Genuine embed consumers do not send this header, so their\n263:   // wake-on-demand path is unchanged.\n264:   const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n265: \n266:   return new Promise((resolve) => {\n267:     let socket;\n268:     let settled = false;\n269:     let chunks = [];\n270:     let timer;\n271: \n272:     // Carry the parsed health body so callers (the idle-eviction tick) can read\n273:     // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n274:     const finish = (status, reason, health) => {\n275:       if (settled) return;\n276:       settled = true;\n277:       if (timer) clearTimeout(timer);\n278:       if (socket) socket.destroy();\n279:       resolve({ status, reason, health });\n280:     };\n281: \n282:     try {\n283:       socket = connect(toConnectionOptions(socketPath));\n284:     } catch (error) {\n285:       finish('dead', error instanceof Error ? error.message : 'connect-threw');\n286:       return;\n287:     }\n288: \n289:     timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n290:     timer.unref?.();\n291: \n292:     socket.once('connect', () => {\n293:       socket.write(request);\n294:     });\n295:     socket.on('data', (chunk) => {\n296:       chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n297:     });\n298:     socket.once('end', () => {\n299:       const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n300:       const state = parsed && parsed.body && typeof parsed.body === 'object'\n301:         ? parsed.body.state\n302:         : null;\n303:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n304:         finish('alive', `health-${state}`, parsed.body);\n305:         return;\n306:       }\n307:       if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n308:         const loadStartedAt = parsed.body.loadStartedAt;\n309:         const loadProgressAt = parsed.body.loadProgressAt;\n310:         // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n311:         const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n312:           ? loadProgressAt\n313:           : loadStartedAt;\n314:         if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n315:           finish('dead', 'loading-wedged');\n316:           return;\n317:         }\n318:         finish('alive', 'health-loading', parsed.body);\n319:         return;\n320:       }\n321:       finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n322:     });\n323:     socket.once('error', (error) => {\n324:       finish('dead', error instanceof Error ? error.message : 'socket-error');\n325:     });\n326:     socket.once('close', () => {\n327:       if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n328:     });\n329:   });\n330: }\n331: \n332: // Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n333: // only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n334: // sleep are injectable so the retry decision is unit-testable without real sockets or timers.\n335: async function probeLeaseHolderWithRetries(socketPath, options = {}) {\n336:   const {\n337:     probe = probeDaemon,\n338:     firstTimeoutMs,\n339:     retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n340:     retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n341:     attempts = resolveLeaseProbeAttempts(),\n342:     connect,\n343:     sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n344:     onRetry,\n345:   } = options;\n346:   const totalAttempts = Math.max(1, attempts);\n347:   let result = { status: 'dead', reason: 'no-probe-attempted' };\n348:   for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n349:     const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n350:     result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n351:     if (result.status === 'alive') return result;\n352:     if (attempt < totalAttempts) {\n353:       if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n354:       await sleepFn(retryBackoffMs);\n355:     }\n356:   }\n357:   return result;\n358: }\n359: \n360: async function maybeBridgeLeaseHolder(options) {\n361:   const {\n362:     serviceName,\n363:     leaseResult,\n364:     loggerPrefix,\n365:     dbDir,\n366:     legacyReport,\n367:     probeTimeoutMs,\n368:     connect,\n369:     bridge,\n370:   } = options;\n371:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n372:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n373:   const ownerPid = leaseResult.ownerPid;\n374:   const writeLeaseHeld = (suffix = '') => {\n375:     process.stdout.write(`LEASE_HELD_BY:${ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n376:   };\n377: \n378:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n379:     if (legacyReport) {\n380:       legacyReport(leaseResult);\n381:       return { action: 'report', reason: 'bridge-disabled' };\n382:     }\n383:     writeLeaseHeld();\n384:     return { action: 'report', reason: 'bridge-disabled' };\n385:   }\n386: \n387:   // Prefer the path the lease owner actually recorded over recomputing one from env. Under a\n388:   // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n389:   // recomputed path can miss the live socket and false-report 'no-bridge-socket'. Only trust the\n390:   // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n391:   // to recomputation for legacy leases that predate socketPath and for the other launchers whose\n392:   // leases never carry it.\n393:   const storedSocketPath = leaseResult.socketPath;\n394:   const usableStoredSocketPath = typeof storedSocketPath === 'string'\n395:     && storedSocketPath.length > 0\n396:     && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n397:     ? storedSocketPath\n398:     : null;\n399:   const socketPath = usableStoredSocketPath ?? getIpcSocketPath(serviceName, { dbDir });\n400:   if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n401:     writeLeaseHeld(' (no-bridge-socket)');\n402:     return { action: 'report', reason: 'no-bridge-socket', socketPath };\n403:   }\n404: \n405:   // deepProbe: REQUIRE a JSON-RPC reply, not just a socket accept. The reap/bridge decision must\n406:   // detect a HUNG daemon (event loop wedged / deadlocked — it still accepts the UDS connection but\n407:   // never services requests). A connect-ok-only probe would bridge a client to the wedged daemon and\n408:   // hang it forever, never respawning. The raised probe timeout (default 5000ms, < the 7000ms launcher\n409:   // grace) already prevents false-reaping a busy-but-responsive daemon mid-FTS-merge, so deep probing\n410:   // does not regress that.\n411:   // Require N consecutive failures (not one transient miss) before reaping a sibling's owner.\n412:   const probeAttempts = resolveLeaseProbeAttempts();\n413:   const probe = await probeLeaseHolderWithRetries(socketPath, {\n414:     firstTimeoutMs: probeTimeoutMs,\n415:     attempts: probeAttempts,\n416:     connect,\n417:     onRetry: (attempt, total, result) => process.stderr.write(\n418:       `[${loggerPrefix}] lease holder pid=${ownerPid} probe ${attempt}/${total} not alive (${result.reason}); retrying\\n`,\n419:     ),\n420:   });\n421:   if (probe.status !== 'alive') {\n422:     process.stderr.write(`[${loggerPrefix}] lease holder pid=${ownerPid} socket=${socketPath} failed ${probeAttempts} consecutive liveness probes: ${probe.reason}\\n`);\n423:     return { action: 'respawn', reason: probe.reason, socketPath };\n424:   }\n425: \n426:   process.stderr.write(`[${loggerPrefix}] bridging to lease holder pid=${ownerPid} socket=${socketPath}\\n`);\n427:   const bridgeToSocket = bridge ?? bridgeStdioToSocket;\n428:   // Await so an injected reconnecting bridge (whose start() resolves after the first\n429:   // attach) is fully wired before returning. The raw bridge returns a socket, not a\n430:   // promise, so Promise.resolve keeps the original fire-and-forget timing for it.\n431:   await Promise.resolve(bridgeToSocket(socketPath, {\n432:     onError: () => {\n433:       writeLeaseHeld(' (bridge-refused)');\n434:     },\n435:   }));\n436:   return { action: 'bridge', socketPath };\n437: }\n438: \n439: module.exports = {\n440:   DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n441:   bridgeStdioToSocket,\n442:   getIpcSocketPath,\n443:   maybeBridgeLeaseHolder,\n444:   probeDaemon,\n445:   probeLeaseHolderWithRetries,\n446:   probeModelServer,\n447:   resolveLeaseProbeAttempts,\n448:   resolveLeaseProbeRetryBackoffMs,\n449:   resolveLeaseProbeRetryTimeoutMs,\n450:   toConnectionOptions,\n451: };\n\n(End of file - total 451 lines)\n</content>","metadata":{"preview":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","text":"'use strict';\n\nconst fs = require('fs');\nconst net = require('net');\nconst path = require('path');\nconst { StringDecoder } = require('string_decoder');\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst DEFAULT_PROBE_TIMEOUT_MS = 5000;\nconst MAX_PROBE_TIMEOUT_MS = 6999;\nconst DEFAULT_MODEL_SERVER_LOADING_MAX_MS = 150000;\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst MODEL_SERVER_HEALTH_PATH = '/api/health';\nlet nextProbeId = 1;\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction clampProbeTimeoutMs(value) {\n  return Math.min(value, MAX_PROBE_TIMEOUT_MS);\n}\n\nfunction resolveProbeTimeoutMs(options = {}) {\n  if (Number.isFinite(options.timeoutMs) && options.timeoutMs > 0) {\n    return clampProbeTimeoutMs(options.timeoutMs);\n  }\n  return clampProbeTimeoutMs(parsePositiveInteger(\n    (options.env ?? process.env).SPECKIT_PROBE_TIMEOUT_MS,\n    DEFAULT_PROBE_TIMEOUT_MS,\n  ));\n}\n\nfunction parseNonNegativeInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed >= 0 ? parsed : fallback;\n}\n\n// A single transient probe miss must NOT make a sibling reap the lease owner and respawn a second\n// daemon: a busy owner (e.g. mid-FTS-merge) can momentarily exceed the probe window. Require N\n// consecutive deep-probe failures before declaring the owner dead. Defaults keep the first probe at\n// its tuned full timeout and add one short retry plus a small backoff so the worst case stays inside\n// the probe grace ceiling — a genuinely dead socket fails fast, so only a hung daemon pays the retry.\nfunction resolveLeaseProbeAttempts(env = process.env) {\n  return 1 + parseNonNegativeInteger(env.SPECKIT_LEASE_PROBE_RETRIES, 1);\n}\nfunction resolveLeaseProbeRetryTimeoutMs(env = process.env) {\n  return clampProbeTimeoutMs(parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS, 1500));\n}\nfunction resolveLeaseProbeRetryBackoffMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_LEASE_PROBE_RETRY_BACKOFF_MS, 250);\n}\n\nfunction repoRoot() {\n  return path.resolve(__dirname, '..', '..', '..');\n}\n\nfunction defaultDbDirForService(serviceName) {\n  const root = repoRoot();\n  if (serviceName === 'mk-spec-memory') {\n    return path.join(root, '.opencode', 'skills', 'system-spec-kit', 'mcp_server', 'database');\n  }\n  if (serviceName === 'mk-code-index') {\n    return process.env.SPECKIT_CODE_GRAPH_DB_DIR\n      ? path.resolve(process.env.SPECKIT_CODE_GRAPH_DB_DIR)\n      : path.join(root, '.opencode', '.spec-kit', 'code-graph', 'database');\n  }\n  if (serviceName === 'mk-skill-advisor') {\n    const advisorOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n    return advisorOverride\n      ? path.resolve(advisorOverride)\n      : path.join(root, '.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database');\n  }\n  throw new Error(`Unknown MCP service name: ${serviceName}`);\n}\n\nfunction getIpcSocketPath(serviceName, options = {}) {\n  if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {\n    return process.env.SPECKIT_IPC_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(options.dbDir ?? defaultDbDirForService(serviceName));\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\nfunction toConnectionOptions(socketPath) {\n  if (!socketPath.startsWith('tcp://')) {\n    return socketPath;\n  }\n  const url = new URL(socketPath);\n  return {\n    host: url.hostname,\n    port: Number.parseInt(url.port, 10),\n  };\n}\n\nfunction bridgeStdioToSocket(socketPath, options = {}) {\n  const input = options.stdin ?? process.stdin;\n  const output = options.stdout ?? process.stdout;\n  const exit = options.exit ?? ((code) => process.exit(code));\n  const socket = net.createConnection(toConnectionOptions(socketPath));\n  let closed = false;\n\n  const closeOnce = (code = 0) => {\n    if (closed) return;\n    closed = true;\n    input.unpipe(socket);\n    socket.unpipe(output);\n    socket.destroy();\n    exit(code);\n  };\n\n  socket.once('connect', () => {\n    options.onConnect?.(socket);\n    input.pipe(socket);\n    socket.pipe(output);\n  });\n\n  socket.once('error', (error) => {\n    options.onError?.(error);\n    closeOnce(0);\n  });\n\n  socket.once('close', () => {\n    closeOnce(0);\n  });\n\n  input.once('end', () => {\n    socket.end();\n  });\n  input.once('close', () => {\n    closeOnce(0);\n  });\n  output.once('error', () => {\n    closeOnce(0);\n  });\n\n  return socket;\n}\n\nfunction probeDaemon(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // deepProbe=true REQUIRES a JSON-RPC initialize reply to call the daemon alive (detects a hung daemon\n  // that accepts the connection but never responds). Without it, a bare socket 'connect' counts as alive\n  // (connect-ok) — only safe for callers that genuinely need connection-liveness, NOT for the reap/bridge\n  // decision (which always passes deepProbe:true). See maybeBridgeLeaseHolder.\n  const deepProbe = options.deepProbe === true;\n  const id = nextProbeId++;\n  const request = `${JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    method: 'initialize',\n    params: {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'liveness-probe', version: '0' },\n    },\n  })}\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let buffer = '';\n    let timer;\n    // Hold a multibyte char split across chunk boundaries until complete, so a probe reply\n    // carrying CJK/emoji (e.g. serverInfo strings) is not corrupted to U+FFFD mid-parse.\n    const decoder = new StringDecoder('utf8');\n\n    const finish = (status, reason) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      if (!deepProbe) {\n        finish('alive', 'connect-ok');\n        return;\n      }\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const line = buffer.slice(0, newlineIndex).trim();\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (!line) continue;\n        try {\n          const parsed = JSON.parse(line);\n          if (\n            parsed &&\n            parsed.jsonrpc === '2.0' &&\n            parsed.id === id &&\n            (Object.prototype.hasOwnProperty.call(parsed, 'result') ||\n              Object.prototype.hasOwnProperty.call(parsed, 'error'))\n          ) {\n            finish('alive', 'json-rpc-reply');\n            return;\n          }\n        } catch {\n          // Ignore malformed or unrelated frames; the bounded probe decides liveness.\n        }\n      }\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\nfunction parseHttpJsonResponse(buffer) {\n  const raw = buffer.toString('utf8');\n  const headerEnd = raw.indexOf('\\r\\n\\r\\n');\n  if (headerEnd === -1) return null;\n  const statusLine = raw.slice(0, raw.indexOf('\\r\\n'));\n  const statusMatch = statusLine.match(/^HTTP\\/\\d(?:\\.\\d)?\\s+(\\d+)/);\n  if (!statusMatch) return null;\n  const statusCode = Number.parseInt(statusMatch[1], 10);\n  const bodyRaw = raw.slice(headerEnd + 4).trim();\n  let body = null;\n  try {\n    body = bodyRaw ? JSON.parse(bodyRaw) : null;\n  } catch {\n    return { statusCode, body: null };\n  }\n  return { statusCode, body };\n}\n\nfunction probeModelServer(socketPath, options = {}) {\n  const timeoutMs = resolveProbeTimeoutMs(options);\n  const loadingMaxMs = Number.isFinite(options.loadingMaxMs) && options.loadingMaxMs > 0\n    ? options.loadingMaxMs\n    : parsePositiveInteger(\n      (options.env ?? process.env).SPECKIT_HF_MODEL_SERVER_LOADING_MAX_MS,\n      DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n    );\n  const nowMs = typeof options.nowMs === 'function' ? options.nowMs : () => Date.now();\n  const connect = options.connect ?? ((connectionOptions) => net.createConnection(connectionOptions));\n  // Mark this as the launcher's internal liveness probe so a cold-state demand listener can answer\n  // without spawning a model server. Genuine embed consumers do not send this header, so their\n  // wake-on-demand path is unchanged.\n  const request = `GET ${MODEL_SERVER_HEALTH_PATH} HTTP/1.1\\r\\nHost: localhost\\r\\nAccept: application/json\\r\\nX-Speckit-Probe: liveness\\r\\nConnection: close\\r\\n\\r\\n`;\n\n  return new Promise((resolve) => {\n    let socket;\n    let settled = false;\n    let chunks = [];\n    let timer;\n\n    // Carry the parsed health body so callers (the idle-eviction tick) can read\n    // lastSuccessfulEmbedAt / inFlight. The 'alive' branches below pass parsed.body as the 3rd arg.\n    const finish = (status, reason, health) => {\n      if (settled) return;\n      settled = true;\n      if (timer) clearTimeout(timer);\n      if (socket) socket.destroy();\n      resolve({ status, reason, health });\n    };\n\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      finish('dead', error instanceof Error ? error.message : 'connect-threw');\n      return;\n    }\n\n    timer = setTimeout(() => finish('dead', 'timeout'), timeoutMs);\n    timer.unref?.();\n\n    socket.once('connect', () => {\n      socket.write(request);\n    });\n    socket.on('data', (chunk) => {\n      chunks.push(Buffer.isBuffer(chunk) ? chunk : Buffer.from(String(chunk ?? '')));\n    });\n    socket.once('end', () => {\n      const parsed = parseHttpJsonResponse(Buffer.concat(chunks));\n      const state = parsed && parsed.body && typeof parsed.body === 'object'\n        ? parsed.body.state\n        : null;\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'ready') {\n        finish('alive', `health-${state}`, parsed.body);\n        return;\n      }\n      if (parsed && parsed.statusCode >= 200 && parsed.statusCode < 300 && state === 'loading') {\n        const loadStartedAt = parsed.body.loadStartedAt;\n        const loadProgressAt = parsed.body.loadProgressAt;\n        // The loading budget is per model-load attempt; device fallback re-stamps loadProgressAt.\n        const loadingMarker = Number.isFinite(loadProgressAt) && loadProgressAt > 0\n          ? loadProgressAt\n          : loadStartedAt;\n        if (Number.isFinite(loadingMarker) && loadingMarker > 0 && nowMs() - loadingMarker > loadingMaxMs) {\n          finish('dead', 'loading-wedged');\n          return;\n        }\n        finish('alive', 'health-loading', parsed.body);\n        return;\n      }\n      finish('dead', state === 'error' ? 'health-error' : 'health-not-ready');\n    });\n    socket.once('error', (error) => {\n      finish('dead', error instanceof Error ? error.message : 'socket-error');\n    });\n    socket.once('close', () => {\n      if (!settled && chunks.length === 0) finish('dead', 'closed-before-reply');\n    });\n  });\n}\n\n// Run the deep liveness probe up to `attempts` times; any 'alive' short-circuits to a bridge, and\n// only an all-failures run returns the final (dead) result so the caller respawns. The probe fn and\n// sleep are injectable so the retry decision is unit-testable without real sockets or timers.\nasync function probeLeaseHolderWithRetries(socketPath, options = {}) {\n  const {\n    probe = probeDaemon,\n    firstTimeoutMs,\n    retryTimeoutMs = resolveLeaseProbeRetryTimeoutMs(),\n    retryBackoffMs = resolveLeaseProbeRetryBackoffMs(),\n    attempts = resolveLeaseProbeAttempts(),\n    connect,\n    sleepFn = (ms) => new Promise((resolve) => { setTimeout(resolve, ms); }),\n    onRetry,\n  } = options;\n  const totalAttempts = Math.max(1, attempts);\n  let result = { status: 'dead', reason: 'no-probe-attempted' };\n  for (let attempt = 1; attempt <= totalAttempts; attempt += 1) {\n    const timeoutMs = attempt === 1 ? firstTimeoutMs : retryTimeoutMs;\n    result = await probe(socketPath, { timeoutMs, connect, deepProbe: true });\n    if (result.status === 'alive') return result;\n    if (attempt < totalAttempts) {\n      if (typeof onRetry === 'function') onRetry(attempt, totalAttempts, result);\n      await sleepFn(retryBackoffMs);\n    }\n  }\n  return result;\n}\n\nasync function maybeBridgeLeaseHolder(options) {\n  const {\n    serviceName,\n    leaseResult,\n    loggerPrefix,\n    dbDir,\n    legacyReport,\n    probeTimeoutMs,\n    connect,\n    bridge,\n  } = options;\n  const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n  const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n  const ownerPid = leaseResult.ownerPid;\n  const writeLeaseHeld = (suffix = '') => {\n    process.stdout.write(`LEASE_HELD_BY:${ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n  };\n\n  if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n    if (legacyReport) {\n      legacyReport(leaseResult);\n      return { action: 'report', reason: 'bridge-disabled' };\n    }\n    writeLeaseHeld();\n    return { action: 'report', reason: 'bridge-disabled' };\n  }\n\n  // Prefer the path the lease owner actually recorded over recomputing one from env. Under a\n  // divergent SPECKIT_IPC_SOCKET_DIR (e.g. a secondary launcher in a different worktree env), the\n  // recomputed path can miss the live socket and false-report 'no-bridge-socket'. Only trust the\n  // stored path when it still exists on disk; tcp:// endpoints bypass the existence check. Fall back\n  // to recomputation for legacy leases that predate socketPath and for the other launchers whose\n  // leases never carry it.\n  const storedSocketPath = leaseResult.socketPath;\n  const usableStoredSocketPath = typeof storedSocketPath === 'string'\n    && storedSocketPath.length > 0\n    && (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n    ? storedSocketPath\n    : null;\n  const socketPath = usableStoredSocketPath ?? getIpcSocketPath(serviceName, { dbDir });\n  if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n    writeLeaseHeld(' (no-bridge-socket)');\n    return { action: 'report', reason: 'no-bridge-socket', socketPath };\n  }\n\n  // deepProbe: REQUIRE a JSON-RPC reply, not just a socket accept. The reap/bridge decision must\n  // detect a HUNG daemon (event loop wedged / deadlocked — it still accepts the UDS connection but\n  // never services requests). A connect-ok-only probe would bridge a client to the wedged daemon and\n  // hang it forever, never respawning. The raised probe timeout (default 5000ms, < the 7000ms launcher\n  // grace) already prevents false-reaping a busy-but-responsive daemon mid-FTS-merge, so deep probing\n  // does not regress that.\n  // Require N consecutive failures (not one transient miss) before reaping a sibling's owner.\n  const probeAttempts = resolveLeaseProbeAttempts();\n  const probe = await probeLeaseHolderWithRetries(socketPath, {\n    firstTimeoutMs: probeTimeoutMs,\n    attempts: probeAttempts,\n    connect,\n    onRetry: (attempt, total, result) => process.stderr.write(\n      `[${loggerPrefix}] lease holder pid=${ownerPid} probe ${attempt}/${total} not alive (${result.reason}); retrying\\n`,\n    ),\n  });\n  if (probe.status !== 'alive') {\n    process.stderr.write(`[${loggerPrefix}] lease holder pid=${ownerPid} socket=${socketPath} failed ${probeAttempts} consecutive liveness probes: ${probe.reason}\\n`);\n    return { action: 'respawn', reason: probe.reason, socketPath };\n  }\n\n  process.stderr.write(`[${loggerPrefix}] bridging to lease holder pid=${ownerPid} socket=${socketPath}\\n`);\n  const bridgeToSocket = bridge ?? bridgeStdioToSocket;\n  // Await so an injected reconnecting bridge (whose start() resolves after the first\n  // attach) is fully wired before returning. The raw bridge returns a socket, not a\n  // promise, so Promise.resolve keeps the original fire-and-forget timing for it.\n  await Promise.resolve(bridgeToSocket(socketPath, {\n    onError: () => {\n      writeLeaseHeld(' (bridge-refused)');\n    },\n  }));\n  return { action: 'bridge', socketPath };\n}\n\nmodule.exports = {\n  DEFAULT_MODEL_SERVER_LOADING_MAX_MS,\n  bridgeStdioToSocket,\n  getIpcSocketPath,\n  maybeBridgeLeaseHolder,\n  probeDaemon,\n  probeLeaseHolderWithRetries,\n  probeModelServer,\n  resolveLeaseProbeAttempts,\n  resolveLeaseProbeRetryBackoffMs,\n  resolveLeaseProbeRetryTimeoutMs,\n  toConnectionOptions,\n};","lineStart":1,"lineEnd":451,"totalLines":451,"truncated":false}},"title":".opencode/bin/lib/launcher-ipc-bridge.cjs","time":{"start":1780907815996,"end":1780907816007}},"metadata":{"openai":{"itemId":"fc_0496853919e9ef02016a267f27c668819196a602b05b5241da"}},"id":"prt_ea660b4140011zJn7lZXEKomLW","sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","messageID":"msg_ea6608043001bRKh2O65UAKOye"}}
{"type":"tool_use","timestamp":1780907816054,"sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","part":{"type":"tool","tool":"read","callID":"call_crLgsBswDNEDaEO9rjX4xQR3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/session-cleanup.sh","offset":1,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/session-cleanup.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bash\n2: # Clean up MCP helper descendants owned by the current Claude Code session.\n3: #\n4: # This script is intentionally session-scoped: it only ever kills processes it\n5: # can prove are descendants of CLAUDE_SESSION_PID, and it re-proves that\n6: # ancestry immediately before each kill. There is deliberately NO fallback to\n7: # the hook's PPID — under a shared terminal that PPID can resolve to an\n8: # ancestor common to MANY live sessions, turning \"this session's descendants\"\n9: # into \"every session's MCP helpers\" and killing sibling sessions' transports\n10: # mid-flight. Missing session identity means we do nothing.\n11: \n12: set -euo pipefail\n13: \n14: SESSION_PID=\"${CLAUDE_SESSION_PID:-}\"\n15: LOG_PATH=\"${CLAUDE_SESSION_CLEANUP_LOG_PATH:-${HOME:-/tmp}/.local/share/claude-stop-hook.log}\"\n16: EXIT_CODE=0\n17: descendants=()\n18: \n19: # Orphan-sweep fallback for the no-session-pid case. Default off. \"dry-run\" logs candidate reaps\n20: # without mutating; \"1\"/\"on\"/\"live\" reaps. It delegates to the ORPHAN-ONLY sweeper, which reaps only\n21: # ownerless (reparented) MCP processes and so can never touch a live sibling session — unlike a PPID\n22: # guess, which this script deliberately refuses (see header). The sweeper path is overridable for tests.\n23: SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n24: ORPHAN_SWEEP_MODE=\"${SPECKIT_STOP_HOOK_ORPHAN_SWEEP:-off}\"\n25: ORPHAN_SWEEPER_BIN=\"${SPECKIT_ORPHAN_SWEEPER_BIN:-$SCRIPT_DIR/orphan-mcp-sweeper.sh}\"\n26: \n27: emit() {\n28:   local line\n29:   line=\"$(date '+%Y-%m-%dT%H:%M:%S%z') $*\"\n30:   printf '%s\\n' \"$line\"\n31:   if [ -n \"$LOG_PATH\" ]; then\n32:     mkdir -p \"$(dirname \"$LOG_PATH\")\" 2>/dev/null || true\n33:     printf '%s\\n' \"$line\" >> \"$LOG_PATH\" 2>/dev/null || true\n34:   fi\n35: }\n36: \n37: pid_in_descendants() {\n38:   local needle=\"$1\"\n39:   local item\n40:   [ \"${#descendants[@]}\" -gt 0 ] || return 1\n41:   for item in \"${descendants[@]}\"; do\n42:     [ \"$item\" = \"$needle\" ] && return 0\n43:   done\n44:   return 1\n45: }\n46: \n47: append_descendants() {\n48:   local parent=\"$1\"\n49:   local child\n50:   while read -r child; do\n51:     [ -n \"$child\" ] || continue\n52:     if ! pid_in_descendants \"$child\"; then\n53:       descendants+=(\"$child\")\n54:       append_descendants \"$child\"\n55:     fi\n56:   done <<EOF\n57: $(pgrep -P \"$parent\" 2>/dev/null || true)\n58: EOF\n59: }\n60: \n61: is_target_command() {\n62:   local cmd=\"$1\"\n63:   case \"$cmd\" in\n64:     *\"mk-spec-memory-launcher.cjs\"*|\\\n65:     *\"mk-skill-advisor-launcher.cjs\"*|\\\n66:     *\"mk-code-index-launcher.cjs\"*|\\\n67:     *\"system-spec-kit/mcp_server/dist/context-server.js\"*|\\\n68:     *\"system-skill-advisor/mcp_server/dist/\"*\"advisor-server.js\"*|\\\n69:     *\"system-code-graph/mcp_server/dist/index.js\"*|\\\n70:     *\"mcp-code-mode/mcp_server/dist/index.js\"*|\\\n71:     *\"@modelcontextprotocol/server-sequential-thinking\"*|\\\n72:     *\"server-sequential-thinking\"*|\\\n73:     *\"clickup-mcp-server\"*)\n74:       return 0\n75:       ;;\n76:   esac\n77:   return 1\n78: }\n79: \n80: # Re-prove, at kill time, that a candidate is still a descendant of the\n81: # session. The pgrep walk above is a snapshot; a process can be re-parented\n82: # (orphan adoption by launchd/init) between the walk and the kill, and a pid\n83: # can in principle be recycled. Walking the live ppid chain upward closes\n84: # that race: a process belonging to a sibling session can never have OUR\n85: # session pid in its ancestor chain.\n86: is_descendant_of_session() {\n87:   local pid=\"$1\"\n88:   local depth=0\n89:   local current=\"$pid\"\n90:   while [ \"$depth\" -lt 15 ]; do\n91:     current=\"$(ps -o ppid= -p \"$current\" 2>/dev/null | tr -d ' ' || true)\"\n92:     [ -n \"$current\" ] || return 1\n93:     [ \"$current\" = \"0\" ] && return 1\n94:     [ \"$current\" = \"1\" ] && return 1\n95:     if [ \"$current\" = \"$SESSION_PID\" ]; then\n96:       return 0\n97:     fi\n98:     depth=$((depth + 1))\n99:   done\n100:   return 1\n101: }\n102: \n103: # Without a session pid the session-scoped kill below is impossible, and guessing is unsafe. Fall\n104: # back to the orphan-only sweeper when explicitly enabled; otherwise keep the historical no-op.\n105: run_orphan_sweep_fallback() {\n106:   case \"$ORPHAN_SWEEP_MODE\" in\n107:     1|on|live)\n108:       emit \"action=orphan-sweep mode=live reason=no-session-pid\"\n109:       bash \"$ORPHAN_SWEEPER_BIN\" || true\n110:       ;;\n111:     dry-run|dryrun|dry)\n112:       emit \"action=orphan-sweep mode=dry-run reason=no-session-pid\"\n113:       bash \"$ORPHAN_SWEEPER_BIN\" --dry-run || true\n114:       ;;\n115:     *)\n116:       emit \"action=skip reason=no-session-pid\"\n117:       ;;\n118:   esac\n119: }\n120: \n121: if [ -z \"$SESSION_PID\" ]; then\n122:   run_orphan_sweep_fallback\n123:   exit 0\n124: fi\n125: if ! kill -0 \"$SESSION_PID\" 2>/dev/null; then\n126:   emit \"action=skip reason=session-pid-not-alive session_pid=$SESSION_PID\"\n127:   exit 0\n128: fi\n129: \n130: append_descendants \"$SESSION_PID\"\n131: emit \"action=start session_pid=$SESSION_PID descendants=${#descendants[@]}\"\n132: \n133: if [ \"${#descendants[@]}\" -gt 0 ]; then\n134:   for pid in \"${descendants[@]}\"; do\n135:     cmd=\"$(ps -p \"$pid\" -o command= 2>/dev/null || true)\"\n136:     [ -n \"$cmd\" ] || continue\n137:     if is_target_command \"$cmd\"; then\n138:       if ! is_descendant_of_session \"$pid\"; then\n139:         emit \"action=skip-kill reason=ancestry-not-confirmed pid=$pid matched_by=name ancestor_ok=no command=$cmd\"\n140:         continue\n141:       fi\n142:       emit \"action=kill signal=TERM pid=$pid matched_by=name ancestor_ok=yes command=$cmd\"\n143:       if ! kill -15 \"$pid\" 2>/dev/null; then\n144:         emit \"action=kill-failed signal=TERM pid=$pid\"\n145:         EXIT_CODE=1\n146:       fi\n147:     fi\n148:   done\n149: fi\n150: \n151: emit \"action=summary session_pid=$SESSION_PID exit_code=$EXIT_CODE\"\n152: exit \"$EXIT_CODE\"\n\n(End of file - total 152 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bash\n# Clean up MCP helper descendants owned by the current Claude Code session.\n#\n# This script is intentionally session-scoped: it only ever kills processes it\n# can prove are descendants of CLAUDE_SESSION_PID, and it re-proves that\n# ancestry immediately before each kill. There is deliberately NO fallback to\n# the hook's PPID — under a shared terminal that PPID can resolve to an\n# ancestor common to MANY live sessions, turning \"this session's descendants\"\n# into \"every session's MCP helpers\" and killing sibling sessions' transports\n# mid-flight. Missing session identity means we do nothing.\n\nset -euo pipefail\n\nSESSION_PID=\"${CLAUDE_SESSION_PID:-}\"\nLOG_PATH=\"${CLAUDE_SESSION_CLEANUP_LOG_PATH:-${HOME:-/tmp}/.local/share/claude-stop-hook.log}\"\nEXIT_CODE=0\ndescendants=()\n\n# Orphan-sweep fallback for the no-session-pid case. Default off. \"dry-run\" logs candidate reaps\n# without mutating; \"1\"/\"on\"/\"live\" reaps. It delegates to the ORPHAN-ONLY sweeper, which reaps only","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/scripts/session-cleanup.sh","text":"#!/usr/bin/env bash\n# Clean up MCP helper descendants owned by the current Claude Code session.\n#\n# This script is intentionally session-scoped: it only ever kills processes it\n# can prove are descendants of CLAUDE_SESSION_PID, and it re-proves that\n# ancestry immediately before each kill. There is deliberately NO fallback to\n# the hook's PPID — under a shared terminal that PPID can resolve to an\n# ancestor common to MANY live sessions, turning \"this session's descendants\"\n# into \"every session's MCP helpers\" and killing sibling sessions' transports\n# mid-flight. Missing session identity means we do nothing.\n\nset -euo pipefail\n\nSESSION_PID=\"${CLAUDE_SESSION_PID:-}\"\nLOG_PATH=\"${CLAUDE_SESSION_CLEANUP_LOG_PATH:-${HOME:-/tmp}/.local/share/claude-stop-hook.log}\"\nEXIT_CODE=0\ndescendants=()\n\n# Orphan-sweep fallback for the no-session-pid case. Default off. \"dry-run\" logs candidate reaps\n# without mutating; \"1\"/\"on\"/\"live\" reaps. It delegates to the ORPHAN-ONLY sweeper, which reaps only\n# ownerless (reparented) MCP processes and so can never touch a live sibling session — unlike a PPID\n# guess, which this script deliberately refuses (see header). The sweeper path is overridable for tests.\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nORPHAN_SWEEP_MODE=\"${SPECKIT_STOP_HOOK_ORPHAN_SWEEP:-off}\"\nORPHAN_SWEEPER_BIN=\"${SPECKIT_ORPHAN_SWEEPER_BIN:-$SCRIPT_DIR/orphan-mcp-sweeper.sh}\"\n\nemit() {\n  local line\n  line=\"$(date '+%Y-%m-%dT%H:%M:%S%z') $*\"\n  printf '%s\\n' \"$line\"\n  if [ -n \"$LOG_PATH\" ]; then\n    mkdir -p \"$(dirname \"$LOG_PATH\")\" 2>/dev/null || true\n    printf '%s\\n' \"$line\" >> \"$LOG_PATH\" 2>/dev/null || true\n  fi\n}\n\npid_in_descendants() {\n  local needle=\"$1\"\n  local item\n  [ \"${#descendants[@]}\" -gt 0 ] || return 1\n  for item in \"${descendants[@]}\"; do\n    [ \"$item\" = \"$needle\" ] && return 0\n  done\n  return 1\n}\n\nappend_descendants() {\n  local parent=\"$1\"\n  local child\n  while read -r child; do\n    [ -n \"$child\" ] || continue\n    if ! pid_in_descendants \"$child\"; then\n      descendants+=(\"$child\")\n      append_descendants \"$child\"\n    fi\n  done <<EOF\n$(pgrep -P \"$parent\" 2>/dev/null || true)\nEOF\n}\n\nis_target_command() {\n  local cmd=\"$1\"\n  case \"$cmd\" in\n    *\"mk-spec-memory-launcher.cjs\"*|\\\n    *\"mk-skill-advisor-launcher.cjs\"*|\\\n    *\"mk-code-index-launcher.cjs\"*|\\\n    *\"system-spec-kit/mcp_server/dist/context-server.js\"*|\\\n    *\"system-skill-advisor/mcp_server/dist/\"*\"advisor-server.js\"*|\\\n    *\"system-code-graph/mcp_server/dist/index.js\"*|\\\n    *\"mcp-code-mode/mcp_server/dist/index.js\"*|\\\n    *\"@modelcontextprotocol/server-sequential-thinking\"*|\\\n    *\"server-sequential-thinking\"*|\\\n    *\"clickup-mcp-server\"*)\n      return 0\n      ;;\n  esac\n  return 1\n}\n\n# Re-prove, at kill time, that a candidate is still a descendant of the\n# session. The pgrep walk above is a snapshot; a process can be re-parented\n# (orphan adoption by launchd/init) between the walk and the kill, and a pid\n# can in principle be recycled. Walking the live ppid chain upward closes\n# that race: a process belonging to a sibling session can never have OUR\n# session pid in its ancestor chain.\nis_descendant_of_session() {\n  local pid=\"$1\"\n  local depth=0\n  local current=\"$pid\"\n  while [ \"$depth\" -lt 15 ]; do\n    current=\"$(ps -o ppid= -p \"$current\" 2>/dev/null | tr -d ' ' || true)\"\n    [ -n \"$current\" ] || return 1\n    [ \"$current\" = \"0\" ] && return 1\n    [ \"$current\" = \"1\" ] && return 1\n    if [ \"$current\" = \"$SESSION_PID\" ]; then\n      return 0\n    fi\n    depth=$((depth + 1))\n  done\n  return 1\n}\n\n# Without a session pid the session-scoped kill below is impossible, and guessing is unsafe. Fall\n# back to the orphan-only sweeper when explicitly enabled; otherwise keep the historical no-op.\nrun_orphan_sweep_fallback() {\n  case \"$ORPHAN_SWEEP_MODE\" in\n    1|on|live)\n      emit \"action=orphan-sweep mode=live reason=no-session-pid\"\n      bash \"$ORPHAN_SWEEPER_BIN\" || true\n      ;;\n    dry-run|dryrun|dry)\n      emit \"action=orphan-sweep mode=dry-run reason=no-session-pid\"\n      bash \"$ORPHAN_SWEEPER_BIN\" --dry-run || true\n      ;;\n    *)\n      emit \"action=skip reason=no-session-pid\"\n      ;;\n  esac\n}\n\nif [ -z \"$SESSION_PID\" ]; then\n  run_orphan_sweep_fallback\n  exit 0\nfi\nif ! kill -0 \"$SESSION_PID\" 2>/dev/null; then\n  emit \"action=skip reason=session-pid-not-alive session_pid=$SESSION_PID\"\n  exit 0\nfi\n\nappend_descendants \"$SESSION_PID\"\nemit \"action=start session_pid=$SESSION_PID descendants=${#descendants[@]}\"\n\nif [ \"${#descendants[@]}\" -gt 0 ]; then\n  for pid in \"${descendants[@]}\"; do\n    cmd=\"$(ps -p \"$pid\" -o command= 2>/dev/null || true)\"\n    [ -n \"$cmd\" ] || continue\n    if is_target_command \"$cmd\"; then\n      if ! is_descendant_of_session \"$pid\"; then\n        emit \"action=skip-kill reason=ancestry-not-confirmed pid=$pid matched_by=name ancestor_ok=no command=$cmd\"\n        continue\n      fi\n      emit \"action=kill signal=TERM pid=$pid matched_by=name ancestor_ok=yes command=$cmd\"\n      if ! kill -15 \"$pid\" 2>/dev/null; then\n        emit \"action=kill-failed signal=TERM pid=$pid\"\n        EXIT_CODE=1\n      fi\n    fi\n  done\nfi\n\nemit \"action=summary session_pid=$SESSION_PID exit_code=$EXIT_CODE\"\nexit \"$EXIT_CODE\"","lineStart":1,"lineEnd":152,"totalLines":152,"truncated":false}},"title":".opencode/scripts/session-cleanup.sh","time":{"start":1780907816043,"end":1780907816053}},"metadata":{"openai":{"itemId":"fc_0496853919e9ef02016a267f27c69481919307e8721c60699e"}},"id":"prt_ea660b469001mChS4jQGZeyWzU","sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","messageID":"msg_ea6608043001bRKh2O65UAKOye"}}
{"type":"tool_use","timestamp":1780907816066,"sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","part":{"type":"tool","tool":"read","callID":"call_xiXSh28jomgd5A5NfoH8dYMM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","offset":1,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs</path>\n<type>file</type>\n<content>\n1: // [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n2: 'use strict';\n3: \n4: const net = require('net');\n5: const { StringDecoder } = require('string_decoder');\n6: const {\n7:   probeDaemon,\n8:   toConnectionOptions,\n9: } = require('./launcher-ipc-bridge.cjs');\n10: \n11: const PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\n12: const DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n13: // Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n14: // seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n15: // daemon answers the deep probe within the first few attempts; the only thing this shortens is\n16: // the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\n17: const DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\n18: const INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\n19: const DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\n20: const DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;\n21: const DEFAULT_MAX_QUEUED_CLIENT_FRAMES = 1000;\n22: const PROXY_PRIVATE_ID_PREFIX = '__launcher_session_proxy_keepalive__';\n23: const RETRYABLE_RECYCLE_ERROR = Object.freeze({\n24:   code: -32001,\n25:   message: 'backend recycled; retry',\n26:   data: { retryable: true },\n27: });\n28: const PROTOCOL_MISMATCH_ERROR = Object.freeze({\n29:   code: -32002,\n30:   message: 'backend protocol version changed; client reconnect required',\n31:   data: { retryable: false },\n32: });\n33: const REPLAYABLE_TOOL_NAMES = new Set([\n34:   'memory_search',\n35:   'memory_context',\n36:   'memory_match_triggers',\n37:   'memory_quick_search',\n38:   'memory_save',\n39:   'session_bootstrap',\n40:   'session_health',\n41:   'session_resume',\n42:   'session_status',\n43:   'memory_stats',\n44:   'memory_status',\n45:   'checkpoint_list',\n46:   'embedder_health',\n47: ]);\n48: const UNSAFE_TOOL_NAMES = new Set([\n49:   'memory_delete',\n50:   'memory_bulk_delete',\n51:   'memory_update',\n52:   'checkpoint_restore',\n53:   'checkpoint_delete',\n54:   'embedder_set',\n55:   'memory_retention_sweep',\n56:   'memory_ingest_start',\n57:   'memory_ingest_cancel',\n58: ]);\n59: const REPLAYABLE_PROTOCOL_METHODS = new Set([\n60:   'initialize',\n61:   'ping',\n62: ]);\n63: \n64: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n65: \n66: function defaultConnect(connectionOptions) {\n67:   return net.createConnection(connectionOptions);\n68: }\n69: \n70: function defaultLog(message) {\n71:   process.stderr.write(`[launcher-session-proxy] ${message}\\n`);\n72: }\n73: \n74: function createFrameSplitter(onFrame) {\n75:   let buffer = '';\n76:   // A multibyte UTF-8 char (CJK/emoji) can straddle a socket-chunk boundary; the\n77:   // StringDecoder holds the incomplete tail until the next chunk completes it, instead\n78:   // of emitting U+FFFD replacement chars on the partial sequence.\n79:   const decoder = new StringDecoder('utf8');\n80:   return {\n81:     push(chunk) {\n82:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n83:       let newlineIndex = buffer.indexOf('\\n');\n84:       while (newlineIndex !== -1) {\n85:         const frame = buffer.slice(0, newlineIndex);\n86:         buffer = buffer.slice(newlineIndex + 1);\n87:         newlineIndex = buffer.indexOf('\\n');\n88:         if (frame.trim().length === 0) continue;\n89:         onFrame(frame);\n90:       }\n91:     },\n92:     discard() {\n93:       buffer = '';\n94:       decoder.end();\n95:     },\n96:     buffered() {\n97:       return buffer;\n98:     },\n99:   };\n100: }\n101: \n102: function parseFrame(frame) {\n103:   try {\n104:     const parsed = JSON.parse(String(frame).trim());\n105:     return parsed && typeof parsed === 'object' ? parsed : null;\n106:   } catch {\n107:     return null;\n108:   }\n109: }\n110: \n111: function hasOwn(object, key) {\n112:   return Object.prototype.hasOwnProperty.call(object, key);\n113: }\n114: \n115: function hasRequestId(parsed) {\n116:   return parsed !== null && hasOwn(parsed, 'id');\n117: }\n118: \n119: function isResponseFrame(parsed) {\n120:   return hasRequestId(parsed) && (hasOwn(parsed, 'result') || hasOwn(parsed, 'error'));\n121: }\n122: \n123: // Build a frame classifier for a given replayable/unsafe tool set. The protocol-method rules\n124: // (initialize/ping/notifications) and the parse/unsafe/replayable order are identical across MCP\n125: // servers; only the tools/call replayability set differs per server (memory tools vs code-graph\n126: // tools). Each launcher passes its own sets so the reattach/replay machinery stays one implementation.\n127: function createClassifyFrame(options = {}) {\n128:   const replayable = options.replayableToolNames instanceof Set ? options.replayableToolNames : REPLAYABLE_TOOL_NAMES;\n129:   const unsafe = options.unsafeToolNames instanceof Set ? options.unsafeToolNames : UNSAFE_TOOL_NAMES;\n130:   return function classify(frame) {\n131:     const parsed = typeof frame === 'string' ? parseFrame(frame) : frame;\n132:     if (!parsed || typeof parsed.method !== 'string') return false;\n133:     if (parsed.method !== 'tools/call') {\n134:       return REPLAYABLE_PROTOCOL_METHODS.has(parsed.method) || parsed.method.startsWith('notifications/');\n135:     }\n136:     const toolName = parsed.params && typeof parsed.params === 'object'\n137:       ? parsed.params.name\n138:       : undefined;\n139:     if (typeof toolName !== 'string') return false;\n140:     if (unsafe.has(toolName)) return false;\n141:     if (replayable.has(toolName)) return true;\n142:     return false;\n143:   };\n144: }\n145: \n146: // Default classifier uses the mk-spec-memory tool sets. memory_save is replayable on a\n147: // commit-then-die backend because its primary row is protected by content-hash dedup AND the v28\n148: // active-row partial unique index (idx_memory_logical_key_active_unique): an identical-content replay\n149: // collapses to the same logical key and writes no new primary row. The KNOWN GAP is the secondary\n150: // index — a commit-then-die that finished the primary insert but not the secondary-index write can,\n151: // on replay, append duplicate secondary-index rows because that path is not yet keyed by an\n152: // idempotency token. Closing it requires a request-id/dedup key threaded into the save handler, which\n153: // lives behind the daemon IPC and is out of scope for this proxy-layer frame classifier.\n154: const classifyFrame = createClassifyFrame();\n155: \n156: function createPendingRequestsTracker(classify = classifyFrame) {\n157:   const pendingRequests = new Map();\n158:   let cachedInitialize = null;\n159:   let cachedInitializeId = null;\n160:   let negotiatedProtocolVersion = null;\n161:   let protocolVersionObserved = false;\n162: \n163:   function handleClientFrame(frame) {\n164:     const parsed = parseFrame(frame);\n165:     if (!parsed) return;\n166:     if (parsed.method === 'initialize') {\n167:       cachedInitialize = frame;\n168:       cachedInitializeId = hasRequestId(parsed) ? parsed.id : null;\n169:     }\n170:     if (!hasRequestId(parsed)) return;\n171:     pendingRequests.set(parsed.id, {\n172:       frame,\n173:       replayable: classify(frame),\n174:     });\n175:   }\n176: \n177:   function handleBackendFrame(frame) {\n178:     const parsed = parseFrame(frame);\n179:     if (!parsed || !isResponseFrame(parsed)) return;\n180:     pendingRequests.delete(parsed.id);\n181:   }\n182: \n183:   return {\n184:     pendingRequests,\n185:     handleClientFrame,\n186:     handleBackendFrame,\n187:     getCachedInitialize() {\n188:       return cachedInitialize;\n189:     },\n190:     getCachedInitializeId() {\n191:       return cachedInitializeId;\n192:     },\n193:     getNegotiatedProtocolVersion() {\n194:       return negotiatedProtocolVersion;\n195:     },\n196:     hasObservedProtocolVersion() {\n197:       return protocolVersionObserved;\n198:     },\n199:     recordNegotiatedProtocolVersion(version) {\n200:       if (protocolVersionObserved) return;\n201:       protocolVersionObserved = true;\n202:       negotiatedProtocolVersion = typeof version === 'string' ? version : null;\n203:     },\n204:   };\n205: }\n206: \n207: function resolveColdStartAttempts() {\n208:   const fromEnv = Number.parseInt(process.env.SPECKIT_PROXY_COLD_START_ATTEMPTS ?? '', 10);\n209:   return Number.isInteger(fromEnv) && fromEnv > 0 ? fromEnv : DEFAULT_MAX_COLD_START_ATTEMPTS;\n210: }\n211: \n212: async function waitForDaemonReady(socketPath, probe, connect, log, options = {}) {\n213:   const maxAttempts = Number.isInteger(options.maxAttempts) && options.maxAttempts > 0\n214:     ? options.maxAttempts\n215:     : Infinity;\n216:   for (let attempt = 0; attempt < maxAttempts; attempt += 1) {\n217:     const result = await probe(socketPath, { connect, deepProbe: true });\n218:     if (result.status === 'alive') return result;\n219:     if (attempt + 1 >= maxAttempts) return result;\n220:     const delayMs = PROBE_BACKOFF_MS[Math.min(attempt, PROBE_BACKOFF_MS.length - 1)];\n221:     log(`daemon socket not ready (${result.reason}); retrying in ${delayMs}ms`);\n222:     await sleep(delayMs);\n223:   }\n224:   return { status: 'dead', reason: 'reattach-attempts-exhausted' };\n225: }\n226: \n227: function writeFrame(stream, frame) {\n228:   return stream.write(`${frame}\\n`);\n229: }\n230: \n231: function retryableErrorFrame(id) {\n232:   return JSON.stringify({\n233:     jsonrpc: '2.0',\n234:     id,\n235:     error: RETRYABLE_RECYCLE_ERROR,\n236:   });\n237: }\n238: \n239: function protocolMismatchErrorFrame(id) {\n240:   return JSON.stringify({\n241:     jsonrpc: '2.0',\n242:     id,\n243:     error: PROTOCOL_MISMATCH_ERROR,\n244:   });\n245: }\n246: \n247: function connectSocket(connect, socketPath) {\n248:   return new Promise((resolve, reject) => {\n249:     let socket;\n250:     try {\n251:       socket = connect(toConnectionOptions(socketPath));\n252:     } catch (error) {\n253:       reject(error);\n254:       return;\n255:     }\n256: \n257:     const cleanup = () => {\n258:       socket.off?.('connect', onConnect);\n259:       socket.off?.('error', onError);\n260:     };\n261:     const onConnect = () => {\n262:       cleanup();\n263:       resolve(socket);\n264:     };\n265:     const onError = (error) => {\n266:       cleanup();\n267:       socket.destroy?.();\n268:       reject(error);\n269:     };\n270: \n271:     socket.once('connect', onConnect);\n272:     socket.once('error', onError);\n273:   });\n274: }\n275: \n276: function internalHandshake(socket, initializeFrame) {\n277:   if (!initializeFrame) return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n278: \n279:   const initialize = parseFrame(initializeFrame);\n280:   if (!initialize || !hasRequestId(initialize)) {\n281:     return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n282:   }\n283: \n284:   return new Promise((resolve, reject) => {\n285:     let buffer = '';\n286:     let residual = '';\n287:     let negotiatedVersion;\n288:     let initializeResponse = null;\n289:     // Hold a multibyte char split across chunk boundaries until complete, so a CJK/emoji\n290:     // payload in the residual (post-handshake) stream is not corrupted to U+FFFD.\n291:     const decoder = new StringDecoder('utf8');\n292:     const timer = setTimeout(() => {\n293:       cleanup();\n294:       reject(new Error('timed out waiting for internal initialize'));\n295:     }, INTERNAL_HANDSHAKE_TIMEOUT_MS);\n296:     timer.unref?.();\n297:     const cleanup = () => {\n298:       clearTimeout(timer);\n299:       socket.off?.('data', onData);\n300:       socket.off?.('error', onError);\n301:       socket.off?.('close', onClose);\n302:     };\n303:     const onData = (chunk) => {\n304:       buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n305:       let initialized = false;\n306:       let newlineIndex = buffer.indexOf('\\n');\n307:       while (newlineIndex !== -1) {\n308:         const frame = buffer.slice(0, newlineIndex);\n309:         buffer = buffer.slice(newlineIndex + 1);\n310:         newlineIndex = buffer.indexOf('\\n');\n311:         if (frame.trim().length === 0) continue;\n312:         const parsed = parseFrame(frame);\n313:         if (parsed && isResponseFrame(parsed) && parsed.id === initialize.id) {\n314:           initialized = true;\n315:           initializeResponse = frame;\n316:           negotiatedVersion = parsed.result && typeof parsed.result === 'object'\n317:             ? parsed.result.protocolVersion\n318:             : undefined;\n319:           continue;\n320:         }\n321:         residual += `${frame}\\n`;\n322:       }\n323:       if (!initialized) return;\n324:       const remainder = residual + buffer;\n325:       buffer = '';\n326:       residual = '';\n327:       cleanup();\n328:       resolve({ residual: remainder, protocolVersion: negotiatedVersion, handshakeObserved: true, initializeResponse });\n329:     };\n330:     const onError = (error) => {\n331:       cleanup();\n332:       reject(error);\n333:     };\n334:     const onClose = () => {\n335:       cleanup();\n336:       reject(new Error('socket closed during internal initialize'));\n337:     };\n338: \n339:     socket.on('data', onData);\n340:     socket.once('error', onError);\n341:     socket.once('close', onClose);\n342:     writeFrame(socket, initializeFrame);\n343:   });\n344: }\n345: \n346: function createSessionProxy(options) {\n347:   const socketPath = options?.socketPath;\n348:   const input = options?.stdin ?? process.stdin;\n349:   const output = options?.stdout ?? process.stdout;\n350:   const probe = options?.probe ?? probeDaemon;\n351:   const connect = options?.connect ?? defaultConnect;\n352:   const log = options?.log ?? defaultLog;\n353:   const classify = options?.classify ?? classifyFrame;\n354:   const maxReattachAttempts = Number.isInteger(options?.maxReattachAttempts) && options.maxReattachAttempts > 0\n355:     ? options.maxReattachAttempts\n356:     : DEFAULT_MAX_REATTACH_ATTEMPTS;\n357:   const maxColdStartAttempts = Number.isInteger(options?.maxColdStartAttempts) && options.maxColdStartAttempts > 0\n358:     ? options.maxColdStartAttempts\n359:     : resolveColdStartAttempts();\n360:   const keepaliveIntervalMs = Number.isInteger(options?.keepaliveIntervalMs) && options.keepaliveIntervalMs > 0\n361:     ? options.keepaliveIntervalMs\n362:     : DEFAULT_KEEPALIVE_INTERVAL_MS;\n363:   const keepaliveTimeoutMs = Number.isInteger(options?.keepaliveTimeoutMs) && options.keepaliveTimeoutMs > 0\n364:     ? options.keepaliveTimeoutMs\n365:     : DEFAULT_KEEPALIVE_TIMEOUT_MS;\n366:   const maxQueuedClientFrames = Number.isInteger(options?.maxQueuedClientFrames) && options.maxQueuedClientFrames > 0\n367:     ? options.maxQueuedClientFrames\n368:     : DEFAULT_MAX_QUEUED_CLIENT_FRAMES;\n369: \n370:   let socket = null;\n371:   let state = 'REATTACHING';\n372:   let stopped = false;\n373:   let clientEnded = false;\n374:   let reattachRunning = false;\n375:   let backendSplitter = createFrameSplitter(handleBackendFrame);\n376:   let keepaliveInterval = null;\n377:   let keepaliveTimer = null;\n378:   let keepaliveId = 0;\n379:   let pendingKeepaliveId = null;\n380:   let lastBackendActivity = Date.now();\n381:   let socketDrainWaiting = false;\n382:   let outputDrainWaiting = false;\n383:   let outputEndRequested = false;\n384:   const queuedClientFrames = [];\n385:   const socketWriteQueue = [];\n386:   const outputWriteQueue = [];\n387:   const tracker = createPendingRequestsTracker(classify);\n388:   const clientSplitter = createFrameSplitter(handleClientFrame);\n389: \n390:   if (typeof socketPath !== 'string' || socketPath.length === 0) {\n391:     throw new Error('createSessionProxy requires a non-empty socketPath');\n392:   }\n393: \n394:   function pauseClientInput() {\n395:     input.pause?.();\n396:   }\n397: \n398:   function resumeClientInputIfReady() {\n399:     if (!clientEnded && !stopped && state === 'CONNECTED') input.resume?.();\n400:   }\n401: \n402:   function stopKeepalive() {\n403:     if (keepaliveInterval !== null) {\n404:       clearInterval(keepaliveInterval);\n405:       keepaliveInterval = null;\n406:     }\n407:     if (keepaliveTimer !== null) {\n408:       clearTimeout(keepaliveTimer);\n409:       keepaliveTimer = null;\n410:     }\n411:     pendingKeepaliveId = null;\n412:   }\n413: \n414:   function detachSocket(destroy = true) {\n415:     stopKeepalive();\n416:     if (!socket) return;\n417:     const oldSocket = socket;\n418:     socket = null;\n419:     // The backpressure 'drain' wait was bound to this now-discarded socket and its\n420:     // handler short-circuits once the socket is swapped, so it can never reset the\n421:     // flag. Clear it here (and drop the listener) or the next socket's pump stays\n422:     // blocked forever — a silent hang when backpressure coincides with a recycle.\n423:     socketDrainWaiting = false;\n424:     oldSocket.removeAllListeners?.('data');\n425:     oldSocket.removeAllListeners?.('error');\n426:     oldSocket.removeAllListeners?.('close');\n427:     oldSocket.removeAllListeners?.('drain');\n428:     if (destroy) oldSocket.destroy?.();\n429:   }\n430: \n431:   function stop() {\n432:     if (stopped) return;\n433:     stopped = true;\n434:     input.off?.('data', onInputData);\n435:     input.off?.('end', onInputEnd);\n436:     input.off?.('close', onInputClose);\n437:     output.off?.('error', onOutputError);\n438:     detachSocket(true);\n439:   }\n440: \n441:   function pumpOutputQueue() {\n442:     if (outputDrainWaiting) return;\n443:     while (outputWriteQueue.length > 0) {\n444:       const frame = outputWriteQueue[0];\n445:       const accepted = writeFrame(output, frame);\n446:       outputWriteQueue.shift();\n447:       if (!accepted) {\n448:         outputDrainWaiting = true;\n449:         socket?.pause?.();\n450:         output.once?.('drain', () => {\n451:           outputDrainWaiting = false;\n452:           socket?.resume?.();\n453:           pumpOutputQueue();\n454:         });\n455:         return;\n456:       }\n457:     }\n458:     if (outputEndRequested) {\n459:       output.end?.();\n460:       stop();\n461:     }\n462:   }\n463: \n464:   function enqueueOutputFrame(frame) {\n465:     outputWriteQueue.push(frame);\n466:     pumpOutputQueue();\n467:   }\n468: \n469:   function requestOutputEnd() {\n470:     outputEndRequested = true;\n471:     pumpOutputQueue();\n472:   }\n473: \n474:   function failPendingAndEndWith(makeErrorFrame) {\n475:     const failedIds = new Set();\n476:     for (const id of tracker.pendingRequests.keys()) {\n477:       failedIds.add(JSON.stringify(id));\n478:       enqueueOutputFrame(makeErrorFrame(id));\n479:     }\n480:     tracker.pendingRequests.clear();\n481:     while (queuedClientFrames.length > 0) {\n482:       const frame = queuedClientFrames.shift();\n483:       const parsed = parseFrame(frame);\n484:       if (!hasRequestId(parsed)) continue;\n485:       const key = JSON.stringify(parsed.id);\n486:       if (failedIds.has(key)) continue;\n487:       failedIds.add(key);\n488:       enqueueOutputFrame(makeErrorFrame(parsed.id));\n489:     }\n490:     requestOutputEnd();\n491:   }\n492: \n493:   function failPendingAndEnd() {\n494:     failPendingAndEndWith(retryableErrorFrame);\n495:   }\n496: \n497:   function failPendingAndEndProtocolMismatch() {\n498:     failPendingAndEndWith(protocolMismatchErrorFrame);\n499:   }\n500: \n501:   function failOldestQueuedClientFrame() {\n502:     while (queuedClientFrames.length > maxQueuedClientFrames) {\n503:       const frame = queuedClientFrames.shift();\n504:       const parsed = parseFrame(frame);\n505:       if (hasRequestId(parsed)) {\n506:         enqueueOutputFrame(retryableErrorFrame(parsed.id));\n507:         tracker.pendingRequests.delete(parsed.id);\n508:       }\n509:     }\n510:   }\n511: \n512:   function queueClientFrame(frame) {\n513:     queuedClientFrames.push(frame);\n514:     failOldestQueuedClientFrame();\n515:   }\n516: \n517:   function pumpSocketQueue() {\n518:     if (!socket || state !== 'CONNECTED' || socketDrainWaiting) return;\n519:     while (socketWriteQueue.length > 0 && socket && state === 'CONNECTED') {\n520:       const activeSocket = socket;\n521:       const frame = socketWriteQueue[0];\n522:       const accepted = writeFrame(activeSocket, frame);\n523:       socketWriteQueue.shift();\n524:       if (!accepted) {\n525:         socketDrainWaiting = true;\n526:         pauseClientInput();\n527:         activeSocket.once?.('drain', () => {\n528:           if (activeSocket !== socket) return;\n529:           socketDrainWaiting = false;\n530:           resumeClientInputIfReady();\n531:           pumpSocketQueue();\n532:         });\n533:         return;\n534:       }\n535:     }\n536:     resumeClientInputIfReady();\n537:   }\n538: \n539:   function enqueueSocketFrame(frame) {\n540:     socketWriteQueue.push(frame);\n541:     pumpSocketQueue();\n542:   }\n543: \n544:   function sendKeepalive() {\n545:     if (!socket || state !== 'CONNECTED' || pendingKeepaliveId !== null) return;\n546:     if (Date.now() - lastBackendActivity < keepaliveIntervalMs) return;\n547:     pendingKeepaliveId = `${PROXY_PRIVATE_ID_PREFIX}${keepaliveId += 1}`;\n548:     enqueueSocketFrame(JSON.stringify({ jsonrpc: '2.0', id: pendingKeepaliveId, method: 'ping' }));\n549:     keepaliveTimer = setTimeout(() => {\n550:       keepaliveTimer = null;\n551:       if (pendingKeepaliveId === null) return;\n552:       pendingKeepaliveId = null;\n553:       handleBackendFailure('keepalive-timeout');\n554:     }, keepaliveTimeoutMs);\n555:     keepaliveTimer.unref?.();\n556:   }\n557: \n558:   function startKeepalive() {\n559:     stopKeepalive();\n560:     lastBackendActivity = Date.now();\n561:     keepaliveInterval = setInterval(sendKeepalive, keepaliveIntervalMs);\n562:     keepaliveInterval.unref?.();\n563:   }\n564: \n565:   function forwardClientFrame(frame) {\n566:     tracker.handleClientFrame(frame);\n567:     if (!socket || state !== 'CONNECTED') {\n568:       queueClientFrame(frame);\n569:       return;\n570:     }\n571:     enqueueSocketFrame(frame);\n572:   }\n573: \n574:   function flushQueuedClientFrames() {\n575:     while (queuedClientFrames.length > 0 && socket && state === 'CONNECTED') {\n576:       forwardClientFrame(queuedClientFrames.shift());\n577:     }\n578:   }\n579: \n580:   function handleClientFrame(frame) {\n581:     const parsedClient = parseFrame(frame);\n582:     if (parsedClient\n583:         && parsedClient.method !== undefined\n584:         && typeof parsedClient.id === 'string'\n585:         && parsedClient.id.startsWith(PROXY_PRIVATE_ID_PREFIX)) {\n586:       // This id prefix is reserved for the proxy's private keepalive pings. A\n587:       // client request carrying a colliding id would have its backend response\n588:       // silently swallowed by the keepalive interceptor in handleBackendFrame,\n589:       // hanging the request. Reject the reserved id rather than forward it.\n590:       enqueueOutputFrame(JSON.stringify({\n591:         jsonrpc: '2.0',\n592:         id: parsedClient.id,\n593:         error: { code: -32600, message: 'Request id uses a reserved prefix' },\n594:       }));\n595:       return;\n596:     }\n597:     if (state !== 'CONNECTED' || !socket) {\n598:       queueClientFrame(frame);\n599:       return;\n600:     }\n601:     forwardClientFrame(frame);\n602:   }\n603: \n604:   function handleBackendFrame(frame) {\n605:     lastBackendActivity = Date.now();\n606:     const parsed = parseFrame(frame);\n607:     if (pendingKeepaliveId !== null && isResponseFrame(parsed) && parsed.id === pendingKeepaliveId) {\n608:       pendingKeepaliveId = null;\n609:       if (keepaliveTimer !== null) {\n610:         clearTimeout(keepaliveTimer);\n611:         keepaliveTimer = null;\n612:       }\n613:       return;\n614:     }\n615:     const cachedInitializeId = tracker.getCachedInitializeId();\n616:     if (!tracker.hasObservedProtocolVersion()\n617:         && cachedInitializeId !== null\n618:         && isResponseFrame(parsed)\n619:         && parsed.id === cachedInitializeId) {\n620:       // Record the protocol version negotiated on the first initialize so an internal\n621:       // re-handshake to a swapped backend can fail closed on a version change rather\n622:       // than silently serve the client a protocol it never negotiated.\n623:       tracker.recordNegotiatedProtocolVersion(\n624:         parsed.result && typeof parsed.result === 'object' ? parsed.result.protocolVersion : undefined,\n625:       );\n626:     }\n627:     tracker.handleBackendFrame(frame);\n628:     enqueueOutputFrame(frame);\n629:   }\n630: \n631:   function replaySnapshot(snapshot) {\n632:     const cachedInitializeId = tracker.getCachedInitializeId();\n633:     for (const [id, entry] of snapshot) {\n634:       if (!tracker.pendingRequests.has(id)) continue;\n635:       // internalHandshake already re-sent (and consumed the reply for) the cached\n636:       // initialize on the fresh socket. Replaying it here too would deliver a second\n637:       // initialize to the backend, so the handshake path owns the initialize replay.\n638:       if (cachedInitializeId !== null && id === cachedInitializeId) continue;\n639:       if (entry.replayable) {\n640:         enqueueSocketFrame(entry.frame);\n641:         continue;\n642:       }\n643:       enqueueOutputFrame(retryableErrorFrame(id));\n644:       tracker.pendingRequests.delete(id);\n645:     }\n646:   }\n647: \n648:   async function attachFreshSocket({ replaySnapshotEntries = [] } = {}) {\n649:     const freshSocket = await connectSocket(connect, socketPath);\n650:     const handshake = await internalHandshake(freshSocket, tracker.getCachedInitialize());\n651:     const expectedProtocolVersion = tracker.getNegotiatedProtocolVersion();\n652:     if (handshake.handshakeObserved\n653:         && expectedProtocolVersion !== null\n654:         && (handshake.protocolVersion ?? null) !== expectedProtocolVersion) {\n655:       // A backend build swap can re-handshake with a different negotiated protocol\n656:       // version. Serving it would silently break the client's protocol contract, so\n657:       // end the session with a non-retryable error instead of attaching the socket.\n658:       // CLOSED is terminal: the reattach loop must not retry a version-mismatched backend.\n659:       log(`backend protocol version drift: expected ${expectedProtocolVersion}, got ${handshake.protocolVersion ?? 'none'}; failing closed`);\n660:       freshSocket.destroy?.();\n661:       state = 'CLOSED';\n662:       failPendingAndEndProtocolMismatch();\n663:       return;\n664:     }\n665:     socket = freshSocket;\n666:     backendSplitter = createFrameSplitter(handleBackendFrame);\n667:     if (handshake.residual.length > 0) backendSplitter.push(handshake.residual);\n668:     socket.on('data', (chunk) => backendSplitter.push(chunk));\n669:     socket.once('error', (error) => {\n670:       log(`socket proxy error: ${error instanceof Error ? error.message : String(error)}`);\n671:       handleBackendFailure('error');\n672:     });\n673:     socket.once('close', () => {\n674:       handleBackendFailure('close');\n675:     });\n676:     state = 'CONNECTED';\n677:     startKeepalive();\n678:     // The fresh backend may have died after receiving the client's initialize but before\n679:     // answering it on the old socket, leaving initialize pending. internalHandshake just\n680:     // re-sent and answered it; forward that single answer to the client and clear it from\n681:     // pending so replaySnapshot does not send a duplicate initialize to the backend.\n682:     const cachedInitializeId = tracker.getCachedInitializeId();\n683:     if (handshake.handshakeObserved\n684:         && handshake.initializeResponse\n685:         && cachedInitializeId !== null\n686:         && tracker.pendingRequests.has(cachedInitializeId)) {\n687:       tracker.pendingRequests.delete(cachedInitializeId);\n688:       enqueueOutputFrame(handshake.initializeResponse);\n689:     }\n690:     replaySnapshot(replaySnapshotEntries);\n691:     flushQueuedClientFrames();\n692:     pumpSocketQueue();\n693:     if (clientEnded) {\n694:       socket?.end?.();\n695:       stop();\n696:       return;\n697:     }\n698:     resumeClientInputIfReady();\n699:   }\n700: \n\n(Showing lines 1-700 of 823. Use offset=701 to continue.)\n</content>","metadata":{"preview":"// [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n'use strict';\n\nconst net = require('net');\nconst { StringDecoder } = require('string_decoder');\nconst {\n  probeDaemon,\n  toConnectionOptions,\n} = require('./launcher-ipc-bridge.cjs');\n\nconst PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\nconst DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n// Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n// seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n// daemon answers the deep probe within the first few attempts; the only thing this shortens is\n// the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\nconst DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\nconst INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\nconst DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\nconst DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","text":"// [launcher-session-proxy] Launcher-owned MCP stdin/stdout bridge over daemon IPC.\n'use strict';\n\nconst net = require('net');\nconst { StringDecoder } = require('string_decoder');\nconst {\n  probeDaemon,\n  toConnectionOptions,\n} = require('./launcher-ipc-bridge.cjs');\n\nconst PROBE_BACKOFF_MS = [100, 250, 500, 1000, 1500];\nconst DEFAULT_MAX_REATTACH_ATTEMPTS = 40;\n// Bounded so a dead/booting daemon surfaces a retryable -32001 to the client in ~tens of\n// seconds (~41s with the backoff ladder) instead of ~176s of silent \"connecting…\". A healthy\n// daemon answers the deep probe within the first few attempts; the only thing this shortens is\n// the pathological wait when the backend cannot come up. Tunable via SPECKIT_PROXY_COLD_START_ATTEMPTS.\nconst DEFAULT_MAX_COLD_START_ATTEMPTS = 30;\nconst INTERNAL_HANDSHAKE_TIMEOUT_MS = 7000;\nconst DEFAULT_KEEPALIVE_INTERVAL_MS = 10_000;\nconst DEFAULT_KEEPALIVE_TIMEOUT_MS = 5_000;\nconst DEFAULT_MAX_QUEUED_CLIENT_FRAMES = 1000;\nconst PROXY_PRIVATE_ID_PREFIX = '__launcher_session_proxy_keepalive__';\nconst RETRYABLE_RECYCLE_ERROR = Object.freeze({\n  code: -32001,\n  message: 'backend recycled; retry',\n  data: { retryable: true },\n});\nconst PROTOCOL_MISMATCH_ERROR = Object.freeze({\n  code: -32002,\n  message: 'backend protocol version changed; client reconnect required',\n  data: { retryable: false },\n});\nconst REPLAYABLE_TOOL_NAMES = new Set([\n  'memory_search',\n  'memory_context',\n  'memory_match_triggers',\n  'memory_quick_search',\n  'memory_save',\n  'session_bootstrap',\n  'session_health',\n  'session_resume',\n  'session_status',\n  'memory_stats',\n  'memory_status',\n  'checkpoint_list',\n  'embedder_health',\n]);\nconst UNSAFE_TOOL_NAMES = new Set([\n  'memory_delete',\n  'memory_bulk_delete',\n  'memory_update',\n  'checkpoint_restore',\n  'checkpoint_delete',\n  'embedder_set',\n  'memory_retention_sweep',\n  'memory_ingest_start',\n  'memory_ingest_cancel',\n]);\nconst REPLAYABLE_PROTOCOL_METHODS = new Set([\n  'initialize',\n  'ping',\n]);\n\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nfunction defaultConnect(connectionOptions) {\n  return net.createConnection(connectionOptions);\n}\n\nfunction defaultLog(message) {\n  process.stderr.write(`[launcher-session-proxy] ${message}\\n`);\n}\n\nfunction createFrameSplitter(onFrame) {\n  let buffer = '';\n  // A multibyte UTF-8 char (CJK/emoji) can straddle a socket-chunk boundary; the\n  // StringDecoder holds the incomplete tail until the next chunk completes it, instead\n  // of emitting U+FFFD replacement chars on the partial sequence.\n  const decoder = new StringDecoder('utf8');\n  return {\n    push(chunk) {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const frame = buffer.slice(0, newlineIndex);\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (frame.trim().length === 0) continue;\n        onFrame(frame);\n      }\n    },\n    discard() {\n      buffer = '';\n      decoder.end();\n    },\n    buffered() {\n      return buffer;\n    },\n  };\n}\n\nfunction parseFrame(frame) {\n  try {\n    const parsed = JSON.parse(String(frame).trim());\n    return parsed && typeof parsed === 'object' ? parsed : null;\n  } catch {\n    return null;\n  }\n}\n\nfunction hasOwn(object, key) {\n  return Object.prototype.hasOwnProperty.call(object, key);\n}\n\nfunction hasRequestId(parsed) {\n  return parsed !== null && hasOwn(parsed, 'id');\n}\n\nfunction isResponseFrame(parsed) {\n  return hasRequestId(parsed) && (hasOwn(parsed, 'result') || hasOwn(parsed, 'error'));\n}\n\n// Build a frame classifier for a given replayable/unsafe tool set. The protocol-method rules\n// (initialize/ping/notifications) and the parse/unsafe/replayable order are identical across MCP\n// servers; only the tools/call replayability set differs per server (memory tools vs code-graph\n// tools). Each launcher passes its own sets so the reattach/replay machinery stays one implementation.\nfunction createClassifyFrame(options = {}) {\n  const replayable = options.replayableToolNames instanceof Set ? options.replayableToolNames : REPLAYABLE_TOOL_NAMES;\n  const unsafe = options.unsafeToolNames instanceof Set ? options.unsafeToolNames : UNSAFE_TOOL_NAMES;\n  return function classify(frame) {\n    const parsed = typeof frame === 'string' ? parseFrame(frame) : frame;\n    if (!parsed || typeof parsed.method !== 'string') return false;\n    if (parsed.method !== 'tools/call') {\n      return REPLAYABLE_PROTOCOL_METHODS.has(parsed.method) || parsed.method.startsWith('notifications/');\n    }\n    const toolName = parsed.params && typeof parsed.params === 'object'\n      ? parsed.params.name\n      : undefined;\n    if (typeof toolName !== 'string') return false;\n    if (unsafe.has(toolName)) return false;\n    if (replayable.has(toolName)) return true;\n    return false;\n  };\n}\n\n// Default classifier uses the mk-spec-memory tool sets. memory_save is replayable on a\n// commit-then-die backend because its primary row is protected by content-hash dedup AND the v28\n// active-row partial unique index (idx_memory_logical_key_active_unique): an identical-content replay\n// collapses to the same logical key and writes no new primary row. The KNOWN GAP is the secondary\n// index — a commit-then-die that finished the primary insert but not the secondary-index write can,\n// on replay, append duplicate secondary-index rows because that path is not yet keyed by an\n// idempotency token. Closing it requires a request-id/dedup key threaded into the save handler, which\n// lives behind the daemon IPC and is out of scope for this proxy-layer frame classifier.\nconst classifyFrame = createClassifyFrame();\n\nfunction createPendingRequestsTracker(classify = classifyFrame) {\n  const pendingRequests = new Map();\n  let cachedInitialize = null;\n  let cachedInitializeId = null;\n  let negotiatedProtocolVersion = null;\n  let protocolVersionObserved = false;\n\n  function handleClientFrame(frame) {\n    const parsed = parseFrame(frame);\n    if (!parsed) return;\n    if (parsed.method === 'initialize') {\n      cachedInitialize = frame;\n      cachedInitializeId = hasRequestId(parsed) ? parsed.id : null;\n    }\n    if (!hasRequestId(parsed)) return;\n    pendingRequests.set(parsed.id, {\n      frame,\n      replayable: classify(frame),\n    });\n  }\n\n  function handleBackendFrame(frame) {\n    const parsed = parseFrame(frame);\n    if (!parsed || !isResponseFrame(parsed)) return;\n    pendingRequests.delete(parsed.id);\n  }\n\n  return {\n    pendingRequests,\n    handleClientFrame,\n    handleBackendFrame,\n    getCachedInitialize() {\n      return cachedInitialize;\n    },\n    getCachedInitializeId() {\n      return cachedInitializeId;\n    },\n    getNegotiatedProtocolVersion() {\n      return negotiatedProtocolVersion;\n    },\n    hasObservedProtocolVersion() {\n      return protocolVersionObserved;\n    },\n    recordNegotiatedProtocolVersion(version) {\n      if (protocolVersionObserved) return;\n      protocolVersionObserved = true;\n      negotiatedProtocolVersion = typeof version === 'string' ? version : null;\n    },\n  };\n}\n\nfunction resolveColdStartAttempts() {\n  const fromEnv = Number.parseInt(process.env.SPECKIT_PROXY_COLD_START_ATTEMPTS ?? '', 10);\n  return Number.isInteger(fromEnv) && fromEnv > 0 ? fromEnv : DEFAULT_MAX_COLD_START_ATTEMPTS;\n}\n\nasync function waitForDaemonReady(socketPath, probe, connect, log, options = {}) {\n  const maxAttempts = Number.isInteger(options.maxAttempts) && options.maxAttempts > 0\n    ? options.maxAttempts\n    : Infinity;\n  for (let attempt = 0; attempt < maxAttempts; attempt += 1) {\n    const result = await probe(socketPath, { connect, deepProbe: true });\n    if (result.status === 'alive') return result;\n    if (attempt + 1 >= maxAttempts) return result;\n    const delayMs = PROBE_BACKOFF_MS[Math.min(attempt, PROBE_BACKOFF_MS.length - 1)];\n    log(`daemon socket not ready (${result.reason}); retrying in ${delayMs}ms`);\n    await sleep(delayMs);\n  }\n  return { status: 'dead', reason: 'reattach-attempts-exhausted' };\n}\n\nfunction writeFrame(stream, frame) {\n  return stream.write(`${frame}\\n`);\n}\n\nfunction retryableErrorFrame(id) {\n  return JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    error: RETRYABLE_RECYCLE_ERROR,\n  });\n}\n\nfunction protocolMismatchErrorFrame(id) {\n  return JSON.stringify({\n    jsonrpc: '2.0',\n    id,\n    error: PROTOCOL_MISMATCH_ERROR,\n  });\n}\n\nfunction connectSocket(connect, socketPath) {\n  return new Promise((resolve, reject) => {\n    let socket;\n    try {\n      socket = connect(toConnectionOptions(socketPath));\n    } catch (error) {\n      reject(error);\n      return;\n    }\n\n    const cleanup = () => {\n      socket.off?.('connect', onConnect);\n      socket.off?.('error', onError);\n    };\n    const onConnect = () => {\n      cleanup();\n      resolve(socket);\n    };\n    const onError = (error) => {\n      cleanup();\n      socket.destroy?.();\n      reject(error);\n    };\n\n    socket.once('connect', onConnect);\n    socket.once('error', onError);\n  });\n}\n\nfunction internalHandshake(socket, initializeFrame) {\n  if (!initializeFrame) return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n\n  const initialize = parseFrame(initializeFrame);\n  if (!initialize || !hasRequestId(initialize)) {\n    return Promise.resolve({ residual: '', protocolVersion: undefined, handshakeObserved: false, initializeResponse: null });\n  }\n\n  return new Promise((resolve, reject) => {\n    let buffer = '';\n    let residual = '';\n    let negotiatedVersion;\n    let initializeResponse = null;\n    // Hold a multibyte char split across chunk boundaries until complete, so a CJK/emoji\n    // payload in the residual (post-handshake) stream is not corrupted to U+FFFD.\n    const decoder = new StringDecoder('utf8');\n    const timer = setTimeout(() => {\n      cleanup();\n      reject(new Error('timed out waiting for internal initialize'));\n    }, INTERNAL_HANDSHAKE_TIMEOUT_MS);\n    timer.unref?.();\n    const cleanup = () => {\n      clearTimeout(timer);\n      socket.off?.('data', onData);\n      socket.off?.('error', onError);\n      socket.off?.('close', onClose);\n    };\n    const onData = (chunk) => {\n      buffer += Buffer.isBuffer(chunk) ? decoder.write(chunk) : String(chunk ?? '');\n      let initialized = false;\n      let newlineIndex = buffer.indexOf('\\n');\n      while (newlineIndex !== -1) {\n        const frame = buffer.slice(0, newlineIndex);\n        buffer = buffer.slice(newlineIndex + 1);\n        newlineIndex = buffer.indexOf('\\n');\n        if (frame.trim().length === 0) continue;\n        const parsed = parseFrame(frame);\n        if (parsed && isResponseFrame(parsed) && parsed.id === initialize.id) {\n          initialized = true;\n          initializeResponse = frame;\n          negotiatedVersion = parsed.result && typeof parsed.result === 'object'\n            ? parsed.result.protocolVersion\n            : undefined;\n          continue;\n        }\n        residual += `${frame}\\n`;\n      }\n      if (!initialized) return;\n      const remainder = residual + buffer;\n      buffer = '';\n      residual = '';\n      cleanup();\n      resolve({ residual: remainder, protocolVersion: negotiatedVersion, handshakeObserved: true, initializeResponse });\n    };\n    const onError = (error) => {\n      cleanup();\n      reject(error);\n    };\n    const onClose = () => {\n      cleanup();\n      reject(new Error('socket closed during internal initialize'));\n    };\n\n    socket.on('data', onData);\n    socket.once('error', onError);\n    socket.once('close', onClose);\n    writeFrame(socket, initializeFrame);\n  });\n}\n\nfunction createSessionProxy(options) {\n  const socketPath = options?.socketPath;\n  const input = options?.stdin ?? process.stdin;\n  const output = options?.stdout ?? process.stdout;\n  const probe = options?.probe ?? probeDaemon;\n  const connect = options?.connect ?? defaultConnect;\n  const log = options?.log ?? defaultLog;\n  const classify = options?.classify ?? classifyFrame;\n  const maxReattachAttempts = Number.isInteger(options?.maxReattachAttempts) && options.maxReattachAttempts > 0\n    ? options.maxReattachAttempts\n    : DEFAULT_MAX_REATTACH_ATTEMPTS;\n  const maxColdStartAttempts = Number.isInteger(options?.maxColdStartAttempts) && options.maxColdStartAttempts > 0\n    ? options.maxColdStartAttempts\n    : resolveColdStartAttempts();\n  const keepaliveIntervalMs = Number.isInteger(options?.keepaliveIntervalMs) && options.keepaliveIntervalMs > 0\n    ? options.keepaliveIntervalMs\n    : DEFAULT_KEEPALIVE_INTERVAL_MS;\n  const keepaliveTimeoutMs = Number.isInteger(options?.keepaliveTimeoutMs) && options.keepaliveTimeoutMs > 0\n    ? options.keepaliveTimeoutMs\n    : DEFAULT_KEEPALIVE_TIMEOUT_MS;\n  const maxQueuedClientFrames = Number.isInteger(options?.maxQueuedClientFrames) && options.maxQueuedClientFrames > 0\n    ? options.maxQueuedClientFrames\n    : DEFAULT_MAX_QUEUED_CLIENT_FRAMES;\n\n  let socket = null;\n  let state = 'REATTACHING';\n  let stopped = false;\n  let clientEnded = false;\n  let reattachRunning = false;\n  let backendSplitter = createFrameSplitter(handleBackendFrame);\n  let keepaliveInterval = null;\n  let keepaliveTimer = null;\n  let keepaliveId = 0;\n  let pendingKeepaliveId = null;\n  let lastBackendActivity = Date.now();\n  let socketDrainWaiting = false;\n  let outputDrainWaiting = false;\n  let outputEndRequested = false;\n  const queuedClientFrames = [];\n  const socketWriteQueue = [];\n  const outputWriteQueue = [];\n  const tracker = createPendingRequestsTracker(classify);\n  const clientSplitter = createFrameSplitter(handleClientFrame);\n\n  if (typeof socketPath !== 'string' || socketPath.length === 0) {\n    throw new Error('createSessionProxy requires a non-empty socketPath');\n  }\n\n  function pauseClientInput() {\n    input.pause?.();\n  }\n\n  function resumeClientInputIfReady() {\n    if (!clientEnded && !stopped && state === 'CONNECTED') input.resume?.();\n  }\n\n  function stopKeepalive() {\n    if (keepaliveInterval !== null) {\n      clearInterval(keepaliveInterval);\n      keepaliveInterval = null;\n    }\n    if (keepaliveTimer !== null) {\n      clearTimeout(keepaliveTimer);\n      keepaliveTimer = null;\n    }\n    pendingKeepaliveId = null;\n  }\n\n  function detachSocket(destroy = true) {\n    stopKeepalive();\n    if (!socket) return;\n    const oldSocket = socket;\n    socket = null;\n    // The backpressure 'drain' wait was bound to this now-discarded socket and its\n    // handler short-circuits once the socket is swapped, so it can never reset the\n    // flag. Clear it here (and drop the listener) or the next socket's pump stays\n    // blocked forever — a silent hang when backpressure coincides with a recycle.\n    socketDrainWaiting = false;\n    oldSocket.removeAllListeners?.('data');\n    oldSocket.removeAllListeners?.('error');\n    oldSocket.removeAllListeners?.('close');\n    oldSocket.removeAllListeners?.('drain');\n    if (destroy) oldSocket.destroy?.();\n  }\n\n  function stop() {\n    if (stopped) return;\n    stopped = true;\n    input.off?.('data', onInputData);\n    input.off?.('end', onInputEnd);\n    input.off?.('close', onInputClose);\n    output.off?.('error', onOutputError);\n    detachSocket(true);\n  }\n\n  function pumpOutputQueue() {\n    if (outputDrainWaiting) return;\n    while (outputWriteQueue.length > 0) {\n      const frame = outputWriteQueue[0];\n      const accepted = writeFrame(output, frame);\n      outputWriteQueue.shift();\n      if (!accepted) {\n        outputDrainWaiting = true;\n        socket?.pause?.();\n        output.once?.('drain', () => {\n          outputDrainWaiting = false;\n          socket?.resume?.();\n          pumpOutputQueue();\n        });\n        return;\n      }\n    }\n    if (outputEndRequested) {\n      output.end?.();\n      stop();\n    }\n  }\n\n  function enqueueOutputFrame(frame) {\n    outputWriteQueue.push(frame);\n    pumpOutputQueue();\n  }\n\n  function requestOutputEnd() {\n    outputEndRequested = true;\n    pumpOutputQueue();\n  }\n\n  function failPendingAndEndWith(makeErrorFrame) {\n    const failedIds = new Set();\n    for (const id of tracker.pendingRequests.keys()) {\n      failedIds.add(JSON.stringify(id));\n      enqueueOutputFrame(makeErrorFrame(id));\n    }\n    tracker.pendingRequests.clear();\n    while (queuedClientFrames.length > 0) {\n      const frame = queuedClientFrames.shift();\n      const parsed = parseFrame(frame);\n      if (!hasRequestId(parsed)) continue;\n      const key = JSON.stringify(parsed.id);\n      if (failedIds.has(key)) continue;\n      failedIds.add(key);\n      enqueueOutputFrame(makeErrorFrame(parsed.id));\n    }\n    requestOutputEnd();\n  }\n\n  function failPendingAndEnd() {\n    failPendingAndEndWith(retryableErrorFrame);\n  }\n\n  function failPendingAndEndProtocolMismatch() {\n    failPendingAndEndWith(protocolMismatchErrorFrame);\n  }\n\n  function failOldestQueuedClientFrame() {\n    while (queuedClientFrames.length > maxQueuedClientFrames) {\n      const frame = queuedClientFrames.shift();\n      const parsed = parseFrame(frame);\n      if (hasRequestId(parsed)) {\n        enqueueOutputFrame(retryableErrorFrame(parsed.id));\n        tracker.pendingRequests.delete(parsed.id);\n      }\n    }\n  }\n\n  function queueClientFrame(frame) {\n    queuedClientFrames.push(frame);\n    failOldestQueuedClientFrame();\n  }\n\n  function pumpSocketQueue() {\n    if (!socket || state !== 'CONNECTED' || socketDrainWaiting) return;\n    while (socketWriteQueue.length > 0 && socket && state === 'CONNECTED') {\n      const activeSocket = socket;\n      const frame = socketWriteQueue[0];\n      const accepted = writeFrame(activeSocket, frame);\n      socketWriteQueue.shift();\n      if (!accepted) {\n        socketDrainWaiting = true;\n        pauseClientInput();\n        activeSocket.once?.('drain', () => {\n          if (activeSocket !== socket) return;\n          socketDrainWaiting = false;\n          resumeClientInputIfReady();\n          pumpSocketQueue();\n        });\n        return;\n      }\n    }\n    resumeClientInputIfReady();\n  }\n\n  function enqueueSocketFrame(frame) {\n    socketWriteQueue.push(frame);\n    pumpSocketQueue();\n  }\n\n  function sendKeepalive() {\n    if (!socket || state !== 'CONNECTED' || pendingKeepaliveId !== null) return;\n    if (Date.now() - lastBackendActivity < keepaliveIntervalMs) return;\n    pendingKeepaliveId = `${PROXY_PRIVATE_ID_PREFIX}${keepaliveId += 1}`;\n    enqueueSocketFrame(JSON.stringify({ jsonrpc: '2.0', id: pendingKeepaliveId, method: 'ping' }));\n    keepaliveTimer = setTimeout(() => {\n      keepaliveTimer = null;\n      if (pendingKeepaliveId === null) return;\n      pendingKeepaliveId = null;\n      handleBackendFailure('keepalive-timeout');\n    }, keepaliveTimeoutMs);\n    keepaliveTimer.unref?.();\n  }\n\n  function startKeepalive() {\n    stopKeepalive();\n    lastBackendActivity = Date.now();\n    keepaliveInterval = setInterval(sendKeepalive, keepaliveIntervalMs);\n    keepaliveInterval.unref?.();\n  }\n\n  function forwardClientFrame(frame) {\n    tracker.handleClientFrame(frame);\n    if (!socket || state !== 'CONNECTED') {\n      queueClientFrame(frame);\n      return;\n    }\n    enqueueSocketFrame(frame);\n  }\n\n  function flushQueuedClientFrames() {\n    while (queuedClientFrames.length > 0 && socket && state === 'CONNECTED') {\n      forwardClientFrame(queuedClientFrames.shift());\n    }\n  }\n\n  function handleClientFrame(frame) {\n    const parsedClient = parseFrame(frame);\n    if (parsedClient\n        && parsedClient.method !== undefined\n        && typeof parsedClient.id === 'string'\n        && parsedClient.id.startsWith(PROXY_PRIVATE_ID_PREFIX)) {\n      // This id prefix is reserved for the proxy's private keepalive pings. A\n      // client request carrying a colliding id would have its backend response\n      // silently swallowed by the keepalive interceptor in handleBackendFrame,\n      // hanging the request. Reject the reserved id rather than forward it.\n      enqueueOutputFrame(JSON.stringify({\n        jsonrpc: '2.0',\n        id: parsedClient.id,\n        error: { code: -32600, message: 'Request id uses a reserved prefix' },\n      }));\n      return;\n    }\n    if (state !== 'CONNECTED' || !socket) {\n      queueClientFrame(frame);\n      return;\n    }\n    forwardClientFrame(frame);\n  }\n\n  function handleBackendFrame(frame) {\n    lastBackendActivity = Date.now();\n    const parsed = parseFrame(frame);\n    if (pendingKeepaliveId !== null && isResponseFrame(parsed) && parsed.id === pendingKeepaliveId) {\n      pendingKeepaliveId = null;\n      if (keepaliveTimer !== null) {\n        clearTimeout(keepaliveTimer);\n        keepaliveTimer = null;\n      }\n      return;\n    }\n    const cachedInitializeId = tracker.getCachedInitializeId();\n    if (!tracker.hasObservedProtocolVersion()\n        && cachedInitializeId !== null\n        && isResponseFrame(parsed)\n        && parsed.id === cachedInitializeId) {\n      // Record the protocol version negotiated on the first initialize so an internal\n      // re-handshake to a swapped backend can fail closed on a version change rather\n      // than silently serve the client a protocol it never negotiated.\n      tracker.recordNegotiatedProtocolVersion(\n        parsed.result && typeof parsed.result === 'object' ? parsed.result.protocolVersion : undefined,\n      );\n    }\n    tracker.handleBackendFrame(frame);\n    enqueueOutputFrame(frame);\n  }\n\n  function replaySnapshot(snapshot) {\n    const cachedInitializeId = tracker.getCachedInitializeId();\n    for (const [id, entry] of snapshot) {\n      if (!tracker.pendingRequests.has(id)) continue;\n      // internalHandshake already re-sent (and consumed the reply for) the cached\n      // initialize on the fresh socket. Replaying it here too would deliver a second\n      // initialize to the backend, so the handshake path owns the initialize replay.\n      if (cachedInitializeId !== null && id === cachedInitializeId) continue;\n      if (entry.replayable) {\n        enqueueSocketFrame(entry.frame);\n        continue;\n      }\n      enqueueOutputFrame(retryableErrorFrame(id));\n      tracker.pendingRequests.delete(id);\n    }\n  }\n\n  async function attachFreshSocket({ replaySnapshotEntries = [] } = {}) {\n    const freshSocket = await connectSocket(connect, socketPath);\n    const handshake = await internalHandshake(freshSocket, tracker.getCachedInitialize());\n    const expectedProtocolVersion = tracker.getNegotiatedProtocolVersion();\n    if (handshake.handshakeObserved\n        && expectedProtocolVersion !== null\n        && (handshake.protocolVersion ?? null) !== expectedProtocolVersion) {\n      // A backend build swap can re-handshake with a different negotiated protocol\n      // version. Serving it would silently break the client's protocol contract, so\n      // end the session with a non-retryable error instead of attaching the socket.\n      // CLOSED is terminal: the reattach loop must not retry a version-mismatched backend.\n      log(`backend protocol version drift: expected ${expectedProtocolVersion}, got ${handshake.protocolVersion ?? 'none'}; failing closed`);\n      freshSocket.destroy?.();\n      state = 'CLOSED';\n      failPendingAndEndProtocolMismatch();\n      return;\n    }\n    socket = freshSocket;\n    backendSplitter = createFrameSplitter(handleBackendFrame);\n    if (handshake.residual.length > 0) backendSplitter.push(handshake.residual);\n    socket.on('data', (chunk) => backendSplitter.push(chunk));\n    socket.once('error', (error) => {\n      log(`socket proxy error: ${error instanceof Error ? error.message : String(error)}`);\n      handleBackendFailure('error');\n    });\n    socket.once('close', () => {\n      handleBackendFailure('close');\n    });\n    state = 'CONNECTED';\n    startKeepalive();\n    // The fresh backend may have died after receiving the client's initialize but before\n    // answering it on the old socket, leaving initialize pending. internalHandshake just\n    // re-sent and answered it; forward that single answer to the client and clear it from\n    // pending so replaySnapshot does not send a duplicate initialize to the backend.\n    const cachedInitializeId = tracker.getCachedInitializeId();\n    if (handshake.handshakeObserved\n        && handshake.initializeResponse\n        && cachedInitializeId !== null\n        && tracker.pendingRequests.has(cachedInitializeId)) {\n      tracker.pendingRequests.delete(cachedInitializeId);\n      enqueueOutputFrame(handshake.initializeResponse);\n    }\n    replaySnapshot(replaySnapshotEntries);\n    flushQueuedClientFrames();\n    pumpSocketQueue();\n    if (clientEnded) {\n      socket?.end?.();\n      stop();\n      return;\n    }\n    resumeClientInputIfReady();\n  }\n","lineStart":1,"lineEnd":700,"totalLines":823,"truncated":true}},"title":".opencode/bin/lib/launcher-session-proxy.cjs","time":{"start":1780907816037,"end":1780907816061}},"metadata":{"openai":{"itemId":"fc_0496853919e9ef02016a267f27c6748191bb29dc1a5a10737a"}},"id":"prt_ea660b43d001L48YuQFdw4nud6","sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","messageID":"msg_ea6608043001bRKh2O65UAKOye"}}
{"type":"tool_use","timestamp":1780907816066,"sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","part":{"type":"tool","tool":"read","callID":"call_0eFIpmSpWMZlaxjlCrWVumi0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // [mk-code-index-launcher] MCP child-process launcher for the mk-code-index server\n3: // (system-code-graph). Loads project-local env overrides, applies the maintainer-mode\n4: // INDEX_* override when SPECKIT_CODE_GRAPH_MAINTAINER_MODE=true, auto-migrates the\n5: // code-graph database from the former shared location (.opencode/.spec-kit/code-graph/database/)\n6: // back to the skill-local location (mcp_server/database/), ensures dist\n7: // artifacts are built and current, serializes concurrent starts via a filesystem bootstrap\n8: // lock, sets SPECKIT_CODE_GRAPH_DB_DIR for the child process (operator override wins),\n9: // then spawns the code-graph MCP server child. All stderr lines are tagged with the\n10: // bracketed module prefix for ops grepping. See .opencode/skills/system-code-graph/ for\n11: // the standalone skill that owns the server source.\n12: \n13: 'use strict';\n14: \n15: const fs = require('fs');\n16: const path = require('path');\n17: const { spawn, spawnSync } = require('child_process');\n18: const { createSessionProxy, createClassifyFrame } = require('./lib/launcher-session-proxy.cjs');\n19: \n20: const root = path.resolve(__dirname, '..', '..');\n21: const opencodeDir = path.join(root, '.opencode');\n22: const BLOCKED_CHILD_ENV_RE = /^(NODE_|npm_|NPM_)/;\n23: const DOTENV_ALLOW_RE = /^(SPECKIT_CODE_GRAPH_|SPECKIT_LAUNCHER_IDLE_TIMEOUT_MIN$|MK_CODE_INDEX_)/;\n24: \n25: // Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n26: // .env, both are gitignored. Existing process.env wins over file values (do not override).\n27: // Minimal parser — no external dependency.\n28: function loadEnvFile(filePath) {\n29:   if (!fs.existsSync(filePath)) return 0;\n30:   let count = 0;\n31:   const raw = fs.readFileSync(filePath, 'utf8');\n32:   for (const line of raw.split('\\n')) {\n33:     const trimmed = line.trim();\n34:     if (!trimmed || trimmed.startsWith('#')) continue;\n35:     const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n36:     if (!m) continue;\n37:     const key = m[1];\n38:     let val = m[2];\n39:     // Strip matching outer quotes (single or double)\n40:     if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n41:       val = val.slice(1, -1);\n42:     }\n43:     // The minimal parser is line-oriented; embedded \\n in a quoted value would\n44:     // already have terminated the line, but defend explicitly.\n45:     if (val.includes('\\n') || val.includes('\\0')) {\n46:       process.stderr.write(`[mk-code-index-launcher] env value for ${key} contains control chars; skipping\\n`);\n47:       continue;\n48:     }\n49:     if (!DOTENV_ALLOW_RE.test(key)) {\n50:       process.stderr.write(`[mk-code-index-launcher] env ${key} from ${path.basename(filePath)} is not allowlisted; skipping\\n`);\n51:       continue;\n52:     }\n53:     if (!(key in process.env)) {\n54:       process.env[key] = val;\n55:       count++;\n56:     }\n57:   }\n58:   return count;\n59: }\n60: \n61: function isStrictModeDisabled(value) {\n62:   if (value === undefined || value === null) return false;\n63:   const v = String(value).trim().toLowerCase();\n64:   return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n65: }\n66: \n67: function bootstrapLauncherEnv() {\n68:   for (const fname of ['.env.local', '.env']) {\n69:     const p = path.join(root, fname);\n70:     if (fs.existsSync(p)) {\n71:       const n = loadEnvFile(p);\n72:       if (n > 0) process.stderr.write(`[mk-code-index-launcher] loaded ${n} env(s) from ${fname}\\n`);\n73:     }\n74:   }\n75: \n76:   // Maintainer-mode override: when SPECKIT_CODE_GRAPH_MAINTAINER_MODE=true is set in\n77:   // .env.local (gitignored maintainer-only file), force all 5 INDEX_* flags to \"true\"\n78:   // regardless of what the runtime's MCP config injected. Committed configs ship \"false\"\n79:   // defaults (end-user safe); the maintainer flips this one flag locally to enable\n80:   // indexing of .opencode/{skills,agents,commands,specs,plugins} on their machine only.\n81:   // Per-call code_graph_scan args (includeSkills, etc.) still override env for fine-grained\n82:   // control. See ENV_REFERENCE.md § GRAPH.\n83:   if (process.env.SPECKIT_CODE_GRAPH_MAINTAINER_MODE === 'true') {\n84:     const INDEX_KEYS = [\n85:       'SPECKIT_CODE_GRAPH_INDEX_SKILLS',\n86:       'SPECKIT_CODE_GRAPH_INDEX_AGENTS',\n87:       'SPECKIT_CODE_GRAPH_INDEX_COMMANDS',\n88:       'SPECKIT_CODE_GRAPH_INDEX_SPECS',\n89:       'SPECKIT_CODE_GRAPH_INDEX_PLUGINS',\n90:     ];\n91:     for (const key of INDEX_KEYS) {\n92:       process.env[key] = 'true';\n93:     }\n94:     process.stderr.write(\n95:       '[mk-code-index-launcher] MAINTAINER_MODE=true: forcing all 5 INDEX_* to \"true\"\\n'\n96:     );\n97:   }\n98: }\n99: \n100: let skillsDir = path.join(opencodeDir, 'skills');\n101: let legacySkillDir = path.join(opencodeDir, 'skill');\n102: let kitDir = path.join(skillsDir, 'system-code-graph');\n103: // DB lives SKILL-LOCAL at mcp_server/database/; SPECKIT_CODE_GRAPH_DB_DIR overrides.\n104: // Former shared location (.opencode/.spec-kit/code-graph/database/) is migrated back on first startup.\n105: let dbDir = path.join(kitDir, 'mcp_server', 'database');\n106: let lockDir = path.join(dbDir, '.mk-code-index-launcher.lockdir');\n107: const PID_FILE_NAME = '.mk-code-index-launcher.json';\n108: const OWNER_LEASE_FILE_NAME = '.code-graph-owner.json';\n109: let stateFile = path.join(dbDir, PID_FILE_NAME);\n110: \n111: const rel = (p) => path.relative(root, p) || '.';\n112: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n113: const now = () => new Date().toISOString();\n114: const RESPAWN_REAP_GRACE_MS = 7000;\n115: let childProcess = null;\n116: let ownerLeasePid = null;\n117: let launchStarted = false;\n118: \n119: function log(message) {\n120:   process.stderr.write(`[mk-code-index-launcher] ${message}\\n`);\n121: }\n122: \n123: function loadBridgeModule() {\n124:   try {\n125:     return require('./lib/launcher-ipc-bridge.cjs');\n126:   } catch (error) {\n127:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n128:     return {\n129:       async maybeBridgeLeaseHolder({ leaseResult }) {\n130:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n131:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n132:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n133:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n134:         return { action: 'report', reason: 'bridge-module-missing' };\n135:       },\n136:     };\n137:   }\n138: }\n139: \n140: // Code-index replayable / unsafe tool sets for the reconnecting session proxy. Read-only structural\n141: // queries are safe to replay across a backend reattach; a full scan or an apply mutates the graph and\n142: // must NOT be replayed (the client re-drives it on a retryable recycle error). The proxy machinery is\n143: // shared with mk-spec-memory; only this tool set differs.\n144: const CODE_INDEX_REPLAYABLE_TOOL_NAMES = new Set([\n145:   'code_graph_query',\n146:   'code_graph_context',\n147:   'code_graph_status',\n148:   'code_graph_classify_query_intent',\n149:   'detect_changes',\n150: ]);\n151: const CODE_INDEX_UNSAFE_TOOL_NAMES = new Set([\n152:   'code_graph_scan',\n153:   'code_graph_apply',\n154:   // code_graph_verify is read-mostly but MUTATES when persistBaseline=true (it persists the gold\n155:   // verification baseline), so it must NOT be replayed across a reconnect — the client re-drives it.\n156:   'code_graph_verify',\n157: ]);\n158: const classifyCodeIndexFrame = createClassifyFrame({\n159:   replayableToolNames: CODE_INDEX_REPLAYABLE_TOOL_NAMES,\n160:   unsafeToolNames: CODE_INDEX_UNSAFE_TOOL_NAMES,\n161: });\n162: \n163: // Bridge a secondary client through the reconnecting session proxy so a code-index owner death no\n164: // longer surfaces as a hard \"Connection closed\" — the proxy reattaches to the respawned backend and\n165: // replays in-flight read queries. Mirrors the mk-spec-memory wiring; the classifier is the only diff.\n166: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n167:   const createProxy = options.createProxy ?? createSessionProxy;\n168:   const sessionProxy = createProxy({\n169:     socketPath,\n170:     stdin: options.stdin ?? process.stdin,\n171:     stdout: options.stdout ?? process.stdout,\n172:     log,\n173:     classify: classifyCodeIndexFrame,\n174:   });\n175:   return sessionProxy.start();\n176: }\n177: \n178: function refreshPaths() {\n179:   skillsDir = path.join(opencodeDir, 'skills');\n180:   legacySkillDir = path.join(opencodeDir, 'skill');\n181:   kitDir = path.join(skillsDir, 'system-code-graph');\n182:   dbDir = path.join(kitDir, 'mcp_server', 'database');\n183:   lockDir = path.join(dbDir, '.mk-code-index-launcher.lockdir');\n184:   stateFile = path.join(dbDir, PID_FILE_NAME);\n185: }\n186: \n187: function exists(p) {\n188:   return fs.existsSync(p);\n189: }\n190: \n191: function canonicalizePath(pathValue) {\n192:   const resolvedPath = path.resolve(pathValue);\n193:   try {\n194:     return fs.realpathSync.native(resolvedPath);\n195:   } catch (error) {\n196:     if (error.code === 'ENOENT') return resolvedPath;\n197:     throw error;\n198:   }\n199: }\n200: \n201: function canonicalizeExistingPrefix(pathValue) {\n202:   const resolvedPath = path.resolve(pathValue);\n203:   if (fs.existsSync(resolvedPath)) return fs.realpathSync.native(resolvedPath);\n204: \n205:   const segments = [];\n206:   let current = resolvedPath;\n207:   while (!fs.existsSync(current)) {\n208:     const parent = path.dirname(current);\n209:     if (parent === current) return resolvedPath;\n210:     segments.unshift(path.basename(current));\n211:     current = parent;\n212:   }\n213:   return path.join(fs.realpathSync.native(current), ...segments);\n214: }\n215: \n216: function isWithinBase(basePath, candidatePath) {\n217:   return candidatePath === basePath || candidatePath.startsWith(`${basePath}${path.sep}`);\n218: }\n219: \n220: function isWithinRoot(candidatePath, requireCanonical = false) {\n221:   const canonicalRoot = fs.realpathSync.native(path.resolve(root));\n222:   const normalizedCandidate = canonicalizeExistingPrefix(candidatePath);\n223:   if (!isWithinBase(canonicalRoot, normalizedCandidate)) return false;\n224:   if (!requireCanonical && !fs.existsSync(path.resolve(candidatePath))) return true;\n225:   const candidate = canonicalizePath(candidatePath);\n226:   return isWithinBase(canonicalRoot, candidate);\n227: }\n228: \n229: function assertPathWithinRoot(candidatePath, label, requireCanonical = false) {\n230:   if (!isWithinRoot(candidatePath, requireCanonical)) {\n231:     throw new Error(`${label} must stay within workspace root ${root}: ${candidatePath}`);\n232:   }\n233: }\n234: \n235: function ensureCanonicalDir(dirPath) {\n236:   assertPathWithinRoot(dirPath, 'code graph DB directory');\n237:   fs.mkdirSync(path.resolve(dirPath), { recursive: true, mode: 0o700 });\n238:   assertPathWithinRoot(dirPath, 'code graph DB directory', true);\n239:   return canonicalizePath(dirPath);\n240: }\n241: \n242: function writeState(payload) {\n243:   fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n244:   fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n245: }\n246: \n247: function resolvedDbDir() {\n248:   const candidate = process.env.SPECKIT_CODE_GRAPH_DB_DIR ?? dbDir;\n249:   assertPathWithinRoot(candidate, 'SPECKIT_CODE_GRAPH_DB_DIR');\n250:   if (fs.existsSync(candidate)) assertPathWithinRoot(candidate, 'SPECKIT_CODE_GRAPH_DB_DIR', true);\n251:   return canonicalizePath(candidate);\n252: }\n253: \n254: function leasePath() {\n255:   return path.join(resolvedDbDir(), PID_FILE_NAME);\n256: }\n257: \n258: function ownerLeasePath() {\n259:   return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n260: }\n\n(Showing lines 1-260 of 1022. Use offset=261 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// [mk-code-index-launcher] MCP child-process launcher for the mk-code-index server\n// (system-code-graph). Loads project-local env overrides, applies the maintainer-mode\n// INDEX_* override when SPECKIT_CODE_GRAPH_MAINTAINER_MODE=true, auto-migrates the\n// code-graph database from the former shared location (.opencode/.spec-kit/code-graph/database/)\n// back to the skill-local location (mcp_server/database/), ensures dist\n// artifacts are built and current, serializes concurrent starts via a filesystem bootstrap\n// lock, sets SPECKIT_CODE_GRAPH_DB_DIR for the child process (operator override wins),\n// then spawns the code-graph MCP server child. All stderr lines are tagged with the\n// bracketed module prefix for ops grepping. See .opencode/skills/system-code-graph/ for\n// the standalone skill that owns the server source.\n\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst { createSessionProxy, createClassifyFrame } = require('./lib/launcher-session-proxy.cjs');\n\nconst root = path.resolve(__dirname, '..', '..');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-code-index-launcher.cjs","text":"#!/usr/bin/env node\n// [mk-code-index-launcher] MCP child-process launcher for the mk-code-index server\n// (system-code-graph). Loads project-local env overrides, applies the maintainer-mode\n// INDEX_* override when SPECKIT_CODE_GRAPH_MAINTAINER_MODE=true, auto-migrates the\n// code-graph database from the former shared location (.opencode/.spec-kit/code-graph/database/)\n// back to the skill-local location (mcp_server/database/), ensures dist\n// artifacts are built and current, serializes concurrent starts via a filesystem bootstrap\n// lock, sets SPECKIT_CODE_GRAPH_DB_DIR for the child process (operator override wins),\n// then spawns the code-graph MCP server child. All stderr lines are tagged with the\n// bracketed module prefix for ops grepping. See .opencode/skills/system-code-graph/ for\n// the standalone skill that owns the server source.\n\n'use strict';\n\nconst fs = require('fs');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\nconst { createSessionProxy, createClassifyFrame } = require('./lib/launcher-session-proxy.cjs');\n\nconst root = path.resolve(__dirname, '..', '..');\nconst opencodeDir = path.join(root, '.opencode');\nconst BLOCKED_CHILD_ENV_RE = /^(NODE_|npm_|NPM_)/;\nconst DOTENV_ALLOW_RE = /^(SPECKIT_CODE_GRAPH_|SPECKIT_LAUNCHER_IDLE_TIMEOUT_MIN$|MK_CODE_INDEX_)/;\n\n// Load project-local env overrides BEFORE spawning the MCP child. .env.local wins over\n// .env, both are gitignored. Existing process.env wins over file values (do not override).\n// Minimal parser — no external dependency.\nfunction loadEnvFile(filePath) {\n  if (!fs.existsSync(filePath)) return 0;\n  let count = 0;\n  const raw = fs.readFileSync(filePath, 'utf8');\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed || trimmed.startsWith('#')) continue;\n    const m = trimmed.match(/^([A-Za-z_][A-Za-z0-9_]*)\\s*=\\s*(.*)$/);\n    if (!m) continue;\n    const key = m[1];\n    let val = m[2];\n    // Strip matching outer quotes (single or double)\n    if ((val.startsWith('\"') && val.endsWith('\"')) || (val.startsWith(\"'\") && val.endsWith(\"'\"))) {\n      val = val.slice(1, -1);\n    }\n    // The minimal parser is line-oriented; embedded \\n in a quoted value would\n    // already have terminated the line, but defend explicitly.\n    if (val.includes('\\n') || val.includes('\\0')) {\n      process.stderr.write(`[mk-code-index-launcher] env value for ${key} contains control chars; skipping\\n`);\n      continue;\n    }\n    if (!DOTENV_ALLOW_RE.test(key)) {\n      process.stderr.write(`[mk-code-index-launcher] env ${key} from ${path.basename(filePath)} is not allowlisted; skipping\\n`);\n      continue;\n    }\n    if (!(key in process.env)) {\n      process.env[key] = val;\n      count++;\n    }\n  }\n  return count;\n}\n\nfunction isStrictModeDisabled(value) {\n  if (value === undefined || value === null) return false;\n  const v = String(value).trim().toLowerCase();\n  return v === '0' || v === 'false' || v === 'no' || v === 'off' || v === '';\n}\n\nfunction bootstrapLauncherEnv() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-code-index-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n\n  // Maintainer-mode override: when SPECKIT_CODE_GRAPH_MAINTAINER_MODE=true is set in\n  // .env.local (gitignored maintainer-only file), force all 5 INDEX_* flags to \"true\"\n  // regardless of what the runtime's MCP config injected. Committed configs ship \"false\"\n  // defaults (end-user safe); the maintainer flips this one flag locally to enable\n  // indexing of .opencode/{skills,agents,commands,specs,plugins} on their machine only.\n  // Per-call code_graph_scan args (includeSkills, etc.) still override env for fine-grained\n  // control. See ENV_REFERENCE.md § GRAPH.\n  if (process.env.SPECKIT_CODE_GRAPH_MAINTAINER_MODE === 'true') {\n    const INDEX_KEYS = [\n      'SPECKIT_CODE_GRAPH_INDEX_SKILLS',\n      'SPECKIT_CODE_GRAPH_INDEX_AGENTS',\n      'SPECKIT_CODE_GRAPH_INDEX_COMMANDS',\n      'SPECKIT_CODE_GRAPH_INDEX_SPECS',\n      'SPECKIT_CODE_GRAPH_INDEX_PLUGINS',\n    ];\n    for (const key of INDEX_KEYS) {\n      process.env[key] = 'true';\n    }\n    process.stderr.write(\n      '[mk-code-index-launcher] MAINTAINER_MODE=true: forcing all 5 INDEX_* to \"true\"\\n'\n    );\n  }\n}\n\nlet skillsDir = path.join(opencodeDir, 'skills');\nlet legacySkillDir = path.join(opencodeDir, 'skill');\nlet kitDir = path.join(skillsDir, 'system-code-graph');\n// DB lives SKILL-LOCAL at mcp_server/database/; SPECKIT_CODE_GRAPH_DB_DIR overrides.\n// Former shared location (.opencode/.spec-kit/code-graph/database/) is migrated back on first startup.\nlet dbDir = path.join(kitDir, 'mcp_server', 'database');\nlet lockDir = path.join(dbDir, '.mk-code-index-launcher.lockdir');\nconst PID_FILE_NAME = '.mk-code-index-launcher.json';\nconst OWNER_LEASE_FILE_NAME = '.code-graph-owner.json';\nlet stateFile = path.join(dbDir, PID_FILE_NAME);\n\nconst rel = (p) => path.relative(root, p) || '.';\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\nconst now = () => new Date().toISOString();\nconst RESPAWN_REAP_GRACE_MS = 7000;\nlet childProcess = null;\nlet ownerLeasePid = null;\nlet launchStarted = false;\n\nfunction log(message) {\n  process.stderr.write(`[mk-code-index-launcher] ${message}\\n`);\n}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\n// Code-index replayable / unsafe tool sets for the reconnecting session proxy. Read-only structural\n// queries are safe to replay across a backend reattach; a full scan or an apply mutates the graph and\n// must NOT be replayed (the client re-drives it on a retryable recycle error). The proxy machinery is\n// shared with mk-spec-memory; only this tool set differs.\nconst CODE_INDEX_REPLAYABLE_TOOL_NAMES = new Set([\n  'code_graph_query',\n  'code_graph_context',\n  'code_graph_status',\n  'code_graph_classify_query_intent',\n  'detect_changes',\n]);\nconst CODE_INDEX_UNSAFE_TOOL_NAMES = new Set([\n  'code_graph_scan',\n  'code_graph_apply',\n  // code_graph_verify is read-mostly but MUTATES when persistBaseline=true (it persists the gold\n  // verification baseline), so it must NOT be replayed across a reconnect — the client re-drives it.\n  'code_graph_verify',\n]);\nconst classifyCodeIndexFrame = createClassifyFrame({\n  replayableToolNames: CODE_INDEX_REPLAYABLE_TOOL_NAMES,\n  unsafeToolNames: CODE_INDEX_UNSAFE_TOOL_NAMES,\n});\n\n// Bridge a secondary client through the reconnecting session proxy so a code-index owner death no\n// longer surfaces as a hard \"Connection closed\" — the proxy reattaches to the respawned backend and\n// replays in-flight read queries. Mirrors the mk-spec-memory wiring; the classifier is the only diff.\nfunction bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n  const createProxy = options.createProxy ?? createSessionProxy;\n  const sessionProxy = createProxy({\n    socketPath,\n    stdin: options.stdin ?? process.stdin,\n    stdout: options.stdout ?? process.stdout,\n    log,\n    classify: classifyCodeIndexFrame,\n  });\n  return sessionProxy.start();\n}\n\nfunction refreshPaths() {\n  skillsDir = path.join(opencodeDir, 'skills');\n  legacySkillDir = path.join(opencodeDir, 'skill');\n  kitDir = path.join(skillsDir, 'system-code-graph');\n  dbDir = path.join(kitDir, 'mcp_server', 'database');\n  lockDir = path.join(dbDir, '.mk-code-index-launcher.lockdir');\n  stateFile = path.join(dbDir, PID_FILE_NAME);\n}\n\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction canonicalizePath(pathValue) {\n  const resolvedPath = path.resolve(pathValue);\n  try {\n    return fs.realpathSync.native(resolvedPath);\n  } catch (error) {\n    if (error.code === 'ENOENT') return resolvedPath;\n    throw error;\n  }\n}\n\nfunction canonicalizeExistingPrefix(pathValue) {\n  const resolvedPath = path.resolve(pathValue);\n  if (fs.existsSync(resolvedPath)) return fs.realpathSync.native(resolvedPath);\n\n  const segments = [];\n  let current = resolvedPath;\n  while (!fs.existsSync(current)) {\n    const parent = path.dirname(current);\n    if (parent === current) return resolvedPath;\n    segments.unshift(path.basename(current));\n    current = parent;\n  }\n  return path.join(fs.realpathSync.native(current), ...segments);\n}\n\nfunction isWithinBase(basePath, candidatePath) {\n  return candidatePath === basePath || candidatePath.startsWith(`${basePath}${path.sep}`);\n}\n\nfunction isWithinRoot(candidatePath, requireCanonical = false) {\n  const canonicalRoot = fs.realpathSync.native(path.resolve(root));\n  const normalizedCandidate = canonicalizeExistingPrefix(candidatePath);\n  if (!isWithinBase(canonicalRoot, normalizedCandidate)) return false;\n  if (!requireCanonical && !fs.existsSync(path.resolve(candidatePath))) return true;\n  const candidate = canonicalizePath(candidatePath);\n  return isWithinBase(canonicalRoot, candidate);\n}\n\nfunction assertPathWithinRoot(candidatePath, label, requireCanonical = false) {\n  if (!isWithinRoot(candidatePath, requireCanonical)) {\n    throw new Error(`${label} must stay within workspace root ${root}: ${candidatePath}`);\n  }\n}\n\nfunction ensureCanonicalDir(dirPath) {\n  assertPathWithinRoot(dirPath, 'code graph DB directory');\n  fs.mkdirSync(path.resolve(dirPath), { recursive: true, mode: 0o700 });\n  assertPathWithinRoot(dirPath, 'code graph DB directory', true);\n  return canonicalizePath(dirPath);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  const candidate = process.env.SPECKIT_CODE_GRAPH_DB_DIR ?? dbDir;\n  assertPathWithinRoot(candidate, 'SPECKIT_CODE_GRAPH_DB_DIR');\n  if (fs.existsSync(candidate)) assertPathWithinRoot(candidate, 'SPECKIT_CODE_GRAPH_DB_DIR', true);\n  return canonicalizePath(candidate);\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n}","lineStart":1,"lineEnd":260,"totalLines":1022,"truncated":true}},"title":".opencode/bin/mk-code-index-launcher.cjs","time":{"start":1780907816041,"end":1780907816064}},"metadata":{"openai":{"itemId":"fc_0496853919e9ef02016a267f27c6848191bc927e7406119293"}},"id":"prt_ea660b467001DlEEMrJuHICBAy","sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","messageID":"msg_ea6608043001bRKh2O65UAKOye"}}
{"type":"tool_use","timestamp":1780907816070,"sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","part":{"type":"tool","tool":"read","callID":"call_7hGqGAxgLDd7Ki5nWAa6T6F0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh","offset":1,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"\n3: Comment hygiene checker — detects ephemeral-artifact pointers in code comment lines.\n4: \n5: Usage: check-comment-hygiene.sh <file>\n6: \n7: Exit codes:\n8:   0 — file is clean (no violations found)\n9:   1 — violations found (reported to stdout as FILEPATH:LINE: excerpt)\n10:   2 — file skipped (binary, unknown extension, or in excluded dir)\n11: \n12: Escape: add \"hygiene-ok\" anywhere on a comment line to suppress it.\n13: \n14: See: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\n15: \"\"\"\n16: import sys\n17: import os\n18: import re\n19: \n20: def main():\n21:     if len(sys.argv) < 2:\n22:         print(\"Usage: check-comment-hygiene.sh <file>\", file=sys.stderr)\n23:         sys.exit(2)\n24: \n25:     filepath = sys.argv[1]\n26: \n27:     # --- Excluded directories and file patterns ---\n28:     abs_path = os.path.abspath(filepath)\n29:     excluded_dirs = [\"/dist/\", \"/node_modules/\", \"/.git/\"]\n30:     for excl in excluded_dirs:\n31:         if excl in abs_path:\n32:             sys.exit(2)\n33: \n34:     basename = os.path.basename(filepath)\n35:     if basename.endswith(\".vitest.js\"):\n36:         sys.exit(2)\n37: \n38:     # --- Language detection from extension ---\n39:     _, ext = os.path.splitext(basename)\n40:     ext = ext.lower()\n41: \n42:     if ext in (\".ts\", \".tsx\", \".js\", \".mjs\", \".cjs\"):\n43:         lang = \"js\"\n44:     elif ext == \".py\":\n45:         lang = \"py\"\n46:     elif ext in (\".sh\", \".bash\"):\n47:         lang = \"sh\"\n48:     elif ext == \".jsonc\":\n49:         lang = \"jsonc\"\n50:     else:\n51:         # Unknown extension — skip silently\n52:         sys.exit(2)\n53: \n54:     # --- Read file ---\n55:     try:\n56:         with open(filepath, \"r\", encoding=\"utf-8\", errors=\"replace\") as f:\n57:             lines = f.readlines()\n58:     except (OSError, IOError) as e:\n59:         print(f\"WARNING: cannot read {filepath}: {e}\", file=sys.stderr)\n60:         sys.exit(0)\n61: \n62:     # --- Comment detection ---\n63:     def find_unquoted_js_line_comment(line: str) -> int:\n64:         in_string = False\n65:         quote = \"\"\n66:         escaping = False\n67: \n68:         index = 0\n69:         while index < len(line):\n70:             char = line[index]\n71:             next_char = line[index + 1] if index + 1 < len(line) else \"\"\n72: \n73:             if in_string:\n74:                 if escaping:\n75:                     escaping = False\n76:                 elif char == \"\\\\\":\n77:                     escaping = True\n78:                 elif char == quote:\n79:                     in_string = False\n80:                 index += 1\n81:                 continue\n82: \n83:             if char in (\"'\", '\"', \"`\"):\n84:                 in_string = True\n85:                 quote = char\n86:                 index += 1\n87:                 continue\n88: \n89:             if char == \"/\" and next_char == \"/\":\n90:                 return index\n91: \n92:             index += 1\n93: \n94:         return -1\n95: \n96:     def find_unquoted_hash_comment(line: str) -> int:\n97:         in_string = False\n98:         quote = \"\"\n99:         escaping = False\n100: \n101:         for index, char in enumerate(line):\n102:             if in_string:\n103:                 if escaping:\n104:                     escaping = False\n105:                 elif char == \"\\\\\" and quote != \"'\":\n106:                     escaping = True\n107:                 elif char == quote:\n108:                     in_string = False\n109:                 continue\n110: \n111:             if char in (\"'\", '\"'):\n112:                 in_string = True\n113:                 quote = char\n114:                 continue\n115: \n116:             if char == \"#\" and (index == 0 or line[index - 1].isspace()):\n117:                 return index\n118: \n119:         return -1\n120: \n121:     def is_comment_line(stripped: str, lang: str) -> bool:\n122:         if lang in (\"js\", \"jsonc\"):\n123:             return stripped.startswith(\"//\") or stripped.startswith(\"*\") or stripped.startswith(\"/*\")\n124:         elif lang in (\"py\", \"sh\"):\n125:             return stripped.startswith(\"#\")\n126:         return False\n127: \n128:     def extract_comment_text(raw_line: str, lang: str) -> str:\n129:         stripped = raw_line.strip()\n130:         if is_comment_line(stripped, lang):\n131:             return stripped\n132: \n133:         if lang in (\"js\", \"jsonc\"):\n134:             comment_index = find_unquoted_js_line_comment(raw_line)\n135:             if comment_index >= 0:\n136:                 return raw_line[comment_index:].strip()\n137: \n138:         if lang in (\"py\", \"sh\"):\n139:             comment_index = find_unquoted_hash_comment(raw_line)\n140:             if comment_index >= 0:\n141:                 return raw_line[comment_index:].strip()\n142: \n143:         return \"\"\n144: \n145:     # --- Allowed-class patterns (these suppress violation detection) ---\n146:     # Order: check these BEFORE violation patterns.\n147:     ALLOWED_PATTERNS = [\n148:         re.compile(r'\\bCWE-\\d+\\b'),                    # CWE security codes\n149:         re.compile(r'\\bRFC\\s*-?\\d+\\b'),                 # RFC references\n150:         re.compile(r'\\bPOSIX\\b'),                        # POSIX standard\n151:         re.compile(r'\\bHTTP\\s+\\d{3}\\b'),                 # HTTP status codes\n152:         re.compile(r'\\bWEBFLOW\\s*:'),                   # WEBFLOW: platform tag\n153:         re.compile(r'\\bMOTION\\s*:'),                    # MOTION: platform tag\n154:         re.compile(r'\\bLENIS\\s*:'),                     # LENIS: platform tag\n155:         re.compile(r'\\bV\\d+\\s*:'),                       # V16: schema tag\n156:     ]\n157: \n158:     # --- Violation patterns ---\n159:     # Each is (pattern, description) for clear reporting.\n160:     # F-notation is intentionally excluded: repo comments use it heavily for function keys,\n161:     # figures, and field references, so genuine finding labels stay review-owned.\n162:     VIOLATION_PATTERNS = [\n163:         (re.compile(r'\\b\\d{3}/\\d{3}\\b'),                            \"packet/phase reference\"),\n164:         (re.compile(r'\\bRC-\\d+\\b'),                                  \"RC reference\"),\n165:         (re.compile(r'\\bADR-\\d+\\b'),                                \"ADR reference\"),\n166:         (re.compile(r'\\bREQ-\\d+\\b'),                                \"REQ reference\"),\n167:         (re.compile(r'\\bCHK-\\d+\\b'),                                \"CHK reference\"),\n168:         (re.compile(r'\\bT\\d{3,4}\\b'),                               \"task ID reference\"),\n169:         (re.compile(r'\\bpacket\\s+\\d+\\b', re.IGNORECASE),            \"packet number reference\"),\n170:         (re.compile(r'\\bphase[\\s-]\\d{3}\\b', re.IGNORECASE),          \"3-digit phase reference\"),\n171:         (re.compile(r'specs/[a-z0-9]+-[a-z0-9-]*/'),               \"spec path reference\"),\n172:         (re.compile(r'\\bWS-\\d+-\\d+\\b'),                             \"worktree session reference\"),\n173:         (re.compile(r'\\bDR-\\d+(?:-\\d+)?\\b'),                        \"deep review reference\"),\n174:         (re.compile(r'\\bP\\d+-Seat\\d+\\b'),                           \"council seat reference\"),\n175:         (re.compile(r'\\breview\\s+finding\\b', re.IGNORECASE),        \"review finding reference\"),\n176:         (re.compile(r'\\bchecklist\\s+item\\s+\\d+\\b', re.IGNORECASE), \"checklist item reference\"),\n177:         (re.compile(r'\\b[Pp]\\d-finding[-\\s]\\d+\\b'),                 \"finding id reference\"),\n178:         (re.compile(r'\\bfinding\\s+#\\d+\\b', re.IGNORECASE),         \"finding id reference\"),\n179:     ]\n180: \n181:     violations = []\n182: \n183:     for lineno, raw_line in enumerate(lines, start=1):\n184:         comment_text = extract_comment_text(raw_line, lang)\n185: \n186:         if not comment_text:\n187:             continue\n188: \n189:         # Hygiene-ok escape: skip this line entirely\n190:         if \"hygiene-ok\" in comment_text:\n191:             continue\n192: \n193:         # Check allowed-class patterns first — if any match, skip violation check\n194:         if any(pat.search(comment_text) for pat in ALLOWED_PATTERNS):\n195:             continue\n196: \n197:         # Check violation patterns\n198:         for vpat, _desc in VIOLATION_PATTERNS:\n199:             m = vpat.search(comment_text)\n200:             if m:\n201:                 excerpt = raw_line.rstrip()\n202:                 violations.append(f\"{filepath}:{lineno}: {excerpt}\")\n203:                 break  # One violation per line is enough\n204: \n205:     if violations:\n206:         for v in violations:\n207:             print(v)\n208:         sys.exit(1)\n209: \n210:     sys.exit(0)\n211: \n212: \n213: if __name__ == \"__main__\":\n214:     main()\n\n(End of file - total 214 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"\nComment hygiene checker — detects ephemeral-artifact pointers in code comment lines.\n\nUsage: check-comment-hygiene.sh <file>\n\nExit codes:\n  0 — file is clean (no violations found)\n  1 — violations found (reported to stdout as FILEPATH:LINE: excerpt)\n  2 — file skipped (binary, unknown extension, or in excluded dir)\n\nEscape: add \"hygiene-ok\" anywhere on a comment line to suppress it.\n\nSee: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\n\"\"\"\nimport sys\nimport os\nimport re\n\ndef main():","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/scripts/check-comment-hygiene.sh","text":"#!/usr/bin/env python3\n\"\"\"\nComment hygiene checker — detects ephemeral-artifact pointers in code comment lines.\n\nUsage: check-comment-hygiene.sh <file>\n\nExit codes:\n  0 — file is clean (no violations found)\n  1 — violations found (reported to stdout as FILEPATH:LINE: excerpt)\n  2 — file skipped (binary, unknown extension, or in excluded dir)\n\nEscape: add \"hygiene-ok\" anywhere on a comment line to suppress it.\n\nSee: .opencode/skills/sk-code/references/universal/code_style_guide.md §4\n\"\"\"\nimport sys\nimport os\nimport re\n\ndef main():\n    if len(sys.argv) < 2:\n        print(\"Usage: check-comment-hygiene.sh <file>\", file=sys.stderr)\n        sys.exit(2)\n\n    filepath = sys.argv[1]\n\n    # --- Excluded directories and file patterns ---\n    abs_path = os.path.abspath(filepath)\n    excluded_dirs = [\"/dist/\", \"/node_modules/\", \"/.git/\"]\n    for excl in excluded_dirs:\n        if excl in abs_path:\n            sys.exit(2)\n\n    basename = os.path.basename(filepath)\n    if basename.endswith(\".vitest.js\"):\n        sys.exit(2)\n\n    # --- Language detection from extension ---\n    _, ext = os.path.splitext(basename)\n    ext = ext.lower()\n\n    if ext in (\".ts\", \".tsx\", \".js\", \".mjs\", \".cjs\"):\n        lang = \"js\"\n    elif ext == \".py\":\n        lang = \"py\"\n    elif ext in (\".sh\", \".bash\"):\n        lang = \"sh\"\n    elif ext == \".jsonc\":\n        lang = \"jsonc\"\n    else:\n        # Unknown extension — skip silently\n        sys.exit(2)\n\n    # --- Read file ---\n    try:\n        with open(filepath, \"r\", encoding=\"utf-8\", errors=\"replace\") as f:\n            lines = f.readlines()\n    except (OSError, IOError) as e:\n        print(f\"WARNING: cannot read {filepath}: {e}\", file=sys.stderr)\n        sys.exit(0)\n\n    # --- Comment detection ---\n    def find_unquoted_js_line_comment(line: str) -> int:\n        in_string = False\n        quote = \"\"\n        escaping = False\n\n        index = 0\n        while index < len(line):\n            char = line[index]\n            next_char = line[index + 1] if index + 1 < len(line) else \"\"\n\n            if in_string:\n                if escaping:\n                    escaping = False\n                elif char == \"\\\\\":\n                    escaping = True\n                elif char == quote:\n                    in_string = False\n                index += 1\n                continue\n\n            if char in (\"'\", '\"', \"`\"):\n                in_string = True\n                quote = char\n                index += 1\n                continue\n\n            if char == \"/\" and next_char == \"/\":\n                return index\n\n            index += 1\n\n        return -1\n\n    def find_unquoted_hash_comment(line: str) -> int:\n        in_string = False\n        quote = \"\"\n        escaping = False\n\n        for index, char in enumerate(line):\n            if in_string:\n                if escaping:\n                    escaping = False\n                elif char == \"\\\\\" and quote != \"'\":\n                    escaping = True\n                elif char == quote:\n                    in_string = False\n                continue\n\n            if char in (\"'\", '\"'):\n                in_string = True\n                quote = char\n                continue\n\n            if char == \"#\" and (index == 0 or line[index - 1].isspace()):\n                return index\n\n        return -1\n\n    def is_comment_line(stripped: str, lang: str) -> bool:\n        if lang in (\"js\", \"jsonc\"):\n            return stripped.startswith(\"//\") or stripped.startswith(\"*\") or stripped.startswith(\"/*\")\n        elif lang in (\"py\", \"sh\"):\n            return stripped.startswith(\"#\")\n        return False\n\n    def extract_comment_text(raw_line: str, lang: str) -> str:\n        stripped = raw_line.strip()\n        if is_comment_line(stripped, lang):\n            return stripped\n\n        if lang in (\"js\", \"jsonc\"):\n            comment_index = find_unquoted_js_line_comment(raw_line)\n            if comment_index >= 0:\n                return raw_line[comment_index:].strip()\n\n        if lang in (\"py\", \"sh\"):\n            comment_index = find_unquoted_hash_comment(raw_line)\n            if comment_index >= 0:\n                return raw_line[comment_index:].strip()\n\n        return \"\"\n\n    # --- Allowed-class patterns (these suppress violation detection) ---\n    # Order: check these BEFORE violation patterns.\n    ALLOWED_PATTERNS = [\n        re.compile(r'\\bCWE-\\d+\\b'),                    # CWE security codes\n        re.compile(r'\\bRFC\\s*-?\\d+\\b'),                 # RFC references\n        re.compile(r'\\bPOSIX\\b'),                        # POSIX standard\n        re.compile(r'\\bHTTP\\s+\\d{3}\\b'),                 # HTTP status codes\n        re.compile(r'\\bWEBFLOW\\s*:'),                   # WEBFLOW: platform tag\n        re.compile(r'\\bMOTION\\s*:'),                    # MOTION: platform tag\n        re.compile(r'\\bLENIS\\s*:'),                     # LENIS: platform tag\n        re.compile(r'\\bV\\d+\\s*:'),                       # V16: schema tag\n    ]\n\n    # --- Violation patterns ---\n    # Each is (pattern, description) for clear reporting.\n    # F-notation is intentionally excluded: repo comments use it heavily for function keys,\n    # figures, and field references, so genuine finding labels stay review-owned.\n    VIOLATION_PATTERNS = [\n        (re.compile(r'\\b\\d{3}/\\d{3}\\b'),                            \"packet/phase reference\"),\n        (re.compile(r'\\bRC-\\d+\\b'),                                  \"RC reference\"),\n        (re.compile(r'\\bADR-\\d+\\b'),                                \"ADR reference\"),\n        (re.compile(r'\\bREQ-\\d+\\b'),                                \"REQ reference\"),\n        (re.compile(r'\\bCHK-\\d+\\b'),                                \"CHK reference\"),\n        (re.compile(r'\\bT\\d{3,4}\\b'),                               \"task ID reference\"),\n        (re.compile(r'\\bpacket\\s+\\d+\\b', re.IGNORECASE),            \"packet number reference\"),\n        (re.compile(r'\\bphase[\\s-]\\d{3}\\b', re.IGNORECASE),          \"3-digit phase reference\"),\n        (re.compile(r'specs/[a-z0-9]+-[a-z0-9-]*/'),               \"spec path reference\"),\n        (re.compile(r'\\bWS-\\d+-\\d+\\b'),                             \"worktree session reference\"),\n        (re.compile(r'\\bDR-\\d+(?:-\\d+)?\\b'),                        \"deep review reference\"),\n        (re.compile(r'\\bP\\d+-Seat\\d+\\b'),                           \"council seat reference\"),\n        (re.compile(r'\\breview\\s+finding\\b', re.IGNORECASE),        \"review finding reference\"),\n        (re.compile(r'\\bchecklist\\s+item\\s+\\d+\\b', re.IGNORECASE), \"checklist item reference\"),\n        (re.compile(r'\\b[Pp]\\d-finding[-\\s]\\d+\\b'),                 \"finding id reference\"),\n        (re.compile(r'\\bfinding\\s+#\\d+\\b', re.IGNORECASE),         \"finding id reference\"),\n    ]\n\n    violations = []\n\n    for lineno, raw_line in enumerate(lines, start=1):\n        comment_text = extract_comment_text(raw_line, lang)\n\n        if not comment_text:\n            continue\n\n        # Hygiene-ok escape: skip this line entirely\n        if \"hygiene-ok\" in comment_text:\n            continue\n\n        # Check allowed-class patterns first — if any match, skip violation check\n        if any(pat.search(comment_text) for pat in ALLOWED_PATTERNS):\n            continue\n\n        # Check violation patterns\n        for vpat, _desc in VIOLATION_PATTERNS:\n            m = vpat.search(comment_text)\n            if m:\n                excerpt = raw_line.rstrip()\n                violations.append(f\"{filepath}:{lineno}: {excerpt}\")\n                break  # One violation per line is enough\n\n    if violations:\n        for v in violations:\n            print(v)\n        sys.exit(1)\n\n    sys.exit(0)\n\n\nif __name__ == \"__main__\":\n    main()","lineStart":1,"lineEnd":214,"totalLines":214,"truncated":false}},"title":".opencode/skills/sk-code/scripts/check-comment-hygiene.sh","time":{"start":1780907816046,"end":1780907816068}},"metadata":{"openai":{"itemId":"fc_0496853919e9ef02016a267f27c6a0819193266e64d6798737"}},"id":"prt_ea660b46c001aRHBwK5z16aLPa","sessionID":"ses_159a25826ffeGycQmqCQ1cpr4r","messageID":"msg_ea6608043001bRKh2O65UAKOye"}}
