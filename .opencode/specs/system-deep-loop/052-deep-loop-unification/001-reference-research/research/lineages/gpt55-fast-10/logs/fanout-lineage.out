routing-registry-drift-guard.vitest.ts';\\n84: \\n85: // Advisor entrypoint for the optional dynamic cross-check of the registry's\\n86: // lexical projection against the live hardcoded map.\\n87: const ADVISOR_SCRIPT =\\n88:   '.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py';\\n89: const ADVISOR_SCRIPT_ABS = path.resolve(REPO_ROOT, ADVISOR_SCRIPT);\\n90: \\n91: // The single global advisor projection map only mirrors this hub, so the\\n92: // dynamic 4b equality check applies to it; every other hub gets the inert-route\\n93: // coverage check (4c) instead. This is interpretation, not a gate — all hubs\\n94: // still run the check.\\n95: const GLOBAL_MAP_OWNER = 'deep-loop-workflows';\\n96: \\n97: const DEFAULT_TARGET = '.opencode/skills/deep-loop-workflows';\\n98: \\n99: // Canon checks are FAIL by default now that every parent hub carries the canon\\n100: // fields (packetKind, toolSurface, grandfatheredFolderMismatch, hub-router,\\n101: // description.json, playbook, benchmark). PARENT_HUB_CHECK_STRICT=0 opts a\\n102: // work-in-progress hub back to advisory WARN while it is being scaffolded.\\n103: const STRICT_HUB_CANON = process.env.PARENT_HUB_CHECK_STRICT !== '0';\\n104... (line truncated to 2000 chars)\n{\"type\":\"tool_use\",\"timestamp\":1783488098160,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_Yfb6FnrZ6jr3hRjW0eItuRtz\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js\",\"offset\":1,\"limit\":140},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-deep-loop-guard.js</path>\\n<type>file</type>\\n<content>\\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\\n2: // ║ COMPONENT: mk-deep-loop-guard OpenCode Plugin                            ║\\n3: // ╠══════════