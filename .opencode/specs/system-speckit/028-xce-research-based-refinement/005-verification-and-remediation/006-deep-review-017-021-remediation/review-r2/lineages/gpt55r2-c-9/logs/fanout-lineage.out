ull bytes which shared handles)\n    if (filePath.includes('..')) {\n      throw new Error('Access denied: Invalid path pattern');\n    }\n    return result;\n  };\n}\n\n/**\n * Get default allowed base paths for file operations\n */\nexport function getDefaultAllowedPaths(defaultBasePath?: string): string[] {\n  const basePath = defaultBasePath || process.cwd();\n  return [\n    path.join(os.homedir(), '.claude'),\n    basePath,\n    process.cwd()\n  ]\n    .filter(Boolean)\n    .map(base => path.resolve(base));\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. (ESM exports above — no CommonJS module.exports needed)\n   ──────────────────────────────────────────────────────────────── */","lineStart":105,"lineEnd":151,"totalLines":151,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/utils/validators.ts","time":{"start":1781764302050,"end":1781764302055}},"metadata":{"openai":{"itemId":"fc_0e4d0f2938ba35b0016a3390cdecec8191a7a5ebe030af5ab4"}},"id":"prt_ed96da4dc001qwLAiEPFjbgomn","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed96d7ee7001UH9306eg3w6VMZ"}}
