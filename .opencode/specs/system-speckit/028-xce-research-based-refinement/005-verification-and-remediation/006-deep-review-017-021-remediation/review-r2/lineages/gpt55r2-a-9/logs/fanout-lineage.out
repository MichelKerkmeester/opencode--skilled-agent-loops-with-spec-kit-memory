 }\n332: \n333:   return {\n334:     requiredAction: 'broaden_or_ask',\n335:     noCanonicalPathClaims: true,\n336:     citationRequiredForPaths: true,\n337:     safeResponse: 'Retrieval quality is weak. Broaden the query or ask the user for disambiguation before citing any path.',\n338:   };\n339: }\n340: \n341: function deriveCitationPolicy(requestQuality: RequestQualityAssessment | null): CitationPolicy {\n342:   const label = requestQuality?.requestQuality?.label;\n343:   return label === 'good' ? 'cite_results' : 'do_not_cite_results';\n344: }\n345: \n346: /**\n347:  * Allowlisted grammar for explicit `extractionAge`\n348:  * `lastAccessAge` strings. Mirrors the output of `formatAgeString`:\n349:  *\n350:  *   never | today | yesterday |\n351:  *   <n> days ago | <n> week ago | <n> weeks ago |\n352:  *   <n> month ago | <n> months ago\n353:  *\n354:  * Strings that don't match are dropped to `null` rather than\n355:  * passed through (which previously allowed arbitrary attacker-\n356:  * controlled strings to surface in result badges). The numeric\n357:  * portion is capped at 6 digits (max ~99,999 days, ~999,999\n358:  * months) to prevent visual-spam injection.\n359:  */\n360: const ALLOWED_AGE_LABEL = /^(?:never|today|yesterday|\\d{1,6}\\s+(?:day|days|week|weeks|month|months)\\s+ago)$/;\n361: const MAX_AGE_LABEL_LENGTH = 32;\n362: \n363: function sanitizeAgeLabel(value: unknown, fallbackIso: unknown): string {\n364:   if (typeof value === 'string') {\n365:     const trimmed = value.trim().toLowerCase();\n366:     if (trimmed.length <= MAX_AGE_LABEL_LENGTH && ALLOWED_AGE_LABEL.test(trimmed)) {\n367:       return trimmed;\n368:     }\n369:     // Explicit string supplied but failed allowlist — fall through\n370:     // to derivation rather than surfacing the raw value.\n371:   }\n372:   return formatAgeString(typeof fallbackIso === 'string' ? fallbackIso : null);\n373: }\n374: \n375: /**\n376:  * Normalize a caller-supplied `trustBadges` payload into\n377:  * a strict `MemoryTrustBadges` shape. Each field is sanitized\n378:  * independently — `null` / wrong type means \"fall through to\n379:  * derivation\" at merge time. Returns `null` only when the input is\n380:  * not an object at all.\n381:  */\n382: function normalizeExplicitTrustBadges(value: unknown): MemoryTrustBadgePartial | null {\n383:   if (!value || typeof value !== 'object') return null;\n384:   const candidate = value as Record<string, unknown>;\n385:   const confidence = clampConfidence(candidate.confidence);\n386: \n387:   // Age strings: allowlist or fallback to ISO-derived format.\n388:   const extractionAge = sanitizeAgeLabel(candidate.extractionAge, candidate.extractedAt);\n389:   const lastAccessAge = sanitizeAgeLabel(candidate.lastAccessAge, candidate.lastAccessed);\n390: \n391:   // Booleans: only `true` counts; anything else (including absent)\n392:   // falls through so the derived value can supply truth.\n393:   const orphan = typeof candidate.orphan === 'boolean' ? candidate.orphan : null;\n394:   const weightHistoryChanged = typeof candidate.weightHistoryChanged === 'boolean'\n395:     ? candidate.weightHistoryChanged\n396:     : null;\n397: \n398:   return {\n399:     confidence,\n400:     extractionAge,\n401:     lastAccessAge,\n402:     orphan,\n403:     weightHistoryChanged,\n404:   };\n405: }\n406: \n407: interface MemoryTrustBadgePartial {\n408:   confidence: number | null;\n409:   extractionAge: string;\n410:   lastAccessAge: string;\n411:   orphan: boolean | null;\n412:   weightHistoryChanged: boolean | null;\n413: }\n414: \n415: export function toTrustBadges(snapshot: TrustBadgeSnapshot | null): MemoryTrustBadges | undefined {\n416:   if (!snapshot) return undefined;\n417:   return {\n418:     confidence: snapshot.confidence,\n419:     extractionAge: formatAgeString(snapshot.extractedAt),\n420:     lastAccessAge: formatAgeString(snapshot.lastAccessed),\n421:     orphan: snapshot.orphan,\n422:     weightHistoryChanged: snapshot.weightHistoryChanged,\n423:   };\n424: }\n425: \n426: /**\n427:  * Merge an explicit caller-supplied partial onto the\n428:  * derived snapshot per-field. Non-null explicit fields override\n429:  * matching derived fields; null/missing fields fall through to\n430:  * derived. When `derived` is undefined and the explicit partial is\n431:  * incomplete (any required field still null after merge), returns\n432:  * undefined so the caller can omit the badge entirely rather than\n433:  * shipping a half-formed shape.\n434:  */\n435: function mergeTrustBadges(\n436:   explicit: MemoryTrustBadgePartial | null,\n437:   derived: MemoryTrustBadges | undefined,\n438: ): MemoryTrustBadges | undefined {\n439:   if (!explicit) return derived;\n440: \n441:   const confidence = explicit.confidence ?? derived?.confidence ?? null;\n442:   const extractionAge = explicit.extractionAge !== 'never' && explicit.extractionAge.length > 0\n443:     ? explicit.extractionAge\n444:     : (derived?.extractionAge ?? explicit.extractionAge);\n445:   const lastAccessAge = explicit.lastAccessAge !== 'never' && explicit.lastAccessAge.length > 0\n446:     ? explicit.lastAccessAge\n447:     : (derived?.lastAccessAge ?? explicit.lastAccessAge);\n448:   const orphan = explicit.orphan ?? derived?.orphan;\n449:   const weightHistoryChanged = explicit.weightHistoryChanged ?? derived?.weightHistoryChanged;\n450: \n451:   if (orphan === undefined || weightHistoryChanged === undefined) {\n452:     return undefined;\n453:   }\n454: \n455:   return {\n456:     confidence,\n457:     extractionAge,\n458:     lastAccessAge,\n459:     orphan,\n460:     weightHistoryChanged,\n461:   };\n462: }\n463: \n464: interface TrustBadgeFetchResult {\n465:   readonly snapshots: Map<number, TrustBadgeSnapshot>;\n466:   readonly attempted: boolean;\n467:   readonly derivedCount: number;\n468:   readonly failureReason:\n469:     | 'no_db'\n\n(Showing lines 300-469 of 1169. Use offset=470 to continue.)\n</content>","metadata":{"preview":"  const numeric = toNullableNumber(value);\n  if (numeric === null) return null;\n  return Math.max(0, Math.min(1, numeric));\n}\n\nfunction toExplainabilityRow(rawResult: RawSearchResult): Parameters<typeof attachExplainabilityToResults>[0][number] {\n  const finalRankScore = toNullableNumber(rawResult.finalRankScore);\n  if (finalRankScore === null) {\n    return rawResult as Parameters<typeof attachExplainabilityToResults>[0][number];\n  }\n\n  return {\n    ...rawResult,\n    intentAdjustedScore: Math.max(0, Math.min(1, finalRankScore)),\n  } as Parameters<typeof attachExplainabilityToResults>[0][number];\n}\n\nfunction deriveResponsePolicy(\n  requestQuality: RequestQualityAssessment | null,\n  recovery: RecoveryPayload | null,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts","text":"  const numeric = toNullableNumber(value);\n  if (numeric === null) return null;\n  return Math.max(0, Math.min(1, numeric));\n}\n\nfunction toExplainabilityRow(rawResult: RawSearchResult): Parameters<typeof attachExplainabilityToResults>[0][number] {\n  const finalRankScore = toNullableNumber(rawResult.finalRankScore);\n  if (finalRankScore === null) {\n    return rawResult as Parameters<typeof attachExplainabilityToResults>[0][number];\n  }\n\n  return {\n    ...rawResult,\n    intentAdjustedScore: Math.max(0, Math.min(1, finalRankScore)),\n  } as Parameters<typeof attachExplainabilityToResults>[0][number];\n}\n\nfunction deriveResponsePolicy(\n  requestQuality: RequestQualityAssessment | null,\n  recovery: RecoveryPayload | null,\n): ResponsePolicy | null {\n  if (!requestQuality || requestQuality.requestQuality?.label === 'good') return null;\n  if (!recovery) return null;\n\n  if (recovery.recommendedAction === 'ask_user' && recovery.suggestedQueries.length === 0) {\n    return {\n      requiredAction: 'ask_disambiguation',\n      noCanonicalPathClaims: true,\n      citationRequiredForPaths: true,\n      safeResponse: 'No canonical context found from the current retrieval. Ask a clarifying question or request a broader query.',\n    };\n  }\n\n  return {\n    requiredAction: 'broaden_or_ask',\n    noCanonicalPathClaims: true,\n    citationRequiredForPaths: true,\n    safeResponse: 'Retrieval quality is weak. Broaden the query or ask the user for disambiguation before citing any path.',\n  };\n}\n\nfunction deriveCitationPolicy(requestQuality: RequestQualityAssessment | null): CitationPolicy {\n  const label = requestQuality?.requestQuality?.label;\n  return label === 'good' ? 'cite_results' : 'do_not_cite_results';\n}\n\n/**\n * Allowlisted grammar for explicit `extractionAge`\n * `lastAccessAge` strings. Mirrors the output of `formatAgeString`:\n *\n *   never | today | yesterday |\n *   <n> days ago | <n> week ago | <n> weeks ago |\n *   <n> month ago | <n> months ago\n *\n * Strings that don't match are dropped to `null` rather than\n * passed through (which previously allowed arbitrary attacker-\n * controlled strings to surface in result badges). The numeric\n * portion is capped at 6 digits (max ~99,999 days, ~999,999\n * months) to prevent visual-spam injection.\n */\nconst ALLOWED_AGE_LABEL = /^(?:never|today|yesterday|\\d{1,6}\\s+(?:day|days|week|weeks|month|months)\\s+ago)$/;\nconst MAX_AGE_LABEL_LENGTH = 32;\n\nfunction sanitizeAgeLabel(value: unknown, fallbackIso: unknown): string {\n  if (typeof value === 'string') {\n    const trimmed = value.trim().toLowerCase();\n    if (trimmed.length <= MAX_AGE_LABEL_LENGTH && ALLOWED_AGE_LABEL.test(trimmed)) {\n      return trimmed;\n    }\n    // Explicit string supplied but failed allowlist — fall through\n    // to derivation rather than surfacing the raw value.\n  }\n  return formatAgeString(typeof fallbackIso === 'string' ? fallbackIso : null);\n}\n\n/**\n * Normalize a caller-supplied `trustBadges` payload into\n * a strict `MemoryTrustBadges` shape. Each field is sanitized\n * independently — `null` / wrong type means \"fall through to\n * derivation\" at merge time. Returns `null` only when the input is\n * not an object at all.\n */\nfunction normalizeExplicitTrustBadges(value: unknown): MemoryTrustBadgePartial | null {\n  if (!value || typeof value !== 'object') return null;\n  const candidate = value as Record<string, unknown>;\n  const confidence = clampConfidence(candidate.confidence);\n\n  // Age strings: allowlist or fallback to ISO-derived format.\n  const extractionAge = sanitizeAgeLabel(candidate.extractionAge, candidate.extractedAt);\n  const lastAccessAge = sanitizeAgeLabel(candidate.lastAccessAge, candidate.lastAccessed);\n\n  // Booleans: only `true` counts; anything else (including absent)\n  // falls through so the derived value can supply truth.\n  const orphan = typeof candidate.orphan === 'boolean' ? candidate.orphan : null;\n  const weightHistoryChanged = typeof candidate.weightHistoryChanged === 'boolean'\n    ? candidate.weightHistoryChanged\n    : null;\n\n  return {\n    confidence,\n    extractionAge,\n    lastAccessAge,\n    orphan,\n    weightHistoryChanged,\n  };\n}\n\ninterface MemoryTrustBadgePartial {\n  confidence: number | null;\n  extractionAge: string;\n  lastAccessAge: string;\n  orphan: boolean | null;\n  weightHistoryChanged: boolean | null;\n}\n\nexport function toTrustBadges(snapshot: TrustBadgeSnapshot | null): MemoryTrustBadges | undefined {\n  if (!snapshot) return undefined;\n  return {\n    confidence: snapshot.confidence,\n    extractionAge: formatAgeString(snapshot.extractedAt),\n    lastAccessAge: formatAgeString(snapshot.lastAccessed),\n    orphan: snapshot.orphan,\n    weightHistoryChanged: snapshot.weightHistoryChanged,\n  };\n}\n\n/**\n * Merge an explicit caller-supplied partial onto the\n * derived snapshot per-field. Non-null explicit fields override\n * matching derived fields; null/missing fields fall through to\n * derived. When `derived` is undefined and the explicit partial is\n * incomplete (any required field still null after merge), returns\n * undefined so the caller can omit the badge entirely rather than\n * shipping a half-formed shape.\n */\nfunction mergeTrustBadges(\n  explicit: MemoryTrustBadgePartial | null,\n  derived: MemoryTrustBadges | undefined,\n): MemoryTrustBadges | undefined {\n  if (!explicit) return derived;\n\n  const confidence = explicit.confidence ?? derived?.confidence ?? null;\n  const extractionAge = explicit.extractionAge !== 'never' && explicit.extractionAge.length > 0\n    ? explicit.extractionAge\n    : (derived?.extractionAge ?? explicit.extractionAge);\n  const lastAccessAge = explicit.lastAccessAge !== 'never' && explicit.lastAccessAge.length > 0\n    ? explicit.lastAccessAge\n    : (derived?.lastAccessAge ?? explicit.lastAccessAge);\n  const orphan = explicit.orphan ?? derived?.orphan;\n  const weightHistoryChanged = explicit.weightHistoryChanged ?? derived?.weightHistoryChanged;\n\n  if (orphan === undefined || weightHistoryChanged === undefined) {\n    return undefined;\n  }\n\n  return {\n    confidence,\n    extractionAge,\n    lastAccessAge,\n    orphan,\n    weightHistoryChanged,\n  };\n}\n\ninterface TrustBadgeFetchResult {\n  readonly snapshots: Map<number, TrustBadgeSnapshot>;\n  readonly attempted: boolean;\n  readonly derivedCount: number;\n  readonly failureReason:\n    | 'no_db'","lineStart":300,"lineEnd":469,"totalLines":1169,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts","time":{"start":1781764241267,"end":1781764241270}},"metadata":{"openai":{"itemId":"fc_0ef9904291217aa8016a339090f9f8819181213416ff8f5552"}},"id":"prt_ed96cb729001SJgmmkz8Mw5Hlh","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96c70bd001XdAPkqzC5UE2eG"}}
