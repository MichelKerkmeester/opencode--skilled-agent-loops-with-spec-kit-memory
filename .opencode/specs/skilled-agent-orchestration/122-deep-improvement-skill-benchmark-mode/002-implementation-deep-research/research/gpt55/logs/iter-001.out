   148	  readonly createAgentSkDocPenalty: number;
   149	  // create-testing-playbook intent
   150	  readonly createTestingPlaybookBonus: number;
   151	  readonly createTestingPlaybookSkDocPenalty: number;
   152	  readonly createTestingPlaybookOtherSkillsPenalty: number;
   153	}
   154	
   155	export interface ScoringCalibration {
