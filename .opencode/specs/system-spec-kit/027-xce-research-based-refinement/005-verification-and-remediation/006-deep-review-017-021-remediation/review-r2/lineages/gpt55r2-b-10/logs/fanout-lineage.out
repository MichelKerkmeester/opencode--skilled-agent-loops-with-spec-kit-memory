18:     expect(indexes[0].sql).toContain('WHERE deleted_at IS NULL');\n\n  Line 719:     expect(indexes[1].sql).toContain('WHERE deleted_at IS NOT NULL');\n\n  Line 724:       WHERE deleted_at IS NULL AND spec_folder = ?\n\n  Line 730:       WHERE deleted_at IS NOT NULL AND delete_after IS NOT NULL\n","metadata":{"matches":75,"truncated":false},"title":"deleted_at|tombstoneMemory|deleteMemory\\(","time":{"start":1781764242754,"end":1781764242779}},"metadata":{"openai":{"itemId":"fc_09a06c8bbd7bd3eb016a339092a66c819191abb600e09ad279"}},"id":"prt_ed96cbd41001Fzx48X2JwJGu1i","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c6f19001AvuEb9S058jVmN"}}
{"type":"tool_use","timestamp":1781764242881,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_XeZ0Ft5HWxXhULpfl1YxC9gy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Retention Sweep\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\n9: import { recordGovernanceAudit } from './scope-governance.js';\n10: import { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\n11: import type { AggregatedSignal } from '../feedback/batch-learning.js';\n12: import {\n13:   evaluateFeedbackRetention,\n14:   isFeedbackRetentionLearningEnabled,\n15:   recordFeedbackRetentionAudit,\n16:   resolveFeedbackRetentionMode,\n17: } from '../feedback/feedback-retention-reducer.js';\n18: import type {\n19:   FeedbackRetentionDecisionResult,\n20:   FeedbackRetentionMode,\n21: } from '../feedback/feedback-retention-reducer.js';\n22: \n23: import type Database from 'better-sqlite3';\n24: \n25: /** Options for a governed memory retention sweep. */\n26: export interface MemoryRetentionSweepArgs {\n27:   dryRun?: boolean;\n28:   feedbackRetention?: FeedbackRetentionSweepArgs;\n29: }\n30: \n31: /** Options for the feedback-aware retention learning branch. */\n32: export interface FeedbackRetentionSweepArgs {\n33:   runAt?: number;\n34:   windowMs?: number;\n35:   extendDays?: number;\n36:   shadowEvaluationPassed?: boolean;\n37:   signals?: AggregatedSignal[];\n38: }\n39: \n40: /**\n41:  * Expired memory_index row selected for retention deletion.\n42:  *\n43:  * Beyond `delete_after`, the row carries tier and usage metadata so the\n44:  * destructive delete decision can protect high-tier and pinned records:\n45:  * deletion must never be driven by TTL expiry alone.\n46:  */\n47: export interface RetentionExpiredRow {\n48:   id: number;\n49:   specFolder: string | null;\n50:   filePath: string | null;\n51:   contentHash: string | null;\n52:   tenantId: string | null;\n53:   userId: string | null;\n54:   agentId: string | null;\n55:   sessionId: string | null;\n56:   deleteAfter: string;\n57:   importanceTier: string | null;\n58:   decayHalfLifeDays: number | null;\n59:   isPinned: number | null;\n60:   accessCount: number | null;\n61:   lastAccessed: string | number | null;\n62:   deletedAt: string | null;\n63: }\n64: \n65: /** Aggregate sweep counts returned to callers and audit logs. */\n66: export interface MemoryRetentionSweepSummary {\n67:   swept: number;\n68:   retained: number;\n69:   protectedCount: number;\n70:   dryRun: boolean;\n71:   durationMs: number;\n72: }\n73: \n74: /** Full sweep result including candidates, deletions, and ledger state. */\n75: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n76:   candidates: RetentionExpiredRow[];\n77:   deletedIds: number[];\n78:   protectedIds: number[];\n79:   extendedIds?: number[];\n80:   ledgerRecorded: boolean | null;\n81:   feedbackRetention?: FeedbackRetentionSweepReport;\n82:   tombstoneState: {\n83:     usesPurgeablePartition: boolean;\n84:     usingPurgeableIndex: boolean;\n85:     candidateCount: number;\n86:     deletedCount: number;\n87:   };\n88:   edgeState: {\n89:     causalEdgesTablePresent: boolean;\n90:     candidateEdgeCount: number;\n91:   };\n92: }\n93: \n94: /** Feedback-retention learning summary included only when the feature is enabled. */\n95: export interface FeedbackRetentionSweepReport {\n96:   mode: FeedbackRetentionMode;\n97:   activeGatePassed: boolean;\n98:   activeBlocked: boolean;\n99:   auditCount: number;\n100:   decisions: FeedbackRetentionDecisionResult[];\n101:   extendedIds: number[];\n102:   protectedIds: number[];\n103:   deletedIds: number[];\n104: }\n105: \n106: function hasTable(database: Database.Database, tableName: string): boolean {\n107:   const row = database.prepare(\n108:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n109:   ).get(tableName) as { present?: number } | undefined;\n110:   return row?.present === 1;\n111: }\n112: \n113: function hasIndex(database: Database.Database, indexName: string): boolean {\n114:   const row = database.prepare(\n115:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n116:   ).get(indexName) as { present?: number } | undefined;\n117:   return row?.present === 1;\n118: }\n119: \n120: /**\n121:  * Tier/usage columns may be absent on legacy databases that predate the\n122:  * corresponding migrations. Missing columns are selected as NULL so the\n123:  * protection decision degrades conservatively instead of crashing the sweep.\n124:  */\n125: const OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n126:   { column: 'importance_tier', alias: 'importanceTier' },\n127:   { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n128:   { column: 'is_pinned', alias: 'isPinned' },\n129:   { column: 'access_count', alias: 'accessCount' },\n130:   { column: 'last_accessed', alias: 'lastAccessed' },\n131: ];\n132: \n133: function isSoftDeleteTombstonesEnabled(): boolean {\n134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n135: }\n136: \n137: function selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n138:   const presentColumns = new Set(\n139:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n140:       .map((row) => row.name),\n141:   );\n142:   const hasDeletedAt = presentColumns.has('deleted_at');\n143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n144:   const memoryIndexSource = usePurgeableIndex\n145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n146:     : 'memory_index';\n147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n149:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n150:     .map(({ column, alias }) => (presentColumns.has(column)\n151:       ? `${column} AS ${alias}`\n152:       : `NULL AS ${alias}`))\n153:     .join(',\\n      ');\n154: \n155:   return database.prepare(`\n156:     SELECT\n157:       id,\n158:       spec_folder AS specFolder,\n159:       file_path AS filePath,\n160:       content_hash AS contentHash,\n161:       tenant_id AS tenantId,\n162:       user_id AS userId,\n163:       agent_id AS agentId,\n164:       session_id AS sessionId,\n165:       delete_after AS deleteAfter,\n166:       ${deletedAtSelect},\n167:       ${optionalSelects}\n168:     FROM ${memoryIndexSource}\n169:     WHERE delete_after IS NOT NULL\n170:       ${tombstonePredicate}\n171:       AND datetime(delete_after) < datetime('now')\n172:     ORDER BY datetime(delete_after) ASC, id ASC\n173:   `).all() as RetentionExpiredRow[];\n174: }\n175: \n176: /** Importance tiers that must never be deleted on TTL expiry alone. */\n177: const PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n178: \n179: /**\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n191:   }\n192:   return row.isPinned != null && Number(row.isPinned) !== 0;\n193: }\n194: \n195: // Re-validate inside the delete transaction: a concurrent writer can raise or\n196: // clear delete_after between candidate selection and deletion, so a row that is\n197: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n198: function getCurrentExpiredRow(\n199:   database: Database.Database,\n200:   id: number,\n201:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n202: ): RetentionExpiredRow | null {\n203:   const presentColumns = new Set(\n204:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n205:       .map((row) => row.name),\n206:   );\n207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n209:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n210:     .map(({ column, alias }) => (presentColumns.has(column)\n211:       ? `${column} AS ${alias}`\n212:       : `NULL AS ${alias}`))\n213:     .join(',\\n      ');\n214:   const row = database.prepare(`\n215:     SELECT\n216:       id,\n217:       spec_folder AS specFolder,\n218:       file_path AS filePath,\n219:       content_hash AS contentHash,\n220:       tenant_id AS tenantId,\n221:       user_id AS userId,\n222:       agent_id AS agentId,\n223:       session_id AS sessionId,\n224:       delete_after AS deleteAfter,\n225:       ${deletedAtSelect},\n226:       ${optionalSelects}\n227:     FROM memory_index\n228:     WHERE id = ?\n229:       AND delete_after IS NOT NULL\n230:       ${tombstonePredicate}\n231:       AND datetime(delete_after) < datetime('now')\n232:     LIMIT 1\n233:   `).get(id) as RetentionExpiredRow | undefined;\n234:   return row ?? null;\n235: }\n236: \n237: function isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n238:   return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n239: }\n240: \n241: /** Test-only surface for the retention TOCTOU guard. */\n242: export const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n243: \n244: function countRows(database: Database.Database): number {\n245:   const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n246:   return row.count;\n247: }\n248: \n249: function buildTombstoneState(\n250:   database: Database.Database,\n251:   candidateCount: number,\n252:   deletedCount: number,\n253:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n254: ): MemoryRetentionSweepResult['tombstoneState'] {\n255:   const columns = new Set(\n256:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n257:       .map((row) => row.name),\n258:   );\n259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n260:   return {\n261:     usesPurgeablePartition,\n262:     usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n263:     candidateCount,\n264:     deletedCount,\n265:   };\n266: }\n267: \n268: function buildEdgeState(\n269:   database: Database.Database,\n270:   candidates: RetentionExpiredRow[],\n271: ): MemoryRetentionSweepResult['edgeState'] {\n272:   if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n273:     return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n274:   }\n275:   const ids = candidates.map((candidate) => String(candidate.id));\n276:   const placeholders = ids.map(() => '?').join(', ');\n277:   const row = database.prepare(`\n278:     SELECT COUNT(*) AS count\n279:     FROM causal_edges\n280:     WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n281:   `).get(...ids, ...ids) as { count: number };\n282:   return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n283: }\n284: \n285: function buildFeedbackRetentionReport(\n286:   database: Database.Database,\n287:   candidates: RetentionExpiredRow[],\n288:   dryRun: boolean,\n289:   args: FeedbackRetentionSweepArgs = {},\n290: ): FeedbackRetentionSweepReport {\n291:   const mode = resolveFeedbackRetentionMode();\n292:   const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n293:   // Dry-run previews must evaluate the SAME real signal window the apply\n294:   // path would see вҖ” aggregation is a pure read, and an empty-signal preview\n295:   // told operators nothing about what apply would actually do. The audit\n296:   // write path stays unreachable in dry-run (the sweep returns before it).\n297:   const signals = args.signals ?? aggregateEvents(\n298:     database,\n299:     (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n300:     args.runAt ?? Date.now(),\n301:   );\n302:   const evaluation = evaluateFeedbackRetention(candidates, signals, {\n303:     runAt: args.runAt,\n304:     extendDays: args.extendDays,\n305:   });\n306: \n307:   return {\n308:     mode,\n309:     activeGatePassed,\n310:     activeBlocked: mode === 'active' && !activeGatePassed,\n311:     auditCount: 0,\n312:     decisions: evaluation.decisions,\n313:     extendedIds: [],\n314:     protectedIds: evaluation.decisions\n315:       .filter((decision) => decision.decision === 'protect')\n316:       .map((decision) => decision.memoryId),\n317:     deletedIds: [],\n318:   };\n319: }\n320: \n321: function recordFeedbackRetentionAudits(\n322:   database: Database.Database,\n323:   candidates: RetentionExpiredRow[],\n324:   report: FeedbackRetentionSweepReport,\n325:   applied: boolean,\n326: ): number {\n327:   const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n328:   let auditCount = 0;\n329:   for (const decision of report.decisions) {\n330:     const row = rowsById.get(decision.memoryId);\n331:     if (!row) continue;\n332:     recordFeedbackRetentionAudit(database, row, decision, {\n333:       mode: report.mode,\n334:       applied,\n335:       activeGatePassed: report.activeGatePassed,\n336:     });\n337:     auditCount += 1;\n338:   }\n339:   return auditCount;\n340: }\n341: \n342: function appendRetentionLedger(\n343:   database: Database.Database,\n344:   deletedIds: number[],\n345:   candidates: RetentionExpiredRow[],\n346: ): boolean {\n347:   try {\n348:     mutationLedger.initLedger(database);\n349:     mutationLedger.appendEntry(database, {\n350:       mutation_type: 'delete',\n351:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n352:       prior_hash: null,\n353:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n354:       linked_memory_ids: deletedIds.slice(0, 50),\n355:       decision_meta: {\n356:         tool: 'memory_retention_sweep',\n357:         reason: 'retention_expired',\n358:         totalDeleted: deletedIds.length,\n359:         originalDeleteAfter: candidates\n360:           .filter((candidate) => deletedIds.includes(candidate.id))\n361:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n362:       },\n363:       actor: 'mcp:memory_retention_sweep',\n364:     });\n365:     return true;\n366:   } catch (error: unknown) {\n367:     const message = error instanceof Error ? error.message : String(error);\n368:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n369:     return false;\n370:   }\n371: }\n372: \n373: function runPostDeleteMaintenance(database: Database.Database): void {\n374:   try {\n375:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n376:   } catch (error: unknown) {\n377:     const message = error instanceof Error ? error.message : String(error);\n378:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n379:   }\n380: \n381:   const maintenance = new BetterSqliteMaintenance(database, {\n382:     onMaintenanceError: reportRetentionMaintenanceError,\n383:   });\n384:   maintenance.vacuum();\n385:   maintenance.checkpoint({ mode: 'truncate' });\n386: }\n387: \n388: function reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n389:   const message = error instanceof Error ? error.message : String(error);\n390:   if (operation === 'auto_vacuum') {\n391:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n392:   } else if (operation === 'incremental_vacuum') {\n393:     console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n394:   } else if (operation === 'wal_checkpoint') {\n395:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n396:   }\n397: }\n398: \n399: /**\n400:  * Sweep expired governed memory rows.\n401:  *\n402:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n403:  * to enforce the ISO timestamps persisted by governed ingest.\n404:  */\n405: export function runMemoryRetentionSweep(\n406:   database: Database.Database,\n407:   args: MemoryRetentionSweepArgs = {},\n408: ): MemoryRetentionSweepResult {\n409:   const startTime = Date.now();\n410:   const dryRun = args.dryRun === true;\n411:   const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n412: \n413:   if (!hasTable(database, 'memory_index')) {\n414:     return {\n415:       swept: 0,\n416:       retained: 0,\n417:       protectedCount: 0,\n418:       dryRun,\n419:       durationMs: Date.now() - startTime,\n420:       candidates: [],\n421:       deletedIds: [],\n422:       protectedIds: [],\n423:       ledgerRecorded: null,\n424:       tombstoneState: {\n425:         usesPurgeablePartition: false,\n426:         usingPurgeableIndex: false,\n427:         candidateCount: 0,\n428:         deletedCount: 0,\n429:       },\n430:       edgeState: {\n431:         causalEdgesTablePresent: false,\n432:         candidateEdgeCount: 0,\n433:       },\n434:     };\n435:   }\n436: \n437:   const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n438:   const initialEdgeState = buildEdgeState(database, candidates);\n439:   const feedbackRetention = isFeedbackRetentionLearningEnabled()\n440:     ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n441:     : null;\n442: \n443:   if (dryRun || candidates.length === 0) {\n444:     const totalRows = countRows(database);\n445:     const dryRunProtectedIds = candidates\n446:       .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n447:       .map((candidate) => candidate.id);\n448:     return {\n449:       swept: 0,\n450:       retained: totalRows,\n451:       protectedCount: dryRunProtectedIds.length,\n452:       dryRun,\n453:       durationMs: Date.now() - startTime,\n454:       candidates,\n455:       deletedIds: [],\n456:       protectedIds: dryRunProtectedIds,\n457:       ledgerRecorded: null,\n458:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n459:       edgeState: initialEdgeState,\n460:       ...(feedbackRetention ? { feedbackRetention } : {}),\n461:     };\n462:   }\n463: \n464:   if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n465:     const auditTx = database.transaction(() => {\n466:       feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n467:         database,\n468:         candidates,\n469:         feedbackRetention,\n470:         false,\n471:       );\n472:     });\n473:     auditTx();\n474: \n475:     return {\n476:       swept: 0,\n477:       retained: countRows(database),\n478:       protectedCount: feedbackRetention.protectedIds.length,\n479:       dryRun,\n480:       durationMs: Date.now() - startTime,\n481:       candidates,\n482:       deletedIds: [],\n483:       protectedIds: feedbackRetention.protectedIds,\n484:       extendedIds: [],\n485:       ledgerRecorded: null,\n486:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n487:       edgeState: initialEdgeState,\n488:       feedbackRetention,\n489:     };\n490:   }\n491: \n492:   initHistory(database);\n493: \n494:   const deletedIds: number[] = [];\n495:   const protectedIds: number[] = [];\n496:   const extendedIds: number[] = [];\n497:   let ledgerRecorded: boolean | null = null;\n498: \n499:   const sweepTx = database.transaction(() => {\n500:     for (const candidate of candidates) {\n501:       // TOCTOU guard: skip rows un-expired by another writer since selection.\n502:       const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n503:       if (!currentCandidate) {\n504:         continue;\n505:       }\n506:       let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n507:       if (feedbackRetention) {\n508:         const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n509:         if (!decision) {\n510:           continue;\n511:         }\n512: \n513:         if (decision.decision === 'protect') {\n514:           database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n515:           protectedIds.push(candidate.id);\n516:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n517:             mode: feedbackRetention.mode,\n518:             applied: true,\n519:             activeGatePassed: feedbackRetention.activeGatePassed,\n520:           });\n521:           feedbackRetention.auditCount += 1;\n522:           continue;\n523:         }\n524: \n525:         if (decision.decision === 'extend') {\n526:           database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n527:             decision.nextDeleteAfter,\n528:             candidate.id,\n529:           );\n530:           extendedIds.push(candidate.id);\n531:           recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n532:             mode: feedbackRetention.mode,\n533:             applied: true,\n534:             activeGatePassed: feedbackRetention.activeGatePassed,\n535:           });\n536:           feedbackRetention.auditCount += 1;\n537:           continue;\n538:         }\n539:         feedbackDeleteDecision = decision;\n540:       }\n541:       // Tier basement: protected rows are never deleted on TTL expiry alone.\n542:       // Audited as decision='deny' (the delete was denied) with a protection reason.\n543:       if (isProtectedFromRetentionDelete(currentCandidate)) {\n544:         if (feedbackRetention && feedbackDeleteDecision) {\n545:           recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n546:             mode: feedbackRetention.mode,\n547:             applied: false,\n548:             activeGatePassed: feedbackRetention.activeGatePassed,\n549:           });\n550:           feedbackRetention.auditCount += 1;\n551:         }\n552:         protectedIds.push(currentCandidate.id);\n553:         recordGovernanceAudit(database, {\n554:           action: 'retention_sweep',\n555:           decision: 'deny',\n556:           memoryId: currentCandidate.id,\n557:           logicalKey: currentCandidate.filePath,\n558:           tenantId: currentCandidate.tenantId ?? undefined,\n559:           userId: currentCandidate.userId ?? undefined,\n560:           agentId: currentCandidate.agentId ?? undefined,\n561:           sessionId: currentCandidate.sessionId ?? undefined,\n562:           reason: 'retention_tier_protected',\n563:           metadata: {\n564:             originalDeleteAfter: currentCandidate.deleteAfter,\n565:             importanceTier: currentCandidate.importanceTier,\n566:             isPinned: currentCandidate.isPinned,\n567:             specFolder: currentCandidate.specFolder,\n568:             filePath: currentCandidate.filePath,\n569:           },\n570:         });\n571:         continue;\n572:       }\n573:       if (feedbackRetention && feedbackDeleteDecision) {\n574:         recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n575:           mode: feedbackRetention.mode,\n576:           applied: true,\n577:           activeGatePassed: feedbackRetention.activeGatePassed,\n578:         });\n579:         feedbackRetention.auditCount += 1;\n580:       }\n581:       const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n582:       if (!deleted) {\n583:         continue;\n584:       }\n585: \n586:       deletedIds.push(currentCandidate.id);\n587: \n588:       recordHistory(\n589:         currentCandidate.id,\n590:         'DELETE',\n591:         {\n592:           reason: 'retention_expired',\n593:           deleteAfter: currentCandidate.deleteAfter,\n594:           filePath: currentCandidate.filePath,\n595:         },\n596:         null,\n597:         'mcp:memory_retention_sweep',\n598:         currentCandidate.specFolder,\n599:       );\n600: \n601:       recordGovernanceAudit(database, {\n602:         action: 'retention_sweep',\n603:         decision: 'delete',\n604:         memoryId: currentCandidate.id,\n605:         logicalKey: currentCandidate.filePath,\n606:         tenantId: currentCandidate.tenantId ?? undefined,\n607:         userId: currentCandidate.userId ?? undefined,\n608:         agentId: currentCandidate.agentId ?? undefined,\n609:         sessionId: currentCandidate.sessionId ?? undefined,\n610:         reason: 'retention_expired',\n611:         metadata: {\n612:           originalDeleteAfter: currentCandidate.deleteAfter,\n613:           delete_after: currentCandidate.deleteAfter,\n614:           specFolder: currentCandidate.specFolder,\n615:           filePath: currentCandidate.filePath,\n616:         },\n617:       });\n618:     }\n619: \n620:     if (deletedIds.length > 0) {\n621:       ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n622:     }\n623:   });\n624: \n625:   sweepTx();\n626:   if (deletedIds.length > 0) {\n627:     runPostDeleteMaintenance(database);\n628:   }\n629:   if (feedbackRetention) {\n630:     feedbackRetention.extendedIds = extendedIds;\n631:     feedbackRetention.protectedIds = protectedIds;\n632:     feedbackRetention.deletedIds = deletedIds;\n633:   }\n634: \n635:   return {\n636:     swept: deletedIds.length,\n637:     retained: countRows(database),\n638:     protectedCount: protectedIds.length,\n639:     dryRun,\n640:     durationMs: Date.now() - startTime,\n641:     candidates,\n642:     deletedIds,\n643:     protectedIds,\n644:     ledgerRecorded,\n645:     tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n646:     edgeState: initialEdgeState,\n647:     ...(feedbackRetention ? { extendedIds } : {}),\n648:     ...(feedbackRetention ? { feedbackRetention } : {}),\n649:   };\n650: }\n\n(End of file - total 650 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Retention Sweep\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Retention Sweep\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n  feedbackRetention?: FeedbackRetentionSweepArgs;\n}\n\n/** Options for the feedback-aware retention learning branch. */\nexport interface FeedbackRetentionSweepArgs {\n  runAt?: number;\n  windowMs?: number;\n  extendDays?: number;\n  shadowEvaluationPassed?: boolean;\n  signals?: AggregatedSignal[];\n}\n\n/**\n * Expired memory_index row selected for retention deletion.\n *\n * Beyond `delete_after`, the row carries tier and usage metadata so the\n * destructive delete decision can protect high-tier and pinned records:\n * deletion must never be driven by TTL expiry alone.\n */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n  importanceTier: string | null;\n  decayHalfLifeDays: number | null;\n  isPinned: number | null;\n  accessCount: number | null;\n  lastAccessed: string | number | null;\n  deletedAt: string | null;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  protectedCount: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  protectedIds: number[];\n  extendedIds?: number[];\n  ledgerRecorded: boolean | null;\n  feedbackRetention?: FeedbackRetentionSweepReport;\n  tombstoneState: {\n    usesPurgeablePartition: boolean;\n    usingPurgeableIndex: boolean;\n    candidateCount: number;\n    deletedCount: number;\n  };\n  edgeState: {\n    causalEdgesTablePresent: boolean;\n    candidateEdgeCount: number;\n  };\n}\n\n/** Feedback-retention learning summary included only when the feature is enabled. */\nexport interface FeedbackRetentionSweepReport {\n  mode: FeedbackRetentionMode;\n  activeGatePassed: boolean;\n  activeBlocked: boolean;\n  auditCount: number;\n  decisions: FeedbackRetentionDecisionResult[];\n  extendedIds: number[];\n  protectedIds: number[];\n  deletedIds: number[];\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction hasIndex(database: Database.Database, indexName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n  ).get(indexName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\n/**\n * Tier/usage columns may be absent on legacy databases that predate the\n * corresponding migrations. Missing columns are selected as NULL so the\n * protection decision degrades conservatively instead of crashing the sweep.\n */\nconst OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n  { column: 'importance_tier', alias: 'importanceTier' },\n  { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n  { column: 'is_pinned', alias: 'isPinned' },\n  { column: 'access_count', alias: 'accessCount' },\n  { column: 'last_accessed', alias: 'lastAccessed' },\n];\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const hasDeletedAt = presentColumns.has('deleted_at');\n  const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n  const memoryIndexSource = usePurgeableIndex\n    ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n    : 'memory_index';\n  const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM ${memoryIndexSource}\n    WHERE delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n/** Importance tiers that must never be deleted on TTL expiry alone. */\nconst PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n\n/**\n * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,\n  id: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): RetentionExpiredRow | null {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n  const row = database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as RetentionExpiredRow | undefined;\n  return row ?? null;\n}\n\nfunction isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n  return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n}\n\n/** Test-only surface for the retention TOCTOU guard. */\nexport const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n\nfunction countRows(database: Database.Database): number {\n  const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n  return row.count;\n}\n\nfunction buildTombstoneState(\n  database: Database.Database,\n  candidateCount: number,\n  deletedCount: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): MemoryRetentionSweepResult['tombstoneState'] {\n  const columns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n  return {\n    usesPurgeablePartition,\n    usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n    candidateCount,\n    deletedCount,\n  };\n}\n\nfunction buildEdgeState(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n): MemoryRetentionSweepResult['edgeState'] {\n  if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n    return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n  }\n  const ids = candidates.map((candidate) => String(candidate.id));\n  const placeholders = ids.map(() => '?').join(', ');\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM causal_edges\n    WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n  `).get(...ids, ...ids) as { count: number };\n  return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n}\n\nfunction buildFeedbackRetentionReport(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  dryRun: boolean,\n  args: FeedbackRetentionSweepArgs = {},\n): FeedbackRetentionSweepReport {\n  const mode = resolveFeedbackRetentionMode();\n  const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n  // Dry-run previews must evaluate the SAME real signal window the apply\n  // path would see вҖ” aggregation is a pure read, and an empty-signal preview\n  // told operators nothing about what apply would actually do. The audit\n  // write path stays unreachable in dry-run (the sweep returns before it).\n  const signals = args.signals ?? aggregateEvents(\n    database,\n    (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n    args.runAt ?? Date.now(),\n  );\n  const evaluation = evaluateFeedbackRetention(candidates, signals, {\n    runAt: args.runAt,\n    extendDays: args.extendDays,\n  });\n\n  return {\n    mode,\n    activeGatePassed,\n    activeBlocked: mode === 'active' && !activeGatePassed,\n    auditCount: 0,\n    decisions: evaluation.decisions,\n    extendedIds: [],\n    protectedIds: evaluation.decisions\n      .filter((decision) => decision.decision === 'protect')\n      .map((decision) => decision.memoryId),\n    deletedIds: [],\n  };\n}\n\nfunction recordFeedbackRetentionAudits(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  report: FeedbackRetentionSweepReport,\n  applied: boolean,\n): number {\n  const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n  let auditCount = 0;\n  for (const decision of report.decisions) {\n    const row = rowsById.get(decision.memoryId);\n    if (!row) continue;\n    recordFeedbackRetentionAudit(database, row, decision, {\n      mode: report.mode,\n      applied,\n      activeGatePassed: report.activeGatePassed,\n    });\n    auditCount += 1;\n  }\n  return auditCount;\n}\n\nfunction appendRetentionLedger(\n  database: Database.Database,\n  deletedIds: number[],\n  candidates: RetentionExpiredRow[],\n): boolean {\n  try {\n    mutationLedger.initLedger(database);\n    mutationLedger.appendEntry(database, {\n      mutation_type: 'delete',\n      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  const maintenance = new BetterSqliteMaintenance(database, {\n    onMaintenanceError: reportRetentionMaintenanceError,\n  });\n  maintenance.vacuum();\n  maintenance.checkpoint({ mode: 'truncate' });\n}\n\nfunction reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  if (operation === 'auto_vacuum') {\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  } else if (operation === 'incremental_vacuum') {\n    console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n  } else if (operation === 'wal_checkpoint') {\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n  const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      protectedCount: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      protectedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 0,\n        deletedCount: 0,\n      },\n      edgeState: {\n        causalEdgesTablePresent: false,\n        candidateEdgeCount: 0,\n      },\n    };\n  }\n\n  const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n  const initialEdgeState = buildEdgeState(database, candidates);\n  const feedbackRetention = isFeedbackRetentionLearningEnabled()\n    ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n    : null;\n\n  if (dryRun || candidates.length === 0) {\n    const totalRows = countRows(database);\n    const dryRunProtectedIds = candidates\n      .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n      .map((candidate) => candidate.id);\n    return {\n      swept: 0,\n      retained: totalRows,\n      protectedCount: dryRunProtectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: dryRunProtectedIds,\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      ...(feedbackRetention ? { feedbackRetention } : {}),\n    };\n  }\n\n  if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n    const auditTx = database.transaction(() => {\n      feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n        database,\n        candidates,\n        feedbackRetention,\n        false,\n      );\n    });\n    auditTx();\n\n    return {\n      swept: 0,\n      retained: countRows(database),\n      protectedCount: feedbackRetention.protectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: feedbackRetention.protectedIds,\n      extendedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      feedbackRetention,\n    };\n  }\n\n  initHistory(database);\n\n  const deletedIds: number[] = [];\n  const protectedIds: number[] = [];\n  const extendedIds: number[] = [];\n  let ledgerRecorded: boolean | null = null;\n\n  const sweepTx = database.transaction(() => {\n    for (const candidate of candidates) {\n      // TOCTOU guard: skip rows un-expired by another writer since selection.\n      const currentCandidate = getCurrentExpiredRow(database, candidate.id, useSoftDeleteTombstones);\n      if (!currentCandidate) {\n        continue;\n      }\n      let feedbackDeleteDecision: FeedbackRetentionDecisionResult | null = null;\n      if (feedbackRetention) {\n        const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n        if (!decision) {\n          continue;\n        }\n\n        if (decision.decision === 'protect') {\n          database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n          protectedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n\n        if (decision.decision === 'extend') {\n          database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n            decision.nextDeleteAfter,\n            candidate.id,\n          );\n          extendedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, currentCandidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n        feedbackDeleteDecision = decision;\n      }\n      // Tier basement: protected rows are never deleted on TTL expiry alone.\n      // Audited as decision='deny' (the delete was denied) with a protection reason.\n      if (isProtectedFromRetentionDelete(currentCandidate)) {\n        if (feedbackRetention && feedbackDeleteDecision) {\n          recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n            mode: feedbackRetention.mode,\n            applied: false,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n        }\n        protectedIds.push(currentCandidate.id);\n        recordGovernanceAudit(database, {\n          action: 'retention_sweep',\n          decision: 'deny',\n          memoryId: currentCandidate.id,\n          logicalKey: currentCandidate.filePath,\n          tenantId: currentCandidate.tenantId ?? undefined,\n          userId: currentCandidate.userId ?? undefined,\n          agentId: currentCandidate.agentId ?? undefined,\n          sessionId: currentCandidate.sessionId ?? undefined,\n          reason: 'retention_tier_protected',\n          metadata: {\n            originalDeleteAfter: currentCandidate.deleteAfter,\n            importanceTier: currentCandidate.importanceTier,\n            isPinned: currentCandidate.isPinned,\n            specFolder: currentCandidate.specFolder,\n            filePath: currentCandidate.filePath,\n          },\n        });\n        continue;\n      }\n      if (feedbackRetention && feedbackDeleteDecision) {\n        recordFeedbackRetentionAudit(database, currentCandidate, feedbackDeleteDecision, {\n          mode: feedbackRetention.mode,\n          applied: true,\n          activeGatePassed: feedbackRetention.activeGatePassed,\n        });\n        feedbackRetention.auditCount += 1;\n      }\n      const deleted = vectorIndex.deleteMemory(currentCandidate.id, database);\n      if (!deleted) {\n        continue;\n      }\n\n      deletedIds.push(currentCandidate.id);\n\n      recordHistory(\n        currentCandidate.id,\n        'DELETE',\n        {\n          reason: 'retention_expired',\n          deleteAfter: currentCandidate.deleteAfter,\n          filePath: currentCandidate.filePath,\n        },\n        null,\n        'mcp:memory_retention_sweep',\n        currentCandidate.specFolder,\n      );\n\n      recordGovernanceAudit(database, {\n        action: 'retention_sweep',\n        decision: 'delete',\n        memoryId: currentCandidate.id,\n        logicalKey: currentCandidate.filePath,\n        tenantId: currentCandidate.tenantId ?? undefined,\n        userId: currentCandidate.userId ?? undefined,\n        agentId: currentCandidate.agentId ?? undefined,\n        sessionId: currentCandidate.sessionId ?? undefined,\n        reason: 'retention_expired',\n        metadata: {\n          originalDeleteAfter: currentCandidate.deleteAfter,\n          delete_after: currentCandidate.deleteAfter,\n          specFolder: currentCandidate.specFolder,\n          filePath: currentCandidate.filePath,\n        },\n      });\n    }\n\n    if (deletedIds.length > 0) {\n      ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n    }\n  });\n\n  sweepTx();\n  if (deletedIds.length > 0) {\n    runPostDeleteMaintenance(database);\n  }\n  if (feedbackRetention) {\n    feedbackRetention.extendedIds = extendedIds;\n    feedbackRetention.protectedIds = protectedIds;\n    feedbackRetention.deletedIds = deletedIds;\n  }\n\n  return {\n    swept: deletedIds.length,\n    retained: countRows(database),\n    protectedCount: protectedIds.length,\n    dryRun,\n    durationMs: Date.now() - startTime,\n    candidates,\n    deletedIds,\n    protectedIds,\n    ledgerRecorded,\n    tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n    edgeState: initialEdgeState,\n    ...(feedbackRetention ? { extendedIds } : {}),\n    ...(feedbackRetention ? { feedbackRetention } : {}),\n  };\n}","lineStart":1,"lineEnd":650,"totalLines":650,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781764242875,"end":1781764242879}},"metadata":{"openai":{"itemId":"fc_09a06c8bbd7bd3eb016a339092a6788191b4e331bb0431b1cf"}},"id":"prt_ed96cbd45001VcfIPFUlUtDtMi","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c6f19001AvuEb9S058jVmN"}}
{"type":"tool_use","timestamp":1781764242883,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_bI1y34TZDU5kx3Yihc1ovelY","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Transaction Manager\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Atomic file + index operations with pending file recovery\n6: import type Database from 'better-sqlite3';\n7: import * as fs from 'fs';\n8: import * as path from 'path';\n9: import { resolveDatabasePaths } from '../../core/config.js';\n10: \n11: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n12:    1. CONSTANTS\n13: ----------------------------------------------------------------*/\n14: \n15: const PENDING_SUFFIX = '_pending';\n16: const TEMP_SUFFIX = '.tmp';\n17: const PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n18: \n19: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n20:    2. INTERFACES\n21: ----------------------------------------------------------------*/\n22: \n23: interface TransactionMetrics {\n24:   totalAtomicWrites: number;\n25:   totalDeletes: number;\n26:   totalRecoveries: number;\n27:   totalErrors: number;\n28:   lastOperationTime: string | null;\n29:   [key: string]: unknown;\n30: }\n31: \n32: interface AtomicSaveResult {\n33:   success: boolean;\n34:   filePath: string;\n35:   error?: string;\n36:   /** Set when DB committed but rename failed, indicating partial state */\n37:   dbCommitted?: boolean;\n38: }\n39: \n40: interface RecoveryResult {\n41:   path: string;\n42:   recovered: boolean;\n43:   error?: string;\n44: }\n45: \n46: /**\n47:  * Optional database probe used during pending-file recovery.\n48:  * Return `true` when the original path already has a committed `memory_index` row.\n49:  * Return `false` to leave the `_pending` file in place for manual review.\n50:  * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n51:  */\n52: type IsCommittedCheck = (originalPath: string) => boolean;\n53: \n54: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n55:    3. MODULE STATE\n56: ----------------------------------------------------------------*/\n57: \n58: const metrics: TransactionMetrics = {\n59:   totalAtomicWrites: 0,\n60:   totalDeletes: 0,\n61:   totalRecoveries: 0,\n62:   totalErrors: 0,\n63:   lastOperationTime: null,\n64: };\n65: \n66: const activeTransactions = new WeakMap<object, number>();\n67: \n68: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n69:    4. METRICS\n70: ----------------------------------------------------------------*/\n71: \n72: function getMetrics(): TransactionMetrics {\n73:   return { ...metrics };\n74: }\n75: \n76: function resetMetrics(): void {\n77:   metrics.totalAtomicWrites = 0;\n78:   metrics.totalDeletes = 0;\n79:   metrics.totalRecoveries = 0;\n80:   metrics.totalErrors = 0;\n81:   metrics.lastOperationTime = null;\n82: }\n83: \n84: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n85:    5. PATH HELPERS\n86: ----------------------------------------------------------------*/\n87: \n88: function getPendingPath(filePath: string): string {\n89:   const dir = path.dirname(filePath);\n90:   const ext = path.extname(filePath);\n91:   const base = path.basename(filePath, ext);\n92:   return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n93: }\n94: \n95: interface PendingPathInfo {\n96:   originalPath: string;\n97:   basePendingPath: string;\n98:   uniqueSuffix: string | null;\n99: }\n100: \n101: function parsePendingPath(filePath: string): PendingPathInfo | null {\n102:   const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n103:     const dir = path.dirname(candidatePath);\n104:     const ext = path.extname(candidatePath);\n105:     const base = path.basename(candidatePath, ext);\n106:     if (!base.endsWith(PENDING_SUFFIX)) {\n107:       return null;\n108:     }\n109: \n110:     const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n111:     return {\n112:       originalPath: path.join(dir, `${originalBase}${ext}`),\n113:       basePendingPath: candidatePath,\n114:       uniqueSuffix: null,\n115:     };\n116:   };\n117: \n118:   const suffixExt = path.extname(filePath);\n119:   if (suffixExt) {\n120:     const uniqueSuffix = suffixExt.slice(1);\n121:     const basePendingPath = filePath.slice(0, -suffixExt.length);\n122:     const suffixedMatch = parseBasePendingPath(basePendingPath);\n123:     if (\n124:       suffixedMatch &&\n125:       path.extname(suffixedMatch.basePendingPath) &&\n126:       PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n127:     ) {\n128:       return {\n129:         ...suffixedMatch,\n130:         uniqueSuffix,\n131:       };\n132:     }\n133:   }\n134: \n135:   return parseBasePendingPath(filePath);\n136: }\n137: \n138: function isPendingFile(filePath: string): boolean {\n139:   return parsePendingPath(filePath) !== null;\n140: }\n141: \n142: function getOriginalPath(pendingPath: string): string {\n143:   return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n144: }\n145: \n146: function runInTransaction<T>(database: Database.Database, callback: () => T): T {\n147:   const runCallback = (): T => {\n148:     const depth = activeTransactions.get(database) ?? 0;\n149:     activeTransactions.set(database, depth + 1);\n150:     try {\n151:       return callback();\n152:     } finally {\n153:       const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n154:       if (nextDepth > 0) {\n155:         activeTransactions.set(database, nextDepth);\n156:       } else {\n157:         activeTransactions.delete(database);\n158:       }\n159:     }\n160:   };\n161: \n162:   if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n163:     return runCallback();\n164:   }\n165: \n166:   return database.transaction(() => runCallback())();\n167: }\n168: \n169: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n170:    6. ATOMIC FILE OPERATIONS\n171: ----------------------------------------------------------------*/\n172: \n173: /**\n174:  * Write a file atomically using write-to-temp-then-rename pattern.\n175:  * This prevents partial writes if the process crashes mid-write.\n176:  */\n177: function atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n178:   const tempPath = filePath + TEMP_SUFFIX;\n179: \n180:   try {\n181:     // Ensure directory exists\n182:     const dir = path.dirname(filePath);\n183:     if (!fs.existsSync(dir)) {\n184:       fs.mkdirSync(dir, { recursive: true });\n185:     }\n186: \n187:     // Write to temp file\n188:     fs.writeFileSync(tempPath, content, encoding);\n189: \n190:     // Atomic rename\n191:     fs.renameSync(tempPath, filePath);\n192: \n193:     metrics.totalAtomicWrites++;\n194:     metrics.lastOperationTime = new Date().toISOString();\n195:     return true;\n196:   } catch (error: unknown) {\n197:     const msg = error instanceof Error ? error.message : String(error);\n198:     console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n199:     metrics.totalErrors++;\n200: \n201:     // Clean up temp file\n202:     try {\n203:       if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n204:     } catch { /* ignore cleanup errors */ }\n205: \n206:     return false;\n207:   }\n208: }\n209: \n210: /**\n211:  * Delete a file if it exists.\n212:  */\n213: function deleteFileIfExists(filePath: string): boolean {\n214:   try {\n215:     if (fs.existsSync(filePath)) {\n216:       fs.unlinkSync(filePath);\n217:       metrics.totalDeletes++;\n218:       metrics.lastOperationTime = new Date().toISOString();\n219:       return true;\n220:     }\n221:     return false;\n222:   } catch (error: unknown) {\n223:     const msg = error instanceof Error ? error.message : String(error);\n224:     console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n225:     metrics.totalErrors++;\n226:     return false;\n227:   }\n228: }\n229: \n230: /**\n231:  * Execute an atomic save with pending file pattern.\n232:  * 1. Write to pending path\n233:  * 2. Execute database operations\n234:  * 3. Rename pending to final\n235:  *\n236:  * This function provides file-system-level atomicity (write-to-pending + rename),\n237:  * NOT database transaction isolation. Callers needing transactional guarantees for\n238:  * dbOperation() must wrap it in their own db.transaction() call. The rename step\n239:  * ensures the file is either fully written or not present, but the DB operation\n240:  * is not rolled back if the rename fails (extremely rare on local filesystems).\n241:  */\n242: function executeAtomicSave(\n243:   filePath: string,\n244:   content: string,\n245:   dbOperation: () => void\n246: ): AtomicSaveResult {\n247:   const pendingPath = getPendingPath(filePath);\n248: \n249:   try {\n250:     // Step 1: Write to pending path\n251:     const dir = path.dirname(pendingPath);\n252:     if (!fs.existsSync(dir)) {\n253:       fs.mkdirSync(dir, { recursive: true });\n254:     }\n255:     fs.writeFileSync(pendingPath, content, 'utf-8');\n256: \n257:     // Flag-based rollback coordination.\n258:     // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n259:     // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n260:     // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n261:     // Can report which step failed. No SAVEPOINT is used вҖ” better-sqlite3 transactions\n262:     // Are all-or-nothing within the dbOperation() callback itself.\n263:     let dbCommitted = false;\n264: \n265:     // Step 2: Execute database operation\n266:     try {\n267:       dbOperation();\n268:       dbCommitted = true;\n269:     } catch (dbError: unknown) {\n270:       // Database failed - clean up pending file\n271:       try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n272:       const msg = dbError instanceof Error ? dbError.message : String(dbError);\n273:       metrics.totalErrors++;\n274:       return { success: false, filePath, error: `DB operation failed: ${msg}` };\n275:     }\n276: \n277:     // Step 3: Rename pending to final (atomic)\n278:     // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n279:     // The DB contains the new state but the file is not at its final path. This is\n280:     // A window of vulnerability that cannot be eliminated without two-phase commit.\n281:     // The `dbCommitted` flag on the returned error result enables callers to detect\n282:     // This state and trigger recovery (e.g., re-index from DB or replay the write).\n283:     // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n284:     // Orphaned pending files and rename them to their final paths.\n285:     try {\n286:       fs.renameSync(pendingPath, filePath);\n287:     } catch (renameError: unknown) {\n288:       // Rename failed after DB committed вҖ” DB has new state but file wasn't renamed.\n289:       // Leave pending file for startup recovery and report failure with dbCommitted flag.\n290:       const msg = renameError instanceof Error ? renameError.message : String(renameError);\n291:       console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n292:       metrics.totalErrors++;\n293:       return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n294:     }\n295: \n296:     metrics.totalAtomicWrites++;\n297:     metrics.lastOperationTime = new Date().toISOString();\n298:     return { success: true, filePath };\n299:   } catch (error: unknown) {\n300:     const msg = error instanceof Error ? error.message : String(error);\n301:     metrics.totalErrors++;\n302: \n303:     // Clean up pending file\n304:     try {\n305:       if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n306:     } catch { /* ignore */ }\n307: \n308:     return { success: false, filePath, error: msg };\n309:   }\n310: }\n311: \n312: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n313:    7. RECOVERY\n314: ----------------------------------------------------------------*/\n315: \n316: /**\n317:  * Find pending files in a directory (crash recovery).\n318:  */\n319: function listFilesRecursive(dirPath: string): string[] {\n320:   const files: string[] = [];\n321:   const stack: string[] = [dirPath];\n322: \n323:   while (stack.length > 0) {\n324:     const current = stack.pop();\n325:     if (!current) continue;\n326: \n327:     const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n328:     for (const entry of entries) {\n329:       const fullPath = path.join(current, entry.name);\n330:       if (entry.isDirectory()) {\n331:         stack.push(fullPath);\n332:       } else if (entry.isFile()) {\n333:         files.push(fullPath);\n334:       }\n335:     }\n336:   }\n337: \n338:   return files;\n339: }\n340: \n341: function findPendingFiles(dirPath: string): string[] {\n342:   try {\n343:     if (!fs.existsSync(dirPath)) return [];\n344: \n345:     let files: string[];\n346:     try {\n347:       files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n348:     } catch {\n349:       // Node 18 compatibility fallback when recursive readdir is unavailable.\n350:       files = listFilesRecursive(dirPath);\n351:     }\n352: \n353:     return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n354:   } catch (error: unknown) {\n355:     const msg = error instanceof Error ? error.message : String(error);\n356:     console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n357:     return [];\n358:   }\n359: }\n360: \n361: /**\n362:  * Recover a single pending file by renaming to its original path.\n363:  */\n364: function recoverPendingFile(\n365:   pendingPath: string,\n366:   isCommittedInDb?: IsCommittedCheck,\n367:   databasePathOverride?: string\n368: ): RecoveryResult {\n369:   try {\n370:     // Guard: verify pending file still exists before attempting recovery\n371:     if (!fs.existsSync(pendingPath)) {\n372:       return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n373:     }\n374:     const pendingInfo = parsePendingPath(pendingPath);\n375:     if (!pendingInfo) {\n376:       return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n377:     }\n378: \n379:     const originalPath = pendingInfo.originalPath;\n380:     const originalExists = fs.existsSync(originalPath);\n381:     let committedInDb: boolean | null = null;\n382:     if (isCommittedInDb) {\n383:       const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n384:       if (!fs.existsSync(databasePath)) {\n385:         console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n386:         return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n387:       }\n388:       committedInDb = isCommittedInDb(originalPath);\n389:     }\n390: \n391:     // If original exists and is newer, delete pending\n392:     if (originalExists) {\n393:       const pendingStats = fs.statSync(pendingPath);\n394:       const originalStats = fs.statSync(originalPath);\n395:       if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n396:         fs.unlinkSync(pendingPath);\n397:         return { path: pendingPath, recovered: false, error: 'Original is newer' };\n398:       }\n399:     }\n400: \n401:     // Stale detection: if DB check is provided and row was never committed,\n402:     // Log and leave for manual review instead of renaming.\n403:     if (committedInDb === false) {\n404:       console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n405:       return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n406:     }\n407: \n408:     // Rename pending to original\n409:     fs.renameSync(pendingPath, originalPath);\n410:     metrics.totalRecoveries++;\n411:     metrics.lastOperationTime = new Date().toISOString();\n412: \n413:     return { path: pendingPath, recovered: true };\n414:   } catch (error: unknown) {\n415:     const msg = error instanceof Error ? error.message : String(error);\n416:     metrics.totalErrors++;\n417:     return { path: pendingPath, recovered: false, error: msg };\n418:   }\n419: }\n420: \n421: /**\n422:  * Recover all pending files in a directory.\n423:  */\n424: function recoverAllPendingFiles(\n425:   dirPath: string,\n426:   isCommittedInDb?: IsCommittedCheck,\n427:   databasePathOverride?: string\n428: ): RecoveryResult[] {\n429:   const pendingFiles = findPendingFiles(dirPath);\n430:   return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n431: }\n432: \n433: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n434:    8. EXPORTS\n435: ----------------------------------------------------------------*/\n436: \n437: export {\n438:   PENDING_SUFFIX,\n439:   TEMP_SUFFIX,\n440: \n441:   // Metrics\n442:   getMetrics,\n443:   resetMetrics,\n444: \n445:   // Path helpers\n446:   getPendingPath,\n447:   isPendingFile,\n448:   getOriginalPath,\n449:   runInTransaction,\n450: \n451:   // Atomic operations\n452:   atomicWriteFile,\n453:   deleteFileIfExists,\n454:   executeAtomicSave,\n455: \n456:   // Recovery\n457:   findPendingFiles,\n458:   recoverPendingFile,\n459:   recoverAllPendingFiles,\n460: };\n461: \n462: /**\n463:  * Re-exports related public types.\n464:  */\n465: export type {\n466:   TransactionMetrics,\n467:   AtomicSaveResult,\n468:   RecoveryResult,\n469:   IsCommittedCheck,\n470: };\n\n(End of file - total 470 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Transaction Manager\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. INTERFACES","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Transaction Manager\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface TransactionMetrics {\n  totalAtomicWrites: number;\n  totalDeletes: number;\n  totalRecoveries: number;\n  totalErrors: number;\n  lastOperationTime: string | null;\n  [key: string]: unknown;\n}\n\ninterface AtomicSaveResult {\n  success: boolean;\n  filePath: string;\n  error?: string;\n  /** Set when DB committed but rename failed, indicating partial state */\n  dbCommitted?: boolean;\n}\n\ninterface RecoveryResult {\n  path: string;\n  recovered: boolean;\n  error?: string;\n}\n\n/**\n * Optional database probe used during pending-file recovery.\n * Return `true` when the original path already has a committed `memory_index` row.\n * Return `false` to leave the `_pending` file in place for manual review.\n * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n */\ntype IsCommittedCheck = (originalPath: string) => boolean;\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nconst metrics: TransactionMetrics = {\n  totalAtomicWrites: 0,\n  totalDeletes: 0,\n  totalRecoveries: 0,\n  totalErrors: 0,\n  lastOperationTime: null,\n};\n\nconst activeTransactions = new WeakMap<object, number>();\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. METRICS\n----------------------------------------------------------------*/\n\nfunction getMetrics(): TransactionMetrics {\n  return { ...metrics };\n}\n\nfunction resetMetrics(): void {\n  metrics.totalAtomicWrites = 0;\n  metrics.totalDeletes = 0;\n  metrics.totalRecoveries = 0;\n  metrics.totalErrors = 0;\n  metrics.lastOperationTime = null;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. PATH HELPERS\n----------------------------------------------------------------*/\n\nfunction getPendingPath(filePath: string): string {\n  const dir = path.dirname(filePath);\n  const ext = path.extname(filePath);\n  const base = path.basename(filePath, ext);\n  return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n}\n\ninterface PendingPathInfo {\n  originalPath: string;\n  basePendingPath: string;\n  uniqueSuffix: string | null;\n}\n\nfunction parsePendingPath(filePath: string): PendingPathInfo | null {\n  const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n    const dir = path.dirname(candidatePath);\n    const ext = path.extname(candidatePath);\n    const base = path.basename(candidatePath, ext);\n    if (!base.endsWith(PENDING_SUFFIX)) {\n      return null;\n    }\n\n    const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n    return {\n      originalPath: path.join(dir, `${originalBase}${ext}`),\n      basePendingPath: candidatePath,\n      uniqueSuffix: null,\n    };\n  };\n\n  const suffixExt = path.extname(filePath);\n  if (suffixExt) {\n    const uniqueSuffix = suffixExt.slice(1);\n    const basePendingPath = filePath.slice(0, -suffixExt.length);\n    const suffixedMatch = parseBasePendingPath(basePendingPath);\n    if (\n      suffixedMatch &&\n      path.extname(suffixedMatch.basePendingPath) &&\n      PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n    ) {\n      return {\n        ...suffixedMatch,\n        uniqueSuffix,\n      };\n    }\n  }\n\n  return parseBasePendingPath(filePath);\n}\n\nfunction isPendingFile(filePath: string): boolean {\n  return parsePendingPath(filePath) !== null;\n}\n\nfunction getOriginalPath(pendingPath: string): string {\n  return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n}\n\nfunction runInTransaction<T>(database: Database.Database, callback: () => T): T {\n  const runCallback = (): T => {\n    const depth = activeTransactions.get(database) ?? 0;\n    activeTransactions.set(database, depth + 1);\n    try {\n      return callback();\n    } finally {\n      const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n      if (nextDepth > 0) {\n        activeTransactions.set(database, nextDepth);\n      } else {\n        activeTransactions.delete(database);\n      }\n    }\n  };\n\n  if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n    return runCallback();\n  }\n\n  return database.transaction(() => runCallback())();\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. ATOMIC FILE OPERATIONS\n----------------------------------------------------------------*/\n\n/**\n * Write a file atomically using write-to-temp-then-rename pattern.\n * This prevents partial writes if the process crashes mid-write.\n */\nfunction atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n  const tempPath = filePath + TEMP_SUFFIX;\n\n  try {\n    // Ensure directory exists\n    const dir = path.dirname(filePath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n\n    // Write to temp file\n    fs.writeFileSync(tempPath, content, encoding);\n\n    // Atomic rename\n    fs.renameSync(tempPath, filePath);\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n    metrics.totalErrors++;\n\n    // Clean up temp file\n    try {\n      if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n    } catch { /* ignore cleanup errors */ }\n\n    return false;\n  }\n}\n\n/**\n * Delete a file if it exists.\n */\nfunction deleteFileIfExists(filePath: string): boolean {\n  try {\n    if (fs.existsSync(filePath)) {\n      fs.unlinkSync(filePath);\n      metrics.totalDeletes++;\n      metrics.lastOperationTime = new Date().toISOString();\n      return true;\n    }\n    return false;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n    metrics.totalErrors++;\n    return false;\n  }\n}\n\n/**\n * Execute an atomic save with pending file pattern.\n * 1. Write to pending path\n * 2. Execute database operations\n * 3. Rename pending to final\n *\n * This function provides file-system-level atomicity (write-to-pending + rename),\n * NOT database transaction isolation. Callers needing transactional guarantees for\n * dbOperation() must wrap it in their own db.transaction() call. The rename step\n * ensures the file is either fully written or not present, but the DB operation\n * is not rolled back if the rename fails (extremely rare on local filesystems).\n */\nfunction executeAtomicSave(\n  filePath: string,\n  content: string,\n  dbOperation: () => void\n): AtomicSaveResult {\n  const pendingPath = getPendingPath(filePath);\n\n  try {\n    // Step 1: Write to pending path\n    const dir = path.dirname(pendingPath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n    fs.writeFileSync(pendingPath, content, 'utf-8');\n\n    // Flag-based rollback coordination.\n    // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n    // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n    // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n    // Can report which step failed. No SAVEPOINT is used вҖ” better-sqlite3 transactions\n    // Are all-or-nothing within the dbOperation() callback itself.\n    let dbCommitted = false;\n\n    // Step 2: Execute database operation\n    try {\n      dbOperation();\n      dbCommitted = true;\n    } catch (dbError: unknown) {\n      // Database failed - clean up pending file\n      try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n      const msg = dbError instanceof Error ? dbError.message : String(dbError);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `DB operation failed: ${msg}` };\n    }\n\n    // Step 3: Rename pending to final (atomic)\n    // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n    // The DB contains the new state but the file is not at its final path. This is\n    // A window of vulnerability that cannot be eliminated without two-phase commit.\n    // The `dbCommitted` flag on the returned error result enables callers to detect\n    // This state and trigger recovery (e.g., re-index from DB or replay the write).\n    // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n    // Orphaned pending files and rename them to their final paths.\n    try {\n      fs.renameSync(pendingPath, filePath);\n    } catch (renameError: unknown) {\n      // Rename failed after DB committed вҖ” DB has new state but file wasn't renamed.\n      // Leave pending file for startup recovery and report failure with dbCommitted flag.\n      const msg = renameError instanceof Error ? renameError.message : String(renameError);\n      console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n    }\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return { success: true, filePath };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n\n    // Clean up pending file\n    try {\n      if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n    } catch { /* ignore */ }\n\n    return { success: false, filePath, error: msg };\n  }\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   7. RECOVERY\n----------------------------------------------------------------*/\n\n/**\n * Find pending files in a directory (crash recovery).\n */\nfunction listFilesRecursive(dirPath: string): string[] {\n  const files: string[] = [];\n  const stack: string[] = [dirPath];\n\n  while (stack.length > 0) {\n    const current = stack.pop();\n    if (!current) continue;\n\n    const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n    for (const entry of entries) {\n      const fullPath = path.join(current, entry.name);\n      if (entry.isDirectory()) {\n        stack.push(fullPath);\n      } else if (entry.isFile()) {\n        files.push(fullPath);\n      }\n    }\n  }\n\n  return files;\n}\n\nfunction findPendingFiles(dirPath: string): string[] {\n  try {\n    if (!fs.existsSync(dirPath)) return [];\n\n    let files: string[];\n    try {\n      files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n    } catch {\n      // Node 18 compatibility fallback when recursive readdir is unavailable.\n      files = listFilesRecursive(dirPath);\n    }\n\n    return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Recover a single pending file by renaming to its original path.\n */\nfunction recoverPendingFile(\n  pendingPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult {\n  try {\n    // Guard: verify pending file still exists before attempting recovery\n    if (!fs.existsSync(pendingPath)) {\n      return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n    }\n    const pendingInfo = parsePendingPath(pendingPath);\n    if (!pendingInfo) {\n      return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n    }\n\n    const originalPath = pendingInfo.originalPath;\n    const originalExists = fs.existsSync(originalPath);\n    let committedInDb: boolean | null = null;\n    if (isCommittedInDb) {\n      const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n      if (!fs.existsSync(databasePath)) {\n        console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n        return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n      }\n      committedInDb = isCommittedInDb(originalPath);\n    }\n\n    // If original exists and is newer, delete pending\n    if (originalExists) {\n      const pendingStats = fs.statSync(pendingPath);\n      const originalStats = fs.statSync(originalPath);\n      if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n        fs.unlinkSync(pendingPath);\n        return { path: pendingPath, recovered: false, error: 'Original is newer' };\n      }\n    }\n\n    // Stale detection: if DB check is provided and row was never committed,\n    // Log and leave for manual review instead of renaming.\n    if (committedInDb === false) {\n      console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n      return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n    }\n\n    // Rename pending to original\n    fs.renameSync(pendingPath, originalPath);\n    metrics.totalRecoveries++;\n    metrics.lastOperationTime = new Date().toISOString();\n\n    return { path: pendingPath, recovered: true };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n    return { path: pendingPath, recovered: false, error: msg };\n  }\n}\n\n/**\n * Recover all pending files in a directory.\n */\nfunction recoverAllPendingFiles(\n  dirPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult[] {\n  const pendingFiles = findPendingFiles(dirPath);\n  return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   8. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  PENDING_SUFFIX,\n  TEMP_SUFFIX,\n\n  // Metrics\n  getMetrics,\n  resetMetrics,\n\n  // Path helpers\n  getPendingPath,\n  isPendingFile,\n  getOriginalPath,\n  runInTransaction,\n\n  // Atomic operations\n  atomicWriteFile,\n  deleteFileIfExists,\n  executeAtomicSave,\n\n  // Recovery\n  findPendingFiles,\n  recoverPendingFile,\n  recoverAllPendingFiles,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  TransactionMetrics,\n  AtomicSaveResult,\n  RecoveryResult,\n  IsCommittedCheck,\n};","lineStart":1,"lineEnd":470,"totalLines":470,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","time":{"start":1781764242880,"end":1781764242882}},"metadata":{"openai":{"itemId":"fc_09a06c8bbd7bd3eb016a339092a67c819198be16129bf075a7"}},"id":"prt_ed96cbdbc001883X6cqd22AE8T","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c6f19001AvuEb9S058jVmN"}}
{"type":"tool_use","timestamp":1781764242902,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_xCaCFMsZFVNVtLuaV67qDmYt","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Idempotency Receipts\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: import { createHash } from 'node:crypto';\n5: import type BetterSqlite3 from 'better-sqlite3';\n6: \n7: import type { MCPResponse } from '../../handlers/types.js';\n8: \n9: export type IdempotencyOperation = 'memory_save' | 'memory_update';\n10: \n11: export interface IdempotencyReceiptInput {\n12:   operation: IdempotencyOperation;\n13:   contentHash: string | null;\n14:   requestFingerprint: Record<string, unknown>;\n15:   payload: Record<string, unknown>;\n16: }\n17: \n18: export interface IdempotencyReceiptKey {\n19:   operation: IdempotencyOperation;\n20:   receiptKey: string;\n21:   contentHash: string | null;\n22:   requestFingerprintHash: string;\n23:   payloadHash: string;\n24: }\n25: \n26: export type IdempotencyLookupResult =\n27:   | { status: 'miss'; key: IdempotencyReceiptKey }\n28:   | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n29:   | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n30: \n31: interface ReceiptRow {\n32:   payload_hash: string;\n33:   response_payload: string;\n34: }\n35: \n36: interface MemorySaveReceiptCandidate {\n37:   id?: unknown;\n38:   status?: unknown;\n39: }\n40: \n41: const RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n42: \n43: const CLIENT_TOKEN_KEYS = new Set([\n44:   'idempotencykey',\n45:   'idempotency_key',\n46:   'idempotencytoken',\n47:   'idempotency_token',\n48:   'clientidempotencykey',\n49:   'client_idempotency_key',\n50:   'clientidempotencytoken',\n51:   'client_idempotency_token',\n52: ]);\n53: \n54: export function isMemoryIdempotencyEnabled(): boolean {\n55:   const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n56:   return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n57: }\n58: \n59: function normalizeForHash(value: unknown): unknown {\n60:   if (Array.isArray(value)) {\n61:     return value.map(normalizeForHash);\n62:   }\n63:   if (!value || typeof value !== 'object') {\n64:     return value;\n65:   }\n66: \n67:   const record = value as Record<string, unknown>;\n68:   const normalized: Record<string, unknown> = {};\n69:   for (const key of Object.keys(record).sort()) {\n70:     if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n71:       continue;\n72:     }\n73:     const normalizedValue = normalizeForHash(record[key]);\n74:     if (normalizedValue !== undefined) {\n75:       normalized[key] = normalizedValue;\n76:     }\n77:   }\n78:   return normalized;\n79: }\n80: \n81: function hashJson(value: unknown): string {\n82:   return createHash('sha256')\n83:     .update(JSON.stringify(normalizeForHash(value)))\n84:     .digest('hex');\n85: }\n86: \n87: export function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n88:   const requestFingerprintHash = hashJson(input.requestFingerprint);\n89:   const payloadHash = hashJson(input.payload);\n90:   const material = {\n91:     operation: input.operation,\n92:     contentHash: input.contentHash ?? null,\n93:     requestFingerprintHash,\n94:   };\n95:   return {\n96:     operation: input.operation,\n97:     receiptKey: hashJson(material),\n98:     contentHash: input.contentHash ?? null,\n99:     requestFingerprintHash,\n100:     payloadHash,\n101:   };\n102: }\n103: \n104: export function shouldStoreMemorySaveReceipt(\n105:   result: MemorySaveReceiptCandidate,\n106:   response: MCPResponse,\n107: ): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n108:   return response.isError !== true\n109:     && typeof result.id === 'number'\n110:     && Number.isInteger(result.id)\n111:     && result.id > 0\n112:     && typeof result.status === 'string'\n113:     && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n114: }\n115: \n116: export function lookupIdempotencyReceipt(\n117:   database: BetterSqlite3.Database,\n118:   input: IdempotencyReceiptInput,\n119: ): IdempotencyLookupResult {\n120:   return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n121: }\n122: \n123: export function lookupIdempotencyReceiptByKey(\n124:   database: BetterSqlite3.Database,\n125:   key: IdempotencyReceiptKey,\n126: ): IdempotencyLookupResult {\n127:   const row = database.prepare(`\n128:     SELECT payload_hash, response_payload\n129:     FROM memory_idempotency_receipts\n130:     WHERE receipt_key = ?\n131:   `).get(key.receiptKey) as ReceiptRow | undefined;\n132: \n133:   if (!row) {\n134:     return { status: 'miss', key };\n135:   }\n136:   if (row.payload_hash !== key.payloadHash) {\n137:     return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n138:   }\n139:   return {\n140:     status: 'replay',\n141:     key,\n142:     response: JSON.parse(row.response_payload) as MCPResponse,\n143:   };\n144: }\n145: \n146: /**\n147:  * Drops the receipt for a key so a follow-up store writes fresh.\n148:  *\n149:  * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n150:  * not a durable record. When a replay is rejected because the live index no\n151:  * longer matches the receipt's content_hash (the logical path moved on and\n152:  * came back, so the cached response now carries a superseded memory id), the\n153:  * cache entry is stale: leaving it lets the post-write store lose the\n154:  * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n155:  * it first lets the re-indexed write store its current response and keeps the\n156:  * cache consistent with the active row. Best-effort: a delete failure must\n157:  * never block serving the live write.\n158:  */\n159: export function deleteIdempotencyReceiptByKey(\n160:   database: BetterSqlite3.Database,\n161:   key: IdempotencyReceiptKey,\n162: ): void {\n163:   try {\n164:     database.prepare(`\n165:       DELETE FROM memory_idempotency_receipts\n166:       WHERE receipt_key = ?\n167:     `).run(key.receiptKey);\n168:   } catch {\n169:     // Best-effort cache eviction; serving the live write takes priority.\n170:   }\n171: }\n172: \n173: export function storeIdempotencyReceipt(\n174:   database: BetterSqlite3.Database,\n175:   key: IdempotencyReceiptKey,\n176:   response: MCPResponse,\n177:   memoryId?: number | null,\n178: ): boolean {\n179:   const info = database.prepare(`\n180:     INSERT INTO memory_idempotency_receipts (\n181:       receipt_key,\n182:       operation,\n183:       content_hash,\n184:       request_fingerprint,\n185:       payload_hash,\n186:       response_payload,\n187:       memory_id,\n188:       updated_at\n189:     ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n190:     ON CONFLICT(receipt_key) DO NOTHING\n191:   `).run(\n192:     key.receiptKey,\n193:     key.operation,\n194:     key.contentHash,\n195:     key.requestFingerprintHash,\n196:     key.payloadHash,\n197:     JSON.stringify(response),\n198:     memoryId ?? null,\n199:   );\n200:   // changes === 0 means a concurrent caller already stored the canonical receipt\n201:   // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n202:   return info.changes > 0;\n203: }\n204: \n205: /**\n206:  * Marks a mutated loser's response with an explicit store-race conflict.\n207:  *\n208:  * When a writer loses the first-store race to a concurrent SAME-KEY,\n209:  * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n210:  * already landed (so an error response would lie), and the winner's stored\n211:  * response answers a different payload (so replaying it would lie too).\n212:  * Rolling the landed mutation back from this late window is the dangerous\n213:  * non-option. What remains is the loser's own response carrying a visible\n214:  * conflict block, so callers know the canonical receipt for this key\n215:  * belongs to a different concurrent request and a later retry may replay\n216:  * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n217:  * original response is returned unmodified.\n218:  */\n219: export function markResponseWithReceiptStoreConflict(\n220:   response: MCPResponse,\n221:   key: IdempotencyReceiptKey,\n222:   storedPayloadHash: string | undefined,\n223: ): MCPResponse {\n224:   const first = response.content?.[0];\n225:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n226:     return response;\n227:   }\n228:   try {\n229:     const envelope = JSON.parse(first.text) as Record<string, unknown>;\n230:     const data = (envelope.data && typeof envelope.data === 'object')\n231:       ? envelope.data as Record<string, unknown>\n232:       : {};\n233:     data.idempotencyStoreConflict = {\n234:       receiptKey: key.receiptKey,\n235:       payloadHash: key.payloadHash,\n236:       storedPayloadHash: storedPayloadHash ?? null,\n237:     };\n238:     envelope.data = data;\n239:     const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n240:     hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n241:     envelope.hints = hints;\n242:     return {\n243:       ...response,\n244:       content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n245:     };\n246:   } catch {\n247:     return response;\n248:   }\n249: }\n250: \n251: /**\n252:  * Deletes receipts older than the retention window. Receipts are replay\n253:  * caches, not durable records: unbounded growth plus indefinite stale\n254:  * replays (including against deleted memories) is the failure mode this\n255:  * sweep bounds. Best-effort by contract вҖ” callers must never let a sweep\n256:  * failure block serving.\n257:  */\n258: export function pruneExpiredIdempotencyReceipts(\n259:   database: BetterSqlite3.Database,\n260:   ttlDays?: number,\n261: ): number {\n262:   const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n263:   const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n264:   try {\n265:     // Prune on created_at: it is indexed and, since receipts are insert-only\n266:     // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at вҖ”\n267:     // so this is behaviorally identical but avoids a full table scan.\n268:     const info = database.prepare(`\n269:       DELETE FROM memory_idempotency_receipts\n270:       WHERE created_at < datetime('now', ?)\n271:     `).run(`-${days} days`);\n272:     return info.changes;\n273:   } catch {\n274:     return 0;\n275:   }\n276: }\n277: \n278: export function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n279:   const first = response.content?.[0];\n280:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n281:     return null;\n282:   }\n283:   try {\n284:     const envelope = JSON.parse(first.text) as { data?: { id?: unknown; updated?: unknown } };\n285:     const id = envelope.data?.id ?? envelope.data?.updated;\n286:     return typeof id === 'number' && Number.isInteger(id) && id > 0 ? id : null;\n287:   } catch {\n288:     return null;\n289:   }\n290: }\n\n(End of file - total 290 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Idempotency Receipts\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Idempotency Receipts\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;\n  contentHash: string | null;\n  requestFingerprintHash: string;\n  payloadHash: string;\n}\n\nexport type IdempotencyLookupResult =\n  | { status: 'miss'; key: IdempotencyReceiptKey }\n  | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n  | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n\ninterface ReceiptRow {\n  payload_hash: string;\n  response_payload: string;\n}\n\ninterface MemorySaveReceiptCandidate {\n  id?: unknown;\n  status?: unknown;\n}\n\nconst RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n\nconst CLIENT_TOKEN_KEYS = new Set([\n  'idempotencykey',\n  'idempotency_key',\n  'idempotencytoken',\n  'idempotency_token',\n  'clientidempotencykey',\n  'client_idempotency_key',\n  'clientidempotencytoken',\n  'client_idempotency_token',\n]);\n\nexport function isMemoryIdempotencyEnabled(): boolean {\n  const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n  return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n}\n\nfunction normalizeForHash(value: unknown): unknown {\n  if (Array.isArray(value)) {\n    return value.map(normalizeForHash);\n  }\n  if (!value || typeof value !== 'object') {\n    return value;\n  }\n\n  const record = value as Record<string, unknown>;\n  const normalized: Record<string, unknown> = {};\n  for (const key of Object.keys(record).sort()) {\n    if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n      continue;\n    }\n    const normalizedValue = normalizeForHash(record[key]);\n    if (normalizedValue !== undefined) {\n      normalized[key] = normalizedValue;\n    }\n  }\n  return normalized;\n}\n\nfunction hashJson(value: unknown): string {\n  return createHash('sha256')\n    .update(JSON.stringify(normalizeForHash(value)))\n    .digest('hex');\n}\n\nexport function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n  const requestFingerprintHash = hashJson(input.requestFingerprint);\n  const payloadHash = hashJson(input.payload);\n  const material = {\n    operation: input.operation,\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n  };\n  return {\n    operation: input.operation,\n    receiptKey: hashJson(material),\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n    payloadHash,\n  };\n}\n\nexport function shouldStoreMemorySaveReceipt(\n  result: MemorySaveReceiptCandidate,\n  response: MCPResponse,\n): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n  return response.isError !== true\n    && typeof result.id === 'number'\n    && Number.isInteger(result.id)\n    && result.id > 0\n    && typeof result.status === 'string'\n    && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n}\n\nexport function lookupIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  input: IdempotencyReceiptInput,\n): IdempotencyLookupResult {\n  return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n}\n\nexport function lookupIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): IdempotencyLookupResult {\n  const row = database.prepare(`\n    SELECT payload_hash, response_payload\n    FROM memory_idempotency_receipts\n    WHERE receipt_key = ?\n  `).get(key.receiptKey) as ReceiptRow | undefined;\n\n  if (!row) {\n    return { status: 'miss', key };\n  }\n  if (row.payload_hash !== key.payloadHash) {\n    return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n  }\n  return {\n    status: 'replay',\n    key,\n    response: JSON.parse(row.response_payload) as MCPResponse,\n  };\n}\n\n/**\n * Drops the receipt for a key so a follow-up store writes fresh.\n *\n * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n * not a durable record. When a replay is rejected because the live index no\n * longer matches the receipt's content_hash (the logical path moved on and\n * came back, so the cached response now carries a superseded memory id), the\n * cache entry is stale: leaving it lets the post-write store lose the\n * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n * it first lets the re-indexed write store its current response and keeps the\n * cache consistent with the active row. Best-effort: a delete failure must\n * never block serving the live write.\n */\nexport function deleteIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): void {\n  try {\n    database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE receipt_key = ?\n    `).run(key.receiptKey);\n  } catch {\n    // Best-effort cache eviction; serving the live write takes priority.\n  }\n}\n\nexport function storeIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n  response: MCPResponse,\n  memoryId?: number | null,\n): boolean {\n  const info = database.prepare(`\n    INSERT INTO memory_idempotency_receipts (\n      receipt_key,\n      operation,\n      content_hash,\n      request_fingerprint,\n      payload_hash,\n      response_payload,\n      memory_id,\n      updated_at\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n    ON CONFLICT(receipt_key) DO NOTHING\n  `).run(\n    key.receiptKey,\n    key.operation,\n    key.contentHash,\n    key.requestFingerprintHash,\n    key.payloadHash,\n    JSON.stringify(response),\n    memoryId ?? null,\n  );\n  // changes === 0 means a concurrent caller already stored the canonical receipt\n  // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n  return info.changes > 0;\n}\n\n/**\n * Marks a mutated loser's response with an explicit store-race conflict.\n *\n * When a writer loses the first-store race to a concurrent SAME-KEY,\n * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n * already landed (so an error response would lie), and the winner's stored\n * response answers a different payload (so replaying it would lie too).\n * Rolling the landed mutation back from this late window is the dangerous\n * non-option. What remains is the loser's own response carrying a visible\n * conflict block, so callers know the canonical receipt for this key\n * belongs to a different concurrent request and a later retry may replay\n * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n * original response is returned unmodified.\n */\nexport function markResponseWithReceiptStoreConflict(\n  response: MCPResponse,\n  key: IdempotencyReceiptKey,\n  storedPayloadHash: string | undefined,\n): MCPResponse {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return response;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as Record<string, unknown>;\n    const data = (envelope.data && typeof envelope.data === 'object')\n      ? envelope.data as Record<string, unknown>\n      : {};\n    data.idempotencyStoreConflict = {\n      receiptKey: key.receiptKey,\n      payloadHash: key.payloadHash,\n      storedPayloadHash: storedPayloadHash ?? null,\n    };\n    envelope.data = data;\n    const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n    hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n    envelope.hints = hints;\n    return {\n      ...response,\n      content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n    };\n  } catch {\n    return response;\n  }\n}\n\n/**\n * Deletes receipts older than the retention window. Receipts are replay\n * caches, not durable records: unbounded growth plus indefinite stale\n * replays (including against deleted memories) is the failure mode this\n * sweep bounds. Best-effort by contract вҖ” callers must never let a sweep\n * failure block serving.\n */\nexport function pruneExpiredIdempotencyReceipts(\n  database: BetterSqlite3.Database,\n  ttlDays?: number,\n): number {\n  const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n  const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n  try {\n    // Prune on created_at: it is indexed and, since receipts are insert-only\n    // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at вҖ”\n    // so this is behaviorally identical but avoids a full table scan.\n    const info = database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE created_at < datetime('now', ?)\n    `).run(`-${days} days`);\n    return info.changes;\n  } catch {\n    return 0;\n  }\n}\n\nexport function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return null;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as { data?: { id?: unknown; updated?: unknown } };\n    const id = envelope.data?.id ?? envelope.data?.updated;\n    return typeof id === 'number' && Number.isInteger(id) && id > 0 ? id : null;\n  } catch {\n    return null;\n  }\n}","lineStart":1,"lineEnd":290,"totalLines":290,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","time":{"start":1781764242899,"end":1781764242901}},"metadata":{"openai":{"itemId":"fc_09a06c8bbd7bd3eb016a339092a684819193181563a7f675d2"}},"id":"prt_ed96cbdcb001MbCcJep7F6sgiz","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c6f19001AvuEb9S058jVmN"}}
