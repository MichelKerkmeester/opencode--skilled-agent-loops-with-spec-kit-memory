ontext(_extra);\n1057:   if (sessionTrackingId) lastKnownSessionId = sessionTrackingId;\n1058: \n1059:   try {\n1060:     // SEC-003: Validate input lengths before processing (CWE-400 mitigation)\n1061:     validateInputLengths(args);\n1062:     // Validate at the server boundary before metrics, session priming, and\n1063:     // auto-surface logic can observe malformed raw tool arguments.\n1064:     const validatedArgs: Record<string, unknown> = KNOWN_TOOL_NAMES.has(name)\n1065:       ? validateToolArgs(name, args) as Record<string, unknown>\n1066:       : args;\n1067: \n1068:     // Track last tool call timestamp for all tools except session_health.\n1069:     if (name !== 'session_health') {\n1070:       recordToolCall(sessionTrackingId);\n1071: \n1072:       // Record metric event for context quality tracking\n1073:       recordMetricEvent({ kind: 'tool_call', toolName: name });\n1074:     }\n1075:     // Classify specific tool calls for finer-grained metrics\n1076:     if (name === 'memory_context' && validatedArgs.mode === 'resume') {\n1077:       recordMetricEvent({ kind: 'memory_recovery' });\n1078:     }\n1079:     // Code-graph MCP metrics now originate from standalone mk-code-index\n1080:     if (typeof validatedArgs.specFolder === 'string' && validatedArgs.specFolder) {\n1081:       recordMetricEvent({ kind: 'spec_folder_change', specFolder: validatedArgs.specFolder as string });\n1082:     }\n1083: \n1084:     const memoryRuntimeRequired = MEMORY_RUNTIME_TOOL_NAMES.has(name);\n1085:     if (memoryRuntimeRequired) {\n1086:       await ensureMemoryRuntimeInitialized(`handler:${name}`);\n1087:     }\n1088: \n1089:     const dbReinitialized = memoryRuntimeRequired\n1090:       ? await checkDatabaseUpdated()\n1091:       : false;\n1092:     if (dbReinitialized) {\n1093:       await invalidateReinitializedDbCaches();\n1094:     }\n1095: \n1096:     let sessionPrimeContext: AutoSurfaceResult | null = null;\n1097:     const memoryRuntimeAvailable = memoryRuntimeRequired || isMemoryRuntimeInitialized();\n1098:     if (memoryRuntimeAvailable) {\n1099:       try {\n1100:         sessionPrimeContext = await primeSessionIfNeeded(\n1101:           name,\n1102:           validatedArgs,\n1103:           sessionTrackingId,\n1104:         );\n1105:       } catch (primeErr: unknown) {\n1106:         const msg = primeErr instanceof Error ? primeErr.message : String(primeErr);\n1107:         console.error(`[context-server] Session priming failed (non-fatal): ${msg}`);\n1108:       }\n1109:     }\n1110: \n1111:     // Auto-surface memories before dispatch (after validation)\n1112:     let autoSurfacedContext: AutoSurfaceResult | null = null;\n1113:     const isCompactionLifecycleCall =\n1114:       name === 'memory_context' && validatedArgs.mode === 'resume';\n1115: \n1116:     const autoSurfaceStart = Date.now();\n1117:     if (MEMORY_AWARE_TOOLS.has(name) && memoryRuntimeAvailable) {\n1118:       const contextHint: string | null = extractContextHint(validatedArgs);\n1119:       if (contextHint) {\n1120:         try {\n1121:           if (isCompactionLifecycleCall) {\n1122:             autoSurfacedContext = await autoSurfaceAtCompaction(contextHint);\n1123:           } else {\n1124:             autoSurfacedContext = await autoSurfaceMemories(contextHint);\n1125:           }\n1126:         } catch (surfaceErr: unknown) {\n1127:           const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n1128:           console.error(`[context-server] Auto-surface failed (non-fatal): ${msg}`);\n1129:         }\n1130:       }\n1131:     } else if (memoryRuntimeAvailable) {\n1132:       try {\n1133:         autoSurfacedContext = await autoSurfaceAtToolDispatch(name, validatedArgs);\n1134:       } catch (surfaceErr: unknown) {\n1135:         const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n1136:         console.error(`[context-server] Tool-dispatch auto-surface failed (non-fatal): ${msg}`);\n1137:       }\n1138:     }\n1139:     const autoSurfaceLatencyMs = Date.now() - autoSurfaceStart;\n1140:     if (autoSurfaceLatencyMs > 250) {\n1141:       console.warn(`[context-server] Auto-surface precheck exceeded p95 target: ${autoSurfaceLatencyMs}ms`);\n1142:     }\n1143: \n1144:     // Dispatch to tool modules\n1145:     const result = await runWithCallerContext(\n1146:       callerContext,\n1147:       async () => dispatchTool(name, validatedArgs, callerContext),\n1148:     ) as ToolCallResponse | null;\n1149:     if (!result) {\n1150:       throw new Error(`Unknown tool: ${name}`);\n1151:     }\n1152: \n1153:     let dispatchGraphContext: DispatchGraphContextMeta | null = null;\n1154:     if (!result.isError) {\n1155:       dispatchGraphContext = await resolveDispatchGraphContext(name, validatedArgs);\n1156:     }\n1157: \n1158:     runAfterToolCallbacks(name, callId, structuredClone(result));\n1159: \n1160:     // Log follow_on_tool_use when a non-search tool is called after a recent search\n1161:     // Shadow-only: no ranking side effects. Fail-safe, never throws.\n1162:     if (isMemoryRuntimeInitialized() && name !== 'memory_search' && name !== 'memory_context' && name !== 'session_health') {\n1163:       try {\n1164:         const { logFollowOnToolUse } = await import('./lib/feedback/query-flow-tracker.js');\n1165:         const { requireDb } = await import('./utils/index.js');\n1166:         const db = (() => { try { return requireDb(); } catch { return null; } })();\n1167:         const followOnSessionId = sessionTrackingId ?? lastKnownSessionId;\n1168:         if (db && followOnSessionId) {\n1169:           logFollowOnToolUse(db, followOnSessionId);\n\n(Showing lines 1030-1169 of 2341. Use offset=1170 to continue.)\n</content>","metadata":{"preview":"}\n\nconst server = createContextMcpServer();\nconst serverWithInstructions = server as unknown as { setInstructions?: (instructions: string) => void };\nconst KNOWN_TOOL_NAMES = new Set(TOOL_DEFINITIONS.map((tool) => tool.name));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nfunction registerContextServerHandlers(targetServer: Server): void {\n  targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n    tools: TOOL_DEFINITIONS\n  }));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DISPATCH\n──────────────────────────────────────────────────────────────── */\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"}\n\nconst server = createContextMcpServer();\nconst serverWithInstructions = server as unknown as { setInstructions?: (instructions: string) => void };\nconst KNOWN_TOOL_NAMES = new Set(TOOL_DEFINITIONS.map((tool) => tool.name));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nfunction registerContextServerHandlers(targetServer: Server): void {\n  targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n    tools: TOOL_DEFINITIONS\n  }));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DISPATCH\n──────────────────────────────────────────────────────────────── */\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\n  targetServer.setRequestHandler(CallToolRequestSchema, async (request, _extra: unknown): Promise<any> => {\n  const requestParams = request.params as { name: string; arguments?: Record<string, unknown> };\n  const { name } = requestParams;\n  const args: Record<string, unknown> = requestParams.arguments ?? {};\n  const callId = resolveToolCallId(request as { id?: unknown });\n  const sessionTrackingId = resolveSessionTrackingId(args, _extra);\n  const callerContext = buildCallerContext(_extra);\n  if (sessionTrackingId) lastKnownSessionId = sessionTrackingId;\n\n  try {\n    // SEC-003: Validate input lengths before processing (CWE-400 mitigation)\n    validateInputLengths(args);\n    // Validate at the server boundary before metrics, session priming, and\n    // auto-surface logic can observe malformed raw tool arguments.\n    const validatedArgs: Record<string, unknown> = KNOWN_TOOL_NAMES.has(name)\n      ? validateToolArgs(name, args) as Record<string, unknown>\n      : args;\n\n    // Track last tool call timestamp for all tools except session_health.\n    if (name !== 'session_health') {\n      recordToolCall(sessionTrackingId);\n\n      // Record metric event for context quality tracking\n      recordMetricEvent({ kind: 'tool_call', toolName: name });\n    }\n    // Classify specific tool calls for finer-grained metrics\n    if (name === 'memory_context' && validatedArgs.mode === 'resume') {\n      recordMetricEvent({ kind: 'memory_recovery' });\n    }\n    // Code-graph MCP metrics now originate from standalone mk-code-index\n    if (typeof validatedArgs.specFolder === 'string' && validatedArgs.specFolder) {\n      recordMetricEvent({ kind: 'spec_folder_change', specFolder: validatedArgs.specFolder as string });\n    }\n\n    const memoryRuntimeRequired = MEMORY_RUNTIME_TOOL_NAMES.has(name);\n    if (memoryRuntimeRequired) {\n      await ensureMemoryRuntimeInitialized(`handler:${name}`);\n    }\n\n    const dbReinitialized = memoryRuntimeRequired\n      ? await checkDatabaseUpdated()\n      : false;\n    if (dbReinitialized) {\n      await invalidateReinitializedDbCaches();\n    }\n\n    let sessionPrimeContext: AutoSurfaceResult | null = null;\n    const memoryRuntimeAvailable = memoryRuntimeRequired || isMemoryRuntimeInitialized();\n    if (memoryRuntimeAvailable) {\n      try {\n        sessionPrimeContext = await primeSessionIfNeeded(\n          name,\n          validatedArgs,\n          sessionTrackingId,\n        );\n      } catch (primeErr: unknown) {\n        const msg = primeErr instanceof Error ? primeErr.message : String(primeErr);\n        console.error(`[context-server] Session priming failed (non-fatal): ${msg}`);\n      }\n    }\n\n    // Auto-surface memories before dispatch (after validation)\n    let autoSurfacedContext: AutoSurfaceResult | null = null;\n    const isCompactionLifecycleCall =\n      name === 'memory_context' && validatedArgs.mode === 'resume';\n\n    const autoSurfaceStart = Date.now();\n    if (MEMORY_AWARE_TOOLS.has(name) && memoryRuntimeAvailable) {\n      const contextHint: string | null = extractContextHint(validatedArgs);\n      if (contextHint) {\n        try {\n          if (isCompactionLifecycleCall) {\n            autoSurfacedContext = await autoSurfaceAtCompaction(contextHint);\n          } else {\n            autoSurfacedContext = await autoSurfaceMemories(contextHint);\n          }\n        } catch (surfaceErr: unknown) {\n          const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n          console.error(`[context-server] Auto-surface failed (non-fatal): ${msg}`);\n        }\n      }\n    } else if (memoryRuntimeAvailable) {\n      try {\n        autoSurfacedContext = await autoSurfaceAtToolDispatch(name, validatedArgs);\n      } catch (surfaceErr: unknown) {\n        const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n        console.error(`[context-server] Tool-dispatch auto-surface failed (non-fatal): ${msg}`);\n      }\n    }\n    const autoSurfaceLatencyMs = Date.now() - autoSurfaceStart;\n    if (autoSurfaceLatencyMs > 250) {\n      console.warn(`[context-server] Auto-surface precheck exceeded p95 target: ${autoSurfaceLatencyMs}ms`);\n    }\n\n    // Dispatch to tool modules\n    const result = await runWithCallerContext(\n      callerContext,\n      async () => dispatchTool(name, validatedArgs, callerContext),\n    ) as ToolCallResponse | null;\n    if (!result) {\n      throw new Error(`Unknown tool: ${name}`);\n    }\n\n    let dispatchGraphContext: DispatchGraphContextMeta | null = null;\n    if (!result.isError) {\n      dispatchGraphContext = await resolveDispatchGraphContext(name, validatedArgs);\n    }\n\n    runAfterToolCallbacks(name, callId, structuredClone(result));\n\n    // Log follow_on_tool_use when a non-search tool is called after a recent search\n    // Shadow-only: no ranking side effects. Fail-safe, never throws.\n    if (isMemoryRuntimeInitialized() && name !== 'memory_search' && name !== 'memory_context' && name !== 'session_health') {\n      try {\n        const { logFollowOnToolUse } = await import('./lib/feedback/query-flow-tracker.js');\n        const { requireDb } = await import('./utils/index.js');\n        const db = (() => { try { return requireDb(); } catch { return null; } })();\n        const followOnSessionId = sessionTrackingId ?? lastKnownSessionId;\n        if (db && followOnSessionId) {\n          logFollowOnToolUse(db, followOnSessionId);","lineStart":1030,"lineEnd":1169,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781761685576,"end":1781761685582}},"metadata":{"openai":{"itemId":"fc_0e45db120c1d0521016a33869520a0819181b92c2eea3de552"}},"id":"prt_ed945b68e001nYDstUrfeVMY1P","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed945a340001wHwUTgemckgpi0"}}
