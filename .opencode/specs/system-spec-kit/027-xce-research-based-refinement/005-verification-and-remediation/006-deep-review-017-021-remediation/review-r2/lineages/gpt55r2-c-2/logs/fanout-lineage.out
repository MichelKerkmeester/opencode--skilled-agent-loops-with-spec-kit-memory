andle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n266:     } catch (error: unknown) {\n267:       if ((error as NodeJS.ErrnoException).code === 'EPERM') return;\n268:       throw error;\n269:     }\n270:     handles.push(handle);\n271: \n272:     const socket = await connectSocket(sock);\n273:     socket.write('{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\",\"params\":{}}\\n');\n274:     const response = JSON.parse(await readLine(socket)) as { result?: { tools?: Array<{ name: string }> } };\n275:     expect(response.result?.tools?.[0]?.name).toBe('ping');\n276:     socket.destroy();\n277:   });\n278: \n279:   it('serves multiple concurrent secondary clients', async () => {\n280:     const sock = 'tcp://127.0.0.1:0';\n281:     let handle: IpcSocketServerHandle;\n282:     try {\n283:       handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n284:     } catch (error: unknown) {\n285:       if ((error as NodeJS.ErrnoException).code === 'EPERM') return;\n286:       throw error;\n287:     }\n288:     handles.push(handle);\n289: \n290:     const sockets = await Promise.all([connectSocket(sock), connectSocket(sock), connectSocket(sock)]);\n291:     const responses = await Promise.all(sockets.map((socket, index) => {\n292:       socket.write(`{\"jsonrpc\":\"2.0\",\"id\":${index + 1},\"method\":\"tools/list\",\"params\":{}}\\n`);\n293:       return readLine(socket);\n294:     }));\n295:     expect(responses).toHaveLength(3);\n296:     for (const response of responses) {\n297:       expect(JSON.parse(response).result.tools[0].name).toBe('ping');\n298:     }\n299:     sockets.forEach((socket) => socket.destroy());\n300:   });\n301: \n302:   it('refuses clients beyond SPECKIT_MAX_SECONDARY_CLIENTS', async () => {\n303:     const sock = 'tcp://127.0.0.1:0';\n304:     let handle: IpcSocketServerHandle;\n305:     try {\n306:       handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer, maxClients: 8 });\n307:     } catch (error: unknown) {\n308:       if ((error as NodeJS.ErrnoException).code === 'EPERM') return;\n309:       throw error;\n310:     }\n311:     handles.push(handle);\n312:     const sockets = await Promise.all(Array.from({ length: 8 }, () => connectSocket(sock)));\n313:     await waitFor(() => getIpcBridgeStats().secondary_clients_count === 8, 'eight active clients');\n314: \n315:     const ninth = await connectSocket(sock);\n316:     await new Promise<void>((resolvePromise) => ninth.once('close', () => resolvePromise()));\n317:     expect(getIpcBridgeStats().secondary_clients_count).toBe(8);\n318:     sockets.forEach((socket) => socket.destroy());\n319:   });\n320: \n321:   it('cleans up the socket file when the listener closes', async () => {\n322:     const dbDir = tempDir('daemon-bridge-cleanup-');\n323:     const unixSock = resolveIpcSocketPath(dbDir);\n324:     expect(unixSock).toBe(join(dbDir, 'daemon-ipc.sock'));\n325:     const sock = 'tcp://127.0.0.1:0';\n326:     let handle: IpcSocketServerHandle;\n327:     try {\n328:       handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n329:     } catch (error: unknown) {\n330:       if ((error as NodeJS.ErrnoException).code === 'EPERM') return;\n331:       throw error;\n332:     }\n333:     expect(getIpcBridgeStats().socket_path).toMatch(/^tcp:\\/\\/127\\.0\\.0\\.1:\\d+$/);\n334:     await handle.close();\n335:     expect(getIpcBridgeStats().socket_path).toBeNull();\n336:   });\n337: });\n\n(End of file - total 337 lines)\n</content>","metadata":{"preview":"    expect(run.stdout).toContain(`LEASE_HELD_BY:${process.pid} startedAt=2026-05-19T00:00:00.000Z (no-bridge-socket)`);\n  });\n\n  it('SPECKIT_LAUNCHER_BRIDGE_DISABLED forces legacy lease-held output', async () => {\n    const root = tempDir('launcher-bridge-disabled-');\n    const launcherPath = copyLauncherFixture(root, '.opencode/bin/mk-spec-memory-launcher.cjs');\n    const dbDir = join(root, '.opencode/skills/system-spec-kit/mcp_server/database');\n    mkdirSync(dbDir, { recursive: true });\n    writeFileSync(join(dbDir, '.mk-spec-memory-launcher.json'), JSON.stringify({ pid: process.pid, startedAt: '2026-05-19T00:00:00.000Z' }));\n    const server = net.createServer(() => undefined);\n    const socketEndpoint = await listenTcp(server);\n    if (!socketEndpoint) return;\n\n    const run = spawnLauncher(root, launcherPath, {\n      SPECKIT_IPC_SOCKET_DIR: socketEndpoint,\n      SPECKIT_LAUNCHER_BRIDGE_DISABLED: '1',\n    });\n    await waitForExit(run.child);\n    expect(run.stdout).toBe(`LEASE_HELD_BY:${process.pid} startedAt=2026-05-19T00:00:00.000Z\\n`);\n  });","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-ipc-bridge.vitest.ts","text":"    expect(run.stdout).toContain(`LEASE_HELD_BY:${process.pid} startedAt=2026-05-19T00:00:00.000Z (no-bridge-socket)`);\n  });\n\n  it('SPECKIT_LAUNCHER_BRIDGE_DISABLED forces legacy lease-held output', async () => {\n    const root = tempDir('launcher-bridge-disabled-');\n    const launcherPath = copyLauncherFixture(root, '.opencode/bin/mk-spec-memory-launcher.cjs');\n    const dbDir = join(root, '.opencode/skills/system-spec-kit/mcp_server/database');\n    mkdirSync(dbDir, { recursive: true });\n    writeFileSync(join(dbDir, '.mk-spec-memory-launcher.json'), JSON.stringify({ pid: process.pid, startedAt: '2026-05-19T00:00:00.000Z' }));\n    const server = net.createServer(() => undefined);\n    const socketEndpoint = await listenTcp(server);\n    if (!socketEndpoint) return;\n\n    const run = spawnLauncher(root, launcherPath, {\n      SPECKIT_IPC_SOCKET_DIR: socketEndpoint,\n      SPECKIT_LAUNCHER_BRIDGE_DISABLED: '1',\n    });\n    await waitForExit(run.child);\n    expect(run.stdout).toBe(`LEASE_HELD_BY:${process.pid} startedAt=2026-05-19T00:00:00.000Z\\n`);\n  });\n\n  it('daemon-side socket listener accepts tools/list and returns a response', async () => {\n    const sock = 'tcp://127.0.0.1:0';\n    let handle: IpcSocketServerHandle;\n    try {\n      handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n    } catch (error: unknown) {\n      if ((error as NodeJS.ErrnoException).code === 'EPERM') return;\n      throw error;\n    }\n    handles.push(handle);\n\n    const socket = await connectSocket(sock);\n    socket.write('{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\",\"params\":{}}\\n');\n    const response = JSON.parse(await readLine(socket)) as { result?: { tools?: Array<{ name: string }> } };\n    expect(response.result?.tools?.[0]?.name).toBe('ping');\n    socket.destroy();\n  });\n\n  it('serves multiple concurrent secondary clients', async () => {\n    const sock = 'tcp://127.0.0.1:0';\n    let handle: IpcSocketServerHandle;\n    try {\n      handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n    } catch (error: unknown) {\n      if ((error as NodeJS.ErrnoException).code === 'EPERM') return;\n      throw error;\n    }\n    handles.push(handle);\n\n    const sockets = await Promise.all([connectSocket(sock), connectSocket(sock), connectSocket(sock)]);\n    const responses = await Promise.all(sockets.map((socket, index) => {\n      socket.write(`{\"jsonrpc\":\"2.0\",\"id\":${index + 1},\"method\":\"tools/list\",\"params\":{}}\\n`);\n      return readLine(socket);\n    }));\n    expect(responses).toHaveLength(3);\n    for (const response of responses) {\n      expect(JSON.parse(response).result.tools[0].name).toBe('ping');\n    }\n    sockets.forEach((socket) => socket.destroy());\n  });\n\n  it('refuses clients beyond SPECKIT_MAX_SECONDARY_CLIENTS', async () => {\n    const sock = 'tcp://127.0.0.1:0';\n    let handle: IpcSocketServerHandle;\n    try {\n      handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer, maxClients: 8 });\n    } catch (error: unknown) {\n      if ((error as NodeJS.ErrnoException).code === 'EPERM') return;\n      throw error;\n    }\n    handles.push(handle);\n    const sockets = await Promise.all(Array.from({ length: 8 }, () => connectSocket(sock)));\n    await waitFor(() => getIpcBridgeStats().secondary_clients_count === 8, 'eight active clients');\n\n    const ninth = await connectSocket(sock);\n    await new Promise<void>((resolvePromise) => ninth.once('close', () => resolvePromise()));\n    expect(getIpcBridgeStats().secondary_clients_count).toBe(8);\n    sockets.forEach((socket) => socket.destroy());\n  });\n\n  it('cleans up the socket file when the listener closes', async () => {\n    const dbDir = tempDir('daemon-bridge-cleanup-');\n    const unixSock = resolveIpcSocketPath(dbDir);\n    expect(unixSock).toBe(join(dbDir, 'daemon-ipc.sock'));\n    const sock = 'tcp://127.0.0.1:0';\n    let handle: IpcSocketServerHandle;\n    try {\n      handle = await startIpcSocketServer({ socketPath: sock, createServer: makeServer });\n    } catch (error: unknown) {\n      if ((error as NodeJS.ErrnoException).code === 'EPERM') return;\n      throw error;\n    }\n    expect(getIpcBridgeStats().socket_path).toMatch(/^tcp:\\/\\/127\\.0\\.0\\.1:\\d+$/);\n    await handle.close();\n    expect(getIpcBridgeStats().socket_path).toBeNull();\n  });\n});","lineStart":240,"lineEnd":337,"totalLines":337,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/launcher-ipc-bridge.vitest.ts","time":{"start":1781761536495,"end":1781761536498}},"metadata":{"openai":{"itemId":"fc_0de4afc595c86da3016a3386005e308191a0968ff2166bfd5d"}},"id":"prt_ed94371b6001jV0uklZjEV1BOK","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943435d0017ZeyD1A9r1kZ81"}}
{"type":"tool_use","timestamp":1781761536547,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_tJGt2fwnZFNwJXujynMvP07l","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/ipc/socket-server.ts","offset":190,"limit":110},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/ipc/socket-server.ts</path>\n<type>file</type>\n<content>\n190:   };\n191: }\n192: \n193: async function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n194:   await new Promise<void>((resolve, reject) => {\n195:     const onError = (error: NodeJS.ErrnoException) => {\n196:       server.off('listening', onListening);\n197:       reject(error);\n198:     };\n199:     const onListening = () => {\n200:       server.off('error', onError);\n201:       resolve();\n202:     };\n203:     server.once('error', onError);\n204:     server.once('listening', onListening);\n205:     if (socketPath.startsWith('tcp://')) {\n206:       const url = new URL(socketPath);\n207:       server.listen(Number.parseInt(url.port, 10), url.hostname);\n208:       return;\n209:     }\n210:     server.listen(socketPath);\n211:   });\n212: }\n213: \n214: // TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n215: // unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n216: // few times before giving up. Returns true once a retry binds, false if the port stays in use.\n217: async function retryTcpListenAfterEaddrInUse(\n218:   server: net.Server,\n219:   socketPath: string,\n220:   log: (message: string) => void,\n221: ): Promise<boolean> {\n222:   for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n223:     log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n224:     await sleep(delayMs);\n225:     try {\n226:       await listenOnce(server, socketPath);\n227:       return true;\n228:     } catch (error: unknown) {\n229:       const err = error as NodeJS.ErrnoException;\n230:       if (err.code !== 'EADDRINUSE') {\n231:         throw err;\n232:       }\n233:     }\n234:   }\n235:   return false;\n236: }\n237: \n238: // Tear down any server still registered in the module-global slots before a new bind reuses them.\n239: // startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n240: // dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n241: // shared stats. Re-entrancy must close the prior server first.\n242: async function disposeActiveServer(): Promise<void> {\n243:   const priorServer = activeServer;\n244:   for (const socket of activeSockets) {\n245:     socket.destroy();\n246:   }\n247:   activeSockets.clear();\n248:   activeTransports.clear();\n249:   if (priorServer) {\n250:     await new Promise<void>((resolve) => {\n251:       priorServer.close(() => resolve());\n252:     });\n253:   }\n254:   activeServer = null;\n255:   activeSocketPath = null;\n256: }\n257: \n258: async function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n259:   if (activeServer) {\n260:     await disposeActiveServer();\n261:   }\n262:   const socketPath = options.socketPath.startsWith('tcp://')\n263:     ? options.socketPath\n264:     : path.resolve(options.socketPath);\n265:   const log = options.log ?? ((message: string) => console.error(message));\n266:   const maxClients = options.maxClients ?? parseMaxClients();\n267:   const onActivity = options.onActivity ?? (() => undefined);\n268:   if (!socketPath.startsWith('tcp://')) {\n269:     const socketDir = path.dirname(socketPath);\n270:     fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n271:     // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n272:     // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n273:     // so refuse to bind under a dir not owned by us or that is group/world-writable.\n274:     try {\n275:       const st = fs.statSync(socketDir);\n276:       const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n277:       if (uid !== null && st.uid !== uid) {\n278:         throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n279:       }\n280:       if ((st.mode & 0o022) !== 0) {\n281:         throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n282:       }\n283:     } catch (error: unknown) {\n284:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n285:       if (code !== 'ENOENT') throw error;\n286:     }\n287:     // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n288:     // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n289:     // protection so a symlink whose target we would later chmod cannot be used to redirect the\n290:     // permission change onto an arbitrary file.\n291:     try {\n292:       const linkStat = fs.lstatSync(socketPath);\n293:       if (linkStat.isSymbolicLink()) {\n294:         throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n295:       }\n296:     } catch (error: unknown) {\n297:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n298:       if (code !== 'ENOENT') throw error;\n299:     }\n\n(Showing lines 190-299 of 447. Use offset=300 to continue.)\n</content>","metadata":{"preview":"  };\n}\n\nasync function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n  await new Promise<void>((resolve, reject) => {\n    const onError = (error: NodeJS.ErrnoException) => {\n      server.off('listening', onListening);\n      reject(error);\n    };\n    const onListening = () => {\n      server.off('error', onError);\n      resolve();\n    };\n    server.once('error', onError);\n    server.once('listening', onListening);\n    if (socketPath.startsWith('tcp://')) {\n      const url = new URL(socketPath);\n      server.listen(Number.parseInt(url.port, 10), url.hostname);\n      return;\n    }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/ipc/socket-server.ts","text":"  };\n}\n\nasync function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n  await new Promise<void>((resolve, reject) => {\n    const onError = (error: NodeJS.ErrnoException) => {\n      server.off('listening', onListening);\n      reject(error);\n    };\n    const onListening = () => {\n      server.off('error', onError);\n      resolve();\n    };\n    server.once('error', onError);\n    server.once('listening', onListening);\n    if (socketPath.startsWith('tcp://')) {\n      const url = new URL(socketPath);\n      server.listen(Number.parseInt(url.port, 10), url.hostname);\n      return;\n    }\n    server.listen(socketPath);\n  });\n}\n\n// TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n// unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n// few times before giving up. Returns true once a retry binds, false if the port stays in use.\nasync function retryTcpListenAfterEaddrInUse(\n  server: net.Server,\n  socketPath: string,\n  log: (message: string) => void,\n): Promise<boolean> {\n  for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n    log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n    await sleep(delayMs);\n    try {\n      await listenOnce(server, socketPath);\n      return true;\n    } catch (error: unknown) {\n      const err = error as NodeJS.ErrnoException;\n      if (err.code !== 'EADDRINUSE') {\n        throw err;\n      }\n    }\n  }\n  return false;\n}\n\n// Tear down any server still registered in the module-global slots before a new bind reuses them.\n// startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n// dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n// shared stats. Re-entrancy must close the prior server first.\nasync function disposeActiveServer(): Promise<void> {\n  const priorServer = activeServer;\n  for (const socket of activeSockets) {\n    socket.destroy();\n  }\n  activeSockets.clear();\n  activeTransports.clear();\n  if (priorServer) {\n    await new Promise<void>((resolve) => {\n      priorServer.close(() => resolve());\n    });\n  }\n  activeServer = null;\n  activeSocketPath = null;\n}\n\nasync function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n  if (activeServer) {\n    await disposeActiveServer();\n  }\n  const socketPath = options.socketPath.startsWith('tcp://')\n    ? options.socketPath\n    : path.resolve(options.socketPath);\n  const log = options.log ?? ((message: string) => console.error(message));\n  const maxClients = options.maxClients ?? parseMaxClients();\n  const onActivity = options.onActivity ?? (() => undefined);\n  if (!socketPath.startsWith('tcp://')) {\n    const socketDir = path.dirname(socketPath);\n    fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n    // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n    // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n    // so refuse to bind under a dir not owned by us or that is group/world-writable.\n    try {\n      const st = fs.statSync(socketDir);\n      const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n      if (uid !== null && st.uid !== uid) {\n        throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n      }\n      if ((st.mode & 0o022) !== 0) {\n        throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n    // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n    // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n    // protection so a symlink whose target we would later chmod cannot be used to redirect the\n    // permission change onto an arbitrary file.\n    try {\n      const linkStat = fs.lstatSync(socketPath);\n      if (linkStat.isSymbolicLink()) {\n        throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }","lineStart":190,"lineEnd":299,"totalLines":447,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/lib/ipc/socket-server.ts","time":{"start":1781761536544,"end":1781761536547}},"metadata":{"openai":{"itemId":"fc_0de4afc595c86da3016a3386005e348191a5f6aafd9de3c337"}},"id":"prt_ed94371f0001n4hrAHrU2Kvs4i","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943435d0017ZeyD1A9r1kZ81"}}
{"type":"step_finish","timestamp":1781761536863,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"id":"prt_ed943735c001kuKvHFMNV1dVLf","reason":"tool-calls","snapshot":"c29c491d2807ad2c4534b5d44bf0f760f98123c6","messageID":"msg_ed943435d0017ZeyD1A9r1kZ81","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","type":"step-finish","tokens":{"total":141298,"input":12276,"output":270,"reasoning":240,"cache":{"write":0,"read":128512}},"cost":0}}
{"type":"step_start","timestamp":1781761538777,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"id":"prt_ed9437ad4001H1pkRrPHcVXZOX","messageID":"msg_ed943748d001K1Wlv6cYNV7gOv","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","snapshot":"c29c491d2807ad2c4534b5d44bf0f760f98123c6","type":"step-start"}}
{"type":"tool_use","timestamp":1781761555218,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_pLSap7kq25L1ckWiuu4tNqgT","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Bulk Delete\n3: // ────────────────────────────────────────────────────────────────\n4: // Tier-based bulk deletion of memories with safety gates.\n5: // Eliminates the need for direct DB scripts when cleaning up\n6: // Deprecated/temporary memories at scale.\n7: import { checkDatabaseUpdated } from '../core/index.js';\n8: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n9: import * as vectorIndex from '../lib/search/vector-index.js';\n10: import * as checkpoints from '../lib/storage/checkpoints.js';\n11: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { createStatediffAction } from '../lib/storage/statediff.js';\n14: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { recordHistory } from '../lib/storage/history.js';\n18: import { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\n19: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: \n23: import type { MCPResponse } from './types.js';\n24: \n25: // Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n26: // Feature catalog: Per-memory history log\n27: \n28: /* ───────────────────────────────────────────────────────────────\n29:    1. TYPES\n30: ──────────────────────────────────────────────────────────────── */\n31: \n32: interface BulkDeleteArgs {\n33:   tier: string;\n34:   specFolder?: string;\n35:   confirm: boolean;\n36:   olderThanDays?: number;\n37:   skipCheckpoint?: boolean;\n38: }\n39: \n40: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n41:   if (!database || !('prepare' in database)) return false;\n42:   try {\n43:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n44:     return columns.some((column) => column.name === 'deleted_at');\n45:   } catch {\n46:     return false;\n47:   }\n48: }\n49: \n50: function isSoftDeleteTombstonesEnabled(): boolean {\n51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n52: }\n53: \n54: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n55:   if (!isSoftDeleteTombstonesEnabled()) {\n56:     return vectorIndex.deleteMemory(memoryId, database);\n57:   }\n58: \n59:   if (!hasDeletedAtColumn(database)) {\n60:     return vectorIndex.deleteMemory(memoryId, database);\n61:   }\n62: \n63:   const deletedAt = new Date().toISOString();\n64:   const result = database.prepare(`\n65:     UPDATE memory_index\n66:     SET deleted_at = COALESCE(deleted_at, ?),\n67:         updated_at = datetime('now')\n68:     WHERE id = ?\n69:   `).run(deletedAt, memoryId);\n70:   return result.changes > 0;\n71: }\n72: \n73: /* ───────────────────────────────────────────────────────────────\n74:     2. HANDLER\n75: ──────────────────────────────────────────────────────────────── */\n76: \n77: async function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n78:   await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n79:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n80:   if (restoreBarrier) {\n81:     return createMCPErrorResponse({\n82:       tool: 'memory_bulk_delete',\n83:       error: restoreBarrier.message,\n84:       code: restoreBarrier.code,\n85:       details: {\n86:         tier: args.tier ?? null,\n87:         specFolder: args.specFolder ?? null,\n88:       },\n89:       recovery: {\n90:         hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n91:         actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   await checkDatabaseUpdated();\n98: \n99:   const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n100: \n101:   // Validation\n102:   if (!tier || typeof tier !== 'string') {\n103:     throw new Error('tier is required and must be a string');\n104:   }\n105: \n106:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n107:   if (!validTiers.includes(tier)) {\n108:     throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n109:   }\n110: \n111:   if (!confirm) {\n112:     throw new Error('Bulk delete requires confirm: true as a safety gate');\n113:   }\n114: \n115:   // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n116:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n117:     throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n118:   }\n119: \n120:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n121:     throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n122:   }\n123: \n124:   if (\n125:     olderThanDays !== undefined\n126:     && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n127:   ) {\n128:     throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n129:   }\n130: \n131:   const database = vectorIndex.getDb();\n132:   if (!database) {\n133:     return createMCPErrorResponse({\n134:       tool: 'memory_bulk_delete',\n135:       error: 'Memory bulk delete aborted: database unavailable',\n136:       code: 'E_DB_UNAVAILABLE',\n137:       details: {\n138:         tier,\n139:         specFolder: specFolder || null,\n140:         olderThanDays: olderThanDays || null,\n141:       },\n142:       recovery: {\n143:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n144:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n145:         severity: 'error',\n146:       },\n147:     });\n148:   }\n149: \n150:   // Build query to count affected memories\n151:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n152:   const countParams: unknown[] = [tier];\n153: \n154:   if (specFolder) {\n155:     countSql += ' AND spec_folder = ?';\n156:     countParams.push(specFolder);\n157:   }\n158: \n159:   if (olderThanDays !== undefined) {\n160:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n161:     countParams.push(olderThanDays);\n162:   }\n163: \n164:   const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n165:   const affectedCount = countResult.count;\n166: \n167:   if (affectedCount === 0) {\n168:     return createMCPSuccessResponse({\n169:       tool: 'memory_bulk_delete',\n170:       summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n172:       hints: ['Use memory_list() to browse existing memories'],\n173:     });\n174:   }\n175: \n176:   // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n177:   let checkpointName: string | null = null;\n178:   if (!skipCheckpoint) {\n179:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n181: \n182:     try {\n183:       const checkpoint = checkpoints.createCheckpoint({\n184:         name: proposedCheckpointName,\n185:         specFolder,\n186:         metadata: {\n187:           reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n188:           tier,\n189:           affectedCount,\n190:           olderThanDays: olderThanDays || null,\n191:         },\n192:       });\n193: \n194:       if (!checkpoint) {\n195:         const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n196:         if (tier === 'constitutional' || tier === 'critical') {\n197:           throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n198:         }\n199:         console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n200:       } else {\n201:         checkpointName = checkpoint.name;\n202:         console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n203:       }\n204:     } catch (cpErr: unknown) {\n205:       const message = toErrorMessage(cpErr);\n206:       console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n207:       // High-safety tiers require a valid checkpoint.\n208:       if (tier === 'constitutional' || tier === 'critical') {\n209:         throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n210:       }\n211:       // Lower tiers can proceed with explicit no-rollback notice.\n212:       checkpointName = null;\n213:     }\n214:   } else {\n215:     console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n216:   }\n217: \n218:   // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n219:   let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n220:   const selectParams: unknown[] = [tier];\n221: \n222:   if (specFolder) {\n223:     selectSql += ' AND spec_folder = ?';\n224:     selectParams.push(specFolder);\n225:   }\n226: \n227:   if (olderThanDays !== undefined) {\n228:     selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n229:     selectParams.push(olderThanDays);\n230:   }\n231: \n232:   const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n233:     id: number;\n234:     content_hash: string | null;\n235:     file_path: string | null;\n236:     spec_folder: string | null;\n237:   }>;\n238: \n239:   // Perform deletion in a transaction\n240:   let deletedCount = 0;\n241:   const deletedIds: number[] = [];\n242: \n243:   causalEdges.init(database);\n244: \n245:   const bulkDeleteTx = database.transaction(() => {\n246:     for (const memory of memoriesToDelete) {\n247:       if (tombstoneMemory(database, memory.id)) {\n248:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n249:         try {\n250:           recordHistory(\n251:             memory.id,\n252:             'DELETE',\n253:             memory.file_path ?? null,\n254:             null,\n255:             'mcp:memory_bulk_delete',\n256:             memory.spec_folder ?? null,\n257:           );\n258:         } catch (_histErr: unknown) {\n259:           // History recording is best-effort inside bulk delete\n260:         }\n261:         deletedCount++;\n262:         deletedIds.push(memory.id);\n263: \n264:         // Clean up causal edges\n265:         // Propagate edge-cleanup errors to fail the transaction.\n266:         // Previously errors were caught and logged, leaving orphan causal edges\n267:         // When memory rows were successfully deleted but edge cleanup failed.\n268:         causalEdges.deleteEdgesForMemory(String(memory.id), {\n269:           reason: 'memory row mutation cleanup',\n270:           command: 'memory-bulk-delete.handleMemoryBulkDelete',\n271:           restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n272:         });\n273:       }\n274:     }\n275:   });\n276: \n277:   bulkDeleteTx();\n278: \n279:   // Record in mutation ledger (single entry for bulk operation)\n280:   const ledgerRecorded = appendMutationLedgerSafe(database, {\n281:     mutationType: 'delete',\n282:     reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n283:     priorHash: null,\n284:     newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n285:     linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n286:     decisionMeta: {\n287:       tool: 'memory_bulk_delete',\n288:       tier,\n289:       specFolder: specFolder || null,\n290:       olderThanDays: olderThanDays || null,\n291:       totalDeleted: deletedCount,\n292:       checkpoint: checkpointName,\n293:       skipCheckpoint,\n294:     },\n295:     actor: 'mcp:memory_bulk_delete',\n296:   });\n297: \n298:   // Invalidate caches\n299:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n300:   if (deletedCount > 0) {\n301:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n302:     try {\n303:       postMutationHooks = runPostMutationHooks('bulk-delete', {\n304:         specFolder,\n305:         tier,\n306:         deletedCount,\n307:         statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n308:           target: 'memory_index',\n309:           key: String(id),\n310:           sourceOperation: 'bulk-delete',\n311:           metadata: { tier, specFolder: specFolder ?? null },\n312:         })),\n313:       });\n314:     } catch (hookError: unknown) {\n315:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n316:       postMutationHooks = {\n317:         latencyMs: 0, triggerCacheCleared: false,\n318:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n319:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n320:         errors: [msg],\n\n(Showing lines 1-320 of 372. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n// Feature catalog: Per-memory history log\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n    2. HANDLER\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        tier: args.tier ?? null,\n        specFolder: args.specFolder ?? null,\n      },\n      recovery: {\n        hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n\n  // Validation\n  if (!tier || typeof tier !== 'string') {\n    throw new Error('tier is required and must be a string');\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n  }\n\n  if (!confirm) {\n    throw new Error('Bulk delete requires confirm: true as a safety gate');\n  }\n\n  // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n  }\n\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n  }\n\n  if (\n    olderThanDays !== undefined\n    && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n  ) {\n    throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n  }\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: 'Memory bulk delete aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        tier,\n        specFolder: specFolder || null,\n        olderThanDays: olderThanDays || null,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Build query to count affected memories\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(olderThanDays);\n  }\n\n  const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  if (affectedCount === 0) {\n    return createMCPSuccessResponse({\n      tool: 'memory_bulk_delete',\n      summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n      data: { deleted: 0, tier, specFolder: specFolder || null },\n      hints: ['Use memory_list() to browse existing memories'],\n    });\n  }\n\n  // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n    try {\n      const checkpoint = checkpoints.createCheckpoint({\n        name: proposedCheckpointName,\n        specFolder,\n        metadata: {\n          reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n          tier,\n          affectedCount,\n          olderThanDays: olderThanDays || null,\n        },\n      });\n\n      if (!checkpoint) {\n        const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n        if (tier === 'constitutional' || tier === 'critical') {\n          throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n        }\n        console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n      } else {\n        checkpointName = checkpoint.name;\n        console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n      }\n    } catch (cpErr: unknown) {\n      const message = toErrorMessage(cpErr);\n      console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n      // High-safety tiers require a valid checkpoint.\n      if (tier === 'constitutional' || tier === 'critical') {\n        throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n      }\n      // Lower tiers can proceed with explicit no-rollback notice.\n      checkpointName = null;\n    }\n  } else {\n    console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n  }\n\n  // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n  let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n  const selectParams: unknown[] = [tier];\n\n  if (specFolder) {\n    selectSql += ' AND spec_folder = ?';\n    selectParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    selectParams.push(olderThanDays);\n  }\n\n  const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n    id: number;\n    content_hash: string | null;\n    file_path: string | null;\n    spec_folder: string | null;\n  }>;\n\n  // Perform deletion in a transaction\n  let deletedCount = 0;\n  const deletedIds: number[] = [];\n\n  causalEdges.init(database);\n\n  const bulkDeleteTx = database.transaction(() => {\n    for (const memory of memoriesToDelete) {\n      if (tombstoneMemory(database, memory.id)) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        try {\n          recordHistory(\n            memory.id,\n            'DELETE',\n            memory.file_path ?? null,\n            null,\n            'mcp:memory_bulk_delete',\n            memory.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort inside bulk delete\n        }\n        deletedCount++;\n        deletedIds.push(memory.id);\n\n        // Clean up causal edges\n        // Propagate edge-cleanup errors to fail the transaction.\n        // Previously errors were caught and logged, leaving orphan causal edges\n        // When memory rows were successfully deleted but edge cleanup failed.\n        causalEdges.deleteEdgesForMemory(String(memory.id), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-bulk-delete.handleMemoryBulkDelete',\n          restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n        });\n      }\n    }\n  });\n\n  bulkDeleteTx();\n\n  // Record in mutation ledger (single entry for bulk operation)\n  const ledgerRecorded = appendMutationLedgerSafe(database, {\n    mutationType: 'delete',\n    reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n    priorHash: null,\n    newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n    linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n    decisionMeta: {\n      tool: 'memory_bulk_delete',\n      tier,\n      specFolder: specFolder || null,\n      olderThanDays: olderThanDays || null,\n      totalDeleted: deletedCount,\n      checkpoint: checkpointName,\n      skipCheckpoint,\n    },\n    actor: 'mcp:memory_bulk_delete',\n  });\n\n  // Invalidate caches\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('bulk-delete', {\n        specFolder,\n        tier,\n        deletedCount,\n        statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n          target: 'memory_index',\n          key: String(id),\n          sourceOperation: 'bulk-delete',\n          metadata: { tier, specFolder: specFolder ?? null },\n        })),\n      });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],","lineStart":1,"lineEnd":320,"totalLines":372,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","time":{"start":1781761555197,"end":1781761555213}},"metadata":{"openai":{"itemId":"fc_021bca402a8feaa6016a3386132b4c81919b28899e1ea74f67"}},"id":"prt_ed943baf7001Me1k6diK9VMyd8","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943748d001K1Wlv6cYNV7gOv"}}
{"type":"tool_use","timestamp":1781761555297,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_gWanZPdWNlc2N86ZWc2cKYmF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n11: \n12: import type { MCPResponse } from './types.js';\n13: import type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n14: \n15: /** Handle the memory_retention_sweep MCP tool request. */\n16: async function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n17:   await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n18:   await checkDatabaseUpdated();\n19: \n20:   const database = vectorIndex.getDb();\n21:   if (!database) {\n22:     recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n23:     return createMCPErrorResponse({\n24:       tool: 'memory_retention_sweep',\n25:       error: 'Retention sweep aborted: database unavailable',\n26:       code: 'E_DB_UNAVAILABLE',\n27:       details: {\n28:         dryRun: args?.dryRun === true,\n29:       },\n30:       recovery: {\n31:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n32:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n33:         severity: 'error',\n34:       },\n35:     });\n36:   }\n37: \n38:   try {\n39:     const result = runMemoryRetentionSweep(database, {\n40:       dryRun: args?.dryRun === true,\n41:       feedbackRetention: args?.feedbackRetention,\n42:     });\n43:     const protectedSuffix = result.protectedCount > 0\n44:       ? `; protected ${result.protectedCount} high-tier/pinned row(s)`\n45:       : '';\n46:     const summary = result.dryRun\n47:       ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted${protectedSuffix}`\n48:       : `Swept ${result.swept} expired memory row(s); retained ${result.retained}${protectedSuffix}`;\n49: \n50:     const hints: string[] = [];\n51:     if (result.ledgerRecorded === false) {\n52:       hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n53:     }\n54:     if (result.dryRun && result.candidates.length > 0) {\n55:       hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n56:     }\n57:     recordMaintenanceRun('memory_retention_sweep', {\n58:       status: 'success',\n59:       counts: {\n60:         swept: result.swept,\n61:         retained: result.retained,\n62:         candidates: result.candidates.length,\n63:         protectedCount: result.protectedCount,\n64:       },\n65:       staleCandidates: result.candidates.length,\n66:     });\n67: \n68:     return createMCPSuccessResponse({\n69:       tool: 'memory_retention_sweep',\n70:       summary,\n71:       data: {\n72:         swept: result.swept,\n73:         retained: result.retained,\n74:         dryRun: result.dryRun,\n75:         durationMs: result.durationMs,\n76:         candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n77:           id: candidate.id,\n78:           deleteAfter: candidate.deleteAfter,\n79:           specFolder: candidate.specFolder,\n80:           filePath: candidate.filePath,\n81:         })),\n82:         deletedIds: result.deletedIds,\n83:         protectedCount: result.protectedCount,\n84:         protectedIds: result.protectedIds,\n85:         ledgerRecorded: result.ledgerRecorded,\n86:         ...(result.feedbackRetention ? {\n87:           feedbackRetention: {\n88:             mode: result.feedbackRetention.mode,\n89:             activeGatePassed: result.feedbackRetention.activeGatePassed,\n90:             activeBlocked: result.feedbackRetention.activeBlocked,\n91:             auditCount: result.feedbackRetention.auditCount,\n92:             protectedCount: result.feedbackRetention.protectedIds.length,\n93:             extendedCount: result.feedbackRetention.extendedIds.length,\n94:             deletedCount: result.feedbackRetention.deletedIds.length,\n95:           },\n96:           extendedIds: result.feedbackRetention.extendedIds,\n97:         } : {}),\n98:       },\n99:       hints,\n100:     });\n101:   } catch (error: unknown) {\n102:     recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n103:     return createMCPErrorResponse({\n104:       tool: 'memory_retention_sweep',\n105:       error: `Retention sweep failed: ${toErrorMessage(error)}`,\n106:       code: 'E_RETENTION_SWEEP_FAILED',\n107:       details: {\n108:         dryRun: args?.dryRun === true,\n109:       },\n110:       recovery: {\n111:         hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n112:         actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n113:         severity: 'error',\n114:       },\n115:     });\n116:   }\n117: }\n118: \n119: export { handleMemoryRetentionSweep };\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: 'Retention sweep aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  try {\n    const result = runMemoryRetentionSweep(database, {\n      dryRun: args?.dryRun === true,\n      feedbackRetention: args?.feedbackRetention,\n    });\n    const protectedSuffix = result.protectedCount > 0\n      ? `; protected ${result.protectedCount} high-tier/pinned row(s)`\n      : '';\n    const summary = result.dryRun\n      ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted${protectedSuffix}`\n      : `Swept ${result.swept} expired memory row(s); retained ${result.retained}${protectedSuffix}`;\n\n    const hints: string[] = [];\n    if (result.ledgerRecorded === false) {\n      hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n    }\n    if (result.dryRun && result.candidates.length > 0) {\n      hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n    }\n    recordMaintenanceRun('memory_retention_sweep', {\n      status: 'success',\n      counts: {\n        swept: result.swept,\n        retained: result.retained,\n        candidates: result.candidates.length,\n        protectedCount: result.protectedCount,\n      },\n      staleCandidates: result.candidates.length,\n    });\n\n    return createMCPSuccessResponse({\n      tool: 'memory_retention_sweep',\n      summary,\n      data: {\n        swept: result.swept,\n        retained: result.retained,\n        dryRun: result.dryRun,\n        durationMs: result.durationMs,\n        candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n          id: candidate.id,\n          deleteAfter: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        })),\n        deletedIds: result.deletedIds,\n        protectedCount: result.protectedCount,\n        protectedIds: result.protectedIds,\n        ledgerRecorded: result.ledgerRecorded,\n        ...(result.feedbackRetention ? {\n          feedbackRetention: {\n            mode: result.feedbackRetention.mode,\n            activeGatePassed: result.feedbackRetention.activeGatePassed,\n            activeBlocked: result.feedbackRetention.activeBlocked,\n            auditCount: result.feedbackRetention.auditCount,\n            protectedCount: result.feedbackRetention.protectedIds.length,\n            extendedCount: result.feedbackRetention.extendedIds.length,\n            deletedCount: result.feedbackRetention.deletedIds.length,\n          },\n          extendedIds: result.feedbackRetention.extendedIds,\n        } : {}),\n      },\n      hints,\n    });\n  } catch (error: unknown) {\n    recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: `Retention sweep failed: ${toErrorMessage(error)}`,\n      code: 'E_RETENTION_SWEEP_FAILED',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n        actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryRetentionSweep };","lineStart":1,"lineEnd":119,"totalLines":119,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","time":{"start":1781761555255,"end":1781761555286}},"metadata":{"openai":{"itemId":"fc_021bca402a8feaa6016a3386132b588191a048f3db5a6aa9e7"}},"id":"prt_ed943baff001ffuLVE4rpMwc6k","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943748d001K1Wlv6cYNV7gOv"}}
{"type":"tool_use","timestamp":1781761555297,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_ai1ifpQIsHCtmwAtLuFgqB84","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Checkpoints\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    1. LIB MODULE IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import * as checkpoints from '../lib/storage/checkpoints.js';\n10: import * as vectorIndex from '../lib/search/vector-index.js';\n11: import * as bm25Index from '../lib/search/bm25-index.js';\n12: import * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\n13: import * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\n14: import { executeAutoPromotion } from '../lib/search/auto-promotion.js';\n15: import { recordSelection } from '../lib/search/learned-feedback.js';\n16: import { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\n17: import { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\n18: import { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\n19: import { checkDatabaseUpdated } from '../core/index.js';\n20: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n21: import { requireDb, toErrorMessage } from '../utils/index.js';\n22: import * as sessionManager from '../lib/session/session-manager.js';\n23: \n24: // Standardized response structure\n25: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n26: \n27: // Shared handler types\n28: import type { MCPResponse } from './types.js';\n29: \n30: // Feature catalog: Checkpoint creation (checkpoint_create)\n31: // Feature catalog: Checkpoint listing (checkpoint_list)\n32: // Feature catalog: Checkpoint restore (checkpoint_restore)\n33: // Feature catalog: Checkpoint deletion (checkpoint_delete)\n34: // Feature catalog: Checkpoint delete confirmName safety\n35: \n36: \n37: /* ───────────────────────────────────────────────────────────────\n38:    2. TYPES\n39: ──────────────────────────────────────────────────────────────── */\n40: \n41: interface CheckpointCreateArgs {\n42:   name: string;\n43:   specFolder?: string;\n44:   tenantId?: string;\n45:   userId?: string;\n46:   agentId?: string;\n47:   includeEmbeddings?: boolean;\n48:   metadata?: Record<string, unknown>;\n49: }\n50: \n51: interface CheckpointListArgs {\n52:   specFolder?: string;\n53:   tenantId?: string;\n54:   userId?: string;\n55:   agentId?: string;\n56:   limit?: number;\n57: }\n58: \n59: interface CheckpointRestoreArgs {\n60:   name: string;\n61:   tenantId?: string;\n62:   userId?: string;\n63:   agentId?: string;\n64:   clearExisting?: boolean;\n65: }\n66: \n67: interface CheckpointDeleteArgs {\n68:   name: string;\n69:   tenantId?: string;\n70:   userId?: string;\n71:   agentId?: string;\n72:   confirmName: string;\n73: }\n74: \n75: interface CheckpointScopeArgs {\n76:   tenantId?: string;\n77:   userId?: string;\n78:   agentId?: string;\n79: }\n80: \n81: interface MemoryValidateArgs {\n82:   id: number | string;\n83:   wasUseful: boolean;\n84:   queryId?: string;\n85:   queryTerms?: string[];\n86:   resultRank?: number;\n87:   totalResultsShown?: number;\n88:   searchMode?: string;\n89:   intent?: string;\n90:   sessionId?: string;\n91:   notes?: string;\n92: }\n93: \n94: interface ValidationResult {\n95:   confidence: number;\n96:   validationCount: number;\n97:   positiveValidationCount: number;\n98:   promotionEligible: boolean;\n99: }\n100: \n101: function resolveValidationQueryText(\n102:   database: ReturnType<typeof requireDb>,\n103:   queryId?: string,\n104: ): string | null {\n105:   if (typeof queryId !== 'string') {\n106:     return null;\n107:   }\n108: \n109:   const normalizedQueryId = queryId.trim();\n110:   if (normalizedQueryId.length === 0) {\n111:     return null;\n112:   }\n113: \n114:   if (/\\s/.test(normalizedQueryId)) {\n115:     return normalizedQueryId;\n116:   }\n117: \n118:   const consumptionMatch = normalizedQueryId.match(/^(?:consumption:)?(\\d+)$/);\n119:   if (!consumptionMatch) {\n120:     return null;\n121:   }\n122: \n123:   const consumptionLogTable = database.prepare(`\n124:     SELECT 1\n125:     FROM sqlite_master\n126:     WHERE type = 'table'\n127:       AND name = 'consumption_log'\n128:     LIMIT 1\n129:   `).get();\n130:   if (!consumptionLogTable) {\n131:     return null;\n132:   }\n133: \n134:   // The clean consumption_log schema stores only a query fingerprint; raw\n135:   // query text exists solely on unmigrated legacy tables. Without the column\n136:   // there is nothing to resolve, and selecting it would throw.\n137:   const columns = database.prepare(`PRAGMA table_info(consumption_log)`).all() as Array<{ name: string }>;\n138:   if (!columns.some((column) => column.name === 'query_text')) {\n139:     return null;\n140:   }\n141: \n142:   const row = database.prepare(`\n143:     SELECT query_text\n144:     FROM consumption_log\n145:     WHERE id = ?\n146:       AND query_text IS NOT NULL\n147:       AND TRIM(query_text) != ''\n148:     LIMIT 1\n149:   `).get(Number.parseInt(consumptionMatch[1], 10)) as { query_text?: string } | undefined;\n150: \n151:   return typeof row?.query_text === 'string' && row.query_text.trim().length > 0\n152:     ? row.query_text\n153:     : null;\n154: }\n155: \n156: function parseMemoryId(rawId: number | string): number {\n157:   const numericId = typeof rawId === 'string'\n158:     ? Number.parseInt(rawId.trim(), 10)\n159:     : rawId;\n160: \n161:   if (\n162:     typeof numericId !== 'number' ||\n163:     !Number.isSafeInteger(numericId) ||\n164:     numericId <= 0 ||\n165:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n166:   ) {\n167:     throw new Error('id must be a positive integer');\n168:   }\n169: \n170:   return numericId;\n171: }\n172: \n173: function parseCheckpointMetadata(rawMetadata: unknown): Record<string, unknown> {\n174:   if (!rawMetadata) {\n175:     return {};\n176:   }\n177: \n178:   if (typeof rawMetadata === 'string') {\n179:     try {\n180:       const parsed = JSON.parse(rawMetadata);\n181:       return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n182:         ? parsed as Record<string, unknown>\n183:         : {};\n184:     } catch (_error: unknown) {\n185:       return {};\n186:     }\n187:   }\n188: \n189:   return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n190:     ? rawMetadata as Record<string, unknown>\n191:     : {};\n192: }\n193: \n194: function validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n195:   const validateValue = (\n196:     value: string | undefined,\n197:     field: keyof CheckpointScopeArgs,\n198:     options: { trim?: boolean } = {},\n199:   ): string | undefined => {\n200:     if (value === undefined) {\n201:       return undefined;\n202:     }\n203:     if (typeof value !== 'string') {\n204:       throw new Error(`${field} must be a string`);\n205:     }\n206:     return options.trim ? value.trim() : value;\n207:   };\n208: \n209:   const tenantId = validateValue(args.tenantId, 'tenantId', { trim: true });\n210:   const userId = validateValue(args.userId, 'userId');\n211:   const agentId = validateValue(args.agentId, 'agentId');\n212:   const hasActorScope = userId !== undefined || agentId !== undefined;\n213: \n214:   if (\n215:     hasActorScope\n216:     && tenantId !== undefined\n217:     && tenantId.trim().length === 0\n218:   ) {\n219:     throw new Error('tenantId must be a non-empty string when userId or agentId is provided');\n220:   }\n\n(Showing lines 1-220 of 918. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\nimport { executeAutoPromotion } from '../lib/search/auto-promotion.js';\nimport { recordSelection } from '../lib/search/learned-feedback.js';\nimport { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\nimport { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\nimport { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\nimport { executeAutoPromotion } from '../lib/search/auto-promotion.js';\nimport { recordSelection } from '../lib/search/learned-feedback.js';\nimport { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\nimport { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\nimport { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { requireDb, toErrorMessage } from '../utils/index.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\n\n// Standardized response structure\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n\n// Shared handler types\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint listing (checkpoint_list)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Feature catalog: Checkpoint deletion (checkpoint_delete)\n// Feature catalog: Checkpoint delete confirmName safety\n\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface CheckpointCreateArgs {\n  name: string;\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  includeEmbeddings?: boolean;\n  metadata?: Record<string, unknown>;\n}\n\ninterface CheckpointListArgs {\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit?: number;\n}\n\ninterface CheckpointRestoreArgs {\n  name: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  clearExisting?: boolean;\n}\n\ninterface CheckpointDeleteArgs {\n  name: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  confirmName: string;\n}\n\ninterface CheckpointScopeArgs {\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n}\n\ninterface MemoryValidateArgs {\n  id: number | string;\n  wasUseful: boolean;\n  queryId?: string;\n  queryTerms?: string[];\n  resultRank?: number;\n  totalResultsShown?: number;\n  searchMode?: string;\n  intent?: string;\n  sessionId?: string;\n  notes?: string;\n}\n\ninterface ValidationResult {\n  confidence: number;\n  validationCount: number;\n  positiveValidationCount: number;\n  promotionEligible: boolean;\n}\n\nfunction resolveValidationQueryText(\n  database: ReturnType<typeof requireDb>,\n  queryId?: string,\n): string | null {\n  if (typeof queryId !== 'string') {\n    return null;\n  }\n\n  const normalizedQueryId = queryId.trim();\n  if (normalizedQueryId.length === 0) {\n    return null;\n  }\n\n  if (/\\s/.test(normalizedQueryId)) {\n    return normalizedQueryId;\n  }\n\n  const consumptionMatch = normalizedQueryId.match(/^(?:consumption:)?(\\d+)$/);\n  if (!consumptionMatch) {\n    return null;\n  }\n\n  const consumptionLogTable = database.prepare(`\n    SELECT 1\n    FROM sqlite_master\n    WHERE type = 'table'\n      AND name = 'consumption_log'\n    LIMIT 1\n  `).get();\n  if (!consumptionLogTable) {\n    return null;\n  }\n\n  // The clean consumption_log schema stores only a query fingerprint; raw\n  // query text exists solely on unmigrated legacy tables. Without the column\n  // there is nothing to resolve, and selecting it would throw.\n  const columns = database.prepare(`PRAGMA table_info(consumption_log)`).all() as Array<{ name: string }>;\n  if (!columns.some((column) => column.name === 'query_text')) {\n    return null;\n  }\n\n  const row = database.prepare(`\n    SELECT query_text\n    FROM consumption_log\n    WHERE id = ?\n      AND query_text IS NOT NULL\n      AND TRIM(query_text) != ''\n    LIMIT 1\n  `).get(Number.parseInt(consumptionMatch[1], 10)) as { query_text?: string } | undefined;\n\n  return typeof row?.query_text === 'string' && row.query_text.trim().length > 0\n    ? row.query_text\n    : null;\n}\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('id must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction parseCheckpointMetadata(rawMetadata: unknown): Record<string, unknown> {\n  if (!rawMetadata) {\n    return {};\n  }\n\n  if (typeof rawMetadata === 'string') {\n    try {\n      const parsed = JSON.parse(rawMetadata);\n      return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n        ? parsed as Record<string, unknown>\n        : {};\n    } catch (_error: unknown) {\n      return {};\n    }\n  }\n\n  return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n    ? rawMetadata as Record<string, unknown>\n    : {};\n}\n\nfunction validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n  const validateValue = (\n    value: string | undefined,\n    field: keyof CheckpointScopeArgs,\n    options: { trim?: boolean } = {},\n  ): string | undefined => {\n    if (value === undefined) {\n      return undefined;\n    }\n    if (typeof value !== 'string') {\n      throw new Error(`${field} must be a string`);\n    }\n    return options.trim ? value.trim() : value;\n  };\n\n  const tenantId = validateValue(args.tenantId, 'tenantId', { trim: true });\n  const userId = validateValue(args.userId, 'userId');\n  const agentId = validateValue(args.agentId, 'agentId');\n  const hasActorScope = userId !== undefined || agentId !== undefined;\n\n  if (\n    hasActorScope\n    && tenantId !== undefined\n    && tenantId.trim().length === 0\n  ) {\n    throw new Error('tenantId must be a non-empty string when userId or agentId is provided');\n  }","lineStart":1,"lineEnd":220,"totalLines":918,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","time":{"start":1781761555265,"end":1781761555296}},"metadata":{"openai":{"itemId":"fc_021bca402a8feaa6016a3386132b6481919c8f178c0111685c"}},"id":"prt_ed943bb3b0011K1aOSeS5VOXta","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943748d001K1Wlv6cYNV7gOv"}}
{"type":"tool_use","timestamp":1781761555309,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_9qZSEeTwwGZBOILgrmQYSlFb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Delete\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* ───────────────────────────────────────────────────────────────\n34:    CORE LOGIC\n35: ──────────────────────────────────────────────────────────────── */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n181:     const deletedIds: number[] = [];\n182:     const hashById = new Map<number, MemoryHashSnapshot>();\n183: \n184:     if (database && 'prepare' in database) {\n185:       try {\n186:         const rows = database.prepare(`\n187:           SELECT id, content_hash, spec_folder, file_path\n188:           FROM memory_index\n189:           WHERE spec_folder = ?\n190:         `).all(specFolder as string) as MemoryHashSnapshot[];\n191: \n192:         for (const row of rows) {\n193:           hashById.set(row.id, row);\n194:         }\n195:       } catch (_err: unknown) {\n196:         // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n197:       }\n198:     }\n199: \n200:     if (memories.length > 0) {\n201:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n202:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n203:       try {\n204:         const checkpoint = checkpoints.createCheckpoint({\n205:           name: proposedCheckpointName,\n206:           specFolder,\n207:           metadata: {\n208:             reason: 'auto-checkpoint before bulk delete',\n209:             memoryCount: memories.length,\n210:           },\n211:         });\n212: \n213:         if (checkpoint) {\n214:           checkpointName = checkpoint.name;\n215:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n216:         } else {\n217:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n218:           checkpointName = null;\n219:         }\n220:       } catch (cpErr: unknown) {\n221:         const message = toErrorMessage(cpErr);\n222:         console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n223:         // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n224:         console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n225:         checkpointName = null;\n226:       }\n227:     }\n228: \n229:     // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n230:     causalEdges.init(database);\n231:     const bulkDeleteTx = database.transaction(() => {\n232:       for (const memory of memories) {\n233:         if (tombstoneMemory(database, memory.id)) {\n234:           // Record DELETE history after confirmed delete (no FK, history rows survive).\n235:           try {\n236:             const snapshot = hashById.get(memory.id);\n237:             recordHistory(\n238:               memory.id,\n239:               'DELETE',\n240:               snapshot?.file_path ?? null,\n241:               null,\n242:               'mcp:memory_delete',\n243:               snapshot?.spec_folder ?? null,\n244:             );\n245:           } catch (_histErr: unknown) {\n246:             // History recording is best-effort inside bulk delete\n247:           }\n248:           deletedCount++;\n249:           deletedIds.push(memory.id);\n250:           causalEdges.deleteEdgesForMemory(String(memory.id), {\n251:             reason: 'memory row mutation cleanup',\n252:             command: 'memory-crud-delete.handleMemoryDelete',\n253:             restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n254:           });\n255:         }\n256:       }\n257: \n258:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n259:       for (const deletedId of deletedIds) {\n260:         const snapshot = hashById.get(deletedId) ?? null;\n\n(Showing lines 1-260 of 344. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper — wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {\n        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id), {\n            reason: 'memory row mutation cleanup',\n            command: 'memory-crud-delete.handleMemoryDelete',\n            restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n          });\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;","lineStart":1,"lineEnd":260,"totalLines":344,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781761555302,"end":1781761555307}},"metadata":{"openai":{"itemId":"fc_021bca402a8feaa6016a3386132b688191aca0f5bef1a88b29"}},"id":"prt_ed943bb44001X1U7QZiNlAE5eS","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943748d001K1Wlv6cYNV7gOv"}}
{"type":"tool_use","timestamp":1781761555386,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_2jVowSzdiINWLriDrvVvWJbV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/embedder-set.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/embedder-set.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Embedder Set Handler\n3: // -------------------------------------------------------------------\n4: \n5: import { checkDatabaseUpdated } from '../core/index.js';\n6: import { createMCPSuccessResponse } from '../lib/response/envelope.js';\n7: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n8: import { get_db } from '../lib/search/vector-index-store.js';\n9: import { ensureVecTableForDim, getManifest } from '../lib/embedders/index.js';\n10: import { createLogger } from '../lib/utils/logger.js';\n11: import {\n12:   estimateEta,\n13:   getJobStatus,\n14:   startReindex,\n15: } from '../lib/embedders/reindex.js';\n16: \n17: import type { MCPResponse } from './types.js';\n18: \n19: // -------------------------------------------------------------------\n20: // 1. TYPE DEFINITIONS\n21: // -------------------------------------------------------------------\n22: \n23: export interface EmbedderSetArgs {\n24:   readonly name: string;\n25: }\n26: \n27: interface EmbedderSetData {\n28:   readonly jobId: string;\n29:   readonly eta: number | null;\n30:   readonly status: 'queued' | 'running';\n31: }\n32: \n33: const MAX_EMBEDDER_NAME_LENGTH = 256;\n34: const logger = createLogger('embedder-set');\n35: \n36: // -------------------------------------------------------------------\n37: // 2. ERRORS\n38: // -------------------------------------------------------------------\n39: \n40: export class UnknownEmbedderError extends Error {\n41:   readonly code = 'UNKNOWN_EMBEDDER';\n42: \n43:   constructor(name: string) {\n44:     super(`UNKNOWN_EMBEDDER: ${name}`);\n45:     this.name = 'UNKNOWN_EMBEDDER';\n46:     Object.setPrototypeOf(this, new.target.prototype);\n47:   }\n48: }\n49: \n50: // -------------------------------------------------------------------\n51: // 3. HANDLER\n52: // -------------------------------------------------------------------\n53: \n54: export async function handleEmbedderSet(args: EmbedderSetArgs): Promise<MCPResponse> {\n55:   await ensureMemoryRuntimeInitialized('handler:embedder_set');\n56:   const startTime = Date.now();\n57:   await checkDatabaseUpdated();\n58: \n59:   const name = typeof args.name === 'string' ? args.name.trim() : '';\n60:   if (name.length > MAX_EMBEDDER_NAME_LENGTH) {\n61:     throw new RangeError(`Embedder name must be at most ${MAX_EMBEDDER_NAME_LENGTH} characters`);\n62:   }\n63:   const manifest = getManifest(name);\n64:   if (!manifest) {\n65:     throw new UnknownEmbedderError(name);\n66:   }\n67: \n68:   const db = get_db();\n69:   ensureVecTableForDim(db, manifest.dim);\n70: \n71:   const jobId = startReindex({ toName: manifest.name }, { db });\n72:   const job = getJobStatus(jobId, db);\n73:   const status = job?.status === 'running' ? 'running' : 'queued';\n74:   const data: EmbedderSetData = {\n75:     jobId,\n76:     eta: estimateEta(job),\n77:     status,\n78:   };\n79: \n80:   logger.info('embedder swap queued', {\n81:     event: 'embedder_swap',\n82:     toName: manifest.name,\n83:     toDim: manifest.dim,\n84:     jobId,\n85:     status,\n86:   });\n87: \n88:   return createMCPSuccessResponse({\n89:     tool: 'embedder_set',\n90:     summary: `Re-index queued for ${manifest.name}`,\n91:     data,\n92:     startTime,\n93:   });\n94: }\n95: \n96: export const handle_embedder_set = handleEmbedderSet;\n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Embedder Set Handler\n// -------------------------------------------------------------------\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { get_db } from '../lib/search/vector-index-store.js';\nimport { ensureVecTableForDim, getManifest } from '../lib/embedders/index.js';\nimport { createLogger } from '../lib/utils/logger.js';\nimport {\n  estimateEta,\n  getJobStatus,\n  startReindex,\n} from '../lib/embedders/reindex.js';\n\nimport type { MCPResponse } from './types.js';\n\n// -------------------------------------------------------------------\n// 1. TYPE DEFINITIONS","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/embedder-set.ts","text":"// -------------------------------------------------------------------\n// MODULE: Embedder Set Handler\n// -------------------------------------------------------------------\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { get_db } from '../lib/search/vector-index-store.js';\nimport { ensureVecTableForDim, getManifest } from '../lib/embedders/index.js';\nimport { createLogger } from '../lib/utils/logger.js';\nimport {\n  estimateEta,\n  getJobStatus,\n  startReindex,\n} from '../lib/embedders/reindex.js';\n\nimport type { MCPResponse } from './types.js';\n\n// -------------------------------------------------------------------\n// 1. TYPE DEFINITIONS\n// -------------------------------------------------------------------\n\nexport interface EmbedderSetArgs {\n  readonly name: string;\n}\n\ninterface EmbedderSetData {\n  readonly jobId: string;\n  readonly eta: number | null;\n  readonly status: 'queued' | 'running';\n}\n\nconst MAX_EMBEDDER_NAME_LENGTH = 256;\nconst logger = createLogger('embedder-set');\n\n// -------------------------------------------------------------------\n// 2. ERRORS\n// -------------------------------------------------------------------\n\nexport class UnknownEmbedderError extends Error {\n  readonly code = 'UNKNOWN_EMBEDDER';\n\n  constructor(name: string) {\n    super(`UNKNOWN_EMBEDDER: ${name}`);\n    this.name = 'UNKNOWN_EMBEDDER';\n    Object.setPrototypeOf(this, new.target.prototype);\n  }\n}\n\n// -------------------------------------------------------------------\n// 3. HANDLER\n// -------------------------------------------------------------------\n\nexport async function handleEmbedderSet(args: EmbedderSetArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:embedder_set');\n  const startTime = Date.now();\n  await checkDatabaseUpdated();\n\n  const name = typeof args.name === 'string' ? args.name.trim() : '';\n  if (name.length > MAX_EMBEDDER_NAME_LENGTH) {\n    throw new RangeError(`Embedder name must be at most ${MAX_EMBEDDER_NAME_LENGTH} characters`);\n  }\n  const manifest = getManifest(name);\n  if (!manifest) {\n    throw new UnknownEmbedderError(name);\n  }\n\n  const db = get_db();\n  ensureVecTableForDim(db, manifest.dim);\n\n  const jobId = startReindex({ toName: manifest.name }, { db });\n  const job = getJobStatus(jobId, db);\n  const status = job?.status === 'running' ? 'running' : 'queued';\n  const data: EmbedderSetData = {\n    jobId,\n    eta: estimateEta(job),\n    status,\n  };\n\n  logger.info('embedder swap queued', {\n    event: 'embedder_swap',\n    toName: manifest.name,\n    toDim: manifest.dim,\n    jobId,\n    status,\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'embedder_set',\n    summary: `Re-index queued for ${manifest.name}`,\n    data,\n    startTime,\n  });\n}\n\nexport const handle_embedder_set = handleEmbedderSet;","lineStart":1,"lineEnd":96,"totalLines":96,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/embedder-set.ts","time":{"start":1781761555372,"end":1781761555383}},"metadata":{"openai":{"itemId":"fc_021bca402a8feaa6016a3386132b84819183ed6a60d9ad185b"}},"id":"prt_ed943bba8001bwTGcVP4ZMx5K9","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943748d001K1Wlv6cYNV7gOv"}}
{"type":"tool_use","timestamp":1781761555387,"sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","part":{"type":"tool","tool":"read","callID":"call_RkpZ9tbXtZv6dF3Kkr5eHM8t","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Embedding Reconcile Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n11: \n12: import type { MCPResponse } from './types.js';\n13: import type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n14: \n15: /** Handle the memory_embedding_reconcile MCP tool request. */\n16: async function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n17:   await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n18:   await checkDatabaseUpdated();\n19: \n20:   const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';\n21: \n22:   const database = vectorIndex.getDb();\n23:   if (!database) {\n24:     recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n25:     return createMCPErrorResponse({\n26:       tool: 'memory_embedding_reconcile',\n27:       error: 'Embedding reconcile aborted: database unavailable',\n28:       code: 'E_DB_UNAVAILABLE',\n29:       details: { mode },\n30:       recovery: {\n31:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n32:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n33:         severity: 'error',\n34:       },\n35:     });\n36:   }\n37: \n38:   // Best-effort: guarantee the active shard is attached as active_vec. The\n39:   // reconcile verifies it and fails closed if it is still unavailable.\n40:   // Attach (or re-point) the canonical active shard as active_vec. This is the\n41:   // path authority: it detaches any wrong/stale shard and attaches the shard\n42:   // resolved from the active embedder profile. For apply, a failed attach is\n43:   // FATAL — proceeding could mutate rows against a stale same-profile shard\n44:   // (the metadata-only guard can't tell two same-profile shard files apart).\n45:   try {\n46:     vectorIndex.attachActiveVectorShardForActiveProfile(database);\n47:   } catch (attachErr: unknown) {\n48:     if (mode === 'apply') {\n49:       recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n50:       return createMCPErrorResponse({\n51:         tool: 'memory_embedding_reconcile',\n52:         error: `Embedding reconcile aborted: could not attach the active vector shard (${toErrorMessage(attachErr)})`,\n53:         code: 'E_ACTIVE_SHARD_UNVERIFIED',\n54:         details: { mode },\n55:         recovery: {\n56:           hint: 'Ensure the active embedder shard exists and the daemon is healthy, then retry; restart the MCP server if it persists.',\n57:           actions: ['Run embedder_status()', 'Run memory_health()'],\n58:           severity: 'error',\n59:         },\n60:       });\n61:     }\n62:     // dry-run: non-fatal; verifyActiveShard reports activeShardVerified=false.\n63:   }\n64: \n65:   try {\n66:     const result = runMemoryEmbeddingReconcile(database, args ?? {});\n67:     const stale = result.buckets.vector_present_status_stale.count;\n68:     const missing = result.buckets.missing_active_vector_retry_eligible.count;\n69: \n70:     const coverageReset = result.applied?.successCoverageReset ?? 0;\n71:     const summary = result.mode === 'apply'\n72:       ? `Reconciled ${result.applied?.reconciledToSuccess ?? 0} vector-present row(s) to success; reset ${result.applied?.resetToRetry ?? 0} missing-vector row(s) to retry${coverageReset ? `; repaired ${coverageReset} success-coverage row(s) to retry` : ''}`\n73:       : `Dry-run: ${stale} vector-present stale row(s), ${missing} missing-vector retry-eligible; no rows mutated`;\n74: \n75:     const hints: string[] = [];\n76:     if (!result.safety.activeShardVerified) {\n77:       hints.push(`Active shard not verified (${result.safety.reason ?? 'unknown'}); no rows were counted or mutated.`);\n78:     } else if (result.mode === 'dry-run' && stale > 0) {\n79:       hints.push('Run memory_embedding_reconcile({ mode: \"apply\" }) to converge embedding_status to success.');\n80:     }\n81:     recordMaintenanceRun('memory_embedding_reconcile', {\n82:       status: 'success',\n83:       counts: {\n84:         vectorPresentStatusStale: stale,\n85:         missingActiveVectorRetryEligible: missing,\n86:         reconciledToSuccess: result.applied?.reconciledToSuccess ?? 0,\n87:         resetToRetry: result.applied?.resetToRetry ?? 0,\n88:         successCoverageReset: coverageReset,\n89:       },\n90:       staleCandidates: stale + missing,\n91:     });\n92: \n93:     return createMCPSuccessResponse({\n94:       tool: 'memory_embedding_reconcile',\n95:       summary,\n96:       data: result,\n97:       hints,\n98:     });\n99:   } catch (error: unknown) {\n100:     // Health reads last-run state; a failed run must be visible there, not\n101:     // only in the error response of the call that happened to observe it.\n102:     recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n103:     if (error instanceof ActiveShardGuardError) {\n104:       return createMCPErrorResponse({\n105:         tool: 'memory_embedding_reconcile',\n106:         error: error.message,\n107:         code: error.code,\n108:         details: { mode },\n109:         recovery: {\n110:           hint: 'Ensure the active embedder shard is attached and matches the active pointer; restart the MCP server if needed.',\n111:           actions: ['Run embedder_status()', 'Run memory_health()'],\n112:           severity: 'error',\n113:         },\n114:       });\n115:     }\n116:     return createMCPErrorResponse({\n117:       tool: 'memory_embedding_reconcile',\n118:       error: `Embedding reconcile failed: ${toErrorMessage(error)}`,\n119:       code: 'E_EMBEDDING_RECONCILE_FAILED',\n120:       details: { mode },\n121:       recovery: {\n122:         hint: 'Inspect memory_index and the active vector shard state, then retry in dry-run.',\n123:         actions: ['Run memory_health()', 'Retry memory_embedding_reconcile({ mode: \"dry-run\" })'],\n124:         severity: 'error',\n125:       },\n126:     });\n127:   }\n128: }\n129: \n130: export { handleMemoryEmbeddingReconcile };\n\n(End of file - total 130 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Embedding Reconcile Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n\n/** Handle the memory_embedding_reconcile MCP tool request. */\nasync function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n  await checkDatabaseUpdated();\n\n  const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Embedding Reconcile Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n\n/** Handle the memory_embedding_reconcile MCP tool request. */\nasync function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n  await checkDatabaseUpdated();\n\n  const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_embedding_reconcile',\n      error: 'Embedding reconcile aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: { mode },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Best-effort: guarantee the active shard is attached as active_vec. The\n  // reconcile verifies it and fails closed if it is still unavailable.\n  // Attach (or re-point) the canonical active shard as active_vec. This is the\n  // path authority: it detaches any wrong/stale shard and attaches the shard\n  // resolved from the active embedder profile. For apply, a failed attach is\n  // FATAL — proceeding could mutate rows against a stale same-profile shard\n  // (the metadata-only guard can't tell two same-profile shard files apart).\n  try {\n    vectorIndex.attachActiveVectorShardForActiveProfile(database);\n  } catch (attachErr: unknown) {\n    if (mode === 'apply') {\n      recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n      return createMCPErrorResponse({\n        tool: 'memory_embedding_reconcile',\n        error: `Embedding reconcile aborted: could not attach the active vector shard (${toErrorMessage(attachErr)})`,\n        code: 'E_ACTIVE_SHARD_UNVERIFIED',\n        details: { mode },\n        recovery: {\n          hint: 'Ensure the active embedder shard exists and the daemon is healthy, then retry; restart the MCP server if it persists.',\n          actions: ['Run embedder_status()', 'Run memory_health()'],\n          severity: 'error',\n        },\n      });\n    }\n    // dry-run: non-fatal; verifyActiveShard reports activeShardVerified=false.\n  }\n\n  try {\n    const result = runMemoryEmbeddingReconcile(database, args ?? {});\n    const stale = result.buckets.vector_present_status_stale.count;\n    const missing = result.buckets.missing_active_vector_retry_eligible.count;\n\n    const coverageReset = result.applied?.successCoverageReset ?? 0;\n    const summary = result.mode === 'apply'\n      ? `Reconciled ${result.applied?.reconciledToSuccess ?? 0} vector-present row(s) to success; reset ${result.applied?.resetToRetry ?? 0} missing-vector row(s) to retry${coverageReset ? `; repaired ${coverageReset} success-coverage row(s) to retry` : ''}`\n      : `Dry-run: ${stale} vector-present stale row(s), ${missing} missing-vector retry-eligible; no rows mutated`;\n\n    const hints: string[] = [];\n    if (!result.safety.activeShardVerified) {\n      hints.push(`Active shard not verified (${result.safety.reason ?? 'unknown'}); no rows were counted or mutated.`);\n    } else if (result.mode === 'dry-run' && stale > 0) {\n      hints.push('Run memory_embedding_reconcile({ mode: \"apply\" }) to converge embedding_status to success.');\n    }\n    recordMaintenanceRun('memory_embedding_reconcile', {\n      status: 'success',\n      counts: {\n        vectorPresentStatusStale: stale,\n        missingActiveVectorRetryEligible: missing,\n        reconciledToSuccess: result.applied?.reconciledToSuccess ?? 0,\n        resetToRetry: result.applied?.resetToRetry ?? 0,\n        successCoverageReset: coverageReset,\n      },\n      staleCandidates: stale + missing,\n    });\n\n    return createMCPSuccessResponse({\n      tool: 'memory_embedding_reconcile',\n      summary,\n      data: result,\n      hints,\n    });\n  } catch (error: unknown) {\n    // Health reads last-run state; a failed run must be visible there, not\n    // only in the error response of the call that happened to observe it.\n    recordMaintenanceRun('memory_embedding_reconcile', { status: 'error' });\n    if (error instanceof ActiveShardGuardError) {\n      return createMCPErrorResponse({\n        tool: 'memory_embedding_reconcile',\n        error: error.message,\n        code: error.code,\n        details: { mode },\n        recovery: {\n          hint: 'Ensure the active embedder shard is attached and matches the active pointer; restart the MCP server if needed.',\n          actions: ['Run embedder_status()', 'Run memory_health()'],\n          severity: 'error',\n        },\n      });\n    }\n    return createMCPErrorResponse({\n      tool: 'memory_embedding_reconcile',\n      error: `Embedding reconcile failed: ${toErrorMessage(error)}`,\n      code: 'E_EMBEDDING_RECONCILE_FAILED',\n      details: { mode },\n      recovery: {\n        hint: 'Inspect memory_index and the active vector shard state, then retry in dry-run.',\n        actions: ['Run memory_health()', 'Retry memory_embedding_reconcile({ mode: \"dry-run\" })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryEmbeddingReconcile };","lineStart":1,"lineEnd":130,"totalLines":130,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","time":{"start":1781761555363,"end":1781761555385}},"metadata":{"openai":{"itemId":"fc_021bca402a8feaa6016a3386132b80819192f5d72fc3291c26"}},"id":"prt_ed943bb92001jBRXwbyFHE80Eb","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed943748d001K1Wlv6cYNV7gOv"}}
