boolean) | null;\n1299: } {\n1300:   const normalizedScope = normalizeScopeContext(scope);\n1301:   if (!hasScopeConstraints(normalizedScope)) {\n1302:     return {\n1303:       normalizedScope,\n1304:       predicate: null,\n1305:     };\n1306:   }\n1307: \n1308:   return {\n1309:     normalizedScope,\n1310:     predicate: createScopeFilterPredicate<Record<string, unknown>>(normalizedScope),\n1311:   };\n1312: }\n1313: \n1314: function getScopedMemories(\n1315:   database: Database.Database,\n1316:   specFolder: string | null,\n1317:   scope: ScopeContext = {},\n1318: ): {\n1319:   memories: Array<Record<string, unknown>>;\n1320:   memoryIds: number[];\n1321:   normalizedScope: ScopeContext;\n1322: } {\n1323:   const { normalizedScope, predicate } = getScopeFilterContext(database, scope);\n1324:   const baseMemories = specFolder\n1325:     ? database.prepare('SELECT * FROM memory_index WHERE spec_folder = ?').all(specFolder) as Array<Record<string, unknown>>\n1326:     : database.prepare('SELECT * FROM memory_index').all() as Array<Record<string, unknown>>;\n1327:   const memories = predicate ? baseMemories.filter((row) => predicate(row)) : baseMemories;\n1328: \n1329:   return {\n1330:     memories,\n1331:     memoryIds: getMemoryIds(memories),\n1332:     normalizedScope,\n1333:   };\n1334: }\n1335: \n1336: function getCurrentScopedMemoryIds(\n1337:   database: Database.Database,\n1338:   specFolder: string | null,\n1339:   scope: ScopeContext = {},\n1340: ): number[] {\n1341:   return getScopedMemories(database, specFolder, scope).memoryIds;\n1342: }\n1343: \n1344: function buildRestoreScopeDeleteWhere(\n1345:   columns: ReadonlySet<string>,\n1346:   checkpointSpecFolder: string | null,\n1347:   scope: ScopeContext = {},\n1348: ): {\n1349:   clauses: string[];\n1350:   params: string[];\n1351: } {\n1352:   const normalizedScope = normalizeScopeContext(scope);\n1353:   const clauses: string[] = [];\n1354:   const params: string[] = [];\n1355: \n1356:   if (checkpointSpecFolder && columns.has('spec_folder')) {\n1357:     clauses.push('spec_folder = ?');\n1358:     params.push(checkpointSpecFolder);\n1359:   }\n1360:   if (normalizedScope.tenantId && columns.has('tenant_id')) {\n1361:     clauses.push('tenant_id = ?');\n1362:     params.push(normalizedScope.tenantId);\n1363:   }\n1364:   if (normalizedScope.userId && columns.has('user_id')) {\n1365:     clauses.push('user_id = ?');\n1366:     params.push(normalizedScope.userId);\n1367:   }\n1368:   if (normalizedScope.agentId && columns.has('agent_id')) {\n1369:     clauses.push('agent_id = ?');\n1370:     params.push(normalizedScope.agentId);\n1371:   }\n1372: \n1373:   return { clauses, params };\n1374: }\n1375: \n1376: function getEdgeIds(edges: Array<Record<string, unknown>>): number[] {\n1377:   const ids = new Set<number>();\n1378:   for (const edge of edges) {\n1379:     const rawId = edge?.id;\n1380:     if (typeof rawId === 'number' && Number.isSafeInteger(rawId)) {\n1381:       ids.add(rawId);\n1382:       continue;\n1383:     }\n1384:     if (typeof rawId === 'string' && /^\\d+$/.test(rawId)) {\n1385:       ids.add(Number.parseInt(rawId, 10));\n1386:     }\n1387:   }\n1388:   return Array.from(ids);\n1389: }\n\n(Showing lines 1260-1389 of 3364. Use offset=1390 to continue.)\n</content>","metadata":{"preview":"        : {};\n    } catch (_error: unknown) {\n      return {};\n    }\n  }\n  return typeof value === 'object' && !Array.isArray(value)\n    ? value as Record<string, unknown>\n    : {};\n}\n\nfunction checkpointMetadataMatchesScope(rawMetadata: unknown, scope: ScopeContext): boolean {\n  const normalizedScope = normalizeScopeContext(scope);\n  if (!hasScopeConstraints(normalizedScope)) {\n    return true;\n  }\n\n  const metadata = parseCheckpointMetadata(rawMetadata);\n  return (\n    (normalizedScope.tenantId === undefined || metadata.tenantId === normalizedScope.tenantId)\n    && (normalizedScope.userId === undefined || metadata.userId === normalizedScope.userId)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","text":"        : {};\n    } catch (_error: unknown) {\n      return {};\n    }\n  }\n  return typeof value === 'object' && !Array.isArray(value)\n    ? value as Record<string, unknown>\n    : {};\n}\n\nfunction checkpointMetadataMatchesScope(rawMetadata: unknown, scope: ScopeContext): boolean {\n  const normalizedScope = normalizeScopeContext(scope);\n  if (!hasScopeConstraints(normalizedScope)) {\n    return true;\n  }\n\n  const metadata = parseCheckpointMetadata(rawMetadata);\n  return (\n    (normalizedScope.tenantId === undefined || metadata.tenantId === normalizedScope.tenantId)\n    && (normalizedScope.userId === undefined || metadata.userId === normalizedScope.userId)\n    && (normalizedScope.agentId === undefined || metadata.agentId === normalizedScope.agentId)\n  );\n}\n\nfunction hasDirectScopeColumns(columns: ReadonlySet<string>): boolean {\n  return (\n    columns.has('tenant_id')\n    || columns.has('user_id')\n    || columns.has('agent_id')\n    || columns.has('session_id')\n  );\n}\n\nfunction getScopeFilterContext(\n  _database: Database.Database,\n  scope: ScopeContext = {},\n): {\n  normalizedScope: ScopeContext;\n  predicate: ((row: Record<string, unknown>) => boolean) | null;\n} {\n  const normalizedScope = normalizeScopeContext(scope);\n  if (!hasScopeConstraints(normalizedScope)) {\n    return {\n      normalizedScope,\n      predicate: null,\n    };\n  }\n\n  return {\n    normalizedScope,\n    predicate: createScopeFilterPredicate<Record<string, unknown>>(normalizedScope),\n  };\n}\n\nfunction getScopedMemories(\n  database: Database.Database,\n  specFolder: string | null,\n  scope: ScopeContext = {},\n): {\n  memories: Array<Record<string, unknown>>;\n  memoryIds: number[];\n  normalizedScope: ScopeContext;\n} {\n  const { normalizedScope, predicate } = getScopeFilterContext(database, scope);\n  const baseMemories = specFolder\n    ? database.prepare('SELECT * FROM memory_index WHERE spec_folder = ?').all(specFolder) as Array<Record<string, unknown>>\n    : database.prepare('SELECT * FROM memory_index').all() as Array<Record<string, unknown>>;\n  const memories = predicate ? baseMemories.filter((row) => predicate(row)) : baseMemories;\n\n  return {\n    memories,\n    memoryIds: getMemoryIds(memories),\n    normalizedScope,\n  };\n}\n\nfunction getCurrentScopedMemoryIds(\n  database: Database.Database,\n  specFolder: string | null,\n  scope: ScopeContext = {},\n): number[] {\n  return getScopedMemories(database, specFolder, scope).memoryIds;\n}\n\nfunction buildRestoreScopeDeleteWhere(\n  columns: ReadonlySet<string>,\n  checkpointSpecFolder: string | null,\n  scope: ScopeContext = {},\n): {\n  clauses: string[];\n  params: string[];\n} {\n  const normalizedScope = normalizeScopeContext(scope);\n  const clauses: string[] = [];\n  const params: string[] = [];\n\n  if (checkpointSpecFolder && columns.has('spec_folder')) {\n    clauses.push('spec_folder = ?');\n    params.push(checkpointSpecFolder);\n  }\n  if (normalizedScope.tenantId && columns.has('tenant_id')) {\n    clauses.push('tenant_id = ?');\n    params.push(normalizedScope.tenantId);\n  }\n  if (normalizedScope.userId && columns.has('user_id')) {\n    clauses.push('user_id = ?');\n    params.push(normalizedScope.userId);\n  }\n  if (normalizedScope.agentId && columns.has('agent_id')) {\n    clauses.push('agent_id = ?');\n    params.push(normalizedScope.agentId);\n  }\n\n  return { clauses, params };\n}\n\nfunction getEdgeIds(edges: Array<Record<string, unknown>>): number[] {\n  const ids = new Set<number>();\n  for (const edge of edges) {\n    const rawId = edge?.id;\n    if (typeof rawId === 'number' && Number.isSafeInteger(rawId)) {\n      ids.add(rawId);\n      continue;\n    }\n    if (typeof rawId === 'string' && /^\\d+$/.test(rawId)) {\n      ids.add(Number.parseInt(rawId, 10));\n    }\n  }\n  return Array.from(ids);\n}","lineStart":1260,"lineEnd":1389,"totalLines":3364,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","time":{"start":1781761653643,"end":1781761653647}},"metadata":{"openai":{"itemId":"fc_074d4686bf7c9df9016a338675839881918da0aa3d233e5561"}},"id":"prt_ed9453b47001tdnHzyMyQvE4BM","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed945108a001Zn6pZKTpAb7DmI"}}
{"type":"tool_use","timestamp":1781761653686,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_uk1NAXQWhpwDj6b9WrzkCCXM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","offset":2850,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts</path>\n<type>file</type>\n<content>\n2850:     console.warn(`[checkpoints] restoreCheckpoint v2 error: ${typedMessage}`);\n2851:   } finally {\n2852:     releaseRestoreBarrier();\n2853:   }\n2854: \n2855:   return result;\n2856: }\n2857: \n2858: function listCheckpoints(\n2859:   specFolder: string | null = null,\n2860:   limit: number = 50,\n2861:   scope: ScopeContext = {},\n2862: ): CheckpointInfo[] {\n2863:   const database = getDatabase();\n2864: \n2865:   try {\n2866:     const folderFilter = specFolder ? 'WHERE spec_folder = ?' : '';\n2867:     const params: Array<string | number> = specFolder ? [specFolder] : [];\n2868:     params.push(limit);\n2869:     const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n2870:     const snapshotFormatSelect = checkpointColumns.has('snapshot_format')\n2871:       ? 'snapshot_format'\n2872:       : \"'v1' AS snapshot_format\";\n2873:     const snapshotPathSelect = checkpointColumns.has('snapshot_path')\n2874:       ? 'snapshot_path'\n2875:       : 'NULL AS snapshot_path';\n2876: \n2877:     const rows = database.prepare(`\n2878:       SELECT id, name, created_at, spec_folder, git_branch, LENGTH(memory_snapshot) as snapshot_size, ${snapshotFormatSelect}, ${snapshotPathSelect}, metadata\n2879:       FROM checkpoints ${folderFilter}\n2880:       ORDER BY created_at DESC\n2881:       LIMIT ?\n2882:     `).all(...params) as Array<Record<string, unknown>>;\n2883: \n2884:     return rows\n2885:       .filter((row) => checkpointMetadataMatchesScope(row.metadata, scope))\n2886:       .map(row => {\n2887:         const snapshotFormat = (row.snapshot_format as string | null | undefined) ?? 'v1';\n2888:         const snapshotPath = (row.snapshot_path as string | null | undefined) ?? null;\n2889:         return {\n2890:           id: row.id as number,\n2891:           name: row.name as string,\n2892:           createdAt: row.created_at as string,\n2893:           specFolder: row.spec_folder as string | null,\n2894:           gitBranch: row.git_branch as string | null,\n2895:           snapshotSize: snapshotFormat === 'v2'\n2896:             ? getCheckpointV2SnapshotSize(snapshotPath)\n2897:             : (row.snapshot_size as number) || 0,\n2898:           snapshotFormat,\n2899:           snapshotPath,\n2900:           metadata: row.metadata ? JSON.parse(row.metadata as string) : {},\n2901:         };\n2902:       });\n2903:   } catch (error: unknown) {\n2904:     const msg = toErrorMessage(error);\n2905:     console.warn(`[checkpoints] listCheckpoints error: ${msg}`);\n2906:     return [];\n2907:   }\n2908: }\n2909: \n2910: function getCheckpoint(nameOrId: string | number, scope: ScopeContext = {}): CheckpointEntry | null {\n2911:   const database = getDatabase();\n2912: \n2913:   try {\n2914:     const row = typeof nameOrId === 'number'\n2915:       ? database.prepare('SELECT * FROM checkpoints WHERE id = ?').get(nameOrId)\n2916:       : database.prepare('SELECT * FROM checkpoints WHERE name = ?').get(nameOrId);\n2917: \n2918:     const checkpoint = (row as CheckpointEntry) || null;\n2919:     if (checkpoint && !checkpointMetadataMatchesScope(checkpoint.metadata, scope)) {\n2920:       return null;\n2921:     }\n2922:     return checkpoint;\n2923:   } catch (error: unknown) {\n2924:     const msg = toErrorMessage(error);\n2925:     console.warn(`[checkpoints] getCheckpoint error: ${msg}`);\n2926:     return null;\n2927:   }\n2928: }\n2929: \n2930: function restoreCheckpoint(\n2931:   nameOrId: string | number,\n2932:   clearExisting: boolean = false,\n2933:   scope: ScopeContext = {},\n2934:   opts: RestoreCheckpointV2Options = {},\n2935: ): RestoreResult {\n2936:   const database = getDatabase();\n2937:   const result: RestoreResult = {\n2938:     restored: 0,\n2939:     skipped: 0,\n2940:     errors: [],\n2941:     workingMemoryRestored: 0,\n2942:     partialFailure: false,\n2943:     rolledBackTables: [],\n2944:   };\n2945: \n2946:   let restoreBarrierHeld = false;\n2947:   const governanceAudits: GovernanceAuditEntry[] = [];\n2948:   const tierDowngradeAudits: TierDowngradeAuditParams[] = [];\n2949: \n2950:   try {\n2951:     const checkpoint = getCheckpoint(nameOrId, scope);\n2952:     if (checkpoint?.snapshot_format === 'v2' && checkpoint.snapshot_path) {\n2953:       return restoreCheckpointV2(database, checkpoint, scope, opts);\n2954:     }\n2955: \n2956:     if (!checkpoint || !checkpoint.memory_snapshot) {\n2957:       result.errors.push('Checkpoint not found or empty');\n2958:       return result;\n2959:     }\n2960: \n2961:     // Decompress snapshot\n2962:     const decompressed = zlib.gunzipSync(checkpoint.memory_snapshot);\n2963:     let parsedSnapshot: unknown;\n2964:     try {\n2965:       parsedSnapshot = JSON.parse(decompressed.toString());\n2966:     } catch (parseError: unknown) {\n2967:       const message = parseError instanceof Error ? parseError.message : String(parseError);\n2968:       result.errors.push(`Invalid snapshot JSON: ${message}`);\n2969:       return result;\n2970:     }\n2971: \n2972:     // Validate the snapshot envelope against\n2973:     // CheckpointSnapshotSchema before restore. Failures route into\n2974:     // `result.errors` as a single `Malformed snapshot row N: <reason>`\n2975:     // entry per failing path so callers see exactly which structural\n2976:     // expectation was violated instead of inheriting a runtime cast bug.\n2977:     const snapshotValidation = CheckpointSnapshotSchema.safeParse(parsedSnapshot);\n2978:     if (!snapshotValidation.success) {\n2979:       for (const issue of snapshotValidation.error.issues) {\n2980:         const pathStr = issue.path.length > 0 ? issue.path.join('.') : 'root';\n2981:         result.errors.push(`Malformed snapshot row ${pathStr}: ${issue.message}`);\n2982:       }\n2983:       return result;\n2984:     }\n2985:     const snapshot = snapshotValidation.data as CheckpointSnapshot;\n2986:     const tableSnapshots = getSnapshotTables(snapshot);\n2987:     const memorySnapshot = tableSnapshots.memory_index;\n2988:     const memoryRows = memorySnapshot?.rows ?? snapshot.memories;\n2989: \n2990:     if (!Array.isArray(memoryRows)) {\n2991:       result.errors.push('Invalid snapshot format');\n2992:       return result;\n2993:     }\n2994: \n2995:     const checkpointSpecFolder = checkpoint.spec_folder ?? null;\n2996:     const snapshotMemoryIds = getMemoryIds(memoryRows);\n2997:     const { normalizedScope } = getScopeFilterContext(database, scope);\n2998:     const currentScopedMemoryIds = checkpointSpecFolder\n2999:       ? getCurrentScopedMemoryIds(database, checkpointSpecFolder, normalizedScope)\n3000:       : getCurrentScopedMemoryIds(database, null, normalizedScope);\n3001:     const scopedMemoryIdsToReplace = Array.from(\n3002:       new Set([...currentScopedMemoryIds, ...snapshotMemoryIds])\n3003:     );\n3004:     const edgeIds = getEdgeIds(tableSnapshots.causal_edges?.rows ?? []);\n3005: \n3006:     const memoryRestoreColumns = memoryRows.length > 0\n3007:       ? getMemoryRestoreColumns(database, memoryRows)\n3008:       : [];\n3009:     if (memoryRows.length > 0 && memoryRestoreColumns.length === 0) {\n3010:       result.errors.push('No compatible memory_index columns found for restore');\n3011:       return result;\n3012:     }\n3013: \n3014:     // FIX: Split INSERT strategy by restore mode.\n3015:     // ClearExisting mode: INSERT OR REPLACE is safe (table was already emptied).\n3016:     // Merge mode: INSERT OR REPLACE triggers CASCADE DELETE on working_memory\n3017:     // Via the FOREIGN KEY (memory_id) REFERENCES memory_index(id) ON DELETE CASCADE.\n3018:     // Use INSERT OR IGNORE + explicit UPDATE to avoid the delete-reinsert cycle.\n3019:     const memoryInsertStmt = memoryRestoreColumns.length > 0\n3020:       ? database.prepare(`\n3021:           INSERT OR ${clearExisting ? 'REPLACE' : 'IGNORE'} INTO memory_index (${memoryRestoreColumns.join(', ')})\n3022:           VALUES (${memoryRestoreColumns.map(() => '?').join(', ')})\n3023:         `) as Database.Statement\n3024:       : null;\n3025: \n3026:     const nonIdColumns = memoryRestoreColumns.filter(c => c !== 'id');\n3027:     const memoryUpdateStmt = (!clearExisting && nonIdColumns.length > 0)\n3028:       ? database.prepare(`\n3029:           UPDATE memory_index SET ${nonIdColumns.map(c => `${c} = ?`).join(', ')}\n3030:           WHERE id = ?\n3031:         `) as Database.Statement\n3032:       : null;\n3033: \n3034:     // Ensure working_memory table schema is ready BEFORE the transaction.\n3035:     // DDL (CREATE TABLE, ALTER TABLE) causes SQLite to auto-commit, which would\n3036:     // Corrupt a surrounding transaction. Run DDL outside the transaction boundary.\n3037:     if (tableSnapshots.working_memory) {\n3038:       ensureWorkingMemorySchema(database);\n3039:     }\n3040: \n3041:     acquireRestoreBarrier();\n3042:     restoreBarrierHeld = true;\n3043: \n3044:     // Transaction-wrap checkpoint restore to prevent data loss.\n3045:     // When clearExisting=true, the DELETE and all INSERTs must be atomic.\n3046:     // If any INSERT fails after DELETE, ROLLBACK restores original data.\n3047:     // Previously, individual insert errors were silently swallowed inside\n3048:     // The transaction, allowing COMMIT after DELETE + partial inserts = data loss.\n3049:     const restoreTx = database.transaction(() => {\n3050:       if (memoryRows.length > 0) {\n3051:         for (let i = 0; i < memoryRows.length; i++) {\n3052:           try {\n3053:             validateMemoryRow(memoryRows[i], i, governanceAudits, tierDowngradeAudits);\n3054:           } catch (validationError: unknown) {\n3055:             throw new Error(`Restore validation failed: ${toErrorMessage(validationError)}`);\n3056:           }\n3057:         }\n3058:       }\n3059: \n3060:       // Clear existing data if requested\n3061:       if (clearExisting) {\n3062:         try {\n3063:           clearDerivedTablesForRestore(database, {\n3064:             checkpointSpecFolder,\n3065:             memoryIds: scopedMemoryIdsToReplace,\n3066:             scope: normalizedScope,\n3067:           });\n3068:           for (const tableName of CHECKPOINT_CLEAR_ORDER) {\n3069:             if (!tableSnapshots[tableName]) {\n3070:               continue;\n3071:             }\n3072:             try {\n3073:               clearTableForRestoreScope(database, tableName, {\n3074:                 checkpointSpecFolder,\n3075:                 memoryIds: scopedMemoryIdsToReplace,\n3076:                 edgeIds,\n3077:                 scope: normalizedScope,\n3078:               });\n3079:             } catch (tableError: unknown) {\n3080:               throw new Error(`${tableName}: ${toErrorMessage(tableError)}`);\n3081:             }\n3082:           }\n3083:         } catch (error: unknown) {\n3084:           const msg = toErrorMessage(error);\n3085:           result.errors.push(`Restore clearExisting cleanup failed: ${msg}`);\n3086:           throw error;\n3087:         }\n3088:       }\n3089: \n3090:       const txErrors: string[] = [];\n3091:       const rolledBackTables = new Set<string>();\n3092:       const restoredMemoryIds = new Set<number>();\n3093: \n3094:       for (const memory of memoryRows) {\n3095:         try {\n3096:           // When clearExisting=false, check for duplicate logical key\n3097:           // (spec_folder + file_path + anchor_id) before inserting.\n3098:           if (!clearExisting) {\n3099:             const existingByPath = database.prepare(\n3100:               `\n3101:                 SELECT id FROM memory_index\n3102:                 WHERE spec_folder = ?\n3103:                   AND file_path = ?\n3104:                   AND (\n3105:                     (anchor_id IS NULL AND ? IS NULL)\n3106:                     OR anchor_id = ?\n3107:                   )\n3108:                   AND id != ?\n3109:               `\n\n(Showing lines 2850-3109 of 3364. Use offset=3110 to continue.)\n</content>","metadata":{"preview":"    console.warn(`[checkpoints] restoreCheckpoint v2 error: ${typedMessage}`);\n  } finally {\n    releaseRestoreBarrier();\n  }\n\n  return result;\n}\n\nfunction listCheckpoints(\n  specFolder: string | null = null,\n  limit: number = 50,\n  scope: ScopeContext = {},\n): CheckpointInfo[] {\n  const database = getDatabase();\n\n  try {\n    const folderFilter = specFolder ? 'WHERE spec_folder = ?' : '';\n    const params: Array<string | number> = specFolder ? [specFolder] : [];\n    params.push(limit);\n    const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","text":"    console.warn(`[checkpoints] restoreCheckpoint v2 error: ${typedMessage}`);\n  } finally {\n    releaseRestoreBarrier();\n  }\n\n  return result;\n}\n\nfunction listCheckpoints(\n  specFolder: string | null = null,\n  limit: number = 50,\n  scope: ScopeContext = {},\n): CheckpointInfo[] {\n  const database = getDatabase();\n\n  try {\n    const folderFilter = specFolder ? 'WHERE spec_folder = ?' : '';\n    const params: Array<string | number> = specFolder ? [specFolder] : [];\n    params.push(limit);\n    const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n    const snapshotFormatSelect = checkpointColumns.has('snapshot_format')\n      ? 'snapshot_format'\n      : \"'v1' AS snapshot_format\";\n    const snapshotPathSelect = checkpointColumns.has('snapshot_path')\n      ? 'snapshot_path'\n      : 'NULL AS snapshot_path';\n\n    const rows = database.prepare(`\n      SELECT id, name, created_at, spec_folder, git_branch, LENGTH(memory_snapshot) as snapshot_size, ${snapshotFormatSelect}, ${snapshotPathSelect}, metadata\n      FROM checkpoints ${folderFilter}\n      ORDER BY created_at DESC\n      LIMIT ?\n    `).all(...params) as Array<Record<string, unknown>>;\n\n    return rows\n      .filter((row) => checkpointMetadataMatchesScope(row.metadata, scope))\n      .map(row => {\n        const snapshotFormat = (row.snapshot_format as string | null | undefined) ?? 'v1';\n        const snapshotPath = (row.snapshot_path as string | null | undefined) ?? null;\n        return {\n          id: row.id as number,\n          name: row.name as string,\n          createdAt: row.created_at as string,\n          specFolder: row.spec_folder as string | null,\n          gitBranch: row.git_branch as string | null,\n          snapshotSize: snapshotFormat === 'v2'\n            ? getCheckpointV2SnapshotSize(snapshotPath)\n            : (row.snapshot_size as number) || 0,\n          snapshotFormat,\n          snapshotPath,\n          metadata: row.metadata ? JSON.parse(row.metadata as string) : {},\n        };\n      });\n  } catch (error: unknown) {\n    const msg = toErrorMessage(error);\n    console.warn(`[checkpoints] listCheckpoints error: ${msg}`);\n    return [];\n  }\n}\n\nfunction getCheckpoint(nameOrId: string | number, scope: ScopeContext = {}): CheckpointEntry | null {\n  const database = getDatabase();\n\n  try {\n    const row = typeof nameOrId === 'number'\n      ? database.prepare('SELECT * FROM checkpoints WHERE id = ?').get(nameOrId)\n      : database.prepare('SELECT * FROM checkpoints WHERE name = ?').get(nameOrId);\n\n    const checkpoint = (row as CheckpointEntry) || null;\n    if (checkpoint && !checkpointMetadataMatchesScope(checkpoint.metadata, scope)) {\n      return null;\n    }\n    return checkpoint;\n  } catch (error: unknown) {\n    const msg = toErrorMessage(error);\n    console.warn(`[checkpoints] getCheckpoint error: ${msg}`);\n    return null;\n  }\n}\n\nfunction restoreCheckpoint(\n  nameOrId: string | number,\n  clearExisting: boolean = false,\n  scope: ScopeContext = {},\n  opts: RestoreCheckpointV2Options = {},\n): RestoreResult {\n  const database = getDatabase();\n  const result: RestoreResult = {\n    restored: 0,\n    skipped: 0,\n    errors: [],\n    workingMemoryRestored: 0,\n    partialFailure: false,\n    rolledBackTables: [],\n  };\n\n  let restoreBarrierHeld = false;\n  const governanceAudits: GovernanceAuditEntry[] = [];\n  const tierDowngradeAudits: TierDowngradeAuditParams[] = [];\n\n  try {\n    const checkpoint = getCheckpoint(nameOrId, scope);\n    if (checkpoint?.snapshot_format === 'v2' && checkpoint.snapshot_path) {\n      return restoreCheckpointV2(database, checkpoint, scope, opts);\n    }\n\n    if (!checkpoint || !checkpoint.memory_snapshot) {\n      result.errors.push('Checkpoint not found or empty');\n      return result;\n    }\n\n    // Decompress snapshot\n    const decompressed = zlib.gunzipSync(checkpoint.memory_snapshot);\n    let parsedSnapshot: unknown;\n    try {\n      parsedSnapshot = JSON.parse(decompressed.toString());\n    } catch (parseError: unknown) {\n      const message = parseError instanceof Error ? parseError.message : String(parseError);\n      result.errors.push(`Invalid snapshot JSON: ${message}`);\n      return result;\n    }\n\n    // Validate the snapshot envelope against\n    // CheckpointSnapshotSchema before restore. Failures route into\n    // `result.errors` as a single `Malformed snapshot row N: <reason>`\n    // entry per failing path so callers see exactly which structural\n    // expectation was violated instead of inheriting a runtime cast bug.\n    const snapshotValidation = CheckpointSnapshotSchema.safeParse(parsedSnapshot);\n    if (!snapshotValidation.success) {\n      for (const issue of snapshotValidation.error.issues) {\n        const pathStr = issue.path.length > 0 ? issue.path.join('.') : 'root';\n        result.errors.push(`Malformed snapshot row ${pathStr}: ${issue.message}`);\n      }\n      return result;\n    }\n    const snapshot = snapshotValidation.data as CheckpointSnapshot;\n    const tableSnapshots = getSnapshotTables(snapshot);\n    const memorySnapshot = tableSnapshots.memory_index;\n    const memoryRows = memorySnapshot?.rows ?? snapshot.memories;\n\n    if (!Array.isArray(memoryRows)) {\n      result.errors.push('Invalid snapshot format');\n      return result;\n    }\n\n    const checkpointSpecFolder = checkpoint.spec_folder ?? null;\n    const snapshotMemoryIds = getMemoryIds(memoryRows);\n    const { normalizedScope } = getScopeFilterContext(database, scope);\n    const currentScopedMemoryIds = checkpointSpecFolder\n      ? getCurrentScopedMemoryIds(database, checkpointSpecFolder, normalizedScope)\n      : getCurrentScopedMemoryIds(database, null, normalizedScope);\n    const scopedMemoryIdsToReplace = Array.from(\n      new Set([...currentScopedMemoryIds, ...snapshotMemoryIds])\n    );\n    const edgeIds = getEdgeIds(tableSnapshots.causal_edges?.rows ?? []);\n\n    const memoryRestoreColumns = memoryRows.length > 0\n      ? getMemoryRestoreColumns(database, memoryRows)\n      : [];\n    if (memoryRows.length > 0 && memoryRestoreColumns.length === 0) {\n      result.errors.push('No compatible memory_index columns found for restore');\n      return result;\n    }\n\n    // FIX: Split INSERT strategy by restore mode.\n    // ClearExisting mode: INSERT OR REPLACE is safe (table was already emptied).\n    // Merge mode: INSERT OR REPLACE triggers CASCADE DELETE on working_memory\n    // Via the FOREIGN KEY (memory_id) REFERENCES memory_index(id) ON DELETE CASCADE.\n    // Use INSERT OR IGNORE + explicit UPDATE to avoid the delete-reinsert cycle.\n    const memoryInsertStmt = memoryRestoreColumns.length > 0\n      ? database.prepare(`\n          INSERT OR ${clearExisting ? 'REPLACE' : 'IGNORE'} INTO memory_index (${memoryRestoreColumns.join(', ')})\n          VALUES (${memoryRestoreColumns.map(() => '?').join(', ')})\n        `) as Database.Statement\n      : null;\n\n    const nonIdColumns = memoryRestoreColumns.filter(c => c !== 'id');\n    const memoryUpdateStmt = (!clearExisting && nonIdColumns.length > 0)\n      ? database.prepare(`\n          UPDATE memory_index SET ${nonIdColumns.map(c => `${c} = ?`).join(', ')}\n          WHERE id = ?\n        `) as Database.Statement\n      : null;\n\n    // Ensure working_memory table schema is ready BEFORE the transaction.\n    // DDL (CREATE TABLE, ALTER TABLE) causes SQLite to auto-commit, which would\n    // Corrupt a surrounding transaction. Run DDL outside the transaction boundary.\n    if (tableSnapshots.working_memory) {\n      ensureWorkingMemorySchema(database);\n    }\n\n    acquireRestoreBarrier();\n    restoreBarrierHeld = true;\n\n    // Transaction-wrap checkpoint restore to prevent data loss.\n    // When clearExisting=true, the DELETE and all INSERTs must be atomic.\n    // If any INSERT fails after DELETE, ROLLBACK restores original data.\n    // Previously, individual insert errors were silently swallowed inside\n    // The transaction, allowing COMMIT after DELETE + partial inserts = data loss.\n    const restoreTx = database.transaction(() => {\n      if (memoryRows.length > 0) {\n        for (let i = 0; i < memoryRows.length; i++) {\n          try {\n            validateMemoryRow(memoryRows[i], i, governanceAudits, tierDowngradeAudits);\n          } catch (validationError: unknown) {\n            throw new Error(`Restore validation failed: ${toErrorMessage(validationError)}`);\n          }\n        }\n      }\n\n      // Clear existing data if requested\n      if (clearExisting) {\n        try {\n          clearDerivedTablesForRestore(database, {\n            checkpointSpecFolder,\n            memoryIds: scopedMemoryIdsToReplace,\n            scope: normalizedScope,\n          });\n          for (const tableName of CHECKPOINT_CLEAR_ORDER) {\n            if (!tableSnapshots[tableName]) {\n              continue;\n            }\n            try {\n              clearTableForRestoreScope(database, tableName, {\n                checkpointSpecFolder,\n                memoryIds: scopedMemoryIdsToReplace,\n                edgeIds,\n                scope: normalizedScope,\n              });\n            } catch (tableError: unknown) {\n              throw new Error(`${tableName}: ${toErrorMessage(tableError)}`);\n            }\n          }\n        } catch (error: unknown) {\n          const msg = toErrorMessage(error);\n          result.errors.push(`Restore clearExisting cleanup failed: ${msg}`);\n          throw error;\n        }\n      }\n\n      const txErrors: string[] = [];\n      const rolledBackTables = new Set<string>();\n      const restoredMemoryIds = new Set<number>();\n\n      for (const memory of memoryRows) {\n        try {\n          // When clearExisting=false, check for duplicate logical key\n          // (spec_folder + file_path + anchor_id) before inserting.\n          if (!clearExisting) {\n            const existingByPath = database.prepare(\n              `\n                SELECT id FROM memory_index\n                WHERE spec_folder = ?\n                  AND file_path = ?\n                  AND (\n                    (anchor_id IS NULL AND ? IS NULL)\n                    OR anchor_id = ?\n                  )\n                  AND id != ?\n              `","lineStart":2850,"lineEnd":3109,"totalLines":3364,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","time":{"start":1781761653680,"end":1781761653685}},"metadata":{"openai":{"itemId":"fc_074d4