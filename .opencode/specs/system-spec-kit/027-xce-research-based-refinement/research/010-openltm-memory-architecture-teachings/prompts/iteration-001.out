    // Items with wildly different raw scores should get similar RRF scores\n\n  Line 436:       source: 'vector',\n\n  Line 447:         { id: 'c', score: 0.001 },\n\n  Line 448:         { id: 'd', score: 0.0005 },\n\n  Line 455:     // All rank-1 items should get the same base RRF score regardless of raw values\n\n  Line 464:     expect(itemA!.rrfScore).toBeCloseTo(itemC!.rrfScore, 5);\n\n  Line 474:     const score = applied[0].intentAdjustedScore as number;\n\n  Line 477:     // Recency is now included in the score.\n\n  Line 480:     expect(score).toBeCloseTo(0.9, 2);\n\n  Line 485:     // This is by design: each channel's weight scales its RRF contribution independently\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/spec-folder-canonicalization.vitest.ts:\n  Line 225:     // Create a symlink loop to trigger ELOOP\n\n  Line 247:   it('ENOENT still triggers parent-walk (atomic save)', () => {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts:\n  Line 15: import { attachActiveVectorShard, initializeDb } from '../search/vector-index-store.js';\n\n  Line 16: import { to_embedding_buffer } from '../search/vector-index-types.js';\n\n  Line 414:   const databaseDir = requireDatabaseDir(db, 'vector shard write');\n\n  Line 427:     // lexical signals; we surface that through the existing console.warn in vector-index-store.\n\n  Line 603:       // Commit embedding_status for rows now backed by an active-profile vector.\n\n  Line 604:       // A vector-only reindex previously wrote vectors but left memory_index.embedding_status\n\n  Line 607:       // atomic completion transaction so vectors and status flip together.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts:\n  Line 6: // TypeScript port of the vector index implementation.\n\n  Line 8: // FSRS-preferred strategy. Memories with FSRS review data (last_review\n\n  Line 9: // IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n\n  Line 14: // Memories with the canonical FSRS algorithm.\n\n  Line 30: import { IVectorStore } from '../interfaces/vector-store.js';\n\n  Line 37:   parse_trigger_phrases,\n\n  Line 40: } from './vector-index-types.js';\n\n  Line 44: } from './vector-index-schema.js';\n\n  Line 52: } from './vector-index-types.js';\n\n  Line 112: /** Loaded search weight configuration for vector-index ranking (lazy-loaded). */\n\n  Line 130: let _cached_queries: Awaited<typeof import('./vector-index-queries.js')> | null = null;\n\n  Line 131: let _cached_mutations: Awaited<typeof import('./vector-index-mutations.js')> | null = null;\n\n  Line 132: let _cached_aliases: Awaited<typeof import('./vector-index-aliases.js')> | null = null;\n\n  Line 135:   return _cached_queries ??= await import('./vector-index-queries.js');\n\n  Line 139:   return _cached_mutations ??= await import('./vector-index-mutations.js');\n\n  Line 143:   return _cached_aliases ??= await import('./vector-index-aliases.js');\n\n  Line 150: /** Default embedding dimension used by the vector index. */\n\n  Line 176:   console.warn(`[vector-index] Using embedding dimension ${fallbackDim} after timeout`);\n\n  Line 279:     reason: 'No stored vector dimension found for existing schema',\n\n  Line 308:       const warning = `EMBEDDING DIMENSION MISMATCH: Existing database stores ${existing.stored_dim}-dim vectors (${source_label}), ` +\n\n  Line 309:         `but the active embedding configuration resolves to ${current_dim}. Refusing to bootstrap because vector search would fail. ` +\n\n  Line 312:       console.error(`[vector-index] WARNING: ${warning}`);\n\n  Line 318:     console.warn('[vector-index] Dimension validation error:', get_error_message(e));\n\n  Line 324:  * Validates that stored vector dimensions match the provider.\n\n  Line 339: /** Default path for the vector-index database file. */\n\n  Line 388: function get_vector_shard_path(profile: EmbeddingProfile, baseDir: string): string {\n\n  Line 389:   const vectorDir = path.join(baseDir, 'vectors');\n\n  Line 390:   if (!fs.existsSync(vectorDir)) {\n\n  Line 391:     fs.mkdirSync(vectorDir, { recursive: true, mode: 0o700 });\n\n  Line 393:   return path.join(vectorDir, `context-vectors__${profile.slug}.sqlite`);\n\n  Line 411: function vector_table_name_for_profile(profile: EmbeddingProfile): string {\n\n  Line 423: function get_attached_vector_path(database: Database.Database): string | null {\n\n  Line 467:       `Attached vector shard metadata mismatch (${detail})`,\n\n  Line 498: function ensure_vector_shard_schema(database: Database.Database, profile: EmbeddingProfile): void {\n\n  Line 508:   const dimTableName = vector_table_name_for_profile(profile);\n\n  Line 525: function drop_canonical_vector_payload_tables(database: Database.Database): void {\n\n  Line 552:   const dimTableName = vector_table_name_for_profile(profile);\n\n  Line 589:     console.warn(`[vector-index] Could not create legacy vector temp aliases: ${get_error_message(error)}`);\n\n  Line 604:       if (row.type !== 'view' && row.type !== 'trigger') {\n\n  Line 652:       console.warn(`[vector-index] Could not read file ${valid_path}: ${get_error_message(err)}`);\n\n  Line 685:         console.warn('[vector-index] Blocked potential prototype pollution in JSON');\n\n  Line 692:     console.warn(`[vector-index] JSON parse error: ${get_error_message(err)}`);\n\n  Line 704: let active_vector_source: ActiveVectorSourceTelemetry | null = null;\n\n\n(Results truncated: showing 100 of 12472 matches (12372 hidden). Consider using a more specific path or pattern.)","metadata":{"matches":12472,"truncated":true},"title":"RRF|rrf|BM25|FTS5|fts5|vector|trigger|score|why|explain|causal|FSRS|co-activation|coactivation|rerank","time":{"start":1780925011533,"end":1780925011822}},"metadata":{"openai":{"itemId":"fc_0e68cd3eda11ad55016a26c25377388191aade20b105fd15fd"}},"id":"prt_ea767162d001CKpGQ6b6z8qdp4","sessionID":"ses_1589b1327ffe3NF41ZJpTNBQ7B","messageID":"msg_ea766f2770013tqKSAdnoVB8sd"}}
