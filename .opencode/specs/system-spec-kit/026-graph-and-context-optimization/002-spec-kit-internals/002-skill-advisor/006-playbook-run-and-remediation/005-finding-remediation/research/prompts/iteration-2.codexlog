   938	def _apply_graph_boosts(
   939	    skill_boosts: Dict[str, float],
   940	    boost_reasons: Dict[str, List[str]],
   941	) -> None:
   942	    """Apply transitive boosts from skill graph relationships."""
   943	    graph = _load_skill_graph()
   944	    if not graph:
   945	        return
   946	
   947	    adjacency = graph.get("adjacency", {})
   948	    snapshot = dict(skill_boosts)
   949	
   950	    for skill_name, current_boost in snapshot.items():
   951	        if current_boost <= 0:
   952	            continue
