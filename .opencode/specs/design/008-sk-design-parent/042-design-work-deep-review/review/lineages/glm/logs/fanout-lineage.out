ign-md-generator/backend/scripts/motion-extract.ts\n     267 .opencode/skills/sk-design/design-md-generator/backend/scripts/preview-gen.ts\n     474 .opencode/skills/sk-design/design-md-generator/backend/scripts/proof.ts\n     676 .opencode/skills/sk-design/design-md-generator/backend/scripts/report-gen.ts\n     496 .opencode/skills/sk-design/design-md-generator/backend/scripts/types.ts\n     563 .opencode/skills/sk-design/design-md-generator/backend/scripts/validate.ts\n    9856 total\n===\n.opencode/skills/sk-design/design-md-generator/backend/scripts/guided-run.ts:12:import { spawnSync } from 'child_process';\n.opencode/skills/sk-design/design-md-generator/backend/scripts/guided-run.ts:69:  const result = spawnSync(command, args, { cwd: BACKEND_ROOT, stdio: 'ignore' });\n.opencode/skills/sk-design/design-md-generator/backend/scripts/guided-run.ts:114:  const result = spawnSync(step.command, step.args, { cwd: BACKEND_ROOT, encoding: 'utf-8' });\n.opencode/skills/sk-design/design-md-generator/backend/scripts/validate.ts:144:  while ((match = backtickPattern.exec(md)) !== null) {\n.opencode/skills/sk-design/design-md-generator/backend/scripts/validate.ts:197:  while ((match = hexPattern.exec(cleaned)) !== null) {\n.opencode/skills/sk-design/design-md-generator/backend/scripts/validate.ts:211:  while ((match = weightWords.exec(md)) !== null) {\n.opencode/skills/sk-design/design-md-generator/backend/scripts/validate.ts:240:  while ((match = blankRun.exec(md)) !== null) {\n.opencode/skills/sk-design/design-md-generator/backend/scripts/dom-collector.ts:318:        const match = gradientPattern.exec(bg);\n","metadata":{"output":"     396 .opencode/skills/sk-design/design-md-generator/backend/scripts/a11y-extract.ts\n     117 .opencode/skills/sk-design/design-md-generator/backend/scripts/build-write-prompt.ts\n      59 .opencode/skills/sk-design/design-md-generator/backend/scripts/cli.ts\n    1685 .opencode/skills/sk-design/design-md-generator/backend/scripts/cluster.ts\n     913 .opencode/skills/sk-design/design-md-generator/backend/scripts/crawl.ts\n     518 .opencode/skills/sk-design/design-md-generator/backend/scripts/css-analyzer.ts\n      46 .opencode/skills/sk-design/design-md-generator/backend/scripts/css-tree.d.ts\n     266 .opencode/skills/sk-design/design-md-generator/backend/scripts/dark-mode-detect.ts\n     311 .opencode/skills/sk-design/design-md-generator/backend/scripts/design-boundary-detect.ts\n     575 .opencode/skills/sk-design/design-md-generator/backend/scripts/dom-collector.ts\n     681 .opencode/skills/sk-design/design-md-generator/backend/scripts/extract.ts\n     239 .opencode/skills/sk-design/design-md-generator/backend/scripts/formatters-v3.ts\n     188 .opencode/skills/sk-design/design-md-generator/backend/scripts/framework-detect.ts\n     165 .opencode/skills/sk-design/design-md-generator/backend/scripts/guided-run.ts\n     248 .opencode/skills/sk-design/design-md-generator/backend/scripts/icon-detect.ts\n     799 .opencode/skills/sk-design/design-md-generator/backend/scripts/interaction-capture.ts\n     174 .opencode/skills/sk-design/design-md-generator/backend/scripts/motion-extract.ts\n     267 .opencode/skills/sk-design/design-md-generator/backend/scripts/preview-gen.ts\n     474 .opencode/skills/sk-design/design-md-generator/backend/scripts/proof.ts\n     676 .opencode/skills/sk-design/design-md-generator/backend/scripts/report-gen.ts\n     496 .opencode/skills/sk-design/design-md-generator/backend/scripts/types.ts\n     563 .opencode/skills/sk-design/design-md-generator/backend/scripts/validate.ts\n    9856 total\n===\n.opencode/skills/sk-design/design-md-generator/backend/scripts/guided-run.ts:12:import { spawnSync } from 'child_process';\n.opencode/skills/sk-design/design-md-generator/backend/scripts/guided-run.ts:69:  const result = spawnSync(command, args, { cwd: BACKEND_ROOT, stdio: 'ignore' });\n.opencode/skills/sk-design/design-md-generator/backend/scripts/guided-run.ts:114:  const result = 