rver V8 old-space cap: ${parsedOldSpaceMb} MB`);\n1001:   return nodeArgs;\n1002: }\n1003: \n1004: function waitForChildExit(child, timeoutMs) {\n1005:   if (!isChildRunning(child)) return Promise.resolve(true);\n1006:   return new Promise((resolve) => {\n1007:     let settled = false;\n1008:     const finish = (exited) => {\n1009:       if (settled) return;\n1010:       settled = true;\n1011:       clearTimeout(timer);\n1012:       child.off('exit', onExit);\n1013:       resolve(exited);\n1014:     };\n1015:     const onExit = () => finish(true);\n1016:     const timer = setTimeout(() => finish(false), timeoutMs);\n1017:     timer.unref?.();\n1018:     child.once('exit', onExit);\n1019:   });\n1020: }\n1021: \n1022: // Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n1023: // the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n1024: // snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\n1025: function refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n1026:   return mss.refreshDescendantSnapshot(childPid, runner, {\n1027:     snapshotPids: lastKnownDescendantPids,\n1028:     snapshot: {\n1029:       set: (pids) => {\n1030:         lastKnownDescendantPids = pids;\n1031:       },\n1032:     },\n1033:   });\n1034: }\n1035: \n1036: // Reap an orphaned sidecar on crash-loop give-up. The dominant RC-1 RSS lives in a\n1037: // forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n1038: // anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n1039: // still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n1040: // (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n1041: // bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\n1042: function reapProcessTreeGroups(childPid, options = {}) {\n1043:   return mss.reapProcessTreeGroups(childPid, {\n1044:     ...options,\n1045:     snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n1046:     signal: options.signal || signalProcess,\n1047:   });\n1048: }\n1049: \n1050: // Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n1051: // reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n1052: // closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\n1053: async function recycleDaemonInPlace(graceMs, deps = {}) {\n1054:   const ctx = {\n1055:     getContextChild: deps.getContextChild ?? (() => childProcess),\n1056:     hfControl: deps.hfControl ?? hfControl,\n1057:     isChildRunning: deps.isChildRunning ?? isChildRunning,\n1058:     waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n1059:     clearLease: deps.clearLease ?? clearLeaseFile,\n1060:     clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n1061:     isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n1062:     setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n1063:     log: deps.log ?? log,\n1064:   };\n1065:   if (ctx.isRecycleInProgress()) return;\n1066:   ctx.setRecycleInProgress(true);\n1067:   ctx.clearWatchdog();\n1068:   ctx.hfControl.clearTimers();\n1069:   await ctx.hfControl.stopDemandListener();\n1070:   const modelServerChild = ctx.hfControl.getChild();\n1071:   if (ctx.isChildRunning(modelServerChild)) {\n1072:     ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n1073:     modelServerChild.kill('SIGTERM');\n1074:     ctx.hfControl.reapProcessTree(modelServerChild.pid);\n1075:     const modelExitedAfterTerm = await ctx.waitForChildExit(modelServerChild, graceMs);\n1076:     if (!modelExitedAfterTerm && ctx.isChildRunning(modelServerChild)) {\n1077:       ctx.log(`hf-model-server pid ${modelServerChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n1078:       modelServerChild.kill('SIGKILL');\n1079:       await ctx.waitForChildExit(modelServerChild, 1000);\n1080:     }\n1081:   }\n1082:   const contextChild = ctx.getContextChild();\n1083:   if (!ctx.isChildRunning(contextChild)) {\n1084:     ctx.clearLease();\n1085:     ctx.setRecycleInProgress(false);\n1086:     return;\n1087:   }\n1088: \n1089:   ctx.log(`RSS ceiling sustained; sending SIGTERM to context-server pid ${contextChild.pid} before daemon recycle`);\n1090:   contextChild.kill('SIGTERM');\n1091:   const exitedAfterTerm = await ctx.waitForChildExit(contextChild, graceMs);\n1092:   if (!exitedAfterTerm && ctx.isChildRunning(contextChild)) {\n1093:     ctx.log(`context-server pid ${contextChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n1094:     contextChild.kill('SIGKILL');\n1095:     await ctx.waitForChildExit(contextChild, 1000);\n1096:   }\n1097:   // Keep the lease held across an in-place recycle. The launcher process stays alive and the\n1098:   // lease is keyed on its (still-live) pid, so the replacement daemon is respawned by the child\n1099:   // exit handler's scheduleRelaunch backoff. Clearing the lease here would open a window — until\n1100:   // relaunch rewrites childPid — where a concurrent launcher reads no lease and passes the\n1101:   // single-writer gate, producing a competing daemon. Relaunch (writeLeaseFile) rewrites childPid.\n1102: }\n1103: \n1104: function startRssWatchdog(childPid, options = {}) {\n1105:   return mss.startRssWatchdog(childPid, {\n1106:     ...options,\n1107:     timerState: options.timerState || {\n1108:       get: () => rssWatchdogTimer,\n1109:       set: (timer) => {\n1110:         rssWatchdogTimer = timer;\n1111:       },\n1112:     },\n1113:     snapshot: options.snapshot || {\n1114:       set: (pids) => {\n1115:         lastKnownDescendantPids = pids;\n1116:       },\n1117:     },\n1118:     log: options.log || log,\n1119:     onBreach: options.onBreach || ((breachConfig) => recycleDaemonInPlace(breachConfig.graceMs)),\n1120:   });\n1121: }\n1122: \n1123: // Launcher-local factory that pre-seeds the launcher-aware defaults (writeLease/shouldExitLauncher/\n1124: // onRssBreach) the shared lib intentionally leaves as generic no-ops. Keeps the launcher's exported\n1125: // createModelServerSupervisor + launchModelServer(options) seam byte-equivalent to pre-extraction HEAD.\n1126: // Explicit caller options still win via the trailing spread (the 004 test injects its own writeLease).\n1127: function createModelServerSupervisor(options = {}) {\n1128:   return baseCreateModelServerSupervisor({\n1129:     writeLease: () => writeLeaseFile(),\n1130:     shouldExitLauncher: () => launcherShutdownInProgress,\n1131:     onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n1132:     ...options,\n1133:   });\n1134: }\n1135: \n1136: function launchModelServer(options = null) {\n1137:   if (options && typeof options === 'object') {\n1138:     return createModelServerSupervisor(options).launch();\n1139:   }\n1140:   return hfControl.launch();\n1141: }\n1142: \n1143: function startModelServerDemandListener(options = {}) {\n1144:   return hfControl.startDemandListener(options);\n1145: }\n1146: \n1147: function stopModelServerDemandListener() {\n1148:   return hfControl.stopDemandListener();\n1149: }\n1150: \n1151: async function acquireBootstrapLock(options = {}) {\n1152:   const requireLock = options.requireLock === true;\n1153:   fs.mkdirSync(dbDir, { recursive: true });\n1154:   const deadline = Date.now() + 120000;\n1155:   while (true) {\n1156:     try {\n1157:       fs.mkdirSync(lockDir);\n1158:       return true;\n1159:     } catch (error) {\n1160:       if (error.code !== 'EEXIST') {\n1161:         throw error;\n1162:       }\n1163:       // Reclaim a stale lockdir left by a SIGKILL'd launcher (mtime-based; the lockdir records no pid),\n1164:       // so a crashed holder cannot block a requireLock respawn for the full 120s deadline.\n1165:       try {\n1166:         const ageMs = Date.now() - fs.statSync(lockDir).mtimeMs;\n1167:         if (ageMs > BOOTSTRAP_LOCK_STALE_MS) {\n1168:           log(`reclaiming stale bootstrap lock ${rel(lockDir)} (age ${Math.round(ageMs / 1000)}s)`);\n1169:           // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n1170:           // racer wins the rename; a successor that mkdir'd a fresh lockDir after our stat\n1171:           // creates a new inode that our rename/rmSync cannot touch, so we never delete a\n1172:           // live successor lock. A losing racer's rename throws ENOENT and falls through to\n1173:           // the outer retry.\n1174:           const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n1175:           fs.renameSync(lockDir, staleClaim);\n1176:           fs.rmSync(staleClaim, { recursive: true, force: true });\n1177:           continue;\n1178:         }\n1179:       } catch (statErr) {\n1180:         // stat/rename race — lock disappeared or was reclaimed by another launcher; retry mkdirSync\n1181:         if (statErr.code === 'ENOENT') continue;\n1182:         if (statErr.code === 'ENOTEMPTY') continue;\n1183:         throw statErr;\n1184:       }\n1185:       if (artifactsReady() && !requireLock) {\n1186:         return false;\n1187:       }\n1188:       if (Date.now() > deadline) {\n1189:         throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n1190:       }\n1191:       await sleep(1000);\n1192:     }\n1193:   }\n1194: }\n1195: \n1196: function launchServer() {\n1197:   if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n1198:     log('launchServer skipped: spec-memory owner lease is absent or own