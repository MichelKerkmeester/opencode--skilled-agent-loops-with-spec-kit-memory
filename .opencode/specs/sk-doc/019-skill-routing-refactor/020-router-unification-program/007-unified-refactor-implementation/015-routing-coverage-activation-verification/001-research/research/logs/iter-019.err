   149	def should_exclude_path(file_path: str) -> Tuple[bool, Optional[str]]:
   150	    """Check if file path should be excluded from validation."""
   151	    path_str = str(file_path)
   152	
   153	    # Check excluded patterns (auto-generated, dependencies)
   154	    for pattern in EXCLUDED_PATH_PATTERNS:
   155	        if f'/{pattern}/' in path_str or f'\\{pattern}\\' in path_str:
   156	            return True, f"Excluded: matches pattern '{pattern}'"
   157	
   158	    # Check third-party patterns
   159	    for pattern in THIRD_PARTY_PATTERNS:
   160	        if pattern in path_str:
   161	            return True, f"Third-party: matches pattern '{pattern}'"
   162	
   163	    # Check template patterns (intentionally minimal)
   164	    for pattern in TEMPLATE_PATTERNS:
   165	        if pattern in path_str:
   166	            return True, f"Template: matches pattern '{pattern}' (intentionally minimal)"
   167	
   168	    return False, None
