PResponse> {\n738:   await ensureMemoryRuntimeInitialized('handler:memory_validate');\n739:   const startTime = Date.now();\n740:   await checkDatabaseUpdated();\n741:   const {\n742:     id,\n743:     wasUseful,\n744:     queryId,\n745:     queryTerms,\n746:     resultRank,\n747:     totalResultsShown,\n748:     searchMode,\n749:     intent,\n750:     sessionId,\n751:     notes,\n752:   } = args;\n753: \n754:   if (id === undefined || id === null) {\n755:     throw new Error('id is required');\n756:   }\n757: \n758:   if (typeof wasUseful !== 'boolean') {\n759:     throw new Error('wasUseful is required and must be a boolean');\n760:   }\n761: \n762:   const memoryId = parseMemoryId(id);\n763: \n764:   vectorIndex.initializeDb();\n765:   const database = requireDb();\n766:   const normalizedQueryId = typeof queryId === 'string' && queryId.trim().length > 0\n767:     ? queryId.trim()\n768:     : null;\n769:   const queryText = resolveValidationQueryText(database, normalizedQueryId ?? undefined);\n770:   // Validate the caller-supplied sessionId before using it for feedback\n771:   // attribution (adaptive-signal actor + ground-truth selection). A forged or\n772:   // untracked id must not attribute signals to another session; degrade to\n773:   // no-attribution rather than reject, since validation feedback is best-effort.\n774:   const trustedValidation = sessionManager.resolveTrustedSession(sessionId ?? null);\n775:   const trustedSessionId = trustedValidation.trusted ? trustedValidation.effectiveSessionId : undefined;\n776:   const result: ValidationResult = confidenceTracker.recordValidation(database, memoryId, wasUseful);\n777:   try {\n778:     recordAdaptiveSignal(database, {\n779:       memoryId,\n780:       signalType: wasUseful ? 'outcome' : 'correction',\n781:       signalValue: 1,\n782:       query: queryText,\n783:       actor: trustedSessionId ?? 'memory_validate',\n784:       metadata: {\n785:         queryId: normalizedQueryId,\n786:         queryText,\n787:         resultRank: typeof resultRank === 'number' ? resultRank : null,\n788:         totalResultsShown: typeof totalResultsShown === 'number' ? totalResultsShown : null,\n789:         intent: intent ?? null,\n790:       },\n791:     });\n792:   } catch (_error: unknown) {\n793:     // Adaptive signals are best-effort only\n794:   }\n795: \n796:   // Auto-promotion wiring on positive feedback.\n797:   let autoPromotion: {\n798:     attempted: boolean;\n799:     promoted: boolean;\n800:     previousTier?: string;\n801:     newTier?: string;\n802:     reason?: string;\n803:   } | null = null;\n804: \n805:   if (wasUseful) {\n806:     const promotionResult = executeAutoPromotion(database, memoryId);\n807:     autoPromotion = {\n808:       attempted: true,\n809:       promoted: promotionResult.promoted,\n810:       previousTier: promotionResult.previousTier,\n811:       newTier: promotionResult.newTier,\n812:       reason: promotionResult.reason,\n813:     };\n814:   }\n815: \n816:   // Negative-feedback confidence signal persistence for runtime scoring.\n817:   if (!wasUseful) {\n818:     recordNegativeFeedbackEvent(database, memoryId);\n819:   }\n820: \n821:   // Optional wiring from memory_validate to learned feedback + ground truth.\n822:   let learnedFeedback: {\n823:     attempted: boolean;\n824:     applied: boolean;\n825:     termsLearned: string[];\n826:     reason?: string;\n827:   } | null = null;\n828:   let groundTruthSelectionId: number | null = null;\n829: \n830:   if (wasUseful && typeof queryId === 'string' && queryId.trim().length > 0) {\n831:     groundTruthSelectionId = recordUserSelection(queryId, memoryId, {\n832:       searchMode,\n833:       intent,\n834:       selectedRank: resultRank,\n835:       totalResultsShown,\n836:       sessionId: trustedSessionId,\n837:       notes,\n838:     });\n839: \n840:     const normalizedTerms = Array.isArray(queryTerms)\n841:       ? queryTerms.filter((term) => typeof term === 'string' && term.trim().length > 0).map((term) => term.trim())\n842:       : [];\n843: \n844:     if (typeof resultRank === 'number' && Number.isFinite(resultRank) && resultRank > 0 && normalizedTerms.length > 0) {\n845:       const learnResult = recordSelection(queryId, memoryId, normalizedTerms, Math.floor(resultRank), database);\n846:       learnedFeedback = {\n847:         attempted: true,\n848:         applied: learnResult.applied,\n849:         termsLearned: learnResult.terms,\n850:         reason: learnResult.reason,\n851:       };\n852:     } else {\n853:       learnedFeedback = {\n854:         attempted: false,\n855:         applied: false,\n856:         termsLearned: [],\n857:         reason: 'missing_query_terms_or_rank',\n858:       };\n859:     }\n860:   }\n861: \n862:   const summary = wasUseful\n863:     ? `Positive validation recorded (confidence: ${result.confidence.toFixed(2)})`\n864:     : `Negative validation recorded (confidence: ${result.confidence.toFixed(2)})`;\n865: \n866:   const hints: string[] = [];\n867:   if (result.promotionEligible) {\n868:     hints.push('Memory eligible for promotion to critical tier');\n869:   }\n870:   if (!wasUseful && result.validationCount > 3) {\n871:     hints.push('Consider updating or deleting this memory if consistently unhelpful');\n872:   }\n873: \n874:   return createMCPSuccessResponse({\n875:     tool: 'memory_validate',\n876:     summary,\n877:     data: {\n878:       memoryId,\n879:       wasUseful: wasUseful,\n880:       confidence: result.confidence,\n881:       validationCount: result.validationCount,\n882:       positiveValidationCount: result.positiveValidationCount,\n883:       promotionEligible: result.promotionEligible,\n884:       autoPromotion,\n885:       learnedFeedback,\n886:       groundTruthSelectionId,\n887:     },\n888:     hints,\n889:     startTime: startTime\n890:   });\n891: }\n892: \n893: /* ───────────────────────────────────────────────────────────────\n894:    8. EXPORTS\n895: ──────────────────────────────────────────────────────────────── */\n896: \n897: export {\n898:   handleCheckpointCreate,\n899:   handleCheckpointList,\n900:   handleCheckpointRestore,\n901:   handleCheckpointDelete,\n902:   handleMemoryValidate,\n903: };\n904: \n905: // Backward-compatible aliases (snake_case)\n906: const handle_checkpoint_create = handleCheckpointCreate;\n907: const handle_checkpoint_list = handleCheckpointList;\n908: const handle_checkpoint_restore = handleCheckpointRestore;\n909: const handle_checkpoint_delete = handleCheckpointDelete;\n910: const handle_memory_validate = handleMemoryValidate;\n911: \n912: export {\n913:   handle_checkpoint_create,\n914:   handle_checkpoint_list,\n915:   handle_checkpoint_restore,\n916:   handle_checkpoint_delete,\n917:   handle_memory_validate,\n918: };\n\n(End of file - total 918 lines)\n</content>","metadata":{"preview":"        recovery: {\n          hint: 'Retry with matching scope values or omit optional scope parameters if you intend to access an unscoped checkpoint.',\n          actions: ['Use checkpoint_list() with the same scope parameters to discover accessible checkpoints'],\n        },\n        startTime,\n      });\n    }\n  }\n\n  const success: boolean = checkpoints.deleteCheckpoint(name, scope);\n\n  const summary = success\n    ? `Checkpoint \"${name}\" deleted successfully`\n    : `Checkpoint \"${name}\" not found`;\n\n  return createMCPSuccessResponse({\n    tool: 'checkpoint_delete',\n    summary,\n    data: {\n      success,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","text":"        recovery: {\n          hint: 'Retry with matching scope values or omit optional scope parameters if you intend to access an unscoped checkpoint.',\n          actions: ['Use checkpoint_list() with the same scope parameters to discover accessible checkpoints'],\n        },\n        startTime,\n      });\n    }\n  }\n\n  const success: boolean = checkpoints.deleteCheckpoint(name, scope);\n\n  const summary = success\n    ? `Checkpoint \"${name}\" deleted successfully`\n    : `Checkpoint \"${name}\" not found`;\n\n  return createMCPSuccessResponse({\n    tool: 'checkpoint_delete',\n    summary,\n    data: {\n      success,\n      safetyConfirmationUsed: true,\n      checkpointName: name,\n      ...(success ? { deletedAt: new Date().toISOString() } : {}),\n    },\n    hints: success\n      ? []\n      : ['Use checkpoint_list() to see available checkpoints'],\n    startTime: startTime\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. MEMORY VALIDATE HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_validate tool - records user validation feedback to adjust confidence */\nasync function handleMemoryValidate(args: MemoryValidateArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_validate');\n  const startTime = Date.now();\n  await checkDatabaseUpdated();\n  const {\n    id,\n    wasUseful,\n    queryId,\n    queryTerms,\n    resultRank,\n    totalResultsShown,\n    searchMode,\n    intent,\n    sessionId,\n    notes,\n  } = args;\n\n  if (id === undefined || id === null) {\n    throw new Error('id is required');\n  }\n\n  if (typeof wasUseful !== 'boolean') {\n    throw new Error('wasUseful is required and must be a boolean');\n  }\n\n  const memoryId = parseMemoryId(id);\n\n  vectorIndex.initializeDb();\n  const database = requireDb();\n  const normalizedQueryId = typeof queryId === 'string' && queryId.trim().length > 0\n    ? queryId.trim()\n    : null;\n  const queryText = resolveValidationQueryText(database, normalizedQueryId ?? undefined);\n  // Validate the caller-supplied sessionId before using it for feedback\n  // attribution (adaptive-signal actor + ground-truth selection). A forged or\n  // untracked id must not attribute signals to another session; degrade to\n  // no-attribution rather than reject, since validation feedback is best-effort.\n  const trustedValidation = sessionManager.resolveTrustedSession(sessionId ?? null);\n  const trustedSessionId = trustedValidation.trusted ? trustedValidation.effectiveSessionId : undefined;\n  const result: ValidationResult = confidenceTracker.recordValidation(database, memoryId, wasUseful);\n  try {\n    recordAdaptiveSignal(database, {\n      memoryId,\n      signalType: wasUseful ? 'outcome' : 'correction',\n      signalValue: 1,\n      query: queryText,\n      actor: trustedSessionId ?? 'memory_validate',\n      metadata: {\n        queryId: normalizedQueryId,\n        queryText,\n        resultRank: typeof resultRank === 'number' ? resultRank : null,\n        totalResultsShown: typeof totalResultsShown === 'number' ? totalResultsShown : null,\n        intent: intent ?? null,\n      },\n    });\n  } catch (_error: unknown) {\n    // Adaptive signals are best-effort only\n  }\n\n  // Auto-promotion wiring on positive feedback.\n  let autoPromotion: {\n    attempted: boolean;\n    promoted: boolean;\n    previousTier?: string;\n    newTier?: string;\n    reason?: string;\n  } | null = null;\n\n  if (wasUseful) {\n    const promotionResult = executeAutoPromotion(database, memoryId);\n    autoPromotion = {\n      attempted: true,\n      promoted: promotionResult.promoted,\n      previousTier: promotionResult.previousTier,\n      newTier: promotionResult.newTier,\n      reason: promotionResult.reason,\n    };\n  }\n\n  // Negative-feedback confidence signal persistence for runtime scoring.\n  if (!wasUseful) {\n    recordNegativeFeedbackEvent(database, memoryId);\n  }\n\n  // Optional wiring from memory_validate to learned feedback + ground truth.\n  let learnedFeedback: {\n    attempted: boolean;\n    applied: boolean;\n    termsLearned: string[];\n    reason?: string;\n  } | null = null;\n  let groundTruthSelectionId: number | null = null;\n\n  if (wasUseful && typeof queryId === 'string' && queryId.trim().length > 0) {\n    groundTruthSelectionId = recordUserSelection(queryId, memoryId, {\n      searchMode,\n      intent,\n      selectedRank: resultRank,\n      totalResultsShown,\n      sessionId: trustedSessionId,\n      notes,\n    });\n\n    const normalizedTerms = Array.isArray(queryTerms)\n      ? queryTerms.filter((term) => typeof term === 'string' && term.trim().length > 0).map((term) => term.trim())\n      : [];\n\n    if (typeof resultRank === 'number' && Number.isFinite(resultRank) && resultRank > 0 && normalizedTerms.length > 0) {\n      const learnResult = recordSelection(queryId, memoryId, normalizedTerms, Math.floor(resultRank), database);\n      learnedFeedback = {\n        attempted: true,\n        applied: learnResult.applied,\n        termsLearned: learnResult.terms,\n        reason: learnResult.reason,\n      };\n    } else {\n      learnedFeedback = {\n        attempted: false,\n        applied: false,\n        termsLearned: [],\n        reason: 'missing_query_terms_or_rank',\n      };\n    }\n  }\n\n  const summary = wasUseful\n    ? `Positive validation recorded (confidence: ${result.confidence.toFixed(2)})`\n    : `Negative validation recorded (confidence: ${result.confidence.toFixed(2)})`;\n\n  const hints: string[] = [];\n  if (result.promotionEligible) {\n    hints.push('Memory eligible for promotion to critical tier');\n  }\n  if (!wasUseful && result.validationCount > 3) {\n    hints.push('Consider updating or deleting this memory if consistently unhelpful');\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_validate',\n    summary,\n    data: {\n      memoryId,\n      wasUseful: wasUseful,\n      confidence: result.confidence,\n      validationCount: result.validationCount,\n      positiveValidationCount: result.positiveValidationCount,\n      promotionEligible: result.promotionEligible,\n      autoPromotion,\n      learnedFeedback,\n      groundTruthSelectionId,\n    },\n    hints,\n    startTime: startTime\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  handleCheckpointCreate,\n  handleCheckpointList,\n  handleCheckpointRestore,\n  handleCheckpointDelete,\n  handleMemoryValidate,\n};\n\n// Backward-compatible aliases (snake_case)\nconst handle_checkpoint_create = handleCheckpointCreate;\nconst handle_checkpoint_list = handleCheckpointList;\nconst handle_checkpoint_restore = handleCheckpointRestore;\nconst handle_checkpoint_delete = handleCheckpointDelete;\nconst handle_memory_validate = handleMemoryValidate;\n\nexport {\n  handle_checkpoint_create,\n  handle_checkpoint_list,\n  handle_checkpoint_restore,\n  handle_checkpoint_delete,\n  handle_memory_validate,\n};","lineStart":701,"lineEnd":918,"totalLines":918,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","time":{"start":1781762060990,"end":1781762061004}},"metadata":{"openai":{"itemId":"fc_01d9e7d4148de0b3016a33880bddcc8191a795b06d94992b4e"}},"id":"prt_ed94b6e6b001xrdxOw3zrWwA1D","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94b5c58001LVGYMffCoh4RhW"}}
