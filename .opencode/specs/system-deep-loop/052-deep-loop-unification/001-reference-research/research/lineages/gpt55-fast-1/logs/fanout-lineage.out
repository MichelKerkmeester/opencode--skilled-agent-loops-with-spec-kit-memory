ry: 'intent-described',\n91:   },\n92:   {\n93:     prompt: 'Create a branch, make a conventional commit, push it, and open the pull request.',\n94:     expectedSkill: 'sk-git',\n95:     category: 'intent-described',\n96:   },\n97:   {\n98:     prompt: 'Rewrite this instruction so another model follows the constraints and understands the goal.',\n99:     expectedSkill: 'sk-prompt',\n100:     category: 'intent-described',\n101:   },\n102:   {\n103:     prompt: 'I need to locate where this behavior is implemented without knowing the symbol names.',\n104:     expectedSkill: 'system-code-graph',\n105:     category: 'intent-described',\n106:   },\n107:   {\n108:     prompt: 'Run several MCP calls together through one typed script and return the compact result.',\n109:     expectedSkill: 'mcp-code-mode',\n110:     category: 'intent-described',\n111:   },\n112:   {\n113:     prompt: 'Open the local page, click through the UI, and tell me what appears in the console.',\n114:     expectedSkill: 'mcp-chrome-devtools',\n115:     category: 'intent-described',\n116:   },\n117:   {\n118:     prompt: 'Ask the OpenCode CLI for an independent implementation pass on this module.',\n119:     expectedSkill: 'cli-opencode',\n120:     category: 'intent-described',\n121:   },\n122:   {\n123:     prompt: 'Have Anthropic\\'s coding CLI take a second look at this failing refactor.',\n124:     expectedSkill: 'cli-claude-code',\n125:     category: 'intent-described',\n126:   },\n127:   {\n128:     prompt: 'Compare several planning perspectives, converge on one design, and save the deliberation artifacts.',\n129:     expectedSkill: 'deep-loop-workflows',\n130:     category: 'intent-described',\n131:   },\n132: ];\n\n(End of file - total 132 lines)\n</content>","metadata":{"preview":"    category: 'today-correct',\n  },\n  {\n    prompt: 'Use cli-opencode to delegate this coding task through OpenCode CLI.',\n    expectedSkill: 'cli-opencode',\n    category: 'today-correct',\n  },\n  {\n    promp