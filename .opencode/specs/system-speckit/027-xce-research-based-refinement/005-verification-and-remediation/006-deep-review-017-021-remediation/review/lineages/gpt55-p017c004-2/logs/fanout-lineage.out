{"type":"text","timestamp":1781757752877,"sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","part":{"id":"prt_ed9098f6c001BbHM3avbjmgJ6b","messageID":"msg_ed909783c001aytDnrba8vGXQc","sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","type":"text","text":"The target packet is complete and names the implementation surfaces. I’m reviewing the correctness dimension for the shipped confidence rebalance and calibration wiring, then I’ll synthesize with `maxIterations=1`.","time":{"start":1781757742957,"end":1781757752873},"metadata":{"openai":{"itemId":"msg_0476bff5faf47e28016a33772eee3881919f8110395392d4cc","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781757752922,"sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","part":{"type":"tool","tool":"read","callID":"call_khFz78Pm5Oyr738CzOE684Jo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Confidence Scoring\n3: // ───────────────────────────────────────────────────────────────\n4: // Per-result calibrated confidence scoring\n5: //\n6: // PURPOSE: Combine margin, multi-channel agreement,\n7: // and anchor density into a single calibrated confidence score per\n8: // result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n9: //\n10: // FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n11: //\n12: // OUTPUT SHAPE (per result):\n13: // {\n14: //   \"confidence\": {\n15: //     \"label\": \"high\" | \"medium\" | \"low\",\n16: //     \"value\": 0.78,\n17: //     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n18: //   },\n19: //   \"requestQuality\": {\n20: //     \"label\": \"good\" | \"weak\" | \"gap\"\n21: //   }\n22: // }\n23: //\n24: // IMPORTANT: This module only models ranking confidence for retrieval ordering.\n25: // It is not freshness authority and it is not a substitute for StructuralTrust.\n26: import { statSync } from 'node:fs';\n27: import { resolveEffectiveScore, resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\n28: import {\n29:   isAbsoluteRelevanceCalibrationEnabled,\n30:   isConfidenceCalibrationEnabled,\n31:   getConfidenceCalibrationModelPath,\n32: } from './search-flags.js';\n33: import { applyCalibration, loadCalibrationModel, type CalibrationModel } from './confidence-calibration.js';\n34: \n35: declare const rankingConfidenceBrand: unique symbol;\n36: \n37: // -- Constants --\n38: \n39: const HIGH_THRESHOLD = 0.7;\n40: const LOW_THRESHOLD = 0.4;\n41: \n42: // Weights for each active confidence factor. The former reranker weight (0.20)\n43: // was removed with the LLM reranker; its term was already inert (always 0), so\n44: // rawValue stays capped at 0.80 exactly as before — behavior-neutral. The 0.20\n45: // is intentionally NOT redistributed (that would change confidence scores).\n46: const WEIGHT_MARGIN = 0.35;\n47: const WEIGHT_CHANNEL_AGREEMENT = 0.30;\n48: const WEIGHT_ANCHOR_DENSITY = 0.15;\n49: \n50: // Blend of the heuristic signal (margin/channel/anchor) and the absolute\n51: // relevance prior into the final per-result value. Relevance is intentionally\n52: // weighted higher than the heuristics so the band is monotonic in relevance: a\n53: // strong-but-isolated cosine hit (single channel, no anchors, tail margin) must\n54: // not be capped at \"medium\" purely because the heuristic signals are weak.\n55: // These two must sum to 1.0.\n56: const WEIGHT_HEURISTIC = 0.45;\n57: const WEIGHT_SCORE_PRIOR = 0.55;\n58: \n59: // Guard the sum-to-1.0 invariant at module load: if either weight is retuned\n60: // without adjusting the other, the rebalanced value would no longer be a convex\n61: // blend and could exceed 1 before clamping (silently distorting the band). Fail\n62: // loudly instead. Tolerance absorbs float representation error (0.45 + 0.55).\n63: if (Math.abs(WEIGHT_HEURISTIC + WEIGHT_SCORE_PRIOR - 1.0) > 1e-9) {\n64:   throw new Error(\n65:     `confidence-scoring: WEIGHT_HEURISTIC (${WEIGHT_HEURISTIC}) + WEIGHT_SCORE_PRIOR (${WEIGHT_SCORE_PRIOR}) must sum to 1.0`,\n66:   );\n67: }\n68: \n69: // Margin thresholds (gap between top score and next score, 0–1 scale)\n70: const LARGE_MARGIN_THRESHOLD = 0.15;\n71: const SMALL_MARGIN_THRESHOLD = 0.05;\n72: \n73: // Channel count thresholds\n74: const STRONG_CHANNEL_AGREEMENT_MIN = 2;\n75: \n76: // Request-quality aggregation: a top hit at or above this absolute relevance\n77: // stands on its own, so a weak tail cannot drag the verdict below \"good\".\n78: const TOP_DOMINANT_THRESHOLD = 0.8;\n79: \n80: // Cap the quality-ratio denominator at the head of the ranking. Pulling deeper\n81: // for recall appends weaker tail results; counting them would mechanically\n82: // depress the ratio and penalize a query for retrieving more candidates.\n83: const QUALITY_RATIO_HEAD = 5;\n84: \n85: // -- Types --\n86: \n87: /** Confidence label for a single result. */\n88: export type ConfidenceLabel = 'high' | 'medium' | 'low';\n89: \n90: /**\n91:  * Branded ranking score for retrieval ordering only.\n92:  * Consumers must not reuse this as parser provenance, evidence status,\n93:  * freshness authority, or any other StructuralTrust axis.\n94:  */\n95: export type RankingConfidenceValue = number & {\n96:   readonly [rankingConfidenceBrand]: 'RankingConfidenceValue';\n97: };\n98: \n99: /** Quality label at the request level (across all results). */\n100: export type RequestQualityLabel = 'good' | 'weak' | 'gap';\n101: \n102: /** Which factors drove the confidence score upward. */\n103: export type ConfidenceDriver =\n104:   | 'large_margin'\n105:   | 'multi_channel_agreement'\n106:   | 'anchor_density';\n107: \n108: /** Per-result confidence payload. */\n109: export interface RankingConfidenceContract {\n110:   label: ConfidenceLabel;\n111:   value: RankingConfidenceValue;\n112:   drivers: ConfidenceDriver[];\n113:   structuralTrust?: never;\n114:   parserProvenance?: never;\n115:   evidenceStatus?: never;\n116:   freshnessAuthority?: never;\n117: }\n118: \n119: export interface ResultConfidence {\n120:   confidence: RankingConfidenceContract;\n121: }\n122: \n123: /** Request-level quality assessment (one per search call). */\n124: export interface RequestQualityAssessment {\n125:   requestQuality: {\n126:     label: RequestQualityLabel;\n127:   };\n128: }\n129: \n130: /**\n131:  * Minimal result shape needed for confidence computation.\n132:  * Uses `Record<string, unknown>` to stay compatible with both\n133:  * `RawSearchResult` and `PipelineRow` without importing either.\n134:  */\n135: export interface ScoredResult extends Record<string, unknown> {\n136:   id: number;\n137:   /** Composite score (0–1). */\n138:   score?: number;\n139:   /** RRF fusion score (0–1). */\n140:   rrfScore?: number;\n141:   /** Intent-adjusted score (0–1). */\n142:   intentAdjustedScore?: number;\n143:   /** Raw cosine similarity (0–100 scale from sqlite-vec). */\n144:   similarity?: number;\n145:   /** Score origin metadata for distinguishing real reranks from fallbacks. */\n146:   scoringMethod?: string;\n147:   /** Anchor metadata array populated by Stage 2. */\n148:   anchorMetadata?: Array<Record<string, unknown>>;\n149:   /** Source channels that contributed this result. */\n150:   sources?: string[];\n151:   /** Single source channel string (legacy). */\n152:   source?: string;\n153:   /** Trace metadata containing channel attribution. */\n154:   traceMetadata?: Record<string, unknown>;\n155: }\n156: \n157: // -- Internal helpers --\n158: \n159: function resolveScore(result: ScoredResult): number {\n160:   return resolveEffectiveScore(result as PipelineRow);\n161: }\n162: \n163: /**\n164:  * Absolute relevance used for confidence calibration and request-quality — keeps\n165:  * ordering on the RRF/effective score while reading an absolute 0–1 signal for\n166:  * \"how good is this\", so the 0.7/0.4 thresholds mean what they say. Reverts to the\n167:  * effective score when SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION is disabled.\n168:  */\n169: function resolveCalibrationScore(result: ScoredResult): number {\n170:   return isAbsoluteRelevanceCalibrationEnabled()\n171:     ? resolveAbsoluteRelevance(result as PipelineRow)\n172:     : resolveEffectiveScore(result as PipelineRow);\n173: }\n174: \n175: // Lazily-loaded calibration model, memoized so the search hot path reads the\n176: // file at most once per (path, mtime) pair. The mtime is part of the cache key\n177: // so editing the model in place re-reads it; without it a path-stable file\n178: // rewritten on disk would serve the stale fitted curve indefinitely.\n179: // `undefined` = not yet looked up; `null` = looked up and absent/invalid\n180: // (degrade to identity).\n181: let cachedCalibrationModel: CalibrationModel | null | undefined;\n182: let cachedCalibrationModelPath: string | undefined;\n183: let cachedCalibrationModelMtimeMs: number | undefined;\n184: \n185: /** Best-effort mtime; `undefined` when the path is unreadable (treated as a miss). */\n186: function calibrationModelMtimeMs(path: string): number | undefined {\n187:   try {\n188:     return statSync(path).mtimeMs;\n189:   } catch {\n190:     return undefined;\n191:   }\n192: }\n193: \n194: function resolveCalibrationModel(): CalibrationModel | null {\n195:   const path = getConfidenceCalibrationModelPath();\n196:   if (!path) return null;\n197:   const mtimeMs = calibrationModelMtimeMs(path);\n198:   if (\n199:     cachedCalibrationModel !== undefined &&\n200:     cachedCalibrationModelPath === path &&\n201:     cachedCalibrationModelMtimeMs === mtimeMs\n202:   ) {\n203:     return cachedCalibrationModel;\n204:   }\n205:   cachedCalibrationModelPath = path;\n206:   cachedCalibrationModelMtimeMs = mtimeMs;\n207:   cachedCalibrationModel = loadCalibrationModel(path);\n208:   return cachedCalibrationModel;\n209: }\n210: \n211: /**\n212:  * Map a rebalanced confidence value through the empirical calibration model\n213:  * when enabled. Default OFF and a no-op when no model is configured, so the\n214:  * returned value is identical to the rebalance-only path until a validated\n215:  * model is wired in.\n216:  */\n217: function maybeCalibrate(value: number): number {\n218:   if (!isConfidenceCalibrationEnabled()) return value;\n219:   const model = resolveCalibrationModel();\n220:   if (!model) return value;\n221:   return applyCalibration(model, value);\n222: }\n223: \n224: /**\n225:  * Count the number of unique channels that retrieved this result.\n226:  * Inspects `sources`, `source`, and traceMetadata.attribution.\n227:  */\n228: function countChannels(result: ScoredResult): number {\n229:   const channels = new Set<string>();\n230: \n231:   if (Array.isArray(result.sources)) {\n232:     for (const s of result.sources) {\n233:       if (typeof s === 'string' && s.trim().length > 0) channels.add(s.trim());\n234:     }\n235:   }\n236: \n237:   if (typeof result.source === 'string' && result.source.trim().length > 0) {\n238:     channels.add(result.source.trim());\n239:   }\n240: \n241:   // Check traceMetadata.attribution for richer channel data\n242:   const numericId = typeof result.id === 'number' ? result.id : null;\n243:   const attribution = result.traceMetadata?.attribution;\n244:   if (attribution && typeof attribution === 'object' && numericId !== null) {\n245:     for (const [channel, memoryIds] of Object.entries(attribution as Record<string, unknown>)) {\n246:       if (!Array.isArray(memoryIds)) continue;\n247:       const matched = memoryIds.some((mid) => {\n248:         const n = typeof mid === 'number' ? mid : typeof mid === 'string' ? Number(mid) : NaN;\n249:         return Number.isFinite(n) && n === numericId;\n250:       });\n251:       if (matched && typeof channel === 'string' && channel.trim().length > 0) {\n252:         channels.add(channel.trim());\n253:       }\n254:     }\n255:   }\n256: \n257:   return channels.size;\n258: }\n259: \n260: /**\n261:  * Count anchors present in this result's anchorMetadata array.\n262:  * A result with multiple named anchors is considered \"dense\" and\n263:  * more likely to be a high-quality, well-structured memory.\n264:  */\n265: function countAnchors(result: ScoredResult): number {\n266:   if (!Array.isArray(result.anchorMetadata)) return 0;\n267:   return result.anchorMetadata.length;\n268: }\n269: \n270: /**\n271:  * Compute the score margin between result[i] and result[i+1].\n272:  * Tail results have no successor, so they receive no synthetic margin boost.\n273:  */\n274: function computeMargin(score: number, nextScore: number | null): number {\n275:   if (nextScore === null) return 0;\n276:   const gap = score - nextScore;\n277:   return Math.max(0, gap);\n278: }\n279: \n280: /**\n281:  * Map raw confidence value to a coarse label.\n282:  */\n283: function toConfidenceLabel(value: number): ConfidenceLabel {\n284:   if (value >= HIGH_THRESHOLD) return 'high';\n285:   if (value >= LOW_THRESHOLD) return 'medium';\n286:   return 'low';\n287: }\n288: \n289: export function asRankingConfidenceValue(value: number): RankingConfidenceValue {\n290:   const clamped = Math.max(0, Math.min(1, value));\n291:   return (Math.round(clamped * 1000) / 1000) as RankingConfidenceValue;\n292: }\n293: \n294: // -- Public API --\n295: \n296: /**\n297:  * Compute per-result confidence for a ranked list of results.\n298:  *\n299:  * Each result receives a confidence object derived from:\n300:  *   - Score margin to the next result (35% weight)\n301:  *   - Number of channels that contributed this result (30%)\n302:  *   - Anchor density in anchorMetadata (15%)\n303:  *\n304:  * @param results - Ranked results (highest score first). Ordering is assumed.\n305:  * @returns Array of ResultConfidence objects, parallel to `results`.\n306:  */\n307: export function computeResultConfidence(results: ScoredResult[]): ResultConfidence[] {\n308:   if (!Array.isArray(results) || results.length === 0) return [];\n309: \n310:   const scores = results.map(resolveScore);\n311: \n312:   return results.map((result, i): ResultConfidence => {\n313:     const score = scores[i] ?? 0;\n314:     const nextScore = i + 1 < scores.length ? (scores[i + 1] ?? null) : null;\n315: \n316:     const margin = computeMargin(score, nextScore);\n317:     const channelCount = countChannels(result);\n318:     const anchorCount = countAnchors(result);\n319: \n320:     // Factor scores (each 0–1)\n321:     const marginFactor = margin >= LARGE_MARGIN_THRESHOLD\n322:       ? 1.0\n323:       : margin >= SMALL_MARGIN_THRESHOLD\n324:         ? margin / LARGE_MARGIN_THRESHOLD\n325:         : 0;\n326: \n327:     const channelFactor = channelCount >= STRONG_CHANNEL_AGREEMENT_MIN\n328:       ? 1.0\n329:       : channelCount === 1\n330:         ? 0.5\n331:         : 0;\n332: \n333:     // Anchor density: 1 anchor → 0.3, 2 → 0.6, 3+ → 1.0\n334:     const anchorFactor = Math.min(1, anchorCount * 0.33);\n335: \n336:     const rawValue =\n337:       WEIGHT_MARGIN * marginFactor +\n338:       WEIGHT_CHANNEL_AGREEMENT * channelFactor +\n339:       WEIGHT_ANCHOR_DENSITY * anchorFactor;\n340: \n341:     // Base score is a strong prior: if the score itself is very high, confidence\n342:     // should reflect that even when heuristic signals are weak. Use the absolute\n343:     // relevance (cosine) here, not the RRF ordering score — an RRF magnitude of\n344:     // ~0.03 would make this prior contribute ~0.01 and defeat its purpose.\n345:     // Relevance carries the larger weight so the band stays monotonic in it.\n346:     const scorePrior = resolveCalibrationScore(result) * WEIGHT_SCORE_PRIOR;\n347:     const heuristicValue = rawValue * WEIGHT_HEURISTIC;\n348:     const rebalancedValue = Math.max(0, Math.min(1, heuristicValue + scorePrior));\n349: \n350:     // Optional empirical calibration to P(relevant). Default OFF: only applied\n351:     // when the flag is on AND a fitted model is available, so production\n352:     // confidence is the rebalance-only value until a validated model exists.\n353:     const value = maybeCalibrate(rebalancedValue);\n354: \n355:     const drivers: ConfidenceDriver[] = [];\n356:     if (margin >= LARGE_MARGIN_THRESHOLD) drivers.push('large_margin');\n357:     if (channelCount >= STRONG_CHANNEL_AGREEMENT_MIN) drivers.push('multi_channel_agreement');\n358:     if (anchorCount >= 2) drivers.push('anchor_density');\n359: \n360:       return {\n361:         confidence: {\n362:           label: toConfidenceLabel(value),\n363:           value: asRankingConfidenceValue(value),\n364:           drivers,\n365:         },\n366:       };\n367:   });\n368: }\n369: \n370: /**\n371:  * Compute request-level quality assessment based on the overall result set.\n372:  *\n373:  * - \"good\":  a dominant top hit, or a healthy top score with confident head / clear margin\n374:  * - \"weak\":  results exist but signals are mixed or low\n375:  * - \"gap\":   no results, or all results have low confidence\n376:  *\n377:  * The \"good\" rule is top-dominant and margin-aware: a single strong, well-separated\n378:  * top hit is citable even when the tail is weak. Without this, a strong top result\n379:  * is dragged to \"weak\" by a weaker tail, and expanding recall (more tail candidates)\n380:  * mechanically lowers the quality ratio — penalizing the very recall that found the hit.\n381:  *\n382:  * @param results   - The scored results for the query.\n383:  * @param confidences - Parallel confidence array from `computeResultConfidence`.\n384:  */\n385: export function assessRequestQuality(\n386:   results: ScoredResult[],\n387:   confidences: ResultConfidence[],\n388: ): RequestQualityAssessment {\n389:   if (!Array.isArray(results) || results.length === 0) {\n390:     return { requestQuality: { label: 'gap' } };\n391:   }\n392: \n393:   // `results` and `confidences` are a parallel pair (confidences come from\n394:   // computeResultConfidence(results)). A length mismatch means the head slice\n395:   // below would pair results[i] with an unrelated confidence, so degrade to the\n396:   // conservative do-not-cite verdict rather than emit a quality label off\n397:   // misaligned data. Holds at every call site today — defensive only.\n398:   if (!Array.isArray(confidences) || confidences.length !== results.length) {\n399:     return { requestQuality: { label: 'gap' } };\n400:   }\n401: \n402:   // Absolute relevance, not the RRF ordering score: HIGH_THRESHOLD/LOW_THRESHOLD\n403:   // are calibrated for a 0–1 cosine scale, so an RRF-magnitude topScore (~0.03)\n404:   // would put \"good\" out of reach and collapse every query to weak/gap.\n405:   const topScore = resolveCalibrationScore(results[0]);\n406: \n407:   // Quality ratio over the head of the ranking only, so recall expansion does\n408:   // not depress it (see QUALITY_RATIO_HEAD).\n409:   const head = Math.min(confidences.length, QUALITY_RATIO_HEAD);\n410:   const highOrMediumCount = confidences\n411:     .slice(0, head)\n412:     .filter((c) => c.confidence.label === 'high' || c.confidence.label === 'medium')\n413:     .length;\n414:   const qualityRatio = head > 0 ? highOrMediumCount / head : 0;\n415: \n416:   // Margin between #1 and #2 on the same absolute scale as topScore. A clear gap\n417:   // to the runner-up marks a dominant top hit even when the tail is weak.\n418:   const topMargin = results.length > 1\n419:     ? computeMargin(topScore, resolveCalibrationScore(results[1]))\n420:     : 0;\n421: \n422:   // A sufficiently strong top hit is citable on its own, regardless of the tail.\n423:   if (topScore >= TOP_DOMINANT_THRESHOLD) {\n424:     return { requestQuality: { label: 'good' } };\n425:   }\n426:   // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n427:   // OR the top hit clearly dominates the runner-up.\n428:   if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n429:     return { requestQuality: { label: 'good' } };\n430:   }\n431:   // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n432:   // genuinely low-signal queries.\n433:   if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n434:     return { requestQuality: { label: 'weak' } };\n435:   }\n436:   return { requestQuality: { label: 'gap' } };\n437: }\n438: \n439: /**\n440:  * Check whether the per-result confidence feature flag is enabled.\n441:  * Default: ON (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n442:  */\n443: export { isResultConfidenceEnabled } from './search-flags.js';\n\n(End of file - total 443 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Scoring\n// ───────────────────────────────────────────────────────────────\n// Per-result calibrated confidence scoring\n//\n// PURPOSE: Combine margin, multi-channel agreement,\n// and anchor density into a single calibrated confidence score per\n// result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n//\n// FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE (per result):\n// {\n//   \"confidence\": {\n//     \"label\": \"high\" | \"medium\" | \"low\",\n//     \"value\": 0.78,\n//     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n//   },\n//   \"requestQuality\": {\n//     \"label\": \"good\" | \"weak\" | \"gap\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Scoring\n// ───────────────────────────────────────────────────────────────\n// Per-result calibrated confidence scoring\n//\n// PURPOSE: Combine margin, multi-channel agreement,\n// and anchor density into a single calibrated confidence score per\n// result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n//\n// FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE (per result):\n// {\n//   \"confidence\": {\n//     \"label\": \"high\" | \"medium\" | \"low\",\n//     \"value\": 0.78,\n//     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n//   },\n//   \"requestQuality\": {\n//     \"label\": \"good\" | \"weak\" | \"gap\"\n//   }\n// }\n//\n// IMPORTANT: This module only models ranking confidence for retrieval ordering.\n// It is not freshness authority and it is not a substitute for StructuralTrust.\nimport { statSync } from 'node:fs';\nimport { resolveEffectiveScore, resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\nimport {\n  isAbsoluteRelevanceCalibrationEnabled,\n  isConfidenceCalibrationEnabled,\n  getConfidenceCalibrationModelPath,\n} from './search-flags.js';\nimport { applyCalibration, loadCalibrationModel, type CalibrationModel } from './confidence-calibration.js';\n\ndeclare const rankingConfidenceBrand: unique symbol;\n\n// -- Constants --\n\nconst HIGH_THRESHOLD = 0.7;\nconst LOW_THRESHOLD = 0.4;\n\n// Weights for each active confidence factor. The former reranker weight (0.20)\n// was removed with the LLM reranker; its term was already inert (always 0), so\n// rawValue stays capped at 0.80 exactly as before — behavior-neutral. The 0.20\n// is intentionally NOT redistributed (that would change confidence scores).\nconst WEIGHT_MARGIN = 0.35;\nconst WEIGHT_CHANNEL_AGREEMENT = 0.30;\nconst WEIGHT_ANCHOR_DENSITY = 0.15;\n\n// Blend of the heuristic signal (margin/channel/anchor) and the absolute\n// relevance prior into the final per-result value. Relevance is intentionally\n// weighted higher than the heuristics so the band is monotonic in relevance: a\n// strong-but-isolated cosine hit (single channel, no anchors, tail margin) must\n// not be capped at \"medium\" purely because the heuristic signals are weak.\n// These two must sum to 1.0.\nconst WEIGHT_HEURISTIC = 0.45;\nconst WEIGHT_SCORE_PRIOR = 0.55;\n\n// Guard the sum-to-1.0 invariant at module load: if either weight is retuned\n// without adjusting the other, the rebalanced value would no longer be a convex\n// blend and could exceed 1 before clamping (silently distorting the band). Fail\n// loudly instead. Tolerance absorbs float representation error (0.45 + 0.55).\nif (Math.abs(WEIGHT_HEURISTIC + WEIGHT_SCORE_PRIOR - 1.0) > 1e-9) {\n  throw new Error(\n    `confidence-scoring: WEIGHT_HEURISTIC (${WEIGHT_HEURISTIC}) + WEIGHT_SCORE_PRIOR (${WEIGHT_SCORE_PRIOR}) must sum to 1.0`,\n  );\n}\n\n// Margin thresholds (gap between top score and next score, 0–1 scale)\nconst LARGE_MARGIN_THRESHOLD = 0.15;\nconst SMALL_MARGIN_THRESHOLD = 0.05;\n\n// Channel count thresholds\nconst STRONG_CHANNEL_AGREEMENT_MIN = 2;\n\n// Request-quality aggregation: a top hit at or above this absolute relevance\n// stands on its own, so a weak tail cannot drag the verdict below \"good\".\nconst TOP_DOMINANT_THRESHOLD = 0.8;\n\n// Cap the quality-ratio denominator at the head of the ranking. Pulling deeper\n// for recall appends weaker tail results; counting them would mechanically\n// depress the ratio and penalize a query for retrieving more candidates.\nconst QUALITY_RATIO_HEAD = 5;\n\n// -- Types --\n\n/** Confidence label for a single result. */\nexport type ConfidenceLabel = 'high' | 'medium' | 'low';\n\n/**\n * Branded ranking score for retrieval ordering only.\n * Consumers must not reuse this as parser provenance, evidence status,\n * freshness authority, or any other StructuralTrust axis.\n */\nexport type RankingConfidenceValue = number & {\n  readonly [rankingConfidenceBrand]: 'RankingConfidenceValue';\n};\n\n/** Quality label at the request level (across all results). */\nexport type RequestQualityLabel = 'good' | 'weak' | 'gap';\n\n/** Which factors drove the confidence score upward. */\nexport type ConfidenceDriver =\n  | 'large_margin'\n  | 'multi_channel_agreement'\n  | 'anchor_density';\n\n/** Per-result confidence payload. */\nexport interface RankingConfidenceContract {\n  label: ConfidenceLabel;\n  value: RankingConfidenceValue;\n  drivers: ConfidenceDriver[];\n  structuralTrust?: never;\n  parserProvenance?: never;\n  evidenceStatus?: never;\n  freshnessAuthority?: never;\n}\n\nexport interface ResultConfidence {\n  confidence: RankingConfidenceContract;\n}\n\n/** Request-level quality assessment (one per search call). */\nexport interface RequestQualityAssessment {\n  requestQuality: {\n    label: RequestQualityLabel;\n  };\n}\n\n/**\n * Minimal result shape needed for confidence computation.\n * Uses `Record<string, unknown>` to stay compatible with both\n * `RawSearchResult` and `PipelineRow` without importing either.\n */\nexport interface ScoredResult extends Record<string, unknown> {\n  id: number;\n  /** Composite score (0–1). */\n  score?: number;\n  /** RRF fusion score (0–1). */\n  rrfScore?: number;\n  /** Intent-adjusted score (0–1). */\n  intentAdjustedScore?: number;\n  /** Raw cosine similarity (0–100 scale from sqlite-vec). */\n  similarity?: number;\n  /** Score origin metadata for distinguishing real reranks from fallbacks. */\n  scoringMethod?: string;\n  /** Anchor metadata array populated by Stage 2. */\n  anchorMetadata?: Array<Record<string, unknown>>;\n  /** Source channels that contributed this result. */\n  sources?: string[];\n  /** Single source channel string (legacy). */\n  source?: string;\n  /** Trace metadata containing channel attribution. */\n  traceMetadata?: Record<string, unknown>;\n}\n\n// -- Internal helpers --\n\nfunction resolveScore(result: ScoredResult): number {\n  return resolveEffectiveScore(result as PipelineRow);\n}\n\n/**\n * Absolute relevance used for confidence calibration and request-quality — keeps\n * ordering on the RRF/effective score while reading an absolute 0–1 signal for\n * \"how good is this\", so the 0.7/0.4 thresholds mean what they say. Reverts to the\n * effective score when SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION is disabled.\n */\nfunction resolveCalibrationScore(result: ScoredResult): number {\n  return isAbsoluteRelevanceCalibrationEnabled()\n    ? resolveAbsoluteRelevance(result as PipelineRow)\n    : resolveEffectiveScore(result as PipelineRow);\n}\n\n// Lazily-loaded calibration model, memoized so the search hot path reads the\n// file at most once per (path, mtime) pair. The mtime is part of the cache key\n// so editing the model in place re-reads it; without it a path-stable file\n// rewritten on disk would serve the stale fitted curve indefinitely.\n// `undefined` = not yet looked up; `null` = looked up and absent/invalid\n// (degrade to identity).\nlet cachedCalibrationModel: CalibrationModel | null | undefined;\nlet cachedCalibrationModelPath: string | undefined;\nlet cachedCalibrationModelMtimeMs: number | undefined;\n\n/** Best-effort mtime; `undefined` when the path is unreadable (treated as a miss). */\nfunction calibrationModelMtimeMs(path: string): number | undefined {\n  try {\n    return statSync(path).mtimeMs;\n  } catch {\n    return undefined;\n  }\n}\n\nfunction resolveCalibrationModel(): CalibrationModel | null {\n  const path = getConfidenceCalibrationModelPath();\n  if (!path) return null;\n  const mtimeMs = calibrationModelMtimeMs(path);\n  if (\n    cachedCalibrationModel !== undefined &&\n    cachedCalibrationModelPath === path &&\n    cachedCalibrationModelMtimeMs === mtimeMs\n  ) {\n    return cachedCalibrationModel;\n  }\n  cachedCalibrationModelPath = path;\n  cachedCalibrationModelMtimeMs = mtimeMs;\n  cachedCalibrationModel = loadCalibrationModel(path);\n  return cachedCalibrationModel;\n}\n\n/**\n * Map a rebalanced confidence value through the empirical calibration model\n * when enabled. Default OFF and a no-op when no model is configured, so the\n * returned value is identical to the rebalance-only path until a validated\n * model is wired in.\n */\nfunction maybeCalibrate(value: number): number {\n  if (!isConfidenceCalibrationEnabled()) return value;\n  const model = resolveCalibrationModel();\n  if (!model) return value;\n  return applyCalibration(model, value);\n}\n\n/**\n * Count the number of unique channels that retrieved this result.\n * Inspects `sources`, `source`, and traceMetadata.attribution.\n */\nfunction countChannels(result: ScoredResult): number {\n  const channels = new Set<string>();\n\n  if (Array.isArray(result.sources)) {\n    for (const s of result.sources) {\n      if (typeof s === 'string' && s.trim().length > 0) channels.add(s.trim());\n    }\n  }\n\n  if (typeof result.source === 'string' && result.source.trim().length > 0) {\n    channels.add(result.source.trim());\n  }\n\n  // Check traceMetadata.attribution for richer channel data\n  const numericId = typeof result.id === 'number' ? result.id : null;\n  const attribution = result.traceMetadata?.attribution;\n  if (attribution && typeof attribution === 'object' && numericId !== null) {\n    for (const [channel, memoryIds] of Object.entries(attribution as Record<string, unknown>)) {\n      if (!Array.isArray(memoryIds)) continue;\n      const matched = memoryIds.some((mid) => {\n        const n = typeof mid === 'number' ? mid : typeof mid === 'string' ? Number(mid) : NaN;\n        return Number.isFinite(n) && n === numericId;\n      });\n      if (matched && typeof channel === 'string' && channel.trim().length > 0) {\n        channels.add(channel.trim());\n      }\n    }\n  }\n\n  return channels.size;\n}\n\n/**\n * Count anchors present in this result's anchorMetadata array.\n * A result with multiple named anchors is considered \"dense\" and\n * more likely to be a high-quality, well-structured memory.\n */\nfunction countAnchors(result: ScoredResult): number {\n  if (!Array.isArray(result.anchorMetadata)) return 0;\n  return result.anchorMetadata.length;\n}\n\n/**\n * Compute the score margin between result[i] and result[i+1].\n * Tail results have no successor, so they receive no synthetic margin boost.\n */\nfunction computeMargin(score: number, nextScore: number | null): number {\n  if (nextScore === null) return 0;\n  const gap = score - nextScore;\n  return Math.max(0, gap);\n}\n\n/**\n * Map raw confidence value to a coarse label.\n */\nfunction toConfidenceLabel(value: number): ConfidenceLabel {\n  if (value >= HIGH_THRESHOLD) return 'high';\n  if (value >= LOW_THRESHOLD) return 'medium';\n  return 'low';\n}\n\nexport function asRankingConfidenceValue(value: number): RankingConfidenceValue {\n  const clamped = Math.max(0, Math.min(1, value));\n  return (Math.round(clamped * 1000) / 1000) as RankingConfidenceValue;\n}\n\n// -- Public API --\n\n/**\n * Compute per-result confidence for a ranked list of results.\n *\n * Each result receives a confidence object derived from:\n *   - Score margin to the next result (35% weight)\n *   - Number of channels that contributed this result (30%)\n *   - Anchor density in anchorMetadata (15%)\n *\n * @param results - Ranked results (highest score first). Ordering is assumed.\n * @returns Array of ResultConfidence objects, parallel to `results`.\n */\nexport function computeResultConfidence(results: ScoredResult[]): ResultConfidence[] {\n  if (!Array.isArray(results) || results.length === 0) return [];\n\n  const scores = results.map(resolveScore);\n\n  return results.map((result, i): ResultConfidence => {\n    const score = scores[i] ?? 0;\n    const nextScore = i + 1 < scores.length ? (scores[i + 1] ?? null) : null;\n\n    const margin = computeMargin(score, nextScore);\n    const channelCount = countChannels(result);\n    const anchorCount = countAnchors(result);\n\n    // Factor scores (each 0–1)\n    const marginFactor = margin >= LARGE_MARGIN_THRESHOLD\n      ? 1.0\n      : margin >= SMALL_MARGIN_THRESHOLD\n        ? margin / LARGE_MARGIN_THRESHOLD\n        : 0;\n\n    const channelFactor = channelCount >= STRONG_CHANNEL_AGREEMENT_MIN\n      ? 1.0\n      : channelCount === 1\n        ? 0.5\n        : 0;\n\n    // Anchor density: 1 anchor → 0.3, 2 → 0.6, 3+ → 1.0\n    const anchorFactor = Math.min(1, anchorCount * 0.33);\n\n    const rawValue =\n      WEIGHT_MARGIN * marginFactor +\n      WEIGHT_CHANNEL_AGREEMENT * channelFactor +\n      WEIGHT_ANCHOR_DENSITY * anchorFactor;\n\n    // Base score is a strong prior: if the score itself is very high, confidence\n    // should reflect that even when heuristic signals are weak. Use the absolute\n    // relevance (cosine) here, not the RRF ordering score — an RRF magnitude of\n    // ~0.03 would make this prior contribute ~0.01 and defeat its purpose.\n    // Relevance carries the larger weight so the band stays monotonic in it.\n    const scorePrior = resolveCalibrationScore(result) * WEIGHT_SCORE_PRIOR;\n    const heuristicValue = rawValue * WEIGHT_HEURISTIC;\n    const rebalancedValue = Math.max(0, Math.min(1, heuristicValue + scorePrior));\n\n    // Optional empirical calibration to P(relevant). Default OFF: only applied\n    // when the flag is on AND a fitted model is available, so production\n    // confidence is the rebalance-only value until a validated model exists.\n    const value = maybeCalibrate(rebalancedValue);\n\n    const drivers: ConfidenceDriver[] = [];\n    if (margin >= LARGE_MARGIN_THRESHOLD) drivers.push('large_margin');\n    if (channelCount >= STRONG_CHANNEL_AGREEMENT_MIN) drivers.push('multi_channel_agreement');\n    if (anchorCount >= 2) drivers.push('anchor_density');\n\n      return {\n        confidence: {\n          label: toConfidenceLabel(value),\n          value: asRankingConfidenceValue(value),\n          drivers,\n        },\n      };\n  });\n}\n\n/**\n * Compute request-level quality assessment based on the overall result set.\n *\n * - \"good\":  a dominant top hit, or a healthy top score with confident head / clear margin\n * - \"weak\":  results exist but signals are mixed or low\n * - \"gap\":   no results, or all results have low confidence\n *\n * The \"good\" rule is top-dominant and margin-aware: a single strong, well-separated\n * top hit is citable even when the tail is weak. Without this, a strong top result\n * is dragged to \"weak\" by a weaker tail, and expanding recall (more tail candidates)\n * mechanically lowers the quality ratio — penalizing the very recall that found the hit.\n *\n * @param results   - The scored results for the query.\n * @param confidences - Parallel confidence array from `computeResultConfidence`.\n */\nexport function assessRequestQuality(\n  results: ScoredResult[],\n  confidences: ResultConfidence[],\n): RequestQualityAssessment {\n  if (!Array.isArray(results) || results.length === 0) {\n    return { requestQuality: { label: 'gap' } };\n  }\n\n  // `results` and `confidences` are a parallel pair (confidences come from\n  // computeResultConfidence(results)). A length mismatch means the head slice\n  // below would pair results[i] with an unrelated confidence, so degrade to the\n  // conservative do-not-cite verdict rather than emit a quality label off\n  // misaligned data. Holds at every call site today — defensive only.\n  if (!Array.isArray(confidences) || confidences.length !== results.length) {\n    return { requestQuality: { label: 'gap' } };\n  }\n\n  // Absolute relevance, not the RRF ordering score: HIGH_THRESHOLD/LOW_THRESHOLD\n  // are calibrated for a 0–1 cosine scale, so an RRF-magnitude topScore (~0.03)\n  // would put \"good\" out of reach and collapse every query to weak/gap.\n  const topScore = resolveCalibrationScore(results[0]);\n\n  // Quality ratio over the head of the ranking only, so recall expansion does\n  // not depress it (see QUALITY_RATIO_HEAD).\n  const head = Math.min(confidences.length, QUALITY_RATIO_HEAD);\n  const highOrMediumCount = confidences\n    .slice(0, head)\n    .filter((c) => c.confidence.label === 'high' || c.confidence.label === 'medium')\n    .length;\n  const qualityRatio = head > 0 ? highOrMediumCount / head : 0;\n\n  // Margin between #1 and #2 on the same absolute scale as topScore. A clear gap\n  // to the runner-up marks a dominant top hit even when the tail is weak.\n  const topMargin = results.length > 1\n    ? computeMargin(topScore, resolveCalibrationScore(results[1]))\n    : 0;\n\n  // A sufficiently strong top hit is citable on its own, regardless of the tail.\n  if (topScore >= TOP_DOMINANT_THRESHOLD) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n  // OR the top hit clearly dominates the runner-up.\n  if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n  // genuinely low-signal queries.\n  if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n    return { requestQuality: { label: 'weak' } };\n  }\n  return { requestQuality: { label: 'gap' } };\n}\n\n/**\n * Check whether the per-result confidence feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n */\nexport { isResultConfidenceEnabled } from './search-flags.js';","lineStart":1,"lineEnd":443,"totalLines":443,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","time":{"start":1781757752913,"end":1781757752921}},"metadata":{"openai":{"itemId":"fc_0476bff5faf47e28016a337738d1e88191a56fe312d3b2cf63"}},"id":"prt_ed909b62c001l9RiKftmMQaZio","sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","messageID":"msg_ed909783c001aytDnrba8vGXQc"}}
{"type":"tool_use","timestamp":1781757752929,"sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","part":{"type":"tool","tool":"read","callID":"call_Ly9m39HwvTXmq7l5WfnrL9xl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-calibration.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-calibration.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Confidence Calibration\n3: // ───────────────────────────────────────────────────────────────\n4: // Maps a raw per-result confidence value (0–1) onto an empirical\n5: // P(relevant) using a monotonic calibration model fit from labeled\n6: // query→memory relevance judgements.\n7: //\n8: // STATUS: UNVALIDATED INFRASTRUCTURE. The fitting and apply math here\n9: // is exercised by tests, but no production-grade labeled set has been\n10: // collected yet. The starter labeled set shipped alongside this module\n11: // is a CORPUS-DERIVED PROXY (spec titles/keywords as queries, the spec's\n12: // own memory as the positive), NOT human-judged live `memory_search`\n13: // traffic. The real ~50–100 judged pairs from live traffic are the\n14: // documented follow-up before any model here is trusted in ranking.\n15: //\n16: // Because of that, the wiring in confidence-scoring.ts keeps this OFF by\n17: // default (SPECKIT_CONFIDENCE_CALIBRATION) and only applies a model when\n18: // one is explicitly provided. Default behavior is unchanged.\n19: \n20: import { readFileSync } from 'node:fs';\n21: \n22: // -- Types --\n23: \n24: /**\n25:  * One labeled relevance judgement: did `memoryId` satisfy `query`?\n26:  * `relevant` is the binary ground-truth label (1 = relevant, 0 = not).\n27:  */\n28: export interface LabeledPair {\n29:   query: string;\n30:   memoryId: number | string;\n31:   relevant: 0 | 1;\n32: }\n33: \n34: /**\n35:  * One fitting sample: the model maps a pre-calibration confidence value\n36:  * (`rawValue`, 0–1) onto the observed binary relevance label. Producing\n37:  * these from a LabeledPair[] requires running search to obtain the\n38:  * rawValue each query/memory pair scored — that join is the labeled-traffic\n39:  * follow-up, not something this module can synthesize.\n40:  */\n41: export interface CalibrationSample {\n42:   rawValue: number;\n43:   relevant: 0 | 1;\n44: }\n45: \n46: /**\n47:  * A fitted monotonic calibration curve. `points` are sorted by `x`\n48:  * (rawValue) with non-decreasing `y` (P(relevant)); applyCalibration\n49:  * interpolates between them. Kept as plain data so a model can be\n50:  * serialized to JSON and reloaded without re-fitting.\n51:  */\n52: export interface CalibrationModel {\n53:   method: 'isotonic';\n54:   points: Array<{ x: number; y: number }>;\n55:   /** Number of samples the model was fit from (provenance / sanity check). */\n56:   fittedFrom: number;\n57: }\n58: \n59: // -- Helpers --\n60: \n61: function clamp01(value: number): number {\n62:   if (!Number.isFinite(value)) return 0;\n63:   return Math.max(0, Math.min(1, value));\n64: }\n65: \n66: // -- Labeled-set loading --\n67: \n68: /**\n69:  * Validate and normalize a parsed labeled set into LabeledPair[].\n70:  * Rejects malformed entries rather than silently coercing them, so a\n71:  * bad labeled file fails loudly instead of fitting on garbage.\n72:  */\n73: export function loadLabeledSet(json: unknown): LabeledPair[] {\n74:   if (!Array.isArray(json)) {\n75:     throw new Error('labeled set must be a JSON array of {query, memoryId, relevant}');\n76:   }\n77:   return json.map((entry, i) => {\n78:     if (!entry || typeof entry !== 'object') {\n79:       throw new Error(`labeled set entry ${i} is not an object`);\n80:     }\n81:     const e = entry as Record<string, unknown>;\n82:     const query = e.query;\n83:     const memoryId = e.memoryId;\n84:     const relevant = e.relevant;\n85:     if (typeof query !== 'string' || query.trim().length === 0) {\n86:       throw new Error(`labeled set entry ${i} has an invalid query`);\n87:     }\n88:     if (typeof memoryId !== 'string' && typeof memoryId !== 'number') {\n89:       throw new Error(`labeled set entry ${i} has an invalid memoryId`);\n90:     }\n91:     if (relevant !== 0 && relevant !== 1) {\n92:       throw new Error(`labeled set entry ${i} relevant must be 0 or 1`);\n93:     }\n94:     return { query, memoryId, relevant };\n95:   });\n96: }\n97: \n98: /**\n99:  * Read and parse a CalibrationModel from a JSON file path. Returns null\n100:  * when the path is missing/unreadable or the contents are not a valid\n101:  * model, so a misconfigured path degrades to a no-op rather than throwing\n102:  * in the search hot path.\n103:  */\n104: export function loadCalibrationModel(path: string): CalibrationModel | null {\n105:   let raw: string;\n106:   try {\n107:     raw = readFileSync(path, 'utf8');\n108:   } catch {\n109:     return null;\n110:   }\n111:   let parsed: unknown;\n112:   try {\n113:     parsed = JSON.parse(raw);\n114:   } catch {\n115:     return null;\n116:   }\n117:   if (!parsed || typeof parsed !== 'object') return null;\n118:   const m = parsed as Record<string, unknown>;\n119:   if (m.method !== 'isotonic' || !Array.isArray(m.points)) return null;\n120:   const points: Array<{ x: number; y: number }> = [];\n121:   for (const p of m.points) {\n122:     if (!p || typeof p !== 'object') return null;\n123:     const x = (p as Record<string, unknown>).x;\n124:     const y = (p as Record<string, unknown>).y;\n125:     if (typeof x !== 'number' || typeof y !== 'number') return null;\n126:     points.push({ x, y });\n127:   }\n128:   if (points.length === 0) return null;\n129:   const fittedFrom = typeof m.fittedFrom === 'number' ? m.fittedFrom : points.length;\n130:   return { method: 'isotonic', points, fittedFrom };\n131: }\n132: \n133: // -- Fitting --\n134: \n135: /**\n136:  * Fit an isotonic (monotonic non-decreasing) calibration curve via the\n137:  * Pool Adjacent Violators algorithm (PAV). The result maps rawValue →\n138:  * P(relevant) and is guaranteed non-decreasing, so a higher raw confidence\n139:  * never calibrates to a lower probability.\n140:  *\n141:  * Each output point is a pooled block: x = mean rawValue of the block,\n142:  * y = empirical relevance rate of the block. Ties in rawValue are merged\n143:  * before pooling so the curve is well defined.\n144:  */\n145: export function fitCalibration(samples: CalibrationSample[]): CalibrationModel {\n146:   const clean = samples\n147:     .filter((s) => Number.isFinite(s.rawValue) && (s.relevant === 0 || s.relevant === 1))\n148:     .map((s) => ({ x: clamp01(s.rawValue), y: s.relevant as number }))\n149:     .sort((a, b) => a.x - b.x);\n150: \n151:   if (clean.length === 0) {\n152:     return { method: 'isotonic', points: [], fittedFrom: 0 };\n153:   }\n154: \n155:   // Each block tracks the pooled sum of x and y plus the sample count so a\n156:   // merge is O(1). PAV merges left while the previous block's mean y is greater\n157:   // than OR equal to the current block's mean y. The `>` case repairs a\n158:   // monotonicity violation; the `===` case collapses adjacent equal-mean blocks\n159:   // into one — pooling equal means leaves the mean (and therefore y) unchanged,\n160:   // so it is purely a serialization-size reduction with no effect on the fitted\n161:   // curve or its interpolation.\n162:   interface Block {\n163:     sumX: number;\n164:     sumY: number;\n165:     count: number;\n166:   }\n167:   const blocks: Block[] = [];\n168:   for (const { x, y } of clean) {\n169:     blocks.push({ sumX: x, sumY: y, count: 1 });\n170:     while (blocks.length >= 2) {\n171:       const curr = blocks[blocks.length - 1]!;\n172:       const prev = blocks[blocks.length - 2]!;\n173:       if (prev.sumY / prev.count < curr.sumY / curr.count) break;\n174:       prev.sumX += curr.sumX;\n175:       prev.sumY += curr.sumY;\n176:       prev.count += curr.count;\n177:       blocks.pop();\n178:     }\n179:   }\n180: \n181:   const points = blocks.map((b) => ({\n182:     x: b.sumX / b.count,\n183:     y: clamp01(b.sumY / b.count),\n184:   }));\n185: \n186:   return { method: 'isotonic', points, fittedFrom: clean.length };\n187: }\n188: \n189: // -- Apply --\n190: \n191: /**\n192:  * Map a raw confidence value through the fitted curve via piecewise-linear\n193:  * interpolation between pooled blocks. Values below the first / above the\n194:  * last block clamp to that block's probability. Output is bounded to 0–1\n195:  * and monotonic in `rawValue` (the points are non-decreasing in y).\n196:  *\n197:  * An empty model is the identity (returns the clamped rawValue), so an\n198:  * unfit or degenerate model never distorts confidence.\n199:  */\n200: export function applyCalibration(model: CalibrationModel, rawValue: number): number {\n201:   const x = clamp01(rawValue);\n202:   const pts = model.points;\n203:   if (pts.length === 0) return x;\n204:   if (x <= pts[0]!.x) return clamp01(pts[0]!.y);\n205:   const last = pts[pts.length - 1]!;\n206:   if (x >= last.x) return clamp01(last.y);\n207: \n208:   for (let i = 0; i < pts.length - 1; i++) {\n209:     const a = pts[i]!;\n210:     const b = pts[i + 1]!;\n211:     if (x >= a.x && x <= b.x) {\n212:       const span = b.x - a.x;\n213:       if (span <= 0) return clamp01(b.y);\n214:       const t = (x - a.x) / span;\n215:       return clamp01(a.y + t * (b.y - a.y));\n216:     }\n217:   }\n218:   return clamp01(last.y);\n219: }\n\n(End of file - total 219 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Calibration\n// ───────────────────────────────────────────────────────────────\n// Maps a raw per-result confidence value (0–1) onto an empirical\n// P(relevant) using a monotonic calibration model fit from labeled\n// query→memory relevance judgements.\n//\n// STATUS: UNVALIDATED INFRASTRUCTURE. The fitting and apply math here\n// is exercised by tests, but no production-grade labeled set has been\n// collected yet. The starter labeled set shipped alongside this module\n// is a CORPUS-DERIVED PROXY (spec titles/keywords as queries, the spec's\n// own memory as the positive), NOT human-judged live `memory_search`\n// traffic. The real ~50–100 judged pairs from live traffic are the\n// documented follow-up before any model here is trusted in ranking.\n//\n// Because of that, the wiring in confidence-scoring.ts keeps this OFF by\n// default (SPECKIT_CONFIDENCE_CALIBRATION) and only applies a model when\n// one is explicitly provided. Default behavior is unchanged.\n\nimport { readFileSync } from 'node:fs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-calibration.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Calibration\n// ───────────────────────────────────────────────────────────────\n// Maps a raw per-result confidence value (0–1) onto an empirical\n// P(relevant) using a monotonic calibration model fit from labeled\n// query→memory relevance judgements.\n//\n// STATUS: UNVALIDATED INFRASTRUCTURE. The fitting and apply math here\n// is exercised by tests, but no production-grade labeled set has been\n// collected yet. The starter labeled set shipped alongside this module\n// is a CORPUS-DERIVED PROXY (spec titles/keywords as queries, the spec's\n// own memory as the positive), NOT human-judged live `memory_search`\n// traffic. The real ~50–100 judged pairs from live traffic are the\n// documented follow-up before any model here is trusted in ranking.\n//\n// Because of that, the wiring in confidence-scoring.ts keeps this OFF by\n// default (SPECKIT_CONFIDENCE_CALIBRATION) and only applies a model when\n// one is explicitly provided. Default behavior is unchanged.\n\nimport { readFileSync } from 'node:fs';\n\n// -- Types --\n\n/**\n * One labeled relevance judgement: did `memoryId` satisfy `query`?\n * `relevant` is the binary ground-truth label (1 = relevant, 0 = not).\n */\nexport interface LabeledPair {\n  query: string;\n  memoryId: number | string;\n  relevant: 0 | 1;\n}\n\n/**\n * One fitting sample: the model maps a pre-calibration confidence value\n * (`rawValue`, 0–1) onto the observed binary relevance label. Producing\n * these from a LabeledPair[] requires running search to obtain the\n * rawValue each query/memory pair scored — that join is the labeled-traffic\n * follow-up, not something this module can synthesize.\n */\nexport interface CalibrationSample {\n  rawValue: number;\n  relevant: 0 | 1;\n}\n\n/**\n * A fitted monotonic calibration curve. `points` are sorted by `x`\n * (rawValue) with non-decreasing `y` (P(relevant)); applyCalibration\n * interpolates between them. Kept as plain data so a model can be\n * serialized to JSON and reloaded without re-fitting.\n */\nexport interface CalibrationModel {\n  method: 'isotonic';\n  points: Array<{ x: number; y: number }>;\n  /** Number of samples the model was fit from (provenance / sanity check). */\n  fittedFrom: number;\n}\n\n// -- Helpers --\n\nfunction clamp01(value: number): number {\n  if (!Number.isFinite(value)) return 0;\n  return Math.max(0, Math.min(1, value));\n}\n\n// -- Labeled-set loading --\n\n/**\n * Validate and normalize a parsed labeled set into LabeledPair[].\n * Rejects malformed entries rather than silently coercing them, so a\n * bad labeled file fails loudly instead of fitting on garbage.\n */\nexport function loadLabeledSet(json: unknown): LabeledPair[] {\n  if (!Array.isArray(json)) {\n    throw new Error('labeled set must be a JSON array of {query, memoryId, relevant}');\n  }\n  return json.map((entry, i) => {\n    if (!entry || typeof entry !== 'object') {\n      throw new Error(`labeled set entry ${i} is not an object`);\n    }\n    const e = entry as Record<string, unknown>;\n    const query = e.query;\n    const memoryId = e.memoryId;\n    const relevant = e.relevant;\n    if (typeof query !== 'string' || query.trim().length === 0) {\n      throw new Error(`labeled set entry ${i} has an invalid query`);\n    }\n    if (typeof memoryId !== 'string' && typeof memoryId !== 'number') {\n      throw new Error(`labeled set entry ${i} has an invalid memoryId`);\n    }\n    if (relevant !== 0 && relevant !== 1) {\n      throw new Error(`labeled set entry ${i} relevant must be 0 or 1`);\n    }\n    return { query, memoryId, relevant };\n  });\n}\n\n/**\n * Read and parse a CalibrationModel from a JSON file path. Returns null\n * when the path is missing/unreadable or the contents are not a valid\n * model, so a misconfigured path degrades to a no-op rather than throwing\n * in the search hot path.\n */\nexport function loadCalibrationModel(path: string): CalibrationModel | null {\n  let raw: string;\n  try {\n    raw = readFileSync(path, 'utf8');\n  } catch {\n    return null;\n  }\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw);\n  } catch {\n    return null;\n  }\n  if (!parsed || typeof parsed !== 'object') return null;\n  const m = parsed as Record<string, unknown>;\n  if (m.method !== 'isotonic' || !Array.isArray(m.points)) return null;\n  const points: Array<{ x: number; y: number }> = [];\n  for (const p of m.points) {\n    if (!p || typeof p !== 'object') return null;\n    const x = (p as Record<string, unknown>).x;\n    const y = (p as Record<string, unknown>).y;\n    if (typeof x !== 'number' || typeof y !== 'number') return null;\n    points.push({ x, y });\n  }\n  if (points.length === 0) return null;\n  const fittedFrom = typeof m.fittedFrom === 'number' ? m.fittedFrom : points.length;\n  return { method: 'isotonic', points, fittedFrom };\n}\n\n// -- Fitting --\n\n/**\n * Fit an isotonic (monotonic non-decreasing) calibration curve via the\n * Pool Adjacent Violators algorithm (PAV). The result maps rawValue →\n * P(relevant) and is guaranteed non-decreasing, so a higher raw confidence\n * never calibrates to a lower probability.\n *\n * Each output point is a pooled block: x = mean rawValue of the block,\n * y = empirical relevance rate of the block. Ties in rawValue are merged\n * before pooling so the curve is well defined.\n */\nexport function fitCalibration(samples: CalibrationSample[]): CalibrationModel {\n  const clean = samples\n    .filter((s) => Number.isFinite(s.rawValue) && (s.relevant === 0 || s.relevant === 1))\n    .map((s) => ({ x: clamp01(s.rawValue), y: s.relevant as number }))\n    .sort((a, b) => a.x - b.x);\n\n  if (clean.length === 0) {\n    return { method: 'isotonic', points: [], fittedFrom: 0 };\n  }\n\n  // Each block tracks the pooled sum of x and y plus the sample count so a\n  // merge is O(1). PAV merges left while the previous block's mean y is greater\n  // than OR equal to the current block's mean y. The `>` case repairs a\n  // monotonicity violation; the `===` case collapses adjacent equal-mean blocks\n  // into one — pooling equal means leaves the mean (and therefore y) unchanged,\n  // so it is purely a serialization-size reduction with no effect on the fitted\n  // curve or its interpolation.\n  interface Block {\n    sumX: number;\n    sumY: number;\n    count: number;\n  }\n  const blocks: Block[] = [];\n  for (const { x, y } of clean) {\n    blocks.push({ sumX: x, sumY: y, count: 1 });\n    while (blocks.length >= 2) {\n      const curr = blocks[blocks.length - 1]!;\n      const prev = blocks[blocks.length - 2]!;\n      if (prev.sumY / prev.count < curr.sumY / curr.count) break;\n      prev.sumX += curr.sumX;\n      prev.sumY += curr.sumY;\n      prev.count += curr.count;\n      blocks.pop();\n    }\n  }\n\n  const points = blocks.map((b) => ({\n    x: b.sumX / b.count,\n    y: clamp01(b.sumY / b.count),\n  }));\n\n  return { method: 'isotonic', points, fittedFrom: clean.length };\n}\n\n// -- Apply --\n\n/**\n * Map a raw confidence value through the fitted curve via piecewise-linear\n * interpolation between pooled blocks. Values below the first / above the\n * last block clamp to that block's probability. Output is bounded to 0–1\n * and monotonic in `rawValue` (the points are non-decreasing in y).\n *\n * An empty model is the identity (returns the clamped rawValue), so an\n * unfit or degenerate model never distorts confidence.\n */\nexport function applyCalibration(model: CalibrationModel, rawValue: number): number {\n  const x = clamp01(rawValue);\n  const pts = model.points;\n  if (pts.length === 0) return x;\n  if (x <= pts[0]!.x) return clamp01(pts[0]!.y);\n  const last = pts[pts.length - 1]!;\n  if (x >= last.x) return clamp01(last.y);\n\n  for (let i = 0; i < pts.length - 1; i++) {\n    const a = pts[i]!;\n    const b = pts[i + 1]!;\n    if (x >= a.x && x <= b.x) {\n      const span = b.x - a.x;\n      if (span <= 0) return clamp01(b.y);\n      const t = (x - a.x) / span;\n      return clamp01(a.y + t * (b.y - a.y));\n    }\n  }\n  return clamp01(last.y);\n}","lineStart":1,"lineEnd":219,"totalLines":219,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-calibration.ts","time":{"start":1781757752918,"end":1781757752928}},"metadata":{"openai":{"itemId":"fc_0476bff5faf47e28016a337738d1fc8191ab13d35057f3cf17"}},"id":"prt_ed909b653001XjR1TOdo6GpVNL","sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","messageID":"msg_ed909783c001aytDnrba8vGXQc"}}
{"type":"tool_use","timestamp":1781757752931,"sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","part":{"type":"tool","tool":"read","callID":"call_P9gXz21Mt5yIFpvaVXPVRvuJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Search Flags\n3: // ───────────────────────────────────────────────────────────────\n4: // Default-on runtime gates for search pipeline controls\n5: //\n6: // Production-ready flags graduated to default-ON.\n7: // Set SPECKIT_<FLAG>=false to disable any graduated feature.\n8: \n9: /* ───────────────────────────────────────────────────────────────\n10:    1. IMPORTS\n11: ──────────────────────────────────────────────────────────────── */\n12: \n13: import { isFeatureEnabled } from '../cognitive/rollout-policy.js';\n14: \n15: // Feature catalog: Quality-aware 3-tier search fallback\n16: // Feature catalog: Verify-fix-verify memory quality loop\n17: // Feature catalog: Negative feedback confidence signal\n18: \n19: export type SavePlannerMode = 'plan-only' | 'full-auto' | 'hybrid';\n20: \n21: const TRUTHY_OPT_IN = new Set(['true', '1', 'yes', 'on', 'enabled']);\n22: \n23: /**\n24:  * Returns true for explicit opt-in values: true, 1, yes, on, enabled.\n25:  * Undefined, empty, unrecognized, and explicit false-like values are treated as false.\n26:  */\n27: function isOptInEnabled(variableName: string): boolean {\n28:   const value = process.env[variableName]?.toLowerCase().trim();\n29:   return value !== undefined && TRUTHY_OPT_IN.has(value);\n30: }\n31: \n32: /* ───────────────────────────────────────────────────────────────\n33:    2. BOOST FLAGS (Graduated default-ON)\n34: ──────────────────────────────────────────────────────────────── */\n35: \n36: /**\n37:  * Session attention boost for search result re-ranking.\n38:  * Default: TRUE (graduated). Set SPECKIT_SESSION_BOOST=false to disable.\n39:  */\n40: export function isSessionBoostEnabled(): boolean {\n41:   return isFeatureEnabled('SPECKIT_SESSION_BOOST');\n42: }\n43: \n44: /**\n45:  * Causal graph traversal boost for search result amplification.\n46:  * Default: TRUE (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n47:  */\n48: export function isCausalBoostEnabled(): boolean {\n49:   return isFeatureEnabled('SPECKIT_CAUSAL_BOOST');\n50: }\n51: \n52: /* ───────────────────────────────────────────────────────────────\n53:    3. CORE FLAGS\n54: ──────────────────────────────────────────────────────────────── */\n55: \n56: /**\n57:  * Dynamic startup instruction injection for the MCP server.\n58:  * Default: TRUE (graduated). Set SPECKIT_DYNAMIC_INIT=false to disable.\n59:  */\n60: export function isDynamicInitEnabled(): boolean {\n61:   return isFeatureEnabled('SPECKIT_DYNAMIC_INIT');\n62: }\n63: \n64: /**\n65:  * Token-pressure policy for memory_context.\n66:  * Default: TRUE (graduated). Set SPECKIT_PRESSURE_POLICY=false to disable.\n67:  */\n68: export function isPressurePolicyEnabled(identity?: string): boolean {\n69:   return isFeatureEnabled('SPECKIT_PRESSURE_POLICY', identity);\n70: }\n71: \n72: /**\n73:  * Automatic session resume context injection for memory_context.\n74:  * Default: TRUE (graduated). Set SPECKIT_AUTO_RESUME=false to disable.\n75:  */\n76: export function isAutoResumeEnabled(identity?: string): boolean {\n77:   return isFeatureEnabled('SPECKIT_AUTO_RESUME', identity);\n78: }\n79: \n80: /**\n81:  * Graph-guided MMR diversity reranking.\n82:  * Default: TRUE (enabled). Set SPECKIT_MMR=false to disable.\n83:  */\n84: export function isMMREnabled(): boolean {\n85:   return isFeatureEnabled('SPECKIT_MMR');\n86: }\n87: \n88: /**\n89:  * Transparent Reasoning Module (evidence-gap detection).\n90:  * Default: TRUE (enabled). Set SPECKIT_TRM=false to disable.\n91:  */\n92: export function isTRMEnabled(): boolean {\n93:   return isFeatureEnabled('SPECKIT_TRM');\n94: }\n95: \n96: /**\n97:  * Multi-query expansion for deep-mode retrieval.\n98:  * Default: TRUE (enabled). Set SPECKIT_MULTI_QUERY=false to disable.\n99:  */\n100: export function isMultiQueryEnabled(): boolean {\n101:   return isFeatureEnabled('SPECKIT_MULTI_QUERY');\n102: }\n103: \n104: /**\n105:  * PI-A2: Quality-aware 3-tier search fallback chain.\n106:  * Default: TRUE (graduated). Set SPECKIT_SEARCH_FALLBACK=false to disable.\n107:  */\n108: export function isSearchFallbackEnabled(): boolean {\n109:   return isFeatureEnabled('SPECKIT_SEARCH_FALLBACK');\n110: }\n111: \n112: /**\n113:  * Automatic spec folder discovery via description cache.\n114:  * Default: TRUE (graduated). Set SPECKIT_FOLDER_DISCOVERY=false to disable.\n115:  */\n116: export function isFolderDiscoveryEnabled(): boolean {\n117:   return isFeatureEnabled('SPECKIT_FOLDER_DISCOVERY');\n118: }\n119: \n120: /**\n121:  * Planner-first save mode selection for canonical save flows.\n122:  * Default: 'plan-only'. Set SPECKIT_SAVE_PLANNER_MODE=full-auto to restore\n123:  * the legacy mutation-first behavior. `hybrid` is reserved for future mixed\n124:  * flows and currently behaves the same as `plan-only`.\n125:  */\n126: export function resolveSavePlannerMode(): SavePlannerMode {\n127:   const raw = process.env.SPECKIT_SAVE_PLANNER_MODE?.trim().toLowerCase();\n128:   if (raw === 'full-auto' || raw === 'full_auto') {\n129:     return 'full-auto';\n130:   }\n131:   if (raw === 'hybrid') {\n132:     return 'hybrid';\n133:   }\n134:   return 'plan-only';\n135: }\n136: \n137: /**\n138:  * Save-time reconsolidation gate. Opt-in (default OFF): it enables the destructive\n139:  * reconsolidate() path that can merge near-duplicate rows and deprecate older ones — itself\n140:  * further gated on a per-spec-folder \"pre-reconsolidation\" checkpoint. Kept opt-in so a\n141:  * destructive merge never happens without explicit intent. Set SPECKIT_RECONSOLIDATION_ENABLED=true to enable.\n142:  */\n143: export function isSaveReconsolidationEnabled(): boolean {\n144:   return isOptInEnabled('SPECKIT_RECONSOLIDATION_ENABLED');\n145: }\n146: \n147: /**\n148:  * Save-time post-insert enrichment bundle gate (causal links, entity extraction,\n149:  * summaries, entity linking, graph lifecycle — populates the causal/entity graph).\n150:  * Default: TRUE (graduated). Set SPECKIT_POST_INSERT_ENRICHMENT_ENABLED=false to disable.\n151:  */\n152: export function isPostInsertEnrichmentEnabled(): boolean {\n153:   return isFeatureEnabled('SPECKIT_POST_INSERT_ENRICHMENT_ENABLED');\n154: }\n155: \n156: /**\n157:  * Whether the post-insert enrichment bundle runs in the background (non-blocking save).\n158:  * Default: TRUE (async). Set SPECKIT_POST_INSERT_ENRICHMENT_SYNC=true to run it synchronously\n159:  * when a caller needs the causal/entity graph fresh within the same save response.\n160:  */\n161: export function isPostInsertEnrichmentAsync(): boolean {\n162:   return !isOptInEnabled('SPECKIT_POST_INSERT_ENRICHMENT_SYNC');\n163: }\n164: \n165: /**\n166:  * Save-time quality auto-fix retries gate (regenerates trigger phrases, trims oversized\n167:  * content to the char budget, normalizes anchors on save).\n168:  * Default: TRUE (graduated). Set SPECKIT_QUALITY_AUTO_FIX=false to disable.\n169:  */\n170: export function isQualityAutoFixEnabled(): boolean {\n171:   return isFeatureEnabled('SPECKIT_QUALITY_AUTO_FIX');\n172: }\n173: \n174: // -- Hybrid RAG Fusion Refinement flags --\n175: \n176: /**\n177:  * MPAB: Document-level chunk-to-memory score aggregation.\n178:  * Default: TRUE (graduated). Set SPECKIT_DOCSCORE_AGGREGATION=false to disable.\n179:  */\n180: export function isDocscoreAggregationEnabled(): boolean {\n181:   return isFeatureEnabled('SPECKIT_DOCSCORE_AGGREGATION');\n182: }\n183: \n184: /**\n185:  * Pre-storage quality gate for memory saves.\n186:  * Default: TRUE (graduated). Set SPECKIT_SAVE_QUALITY_GATE=false to disable.\n187:  */\n188: export function isSaveQualityGateEnabled(): boolean {\n189:   return isFeatureEnabled('SPECKIT_SAVE_QUALITY_GATE');\n190: }\n191: \n192: /**\n193:  * Dynamic token budget allocation by query complexity.\n194:  * Default: TRUE (graduated). Set SPECKIT_DYNAMIC_TOKEN_BUDGET=false to disable.\n195:  */\n196: export function isDynamicTokenBudgetEnabled(): boolean {\n197:   return isFeatureEnabled('SPECKIT_DYNAMIC_TOKEN_BUDGET');\n198: }\n199: \n200: /**\n201:  * Confidence-gap truncation for low-confidence tails.\n202:  * Default: TRUE (graduated). Set SPECKIT_CONFIDENCE_TRUNCATION=false to disable.\n203:  */\n204: export function isConfidenceTruncationEnabled(): boolean {\n205:   return isFeatureEnabled('SPECKIT_CONFIDENCE_TRUNCATION');\n206: }\n207: \n208: /**\n209:  * Channel minimum-representation promotion after fusion.\n210:  * Default: TRUE (graduated). Set SPECKIT_CHANNEL_MIN_REP=false to disable.\n211:  */\n212: export function isChannelMinRepEnabled(): boolean {\n213:   return isFeatureEnabled('SPECKIT_CHANNEL_MIN_REP');\n214: }\n215: \n216: /**\n217:  * Reconsolidation-on-save for memory deduplication.\n218:  * Default: TRUE (graduated). Set SPECKIT_RECONSOLIDATION=false to disable.\n219:  */\n220: export function isReconsolidationEnabled(): boolean {\n221:   return isFeatureEnabled('SPECKIT_RECONSOLIDATION');\n222: }\n223: \n224: /**\n225:  * Negative-feedback confidence demotion in ranking.\n226:  * Default: TRUE (graduated). Set SPECKIT_NEGATIVE_FEEDBACK=false to disable.\n227:  */\n228: export function isNegativeFeedbackEnabled(): boolean {\n229:   return isFeatureEnabled('SPECKIT_NEGATIVE_FEEDBACK');\n230: }\n231: \n232: // -- Pipeline Refactor flags --\n233: \n234: /**\n235:  * Query expansion for embedding-based retrieval.\n236:  * Suppressed when classification = \"simple\" (mutual exclusion).\n237:  * Default: TRUE (graduated). Set SPECKIT_EMBEDDING_EXPANSION=false to disable.\n238:  */\n239: export function isEmbeddingExpansionEnabled(): boolean {\n240:   return isFeatureEnabled('SPECKIT_EMBEDDING_EXPANSION');\n241: }\n242: \n243: // -- Indexing and Graph flags --\n244: \n245: /**\n246:  * N3-lite: Consolidation engine — contradiction scan, Hebbian strengthening,\n247:  * staleness detection, edge bounds enforcement.\n248:  * Default: TRUE (graduated). Set SPECKIT_CONSOLIDATION=false to disable.\n249:  */\n250: export function isConsolidationEnabled(): boolean {\n251:   return isFeatureEnabled('SPECKIT_CONSOLIDATION');\n252: }\n253: \n254: /**\n255:  * Encoding-intent capture at index time.\n256:  * Records intent metadata (document, code, structured_data) alongside embeddings.\n257:  * Default: TRUE (graduated). Set SPECKIT_ENCODING_INTENT=false to disable.\n258:  */\n259: export function isEncodingIntentEnabled(): boolean {\n260:   return isFeatureEnabled('SPECKIT_ENCODING_INTENT');\n261: }\n262: \n263: /* ───────────────────────────────────────────────────────────────\n264:    3. GRAPH FLAGS\n265: ──────────────────────────────────────────────────────────────── */\n266: \n267: /**\n268:  * N2a+N2b: Graph momentum scoring and causal depth signals.\n269:  * Default: TRUE (enabled). Set SPECKIT_GRAPH_SIGNALS=false to disable.\n270:  */\n271: // Supported SPECKIT_GRAPH_WALK_ROLLOUT states: off, trace_only, bounded_runtime.\n272: export type GraphWalkRolloutState = 'off' | 'trace_only' | 'bounded_runtime';\n273: \n274: export function resolveGraphWalkRolloutState(): GraphWalkRolloutState {\n275:   const rollout = process.env.SPECKIT_GRAPH_WALK_ROLLOUT?.trim().toLowerCase();\n276:   if (rollout === 'off' || rollout === 'false' || rollout === '0') {\n277:     return 'off';\n278:   }\n279:   if (rollout === 'trace_only' || rollout === 'trace-only') {\n280:     return 'trace_only';\n281:   }\n282:   if (rollout === 'bounded_runtime' || rollout === 'bounded-runtime' || rollout === 'true' || rollout === '1') {\n283:     return 'bounded_runtime';\n284:   }\n285: \n286:   return isFeatureEnabled('SPECKIT_GRAPH_SIGNALS') ? 'bounded_runtime' : 'off';\n287: }\n288: \n289: export function isGraphSignalsEnabled(): boolean {\n290:   return isFeatureEnabled('SPECKIT_GRAPH_SIGNALS');\n291: }\n292: \n293: /**\n294:  * N2c: Community detection (BFS connected components + Louvain escalation).\n295:  * Default: TRUE (enabled). Set SPECKIT_COMMUNITY_DETECTION=false to disable.\n296:  */\n297: export function isCommunityDetectionEnabled(): boolean {\n298:   return isFeatureEnabled('SPECKIT_COMMUNITY_DETECTION');\n299: }\n300: \n301: /**\n302:  * Community summary generation and search channel.\n303:  * Default: TRUE (enabled). Set SPECKIT_COMMUNITY_SUMMARIES=false to disable.\n304:  */\n305: export function isCommunitySummariesEnabled(): boolean {\n306:   return isFeatureEnabled('SPECKIT_COMMUNITY_SUMMARIES');\n307: }\n308: \n309: /**\n310:  * Memory summary generation (TF-IDF extractive summaries as search channel).\n311:  * Default: TRUE (enabled). Set SPECKIT_MEMORY_SUMMARIES=false to disable.\n312:  */\n313: export function isMemorySummariesEnabled(): boolean {\n314:   return isFeatureEnabled('SPECKIT_MEMORY_SUMMARIES');\n315: }\n316: \n317: /**\n318:  * Temporal contiguity boost on raw Stage 1 vector results.\n319:  * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_CONTIGUITY=false to disable.\n320:  */\n321: export function isTemporalContiguityEnabled(): boolean {\n322:   return isFeatureEnabled('SPECKIT_TEMPORAL_CONTIGUITY');\n323: }\n324: \n325: /**\n326:  * Auto entity extraction (rule-based noun-phrase extraction at save time).\n327:  * Default: TRUE (enabled). Set SPECKIT_AUTO_ENTITIES=false to disable.\n328:  */\n329: export function isAutoEntitiesEnabled(): boolean {\n330:   return isFeatureEnabled('SPECKIT_AUTO_ENTITIES');\n331: }\n332: \n333: /**\n334:  * Cross-document entity linking (entity-based cross-doc edges).\n335:  * Requires auto entities to also be enabled.\n336:  * Default: TRUE (enabled). Set SPECKIT_ENTITY_LINKING=false to disable.\n337:  */\n338: export function isEntityLinkingEnabled(): boolean {\n339:   return isFeatureEnabled('SPECKIT_ENTITY_LINKING');\n340: }\n341: \n342: /** Whether causal-edge degree-based re-ranking is enabled (SPECKIT_DEGREE_BOOST). */\n343: export function isDegreeBoostEnabled(): boolean {\n344:   return isFeatureEnabled('SPECKIT_DEGREE_BOOST');\n345: }\n346: \n347: /* ───────────────────────────────────────────────────────────────\n348:    FLAGS\n349: ──────────────────────────────────────────────────────────────── */\n350: \n351: /**\n352:  * Contextual tree headers for Stage 4 result enrichment.\n353:  * Default: TRUE. Set SPECKIT_CONTEXT_HEADERS=false to disable.\n354:  */\n355: export function isContextHeadersEnabled(): boolean {\n356:   return isFeatureEnabled('SPECKIT_CONTEXT_HEADERS');\n357: }\n358: \n359: /**\n360:  * Real-time file watcher for markdown reindexing.\n361:  * Default: FALSE. Set SPECKIT_FILE_WATCHER=true to enable.\n362:  * Honors SPECKIT_ROLLOUT_PERCENT global rollout policy.\n363:  */\n364: export function isFileWatcherEnabled(): boolean {\n365:   if (process.env.SPECKIT_FILE_WATCHER?.toLowerCase().trim() !== 'true') return false;\n366:   return isFeatureEnabled('SPECKIT_FILE_WATCHER');\n367: }\n368: \n369: /**\n370:  * Verify-fix-verify memory quality loop.\n371:  * Default: TRUE (graduated). Set SPECKIT_QUALITY_LOOP=false to disable.\n372:  */\n373: export function isQualityLoopEnabled(): boolean {\n374:   return isFeatureEnabled('SPECKIT_QUALITY_LOOP');\n375: }\n376: \n377: /* ───────────────────────────────────────────────────────────────\n378:    5. QUERY INTELLIGENCE FLAGS\n379: ──────────────────────────────────────────────────────────────── */\n380: \n381: /**\n382:  * Query decomposition — bounded facet detection.\n383:  * Deep-mode only: multi-faceted queries split into up to 3 sub-queries.\n384:  * Default: TRUE (graduated). Set SPECKIT_QUERY_DECOMPOSITION=false to disable.\n385:  */\n386: export function isQueryDecompositionEnabled(): boolean {\n387:   return isFeatureEnabled('SPECKIT_QUERY_DECOMPOSITION');\n388: }\n389: \n390: /**\n391:  * Graph concept routing — query-time alias matching.\n392:  * Extracts noun phrases from the query and matches against concept alias table,\n393:  * activating the graph channel for matched concepts.\n394:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONCEPT_ROUTING=false to disable.\n395:  */\n396: export function isGraphConceptRoutingEnabled(): boolean {\n397:   return isFeatureEnabled('SPECKIT_GRAPH_CONCEPT_ROUTING');\n398: }\n399: \n400: /**\n401:  * Index-time surrogates for recall improvement.\n402:  * Generates surrogate metadata (aliases, headings, summary, questions)\n403:  * at index time; matched at query time with no LLM calls.\n404:  * Default: TRUE (graduated). Set SPECKIT_QUERY_SURROGATES=false to disable.\n405:  */\n406: export function isQuerySurrogatesEnabled(): boolean {\n407:   return isFeatureEnabled('SPECKIT_QUERY_SURROGATES');\n408: }\n409: \n410: /* ───────────────────────────────────────────────────────────────\n411:    6. FEEDBACK & QUALITY LEARNING FLAGS\n412: ──────────────────────────────────────────────────────────────── */\n413: \n414: /**\n415:  * Implicit feedback event ledger.\n416:  * Shadow-only — no ranking side effects.\n417:  * Default: TRUE (graduated). Set SPECKIT_IMPLICIT_FEEDBACK_LOG=false to disable.\n418:  */\n419: export function isImplicitFeedbackLogEnabled(): boolean {\n420:   return isFeatureEnabled('SPECKIT_IMPLICIT_FEEDBACK_LOG');\n421: }\n422: \n423: /**\n424:  * Hybrid decay policy — type-aware no-decay for permanent artifacts.\n425:  * Default: TRUE (graduated). Set SPECKIT_HYBRID_DECAY_POLICY=false to disable.\n426:  * When enabled: decision/constitutional/critical context types receive Infinity\n427:  * stability (no decay). All other types follow the standard FSRS schedule.\n428:  */\n429: export function isHybridDecayPolicyEnabled(): boolean {\n430:   return isFeatureEnabled('SPECKIT_HYBRID_DECAY_POLICY');\n431: }\n432: \n433: /**\n434:  * Short-critical quality gate exception.\n435:  * Default: TRUE (graduated). Set SPECKIT_SAVE_QUALITY_GATE_EXCEPTIONS=false to disable.\n436:  * When enabled: decision context_type documents with >= 2 structural signals\n437:  * bypass the 50-character minimum content length check.\n438:  */\n439: export function isSaveQualityGateExceptionsEnabled(): boolean {\n440:   return isFeatureEnabled('SPECKIT_SAVE_QUALITY_GATE_EXCEPTIONS');\n441: }\n442: \n443: /* ───────────────────────────────────────────────────────────────\n444:    7. LLM QUERY INTELLIGENCE FLAGS\n445: ──────────────────────────────────────────────────────────────── */\n446: \n447: /**\n448:  * Corpus-grounded LLM query reformulation.\n449:  * Step-back abstraction + corpus seed grounding. Deep-mode only.\n450:  * Default: TRUE (graduated). Set SPECKIT_LLM_REFORMULATION=false to disable.\n451:  * Requires an OpenAI-compatible LLM endpoint (LLM_REFORMULATION_ENDPOINT).\n452:  */\n453: export function isLlmReformulationEnabled(): boolean {\n454:   return isFeatureEnabled('SPECKIT_LLM_REFORMULATION');\n455: }\n456: \n457: /**\n458:  * HyDE (Hypothetical Document Embeddings).\n459:  * Generates a pseudo-document for low-confidence deep queries.\n460:  * Default: TRUE (graduated). Set SPECKIT_HYDE=false to disable.\n461:  */\n462: export function isHyDEEnabled(): boolean {\n463:   return isFeatureEnabled('SPECKIT_HYDE');\n464: }\n465: \n466: /* ───────────────────────────────────────────────────────────────\n467:    8. GRAPH LIFECYCLE FLAGS\n468: ──────────────────────────────────────────────────────────────── */\n469: \n470: /**\n471:  * Graph refresh mode.\n472:  * Controls when dirty-node recomputation runs after write operations.\n473:  * Default: 'write_local' (graduated). Set SPECKIT_GRAPH_REFRESH_MODE=off to disable.\n474:  * Values: off | write_local | scheduled.\n475:  */\n476: export function getGraphRefreshMode(): string {\n477:   return process.env.SPECKIT_GRAPH_REFRESH_MODE?.trim().toLowerCase() ?? 'write_local';\n478: }\n479: \n480: export function isGraphRefreshDisabled(): boolean {\n481:   return getGraphRefreshMode() === 'off';\n482: }\n483: \n484: /**\n485:  * Async LLM graph backfill for high-value documents.\n486:  * Runs after deterministic extraction; adds probabilistic edges via LLM.\n487:  * Default: TRUE (graduated). Set SPECKIT_LLM_GRAPH_BACKFILL=false to disable.\n488:  */\n489: export function isLlmGraphBackfillEnabled(): boolean {\n490:   return isFeatureEnabled('SPECKIT_LLM_GRAPH_BACKFILL');\n491: }\n492: \n493: /* ───────────────────────────────────────────────────────────────\n494:    9. GRAPH CALIBRATION & COMMUNITIES FLAGS\n495: ──────────────────────────────────────────────────────────────── */\n496: \n497: /**\n498:  * Graph calibration profiles and community thresholds.\n499:  * Enables calibration profile enforcement, Louvain activation gates, and\n500:  * community score capping (secondary-only).\n501:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_CALIBRATION_PROFILE=false to disable.\n502:  */\n503: export function isGraphCalibrationProfileEnabled(): boolean {\n504:   return isFeatureEnabled('SPECKIT_GRAPH_CALIBRATION_PROFILE');\n505: }\n506: \n507: /* ───────────────────────────────────────────────────────────────\n508:    10. LEARNED RANKING FLAGS\n509: ──────────────────────────────────────────────────────────────── */\n510: \n511: /**\n512:  * Learned Stage 2 weight combiner (shadow mode).\n513:  * Runs the learned linear ranker in parallel with manual weights.\n514:  * Scores are computed but NOT used for ranking (shadow-only).\n515:  * Default: TRUE (graduated). Set SPECKIT_LEARNED_STAGE2_COMBINER=false to disable.\n516:  */\n517: export function isLearnedStage2CombinerEnabled(): boolean {\n518:   return isFeatureEnabled('SPECKIT_LEARNED_STAGE2_COMBINER');\n519: }\n520: \n521: /* ───────────────────────────────────────────────────────────────\n522:    11. SHADOW EVALUATION FLAGS\n523: ──────────────────────────────────────────────────────────────── */\n524: \n525: /**\n526:  * Shadow scoring with holdout evaluation.\n527:  * Compares would-have-changed rankings vs live rankings on a holdout\n528:  * slice of queries. Shadow-only — no ranking side effects.\n529:  * Default: TRUE (graduated). Set SPECKIT_SHADOW_FEEDBACK=false to disable.\n530:  */\n531: export function isShadowFeedbackEnabled(): boolean {\n532:   return isFeatureEnabled('SPECKIT_SHADOW_FEEDBACK');\n533: }\n534: \n535: /* ───────────────────────────────────────────────────────────────\n536:    12. PROGRESSIVE DISCLOSURE & SESSION STATE FLAGS\n537: ──────────────────────────────────────────────────────────────── */\n538: \n539: /**\n540:  * Progressive disclosure for search results.\n541:  * Replaces hard tail-truncation with summary layer + snippet + cursor pagination.\n542:  * Default: TRUE (graduated). Set SPECKIT_PROGRESSIVE_DISCLOSURE_V1=false to disable.\n543:  */\n544: export function isProgressiveDisclosureEnabled(): boolean {\n545:   return isFeatureEnabled('SPECKIT_PROGRESSIVE_DISCLOSURE_V1');\n546: }\n547: \n548: /**\n549:  * Retrieval session state for cross-turn context.\n550:  * Enables cross-turn dedup and goal-aware refinement of search results.\n551:  * Default: TRUE (graduated). Set SPECKIT_SESSION_RETRIEVAL_STATE_V1=false to disable.\n552:  */\n553: export function isSessionRetrievalStateEnabled(): boolean {\n554:   return isFeatureEnabled('SPECKIT_SESSION_RETRIEVAL_STATE_V1');\n555: }\n556: \n557: /* ───────────────────────────────────────────────────────────────\n558:    13. GRADUATED FLAGS\n559: ──────────────────────────────────────────────────────────────── */\n560: \n561: /**\n562:  * Calibrated overlap bonus for multi-channel convergence.\n563:  * Default: TRUE (graduated). Set SPECKIT_CALIBRATED_OVERLAP_BONUS=false to disable.\n564:  */\n565: export function isCalibratedOverlapBonusEnabled(): boolean {\n566:   return isFeatureEnabled('SPECKIT_CALIBRATED_OVERLAP_BONUS');\n567: }\n568: \n569: /**\n570:  * Experimental per-intent RRF K selection.\n571:  * Default: TRUE (graduated). Set SPECKIT_RRF_K_EXPERIMENTAL=false to disable.\n572:  */\n573: export function isRrfKExperimentalEnabled(): boolean {\n574:   return isFeatureEnabled('SPECKIT_RRF_K_EXPERIMENTAL');\n575: }\n576: \n577: /**\n578:  * Sparse-first + intent-aware typed traversal.\n579:  * Default: TRUE (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n580:  */\n581: export function isTypedTraversalEnabled(): boolean {\n582:   return isFeatureEnabled('SPECKIT_TYPED_TRAVERSAL');\n583: }\n584: \n585: /**\n586:  * Empty/weak result recovery UX.\n587:  * Default: TRUE (graduated). Set SPECKIT_EMPTY_RESULT_RECOVERY_V1=false to disable.\n588:  */\n589: export function isEmptyResultRecoveryEnabled(): boolean {\n590:   return isFeatureEnabled('SPECKIT_EMPTY_RESULT_RECOVERY_V1');\n591: }\n592: \n593: /**\n594:  * Per-result calibrated confidence scoring.\n595:  * Default: TRUE (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n596:  */\n597: export function isResultConfidenceEnabled(): boolean {\n598:   return isFeatureEnabled('SPECKIT_RESULT_CONFIDENCE_V1');\n599: }\n600: \n601: /**\n602:  * Calibrate confidence/request-quality and result-set digests on an absolute\n603:  * relevance signal (cosine similarity) instead of the RRF fusion score. RRF\n604:  * magnitudes (~0.01–0.05) understate relevance and make \"good\" unreachable, so\n605:  * every hybrid query degrades to \"weak\"/\"gap\". Ordering is unaffected — this\n606:  * only changes the calibration/display scale.\n607:  * Default: TRUE (graduated). Set SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION=false to disable.\n608:  */\n609: export function isAbsoluteRelevanceCalibrationEnabled(): boolean {\n610:   return isFeatureEnabled('SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION');\n611: }\n612: \n613: /**\n614:  * Map per-result confidence values through a fitted isotonic calibration model\n615:  * so confidence.value approximates P(relevant). Opt-in (default OFF): the only\n616:  * labeled set available today is a corpus-derived PROXY, not human-judged live\n617:  * `memory_search` traffic, so the model is unvalidated and must not silently\n618:  * reshape production confidence. A model is applied only when this flag is ON\n619:  * AND SPECKIT_CONFIDENCE_CALIBRATION_MODEL points at a readable model file.\n620:  * Set SPECKIT_CONFIDENCE_CALIBRATION=true to enable once a validated set exists.\n621:  */\n622: export function isConfidenceCalibrationEnabled(): boolean {\n623:   return isOptInEnabled('SPECKIT_CONFIDENCE_CALIBRATION');\n624: }\n625: \n626: /**\n627:  * Cosine-primary reorder of the result head before truncation.\n628:  *\n629:  * Reorders only the top-N of the final ranked list by absolute cosine relevance\n630:  * (a stable sort, so ties keep their fused RRF order). RRF fusion stays the\n631:  * ordering baseline; only the head is rebalanced toward the strongest absolute\n632:  * semantic signal, which matters now that downstream consumers treat position 1\n633:  * as decisive. Near-zero latency and no model/LLM involved — a pure reorder.\n634:  * Default: TRUE (graduated, low-risk lift). Set SPECKIT_COSINE_TOPN_REORDER=false to disable.\n635:  */\n636: export function isCosineTopnReorderEnabled(): boolean {\n637:   return isFeatureEnabled('SPECKIT_COSINE_TOPN_REORDER');\n638: }\n639: \n640: /** Filesystem path to a fitted CalibrationModel JSON, or undefined when unset. */\n641: export function getConfidenceCalibrationModelPath(): string | undefined {\n642:   const raw = process.env.SPECKIT_CONFIDENCE_CALIBRATION_MODEL?.trim();\n643:   return raw && raw.length > 0 ? raw : undefined;\n644: }\n645: \n646: /**\n647:  * Include archived/cold (deprecated-tier) memories in retrieval for everyone,\n648:  * instead of hard-excluding them. The FSRS temperature system already ranks\n649:  * memories by retrievability (deprecated decays at 0.25x → coldest), so a hard\n650:  * exclusion is redundant and hides legitimately-cold-but-relevant history (e.g.\n651:  * z_archive specs). Cold rows are included and naturally rank below hot ones.\n652:  * Applies to the query-time channels (lexical FTS/BM25, trigger); the vector lane\n653:  * filters via the active_memory_projection and is included separately when that\n654:  * projection is rebuilt. Constitutional rows stay on their own injected path.\n655:  * Default: TRUE (graduated). Set SPECKIT_INCLUDE_ARCHIVED_DEFAULT=false to restore\n656:  * the hard exclusion.\n657:  */\n658: export function isArchivedRetrievalIncludedByDefault(): boolean {\n659:   return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_DEFAULT');\n660: }\n661: \n662: /**\n663:  * Extend cold/archived (deprecated-tier) inclusion to the VECTOR (semantic) lane.\n664:  * The vector lane joins `active_memory_projection`, which holds one active row per\n665:  * logical key, so cold rows are admitted to the projection (option A: only rows\n666:  * whose logical key has no active winner) by a boot-time backfill, and the\n667:  * query-time deprecated filter is relaxed. Graduated to default ON alongside the\n668:  * other cold-tier channels; the backfill is idempotent and preserves the\n669:  * one-active-per-key UNIQUE invariant. Set SPECKIT_INCLUDE_ARCHIVED_VECTOR=false\n670:  * to restore the vector-lane exclusion.\n671:  */\n672: export function isArchivedVectorInclusionEnabled(): boolean {\n673:   return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_VECTOR');\n674: }\n675: \n676: /**\n677:  * Weekly batch feedback learning pipeline.\n678:  * Default: TRUE (graduated). Set SPECKIT_BATCH_LEARNED_FEEDBACK=false to disable.\n679:  */\n680: export function isBatchLearnedFeedbackEnabled(): boolean {\n681:   return isFeatureEnabled('SPECKIT_BATCH_LEARNED_FEEDBACK');\n682: }\n683: \n684: /**\n685:  * Assistive reconsolidation for near-duplicate detection.\n686:  * Default: TRUE (graduated). Set SPECKIT_ASSISTIVE_RECONSOLIDATION=false to disable.\n687:  */\n688: export function isAssistiveReconsolidationEnabled(): boolean {\n689:   return isFeatureEnabled('SPECKIT_ASSISTIVE_RECONSOLIDATION');\n690: }\n691: \n692: /**\n693:  * Two-tier result explainability.\n694:  * Default: TRUE (graduated). Set SPECKIT_RESULT_EXPLAIN_V1=false to disable.\n695:  */\n696: export function isResultExplainEnabled(): boolean {\n697:   return isFeatureEnabled('SPECKIT_RESULT_EXPLAIN_V1');\n698: }\n699: \n700: /**\n701:  * Mode-aware response profile formatting.\n702:  * Default: TRUE (graduated). Set SPECKIT_RESPONSE_PROFILE_V1=false to disable.\n703:  */\n704: export function isResponseProfileEnabled(): boolean {\n705:   return isFeatureEnabled('SPECKIT_RESPONSE_PROFILE_V1');\n706: }\n707: \n708: /* ───────────────────────────────────────────────────────────────\n709:    14. PHASE B GRAPH RETRIEVAL FLAGS\n710: ──────────────────────────────────────────────────────────────── */\n711: \n712: /**\n713:  * Query concept expansion for hybrid search.\n714:  * When concept routing matches aliases, expands query with related terms.\n715:  * Default: TRUE (graduated). Set SPECKIT_QUERY_CONCEPT_EXPANSION=false to disable.\n716:  */\n717: export function isQueryConceptExpansionEnabled(): boolean {\n718:   return isFeatureEnabled('SPECKIT_QUERY_CONCEPT_EXPANSION');\n719: }\n720: \n721: /**\n722:  * Graph-expanded fallback on zero/weak results.\n723:  * Queries causal_edges for neighbor titles when recovery triggers.\n724:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_FALLBACK=false to disable.\n725:  */\n726: export function isGraphFallbackEnabled(): boolean {\n727:   return isFeatureEnabled('SPECKIT_GRAPH_FALLBACK');\n728: }\n729: \n730: /**\n731:  * Always-on graph context injection.\n732:  * Runs concept routing + graph neighbor lookup even without seed results.\n733:  * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONTEXT_INJECTION=false to disable.\n734:  */\n735: export function isGraphContextInjectionEnabled(): boolean {\n736:   return isFeatureEnabled('SPECKIT_GRAPH_CONTEXT_INJECTION');\n737: }\n738: \n739: /**\n740:  * Result provenance — include graph evidence metadata in search results.\n741:  * When enabled, search results include graphEvidence with contributing edges,\n742:  * communities, and boost factors for transparency and debuggability.\n743:  * Default: TRUE (enabled). Set SPECKIT_RESULT_PROVENANCE=false to disable.\n744:  */\n745: export function isResultProvenanceEnabled(): boolean {\n746:   return isFeatureEnabled('SPECKIT_RESULT_PROVENANCE');\n747: }\n748: \n749: /**\n750:  * Temporal validity tracking for causal edges.\n751:  * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_EDGES=false to disable.\n752:  */\n753: export function isTemporalEdgesEnabled(): boolean {\n754:   return isFeatureEnabled('SPECKIT_TEMPORAL_EDGES');\n755: }\n756: \n757: /**\n758:  * Usage-weighted ranking signal.\n759:  * Default: TRUE (graduated). Set SPECKIT_USAGE_RANKING=false to disable.\n760:  */\n761: export function isUsageRankingEnabled(): boolean {\n762:   return isFeatureEnabled('SPECKIT_USAGE_RANKING');\n763: }\n764: \n765: /**\n766:  * Ontology-guided extraction validation hooks.\n767:  * Default: TRUE (graduated). Set SPECKIT_ONTOLOGY_HOOKS=false to disable.\n768:  */\n769: export function isOntologyHooksEnabled(): boolean {\n770:   return isFeatureEnabled('SPECKIT_ONTOLOGY_HOOKS');\n771: }\n772: \n773: /**\n774:  * Community-level search as fallback channel.\n775:  * When primary search returns weak/no results, searches community summaries\n776:  * and injects matching community members as candidates.\n777:  * Default: TRUE (graduated). Set SPECKIT_COMMUNITY_SEARCH_FALLBACK=false to disable.\n778:  */\n779: export function isCommunitySearchFallbackEnabled(): boolean {\n780:   return isFeatureEnabled('SPECKIT_COMMUNITY_SEARCH_FALLBACK');\n781: }\n782: \n783: /**\n784:  * Dual-level retrieval mode.\n785:  * Adds retrievalLevel parameter: 'local' (entity), 'global' (community), 'auto' (local + fallback).\n786:  * Default: TRUE (graduated). Set SPECKIT_DUAL_RETRIEVAL=false to disable.\n787:  */\n788: export function isDualRetrievalEnabled(): boolean {\n789:   return isFeatureEnabled('SPECKIT_DUAL_RETRIEVAL');\n790: }\n791: \n792: /**\n793:  * Phase C: Intent-to-profile auto-routing.\n794:  * When enabled, classifyIntent() results automatically select a response profile\n795:  * (quick, research, resume, debug) when no explicit profile is specified by the caller.\n796:  * Default: TRUE (graduated). Set SPECKIT_INTENT_AUTO_PROFILE=false to disable.\n797:  */\n798: export function isIntentAutoProfileEnabled(): boolean {\n799:   return isFeatureEnabled('SPECKIT_INTENT_AUTO_PROFILE');\n800: }\n\n(End of file - total 800 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Search Flags\n// ───────────────────────────────────────────────────────────────\n// Default-on runtime gates for search pipeline controls\n//\n// Production-ready flags graduated to default-ON.\n// Set SPECKIT_<FLAG>=false to disable any graduated feature.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { isFeatureEnabled } from '../cognitive/rollout-policy.js';\n\n// Feature catalog: Quality-aware 3-tier search fallback\n// Feature catalog: Verify-fix-verify memory quality loop\n// Feature catalog: Negative feedback confidence signal\n\nexport type SavePlannerMode = 'plan-only' | 'full-auto' | 'hybrid';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Search Flags\n// ───────────────────────────────────────────────────────────────\n// Default-on runtime gates for search pipeline controls\n//\n// Production-ready flags graduated to default-ON.\n// Set SPECKIT_<FLAG>=false to disable any graduated feature.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { isFeatureEnabled } from '../cognitive/rollout-policy.js';\n\n// Feature catalog: Quality-aware 3-tier search fallback\n// Feature catalog: Verify-fix-verify memory quality loop\n// Feature catalog: Negative feedback confidence signal\n\nexport type SavePlannerMode = 'plan-only' | 'full-auto' | 'hybrid';\n\nconst TRUTHY_OPT_IN = new Set(['true', '1', 'yes', 'on', 'enabled']);\n\n/**\n * Returns true for explicit opt-in values: true, 1, yes, on, enabled.\n * Undefined, empty, unrecognized, and explicit false-like values are treated as false.\n */\nfunction isOptInEnabled(variableName: string): boolean {\n  const value = process.env[variableName]?.toLowerCase().trim();\n  return value !== undefined && TRUTHY_OPT_IN.has(value);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. BOOST FLAGS (Graduated default-ON)\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Session attention boost for search result re-ranking.\n * Default: TRUE (graduated). Set SPECKIT_SESSION_BOOST=false to disable.\n */\nexport function isSessionBoostEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SESSION_BOOST');\n}\n\n/**\n * Causal graph traversal boost for search result amplification.\n * Default: TRUE (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n */\nexport function isCausalBoostEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CAUSAL_BOOST');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CORE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Dynamic startup instruction injection for the MCP server.\n * Default: TRUE (graduated). Set SPECKIT_DYNAMIC_INIT=false to disable.\n */\nexport function isDynamicInitEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DYNAMIC_INIT');\n}\n\n/**\n * Token-pressure policy for memory_context.\n * Default: TRUE (graduated). Set SPECKIT_PRESSURE_POLICY=false to disable.\n */\nexport function isPressurePolicyEnabled(identity?: string): boolean {\n  return isFeatureEnabled('SPECKIT_PRESSURE_POLICY', identity);\n}\n\n/**\n * Automatic session resume context injection for memory_context.\n * Default: TRUE (graduated). Set SPECKIT_AUTO_RESUME=false to disable.\n */\nexport function isAutoResumeEnabled(identity?: string): boolean {\n  return isFeatureEnabled('SPECKIT_AUTO_RESUME', identity);\n}\n\n/**\n * Graph-guided MMR diversity reranking.\n * Default: TRUE (enabled). Set SPECKIT_MMR=false to disable.\n */\nexport function isMMREnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_MMR');\n}\n\n/**\n * Transparent Reasoning Module (evidence-gap detection).\n * Default: TRUE (enabled). Set SPECKIT_TRM=false to disable.\n */\nexport function isTRMEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TRM');\n}\n\n/**\n * Multi-query expansion for deep-mode retrieval.\n * Default: TRUE (enabled). Set SPECKIT_MULTI_QUERY=false to disable.\n */\nexport function isMultiQueryEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_MULTI_QUERY');\n}\n\n/**\n * PI-A2: Quality-aware 3-tier search fallback chain.\n * Default: TRUE (graduated). Set SPECKIT_SEARCH_FALLBACK=false to disable.\n */\nexport function isSearchFallbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SEARCH_FALLBACK');\n}\n\n/**\n * Automatic spec folder discovery via description cache.\n * Default: TRUE (graduated). Set SPECKIT_FOLDER_DISCOVERY=false to disable.\n */\nexport function isFolderDiscoveryEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_FOLDER_DISCOVERY');\n}\n\n/**\n * Planner-first save mode selection for canonical save flows.\n * Default: 'plan-only'. Set SPECKIT_SAVE_PLANNER_MODE=full-auto to restore\n * the legacy mutation-first behavior. `hybrid` is reserved for future mixed\n * flows and currently behaves the same as `plan-only`.\n */\nexport function resolveSavePlannerMode(): SavePlannerMode {\n  const raw = process.env.SPECKIT_SAVE_PLANNER_MODE?.trim().toLowerCase();\n  if (raw === 'full-auto' || raw === 'full_auto') {\n    return 'full-auto';\n  }\n  if (raw === 'hybrid') {\n    return 'hybrid';\n  }\n  return 'plan-only';\n}\n\n/**\n * Save-time reconsolidation gate. Opt-in (default OFF): it enables the destructive\n * reconsolidate() path that can merge near-duplicate rows and deprecate older ones — itself\n * further gated on a per-spec-folder \"pre-reconsolidation\" checkpoint. Kept opt-in so a\n * destructive merge never happens without explicit intent. Set SPECKIT_RECONSOLIDATION_ENABLED=true to enable.\n */\nexport function isSaveReconsolidationEnabled(): boolean {\n  return isOptInEnabled('SPECKIT_RECONSOLIDATION_ENABLED');\n}\n\n/**\n * Save-time post-insert enrichment bundle gate (causal links, entity extraction,\n * summaries, entity linking, graph lifecycle — populates the causal/entity graph).\n * Default: TRUE (graduated). Set SPECKIT_POST_INSERT_ENRICHMENT_ENABLED=false to disable.\n */\nexport function isPostInsertEnrichmentEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_POST_INSERT_ENRICHMENT_ENABLED');\n}\n\n/**\n * Whether the post-insert enrichment bundle runs in the background (non-blocking save).\n * Default: TRUE (async). Set SPECKIT_POST_INSERT_ENRICHMENT_SYNC=true to run it synchronously\n * when a caller needs the causal/entity graph fresh within the same save response.\n */\nexport function isPostInsertEnrichmentAsync(): boolean {\n  return !isOptInEnabled('SPECKIT_POST_INSERT_ENRICHMENT_SYNC');\n}\n\n/**\n * Save-time quality auto-fix retries gate (regenerates trigger phrases, trims oversized\n * content to the char budget, normalizes anchors on save).\n * Default: TRUE (graduated). Set SPECKIT_QUALITY_AUTO_FIX=false to disable.\n */\nexport function isQualityAutoFixEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUALITY_AUTO_FIX');\n}\n\n// -- Hybrid RAG Fusion Refinement flags --\n\n/**\n * MPAB: Document-level chunk-to-memory score aggregation.\n * Default: TRUE (graduated). Set SPECKIT_DOCSCORE_AGGREGATION=false to disable.\n */\nexport function isDocscoreAggregationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DOCSCORE_AGGREGATION');\n}\n\n/**\n * Pre-storage quality gate for memory saves.\n * Default: TRUE (graduated). Set SPECKIT_SAVE_QUALITY_GATE=false to disable.\n */\nexport function isSaveQualityGateEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SAVE_QUALITY_GATE');\n}\n\n/**\n * Dynamic token budget allocation by query complexity.\n * Default: TRUE (graduated). Set SPECKIT_DYNAMIC_TOKEN_BUDGET=false to disable.\n */\nexport function isDynamicTokenBudgetEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DYNAMIC_TOKEN_BUDGET');\n}\n\n/**\n * Confidence-gap truncation for low-confidence tails.\n * Default: TRUE (graduated). Set SPECKIT_CONFIDENCE_TRUNCATION=false to disable.\n */\nexport function isConfidenceTruncationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CONFIDENCE_TRUNCATION');\n}\n\n/**\n * Channel minimum-representation promotion after fusion.\n * Default: TRUE (graduated). Set SPECKIT_CHANNEL_MIN_REP=false to disable.\n */\nexport function isChannelMinRepEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CHANNEL_MIN_REP');\n}\n\n/**\n * Reconsolidation-on-save for memory deduplication.\n * Default: TRUE (graduated). Set SPECKIT_RECONSOLIDATION=false to disable.\n */\nexport function isReconsolidationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RECONSOLIDATION');\n}\n\n/**\n * Negative-feedback confidence demotion in ranking.\n * Default: TRUE (graduated). Set SPECKIT_NEGATIVE_FEEDBACK=false to disable.\n */\nexport function isNegativeFeedbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_NEGATIVE_FEEDBACK');\n}\n\n// -- Pipeline Refactor flags --\n\n/**\n * Query expansion for embedding-based retrieval.\n * Suppressed when classification = \"simple\" (mutual exclusion).\n * Default: TRUE (graduated). Set SPECKIT_EMBEDDING_EXPANSION=false to disable.\n */\nexport function isEmbeddingExpansionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_EMBEDDING_EXPANSION');\n}\n\n// -- Indexing and Graph flags --\n\n/**\n * N3-lite: Consolidation engine — contradiction scan, Hebbian strengthening,\n * staleness detection, edge bounds enforcement.\n * Default: TRUE (graduated). Set SPECKIT_CONSOLIDATION=false to disable.\n */\nexport function isConsolidationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CONSOLIDATION');\n}\n\n/**\n * Encoding-intent capture at index time.\n * Records intent metadata (document, code, structured_data) alongside embeddings.\n * Default: TRUE (graduated). Set SPECKIT_ENCODING_INTENT=false to disable.\n */\nexport function isEncodingIntentEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ENCODING_INTENT');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. GRAPH FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * N2a+N2b: Graph momentum scoring and causal depth signals.\n * Default: TRUE (enabled). Set SPECKIT_GRAPH_SIGNALS=false to disable.\n */\n// Supported SPECKIT_GRAPH_WALK_ROLLOUT states: off, trace_only, bounded_runtime.\nexport type GraphWalkRolloutState = 'off' | 'trace_only' | 'bounded_runtime';\n\nexport function resolveGraphWalkRolloutState(): GraphWalkRolloutState {\n  const rollout = process.env.SPECKIT_GRAPH_WALK_ROLLOUT?.trim().toLowerCase();\n  if (rollout === 'off' || rollout === 'false' || rollout === '0') {\n    return 'off';\n  }\n  if (rollout === 'trace_only' || rollout === 'trace-only') {\n    return 'trace_only';\n  }\n  if (rollout === 'bounded_runtime' || rollout === 'bounded-runtime' || rollout === 'true' || rollout === '1') {\n    return 'bounded_runtime';\n  }\n\n  return isFeatureEnabled('SPECKIT_GRAPH_SIGNALS') ? 'bounded_runtime' : 'off';\n}\n\nexport function isGraphSignalsEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_SIGNALS');\n}\n\n/**\n * N2c: Community detection (BFS connected components + Louvain escalation).\n * Default: TRUE (enabled). Set SPECKIT_COMMUNITY_DETECTION=false to disable.\n */\nexport function isCommunityDetectionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COMMUNITY_DETECTION');\n}\n\n/**\n * Community summary generation and search channel.\n * Default: TRUE (enabled). Set SPECKIT_COMMUNITY_SUMMARIES=false to disable.\n */\nexport function isCommunitySummariesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COMMUNITY_SUMMARIES');\n}\n\n/**\n * Memory summary generation (TF-IDF extractive summaries as search channel).\n * Default: TRUE (enabled). Set SPECKIT_MEMORY_SUMMARIES=false to disable.\n */\nexport function isMemorySummariesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_MEMORY_SUMMARIES');\n}\n\n/**\n * Temporal contiguity boost on raw Stage 1 vector results.\n * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_CONTIGUITY=false to disable.\n */\nexport function isTemporalContiguityEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TEMPORAL_CONTIGUITY');\n}\n\n/**\n * Auto entity extraction (rule-based noun-phrase extraction at save time).\n * Default: TRUE (enabled). Set SPECKIT_AUTO_ENTITIES=false to disable.\n */\nexport function isAutoEntitiesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_AUTO_ENTITIES');\n}\n\n/**\n * Cross-document entity linking (entity-based cross-doc edges).\n * Requires auto entities to also be enabled.\n * Default: TRUE (enabled). Set SPECKIT_ENTITY_LINKING=false to disable.\n */\nexport function isEntityLinkingEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ENTITY_LINKING');\n}\n\n/** Whether causal-edge degree-based re-ranking is enabled (SPECKIT_DEGREE_BOOST). */\nexport function isDegreeBoostEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DEGREE_BOOST');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Contextual tree headers for Stage 4 result enrichment.\n * Default: TRUE. Set SPECKIT_CONTEXT_HEADERS=false to disable.\n */\nexport function isContextHeadersEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CONTEXT_HEADERS');\n}\n\n/**\n * Real-time file watcher for markdown reindexing.\n * Default: FALSE. Set SPECKIT_FILE_WATCHER=true to enable.\n * Honors SPECKIT_ROLLOUT_PERCENT global rollout policy.\n */\nexport function isFileWatcherEnabled(): boolean {\n  if (process.env.SPECKIT_FILE_WATCHER?.toLowerCase().trim() !== 'true') return false;\n  return isFeatureEnabled('SPECKIT_FILE_WATCHER');\n}\n\n/**\n * Verify-fix-verify memory quality loop.\n * Default: TRUE (graduated). Set SPECKIT_QUALITY_LOOP=false to disable.\n */\nexport function isQualityLoopEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUALITY_LOOP');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. QUERY INTELLIGENCE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Query decomposition — bounded facet detection.\n * Deep-mode only: multi-faceted queries split into up to 3 sub-queries.\n * Default: TRUE (graduated). Set SPECKIT_QUERY_DECOMPOSITION=false to disable.\n */\nexport function isQueryDecompositionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUERY_DECOMPOSITION');\n}\n\n/**\n * Graph concept routing — query-time alias matching.\n * Extracts noun phrases from the query and matches against concept alias table,\n * activating the graph channel for matched concepts.\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONCEPT_ROUTING=false to disable.\n */\nexport function isGraphConceptRoutingEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_CONCEPT_ROUTING');\n}\n\n/**\n * Index-time surrogates for recall improvement.\n * Generates surrogate metadata (aliases, headings, summary, questions)\n * at index time; matched at query time with no LLM calls.\n * Default: TRUE (graduated). Set SPECKIT_QUERY_SURROGATES=false to disable.\n */\nexport function isQuerySurrogatesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUERY_SURROGATES');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. FEEDBACK & QUALITY LEARNING FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Implicit feedback event ledger.\n * Shadow-only — no ranking side effects.\n * Default: TRUE (graduated). Set SPECKIT_IMPLICIT_FEEDBACK_LOG=false to disable.\n */\nexport function isImplicitFeedbackLogEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_IMPLICIT_FEEDBACK_LOG');\n}\n\n/**\n * Hybrid decay policy — type-aware no-decay for permanent artifacts.\n * Default: TRUE (graduated). Set SPECKIT_HYBRID_DECAY_POLICY=false to disable.\n * When enabled: decision/constitutional/critical context types receive Infinity\n * stability (no decay). All other types follow the standard FSRS schedule.\n */\nexport function isHybridDecayPolicyEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_HYBRID_DECAY_POLICY');\n}\n\n/**\n * Short-critical quality gate exception.\n * Default: TRUE (graduated). Set SPECKIT_SAVE_QUALITY_GATE_EXCEPTIONS=false to disable.\n * When enabled: decision context_type documents with >= 2 structural signals\n * bypass the 50-character minimum content length check.\n */\nexport function isSaveQualityGateExceptionsEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SAVE_QUALITY_GATE_EXCEPTIONS');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. LLM QUERY INTELLIGENCE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Corpus-grounded LLM query reformulation.\n * Step-back abstraction + corpus seed grounding. Deep-mode only.\n * Default: TRUE (graduated). Set SPECKIT_LLM_REFORMULATION=false to disable.\n * Requires an OpenAI-compatible LLM endpoint (LLM_REFORMULATION_ENDPOINT).\n */\nexport function isLlmReformulationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_LLM_REFORMULATION');\n}\n\n/**\n * HyDE (Hypothetical Document Embeddings).\n * Generates a pseudo-document for low-confidence deep queries.\n * Default: TRUE (graduated). Set SPECKIT_HYDE=false to disable.\n */\nexport function isHyDEEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_HYDE');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. GRAPH LIFECYCLE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Graph refresh mode.\n * Controls when dirty-node recomputation runs after write operations.\n * Default: 'write_local' (graduated). Set SPECKIT_GRAPH_REFRESH_MODE=off to disable.\n * Values: off | write_local | scheduled.\n */\nexport function getGraphRefreshMode(): string {\n  return process.env.SPECKIT_GRAPH_REFRESH_MODE?.trim().toLowerCase() ?? 'write_local';\n}\n\nexport function isGraphRefreshDisabled(): boolean {\n  return getGraphRefreshMode() === 'off';\n}\n\n/**\n * Async LLM graph backfill for high-value documents.\n * Runs after deterministic extraction; adds probabilistic edges via LLM.\n * Default: TRUE (graduated). Set SPECKIT_LLM_GRAPH_BACKFILL=false to disable.\n */\nexport function isLlmGraphBackfillEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_LLM_GRAPH_BACKFILL');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. GRAPH CALIBRATION & COMMUNITIES FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Graph calibration profiles and community thresholds.\n * Enables calibration profile enforcement, Louvain activation gates, and\n * community score capping (secondary-only).\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_CALIBRATION_PROFILE=false to disable.\n */\nexport function isGraphCalibrationProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_CALIBRATION_PROFILE');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   10. LEARNED RANKING FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Learned Stage 2 weight combiner (shadow mode).\n * Runs the learned linear ranker in parallel with manual weights.\n * Scores are computed but NOT used for ranking (shadow-only).\n * Default: TRUE (graduated). Set SPECKIT_LEARNED_STAGE2_COMBINER=false to disable.\n */\nexport function isLearnedStage2CombinerEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_LEARNED_STAGE2_COMBINER');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   11. SHADOW EVALUATION FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Shadow scoring with holdout evaluation.\n * Compares would-have-changed rankings vs live rankings on a holdout\n * slice of queries. Shadow-only — no ranking side effects.\n * Default: TRUE (graduated). Set SPECKIT_SHADOW_FEEDBACK=false to disable.\n */\nexport function isShadowFeedbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SHADOW_FEEDBACK');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   12. PROGRESSIVE DISCLOSURE & SESSION STATE FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Progressive disclosure for search results.\n * Replaces hard tail-truncation with summary layer + snippet + cursor pagination.\n * Default: TRUE (graduated). Set SPECKIT_PROGRESSIVE_DISCLOSURE_V1=false to disable.\n */\nexport function isProgressiveDisclosureEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_PROGRESSIVE_DISCLOSURE_V1');\n}\n\n/**\n * Retrieval session state for cross-turn context.\n * Enables cross-turn dedup and goal-aware refinement of search results.\n * Default: TRUE (graduated). Set SPECKIT_SESSION_RETRIEVAL_STATE_V1=false to disable.\n */\nexport function isSessionRetrievalStateEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_SESSION_RETRIEVAL_STATE_V1');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   13. GRADUATED FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Calibrated overlap bonus for multi-channel convergence.\n * Default: TRUE (graduated). Set SPECKIT_CALIBRATED_OVERLAP_BONUS=false to disable.\n */\nexport function isCalibratedOverlapBonusEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_CALIBRATED_OVERLAP_BONUS');\n}\n\n/**\n * Experimental per-intent RRF K selection.\n * Default: TRUE (graduated). Set SPECKIT_RRF_K_EXPERIMENTAL=false to disable.\n */\nexport function isRrfKExperimentalEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RRF_K_EXPERIMENTAL');\n}\n\n/**\n * Sparse-first + intent-aware typed traversal.\n * Default: TRUE (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n */\nexport function isTypedTraversalEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TYPED_TRAVERSAL');\n}\n\n/**\n * Empty/weak result recovery UX.\n * Default: TRUE (graduated). Set SPECKIT_EMPTY_RESULT_RECOVERY_V1=false to disable.\n */\nexport function isEmptyResultRecoveryEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_EMPTY_RESULT_RECOVERY_V1');\n}\n\n/**\n * Per-result calibrated confidence scoring.\n * Default: TRUE (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n */\nexport function isResultConfidenceEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESULT_CONFIDENCE_V1');\n}\n\n/**\n * Calibrate confidence/request-quality and result-set digests on an absolute\n * relevance signal (cosine similarity) instead of the RRF fusion score. RRF\n * magnitudes (~0.01–0.05) understate relevance and make \"good\" unreachable, so\n * every hybrid query degrades to \"weak\"/\"gap\". Ordering is unaffected — this\n * only changes the calibration/display scale.\n * Default: TRUE (graduated). Set SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION=false to disable.\n */\nexport function isAbsoluteRelevanceCalibrationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION');\n}\n\n/**\n * Map per-result confidence values through a fitted isotonic calibration model\n * so confidence.value approximates P(relevant). Opt-in (default OFF): the only\n * labeled set available today is a corpus-derived PROXY, not human-judged live\n * `memory_search` traffic, so the model is unvalidated and must not silently\n * reshape production confidence. A model is applied only when this flag is ON\n * AND SPECKIT_CONFIDENCE_CALIBRATION_MODEL points at a readable model file.\n * Set SPECKIT_CONFIDENCE_CALIBRATION=true to enable once a validated set exists.\n */\nexport function isConfidenceCalibrationEnabled(): boolean {\n  return isOptInEnabled('SPECKIT_CONFIDENCE_CALIBRATION');\n}\n\n/**\n * Cosine-primary reorder of the result head before truncation.\n *\n * Reorders only the top-N of the final ranked list by absolute cosine relevance\n * (a stable sort, so ties keep their fused RRF order). RRF fusion stays the\n * ordering baseline; only the head is rebalanced toward the strongest absolute\n * semantic signal, which matters now that downstream consumers treat position 1\n * as decisive. Near-zero latency and no model/LLM involved — a pure reorder.\n * Default: TRUE (graduated, low-risk lift). Set SPECKIT_COSINE_TOPN_REORDER=false to disable.\n */\nexport function isCosineTopnReorderEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COSINE_TOPN_REORDER');\n}\n\n/** Filesystem path to a fitted CalibrationModel JSON, or undefined when unset. */\nexport function getConfidenceCalibrationModelPath(): string | undefined {\n  const raw = process.env.SPECKIT_CONFIDENCE_CALIBRATION_MODEL?.trim();\n  return raw && raw.length > 0 ? raw : undefined;\n}\n\n/**\n * Include archived/cold (deprecated-tier) memories in retrieval for everyone,\n * instead of hard-excluding them. The FSRS temperature system already ranks\n * memories by retrievability (deprecated decays at 0.25x → coldest), so a hard\n * exclusion is redundant and hides legitimately-cold-but-relevant history (e.g.\n * z_archive specs). Cold rows are included and naturally rank below hot ones.\n * Applies to the query-time channels (lexical FTS/BM25, trigger); the vector lane\n * filters via the active_memory_projection and is included separately when that\n * projection is rebuilt. Constitutional rows stay on their own injected path.\n * Default: TRUE (graduated). Set SPECKIT_INCLUDE_ARCHIVED_DEFAULT=false to restore\n * the hard exclusion.\n */\nexport function isArchivedRetrievalIncludedByDefault(): boolean {\n  return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_DEFAULT');\n}\n\n/**\n * Extend cold/archived (deprecated-tier) inclusion to the VECTOR (semantic) lane.\n * The vector lane joins `active_memory_projection`, which holds one active row per\n * logical key, so cold rows are admitted to the projection (option A: only rows\n * whose logical key has no active winner) by a boot-time backfill, and the\n * query-time deprecated filter is relaxed. Graduated to default ON alongside the\n * other cold-tier channels; the backfill is idempotent and preserves the\n * one-active-per-key UNIQUE invariant. Set SPECKIT_INCLUDE_ARCHIVED_VECTOR=false\n * to restore the vector-lane exclusion.\n */\nexport function isArchivedVectorInclusionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_INCLUDE_ARCHIVED_VECTOR');\n}\n\n/**\n * Weekly batch feedback learning pipeline.\n * Default: TRUE (graduated). Set SPECKIT_BATCH_LEARNED_FEEDBACK=false to disable.\n */\nexport function isBatchLearnedFeedbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_BATCH_LEARNED_FEEDBACK');\n}\n\n/**\n * Assistive reconsolidation for near-duplicate detection.\n * Default: TRUE (graduated). Set SPECKIT_ASSISTIVE_RECONSOLIDATION=false to disable.\n */\nexport function isAssistiveReconsolidationEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ASSISTIVE_RECONSOLIDATION');\n}\n\n/**\n * Two-tier result explainability.\n * Default: TRUE (graduated). Set SPECKIT_RESULT_EXPLAIN_V1=false to disable.\n */\nexport function isResultExplainEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESULT_EXPLAIN_V1');\n}\n\n/**\n * Mode-aware response profile formatting.\n * Default: TRUE (graduated). Set SPECKIT_RESPONSE_PROFILE_V1=false to disable.\n */\nexport function isResponseProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESPONSE_PROFILE_V1');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   14. PHASE B GRAPH RETRIEVAL FLAGS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Query concept expansion for hybrid search.\n * When concept routing matches aliases, expands query with related terms.\n * Default: TRUE (graduated). Set SPECKIT_QUERY_CONCEPT_EXPANSION=false to disable.\n */\nexport function isQueryConceptExpansionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_QUERY_CONCEPT_EXPANSION');\n}\n\n/**\n * Graph-expanded fallback on zero/weak results.\n * Queries causal_edges for neighbor titles when recovery triggers.\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_FALLBACK=false to disable.\n */\nexport function isGraphFallbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_FALLBACK');\n}\n\n/**\n * Always-on graph context injection.\n * Runs concept routing + graph neighbor lookup even without seed results.\n * Default: TRUE (graduated). Set SPECKIT_GRAPH_CONTEXT_INJECTION=false to disable.\n */\nexport function isGraphContextInjectionEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_GRAPH_CONTEXT_INJECTION');\n}\n\n/**\n * Result provenance — include graph evidence metadata in search results.\n * When enabled, search results include graphEvidence with contributing edges,\n * communities, and boost factors for transparency and debuggability.\n * Default: TRUE (enabled). Set SPECKIT_RESULT_PROVENANCE=false to disable.\n */\nexport function isResultProvenanceEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_RESULT_PROVENANCE');\n}\n\n/**\n * Temporal validity tracking for causal edges.\n * Default: TRUE (graduated). Set SPECKIT_TEMPORAL_EDGES=false to disable.\n */\nexport function isTemporalEdgesEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_TEMPORAL_EDGES');\n}\n\n/**\n * Usage-weighted ranking signal.\n * Default: TRUE (graduated). Set SPECKIT_USAGE_RANKING=false to disable.\n */\nexport function isUsageRankingEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_USAGE_RANKING');\n}\n\n/**\n * Ontology-guided extraction validation hooks.\n * Default: TRUE (graduated). Set SPECKIT_ONTOLOGY_HOOKS=false to disable.\n */\nexport function isOntologyHooksEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_ONTOLOGY_HOOKS');\n}\n\n/**\n * Community-level search as fallback channel.\n * When primary search returns weak/no results, searches community summaries\n * and injects matching community members as candidates.\n * Default: TRUE (graduated). Set SPECKIT_COMMUNITY_SEARCH_FALLBACK=false to disable.\n */\nexport function isCommunitySearchFallbackEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_COMMUNITY_SEARCH_FALLBACK');\n}\n\n/**\n * Dual-level retrieval mode.\n * Adds retrievalLevel parameter: 'local' (entity), 'global' (community), 'auto' (local + fallback).\n * Default: TRUE (graduated). Set SPECKIT_DUAL_RETRIEVAL=false to disable.\n */\nexport function isDualRetrievalEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_DUAL_RETRIEVAL');\n}\n\n/**\n * Phase C: Intent-to-profile auto-routing.\n * When enabled, classifyIntent() results automatically select a response profile\n * (quick, research, resume, debug) when no explicit profile is specified by the caller.\n * Default: TRUE (graduated). Set SPECKIT_INTENT_AUTO_PROFILE=false to disable.\n */\nexport function isIntentAutoProfileEnabled(): boolean {\n  return isFeatureEnabled('SPECKIT_INTENT_AUTO_PROFILE');\n}","lineStart":1,"lineEnd":800,"totalLines":800,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/search-flags.ts","time":{"start":1781757752926,"end":1781757752930}},"metadata":{"openai":{"itemId":"fc_0476bff5faf47e28016a337738d20481918301f1660d10daf7"}},"id":"prt_ed909b657001LIOEuYJ9C7snPT","sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","messageID":"msg_ed909783c001aytDnrba8vGXQc"}}
{"type":"tool_use","timestamp":1781757752958,"sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","part":{"type":"tool","tool":"read","callID":"call_CBhhi25FDQzP53AUQSXZ3uHg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/confidence-calibration.vitest.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/confidence-calibration.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST: Confidence Calibration (flag-gated, default-OFF infrastructure)\n3: // ───────────────────────────────────────────────────────────────\n4: // Covers the isotonic fit/apply math (monotonicity + 0–1 bounds), the\n5: // labeled-set loader validation, and the default-OFF wiring guarantee:\n6: // with the calibration flag unset, per-result confidence is the\n7: // rebalance-only value, untouched by any configured model.\n8: \n9: import { afterEach, beforeEach, describe, expect, it } from 'vitest';\n10: import { mkdtempSync, writeFileSync, rmSync } from 'node:fs';\n11: import { tmpdir } from 'node:os';\n12: import { join } from 'node:path';\n13: \n14: import {\n15:   fitCalibration,\n16:   applyCalibration,\n17:   loadLabeledSet,\n18:   loadCalibrationModel,\n19:   type CalibrationSample,\n20:   type CalibrationModel,\n21: } from '../lib/search/confidence-calibration';\n22: import { computeResultConfidence, type ScoredResult } from '../lib/search/confidence-scoring';\n23: \n24: const FLAG = 'SPECKIT_CONFIDENCE_CALIBRATION';\n25: const MODEL_PATH_VAR = 'SPECKIT_CONFIDENCE_CALIBRATION_MODEL';\n26: \n27: // -- Fit math --\n28: \n29: describe('fitCalibration() — isotonic PAV', () => {\n30:   it('produces a non-decreasing curve from noisy labels', () => {\n31:     // Relevance trends up with rawValue but with local noise; PAV must pool\n32:     // the violators into a monotonic curve.\n33:     const samples: CalibrationSample[] = [\n34:       { rawValue: 0.1, relevant: 0 },\n35:       { rawValue: 0.2, relevant: 1 }, // noise — out of order vs neighbor\n36:       { rawValue: 0.3, relevant: 0 },\n37:       { rawValue: 0.4, relevant: 0 },\n38:       { rawValue: 0.5, relevant: 1 },\n39:       { rawValue: 0.6, relevant: 0 }, // noise\n40:       { rawValue: 0.7, relevant: 1 },\n41:       { rawValue: 0.8, relevant: 1 },\n42:       { rawValue: 0.9, relevant: 1 },\n43:     ];\n44:     const model = fitCalibration(samples);\n45:     expect(model.method).toBe('isotonic');\n46:     expect(model.fittedFrom).toBe(samples.length);\n47:     expect(model.points.length).toBeGreaterThan(0);\n48: \n49:     for (let i = 1; i < model.points.length; i++) {\n50:       expect(model.points[i].y).toBeGreaterThanOrEqual(model.points[i - 1].y);\n51:       expect(model.points[i].x).toBeGreaterThanOrEqual(model.points[i - 1].x);\n52:       expect(model.points[i].y).toBeGreaterThanOrEqual(0);\n53:       expect(model.points[i].y).toBeLessThanOrEqual(1);\n54:     }\n55:   });\n56: \n57:   it('returns an empty (identity) model for no usable samples', () => {\n58:     const model = fitCalibration([]);\n59:     expect(model.points).toHaveLength(0);\n60:     expect(model.fittedFrom).toBe(0);\n61:     // Empty model is the identity transform.\n62:     expect(applyCalibration(model, 0.42)).toBeCloseTo(0.42, 5);\n63:   });\n64: \n65:   it('filters out non-finite / non-binary samples', () => {\n66:     const model = fitCalibration([\n67:       { rawValue: Number.NaN, relevant: 1 },\n68:       { rawValue: 0.5, relevant: 2 as unknown as 0 },\n69:       { rawValue: 0.6, relevant: 1 },\n70:     ]);\n71:     expect(model.fittedFrom).toBe(1);\n72:   });\n73: \n74:   it('collapses adjacent equal-mean blocks into a single point', () => {\n75:     // Three samples whose pooled means stay equal (all-positive, then a mix that\n76:     // pools back to the same 0.5 mean) must not serialize as separate adjacent\n77:     // points. Pooling equal means leaves y unchanged, so this is a size-only\n78:     // guarantee — the curve and its interpolation are identical either way.\n79:     const model = fitCalibration([\n80:       { rawValue: 0.2, relevant: 1 },\n81:       { rawValue: 0.4, relevant: 0 },\n82:       { rawValue: 0.6, relevant: 1 },\n83:       { rawValue: 0.8, relevant: 0 },\n84:     ]);\n85:     // After PAV all four pool to one block (mean y = 0.5); no two adjacent\n86:     // emitted points share a y.\n87:     for (let i = 1; i < model.points.length; i++) {\n88:       expect(model.points[i].y).not.toBeCloseTo(model.points[i - 1].y, 12);\n89:     }\n90:     // monotonic + bounded still holds\n91:     for (let i = 1; i < model.points.length; i++) {\n92:       expect(model.points[i].y).toBeGreaterThanOrEqual(model.points[i - 1].y);\n93:     }\n94:   });\n95: });\n96: \n97: // -- Drift guard: lib PAV vs the offline seed generator --\n98: //\n99: // `004-…/assets/fit-calibration.mjs` carries a second, near-identical PAV loop\n100: // for offline seed generation. The two are intentionally allowed to diverge in\n101: // one respect — the offline asset breaks on `prev <= curr` (keeps adjacent\n102: // equal-mean blocks) while the lib breaks on `prev < curr` (collapses them).\n103: // This guard locks the lib's pooling contract so a future edit to the lib loop\n104: // is caught by an assertion rather than silently desyncing from its own spec.\n105: \n106: describe('fitCalibration() — PAV pooling contract (drift guard)', () => {\n107:   // A reference PAV that mirrors the lib's break condition (`prev < curr`,\n108:   // i.e. collapse equal means). If the lib diverges from this, the parity\n109:   // assertion below fails.\n110:   function referencePav(\n111:     samples: CalibrationSample[],\n112:   ): Array<{ x: number; y: number }> {\n113:     const clean = samples\n114:       .filter((s) => Number.isFinite(s.rawValue) && (s.relevant === 0 || s.relevant === 1))\n115:       .map((s) => ({ x: Math.max(0, Math.min(1, s.rawValue)), y: s.relevant as number }))\n116:       .sort((a, b) => a.x - b.x);\n117:     const blocks: Array<{ sumX: number; sumY: number; count: number }> = [];\n118:     for (const { x, y } of clean) {\n119:       blocks.push({ sumX: x, sumY: y, count: 1 });\n120:       while (blocks.length >= 2) {\n121:         const curr = blocks[blocks.length - 1]!;\n122:         const prev = blocks[blocks.length - 2]!;\n123:         if (prev.sumY / prev.count < curr.sumY / curr.count) break;\n124:         prev.sumX += curr.sumX;\n125:         prev.sumY += curr.sumY;\n126:         prev.count += curr.count;\n127:         blocks.pop();\n128:       }\n129:     }\n130:     return blocks.map((b) => ({ x: b.sumX / b.count, y: Math.max(0, Math.min(1, b.sumY / b.count)) }));\n131:   }\n132: \n133:   it('matches the reference PAV across noisy and equal-mean inputs', () => {\n134:     const cases: CalibrationSample[][] = [\n135:       [\n136:         { rawValue: 0.1, relevant: 0 },\n137:         { rawValue: 0.2, relevant: 1 },\n138:         { rawValue: 0.3, relevant: 0 },\n139:         { rawValue: 0.4, relevant: 0 },\n140:         { rawValue: 0.5, relevant: 1 },\n141:         { rawValue: 0.6, relevant: 0 },\n142:         { rawValue: 0.7, relevant: 1 },\n143:         { rawValue: 0.8, relevant: 1 },\n144:         { rawValue: 0.9, relevant: 1 },\n145:       ],\n146:       [\n147:         { rawValue: 0.2, relevant: 1 },\n148:         { rawValue: 0.4, relevant: 0 },\n149:         { rawValue: 0.6, relevant: 1 },\n150:         { rawValue: 0.8, relevant: 0 },\n151:       ],\n152:       [\n153:         { rawValue: 0.0, relevant: 0 },\n154:         { rawValue: 1.0, relevant: 1 },\n155:       ],\n156:     ];\n157:     for (const samples of cases) {\n158:       const lib = fitCalibration(samples).points;\n159:       const ref = referencePav(samples);\n160:       expect(lib.length).toBe(ref.length);\n161:       for (let i = 0; i < lib.length; i++) {\n162:         expect(lib[i].x).toBeCloseTo(ref[i].x, 12);\n163:         expect(lib[i].y).toBeCloseTo(ref[i].y, 12);\n164:       }\n165:     }\n166:   });\n167: });\n168: \n169: // -- Apply math --\n170: \n171: describe('applyCalibration() — bounded + monotonic', () => {\n172:   const model: CalibrationModel = fitCalibration([\n173:     { rawValue: 0.0, relevant: 0 },\n174:     { rawValue: 0.25, relevant: 0 },\n175:     { rawValue: 0.5, relevant: 1 },\n176:     { rawValue: 0.75, relevant: 1 },\n177:     { rawValue: 1.0, relevant: 1 },\n178:   ]);\n179: \n180:   it('is monotonic non-decreasing across a dense sweep', () => {\n181:     let prev = -Infinity;\n182:     for (let x = 0; x <= 1.0001; x += 0.01) {\n183:       const y = applyCalibration(model, x);\n184:       expect(y).toBeGreaterThanOrEqual(0);\n185:       expect(y).toBeLessThanOrEqual(1);\n186:       expect(y).toBeGreaterThanOrEqual(prev - 1e-9);\n187:       prev = y;\n188:     }\n189:   });\n190: \n191:   it('clamps out-of-range raw values to the curve endpoints', () => {\n192:     const lo = applyCalibration(model, -5);\n193:     const hi = applyCalibration(model, 5);\n194:     expect(lo).toBeGreaterThanOrEqual(0);\n195:     expect(hi).toBeLessThanOrEqual(1);\n196:     expect(hi).toBeGreaterThanOrEqual(lo);\n197:   });\n198: });\n199: \n200: // -- Labeled-set loader --\n201: \n202: describe('loadLabeledSet()', () => {\n203:   it('accepts well-formed pairs', () => {\n204:     const pairs = loadLabeledSet([\n205:       { query: 'token budget truncation', memoryId: 42, relevant: 1 },\n206:       { query: 'token budget truncation', memoryId: 'spec/foo', relevant: 0 },\n207:     ]);\n208:     expect(pairs).toHaveLength(2);\n209:     expect(pairs[0].relevant).toBe(1);\n210:   });\n211: \n212:   it('rejects a non-array', () => {\n213:     expect(() => loadLabeledSet({} as unknown)).toThrow();\n214:   });\n215: \n216:   it('rejects malformed entries', () => {\n217:     expect(() => loadLabeledSet([{ query: '', memoryId: 1, relevant: 1 }])).toThrow();\n218:     expect(() => loadLabeledSet([{ query: 'q', memoryId: null, relevant: 1 }])).toThrow();\n219:     expect(() => loadLabeledSet([{ query: 'q', memoryId: 1, relevant: 2 }])).toThrow();\n220:   });\n221: });\n222: \n223: // -- Model file loader --\n224: \n225: describe('loadCalibrationModel()', () => {\n226:   let dir: string;\n227:   beforeEach(() => {\n228:     dir = mkdtempSync(join(tmpdir(), 'calib-'));\n229:   });\n230:   afterEach(() => {\n231:     rmSync(dir, { recursive: true, force: true });\n232:   });\n233: \n234:   it('returns null for a missing path', () => {\n235:     expect(loadCalibrationModel(join(dir, 'nope.json'))).toBeNull();\n236:   });\n237: \n238:   it('returns null for an invalid model shape', () => {\n239:     const p = join(dir, 'bad.json');\n240:     writeFileSync(p, JSON.stringify({ method: 'platt', points: [] }));\n241:     expect(loadCalibrationModel(p)).toBeNull();\n242:   });\n243: \n244:   it('round-trips a fitted model', () => {\n245:     const model = fitCalibration([\n246:       { rawValue: 0.1, relevant: 0 },\n247:       { rawValue: 0.9, relevant: 1 },\n248:     ]);\n249:     const p = join(dir, 'model.json');\n250:     writeFileSync(p, JSON.stringify(model));\n251:     const loaded = loadCalibrationModel(p);\n252:     expect(loaded).not.toBeNull();\n253:     expect(loaded!.method).toBe('isotonic');\n254:     expect(loaded!.points.length).toBe(model.points.length);\n255:   });\n256: });\n257: \n258: // -- Wiring: default-OFF guarantee --\n259: \n260: describe('confidence-scoring wiring — calibration default OFF', () => {\n261:   let dir: string;\n262:   const sample: ScoredResult[] = [\n263:     { id: 1, similarity: 80, sources: ['vector', 'fts'], anchorMetadata: [{ id: 'a' }, { id: 'b' }] },\n264:     { id: 2, similarity: 40 },\n265:   ];\n266: \n267:   beforeEach(() => {\n268:     dir = mkdtempSync(join(tmpdir(), 'calib-wire-'));\n269:     delete process.env[FLAG];\n270:     delete process.env[MODEL_PATH_VAR];\n271:   });\n272:   afterEach(() => {\n273:     delete process.env[FLAG];\n274:     delete process.env[MODEL_PATH_VAR];\n275:     rmSync(dir, { recursive: true, force: true });\n276:   });\n277: \n278:   it('leaves value at the rebalance-only path when the flag is unset, even with a model configured', () => {\n279:     const baseline = computeResultConfidence(sample)[0].confidence.value;\n280: \n281:     // A model that would collapse everything to ~0 if it were applied.\n282:     const flatModel: CalibrationModel = {\n283:       method: 'isotonic',\n284:       points: [{ x: 0, y: 0.01 }, { x: 1, y: 0.01 }],\n285:       fittedFrom: 2,\n286:     };\n287:     const p = join(dir, 'flat.json');\n288:     writeFileSync(p, JSON.stringify(flatModel));\n289:     process.env[MODEL_PATH_VAR] = p;\n290:     // Flag still OFF — model must be ignored.\n291: \n292:     const withModelButFlagOff = computeResultConfidence(sample)[0].confidence.value;\n293:     expect(withModelButFlagOff).toBeCloseTo(baseline, 6);\n294:   });\n295: \n296:   it('applies the model only when the flag is ON and a model is configured', () => {\n297:     const baseline = computeResultConfidence(sample)[0].confidence.value;\n298:     expect(baseline).toBeGreaterThan(0.1); // rebalance-only value is healthy\n299: \n300:     const flatModel: CalibrationModel = {\n301:       method: 'isotonic',\n302:       points: [{ x: 0, y: 0.01 }, { x: 1, y: 0.01 }],\n303:       fittedFrom: 2,\n304:     };\n305:     const p = join(dir, 'flat.json');\n306:     writeFileSync(p, JSON.stringify(flatModel));\n307:     process.env[MODEL_PATH_VAR] = p;\n308:     process.env[FLAG] = 'true';\n309: \n310:     const calibrated = computeResultConfidence(sample)[0].confidence.value;\n311:     expect(calibrated).toBeLessThan(baseline);\n312:     expect(calibrated).toBeCloseTo(0.01, 3);\n313:   });\n314: });\n\n(End of file - total 314 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST: Confidence Calibration (flag-gated, default-OFF infrastructure)\n// ───────────────────────────────────────────────────────────────\n// Covers the isotonic fit/apply math (monotonicity + 0–1 bounds), the\n// labeled-set loader validation, and the default-OFF wiring guarantee:\n// with the calibration flag unset, per-result confidence is the\n// rebalance-only value, untouched by any configured model.\n\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\nimport { mkdtempSync, writeFileSync, rmSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { join } from 'node:path';\n\nimport {\n  fitCalibration,\n  applyCalibration,\n  loadLabeledSet,\n  loadCalibrationModel,\n  type CalibrationSample,\n  type CalibrationModel,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/confidence-calibration.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST: Confidence Calibration (flag-gated, default-OFF infrastructure)\n// ───────────────────────────────────────────────────────────────\n// Covers the isotonic fit/apply math (monotonicity + 0–1 bounds), the\n// labeled-set loader validation, and the default-OFF wiring guarantee:\n// with the calibration flag unset, per-result confidence is the\n// rebalance-only value, untouched by any configured model.\n\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\nimport { mkdtempSync, writeFileSync, rmSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { join } from 'node:path';\n\nimport {\n  fitCalibration,\n  applyCalibration,\n  loadLabeledSet,\n  loadCalibrationModel,\n  type CalibrationSample,\n  type CalibrationModel,\n} from '../lib/search/confidence-calibration';\nimport { computeResultConfidence, type ScoredResult } from '../lib/search/confidence-scoring';\n\nconst FLAG = 'SPECKIT_CONFIDENCE_CALIBRATION';\nconst MODEL_PATH_VAR = 'SPECKIT_CONFIDENCE_CALIBRATION_MODEL';\n\n// -- Fit math --\n\ndescribe('fitCalibration() — isotonic PAV', () => {\n  it('produces a non-decreasing curve from noisy labels', () => {\n    // Relevance trends up with rawValue but with local noise; PAV must pool\n    // the violators into a monotonic curve.\n    const samples: CalibrationSample[] = [\n      { rawValue: 0.1, relevant: 0 },\n      { rawValue: 0.2, relevant: 1 }, // noise — out of order vs neighbor\n      { rawValue: 0.3, relevant: 0 },\n      { rawValue: 0.4, relevant: 0 },\n      { rawValue: 0.5, relevant: 1 },\n      { rawValue: 0.6, relevant: 0 }, // noise\n      { rawValue: 0.7, relevant: 1 },\n      { rawValue: 0.8, relevant: 1 },\n      { rawValue: 0.9, relevant: 1 },\n    ];\n    const model = fitCalibration(samples);\n    expect(model.method).toBe('isotonic');\n    expect(model.fittedFrom).toBe(samples.length);\n    expect(model.points.length).toBeGreaterThan(0);\n\n    for (let i = 1; i < model.points.length; i++) {\n      expect(model.points[i].y).toBeGreaterThanOrEqual(model.points[i - 1].y);\n      expect(model.points[i].x).toBeGreaterThanOrEqual(model.points[i - 1].x);\n      expect(model.points[i].y).toBeGreaterThanOrEqual(0);\n      expect(model.points[i].y).toBeLessThanOrEqual(1);\n    }\n  });\n\n  it('returns an empty (identity) model for no usable samples', () => {\n    const model = fitCalibration([]);\n    expect(model.points).toHaveLength(0);\n    expect(model.fittedFrom).toBe(0);\n    // Empty model is the identity transform.\n    expect(applyCalibration(model, 0.42)).toBeCloseTo(0.42, 5);\n  });\n\n  it('filters out non-finite / non-binary samples', () => {\n    const model = fitCalibration([\n      { rawValue: Number.NaN, relevant: 1 },\n      { rawValue: 0.5, relevant: 2 as unknown as 0 },\n      { rawValue: 0.6, relevant: 1 },\n    ]);\n    expect(model.fittedFrom).toBe(1);\n  });\n\n  it('collapses adjacent equal-mean blocks into a single point', () => {\n    // Three samples whose pooled means stay equal (all-positive, then a mix that\n    // pools back to the same 0.5 mean) must not serialize as separate adjacent\n    // points. Pooling equal means leaves y unchanged, so this is a size-only\n    // guarantee — the curve and its interpolation are identical either way.\n    const model = fitCalibration([\n      { rawValue: 0.2, relevant: 1 },\n      { rawValue: 0.4, relevant: 0 },\n      { rawValue: 0.6, relevant: 1 },\n      { rawValue: 0.8, relevant: 0 },\n    ]);\n    // After PAV all four pool to one block (mean y = 0.5); no two adjacent\n    // emitted points share a y.\n    for (let i = 1; i < model.points.length; i++) {\n      expect(model.points[i].y).not.toBeCloseTo(model.points[i - 1].y, 12);\n    }\n    // monotonic + bounded still holds\n    for (let i = 1; i < model.points.length; i++) {\n      expect(model.points[i].y).toBeGreaterThanOrEqual(model.points[i - 1].y);\n    }\n  });\n});\n\n// -- Drift guard: lib PAV vs the offline seed generator --\n//\n// `004-…/assets/fit-calibration.mjs` carries a second, near-identical PAV loop\n// for offline seed generation. The two are intentionally allowed to diverge in\n// one respect — the offline asset breaks on `prev <= curr` (keeps adjacent\n// equal-mean blocks) while the lib breaks on `prev < curr` (collapses them).\n// This guard locks the lib's pooling contract so a future edit to the lib loop\n// is caught by an assertion rather than silently desyncing from its own spec.\n\ndescribe('fitCalibration() — PAV pooling contract (drift guard)', () => {\n  // A reference PAV that mirrors the lib's break condition (`prev < curr`,\n  // i.e. collapse equal means). If the lib diverges from this, the parity\n  // assertion below fails.\n  function referencePav(\n    samples: CalibrationSample[],\n  ): Array<{ x: number; y: number }> {\n    const clean = samples\n      .filter((s) => Number.isFinite(s.rawValue) && (s.relevant === 0 || s.relevant === 1))\n      .map((s) => ({ x: Math.max(0, Math.min(1, s.rawValue)), y: s.relevant as number }))\n      .sort((a, b) => a.x - b.x);\n    const blocks: Array<{ sumX: number; sumY: number; count: number }> = [];\n    for (const { x, y } of clean) {\n      blocks.push({ sumX: x, sumY: y, count: 1 });\n      while (blocks.length >= 2) {\n        const curr = blocks[blocks.length - 1]!;\n        const prev = blocks[blocks.length - 2]!;\n        if (prev.sumY / prev.count < curr.sumY / curr.count) break;\n        prev.sumX += curr.sumX;\n        prev.sumY += curr.sumY;\n        prev.count += curr.count;\n        blocks.pop();\n      }\n    }\n    return blocks.map((b) => ({ x: b.sumX / b.count, y: Math.max(0, Math.min(1, b.sumY / b.count)) }));\n  }\n\n  it('matches the reference PAV across noisy and equal-mean inputs', () => {\n    const cases: CalibrationSample[][] = [\n      [\n        { rawValue: 0.1, relevant: 0 },\n        { rawValue: 0.2, relevant: 1 },\n        { rawValue: 0.3, relevant: 0 },\n        { rawValue: 0.4, relevant: 0 },\n        { rawValue: 0.5, relevant: 1 },\n        { rawValue: 0.6, relevant: 0 },\n        { rawValue: 0.7, relevant: 1 },\n        { rawValue: 0.8, relevant: 1 },\n        { rawValue: 0.9, relevant: 1 },\n      ],\n      [\n        { rawValue: 0.2, relevant: 1 },\n        { rawValue: 0.4, relevant: 0 },\n        { rawValue: 0.6, relevant: 1 },\n        { rawValue: 0.8, relevant: 0 },\n      ],\n      [\n        { rawValue: 0.0, relevant: 0 },\n        { rawValue: 1.0, relevant: 1 },\n      ],\n    ];\n    for (const samples of cases) {\n      const lib = fitCalibration(samples).points;\n      const ref = referencePav(samples);\n      expect(lib.length).toBe(ref.length);\n      for (let i = 0; i < lib.length; i++) {\n        expect(lib[i].x).toBeCloseTo(ref[i].x, 12);\n        expect(lib[i].y).toBeCloseTo(ref[i].y, 12);\n      }\n    }\n  });\n});\n\n// -- Apply math --\n\ndescribe('applyCalibration() — bounded + monotonic', () => {\n  const model: CalibrationModel = fitCalibration([\n    { rawValue: 0.0, relevant: 0 },\n    { rawValue: 0.25, relevant: 0 },\n    { rawValue: 0.5, relevant: 1 },\n    { rawValue: 0.75, relevant: 1 },\n    { rawValue: 1.0, relevant: 1 },\n  ]);\n\n  it('is monotonic non-decreasing across a dense sweep', () => {\n    let prev = -Infinity;\n    for (let x = 0; x <= 1.0001; x += 0.01) {\n      const y = applyCalibration(model, x);\n      expect(y).toBeGreaterThanOrEqual(0);\n      expect(y).toBeLessThanOrEqual(1);\n      expect(y).toBeGreaterThanOrEqual(prev - 1e-9);\n      prev = y;\n    }\n  });\n\n  it('clamps out-of-range raw values to the curve endpoints', () => {\n    const lo = applyCalibration(model, -5);\n    const hi = applyCalibration(model, 5);\n    expect(lo).toBeGreaterThanOrEqual(0);\n    expect(hi).toBeLessThanOrEqual(1);\n    expect(hi).toBeGreaterThanOrEqual(lo);\n  });\n});\n\n// -- Labeled-set loader --\n\ndescribe('loadLabeledSet()', () => {\n  it('accepts well-formed pairs', () => {\n    const pairs = loadLabeledSet([\n      { query: 'token budget truncation', memoryId: 42, relevant: 1 },\n      { query: 'token budget truncation', memoryId: 'spec/foo', relevant: 0 },\n    ]);\n    expect(pairs).toHaveLength(2);\n    expect(pairs[0].relevant).toBe(1);\n  });\n\n  it('rejects a non-array', () => {\n    expect(() => loadLabeledSet({} as unknown)).toThrow();\n  });\n\n  it('rejects malformed entries', () => {\n    expect(() => loadLabeledSet([{ query: '', memoryId: 1, relevant: 1 }])).toThrow();\n    expect(() => loadLabeledSet([{ query: 'q', memoryId: null, relevant: 1 }])).toThrow();\n    expect(() => loadLabeledSet([{ query: 'q', memoryId: 1, relevant: 2 }])).toThrow();\n  });\n});\n\n// -- Model file loader --\n\ndescribe('loadCalibrationModel()', () => {\n  let dir: string;\n  beforeEach(() => {\n    dir = mkdtempSync(join(tmpdir(), 'calib-'));\n  });\n  afterEach(() => {\n    rmSync(dir, { recursive: true, force: true });\n  });\n\n  it('returns null for a missing path', () => {\n    expect(loadCalibrationModel(join(dir, 'nope.json'))).toBeNull();\n  });\n\n  it('returns null for an invalid model shape', () => {\n    const p = join(dir, 'bad.json');\n    writeFileSync(p, JSON.stringify({ method: 'platt', points: [] }));\n    expect(loadCalibrationModel(p)).toBeNull();\n  });\n\n  it('round-trips a fitted model', () => {\n    const model = fitCalibration([\n      { rawValue: 0.1, relevant: 0 },\n      { rawValue: 0.9, relevant: 1 },\n    ]);\n    const p = join(dir, 'model.json');\n    writeFileSync(p, JSON.stringify(model));\n    const loaded = loadCalibrationModel(p);\n    expect(loaded).not.toBeNull();\n    expect(loaded!.method).toBe('isotonic');\n    expect(loaded!.points.length).toBe(model.points.length);\n  });\n});\n\n// -- Wiring: default-OFF guarantee --\n\ndescribe('confidence-scoring wiring — calibration default OFF', () => {\n  let dir: string;\n  const sample: ScoredResult[] = [\n    { id: 1, similarity: 80, sources: ['vector', 'fts'], anchorMetadata: [{ id: 'a' }, { id: 'b' }] },\n    { id: 2, similarity: 40 },\n  ];\n\n  beforeEach(() => {\n    dir = mkdtempSync(join(tmpdir(), 'calib-wire-'));\n    delete process.env[FLAG];\n    delete process.env[MODEL_PATH_VAR];\n  });\n  afterEach(() => {\n    delete process.env[FLAG];\n    delete process.env[MODEL_PATH_VAR];\n    rmSync(dir, { recursive: true, force: true });\n  });\n\n  it('leaves value at the rebalance-only path when the flag is unset, even with a model configured', () => {\n    const baseline = computeResultConfidence(sample)[0].confidence.value;\n\n    // A model that would collapse everything to ~0 if it were applied.\n    const flatModel: CalibrationModel = {\n      method: 'isotonic',\n      points: [{ x: 0, y: 0.01 }, { x: 1, y: 0.01 }],\n      fittedFrom: 2,\n    };\n    const p = join(dir, 'flat.json');\n    writeFileSync(p, JSON.stringify(flatModel));\n    process.env[MODEL_PATH_VAR] = p;\n    // Flag still OFF — model must be ignored.\n\n    const withModelButFlagOff = computeResultConfidence(sample)[0].confidence.value;\n    expect(withModelButFlagOff).toBeCloseTo(baseline, 6);\n  });\n\n  it('applies the model only when the flag is ON and a model is configured', () => {\n    const baseline = computeResultConfidence(sample)[0].confidence.value;\n    expect(baseline).toBeGreaterThan(0.1); // rebalance-only value is healthy\n\n    const flatModel: CalibrationModel = {\n      method: 'isotonic',\n      points: [{ x: 0, y: 0.01 }, { x: 1, y: 0.01 }],\n      fittedFrom: 2,\n    };\n    const p = join(dir, 'flat.json');\n    writeFileSync(p, JSON.stringify(flatModel));\n    process.env[MODEL_PATH_VAR] = p;\n    process.env[FLAG] = 'true';\n\n    const calibrated = computeResultConfidence(sample)[0].confidence.value;\n    expect(calibrated).toBeLessThan(baseline);\n    expect(calibrated).toBeCloseTo(0.01, 3);\n  });\n});","lineStart":1,"lineEnd":314,"totalLines":314,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/confidence-calibration.vitest.ts","time":{"start":1781757752955,"end":1781757752958}},"metadata":{"openai":{"itemId":"fc_0476bff5faf47e28016a337738d20c819189c17f75e3edfc89"}},"id":"prt_ed909b67a001BSg6q5dJR6KUwq","sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","messageID":"msg_ed909783c001aytDnrba8vGXQc"}}
{"type":"tool_use","timestamp":1781757752969,"sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","part":{"type":"tool","tool":"read","callID":"call_HNmy5SSlIRpYr5vx5mixsYR1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/017-search-and-output-intelligence-implementation/004-confidence-calibration-labeled-set/assets/fit-calibration.mjs","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/017-search-and-output-intelligence-implementation/004-confidence-calibration-labeled-set/assets/fit-calibration.mjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ───────────────────────────────────────────────────────────────\n3: // Confidence-calibration STARTER seed generator (CORPUS-DERIVED PROXY)\n4: // ───────────────────────────────────────────────────────────────\n5: // Emits two artifacts next to this script:\n6: //   - confidence-labeled-set.starter.json   ({query, memoryId, relevant}[])\n7: //   - confidence-calibration-model.starter.json   (fitted isotonic model)\n8: //\n9: // ⚠️ THIS IS A PROXY, NOT GROUND TRUTH. The \"labels\" are derived from the\n10: // indexed spec corpus: a spec's own title/keywords become the query and that\n11: // spec's memory is the positive; a different spec is the negative. The\n12: // per-pair rawValue is a keyword Jaccard overlap — a weak stand-in for the\n13: // real cosine confidence the live pipeline would assign. The fitted model is\n14: // therefore UNVALIDATED and must not be trusted for production ranking.\n15: //\n16: // The real labeled set is ~50–100 human-judged pairs sampled from live\n17: // `memory_search` traffic, joined to the rawValue the pipeline actually scored\n18: // each pair. That collection is the documented follow-up; this seed only\n19: // proves the fit/apply machinery end-to-end on representative shapes.\n20: //\n21: // Usage:  node fit-calibration.mjs [--limit N] [--specs <dir>]\n22: \n23: import { readFileSync, writeFileSync, readdirSync, statSync } from 'node:fs';\n24: import { join, dirname, relative } from 'node:path';\n25: import { fileURLToPath } from 'node:url';\n26: \n27: const HERE = dirname(fileURLToPath(import.meta.url));\n28: const REPO_ROOT = join(HERE, '../../../../../../../..'); // assets/ -> repo root (8 levels)\n29: const args = process.argv.slice(2);\n30: const limitArg = args.indexOf('--limit');\n31: const PAIR_DOCS = limitArg >= 0 ? Number(args[limitArg + 1]) : 50; // 50 docs -> ~100 pairs\n32: const specsArg = args.indexOf('--specs');\n33: const SPECS_DIR = specsArg >= 0 ? args[specsArg + 1] : join(REPO_ROOT, '.opencode/specs');\n34: \n35: // -- Corpus walk --\n36: \n37: function findDescriptions(root) {\n38:   const out = [];\n39:   const stack = [root];\n40:   while (stack.length) {\n41:     const dir = stack.pop();\n42:     let entries;\n43:     try {\n44:       entries = readdirSync(dir, { withFileTypes: true });\n45:     } catch {\n46:       continue;\n47:     }\n48:     for (const e of entries) {\n49:       const p = join(dir, e.name);\n50:       if (e.isDirectory()) {\n51:         stack.push(p);\n52:       } else if (e.name === 'description.json') {\n53:         out.push(p);\n54:       }\n55:     }\n56:   }\n57:   return out;\n58: }\n59: \n60: function loadDoc(path) {\n61:   try {\n62:     const d = JSON.parse(readFileSync(path, 'utf8'));\n63:     const keywords = Array.isArray(d.keywords)\n64:       ? d.keywords.filter((k) => typeof k === 'string' && k.length > 2)\n65:       : [];\n66:     const description = typeof d.description === 'string' ? d.description : '';\n67:     if (keywords.length < 4 || description.length < 40) return null;\n68:     return {\n69:       id: relative(REPO_ROOT, dirname(path)),\n70:       slug: typeof d.folderSlug === 'string' ? d.folderSlug : '',\n71:       keywords,\n72:     };\n73:   } catch {\n74:     return null;\n75:   }\n76: }\n77: \n78: // -- Proxy rawValue: keyword Jaccard overlap (weak stand-in for cosine) --\n79: \n80: function jaccard(a, b) {\n81:   const sa = new Set(a);\n82:   const sb = new Set(b);\n83:   let inter = 0;\n84:   for (const x of sa) if (sb.has(x)) inter++;\n85:   const union = sa.size + sb.size - inter;\n86:   return union === 0 ? 0 : inter / union;\n87: }\n88: \n89: function queryTerms(doc) {\n90:   // The query is the doc's own leading keywords — the \"title/anchor phrase as\n91:   // query\" proxy. Deliberately a SUBSET so the positive overlap is high but < 1.\n92:   return doc.keywords.slice(0, 6);\n93: }\n94: \n95: // -- Isotonic fit (PAV), mirrors lib/search/confidence-calibration.ts --\n96: \n97: function fitCalibration(samples) {\n98:   const clean = samples\n99:     .filter((s) => Number.isFinite(s.rawValue) && (s.relevant === 0 || s.relevant === 1))\n100:     .map((s) => ({ x: Math.max(0, Math.min(1, s.rawValue)), y: s.relevant }))\n101:     .sort((a, b) => a.x - b.x);\n102:   if (clean.length === 0) return { method: 'isotonic', points: [], fittedFrom: 0 };\n103:   const blocks = [];\n104:   for (const { x, y } of clean) {\n105:     blocks.push({ sumX: x, sumY: y, count: 1 });\n106:     while (blocks.length >= 2) {\n107:       const curr = blocks[blocks.length - 1];\n108:       const prev = blocks[blocks.length - 2];\n109:       if (prev.sumY / prev.count <= curr.sumY / curr.count) break;\n110:       prev.sumX += curr.sumX;\n111:       prev.sumY += curr.sumY;\n112:       prev.count += curr.count;\n113:       blocks.pop();\n114:     }\n115:   }\n116:   return {\n117:     method: 'isotonic',\n118:     points: blocks.map((b) => ({\n119:       x: b.sumX / b.count,\n120:       y: Math.max(0, Math.min(1, b.sumY / b.count)),\n121:     })),\n122:     fittedFrom: clean.length,\n123:   };\n124: }\n125: \n126: // -- Build --\n127: \n128: const docs = findDescriptions(SPECS_DIR)\n129:   .map(loadDoc)\n130:   .filter(Boolean);\n131: \n132: // Stable selection (sorted by id) so reruns are deterministic.\n133: docs.sort((a, b) => a.id.localeCompare(b.id));\n134: const seen = new Set();\n135: const selected = [];\n136: for (const d of docs) {\n137:   if (seen.has(d.slug)) continue;\n138:   seen.add(d.slug);\n139:   selected.push(d);\n140:   if (selected.length >= PAIR_DOCS) break;\n141: }\n142: \n143: const labeled = [];\n144: const samples = [];\n145: for (let i = 0; i < selected.length; i++) {\n146:   const doc = selected[i];\n147:   const q = queryTerms(doc);\n148:   const query = q.join(' ');\n149:   // Positive: the doc's own memory. rawValue = overlap(query, its own keywords).\n150:   const pos = jaccard(q, doc.keywords);\n151:   labeled.push({ query, memoryId: doc.id, relevant: 1 });\n152:   samples.push({ rawValue: pos, relevant: 1 });\n153:   // Negative: a different doc, picked far away in the sorted list to minimize\n154:   // accidental topical overlap.\n155:   const neg = selected[(i + Math.floor(selected.length / 2)) % selected.length];\n156:   if (neg && neg.id !== doc.id) {\n157:     const negVal = jaccard(q, neg.keywords);\n158:     labeled.push({ query, memoryId: neg.id, relevant: 0 });\n159:     samples.push({ rawValue: negVal, relevant: 0 });\n160:   }\n161: }\n162: \n163: const model = fitCalibration(samples);\n164: \n165: const labeledPath = join(HERE, 'confidence-labeled-set.starter.json');\n166: const modelPath = join(HERE, 'confidence-calibration-model.starter.json');\n167: \n168: writeFileSync(\n169:   labeledPath,\n170:   JSON.stringify(\n171:     {\n172:       _note:\n173:         'CORPUS-DERIVED PROXY, NOT human-judged traffic. Spec keywords as query, the spec memory as positive, a mismatched spec as negative. Replace with ~50-100 labeled pairs from live memory_search before trusting any fitted model.',\n174:       generatedFrom: relative(REPO_ROOT, SPECS_DIR),\n175:       docCount: selected.length,\n176:       pairs: labeled,\n177:     },\n178:     null,\n179:     2,\n180:   ),\n181: );\n182: \n183: writeFileSync(\n184:   modelPath,\n185:   JSON.stringify(\n186:     {\n187:       ...model,\n188:       _note:\n189:         'UNVALIDATED: fitted from a keyword-overlap PROXY rawValue, not real pipeline cosine confidence. Demonstrates the fit/apply pipeline only. Do NOT wire as a production model (SPECKIT_CONFIDENCE_CALIBRATION stays OFF) until refit from live labeled traffic.',\n190:     },\n191:     null,\n192:     2,\n193:   ),\n194: );\n195: \n196: console.log(`labeled pairs: ${labeled.length} (${selected.length} docs)`);\n197: console.log(`model blocks:  ${model.points.length} (fittedFrom ${model.fittedFrom})`);\n198: console.log(`wrote ${relative(REPO_ROOT, labeledPath)}`);\n199: console.log(`wrote ${relative(REPO_ROOT, modelPath)}`);\n\n(End of file - total 199 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// Confidence-calibration STARTER seed generator (CORPUS-DERIVED PROXY)\n// ───────────────────────────────────────────────────────────────\n// Emits two artifacts next to this script:\n//   - confidence-labeled-set.starter.json   ({query, memoryId, relevant}[])\n//   - confidence-calibration-model.starter.json   (fitted isotonic model)\n//\n// ⚠️ THIS IS A PROXY, NOT GROUND TRUTH. The \"labels\" are derived from the\n// indexed spec corpus: a spec's own title/keywords become the query and that\n// spec's memory is the positive; a different spec is the negative. The\n// per-pair rawValue is a keyword Jaccard overlap — a weak stand-in for the\n// real cosine confidence the live pipeline would assign. The fitted model is\n// therefore UNVALIDATED and must not be trusted for production ranking.\n//\n// The real labeled set is ~50–100 human-judged pairs sampled from live\n// `memory_search` traffic, joined to the rawValue the pipeline actually scored\n// each pair. That collection is the documented follow-up; this seed only\n// proves the fit/apply machinery end-to-end on representative shapes.\n//","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/017-search-and-output-intelligence-implementation/004-confidence-calibration-labeled-set/assets/fit-calibration.mjs","text":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// Confidence-calibration STARTER seed generator (CORPUS-DERIVED PROXY)\n// ───────────────────────────────────────────────────────────────\n// Emits two artifacts next to this script:\n//   - confidence-labeled-set.starter.json   ({query, memoryId, relevant}[])\n//   - confidence-calibration-model.starter.json   (fitted isotonic model)\n//\n// ⚠️ THIS IS A PROXY, NOT GROUND TRUTH. The \"labels\" are derived from the\n// indexed spec corpus: a spec's own title/keywords become the query and that\n// spec's memory is the positive; a different spec is the negative. The\n// per-pair rawValue is a keyword Jaccard overlap — a weak stand-in for the\n// real cosine confidence the live pipeline would assign. The fitted model is\n// therefore UNVALIDATED and must not be trusted for production ranking.\n//\n// The real labeled set is ~50–100 human-judged pairs sampled from live\n// `memory_search` traffic, joined to the rawValue the pipeline actually scored\n// each pair. That collection is the documented follow-up; this seed only\n// proves the fit/apply machinery end-to-end on representative shapes.\n//\n// Usage:  node fit-calibration.mjs [--limit N] [--specs <dir>]\n\nimport { readFileSync, writeFileSync, readdirSync, statSync } from 'node:fs';\nimport { join, dirname, relative } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nconst HERE = dirname(fileURLToPath(import.meta.url));\nconst REPO_ROOT = join(HERE, '../../../../../../../..'); // assets/ -> repo root (8 levels)\nconst args = process.argv.slice(2);\nconst limitArg = args.indexOf('--limit');\nconst PAIR_DOCS = limitArg >= 0 ? Number(args[limitArg + 1]) : 50; // 50 docs -> ~100 pairs\nconst specsArg = args.indexOf('--specs');\nconst SPECS_DIR = specsArg >= 0 ? args[specsArg + 1] : join(REPO_ROOT, '.opencode/specs');\n\n// -- Corpus walk --\n\nfunction findDescriptions(root) {\n  const out = [];\n  const stack = [root];\n  while (stack.length) {\n    const dir = stack.pop();\n    let entries;\n    try {\n      entries = readdirSync(dir, { withFileTypes: true });\n    } catch {\n      continue;\n    }\n    for (const e of entries) {\n      const p = join(dir, e.name);\n      if (e.isDirectory()) {\n        stack.push(p);\n      } else if (e.name === 'description.json') {\n        out.push(p);\n      }\n    }\n  }\n  return out;\n}\n\nfunction loadDoc(path) {\n  try {\n    const d = JSON.parse(readFileSync(path, 'utf8'));\n    const keywords = Array.isArray(d.keywords)\n      ? d.keywords.filter((k) => typeof k === 'string' && k.length > 2)\n      : [];\n    const description = typeof d.description === 'string' ? d.description : '';\n    if (keywords.length < 4 || description.length < 40) return null;\n    return {\n      id: relative(REPO_ROOT, dirname(path)),\n      slug: typeof d.folderSlug === 'string' ? d.folderSlug : '',\n      keywords,\n    };\n  } catch {\n    return null;\n  }\n}\n\n// -- Proxy rawValue: keyword Jaccard overlap (weak stand-in for cosine) --\n\nfunction jaccard(a, b) {\n  const sa = new Set(a);\n  const sb = new Set(b);\n  let inter = 0;\n  for (const x of sa) if (sb.has(x)) inter++;\n  const union = sa.size + sb.size - inter;\n  return union === 0 ? 0 : inter / union;\n}\n\nfunction queryTerms(doc) {\n  // The query is the doc's own leading keywords — the \"title/anchor phrase as\n  // query\" proxy. Deliberately a SUBSET so the positive overlap is high but < 1.\n  return doc.keywords.slice(0, 6);\n}\n\n// -- Isotonic fit (PAV), mirrors lib/search/confidence-calibration.ts --\n\nfunction fitCalibration(samples) {\n  const clean = samples\n    .filter((s) => Number.isFinite(s.rawValue) && (s.relevant === 0 || s.relevant === 1))\n    .map((s) => ({ x: Math.max(0, Math.min(1, s.rawValue)), y: s.relevant }))\n    .sort((a, b) => a.x - b.x);\n  if (clean.length === 0) return { method: 'isotonic', points: [], fittedFrom: 0 };\n  const blocks = [];\n  for (const { x, y } of clean) {\n    blocks.push({ sumX: x, sumY: y, count: 1 });\n    while (blocks.length >= 2) {\n      const curr = blocks[blocks.length - 1];\n      const prev = blocks[blocks.length - 2];\n      if (prev.sumY / prev.count <= curr.sumY / curr.count) break;\n      prev.sumX += curr.sumX;\n      prev.sumY += curr.sumY;\n      prev.count += curr.count;\n      blocks.pop();\n    }\n  }\n  return {\n    method: 'isotonic',\n    points: blocks.map((b) => ({\n      x: b.sumX / b.count,\n      y: Math.max(0, Math.min(1, b.sumY / b.count)),\n    })),\n    fittedFrom: clean.length,\n  };\n}\n\n// -- Build --\n\nconst docs = findDescriptions(SPECS_DIR)\n  .map(loadDoc)\n  .filter(Boolean);\n\n// Stable selection (sorted by id) so reruns are deterministic.\ndocs.sort((a, b) => a.id.localeCompare(b.id));\nconst seen = new Set();\nconst selected = [];\nfor (const d of docs) {\n  if (seen.has(d.slug)) continue;\n  seen.add(d.slug);\n  selected.push(d);\n  if (selected.length >= PAIR_DOCS) break;\n}\n\nconst labeled = [];\nconst samples = [];\nfor (let i = 0; i < selected.length; i++) {\n  const doc = selected[i];\n  const q = queryTerms(doc);\n  const query = q.join(' ');\n  // Positive: the doc's own memory. rawValue = overlap(query, its own keywords).\n  const pos = jaccard(q, doc.keywords);\n  labeled.push({ query, memoryId: doc.id, relevant: 1 });\n  samples.push({ rawValue: pos, relevant: 1 });\n  // Negative: a different doc, picked far away in the sorted list to minimize\n  // accidental topical overlap.\n  const neg = selected[(i + Math.floor(selected.length / 2)) % selected.length];\n  if (neg && neg.id !== doc.id) {\n    const negVal = jaccard(q, neg.keywords);\n    labeled.push({ query, memoryId: neg.id, relevant: 0 });\n    samples.push({ rawValue: negVal, relevant: 0 });\n  }\n}\n\nconst model = fitCalibration(samples);\n\nconst labeledPath = join(HERE, 'confidence-labeled-set.starter.json');\nconst modelPath = join(HERE, 'confidence-calibration-model.starter.json');\n\nwriteFileSync(\n  labeledPath,\n  JSON.stringify(\n    {\n      _note:\n        'CORPUS-DERIVED PROXY, NOT human-judged traffic. Spec keywords as query, the spec memory as positive, a mismatched spec as negative. Replace with ~50-100 labeled pairs from live memory_search before trusting any fitted model.',\n      generatedFrom: relative(REPO_ROOT, SPECS_DIR),\n      docCount: selected.length,\n      pairs: labeled,\n    },\n    null,\n    2,\n  ),\n);\n\nwriteFileSync(\n  modelPath,\n  JSON.stringify(\n    {\n      ...model,\n      _note:\n        'UNVALIDATED: fitted from a keyword-overlap PROXY rawValue, not real pipeline cosine confidence. Demonstrates the fit/apply pipeline only. Do NOT wire as a production model (SPECKIT_CONFIDENCE_CALIBRATION stays OFF) until refit from live labeled traffic.',\n    },\n    null,\n    2,\n  ),\n);\n\nconsole.log(`labeled pairs: ${labeled.length} (${selected.length} docs)`);\nconsole.log(`model blocks:  ${model.points.length} (fittedFrom ${model.fittedFrom})`);\nconsole.log(`wrote ${relative(REPO_ROOT, labeledPath)}`);\nconsole.log(`wrote ${relative(REPO_ROOT, modelPath)}`);","lineStart":1,"lineEnd":199,"totalLines":199,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/017-search-and-output-intelligence-implementation/004-confidence-calibration-labeled-set/assets/fit-calibration.mjs","time":{"start":1781757752960,"end":1781757752966}},"metadata":{"openai":{"itemId":"fc_0476bff5faf47e28016a337738d210819183126e6a3626f89f"}},"id":"prt_ed909b67c001StLgJXZ6vT74ub","sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","messageID":"msg_ed909783c001aytDnrba8vGXQc"}}
{"type":"tool_use","timestamp":1781757752969,"sessionID":"ses_126f83aa4ffekBSRvWmpN9g5Xg","part":{"type":"tool","tool":"read","callID":"call_hjuxHmcEh5qaG9bsTXcaIiJY","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/017-search-and-output-intelligence-implementation/004-confidence-calibration-labeled-set/assets/confidence-labeled-set.starter.json","offset":1,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/017-search-and-output-intelligence-implementation/004-confidence-calibration-labeled-set/assets/confidence-labeled-set.starter.json</path>\n<type>file</type>\n<content>\n1: {\n2:   \"_note\": \"CORPUS-DERIVED PROXY, NOT human-judged traffic. Spec keywords as query, the spec memory as positive, a mismatched spec as negative. Replace with ~50-100 labeled pairs from live memory_search before trusting any fitted model.\",\n3:   \"generatedFrom\": \".opencode/specs\",\n4:   \"docCount\": 50,\n5:   \"pairs\": [\n6:     {\n7:       \"query\": \"system architecture barter agent ecosystem\",\n8:       \"memoryId\": \".opencode/specs/ai-systems/001-ai-system-architecture\",\n9:       \"relevant\": 1\n10:     },\n11:     {\n12:       \"query\": \"system architecture barter agent ecosystem\",\n13:       \"memoryId\": \".opencode/specs/barter/001-reel-video-flicker-expo\",\n14:       \"relevant\": 0\n15:     },\n16:     {\n17:       \"query\": \"two-runtime packaging architecture design copywriter pilot\",\n18:       \"memoryId\": \".opencode/specs/ai-systems/001-ai-system-architecture/001-two-runtime-packaging-design\",\n19:       \"relevant\": 1\n20:     },\n21:     {\n22:       \"query\": \"two-runtime packaging architecture design copywriter pilot\",\n23:       \"memoryId\": \"