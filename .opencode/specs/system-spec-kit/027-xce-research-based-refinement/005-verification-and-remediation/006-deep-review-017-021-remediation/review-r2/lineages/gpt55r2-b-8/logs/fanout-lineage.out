{"type":"tool_use","timestamp":1781763522598,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_tAJqBA5qYkKsPE5AcX8G7xbc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Index Scan Job Handlers\n3: // ───────────────────────────────────────────────────────────────\n4: // Status/cancel surface for background memory_index_scan jobs backed\n5: // by the kind-agnostic maintenance job store.\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n13: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n14: import {\n15:   getMaintenanceJob,\n16:   requestCancel,\n17:   isTerminalJobState,\n18:   type MaintenanceJob,\n19: } from '../lib/ops/job-store.js';\n20: \n21: import type { MCPResponse } from './types.js';\n22: \n23: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n24: \n25: /* ───────────────────────────────────────────────────────────────\n26:    2. TYPES\n27: ──────────────────────────────────────────────────────────────── */\n28: \n29: interface MemoryIndexScanStatusArgs {\n30:   jobId: string;\n31: }\n32: \n33: interface MemoryIndexScanCancelArgs {\n34:   jobId: string;\n35: }\n36: \n37: /* ───────────────────────────────────────────────────────────────\n38:    3. HELPERS\n39: ──────────────────────────────────────────────────────────────── */\n40: \n41: function progressPercent(job: MaintenanceJob): number {\n42:   if (job.progressTotal <= 0) return 0;\n43:   const raw = Math.round((job.progressProcessed / job.progressTotal) * 100);\n44:   return Math.max(0, Math.min(100, raw));\n45: }\n46: \n47: function mapScanJobForResponse(job: MaintenanceJob): Record<string, unknown> {\n48:   return {\n49:     jobId: job.id,\n50:     kind: job.kind,\n51:     state: job.state,\n52:     phase: job.phase,\n53:     progress: { processed: job.progressProcessed, total: job.progressTotal },\n54:     progressPercent: progressPercent(job),\n55:     cancelRequested: job.cancelRequested,\n56:     errors: job.errors,\n57:     result: job.result,\n58:     createdAt: job.createdAt,\n59:     updatedAt: job.updatedAt,\n60:   };\n61: }\n62: \n63: // Scan job tools own only index_scan jobs; an ingest jobId is not addressable here.\n64: function getScanJob(jobId: string): MaintenanceJob | null {\n65:   const job = getMaintenanceJob(jobId);\n66:   if (!job || job.kind !== 'index_scan') return null;\n67:   return job;\n68: }\n69: \n70: /* ───────────────────────────────────────────────────────────────\n71:    4. HANDLERS\n72: ──────────────────────────────────────────────────────────────── */\n73: \n74: async function handleMemoryIndexScanStatus(args: MemoryIndexScanStatusArgs): Promise<MCPResponse> {\n75:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan_status');\n76:   await checkDatabaseUpdated();\n77: \n78:   if (!args.jobId || typeof args.jobId !== 'string') {\n79:     throw new Error('jobId is required and must be a string');\n80:   }\n81: \n82:   const job = getScanJob(args.jobId);\n83:   if (!job) {\n84:     return createMCPErrorResponse({\n85:       tool: 'memory_index_scan_status',\n86:       error: `Index scan job not found: ${args.jobId}`,\n87:       code: 'E404',\n88:       details: { jobId: args.jobId },\n89:       recovery: {\n90:         hint: 'Verify the jobId and retry.',\n91:         actions: ['Call memory_index_scan with background:true to create a new background scan job'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   return createMCPSuccessResponse({\n98:     tool: 'memory_index_scan_status',\n99:     summary: `Index scan job ${job.id}: ${job.state}${job.phase ? ` (${job.phase})` : ''}`,\n100:     data: mapScanJobForResponse(job),\n101:   });\n102: }\n103: \n104: async function handleMemoryIndexScanCancel(args: MemoryIndexScanCancelArgs): Promise<MCPResponse> {\n105:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan_cancel');\n106:   await checkDatabaseUpdated();\n107: \n108:   if (!args.jobId || typeof args.jobId !== 'string') {\n109:     throw new Error('jobId is required and must be a string');\n110:   }\n111: \n112:   const job = getScanJob(args.jobId);\n113:   if (!job) {\n114:     return createMCPErrorResponse({\n115:       tool: 'memory_index_scan_cancel',\n116:       error: `Index scan job not found: ${args.jobId}`,\n117:       code: 'E404',\n118:       details: { jobId: args.jobId },\n119:       recovery: {\n120:         hint: 'Verify the jobId and retry.',\n121:         actions: ['Call memory_index_scan_status with a known jobId'],\n122:         severity: 'warning',\n123:       },\n124:     });\n125:   }\n126: \n127:   if (isTerminalJobState(job.state)) {\n128:     return createMCPSuccessResponse({\n129:       tool: 'memory_index_scan_cancel',\n130:       summary: `Index scan job ${job.id} is already terminal (${job.state})`,\n131:       data: mapScanJobForResponse(job),\n132:     });\n133:   }\n134: \n135:   await requestCancel(args.jobId);\n136:   const updated = getScanJob(args.jobId) ?? job;\n137: \n138:   return createMCPSuccessResponse({\n139:     tool: 'memory_index_scan_cancel',\n140:     summary: `Cancellation requested for index scan job ${updated.id}`,\n141:     data: mapScanJobForResponse(updated),\n142:   });\n143: }\n144: \n145: /* ───────────────────────────────────────────────────────────────\n146:    5. EXPORTS\n147: ──────────────────────────────────────────────────────────────── */\n148: \n149: const handle_memory_index_scan_status = handleMemoryIndexScanStatus;\n150: const handle_memory_index_scan_cancel = handleMemoryIndexScanCancel;\n151: \n152: export {\n153:   handleMemoryIndexScanStatus,\n154:   handleMemoryIndexScanCancel,\n155:   mapScanJobForResponse,\n156:   handle_memory_index_scan_status,\n157:   handle_memory_index_scan_cancel,\n158: };\n\n(End of file - total 158 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index Scan Job Handlers\n// ───────────────────────────────────────────────────────────────\n// Status/cancel surface for background memory_index_scan jobs backed\n// by the kind-agnostic maintenance job store.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  getMaintenanceJob,\n  requestCancel,\n  isTerminalJobState,\n  type MaintenanceJob,\n} from '../lib/ops/job-store.js';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index Scan Job Handlers\n// ───────────────────────────────────────────────────────────────\n// Status/cancel surface for background memory_index_scan jobs backed\n// by the kind-agnostic maintenance job store.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  getMaintenanceJob,\n  requestCancel,\n  isTerminalJobState,\n  type MaintenanceJob,\n} from '../lib/ops/job-store.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface MemoryIndexScanStatusArgs {\n  jobId: string;\n}\n\ninterface MemoryIndexScanCancelArgs {\n  jobId: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction progressPercent(job: MaintenanceJob): number {\n  if (job.progressTotal <= 0) return 0;\n  const raw = Math.round((job.progressProcessed / job.progressTotal) * 100);\n  return Math.max(0, Math.min(100, raw));\n}\n\nfunction mapScanJobForResponse(job: MaintenanceJob): Record<string, unknown> {\n  return {\n    jobId: job.id,\n    kind: job.kind,\n    state: job.state,\n    phase: job.phase,\n    progress: { processed: job.progressProcessed, total: job.progressTotal },\n    progressPercent: progressPercent(job),\n    cancelRequested: job.cancelRequested,\n    errors: job.errors,\n    result: job.result,\n    createdAt: job.createdAt,\n    updatedAt: job.updatedAt,\n  };\n}\n\n// Scan job tools own only index_scan jobs; an ingest jobId is not addressable here.\nfunction getScanJob(jobId: string): MaintenanceJob | null {\n  const job = getMaintenanceJob(jobId);\n  if (!job || job.kind !== 'index_scan') return null;\n  return job;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HANDLERS\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryIndexScanStatus(args: MemoryIndexScanStatusArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan_status');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getScanJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan_status',\n      error: `Index scan job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_index_scan with background:true to create a new background scan job'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan_status',\n    summary: `Index scan job ${job.id}: ${job.state}${job.phase ? ` (${job.phase})` : ''}`,\n    data: mapScanJobForResponse(job),\n  });\n}\n\nasync function handleMemoryIndexScanCancel(args: MemoryIndexScanCancelArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan_cancel');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getScanJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan_cancel',\n      error: `Index scan job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_index_scan_status with a known jobId'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (isTerminalJobState(job.state)) {\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan_cancel',\n      summary: `Index scan job ${job.id} is already terminal (${job.state})`,\n      data: mapScanJobForResponse(job),\n    });\n  }\n\n  await requestCancel(args.jobId);\n  const updated = getScanJob(args.jobId) ?? job;\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan_cancel',\n    summary: `Cancellation requested for index scan job ${updated.id}`,\n    data: mapScanJobForResponse(updated),\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nconst handle_memory_index_scan_status = handleMemoryIndexScanStatus;\nconst handle_memory_index_scan_cancel = handleMemoryIndexScanCancel;\n\nexport {\n  handleMemoryIndexScanStatus,\n  handleMemoryIndexScanCancel,\n  mapScanJobForResponse,\n  handle_memory_index_scan_status,\n  handle_memory_index_scan_cancel,\n};","lineStart":1,"lineEnd":158,"totalLines":158,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","time":{"start":1781763522530,"end":1781763522587}},"metadata":{"openai":{"itemId":"fc_07d11185e93d73e2016a338dc1a44c8191a4d7046ad8eb2c73"}},"id":"prt_ed961bfdd001Z0Jmv91bIRJG87","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed9618031001aMd6sS9Tw21zdA"}}
{"type":"tool_use","timestamp":1781763522598,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_9Brje9BfK5u7hFqa252GxcRV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n11: \n12: import type { MCPResponse } from './types.js';\n13: import type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n14: \n15: /** Handle the memory_retention_sweep MCP tool request. */\n16: async function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n17:   await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n18:   await checkDatabaseUpdated();\n19: \n20:   const database = vectorIndex.getDb();\n21:   if (!database) {\n22:     recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n23:     return createMCPErrorResponse({\n24:       tool: 'memory_retention_sweep',\n25:       error: 'Retention sweep aborted: database unavailable',\n26:       code: 'E_DB_UNAVAILABLE',\n27:       details: {\n28:         dryRun: args?.dryRun === true,\n29:       },\n30:       recovery: {\n31:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n32:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n33:         severity: 'error',\n34:       },\n35:     });\n36:   }\n37: \n38:   try {\n39:     const result = runMemoryRetentionSweep(database, {\n40:       dryRun: args?.dryRun === true,\n41:       feedbackRetention: args?.feedbackRetention,\n42:     });\n43:     const protectedSuffix = result.protectedCount > 0\n44:       ? `; protected ${result.protectedCount} high-tier/pinned row(s)`\n45:       : '';\n46:     const summary = result.dryRun\n47:       ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted${protectedSuffix}`\n48:       : `Swept ${result.swept} expired memory row(s); retained ${result.retained}${protectedSuffix}`;\n49: \n50:     const hints: string[] = [];\n51:     if (result.ledgerRecorded === false) {\n52:       hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n53:     }\n54:     if (result.dryRun && result.candidates.length > 0) {\n55:       hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n56:     }\n57:     recordMaintenanceRun('memory_retention_sweep', {\n58:       status: 'success',\n59:       counts: {\n60:         swept: result.swept,\n61:         retained: result.retained,\n62:         candidates: result.candidates.length,\n63:         protectedCount: result.protectedCount,\n64:       },\n65:       staleCandidates: result.candidates.length,\n66:     });\n67: \n68:     return createMCPSuccessResponse({\n69:       tool: 'memory_retention_sweep',\n70:       summary,\n71:       data: {\n72:         swept: result.swept,\n73:         retained: result.retained,\n74:         dryRun: result.dryRun,\n75:         durationMs: result.durationMs,\n76:         candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n77:           id: candidate.id,\n78:           deleteAfter: candidate.deleteAfter,\n79:           specFolder: candidate.specFolder,\n80:           filePath: candidate.filePath,\n81:         })),\n82:         deletedIds: result.deletedIds,\n83:         protectedCount: result.protectedCount,\n84:         protectedIds: result.protectedIds,\n85:         ledgerRecorded: result.ledgerRecorded,\n86:         ...(result.feedbackRetention ? {\n87:           feedbackRetention: {\n88:             mode: result.feedbackRetention.mode,\n89:             activeGatePassed: result.feedbackRetention.activeGatePassed,\n90:             activeBlocked: result.feedbackRetention.activeBlocked,\n91:             auditCount: result.feedbackRetention.auditCount,\n92:             protectedCount: result.feedbackRetention.protectedIds.length,\n93:             extendedCount: result.feedbackRetention.extendedIds.length,\n94:             deletedCount: result.feedbackRetention.deletedIds.length,\n95:           },\n96:           extendedIds: result.feedbackRetention.extendedIds,\n97:         } : {}),\n98:       },\n99:       hints,\n100:     });\n101:   } catch (error: unknown) {\n102:     recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n103:     return createMCPErrorResponse({\n104:       tool: 'memory_retention_sweep',\n105:       error: `Retention sweep failed: ${toErrorMessage(error)}`,\n106:       code: 'E_RETENTION_SWEEP_FAILED',\n107:       details: {\n108:         dryRun: args?.dryRun === true,\n109:       },\n110:       recovery: {\n111:         hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n112:         actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n113:         severity: 'error',\n114:       },\n115:     });\n116:   }\n117: }\n118: \n119: export { handleMemoryRetentionSweep };\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: 'Retention sweep aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  try {\n    const result = runMemoryRetentionSweep(database, {\n      dryRun: args?.dryRun === true,\n      feedbackRetention: args?.feedbackRetention,\n    });\n    const protectedSuffix = result.protectedCount > 0\n      ? `; protected ${result.protectedCount} high-tier/pinned row(s)`\n      : '';\n    const summary = result.dryRun\n      ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted${protectedSuffix}`\n      : `Swept ${result.swept} expired memory row(s); retained ${result.retained}${protectedSuffix}`;\n\n    const hints: string[] = [];\n    if (result.ledgerRecorded === false) {\n      hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n    }\n    if (result.dryRun && result.candidates.length > 0) {\n      hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n    }\n    recordMaintenanceRun('memory_retention_sweep', {\n      status: 'success',\n      counts: {\n        swept: result.swept,\n        retained: result.retained,\n        candidates: result.candidates.length,\n        protectedCount: result.protectedCount,\n      },\n      staleCandidates: result.candidates.length,\n    });\n\n    return createMCPSuccessResponse({\n      tool: 'memory_retention_sweep',\n      summary,\n      data: {\n        swept: result.swept,\n        retained: result.retained,\n        dryRun: result.dryRun,\n        durationMs: result.durationMs,\n        candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n          id: candidate.id,\n          deleteAfter: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        })),\n        deletedIds: result.deletedIds,\n        protectedCount: result.protectedCount,\n        protectedIds: result.protectedIds,\n        ledgerRecorded: result.ledgerRecorded,\n        ...(result.feedbackRetention ? {\n          feedbackRetention: {\n            mode: result.feedbackRetention.mode,\n            activeGatePassed: result.feedbackRetention.activeGatePassed,\n            activeBlocked: result.feedbackRetention.activeBlocked,\n            auditCount: result.feedbackRetention.auditCount,\n            protectedCount: result.feedbackRetention.protectedIds.length,\n            extendedCount: result.feedbackRetention.extendedIds.length,\n            deletedCount: result.feedbackRetention.deletedIds.length,\n          },\n          extendedIds: result.feedbackRetention.extendedIds,\n        } : {}),\n      },\n      hints,\n    });\n  } catch (error: unknown) {\n    recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: `Retention sweep failed: ${toErrorMessage(error)}`,\n      code: 'E_RETENTION_SWEEP_FAILED',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n        actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryRetentionSweep };","lineStart":1,"lineEnd":119,"totalLines":119,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","time":{"start":1781763522535,"end":1781763522589}},"metadata":{"openai":{"itemId":"fc_07d11185e93d73e2016a338dc1a4548191af1c7e807e595d8a"}},"id":"prt_ed961bfe3001qTlziXX8va92Z3","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed9618031001aMd6sS9Tw21zdA"}}
{"type":"tool_use","timestamp":1781763522598,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_JfKNsM2FhcnprLfz1SzlkiqK","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Bulk Delete\n3: // ────────────────────────────────────────────────────────────────\n4: // Tier-based bulk deletion of memories with safety gates.\n5: // Eliminates the need for direct DB scripts when cleaning up\n6: // Deprecated/temporary memories at scale.\n7: import { checkDatabaseUpdated } from '../core/index.js';\n8: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n9: import * as vectorIndex from '../lib/search/vector-index.js';\n10: import * as checkpoints from '../lib/storage/checkpoints.js';\n11: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { createStatediffAction } from '../lib/storage/statediff.js';\n14: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { recordHistory } from '../lib/storage/history.js';\n18: import { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\n19: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: \n23: import type { MCPResponse } from './types.js';\n24: \n25: // Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n26: // Feature catalog: Per-memory history log\n27: \n28: /* ───────────────────────────────────────────────────────────────\n29:    1. TYPES\n30: ──────────────────────────────────────────────────────────────── */\n31: \n32: interface BulkDeleteArgs {\n33:   tier: string;\n34:   specFolder?: string;\n35:   confirm: boolean;\n36:   olderThanDays?: number;\n37:   skipCheckpoint?: boolean;\n38: }\n39: \n40: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n41:   if (!database || !('prepare' in database)) return false;\n42:   try {\n43:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n44:     return columns.some((column) => column.name === 'deleted_at');\n45:   } catch {\n46:     return false;\n47:   }\n48: }\n49: \n50: function isSoftDeleteTombstonesEnabled(): boolean {\n51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n52: }\n53: \n54: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n55:   if (!isSoftDeleteTombstonesEnabled()) {\n56:     return vectorIndex.deleteMemory(memoryId, database);\n57:   }\n58: \n59:   if (!hasDeletedAtColumn(database)) {\n60:     return vectorIndex.deleteMemory(memoryId, database);\n61:   }\n62: \n63:   const deletedAt = new Date().toISOString();\n64:   const result = database.prepare(`\n65:     UPDATE memory_index\n66:     SET deleted_at = COALESCE(deleted_at, ?),\n67:         updated_at = datetime('now')\n68:     WHERE id = ?\n69:   `).run(deletedAt, memoryId);\n70:   return result.changes > 0;\n71: }\n72: \n73: /* ───────────────────────────────────────────────────────────────\n74:     2. HANDLER\n75: ──────────────────────────────────────────────────────────────── */\n76: \n77: async function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n78:   await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n79:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n80:   if (restoreBarrier) {\n81:     return createMCPErrorResponse({\n82:       tool: 'memory_bulk_delete',\n83:       error: restoreBarrier.message,\n84:       code: restoreBarrier.code,\n85:       details: {\n86:         tier: args.tier ?? null,\n87:         specFolder: args.specFolder ?? null,\n88:       },\n89:       recovery: {\n90:         hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n91:         actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   await checkDatabaseUpdated();\n98: \n99:   const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n100: \n101:   // Validation\n102:   if (!tier || typeof tier !== 'string') {\n103:     throw new Error('tier is required and must be a string');\n104:   }\n105: \n106:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n107:   if (!validTiers.includes(tier)) {\n108:     throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n109:   }\n110: \n111:   if (!confirm) {\n112:     throw new Error('Bulk delete requires confirm: true as a safety gate');\n113:   }\n114: \n115:   // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n116:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n117:     throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n118:   }\n119: \n120:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n121:     throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n122:   }\n123: \n124:   if (\n125:     olderThanDays !== undefined\n126:     && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n127:   ) {\n128:     throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n129:   }\n130: \n131:   const database = vectorIndex.getDb();\n132:   if (!database) {\n133:     return createMCPErrorResponse({\n134:       tool: 'memory_bulk_delete',\n135:       error: 'Memory bulk delete aborted: database unavailable',\n136:       code: 'E_DB_UNAVAILABLE',\n137:       details: {\n138:         tier,\n139:         specFolder: specFolder || null,\n140:         olderThanDays: olderThanDays || null,\n141:       },\n142:       recovery: {\n143:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n144:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n145:         severity: 'error',\n146:       },\n147:     });\n148:   }\n149: \n150:   // Build query to count affected memories\n151:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n152:   const countParams: unknown[] = [tier];\n153: \n154:   if (specFolder) {\n155:     countSql += ' AND spec_folder = ?';\n156:     countParams.push(specFolder);\n157:   }\n158: \n159:   if (olderThanDays !== undefined) {\n160:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n161:     countParams.push(olderThanDays);\n162:   }\n163: \n164:   const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n165:   const affectedCount = countResult.count;\n166: \n167:   if (affectedCount === 0) {\n168:     return createMCPSuccessResponse({\n169:       tool: 'memory_bulk_delete',\n170:       summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n172:       hints: ['Use memory_list() to browse existing memories'],\n173:     });\n174:   }\n175: \n176:   // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n177:   let checkpointName: string | null = null;\n178:   if (!skipCheckpoint) {\n179:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n181: \n182:     try {\n183:       const checkpoint = checkpoints.createCheckpoint({\n184:         name: proposedCheckpointName,\n185:         specFolder,\n186:         metadata: {\n187:           reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n188:           tier,\n189:           affectedCount,\n190:           olderThanDays: olderThanDays || null,\n191:         },\n192:       });\n193: \n194:       if (!checkpoint) {\n195:         const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n196:         if (tier === 'constitutional' || tier === 'critical') {\n197:           throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n198:         }\n199:         console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n200:       } else {\n201:         checkpointName = checkpoint.name;\n202:         console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n203:       }\n204:     } catch (cpErr: unknown) {\n205:       const message = toErrorMessage(cpErr);\n206:       console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n207:       // High-safety tiers require a valid checkpoint.\n208:       if (tier === 'constitutional' || tier === 'critical') {\n209:         throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n210:       }\n211:       // Lower tiers can proceed with explicit no-rollback notice.\n212:       checkpointName = null;\n213:     }\n214:   } else {\n215:     console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n216:   }\n217: \n218:   // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n219:   let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n220:   const selectParams: unknown[] = [tier];\n221: \n222:   if (specFolder) {\n223:     selectSql += ' AND spec_folder = ?';\n224:     selectParams.push(specFolder);\n225:   }\n226: \n227:   if (olderThanDays !== undefined) {\n228:     selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n229:     selectParams.push(olderThanDays);\n230:   }\n231: \n232:   const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n233:     id: number;\n234:     content_hash: string | null;\n235:     file_path: string | null;\n236:     spec_folder: string | null;\n237:   }>;\n238: \n239:   // Perform deletion in a transaction\n240:   let deletedCount = 0;\n241:   const deletedIds: number[] = [];\n242: \n243:   causalEdges.init(database);\n244: \n245:   const bulkDeleteTx = database.transaction(() => {\n246:     for (const memory of memoriesToDelete) {\n247:       if (tombstoneMemory(database, memory.id)) {\n248:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n249:         try {\n250:           recordHistory(\n251:             memory.id,\n252:             'DELETE',\n253:             memory.file_path ?? null,\n254:             null,\n255:             'mcp:memory_bulk_delete',\n256:             memory.spec_folder ?? null,\n257:           );\n258:         } catch (_histErr: unknown) {\n259:           // History recording is best-effort inside bulk delete\n260:         }\n261:         deletedCount++;\n262:         deletedIds.push(memory.id);\n263: \n264:         // Clean up causal edges\n265:         // Propagate edge-cleanup errors to fail the transaction.\n266:         // Previously errors were caught and logged, leaving orphan causal edges\n267:         // When memory rows were successfully deleted but edge cleanup failed.\n268:         causalEdges.deleteEdgesForMemory(String(memory.id), {\n269:           reason: 'memory row mutation cleanup',\n270:           command: 'memory-bulk-delete.handleMemoryBulkDelete',\n271:           restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n272:         });\n273:       }\n274:     }\n275:   });\n276: \n277:   bulkDeleteTx();\n278: \n279:   // Record in mutation ledger (single entry for bulk operation)\n280:   const ledgerRecorded = appendMutationLedgerSafe(database, {\n281:     mutationType: 'delete',\n282:     reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n283:     priorHash: null,\n284:     newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n285:     linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n286:     decisionMeta: {\n287:       tool: 'memory_bulk_delete',\n288:       tier,\n289:       specFolder: specFolder || null,\n290:       olderThanDays: olderThanDays || null,\n291:       totalDeleted: deletedCount,\n292:       checkpoint: checkpointName,\n293:       skipCheckpoint,\n294:     },\n295:     actor: 'mcp:memory_bulk_delete',\n296:   });\n297: \n298:   // Invalidate caches\n299:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n300:   if (deletedCount > 0) {\n301:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n302:     try {\n303:       postMutationHooks = runPostMutationHooks('bulk-delete', {\n304:         specFolder,\n305:         tier,\n306:         deletedCount,\n307:         statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n308:           target: 'memory_index',\n309:           key: String(id),\n310:           sourceOperation: 'bulk-delete',\n311:           metadata: { tier, specFolder: specFolder ?? null },\n312:         })),\n313:       });\n314:     } catch (hookError: unknown) {\n315:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n316:       postMutationHooks = {\n317:         latencyMs: 0, triggerCacheCleared: false,\n318:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n319:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n320:         errors: [msg],\n321:       };\n322:     }\n323:     postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n324:   }\n325: \n326:   const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n327: \n328:   const hints: string[] = [];\n329:   if (checkpointName) {\n330:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n331:   } else if (skipCheckpoint) {\n332:     hints.push('Checkpoint skipped: restore is not available for this operation');\n333:   }\n334:   if (postMutationFeedback) {\n335:     hints.push(...postMutationFeedback.hints);\n336:   }\n337:   if (!ledgerRecorded) {\n338:     hints.push('Mutation ledger append failed; audit trail may be incomplete.');\n339:   }\n340:   hints.push(`Run memory_index_scan({ force: true }) to re-index if needed`);\n341: \n342:   const data: Record<string, unknown> = {\n343:     deleted: deletedCount,\n344:     tier,\n345:     specFolder: specFolder || null,\n346:     olderThanDays: olderThanDays || null,\n347:     skipCheckpoint,\n348:   };\n349:   if (checkpointName) {\n350:     data.checkpoint = checkpointName;\n351:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n352:   }\n353:   if (postMutationFeedback) {\n354:     data.postMutationHooks = postMutationFeedback.data;\n355:   }\n356:   if (!ledgerRecorded) {\n357:     data.warning = 'Mutation ledger append failed; audit trail may be incomplete.';\n358:   }\n359: \n360:   return createMCPSuccessResponse({\n361:     tool: 'memory_bulk_delete',\n362:     summary,\n363:     data,\n364:     hints,\n365:   });\n366: }\n367: \n368: /* ───────────────────────────────────────────────────────────────\n369:    3. EXPORTS\n370: ──────────────────────────────────────────────────────────────── */\n371: \n372: export { handleMemoryBulkDelete };\n\n(End of file - total 372 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n// Feature catalog: Per-memory history log\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n    2. HANDLER\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        tier: args.tier ?? null,\n        specFolder: args.specFolder ?? null,\n      },\n      recovery: {\n        hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n\n  // Validation\n  if (!tier || typeof tier !== 'string') {\n    throw new Error('tier is required and must be a string');\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n  }\n\n  if (!confirm) {\n    throw new Error('Bulk delete requires confirm: true as a safety gate');\n  }\n\n  // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n  }\n\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n  }\n\n  if (\n    olderThanDays !== undefined\n    && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n  ) {\n    throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n  }\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: 'Memory bulk delete aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        tier,\n        specFolder: specFolder || null,\n        olderThanDays: olderThanDays || null,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Build query to count affected memories\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(olderThanDays);\n  }\n\n  const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  if (affectedCount === 0) {\n    return createMCPSuccessResponse({\n      tool: 'memory_bulk_delete',\n      summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n      data: { deleted: 0, tier, specFolder: specFolder || null },\n      hints: ['Use memory_list() to browse existing memories'],\n    });\n  }\n\n  // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n    try {\n      const checkpoint = checkpoints.createCheckpoint({\n        name: proposedCheckpointName,\n        specFolder,\n        metadata: {\n          reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n          tier,\n          affectedCount,\n          olderThanDays: olderThanDays || null,\n        },\n      });\n\n      if (!checkpoint) {\n        const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n        if (tier === 'constitutional' || tier === 'critical') {\n          throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n        }\n        console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n      } else {\n        checkpointName = checkpoint.name;\n        console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n      }\n    } catch (cpErr: unknown) {\n      const message = toErrorMessage(cpErr);\n      console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n      // High-safety tiers require a valid checkpoint.\n      if (tier === 'constitutional' || tier === 'critical') {\n        throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n      }\n      // Lower tiers can proceed with explicit no-rollback notice.\n      checkpointName = null;\n    }\n  } else {\n    console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n  }\n\n  // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n  let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n  const selectParams: unknown[] = [tier];\n\n  if (specFolder) {\n    selectSql += ' AND spec_folder = ?';\n    selectParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    selectParams.push(olderThanDays);\n  }\n\n  const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n    id: number;\n    content_hash: string | null;\n    file_path: string | null;\n    spec_folder: string | null;\n  }>;\n\n  // Perform deletion in a transaction\n  let deletedCount = 0;\n  const deletedIds: number[] = [];\n\n  causalEdges.init(database);\n\n  const bulkDeleteTx = database.transaction(() => {\n    for (const memory of memoriesToDelete) {\n      if (tombstoneMemory(database, memory.id)) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        try {\n          recordHistory(\n            memory.id,\n            'DELETE',\n            memory.file_path ?? null,\n            null,\n            'mcp:memory_bulk_delete',\n            memory.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort inside bulk delete\n        }\n        deletedCount++;\n        deletedIds.push(memory.id);\n\n        // Clean up causal edges\n        // Propagate edge-cleanup errors to fail the transaction.\n        // Previously errors were caught and logged, leaving orphan causal edges\n        // When memory rows were successfully deleted but edge cleanup failed.\n        causalEdges.deleteEdgesForMemory(String(memory.id), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-bulk-delete.handleMemoryBulkDelete',\n          restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n        });\n      }\n    }\n  });\n\n  bulkDeleteTx();\n\n  // Record in mutation ledger (single entry for bulk operation)\n  const ledgerRecorded = appendMutationLedgerSafe(database, {\n    mutationType: 'delete',\n    reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n    priorHash: null,\n    newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n    linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n    decisionMeta: {\n      tool: 'memory_bulk_delete',\n      tier,\n      specFolder: specFolder || null,\n      olderThanDays: olderThanDays || null,\n      totalDeleted: deletedCount,\n      checkpoint: checkpointName,\n      skipCheckpoint,\n    },\n    actor: 'mcp:memory_bulk_delete',\n  });\n\n  // Invalidate caches\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('bulk-delete', {\n        specFolder,\n        tier,\n        deletedCount,\n        statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n          target: 'memory_index',\n          key: String(id),\n          sourceOperation: 'bulk-delete',\n          metadata: { tier, specFolder: specFolder ?? null },\n        })),\n      });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n  }\n\n  const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  } else if (skipCheckpoint) {\n    hints.push('Checkpoint skipped: restore is not available for this operation');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (!ledgerRecorded) {\n    hints.push('Mutation ledger append failed; audit trail may be incomplete.');\n  }\n  hints.push(`Run memory_index_scan({ force: true }) to re-index if needed`);\n\n  const data: Record<string, unknown> = {\n    deleted: deletedCount,\n    tier,\n    specFolder: specFolder || null,\n    olderThanDays: olderThanDays || null,\n    skipCheckpoint,\n  };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (!ledgerRecorded) {\n    data.warning = 'Mutation ledger append failed; audit trail may be incomplete.';\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_bulk_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryBulkDelete };","lineStart":1,"lineEnd":372,"totalLines":372,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","time":{"start":1781763522546,"end":1781763522591}},"metadata":{"openai":{"itemId":"fc_07d11185e93d73e2016a338dc1a45c81918af78683261051de"}},"id":"prt_ed961bfe8001HojYNyckR5RhWP","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed9618031001aMd6sS9Tw21zdA"}}
{"type":"tool_use","timestamp":1781763522598,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_z7d9n8Se9G6NxgiV8GbzYClD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Transaction Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Atomic file + index operations with pending file recovery\n6: import type Database from 'better-sqlite3';\n7: import * as fs from 'fs';\n8: import * as path from 'path';\n9: import { resolveDatabasePaths } from '../../core/config.js';\n10: \n11: /* ───────────────────────────────────────────────────────────────\n12:    1. CONSTANTS\n13: ----------------------------------------------------------------*/\n14: \n15: const PENDING_SUFFIX = '_pending';\n16: const TEMP_SUFFIX = '.tmp';\n17: const PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n18: \n19: /* ───────────────────────────────────────────────────────────────\n20:    2. INTERFACES\n21: ----------------------------------------------------------------*/\n22: \n23: interface TransactionMetrics {\n24:   totalAtomicWrites: number;\n25:   totalDeletes: number;\n26:   totalRecoveries: number;\n27:   totalErrors: number;\n28:   lastOperationTime: string | null;\n29:   [key: string]: unknown;\n30: }\n31: \n32: interface AtomicSaveResult {\n33:   success: boolean;\n34:   filePath: string;\n35:   error?: string;\n36:   /** Set when DB committed but rename failed, indicating partial state */\n37:   dbCommitted?: boolean;\n38: }\n39: \n40: interface RecoveryResult {\n41:   path: string;\n42:   recovered: boolean;\n43:   error?: string;\n44: }\n45: \n46: /**\n47:  * Optional database probe used during pending-file recovery.\n48:  * Return `true` when the original path already has a committed `memory_index` row.\n49:  * Return `false` to leave the `_pending` file in place for manual review.\n50:  * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n51:  */\n52: type IsCommittedCheck = (originalPath: string) => boolean;\n53: \n54: /* ───────────────────────────────────────────────────────────────\n55:    3. MODULE STATE\n56: ----------------------------------------------------------------*/\n57: \n58: const metrics: TransactionMetrics = {\n59:   totalAtomicWrites: 0,\n60:   totalDeletes: 0,\n61:   totalRecoveries: 0,\n62:   totalErrors: 0,\n63:   lastOperationTime: null,\n64: };\n65: \n66: const activeTransactions = new WeakMap<object, number>();\n67: \n68: /* ───────────────────────────────────────────────────────────────\n69:    4. METRICS\n70: ----------------------------------------------------------------*/\n71: \n72: function getMetrics(): TransactionMetrics {\n73:   return { ...metrics };\n74: }\n75: \n76: function resetMetrics(): void {\n77:   metrics.totalAtomicWrites = 0;\n78:   metrics.totalDeletes = 0;\n79:   metrics.totalRecoveries = 0;\n80:   metrics.totalErrors = 0;\n81:   metrics.lastOperationTime = null;\n82: }\n83: \n84: /* ───────────────────────────────────────────────────────────────\n85:    5. PATH HELPERS\n86: ----------------------------------------------------------------*/\n87: \n88: function getPendingPath(filePath: string): string {\n89:   const dir = path.dirname(filePath);\n90:   const ext = path.extname(filePath);\n91:   const base = path.basename(filePath, ext);\n92:   return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n93: }\n94: \n95: interface PendingPathInfo {\n96:   originalPath: string;\n97:   basePendingPath: string;\n98:   uniqueSuffix: string | null;\n99: }\n100: \n101: function parsePendingPath(filePath: string): PendingPathInfo | null {\n102:   const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n103:     const dir = path.dirname(candidatePath);\n104:     const ext = path.extname(candidatePath);\n105:     const base = path.basename(candidatePath, ext);\n106:     if (!base.endsWith(PENDING_SUFFIX)) {\n107:       return null;\n108:     }\n109: \n110:     const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n111:     return {\n112:       originalPath: path.join(dir, `${originalBase}${ext}`),\n113:       basePendingPath: candidatePath,\n114:       uniqueSuffix: null,\n115:     };\n116:   };\n117: \n118:   const suffixExt = path.extname(filePath);\n119:   if (suffixExt) {\n120:     const uniqueSuffix = suffixExt.slice(1);\n121:     const basePendingPath = filePath.slice(0, -suffixExt.length);\n122:     const suffixedMatch = parseBasePendingPath(basePendingPath);\n123:     if (\n124:       suffixedMatch &&\n125:       path.extname(suffixedMatch.basePendingPath) &&\n126:       PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n127:     ) {\n128:       return {\n129:         ...suffixedMatch,\n130:         uniqueSuffix,\n131:       };\n132:     }\n133:   }\n134: \n135:   return parseBasePendingPath(filePath);\n136: }\n137: \n138: function isPendingFile(filePath: string): boolean {\n139:   return parsePendingPath(filePath) !== null;\n140: }\n141: \n142: function getOriginalPath(pendingPath: string): string {\n143:   return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n144: }\n145: \n146: function runInTransaction<T>(database: Database.Database, callback: () => T): T {\n147:   const runCallback = (): T => {\n148:     const depth = activeTransactions.get(database) ?? 0;\n149:     activeTransactions.set(database, depth + 1);\n150:     try {\n151:       return callback();\n152:     } finally {\n153:       const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n154:       if (nextDepth > 0) {\n155:         activeTransactions.set(database, nextDepth);\n156:       } else {\n157:         activeTransactions.delete(database);\n158:       }\n159:     }\n160:   };\n161: \n162:   if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n163:     return runCallback();\n164:   }\n165: \n166:   return database.transaction(() => runCallback())();\n167: }\n168: \n169: /* ───────────────────────────────────────────────────────────────\n170:    6. ATOMIC FILE OPERATIONS\n171: ----------------------------------------------------------------*/\n172: \n173: /**\n174:  * Write a file atomically using write-to-temp-then-rename pattern.\n175:  * This prevents partial writes if the process crashes mid-write.\n176:  */\n177: function atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n178:   const tempPath = filePath + TEMP_SUFFIX;\n179: \n180:   try {\n181:     // Ensure directory exists\n182:     const dir = path.dirname(filePath);\n183:     if (!fs.existsSync(dir)) {\n184:       fs.mkdirSync(dir, { recursive: true });\n185:     }\n186: \n187:     // Write to temp file\n188:     fs.writeFileSync(tempPath, content, encoding);\n189: \n190:     // Atomic rename\n191:     fs.renameSync(tempPath, filePath);\n192: \n193:     metrics.totalAtomicWrites++;\n194:     metrics.lastOperationTime = new Date().toISOString();\n195:     return true;\n196:   } catch (error: unknown) {\n197:     const msg = error instanceof Error ? error.message : String(error);\n198:     console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n199:     metrics.totalErrors++;\n200: \n201:     // Clean up temp file\n202:     try {\n203:       if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n204:     } catch { /* ignore cleanup errors */ }\n205: \n206:     return false;\n207:   }\n208: }\n209: \n210: /**\n211:  * Delete a file if it exists.\n212:  */\n213: function deleteFileIfExists(filePath: string): boolean {\n214:   try {\n215:     if (fs.existsSync(filePath)) {\n216:       fs.unlinkSync(filePath);\n217:       metrics.totalDeletes++;\n218:       metrics.lastOperationTime = new Date().toISOString();\n219:       return true;\n220:     }\n221:     return false;\n222:   } catch (error: unknown) {\n223:     const msg = error instanceof Error ? error.message : String(error);\n224:     console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n225:     metrics.totalErrors++;\n226:     return false;\n227:   }\n228: }\n229: \n230: /**\n231:  * Execute an atomic save with pending file pattern.\n232:  * 1. Write to pending path\n233:  * 2. Execute database operations\n234:  * 3. Rename pending to final\n235:  *\n236:  * This function provides file-system-level atomicity (write-to-pending + rename),\n237:  * NOT database transaction isolation. Callers needing transactional guarantees for\n238:  * dbOperation() must wrap it in their own db.transaction() call. The rename step\n239:  * ensures the file is either fully written or not present, but the DB operation\n240:  * is not rolled back if the rename fails (extremely rare on local filesystems).\n241:  */\n242: function executeAtomicSave(\n243:   filePath: string,\n244:   content: string,\n245:   dbOperation: () => void\n246: ): AtomicSaveResult {\n247:   const pendingPath = getPendingPath(filePath);\n248: \n249:   try {\n250:     // Step 1: Write to pending path\n251:     const dir = path.dirname(pendingPath);\n252:     if (!fs.existsSync(dir)) {\n253:       fs.mkdirSync(dir, { recursive: true });\n254:     }\n255:     fs.writeFileSync(pendingPath, content, 'utf-8');\n256: \n257:     // Flag-based rollback coordination.\n258:     // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n259:     // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n260:     // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n261:     // Can report which step failed. No SAVEPOINT is used — better-sqlite3 transactions\n262:     // Are all-or-nothing within the dbOperation() callback itself.\n263:     let dbCommitted = false;\n264: \n265:     // Step 2: Execute database operation\n266:     try {\n267:       dbOperation();\n268:       dbCommitted = true;\n269:     } catch (dbError: unknown) {\n270:       // Database failed - clean up pending file\n271:       try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n272:       const msg = dbError instanceof Error ? dbError.message : String(dbError);\n273:       metrics.totalErrors++;\n274:       return { success: false, filePath, error: `DB operation failed: ${msg}` };\n275:     }\n276: \n277:     // Step 3: Rename pending to final (atomic)\n278:     // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n279:     // The DB contains the new state but the file is not at its final path. This is\n280:     // A window of vulnerability that cannot be eliminated without two-phase commit.\n281:     // The `dbCommitted` flag on the returned error result enables callers to detect\n282:     // This state and trigger recovery (e.g., re-index from DB or replay the write).\n283:     // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n284:     // Orphaned pending files and rename them to their final paths.\n285:     try {\n286:       fs.renameSync(pendingPath, filePath);\n287:     } catch (renameError: unknown) {\n288:       // Rename failed after DB committed — DB has new state but file wasn't renamed.\n289:       // Leave pending file for startup recovery and report failure with dbCommitted flag.\n290:       const msg = renameError instanceof Error ? renameError.message : String(renameError);\n291:       console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n292:       metrics.totalErrors++;\n293:       return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n294:     }\n295: \n296:     metrics.totalAtomicWrites++;\n297:     metrics.lastOperationTime = new Date().toISOString();\n298:     return { success: true, filePath };\n299:   } catch (error: unknown) {\n300:     const msg = error instanceof Error ? error.message : String(error);\n301:     metrics.totalErrors++;\n302: \n303:     // Clean up pending file\n304:     try {\n305:       if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n306:     } catch { /* ignore */ }\n307: \n308:     return { success: false, filePath, error: msg };\n309:   }\n310: }\n311: \n312: /* ───────────────────────────────────────────────────────────────\n313:    7. RECOVERY\n314: ----------------------------------------------------------------*/\n315: \n316: /**\n317:  * Find pending files in a directory (crash recovery).\n318:  */\n319: function listFilesRecursive(dirPath: string): string[] {\n320:   const files: string[] = [];\n321:   const stack: string[] = [dirPath];\n322: \n323:   while (stack.length > 0) {\n324:     const current = stack.pop();\n325:     if (!current) continue;\n326: \n327:     const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n328:     for (const entry of entries) {\n329:       const fullPath = path.join(current, entry.name);\n330:       if (entry.isDirectory()) {\n331:         stack.push(fullPath);\n332:       } else if (entry.isFile()) {\n333:         files.push(fullPath);\n334:       }\n335:     }\n336:   }\n337: \n338:   return files;\n339: }\n340: \n341: function findPendingFiles(dirPath: string): string[] {\n342:   try {\n343:     if (!fs.existsSync(dirPath)) return [];\n344: \n345:     let files: string[];\n346:     try {\n347:       files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n348:     } catch {\n349:       // Node 18 compatibility fallback when recursive readdir is unavailable.\n350:       files = listFilesRecursive(dirPath);\n351:     }\n352: \n353:     return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n354:   } catch (error: unknown) {\n355:     const msg = error instanceof Error ? error.message : String(error);\n356:     console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n357:     return [];\n358:   }\n359: }\n360: \n361: /**\n362:  * Recover a single pending file by renaming to its original path.\n363:  */\n364: function recoverPendingFile(\n365:   pendingPath: string,\n366:   isCommittedInDb?: IsCommittedCheck,\n367:   databasePathOverride?: string\n368: ): RecoveryResult {\n369:   try {\n370:     // Guard: verify pending file still exists before attempting recovery\n371:     if (!fs.existsSync(pendingPath)) {\n372:       return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n373:     }\n374:     const pendingInfo = parsePendingPath(pendingPath);\n375:     if (!pendingInfo) {\n376:       return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n377:     }\n378: \n379:     const originalPath = pendingInfo.originalPath;\n380:     const originalExists = fs.existsSync(originalPath);\n381:     let committedInDb: boolean | null = null;\n382:     if (isCommittedInDb) {\n383:       const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n384:       if (!fs.existsSync(databasePath)) {\n385:         console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n386:         return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n387:       }\n388:       committedInDb = isCommittedInDb(originalPath);\n389:     }\n390: \n391:     // If original exists and is newer, delete pending\n392:     if (originalExists) {\n393:       const pendingStats = fs.statSync(pendingPath);\n394:       const originalStats = fs.statSync(originalPath);\n395:       if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n396:         fs.unlinkSync(pendingPath);\n397:         return { path: pendingPath, recovered: false, error: 'Original is newer' };\n398:       }\n399:     }\n400: \n401:     // Stale detection: if DB check is provided and row was never committed,\n402:     // Log and leave for manual review instead of renaming.\n403:     if (committedInDb === false) {\n404:       console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n405:       return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n406:     }\n407: \n408:     // Rename pending to original\n409:     fs.renameSync(pendingPath, originalPath);\n410:     metrics.totalRecoveries++;\n411:     metrics.lastOperationTime = new Date().toISOString();\n412: \n413:     return { path: pendingPath, recovered: true };\n414:   } catch (error: unknown) {\n415:     const msg = error instanceof Error ? error.message : String(error);\n416:     metrics.totalErrors++;\n417:     return { path: pendingPath, recovered: false, error: msg };\n418:   }\n419: }\n420: \n421: /**\n422:  * Recover all pending files in a directory.\n423:  */\n424: function recoverAllPendingFiles(\n425:   dirPath: string,\n426:   isCommittedInDb?: IsCommittedCheck,\n427:   databasePathOverride?: string\n428: ): RecoveryResult[] {\n429:   const pendingFiles = findPendingFiles(dirPath);\n430:   return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n431: }\n432: \n433: /* ───────────────────────────────────────────────────────────────\n434:    8. EXPORTS\n435: ----------------------------------------------------------------*/\n436: \n437: export {\n438:   PENDING_SUFFIX,\n439:   TEMP_SUFFIX,\n440: \n441:   // Metrics\n442:   getMetrics,\n443:   resetMetrics,\n444: \n445:   // Path helpers\n446:   getPendingPath,\n447:   isPendingFile,\n448:   getOriginalPath,\n449:   runInTransaction,\n450: \n451:   // Atomic operations\n452:   atomicWriteFile,\n453:   deleteFileIfExists,\n454:   executeAtomicSave,\n455: \n456:   // Recovery\n457:   findPendingFiles,\n458:   recoverPendingFile,\n459:   recoverAllPendingFiles,\n460: };\n461: \n462: /**\n463:  * Re-exports related public types.\n464:  */\n465: export type {\n466:   TransactionMetrics,\n467:   AtomicSaveResult,\n468:   RecoveryResult,\n469:   IsCommittedCheck,\n470: };\n\n(End of file - total 470 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Transaction Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Transaction Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface TransactionMetrics {\n  totalAtomicWrites: number;\n  totalDeletes: number;\n  totalRecoveries: number;\n  totalErrors: number;\n  lastOperationTime: string | null;\n  [key: string]: unknown;\n}\n\ninterface AtomicSaveResult {\n  success: boolean;\n  filePath: string;\n  error?: string;\n  /** Set when DB committed but rename failed, indicating partial state */\n  dbCommitted?: boolean;\n}\n\ninterface RecoveryResult {\n  path: string;\n  recovered: boolean;\n  error?: string;\n}\n\n/**\n * Optional database probe used during pending-file recovery.\n * Return `true` when the original path already has a committed `memory_index` row.\n * Return `false` to leave the `_pending` file in place for manual review.\n * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n */\ntype IsCommittedCheck = (originalPath: string) => boolean;\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nconst metrics: TransactionMetrics = {\n  totalAtomicWrites: 0,\n  totalDeletes: 0,\n  totalRecoveries: 0,\n  totalErrors: 0,\n  lastOperationTime: null,\n};\n\nconst activeTransactions = new WeakMap<object, number>();\n\n/* ───────────────────────────────────────────────────────────────\n   4. METRICS\n----------------------------------------------------------------*/\n\nfunction getMetrics(): TransactionMetrics {\n  return { ...metrics };\n}\n\nfunction resetMetrics(): void {\n  metrics.totalAtomicWrites = 0;\n  metrics.totalDeletes = 0;\n  metrics.totalRecoveries = 0;\n  metrics.totalErrors = 0;\n  metrics.lastOperationTime = null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. PATH HELPERS\n----------------------------------------------------------------*/\n\nfunction getPendingPath(filePath: string): string {\n  const dir = path.dirname(filePath);\n  const ext = path.extname(filePath);\n  const base = path.basename(filePath, ext);\n  return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n}\n\ninterface PendingPathInfo {\n  originalPath: string;\n  basePendingPath: string;\n  uniqueSuffix: string | null;\n}\n\nfunction parsePendingPath(filePath: string): PendingPathInfo | null {\n  const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n    const dir = path.dirname(candidatePath);\n    const ext = path.extname(candidatePath);\n    const base = path.basename(candidatePath, ext);\n    if (!base.endsWith(PENDING_SUFFIX)) {\n      return null;\n    }\n\n    const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n    return {\n      originalPath: path.join(dir, `${originalBase}${ext}`),\n      basePendingPath: candidatePath,\n      uniqueSuffix: null,\n    };\n  };\n\n  const suffixExt = path.extname(filePath);\n  if (suffixExt) {\n    const uniqueSuffix = suffixExt.slice(1);\n    const basePendingPath = filePath.slice(0, -suffixExt.length);\n    const suffixedMatch = parseBasePendingPath(basePendingPath);\n    if (\n      suffixedMatch &&\n      path.extname(suffixedMatch.basePendingPath) &&\n      PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n    ) {\n      return {\n        ...suffixedMatch,\n        uniqueSuffix,\n      };\n    }\n  }\n\n  return parseBasePendingPath(filePath);\n}\n\nfunction isPendingFile(filePath: string): boolean {\n  return parsePendingPath(filePath) !== null;\n}\n\nfunction getOriginalPath(pendingPath: string): string {\n  return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n}\n\nfunction runInTransaction<T>(database: Database.Database, callback: () => T): T {\n  const runCallback = (): T => {\n    const depth = activeTransactions.get(database) ?? 0;\n    activeTransactions.set(database, depth + 1);\n    try {\n      return callback();\n    } finally {\n      const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n      if (nextDepth > 0) {\n        activeTransactions.set(database, nextDepth);\n      } else {\n        activeTransactions.delete(database);\n      }\n    }\n  };\n\n  if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n    return runCallback();\n  }\n\n  return database.transaction(() => runCallback())();\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. ATOMIC FILE OPERATIONS\n----------------------------------------------------------------*/\n\n/**\n * Write a file atomically using write-to-temp-then-rename pattern.\n * This prevents partial writes if the process crashes mid-write.\n */\nfunction atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n  const tempPath = filePath + TEMP_SUFFIX;\n\n  try {\n    // Ensure directory exists\n    const dir = path.dirname(filePath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n\n    // Write to temp file\n    fs.writeFileSync(tempPath, content, encoding);\n\n    // Atomic rename\n    fs.renameSync(tempPath, filePath);\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n    metrics.totalErrors++;\n\n    // Clean up temp file\n    try {\n      if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n    } catch { /* ignore cleanup errors */ }\n\n    return false;\n  }\n}\n\n/**\n * Delete a file if it exists.\n */\nfunction deleteFileIfExists(filePath: string): boolean {\n  try {\n    if (fs.existsSync(filePath)) {\n      fs.unlinkSync(filePath);\n      metrics.totalDeletes++;\n      metrics.lastOperationTime = new Date().toISOString();\n      return true;\n    }\n    return false;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n    metrics.totalErrors++;\n    return false;\n  }\n}\n\n/**\n * Execute an atomic save with pending file pattern.\n * 1. Write to pending path\n * 2. Execute database operations\n * 3. Rename pending to final\n *\n * This function provides file-system-level atomicity (write-to-pending + rename),\n * NOT database transaction isolation. Callers needing transactional guarantees for\n * dbOperation() must wrap it in their own db.transaction() call. The rename step\n * ensures the file is either fully written or not present, but the DB operation\n * is not rolled back if the rename fails (extremely rare on local filesystems).\n */\nfunction executeAtomicSave(\n  filePath: string,\n  content: string,\n  dbOperation: () => void\n): AtomicSaveResult {\n  const pendingPath = getPendingPath(filePath);\n\n  try {\n    // Step 1: Write to pending path\n    const dir = path.dirname(pendingPath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n    fs.writeFileSync(pendingPath, content, 'utf-8');\n\n    // Flag-based rollback coordination.\n    // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n    // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n    // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n    // Can report which step failed. No SAVEPOINT is used — better-sqlite3 transactions\n    // Are all-or-nothing within the dbOperation() callback itself.\n    let dbCommitted = false;\n\n    // Step 2: Execute database operation\n    try {\n      dbOperation();\n      dbCommitted = true;\n    } catch (dbError: unknown) {\n      // Database failed - clean up pending file\n      try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n      const msg = dbError instanceof Error ? dbError.message : String(dbError);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `DB operation failed: ${msg}` };\n    }\n\n    // Step 3: Rename pending to final (atomic)\n    // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n    // The DB contains the new state but the file is not at its final path. This is\n    // A window of vulnerability that cannot be eliminated without two-phase commit.\n    // The `dbCommitted` flag on the returned error result enables callers to detect\n    // This state and trigger recovery (e.g., re-index from DB or replay the write).\n    // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n    // Orphaned pending files and rename them to their final paths.\n    try {\n      fs.renameSync(pendingPath, filePath);\n    } catch (renameError: unknown) {\n      // Rename failed after DB committed — DB has new state but file wasn't renamed.\n      // Leave pending file for startup recovery and report failure with dbCommitted flag.\n      const msg = renameError instanceof Error ? renameError.message : String(renameError);\n      console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n    }\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return { success: true, filePath };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n\n    // Clean up pending file\n    try {\n      if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n    } catch { /* ignore */ }\n\n    return { success: false, filePath, error: msg };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. RECOVERY\n----------------------------------------------------------------*/\n\n/**\n * Find pending files in a directory (crash recovery).\n */\nfunction listFilesRecursive(dirPath: string): string[] {\n  const files: string[] = [];\n  const stack: string[] = [dirPath];\n\n  while (stack.length > 0) {\n    const current = stack.pop();\n    if (!current) continue;\n\n    const entries = fs.readdirSync(current, { withFileTypes: true, encoding: 'utf-8' });\n    for (const entry of entries) {\n      const fullPath = path.join(current, entry.name);\n      if (entry.isDirectory()) {\n        stack.push(fullPath);\n      } else if (entry.isFile()) {\n        files.push(fullPath);\n      }\n    }\n  }\n\n  return files;\n}\n\nfunction findPendingFiles(dirPath: string): string[] {\n  try {\n    if (!fs.existsSync(dirPath)) return [];\n\n    let files: string[];\n    try {\n      files = (fs.readdirSync(dirPath, { recursive: true, encoding: 'utf-8' }) as string[]).map((f) => path.join(dirPath, f));\n    } catch {\n      // Node 18 compatibility fallback when recursive readdir is unavailable.\n      files = listFilesRecursive(dirPath);\n    }\n\n    return files.filter((filePath) => parsePendingPath(filePath) !== null && fs.statSync(filePath).isFile());\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] findPendingFiles error: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Recover a single pending file by renaming to its original path.\n */\nfunction recoverPendingFile(\n  pendingPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult {\n  try {\n    // Guard: verify pending file still exists before attempting recovery\n    if (!fs.existsSync(pendingPath)) {\n      return { path: pendingPath, recovered: false, error: 'Pending file no longer exists' };\n    }\n    const pendingInfo = parsePendingPath(pendingPath);\n    if (!pendingInfo) {\n      return { path: pendingPath, recovered: false, error: 'File does not match pending-file naming contract' };\n    }\n\n    const originalPath = pendingInfo.originalPath;\n    const originalExists = fs.existsSync(originalPath);\n    let committedInDb: boolean | null = null;\n    if (isCommittedInDb) {\n      const databasePath = databasePathOverride ?? resolveDatabasePaths().databasePath;\n      if (!fs.existsSync(databasePath)) {\n        console.warn(`[transaction-manager] Skipping pending recovery because DB file is missing: ${databasePath}`);\n        return { path: pendingPath, recovered: false, error: 'Database file missing during recovery' };\n      }\n      committedInDb = isCommittedInDb(originalPath);\n    }\n\n    // If original exists and is newer, delete pending\n    if (originalExists) {\n      const pendingStats = fs.statSync(pendingPath);\n      const originalStats = fs.statSync(originalPath);\n      if (originalStats.mtimeMs > pendingStats.mtimeMs) {\n        fs.unlinkSync(pendingPath);\n        return { path: pendingPath, recovered: false, error: 'Original is newer' };\n      }\n    }\n\n    // Stale detection: if DB check is provided and row was never committed,\n    // Log and leave for manual review instead of renaming.\n    if (committedInDb === false) {\n      console.warn(`[transaction-manager] Stale pending file detected (no committed DB row): ${pendingPath}`);\n      return { path: pendingPath, recovered: false, error: 'Stale pending file: DB row not committed' };\n    }\n\n    // Rename pending to original\n    fs.renameSync(pendingPath, originalPath);\n    metrics.totalRecoveries++;\n    metrics.lastOperationTime = new Date().toISOString();\n\n    return { path: pendingPath, recovered: true };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n    return { path: pendingPath, recovered: false, error: msg };\n  }\n}\n\n/**\n * Recover all pending files in a directory.\n */\nfunction recoverAllPendingFiles(\n  dirPath: string,\n  isCommittedInDb?: IsCommittedCheck,\n  databasePathOverride?: string\n): RecoveryResult[] {\n  const pendingFiles = findPendingFiles(dirPath);\n  return pendingFiles.map((f) => recoverPendingFile(f, isCommittedInDb, databasePathOverride));\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  PENDING_SUFFIX,\n  TEMP_SUFFIX,\n\n  // Metrics\n  getMetrics,\n  resetMetrics,\n\n  // Path helpers\n  getPendingPath,\n  isPendingFile,\n  getOriginalPath,\n  runInTransaction,\n\n  // Atomic operations\n  atomicWriteFile,\n  deleteFileIfExists,\n  executeAtomicSave,\n\n  // Recovery\n  findPendingFiles,\n  recoverPendingFile,\n  recoverAllPendingFiles,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  TransactionMetrics,\n  AtomicSaveResult,\n  RecoveryResult,\n  IsCommittedCheck,\n};","lineStart":1,"lineEnd":470,"totalLines":470,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","time":{"start":1781763522550,"end":1781763522595}},"metadata":{"openai":{"itemId":"fc_07d11185e93d73e2016a338dc1a46481918532b17e58ebc4cf"}},"id":"prt_ed961bff30017us6TOfAXqr9yW","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed9618031001aMd6sS9Tw21zdA"}}
{"type":"tool_use","timestamp":1781763522599,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_mn3U7B15e8PQsnIsohydCc0I","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Maintenance Job Store\n3: // ───────────────────────────────────────────────────────────────\n4: // Kind-agnostic persisted job lifecycle: jobId, state record, progress\n5: // counters, error capture+truncation, cancel flag, and crash-recovery\n6: // reset. Shared lifecycle/registry across long-running maintenance jobs.\n7: \n8: /* ───────────────────────────────────────────────────────────────\n9:    1. IMPORTS\n10: ──────────────────────────────────────────────────────────────── */\n11: \n12: import { randomBytes } from 'node:crypto';\n13: \n14: import { requireDb, toErrorMessage } from '../../utils/index.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    2. TYPES\n19: ──────────────────────────────────────────────────────────────── */\n20: \n21: export type MaintenanceJobKind = 'ingest' | 'index_scan';\n22: \n23: export type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n24: \n25: export interface JobError {\n26:   source: string;\n27:   message: string;\n28:   timestamp: string;\n29: }\n30: \n31: export interface MaintenanceJob {\n32:   id: string;\n33:   kind: MaintenanceJobKind;\n34:   state: JobLifecycleState;\n35:   phase: string | null;\n36:   progressTotal: number;\n37:   progressProcessed: number;\n38:   cancelRequested: boolean;\n39:   errors: JobError[];\n40:   result: unknown | null;\n41:   payload: unknown | null;\n42:   createdAt: string;\n43:   updatedAt: string;\n44: }\n45: \n46: interface MaintenanceJobRow {\n47:   id: string;\n48:   kind: string;\n49:   state: string;\n50:   phase: string | null;\n51:   progress_total: number;\n52:   progress_processed: number;\n53:   cancel_requested: number;\n54:   errors_json: string;\n55:   result_json: string | null;\n56:   payload_json: string | null;\n57:   created_at: string;\n58:   updated_at: string;\n59: }\n60: \n61: /* ───────────────────────────────────────────────────────────────\n62:    3. CONSTANTS\n63: ──────────────────────────────────────────────────────────────── */\n64: \n65: export const MAX_STORED_ERRORS = 50;\n66: \n67: const TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n68: \n69: // In-process mirror of cancel_requested. A running job polls this from a hot loop\n70: // to decide whether to stop, avoiding a DB SELECT on the single shared connection\n71: // every check. The cancel request runs in this same process, so the Set is\n72: // authoritative for an in-flight run; the durable column still backs status\n73: // responses and crash recovery. Entries are cleared when a job reaches a terminal\n74: // state so the Set cannot grow without bound across many jobs.\n75: const cancelledJobIds = new Set<string>();\n76: \n77: const ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n78:   queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n79:   running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n80:   complete: new Set<JobLifecycleState>([]),\n81:   failed: new Set<JobLifecycleState>([]),\n82:   cancelled: new Set<JobLifecycleState>([]),\n83: };\n84: \n85: // URL-safe 12-char identifier without a UUID dependency.\n86: const NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n87: \n88: /* ───────────────────────────────────────────────────────────────\n89:    4. HELPERS\n90: ──────────────────────────────────────────────────────────────── */\n91: \n92: function nowIso(): string {\n93:   return new Date().toISOString();\n94: }\n95: \n96: function isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n97:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n98: }\n99: \n100: function parseJson<T>(value: string | null | undefined, fallback: T): T {\n101:   if (value === null || value === undefined) return fallback;\n102:   try {\n103:     return JSON.parse(value) as T;\n104:   } catch (_error: unknown) {\n105:     return fallback;\n106:   }\n107: }\n108: \n109: function parseJobErrors(value: string | null | undefined): JobError[] {\n110:   const parsed = parseJson<unknown>(value, []);\n111:   return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n112: }\n113: \n114: function mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n115:   if (!row) return null;\n116:   return {\n117:     id: row.id,\n118:     kind: row.kind as MaintenanceJobKind,\n119:     state: row.state as JobLifecycleState,\n120:     phase: row.phase,\n121:     progressTotal: row.progress_total,\n122:     progressProcessed: row.progress_processed,\n123:     cancelRequested: row.cancel_requested === 1,\n124:     errors: parseJobErrors(row.errors_json),\n125:     result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n126:     payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n127:     createdAt: row.created_at,\n128:     updatedAt: row.updated_at,\n129:   };\n130: }\n131: \n132: const SELECT_COLUMNS =\n133:   'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n134: \n135: /* ───────────────────────────────────────────────────────────────\n136:    5. SCHEMA\n137: ──────────────────────────────────────────────────────────────── */\n138: \n139: export function ensureMaintenanceJobsTable(): void {\n140:   const db = requireDb();\n141:   db.exec(`\n142:     CREATE TABLE IF NOT EXISTS maintenance_jobs (\n143:       id TEXT PRIMARY KEY,\n144:       kind TEXT NOT NULL,\n145:       state TEXT NOT NULL,\n146:       phase TEXT,\n147:       progress_total INTEGER NOT NULL DEFAULT 0,\n148:       progress_processed INTEGER NOT NULL DEFAULT 0,\n149:       cancel_requested INTEGER NOT NULL DEFAULT 0,\n150:       errors_json TEXT NOT NULL DEFAULT '[]',\n151:       result_json TEXT,\n152:       payload_json TEXT,\n153:       created_at TEXT NOT NULL,\n154:       updated_at TEXT NOT NULL\n155:     )\n156:   `);\n157:   db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n158: }\n159: \n160: /* ───────────────────────────────────────────────────────────────\n161:    6. IDENTIFIERS\n162: ──────────────────────────────────────────────────────────────── */\n163: \n164: export function createJobId(): string {\n165:   const bytes = randomBytes(12);\n166:   let id = '';\n167:   for (let i = 0; i < 12; i++) {\n168:     id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n169:   }\n170:   return `job_${id}`;\n171: }\n172: \n173: /* ───────────────────────────────────────────────────────────────\n174:    7. LIFECYCLE\n175: ──────────────────────────────────────────────────────────────── */\n176: \n177: export async function createMaintenanceJob(args: {\n178:   id: string;\n179:   kind: MaintenanceJobKind;\n180:   payload?: unknown;\n181: }): Promise<MaintenanceJob> {\n182:   const db = requireDb();\n183:   const timestamp = nowIso();\n184:   const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n185: \n186:   await withBusyRetry(() =>\n187:     db.prepare(`\n188:       INSERT INTO maintenance_jobs (\n189:         id, kind, state, phase, progress_total, progress_processed,\n190:         cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n191:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n192:     `).run(\n193:       args.id,\n194:       args.kind,\n195:       'queued',\n196:       null,\n197:       0,\n198:       0,\n199:       0,\n200:       '[]',\n201:       null,\n202:       payloadJson,\n203:       timestamp,\n204:       timestamp,\n205:     )\n206:   );\n207: \n208:   return {\n209:     id: args.id,\n210:     kind: args.kind,\n211:     state: 'queued',\n212:     phase: null,\n213:     progressTotal: 0,\n214:     progressProcessed: 0,\n215:     cancelRequested: false,\n216:     errors: [],\n217:     result: null,\n218:     payload: args.payload ?? null,\n219:     createdAt: timestamp,\n220:     updatedAt: timestamp,\n221:   };\n222: }\n223: \n224: export function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n225:   const db = requireDb();\n226:   const row = db.prepare(`\n227:     SELECT ${SELECT_COLUMNS}\n228:     FROM maintenance_jobs\n229:     WHERE id = ?\n230:   `).get(jobId) as MaintenanceJobRow | undefined;\n231:   return mapRowToJob(row);\n232: }\n233: \n234: export async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n235:   const db = requireDb();\n236:   const current = getMaintenanceJob(jobId);\n237:   if (!current) {\n238:     throw new Error(`Maintenance job not found: ${jobId}`);\n239:   }\n240: \n241:   if (current.state === nextState) {\n242:     return current;\n243:   }\n244: \n245:   if (!isTransitionAllowed(current.state, nextState)) {\n246:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n247:   }\n248: \n249:   const updatedAt = nowIso();\n250:   const result = await withBusyRetry(() =>\n251:     db.prepare(`\n252:       UPDATE maintenance_jobs\n253:       SET state = ?, updated_at = ?\n254:       WHERE id = ? AND state = ?\n255:     `).run(nextState, updatedAt, jobId, current.state)\n256:   );\n257: \n258:   if ((result as { changes: number }).changes === 0) {\n259:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n260:   }\n261: \n262:   // Every terminal transition must release the in-process cancel mirror, not just\n263:   // completeJob/resetRunningJobsForKind. A cancel-then-fail-while-running race\n264:   // routes through setJobState('failed'); without this the job-id would leak,\n265:   // contradicting the cancelledJobIds bounded-growth guarantee.\n266:   if (isTerminalJobState(nextState)) {\n267:     cancelledJobIds.delete(jobId);\n268:   }\n269: \n270:   return { ...current, state: nextState, updatedAt };\n271: }\n272: \n273: export async function setJobPhase(jobId: string, phase: string): Promise<void> {\n274:   const db = requireDb();\n275:   await withBusyRetry(() =>\n276:     db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n277:       .run(phase, nowIso(), jobId)\n278:   );\n279: }\n280: \n281: export async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n282:   const db = requireDb();\n283:   const processed = Math.max(0, Math.trunc(progress.processed));\n284:   const total = Math.max(0, Math.trunc(progress.total));\n285:   await withBusyRetry(() =>\n286:     db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n287:       .run(processed, total, nowIso(), jobId)\n288:   );\n289: }\n290: \n291: export async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n292:   const db = requireDb();\n293:   const current = getMaintenanceJob(jobId);\n294:   if (!current) {\n295:     throw new Error(`Maintenance job not found: ${jobId}`);\n296:   }\n297: \n298:   let errors: JobError[] = [\n299:     ...current.errors,\n300:     { source, message: toErrorMessage(error), timestamp: nowIso() },\n301:   ];\n302: \n303:   if (errors.length > MAX_STORED_ERRORS) {\n304:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n305:     const trimmedCount = errors.length - tailLength;\n306:     const truncationNotice: JobError = {\n307:       source: '__job__',\n308:       message: `error log truncated (${trimmedCount} older entries removed)`,\n309:       timestamp: nowIso(),\n310:     };\n311:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n312:     errors = [truncationNotice, ...truncatedTail];\n313:   }\n314: \n315:   const updatedAt = nowIso();\n316:   await withBusyRetry(() =>\n317:     db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n318:       .run(JSON.stringify(errors), updatedAt, jobId)\n319:   );\n320: \n321:   return { ...current, errors, updatedAt };\n322: }\n323: \n324: export async function requestCancel(jobId: string): Promise<void> {\n325:   // Set the in-process flag first so a running loop observes the cancel even if the\n326:   // durable write contends on the shared connection.\n327:   cancelledJobIds.add(jobId);\n328:   const db = requireDb();\n329:   await withBusyRetry(() =>\n330:     db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n331:       .run(nowIso(), jobId)\n332:   );\n333: }\n334: \n335: // Synchronous so the runner can poll it inline at batch/phase boundaries.\n336: export function isCancelRequested(jobId: string): boolean {\n337:   const db = requireDb();\n338:   const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n339:     .get(jobId) as { cancel_requested?: number } | undefined;\n340:   return !!row && row.cancel_requested === 1;\n341: }\n342: \n343: // Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n344: // mirror, so it is safe to call thousands of times during a scan without touching\n345: // the shared SQLite connection. Use isCancelRequested when durability across the\n346: // in-memory boundary matters (status responses, post-restart).\n347: export function isCancelRequestedFast(jobId: string): boolean {\n348:   return cancelledJobIds.has(jobId);\n349: }\n350: \n351: export async function completeJob(\n352:   jobId: string,\n353:   options: { state: JobLifecycleState; result?: unknown },\n354: ): Promise<MaintenanceJob> {\n355:   const db = requireDb();\n356:   const current = getMaintenanceJob(jobId);\n357:   if (!current) {\n358:     throw new Error(`Maintenance job not found: ${jobId}`);\n359:   }\n360: \n361:   if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n362:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n363:   }\n364: \n365:   const updatedAt = nowIso();\n366:   const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n367:   const completion = await withBusyRetry(() =>\n368:     db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n369:       .run(options.state, resultJson, updatedAt, jobId, current.state)\n370:   );\n371:   if (completion.changes === 0) {\n372:     // The row moved out from under the read-then-check; refuse to clobber a state\n373:     // another writer set rather than overwriting it from a stale read.\n374:     throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n375:   }\n376: \n377:   cancelledJobIds.delete(jobId);\n378:   return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n379: }\n380: \n381: // Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n382: // re-run fresh, so they are reset to 'failed' rather than re-enqueued.\n383: export function resetRunningJobsForKind(\n384:   kind: MaintenanceJobKind,\n385:   // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n386:   // target keeps a caller from persisting an illegal transition past the guard.\n387:   options: { to: 'failed' | 'cancelled' },\n388: ): string[] {\n389:   const db = requireDb();\n390:   const rows = db.prepare(`\n391:     SELECT id FROM maintenance_jobs\n392:     WHERE kind = ? AND state IN ('queued', 'running')\n393:   `).all(kind) as Array<{ id: string }>;\n394: \n395:   if (rows.length === 0) return [];\n396: \n397:   withBusyRetrySync(() =>\n398:     db.prepare(`\n399:       UPDATE maintenance_jobs\n400:       SET state = ?, updated_at = ?\n401:       WHERE kind = ? AND state IN ('queued', 'running')\n402:     `).run(options.to, nowIso(), kind)\n403:   );\n404: \n405:   for (const row of rows) {\n406:     cancelledJobIds.delete(row.id);\n407:   }\n408:   return rows.map((r) => r.id);\n409: }\n410: \n411: export function isTerminalJobState(state: JobLifecycleState): boolean {\n412:   return TERMINAL_STATES.has(state);\n413: }\n\n(End of file - total 413 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance Job Store\n// ───────────────────────────────────────────────────────────────\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance Job Store\n// ───────────────────────────────────────────────────────────────\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\nexport type MaintenanceJobKind = 'ingest' | 'index_scan';\n\nexport type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n\nexport interface JobError {\n  source: string;\n  message: string;\n  timestamp: string;\n}\n\nexport interface MaintenanceJob {\n  id: string;\n  kind: MaintenanceJobKind;\n  state: JobLifecycleState;\n  phase: string | null;\n  progressTotal: number;\n  progressProcessed: number;\n  cancelRequested: boolean;\n  errors: JobError[];\n  result: unknown | null;\n  payload: unknown | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\ninterface MaintenanceJobRow {\n  id: string;\n  kind: string;\n  state: string;\n  phase: string | null;\n  progress_total: number;\n  progress_processed: number;\n  cancel_requested: number;\n  errors_json: string;\n  result_json: string | null;\n  payload_json: string | null;\n  created_at: string;\n  updated_at: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nexport const MAX_STORED_ERRORS = 50;\n\nconst TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n\n// In-process mirror of cancel_requested. A running job polls this from a hot loop\n// to decide whether to stop, avoiding a DB SELECT on the single shared connection\n// every check. The cancel request runs in this same process, so the Set is\n// authoritative for an in-flight run; the durable column still backs status\n// responses and crash recovery. Entries are cleared when a job reaches a terminal\n// state so the Set cannot grow without bound across many jobs.\nconst cancelledJobIds = new Set<string>();\n\nconst ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n  queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n  running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n  complete: new Set<JobLifecycleState>([]),\n  failed: new Set<JobLifecycleState>([]),\n  cancelled: new Set<JobLifecycleState>([]),\n};\n\n// URL-safe 12-char identifier without a UUID dependency.\nconst NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\nfunction parseJson<T>(value: string | null | undefined, fallback: T): T {\n  if (value === null || value === undefined) return fallback;\n  try {\n    return JSON.parse(value) as T;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseJobErrors(value: string | null | undefined): JobError[] {\n  const parsed = parseJson<unknown>(value, []);\n  return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n}\n\nfunction mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    kind: row.kind as MaintenanceJobKind,\n    state: row.state as JobLifecycleState,\n    phase: row.phase,\n    progressTotal: row.progress_total,\n    progressProcessed: row.progress_processed,\n    cancelRequested: row.cancel_requested === 1,\n    errors: parseJobErrors(row.errors_json),\n    result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n    payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nconst SELECT_COLUMNS =\n  'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n\n/* ───────────────────────────────────────────────────────────────\n   5. SCHEMA\n──────────────────────────────────────────────────────────────── */\n\nexport function ensureMaintenanceJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS maintenance_jobs (\n      id TEXT PRIMARY KEY,\n      kind TEXT NOT NULL,\n      state TEXT NOT NULL,\n      phase TEXT,\n      progress_total INTEGER NOT NULL DEFAULT 0,\n      progress_processed INTEGER NOT NULL DEFAULT 0,\n      cancel_requested INTEGER NOT NULL DEFAULT 0,\n      errors_json TEXT NOT NULL DEFAULT '[]',\n      result_json TEXT,\n      payload_json TEXT,\n      created_at TEXT NOT NULL,\n      updated_at TEXT NOT NULL\n    )\n  `);\n  db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. IDENTIFIERS\n──────────────────────────────────────────────────────────────── */\n\nexport function createJobId(): string {\n  const bytes = randomBytes(12);\n  let id = '';\n  for (let i = 0; i < 12; i++) {\n    id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n  }\n  return `job_${id}`;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. LIFECYCLE\n──────────────────────────────────────────────────────────────── */\n\nexport async function createMaintenanceJob(args: {\n  id: string;\n  kind: MaintenanceJobKind;\n  payload?: unknown;\n}): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO maintenance_jobs (\n        id, kind, state, phase, progress_total, progress_processed,\n        cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      args.kind,\n      'queued',\n      null,\n      0,\n      0,\n      0,\n      '[]',\n      null,\n      payloadJson,\n      timestamp,\n      timestamp,\n    )\n  );\n\n  return {\n    id: args.id,\n    kind: args.kind,\n    state: 'queued',\n    phase: null,\n    progressTotal: 0,\n    progressProcessed: 0,\n    cancelRequested: false,\n    errors: [],\n    result: null,\n    payload: args.payload ?? null,\n    createdAt: timestamp,\n    updatedAt: timestamp,\n  };\n}\n\nexport function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n  const db = requireDb();\n  const row = db.prepare(`\n    SELECT ${SELECT_COLUMNS}\n    FROM maintenance_jobs\n    WHERE id = ?\n  `).get(jobId) as MaintenanceJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nexport async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  // Every terminal transition must release the in-process cancel mirror, not just\n  // completeJob/resetRunningJobsForKind. A cancel-then-fail-while-running race\n  // routes through setJobState('failed'); without this the job-id would leak,\n  // contradicting the cancelledJobIds bounded-growth guarantee.\n  if (isTerminalJobState(nextState)) {\n    cancelledJobIds.delete(jobId);\n  }\n\n  return { ...current, state: nextState, updatedAt };\n}\n\nexport async function setJobPhase(jobId: string, phase: string): Promise<void> {\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n      .run(phase, nowIso(), jobId)\n  );\n}\n\nexport async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n  const db = requireDb();\n  const processed = Math.max(0, Math.trunc(progress.processed));\n  const total = Math.max(0, Math.trunc(progress.total));\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n      .run(processed, total, nowIso(), jobId)\n  );\n}\n\nexport async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  let errors: JobError[] = [\n    ...current.errors,\n    { source, message: toErrorMessage(error), timestamp: nowIso() },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: JobError = {\n      source: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n      .run(JSON.stringify(errors), updatedAt, jobId)\n  );\n\n  return { ...current, errors, updatedAt };\n}\n\nexport async function requestCancel(jobId: string): Promise<void> {\n  // Set the in-process flag first so a running loop observes the cancel even if the\n  // durable write contends on the shared connection.\n  cancelledJobIds.add(jobId);\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n      .run(nowIso(), jobId)\n  );\n}\n\n// Synchronous so the runner can poll it inline at batch/phase boundaries.\nexport function isCancelRequested(jobId: string): boolean {\n  const db = requireDb();\n  const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n    .get(jobId) as { cancel_requested?: number } | undefined;\n  return !!row && row.cancel_requested === 1;\n}\n\n// Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n// mirror, so it is safe to call thousands of times during a scan without touching\n// the shared SQLite connection. Use isCancelRequested when durability across the\n// in-memory boundary matters (status responses, post-restart).\nexport function isCancelRequestedFast(jobId: string): boolean {\n  return cancelledJobIds.has(jobId);\n}\n\nexport async function completeJob(\n  jobId: string,\n  options: { state: JobLifecycleState; result?: unknown },\n): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n  }\n\n  const updatedAt = nowIso();\n  const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n  const completion = await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n      .run(options.state, resultJson, updatedAt, jobId, current.state)\n  );\n  if (completion.changes === 0) {\n    // The row moved out from under the read-then-check; refuse to clobber a state\n    // another writer set rather than overwriting it from a stale read.\n    throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n  }\n\n  cancelledJobIds.delete(jobId);\n  return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n}\n\n// Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n// re-run fresh, so they are reset to 'failed' rather than re-enqueued.\nexport function resetRunningJobsForKind(\n  kind: MaintenanceJobKind,\n  // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n  // target keeps a caller from persisting an illegal transition past the guard.\n  options: { to: 'failed' | 'cancelled' },\n): string[] {\n  const db = requireDb();\n  const rows = db.prepare(`\n    SELECT id FROM maintenance_jobs\n    WHERE kind = ? AND state IN ('queued', 'running')\n  `).all(kind) as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE kind = ? AND state IN ('queued', 'running')\n    `).run(options.to, nowIso(), kind)\n  );\n\n  for (const row of rows) {\n    cancelledJobIds.delete(row.id);\n  }\n  return rows.map((r) => r.id);\n}\n\nexport function isTerminalJobState(state: JobLifecycleState): boolean {\n  return TERMINAL_STATES.has(state);\n}","lineStart":1,"lineEnd":413,"totalLines":413,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","time":{"start":1781763522576,"end":1781763522597}},"metadata":{"openai":{"itemId":"fc_07d11185e93d73e2016a338dc1a4748191bb925f2c42d850dd"}},"id":"prt_ed961c00e001SJvzk18k9MaVLG","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed9618031001aMd6sS9Tw21zdA"}}
{"type":"tool_use","timestamp":1781763522612,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_KsYxRRJEz0cRRqqxRskJBhkb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","offset":1,"limit":2400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Index\n3: // ───────────────────────────────────────────────────────────────\n4: import path from 'path';\n5: import { createHash } from 'node:crypto';\n6: \n7: /* ───────────────────────────────────────────────────────────────\n8:    1. CORE AND UTILS IMPORTS\n9: ──────────────────────────────────────────────────────────────── */\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\n13: import { beginMaintenance } from '../lib/storage/maintenance-marker.js';\n14: import { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\n15: import { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\n16: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n17: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n18: import {\n19:   runTriggerEmbeddingBackfill,\n20:   type TriggerEmbeddingBackfillResult,\n21: } from '../lib/search/trigger-embedding-backfill.js';\n22: \n23: /* ───────────────────────────────────────────────────────────────\n24:    2. LIB MODULE IMPORTS\n25: ──────────────────────────────────────────────────────────────── */\n26: \n27: import { recordHistory } from '../lib/storage/history.js';\n28: import * as checkpoints from '../lib/storage/checkpoints.js';\n29: import * as memoryParser from '../lib/parsing/memory-parser.js';\n30: import * as embeddings from '../lib/providers/embeddings.js';\n31: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n32: import * as causalEdges from '../lib/storage/causal-edges.js';\n33: import * as vectorIndex from '../lib/search/vector-index.js';\n34: import { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\n35: import { runPostMutationHooks } from './mutation-hooks.js';\n36: import { createStatediffAction } from '../lib/storage/statediff.js';\n37: import { repairIncompleteMarkers } from './save/enrichment-state.js';\n38: import { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\n39: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n40: import {\n41:   findConstitutionalFiles,\n42:   findGraphMetadataFiles,\n43:   findSpecDocuments,\n44:   detectSpecLevel,\n45:   type DiscoveryCapExceeded,\n46:   type DiscoveryFileList,\n47: } from './memory-index-discovery.js';\n48: import {\n49:   EMPTY_ALIAS_CONFLICT_SUMMARY,\n50:   createDefaultDivergenceReconcileSummary,\n51:   detectAliasConflictsFromIndex,\n52:   summarizeAliasConflicts,\n53:   runDivergenceReconcileHooks,\n54:   type AliasConflictSummary,\n55:   type DivergenceReconcileSummary,\n56: } from './memory-index-alias.js';\n57: \n58: // Standardized response structure\n59: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n60: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n61: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n62: import {\n63:   createJobId,\n64:   createMaintenanceJob,\n65:   setJobState,\n66:   setJobPhase,\n67:   setJobProgress,\n68:   appendJobError,\n69:   completeJob,\n70:   isCancelRequestedFast,\n71: } from '../lib/ops/job-store.js';\n72: \n73: // Shared handler types\n74: import type { MCPResponse, EmbeddingProfile } from './types.js';\n75: import type { StatediffAction } from '../lib/storage/statediff.js';\n76: \n77: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n78: // Feature catalog: Async ingestion job lifecycle\n79: \n80: \n81: /* ───────────────────────────────────────────────────────────────\n82:    4. TYPES\n83: ──────────────────────────────────────────────────────────────── */\n84: \n85: interface IndexResult {\n86:   status: string;\n87:   id?: number;\n88:   specFolder?: string;\n89:   title?: string | null;\n90:   error?: string;\n91:   errorDetail?: string;\n92:   [key: string]: unknown;\n93: }\n94: \n95: /** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\n96: function isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n97:   return (\n98:     typeof result === 'object' &&\n99:     result !== null &&\n100:     typeof (result as { status?: unknown }).status === 'string' &&\n101:     !('retries_failed' in result)\n102:   );\n103: }\n104: \n105: function emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n106:   return { maxNodes: false, depth: false, gitignoreSize: false };\n107: }\n108: \n109: function mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n110:   return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n111:     maxNodes: merged.maxNodes || cap?.maxNodes === true,\n112:     depth: merged.depth || cap?.depth === true,\n113:     gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n114:   }), emptyDiscoveryCapExceeded());\n115: }\n116: \n117: function discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n118:   const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n119:   return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n120: }\n121: \n122: function discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n123:   return (files as Partial<DiscoveryFileList>).capExceeded;\n124: }\n125: \n126: /** Individual file result from a memory index scan. */\n127: interface ScanFileEntry {\n128:   file: string;\n129:   filePath?: string;\n130:   status?: string;\n131:   specFolder?: string;\n132:   id?: number;\n133:   isConstitutional?: boolean;\n134:   error?: string;\n135:   errorDetail?: string;\n136: }\n137: \n138: interface CheckpointRepairReport {\n139:   sentinelPresent: boolean;\n140:   attempted: boolean;\n141:   completed: number;\n142:   failed: number;\n143:   skipped: number;\n144:   cleared: boolean;\n145:   error: string | null;\n146: }\n147: \n148: interface ScanResults {\n149:   scanned: number;\n150:   indexed: number;\n151:   updated: number;\n152:   unchanged: number;\n153:   failed: number;\n154:   deferred: number;\n155:   skipped_mtime: number;\n156:   mtimeUpdates: number;\n157:   staleDeleted: number;\n158:   staleDeleteFailed: number;\n159:   postInsertEnrichmentRepaired: number;\n160:   nearDuplicateRepaired: number;\n161:   orphanSwept: number;\n162:   orphanSweepFailed: number;\n163:   orphanSweepScanned: number;\n164:   orphanSweepNextCursor: number | null;\n165:   moveReconciled?: number;\n166:   files: ScanFileEntry[];\n167:   constitutional: {\n168:     found: number;\n169:     indexed: number;\n170:     alreadyIndexed: number;\n171:   };\n172:   incremental: {\n173:     enabled: boolean;\n174:     fast_path_skips: number;\n175:     mtime_changed: number;\n176:     metadataPromoter: {\n177:       processed: number;\n178:       resolved: number;\n179:       inserted: number;\n180:       skippedManual: number;\n181:       staleTombstoned: number;\n182:       staleDeleted: number;\n183:       warnings: number;\n184:     };\n185:   };\n186:   dedup: {\n187:     inputTotal: number;\n188:     uniqueTotal: number;\n189:     duplicatesSkipped: number;\n190:   };\n191:   aliasConflicts: AliasConflictSummary;\n192:   divergenceReconcile: DivergenceReconcileSummary;\n193:   checkpointRepair: CheckpointRepairReport;\n194:   triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n195:   warnings: string[];\n196:   capExceeded: DiscoveryCapExceeded;\n197: }\n198: \n199: interface CategorizedFiles {\n200:   toIndex: string[];\n201:   toUpdate: string[];\n202:   toSkip: string[];\n203:   toDelete: string[];\n204: }\n205: \n206: interface ScanKeyOptions {\n207:   spec_folder: string | null;\n208:   force: boolean;\n209:   incremental: boolean;\n210:   include_constitutional: boolean;\n211:   include_spec_docs: boolean;\n212: }\n213: \n214: interface RecordDeleteResult {\n215:   deleted: number;\n216:   failed: number;\n217:   actions: StatediffAction[];\n218: }\n219: \n220: interface OrphanSweepDeleteResult {\n221:   swept: number;\n222:   failed: number;\n223:   scannedRows: number;\n224:   nextCursor: number | null;\n225:   actions: StatediffAction[];\n226: }\n227: \n228: interface OrphanSweepCandidates {\n229:   swept: number;\n230:   nextCursor: number | null;\n231:   scannedRows: number;\n232:   orphanRecordIds?: number[];\n233: }\n234: \n235: const ORPHAN_SWEEP_LIMIT = 200;\n236: \n237: // Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n238: // breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n239: // launcher spawns a second daemon. Sampling timer drift distinguishes a true\n240: // event-loop block from a phase that is merely slow but yields — the two need\n241: // different fixes (chunk-and-yield vs launcher-side probe tolerance).\n242: const LOOP_LAG_SAMPLE_MS = 250;\n243: const LOOP_LAG_WARN_MS = 1000;\n244: \n245: function emptyCheckpointRepairReport(): CheckpointRepairReport {\n246:   return {\n247:     sentinelPresent: false,\n248:     attempted: false,\n249:     completed: 0,\n250:     failed: 0,\n251:     skipped: 0,\n252:     cleared: false,\n253:     error: null,\n254:   };\n255: }\n256: \n257: function runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n258:   try {\n259:     const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n260:       source: 'memory_index_scan',\n261:       actor: 'mcp:memory_index_scan',\n262:     });\n263:     return {\n264:       sentinelPresent: repair.sentinelPresent,\n265:       attempted: repair.attempted,\n266:       completed: repair.summary?.completed.length ?? 0,\n267:       failed: repair.summary?.failed.length ?? 0,\n268:       skipped: repair.summary?.skipped.length ?? 0,\n269:       cleared: repair.cleared,\n270:       error: repair.error,\n271:     };\n272:   } catch (error: unknown) {\n273:     return {\n274:       ...emptyCheckpointRepairReport(),\n275:       sentinelPresent: true,\n276:       attempted: true,\n277:       error: toErrorMessage(error),\n278:     };\n279:   }\n280: }\n281: \n282: function createScanKey(options: ScanKeyOptions): string {\n283:   const normalized = {\n284:     spec_folder: options.spec_folder ?? null,\n285:     force: !!options.force,\n286:     incremental: !!options.incremental,\n287:     include_constitutional: !!options.include_constitutional,\n288:     include_spec_docs: !!options.include_spec_docs,\n289:   };\n290: \n291:   return createHash('sha256')\n292:     .update(JSON.stringify(normalized))\n293:     .digest('hex')\n294:     .slice(0, 16);\n295: }\n296: \n297: interface ScanArgs {\n298:   specFolder?: string | null;\n299:   force?: boolean;\n300:   includeConstitutional?: boolean;\n301:   includeSpecDocs?: boolean;\n302:   incremental?: boolean;\n303:   // Opt-in: run the scan as a background job and return a jobId immediately.\n304:   background?: boolean;\n305:   tenantId?: string;\n306:   userId?: string;\n307:   agentId?: string;\n308:   sessionId?: string;\n309:   provenanceSource?: string;\n310:   provenanceActor?: string;\n311:   governedAt?: string;\n312:   retentionPolicy?: 'keep' | 'ephemeral';\n313:   deleteAfter?: string;\n314: }\n315: \n316: /* ───────────────────────────────────────────────────────────────\n317:    5. SHARED INDEXING LOGIC\n318: ──────────────────────────────────────────────────────────────── */\n319: \n320: import { indexMemoryFile } from './memory-save.js';\n321: import type { GovernanceDecision } from '../lib/governance/scope-governance.js';\n322: import type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n323: \n324: /** Index a single memory file, delegating to the shared indexMemoryFile logic */\n325: async function indexSingleFile(\n326:   filePath: string,\n327:   force: boolean = false,\n328:   options?: {\n329:     qualityGateMode?: 'enforce' | 'warn-only';\n330:     fromScan?: boolean;\n331:     asyncEmbedding?: boolean;\n332:     governance?: GovernanceDecision;\n333:     provenance?: WriteProvenanceContext;\n334:   },\n335: ): Promise<IndexResult> {\n336:   return indexMemoryFile(filePath, {\n337:     force,\n338:     qualityGateMode: options?.qualityGateMode,\n339:     fromScan: options?.fromScan,\n340:     asyncEmbedding: options?.asyncEmbedding,\n341:     governance: options?.governance,\n342:     provenance: options?.provenance,\n343:   });\n344: }\n345: \n346: /* ───────────────────────────────────────────────────────────────\n347:    6. MEMORY INDEX SCAN HANDLER\n348: ──────────────────────────────────────────────────────────────── */\n349: \n350: // Hooks let a background runner observe cancellation and report phase/progress.\n351: // On the synchronous path every hook is undefined, so behavior is identical.\n352: interface ScanRunContext {\n353:   isCancelled?: () => boolean;\n354:   onPhase?: (phase: string) => void;\n355:   onProgress?: (progress: { processed: number; total: number }) => void;\n356: }\n357: \n358: // Pull the envelope.data field back out of an MCP response so status can echo it.\n359: function extractEnvelopeData(response: MCPResponse): unknown {\n360:   try {\n361:     const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n362:     if (typeof text !== 'string') return null;\n363:     const parsed = JSON.parse(text) as { data?: unknown };\n364:     return parsed?.data ?? null;\n365:   } catch (_error: unknown) {\n366:     return null;\n367:   }\n368: }\n369: \n370: // Persisted payload for debugging: scan shape only, no governance identifiers.\n371: function redactScanArgs(args: ScanArgs): Record<string, unknown> {\n372:   return {\n373:     specFolder: args.specFolder ?? null,\n374:     force: !!args.force,\n375:     includeConstitutional: args.includeConstitutional !== false,\n376:     includeSpecDocs: args.includeSpecDocs !== false,\n377:     incremental: args.incremental !== false,\n378:     background: true,\n379:   };\n380: }\n381: \n382: function cancelledScanEnvelope(scanKey: string): MCPResponse {\n383:   return createMCPSuccessResponse({\n384:     tool: 'memory_index_scan',\n385:     summary: 'Index scan cancelled before completion',\n386:     data: { status: 'cancelled', cancelled: true, scanKey },\n387:     hints: ['The scan was cancelled via memory_index_scan_cancel'],\n388:   });\n389: }\n390: \n391: /** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\n392: async function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n393:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n394:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n395:   if (restoreBarrier) {\n396:     recordMaintenanceRun('memory_index_scan', { status: 'error' });\n397:     return createMCPErrorResponse({\n398:       tool: 'memory_index_scan',\n399:       error: restoreBarrier.message,\n400:       code: restoreBarrier.code,\n401:       recovery: {\n402:         hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n403:         actions: ['Wait for the restore to finish', 'Retry the index scan'],\n404:         severity: 'warning',\n405:       },\n406:     });\n407:   }\n408: \n409:   const {\n410:     specFolder: spec_folder = null,\n411:     force = false,\n412:     includeConstitutional: include_constitutional = true,\n413:     includeSpecDocs: include_spec_docs = true,\n414:     incremental = true\n415:   } = args;\n416:   const scanKey = createScanKey({\n417:     spec_folder,\n418:     force,\n419:     incremental,\n420:     include_constitutional,\n421:     include_spec_docs,\n422:   });\n423:   const governedIngest = requiresGovernedIngest(args);\n424:   const governanceDecision = validateGovernedIngest(args);\n425:   if (!governanceDecision.allowed) {\n426:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n427:   }\n428: \n429:   // Pre-flight dimension check\n430:   try {\n431:     const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n432:     if (profile) {\n433:       console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n434:     }\n435:   } catch (dimCheckError: unknown) {\n436:     const message = toErrorMessage(dimCheckError);\n437:     console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n438:   }\n439: \n440:   await checkDatabaseUpdated();\n441: \n442:   // Atomic scan lease check.\n443:   // Reserve scan_started_at up front to avoid check-then-set race windows.\n444:   const now = Date.now();\n445:   const lease = await acquireIndexScanLease({\n446:     now,\n447:     cooldownMs: INDEX_SCAN_COOLDOWN,\n448:   });\n449:   if (!lease.acquired) {\n450:     let message: string;\n451:     if (lease.reason === 'lease_active') {\n452:       message = 'A scan is already in progress; this call coalesced onto it.';\n453:     } else if (lease.reason === 'contention') {\n454:       message = 'The index DB is briefly locked by another writer; retry shortly.';\n455:     } else {\n456:       message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n457:     }\n458:     recordMaintenanceRun('memory_index_scan', {\n459:       status: 'coalesced',\n460:       counts: { waitSeconds: lease.waitSeconds },\n461:       staleCandidates: 0,\n462:     });\n463:     return createMCPSuccessResponse({\n464:       tool: 'memory_index_scan',\n465:       summary: message,\n466:       data: {\n467:         success: true,\n468:         coalesced: true,\n469:         status: 'coalesced',\n470:         reason: lease.reason,\n471:         scanKey,\n472:         waitSeconds: lease.waitSeconds,\n473:         nextPollAfterMs: lease.waitSeconds * 1000,\n474:         message,\n475:       },\n476:       hints: [message],\n477:     });\n478:   }\n479: \n480:   let scanLeaseReleased = false;\n481:   const releaseScanLease = async (): Promise<void> => {\n482:     if (scanLeaseReleased) return;\n483:     scanLeaseReleased = true;\n484:     await completeIndexScanLease(Date.now());\n485:   };\n486: \n487:   const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n488: \n489:   // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n490:   // processBatches() runs all batches sequentially and may exceed the lease expiry\n491:   // window (each batch waits on embedding/API latency). Without a periodic refresh\n492:   // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n493:   // launch a second parallel scan. Refresh well inside the expiry window (a third of\n494:   // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n495:   // from holding the event loop open at shutdown; finally clears it before release.\n496:   const leaseExpiryMs = lease.leaseExpiryMs;\n497:   const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n498:   let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n499: \n500:   // Background scans pass an onPhase hook; the synchronous foreground path does not.\n501:   // Gate diagnostics on it so the synchronous path's behavior stays identical.\n502:   const instrument = typeof ctx.onPhase === 'function';\n503:   let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n504:   let maxLoopLagMs = 0;\n505: \n506:   try {\n507:   leaseHeartbeat = setInterval(() => {\n508:     refreshScanLease();\n509:   }, leaseHeartbeatMs);\n510:   leaseHeartbeat.unref?.();\n511: \n512:   if (instrument) {\n513:     let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n514:     loopLagTimer = setInterval(() => {\n515:       const sampledAt = Date.now();\n516:       const lag = sampledAt - loopLagExpectedAt;\n517:       loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n518:       if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n519:       if (lag > LOOP_LAG_WARN_MS) {\n520:         // A late sample means the loop was blocked since the prior tick; logged\n521:         // adjacent to the phase=... line of whatever phase just ran, so the daemon\n522:         // log timeline fingers the blocking phase.\n523:         console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n524:       }\n525:     }, LOOP_LAG_SAMPLE_MS);\n526:     loopLagTimer.unref?.();\n527:   }\n528: \n529:   if (ctx.isCancelled?.()) {\n530:     await releaseScanLease();\n531:     return cancelledScanEnvelope(scanKey);\n532:   }\n533:   ctx.onPhase?.('discovering');\n534: \n535:   const workspacePath: string = DEFAULT_BASE_PATH;\n536: \n537:   const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n538:   const specDocFiles = include_spec_docs\n539:     ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n540:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n541:   const graphMetadataFiles = include_spec_docs\n542:     ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n543:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n544:   const walkerWarnings = [\n545:     ...discoveryWarnings(specDocFiles),\n546:     ...discoveryWarnings(graphMetadataFiles),\n547:   ];\n548:   const walkerCapExceeded = mergeDiscoveryCapExceeded(\n549:     discoveryCaps(specDocFiles),\n550:     discoveryCaps(graphMetadataFiles),\n551:   );\n552: \n553:   const canonicalKeyCache = new Map<string, string>();\n554:   const getCachedKey = (filePath: string): string => {\n555:     const cached = canonicalKeyCache.get(filePath);\n556:     if (cached) {\n557:       return cached;\n558:     }\n559: \n560:     const canonicalKey = getCanonicalPathKey(filePath);\n561:     canonicalKeyCache.set(filePath, canonicalKey);\n562:     return canonicalKey;\n563:   };\n564: \n565:   const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n566:   const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n567:   const seenCanonicalFiles = new Set<string>();\n568:   const files: string[] = [];\n569: \n570:   for (const filePath of mergedFiles) {\n571:     const canonicalKey = getCachedKey(filePath);\n572:     if (seenCanonicalFiles.has(canonicalKey)) {\n573:       continue;\n574:     }\n575:     seenCanonicalFiles.add(canonicalKey);\n576:     files.push(filePath);\n577:   }\n578: \n579:   const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n580:   if (dedupDuplicatesSkipped > 0) {\n581:     console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n582:   }\n583: \n584:   const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n585:     if (recordIds.length === 0) {\n586:       return { deleted: 0, failed: 0, actions: [] };\n587:     }\n588: \n589:     let deleted = 0;\n590:     let failed = 0;\n591:     const actions: StatediffAction[] = [];\n592: \n593:     for (const staleRecordId of recordIds) {\n594:       try {\n595:         const database = vectorIndex.getDb();\n596:         const staleSnapshot = database?.prepare(\n597:           'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n598:         ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n599: \n600:         if (database) {\n601:           causalEdges.init(database);\n602:           causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n603:             reason: 'memory_index stale record cleanup',\n604:             command: 'memory-index.deleteIndexedRecordIds',\n605:             restoreContext: {\n606:               memoryId: staleRecordId,\n607:               specFolder: staleSnapshot?.spec_folder ?? null,\n608:               filePath: staleSnapshot?.file_path ?? null,\n609:             },\n610:           });\n611:         }\n612: \n613:         if (vectorIndex.deleteMemory(staleRecordId)) {\n614:           deleted++;\n615:           actions.push(createStatediffAction('delete', {\n616:             target: 'memory_index',\n617:             key: String(staleRecordId),\n618:             sourceOperation: 'scan',\n619:             oldStateHash: null,\n620:             newStateHash: null,\n621:             metadata: {\n622:               filePath: staleSnapshot?.file_path ?? null,\n623:               specFolder: staleSnapshot?.spec_folder ?? null,\n624:             },\n625:           }));\n626:           // Record DELETE history only after confirmed deletion.\n627:           try {\n628:             recordHistory(\n629:               staleRecordId,\n630:               'DELETE',\n631:               staleSnapshot?.file_path ?? null,\n632:               null,\n633:               'mcp:memory_index_scan',\n634:               staleSnapshot?.spec_folder ?? null,\n635:             );\n636:           } catch (_histErr: unknown) {\n637:             // History recording is best-effort\n638:           }\n639:         } else {\n640:           failed++;\n641:         }\n642:       } catch (_error: unknown) {\n643:         failed++;\n644:       }\n645:     }\n646: \n647:     return { deleted, failed, actions };\n648:   };\n649: \n650:   const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n651:     if (paths.length === 0) {\n652:       return { deleted: 0, failed: 0, actions: [] };\n653:     }\n654: \n655:     return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n656:   };\n657: \n658:   const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n659:     if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n660:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n661:     }\n662: \n663:     const sweepOrphanIndexRows = (incrementalIndex as {\n664:       sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n665:     }).sweepOrphanIndexRows;\n666: \n667:     if (typeof sweepOrphanIndexRows !== 'function') {\n668:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n669:     }\n670: \n671:     const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n672:     const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n673:     return {\n674:       swept: deleteResult.deleted,\n675:       failed: deleteResult.failed,\n676:       scannedRows: sweep.scannedRows,\n677:       nextCursor: sweep.nextCursor,\n678:       actions: deleteResult.actions,\n679:     };\n680:   };\n681: \n682:   const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n683:     try {\n684:       runPostMutationHooks('scan', { ...context, statediffActions: actions });\n685:     } catch (error: unknown) {\n686:       console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n687:     }\n688:   };\n689: \n690:   const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n691:     result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n692:   );\n693: \n694:   const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n695:     target: 'memory_index',\n696:     key: 'trigger-embedding-backfill',\n697:     sourceOperation: 'scan',\n698:     metadata: {\n699:       readyRows: result.readyRows,\n700:       failedRows: result.failedRows,\n701:       pendingRows: result.pendingRows,\n702:     },\n703:   });\n704: \n705:   const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n706:     if (actions.length === 0) {\n707:       return;\n708:     }\n709:     results.aliasConflicts = detectAliasConflictsFromIndex();\n710:     results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n711:   };\n712: \n713:   const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n714:     try {\n715:       const repairResult = await repairIncompleteMarkers(\n716:         { database: requireDb(), plannerMode: 'full-auto' },\n717:         { limit: BATCH_SIZE },\n718:       );\n719:       if (repairResult.failed > 0) {\n720:         console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n721:       }\n722:       return repairResult.repaired;\n723:     } catch (error: unknown) {\n724:       console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n725:       return 0;\n726:     }\n727:   };\n728: \n729:   const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n730:     if (!isMemoryIdempotencyEnabled()) {\n731:       return 0;\n732:     }\n733:     try {\n734:       const database = requireDb();\n735:       const rows = database.prepare(`\n736:         SELECT id, spec_folder, title, content_text, content_hash,\n737:                tenant_id, user_id, agent_id, session_id\n738:         FROM memory_index\n739:         WHERE parent_id IS NULL\n740:           AND embedding_status = 'success'\n741:           AND content_text IS NOT NULL\n742:           AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n743:         ORDER BY id ASC\n744:         LIMIT ?\n745:       `).all(BATCH_SIZE) as Array<{\n746:         id: number;\n747:         spec_folder: string;\n748:         title: string | null;\n749:         content_text: string;\n750:         content_hash: string | null;\n751:         tenant_id: string | null;\n752:         user_id: string | null;\n753:         agent_id: string | null;\n754:         session_id: string | null;\n755:       }>;\n756:       let repaired = 0;\n757:       for (const row of rows) {\n758:         try {\n759:           const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n760:           const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n761:           recordNearDuplicateCheck({\n762:             database,\n763:             memoryId: row.id,\n764:             specFolder: row.spec_folder,\n765:             contentHash: row.content_hash,\n766:             embedding,\n767:             scope: {\n768:               tenantId: row.tenant_id,\n769:               userId: row.user_id,\n770:               agentId: row.agent_id,\n771:               sessionId: row.session_id,\n772:             },\n773:           });\n774:           repaired++;\n775:         } catch (error: unknown) {\n776:           console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n777:         }\n778:       }\n779:       return repaired;\n780:     } catch (error: unknown) {\n781:       console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n782:       return 0;\n783:     }\n784:   };\n785: \n786:   // Time each un-yielded tail phase: because these phases do not yield, their\n787:   // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n788:   // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n789:   // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n790:   const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n791:     ctx.onPhase?.(phase);\n792:     if (!instrument) {\n793:       return await fn();\n794:     }\n795:     const startedAt = Date.now();\n796:     try {\n797:       return await fn();\n798:     } finally {\n799:       console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n800:     }\n801:   };\n802: \n803:   if (files.length === 0) {\n804:     let staleDeleted = 0;\n805:     let staleDeleteFailed = 0;\n806:     const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n807:     const postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n808:     const nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n809: \n810:     if (incremental && !force) {\n811:       const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n812:       const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n813:       staleDeleted = staleDeleteResult.deleted;\n814:       staleDeleteFailed = staleDeleteResult.failed;\n815:       if (staleDeleted > 0) {\n816:         runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n817:       }\n818:     }\n819: \n820:     const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n821:       runTriggerEmbeddingBackfill(requireDb(), {\n822:         isCancelled: () => ctx.isCancelled?.() ?? false,\n823:       }));\n824: \n825:     if (orphanSweepResult.swept > 0) {\n826:       runScanInvalidationHooks({\n827:         orphanSwept: orphanSweepResult.swept,\n828:         orphanSweepFailed: orphanSweepResult.failed,\n829:         operation: 'orphan-sweep',\n830:       }, orphanSweepResult.actions);\n831:     }\n832:     if (postInsertEnrichmentRepaired > 0) {\n833:       runScanInvalidationHooks({\n834:         postInsertEnrichmentRepaired,\n835:         operation: 'post-insert-enrichment-repair',\n836:       }, [createStatediffAction('upsert', {\n837:         target: 'graph_edge',\n838:         key: 'post-insert-enrichment-repair',\n839:         sourceOperation: 'scan',\n840:         metadata: { postInsertEnrichmentRepaired },\n841:       })]);\n842:     }\n843:     if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n844:       runScanInvalidationHooks({\n845:         triggerEmbeddingBackfill,\n846:         operation: 'trigger-embedding-backfill',\n847:       }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n848:     }\n849: \n850:     recordMaintenanceRun('memory_index_scan', {\n851:       status: 'success',\n852:       counts: {\n853:         scanned: 0,\n854:         indexed: 0,\n855:         updated: 0,\n856:         unchanged: 0,\n857:         failed: 0,\n858:         staleDeleted,\n859:         staleDeleteFailed,\n860:         orphanSwept: orphanSweepResult.swept,\n861:       },\n862:       staleCandidates: staleDeleted + staleDeleteFailed,\n863:     });\n864:     await releaseScanLease();\n865:     return createMCPSuccessResponse({\n866:       tool: 'memory_index_scan',\n867:       summary: 'No memory files found',\n868:       data: {\n869:         status: 'complete',\n870:         scanKey,\n871:         scanned: 0,\n872:         indexed: 0,\n873:         updated: 0,\n874:         unchanged: 0,\n875:         failed: 0,\n876:         staleDeleted,\n877:         staleDeleteFailed,\n878:         postInsertEnrichmentRepaired,\n879:         nearDuplicateRepaired,\n880:         triggerEmbeddingBackfill,\n881:         orphanSwept: orphanSweepResult.swept,\n882:         orphanSweepFailed: orphanSweepResult.failed,\n883:         orphanSweepScanned: orphanSweepResult.scannedRows,\n884:         orphanSweepNextCursor: orphanSweepResult.nextCursor,\n885:         checkpointRepair,\n886:         warnings: walkerWarnings,\n887:         capExceeded: walkerCapExceeded,\n888:       },\n889:       hints: [\n890:         ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n891:         ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n892:         ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n893:         ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n894:         ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n895:         ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n896:         ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n897:         ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n898:         ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n899:         ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n900:         'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n901:         'Constitutional files go in .opencode/skills/*/constitutional/'\n902:       ]\n903:     });\n904:   }\n905: \n906:   const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n907: \n908:   const results: ScanResults = {\n909:     scanned: files.length,\n910:     indexed: 0,\n911:     updated: 0,\n912:     unchanged: 0,\n913:     failed: 0,\n914:     deferred: 0,\n915:     skipped_mtime: 0,\n916:     mtimeUpdates: 0,\n917:     staleDeleted: 0,\n918:     staleDeleteFailed: 0,\n919:     postInsertEnrichmentRepaired: 0,\n920:     nearDuplicateRepaired: 0,\n921:     orphanSwept: 0,\n922:     orphanSweepFailed: 0,\n923:     orphanSweepScanned: 0,\n924:     orphanSweepNextCursor: null,\n925:     files: [],\n926:     constitutional: {\n927:       found: constitutionalFiles.length,\n928:       indexed: 0,\n929:       alreadyIndexed: 0\n930:     },\n931:     incremental: {\n932:       enabled: incremental && !force,\n933:       fast_path_skips: 0,\n934:       mtime_changed: 0,\n935:       metadataPromoter: {\n936:         processed: 0,\n937:         resolved: 0,\n938:         inserted: 0,\n939:         skippedManual: 0,\n940:         staleTombstoned: 0,\n941:         staleDeleted: 0,\n942:         warnings: 0,\n943:       }\n944:     },\n945:     dedup: {\n946:       inputTotal: mergedFiles.length,\n947:       uniqueTotal: files.length,\n948:       duplicatesSkipped: dedupDuplicatesSkipped,\n949:     },\n950:     aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n951:     divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n952:     checkpointRepair,\n953:     warnings: walkerWarnings,\n954:     capExceeded: walkerCapExceeded,\n955:   };\n956:   const scanAppliedActions: StatediffAction[] = [];\n957: \n958:   let filesToIndex: string[] = files;\n959:   let filesToDelete: string[] = [];\n960: \n961:   if (incremental && !force) {\n962:     const startCategorize = Date.now();\n963:     const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n964: \n965:     filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n966:     filesToDelete = categorized.toDelete;\n967: \n968:     results.unchanged = categorized.toSkip.length;\n969:     results.skipped_mtime = categorized.toSkip.length;\n970:     results.incremental.fast_path_skips = categorized.toSkip.length;\n971:     results.incremental.mtime_changed = categorized.toUpdate.length;\n972: \n973:     for (const unchangedPath of categorized.toSkip) {\n974:       if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n975:         results.constitutional.alreadyIndexed++;\n976:       }\n977:     }\n978: \n979:     const categorizeTime = Date.now() - startCategorize;\n980:     console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n981:     console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n982:   }\n983: \n984:   // Attempt move reconciliation before full delete+reindex cycle.\n985:   // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n986:   // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n987:   // stored-document_type cross-checks; the matched row is updated in place.\n988:   if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n989:     const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n990:     if (moveResult.reconciled.length > 0) {\n991:       results.moveReconciled = moveResult.reconciled.length;\n992:       filesToDelete = moveResult.filteredToDelete;\n993:       filesToIndex = moveResult.filteredToIndex;\n994:       console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n995:     }\n996:   }\n997: \n998:   const plannedScanActions = [\n999:     ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n1000:       target: 'memory_index',\n1001:       key: getCachedKey(filePath),\n1002:       sourceOperation: 'scan',\n1003:       metadata: { filePath },\n1004:     })),\n1005:     ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n1006:       target: 'memory_index',\n1007:       key: getCachedKey(filePath),\n1008:       sourceOperation: 'scan',\n1009:       metadata: { filePath },\n1010:     })),\n1011:   ];\n1012:   if (plannedScanActions.length > 0) {\n1013:     console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n1014:   }\n1015: \n1016:   // Track successfully indexed files for post-indexing mtime update.\n1017:   // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n1018:   // Failed files keep their old mtime so shouldReindex() returns 'modified'\n1019:   // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n1020:   // Before indexing would cause silent data loss — a failed file would be\n1021:   // Marked \"already indexed\" and permanently skipped.\n1022:   const successfullyIndexedFiles: string[] = [];\n1023:   const scanBatchSize = BATCH_SIZE;\n1024: \n1025:   ctx.onPhase?.('indexing');\n1026:   ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n1027: \n1028:   if (filesToIndex.length > 0) {\n1029:     let processedInScan = 0;\n1030:     const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n1031:       // Cancellation is checked between files (mirrors ingest). A cancelled file is\n1032:       // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n1033:       if (ctx.isCancelled?.()) {\n1034:         return { status: 'cancelled' } as IndexResult;\n1035:       }\n1036:       const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n1037:       // Constitutional markdown is policy text, not evidence-bearing memory.\n1038:       // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n1039:       // strict sufficiency gate would always reject it. Treat constitutional files like\n1040:       // spec docs and pass them through warn-only mode so they index against the same\n1041:       // pipeline without the document-evidence requirements.\n1042:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1043:       // During force reindex, use warn-only for all files — the goal is to index\n1044:       // everything that has valid frontmatter, not to enforce template contracts on\n1045:       // older files created before current templates were established.\n1046:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n1047:       const indexResult = await indexSingleFile(filePath, force, {\n1048:         ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n1049:         fromScan: true,\n1050:         asyncEmbedding: true,\n1051:         governance: governedIngest ? governanceDecision : undefined,\n1052:       });\n1053:       processedInScan += 1;\n1054:       ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n1055:       return indexResult;\n1056:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n1057: \n1058:     for (let i = 0; i < batchResults.length; i++) {\n1059:       const result = batchResults[i];\n1060:       const filePath = filesToIndex[i];\n1061:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1062: \n1063:       if (result.error) {\n1064:         results.failed++;\n1065:         results.files.push({\n1066:           file: path.basename(filePath),\n1067:           filePath,\n1068:           status: 'failed',\n1069:           error: result.error,\n1070:           errorDetail: result.errorDetail\n1071:         });\n1072:       } else if (isIndexResult(result)) {\n1073:         const isSuccessfulStatus =\n1074:           result.status === 'success' ||\n1075:           result.status === 'indexed' ||\n1076:           result.status === 'updated' ||\n1077:           result.status === 'unchanged' ||\n1078:           result.status === 'reinforced' ||\n1079:           result.status === 'duplicate' ||\n1080:           result.status === 'deferred';\n1081:         // A cancelled file was never indexed and was never going to be: counting it\n1082:         // as a failure would attribute an operator-requested stop to a file error.\n1083:         // It is neither success nor failure, so it falls through both tallies.\n1084:         if (!isSuccessfulStatus && result.status !== 'cancelled') {\n1085:           results.failed++;\n1086:         }\n1087: \n1088:         if (result.status === 'indexed') {\n1089:           results.indexed++;\n1090:           successfullyIndexedFiles.push(filePath);\n1091:           scanAppliedActions.push(createStatediffAction('insert', {\n1092:             target: 'memory_index',\n1093:             key: String(result.id ?? getCachedKey(filePath)),\n1094:             sourceOperation: 'scan',\n1095:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1096:           }));\n1097:         } else if (result.status === 'updated') {\n1098:           results.updated++;\n1099:           successfullyIndexedFiles.push(filePath);\n1100:           scanAppliedActions.push(createStatediffAction('upsert', {\n1101:             target: 'memory_index',\n1102:             key: String(result.id ?? getCachedKey(filePath)),\n1103:             sourceOperation: 'scan',\n1104:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1105:           }));\n1106:         } else if (result.status === 'unchanged') {\n1107:           results.unchanged++;\n1108:           successfullyIndexedFiles.push(filePath);\n1109:         } else if (result.status === 'reinforced') {\n1110:           results.updated++;\n1111:           successfullyIndexedFiles.push(filePath);\n1112:           scanAppliedActions.push(createStatediffAction('upsert', {\n1113:             target: 'memory_index',\n1114:             key: String(result.id ?? getCachedKey(filePath)),\n1115:             sourceOperation: 'scan',\n1116:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1117:           }));\n1118:         } else if (result.status === 'duplicate') {\n1119:           results.unchanged++;\n1120:           successfullyIndexedFiles.push(filePath);\n1121:         } else if (result.status === 'deferred') {\n1122:           results.indexed++;\n1123:           results.deferred++;\n1124:           successfullyIndexedFiles.push(filePath);\n1125:           scanAppliedActions.push(createStatediffAction('insert', {\n1126:             target: 'memory_index',\n1127:             key: String(result.id ?? getCachedKey(filePath)),\n1128:             sourceOperation: 'scan',\n1129:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1130:           }));\n1131:         }\n1132: \n1133:         if (isConstitutional) {\n1134:           if (result.status === 'indexed') {\n1135:             results.constitutional.indexed++;\n1136:           } else if (result.status === 'unchanged') {\n1137:             results.constitutional.alreadyIndexed++;\n1138:           }\n1139:         }\n1140: \n1141:         if (result.status !== 'unchanged') {\n1142:           const rejectionDetail = !isSuccessfulStatus\n1143:             ? {\n1144:                 ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n1145:                   ? { rejectionCode: result.rejectionCode }\n1146:                   : {}),\n1147:                 ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n1148:                   ? { rejectionReason: result.rejectionReason }\n1149:                   : (typeof result.message === 'string' && result.message.length > 0\n1150:                     ? { rejectionReason: result.message }\n1151:                     : {})),\n1152:                 ...(typeof result.error === 'string' && result.error.length > 0\n1153:                   ? { error: result.error }\n1154:                   : {}),\n1155:               }\n1156:             : {};\n1157: \n1158:           results.files.push({\n1159:             file: path.basename(filePath),\n1160:             filePath,\n1161:             specFolder: result.specFolder,\n1162:             status: result.status,\n1163:             id: result.id,\n1164:             isConstitutional,\n1165:             ...rejectionDetail,\n1166:           });\n1167:         }\n1168:       } else {\n1169:         results.failed++;\n1170:         results.files.push({\n1171:           file: path.basename(filePath),\n1172:           filePath,\n1173:           status: 'failed',\n1174:           error: 'Unexpected batch result shape',\n1175:           errorDetail: JSON.stringify(result),\n1176:         });\n1177:       }\n1178:     }\n1179:   }\n1180: \n1181:   // Update mtimes ONLY for successfully indexed files, not before indexing.\n1182:   // Failed files keep their old mtime so they are retried on next scan.\n1183:   // This is the ONLY place where scan-triggered mtime updates occur.\n1184:   // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n1185:   // Which rolls back atomically on failure — a complementary safety mechanism.\n1186:   if (successfullyIndexedFiles.length > 0) {\n1187:     const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n1188:     results.mtimeUpdates = mtimeUpdateResult.updated;\n1189:   }\n1190: \n1191:   if (include_spec_docs) {\n1192:     const database = requireDb();\n1193:     let promoterYieldCount = 0;\n1194:     for (const fileResult of results.files) {\n1195:       // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n1196:       // that is the whole corpus, so without a periodic macrotask yield the event\n1197:       // loop is starved for the duration and no IPC (status, cancel, health,\n1198:       // search) can be serviced. Yield and re-check cancellation between rows; the\n1199:       // yield lands between self-contained promoteMetadataEdges transactions, never\n1200:       // inside one, so atomicity on the shared connection is preserved.\n1201:       if (++promoterYieldCount % 200 === 0) {\n1202:         if (ctx.isCancelled?.()) {\n1203:           return cancelledScanEnvelope(scanKey);\n1204:         }\n1205:         await new Promise<void>((resolve) => setImmediate(resolve));\n1206:       }\n1207:       if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n1208:         continue;\n1209:       }\n1210:       try {\n1211:         const promotion = promoteMetadataEdges(database, {\n1212:           memoryId: fileResult.id,\n1213:           filePath: fileResult.filePath,\n1214:         });\n1215:         results.incremental.metadataPromoter.processed += promotion.processed;\n1216:         results.incremental.metadataPromoter.resolved += promotion.resolved;\n1217:         results.incremental.metadataPromoter.inserted += promotion.inserted;\n1218:         results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n1219:         results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n1220:         results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n1221:         results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n1222:         for (const warning of promotion.warnings) {\n1223:           results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n1224:         }\n1225:       } catch (error: unknown) {\n1226:         results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n1227:       }\n1228:     }\n1229:   }\n1230: \n1231:   if (ctx.isCancelled?.()) {\n1232:     return cancelledScanEnvelope(scanKey);\n1233:   }\n1234:   ctx.onPhase?.('post-processing');\n1235: \n1236:   if (filesToDelete.length > 0) {\n1237:     if (results.failed === 0) {\n1238:       const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n1239:       results.staleDeleted = staleDeleteResult.deleted;\n1240:       results.staleDeleteFailed = staleDeleteResult.failed;\n1241:       scanAppliedActions.push(...staleDeleteResult.actions);\n1242:     } else {\n1243:       console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n1244:     }\n1245:   }\n1246: \n1247:   const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n1248:   results.orphanSwept = orphanSweepResult.swept;\n1249:   results.orphanSweepFailed = orphanSweepResult.failed;\n1250:   results.orphanSweepScanned = orphanSweepResult.scannedRows;\n1251:   results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n1252:   scanAppliedActions.push(...orphanSweepResult.actions);\n1253: \n1254:   results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n1255:   if (results.postInsertEnrichmentRepaired > 0) {\n1256:     scanAppliedActions.push(createStatediffAction('upsert', {\n1257:       target: 'graph_edge',\n1258:       key: 'post-insert-enrichment-repair',\n1259:       sourceOperation: 'scan',\n1260:       metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n1261:     }));\n1262:   }\n1263: \n1264:   results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n1265:     runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n1266:   if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1267:     scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n1268:   }\n1269:   results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n1270: \n1271:   // Create causal chains between spec folder documents.\n1272:   // Includes deferred indexing outcomes and incremental single-file updates.\n1273:   if (include_spec_docs) {\n1274:     try {\n1275:       // Determine which spec folders had spec document changes in this scan.\n1276:       // We use parsed document type (not basename) to avoid false positives\n1277:       // From memory/plan.md or similar filenames.\n1278:       const affectedSpecFolders = new Set<string>();\n1279:       for (const fileResult of results.files) {\n1280:         if (!fileResult.specFolder || fileResult.status === 'failed') {\n1281:           continue;\n1282:         }\n1283: \n1284:         if (!fileResult.filePath) {\n1285:           continue;\n1286:         }\n1287: \n1288:         const docType = memoryParser.extractDocumentType(fileResult.filePath);\n1289:         if (\n1290:           docType !== 'memory' &&\n1291:           docType !== 'constitutional'\n1292:         ) {\n1293:           affectedSpecFolders.add(fileResult.specFolder);\n1294:         }\n1295:       }\n1296: \n1297:       if (affectedSpecFolders.size > 0) {\n1298:         const database = requireDb();\n1299:         const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n1300:         initCausalEdges(database);\n1301: \n1302:         // Build full per-folder document map from DB (not just this scan's files).\n1303:         const selectDocIds = database.prepare(`\n1304:           SELECT document_type, MAX(id) AS id\n1305:           FROM memory_index\n1306:           WHERE spec_folder = ?\n1307:             AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n1308:           GROUP BY document_type\n1309:         `);\n1310: \n1311:         let chainsCreated = 0;\n1312:         let foldersProcessed = 0;\n1313:         let chainYieldCount = 0;\n1314: \n1315:         for (const folder of affectedSpecFolders) {\n\n(Output capped at 50 KB. Showing lines 1-1315. Use offset=1316 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CORE AND UTILS IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,\n} from '../lib/search/trigger-embedding-backfill.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as incrementalIndex from '../lib/storage/incremental-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { repairIncompleteMarkers } from './save/enrichment-state.js';\nimport { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\nimport {\n  findConstitutionalFiles,\n  findGraphMetadataFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  type DiscoveryCapExceeded,\n  type DiscoveryFileList,\n} from './memory-index-discovery.js';\nimport {\n  EMPTY_ALIAS_CONFLICT_SUMMARY,\n  createDefaultDivergenceReconcileSummary,\n  detectAliasConflictsFromIndex,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n  type AliasConflictSummary,\n  type DivergenceReconcileSummary,\n} from './memory-index-alias.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\nimport {\n  createJobId,\n  createMaintenanceJob,\n  setJobState,\n  setJobPhase,\n  setJobProgress,\n  appendJobError,\n  completeJob,\n  isCancelRequestedFast,\n} from '../lib/ops/job-store.js';\n\n// Shared handler types\nimport type { MCPResponse, EmbeddingProfile } from './types.js';\nimport type { StatediffAction } from '../lib/storage/statediff.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n// Feature catalog: Async ingestion job lifecycle\n\n\n/* ───────────────────────────────────────────────────────────────\n   4. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface IndexResult {\n  status: string;\n  id?: number;\n  specFolder?: string;\n  title?: string | null;\n  error?: string;\n  errorDetail?: string;\n  [key: string]: unknown;\n}\n\n/** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\nfunction isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n  return (\n    typeof result === 'object' &&\n    result !== null &&\n    typeof (result as { status?: unknown }).status === 'string' &&\n    !('retries_failed' in result)\n  );\n}\n\nfunction emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n  return { maxNodes: false, depth: false, gitignoreSize: false };\n}\n\nfunction mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n  return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n    maxNodes: merged.maxNodes || cap?.maxNodes === true,\n    depth: merged.depth || cap?.depth === true,\n    gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n  }), emptyDiscoveryCapExceeded());\n}\n\nfunction discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n  const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n  return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n}\n\nfunction discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n  return (files as Partial<DiscoveryFileList>).capExceeded;\n}\n\n/** Individual file result from a memory index scan. */\ninterface ScanFileEntry {\n  file: string;\n  filePath?: string;\n  status?: string;\n  specFolder?: string;\n  id?: number;\n  isConstitutional?: boolean;\n  error?: string;\n  errorDetail?: string;\n}\n\ninterface CheckpointRepairReport {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  completed: number;\n  failed: number;\n  skipped: number;\n  cleared: boolean;\n  error: string | null;\n}\n\ninterface ScanResults {\n  scanned: number;\n  indexed: number;\n  updated: number;\n  unchanged: number;\n  failed: number;\n  deferred: number;\n  skipped_mtime: number;\n  mtimeUpdates: number;\n  staleDeleted: number;\n  staleDeleteFailed: number;\n  postInsertEnrichmentRepaired: number;\n  nearDuplicateRepaired: number;\n  orphanSwept: number;\n  orphanSweepFailed: number;\n  orphanSweepScanned: number;\n  orphanSweepNextCursor: number | null;\n  moveReconciled?: number;\n  files: ScanFileEntry[];\n  constitutional: {\n    found: number;\n    indexed: number;\n    alreadyIndexed: number;\n  };\n  incremental: {\n    enabled: boolean;\n    fast_path_skips: number;\n    mtime_changed: number;\n    metadataPromoter: {\n      processed: number;\n      resolved: number;\n      inserted: number;\n      skippedManual: number;\n      staleTombstoned: number;\n      staleDeleted: number;\n      warnings: number;\n    };\n  };\n  dedup: {\n    inputTotal: number;\n    uniqueTotal: number;\n    duplicatesSkipped: number;\n  };\n  aliasConflicts: AliasConflictSummary;\n  divergenceReconcile: DivergenceReconcileSummary;\n  checkpointRepair: CheckpointRepairReport;\n  triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n  warnings: string[];\n  capExceeded: DiscoveryCapExceeded;\n}\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface ScanKeyOptions {\n  spec_folder: string | null;\n  force: boolean;\n  incremental: boolean;\n  include_constitutional: boolean;\n  include_spec_docs: boolean;\n}\n\ninterface RecordDeleteResult {\n  deleted: number;\n  failed: number;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepDeleteResult {\n  swept: number;\n  failed: number;\n  scannedRows: number;\n  nextCursor: number | null;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepCandidates {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds?: number[];\n}\n\nconst ORPHAN_SWEEP_LIMIT = 200;\n\n// Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n// breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n// launcher spawns a second daemon. Sampling timer drift distinguishes a true\n// event-loop block from a phase that is merely slow but yields — the two need\n// different fixes (chunk-and-yield vs launcher-side probe tolerance).\nconst LOOP_LAG_SAMPLE_MS = 250;\nconst LOOP_LAG_WARN_MS = 1000;\n\nfunction emptyCheckpointRepairReport(): CheckpointRepairReport {\n  return {\n    sentinelPresent: false,\n    attempted: false,\n    completed: 0,\n    failed: 0,\n    skipped: 0,\n    cleared: false,\n    error: null,\n  };\n}\n\nfunction runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n  try {\n    const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n      source: 'memory_index_scan',\n      actor: 'mcp:memory_index_scan',\n    });\n    return {\n      sentinelPresent: repair.sentinelPresent,\n      attempted: repair.attempted,\n      completed: repair.summary?.completed.length ?? 0,\n      failed: repair.summary?.failed.length ?? 0,\n      skipped: repair.summary?.skipped.length ?? 0,\n      cleared: repair.cleared,\n      error: repair.error,\n    };\n  } catch (error: unknown) {\n    return {\n      ...emptyCheckpointRepairReport(),\n      sentinelPresent: true,\n      attempted: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction createScanKey(options: ScanKeyOptions): string {\n  const normalized = {\n    spec_folder: options.spec_folder ?? null,\n    force: !!options.force,\n    incremental: !!options.incremental,\n    include_constitutional: !!options.include_constitutional,\n    include_spec_docs: !!options.include_spec_docs,\n  };\n\n  return createHash('sha256')\n    .update(JSON.stringify(normalized))\n    .digest('hex')\n    .slice(0, 16);\n}\n\ninterface ScanArgs {\n  specFolder?: string | null;\n  force?: boolean;\n  includeConstitutional?: boolean;\n  includeSpecDocs?: boolean;\n  incremental?: boolean;\n  // Opt-in: run the scan as a background job and return a jobId immediately.\n  background?: boolean;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. SHARED INDEXING LOGIC\n──────────────────────────────────────────────────────────────── */\n\nimport { indexMemoryFile } from './memory-save.js';\nimport type { GovernanceDecision } from '../lib/governance/scope-governance.js';\nimport type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n\n/** Index a single memory file, delegating to the shared indexMemoryFile logic */\nasync function indexSingleFile(\n  filePath: string,\n  force: boolean = false,\n  options?: {\n    qualityGateMode?: 'enforce' | 'warn-only';\n    fromScan?: boolean;\n    asyncEmbedding?: boolean;\n    governance?: GovernanceDecision;\n    provenance?: WriteProvenanceContext;\n  },\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    force,\n    qualityGateMode: options?.qualityGateMode,\n    fromScan: options?.fromScan,\n    asyncEmbedding: options?.asyncEmbedding,\n    governance: options?.governance,\n    provenance: options?.provenance,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. MEMORY INDEX SCAN HANDLER\n──────────────────────────────────────────────────────────────── */\n\n// Hooks let a background runner observe cancellation and report phase/progress.\n// On the synchronous path every hook is undefined, so behavior is identical.\ninterface ScanRunContext {\n  isCancelled?: () => boolean;\n  onPhase?: (phase: string) => void;\n  onProgress?: (progress: { processed: number; total: number }) => void;\n}\n\n// Pull the envelope.data field back out of an MCP response so status can echo it.\nfunction extractEnvelopeData(response: MCPResponse): unknown {\n  try {\n    const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n    if (typeof text !== 'string') return null;\n    const parsed = JSON.parse(text) as { data?: unknown };\n    return parsed?.data ?? null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\n// Persisted payload for debugging: scan shape only, no governance identifiers.\nfunction redactScanArgs(args: ScanArgs): Record<string, unknown> {\n  return {\n    specFolder: args.specFolder ?? null,\n    force: !!args.force,\n    includeConstitutional: args.includeConstitutional !== false,\n    includeSpecDocs: args.includeSpecDocs !== false,\n    incremental: args.incremental !== false,\n    background: true,\n  };\n}\n\nfunction cancelledScanEnvelope(scanKey: string): MCPResponse {\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: 'Index scan cancelled before completion',\n    data: { status: 'cancelled', cancelled: true, scanKey },\n    hints: ['The scan was cancelled via memory_index_scan_cancel'],\n  });\n}\n\n/** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\nasync function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    recordMaintenanceRun('memory_index_scan', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      recovery: {\n        hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the index scan'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    specFolder: spec_folder = null,\n    force = false,\n    includeConstitutional: include_constitutional = true,\n    includeSpecDocs: include_spec_docs = true,\n    incremental = true\n  } = args;\n  const scanKey = createScanKey({\n    spec_folder,\n    force,\n    incremental,\n    include_constitutional,\n    include_spec_docs,\n  });\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  // Pre-flight dimension check\n  try {\n    const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n    if (profile) {\n      console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n    }\n  } catch (dimCheckError: unknown) {\n    const message = toErrorMessage(dimCheckError);\n    console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n  }\n\n  await checkDatabaseUpdated();\n\n  // Atomic scan lease check.\n  // Reserve scan_started_at up front to avoid check-then-set race windows.\n  const now = Date.now();\n  const lease = await acquireIndexScanLease({\n    now,\n    cooldownMs: INDEX_SCAN_COOLDOWN,\n  });\n  if (!lease.acquired) {\n    let message: string;\n    if (lease.reason === 'lease_active') {\n      message = 'A scan is already in progress; this call coalesced onto it.';\n    } else if (lease.reason === 'contention') {\n      message = 'The index DB is briefly locked by another writer; retry shortly.';\n    } else {\n      message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n    }\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'coalesced',\n      counts: { waitSeconds: lease.waitSeconds },\n      staleCandidates: 0,\n    });\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: message,\n      data: {\n        success: true,\n        coalesced: true,\n        status: 'coalesced',\n        reason: lease.reason,\n        scanKey,\n        waitSeconds: lease.waitSeconds,\n        nextPollAfterMs: lease.waitSeconds * 1000,\n        message,\n      },\n      hints: [message],\n    });\n  }\n\n  let scanLeaseReleased = false;\n  const releaseScanLease = async (): Promise<void> => {\n    if (scanLeaseReleased) return;\n    scanLeaseReleased = true;\n    await completeIndexScanLease(Date.now());\n  };\n\n  const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n\n  // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n  // processBatches() runs all batches sequentially and may exceed the lease expiry\n  // window (each batch waits on embedding/API latency). Without a periodic refresh\n  // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n  // launch a second parallel scan. Refresh well inside the expiry window (a third of\n  // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n  // from holding the event loop open at shutdown; finally clears it before release.\n  const leaseExpiryMs = lease.leaseExpiryMs;\n  const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n  let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n\n  // Background scans pass an onPhase hook; the synchronous foreground path does not.\n  // Gate diagnostics on it so the synchronous path's behavior stays identical.\n  const instrument = typeof ctx.onPhase === 'function';\n  let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n  let maxLoopLagMs = 0;\n\n  try {\n  leaseHeartbeat = setInterval(() => {\n    refreshScanLease();\n  }, leaseHeartbeatMs);\n  leaseHeartbeat.unref?.();\n\n  if (instrument) {\n    let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n    loopLagTimer = setInterval(() => {\n      const sampledAt = Date.now();\n      const lag = sampledAt - loopLagExpectedAt;\n      loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n      if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n      if (lag > LOOP_LAG_WARN_MS) {\n        // A late sample means the loop was blocked since the prior tick; logged\n        // adjacent to the phase=... line of whatever phase just ran, so the daemon\n        // log timeline fingers the blocking phase.\n        console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n      }\n    }, LOOP_LAG_SAMPLE_MS);\n    loopLagTimer.unref?.();\n  }\n\n  if (ctx.isCancelled?.()) {\n    await releaseScanLease();\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('discovering');\n\n  const workspacePath: string = DEFAULT_BASE_PATH;\n\n  const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n  const specDocFiles = include_spec_docs\n    ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const graphMetadataFiles = include_spec_docs\n    ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const walkerWarnings = [\n    ...discoveryWarnings(specDocFiles),\n    ...discoveryWarnings(graphMetadataFiles),\n  ];\n  const walkerCapExceeded = mergeDiscoveryCapExceeded(\n    discoveryCaps(specDocFiles),\n    discoveryCaps(graphMetadataFiles),\n  );\n\n  const canonicalKeyCache = new Map<string, string>();\n  const getCachedKey = (filePath: string): string => {\n    const cached = canonicalKeyCache.get(filePath);\n    if (cached) {\n      return cached;\n    }\n\n    const canonicalKey = getCanonicalPathKey(filePath);\n    canonicalKeyCache.set(filePath, canonicalKey);\n    return canonicalKey;\n  };\n\n  const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n  const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n  const seenCanonicalFiles = new Set<string>();\n  const files: string[] = [];\n\n  for (const filePath of mergedFiles) {\n    const canonicalKey = getCachedKey(filePath);\n    if (seenCanonicalFiles.has(canonicalKey)) {\n      continue;\n    }\n    seenCanonicalFiles.add(canonicalKey);\n    files.push(filePath);\n  }\n\n  const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n  if (dedupDuplicatesSkipped > 0) {\n    console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n  }\n\n  const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n    if (recordIds.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    let deleted = 0;\n    let failed = 0;\n    const actions: StatediffAction[] = [];\n\n    for (const staleRecordId of recordIds) {\n      try {\n        const database = vectorIndex.getDb();\n        const staleSnapshot = database?.prepare(\n          'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n        ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n\n        if (database) {\n          causalEdges.init(database);\n          causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n            reason: 'memory_index stale record cleanup',\n            command: 'memory-index.deleteIndexedRecordIds',\n            restoreContext: {\n              memoryId: staleRecordId,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n              filePath: staleSnapshot?.file_path ?? null,\n            },\n          });\n        }\n\n        if (vectorIndex.deleteMemory(staleRecordId)) {\n          deleted++;\n          actions.push(createStatediffAction('delete', {\n            target: 'memory_index',\n            key: String(staleRecordId),\n            sourceOperation: 'scan',\n            oldStateHash: null,\n            newStateHash: null,\n            metadata: {\n              filePath: staleSnapshot?.file_path ?? null,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n            },\n          }));\n          // Record DELETE history only after confirmed deletion.\n          try {\n            recordHistory(\n              staleRecordId,\n              'DELETE',\n              staleSnapshot?.file_path ?? null,\n              null,\n              'mcp:memory_index_scan',\n              staleSnapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort\n          }\n        } else {\n          failed++;\n        }\n      } catch (_error: unknown) {\n        failed++;\n      }\n    }\n\n    return { deleted, failed, actions };\n  };\n\n  const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n    if (paths.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n  };\n\n  const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n    if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweepOrphanIndexRows = (incrementalIndex as {\n      sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n    }).sweepOrphanIndexRows;\n\n    if (typeof sweepOrphanIndexRows !== 'function') {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n    const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n    return {\n      swept: deleteResult.deleted,\n      failed: deleteResult.failed,\n      scannedRows: sweep.scannedRows,\n      nextCursor: sweep.nextCursor,\n      actions: deleteResult.actions,\n    };\n  };\n\n  const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n    try {\n      runPostMutationHooks('scan', { ...context, statediffActions: actions });\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n    }\n  };\n\n  const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n    result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n  );\n\n  const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n    target: 'memory_index',\n    key: 'trigger-embedding-backfill',\n    sourceOperation: 'scan',\n    metadata: {\n      readyRows: result.readyRows,\n      failedRows: result.failedRows,\n      pendingRows: result.pendingRows,\n    },\n  });\n\n  const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n    if (actions.length === 0) {\n      return;\n    }\n    results.aliasConflicts = detectAliasConflictsFromIndex();\n    results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n  };\n\n  const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n    try {\n      const repairResult = await repairIncompleteMarkers(\n        { database: requireDb(), plannerMode: 'full-auto' },\n        { limit: BATCH_SIZE },\n      );\n      if (repairResult.failed > 0) {\n        console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n      }\n      return repairResult.repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n    if (!isMemoryIdempotencyEnabled()) {\n      return 0;\n    }\n    try {\n      const database = requireDb();\n      const rows = database.prepare(`\n        SELECT id, spec_folder, title, content_text, content_hash,\n               tenant_id, user_id, agent_id, session_id\n        FROM memory_index\n        WHERE parent_id IS NULL\n          AND embedding_status = 'success'\n          AND content_text IS NOT NULL\n          AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n        ORDER BY id ASC\n        LIMIT ?\n      `).all(BATCH_SIZE) as Array<{\n        id: number;\n        spec_folder: string;\n        title: string | null;\n        content_text: string;\n        content_hash: string | null;\n        tenant_id: string | null;\n        user_id: string | null;\n        agent_id: string | null;\n        session_id: string | null;\n      }>;\n      let repaired = 0;\n      for (const row of rows) {\n        try {\n          const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n          const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n          recordNearDuplicateCheck({\n            database,\n            memoryId: row.id,\n            specFolder: row.spec_folder,\n            contentHash: row.content_hash,\n            embedding,\n            scope: {\n              tenantId: row.tenant_id,\n              userId: row.user_id,\n              agentId: row.agent_id,\n              sessionId: row.session_id,\n            },\n          });\n          repaired++;\n        } catch (error: unknown) {\n          console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n        }\n      }\n      return repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  // Time each un-yielded tail phase: because these phases do not yield, their\n  // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n  // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n  // onPhase, which refreshes the busy marker — giving each phase a full TTL ahead.\n  const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n    ctx.onPhase?.(phase);\n    if (!instrument) {\n      return await fn();\n    }\n    const startedAt = Date.now();\n    try {\n      return await fn();\n    } finally {\n      console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n    }\n  };\n\n  if (files.length === 0) {\n    let staleDeleted = 0;\n    let staleDeleteFailed = 0;\n    const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n    const postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n    const nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n    if (incremental && !force) {\n      const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n      const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n      staleDeleted = staleDeleteResult.deleted;\n      staleDeleteFailed = staleDeleteResult.failed;\n      if (staleDeleted > 0) {\n        runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n      }\n    }\n\n    const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n      runTriggerEmbeddingBackfill(requireDb(), {\n        isCancelled: () => ctx.isCancelled?.() ?? false,\n      }));\n\n    if (orphanSweepResult.swept > 0) {\n      runScanInvalidationHooks({\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        operation: 'orphan-sweep',\n      }, orphanSweepResult.actions);\n    }\n    if (postInsertEnrichmentRepaired > 0) {\n      runScanInvalidationHooks({\n        postInsertEnrichmentRepaired,\n        operation: 'post-insert-enrichment-repair',\n      }, [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: 'post-insert-enrichment-repair',\n        sourceOperation: 'scan',\n        metadata: { postInsertEnrichmentRepaired },\n      })]);\n    }\n    if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n      runScanInvalidationHooks({\n        triggerEmbeddingBackfill,\n        operation: 'trigger-embedding-backfill',\n      }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n    }\n\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'success',\n      counts: {\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        orphanSwept: orphanSweepResult.swept,\n      },\n      staleCandidates: staleDeleted + staleDeleteFailed,\n    });\n    await releaseScanLease();\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: 'No memory files found',\n      data: {\n        status: 'complete',\n        scanKey,\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        postInsertEnrichmentRepaired,\n        nearDuplicateRepaired,\n        triggerEmbeddingBackfill,\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        orphanSweepScanned: orphanSweepResult.scannedRows,\n        orphanSweepNextCursor: orphanSweepResult.nextCursor,\n        checkpointRepair,\n        warnings: walkerWarnings,\n        capExceeded: walkerCapExceeded,\n      },\n      hints: [\n        ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n        ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n        ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n        ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n        ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n        ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n        ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n        ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n        ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n        ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n        'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n        'Constitutional files go in .opencode/skills/*/constitutional/'\n      ]\n    });\n  }\n\n  const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n\n  const results: ScanResults = {\n    scanned: files.length,\n    indexed: 0,\n    updated: 0,\n    unchanged: 0,\n    failed: 0,\n    deferred: 0,\n    skipped_mtime: 0,\n    mtimeUpdates: 0,\n    staleDeleted: 0,\n    staleDeleteFailed: 0,\n    postInsertEnrichmentRepaired: 0,\n    nearDuplicateRepaired: 0,\n    orphanSwept: 0,\n    orphanSweepFailed: 0,\n    orphanSweepScanned: 0,\n    orphanSweepNextCursor: null,\n    files: [],\n    constitutional: {\n      found: constitutionalFiles.length,\n      indexed: 0,\n      alreadyIndexed: 0\n    },\n    incremental: {\n      enabled: incremental && !force,\n      fast_path_skips: 0,\n      mtime_changed: 0,\n      metadataPromoter: {\n        processed: 0,\n        resolved: 0,\n        inserted: 0,\n        skippedManual: 0,\n        staleTombstoned: 0,\n        staleDeleted: 0,\n        warnings: 0,\n      }\n    },\n    dedup: {\n      inputTotal: mergedFiles.length,\n      uniqueTotal: files.length,\n      duplicatesSkipped: dedupDuplicatesSkipped,\n    },\n    aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n    divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n    checkpointRepair,\n    warnings: walkerWarnings,\n    capExceeded: walkerCapExceeded,\n  };\n  const scanAppliedActions: StatediffAction[] = [];\n\n  let filesToIndex: string[] = files;\n  let filesToDelete: string[] = [];\n\n  if (incremental && !force) {\n    const startCategorize = Date.now();\n    const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n\n    filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n    filesToDelete = categorized.toDelete;\n\n    results.unchanged = categorized.toSkip.length;\n    results.skipped_mtime = categorized.toSkip.length;\n    results.incremental.fast_path_skips = categorized.toSkip.length;\n    results.incremental.mtime_changed = categorized.toUpdate.length;\n\n    for (const unchangedPath of categorized.toSkip) {\n      if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n        results.constitutional.alreadyIndexed++;\n      }\n    }\n\n    const categorizeTime = Date.now() - startCategorize;\n    console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n    console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n  }\n\n  // Attempt move reconciliation before full delete+reindex cycle.\n  // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n  // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n  // stored-document_type cross-checks; the matched row is updated in place.\n  if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n    const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n    if (moveResult.reconciled.length > 0) {\n      results.moveReconciled = moveResult.reconciled.length;\n      filesToDelete = moveResult.filteredToDelete;\n      filesToIndex = moveResult.filteredToIndex;\n      console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n    }\n  }\n\n  const plannedScanActions = [\n    ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n    ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss — a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;\n    const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n      // Cancellation is checked between files (mirrors ingest). A cancelled file is\n      // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n      if (ctx.isCancelled?.()) {\n        return { status: 'cancelled' } as IndexResult;\n      }\n      const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n      // Constitutional markdown is policy text, not evidence-bearing memory.\n      // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n      // strict sufficiency gate would always reject it. Treat constitutional files like\n      // spec docs and pass them through warn-only mode so they index against the same\n      // pipeline without the document-evidence requirements.\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n      // During force reindex, use warn-only for all files — the goal is to index\n      // everything that has valid frontmatter, not to enforce template contracts on\n      // older files created before current templates were established.\n      const useWarnOnly = force || isSpecDoc || isConstitutional;\n      const indexResult = await indexSingleFile(filePath, force, {\n        ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n        fromScan: true,\n        asyncEmbedding: true,\n        governance: governedIngest ? governanceDecision : undefined,\n      });\n      processedInScan += 1;\n      ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n      return indexResult;\n    }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n    for (let i = 0; i < batchResults.length; i++) {\n      const result = batchResults[i];\n      const filePath = filesToIndex[i];\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n\n      if (result.error) {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: result.error,\n          errorDetail: result.errorDetail\n        });\n      } else if (isIndexResult(result)) {\n        const isSuccessfulStatus =\n          result.status === 'success' ||\n          result.status === 'indexed' ||\n          result.status === 'updated' ||\n          result.status === 'unchanged' ||\n          result.status === 'reinforced' ||\n          result.status === 'duplicate' ||\n          result.status === 'deferred';\n        // A cancelled file was never indexed and was never going to be: counting it\n        // as a failure would attribute an operator-requested stop to a file error.\n        // It is neither success nor failure, so it falls through both tallies.\n        if (!isSuccessfulStatus && result.status !== 'cancelled') {\n          results.failed++;\n        }\n\n        if (result.status === 'indexed') {\n          results.indexed++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'updated') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'unchanged') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'reinforced') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'duplicate') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'deferred') {\n          results.indexed++;\n          results.deferred++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        }\n\n        if (isConstitutional) {\n          if (result.status === 'indexed') {\n            results.constitutional.indexed++;\n          } else if (result.status === 'unchanged') {\n            results.constitutional.alreadyIndexed++;\n          }\n        }\n\n        if (result.status !== 'unchanged') {\n          const rejectionDetail = !isSuccessfulStatus\n            ? {\n                ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n                  ? { rejectionCode: result.rejectionCode }\n                  : {}),\n                ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n                  ? { rejectionReason: result.rejectionReason }\n                  : (typeof result.message === 'string' && result.message.length > 0\n                    ? { rejectionReason: result.message }\n                    : {})),\n                ...(typeof result.error === 'string' && result.error.length > 0\n                  ? { error: result.error }\n                  : {}),\n              }\n            : {};\n\n          results.files.push({\n            file: path.basename(filePath),\n            filePath,\n            specFolder: result.specFolder,\n            status: result.status,\n            id: result.id,\n            isConstitutional,\n            ...rejectionDetail,\n          });\n        }\n      } else {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: 'Unexpected batch result shape',\n          errorDetail: JSON.stringify(result),\n        });\n      }\n    }\n  }\n\n  // Update mtimes ONLY for successfully indexed files, not before indexing.\n  // Failed files keep their old mtime so they are retried on next scan.\n  // This is the ONLY place where scan-triggered mtime updates occur.\n  // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n  // Which rolls back atomically on failure — a complementary safety mechanism.\n  if (successfullyIndexedFiles.length > 0) {\n    const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n    results.mtimeUpdates = mtimeUpdateResult.updated;\n  }\n\n  if (include_spec_docs) {\n    const database = requireDb();\n    let promoterYieldCount = 0;\n    for (const fileResult of results.files) {\n      // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n      // that is the whole corpus, so without a periodic macrotask yield the event\n      // loop is starved for the duration and no IPC (status, cancel, health,\n      // search) can be serviced. Yield and re-check cancellation between rows; the\n      // yield lands between self-contained promoteMetadataEdges transactions, never\n      // inside one, so atomicity on the shared connection is preserved.\n      if (++promoterYieldCount % 200 === 0) {\n        if (ctx.isCancelled?.()) {\n          return cancelledScanEnvelope(scanKey);\n        }\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n        continue;\n      }\n      try {\n        const promotion = promoteMetadataEdges(database, {\n          memoryId: fileResult.id,\n          filePath: fileResult.filePath,\n        });\n        results.incremental.metadataPromoter.processed += promotion.processed;\n        results.incremental.metadataPromoter.resolved += promotion.resolved;\n        results.incremental.metadataPromoter.inserted += promotion.inserted;\n        results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n        results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n        results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n        results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n        for (const warning of promotion.warnings) {\n          results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n        }\n      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }\n  }\n\n  const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n  results.orphanSwept = orphanSweepResult.swept;\n  results.orphanSweepFailed = orphanSweepResult.failed;\n  results.orphanSweepScanned = orphanSweepResult.scannedRows;\n  results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n  scanAppliedActions.push(...orphanSweepResult.actions);\n\n  results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n  if (results.postInsertEnrichmentRepaired > 0) {\n    scanAppliedActions.push(createStatediffAction('upsert', {\n      target: 'graph_edge',\n      key: 'post-insert-enrichment-repair',\n      sourceOperation: 'scan',\n      metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n    }));\n  }\n\n  results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n    runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n  if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n  }\n  results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n  // Create causal chains between spec folder documents.\n  // Includes deferred indexing outcomes and incremental single-file updates.\n  if (include_spec_docs) {\n    try {\n      // Determine which spec folders had spec document changes in this scan.\n      // We use parsed document type (not basename) to avoid false positives\n      // From memory/plan.md or similar filenames.\n      const affectedSpecFolders = new Set<string>();\n      for (const fileResult of results.files) {\n        if (!fileResult.specFolder || fileResult.status === 'failed') {\n          continue;\n        }\n\n        if (!fileResult.filePath) {\n          continue;\n        }\n\n        const docType = memoryParser.extractDocumentType(fileResult.filePath);\n        if (\n          docType !== 'memory' &&\n          docType !== 'constitutional'\n        ) {\n          affectedSpecFolders.add(fileResult.specFolder);\n        }\n      }\n\n      if (affectedSpecFolders.size > 0) {\n        const database = requireDb();\n        const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n        initCausalEdges(database);\n\n        // Build full per-folder document map from DB (not just this scan's files).\n        const selectDocIds = database.prepare(`\n          SELECT document_type, MAX(id) AS id\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n          GROUP BY document_type\n        `);\n\n        let chainsCreated = 0;\n        let foldersProcessed = 0;\n        let chainYieldCount = 0;\n\n        for (const folder of affectedSpecFolders) {","lineStart":1,"lineEnd":1315,"totalLines":1316,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781763522522,"end":1781763522606}},"metadata":{"openai":{"itemId":"fc_07d11185e93d73e2016a338dc1a43c8191ad95fde4bf76588e"}},"id":"prt_ed961bfd3001QkFHPcDgT0dhbx","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed9618031001aMd6sS9Tw21zdA"}}
{"type":"tool_use","timestamp":1781763522613,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_WUu3SY9GM31qSXgS8PsyHb35","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Job Queue\n3: // ───────────────────────────────────────────────────────────────\n4: // True sequential worker, meaningful state transitions,\n5: // Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n6: // Crash recovery with re-enqueue, and original-path progress tracking.\n7: \n8: /* ───────────────────────────────────────────────────────────────\n9:    1. IMPORTS\n10: ──────────────────────────────────────────────────────────────── */\n11: \n12: import path from 'node:path';\n13: import { requireDb, toErrorMessage } from '../../utils/index.js';\n14: import type { GovernanceDecision } from '../governance/scope-governance.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: // Feature catalog: Async ingestion job lifecycle\n18: \n19: /* ───────────────────────────────────────────────────────────────\n20:    2. TYPES\n21: ──────────────────────────────────────────────────────────────── */\n22: \n23: /**\n24:  * Defines the IngestJobState type.\n25:  */\n26: export type IngestJobState =\n27:   | 'queued'\n28:   | 'parsing'\n29:   | 'embedding'\n30:   | 'indexing'\n31:   | 'complete'\n32:   | 'failed'\n33:   | 'cancelled';\n34: \n35: /**\n36:  * Describes the IngestJobError shape.\n37:  */\n38: export interface IngestJobError {\n39:   filePath: string;\n40:   message: string;\n41:   timestamp: string;\n42: }\n43: \n44: /**\n45:  * Describes the IngestJob shape.\n46:  */\n47: export interface IngestJob {\n48:   id: string;\n49:   state: IngestJobState;\n50:   specFolder: string | null;\n51:   paths: string[];\n52:   filesTotal: number;\n53:   filesProcessed: number;\n54:   errors: IngestJobError[];\n55:   createdAt: string;\n56:   updatedAt: string;\n57:   // Validated governance decision captured at enqueue time so the worker\n58:   // re-indexes each path under the same provenance/retention/scope the\n59:   // synchronous save path applies. Null for ungoverned jobs (the default).\n60:   governance: GovernanceDecision | null;\n61: }\n62: \n63: export interface IngestJobForecast {\n64:   etaSeconds: number | null;\n65:   etaConfidence: number | null;\n66:   failureRisk: number | null;\n67:   riskSignals: string[];\n68:   caveat: string | null;\n69: }\n70: \n71: interface IngestJobRow {\n72:   id: string;\n73:   state: IngestJobState;\n74:   spec_folder: string | null;\n75:   paths_json: string;\n76:   files_total: number;\n77:   files_processed: number;\n78:   errors_json: string;\n79:   created_at: string;\n80:   updated_at: string;\n81:   governance_json?: string | null;\n82: }\n83: \n84: interface JobQueueConfig {\n85:   processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n86: }\n87: \n88: /* ───────────────────────────────────────────────────────────────\n89:    3. CONSTANTS\n90: ──────────────────────────────────────────────────────────────── */\n91: \n92: const ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\n93: const TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n94: \n95: const ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n96:   queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n97:   parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n98:   embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n99:   indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n100:   complete: new Set<IngestJobState>([]),\n101:   failed: new Set<IngestJobState>([]),\n102:   cancelled: new Set<IngestJobState>([]),\n103: };\n104: \n105: /* ───────────────────────────────────────────────────────────────\n106:    5. STATE MANAGEMENT\n107: ──────────────────────────────────────────────────────────────── */\n108: \n109: // True sequential queue — only one job processes at a time.\n110: const pendingQueue: string[] = [];\n111: let workerActive = false;\n112: // Drain fence. Once set, the worker stops draining and refuses to touch the\n113: // database. This prevents the worker from reopening a connection that shutdown\n114: // has already checkpointed and closed, which would otherwise re-dirty the WAL\n115: // and the unclean-shutdown marker at rest.\n116: let shuttingDown = false;\n117: let processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\n118: const MAX_STORED_ERRORS = 50;\n119: const MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n120: \n121: /* ───────────────────────────────────────────────────────────────\n122:    4. HELPERS\n123: ──────────────────────────────────────────────────────────────── */\n124: \n125: function toPublicPathLabel(filePath: string): string {\n126:   return filePath === '__job__' ? filePath : path.basename(filePath || '');\n127: }\n128: \n129: function sleep(ms: number): Promise<void> {\n130:   return new Promise((resolve) => setTimeout(resolve, ms));\n131: }\n132: \n133: function parsePositiveIntEnv(name: string, fallback: number): number {\n134:   const raw = process.env[name];\n135:   if (!raw) return fallback;\n136: \n137:   const parsed = Number.parseInt(raw, 10);\n138:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n139: }\n140: \n141: function parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n142:   if (!value) return fallback;\n143:   try {\n144:     const parsed = JSON.parse(value) as unknown;\n145:     return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n146:   } catch (_error: unknown) {\n147:     return fallback;\n148:   }\n149: }\n150: \n151: function parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n152:   if (!value) return null;\n153:   try {\n154:     const parsed = JSON.parse(value) as unknown;\n155:     if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n156:       return parsed as GovernanceDecision;\n157:     }\n158:     return null;\n159:   } catch (_error: unknown) {\n160:     return null;\n161:   }\n162: }\n163: \n164: function mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n165:   if (!row) return null;\n166:   return {\n167:     id: row.id,\n168:     state: row.state,\n169:     specFolder: row.spec_folder,\n170:     paths: parseJsonArray<string>(row.paths_json, []),\n171:     filesTotal: row.files_total,\n172:     filesProcessed: row.files_processed,\n173:     errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n174:     createdAt: row.created_at,\n175:     updatedAt: row.updated_at,\n176:     governance: parseGovernanceJson(row.governance_json),\n177:   };\n178: }\n179: \n180: function nowIso(): string {\n181:   return new Date().toISOString();\n182: }\n183: \n184: function isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n185:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n186: }\n187: \n188: // DB accessor for the worker path. While shutting down it refuses to acquire a\n189: // connection so the worker can never travel the requireDb -> getDb -> reopen\n190: // path after shutdown has closed the database. The throw is caught by the\n191: // worker's surrounding error handling and the drain unwinds cleanly.\n192: function acquireWorkerDb(): ReturnType<typeof requireDb> {\n193:   if (shuttingDown) {\n194:     throw new Error('Ingest worker is shutting down; database access refused');\n195:   }\n196:   return requireDb();\n197: }\n198: \n199: function ensureIngestJobsTable(): void {\n200:   const db = requireDb();\n201:   db.exec(`\n202:     CREATE TABLE IF NOT EXISTS ingest_jobs (\n203:       id TEXT PRIMARY KEY,\n204:       state TEXT,\n205:       spec_folder TEXT,\n206:       paths_json TEXT,\n207:       files_total INTEGER,\n208:       files_processed INTEGER,\n209:       errors_json TEXT,\n210:       created_at TEXT,\n211:       updated_at TEXT,\n212:       governance_json TEXT\n213:     )\n214:   `);\n215:   // Backward-compatible migration: add the nullable governance column to tables\n216:   // created before governed ingest existed. In-flight jobs simply carry a null\n217:   // governance and remain ungoverned, exactly as before.\n218:   const columns = db.prepare(`PRAGMA table_info(ingest_jobs)`).all() as Array<{ name: string }>;\n219:   if (!columns.some((column) => column.name === 'governance_json')) {\n220:     db.exec(`ALTER TABLE ingest_jobs ADD COLUMN governance_json TEXT`);\n221:   }\n222: }\n223: \n224: // Restart interrupted jobs from the beginning on process startup.\n225: // Indexing is idempotent, and replaying the original path list avoids\n226: // Mismatches when path accessibility changes between runs.\n227: function resetIncompleteJobsToQueued(): string[] {\n228:   const db = requireDb();\n229:   // Collect IDs of jobs that will be reset so we can re-enqueue them.\n230:   const rows = db.prepare(`\n231:     SELECT id FROM ingest_jobs\n232:     WHERE state NOT IN ('complete', 'failed', 'cancelled')\n233:   `).all() as Array<{ id: string }>;\n234: \n235:   if (rows.length === 0) return [];\n236: \n237:   withBusyRetrySync(() =>\n238:     db.prepare(`\n239:       UPDATE ingest_jobs\n240:       SET\n241:         state = 'queued',\n242:         files_processed = 0,\n243:         errors_json = '[]',\n244:         updated_at = ?\n245:       WHERE state NOT IN ('complete', 'failed', 'cancelled')\n246:     `).run(nowIso())\n247:   );\n248: \n249:   return rows.map((r) => r.id);\n250: }\n251: \n252: async function createIngestJob(args: {\n253:   id: string;\n254:   paths: string[];\n255:   specFolder?: string;\n256:   governance?: GovernanceDecision | null;\n257: }): Promise<IngestJob> {\n258:   const db = requireDb();\n259:   const timestamp = nowIso();\n260:   const normalizedPaths = args.paths.map((entry) => String(entry).trim()).filter((entry) => entry.length > 0);\n261: \n262:   if (normalizedPaths.length === 0) {\n263:     throw new Error('paths must include at least one file path');\n264:   }\n265: \n266:   const governance = args.governance ?? null;\n267:   const governanceJson = governance ? JSON.stringify(governance) : null;\n268: \n269:   await withBusyRetry(() =>\n270:     db.prepare(`\n271:       INSERT INTO ingest_jobs (\n272:         id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n273:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n274:     `).run(\n275:       args.id,\n276:       'queued',\n277:       args.specFolder ?? null,\n278:       JSON.stringify(normalizedPaths),\n279:       normalizedPaths.length,\n280:       0,\n281:       JSON.stringify([]),\n282:       timestamp,\n283:       timestamp,\n284:       governanceJson,\n285:     )\n286:   );\n287: \n288:   return {\n289:     id: args.id,\n290:     state: 'queued',\n291:     specFolder: args.specFolder ?? null,\n292:     paths: normalizedPaths,\n293:     filesTotal: normalizedPaths.length,\n294:     filesProcessed: 0,\n295:     errors: [],\n296:     createdAt: timestamp,\n297:     updatedAt: timestamp,\n298:     governance,\n299:   };\n300: }\n301: \n302: function getIngestJob(jobId: string): IngestJob | null {\n303:   const db = acquireWorkerDb();\n304:   const row = db.prepare(`\n305:     SELECT id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n306:     FROM ingest_jobs\n307:     WHERE id = ?\n308:   `).get(jobId) as IngestJobRow | undefined;\n309:   return mapRowToJob(row);\n310: }\n311: \n312: async function setIngestJobState(jobId: string, nextState: IngestJobState): Promise<IngestJob> {\n313:   const db = acquireWorkerDb();\n314:   const current = getIngestJob(jobId);\n315:   if (!current) {\n316:     throw new Error(`Ingest job not found: ${jobId}`);\n317:   }\n318: \n319:   if (current.state === nextState) {\n320:     return current;\n321:   }\n322: \n323:   if (!isTransitionAllowed(current.state, nextState)) {\n324:     throw new Error(`Invalid ingest job state transition: ${current.state} -> ${nextState}`);\n325:   }\n326: \n327:   const updatedAt = nowIso();\n328:   const result = await withBusyRetry(() =>\n329:     db.prepare(`\n330:       UPDATE ingest_jobs\n331:       SET state = ?, updated_at = ?\n332:       WHERE id = ? AND state = ?\n333:     `).run(nextState, updatedAt, jobId, current.state)\n334:   );\n335: \n336:   if ((result as { changes: number }).changes === 0) {\n337:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n338:   }\n339: \n340:   return {\n341:     ...current,\n342:     state: nextState,\n343:     updatedAt,\n344:   };\n345: }\n346: \n347: async function incrementProcessed(jobId: string): Promise<IngestJob> {\n348:   const db = acquireWorkerDb();\n349:   const updatedAt = nowIso();\n350:   await withBusyRetry(() =>\n351:     db.prepare(`\n352:       UPDATE ingest_jobs\n353:       SET files_processed = files_processed + 1, updated_at = ?\n354:       WHERE id = ?\n355:     `).run(updatedAt, jobId)\n356:   );\n357: \n358:   const updated = getIngestJob(jobId);\n359:   if (!updated) {\n360:     throw new Error(`Ingest job not found after progress update: ${jobId}`);\n361:   }\n362:   return updated;\n363: }\n364: \n365: async function appendIngestError(jobId: string, filePath: string, error: unknown): Promise<IngestJob> {\n366:   const db = acquireWorkerDb();\n367:   const current = getIngestJob(jobId);\n368:   if (!current) {\n369:     throw new Error(`Ingest job not found: ${jobId}`);\n370:   }\n371: \n372:   let errors = [\n373:     ...current.errors,\n374:     {\n375:       filePath: toPublicPathLabel(filePath),\n376:       message: toErrorMessage(error),\n377:       timestamp: nowIso(),\n378:     },\n379:   ];\n380: \n381:   if (errors.length > MAX_STORED_ERRORS) {\n382:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n383:     const trimmedCount = errors.length - tailLength;\n384:     const truncationNotice: IngestJobError = {\n385:       filePath: '__job__',\n386:       message: `error log truncated (${trimmedCount} older entries removed)`,\n387:       timestamp: nowIso(),\n388:     };\n389:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n390:     errors = [truncationNotice, ...truncatedTail];\n391:   }\n392: \n393:   const updatedAt = nowIso();\n394:   await withBusyRetry(() =>\n395:     db.prepare(`\n396:       UPDATE ingest_jobs\n397:       SET errors_json = ?, updated_at = ?\n398:       WHERE id = ?\n399:     `).run(JSON.stringify(errors), updatedAt, jobId)\n400:   );\n401: \n402:   return {\n403:     ...current,\n404:     errors,\n405:     updatedAt,\n406:   };\n407: }\n408: \n409: async function cancelIngestJob(jobId: string): Promise<IngestJob> {\n410:   const MAX_CANCEL_RETRIES = 3;\n411: \n412:   for (let attempt = 0; attempt < MAX_CANCEL_RETRIES; attempt += 1) {\n413:     const current = getIngestJob(jobId);\n414:     if (!current) {\n415:       throw new Error(`Ingest job not found: ${jobId}`);\n416:     }\n417:     if (TERMINAL_STATES.has(current.state)) {\n418:       return current;\n419:     }\n420: \n421:     try {\n422:       return await setIngestJobState(jobId, 'cancelled');\n423:     } catch (error: unknown) {\n424:       const message = toErrorMessage(error);\n425:       if (message.startsWith('State transition conflict:')) {\n426:         continue;\n427:       }\n428: \n429:       if (message.startsWith('Invalid ingest job state transition:')) {\n430:         const latest = getIngestJob(jobId);\n431:         if (latest && TERMINAL_STATES.has(latest.state)) {\n432:           return latest;\n433:         }\n434:         continue;\n435:       }\n436: \n437:       throw error;\n438:     }\n439:   }\n440: \n441:   const latest = getIngestJob(jobId);\n442:   if (!latest) {\n443:     throw new Error(`Ingest job not found: ${jobId}`);\n444:   }\n445:   if (TERMINAL_STATES.has(latest.state)) {\n446:     return latest;\n447:   }\n448: \n449:   return setIngestJobState(jobId, 'cancelled');\n450: }\n451: \n452: /**\n453:  * Provides the getIngestProgressPercent helper.\n454:  */\n455: export function getIngestProgressPercent(job: Pick<IngestJob, 'filesProcessed' | 'filesTotal'>): number {\n456:   if (job.filesTotal <= 0) return 0;\n457:   const raw = Math.round((job.filesProcessed / job.filesTotal) * 100);\n458:   return Math.max(0, Math.min(100, raw));\n459: }\n460: \n461: function parseIsoTimestamp(timestamp: string): number | null {\n462:   if (typeof timestamp !== 'string' || timestamp.trim().length === 0) {\n463:     return null;\n464:   }\n465: \n466:   const parsed = Date.parse(timestamp);\n467:   return Number.isFinite(parsed) ? parsed : null;\n468: }\n469: \n470: function clampUnitInterval(value: number): number {\n471:   if (!Number.isFinite(value)) return 0;\n472:   return Math.max(0, Math.min(1, value));\n473: }\n474: \n475: export function getIngestForecast(\n476:   job: Pick<IngestJob, 'state' | 'filesProcessed' | 'filesTotal' | 'errors' | 'createdAt' | 'updatedAt'>,\n477: ): IngestJobForecast {\n478:   const filesTotal = Math.max(0, job.filesTotal || 0);\n479:   const filesProcessed = Math.max(0, job.filesProcessed || 0);\n480:   const remaining = Math.max(0, filesTotal - filesProcessed);\n481:   const errorCount = Array.isArray(job.errors) ? job.errors.length : 0;\n482:   const errorRatio = filesTotal > 0 ? errorCount / filesTotal : 0;\n483:   const progressRatio = filesTotal > 0 ? filesProcessed / filesTotal : 0;\n484:   const riskSignals: string[] = [];\n485: \n486:   if (job.state === 'failed') {\n487:     return {\n488:       etaSeconds: 0,\n489:       etaConfidence: 1,\n490:       failureRisk: 1,\n491:       riskSignals: ['terminal_failed'],\n492:       caveat: null,\n493:     };\n494:   }\n495: \n496:   if (job.state === 'complete') {\n497:     return {\n498:       etaSeconds: 0,\n499:       etaConfidence: 1,\n500:       failureRisk: clampUnitInterval(errorRatio * 0.5),\n501:       riskSignals: errorCount > 0 ? ['completed_with_file_errors'] : [],\n502:       caveat: null,\n503:     };\n504:   }\n505: \n506:   if (job.state === 'cancelled') {\n507:     return {\n508:       etaSeconds: 0,\n509:       etaConfidence: 1,\n510:       failureRisk: 0,\n511:       riskSignals: ['terminal_cancelled'],\n512:       caveat: 'Forecast is advisory only because the job is no longer progressing.',\n513:     };\n514:   }\n515: \n516:   if (filesTotal <= 0) {\n517:     return {\n518:       etaSeconds: null,\n519:       etaConfidence: null,\n520:       failureRisk: null,\n521:       riskSignals,\n522:       caveat: 'Forecast unavailable because the queue has no file-count baseline yet.',\n523:     };\n524:   }\n525: \n526:   if (errorCount > 0) {\n527:     riskSignals.push('file_errors_seen');\n528:   }\n529:   if (job.state === 'queued') {\n530:     riskSignals.push('queued_not_started');\n531:   }\n532: \n533:   const createdAtMs = parseIsoTimestamp(job.createdAt);\n534:   const updatedAtMs = parseIsoTimestamp(job.updatedAt);\n535:   const elapsedSeconds = createdAtMs !== null && updatedAtMs !== null && updatedAtMs >= createdAtMs\n536:     ? Math.max(0, (updatedAtMs - createdAtMs) / 1000)\n537:     : 0;\n538: \n539:   let etaSeconds: number | null = null;\n540:   let etaConfidence: number | null = null;\n541:   let caveat: string | null = null;\n542: \n543:   if (filesProcessed <= 0 || elapsedSeconds < 1) {\n544:     caveat = 'Forecast is low-confidence until at least one file has been processed.';\n545:   } else {\n546:     const throughput = filesProcessed / elapsedSeconds;\n547:     if (throughput > 0) {\n548:       etaSeconds = Math.max(0, Math.round(remaining / throughput));\n549:       etaConfidence = clampUnitInterval(0.35 + (progressRatio * 0.45) - (errorRatio * 0.25));\n550:       if (etaConfidence < 0.4) {\n551:         caveat = 'Forecast is low-confidence because queue history is still sparse or noisy.';\n552:       }\n553:     } else {\n554:       caveat = 'Forecast unavailable because throughput could not be derived from queue history.';\n555:     }\n556:   }\n557: \n558:   if (progressRatio <= 0 && job.state !== 'queued') {\n559:     riskSignals.push('active_without_progress');\n560:   }\n561:   if (errorRatio >= 0.5 && errorCount > 0) {\n562:     riskSignals.push('high_error_ratio');\n563:   }\n564: \n565:   const stateRisk = job.state === 'indexing' ? 0.15 : (job.state === 'embedding' ? 0.1 : 0.05);\n566:   const failureRisk = clampUnitInterval((errorRatio * 0.7) + stateRisk + (progressRatio === 0 ? 0.05 : 0));\n567: \n568:   return {\n569:     etaSeconds,\n570:     etaConfidence,\n571:     failureRisk,\n572:     riskSignals,\n573:     caveat,\n574:   };\n575: }\n576: \n577: /* ───────────────────────────────────────────────────────────────\n578:    6. WORKER\n579: ──────────────────────────────────────────────────────────────── */\n580: \n581: // Real state machine — states now correspond to actual work phases.\n582: // Progress is tracked against the original submitted path list so terminal\n583: // Accounting stays stable even when some files are inaccessible.\n584: async function processQueuedJob(jobId: string): Promise<void> {\n585:   if (!processFileFn) {\n586:     throw new Error('Ingest queue not initialized: processFile handler is missing');\n587:   }\n588: \n589:   let job = getIngestJob(jobId);\n590:   if (!job || TERMINAL_STATES.has(job.state)) {\n591:     return;\n592:   }\n593: \n594:   // Step 1: Parsing — validate all paths exist and are readable.\n595:   job = await setIngestJobState(jobId, 'parsing');\n596:   if (TERMINAL_STATES.has(job.state)) return;\n597: \n598:   const { access } = await import('fs/promises');\n599: \n600:   // Step 2: Embedding — placeholder for batch embedding pre-processing.\n601:   // Transition is meaningful: it signals readiness for indexing after validation.\n602:   const latest1 = getIngestJob(jobId);\n603:   if (!latest1 || TERMINAL_STATES.has(latest1.state)) return;\n604:   job = await setIngestJobState(jobId, 'embedding');\n605:   if (TERMINAL_STATES.has(job.state)) return;\n606: \n607:   // Step 3: Indexing — process only validated paths (not original paths).\n608:   const latest2 = getIngestJob(jobId);\n609:   if (!latest2 || TERMINAL_STATES.has(latest2.state)) return;\n610:   job = await setIngestJobState(jobId, 'indexing');\n611: \n612:   // Resume from filesProcessed against the original submitted path order.\n613:   let currentIndex = job.filesProcessed;\n614:   // Track actual failure count independently of the truncated errors array.\n615:   // The errors array is capped at MAX_STORED_ERRORS, so using errors.length for\n616:   // Terminal state decisions would misclassify all-fail jobs with >50 files as \"complete\".\n617:   let failCount = 0;\n618: \n619:   while (currentIndex < job.paths.length) {\n620:     // Stop touching the DB the moment shutdown begins. The job stays in an\n621:     // active state and boot crash-recovery re-enqueues it on the next start.\n622:     if (shuttingDown) return;\n623:     const current = getIngestJob(jobId);\n624:     if (!current) return;\n625:     if (current.state === 'cancelled') return;\n626: \n627:     const nextPath = current.paths[currentIndex];\n628:     if (!nextPath) {\n629:       break;\n630:     }\n631: \n632:     // Continue on file error instead of aborting the entire job.\n633:     try {\n634:       await access(nextPath);\n635:       await processFileFn(nextPath, current.governance);\n636:     } catch (error: unknown) {\n637:       const normalizedError = error instanceof Error\n638:         && 'code' in error\n639:         && typeof error.code === 'string'\n640:         && error.code === 'ENOENT'\n641:         ? new Error('File not accessible')\n642:         : error;\n643:       await appendIngestError(jobId, nextPath, normalizedError);\n644:       failCount += 1;\n645:       console.warn(`[job-queue] File error (continuing): ${toPublicPathLabel(nextPath)} — ${toErrorMessage(normalizedError)}`);\n646:     }\n647: \n648:     job = await incrementProcessed(jobId);\n649:     currentIndex = job.filesProcessed;\n650:   }\n651: \n652:   // Determine terminal state: complete if no errors, failed if all files errored.\n653:   const done = getIngestJob(jobId);\n654:   if (!done) return;\n655:   if (done.state === 'cancelled') return;\n656: \n657:   if (failCount > 0 && failCount >= done.filesTotal) {\n658:     // All files failed — mark as failed.\n659:     await setIngestJobState(jobId, 'failed');\n660:   } else {\n661:     // Partial or full success — mark as complete (errors are preserved in record).\n662:     await setIngestJobState(jobId, 'complete');\n663:   }\n664: }\n665: \n666: // True sequential worker — processes one job at a time.\n667: // Multiple enqueueIngestJob calls add to pendingQueue; a single worker drains it.\n668: async function drainQueue(): Promise<void> {\n669:   if (workerActive) return;\n670:   workerActive = true;\n671: \n672:   try {\n673:     while (pendingQueue.length > 0) {\n674:       // Halt draining once shutdown begins so no new job opens the DB.\n675:       if (shuttingDown) break;\n676:       // PendingQueue.length > 0 in the loop condition guarantees shift() returns a job id\n677:       const jobId = pendingQueue.shift()!;\n678:       try {\n679:         await processQueuedJob(jobId);\n680:       } catch (error: unknown) {\n681:         try {\n682:           await appendIngestError(jobId, '__job__', error);\n683:           const current = getIngestJob(jobId);\n684:           if (current && ACTIVE_STATES.has(current.state)) {\n685:             await setIngestJobState(jobId, 'failed');\n686:           }\n687:         } catch (_error: unknown) {\n688:           // Non-fatal: queue guard to avoid unhandled rejection loops.\n689:         }\n690:       }\n691: \n692:       // Brief yield between jobs to avoid starving the event loop.\n693:       await sleep(10);\n694:     }\n695:   } finally {\n696:     workerActive = false;\n697:   }\n698: }\n699: \n700: function enqueueIngestJob(jobId: string): void {\n701:   // Never admit work or respawn the worker once shutdown has begun.\n702:   if (shuttingDown) {\n703:     return;\n704:   }\n705:   // Prevent duplicate enqueue of the same job.\n706:   if (pendingQueue.includes(jobId)) {\n707:     return;\n708:   }\n709: \n710:   pendingQueue.push(jobId);\n711:   while (pendingQueue.length > MAX_PENDING_INGEST_JOBS) {\n712:     const evictedJobId = pendingQueue.shift();\n713:     if (!evictedJobId) break;\n714:     void appendIngestError(\n715:       evictedJobId,\n716:       '__job__',\n717:       new Error(`Pending ingest queue exceeded cap ${MAX_PENDING_INGEST_JOBS}; oldest job aborted`),\n718:     )\n719:       .then(() => cancelIngestJob(evictedJobId))\n720:       .catch((error: unknown) => {\n721:         console.warn(`[job-queue] Failed to cancel overflow job ${evictedJobId}: ${toErrorMessage(error)}`);\n722:       });\n723:   }\n724: \n725:   // Start worker if not already running (fire-and-forget).\n726:   if (!workerActive) {\n727:     setImmediate(() => {\n728:       void drainQueue().catch((error: unknown) => {\n729:         console.error(`[job-queue] Worker error: ${toErrorMessage(error)}`);\n730:       });\n731:     });\n732:   }\n733: }\n734: \n735: /* ───────────────────────────────────────────────────────────────\n736:    7. INITIALIZATION\n737: ──────────────────────────────────────────────────────────────── */\n738: \n739: function initIngestJobQueue(config: JobQueueConfig): { resetCount: number } {\n740:   processFileFn = config.processFile;\n741:   ensureIngestJobsTable();\n742: \n743:   // Crash recovery: reset incomplete jobs to 'queued' AND re-enqueue them\n744:   // So they actually get processed by the worker.\n745:   const resetJobIds = resetIncompleteJobsToQueued();\n746:   for (const jobId of resetJobIds) {\n747:     enqueueIngestJob(jobId);\n748:   }\n749: \n750:   return { resetCount: resetJobIds.length };\n751: }\n752: \n753: // Default ceiling for how long stopWorker waits for the active drain to settle.\n754: // The worker yields between files and between jobs, so it observes the fence\n755: // quickly; the bound only guards against a wedged in-flight processFile call.\n756: const STOP_WORKER_DRAIN_DEADLINE_MS = 2_000;\n757: \n758: // Fence the ingest worker for shutdown: refuse new work, drop the pending\n759: // queue, and wait (bounded) for any in-flight drain to unwind before the\n760: // database is closed. Must run before closeDb() so the worker cannot reopen a\n761: // closed connection. Idempotent and safe to call when the worker is idle.\n762: async function stopWorker(options: { drainDeadlineMs?: number } = {}): Promise<void> {\n763:   shuttingDown = true;\n764:   pendingQueue.length = 0;\n765: \n766:   if (!workerActive) return;\n767: \n768:   const deadline = Date.now()\n769:     + (Number.isFinite(options.drainDeadlineMs) && (options.drainDeadlineMs as number) > 0\n770:       ? (options.drainDeadlineMs as number)\n771:       : STOP_WORKER_DRAIN_DEADLINE_MS);\n772: \n773:   while (workerActive && Date.now() < deadline) {\n774:     await sleep(10);\n775:   }\n776: }\n777: \n778: /* ───────────────────────────────────────────────────────────────\n779:    8. EXPORTS\n780: ──────────────────────────────────────────────────────────────── */\n781: \n782: export {\n783:   initIngestJobQueue,\n784:   stopWorker,\n785:   createIngestJob,\n786:   getIngestJob,\n787:   cancelIngestJob,\n788:   enqueueIngestJob,\n789:   resetIncompleteJobsToQueued,\n790:   MAX_PENDING_INGEST_JOBS,\n791: };\n\n(End of file - total 791 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Job Queue\n// ───────────────────────────────────────────────────────────────\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Job Queue\n// ───────────────────────────────────────────────────────────────\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Defines the IngestJobState type.\n */\nexport type IngestJobState =\n  | 'queued'\n  | 'parsing'\n  | 'embedding'\n  | 'indexing'\n  | 'complete'\n  | 'failed'\n  | 'cancelled';\n\n/**\n * Describes the IngestJobError shape.\n */\nexport interface IngestJobError {\n  filePath: string;\n  message: string;\n  timestamp: string;\n}\n\n/**\n * Describes the IngestJob shape.\n */\nexport interface IngestJob {\n  id: string;\n  state: IngestJobState;\n  specFolder: string | null;\n  paths: string[];\n  filesTotal: number;\n  filesProcessed: number;\n  errors: IngestJobError[];\n  createdAt: string;\n  updatedAt: string;\n  // Validated governance decision captured at enqueue time so the worker\n  // re-indexes each path under the same provenance/retention/scope the\n  // synchronous save path applies. Null for ungoverned jobs (the default).\n  governance: GovernanceDecision | null;\n}\n\nexport interface IngestJobForecast {\n  etaSeconds: number | null;\n  etaConfidence: number | null;\n  failureRisk: number | null;\n  riskSignals: string[];\n  caveat: string | null;\n}\n\ninterface IngestJobRow {\n  id: string;\n  state: IngestJobState;\n  spec_folder: string | null;\n  paths_json: string;\n  files_total: number;\n  files_processed: number;\n  errors_json: string;\n  created_at: string;\n  updated_at: string;\n  governance_json?: string | null;\n}\n\ninterface JobQueueConfig {\n  processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nconst ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\nconst TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n\nconst ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n  queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n  parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n  embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n  indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n  complete: new Set<IngestJobState>([]),\n  failed: new Set<IngestJobState>([]),\n  cancelled: new Set<IngestJobState>([]),\n};\n\n/* ───────────────────────────────────────────────────────────────\n   5. STATE MANAGEMENT\n──────────────────────────────────────────────────────────────── */\n\n// True sequential queue — only one job processes at a time.\nconst pendingQueue: string[] = [];\nlet workerActive = false;\n// Drain fence. Once set, the worker stops draining and refuses to touch the\n// database. This prevents the worker from reopening a connection that shutdown\n// has already checkpointed and closed, which would otherwise re-dirty the WAL\n// and the unclean-shutdown marker at rest.\nlet shuttingDown = false;\nlet processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\nconst MAX_STORED_ERRORS = 50;\nconst MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n  if (!value) return fallback;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n  if (!value) return null;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n      return parsed as GovernanceDecision;\n    }\n    return null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    state: row.state,\n    specFolder: row.spec_folder,\n    paths: parseJsonArray<string>(row.paths_json, []),\n    filesTotal: row.files_total,\n    filesProcessed: row.files_processed,\n    errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    governance: parseGovernanceJson(row.governance_json),\n  };\n}\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\n// DB accessor for the worker path. While shutting down it refuses to acquire a\n// connection so the worker can never travel the requireDb -> getDb -> reopen\n// path after shutdown has closed the database. The throw is caught by the\n// worker's surrounding error handling and the drain unwinds cleanly.\nfunction acquireWorkerDb(): ReturnType<typeof requireDb> {\n  if (shuttingDown) {\n    throw new Error('Ingest worker is shutting down; database access refused');\n  }\n  return requireDb();\n}\n\nfunction ensureIngestJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS ingest_jobs (\n      id TEXT PRIMARY KEY,\n      state TEXT,\n      spec_folder TEXT,\n      paths_json TEXT,\n      files_total INTEGER,\n      files_processed INTEGER,\n      errors_json TEXT,\n      created_at TEXT,\n      updated_at TEXT,\n      governance_json TEXT\n    )\n  `);\n  // Backward-compatible migration: add the nullable governance column to tables\n  // created before governed ingest existed. In-flight jobs simply carry a null\n  // governance and remain ungoverned, exactly as before.\n  const columns = db.prepare(`PRAGMA table_info(ingest_jobs)`).all() as Array<{ name: string }>;\n  if (!columns.some((column) => column.name === 'governance_json')) {\n    db.exec(`ALTER TABLE ingest_jobs ADD COLUMN governance_json TEXT`);\n  }\n}\n\n// Restart interrupted jobs from the beginning on process startup.\n// Indexing is idempotent, and replaying the original path list avoids\n// Mismatches when path accessibility changes between runs.\nfunction resetIncompleteJobsToQueued(): string[] {\n  const db = requireDb();\n  // Collect IDs of jobs that will be reset so we can re-enqueue them.\n  const rows = db.prepare(`\n    SELECT id FROM ingest_jobs\n    WHERE state NOT IN ('complete', 'failed', 'cancelled')\n  `).all() as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET\n        state = 'queued',\n        files_processed = 0,\n        errors_json = '[]',\n        updated_at = ?\n      WHERE state NOT IN ('complete', 'failed', 'cancelled')\n    `).run(nowIso())\n  );\n\n  return rows.map((r) => r.id);\n}\n\nasync function createIngestJob(args: {\n  id: string;\n  paths: string[];\n  specFolder?: string;\n  governance?: GovernanceDecision | null;\n}): Promise<IngestJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const normalizedPaths = args.paths.map((entry) => String(entry).trim()).filter((entry) => entry.length > 0);\n\n  if (normalizedPaths.length === 0) {\n    throw new Error('paths must include at least one file path');\n  }\n\n  const governance = args.governance ?? null;\n  const governanceJson = governance ? JSON.stringify(governance) : null;\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO ingest_jobs (\n        id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      'queued',\n      args.specFolder ?? null,\n      JSON.stringify(normalizedPaths),\n      normalizedPaths.length,\n      0,\n      JSON.stringify([]),\n      timestamp,\n      timestamp,\n      governanceJson,\n    )\n  );\n\n  return {\n    id: args.id,\n    state: 'queued',\n    specFolder: args.specFolder ?? null,\n    paths: normalizedPaths,\n    filesTotal: normalizedPaths.length,\n    filesProcessed: 0,\n    errors: [],\n    createdAt: timestamp,\n    updatedAt: timestamp,\n    governance,\n  };\n}\n\nfunction getIngestJob(jobId: string): IngestJob | null {\n  const db = acquireWorkerDb();\n  const row = db.prepare(`\n    SELECT id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n    FROM ingest_jobs\n    WHERE id = ?\n  `).get(jobId) as IngestJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nasync function setIngestJobState(jobId: string, nextState: IngestJobState): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const current = getIngestJob(jobId);\n  if (!current) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid ingest job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  return {\n    ...current,\n    state: nextState,\n    updatedAt,\n  };\n}\n\nasync function incrementProcessed(jobId: string): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET files_processed = files_processed + 1, updated_at = ?\n      WHERE id = ?\n    `).run(updatedAt, jobId)\n  );\n\n  const updated = getIngestJob(jobId);\n  if (!updated) {\n    throw new Error(`Ingest job not found after progress update: ${jobId}`);\n  }\n  return updated;\n}\n\nasync function appendIngestError(jobId: string, filePath: string, error: unknown): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const current = getIngestJob(jobId);\n  if (!current) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n\n  let errors = [\n    ...current.errors,\n    {\n      filePath: toPublicPathLabel(filePath),\n      message: toErrorMessage(error),\n      timestamp: nowIso(),\n    },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: IngestJobError = {\n      filePath: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET errors_json = ?, updated_at = ?\n      WHERE id = ?\n    `).run(JSON.stringify(errors), updatedAt, jobId)\n  );\n\n  return {\n    ...current,\n    errors,\n    updatedAt,\n  };\n}\n\nasync function cancelIngestJob(jobId: string): Promise<IngestJob> {\n  const MAX_CANCEL_RETRIES = 3;\n\n  for (let attempt = 0; attempt < MAX_CANCEL_RETRIES; attempt += 1) {\n    const current = getIngestJob(jobId);\n    if (!current) {\n      throw new Error(`Ingest job not found: ${jobId}`);\n    }\n    if (TERMINAL_STATES.has(current.state)) {\n      return current;\n    }\n\n    try {\n      return await setIngestJobState(jobId, 'cancelled');\n    } catch (error: unknown) {\n      const message = toErrorMessage(error);\n      if (message.startsWith('State transition conflict:')) {\n        continue;\n      }\n\n      if (message.startsWith('Invalid ingest job state transition:')) {\n        const latest = getIngestJob(jobId);\n        if (latest && TERMINAL_STATES.has(latest.state)) {\n          return latest;\n        }\n        continue;\n      }\n\n      throw error;\n    }\n  }\n\n  const latest = getIngestJob(jobId);\n  if (!latest) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n  if (TERMINAL_STATES.has(latest.state)) {\n    return latest;\n  }\n\n  return setIngestJobState(jobId, 'cancelled');\n}\n\n/**\n * Provides the getIngestProgressPercent helper.\n */\nexport function getIngestProgressPercent(job: Pick<IngestJob, 'filesProcessed' | 'filesTotal'>): number {\n  if (job.filesTotal <= 0) return 0;\n  const raw = Math.round((job.filesProcessed / job.filesTotal) * 100);\n  return Math.max(0, Math.min(100, raw));\n}\n\nfunction parseIsoTimestamp(timestamp: string): number | null {\n  if (typeof timestamp !== 'string' || timestamp.trim().length === 0) {\n    return null;\n  }\n\n  const parsed = Date.parse(timestamp);\n  return Number.isFinite(parsed) ? parsed : null;\n}\n\nfunction clampUnitInterval(value: number): number {\n  if (!Number.isFinite(value)) return 0;\n  return Math.max(0, Math.min(1, value));\n}\n\nexport function getIngestForecast(\n  job: Pick<IngestJob, 'state' | 'filesProcessed' | 'filesTotal' | 'errors' | 'createdAt' | 'updatedAt'>,\n): IngestJobForecast {\n  const filesTotal = Math.max(0, job.filesTotal || 0);\n  const filesProcessed = Math.max(0, job.filesProcessed || 0);\n  const remaining = Math.max(0, filesTotal - filesProcessed);\n  const errorCount = Array.isArray(job.errors) ? job.errors.length : 0;\n  const errorRatio = filesTotal > 0 ? errorCount / filesTotal : 0;\n  const progressRatio = filesTotal > 0 ? filesProcessed / filesTotal : 0;\n  const riskSignals: string[] = [];\n\n  if (job.state === 'failed') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: 1,\n      riskSignals: ['terminal_failed'],\n      caveat: null,\n    };\n  }\n\n  if (job.state === 'complete') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: clampUnitInterval(errorRatio * 0.5),\n      riskSignals: errorCount > 0 ? ['completed_with_file_errors'] : [],\n      caveat: null,\n    };\n  }\n\n  if (job.state === 'cancelled') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: 0,\n      riskSignals: ['terminal_cancelled'],\n      caveat: 'Forecast is advisory only because the job is no longer progressing.',\n    };\n  }\n\n  if (filesTotal <= 0) {\n    return {\n      etaSeconds: null,\n      etaConfidence: null,\n      failureRisk: null,\n      riskSignals,\n      caveat: 'Forecast unavailable because the queue has no file-count baseline yet.',\n    };\n  }\n\n  if (errorCount > 0) {\n    riskSignals.push('file_errors_seen');\n  }\n  if (job.state === 'queued') {\n    riskSignals.push('queued_not_started');\n  }\n\n  const createdAtMs = parseIsoTimestamp(job.createdAt);\n  const updatedAtMs = parseIsoTimestamp(job.updatedAt);\n  const elapsedSeconds = createdAtMs !== null && updatedAtMs !== null && updatedAtMs >= createdAtMs\n    ? Math.max(0, (updatedAtMs - createdAtMs) / 1000)\n    : 0;\n\n  let etaSeconds: number | null = null;\n  let etaConfidence: number | null = null;\n  let caveat: string | null = null;\n\n  if (filesProcessed <= 0 || elapsedSeconds < 1) {\n    caveat = 'Forecast is low-confidence until at least one file has been processed.';\n  } else {\n    const throughput = filesProcessed / elapsedSeconds;\n    if (throughput > 0) {\n      etaSeconds = Math.max(0, Math.round(remaining / throughput));\n      etaConfidence = clampUnitInterval(0.35 + (progressRatio * 0.45) - (errorRatio * 0.25));\n      if (etaConfidence < 0.4) {\n        caveat = 'Forecast is low-confidence because queue history is still sparse or noisy.';\n      }\n    } else {\n      caveat = 'Forecast unavailable because throughput could not be derived from queue history.';\n    }\n  }\n\n  if (progressRatio <= 0 && job.state !== 'queued') {\n    riskSignals.push('active_without_progress');\n  }\n  if (errorRatio >= 0.5 && errorCount > 0) {\n    riskSignals.push('high_error_ratio');\n  }\n\n  const stateRisk = job.state === 'indexing' ? 0.15 : (job.state === 'embedding' ? 0.1 : 0.05);\n  const failureRisk = clampUnitInterval((errorRatio * 0.7) + stateRisk + (progressRatio === 0 ? 0.05 : 0));\n\n  return {\n    etaSeconds,\n    etaConfidence,\n    failureRisk,\n    riskSignals,\n    caveat,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. WORKER\n──────────────────────────────────────────────────────────────── */\n\n// Real state machine — states now correspond to actual work phases.\n// Progress is tracked against the original submitted path list so terminal\n// Accounting stays stable even when some files are inaccessible.\nasync function processQueuedJob(jobId: string): Promise<void> {\n  if (!processFileFn) {\n    throw new Error('Ingest queue not initialized: processFile handler is missing');\n  }\n\n  let job = getIngestJob(jobId);\n  if (!job || TERMINAL_STATES.has(job.state)) {\n    return;\n  }\n\n  // Step 1: Parsing — validate all paths exist and are readable.\n  job = await setIngestJobState(jobId, 'parsing');\n  if (TERMINAL_STATES.has(job.state)) return;\n\n  const { access } = await import('fs/promises');\n\n  // Step 2: Embedding — placeholder for batch embedding pre-processing.\n  // Transition is meaningful: it signals readiness for indexing after validation.\n  const latest1 = getIngestJob(jobId);\n  if (!latest1 || TERMINAL_STATES.has(latest1.state)) return;\n  job = await setIngestJobState(jobId, 'embedding');\n  if (TERMINAL_STATES.has(job.state)) return;\n\n  // Step 3: Indexing — process only validated paths (not original paths).\n  const latest2 = getIngestJob(jobId);\n  if (!latest2 || TERMINAL_STATES.has(latest2.state)) return;\n  job = await setIngestJobState(jobId, 'indexing');\n\n  // Resume from filesProcessed against the original submitted path order.\n  let currentIndex = job.filesProcessed;\n  // Track actual failure count independently of the truncated errors array.\n  // The errors array is capped at MAX_STORED_ERRORS, so using errors.length for\n  // Terminal state decisions would misclassify all-fail jobs with >50 files as \"complete\".\n  let failCount = 0;\n\n  while (currentIndex < job.paths.length) {\n    // Stop touching the DB the moment shutdown begins. The job stays in an\n    // active state and boot crash-recovery re-enqueues it on the next start.\n    if (shuttingDown) return;\n    const current = getIngestJob(jobId);\n    if (!current) return;\n    if (current.state === 'cancelled') return;\n\n    const nextPath = current.paths[currentIndex];\n    if (!nextPath) {\n      break;\n    }\n\n    // Continue on file error instead of aborting the entire job.\n    try {\n      await access(nextPath);\n      await processFileFn(nextPath, current.governance);\n    } catch (error: unknown) {\n      const normalizedError = error instanceof Error\n        && 'code' in error\n        && typeof error.code === 'string'\n        && error.code === 'ENOENT'\n        ? new Error('File not accessible')\n        : error;\n      await appendIngestError(jobId, nextPath, normalizedError);\n      failCount += 1;\n      console.warn(`[job-queue] File error (continuing): ${toPublicPathLabel(nextPath)} — ${toErrorMessage(normalizedError)}`);\n    }\n\n    job = await incrementProcessed(jobId);\n    currentIndex = job.filesProcessed;\n  }\n\n  // Determine terminal state: complete if no errors, failed if all files errored.\n  const done = getIngestJob(jobId);\n  if (!done) return;\n  if (done.state === 'cancelled') return;\n\n  if (failCount > 0 && failCount >= done.filesTotal) {\n    // All files failed — mark as failed.\n    await setIngestJobState(jobId, 'failed');\n  } else {\n    // Partial or full success — mark as complete (errors are preserved in record).\n    await setIngestJobState(jobId, 'complete');\n  }\n}\n\n// True sequential worker — processes one job at a time.\n// Multiple enqueueIngestJob calls add to pendingQueue; a single worker drains it.\nasync function drainQueue(): Promise<void> {\n  if (workerActive) return;\n  workerActive = true;\n\n  try {\n    while (pendingQueue.length > 0) {\n      // Halt draining once shutdown begins so no new job opens the DB.\n      if (shuttingDown) break;\n      // PendingQueue.length > 0 in the loop condition guarantees shift() returns a job id\n      const jobId = pendingQueue.shift()!;\n      try {\n        await processQueuedJob(jobId);\n      } catch (error: unknown) {\n        try {\n          await appendIngestError(jobId, '__job__', error);\n          const current = getIngestJob(jobId);\n          if (current && ACTIVE_STATES.has(current.state)) {\n            await setIngestJobState(jobId, 'failed');\n          }\n        } catch (_error: unknown) {\n          // Non-fatal: queue guard to avoid unhandled rejection loops.\n        }\n      }\n\n      // Brief yield between jobs to avoid starving the event loop.\n      await sleep(10);\n    }\n  } finally {\n    workerActive = false;\n  }\n}\n\nfunction enqueueIngestJob(jobId: string): void {\n  // Never admit work or respawn the worker once shutdown has begun.\n  if (shuttingDown) {\n    return;\n  }\n  // Prevent duplicate enqueue of the same job.\n  if (pendingQueue.includes(jobId)) {\n    return;\n  }\n\n  pendingQueue.push(jobId);\n  while (pendingQueue.length > MAX_PENDING_INGEST_JOBS) {\n    const evictedJobId = pendingQueue.shift();\n    if (!evictedJobId) break;\n    void appendIngestError(\n      evictedJobId,\n      '__job__',\n      new Error(`Pending ingest queue exceeded cap ${MAX_PENDING_INGEST_JOBS}; oldest job aborted`),\n    )\n      .then(() => cancelIngestJob(evictedJobId))\n      .catch((error: unknown) => {\n        console.warn(`[job-queue] Failed to cancel overflow job ${evictedJobId}: ${toErrorMessage(error)}`);\n      });\n  }\n\n  // Start worker if not already running (fire-and-forget).\n  if (!workerActive) {\n    setImmediate(() => {\n      void drainQueue().catch((error: unknown) => {\n        console.error(`[job-queue] Worker error: ${toErrorMessage(error)}`);\n      });\n    });\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. INITIALIZATION\n──────────────────────────────────────────────────────────────── */\n\nfunction initIngestJobQueue(config: JobQueueConfig): { resetCount: number } {\n  processFileFn = config.processFile;\n  ensureIngestJobsTable();\n\n  // Crash recovery: reset incomplete jobs to 'queued' AND re-enqueue them\n  // So they actually get processed by the worker.\n  const resetJobIds = resetIncompleteJobsToQueued();\n  for (const jobId of resetJobIds) {\n    enqueueIngestJob(jobId);\n  }\n\n  return { resetCount: resetJobIds.length };\n}\n\n// Default ceiling for how long stopWorker waits for the active drain to settle.\n// The worker yields between files and between jobs, so it observes the fence\n// quickly; the bound only guards against a wedged in-flight processFile call.\nconst STOP_WORKER_DRAIN_DEADLINE_MS = 2_000;\n\n// Fence the ingest worker for shutdown: refuse new work, drop the pending\n// queue, and wait (bounded) for any in-flight drain to unwind before the\n// database is closed. Must run before closeDb() so the worker cannot reopen a\n// closed connection. Idempotent and safe to call when the worker is idle.\nasync function stopWorker(options: { drainDeadlineMs?: number } = {}): Promise<void> {\n  shuttingDown = true;\n  pendingQueue.length = 0;\n\n  if (!workerActive) return;\n\n  const deadline = Date.now()\n    + (Number.isFinite(options.drainDeadlineMs) && (options.drainDeadlineMs as number) > 0\n      ? (options.drainDeadlineMs as number)\n      : STOP_WORKER_DRAIN_DEADLINE_MS);\n\n  while (workerActive && Date.now() < deadline) {\n    await sleep(10);\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  initIngestJobQueue,\n  stopWorker,\n  createIngestJob,\n  getIngestJob,\n  cancelIngestJob,\n  enqueueIngestJob,\n  resetIncompleteJobsToQueued,\n  MAX_PENDING_INGEST_JOBS,\n};","lineStart":1,"lineEnd":791,"totalLines":791,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","time":{"start":1781763522579,"end":1781763522610}},"metadata":{"openai":{"itemId":"fc_07d11185e93d73e2016a338dc1a4788191ab6723ee6ae4054f"}},"id":"prt_ed961c011001Qa2p5f8io6Lmt2","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed9618031001aMd6sS9Tw21zdA"}}
{"type":"tool_use","timestamp":1781763522618,"sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","part":{"type":"tool","tool":"read","callID":"call_ekbk5x82qqxZ0lubQaKEkTHj","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Checkpoints\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Checkpoint creation (checkpoint_create)\n5: // Feature catalog: Checkpoint restore (checkpoint_restore)\n6: // Gzip-compressed database checkpoints with embedding preservation\n7: // Node stdlib\n8: import * as fs from 'fs';\n9: import * as path from 'path';\n10: import * as zlib from 'zlib';\n11: \n12: // External packages\n13: import type Database from 'better-sqlite3';\n14: import { z } from 'zod';\n15: \n16: // Internal utils\n17: import { toErrorMessage } from '../../utils/db-helpers.js';\n18: import { rebuildAutoEntities } from '../extraction/entity-extractor.js';\n19: import {\n20:   buildGovernanceLogicalKey,\n21:   createScopeFilterPredicate,\n22:   GOVERNANCE_AUDIT_ACTIONS,\n23:   hasScopeConstraints,\n24:   normalizeScopeContext,\n25:   recordGovernanceAudit,\n26:   recordTierDowngradeAudit,\n27:   type ScopeContext,\n28:   type GovernanceAuditEntry,\n29:   type TierDowngradeAuditParams,\n30: } from '../governance/scope-governance.js';\n31: import { detectCommunities, storeCommunityAssignments } from '../graph/community-detection.js';\n32: import { generateCommunitySummaries } from '../graph/community-summaries.js';\n33: import { storeCommunities } from '../graph/community-storage.js';\n34: import { snapshotDegrees } from '../graph/graph-signals.js';\n35: import { runLineageBackfill } from './lineage-state.js';\n36: import { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../utils/index-scope.js';\n37: import { reopenActiveDatabase } from '../search/vector-index-store.js';\n38: import { SCHEMA_VERSION } from '../search/vector-index-schema.js';\n39: import { sweepCausalEdges } from '../causal/sweep.js';\n40: import { BetterSqliteContentionPolicy } from './ports/contention-policy.js';\n41: \n42: function batchedInQuery<T>(db: Database.Database, sql: string, ids: (number | string)[], batchSize = 500): T[] {\n43:   const results: T[] = [];\n44:   for (let i = 0; i < ids.length; i += batchSize) {\n45:     const batch = ids.slice(i, i + batchSize);\n46:     const placeholders = batch.map(() => '?').join(', ');\n47:     const batchSql = sql.replace('__PLACEHOLDERS__', placeholders);\n48:     results.push(...(db.prepare(batchSql).all(...batch) as T[]));\n49:   }\n50:   return results;\n51: }\n52: \n53: function dedupeRowsById<T extends Record<string, unknown>>(rows: T[]): T[] {\n54:   const results: T[] = [];\n55:   const seenIds = new Set<number | string>();\n56: \n57:   for (const row of rows) {\n58:     const id = row.id;\n59:     if (typeof id === 'number' || typeof id === 'string') {\n60:       if (seenIds.has(id)) {\n61:         continue;\n62:       }\n63:       seenIds.add(id);\n64:     }\n65:     results.push(row);\n66:   }\n67: \n68:   return results;\n69: }\n70: \n71: function getSnapshotColumnsFromRows(rows: Array<Record<string, unknown>>): string[] {\n72:   const columns = new Set<string>();\n73: \n74:   for (const row of rows) {\n75:     for (const key of Object.keys(row ?? {})) {\n76:       if (typeof key === 'string' && key.length > 0) {\n77:         columns.add(key);\n78:       }\n79:     }\n80:   }\n81: \n82:   return Array.from(columns);\n83: }\n84: \n85: function flushGovernanceAudits(\n86:   database: Database.Database,\n87:   entries: GovernanceAuditEntry[],\n88: ): void {\n89:   for (const entry of entries) {\n90:     try {\n91:       recordGovernanceAudit(database, entry);\n92:     } catch (error: unknown) {\n93:       console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n94:     }\n95:   }\n96: }\n97: \n98: function flushTierDowngradeAudits(\n99:   database: Database.Database,\n100:   entries: TierDowngradeAuditParams[],\n101: ): void {\n102:   for (const entry of entries) {\n103:     try {\n104:       recordTierDowngradeAudit(database, entry);\n105:     } catch (error: unknown) {\n106:       console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n107:     }\n108:   }\n109: }\n110: \n111: /* ───────────────────────────────────────────────────────────────\n112:    1. CONSTANTS\n113: ----------------------------------------------------------------*/\n114: \n115: const MAX_CHECKPOINTS = 10;\n116: const CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\n117: const CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\n118: const CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\n119: const RESTORE_JOURNAL_NAME = '.restore-journal.json';\n120: const NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\n121: const checkpointContention = new BetterSqliteContentionPolicy({ retryable: isCheckpointBusyError });\n122: \n123: const CHECKPOINT_MANIFEST = Object.freeze({\n124:   snapshot: [\n125:     'memory_index',\n126:     'vec_memories',\n127:     'vec_metadata',\n128:     'working_memory',\n129:     'causal_edges',\n130:     'weight_history',\n131:     'memory_history',\n132:     'mutation_ledger',\n133:     'memory_conflicts',\n134:     'memory_corrections',\n135:     'adaptive_signal_events',\n136:     'negative_feedback_events',\n137:     'learned_feedback_audit',\n138:     'session_learning',\n139:     'governance_audit',\n140:     'session_state',\n141:     'session_sent_memories',\n142:     'memory_summaries',\n143:   ],\n144:   rebuild: [\n145:     'memory_lineage',\n146:     'active_memory_projection',\n147:     'memory_entities',\n148:     'entity_catalog',\n149:     'degree_snapshots',\n150:     'community_assignments',\n151:     'graph_communities',\n152:     'community_summaries',\n153:     'memory_fts',\n154:   ],\n155:   skip: [\n156:     'checkpoints',\n157:     'schema_version',\n158:     'embedding_cache',\n159:     'adaptive_shadow_runs',\n160:   ],\n161: });\n162: \n163: const CHECKPOINT_RESTORE_ORDER = [\n164:   'memory_index',\n165:   'vec_memories',\n166:   'vec_metadata',\n167:   'working_memory',\n168:   'causal_edges',\n169:   'weight_history',\n170:   'memory_history',\n171:   'mutation_ledger',\n172:   'memory_conflicts',\n173:   'memory_corrections',\n174:   'adaptive_signal_events',\n175:   'negative_feedback_events',\n176:   'learned_feedback_audit',\n177:   'session_learning',\n178:   'governance_audit',\n179:   'session_state',\n180:   'session_sent_memories',\n181:   'memory_summaries',\n182: ] as const;\n183: \n184: const CHECKPOINT_CLEAR_ORDER = [...CHECKPOINT_RESTORE_ORDER].reverse();\n185: \n186: const MUTATION_LEDGER_TRIGGER_SQL = `\n187:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n188:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n189:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n190:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n191: `;\n192: \n193: /* ───────────────────────────────────────────────────────────────\n194:    2. INTERFACES\n195: ----------------------------------------------------------------*/\n196: \n197: interface CheckpointEntry {\n198:   id: number;\n199:   name: string;\n200:   created_at: string;\n201:   spec_folder: string | null;\n202:   git_branch: string | null;\n203:   memory_snapshot: Buffer | null;\n204:   file_snapshot: Buffer | null;\n205:   snapshot_format?: string | null;\n206:   snapshot_path?: string | null;\n207:   metadata: string | null;\n208: }\n209: \n210: interface CheckpointInfo {\n211:   id: number;\n212:   name: string;\n213:   createdAt: string;\n214:   specFolder: string | null;\n215:   gitBranch: string | null;\n216:   snapshotSize: number;\n217:   metadata: Record<string, unknown>;\n218:   [key: string]: unknown;\n219: }\n220: \n221: interface CreateCheckpointOptions {\n222:   name?: string;\n223:   specFolder?: string | null;\n224:   includeEmbeddings?: boolean;\n225:   metadata?: Record<string, unknown>;\n226:   scope?: ScopeContext;\n227: }\n228: \n229: type CheckpointCreateErrorCode =\n230:   | 'CHECKPOINT_CREATE_SQLITE_BUSY'\n231:   | 'CHECKPOINT_CREATE_SQLITE_LOCKED'\n232:   | 'CHECKPOINT_CREATE_DUPLICATE_NAME'\n233:   | 'CHECKPOINT_CREATE_INVALID_NAME'\n234:   | 'CHECKPOINT_CREATE_PERMISSION_DENIED'\n235:   | 'CHECKPOINT_CREATE_FAILED';\n236: \n237: type CheckpointRestoreErrorCode =\n238:   | 'CHECKPOINT_RESTORE_MANIFEST_INVALID'\n239:   | 'CHECKPOINT_RESTORE_DOWNGRADE_UNSAFE'\n240:   | 'CHECKPOINT_RESTORE_EMBEDDER_MISMATCH'\n241:   | 'CHECKPOINT_RESTORE_FILE_MISSING'\n242:   | 'CHECKPOINT_RESTORE_PATH_UNRESOLVED'\n243:   | 'CHECKPOINT_RESTORE_JOURNAL_FAILED'\n244:   | 'CHECKPOINT_RESTORE_SWAP_FAILED';\n245: \n246: class CheckpointCreateError extends Error {\n247:   public readonly code: CheckpointCreateErrorCode;\n248:   public readonly originalCode: string | null;\n249:   public readonly details: Record<string, unknown>;\n250: \n251:   constructor(\n252:     code: CheckpointCreateErrorCode,\n253:     message: string,\n254:     details: Record<string, unknown> = {},\n255:     cause?: unknown,\n256:   ) {\n257:     super(message, { cause });\n258:     Object.setPrototypeOf(this, CheckpointCreateError.prototype);\n259:     this.name = 'CheckpointCreateError';\n260:     this.code = code;\n261:     this.originalCode = typeof details.originalCode === 'string' ? details.originalCode : null;\n262:     this.details = details;\n263:   }\n264: }\n265: \n266: class CheckpointRestoreError extends Error {\n267:   public readonly code: CheckpointRestoreErrorCode;\n268: \n269:   constructor(code: CheckpointRestoreErrorCode, message: string, cause?: unknown) {\n270:     super(message, { cause });\n271:     Object.setPrototypeOf(this, CheckpointRestoreError.prototype);\n272:     this.name = 'CheckpointRestoreError';\n273:     this.code = code;\n274:   }\n275: }\n276: \n277: interface RestoreCheckpointV2Options {\n278:   reopen?: (targetMainPath: string, swapFn: () => void) => Database.Database;\n279: }\n280: \n281: interface RestoreResult {\n282:   restored: number;\n283:   skipped: number;\n284:   errors: string[];\n285:   workingMemoryRestored: number;\n286:   partialFailure?: boolean;\n287:   rolledBackTables?: string[];\n288: }\n289: \n290: interface DerivedRebuildFailure {\n291:   name: string;\n292:   error: string;\n293: }\n294: \n295: interface DerivedRebuildSkipped {\n296:   name: string;\n297:   reason: string;\n298: }\n299: \n300: interface DerivedRebuildSummary {\n301:   completed: string[];\n302:   failed: DerivedRebuildFailure[];\n303:   skipped: DerivedRebuildSkipped[];\n304: }\n305: \n306: interface RunDerivedArtifactRebuildOptions {\n307:   specFolder?: string | null;\n308:   actor?: string;\n309:   logContext?: string;\n310: }\n311: \n312: interface NeedsRebuildSentinelFile {\n313:   formatVersion: 1;\n314:   createdAt: string;\n315:   source: string;\n316:   reason: string;\n317:   rebuildSummary?: DerivedRebuildSummary;\n318: }\n319: \n320: interface NeedsRebuildSentinelWriteOptions {\n321:   source: string;\n322:   reason: string;\n323:   summary?: DerivedRebuildSummary;\n324: }\n325: \n326: interface NeedsRebuildRepairOptions {\n327:   source: string;\n328:   specFolder?: string | null;\n329:   actor?: string;\n330: }\n331: \n332: interface NeedsRebuildRepairResult {\n333:   sentinelPresent: boolean;\n334:   attempted: boolean;\n335:   cleared: boolean;\n336:   summary: DerivedRebuildSummary | null;\n337:   error: string | null;\n338: }\n339: \n340: interface SnapshotVectorRow {\n341:   rowid: number;\n342:   embedding: Buffer | null;\n343: }\n344: \n345: interface TableSnapshot {\n346:   columns: string[];\n347:   rows: Array<Record<string, unknown>>;\n348: }\n349: \n350: interface CheckpointManifest {\n351:   snapshot: string[];\n352:   rebuild: string[];\n353:   skip: string[];\n354: }\n355: \n356: interface CheckpointSnapshot {\n357:   manifest?: CheckpointManifest;\n358:   tables?: Record<string, TableSnapshot>;\n359:   memories: Array<Record<string, unknown>>;\n360:   workingMemory: Array<Record<string, unknown>>;\n361:   vectors?: SnapshotVectorRow[];\n362:   causalEdges?: Array<Record<string, unknown>>;\n363:   timestamp: string;\n364: }\n365: \n366: interface DatabaseListRow {\n367:   seq?: number;\n368:   name?: string;\n369:   file?: string;\n370: }\n371: \n372: interface CheckpointV2Manifest {\n373:   formatVersion: 2;\n374:   createdAt: string;\n375:   specFolder: null;\n376:   gitBranch: string | null;\n377:   embedderSlug: string | null;\n378:   includeEmbeddings: boolean;\n379:   mainTables: string[];\n380:   vecTables: string[];\n381:   schemaVersion: number;\n382:   memoryCount: number;\n383:   vectorCount: number;\n384:   mainBytes: number;\n385:   vecBytes: number;\n386: }\n387: \n388: type RestoreJournalPhase = 'swap-pending' | 'swap-done';\n389: \n390: interface RestoreJournalFile {\n391:   formatVersion: 1;\n392:   phase: RestoreJournalPhase;\n393:   createdAt: string;\n394:   checkpointName: string;\n395:   liveMainPath: string;\n396:   backupMainPath: string;\n397:   snapshotMainPath: string;\n398:   liveShardPath: string | null;\n399:   backupShardPath: string | null;\n400:   snapshotVecPath: string | null;\n401:   shouldRestoreVec: boolean;\n402:   liveShardPreexisted: boolean;\n403: }\n404: \n405: // Validate the decompressed checkpoint snapshot before\n406: // restore. Previously the gzipped blob was JSON.parsed and cast directly\n407: // to CheckpointSnapshot — malformed memory_index rows propagated through\n408: // `getMemoryIds()` and the INSERT loops. This schema validates the\n409: // outer envelope and the array shapes; individual row shapes are still\n410: // permissive (sqlite columns evolve over time) but each row must be a\n411: // non-null object so downstream column extraction doesn't NPE.\n412: const CheckpointTableSnapshotSchema = z.object({\n413:   columns: z.array(z.string()),\n414:   rows: z.array(z.record(z.string(), z.unknown())),\n415: });\n416: \n417: const CheckpointVectorRowSchema = z.object({\n418:   rowid: z.number(),\n419:   embedding: z.unknown(), // Buffer or null — preserved as-is\n420: });\n421: \n422: const CheckpointSnapshotSchema = z.object({\n423:   manifest: z.object({\n424:     snapshot: z.array(z.string()),\n425:     rebuild: z.array(z.string()),\n426:     skip: z.array(z.string()),\n427:   }).optional(),\n428:   tables: z.record(z.string(), CheckpointTableSnapshotSchema).optional(),\n429:   memories: z.array(z.record(z.string(), z.unknown())),\n430:   workingMemory: z.array(z.record(z.string(), z.unknown())),\n431:   vectors: z.array(CheckpointVectorRowSchema).optional(),\n432:   causalEdges: z.array(z.record(z.string(), z.unknown())).optional(),\n433:   timestamp: z.string(),\n434: }).passthrough();\n435: \n436: interface RestoreBarrierStatus {\n437:   code: string;\n438:   message: string;\n439: }\n440: \n441: interface RestoreBarrierHooks {\n442:   afterAcquire?: (() => void) | null;\n443:   beforeRelease?: (() => void) | null;\n444: }\n445: \n446: /* ───────────────────────────────────────────────────────────────\n447:    3. MODULE STATE\n448: ----------------------------------------------------------------*/\n449: \n450: let db: Database.Database | null = null;\n451: let restoreInProgress = false;\n452: let restoreBarrierHooks: RestoreBarrierHooks = {};\n453: \n454: const RESTORE_IN_PROGRESS_ERROR_CODE = 'E_RESTORE_IN_PROGRESS';\n455: const RESTORE_IN_PROGRESS_ERROR_MESSAGE = 'Checkpoint restore maintenance is in progress. Retry after the restore lifecycle completes.';\n456: \n457: /* ───────────────────────────────────────────────────────────────\n458:    4. INITIALIZATION\n459: ----------------------------------------------------------------*/\n460: \n461: function init(database: Database.Database): void {\n462:   db = database;\n463: }\n464: \n465: function getDatabase(): Database.Database {\n466:   if (!db) throw new Error('Database not initialized. The checkpoints module requires the MCP server to be running. Restart the MCP server and retry.');\n467:   return db;\n468: }\n469: \n470: function getErrorCode(error: unknown): string | null {\n471:   if (typeof error === 'object' && error !== null && 'code' in error) {\n472:     const code = (error as { code?: unknown }).code;\n473:     return typeof code === 'string' ? code : null;\n474:   }\n475:   return null;\n476: }\n477: \n478: function isCheckpointBusyError(error: unknown): boolean {\n479:   const code = getErrorCode(error);\n480:   const message = toErrorMessage(error);\n481:   return code === 'SQLITE_BUSY'\n482:     || code === 'SQLITE_LOCKED'\n483:     || /\\bSQLITE_BUSY\\b|\\bSQLITE_LOCKED\\b|database is locked/i.test(message);\n484: }\n485: \n486: function classifyCheckpointCreateError(\n487:   error: unknown,\n488:   context: Record<string, unknown> = {},\n489: ): CheckpointCreateError {\n490:   if (error instanceof CheckpointCreateError) {\n491:     return error;\n492:   }\n493: \n494:   const originalCode = getErrorCode(error);\n495:   const message = toErrorMessage(error);\n496:   const details = {\n497:     ...context,\n498:     ...(originalCode ? { originalCode } : {}),\n499:     originalMessage: message,\n500:   };\n501: \n502:   if (originalCode === 'SQLITE_BUSY' || /\\bSQLITE_BUSY\\b|database is locked/i.test(message)) {\n503:     return new CheckpointCreateError(\n504:       'CHECKPOINT_CREATE_SQLITE_BUSY',\n505:       'Checkpoint creation failed because the SQLite database was busy. Retry after current writes finish.',\n506:       details,\n507:       error,\n508:     );\n509:   }\n510: \n511:   if (originalCode === 'SQLITE_LOCKED' || /\\bSQLITE_LOCKED\\b/i.test(message)) {\n512:     return new CheckpointCreateError(\n513:       'CHECKPOINT_CREATE_SQLITE_LOCKED',\n514:       'Checkpoint creation failed because the SQLite database was locked by another operation.',\n515:       details,\n516:       error,\n517:     );\n518:   }\n519: \n520:   if (/UNIQUE constraint failed: checkpoints\\.name|constraint failed/i.test(message)) {\n521:     return new CheckpointCreateError(\n522:       'CHECKPOINT_CREATE_DUPLICATE_NAME',\n523:       'Checkpoint creation failed because a checkpoint with this name already exists.',\n524:       details,\n525:       error,\n526:     );\n527:   }\n528: \n529:   if (\n530:     originalCode === 'EACCES'\n531:     || originalCode === 'EPERM'\n532:     || originalCode === 'SQLITE_READONLY'\n533:     || /permission denied|readonly|read-only/i.test(message)\n534:   ) {\n535:     return new CheckpointCreateError(\n536:       'CHECKPOINT_CREATE_PERMISSION_DENIED',\n537:       'Checkpoint creation failed because the database path is not writable.',\n538:       details,\n539:       error,\n540:     );\n541:   }\n542: \n543:   return new CheckpointCreateError(\n544:     'CHECKPOINT_CREATE_FAILED',\n545:     `Checkpoint creation failed: ${message}`,\n546:     details,\n547:     error,\n548:   );\n549: }\n550: \n551: function checkpointRetryDelayMs(): number {\n552:   return CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS\n553:     + Math.floor(Math.random() * (CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS - CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS + 1));\n554: }\n555: \n556: function isRestoreInProgress(): boolean {\n557:   return restoreInProgress;\n558: }\n559: \n560: function getRestoreBarrierStatus(): RestoreBarrierStatus | null {\n561:   if (!restoreInProgress) {\n562:     return null;\n563:   }\n564: \n565:   return {\n566:     code: RESTORE_IN_PROGRESS_ERROR_CODE,\n567:     message: RESTORE_IN_PROGRESS_ERROR_MESSAGE,\n568:   };\n569: }\n570: \n571: function setRestoreBarrierHooks(hooks: RestoreBarrierHooks | null): void {\n572:   restoreBarrierHooks = hooks ?? {};\n573: }\n574: \n575: function acquireRestoreBarrier(): void {\n576:   restoreInProgress = true;\n577:   restoreBarrierHooks.afterAcquire?.();\n578: }\n579: \n580: function releaseRestoreBarrier(): void {\n581:   try {\n582:     restoreBarrierHooks.beforeRelease?.();\n583:   } finally {\n584:     restoreInProgress = false;\n585:   }\n586: }\n587: \n588: /* ───────────────────────────────────────────────────────────────\n589:    5. HELPERS\n590: ----------------------------------------------------------------*/\n591: \n592: function getGitBranch(): string | null {\n593:   const candidates = [\n594:     process.env.GIT_BRANCH,\n595:     process.env.BRANCH_NAME,\n596:     process.env.CI_COMMIT_REF_NAME,\n597:     process.env.VERCEL_GIT_COMMIT_REF,\n598:   ];\n599: \n600:   for (const candidate of candidates) {\n601:     if (typeof candidate === 'string' && candidate.trim().length > 0) {\n602:       return candidate.trim();\n603:     }\n604:   }\n605: \n606:   return null;\n607: }\n608: \n609: function quoteSqlString(value: string): string {\n610:   return `'${value.replace(/'/g, \"''\")}'`;\n611: }\n612: \n613: function getDatabaseList(database: Database.Database): DatabaseListRow[] {\n614:   return database.prepare('PRAGMA database_list').all() as DatabaseListRow[];\n615: }\n616: \n617: function sanitizeCheckpointName(name: string): string {\n618:   const sanitized = name.trim();\n619:   if (\n620:     sanitized.length === 0\n621:     || sanitized.length > 128\n622:     || sanitized.includes('/')\n623:     || sanitized.includes('\\\\')\n624:     || sanitized.includes('..')\n625:     || sanitized.includes('\\0')\n626:   ) {\n627:     throw new CheckpointCreateError(\n628:       'CHECKPOINT_CREATE_INVALID_NAME',\n629:       'Checkpoint creation failed because the checkpoint name is invalid.',\n630:       { name },\n631:     );\n632:   }\n633:   return sanitized;\n634: }\n635: \n636: function resolveCheckpointDir(database: Database.Database, name: string): string {\n637:   const sanitizedName = sanitizeCheckpointName(name);\n638:   const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n639:   const mainFile = mainRow?.file;\n640:   if (!mainFile || mainFile === ':memory:') {\n641:     throw new CheckpointCreateError(\n642:       'CHECKPOINT_CREATE_FAILED',\n643:       'Checkpoint creation failed because the main database file path could not be resolved.',\n644:       { name: sanitizedName },\n645:     );\n646:   }\n647:   return path.join(path.dirname(mainFile), 'checkpoints', sanitizedName);\n648: }\n649: \n650: function getActiveVectorShardPath(database: Database.Database): string | null {\n651:   const activeVec = getDatabaseList(database).find((row) => row.name === 'active_vec');\n652:   return activeVec?.file && activeVec.file.length > 0 ? activeVec.file : null;\n653: }\n654: \n655: function deriveEmbedderSlug(shardPath: string | null): string | null {\n656:   if (!shardPath) {\n657:     return null;\n658:   }\n659:   const match = /^context-vectors__(.+)\\.sqlite$/.exec(path.basename(shardPath));\n660:   return match?.[1] ?? null;\n661: }\n662: \n663: function sweepStaleCheckpointTmpDirs(checkpointsDir: string): void {\n664:   if (!fs.existsSync(checkpointsDir)) {\n665:     return;\n666:   }\n667:   for (const entry of fs.readdirSync(checkpointsDir, { withFileTypes: true })) {\n668:     if (entry.isDirectory() && entry.name.includes('.tmp-')) {\n669:       fs.rmSync(path.join(checkpointsDir, entry.name), { recursive: true, force: true });\n670:     }\n671:   }\n672: }\n673: \n674: function resolvePathSafe(targetPath: string): string {\n675:   try {\n676:     return fs.realpathSync(targetPath);\n677:   } catch (_error: unknown) {\n678:     return path.resolve(targetPath);\n679:   }\n680: }\n681: \n682: function sweepOrphanCheckpointSnapshotDirs(database: Database.Database, checkpointsDir: string): void {\n683:   // Checkpoint pruning removes the catalog row inside the create transaction but deletes\n684:   // the snapshot dir AFTER commit. A crash in that gap leaves a snapshot dir with no\n685:   // catalog row — never swept by the .tmp-* sweep (it has a published name) and never\n686:   // restorable. Reconcile on-disk v2 snapshot dirs against the live catalog and remove\n687:   // any that no catalog row references. Best-effort: never throw out of the create path.\n688:   try {\n689:     if (!fs.existsSync(checkpointsDir) || !tableExists(database, 'checkpoints')) {\n690:       return;\n691:     }\n692: \n693:     const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n694:     if (!checkpointColumns.has('snapshot_path')) {\n695:       return;\n696:     }\n697:     const referenced = new Set<string>();\n698:     const rows = database.prepare(\n699:       \"SELECT snapshot_path FROM checkpoints WHERE snapshot_path IS NOT NULL AND snapshot_path <> ''\",\n700:     ).all() as Array<{ snapshot_path?: string | null }>;\n701:     for (const row of rows) {\n702:       if (typeof row.snapshot_path === 'string' && row.snapshot_path.length > 0) {\n703:         referenced.add(resolvePathSafe(row.snapshot_path));\n704:       }\n705:     }\n706: \n707:     for (const entry of fs.readdirSync(checkpointsDir, { withFileTypes: true })) {\n708:       if (!entry.isDirectory() || entry.name.includes('.tmp-')) {\n709:         continue;\n710:       }\n711:       const entryPath = path.join(checkpointsDir, entry.name);\n712:       if (referenced.has(resolvePathSafe(entryPath))) {\n713:         continue;\n714:       }\n715:       try {\n716:         fs.rmSync(entryPath, { recursive: true, force: true });\n717:         console.warn(`[checkpoints] Swept orphan checkpoint snapshot dir with no catalog row: ${entry.name}`);\n718:       } catch (_removeError: unknown) {\n719:         // Best-effort: a single un-removable dir must not block checkpoint creation.\n720:       }\n721:     }\n722:   } catch (error: unknown) {\n723:     console.warn(`[checkpoints] Orphan checkpoint snapshot sweep skipped (non-fatal): ${toErrorMessage(error)}`);\n724:   }\n725: }\n726: \n727: function readSchemaVersion(database: Database.Database): number | null {\n728:   try {\n729:     const row = database.prepare('SELECT version FROM schema_version WHERE id = 1').get() as { version?: number } | undefined;\n730:     return typeof row?.version === 'number' ? row.version : null;\n731:   } catch (_error: unknown) {\n732:     return null;\n733:   }\n734: }\n735: \n736: function countTableRows(database: Database.Database, tableName: string): number {\n737:   if (!tableExists(database, tableName)) {\n738:     return 0;\n739:   }\n740:   const row = database.prepare(`SELECT COUNT(*) AS count FROM ${tableName}`).get() as { count?: number } | undefined;\n741:   return typeof row?.count === 'number' ? row.count : 0;\n742: }\n743: \n744: function countActiveVectorRows(database: Database.Database): number {\n745:   try {\n746:     const row = database.prepare(`\n747:       SELECT 1 AS found\n748:       FROM active_vec.sqlite_master\n749:       WHERE type IN ('table', 'view') AND name = 'vec_memories'\n750:       LIMIT 1\n751:     `).get() as { found?: number } | undefined;\n752:     if (row?.found !== 1) {\n753:       return 0;\n754:     }\n755:     const countRow = database.prepare('SELECT COUNT(*) AS count FROM active_vec.vec_memories').get() as { count?: number } | undefined;\n756:     return typeof countRow?.count === 'number' ? countRow.count : 0;\n757:   } catch (_error: unknown) {\n758:     return 0;\n759:   }\n760: }\n761: \n762: function readCheckpointV2Manifest(snapshotPath: string | null): CheckpointV2Manifest | null {\n763:   if (!snapshotPath) {\n764:     return null;\n765:   }\n766:   try {\n767:     const raw = fs.readFileSync(path.join(snapshotPath, 'manifest.json'), 'utf-8');\n768:     const parsed = JSON.parse(raw) as Partial<CheckpointV2Manifest>;\n769:     return parsed.formatVersion === 2 ? parsed as CheckpointV2Manifest : null;\n770:   } catch (_error: unknown) {\n771:     return null;\n772:   }\n773: }\n774: \n775: function loadCheckpointV2Manifest(snapshotPath: string | null): CheckpointV2Manifest {\n776:   if (!snapshotPath) {\n777:     throw new CheckpointRestoreError(\n778:       'CHECKPOINT_RESTORE_MANIFEST_INVALID',\n779:       'Checkpoint v2 restore failed because snapshot_path is missing.',\n780:     );\n781:   }\n782: \n783:   const manifestPath = path.join(snapshotPath, 'manifest.json');\n784:   try {\n785:     const raw = fs.readFileSync(manifestPath, 'utf-8');\n786:     const parsed = JSON.parse(raw) as Partial<CheckpointV2Manifest>;\n787:     if (\n788:       parsed.formatVersion !== 2\n789:       || typeof parsed.includeEmbeddings !== 'boolean'\n790:       || !Array.isArray(parsed.mainTables)\n791:       || !Array.isArray(parsed.vecTables)\n792:       || typeof parsed.schemaVersion !== 'number'\n793:       || typeof parsed.memoryCount !== 'number'\n794:       || typeof parsed.vectorCount !== 'number'\n795:     ) {\n796:       throw new Error('manifest shape is invalid');\n797:     }\n798:     return parsed as CheckpointV2Manifest;\n799:   } catch (error: unknown) {\n800:     throw new CheckpointRestoreError(\n801:       'CHECKPOINT_RESTORE_MANIFEST_INVALID',\n802:       `Checkpoint v2 restore failed because manifest.json could not be read: ${toErrorMessage(error)}`,\n803:       error,\n804:     );\n805:   }\n806: }\n807: \n808: function resolveMainDatabasePath(database: Database.Database): string {\n809:   const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n810:   const mainFile = mainRow?.file;\n811:   if (!mainFile || mainFile === ':memory:') {\n812:     throw new CheckpointRestoreError(\n813:       'CHECKPOINT_RESTORE_PATH_UNRESOLVED',\n814:       'Checkpoint v2 restore failed because the live main database path could not be resolved.',\n815:     );\n816:   }\n817:   return mainFile;\n818: }\n819: \n820: function removeSqliteSidecars(databasePath: string): void {\n821:   for (const sidecarPath of [`${databasePath}-wal`, `${databasePath}-shm`]) {\n822:     fs.rmSync(sidecarPath, { force: true });\n823:   }\n824: }\n825: \n826: function getRestoreJournalPath(liveMainPath: string): string {\n827:   return path.join(path.dirname(liveMainPath), 'checkpoints', RESTORE_JOURNAL_NAME);\n828: }\n829: \n830: function getNeedsRebuildSentinelPath(liveMainPath: string): string {\n831:   return path.join(path.dirname(liveMainPath), 'checkpoints', NEEDS_REBUILD_SENTINEL_NAME);\n832: }\n833: \n834: function fsyncFileIfPossible(filePath: string): void {\n835:   let fd: number | null = null;\n836:   try {\n837:     fd = fs.openSync(filePath, 'r');\n838:     fs.fsyncSync(fd);\n839:   } catch (_error: unknown) {\n840:     // Best-effort durability; the next boot still treats any visible journal as authoritative.\n841:   } finally {\n842:     if (fd !== null) {\n843:       try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n844:     }\n845:   }\n846: }\n847: \n848: function fsyncDirectoryIfPossible(dirPath: string): void {\n849:   let fd: number | null = null;\n850:   try {\n851:     fd = fs.openSync(dirPath, 'r');\n852:     fs.fsyncSync(fd);\n853:   } catch (_error: unknown) {\n854:     // Directory fsync is unavailable on some platforms/filesystems.\n855:   } finally {\n856:     if (fd !== null) {\n857:       try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n858:     }\n859:   }\n860: }\n861: \n862: function writeRestoreJournal(journalPath: string, journal: RestoreJournalFile): void {\n863:   const journalDir = path.dirname(journalPath);\n864:   const tempJournalPath = `${journalPath}.tmp`;\n865:   fs.mkdirSync(journalDir, { recursive: true, mode: 0o700 });\n866:   fs.writeFileSync(tempJournalPath, `${JSON.stringify(journal, null, 2)}\\n`, { mode: 0o600 });\n867:   fsyncFileIfPossible(tempJournalPath);\n868:   fs.renameSync(tempJournalPath, journalPath);\n869:   fsyncDirectoryIfPossible(journalDir);\n870: }\n871: \n872: function clearRestoreJournal(journalPath: string): void {\n873:   fs.rmSync(journalPath, { force: true });\n874:   fsyncDirectoryIfPossible(path.dirname(journalPath));\n875: }\n876: \n877: function writeNeedsRebuildSentinelAtPath(\n878:   sentinelPath: string,\n879:   options: NeedsRebuildSentinelWriteOptions,\n880: ): void {\n881:   const sentinelDir = path.dirname(sentinelPath);\n882:   const tempSentinelPath = `${sentinelPath}.tmp`;\n883:   const sentinel: NeedsRebuildSentinelFile = {\n884:     formatVersion: 1,\n885:     createdAt: new Date().toISOString(),\n886:     source: options.source,\n887:     reason: options.reason,\n888:     ...(options.summary ? { rebuildSummary: options.summary } : {}),\n889:   };\n890: \n891:   fs.mkdirSync(sentinelDir, { recursive: true, mode: 0o700 });\n892:   fs.writeFileSync(tempSentinelPath, `${JSON.stringify(sentinel, null, 2)}\\n`, { mode: 0o600 });\n893:   fsyncFileIfPossible(tempSentinelPath);\n894:   fs.renameSync(tempSentinelPath, sentinelPath);\n895:   fsyncDirectoryIfPossible(sentinelDir);\n896: }\n897: \n898: function clearNeedsRebuildSentinelAtPath(sentinelPath: string): boolean {\n899:   const existed = fs.existsSync(sentinelPath);\n900:   fs.rmSync(sentinelPath, { force: true });\n901:   if (existed) {\n902:     fsyncDirectoryIfPossible(path.dirname(sentinelPath));\n903:   }\n904:   return existed;\n905: }\n906: \n907: function getNeedsRebuildSentinelPathForDatabase(database: Database.Database): string | null {\n908:   try {\n909:     return getNeedsRebuildSentinelPath(resolveMainDatabasePath(database));\n910:   } catch (_error: unknown) {\n911:     return null;\n912:   }\n913: }\n914: \n915: function hasNeedsRebuildSentinel(database: Database.Database): boolean {\n916:   const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n917:   return sentinelPath !== null && fs.existsSync(sentinelPath);\n918: }\n919: \n920: function writeNeedsRebuildSentinelForDatabase(\n921:   database: Database.Database,\n922:   options: NeedsRebuildSentinelWriteOptions,\n923: ): string | null {\n924:   const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n925:   if (sentinelPath === null) {\n926:     return null;\n927:   }\n928:   writeNeedsRebuildSentinelAtPath(sentinelPath, options);\n929:   return sentinelPath;\n930: }\n931: \n932: function writeNeedsRebuildSentinelForMainPath(\n933:   liveMainPath: string,\n934:   options: NeedsRebuildSentinelWriteOptions,\n935: ): string {\n936:   const sentinelPath = getNeedsRebuildSentinelPath(liveMainPath);\n937:   writeNeedsRebuildSentinelAtPath(sentinelPath, options);\n938:   return sentinelPath;\n939: }\n940: \n941: function clearNeedsRebuildSentinelForDatabase(database: Database.Database): boolean {\n942:   const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n943:   if (sentinelPath === null) {\n944:     return false;\n945:   }\n946:   return clearNeedsRebuildSentinelAtPath(sentinelPath);\n947: }\n948: \n949: function removeRestoreBackupIfPossible(backupPath: string): void {\n950:   try {\n951:     fs.rmSync(backupPath, { force: true });\n952:   } catch (error: unknown) {\n953:     console.warn(`[checkpoints] restore backup cleanup skipped for ${backupPath}: ${toErrorMessage(error)}`);\n954:   }\n955: }\n956: \n957: function readCheckpointCatalogRows(database: Database.Database): Array<Record<string, unknown>> {\n958:   if (!tableExists(database, 'checkpoints')) {\n959:     return [];\n960:   }\n961:   return database.prepare('SELECT * FROM checkpoints ORDER BY id ASC').all() as Array<Record<string, unknown>>;\n962: }\n963: \n964: function mergeCheckpointCatalogRows(database: Database.Database, rows: Array<Record<string, unknown>>): void {\n965:   if (rows.length === 0 || !tableExists(database, 'checkpoints')) {\n966:     return;\n967:   }\n968: \n969:   const targetColumns = new Set(getTableColumns(database, 'checkpoints'));\n970:   for (const row of rows) {\n971:     const name = row.name;\n972:     if (typeof name !== 'string' || name.length === 0) {\n973:       continue;\n974:     }\n975:     const existingByName = database.prepare('SELECT id FROM checkpoints WHERE name = ?').get(name) as { id?: number } | undefined;\n976:     if (existingByName?.id) {\n977:       continue;\n978:     }\n979: \n980:     let columns = Object.keys(row).filter((column) => targetColumns.has(column));\n981:     const id = row.id;\n982:     if (typeof id === 'number') {\n983:       const existingById = database.prepare('SELECT name FROM checkpoints WHERE id = ?').get(id) as { name?: string } | undefined;\n984:       if (existingById?.name && existingById.name !== name) {\n985:         columns = columns.filter((column) => column !== 'id');\n986:       }\n987:     }\n988:     if (columns.length === 0) {\n989:       continue;\n990:     }\n991: \n992:     const placeholders = columns.map(() => '?').join(', ');\n993:     database.prepare(`\n994:       INSERT OR IGNORE INTO checkpoints (${columns.join(', ')})\n995:       VALUES (${placeholders})\n996:     `).run(...columns.map((column) => row[column]));\n997:   }\n998: }\n999: \n1000: function pruneCheckpointCatalogRowsMissingSnapshots(database: Database.Database): void {\n1001:   // The restored snapshot-main DB carries the full checkpoints table as of the\n1002:   // snapshot, including v2 rows whose snapshot dir was deleted after the snapshot\n1003:   // was taken. Those rows would resurface in listCheckpoints with no restorable\n1004:   // dir, so drop any v2 row whose snapshot_path no longer exists on disk.\n1005:   // Best-effort: never throw out of the restore path.\n1006:   try {\n1007:     if (!tableExists(database, 'checkpoints')) {\n1008:       return;\n1009:     }\n1010:     const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n1011:     if (!checkpointColumns.has('snapshot_path') || !checkpointColumns.has('snapshot_format')) {\n1012:       return;\n1013:     }\n1014:     const rows = database.prepare(\n1015:       \"SELECT id, snapshot_path FROM checkpoints WHERE snapshot_format = 'v2' AND snapshot_path IS NOT NULL AND snapshot_path <> ''\",\n1016:     ).all() as Array<{ id: number; snapshot_path: string }>;\n1017:     for (const row of rows) {\n1018:       if (!fs.existsSync(row.snapshot_path)) {\n1019:         database.prepare('DELETE FROM checkpoints WHERE id = ?').run(row.id);\n1020:         console.warn(`[checkpoints] Dropped restored catalog row with missing snapshot dir: ${row.snapshot_path}`);\n1021:       }\n1022:     }\n1023:   } catch (error: unknown) {\n1024:     console.warn(`[checkpoints] Post-restore catalog reconciliation skipped (non-fatal): ${toErrorMessage(error)}`);\n1025:   }\n1026: }\n1027: \n1028: function statPathBytes(targetPath: string): number {\n1029:   try {\n1030:     const stats = fs.statSync(targetPath);\n1031:     if (stats.isFile()) {\n1032:       return stats.size;\n1033:     }\n1034:     if (!stats.isDirectory()) {\n1035:       return 0;\n1036:     }\n1037:     return fs.readdirSync(targetPath).reduce((total, entry) => total + statPathBytes(path.join(targetPath, entry)), 0);\n1038:   } catch (_error: unknown) {\n1039:     return 0;\n1040:   }\n1041: }\n1042: \n1043: function getCheckpointV2SnapshotSize(snapshotPath: string | null): number {\n1044:   const manifest = readCheckpointV2Manifest(snapshotPath);\n1045:   if (manifest) {\n1046:     return manifest.mainBytes + manifest.vecBytes;\n1047:   }\n1048:   return snapshotPath ? statPathBytes(snapshotPath) : 0;\n1049: }\n1050: \n1051: function removeCheckpointSnapshotDirs(snapshotPaths: string[]): void {\n1052:   for (const snapshotPath of snapshotPaths) {\n1053:     try {\n1054:       fs.rmSync(snapshotPath, { recursive: true, force: true });\n1055:     } catch (_error: unknown) {\n1056:       // Best-effort cleanup; the checkpoint row is already gone.\n1057:     }\n1058:   }\n1059: }\n1060: \n1061: function collectPrunedCheckpointSnapshotPaths(database: Database.Database, pruneCount: number): string[] {\n1062:   if (pruneCount <= 0) {\n1063:     return [];\n1064:   }\n1065:   const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n1066:   const snapshotPathSelect = checkpointColumns.has('snapshot_path') ? 'snapshot_path' : 'NULL AS snapshot_path';\n1067:   const snapshotFormatSelect = checkpointColumns.has('snapshot_format') ? 'snapshot_format' : \"'v1' AS snapshot_format\";\n1068:   const rows = database.prepare(`\n1069:     SELECT id, ${snapshotPathSelect}, ${snapshotFormatSelect}\n1070:     FROM checkpoints\n1071:     ORDER BY created_at ASC, id ASC\n1072:     LIMIT ?\n1073:   `).all(pruneCount) as Array<{ id: number; snapshot_path?: string | null; snapshot_format?: string | null }>;\n1074: \n1075:   if (rows.length === 0) {\n1076:     return [];\n1077:   }\n1078:   const ids = rows.map((row) => row.id);\n1079:   const placeholders = ids.map(() => '?').join(', ');\n1080:   database.prepare(`DELETE FROM checkpoints WHERE id IN (${placeholders})`).run(...ids);\n1081:   return rows\n1082:     .filter((row) => row.snapshot_format === 'v2' && typeof row.snapshot_path === 'string' && row.snapshot_path.length > 0)\n1083:     .map((row) => row.snapshot_path as string);\n1084: }\n1085: \n1086: function enforceMaxCheckpointsInTransaction(database: Database.Database): string[] {\n1087:   const checkpointCount = (database.prepare(\n1088:     'SELECT COUNT(*) as count FROM checkpoints'\n1089:   ) as Database.Statement).get() as { count: number };\n1090: \n1091:   if (checkpointCount.count <= MAX_CHECKPOINTS) {\n1092:     return [];\n1093:   }\n1094: \n1095:   return collectPrunedCheckpointSnapshotPaths(database, checkpointCount.count - MAX_CHECKPOINTS);\n1096: }\n1097: \n1098: function supportsCheckpointV2(database: Database.Database): boolean {\n1099:   const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n1100:   return checkpointColumns.has('snapshot_format') && checkpointColumns.has('snapshot_path');\n1101: }\n1102: \n1103: function hasMainVectorPayloadTables(database: Database.Database): boolean {\n1104:   try {\n1105:     // Gate v2 selection on vec_memories ONLY — the actual vector payload that the\n1106:     // shard-attach slimming removes from main. vec_metadata is a tiny key/value\n1107:     // config table that the same slimming intentionally RETAINS in main as a\n1108:     // dimension fallback, so its presence does NOT mean vector payload lives in\n1109:     // main. Including it here made full-DB create always observe \"payload in main\"\n1110:     // on a sharded runtime and silently fall back to the v1 whole-snapshot path\n1111:     // that overflows V8's single-string ceiling — the exact failure v2 prevents.\n1112:     const row = database.prepare(`\n1113:       SELECT 1 AS found\n1114:       FROM sqlite_master\n1115:       WHERE type IN ('table', 'view')\n1116:         AND name = 'vec_memories'\n1117:       LIMIT 1\n1118:     `).get() as { found?: number } | undefined;\n1119:     return row?.found === 1;\n1120:   } catch (_error: unknown) {\n1121:     return false;\n1122:   }\n1123: }\n1124: \n1125: function tableExists(database: Database.Database, tableName: string): boolean {\n1126:   try {\n1127:     if (tableName === 'vec_memories') {\n1128:       const mainOrTempRow = database.prepare(`\n1129:         SELECT 1 AS found\n1130:         FROM temp.sqlite_master\n1131:         WHERE type IN ('table','view') AND name = 'vec_memories'\n1132:         UNION ALL\n1133:         SELECT 1 AS found\n1134:         FROM sqlite_master\n1135:         WHERE type IN ('table','view') AND name = 'vec_memories'\n1136:         LIMIT 1\n1137:       `).get() as { found?: number } | undefined;\n1138:       if (mainOrTempRow?.found === 1) {\n1139:         return true;\n1140:       }\n1141: \n1142:       const hasActiveVectorShard = (database.prepare('PRAGMA database_list').all() as Array<{ name?: string }>)\n1143:         .some((entry) => entry.name === 'active_vec');\n1144:       if (!hasActiveVectorShard) {\n1145:         return false;\n1146:       }\n1147: \n1148:       const vectorRow = database.prepare(`\n1149:         SELECT 1 AS found\n1150:         FROM active_vec.sqlite_master\n1151:         WHERE type IN ('table','view') AND name = 'vec_memories'\n1152:         LIMIT 1\n1153:       `).get() as { found?: number } | undefined;\n1154:       return vectorRow?.found === 1;\n1155:     }\n1156: \n1157:     const row = database.prepare(\n1158:       \"SELECT name FROM sqlite_master WHERE type IN ('table','view') AND name = ?\"\n1159:     ).get(tableName) as { name?: string } | undefined;\n1160:     return !!row?.name;\n1161:   } catch (_error: unknown) {\n1162:     return false;\n1163:   }\n1164: }\n1165: \n1166: // Static allowlist for dynamic table name interpolation\n1167: const ALLOWED_TABLE_NAMES = new Set([\n1168:   // Core tables\n1169:   'memory_index', 'memory_fts', 'vec_memories', 'vec_metadata', 'causal_edges',\n1170:   'memory_conflicts', 'memory_corrections', 'memory_lineage', 'memory_history',\n1171:   'memory_summaries', 'mutation_ledger',\n1172:   // Working memory & session\n1173:   'working_memory', 'session_state', 'session_sent_memories', 'session_learning',\n1174:   // Graph & signals\n1175:   'weight_history', 'adaptive_signal_events', 'negative_feedback_events',\n1176:   'active_memory_projection', 'auto_entities', 'community_assignments', 'degree_snapshots',\n1177:   // Feedback & learning\n1178:   'learned_feedback_audit', 'learned_trigger_scores', 'learned_trigger_feedback',\n1179:   // Governance\n1180:   'governance_audit',\n1181:   // Checkpoints & system\n1182:   'checkpoints', 'checkpoint_items', 'deletion_log', 'consumption_log',\n1183:   'eval_shadow_comparisons',\n1184: ]);\n1185: \n1186: function validateTableName(tableName: string): void {\n1187:   if (!ALLOWED_TABLE_NAMES.has(tableName)) {\n1188:     throw new Error(`[checkpoints] Table name \"${tableName}\" not in allowlist`);\n1189:   }\n1190: }\n1191: \n1192: function getTableColumns(database: Database.Database, tableName: string): string[] {\n1193:   validateTableName(tableName);\n1194:   try {\n1195:     return (database.prepare(`PRAGMA table_info(\"${tableName}\")`).all() as Array<{ name: string }>)\n1196:       .map((column) => column.name)\n1197:       .filter((name) => typeof name === 'string' && name.length > 0);\n1198:   } catch (_error: unknown) {\n1199:     return [];\n1200:   }\n1201: }\n1202: \n1203: function tableHasColumn(\n1204:   database: Database.Database,\n1205:   tableName: string,\n1206:   columnName: string,\n1207: ): boolean {\n1208:   return getTableColumns(database, tableName).includes(columnName);\n1209: }\n1210: \n1211: function toBuffer(value: unknown): Buffer | null {\n1212:   if (Buffer.isBuffer(value)) return value;\n1213:   if (value && typeof value === 'object') {\n1214:     const maybeSerialized = value as { type?: unknown; data?: unknown };\n1215:     if (\n1216:       maybeSerialized.type === 'Buffer' &&\n1217:       Array.isArray(maybeSerialized.data) &&\n1218:       maybeSerialized.data.every((entry) => typeof entry === 'number')\n1219:     ) {\n1220:       return Buffer.from(maybeSerialized.data);\n1221:     }\n1222:   }\n1223:   return null;\n1224: }\n1225: \n1226: function deserializeSnapshotValue(value: unknown): unknown {\n1227:   if (value === undefined) {\n1228:     return null;\n1229:   }\n1230:   return toBuffer(value) ?? value;\n1231: }\n1232: \n1233: function getMemoryIds(memories: Array<Record<string, unknown>>): number[] {\n1234:   const ids = new Set<number>();\n1235:   for (const memory of memories) {\n1236:     if (!memory || typeof memory !== 'object') {\n1237:       continue;\n1238:     }\n1239:     const rawId = memory.id;\n1240:     if (typeof rawId === 'number' && Number.isSafeInteger(rawId)) {\n1241:       ids.add(rawId);\n1242:       continue;\n1243:     }\n1244:     if (typeof rawId === 'string' && /^\\d+$/.test(rawId)) {\n1245:       ids.add(Number.parseInt(rawId, 10));\n1246:     }\n1247:   }\n1248:   return Array.from(ids);\n1249: }\n1250: \n1251: function parseCheckpointMetadata(value: unknown): Record<string, unknown> {\n1252:   if (!value) {\n1253:     return {};\n1254:   }\n1255:   if (typeof value === 'string') {\n1256:     try {\n1257:       const parsed = JSON.parse(value) as unknown;\n1258:       return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n1259:         ? parsed as Record<string, unknown>\n1260:         : {};\n1261:     } catch (_error: unknown) {\n1262:       return {};\n1263:     }\n1264:   }\n1265:   return typeof value === 'object' && !Array.isArray(value)\n1266:     ? value as Record<string, unknown>\n1267:     : {};\n1268: }\n1269: \n1270: function checkpointMetadataMatchesScope(rawMetadata: unknown, scope: ScopeContext): boolean {\n1271:   const normalizedScope = normalizeScopeContext(scope);\n1272:   if (!hasScopeConstraints(normalizedScope)) {\n1273:     return true;\n1274:   }\n1275: \n1276:   const metadata = parseCheckpointMetadata(rawMetadata);\n1277:   return (\n1278:     (normalizedScope.tenantId === undefined || metadata.tenantId === normalizedScope.tenantId)\n1279:     && (normalizedScope.userId === undefined || metadata.userId === normalizedScope.userId)\n1280:     && (normalizedScope.agentId === undefined || metadata.agentId === normalizedScope.agentId)\n1281:   );\n1282: }\n1283: \n1284: function hasDirectScopeColumns(columns: ReadonlySet<string>): boolean {\n1285:   return (\n1286:     columns.has('tenant_id')\n1287:     || columns.has('user_id')\n1288:     || columns.has('agent_id')\n1289:     || columns.has('session_id')\n1290:   );\n1291: }\n1292: \n1293: function getScopeFilterContext(\n1294:   _database: Database.Database,\n1295:   scope: ScopeContext = {},\n1296: ): {\n1297:   normalizedScope: ScopeContext;\n1298:   predicate: ((row: Record<string, unknown>) => boolean) | null;\n1299: } {\n1300:   const normalizedScope = normalizeScopeContext(scope);\n1301:   if (!hasScopeConstraints(normalizedScope)) {\n1302:     return {\n1303:       normalizedScope,\n1304:       predicate: null,\n1305:     };\n1306:   }\n1307: \n1308:   return {\n1309:     normalizedScope,\n1310:     predicate: createScopeFilterPredicate<Record<string, unknown>>(normalizedScope),\n1311:   };\n1312: }\n1313: \n1314: function getScopedMemories(\n1315:   database: Database.Database,\n1316:   specFolder: string | null,\n1317:   scope: ScopeContext = {},\n1318: ): {\n1319:   memories: Array<Record<string, unknown>>;\n1320:   memoryIds: number[];\n1321:   normalizedScope: ScopeContext;\n1322: } {\n1323:   const { normalizedScope, predicate } = getScopeFilterContext(database, scope);\n1324:   const baseMemories = specFolder\n1325:     ? database.prepare('SELECT * FROM memory_index WHERE spec_folder = ?').all(specFolder) as Array<Record<string, unknown>>\n1326:     : database.prepare('SELECT * FROM memory_index').all() as Array<Record<string, unknown>>;\n1327:   const memories = predicate ? baseMemories.filter((row) => predicate(row)) : baseMemories;\n1328: \n1329:   return {\n1330:     memories,\n1331:     memoryIds: getMemoryIds(memories),\n1332:     normalizedScope,\n1333:   };\n1334: }\n1335: \n1336: function getCurrentScopedMemoryIds(\n1337:   database: Database.Database,\n1338:   specFolder: string | null,\n1339:   scope: ScopeContext = {},\n1340: ): number[] {\n1341:   return getScopedMemories(database, specFolder, scope).memoryIds;\n1342: }\n1343: \n1344: function buildRestoreScopeDeleteWhere(\n1345:   columns: ReadonlySet<string>,\n1346:   checkpointSpecFolder: string | null,\n1347:   scope: ScopeContext = {},\n1348: ): {\n1349:   clauses: string[];\n1350:   params: string[];\n1351: } {\n1352:   const normalizedScope = normalizeScopeContext(scope);\n1353:   const clauses: string[] = [];\n1354:   const params: string[] = [];\n1355: \n1356:   if (checkpointSpecFolder && columns.has('spec_folder')) {\n1357:     clauses.push('spec_folder = ?');\n1358:     params.push(checkpointSpecFolder);\n1359:   }\n1360:   if (normalizedScope.tenantId && columns.has('tenant_id')) {\n1361:     clauses.push('tenant_id = ?');\n1362:     params.push(normalizedScope.tenantId);\n1363:   }\n1364:   if (normalizedScope.userId && columns.has('user_id')) {\n1365:     clauses.push('user_id = ?');\n1366:     params.push(normalizedScope.userId);\n1367:   }\n1368:   if (normalizedScope.agentId && columns.has('agent_id')) {\n1369:     clauses.push('agent_id = ?');\n1370:     params.push(normalizedScope.agentId);\n1371:   }\n1372: \n1373:   return { clauses, params };\n1374: }\n1375: \n1376: function getEdgeIds(edges: Array<Record<string, unknown>>): number[] {\n1377:   const ids = new Set<number>();\n1378:   for (const edge of edges) {\n1379:     const rawId = edge?.id;\n1380:     if (typeof rawId === 'number' && Number.isSafeInteger(rawId)) {\n1381:       ids.add(rawId);\n1382:       continue;\n1383:     }\n1384:     if (typeof rawId === 'string' && /^\\d+$/.test(rawId)) {\n1385:       ids.add(Number.parseInt(rawId, 10));\n1386:     }\n1387:   }\n1388:   return Array.from(ids);\n1389: }\n1390: \n1391: function deleteRowsByIds(\n1392:   database: Database.Database,\n1393:   tableName: string,\n1394:   columnName: string,\n1395:   ids: number[],\n1396: ): void {\n1397:   if (ids.length === 0) {\n1398:     return;\n1399:   }\n1400: \n1401:   const sql = `DELETE FROM ${tableName} WHERE ${columnName} IN (__PLACEHOLDERS__)`;\n1402:   for (let i = 0; i < ids.length; i += 500) {\n1403:     const batch = ids.slice(i, i + 500);\n1404:     const placeholders = batch.map(() => '?').join(', ');\n1405:     database.prepare(sql.replace('__PLACEHOLDERS__', placeholders)).run(...batch);\n1406:   }\n1407: }\n1408: \n1409: function snapshotCausalEdgesForMemoryIds(\n1410:   database: Database.Database,\n1411:   memoryIds: number[],\n1412: ): Array<Record<string, unknown>> {\n1413:   if (memoryIds.length === 0 || !tableExists(database, 'causal_edges')) {\n1414:     return [];\n1415:   }\n1416: \n1417:   try {\n1418:     const edgeIds = memoryIds.map((id) => String(id));\n1419:     return dedupeRowsById([\n1420:       ...batchedInQuery<Record<string, unknown>>(\n1421:         database,\n1422:         `\n1423:           SELECT * FROM causal_edges\n1424:           WHERE source_id IN (__PLACEHOLDERS__)\n1425:         `,\n1426:         edgeIds,\n1427:       ),\n1428:       ...batchedInQuery<Record<string, unknown>>(\n1429:         database,\n1430:         `\n1431:           SELECT * FROM causal_edges\n1432:           WHERE target_id IN (__PLACEHOLDERS__)\n1433:         `,\n1434:         edgeIds,\n1435:       ),\n1436:     ]);\n1437:   } catch (_error: unknown) {\n1438:     return [];\n1439:   }\n1440: }\n1441: \n1442: function getTableSnapshotColumns(database: Database.Database, tableName: string): string[] {\n1443:   if (tableName === 'vec_memories') {\n1444:     return ['rowid', 'embedding'];\n1445:   }\n1446:   return getTableColumns(database, tableName);\n1447: }\n1448: \n1449: function selectTableRows(\n1450:   database: Database.Database,\n1451:   tableName: string,\n1452:   options: {\n1453:     specFolder: string | null;\n1454:     memoryIds: number[];\n1455:     scope?: ScopeContext;\n1456:   },\n1457: ): Array<Record<string, unknown>> {\n1458:   const { specFolder, memoryIds, scope = {} } = options;\n1459:   const normalizedScope = normalizeScopeContext(scope);\n1460:   const hasScope = hasScopeConstraints(normalizedScope);\n1461:   const scopePredicate = hasScope\n1462:     ? createScopeFilterPredicate<Record<string, unknown>>(normalizedScope)\n1463:     : null;\n1464: \n1465:   if (tableName === 'memory_index') {\n1466:     const rows = specFolder\n1467:       ? database.prepare(\n1468:         'SELECT * FROM memory_index WHERE spec_folder = ?'\n1469:       ).all(specFolder) as Array<Record<string, unknown>>\n1470:       : database.prepare('SELECT * FROM memory_index').all() as Array<Record<string, unknown>>;\n1471:     return scopePredicate ? rows.filter((row) => scopePredicate(row)) : rows;\n1472:   }\n1473: \n1474:   if (tableName === 'vec_memories') {\n1475:     if (memoryIds.length > 0) {\n1476:       return batchedInQuery<Record<string, unknown>>(\n1477:         database,\n1478:         'SELECT rowid AS rowid, embedding FROM vec_memories WHERE rowid IN (__PLACEHOLDERS__)',\n1479:         memoryIds,\n1480:       );\n1481:     }\n1482:     if (specFolder) {\n1483:       return database.prepare(`\n1484:       SELECT v.rowid AS rowid, v.embedding AS embedding\n1485:       FROM vec_memories v\n1486:       JOIN memory_index m ON m.id = v.rowid\n1487:       WHERE m.spec_folder = ?\n1488:     `).all(specFolder) as Array<Record<string, unknown>>;\n1489:     }\n1490:     return hasScope ? [] : database.prepare(\n1491:       'SELECT rowid AS rowid, embedding FROM vec_memories'\n1492:     ).all() as Array<Record<string, unknown>>;\n1493:   }\n1494: \n1495:   if (tableName === 'causal_edges') {\n1496:     if (memoryIds.length > 0) {\n1497:       return snapshotCausalEdgesForMemoryIds(database, memoryIds);\n1498:     }\n1499:     return hasScope ? [] : database.prepare('SELECT * FROM causal_edges').all() as Array<Record<string, unknown>>;\n1500:   }\n1501: \n1502:   const columns = new Set(getTableColumns(database, tableName));\n1503: \n1504:   if (specFolder && columns.has('spec_folder')) {\n1505:     return database.prepare(\n1506:       `SELECT * FROM ${tableName} WHERE spec_folder = ?`\n1507:     ).all(specFolder) as Array<Record<string, unknown>>;\n1508:   }\n1509: \n1510:   if (memoryIds.length > 0 && columns.has('memory_id')) {\n1511:     return batchedInQuery<Record<string, unknown>>(\n1512:       database,\n1513:       `SELECT * FROM ${tableName} WHERE memory_id IN (__PLACEHOLDERS__)`,\n1514:       memoryIds,\n1515:     );\n1516:   }\n1517: \n1518:   if (memoryIds.length > 0 && tableName === 'memory_corrections') {\n1519:     return dedupeRowsById([\n1520:       ...batchedInQuery<Record<string, unknown>>(\n1521:         database,\n1522:         `\n1523:           SELECT * FROM memory_corrections\n1524:           WHERE original_memory_id IN (__PLACEHOLDERS__)\n1525:         `,\n1526:         memoryIds,\n1527:       ),\n1528:       ...batchedInQuery<Record<string, unknown>>(\n1529:         database,\n1530:         `\n1531:           SELECT * FROM memory_corrections\n1532:           WHERE correction_memory_id IN (__PLACEHOLDERS__)\n1533:         `,\n1534:         memoryIds,\n1535:       ),\n1536:     ]);\n1537:   }\n1538: \n1539:   const allRows = database.prepare(`SELECT * FROM ${tableName}`).all() as Array<Record<string, unknown>>;\n1540:   if (!scopePredicate) {\n1541:     return allRows;\n1542:   }\n1543: \n1544:   if (hasDirectScopeColumns(columns)) {\n1545:     return allRows.filter((row) => scopePredicate(row));\n1546:   }\n1547: \n1548:   return [];\n1549: }\n1550: \n1551: function createTableSnapshot(\n1552:   database: Database.Database,\n1553:   tableName: string,\n1554:   options: {\n1555:     specFolder: string | null;\n1556:     memoryIds: number[];\n1557:     scope?: ScopeContext;\n1558:   },\n1559: ): TableSnapshot | null {\n1560:   if (!tableExists(database, tableName)) {\n1561:     return null;\n1562:   }\n1563: \n1564:   const columns = getTableSnapshotColumns(database, tableName);\n1565:   if (columns.length === 0) {\n1566:     return null;\n1567:   }\n1568: \n1569:   const rows = selectTableRows(database, tableName, options);\n1570:   return { columns, rows };\n1571: }\n1572: \n1573: function buildCheckpointManifest(): CheckpointManifest {\n1574:   return {\n1575:     snapshot: [...CHECKPOINT_MANIFEST.snapshot],\n1576:     rebuild: [...CHECKPOINT_MANIFEST.rebuild],\n1577:     skip: [...CHECKPOINT_MANIFEST.skip],\n1578:   };\n1579: }\n1580: \n1581: function buildLegacyTableSnapshots(snapshot: CheckpointSnapshot): Record<string, TableSnapshot> {\n1582:   const tableSnapshots: Record<string, TableSnapshot> = {};\n1583: \n1584:   if (Array.isArray(snapshot.memories)) {\n1585:     tableSnapshots.memory_index = {\n1586:       columns: Object.keys(snapshot.memories[0] ?? {}),\n1587:       rows: snapshot.memories,\n1588:     };\n1589:   }\n1590: \n1591:   if (Array.isArray(snapshot.workingMemory)) {\n1592:     tableSnapshots.working_memory = {\n1593:       columns: Object.keys(snapshot.workingMemory[0] ?? {}),\n1594:       rows: snapshot.workingMemory,\n1595:     };\n1596:   }\n1597: \n1598:   if (Array.isArray(snapshot.vectors)) {\n1599:     tableSnapshots.vec_memories = {\n1600:       columns: ['rowid', 'embedding'],\n1601:       rows: snapshot.vectors.map((row) => ({\n1602:         rowid: row.rowid,\n1603:         embedding: row.embedding,\n1604:       })),\n\n(Output capped at 50 KB. Showing lines 1-1604. Use offset=1605 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Gzip-compressed database checkpoints with embedding preservation\n// Node stdlib\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport * as zlib from 'zlib';\n\n// External packages\nimport type Database from 'better-sqlite3';\nimport { z } from 'zod';\n\n// Internal utils\nimport { toErrorMessage } from '../../utils/db-helpers.js';\nimport { rebuildAutoEntities } from '../extraction/entity-extractor.js';\nimport {\n  buildGovernanceLogicalKey,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Gzip-compressed database checkpoints with embedding preservation\n// Node stdlib\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport * as zlib from 'zlib';\n\n// External packages\nimport type Database from 'better-sqlite3';\nimport { z } from 'zod';\n\n// Internal utils\nimport { toErrorMessage } from '../../utils/db-helpers.js';\nimport { rebuildAutoEntities } from '../extraction/entity-extractor.js';\nimport {\n  buildGovernanceLogicalKey,\n  createScopeFilterPredicate,\n  GOVERNANCE_AUDIT_ACTIONS,\n  hasScopeConstraints,\n  normalizeScopeContext,\n  recordGovernanceAudit,\n  recordTierDowngradeAudit,\n  type ScopeContext,\n  type GovernanceAuditEntry,\n  type TierDowngradeAuditParams,\n} from '../governance/scope-governance.js';\nimport { detectCommunities, storeCommunityAssignments } from '../graph/community-detection.js';\nimport { generateCommunitySummaries } from '../graph/community-summaries.js';\nimport { storeCommunities } from '../graph/community-storage.js';\nimport { snapshotDegrees } from '../graph/graph-signals.js';\nimport { runLineageBackfill } from './lineage-state.js';\nimport { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../utils/index-scope.js';\nimport { reopenActiveDatabase } from '../search/vector-index-store.js';\nimport { SCHEMA_VERSION } from '../search/vector-index-schema.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { BetterSqliteContentionPolicy } from './ports/contention-policy.js';\n\nfunction batchedInQuery<T>(db: Database.Database, sql: string, ids: (number | string)[], batchSize = 500): T[] {\n  const results: T[] = [];\n  for (let i = 0; i < ids.length; i += batchSize) {\n    const batch = ids.slice(i, i + batchSize);\n    const placeholders = batch.map(() => '?').join(', ');\n    const batchSql = sql.replace('__PLACEHOLDERS__', placeholders);\n    results.push(...(db.prepare(batchSql).all(...batch) as T[]));\n  }\n  return results;\n}\n\nfunction dedupeRowsById<T extends Record<string, unknown>>(rows: T[]): T[] {\n  const results: T[] = [];\n  const seenIds = new Set<number | string>();\n\n  for (const row of rows) {\n    const id = row.id;\n    if (typeof id === 'number' || typeof id === 'string') {\n      if (seenIds.has(id)) {\n        continue;\n      }\n      seenIds.add(id);\n    }\n    results.push(row);\n  }\n\n  return results;\n}\n\nfunction getSnapshotColumnsFromRows(rows: Array<Record<string, unknown>>): string[] {\n  const columns = new Set<string>();\n\n  for (const row of rows) {\n    for (const key of Object.keys(row ?? {})) {\n      if (typeof key === 'string' && key.length > 0) {\n        columns.add(key);\n      }\n    }\n  }\n\n  return Array.from(columns);\n}\n\nfunction flushGovernanceAudits(\n  database: Database.Database,\n  entries: GovernanceAuditEntry[],\n): void {\n  for (const entry of entries) {\n    try {\n      recordGovernanceAudit(database, entry);\n    } catch (error: unknown) {\n      console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n    }\n  }\n}\n\nfunction flushTierDowngradeAudits(\n  database: Database.Database,\n  entries: TierDowngradeAuditParams[],\n): void {\n  for (const entry of entries) {\n    try {\n      recordTierDowngradeAudit(database, entry);\n    } catch (error: unknown) {\n      console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n    }\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst MAX_CHECKPOINTS = 10;\nconst CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\nconst CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\nconst CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\nconst RESTORE_JOURNAL_NAME = '.restore-journal.json';\nconst NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\nconst checkpointContention = new BetterSqliteContentionPolicy({ retryable: isCheckpointBusyError });\n\nconst CHECKPOINT_MANIFEST = Object.freeze({\n  snapshot: [\n    'memory_index',\n    'vec_memories',\n    'vec_metadata',\n    'working_memory',\n    'causal_edges',\n    'weight_history',\n    'memory_history',\n    'mutation_ledger',\n    'memory_conflicts',\n    'memory_corrections',\n    'adaptive_signal_events',\n    'negative_feedback_events',\n    'learned_feedback_audit',\n    'session_learning',\n    'governance_audit',\n    'session_state',\n    'session_sent_memories',\n    'memory_summaries',\n  ],\n  rebuild: [\n    'memory_lineage',\n    'active_memory_projection',\n    'memory_entities',\n    'entity_catalog',\n    'degree_snapshots',\n    'community_assignments',\n    'graph_communities',\n    'community_summaries',\n    'memory_fts',\n  ],\n  skip: [\n    'checkpoints',\n    'schema_version',\n    'embedding_cache',\n    'adaptive_shadow_runs',\n  ],\n});\n\nconst CHECKPOINT_RESTORE_ORDER = [\n  'memory_index',\n  'vec_memories',\n  'vec_metadata',\n  'working_memory',\n  'causal_edges',\n  'weight_history',\n  'memory_history',\n  'mutation_ledger',\n  'memory_conflicts',\n  'memory_corrections',\n  'adaptive_signal_events',\n  'negative_feedback_events',\n  'learned_feedback_audit',\n  'session_learning',\n  'governance_audit',\n  'session_state',\n  'session_sent_memories',\n  'memory_summaries',\n] as const;\n\nconst CHECKPOINT_CLEAR_ORDER = [...CHECKPOINT_RESTORE_ORDER].reverse();\n\nconst MUTATION_LEDGER_TRIGGER_SQL = `\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface CheckpointEntry {\n  id: number;\n  name: string;\n  created_at: string;\n  spec_folder: string | null;\n  git_branch: string | null;\n  memory_snapshot: Buffer | null;\n  file_snapshot: Buffer | null;\n  snapshot_format?: string | null;\n  snapshot_path?: string | null;\n  metadata: string | null;\n}\n\ninterface CheckpointInfo {\n  id: number;\n  name: string;\n  createdAt: string;\n  specFolder: string | null;\n  gitBranch: string | null;\n  snapshotSize: number;\n  metadata: Record<string, unknown>;\n  [key: string]: unknown;\n}\n\ninterface CreateCheckpointOptions {\n  name?: string;\n  specFolder?: string | null;\n  includeEmbeddings?: boolean;\n  metadata?: Record<string, unknown>;\n  scope?: ScopeContext;\n}\n\ntype CheckpointCreateErrorCode =\n  | 'CHECKPOINT_CREATE_SQLITE_BUSY'\n  | 'CHECKPOINT_CREATE_SQLITE_LOCKED'\n  | 'CHECKPOINT_CREATE_DUPLICATE_NAME'\n  | 'CHECKPOINT_CREATE_INVALID_NAME'\n  | 'CHECKPOINT_CREATE_PERMISSION_DENIED'\n  | 'CHECKPOINT_CREATE_FAILED';\n\ntype CheckpointRestoreErrorCode =\n  | 'CHECKPOINT_RESTORE_MANIFEST_INVALID'\n  | 'CHECKPOINT_RESTORE_DOWNGRADE_UNSAFE'\n  | 'CHECKPOINT_RESTORE_EMBEDDER_MISMATCH'\n  | 'CHECKPOINT_RESTORE_FILE_MISSING'\n  | 'CHECKPOINT_RESTORE_PATH_UNRESOLVED'\n  | 'CHECKPOINT_RESTORE_JOURNAL_FAILED'\n  | 'CHECKPOINT_RESTORE_SWAP_FAILED';\n\nclass CheckpointCreateError extends Error {\n  public readonly code: CheckpointCreateErrorCode;\n  public readonly originalCode: string | null;\n  public readonly details: Record<string, unknown>;\n\n  constructor(\n    code: CheckpointCreateErrorCode,\n    message: string,\n    details: Record<string, unknown> = {},\n    cause?: unknown,\n  ) {\n    super(message, { cause });\n    Object.setPrototypeOf(this, CheckpointCreateError.prototype);\n    this.name = 'CheckpointCreateError';\n    this.code = code;\n    this.originalCode = typeof details.originalCode === 'string' ? details.originalCode : null;\n    this.details = details;\n  }\n}\n\nclass CheckpointRestoreError extends Error {\n  public readonly code: CheckpointRestoreErrorCode;\n\n  constructor(code: CheckpointRestoreErrorCode, message: string, cause?: unknown) {\n    super(message, { cause });\n    Object.setPrototypeOf(this, CheckpointRestoreError.prototype);\n    this.name = 'CheckpointRestoreError';\n    this.code = code;\n  }\n}\n\ninterface RestoreCheckpointV2Options {\n  reopen?: (targetMainPath: string, swapFn: () => void) => Database.Database;\n}\n\ninterface RestoreResult {\n  restored: number;\n  skipped: number;\n  errors: string[];\n  workingMemoryRestored: number;\n  partialFailure?: boolean;\n  rolledBackTables?: string[];\n}\n\ninterface DerivedRebuildFailure {\n  name: string;\n  error: string;\n}\n\ninterface DerivedRebuildSkipped {\n  name: string;\n  reason: string;\n}\n\ninterface DerivedRebuildSummary {\n  completed: string[];\n  failed: DerivedRebuildFailure[];\n  skipped: DerivedRebuildSkipped[];\n}\n\ninterface RunDerivedArtifactRebuildOptions {\n  specFolder?: string | null;\n  actor?: string;\n  logContext?: string;\n}\n\ninterface NeedsRebuildSentinelFile {\n  formatVersion: 1;\n  createdAt: string;\n  source: string;\n  reason: string;\n  rebuildSummary?: DerivedRebuildSummary;\n}\n\ninterface NeedsRebuildSentinelWriteOptions {\n  source: string;\n  reason: string;\n  summary?: DerivedRebuildSummary;\n}\n\ninterface NeedsRebuildRepairOptions {\n  source: string;\n  specFolder?: string | null;\n  actor?: string;\n}\n\ninterface NeedsRebuildRepairResult {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  cleared: boolean;\n  summary: DerivedRebuildSummary | null;\n  error: string | null;\n}\n\ninterface SnapshotVectorRow {\n  rowid: number;\n  embedding: Buffer | null;\n}\n\ninterface TableSnapshot {\n  columns: string[];\n  rows: Array<Record<string, unknown>>;\n}\n\ninterface CheckpointManifest {\n  snapshot: string[];\n  rebuild: string[];\n  skip: string[];\n}\n\ninterface CheckpointSnapshot {\n  manifest?: CheckpointManifest;\n  tables?: Record<string, TableSnapshot>;\n  memories: Array<Record<string, unknown>>;\n  workingMemory: Array<Record<string, unknown>>;\n  vectors?: SnapshotVectorRow[];\n  causalEdges?: Array<Record<string, unknown>>;\n  timestamp: string;\n}\n\ninterface DatabaseListRow {\n  seq?: number;\n  name?: string;\n  file?: string;\n}\n\ninterface CheckpointV2Manifest {\n  formatVersion: 2;\n  createdAt: string;\n  specFolder: null;\n  gitBranch: string | null;\n  embedderSlug: string | null;\n  includeEmbeddings: boolean;\n  mainTables: string[];\n  vecTables: string[];\n  schemaVersion: number;\n  memoryCount: number;\n  vectorCount: number;\n  mainBytes: number;\n  vecBytes: number;\n}\n\ntype RestoreJournalPhase = 'swap-pending' | 'swap-done';\n\ninterface RestoreJournalFile {\n  formatVersion: 1;\n  phase: RestoreJournalPhase;\n  createdAt: string;\n  checkpointName: string;\n  liveMainPath: string;\n  backupMainPath: string;\n  snapshotMainPath: string;\n  liveShardPath: string | null;\n  backupShardPath: string | null;\n  snapshotVecPath: string | null;\n  shouldRestoreVec: boolean;\n  liveShardPreexisted: boolean;\n}\n\n// Validate the decompressed checkpoint snapshot before\n// restore. Previously the gzipped blob was JSON.parsed and cast directly\n// to CheckpointSnapshot — malformed memory_index rows propagated through\n// `getMemoryIds()` and the INSERT loops. This schema validates the\n// outer envelope and the array shapes; individual row shapes are still\n// permissive (sqlite columns evolve over time) but each row must be a\n// non-null object so downstream column extraction doesn't NPE.\nconst CheckpointTableSnapshotSchema = z.object({\n  columns: z.array(z.string()),\n  rows: z.array(z.record(z.string(), z.unknown())),\n});\n\nconst CheckpointVectorRowSchema = z.object({\n  rowid: z.number(),\n  embedding: z.unknown(), // Buffer or null — preserved as-is\n});\n\nconst CheckpointSnapshotSchema = z.object({\n  manifest: z.object({\n    snapshot: z.array(z.string()),\n    rebuild: z.array(z.string()),\n    skip: z.array(z.string()),\n  }).optional(),\n  tables: z.record(z.string(), CheckpointTableSnapshotSchema).optional(),\n  memories: z.array(z.record(z.string(), z.unknown())),\n  workingMemory: z.array(z.record(z.string(), z.unknown())),\n  vectors: z.array(CheckpointVectorRowSchema).optional(),\n  causalEdges: z.array(z.record(z.string(), z.unknown())).optional(),\n  timestamp: z.string(),\n}).passthrough();\n\ninterface RestoreBarrierStatus {\n  code: string;\n  message: string;\n}\n\ninterface RestoreBarrierHooks {\n  afterAcquire?: (() => void) | null;\n  beforeRelease?: (() => void) | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet restoreInProgress = false;\nlet restoreBarrierHooks: RestoreBarrierHooks = {};\n\nconst RESTORE_IN_PROGRESS_ERROR_CODE = 'E_RESTORE_IN_PROGRESS';\nconst RESTORE_IN_PROGRESS_ERROR_MESSAGE = 'Checkpoint restore maintenance is in progress. Retry after the restore lifecycle completes.';\n\n/* ───────────────────────────────────────────────────────────────\n   4. INITIALIZATION\n----------------------------------------------------------------*/\n\nfunction init(database: Database.Database): void {\n  db = database;\n}\n\nfunction getDatabase(): Database.Database {\n  if (!db) throw new Error('Database not initialized. The checkpoints module requires the MCP server to be running. Restart the MCP server and retry.');\n  return db;\n}\n\nfunction getErrorCode(error: unknown): string | null {\n  if (typeof error === 'object' && error !== null && 'code' in error) {\n    const code = (error as { code?: unknown }).code;\n    return typeof code === 'string' ? code : null;\n  }\n  return null;\n}\n\nfunction isCheckpointBusyError(error: unknown): boolean {\n  const code = getErrorCode(error);\n  const message = toErrorMessage(error);\n  return code === 'SQLITE_BUSY'\n    || code === 'SQLITE_LOCKED'\n    || /\\bSQLITE_BUSY\\b|\\bSQLITE_LOCKED\\b|database is locked/i.test(message);\n}\n\nfunction classifyCheckpointCreateError(\n  error: unknown,\n  context: Record<string, unknown> = {},\n): CheckpointCreateError {\n  if (error instanceof CheckpointCreateError) {\n    return error;\n  }\n\n  const originalCode = getErrorCode(error);\n  const message = toErrorMessage(error);\n  const details = {\n    ...context,\n    ...(originalCode ? { originalCode } : {}),\n    originalMessage: message,\n  };\n\n  if (originalCode === 'SQLITE_BUSY' || /\\bSQLITE_BUSY\\b|database is locked/i.test(message)) {\n    return new CheckpointCreateError(\n      'CHECKPOINT_CREATE_SQLITE_BUSY',\n      'Checkpoint creation failed because the SQLite database was busy. Retry after current writes finish.',\n      details,\n      error,\n    );\n  }\n\n  if (originalCode === 'SQLITE_LOCKED' || /\\bSQLITE_LOCKED\\b/i.test(message)) {\n    return new CheckpointCreateError(\n      'CHECKPOINT_CREATE_SQLITE_LOCKED',\n      'Checkpoint creation failed because the SQLite database was locked by another operation.',\n      details,\n      error,\n    );\n  }\n\n  if (/UNIQUE constraint failed: checkpoints\\.name|constraint failed/i.test(message)) {\n    return new CheckpointCreateError(\n      'CHECKPOINT_CREATE_DUPLICATE_NAME',\n      'Checkpoint creation failed because a checkpoint with this name already exists.',\n      details,\n      error,\n    );\n  }\n\n  if (\n    originalCode === 'EACCES'\n    || originalCode === 'EPERM'\n    || originalCode === 'SQLITE_READONLY'\n    || /permission denied|readonly|read-only/i.test(message)\n  ) {\n    return new CheckpointCreateError(\n      'CHECKPOINT_CREATE_PERMISSION_DENIED',\n      'Checkpoint creation failed because the database path is not writable.',\n      details,\n      error,\n    );\n  }\n\n  return new CheckpointCreateError(\n    'CHECKPOINT_CREATE_FAILED',\n    `Checkpoint creation failed: ${message}`,\n    details,\n    error,\n  );\n}\n\nfunction checkpointRetryDelayMs(): number {\n  return CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS\n    + Math.floor(Math.random() * (CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS - CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS + 1));\n}\n\nfunction isRestoreInProgress(): boolean {\n  return restoreInProgress;\n}\n\nfunction getRestoreBarrierStatus(): RestoreBarrierStatus | null {\n  if (!restoreInProgress) {\n    return null;\n  }\n\n  return {\n    code: RESTORE_IN_PROGRESS_ERROR_CODE,\n    message: RESTORE_IN_PROGRESS_ERROR_MESSAGE,\n  };\n}\n\nfunction setRestoreBarrierHooks(hooks: RestoreBarrierHooks | null): void {\n  restoreBarrierHooks = hooks ?? {};\n}\n\nfunction acquireRestoreBarrier(): void {\n  restoreInProgress = true;\n  restoreBarrierHooks.afterAcquire?.();\n}\n\nfunction releaseRestoreBarrier(): void {\n  try {\n    restoreBarrierHooks.beforeRelease?.();\n  } finally {\n    restoreInProgress = false;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. HELPERS\n----------------------------------------------------------------*/\n\nfunction getGitBranch(): string | null {\n  const candidates = [\n    process.env.GIT_BRANCH,\n    process.env.BRANCH_NAME,\n    process.env.CI_COMMIT_REF_NAME,\n    process.env.VERCEL_GIT_COMMIT_REF,\n  ];\n\n  for (const candidate of candidates) {\n    if (typeof candidate === 'string' && candidate.trim().length > 0) {\n      return candidate.trim();\n    }\n  }\n\n  return null;\n}\n\nfunction quoteSqlString(value: string): string {\n  return `'${value.replace(/'/g, \"''\")}'`;\n}\n\nfunction getDatabaseList(database: Database.Database): DatabaseListRow[] {\n  return database.prepare('PRAGMA database_list').all() as DatabaseListRow[];\n}\n\nfunction sanitizeCheckpointName(name: string): string {\n  const sanitized = name.trim();\n  if (\n    sanitized.length === 0\n    || sanitized.length > 128\n    || sanitized.includes('/')\n    || sanitized.includes('\\\\')\n    || sanitized.includes('..')\n    || sanitized.includes('\\0')\n  ) {\n    throw new CheckpointCreateError(\n      'CHECKPOINT_CREATE_INVALID_NAME',\n      'Checkpoint creation failed because the checkpoint name is invalid.',\n      { name },\n    );\n  }\n  return sanitized;\n}\n\nfunction resolveCheckpointDir(database: Database.Database, name: string): string {\n  const sanitizedName = sanitizeCheckpointName(name);\n  const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n  const mainFile = mainRow?.file;\n  if (!mainFile || mainFile === ':memory:') {\n    throw new CheckpointCreateError(\n      'CHECKPOINT_CREATE_FAILED',\n      'Checkpoint creation failed because the main database file path could not be resolved.',\n      { name: sanitizedName },\n    );\n  }\n  return path.join(path.dirname(mainFile), 'checkpoints', sanitizedName);\n}\n\nfunction getActiveVectorShardPath(database: Database.Database): string | null {\n  const activeVec = getDatabaseList(database).find((row) => row.name === 'active_vec');\n  return activeVec?.file && activeVec.file.length > 0 ? activeVec.file : null;\n}\n\nfunction deriveEmbedderSlug(shardPath: string | null): string | null {\n  if (!shardPath) {\n    return null;\n  }\n  const match = /^context-vectors__(.+)\\.sqlite$/.exec(path.basename(shardPath));\n  return match?.[1] ?? null;\n}\n\nfunction sweepStaleCheckpointTmpDirs(checkpointsDir: string): void {\n  if (!fs.existsSync(checkpointsDir)) {\n    return;\n  }\n  for (const entry of fs.readdirSync(checkpointsDir, { withFileTypes: true })) {\n    if (entry.isDirectory() && entry.name.includes('.tmp-')) {\n      fs.rmSync(path.join(checkpointsDir, entry.name), { recursive: true, force: true });\n    }\n  }\n}\n\nfunction resolvePathSafe(targetPath: string): string {\n  try {\n    return fs.realpathSync(targetPath);\n  } catch (_error: unknown) {\n    return path.resolve(targetPath);\n  }\n}\n\nfunction sweepOrphanCheckpointSnapshotDirs(database: Database.Database, checkpointsDir: string): void {\n  // Checkpoint pruning removes the catalog row inside the create transaction but deletes\n  // the snapshot dir AFTER commit. A crash in that gap leaves a snapshot dir with no\n  // catalog row — never swept by the .tmp-* sweep (it has a published name) and never\n  // restorable. Reconcile on-disk v2 snapshot dirs against the live catalog and remove\n  // any that no catalog row references. Best-effort: never throw out of the create path.\n  try {\n    if (!fs.existsSync(checkpointsDir) || !tableExists(database, 'checkpoints')) {\n      return;\n    }\n\n    const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n    if (!checkpointColumns.has('snapshot_path')) {\n      return;\n    }\n    const referenced = new Set<string>();\n    const rows = database.prepare(\n      \"SELECT snapshot_path FROM checkpoints WHERE snapshot_path IS NOT NULL AND snapshot_path <> ''\",\n    ).all() as Array<{ snapshot_path?: string | null }>;\n    for (const row of rows) {\n      if (typeof row.snapshot_path === 'string' && row.snapshot_path.length > 0) {\n        referenced.add(resolvePathSafe(row.snapshot_path));\n      }\n    }\n\n    for (const entry of fs.readdirSync(checkpointsDir, { withFileTypes: true })) {\n      if (!entry.isDirectory() || entry.name.includes('.tmp-')) {\n        continue;\n      }\n      const entryPath = path.join(checkpointsDir, entry.name);\n      if (referenced.has(resolvePathSafe(entryPath))) {\n        continue;\n      }\n      try {\n        fs.rmSync(entryPath, { recursive: true, force: true });\n        console.warn(`[checkpoints] Swept orphan checkpoint snapshot dir with no catalog row: ${entry.name}`);\n      } catch (_removeError: unknown) {\n        // Best-effort: a single un-removable dir must not block checkpoint creation.\n      }\n    }\n  } catch (error: unknown) {\n    console.warn(`[checkpoints] Orphan checkpoint snapshot sweep skipped (non-fatal): ${toErrorMessage(error)}`);\n  }\n}\n\nfunction readSchemaVersion(database: Database.Database): number | null {\n  try {\n    const row = database.prepare('SELECT version FROM schema_version WHERE id = 1').get() as { version?: number } | undefined;\n    return typeof row?.version === 'number' ? row.version : null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction countTableRows(database: Database.Database, tableName: string): number {\n  if (!tableExists(database, tableName)) {\n    return 0;\n  }\n  const row = database.prepare(`SELECT COUNT(*) AS count FROM ${tableName}`).get() as { count?: number } | undefined;\n  return typeof row?.count === 'number' ? row.count : 0;\n}\n\nfunction countActiveVectorRows(database: Database.Database): number {\n  try {\n    const row = database.prepare(`\n      SELECT 1 AS found\n      FROM active_vec.sqlite_master\n      WHERE type IN ('table', 'view') AND name = 'vec_memories'\n      LIMIT 1\n    `).get() as { found?: number } | undefined;\n    if (row?.found !== 1) {\n      return 0;\n    }\n    const countRow = database.prepare('SELECT COUNT(*) AS count FROM active_vec.vec_memories').get() as { count?: number } | undefined;\n    return typeof countRow?.count === 'number' ? countRow.count : 0;\n  } catch (_error: unknown) {\n    return 0;\n  }\n}\n\nfunction readCheckpointV2Manifest(snapshotPath: string | null): CheckpointV2Manifest | null {\n  if (!snapshotPath) {\n    return null;\n  }\n  try {\n    const raw = fs.readFileSync(path.join(snapshotPath, 'manifest.json'), 'utf-8');\n    const parsed = JSON.parse(raw) as Partial<CheckpointV2Manifest>;\n    return parsed.formatVersion === 2 ? parsed as CheckpointV2Manifest : null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction loadCheckpointV2Manifest(snapshotPath: string | null): CheckpointV2Manifest {\n  if (!snapshotPath) {\n    throw new CheckpointRestoreError(\n      'CHECKPOINT_RESTORE_MANIFEST_INVALID',\n      'Checkpoint v2 restore failed because snapshot_path is missing.',\n    );\n  }\n\n  const manifestPath = path.join(snapshotPath, 'manifest.json');\n  try {\n    const raw = fs.readFileSync(manifestPath, 'utf-8');\n    const parsed = JSON.parse(raw) as Partial<CheckpointV2Manifest>;\n    if (\n      parsed.formatVersion !== 2\n      || typeof parsed.includeEmbeddings !== 'boolean'\n      || !Array.isArray(parsed.mainTables)\n      || !Array.isArray(parsed.vecTables)\n      || typeof parsed.schemaVersion !== 'number'\n      || typeof parsed.memoryCount !== 'number'\n      || typeof parsed.vectorCount !== 'number'\n    ) {\n      throw new Error('manifest shape is invalid');\n    }\n    return parsed as CheckpointV2Manifest;\n  } catch (error: unknown) {\n    throw new CheckpointRestoreError(\n      'CHECKPOINT_RESTORE_MANIFEST_INVALID',\n      `Checkpoint v2 restore failed because manifest.json could not be read: ${toErrorMessage(error)}`,\n      error,\n    );\n  }\n}\n\nfunction resolveMainDatabasePath(database: Database.Database): string {\n  const mainRow = getDatabaseList(database).find((row) => row.name === 'main');\n  const mainFile = mainRow?.file;\n  if (!mainFile || mainFile === ':memory:') {\n    throw new CheckpointRestoreError(\n      'CHECKPOINT_RESTORE_PATH_UNRESOLVED',\n      'Checkpoint v2 restore failed because the live main database path could not be resolved.',\n    );\n  }\n  return mainFile;\n}\n\nfunction removeSqliteSidecars(databasePath: string): void {\n  for (const sidecarPath of [`${databasePath}-wal`, `${databasePath}-shm`]) {\n    fs.rmSync(sidecarPath, { force: true });\n  }\n}\n\nfunction getRestoreJournalPath(liveMainPath: string): string {\n  return path.join(path.dirname(liveMainPath), 'checkpoints', RESTORE_JOURNAL_NAME);\n}\n\nfunction getNeedsRebuildSentinelPath(liveMainPath: string): string {\n  return path.join(path.dirname(liveMainPath), 'checkpoints', NEEDS_REBUILD_SENTINEL_NAME);\n}\n\nfunction fsyncFileIfPossible(filePath: string): void {\n  let fd: number | null = null;\n  try {\n    fd = fs.openSync(filePath, 'r');\n    fs.fsyncSync(fd);\n  } catch (_error: unknown) {\n    // Best-effort durability; the next boot still treats any visible journal as authoritative.\n  } finally {\n    if (fd !== null) {\n      try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nfunction fsyncDirectoryIfPossible(dirPath: string): void {\n  let fd: number | null = null;\n  try {\n    fd = fs.openSync(dirPath, 'r');\n    fs.fsyncSync(fd);\n  } catch (_error: unknown) {\n    // Directory fsync is unavailable on some platforms/filesystems.\n  } finally {\n    if (fd !== null) {\n      try { fs.closeSync(fd); } catch (_error: unknown) { /* best-effort */ }\n    }\n  }\n}\n\nfunction writeRestoreJournal(journalPath: string, journal: RestoreJournalFile): void {\n  const journalDir = path.dirname(journalPath);\n  const tempJournalPath = `${journalPath}.tmp`;\n  fs.mkdirSync(journalDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(tempJournalPath, `${JSON.stringify(journal, null, 2)}\\n`, { mode: 0o600 });\n  fsyncFileIfPossible(tempJournalPath);\n  fs.renameSync(tempJournalPath, journalPath);\n  fsyncDirectoryIfPossible(journalDir);\n}\n\nfunction clearRestoreJournal(journalPath: string): void {\n  fs.rmSync(journalPath, { force: true });\n  fsyncDirectoryIfPossible(path.dirname(journalPath));\n}\n\nfunction writeNeedsRebuildSentinelAtPath(\n  sentinelPath: string,\n  options: NeedsRebuildSentinelWriteOptions,\n): void {\n  const sentinelDir = path.dirname(sentinelPath);\n  const tempSentinelPath = `${sentinelPath}.tmp`;\n  const sentinel: NeedsRebuildSentinelFile = {\n    formatVersion: 1,\n    createdAt: new Date().toISOString(),\n    source: options.source,\n    reason: options.reason,\n    ...(options.summary ? { rebuildSummary: options.summary } : {}),\n  };\n\n  fs.mkdirSync(sentinelDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(tempSentinelPath, `${JSON.stringify(sentinel, null, 2)}\\n`, { mode: 0o600 });\n  fsyncFileIfPossible(tempSentinelPath);\n  fs.renameSync(tempSentinelPath, sentinelPath);\n  fsyncDirectoryIfPossible(sentinelDir);\n}\n\nfunction clearNeedsRebuildSentinelAtPath(sentinelPath: string): boolean {\n  const existed = fs.existsSync(sentinelPath);\n  fs.rmSync(sentinelPath, { force: true });\n  if (existed) {\n    fsyncDirectoryIfPossible(path.dirname(sentinelPath));\n  }\n  return existed;\n}\n\nfunction getNeedsRebuildSentinelPathForDatabase(database: Database.Database): string | null {\n  try {\n    return getNeedsRebuildSentinelPath(resolveMainDatabasePath(database));\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction hasNeedsRebuildSentinel(database: Database.Database): boolean {\n  const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n  return sentinelPath !== null && fs.existsSync(sentinelPath);\n}\n\nfunction writeNeedsRebuildSentinelForDatabase(\n  database: Database.Database,\n  options: NeedsRebuildSentinelWriteOptions,\n): string | null {\n  const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n  if (sentinelPath === null) {\n    return null;\n  }\n  writeNeedsRebuildSentinelAtPath(sentinelPath, options);\n  return sentinelPath;\n}\n\nfunction writeNeedsRebuildSentinelForMainPath(\n  liveMainPath: string,\n  options: NeedsRebuildSentinelWriteOptions,\n): string {\n  const sentinelPath = getNeedsRebuildSentinelPath(liveMainPath);\n  writeNeedsRebuildSentinelAtPath(sentinelPath, options);\n  return sentinelPath;\n}\n\nfunction clearNeedsRebuildSentinelForDatabase(database: Database.Database): boolean {\n  const sentinelPath = getNeedsRebuildSentinelPathForDatabase(database);\n  if (sentinelPath === null) {\n    return false;\n  }\n  return clearNeedsRebuildSentinelAtPath(sentinelPath);\n}\n\nfunction removeRestoreBackupIfPossible(backupPath: string): void {\n  try {\n    fs.rmSync(backupPath, { force: true });\n  } catch (error: unknown) {\n    console.warn(`[checkpoints] restore backup cleanup skipped for ${backupPath}: ${toErrorMessage(error)}`);\n  }\n}\n\nfunction readCheckpointCatalogRows(database: Database.Database): Array<Record<string, unknown>> {\n  if (!tableExists(database, 'checkpoints')) {\n    return [];\n  }\n  return database.prepare('SELECT * FROM checkpoints ORDER BY id ASC').all() as Array<Record<string, unknown>>;\n}\n\nfunction mergeCheckpointCatalogRows(database: Database.Database, rows: Array<Record<string, unknown>>): void {\n  if (rows.length === 0 || !tableExists(database, 'checkpoints')) {\n    return;\n  }\n\n  const targetColumns = new Set(getTableColumns(database, 'checkpoints'));\n  for (const row of rows) {\n    const name = row.name;\n    if (typeof name !== 'string' || name.length === 0) {\n      continue;\n    }\n    const existingByName = database.prepare('SELECT id FROM checkpoints WHERE name = ?').get(name) as { id?: number } | undefined;\n    if (existingByName?.id) {\n      continue;\n    }\n\n    let columns = Object.keys(row).filter((column) => targetColumns.has(column));\n    const id = row.id;\n    if (typeof id === 'number') {\n      const existingById = database.prepare('SELECT name FROM checkpoints WHERE id = ?').get(id) as { name?: string } | undefined;\n      if (existingById?.name && existingById.name !== name) {\n        columns = columns.filter((column) => column !== 'id');\n      }\n    }\n    if (columns.length === 0) {\n      continue;\n    }\n\n    const placeholders = columns.map(() => '?').join(', ');\n    database.prepare(`\n      INSERT OR IGNORE INTO checkpoints (${columns.join(', ')})\n      VALUES (${placeholders})\n    `).run(...columns.map((column) => row[column]));\n  }\n}\n\nfunction pruneCheckpointCatalogRowsMissingSnapshots(database: Database.Database): void {\n  // The restored snapshot-main DB carries the full checkpoints table as of the\n  // snapshot, including v2 rows whose snapshot dir was deleted after the snapshot\n  // was taken. Those rows would resurface in listCheckpoints with no restorable\n  // dir, so drop any v2 row whose snapshot_path no longer exists on disk.\n  // Best-effort: never throw out of the restore path.\n  try {\n    if (!tableExists(database, 'checkpoints')) {\n      return;\n    }\n    const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n    if (!checkpointColumns.has('snapshot_path') || !checkpointColumns.has('snapshot_format')) {\n      return;\n    }\n    const rows = database.prepare(\n      \"SELECT id, snapshot_path FROM checkpoints WHERE snapshot_format = 'v2' AND snapshot_path IS NOT NULL AND snapshot_path <> ''\",\n    ).all() as Array<{ id: number; snapshot_path: string }>;\n    for (const row of rows) {\n      if (!fs.existsSync(row.snapshot_path)) {\n        database.prepare('DELETE FROM checkpoints WHERE id = ?').run(row.id);\n        console.warn(`[checkpoints] Dropped restored catalog row with missing snapshot dir: ${row.snapshot_path}`);\n      }\n    }\n  } catch (error: unknown) {\n    console.warn(`[checkpoints] Post-restore catalog reconciliation skipped (non-fatal): ${toErrorMessage(error)}`);\n  }\n}\n\nfunction statPathBytes(targetPath: string): number {\n  try {\n    const stats = fs.statSync(targetPath);\n    if (stats.isFile()) {\n      return stats.size;\n    }\n    if (!stats.isDirectory()) {\n      return 0;\n    }\n    return fs.readdirSync(targetPath).reduce((total, entry) => total + statPathBytes(path.join(targetPath, entry)), 0);\n  } catch (_error: unknown) {\n    return 0;\n  }\n}\n\nfunction getCheckpointV2SnapshotSize(snapshotPath: string | null): number {\n  const manifest = readCheckpointV2Manifest(snapshotPath);\n  if (manifest) {\n    return manifest.mainBytes + manifest.vecBytes;\n  }\n  return snapshotPath ? statPathBytes(snapshotPath) : 0;\n}\n\nfunction removeCheckpointSnapshotDirs(snapshotPaths: string[]): void {\n  for (const snapshotPath of snapshotPaths) {\n    try {\n      fs.rmSync(snapshotPath, { recursive: true, force: true });\n    } catch (_error: unknown) {\n      // Best-effort cleanup; the checkpoint row is already gone.\n    }\n  }\n}\n\nfunction collectPrunedCheckpointSnapshotPaths(database: Database.Database, pruneCount: number): string[] {\n  if (pruneCount <= 0) {\n    return [];\n  }\n  const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n  const snapshotPathSelect = checkpointColumns.has('snapshot_path') ? 'snapshot_path' : 'NULL AS snapshot_path';\n  const snapshotFormatSelect = checkpointColumns.has('snapshot_format') ? 'snapshot_format' : \"'v1' AS snapshot_format\";\n  const rows = database.prepare(`\n    SELECT id, ${snapshotPathSelect}, ${snapshotFormatSelect}\n    FROM checkpoints\n    ORDER BY created_at ASC, id ASC\n    LIMIT ?\n  `).all(pruneCount) as Array<{ id: number; snapshot_path?: string | null; snapshot_format?: string | null }>;\n\n  if (rows.length === 0) {\n    return [];\n  }\n  const ids = rows.map((row) => row.id);\n  const placeholders = ids.map(() => '?').join(', ');\n  database.prepare(`DELETE FROM checkpoints WHERE id IN (${placeholders})`).run(...ids);\n  return rows\n    .filter((row) => row.snapshot_format === 'v2' && typeof row.snapshot_path === 'string' && row.snapshot_path.length > 0)\n    .map((row) => row.snapshot_path as string);\n}\n\nfunction enforceMaxCheckpointsInTransaction(database: Database.Database): string[] {\n  const checkpointCount = (database.prepare(\n    'SELECT COUNT(*) as count FROM checkpoints'\n  ) as Database.Statement).get() as { count: number };\n\n  if (checkpointCount.count <= MAX_CHECKPOINTS) {\n    return [];\n  }\n\n  return collectPrunedCheckpointSnapshotPaths(database, checkpointCount.count - MAX_CHECKPOINTS);\n}\n\nfunction supportsCheckpointV2(database: Database.Database): boolean {\n  const checkpointColumns = new Set(getTableColumns(database, 'checkpoints'));\n  return checkpointColumns.has('snapshot_format') && checkpointColumns.has('snapshot_path');\n}\n\nfunction hasMainVectorPayloadTables(database: Database.Database): boolean {\n  try {\n    // Gate v2 selection on vec_memories ONLY — the actual vector payload that the\n    // shard-attach slimming removes from main. vec_metadata is a tiny key/value\n    // config table that the same slimming intentionally RETAINS in main as a\n    // dimension fallback, so its presence does NOT mean vector payload lives in\n    // main. Including it here made full-DB create always observe \"payload in main\"\n    // on a sharded runtime and silently fall back to the v1 whole-snapshot path\n    // that overflows V8's single-string ceiling — the exact failure v2 prevents.\n    const row = database.prepare(`\n      SELECT 1 AS found\n      FROM sqlite_master\n      WHERE type IN ('table', 'view')\n        AND name = 'vec_memories'\n      LIMIT 1\n    `).get() as { found?: number } | undefined;\n    return row?.found === 1;\n  } catch (_error: unknown) {\n    return false;\n  }\n}\n\nfunction tableExists(database: Database.Database, tableName: string): boolean {\n  try {\n    if (tableName === 'vec_memories') {\n      const mainOrTempRow = database.prepare(`\n        SELECT 1 AS found\n        FROM temp.sqlite_master\n        WHERE type IN ('table','view') AND name = 'vec_memories'\n        UNION ALL\n        SELECT 1 AS found\n        FROM sqlite_master\n        WHERE type IN ('table','view') AND name = 'vec_memories'\n        LIMIT 1\n      `).get() as { found?: number } | undefined;\n      if (mainOrTempRow?.found === 1) {\n        return true;\n      }\n\n      const hasActiveVectorShard = (database.prepare('PRAGMA database_list').all() as Array<{ name?: string }>)\n        .some((entry) => entry.name === 'active_vec');\n      if (!hasActiveVectorShard) {\n        return false;\n      }\n\n      const vectorRow = database.prepare(`\n        SELECT 1 AS found\n        FROM active_vec.sqlite_master\n        WHERE type IN ('table','view') AND name = 'vec_memories'\n        LIMIT 1\n      `).get() as { found?: number } | undefined;\n      return vectorRow?.found === 1;\n    }\n\n    const row = database.prepare(\n      \"SELECT name FROM sqlite_master WHERE type IN ('table','view') AND name = ?\"\n    ).get(tableName) as { name?: string } | undefined;\n    return !!row?.name;\n  } catch (_error: unknown) {\n    return false;\n  }\n}\n\n// Static allowlist for dynamic table name interpolation\nconst ALLOWED_TABLE_NAMES = new Set([\n  // Core tables\n  'memory_index', 'memory_fts', 'vec_memories', 'vec_metadata', 'causal_edges',\n  'memory_conflicts', 'memory_corrections', 'memory_lineage', 'memory_history',\n  'memory_summaries', 'mutation_ledger',\n  // Working memory & session\n  'working_memory', 'session_state', 'session_sent_memories', 'session_learning',\n  // Graph & signals\n  'weight_history', 'adaptive_signal_events', 'negative_feedback_events',\n  'active_memory_projection', 'auto_entities', 'community_assignments', 'degree_snapshots',\n  // Feedback & learning\n  'learned_feedback_audit', 'learned_trigger_scores', 'learned_trigger_feedback',\n  // Governance\n  'governance_audit',\n  // Checkpoints & system\n  'checkpoints', 'checkpoint_items', 'deletion_log', 'consumption_log',\n  'eval_shadow_comparisons',\n]);\n\nfunction validateTableName(tableName: string): void {\n  if (!ALLOWED_TABLE_NAMES.has(tableName)) {\n    throw new Error(`[checkpoints] Table name \"${tableName}\" not in allowlist`);\n  }\n}\n\nfunction getTableColumns(database: Database.Database, tableName: string): string[] {\n  validateTableName(tableName);\n  try {\n    return (database.prepare(`PRAGMA table_info(\"${tableName}\")`).all() as Array<{ name: string }>)\n      .map((column) => column.name)\n      .filter((name) => typeof name === 'string' && name.length > 0);\n  } catch (_error: unknown) {\n    return [];\n  }\n}\n\nfunction tableHasColumn(\n  database: Database.Database,\n  tableName: string,\n  columnName: string,\n): boolean {\n  return getTableColumns(database, tableName).includes(columnName);\n}\n\nfunction toBuffer(value: unknown): Buffer | null {\n  if (Buffer.isBuffer(value)) return value;\n  if (value && typeof value === 'object') {\n    const maybeSerialized = value as { type?: unknown; data?: unknown };\n    if (\n      maybeSerialized.type === 'Buffer' &&\n      Array.isArray(maybeSerialized.data) &&\n      maybeSerialized.data.every((entry) => typeof entry === 'number')\n    ) {\n      return Buffer.from(maybeSerialized.data);\n    }\n  }\n  return null;\n}\n\nfunction deserializeSnapshotValue(value: unknown): unknown {\n  if (value === undefined) {\n    return null;\n  }\n  return toBuffer(value) ?? value;\n}\n\nfunction getMemoryIds(memories: Array<Record<string, unknown>>): number[] {\n  const ids = new Set<number>();\n  for (const memory of memories) {\n    if (!memory || typeof memory !== 'object') {\n      continue;\n    }\n    const rawId = memory.id;\n    if (typeof rawId === 'number' && Number.isSafeInteger(rawId)) {\n      ids.add(rawId);\n      continue;\n    }\n    if (typeof rawId === 'string' && /^\\d+$/.test(rawId)) {\n      ids.add(Number.parseInt(rawId, 10));\n    }\n  }\n  return Array.from(ids);\n}\n\nfunction parseCheckpointMetadata(value: unknown): Record<string, unknown> {\n  if (!value) {\n    return {};\n  }\n  if (typeof value === 'string') {\n    try {\n      const parsed = JSON.parse(value) as unknown;\n      return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n        ? parsed as Record<string, unknown>\n        : {};\n    } catch (_error: unknown) {\n      return {};\n    }\n  }\n  return typeof value === 'object' && !Array.isArray(value)\n    ? value as Record<string, unknown>\n    : {};\n}\n\nfunction checkpointMetadataMatchesScope(rawMetadata: unknown, scope: ScopeContext): boolean {\n  const normalizedScope = normalizeScopeContext(scope);\n  if (!hasScopeConstraints(normalizedScope)) {\n    return true;\n  }\n\n  const metadata = parseCheckpointMetadata(rawMetadata);\n  return (\n    (normalizedScope.tenantId === undefined || metadata.tenantId === normalizedScope.tenantId)\n    && (normalizedScope.userId === undefined || metadata.userId === normalizedScope.userId)\n    && (normalizedScope.agentId === undefined || metadata.agentId === normalizedScope.agentId)\n  );\n}\n\nfunction hasDirectScopeColumns(columns: ReadonlySet<string>): boolean {\n  return (\n    columns.has('tenant_id')\n    || columns.has('user_id')\n    || columns.has('agent_id')\n    || columns.has('session_id')\n  );\n}\n\nfunction getScopeFilterContext(\n  _database: Database.Database,\n  scope: ScopeContext = {},\n): {\n  normalizedScope: ScopeContext;\n  predicate: ((row: Record<string, unknown>) => boolean) | null;\n} {\n  const normalizedScope = normalizeScopeContext(scope);\n  if (!hasScopeConstraints(normalizedScope)) {\n    return {\n      normalizedScope,\n      predicate: null,\n    };\n  }\n\n  return {\n    normalizedScope,\n    predicate: createScopeFilterPredicate<Record<string, unknown>>(normalizedScope),\n  };\n}\n\nfunction getScopedMemories(\n  database: Database.Database,\n  specFolder: string | null,\n  scope: ScopeContext = {},\n): {\n  memories: Array<Record<string, unknown>>;\n  memoryIds: number[];\n  normalizedScope: ScopeContext;\n} {\n  const { normalizedScope, predicate } = getScopeFilterContext(database, scope);\n  const baseMemories = specFolder\n    ? database.prepare('SELECT * FROM memory_index WHERE spec_folder = ?').all(specFolder) as Array<Record<string, unknown>>\n    : database.prepare('SELECT * FROM memory_index').all() as Array<Record<string, unknown>>;\n  const memories = predicate ? baseMemories.filter((row) => predicate(row)) : baseMemories;\n\n  return {\n    memories,\n    memoryIds: getMemoryIds(memories),\n    normalizedScope,\n  };\n}\n\nfunction getCurrentScopedMemoryIds(\n  database: Database.Database,\n  specFolder: string | null,\n  scope: ScopeContext = {},\n): number[] {\n  return getScopedMemories(database, specFolder, scope).memoryIds;\n}\n\nfunction buildRestoreScopeDeleteWhere(\n  columns: ReadonlySet<string>,\n  checkpointSpecFolder: string | null,\n  scope: ScopeContext = {},\n): {\n  clauses: string[];\n  params: string[];\n} {\n  const normalizedScope = normalizeScopeContext(scope);\n  const clauses: string[] = [];\n  const params: string[] = [];\n\n  if (checkpointSpecFolder && columns.has('spec_folder')) {\n    clauses.push('spec_folder = ?');\n    params.push(checkpointSpecFolder);\n  }\n  if (normalizedScope.tenantId && columns.has('tenant_id')) {\n    clauses.push('tenant_id = ?');\n    params.push(normalizedScope.tenantId);\n  }\n  if (normalizedScope.userId && columns.has('user_id')) {\n    clauses.push('user_id = ?');\n    params.push(normalizedScope.userId);\n  }\n  if (normalizedScope.agentId && columns.has('agent_id')) {\n    clauses.push('agent_id = ?');\n    params.push(normalizedScope.agentId);\n  }\n\n  return { clauses, params };\n}\n\nfunction getEdgeIds(edges: Array<Record<string, unknown>>): number[] {\n  const ids = new Set<number>();\n  for (const edge of edges) {\n    const rawId = edge?.id;\n    if (typeof rawId === 'number' && Number.isSafeInteger(rawId)) {\n      ids.add(rawId);\n      continue;\n    }\n    if (typeof rawId === 'string' && /^\\d+$/.test(rawId)) {\n      ids.add(Number.parseInt(rawId, 10));\n    }\n  }\n  return Array.from(ids);\n}\n\nfunction deleteRowsByIds(\n  database: Database.Database,\n  tableName: string,\n  columnName: string,\n  ids: number[],\n): void {\n  if (ids.length === 0) {\n    return;\n  }\n\n  const sql = `DELETE FROM ${tableName} WHERE ${columnName} IN (__PLACEHOLDERS__)`;\n  for (let i = 0; i < ids.length; i += 500) {\n    const batch = ids.slice(i, i + 500);\n    const placeholders = batch.map(() => '?').join(', ');\n    database.prepare(sql.replace('__PLACEHOLDERS__', placeholders)).run(...batch);\n  }\n}\n\nfunction snapshotCausalEdgesForMemoryIds(\n  database: Database.Database,\n  memoryIds: number[],\n): Array<Record<string, unknown>> {\n  if (memoryIds.length === 0 || !tableExists(database, 'causal_edges')) {\n    return [];\n  }\n\n  try {\n    const edgeIds = memoryIds.map((id) => String(id));\n    return dedupeRowsById([\n      ...batchedInQuery<Record<string, unknown>>(\n        database,\n        `\n          SELECT * FROM causal_edges\n          WHERE source_id IN (__PLACEHOLDERS__)\n        `,\n        edgeIds,\n      ),\n      ...batchedInQuery<Record<string, unknown>>(\n        database,\n        `\n          SELECT * FROM causal_edges\n          WHERE target_id IN (__PLACEHOLDERS__)\n        `,\n        edgeIds,\n      ),\n    ]);\n  } catch (_error: unknown) {\n    return [];\n  }\n}\n\nfunction getTableSnapshotColumns(database: Database.Database, tableName: string): string[] {\n  if (tableName === 'vec_memories') {\n    return ['rowid', 'embedding'];\n  }\n  return getTableColumns(database, tableName);\n}\n\nfunction selectTableRows(\n  database: Database.Database,\n  tableName: string,\n  options: {\n    specFolder: string | null;\n    memoryIds: number[];\n    scope?: ScopeContext;\n  },\n): Array<Record<string, unknown>> {\n  const { specFolder, memoryIds, scope = {} } = options;\n  const normalizedScope = normalizeScopeContext(scope);\n  const hasScope = hasScopeConstraints(normalizedScope);\n  const scopePredicate = hasScope\n    ? createScopeFilterPredicate<Record<string, unknown>>(normalizedScope)\n    : null;\n\n  if (tableName === 'memory_index') {\n    const rows = specFolder\n      ? database.prepare(\n        'SELECT * FROM memory_index WHERE spec_folder = ?'\n      ).all(specFolder) as Array<Record<string, unknown>>\n      : database.prepare('SELECT * FROM memory_index').all() as Array<Record<string, unknown>>;\n    return scopePredicate ? rows.filter((row) => scopePredicate(row)) : rows;\n  }\n\n  if (tableName === 'vec_memories') {\n    if (memoryIds.length > 0) {\n      return batchedInQuery<Record<string, unknown>>(\n        database,\n        'SELECT rowid AS rowid, embedding FROM vec_memories WHERE rowid IN (__PLACEHOLDERS__)',\n        memoryIds,\n      );\n    }\n    if (specFolder) {\n      return database.prepare(`\n      SELECT v.rowid AS rowid, v.embedding AS embedding\n      FROM vec_memories v\n      JOIN memory_index m ON m.id = v.rowid\n      WHERE m.spec_folder = ?\n    `).all(specFolder) as Array<Record<string, unknown>>;\n    }\n    return hasScope ? [] : database.prepare(\n      'SELECT rowid AS rowid, embedding FROM vec_memories'\n    ).all() as Array<Record<string, unknown>>;\n  }\n\n  if (tableName === 'causal_edges') {\n    if (memoryIds.length > 0) {\n      return snapshotCausalEdgesForMemoryIds(database, memoryIds);\n    }\n    return hasScope ? [] : database.prepare('SELECT * FROM causal_edges').all() as Array<Record<string, unknown>>;\n  }\n\n  const columns = new Set(getTableColumns(database, tableName));\n\n  if (specFolder && columns.has('spec_folder')) {\n    return database.prepare(\n      `SELECT * FROM ${tableName} WHERE spec_folder = ?`\n    ).all(specFolder) as Array<Record<string, unknown>>;\n  }\n\n  if (memoryIds.length > 0 && columns.has('memory_id')) {\n    return batchedInQuery<Record<string, unknown>>(\n      database,\n      `SELECT * FROM ${tableName} WHERE memory_id IN (__PLACEHOLDERS__)`,\n      memoryIds,\n    );\n  }\n\n  if (memoryIds.length > 0 && tableName === 'memory_corrections') {\n    return dedupeRowsById([\n      ...batchedInQuery<Record<string, unknown>>(\n        database,\n        `\n          SELECT * FROM memory_corrections\n          WHERE original_memory_id IN (__PLACEHOLDERS__)\n        `,\n        memoryIds,\n      ),\n      ...batchedInQuery<Record<string, unknown>>(\n        database,\n        `\n          SELECT * FROM memory_corrections\n          WHERE correction_memory_id IN (__PLACEHOLDERS__)\n        `,\n        memoryIds,\n      ),\n    ]);\n  }\n\n  const allRows = database.prepare(`SELECT * FROM ${tableName}`).all() as Array<Record<string, unknown>>;\n  if (!scopePredicate) {\n    return allRows;\n  }\n\n  if (hasDirectScopeColumns(columns)) {\n    return allRows.filter((row) => scopePredicate(row));\n  }\n\n  return [];\n}\n\nfunction createTableSnapshot(\n  database: Database.Database,\n  tableName: string,\n  options: {\n    specFolder: string | null;\n    memoryIds: number[];\n    scope?: ScopeContext;\n  },\n): TableSnapshot | null {\n  if (!tableExists(database, tableName)) {\n    return null;\n  }\n\n  const columns = getTableSnapshotColumns(database, tableName);\n  if (columns.length === 0) {\n    return null;\n  }\n\n  const rows = selectTableRows(database, tableName, options);\n  return { columns, rows };\n}\n\nfunction buildCheckpointManifest(): CheckpointManifest {\n  return {\n    snapshot: [...CHECKPOINT_MANIFEST.snapshot],\n    rebuild: [...CHECKPOINT_MANIFEST.rebuild],\n    skip: [...CHECKPOINT_MANIFEST.skip],\n  };\n}\n\nfunction buildLegacyTableSnapshots(snapshot: CheckpointSnapshot): Record<string, TableSnapshot> {\n  const tableSnapshots: Record<string, TableSnapshot> = {};\n\n  if (Array.isArray(snapshot.memories)) {\n    tableSnapshots.memory_index = {\n      columns: Object.keys(snapshot.memories[0] ?? {}),\n      rows: snapshot.memories,\n    };\n  }\n\n  if (Array.isArray(snapshot.workingMemory)) {\n    tableSnapshots.working_memory = {\n      columns: Object.keys(snapshot.workingMemory[0] ?? {}),\n      rows: snapshot.workingMemory,\n    };\n  }\n\n  if (Array.isArray(snapshot.vectors)) {\n    tableSnapshots.vec_memories = {\n      columns: ['rowid', 'embedding'],\n      rows: snapshot.vectors.map((row) => ({\n        rowid: row.rowid,\n        embedding: row.embedding,\n      })),","lineStart":1,"lineEnd":1604,"totalLines":1605,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","time":{"start":1781763522572,"end":1781763522615}},"metadata":{"openai":{"itemId":"fc_07d11185e93d73e2016a338dc1a46c8191a3848271dd31a27d"}},"id":"prt_ed961c00800134ZcGRrgqj07dq","sessionID":"ses_126a03146ffe6yn9ha3tk3Qb0n","messageID":"msg_ed9618031001aMd6sS9Tw21zdA"}}
