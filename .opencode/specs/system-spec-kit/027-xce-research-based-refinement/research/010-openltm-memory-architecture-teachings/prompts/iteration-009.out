essage(err)}`);\n653:     }\n654:     return '';\n655:   }\n656: }\n657: \n658: // Safely parse JSON with validation (CWE-502: Deserialization mitigation)\n659: /**\n660:  * Parses JSON with prototype-pollution safeguards.\n661:  * @param json_string - The JSON string to parse.\n662:  * @param default_value - The fallback value to return on failure.\n663:  * @returns The parsed JSON value or the fallback.\n664:  */\n665: export function safe_parse_json(json_string: unknown, default_value = []): unknown {\n666:   if (!json_string || typeof json_string !== 'string') {\n667:     return default_value;\n668:   }\n669: \n670:   try {\n671:     const parsed = JSON.parse(json_string);\n672: \n673:     if (Array.isArray(parsed)) {\n674:       return parsed.filter(item =>\n675:         item && typeof item === 'object' &&\n676:         !Array.isArray(item) &&\n677:         !('__proto__' in item) &&\n678:         !('constructor' in item) &&\n679:         !('prototype' in item)\n680:       );\n681:     }\n682: \n683:     if (typeof parsed === 'object' && parsed !== null) {\n684:       if ('__proto__' in parsed || 'constructor' in parsed || 'prototype' in parsed) {\n685:         console.warn('[vector-index] Blocked potential prototype pollution in JSON');\n686:         return default_value;\n687:       }\n688:     }\n689: \n690:     return parsed;\n691:   } catch (err: unknown) {\n692:     console.warn(`[vector-index] JSON parse error: ${get_error_message(err)}`);\n693:     return default_value;\n694:   }\n695: }\n696: \n697: /* ───────────────────────────────────────────────────────────────\n698:    3. DATABASE SINGLETON\n699: ----------------------------------------------------------------*/\n700: \n701: let db: Database.Database | null = null;\n702: let db_path = resolve_database_path();\n703: let sqlite_vec_available_flag = true;\n704: let active_vector_source: ActiveVectorSourceTelemetry | null = null;\n705: // C1 FIX: Key connections by resolved DB path to prevent cross-store data corruption\n706: const db_connections = new Map<string, Database.Database>();\n707: const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n708: type DatabaseConnectionListener = (\n709:   database: Database.Database,\n710:   change: {\n711:     previousDb: Database.Database | null;\n712:     previousPath: string;\n713:     nextPath: string;\n714:   },\n715: ) => boolean | void;\n716: const database_connection_listeners = new Set<DatabaseConnectionListener>();\n717: \n718: function set_active_database_connection(\n719:   connection: Database.Database,\n720:   target_path: string,\n721:   vec_available: boolean,\n722: ): void {\n723:   const previousDb = db;\n724:   const previousPath = db_path;\n725:   db = connection;\n726:   db_path = target_path;\n727:   sqlite_vec_available_flag = vec_available;\n728: \n729:   if (previousDb !== connection || previousPath !== target_path) {\n730:     clear_constitutional_cache();\n731: \n732:     const listenerErrors: string[] = [];\n733:     for (const listener of database_connection_listeners) {\n734:       try {\n735:         const listenerResult = listener(connection, {\n736:           previousDb,\n737:           previousPath,\n738:           nextPath: target_path,\n739:         });\n740:         if (listenerResult === false) {\n741:           listenerErrors.push('listener returned false');\n742:         }\n743:       } catch (error: unknown) {\n744:         const message = get_error_message(error);\n745:         listenerErrors.push(message);\n746:         console.warn(`[vector-index] Database connection listener failed: ${message}`);\n747:       }\n748:     }\n749:     if (listenerErrors.length > 0) {\n750:       throw new Error(`Database connection listener rebind failed: ${listenerErrors.join('; ')}`);\n751:     }\n752:   }\n753: \n754:   if (target_path === ':memory:') {\n755:     return;\n756:   }\n757: \n758:   try {\n759:     fs.chmodSync(target_path, DB_PERMISSIONS);\n760:   } catch (err: unknown) {\n761:     console.warn(`[vector-index] Could not set permissions on ${target_path}: ${get_error_message(err)}`);\n762:   }\n763: }\n764: \n765: function get_unclean_shutdown_marker_path(target_path: string): string | null {\n766:   if (target_path === ':memory:') {\n767:     return null;\n768:   }\n769:   return path.join(path.dirname(target_path), UNCLEAN_SHUTDOWN_MARKER);\n770: }\n771: \n772: function write_unclean_shutdown_marker(target_path: string): void {\n773:   const marker_path = get_unclean_shutdown_marker_path(target_path);\n774:   if (!marker_path) {\n775:     return;\n776:   }\n777: \n778:   try {\n779:     fs.writeFileSync(marker_path, `${JSON.stringify({\n780:       pid: process.pid,\n781:       databasePath: target_path,\n782:       startedAt: new Date().toISOString(),\n783:     })}\\n`, { mode: 0o600 });\n784:   } catch (_error: unknown) {\n785:     // Best-effort: marker failure must not block DB startup.\n786:   }\n787: }\n788: \n789: function remove_unclean_shutdown_marker(target_path: string): void {\n790:   const marker_path = get_unclean_shutdown_marker_path(target_path);\n791:   if (!marker_path) {\n792:     return;\n793:   }\n794: \n795:   try {\n796:     fs.rmSync(marker_path, { force: true });\n797:   } catch (_error: unknown) {\n798:     // Best-effort: marker cleanup must not block DB close.\n799:   }\n\n(Showing lines 620-799 of 2042. Use offset=800 to continue.)\n</content>","metadata":{"preview":"  ...(process.env.MEMORY_ALLOWED_PATHS ? process.env.MEMORY_ALLOWED_PATHS.split(path.delimiter) : [])\n].filter(Boolean).map(p => path.resolve(p));\n\n/**\n * Validates a file path against allowed local base paths.\n * @param file_path - The file path to validate.\n * @returns The validated file path, if allowed.\n */\nexport function validate_file_path_local(file_path: unknown): string | null {\n  if (typeof file_path !== 'string') {\n    return null;\n  }\n\n  return validateFilePath(file_path, ALLOWED_BASE_PATHS);\n}\n\n// HIGH-004 FIX: Async version for non-blocking concurrent file reads\n/**\n * Reads a file asynchronously after validating the path.\n * @param file_path - The file path to read.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","text":"  ...(process.env.MEMORY_ALLOWED_PATHS ? process.env.MEMORY_ALLOWED_PATHS.split(path.delimiter) : [])\n].filter(Boolean).map(p => path.resolve(p));\n\n/**\n * Validates a file path against allowed local base paths.\n * @param file_path - The file path to validate.\n * @returns The validated file path, if allowed.\n */\nexport function validate_file_path_local(file_path: unknown): string | null {\n  if (typeof file_path !== 'string') {\n    return null;\n  }\n\n  return validateFilePath(file_path, ALLOWED_BASE_PATHS);\n}\n\n// HIGH-004 FIX: Async version for non-blocking concurrent file reads\n/**\n * Reads a file asynchronously after validating the path.\n * @param file_path - The file path to read.\n * @returns A promise that resolves to the file contents or an empty string.\n */\nexport async function safe_read_file_async(file_path: unknown): Promise<string> {\n  const valid_path = validate_file_path_local(file_path);\n  if (!valid_path) {\n    return '';\n  }\n\n  try {\n    return await fs.promises.readFile(valid_path, 'utf-8');\n  } catch (err: unknown) {\n    if (!(err instanceof Error && 'code' in err && get_error_code(err) === 'ENOENT')) {\n      console.warn(`[vector-index] Could not read file ${valid_path}: ${get_error_message(err)}`);\n    }\n    return '';\n  }\n}\n\n// Safely parse JSON with validation (CWE-502: Deserialization mitigation)\n/**\n * Parses JSON with prototype-pollution safeguards.\n * @param json_string - The JSON string to parse.\n * @param default_value - The fallback value to return on failure.\n * @returns The parsed JSON value or the fallback.\n */\nexport function safe_parse_json(json_string: unknown, default_value = []): unknown {\n  if (!json_string || typeof json_string !== 'string') {\n    return default_value;\n  }\n\n  try {\n    const parsed = JSON.parse(json_string);\n\n    if (Array.isArray(parsed)) {\n      return parsed.filter(item =>\n        item && typeof item === 'object' &&\n        !Array.isArray(item) &&\n        !('__proto__' in item) &&\n        !('constructor' in item) &&\n        !('prototype' in item)\n      );\n    }\n\n    if (typeof parsed === 'object' && parsed !== null) {\n      if ('__proto__' in parsed || 'constructor' in parsed || 'prototype' in parsed) {\n        console.warn('[vector-index] Blocked potential prototype pollution in JSON');\n        return default_value;\n      }\n    }\n\n    return parsed;\n  } catch (err: unknown) {\n    console.warn(`[vector-index] JSON parse error: ${get_error_message(err)}`);\n    return default_value;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. DATABASE SINGLETON\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet db_path = resolve_database_path();\nlet sqlite_vec_available_flag = true;\nlet active_vector_source: ActiveVectorSourceTelemetry | null = null;\n// C1 FIX: Key connections by resolved DB path to prevent cross-store data corruption\nconst db_connections = new Map<string, Database.Database>();\nconst UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\ntype DatabaseConnectionListener = (\n  database: Database.Database,\n  change: {\n    previousDb: Database.Database | null;\n    previousPath: string;\n    nextPath: string;\n  },\n) => boolean | void;\nconst database_connection_listeners = new Set<DatabaseConnectionListener>();\n\nfunction set_active_database_connection(\n  connection: Database.Database,\n  target_path: string,\n  vec_available: boolean,\n): void {\n  const previousDb = db;\n  const previousPath = db_path;\n  db = connection;\n  db_path = target_path;\n  sqlite_vec_available_flag = vec_available;\n\n  if (previousDb !== connection || previousPath !== target_path) {\n    clear_constitutional_cache();\n\n    const listenerErrors: string[] = [];\n    for (const listener of database_connection_listeners) {\n      try {\n        const listenerResult = listener(connection, {\n          previousDb,\n          previousPath,\n          nextPath: target_path,\n        });\n        if (listenerResult === false) {\n          listenerErrors.push('listener returned false');\n        }\n      } catch (error: unknown) {\n        const message = get_error_message(error);\n        listenerErrors.push(message);\n        console.warn(`[vector-index] Database connection listener failed: ${message}`);\n      }\n    }\n    if (listenerErrors.length > 0) {\n      throw new Error(`Database connection listener rebind failed: ${listenerErrors.join('; ')}`);\n    }\n  }\n\n  if (target_path === ':memory:') {\n    return;\n  }\n\n  try {\n    fs.chmodSync(target_path, DB_PERMISSIONS);\n  } catch (err: unknown) {\n    console.warn(`[vector-index] Could not set permissions on ${target_path}: ${get_error_message(err)}`);\n  }\n}\n\nfunction get_unclean_shutdown_marker_path(target_path: string): string | null {\n  if (target_path === ':memory:') {\n    return null;\n  }\n  return path.join(path.dirname(target_path), UNCLEAN_SHUTDOWN_MARKER);\n}\n\nfunction write_unclean_shutdown_marker(target_path: string): void {\n  const marker_path = get_unclean_shutdown_marker_path(target_path);\n  if (!marker_path) {\n    return;\n  }\n\n  try {\n    fs.writeFileSync(marker_path, `${JSON.stringify({\n      pid: process.pid,\n      databasePath: target_path,\n      startedAt: new Date().toISOString(),\n    })}\\n`, { mode: 0o600 });\n  } catch (_error: unknown) {\n    // Best-effort: marker failure must not block DB startup.\n  }\n}\n\nfunction remove_unclean_shutdown_marker(target_path: string): void {\n  const marker_path = get_unclean_shutdown_marker_path(target_path);\n  if (!marker_path) {\n    return;\n  }\n\n  try {\n    fs.rmSync(marker_path, { force: true });\n  } catch (_error: unknown) {\n    // Best-effort: marker cleanup must not block DB close.\n  }","lineStart":620,"lineEnd":799,"totalLines":2042,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","time":{"start":1780925773407,"end":1780925773418}},"metadata":{"openai":{"itemId":"fc_01f118128bb1efd9016a26c54d3b10819191ce0898eaabf59c"}},"id":"prt_ea772b65e0013oA4M6bWyspzzT","sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","messageID":"msg_ea7729304001Wo1pAL1I6w2EVe"}}
