   249	  }
   250	
   251	  let routeGold;
   252	  try {
   253	    routeGold = resolveRouteGold(args, skillRoot);
   254	  } catch (err) {
   255	    process.stderr.write(`run-skill-benchmark: ${err.message}\n`);
   256	    return 2;
   257	  }
   258	
   259	  // Topology digest snapshot: a manifest-bearing skill's leaf-manifest.json
   260	  // must not change while a run is scoring against it, or the scored rows and
   261	  // the committed gold would silently drift apart mid-run. A skill with no
   262	  // manifest digests to null and never reaches the abort check below.
   263	  const topologyDigestBefore = readManifestDigest(skillRoot);
   264	
   265	  // D5 hard gate first.
   266	  const connectivity = scanConnectivity({ skillRoot });
   267	  const hubRegistry = scanHubRegistry({ skillRoot });
