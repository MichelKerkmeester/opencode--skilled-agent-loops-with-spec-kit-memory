{
  "skill": "sk-code",
  "version": "1.1.0",
  "description": "Declarative two-axis mode registry for the sk-code parent hub. Every packet is a modes[] entry carrying the discriminator (workflowMode/packetKind/backendKind) plus its advisorRouting contract. The WORKFLOW axis (implement/quality/debug/verify/review) is process; the SURFACE axis (webflow/opencode/animation) is read-only domain evidence. The advisor routes the single identity sk-code; the hub resolves the workflow mode and bundles surface packets as evidence.",
  "discriminator": {
    "workflowMode": "Public hub/mode key. Stable identity used by the hub router and this registry. Carried by every mode.",
    "packetKind": "The axis discriminator: 'workflow' for process modes that act, 'surface' for read-only domain-evidence packets bundled alongside a workflow mode.",
    "backendKind": "Which backend runs the mode: surface-router for surface-aware code workflows, review-cache for review output caching, evidence-base for read-only surface packets."
  },
  "advisorRoutingContract": {
    "routingClass": "How the advisor finds the mode. For sk-code every mode is 'metadata' = resolved by hub membership; the advisor routes the single identity sk-code and the hub picks the mode. Surface packets are advisor-invisible and reached only by hub bundling.",
    "packetSkillName": "The packet's SKILL.md name. Folder equals packetSkillName for every mode.",
    "grandfatheredFolderMismatch": "false for every mode because folder equals packetSkillName."
  },
  "extensions": {
    "surface-axis": {
      "description": "Declares the SURFACE axis. packetKind:'surface' entries are read-only domain-evidence packets (backendKind:'evidence-base', routingClass:'metadata', mutatesWorkspace:false) bundled alongside a workflow mode via routerPolicy.outcomes.surfaceBundle. They carry stack knowledge, never process.",
      "surfacePackets": ["webflow", "opencode", "animation"]
    }
  },
  "modes": [
