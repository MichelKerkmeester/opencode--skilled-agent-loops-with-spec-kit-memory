   298	
   299	// F-004-A4-01: previously a bare `catch {}` swallowed every SQLite read error
   300	// and silently fell back to the filesystem projection, hiding corrupt-DB and
   301	// schema-drift failures from operators. We now distinguish three cases:
   302	//   1. SQLite read succeeded → return that projection ('sqlite').
   303	//   2. SQLite DB does not exist yet → loadSqliteProjection returns null and we
   304	//      fall through to a clean 'filesystem' projection (legitimate first run).
   305	//   3. SQLite read THREW → we still degrade to filesystem so the daemon stays
   306	//      up, but the projection is tagged 'filesystem-fallback' with a
   307	//      fallbackReason carrying the underlying error message AND the failure
   308	//      is logged via console.warn so it surfaces in daemon logs.
   309	export function loadAdvisorProjection(workspaceRoot: string): AdvisorProjection {
   310	  const resolvedRoot = resolve(workspaceRoot);
   311	  try {
   312	    const sqliteProjection = loadSqliteProjection(resolvedRoot);
   313	    if (sqliteProjection !== null) return sqliteProjection;
   314	    return loadFilesystemProjection(resolvedRoot);
   315	  } catch (error: unknown) {
   316	    const reason = error instanceof Error ? error.message : String(error);
   317	    console.warn(`[advisor-projection] SQLite projection failed; degraded to filesystem fallback: ${reason}`);
   318	    const fallback = loadFilesystemProjection(resolvedRoot);
   319	    return {
   320	      ...fallback,
   321	      source: 'filesystem-fallback',
   322	      fallbackReason: reason,
   323	    };
   324	  }
   325	}
   326	
   327	export function createFixtureProjection(
   328	  skills: readonly SkillProjection[],
   329	  edges: readonly SkillEdgeProjection[] = [],
   330	): AdvisorProjection {
   331	  return {
   332	    skills,
   333	    edges,
   334	    generatedAt: new Date().toISOString(),
   335	    source: 'fixture',
   336	  };
   337	}

