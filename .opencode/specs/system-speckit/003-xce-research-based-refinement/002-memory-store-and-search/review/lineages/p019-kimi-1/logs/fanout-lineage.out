{"type":"tool_use","timestamp":1781719966659,"sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","part":{"type":"tool","tool":"read","callID":"tool_mLvRcU39KguXePzOINEIocSS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { createRequire } from 'node:module';\n2: \n3: import { describe, expect, it } from 'vitest';\n4: \n5: type MaintenanceMarker = {\n6:   childPid: number;\n7:   activeUntilMs: number;\n8:   jobId?: string;\n9:   refreshedAtIso?: string;\n10: };\n11: \n12: const require = createRequire(import.meta.url);\n13: const launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n14:   readMaintenanceMarker: (\n15:     dbDir: string,\n16:     options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n17:   ) => MaintenanceMarker | null;\n18:   shouldAdoptDespiteProbe: (options?: {\n19:     marker?: MaintenanceMarker | null;\n20:     childPid?: number;\n21:     childLiveness?: string;\n22:     nowMs?: number | (() => number);\n23:   }) => boolean;\n24: };\n25: \n26: describe('launcher maintenance-active adopt guard', () => {\n27:   const NOW = Date.parse('2026-06-09T00:00:00.000Z');\n28:   const freshMarker = (childPid: number): MaintenanceMarker => ({\n29:     childPid,\n30:     activeUntilMs: NOW + 30_000,\n31:     jobId: 'index-scan-1',\n32:     refreshedAtIso: '2026-06-09T00:00:00.000Z',\n33:   });\n34: \n35:   it('adopts a fresh marker that names this exact live child (a)', () => {\n36:     // Busy-by-design: the marker is unexpired, names the probed child, and the\n37:     // child is alive — the only case where adoption beats reaping.\n38:     expect(\n39:       launcher.shouldAdoptDespiteProbe({\n40:         marker: freshMarker(4242),\n41:         childPid: 4242,\n42:         childLiveness: 'alive',\n43:         nowMs: NOW,\n44:       }),\n45:     ).toBe(true);\n46:   });\n47: \n48:   it('reaps once the marker has expired (b)', () => {\n49:     // A genuinely wedged daemon cannot fire its refresh timer, so the marker\n50:     // ages out (activeUntilMs <= nowMs) and normal reaping must resume.\n51:     expect(\n52:       launcher.shouldAdoptDespiteProbe({\n53:         marker: { ...freshMarker(4242), activeUntilMs: NOW },\n54:         childPid: 4242,\n55:         childLiveness: 'alive',\n56:         nowMs: NOW,\n57:       }),\n58:     ).toBe(false);\n59:   });\n60: \n61:   it('reaps when the marker names a different child (c)', () => {\n62:     // A marker left over from a prior daemon child must never pin the current\n63:     // one; a childPid mismatch falls through to the reap path.\n64:     expect(\n65:       launcher.shouldAdoptDespiteProbe({\n66:         marker: freshMarker(4242),\n67:         childPid: 9999,\n68:         childLiveness: 'alive',\n69:         nowMs: NOW,\n70:       }),\n71:     ).toBe(false);\n72:   });\n73: \n74:   it('reaps when the probed child is dead (d)', () => {\n75:     expect(\n76:       launcher.shouldAdoptDespiteProbe({\n77:         marker: freshMarker(4242),\n78:         childPid: 4242,\n79:         childLiveness: 'dead',\n80:         nowMs: NOW,\n81:       }),\n82:     ).toBe(false);\n83:   });\n84: \n85:   it('reaps when liveness is unknown-eperm rather than confirmably alive (e)', () => {\n86:     // Fail-safe toward reaping: anything other than a confirmed 'alive' must not\n87:     // adopt, so an EPERM-masked liveness does not pin a possibly-dead daemon.\n88:     expect(\n89:       launcher.shouldAdoptDespiteProbe({\n90:         marker: freshMarker(4242),\n91:         childPid: 4242,\n92:         childLiveness: 'unknown-eperm',\n93:         nowMs: NOW,\n94:       }),\n95:     ).toBe(false);\n96:   });\n97: \n98:   it('reaps when there is no marker at all (f)', () => {\n99:     expect(\n100:       launcher.shouldAdoptDespiteProbe({\n101:         marker: null,\n102:         childPid: 4242,\n103:         childLiveness: 'alive',\n104:         nowMs: NOW,\n105:       }),\n106:     ).toBe(false);\n107:   });\n108: \n109:   it('reaps for an invalid childPid (0 / non-integer) (g)', () => {\n110:     for (const childPid of [0, -1, 4242.5, Number.NaN] as number[]) {\n111:       expect(\n112:         launcher.shouldAdoptDespiteProbe({\n113:           marker: freshMarker(4242),\n114:           childPid,\n115:           childLiveness: 'alive',\n116:           nowMs: NOW,\n117:         }),\n118:       ).toBe(false);\n119:     }\n120:   });\n121: });\n122: \n123: describe('launcher maintenance marker reader (injected fs)', () => {\n124:   const injectFs = (readFileSync: (path: string) => string) =>\n125:     ({ fs: { readFileSync } });\n126: \n127:   it('returns the parsed object for a valid marker (a)', () => {\n128:     const marker = {\n129:       childPid: 4242,\n130:       activeUntilMs: 1_700_000_000_000,\n131:       jobId: 'index-scan-1',\n132:       refreshedAtIso: '2026-06-09T00:00:00.000Z',\n133:     };\n134:     expect(\n135:       launcher.readMaintenanceMarker('/db', injectFs(() => JSON.stringify(marker))),\n136:     ).toEqual(marker);\n137:   });\n138: \n139:   it('returns null when the marker file is missing (ENOENT) (b)', () => {\n140:     expect(\n141:       launcher.readMaintenanceMarker('/db', injectFs(() => {\n142:         throw Object.assign(new Error('no such file'), { code: 'ENOENT' });\n143:       })),\n144:     ).toBeNull();\n145:   });\n146: \n147:   it('returns null for corrupt JSON (c)', () => {\n148:     expect(\n149:       launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n150:     ).toBeNull();\n151:   });\n152: \n153:   it('returns null when childPid is missing (d)', () => {\n154:     expect(\n155:       launcher.readMaintenanceMarker(\n156:         '/db',\n157:         injectFs(() => JSON.stringify({ activeUntilMs: 1_700_000_000_000, jobId: 'x' })),\n158:       ),\n159:     ).toBeNull();\n160:   });\n161: \n162:   it('returns null when activeUntilMs is non-finite (e)', () => {\n163:     expect(\n164:       launcher.readMaintenanceMarker(\n165:         '/db',\n166:         // JSON.stringify turns Infinity into null, which is non-finite by the\n167:         // reader's Number.isFinite gate — the canonical corrupt-time shape.\n168:         injectFs(() => JSON.stringify({ childPid: 4242, activeUntilMs: Infinity })),\n169:       ),\n170:     ).toBeNull();\n171:   });\n172: });\n\n(End of file - total 172 lines)\n</content>","metadata":{"preview":"import { createRequire } from 'node:module';\n\nimport { describe, expect, it } from 'vitest';\n\ntype MaintenanceMarker = {\n  childPid: number;\n  activeUntilMs: number;\n  jobId?: string;\n  refreshedAtIso?: string;\n};\n\nconst require = createRequire(import.meta.url);\nconst launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n  readMaintenanceMarker: (\n    dbDir: string,\n    options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n  ) => MaintenanceMarker | null;\n  shouldAdoptDespiteProbe: (options?: {\n    marker?: MaintenanceMarker | null;\n    childPid?: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","text":"import { createRequire } from 'node:module';\n\nimport { describe, expect, it } from 'vitest';\n\ntype MaintenanceMarker = {\n  childPid: number;\n  activeUntilMs: number;\n  jobId?: string;\n  refreshedAtIso?: string;\n};\n\nconst require = createRequire(import.meta.url);\nconst launcher = require('../../../../bin/mk-spec-memory-launcher.cjs') as {\n  readMaintenanceMarker: (\n    dbDir: string,\n    options?: { fs?: { readFileSync?: (path: string, encoding?: string) => string } },\n  ) => MaintenanceMarker | null;\n  shouldAdoptDespiteProbe: (options?: {\n    marker?: MaintenanceMarker | null;\n    childPid?: number;\n    childLiveness?: string;\n    nowMs?: number | (() => number);\n  }) => boolean;\n};\n\ndescribe('launcher maintenance-active adopt guard', () => {\n  const NOW = Date.parse('2026-06-09T00:00:00.000Z');\n  const freshMarker = (childPid: number): MaintenanceMarker => ({\n    childPid,\n    activeUntilMs: NOW + 30_000,\n    jobId: 'index-scan-1',\n    refreshedAtIso: '2026-06-09T00:00:00.000Z',\n  });\n\n  it('adopts a fresh marker that names this exact live child (a)', () => {\n    // Busy-by-design: the marker is unexpired, names the probed child, and the\n    // child is alive — the only case where adoption beats reaping.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(true);\n  });\n\n  it('reaps once the marker has expired (b)', () => {\n    // A genuinely wedged daemon cannot fire its refresh timer, so the marker\n    // ages out (activeUntilMs <= nowMs) and normal reaping must resume.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: { ...freshMarker(4242), activeUntilMs: NOW },\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when the marker names a different child (c)', () => {\n    // A marker left over from a prior daemon child must never pin the current\n    // one; a childPid mismatch falls through to the reap path.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 9999,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when the probed child is dead (d)', () => {\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'dead',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when liveness is unknown-eperm rather than confirmably alive (e)', () => {\n    // Fail-safe toward reaping: anything other than a confirmed 'alive' must not\n    // adopt, so an EPERM-masked liveness does not pin a possibly-dead daemon.\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: freshMarker(4242),\n        childPid: 4242,\n        childLiveness: 'unknown-eperm',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps when there is no marker at all (f)', () => {\n    expect(\n      launcher.shouldAdoptDespiteProbe({\n        marker: null,\n        childPid: 4242,\n        childLiveness: 'alive',\n        nowMs: NOW,\n      }),\n    ).toBe(false);\n  });\n\n  it('reaps for an invalid childPid (0 / non-integer) (g)', () => {\n    for (const childPid of [0, -1, 4242.5, Number.NaN] as number[]) {\n      expect(\n        launcher.shouldAdoptDespiteProbe({\n          marker: freshMarker(4242),\n          childPid,\n          childLiveness: 'alive',\n          nowMs: NOW,\n        }),\n      ).toBe(false);\n    }\n  });\n});\n\ndescribe('launcher maintenance marker reader (injected fs)', () => {\n  const injectFs = (readFileSync: (path: string) => string) =>\n    ({ fs: { readFileSync } });\n\n  it('returns the parsed object for a valid marker (a)', () => {\n    const marker = {\n      childPid: 4242,\n      activeUntilMs: 1_700_000_000_000,\n      jobId: 'index-scan-1',\n      refreshedAtIso: '2026-06-09T00:00:00.000Z',\n    };\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => JSON.stringify(marker))),\n    ).toEqual(marker);\n  });\n\n  it('returns null when the marker file is missing (ENOENT) (b)', () => {\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => {\n        throw Object.assign(new Error('no such file'), { code: 'ENOENT' });\n      })),\n    ).toBeNull();\n  });\n\n  it('returns null for corrupt JSON (c)', () => {\n    expect(\n      launcher.readMaintenanceMarker('/db', injectFs(() => 'not json {')),\n    ).toBeNull();\n  });\n\n  it('returns null when childPid is missing (d)', () => {\n    expect(\n      launcher.readMaintenanceMarker(\n        '/db',\n        injectFs(() => JSON.stringify({ activeUntilMs: 1_700_000_000_000, jobId: 'x' })),\n      ),\n    ).toBeNull();\n  });\n\n  it('returns null when activeUntilMs is non-finite (e)', () => {\n    expect(\n      launcher.readMaintenanceMarker(\n        '/db',\n        // JSON.stringify turns Infinity into null, which is non-finite by the\n        // reader's Number.isFinite gate — the canonical corrupt-time shape.\n        injectFs(() => JSON.stringify({ childPid: 4242, activeUntilMs: Infinity })),\n      ),\n    ).toBeNull();\n  });\n});","lineStart":1,"lineEnd":172,"totalLines":172,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/launcher-maintenance-guard.vitest.ts","time":{"start":1781719966647,"end":1781719966657}},"id":"prt_ed6c91f090010n0spL2Z2GNfrm","sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","messageID":"msg_ed6c8fb60001CDLS5WVi6ShwfM"}}
{"type":"tool_use","timestamp":1781719967479,"sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","part":{"type":"tool","tool":"read","callID":"tool_LYRfgSJC7BLrAkda2tcipNcf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2: import fs from 'fs';\n3: import path from 'path';\n4: import os from 'os';\n5: \n6: import {\n7:   beginMaintenance,\n8:   __resetMaintenanceMarkerForTest,\n9: } from '../lib/storage/maintenance-marker';\n10: import { resolveDatabasePaths } from '../core/config';\n11: \n12: const MARKER_FILE = '.maintenance-active.json';\n13: \n14: interface MarkerShape {\n15:   childPid: number;\n16:   activeUntilMs: number;\n17:   labels: string[];\n18:   refreshedAtIso: string;\n19: }\n20: \n21: let tmpDir: string;\n22: const originalSpecKitDbDir = process.env.SPEC_KIT_DB_DIR;\n23: const originalSpeckitDbDir = process.env.SPECKIT_DB_DIR;\n24: \n25: function markerPath(): string {\n26:   return path.join(tmpDir, MARKER_FILE);\n27: }\n28: \n29: function markerExists(): boolean {\n30:   return fs.existsSync(markerPath());\n31: }\n32: \n33: function readMarker(): MarkerShape {\n34:   return JSON.parse(fs.readFileSync(markerPath(), 'utf8')) as MarkerShape;\n35: }\n36: \n37: beforeEach(() => {\n38:   // Point DATABASE_DIR at a throwaway directory so the marker module's real-fs\n39:   // writes never touch a live database. The marker reads DATABASE_DIR as a live\n40:   // ESM binding, so reassigning it via resolveDatabasePaths() redirects writes.\n41:   tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintmarker.'));\n42:   process.env.SPEC_KIT_DB_DIR = tmpDir;\n43:   delete process.env.SPECKIT_DB_DIR;\n44:   resolveDatabasePaths();\n45: });\n46: \n47: afterEach(() => {\n48:   __resetMaintenanceMarkerForTest();\n49:   try {\n50:     fs.rmSync(tmpDir, { recursive: true, force: true });\n51:   } catch {\n52:     // Best-effort cleanup\n53:   }\n54:   if (originalSpecKitDbDir === undefined) {\n55:     delete process.env.SPEC_KIT_DB_DIR;\n56:   } else {\n57:     process.env.SPEC_KIT_DB_DIR = originalSpecKitDbDir;\n58:   }\n59:   if (originalSpeckitDbDir === undefined) {\n60:     delete process.env.SPECKIT_DB_DIR;\n61:   } else {\n62:     process.env.SPECKIT_DB_DIR = originalSpeckitDbDir;\n63:   }\n64:   // Re-resolve so a subsequent suite/test sees a consistent DATABASE_DIR.\n65:   resolveDatabasePaths();\n66: });\n67: \n68: describe('maintenance-marker', () => {\n69:   it('beginMaintenance writes a marker with this pid, a future TTL, and the label', () => {\n70:     const before = Date.now();\n71:     const handle = beginMaintenance('scan');\n72: \n73:     expect(markerExists()).toBe(true);\n74:     const marker = readMarker();\n75:     expect(marker.childPid).toBe(process.pid);\n76:     expect(marker.activeUntilMs).toBeGreaterThan(before);\n77:     expect(marker.labels).toContain('scan');\n78: \n79:     handle.end();\n80:   });\n81: \n82:   it('is reference-counted: marker persists until the LAST holder ends', () => {\n83:     const first = beginMaintenance('scan');\n84:     const second = beginMaintenance('embedding-queue');\n85: \n86:     expect(markerExists()).toBe(true);\n87:     let marker = readMarker();\n88:     expect(marker.labels).toContain('scan');\n89:     expect(marker.labels).toContain('embedding-queue');\n90: \n91:     // Ending the FIRST holder: marker must STILL exist (second is active).\n92:     // The on-disk file is only rewritten on a write event (begin/refresh/timer),\n93:     // so end() does NOT itself re-serialize the pruned label set — it just\n94:     // decrements the in-memory ref count. The reference-counting contract under\n95:     // test is file PERSISTENCE while >=1 holder remains.\n96:     first.end();\n97:     expect(markerExists()).toBe(true);\n98: \n99:     // The next write (refresh on the surviving holder) reflects the pruned label\n100:     // set, confirming the first holder's label was decremented from live state.\n101:     second.refresh();\n102:     marker = readMarker();\n103:     expect(marker.labels).toContain('embedding-queue');\n104:     expect(marker.labels).not.toContain('scan');\n105: \n106:     // Ending the SECOND (last) holder: marker is REMOVED.\n107:     second.end();\n108:     expect(markerExists()).toBe(false);\n109:   });\n110: \n111:   it('end() is idempotent: calling twice on the sole holder removes the file once and does not throw', () => {\n112:     const handle = beginMaintenance('scan');\n113:     expect(markerExists()).toBe(true);\n114: \n115:     expect(() => {\n116:       handle.end();\n117:       handle.end();\n118:     }).not.toThrow();\n119: \n120:     expect(markerExists()).toBe(false);\n121:   });\n122: \n123:   it('refresh() rewrites the marker with a non-decreasing activeUntilMs and a refreshed timestamp', () => {\n124:     const handle = beginMaintenance('scan');\n125:     const first = readMarker();\n126: \n127:     handle.refresh();\n128:     const second = readMarker();\n129: \n130:     // TTL is recomputed from Date.now(); never goes backwards on refresh.\n131:     expect(second.activeUntilMs).toBeGreaterThanOrEqual(first.activeUntilMs);\n132:     // refreshedAtIso must be a valid ISO timestamp and not predate the first write.\n133:     expect(Date.parse(second.refreshedAtIso)).toBeGreaterThanOrEqual(\n134:       Date.parse(first.refreshedAtIso),\n135:     );\n136:     expect(Number.isNaN(Date.parse(second.refreshedAtIso))).toBe(false);\n137: \n138:     handle.end();\n139:   });\n140: \n141:   it('removes the marker once all handles have ended', () => {\n142:     const a = beginMaintenance('scan');\n143:     const b = beginMaintenance('embedding-queue');\n144:     const c = beginMaintenance('checkpoint');\n145:     expect(markerExists()).toBe(true);\n146: \n147:     a.end();\n148:     b.end();\n149:     expect(markerExists()).toBe(true);\n150: \n151:     c.end();\n152:     expect(markerExists()).toBe(false);\n153:   });\n154: });\n\n(End of file - total 154 lines)\n</content>","metadata":{"preview":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\nimport {\n  beginMaintenance,\n  __resetMaintenanceMarkerForTest,\n} from '../lib/storage/maintenance-marker';\nimport { resolveDatabasePaths } from '../core/config';\n\nconst MARKER_FILE = '.maintenance-active.json';\n\ninterface MarkerShape {\n  childPid: number;\n  activeUntilMs: number;\n  labels: string[];\n  refreshedAtIso: string;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts","text":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\nimport {\n  beginMaintenance,\n  __resetMaintenanceMarkerForTest,\n} from '../lib/storage/maintenance-marker';\nimport { resolveDatabasePaths } from '../core/config';\n\nconst MARKER_FILE = '.maintenance-active.json';\n\ninterface MarkerShape {\n  childPid: number;\n  activeUntilMs: number;\n  labels: string[];\n  refreshedAtIso: string;\n}\n\nlet tmpDir: string;\nconst originalSpecKitDbDir = process.env.SPEC_KIT_DB_DIR;\nconst originalSpeckitDbDir = process.env.SPECKIT_DB_DIR;\n\nfunction markerPath(): string {\n  return path.join(tmpDir, MARKER_FILE);\n}\n\nfunction markerExists(): boolean {\n  return fs.existsSync(markerPath());\n}\n\nfunction readMarker(): MarkerShape {\n  return JSON.parse(fs.readFileSync(markerPath(), 'utf8')) as MarkerShape;\n}\n\nbeforeEach(() => {\n  // Point DATABASE_DIR at a throwaway directory so the marker module's real-fs\n  // writes never touch a live database. The marker reads DATABASE_DIR as a live\n  // ESM binding, so reassigning it via resolveDatabasePaths() redirects writes.\n  tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintmarker.'));\n  process.env.SPEC_KIT_DB_DIR = tmpDir;\n  delete process.env.SPECKIT_DB_DIR;\n  resolveDatabasePaths();\n});\n\nafterEach(() => {\n  __resetMaintenanceMarkerForTest();\n  try {\n    fs.rmSync(tmpDir, { recursive: true, force: true });\n  } catch {\n    // Best-effort cleanup\n  }\n  if (originalSpecKitDbDir === undefined) {\n    delete process.env.SPEC_KIT_DB_DIR;\n  } else {\n    process.env.SPEC_KIT_DB_DIR = originalSpecKitDbDir;\n  }\n  if (originalSpeckitDbDir === undefined) {\n    delete process.env.SPECKIT_DB_DIR;\n  } else {\n    process.env.SPECKIT_DB_DIR = originalSpeckitDbDir;\n  }\n  // Re-resolve so a subsequent suite/test sees a consistent DATABASE_DIR.\n  resolveDatabasePaths();\n});\n\ndescribe('maintenance-marker', () => {\n  it('beginMaintenance writes a marker with this pid, a future TTL, and the label', () => {\n    const before = Date.now();\n    const handle = beginMaintenance('scan');\n\n    expect(markerExists()).toBe(true);\n    const marker = readMarker();\n    expect(marker.childPid).toBe(process.pid);\n    expect(marker.activeUntilMs).toBeGreaterThan(before);\n    expect(marker.labels).toContain('scan');\n\n    handle.end();\n  });\n\n  it('is reference-counted: marker persists until the LAST holder ends', () => {\n    const first = beginMaintenance('scan');\n    const second = beginMaintenance('embedding-queue');\n\n    expect(markerExists()).toBe(true);\n    let marker = readMarker();\n    expect(marker.labels).toContain('scan');\n    expect(marker.labels).toContain('embedding-queue');\n\n    // Ending the FIRST holder: marker must STILL exist (second is active).\n    // The on-disk file is only rewritten on a write event (begin/refresh/timer),\n    // so end() does NOT itself re-serialize the pruned label set — it just\n    // decrements the in-memory ref count. The reference-counting contract under\n    // test is file PERSISTENCE while >=1 holder remains.\n    first.end();\n    expect(markerExists()).toBe(true);\n\n    // The next write (refresh on the surviving holder) reflects the pruned label\n    // set, confirming the first holder's label was decremented from live state.\n    second.refresh();\n    marker = readMarker();\n    expect(marker.labels).toContain('embedding-queue');\n    expect(marker.labels).not.toContain('scan');\n\n    // Ending the SECOND (last) holder: marker is REMOVED.\n    second.end();\n    expect(markerExists()).toBe(false);\n  });\n\n  it('end() is idempotent: calling twice on the sole holder removes the file once and does not throw', () => {\n    const handle = beginMaintenance('scan');\n    expect(markerExists()).toBe(true);\n\n    expect(() => {\n      handle.end();\n      handle.end();\n    }).not.toThrow();\n\n    expect(markerExists()).toBe(false);\n  });\n\n  it('refresh() rewrites the marker with a non-decreasing activeUntilMs and a refreshed timestamp', () => {\n    const handle = beginMaintenance('scan');\n    const first = readMarker();\n\n    handle.refresh();\n    const second = readMarker();\n\n    // TTL is recomputed from Date.now(); never goes backwards on refresh.\n    expect(second.activeUntilMs).toBeGreaterThanOrEqual(first.activeUntilMs);\n    // refreshedAtIso must be a valid ISO timestamp and not predate the first write.\n    expect(Date.parse(second.refreshedAtIso)).toBeGreaterThanOrEqual(\n      Date.parse(first.refreshedAtIso),\n    );\n    expect(Number.isNaN(Date.parse(second.refreshedAtIso))).toBe(false);\n\n    handle.end();\n  });\n\n  it('removes the marker once all handles have ended', () => {\n    const a = beginMaintenance('scan');\n    const b = beginMaintenance('embedding-queue');\n    const c = beginMaintenance('checkpoint');\n    expect(markerExists()).toBe(true);\n\n    a.end();\n    b.end();\n    expect(markerExists()).toBe(true);\n\n    c.end();\n    expect(markerExists()).toBe(false);\n  });\n});","lineStart":1,"lineEnd":154,"totalLines":154,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts","time":{"start":1781719967471,"end":1781719967477}},"id":"prt_ed6c923b9001ghqwti67t6XeGq","sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","messageID":"msg_ed6c8fb60001CDLS5WVi6ShwfM"}}
{"type":"tool_use","timestamp":1781719968233,"sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","part":{"type":"tool","tool":"read","callID":"tool_t9G0i4ZLzGBajSVnfTAlsjR6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","limit":120,"offset":330},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts</path>\n<type>file</type>\n<content>\n330:     track(newPid!);\n331: \n332:     // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n333:     expect(newPid).not.toBe(orphanPid);\n334:     await waitForExit(orphanPid!, 10_000);\n335:     expect(isAlive(orphanPid!)).toBe(false);\n336:     await delay(800);\n337: \n338:     // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n339:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n340:     expect(dbWriters.length).toBe(1);\n341:   }, 60_000);\n342: \n343:   it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n344:     const paths = buildFakeRoot();\n345: \n346:     const owner = await startSession(paths, true);\n347:     expect(await statsOk(owner.client)).toBe(true);\n348:     const orphanPid = leaseDaemonPid(paths.base);\n349:     expect(orphanPid).toBeTypeOf('number');\n350:     track(orphanPid!);\n351: \n352:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n353:     owner.child.kill('SIGTERM');\n354:     await waitForExit(owner.child.pid!, 8_000);\n355:     await delay(1_200);\n356:     expect(isAlive(orphanPid!)).toBe(true);\n357: \n358:     // Publish a FRESH maintenance marker naming the live child: the daemon is mid-scan and is\n359:     // intentionally too busy to service the probe. The launcher resolves the marker dir from\n360:     // SPEC_KIT_DB_DIR (paths.dbDir), the same dir leaseDaemonPid reads.\n361:     writeFileSync(\n362:       join(paths.dbDir, '.maintenance-active.json'),\n363:       JSON.stringify({\n364:         childPid: orphanPid,\n365:         activeUntilMs: Date.now() + 60_000,\n366:         jobId: 'test',\n367:         refreshedAtIso: new Date().toISOString(),\n368:       }),\n369:     );\n370: \n371:     // WEDGE the marked daemon so the ADOPTION probe will NOT reply: SIGSTOP freezes its event loop —\n372:     // the exact observable shape of a daemon CPU-blocked mid index-scan. A pre-fix launcher that\n373:     // probes on liveness alone would reap a daemon doing legitimate maintenance; the fix reads the\n374:     // fresh marker, recognizes \"busy, not dead\", and REFUSES the respawn.\n375:     process.kill(orphanPid!, 'SIGSTOP');\n376: \n377:     // A competing launcher arrives with a short probe so its not-responsive verdict is fast and\n378:     // deterministic. The maintenance-grace contract is to ADOPT/refuse-respawn the busy daemon (it is\n379:     // reported lease-held and exits 0), NOT to bridge this contender into a live transport — so we\n380:     // observe the launcher's decision and the daemon's survival, not a working MCP call through it.\n381:     const compete = await spawnCompetingLauncher(paths, {\n382:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n383:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n384:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n385:     });\n386:     await waitForExit(compete.child.pid!, 20_000);\n387:     const settled = compete.settled();\n388:     // The competing launcher refused to respawn the busy daemon and reported lease-held, then exited 0.\n389:     expect(settled.exited).toBe(true);\n390:     expect(settled.code).toBe(0);\n391:     expect(settled.stdout).toMatch(/LEASE_HELD_BY/);\n392:     expect(settled.stdout).toMatch(/maintenance-active/);\n393: \n394:     // Let the marked daemon run again so teardown and the writer checks see a normal process.\n395:     process.kill(orphanPid!, 'SIGCONT');\n396:     await delay(800);\n397: \n398:     // Adoption invariant: the FRESH marker pins the busy daemon. It is reused (same pid, still alive),\n399:     // never reaped and respawned, despite the probe failing while it was stopped.\n400:     expect(leaseDaemonPid(paths.base)).toBe(orphanPid);\n401:     expect(isAlive(orphanPid!)).toBe(true);\n402: \n403:     // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n404:     const dbWriters = sqliteOpenerPids(paths.dbDir);\n405:     expect(dbWriters.length).toBe(1);\n406:   }, 60_000);\n407: \n408:   it('a STALE maintenance marker does NOT block reaping a wedged daemon', async () => {\n409:     const paths = buildFakeRoot();\n410: \n411:     const owner = await startSession(paths, true);\n412:     expect(await statsOk(owner.client)).toBe(true);\n413:     const orphanPid = leaseDaemonPid(paths.base);\n414:     expect(orphanPid).toBeTypeOf('number');\n415:     track(orphanPid!);\n416: \n417:     // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n418:     owner.child.kill('SIGTERM');\n419:     await waitForExit(owner.child.pid!, 8_000);\n420:     await delay(1_200);\n421:     expect(isAlive(orphanPid!)).toBe(true);\n422: \n423:     // Publish a STALE maintenance marker (already expired): it names the live child but its\n424:     // activeUntilMs is in the past, so the launcher must treat the daemon as unprotected.\n425:     writeFileSync(\n426:       join(paths.dbDir, '.maintenance-active.json'),\n427:       JSON.stringify({\n428:         childPid: orphanPid,\n429:         activeUntilMs: Date.now() - 1_000,\n430:         jobId: 'test',\n431:         refreshedAtIso: new Date().toISOString(),\n432:       }),\n433:     );\n434: \n435:     // WEDGE the released daemon. SIGSTOP freezes its event loop, so it never services a probe.\n436:     process.kill(orphanPid!, 'SIGSTOP');\n437: \n438:     // Fresh session with a short probe so the not-alive verdict is fast and deterministic.\n439:     const fresh = await startSession(paths, true, {\n440:       SPECKIT_PROBE_TIMEOUT_MS: '800',\n441:       SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n442:       SPECKIT_LEASE_PROBE_RETRIES: '0',\n443:     });\n444:     expect(await statsOk(fresh.client, 20_000)).toBe(true);\n445:     const newPid = leaseDaemonPid(paths.base);\n446:     expect(newPid).toBeTypeOf('number');\n447:     track(newPid!);\n448: \n449:     // Recovery invariant: the STALE marker does NOT pin the wedged daemon. It was reaped (not adopted)\n\n(Showing lines 330-449 of 488. Use offset=450 to continue.)\n</content>","metadata":{"preview":"    track(newPid!);\n\n    // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","text":"    track(newPid!);\n\n    // Recovery invariant: the wedged daemon was reaped (not adopted) and a fresh daemon replaced it.\n    expect(newPid).not.toBe(orphanPid);\n    await waitForExit(orphanPid!, 10_000);\n    expect(isAlive(orphanPid!)).toBe(false);\n    await delay(800);\n\n    // Single-writer invariant still holds: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a daemon holding a FRESH maintenance marker is ADOPTED, not reaped, despite a non-responsive probe', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Publish a FRESH maintenance marker naming the live child: the daemon is mid-scan and is\n    // intentionally too busy to service the probe. The launcher resolves the marker dir from\n    // SPEC_KIT_DB_DIR (paths.dbDir), the same dir leaseDaemonPid reads.\n    writeFileSync(\n      join(paths.dbDir, '.maintenance-active.json'),\n      JSON.stringify({\n        childPid: orphanPid,\n        activeUntilMs: Date.now() + 60_000,\n        jobId: 'test',\n        refreshedAtIso: new Date().toISOString(),\n      }),\n    );\n\n    // WEDGE the marked daemon so the ADOPTION probe will NOT reply: SIGSTOP freezes its event loop —\n    // the exact observable shape of a daemon CPU-blocked mid index-scan. A pre-fix launcher that\n    // probes on liveness alone would reap a daemon doing legitimate maintenance; the fix reads the\n    // fresh marker, recognizes \"busy, not dead\", and REFUSES the respawn.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // A competing launcher arrives with a short probe so its not-responsive verdict is fast and\n    // deterministic. The maintenance-grace contract is to ADOPT/refuse-respawn the busy daemon (it is\n    // reported lease-held and exits 0), NOT to bridge this contender into a live transport — so we\n    // observe the launcher's decision and the daemon's survival, not a working MCP call through it.\n    const compete = await spawnCompetingLauncher(paths, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    await waitForExit(compete.child.pid!, 20_000);\n    const settled = compete.settled();\n    // The competing launcher refused to respawn the busy daemon and reported lease-held, then exited 0.\n    expect(settled.exited).toBe(true);\n    expect(settled.code).toBe(0);\n    expect(settled.stdout).toMatch(/LEASE_HELD_BY/);\n    expect(settled.stdout).toMatch(/maintenance-active/);\n\n    // Let the marked daemon run again so teardown and the writer checks see a normal process.\n    process.kill(orphanPid!, 'SIGCONT');\n    await delay(800);\n\n    // Adoption invariant: the FRESH marker pins the busy daemon. It is reused (same pid, still alive),\n    // never reaped and respawned, despite the probe failing while it was stopped.\n    expect(leaseDaemonPid(paths.base)).toBe(orphanPid);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Airtight co-residency check: exactly one pid holds the sqlite open under the DB dir.\n    const dbWriters = sqliteOpenerPids(paths.dbDir);\n    expect(dbWriters.length).toBe(1);\n  }, 60_000);\n\n  it('a STALE maintenance marker does NOT block reaping a wedged daemon', async () => {\n    const paths = buildFakeRoot();\n\n    const owner = await startSession(paths, true);\n    expect(await statsOk(owner.client)).toBe(true);\n    const orphanPid = leaseDaemonPid(paths.base);\n    expect(orphanPid).toBeTypeOf('number');\n    track(orphanPid!);\n\n    // Dispose the owner: with reelection the daemon is RELEASED (survives), not killed.\n    owner.child.kill('SIGTERM');\n    await waitForExit(owner.child.pid!, 8_000);\n    await delay(1_200);\n    expect(isAlive(orphanPid!)).toBe(true);\n\n    // Publish a STALE maintenance marker (already expired): it names the live child but its\n    // activeUntilMs is in the past, so the launcher must treat the daemon as unprotected.\n    writeFileSync(\n      join(paths.dbDir, '.maintenance-active.json'),\n      JSON.stringify({\n        childPid: orphanPid,\n        activeUntilMs: Date.now() - 1_000,\n        jobId: 'test',\n        refreshedAtIso: new Date().toISOString(),\n      }),\n    );\n\n    // WEDGE the released daemon. SIGSTOP freezes its event loop, so it never services a probe.\n    process.kill(orphanPid!, 'SIGSTOP');\n\n    // Fresh session with a short probe so the not-alive verdict is fast and deterministic.\n    const fresh = await startSession(paths, true, {\n      SPECKIT_PROBE_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRY_TIMEOUT_MS: '800',\n      SPECKIT_LEASE_PROBE_RETRIES: '0',\n    });\n    expect(await statsOk(fresh.client, 20_000)).toBe(true);\n    const newPid = leaseDaemonPid(paths.base);\n    expect(newPid).toBeTypeOf('number');\n    track(newPid!);\n\n    // Recovery invariant: the STALE marker does NOT pin the wedged daemon. It was reaped (not adopted)","lineStart":330,"lineEnd":449,"totalLines":488,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-reelection-adoption-live.vitest.ts","time":{"start":1781719968222,"end":1781719968232}},"id":"prt_ed6c926f0001EEp9MenLsEfWzL","sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","messageID":"msg_ed6c8fb60001CDLS5WVi6ShwfM"}}
