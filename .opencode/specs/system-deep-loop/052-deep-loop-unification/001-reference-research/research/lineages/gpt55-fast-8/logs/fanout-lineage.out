.join(researchDir, 'deep-research-findings-registry.json');\n2522:   const dashboardPath = path.join(researchDir, 'deep-research-dashboard.md');\n2523:   const resourceMapPath = path.join(researchDir, 'resource-map.md');\n2524:   const inboxPath = path.join(researchDir, INBOX_FILE_NAME);\n2525:   const iterationDir = path.join(researchDir, 'iterations');\n2526:   const deltaDir = path.join(researchDir, 'deltas');\n2527: \n2528:   const config = readJson(configPath);\n2529:   const { records: parsedRecords, corruptionWarnings } = readStateLogForReduction(stateLogPath, requireExistingState);\n2530:   // Allowlist: only iteration + event types bear completion semantics. Progress\n2531:   // records (type:'progress') are additive liveness signals — they reset the\n2532:   // no-progress watchdog but MUST NOT count as iterations or completion events.\n2533:   const completionBearingRecords = filterCompletionBearingRecords(parsedRecords);\n2534:   const records = completionBearingRecords.filter((record) => record.type === 'iteration');\n2535:   const events = completionBearingRecords.filter((record) => record.type === 'event');\n2536:   const strategyContent = readUtf8(strategyPath);\n2537:   const strategyQuestions = parseStrategyQuestions(strategyContent);\n2538:   const inbox = readInboxQuestions(inboxPath);\n2539:   const priorRegistry = readPriorQuestionRegistry(registryPath, documentedRegistryPath);\n2540:   const questionResolution = resolveQuestionConflicts({\n2541:     strategyQuestions,\n2542:     inboxQuestions: inbox.questions,\n2543:     priorRegistry,\n2544:   });\n2545:   const questionInputs = questionResolution.questions;\n2546:   if (write) {\n2547:     warnLegacyImportQuestions(questionInputs);\n2548:   }\n2549:   for (const warning of inbox.warnings) {\n2550:     console.warn(`[deep-research] skipped inbox record: ${warning}`);\n2551:   }\n2552:   const iterationFiles = fs.existsSync(iterationDir)\n2553:     ? fs.readdirSync(iterationDir)\n2554:         .filter((fileName) => /^iteration-\\d+\\.md$/.test(fileName))\n2555:         .sort((a, b) => {\n2556:           // Numeric sort on trailing iter number; default .sort() puts iteration-10.md between iteration-1.md and iteration-2.md.\n2557:           const numA = parseInt(a.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n2558:           const numB = parseInt(b.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n2559:           return numA - numB;\n2560:         })\n2561:         .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))\n2562:     : [];\n2563: \n2564:   const terminalStop = buildTerminalStopState(completionBearingRecords);\n2565:   const lineage = buildLineageState(config, events);\n2566:   config.lineage = {\n2567:     ...(config.lineage && typeof config.lineage === 'object' ? config.lineage : {}),\n2568:     sessionId: lineage.sessionId,\n2569:     parentSessionId: lineage.parentSessionId,\n2570:     lineageMode: lineage.lineageMode,\n2571:     generation: lineage.generation,\n2572:     continuedFromRun: lineage.continuedFromRun,\n2573:   };\n2574:   const status = deriveDashboardStatus(config, records, events, terminalStop);\n2575:   const registry = buildRegistry(questionInputs, iterationFiles, records, events, {\n2576:     lineage,\n2577:     terminalStop,\n2578:     status,\n2579:     questionConflicts: questionResolution.questionConflicts,\n2580:     rejectedPatternFuzzyThreshold: resolveRejectedPatternFuzzyThreshold(config),\n2581:     minIdeaObservations: resolveMinIdeaObservations(config),\n2582:   });\n2583:   // Expose corruptionWarnings as a top-level registry field for parity with\n2584:   // deep-review.\n2585:   registry.corruptionWarnings = corruptionWarnings;\n2586:   registry.inboxPath = inboxPath;\n2587:   registry.inboxWarnings = inbox.warnings;\n2588:   registry.status = status;\n2589:   if (write) {\n2590:     for (const warning of registry.rejectedPatternWarnings) {\n2591:       console.warn(warning);\n2592:     }\n2593:   }\n2594:   const evidenceRecords = records.filter((record) => record.status !== 'thought');\n2595:   const ratioHistory = evidenceRecords\n2596:     .map((record) => (typeof record.newInfoRatio === 'number' ? record.newInfoRatio : null))\n2597:     .filter((value) => value !== null);\n2598:   const scoreHistory = evidenceRecords\n2599:     .map(readIterationScore)\n2600:     .filter(isFiniteNumber);\n2601:   registry.advisoryEvents = buildTrendFlatlineAdvisories(config, {\n2602:     newInfoRatio: ratioHistory,\n2603:     score: scoreHistory,\n2604:   }, evidenceRecords.at(-1));\n2605:   const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, records);\n2606:   const dashboard = renderDashboard(config, registry, records, iterationFiles);\n2607:   let resourceMap = null;\n2608:   let resourceMapSkipped = true;\n2609:   let resourceMapSkipReason = null;\n2610: \n2611:   if (corruptionWarnings.length > 0 && !lenient) {\n2612:     throw createCorruptionError(stateLogPath, corruptionWarnings);\n2613:   }\n2614: \n2615:   if (emitResourceMapOutput) {\n2616:     if (getResourceMapEmitSetting(config) === false) {\n2617:       resourceMapSkipReason = 'config.resource_map.emit=false';\n2618:     } else {\n2619:       const deltaPayloads = loadDeltaPayloads(deltaDir);\n2620:       if (!deltaPayloads.length) {\n2621:         resourceMapSkipReason = 'no delta files found';\n2622:       } else {\n2623:         resourceMap = emitResourceMap({\n2624:           shape: 'research',\n2625:           deltas: deltaPayloads,\n2626:           packet: {\n2627:             title: config.topic || path.basename(resolvedSpecFolder),\n2628:             specFolder: resolvedSpecFolder,\n2629:           },\n2630:           scope: `research convergence output for ${path.basename(resolvedSpecFolder)}`,\n2631:           createdAt: new Date().toISOString(),\n2632:         });\n2633:         resourceMapSkipped = false;\n2634:       }\n2635:     }\n2636:   }\n2637: \n2638:   if (write) {\n2639:     appendQuestionConflictEvents(stateLogPath, questionResolution.questionConflicts, events, {\n2640:       run: records.at(-1)?.run ?? null,\n2641:       sessionId: registry.sessionId || null,\n2642:       generation: registry.generation ?? null,\n2643:     });\n2644:     appendIdeaPromotionEvents(stateLogPath, registry.promotedIdeas, events, {\n2645:       run: records.at(-1)?.run ?? null,\n2646:       minIdeaObservations: registry.minIdeaObservations,\n2647:       sessionId: registry.sessionId || null,\n2648:       generation: registry.generation ?? null,\n2649:     });\n2650:     writeUtf8(registryPath, `${JSON.stringify(registry, null, 2)}\\n`);\n2651:     writeUtf8(strategyPath, strategy.endsWith('\\n') ? strategy : `${strategy}\\n`);\n2652:     writeUtf8(dashboardPath, dashboard);\n2653:     if (emitResourceMapOutput && resourceMap) {\n2654:       writeUtf8(resourceMapPath, resourceMap);\n2655:     }\n2656:   }\n2657: \n2658:   return {\n2659:     configPath,\n2660:     stateLogPath,\n2661:     strategyPath,\n2662:     registryPath,\n2663:     dashboardPath,\n2664:     resourceMapPath,\n2665:     registry,\n2666:     strategy,\n2667:     dashboard,\n2668:     resourceMap,\n2669:     resourceMapSkipped,\n2670:     resourceMapSkipReason,\n2671:     corruptionWarnings,\n2672:     hasCorruption: corruptionWarnings.length > 0,\n2673:   };\n2674: }\n2675: \n2676: // ─────────────────────────────────────────────────────────────────────────────\n2677: // 5. CLI ENTRY POINT\n2678: // ─────────────────────────────────────────────────────────────────────────────\n2679: \n2680: if (require.main === module) {\n2681:   const args = process.argv.slice(2);\n2682:   const lenient = args.includes('--lenient');\n2683:   const emitResourceMapOutput = args.includes('--emit-resource-map');\n2684:   const requireExistingState = args.includes('--require-existing-state');\n2685:   const positional = args.filter((arg) => !arg.startsWith('--'));\n2686:   const specFolder = positional[0];\n2687: \n2688:   if (!specFolder) {\n2689:     process.stderr.write(\n2690:       'Usage: node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs <spec-folder> [--lenient] [--emit-resource-map]\\n',\n2691:     );\n2692:     process.exit(1);\n2693:   }\n2694: \n2695:   try {\n2696:     const result = reduceResearchState(specFolder, {\n2697:       write: true,\n2698:       lenient,\n2699:       emitResourceMap: emitResourceMapOutput,\n2700:       requireExistingState,\n2701:     });\n2702:     process.stdout.write(\n2703:       `${JSON.stringify(\n2704:         {\n2705:           registryPath: result.registryPath,\n2706:           dashboardPath: result.dashboardPath,\n2707:           strategyPath: result.strategyPath,\n2708:           iterationsCompleted: result.registry.metrics.iterationsCompleted,\n2709:           corruptionCount: result.corruptionWarnings.length,\n2710:           resourceMapPath: emitResourceMapOutput ? result.resourceMapPath : null,\n2711:           resourceMapSkipped: emitResourceMapOutput ? result.resourceMapSkipped : null,\n2712:           resourceMapSkipReason: emitResourceMapOutput ? result.resourceMapSkipReason : null,\n2713:         },\n2714:         null,\n2715:         2,\n2716:       )}\\n`,\n2717:     );\n\n(Showing lines 2498-2717 of 2758. Use offset=2718 to continue.)\n</content>","metadata":{"preview":"  ].join('\\n');\n}\n\n/**\n * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n *\n * @param {string} specFolder - Path to the target spec folder for the research packet\n * @param {Object} [options] - Reducer options\n * @param {boolean} [options.write=true] - Write outputs to disk when true\n * @returns {Object} Paths and content for registry, strategy, and dashboard\n */\nfunction reduceResearchState(specFolder, options = {}) {\n  const write = options.write !== false;\n  const lenient = Boolean(options.lenient);\n  const emitResourceMapOutput = Boolean(options.emitResourceMap);\n  const requireExistingState = Boolean(options.requireExistingState);\n  const resolvedSpecFolder = path.resolve(specFolder);\n  const { artifactDir: researchDir } = resolveArtifactRoot(resolvedSpecFolder, 'research');\n  const configPath = path.join(researchDir, 'deep-research-config.json');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","text":"  ].join('\\n');\n}\n\n/**\n * Reduce JSONL state, iteration files, and strategy into synchronized registry,\n * strategy, and dashboard outputs. Idempotent: repeated calls produce identical results.\n *\n * @param {string} specFolder - Path to the target spec folder for the research packet\n * @param {Object} [options] - Reducer options\n * @param {boolean} [options.write=true] - Write outputs to disk when true\n * @returns {Object} Paths and content for registry, strategy, and dashboard\n */\nfunction reduceResearchState(specFolder, options = {}) {\n  const write = options.write !== false;\n  const lenient = Boolean(options.lenient);\n  const emitResourceMapOutput = Boolean(options.emitResourceMap);\n  const requireExistingState = Boolean(options.requireExistingState);\n  const resolvedSpecFolder = path.resolve(specFolder);\n  const { artifactDir: researchDir } = resolveArtifactRoot(resolvedSpecFolder, 'research');\n  const configPath = path.join(researchDir, 'deep-research-config.json');\n  const stateLogPath = path.join(researchDir, 'deep-research-state.jsonl');\n  const strategyPath = path.join(researchDir, 'deep-research-strategy.md');\n  const registryPath = path.join(researchDir, 'findings-registry.json');\n  const documentedRegistryPath = path.join(researchDir, 'deep-research-findings-registry.json');\n  const dashboardPath = path.join(researchDir, 'deep-research-dashboard.md');\n  const resourceMapPath = path.join(researchDir, 'resource-map.md');\n  const inboxPath = path.join(researchDir, INBOX_FILE_NAME);\n  const iterationDir = path.join(researchDir, 'iterations');\n  const deltaDir = path.join(researchDir, 'deltas');\n\n  const config = readJson(configPath);\n  const { records: parsedRecords, corruptionWarnings } = readStateLogForReduction(stateLogPath, requireExistingState);\n  // Allowlist: only iteration + event types bear completion semantics. Progress\n  // records (type:'progress') are additive liveness signals — they reset the\n  // no-progress watchdog but MUST NOT count as iterations or completion events.\n  const completionBearingRecords = filterCompletionBearingRecords(parsedRecords);\n  const records = completionBearingRecords.filter((record) => record.type === 'iteration');\n  const events = completionBearingRecords.filter((record) => record.type === 'event');\n  const strategyContent = readUtf8(strategyPath);\n  const strategyQuestions = parseStrategyQuestions(strategyContent);\n  const inbox = readInboxQuestions(inboxPath);\n  const priorRegistry = readPriorQuestionRegistry(registryPath, documentedRegistryPath);\n  const questionResolution = resolveQuestionConflicts({\n    strategyQuestions,\n    inboxQuestions: inbox.questions,\n    priorRegistry,\n  });\n  const questionInputs = questionResolution.questions;\n  if (write) {\n    warnLegacyImportQuestions(questionInputs);\n  }\n  for (const warning of inbox.warnings) {\n    console.warn(`[deep-research] skipped inbox record: ${warning}`);\n  }\n  const iterationFiles = fs.existsSync(iterationDir)\n    ? fs.readdirSync(iterationDir)\n        .filter((fileName) => /^iteration-\\d+\\.md$/.test(fileName))\n        .sort((a, b) => {\n          // Numeric sort on trailing iter number; default .sort() puts iteration-10.md between iteration-1.md and iteration-2.md.\n          const numA = parseInt(a.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n          const numB = parseInt(b.match(/iteration-(\\d+)\\.md$/)?.[1] ?? '0', 10);\n          return numA - numB;\n        })\n        .map((fileName) => parseIterationFile(path.join(iterationDir, fileName)))\n    : [];\n\n  const terminalStop = buildTerminalStopState(completionBearingRecords);\n  const lineage = buildLineageState(config, events);\n  config.lineage = {\n    ...(config.lineage && typeof config.lineage === 'object' ? config.lineage : {}),\n    sessionId: lineage.sessionId,\n    parentSessionId: lineage.parentSessionId,\n    lineageMode: lineage.lineageMode,\n    generation: lineage.generation,\n    continuedFromRun: lineage.continuedFromRun,\n  };\n  const status = deriveDashboardStatus(config, records, events, terminalStop);\n  const registry = buildRegistry(questionInputs, iterationFiles, records, events, {\n    lineage,\n    terminalStop,\n    status,\n    questionConflicts: questionResolution.questionConflicts,\n    rejectedPatternFuzzyThreshold: resolveRejectedPatternFuzzyThreshold(config),\n    minIdeaObservations: resolveMinIdeaObservations(config),\n  });\n  // Expose corruptionWarnings as a top-level registry field for parity with\n  // deep-review.\n  registry.corruptionWarnings = corruptionWarnings;\n  registry.inboxPath = inboxPath;\n  registry.inboxWarnings = inbox.warnings;\n  registry.status = status;\n  if (write) {\n    for (const warning of registry.rejectedPatternWarnings) {\n      console.warn(warning);\n    }\n  }\n  const evidenceRecords = records.filter((record) => record.status !== 'thought');\n  const ratioHistory = evidenceRecords\n    .map((record) => (typeof record.newInfoRatio === 'number' ? record.newInfoRatio : null))\n    .filter((value) => value !== null);\n  const scoreHistory = evidenceRecords\n    .map(readIterationScore)\n    .filter(isFiniteNumber);\n  registry.advisoryEvents = buildTrendFlatlineAdvisories(config, {\n    newInfoRatio: ratioHistory,\n    score: scoreHistory,\n  }, evidenceRecords.at(-1));\n  const strategy = updateStrategyContent(strategyContent, registry, iterationFiles, records);\n  const dashboard = renderDashboard(config, registry, records, iterationFiles);\n  let resourceMap = null;\n  let resourceMapSkipped = true;\n  let resourceMapSkipReason = null;\n\n  if (corruptionWarnings.length > 0 && !lenient) {\n    throw createCorruptionError(stateLogPath, corruptionWarnings);\n  }\n\n  if (emitResourceMapOutput) {\n    if (getResourceMapEmitSetting(config) === false) {\n      resourceMapSkipReason = 'config.resource_map.emit=false';\n    } else {\n      const deltaPayloads = loadDeltaPayloads(deltaDir);\n      if (!deltaPayloads.length) {\n        resourceMapSkipReason = 'no delta files found';\n      } else {\n        resourceMap = emitResourceMap({\n          shape: 'research',\n          deltas: deltaPayloads,\n          packet: {\n            title: config.topic || path.basename(resolvedSpecFolder),\n            specFolder: resolvedSpecFolder,\n          },\n          scope: `research convergence output for ${path.basename(resolvedSpecFolder)}`,\n          createdAt: new Date().toISOString(),\n        });\n        resourceMapSkipped = false;\n      }\n    }\n  }\n\n  if (write) {\n    appendQuestionConflictEvents(stateLogPath, questionResolution.questionConflicts, events, {\n      run: records.at(-1)?.run ?? null,\n      sessionId: registry.sessionId || null,\n      generation: registry.generation ?? null,\n    });\n    appendIdeaPromotionEvents(stateLogPath, registry.promotedIdeas, events, {\n      run: records.at(-1)?.run ?? null,\n      minIdeaObservations: registry.minIdeaObservations,\n      sessionId: registry.sessionId || null,\n      generation: registry.generation ?? null,\n    });\n    writeUtf8(registryPath, `${JSON.stringify(registry, null, 2)}\\n`);\n    writeUtf8(strategyPath, strategy.endsWith('\\n') ? strategy : `${strategy}\\n`);\n    writeUtf8(dashboardPath, dashboard);\n    if (emitResourceMapOutput && resourceMap) {\n      writeUtf8(resourceMapPath, resourceMap);\n    }\n  }\n\n  return {\n    configPath,\n    stateLogPath,\n    strategyPath,\n    registryPath,\n    dashboardPath,\n    resourceMapPath,\n    registry,\n    strategy,\n    dashboard,\n    resourceMap,\n    resourceMapSkipped,\n    resourceMapSkipReason,\n    corruptionWarnings,\n    hasCorruption: corruptionWarnings.length > 0,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. CLI ENTRY POINT\n// ─────────────────────────────────────────────────────────────────────────────\n\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const lenient = args.includes('--lenient');\n  const emitResourceMapOutput = args.includes('--emit-resource-map');\n  const requireExistingState = args.includes('--require-existing-state');\n  const positional = args.filter((arg) => !arg.startsWith('--'));\n  const specFolder = positional[0];\n\n  if (!specFolder) {\n    process.stderr.write(\n      'Usage: node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs <spec-folder> [--lenient] [--emit-resource-map]\\n',\n    );\n    process.exit(1);\n  }\n\n  try {\n    const result = reduceResearchState(specFolder, {\n      write: true,\n      lenient,\n      emitResourceMap: emitResourceMapOutput,\n      requireExistingState,\n    });\n    process.stdout.write(\n      `${JSON.stringify(\n        {\n          registryPath: result.registryPath,\n          dashboardPath: result.dashboardPath,\n          strategyPath: result.strategyPath,\n          iterationsCompleted: result.registry.metrics.iterationsCompleted,\n          corruptionCount: result.corruptionWarnings.length,\n          resourceMapPath: emitResourceMapOutput ? result.resourceMapPath : null,\n          resourceMapSkipped: emitResourceMapOutput ? result.resourceMapSkipped : null,\n          resourceMapSkipReason: emitResourceMapOutput ? result.resourceMapSkipReason : null,\n        },\n        null,\n        2,\n      )}\\n`,\n    );","lineStart":2498,"lineEnd":2717,"totalLines":2758,"truncated":true}},"title":".opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","time":{"start":1783487834076,"end":1783487834085}},"metadata":{"openai":{"itemId":"fc_05ffda1a8fc0b648016a4ddd58cd508191a1821efc51e6ad49"}},"id":"prt_f4028a2d200113znmcS3QWpXC1","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f40289935001pFUN7e5vDtva4k"}}
