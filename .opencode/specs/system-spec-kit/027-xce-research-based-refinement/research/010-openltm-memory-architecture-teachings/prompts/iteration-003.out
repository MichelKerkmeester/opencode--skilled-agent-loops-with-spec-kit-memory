c/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/janitor/index.ts:\n  Line 2:  * janitor/index.ts — Janitor orchestrator.\n\n  Line 15:   /** Whether the janitor is currently running. */\n\n  Line 45:  * Run all janitor tasks in sequence:\n\n  Line 152: /** Get current janitor status. */\n\n  Line 153: export function getJanitorStatus(): JanitorStatus {\n\n  Line 180: export function startAutoRun(): void {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/janitor/archive.ts:\n  Line 56:         actor: \"janitor:archive\",\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/janitor/providers/types.ts:\n  Line 2:  * types.ts — Provider interfaces for the janitor system.\n\n  Line 70: /** Settings keys used by the janitor for provider configuration. */\n\n  Line 105:   JANITOR_INTERVAL_MINUTES: \"ltm.janitor.intervalMinutes\",\n\n  Line 107:   JANITOR_LAST_RUN_AT:          \"ltm.janitor.lastRunAt\",\n\n  Line 108:   JANITOR_LAST_DECAY_REFRESHED: \"ltm.janitor.lastDecayRefreshed\",\n\n  Line 109:   JANITOR_LAST_DEPRECATED:      \"ltm.janitor.lastDeprecated\",\n\n  Line 110:   JANITOR_LAST_ARCHIVED:        \"ltm.janitor.lastArchived\",\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/janitor/providers/utils.ts:\n  Line 2:  * utils.ts — Shared helpers for all janitor providers.\n","metadata":{"matches":62,"truncated":false},"title":"startAutoRun|startJanitorScheduler|registerJanitorSchedule|getJanitorStatus|janitor","time":{"start":1780925365813,"end":1780925365845}},"metadata":{"openai":{"itemId":"fc_0513cea0