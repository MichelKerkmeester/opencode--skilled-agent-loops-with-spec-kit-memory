#!/usr/bin/env python3
"""Executable derivation of the {{SYSTEM_NAME}} copies (Prereq B).

  derive.py derive   -> regenerate the verbatim-copy surfaces from the configured source root
  derive.py check    -> verify every derived copy matches its source-of-truth; exit 1 on drift

The council's reuse-blocker: the copies are hand-maintained, not derived.
This makes the MECHANICAL half real: every shared knowledge doc is a verbatim copy of the
source, so it can be regenerated and sha-verified. Promotion regenerates these, never hand-edits
them.

Entries may override the source root per copy (src_root, e.g. "skill/assets" for asset
mirrors or "." for a SKILL.md byte-mirror); the default stays the configured source root.

The SYNTHESIZED surfaces are NOT mechanical copies, so they cannot be regenerated by code.
They are flagged here as synthesis-required: when their CLI source sections change, they need
an LLM/human re-derivation step (the loop must escalate, not auto-promote them).
"""
import hashlib
import os
import re
import shutil
import sys
from typing import Optional

# Layout: <packaging>/benchmark/_gates/derive.py -> packaging root is three levels up
HERE = os.path.dirname(os.path.abspath(__file__))
CW = os.environ.get("{{PACKAGING_ROOT_ENV}}") or os.path.dirname(os.path.dirname(HERE))
SOURCE_ROOT_LABEL = {{DERIVE_SOURCE_ROOT}}
SRC_ROOT = os.path.join(CW, SOURCE_ROOT_LABEL)

DERIVED = {{DERIVED_COPIES}}
SYNTHESIZED = {{SYNTHESIZED_SURFACES}}
SKILL_FRONTMATTER = {{SKILL_FRONTMATTER}}

_EMOJI_RE = re.compile("[\U0001F000-\U0001FAFF\u2600-\u27BF\u2B00-\u2BFF\uFE0F\u200D]")
# The do/don't markers stay
_EMOJI_KEEP = {"\u2705", "\u274C"}


def sha(p: str) -> Optional[str]:
    """Return the SHA-256 hex digest of a file, or None if it does not exist."""
    return hashlib.sha256(open(p, "rb").read()).hexdigest() if os.path.exists(p) else None


def _strip_for_skill(text: str) -> str:
    """Apply sk-doc alignment for skill copies: drop the TOC section and decorative emojis."""
    text = re.sub(r"\n## [^\n]*TABLE OF CONTENTS\n.*?(?=\n(?:## |---))", "", text, count=1, flags=re.S)
    text = _EMOJI_RE.sub(lambda m: m.group(0) if m.group(0) in _EMOJI_KEEP else "", text)
    text = re.sub(r"(#+ \d+\.) +", r"\1 ", text)
    return re.sub(r"^(#+) +", r"\1 ", text, flags=re.M)


def _skill_doc_bytes(src: str, skill_name: str, transform: str = "none") -> bytes:
    """Build deterministic skill-reference content: template frontmatter plus the CLI source
    (verbatim, or stripped per the sk-doc template when transform == "skill_strip")."""
    fm_entry = SKILL_FRONTMATTER.get(skill_name, {})
    title = fm_entry.get("title", skill_name.replace("_", " ").replace(".md", "").title())
    desc = fm_entry.get("description", "")
    fm = f"---\ntitle: {title}\ndescription: {desc}\n---\n\n"
    if transform == "skill_strip":
        body = _strip_for_skill(open(src, encoding="utf-8").read())
        return (fm + body).encode("utf-8")
    return fm.encode("utf-8") + open(src, "rb").read()


def derive() -> None:
    """Regenerate all derived copies from the configured source root."""
    n = 0
    for entry in DERIVED:
        src = os.path.join(CW, entry.get("src_root", SOURCE_ROOT_LABEL), entry["src_relpath"])
        for target in entry["targets"]:
            dst = os.path.join(CW, target["relpath"])
            os.makedirs(os.path.dirname(dst), exist_ok=True)
            if target.get("mode", "copy") == "symlink":
                # Shared-global doc: a relative symlink, never a copy (the global carries its own frontmatter)
                if os.path.islink(dst) or os.path.exists(dst):
                    os.remove(dst)
                os.symlink(target["link_target"], dst)
            elif target.get("is_skill_ref"):
                skill_name = target.get("skill_ref_basename", os.path.basename(target["relpath"]))
                open(dst, "wb").write(_skill_doc_bytes(src, skill_name, target.get("transform", "none")))
            else:
                shutil.copyfile(src, dst)
            n += 1
    print(f"Derived {n} copies from {SOURCE_ROOT_LABEL}.")
    if SYNTHESIZED:
        print("Synthesized surfaces NOT regenerated (need LLM/human re-derivation on source change):")
        for s in SYNTHESIZED:
            print("  - " + s)


def check() -> None:
    """Verify every derived copy matches its source-of-truth; exit 1 on drift."""
    drift = []
    for entry in DERIVED:
        src_root = entry.get("src_root", SOURCE_ROOT_LABEL)
        src = os.path.join(CW, src_root, entry["src_relpath"])
        ref = sha(src)
        if ref is None:
            drift.append(f"MISSING source: {src_root}/{entry['src_relpath']}")
            continue
        for target in entry["targets"]:
            dst = os.path.join(CW, target["relpath"])
            if target.get("mode", "copy") == "symlink":
                # Symlink targets are validated by link shape, not content sha
                if not os.path.islink(dst):
                    drift.append(f"NOT A SYMLINK: {target['relpath']} must link to {target['link_target']}")
                elif not os.path.exists(dst):
                    drift.append(f"BROKEN LINK: {target['relpath']} -> {os.readlink(dst)}")
                elif os.path.basename(os.path.realpath(dst)) != os.path.basename(target["link_target"]):
                    drift.append(f"WRONG TARGET: {target['relpath']} -> {os.readlink(dst)}")
                continue
            if target.get("is_skill_ref"):
                skill_name = target.get("skill_ref_basename", os.path.basename(target["relpath"]))
                expected = hashlib.sha256(_skill_doc_bytes(src, skill_name, target.get("transform", "none"))).hexdigest()
            else:
                expected = ref
            h = sha(dst)
            label = "skill" if target.get("is_skill_ref") else "copy"
            if h is None:
                drift.append(f"MISSING {label}: {target['relpath']}")
            elif h != expected:
                drift.append(f"DRIFT  {label} differs from source: {target['relpath']}")
    if drift:
        print("COPY DERIVATION DRIFT (loop must re-derive before promoting):")
        for d in drift:
            print("  - " + d)
        sys.exit(1)
    print(f"All {sum(len(e['targets']) for e in DERIVED)} derived copies match {SOURCE_ROOT_LABEL}. OK")
    if SYNTHESIZED:
        print("Note: synthesized surfaces are NOT checked here; they need synthesis re-derivation.")


if __name__ == "__main__":
    cmd = sys.argv[1] if len(sys.argv) > 1 else "check"
    {"derive": derive, "check": check}.get(cmd, lambda: (_ for _ in ()).throw(SystemExit(f"unknown cmd: {cmd}")))()
