ign\",\n48:     \"design-systems\",\n49:     \"motion-design\",\n50:     \"design-audit\",\n51:     \"design-tokens\"\n52:   ],\n53:   \"intent_signals\": [\n54:     \"design family\",\n55:     \"sk-design\",\n56:     \"make it look good\",\n57:     \"interface design\",\n58:     \"visual direction\",\n59:     \"design tokens\",\n60:     \"typography\",\n61:     \"color palette\",\n62:     \"layout system\",\n63:     \"motion design\",\n64:     \"micro-interactions\",\n65:     \"design audit\",\n66:     \"accessibility audit\",\n67:     \"DESIGN.md\",\n68:     \"style reference\",\n69:     \"open design\",\n70:     \"od cli\"\n71:   ],\n72:   \"derived\": {\n73:     \"trigger_phrases\": [\n74:       \"sk-design\",\n75:       \"design family\",\n76:       \"design router\",\n77:       \"make this look good\",\n78:       \"route design work\",\n79:       \"design tokens\",\n80:       \"motion design\",\n81:       \"design audit\",\n82:       \"DESIGN.md extraction\",\n83:       \"interface design\",\n84:       \"frontend design\",\n85:       \"visual design\",\n86:       \"make it look good\",\n87:       \"looks templated\",\n88:       \"redesign the ui\",\n89:       \"hero section\",\n90:       \"typography and palette\",\n91:       \"color palette\",\n92:       \"font pairing\",\n93:       \"ux quality checklist\",\n94:       \"give me N design variations\",\n95:       \"oklch palette\",\n96:       \"color token system\",\n97:       \"dark mode palette\",\n98:       \"typography scale\",\n99:       \"spacing system\",\n100:       \"responsive layout\",\n101:       \"animate this\",\n102:       \"micro-interactions\",\n103:       \"AnimatePresence\",\n104:       \"exit animation\",\n105:       \"reduced motion\",\n106:       \"morphing icons\",\n107:       \"motion performance\",\n108:       \"ui critique\",\n109:       \"accessibility audit\",\n110:       \"performance audit\",\n111:       \"anti-slop detection\",\n112:       \"production hardening\",\n113:       \"design quality score\",\n114:       \"P0 P1 design findings\",\n115:       \"extract design system\",\n116:       \"generate design.md\",\n117:       \"capture website css\",\n118:       \"design tokens from url\",\n119:       \"create design reference\",\n120:       \"design-to-markdown\",\n121:       \"extract design tokens\"\n122:     ],\n123:     \"key_topics\": [\n124:       \"sk-design\",\n125:       \"mode-registry\",\n126:       \"workflowMode\",\n127:       \"backendKind\",\n128:       \"reference-base\",\n129:       \"interface-mode\",\n130:       \"foundations-mode\",\n131:       \"motion-mode\",\n132:       \"audit-mode\",\n133:       \"md-generator-mode\",\n134:       \"shared-design-reference-base\",\n135:       \"anti-slop\",\n136:       \"design-token-vocabulary\",\n137:       \"cognitive-laws\"\n138:     ],\n139:     \"key_files\": [\n140:       \".opencode/skills/sk-design/SKILL.md\",\n141:       \".opencode/skills/sk-design/mode-registry.json\"\n142:     ],\n143:     \"entities\": [\n144:       {\n145:         \"name\": \"sk-design\",\n146:         \"kind\": \"skill\",\n147:         \"path\": \".opencode/skills/sk-design/SKILL.md\",\n148:         \"source\": \"derived\"\n149:       },\n150:       {\n151:         \"name\": \"mode-registry\",\n152:         \"kind\": \"config\",\n153:         \"path\": \".opencode/skills/sk-design/mode-registry.json\",\n154:         \"source\": \"derived\"\n155:       }\n156:     ],\n157:     \"causal_summary\": \"sk-design is the single public design skill that routes a request to one of five design modes (interface, foundations, motion, audit, md-generator) or one nested transport packet (design-mcp-open-design) by workflowMode through mode-registry.json. The five design modes share packetKind:\\\"workflow\\\"; design-mcp-open-design is the sole packetKind:\\\"transport\\\" entry, driving the external Open Design app's od CLI and stdio MCP server without performing design judgment itself. The four doc-guidance modes cite the shared reference base (anti-slop principles, cognitive laws, design-token vocabulary) for consistent vocabulary, md-generator runs its own Playwright CSS-extraction backend, and design-mcp-open-design runs an od-cli-transport backend (backendKind discriminates all three). The hub holds no per-mode design logic; every mode keeps its own judgment, examples, and verification in its packet, and all six route by hub membership so the advisor sees exactly one design identity.\",\n158:     \"source_docs\": [\n159:       \"SKILL.md\",\n160:       \"mode-registry.json\"\n161:     ],\n162:     \"created_at\": \"2026-06-25T00:00:00Z\",\n163:     \"last_updated_at\": \"2026-06-26T00:00:00Z\"\n164:   }\n165: }\n\n(End of file - total 165 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 2,\n  \"skill_id\": \"sk-design\",\n  \"family\": \"sk-code\",\n  \"category\": \"design\",\n  \"importance_tier\": \"important\",\n  \"edges\": {\n    \"depends_on\": [],\n    \"enhances\": [\n      {\n        \"target\": \"sk-code\",\n        \"weight\": 0.6,\n        \"context\": \"Design output (direction, foundations, motion, audit findings, DESIGN.md) feeds sk-code implementation in the detected code surface\"\n      }\n    ],\n    \"siblings\": [\n      {\n        \"target\": \"sk-code\",\n        \"weight\": 0.5,\n        \"context\": \"Design-and-build peer in the sk-code family; sk-design owns taste, sk-code owns implementation\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/graph-metadata.json","text":"{\n  \"schema_version\": 2,\n  \"skill_id\": \"sk-design\",\n  \"family\": \"sk-code\",\n  \"category\": \"design\",\n  \"importance_tier\": \"important\",\n  \"edges\": {\n    \"depends_on\": [],\n    \"enhances\": [\n      {\n        \"target\": \"sk-code\",\n        \"weight\": 0.6,\n        \"context\": \"Design output (direction, foundations, mo