  {\"id\": \"F2.3\", \"text\": \"Tooling-borrow net neutral; node_modules borrow already shipped (stale claim).\"},\n    {\"id\": \"F3.2\", \"text\": \"Advisor already has merge-identity layer (aliases.ts:92-109); system-deep-loop is SECOND fold = id-rename of MERGED_DEEP_SKILL_ID.\"},\n    {\"id\": \"F3.3\", \"text\": \"Divergence-ledger reason strings are historical narration; mechanical replace corrupts them (REQ-007 ratchet guard).\"},\n    {\"id\": \"F3.5\", \"text\": \"skill-graph.json generated; hand-edit trap; edit graph-metadata.json sources + re-scan.\"},\n    {\"id\": \"F3.6\", \"text\": \"orchestrate.md hardcodes mode-registry.json path 3x x2 agent trees = 6 critical edits.\"},\n    {\"id\": \"F4.2\", \"text\": \"Today's failure path is same-model retry-and-salvage (fanout-pool.cjs), not model-swap.\"},\n    {\"id\": \"F4.4\", \"text\": \"DEFER fallback-router wiring: zero merge-blocking dependency, no router-contract debt.\"}\n  ],\n  \"ruledOutDirections\": [\n    {\"id\": \"R1.1\", \"text\": \"Single mechanical find/replace.\"},\n    {\"id\": \"R1.2\", \"text\": \"Reverse as larger per-site risk.\"},\n    {\"id\": \"R2.1\", \"text\": \"Mechanism A forward-only.\"},\n    {\"id\": \"R2.2\", \"text\": \"4 system-spec-kit edits suffice.\"},\n    {\"id\": \"R2.3\", \"text\": \"tooling-borrow is net risk transfer.\"},\n    {\"id\": \"R3.1\", \"text\": \"Advisor needs from-scratch merge layer.\"},\n    {\"id\": \"R3.2\", \"text\": \"Hand-edit skill-graph.json.\"},\n    {\"id\": \"R3.3\", \"text\": \"Mechanical full-file replace on divergence ledger.\"},\n    {\"id\": \"R4.1\", \"text\": \"Wire fallback-router as part of the merge.\"},\n    {\"id\": \"R4.2\", \"text\": \"The merge forces fallback-router changes.\"}\n  ]\n}\n","filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/glm52-3/deep-research-findings-registry.json"},"output":"Wr