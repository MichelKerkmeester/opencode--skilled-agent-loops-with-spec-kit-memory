{"type":"tool_use","timestamp":1780929649417,"sessionID":"ses_15852ff63ffejJtpJJJcia0535","part":{"type":"tool","tool":"read","callID":"call_uUCSHyczju98x9YlHL87UQKM","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: import { existsSync, mkdirSync, readFileSync, writeFileSync, readdirSync } from \"fs\";\n3: import { join } from \"path\";\n4: import { homedir } from \"os\";\n5: import { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\n6: import { logHook, logEvent } from \"../lib/hookLogger.js\";\n7: import { EVENTS } from \"../lib/eventNames.js\";\n8: import { safeRun } from \"../lib/hookUtils.js\";\n9: import { extractProposals } from \"../lib/llmExtract.js\";\n10: import { writeProposals, type MemoryProposal } from \"../lib/proposalQueue.js\";\n11: import { readConfigSync } from \"../../src/config.js\";\n12: import type { Config } from \"../../src/config.js\";\n13: import { emitEvent } from \"@rohirik/openltm-core\";\n14: \n15: const PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"memory\");\n16: const LEARNED_DIR = join(PLUGIN_ROOT, \"skills\", \"Learned\");\n17: const PATTERNS_DIR = join(LEARNED_DIR, \"patterns\");\n18: const SUMMARY_FILE = join(LEARNED_DIR, \"summary.md\");\n19: const HISTORY_FILE = join(CLAUDE_DIR, \"history.jsonl\");\n20: const MAX_SUMMARY_LINES = 50;\n21: const SUMMARY_HEADER_LINES = 10;\n22: const MIN_SESSION_MESSAGES = 5; // Lowered for testing\n23: \n24: // Proposals dir: ${CLAUDE_PLUGIN_DATA}/proposals/ or fallback to plugin data dir\n25: const PLUGIN_DATA_DIR = process.env.CLAUDE_PLUGIN_DATA\n26:   ?? join(homedir(), \".claude\", \"plugins\", \"data\", \"OpenLtm-openltm\");\n27: const PROPOSALS_DIR = join(PLUGIN_DATA_DIR, \"proposals\");\n28: \n29: async function findTranscript(sessionId: string | undefined): Promise<{ path: string, id: string } | null> {\n30:   if (!existsSync(HISTORY_FILE)) return null;\n31: \n32:   const historyLines = readFileSync(HISTORY_FILE, \"utf-8\").trim().split('\\n');\n33:   if (historyLines.length === 0) return null;\n34: \n35:   // Find the entry matching sessionId, or the last one if not provided\n36:   let historyEntry: any = null;\n37:   if (sessionId) {\n38:     // Search backwards\n39:     for (let i = historyLines.length - 1; i >= 0; i--) {\n40:       try {\n41:         const line = JSON.parse(historyLines[i] ?? \"\");\n42:         if (line.sessionId === sessionId) {\n43:           historyEntry = line;\n44:           break;\n45:         }\n46:       } catch (e) {} // silent: malformed JSONL lines are expected and safely skipped\n47:     }\n48:   } else {\n49:     // Just take the last valid one\n50:     try {\n51:       historyEntry = JSON.parse(historyLines[historyLines.length - 1] ?? \"\");\n52:     } catch (e) {} // silent: malformed JSONL line is safely skipped\n53:   }\n54: \n55:   if (!historyEntry) return null;\n56: \n57:   const finalSessionId = historyEntry.sessionId;\n58:   const projectPath = historyEntry.project;\n59:   if (!finalSessionId || !projectPath) return null;\n60: \n61:   const filename = `${finalSessionId}.jsonl`;\n62: \n63:   // Try registry-resolved project dir first, then scan all project dirs for the session file\n64:   const { projectDir } = resolveProject(projectPath);\n65:   let transcriptPath = join(projectDir, filename);\n66: \n67:   if (!existsSync(transcriptPath)) {\n68:     // Claude Code may use a different slug format — scan all dirs\n69:     try {\n70:       const dirs = readdirSync(PROJECTS_DIR);\n71:       for (const dir of dirs) {\n72:         const candidate = join(PROJECTS_DIR, dir, filename);\n73:         if (existsSync(candidate)) {\n74:           transcriptPath = candidate;\n75:           break;\n76:         }\n77:       }\n78:     } catch (_) {} // silent: dir scan failure means we fall through to existsSync check\n79:   }\n80: \n81:   if (!existsSync(transcriptPath)) return null;\n82: \n83:   return { path: transcriptPath, id: finalSessionId };\n84: }\n85: \n86: function extractAssistantText(messages: any[]): string {\n87:   const parts: string[] = [];\n88:   for (const m of messages) {\n89:     const content = m?.message?.content;\n90:     if (!Array.isArray(content)) continue;\n91:     if (m?.message?.role !== \"assistant\") continue;\n92:     for (const block of content) {\n93:       if (block?.type === \"text\" && typeof block.text === \"string\")\n94:         parts.push(block.text.trim());\n95:     }\n96:   }\n97:   const full = parts.join(\"\\n\\n\");\n98:   return full.length > 8000 ? full.slice(-8000) : full;\n99: }\n100: \n101: async function main() {\n102:   let inputStr = \"\";\n103:   // Hook inputs are optional for this tool now, but we pass through stdin\n104:   try {\n105:     for await (const chunk of Bun.stdin.stream()) {\n106:       const text = new TextDecoder().decode(chunk);\n107:       inputStr += text;\n108:       process.stdout.write(chunk); // Pass through immediately\n109:     }\n110:   } catch (stdinErr) {\n111:     // Stdin might be empty or closed — non-fatal\n112:     logHook(\"EvaluateSession\", \"warn\", \"stdin read failed\", String(stdinErr));\n113:   }\n114: \n115:   let input: any = {};\n116:   try {\n117:     input = JSON.parse(inputStr);\n118:   } catch {\n119:     // Non-JSON input is acceptable — hooks may receive empty or plain-text stdin\n120:   }\n121: \n122:   {\n123:     let transcriptPath = input.transcript_path;\n124:     let sessionId = input.session_id;\n125: \n126:     if (!transcriptPath || !existsSync(transcriptPath)) {\n127:       const found = await findTranscript(sessionId);\n128:       if (found) {\n129:         transcriptPath = found.path;\n130:         sessionId = found.id;\n131:       }\n132:     }\n133: \n134:     if (!transcriptPath || !existsSync(transcriptPath)) {\n135:       return;\n136:     }\n137: \n138:     const transcriptContent = readFileSync(transcriptPath, \"utf-8\");\n139:     // Parse JSONL\n140:     const messages = transcriptContent.trim().split('\\n').map(l => {\n141:         try { return JSON.parse(l); } catch(e) { return null; }\n142:     }).filter(Boolean);\n143: \n144:     const messageCount = messages.length;\n145: \n146:     if (messageCount < MIN_SESSION_MESSAGES) {\n147:       return;\n148:     }\n149: \n150:     if (!existsSync(PATTERNS_DIR)) mkdirSync(PATTERNS_DIR, { recursive: true });\n151: \n152:     const today = new Date().toISOString().split('T')[0];\n153:     const patternFile = join(PATTERNS_DIR, `${today}.md`);\n154: \n155:     let fileContent = `# Session Patterns: ${today}\\n`;\n156:     fileContent += `**Session ID:** ${sessionId || \"unknown\"}\\n`;\n157:     fileContent += `**Messages:** ${messageCount}\\n\\n---\\n\\n`;\n158: \n159:     // Collect all tool_use content blocks from assistant messages\n160:     const toolUseBlocks: any[] = [];\n161:     messages.forEach((m: any) => {\n162:       const content = m.message?.content;\n163:       if (Array.isArray(content)) {\n164:         content.forEach((block: any) => {\n165:           if (block.type === 'tool_use') toolUseBlocks.push(block);\n166:         });\n167:       }\n168:     });\n169: \n170:     // Collect tool result blocks (errors) from user messages\n171:     const errorBlocks: string[] = [];\n172:     messages.forEach((m: any) => {\n173:       const content = m.message?.content;\n174:       if (Array.isArray(content)) {\n175:         content.forEach((block: any) => {\n176:           if (block.type === 'tool_result' && block.is_error) {\n177:             const output = Array.isArray(block.content)\n178:               ? block.content.map((c: any) => c.text || '').join(' ')\n179:               : String(block.content || '');\n180:             errorBlocks.push(output.substring(0, 200).replace(/\\n/g, ' '));\n181:           }\n182:         });\n183:       }\n184:       // Also catch top-level error messages\n185:       if (m.type === 'error') {\n186:         errorBlocks.push((m.error?.message || 'Unknown error').substring(0, 200));\n187:       }\n188:     });\n189: \n190:     fileContent += \"## Errors Encountered\\n\";\n191:     errorBlocks.slice(0, 10).forEach(msg => fileContent += `- ${msg}\\n`);\n192:     fileContent += \"\\n\";\n193: \n194:     // Extract Tool Usage\n195:     const toolUsage: Record<string, number> = {};\n196:     toolUseBlocks.forEach((block: any) => {\n197:       toolUsage[block.name] = (toolUsage[block.name] || 0) + 1;\n198:     });\n199: \n200:     fileContent += \"## Tools Used\\n\";\n201:     Object.entries(toolUsage)\n202:       .sort(([,a], [,b]) => (b as number) - (a as number))\n203:       .slice(0, 10)\n204:       .forEach(([tool, count]) => fileContent += `- ${tool} (${count} times)\\n`);\n205:     fileContent += \"\\n\";\n206: \n207:     // Extract Files Modified\n208:     const files = new Set<string>();\n209:     toolUseBlocks.forEach((block: any) => {\n210:       if (block.name === 'Write' || block.name === 'Edit' || block.name === 'MultiEdit') {\n211:         const path = block.input?.file_path || block.input?.path;\n212:         if (path) files.add(path);\n213:       }\n214:     });\n215:     fileContent += \"## Files Modified\\n\";\n216:     [...files].slice(0, 20).forEach(f => fileContent += `- ${f}\\n`);\n217:     fileContent += \"\\n\";\n218: \n219:     writeFileSync(patternFile, fileContent);\n220: \n221:     const projectName = resolveProject(input.cwd ?? \"\").name;\n222: \n223:     const proposals: MemoryProposal[] = [];\n224: \n225:     for (const msg of errorBlocks.slice(0, 3)) {\n226:       if (msg.trim().length > 20) {\n227:         proposals.push({\n228:           content: msg.trim(),\n229:           category: \"gotcha\",\n230:           importance: 3,\n231:           source: \"evaluate-session\",\n232:         });\n233:       }\n234:     }\n235: \n236:     try {\n237:       if ((readConfigSync() as Config).ltm?.evaluateSessionLlm) {\n238:         const assistantText = extractAssistantText(messages);\n239:         if (assistantText.length > 100) {\n240:           extractProposals(assistantText, projectName, { source: \"evaluate-session\", sessionId })\n241:             .then(({ proposals: llmProposals }) => {\n242:               const merged = [...proposals, ...llmProposals];\n243:               if (merged.length > 0) {\n244:                 const sid = sessionId ?? `unknown-${Date.now()}`;\n245:                 const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n246:                 writeProposals(proposalsPath, merged);\n247:                 process.stdout.write(\n248:                   JSON.stringify({ type: \"ltm_proposal\", count: merged.length, proposalsPath }) + \"\\n\"\n249:                 );\n250:                 logHook(\"EvaluateSession\", \"info\", `${merged.length} proposals written`, proposalsPath);\n251:               }\n252:             })\n253:             .catch((err: unknown) => {\n254:               logHook(\"EvaluateSession\", \"warn\", \"LLM extraction failed\", String(err));\n255:               if (proposals.length > 0) {\n256:                 const sid = sessionId ?? `unknown-${Date.now()}`;\n257:                 const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n258:                 writeProposals(proposalsPath, proposals);\n259:                 process.stdout.write(\n260:                   JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n261:                 );\n262:               }\n263:             });\n264:         } else if (proposals.length > 0) {\n265:           // No LLM extraction but we have error-block proposals\n266:           const sid = sessionId ?? `unknown-${Date.now()}`;\n267:           const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n268:           writeProposals(proposalsPath, proposals);\n269:           process.stdout.write(\n270:             JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n271:           );\n272:           logHook(\"EvaluateSession\", \"info\", `${proposals.length} proposals written`, proposalsPath);\n273:         }\n274:       } else if (proposals.length > 0) {\n275:         // LLM disabled — write error-block proposals only\n276:         const sid = sessionId ?? `unknown-${Date.now()}`;\n277:         const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n278:         writeProposals(proposalsPath, proposals);\n279:         process.stdout.write(\n280:           JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n281:         );\n282:         logHook(\"EvaluateSession\", \"info\", `${proposals.length} proposals written`, proposalsPath);\n283:       }\n284:     } catch (cfgErr) {\n285:       logHook(\"EvaluateSession\", \"warn\", \"Failed to read config for LLM extraction\", String(cfgErr));\n286:     }\n287: \n288:     logEvent(\"EvaluateSession\", EVENTS.SESSION_EVALUATED, { project: projectName, count: messageCount });\n289:     emitEvent({ hook: \"EvaluateSession\", event: EVENTS.SESSION_EVALUATED, project: projectName, count: messageCount, ts: new Date().toISOString() });\n290: \n291:     // Update Summary (deduplicate by sessionId)\n292:     if (!existsSync(SUMMARY_FILE)) {\n293:       writeFileSync(SUMMARY_FILE, \"# Learned Patterns Summary\\n\\nThis file is auto-updated.\\n\\n---\\n\\n## Recent Sessions\\n\\n\");\n294:     }\n295: \n296:     const summaryContent = readFileSync(SUMMARY_FILE, \"utf-8\");\n297:     const shortId = sessionId ? sessionId.substring(0, 8) : 'unknown';\n298:     if (!summaryContent.includes(shortId)) {\n299:       const newLine = `- **${today}** (${messageCount} msgs): Session ${shortId}... (Errors: ${errorBlocks.length})\\n`;\n300:       const updatedLines = (summaryContent + newLine).split('\\n');\n301:       const newSummary = updatedLines.length > MAX_SUMMARY_LINES\n302:         ? updatedLines.slice(0, SUMMARY_HEADER_LINES)\n303:             .concat(updatedLines.slice(updatedLines.length - (MAX_SUMMARY_LINES - SUMMARY_HEADER_LINES)))\n304:             .join('\\n')\n305:         : summaryContent + newLine;\n306:       writeFileSync(SUMMARY_FILE, newSummary);\n307:     }\n308:   }\n309: }\n310: \n311: await safeRun(\"EvaluateSession\", main);\n\n(End of file - total 311 lines)\n</content>\n\n<system-reminder>\nInstructions from: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/AGENTS.md\n# OpenLTM — agent instructions\n\nHost-agnostic guidance for any AI coding agent working in this repo (Claude Code reads `CLAUDE.md`; OpenCode and other tools read this file). OpenLTM gives agents persistent semantic memory across sessions via a local SQLite database.\n\n## Using memory\n\nThe memory tools are exposed over MCP as `recall`, `learn`, `context`, `forget`, `relate` (in Claude Code, prefixed `mcp__plugin_openltm_memory__*`). The goal is automatic knowledge retrieval and capture — use judgment, not a call before every sentence.\n\n- **`recall`** before a non-trivial task, or when the work touches past decisions or an unfamiliar area. Skip for trivial one-liners.\n- **`learn`** after discovering a non-obvious pattern, architectural decision, or gotcha worth keeping across sessions.\n- **`context`** at session start or when switching projects, to restore goals, decisions, and gotchas.\n\nCategories: `preference | architecture | gotcha | pattern | workflow | constraint`. Importance `5` never decays; everything else ages out as it goes unused.\n\n## Working in this repo\n\n- **Runtime is Bun**, not npm/node. Use `bun`, `bunx`, `bun test`.\n- **Tests + typecheck must pass**: `bun test && bun run typecheck`.\n- **Version bumps are mandatory** on any change — `bun run bump <version>` then `bun run verify-version` (it gates all version sources: `package.json`, `.claude-plugin/plugin.json`, `.claude-plugin/marketplace.json`, every `packages/*/package.json`, and the README badge).\n- **No secrets, no database files** in commits. `data/*.db*` is gitignored; keep it that way.\n\n## Shipping to OpenCode\n\nInstalling OpenLTM into OpenCode (`bunx @rohirik/openltm-core --opencode`) does two things: registers the `@rohirik/opencode-ltm` plugin in `opencode.json`, and deploys the bundled customization (agents, skills, plugins) from the package's `assets/opencode/` into the user's OpenCode config directory.\n\n## Releasing\n\nTag-driven and tokenless: bump versions, add a `CHANGELOG.md` entry, then `git tag vX.Y.Z && git push origin main vX.Y.Z`. The tag fires the Release and Publish workflows; npm packages publish via OIDC trusted publishing with provenance — no stored token. Full detail in `CONTRIBUTING.md`.\n\n## Docs\n\nUser-facing docs are in [`docs/`](docs/README.md); internal design specs in [`docs/internal/`](docs/internal/README.md).\n\n</system-reminder>","metadata":{"preview":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, writeFileSync, readdirSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { safeRun } from \"../lib/hookUtils.js\";\nimport { extractProposals } from \"../lib/llmExtract.js\";\nimport { writeProposals, type MemoryProposal } from \"../lib/proposalQueue.js\";\nimport { readConfigSync } from \"../../src/config.js\";\nimport type { Config } from \"../../src/config.js\";\nimport { emitEvent } from \"@rohirik/openltm-core\";\n\nconst PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"memory\");\nconst LEARNED_DIR = join(PLUGIN_ROOT, \"skills\", \"Learned\");\nconst PATTERNS_DIR = join(LEARNED_DIR, \"patterns\");\nconst SUMMARY_FILE = join(LEARNED_DIR, \"summary.md\");\nconst HISTORY_FILE = join(CLAUDE_DIR, \"history.jsonl\");\nconst MAX_SUMMARY_LINES = 50;","truncated":false,"loaded":["/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/AGENTS.md"],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts","text":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, writeFileSync, readdirSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { safeRun } from \"../lib/hookUtils.js\";\nimport { extractProposals } from \"../lib/llmExtract.js\";\nimport { writeProposals, type MemoryProposal } from \"../lib/proposalQueue.js\";\nimport { readConfigSync } from \"../../src/config.js\";\nimport type { Config } from \"../../src/config.js\";\nimport { emitEvent } from \"@rohirik/openltm-core\";\n\nconst PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"memory\");\nconst LEARNED_DIR = join(PLUGIN_ROOT, \"skills\", \"Learned\");\nconst PATTERNS_DIR = join(LEARNED_DIR, \"patterns\");\nconst SUMMARY_FILE = join(LEARNED_DIR, \"summary.md\");\nconst HISTORY_FILE = join(CLAUDE_DIR, \"history.jsonl\");\nconst MAX_SUMMARY_LINES = 50;\nconst SUMMARY_HEADER_LINES = 10;\nconst MIN_SESSION_MESSAGES = 5; // Lowered for testing\n\n// Proposals dir: ${CLAUDE_PLUGIN_DATA}/proposals/ or fallback to plugin data dir\nconst PLUGIN_DATA_DIR = process.env.CLAUDE_PLUGIN_DATA\n  ?? join(homedir(), \".claude\", \"plugins\", \"data\", \"OpenLtm-openltm\");\nconst PROPOSALS_DIR = join(PLUGIN_DATA_DIR, \"proposals\");\n\nasync function findTranscript(sessionId: string | undefined): Promise<{ path: string, id: string } | null> {\n  if (!existsSync(HISTORY_FILE)) return null;\n\n  const historyLines = readFileSync(HISTORY_FILE, \"utf-8\").trim().split('\\n');\n  if (historyLines.length === 0) return null;\n\n  // Find the entry matching sessionId, or the last one if not provided\n  let historyEntry: any = null;\n  if (sessionId) {\n    // Search backwards\n    for (let i = historyLines.length - 1; i >= 0; i--) {\n      try {\n        const line = JSON.parse(historyLines[i] ?? \"\");\n        if (line.sessionId === sessionId) {\n          historyEntry = line;\n          break;\n        }\n      } catch (e) {} // silent: malformed JSONL lines are expected and safely skipped\n    }\n  } else {\n    // Just take the last valid one\n    try {\n      historyEntry = JSON.parse(historyLines[historyLines.length - 1] ?? \"\");\n    } catch (e) {} // silent: malformed JSONL line is safely skipped\n  }\n\n  if (!historyEntry) return null;\n\n  const finalSessionId = historyEntry.sessionId;\n  const projectPath = historyEntry.project;\n  if (!finalSessionId || !projectPath) return null;\n\n  const filename = `${finalSessionId}.jsonl`;\n\n  // Try registry-resolved project dir first, then scan all project dirs for the session file\n  const { projectDir } = resolveProject(projectPath);\n  let transcriptPath = join(projectDir, filename);\n\n  if (!existsSync(transcriptPath)) {\n    // Claude Code may use a different slug format — scan all dirs\n    try {\n      const dirs = readdirSync(PROJECTS_DIR);\n      for (const dir of dirs) {\n        const candidate = join(PROJECTS_DIR, dir, filename);\n        if (existsSync(candidate)) {\n          transcriptPath = candidate;\n          break;\n        }\n      }\n    } catch (_) {} // silent: dir scan failure means we fall through to existsSync check\n  }\n\n  if (!existsSync(transcriptPath)) return null;\n\n  return { path: transcriptPath, id: finalSessionId };\n}\n\nfunction extractAssistantText(messages: any[]): string {\n  const parts: string[] = [];\n  for (const m of messages) {\n    const content = m?.message?.content;\n    if (!Array.isArray(content)) continue;\n    if (m?.message?.role !== \"assistant\") continue;\n    for (const block of content) {\n      if (block?.type === \"text\" && typeof block.text === \"string\")\n        parts.push(block.text.trim());\n    }\n  }\n  const full = parts.join(\"\\n\\n\");\n  return full.length > 8000 ? full.slice(-8000) : full;\n}\n\nasync function main() {\n  let inputStr = \"\";\n  // Hook inputs are optional for this tool now, but we pass through stdin\n  try {\n    for await (const chunk of Bun.stdin.stream()) {\n      const text = new TextDecoder().decode(chunk);\n      inputStr += text;\n      process.stdout.write(chunk); // Pass through immediately\n    }\n  } catch (stdinErr) {\n    // Stdin might be empty or closed — non-fatal\n    logHook(\"EvaluateSession\", \"warn\", \"stdin read failed\", String(stdinErr));\n  }\n\n  let input: any = {};\n  try {\n    input = JSON.parse(inputStr);\n  } catch {\n    // Non-JSON input is acceptable — hooks may receive empty or plain-text stdin\n  }\n\n  {\n    let transcriptPath = input.transcript_path;\n    let sessionId = input.session_id;\n\n    if (!transcriptPath || !existsSync(transcriptPath)) {\n      const found = await findTranscript(sessionId);\n      if (found) {\n        transcriptPath = found.path;\n        sessionId = found.id;\n      }\n    }\n\n    if (!transcriptPath || !existsSync(transcriptPath)) {\n      return;\n    }\n\n    const transcriptContent = readFileSync(transcriptPath, \"utf-8\");\n    // Parse JSONL\n    const messages = transcriptContent.trim().split('\\n').map(l => {\n        try { return JSON.parse(l); } catch(e) { return null; }\n    }).filter(Boolean);\n\n    const messageCount = messages.length;\n\n    if (messageCount < MIN_SESSION_MESSAGES) {\n      return;\n    }\n\n    if (!existsSync(PATTERNS_DIR)) mkdirSync(PATTERNS_DIR, { recursive: true });\n\n    const today = new Date().toISOString().split('T')[0];\n    const patternFile = join(PATTERNS_DIR, `${today}.md`);\n\n    let fileContent = `# Session Patterns: ${today}\\n`;\n    fileContent += `**Session ID:** ${sessionId || \"unknown\"}\\n`;\n    fileContent += `**Messages:** ${messageCount}\\n\\n---\\n\\n`;\n\n    // Collect all tool_use content blocks from assistant messages\n    const toolUseBlocks: any[] = [];\n    messages.forEach((m: any) => {\n      const content = m.message?.content;\n      if (Array.isArray(content)) {\n        content.forEach((block: any) => {\n          if (block.type === 'tool_use') toolUseBlocks.push(block);\n        });\n      }\n    });\n\n    // Collect tool result blocks (errors) from user messages\n    const errorBlocks: string[] = [];\n    messages.forEach((m: any) => {\n      const content = m.message?.content;\n      if (Array.isArray(content)) {\n        content.forEach((block: any) => {\n          if (block.type === 'tool_result' && block.is_error) {\n            const output = Array.isArray(block.content)\n              ? block.content.map((c: any) => c.text || '').join(' ')\n              : String(block.content || '');\n            errorBlocks.push(output.substring(0, 200).replace(/\\n/g, ' '));\n          }\n        });\n      }\n      // Also catch top-level error messages\n      if (m.type === 'error') {\n        errorBlocks.push((m.error?.message || 'Unknown error').substring(0, 200));\n      }\n    });\n\n    fileContent += \"## Errors Encountered\\n\";\n    errorBlocks.slice(0, 10).forEach(msg => fileContent += `- ${msg}\\n`);\n    fileContent += \"\\n\";\n\n    // Extract Tool Usage\n    const toolUsage: Record<string, number> = {};\n    toolUseBlocks.forEach((block: any) => {\n      toolUsage[block.name] = (toolUsage[block.name] || 0) + 1;\n    });\n\n    fileContent += \"## Tools Used\\n\";\n    Object.entries(toolUsage)\n      .sort(([,a], [,b]) => (b as number) - (a as number))\n      .slice(0, 10)\n      .forEach(([tool, count]) => fileContent += `- ${tool} (${count} times)\\n`);\n    fileContent += \"\\n\";\n\n    // Extract Files Modified\n    const files = new Set<string>();\n    toolUseBlocks.forEach((block: any) => {\n      if (block.name === 'Write' || block.name === 'Edit' || block.name === 'MultiEdit') {\n        const path = block.input?.file_path || block.input?.path;\n        if (path) files.add(path);\n      }\n    });\n    fileContent += \"## Files Modified\\n\";\n    [...files].slice(0, 20).forEach(f => fileContent += `- ${f}\\n`);\n    fileContent += \"\\n\";\n\n    writeFileSync(patternFile, fileContent);\n\n    const projectName = resolveProject(input.cwd ?? \"\").name;\n\n    const proposals: MemoryProposal[] = [];\n\n    for (const msg of errorBlocks.slice(0, 3)) {\n      if (msg.trim().length > 20) {\n        proposals.push({\n          content: msg.trim(),\n          category: \"gotcha\",\n          importance: 3,\n          source: \"evaluate-session\",\n        });\n      }\n    }\n\n    try {\n      if ((readConfigSync() as Config).ltm?.evaluateSessionLlm) {\n        const assistantText = extractAssistantText(messages);\n        if (assistantText.length > 100) {\n          extractProposals(assistantText, projectName, { source: \"evaluate-session\", sessionId })\n            .then(({ proposals: llmProposals }) => {\n              const merged = [...proposals, ...llmProposals];\n              if (merged.length > 0) {\n                const sid = sessionId ?? `unknown-${Date.now()}`;\n                const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n                writeProposals(proposalsPath, merged);\n                process.stdout.write(\n                  JSON.stringify({ type: \"ltm_proposal\", count: merged.length, proposalsPath }) + \"\\n\"\n                );\n                logHook(\"EvaluateSession\", \"info\", `${merged.length} proposals written`, proposalsPath);\n              }\n            })\n            .catch((err: unknown) => {\n              logHook(\"EvaluateSession\", \"warn\", \"LLM extraction failed\", String(err));\n              if (proposals.length > 0) {\n                const sid = sessionId ?? `unknown-${Date.now()}`;\n                const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n                writeProposals(proposalsPath, proposals);\n                process.stdout.write(\n                  JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n                );\n              }\n            });\n        } else if (proposals.length > 0) {\n          // No LLM extraction but we have error-block proposals\n          const sid = sessionId ?? `unknown-${Date.now()}`;\n          const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n          writeProposals(proposalsPath, proposals);\n          process.stdout.write(\n            JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n          );\n          logHook(\"EvaluateSession\", \"info\", `${proposals.length} proposals written`, proposalsPath);\n        }\n      } else if (proposals.length > 0) {\n        // LLM disabled — write error-block proposals only\n        const sid = sessionId ?? `unknown-${Date.now()}`;\n        const proposalsPath = join(PROPOSALS_DIR, `${sid}.json`);\n        writeProposals(proposalsPath, proposals);\n        process.stdout.write(\n          JSON.stringify({ type: \"ltm_proposal\", count: proposals.length, proposalsPath }) + \"\\n\"\n        );\n        logHook(\"EvaluateSession\", \"info\", `${proposals.length} proposals written`, proposalsPath);\n      }\n    } catch (cfgErr) {\n      logHook(\"EvaluateSession\", \"warn\", \"Failed to read config for LLM extraction\", String(cfgErr));\n    }\n\n    logEvent(\"EvaluateSession\", EVENTS.SESSION_EVALUATED, { project: projectName, count: messageCount });\n    emitEvent({ hook: \"EvaluateSession\", event: EVENTS.SESSION_EVALUATED, project: projectName, count: messageCount, ts: new Date().toISOString() });\n\n    // Update Summary (deduplicate by sessionId)\n    if (!existsSync(SUMMARY_FILE)) {\n      writeFileSync(SUMMARY_FILE, \"# Learned Patterns Summary\\n\\nThis file is auto-updated.\\n\\n---\\n\\n## Recent Sessions\\n\\n\");\n    }\n\n    const summaryContent = readFileSync(SUMMARY_FILE, \"utf-8\");\n    const shortId = sessionId ? sessionId.substring(0, 8) : 'unknown';\n    if (!summaryContent.includes(shortId)) {\n      const newLine = `- **${today}** (${messageCount} msgs): Session ${shortId}... (Errors: ${errorBlocks.length})\\n`;\n      const updatedLines = (summaryContent + newLine).split('\\n');\n      const newSummary = updatedLines.length > MAX_SUMMARY_LINES\n        ? updatedLines.slice(0, SUMMARY_HEADER_LINES)\n            .concat(updatedLines.slice(updatedLines.length - (MAX_SUMMARY_LINES - SUMMARY_HEADER_LINES)))\n            .join('\\n')\n        : summaryContent + newLine;\n      writeFileSync(SUMMARY_FILE, newSummary);\n    }\n  }\n}\n\nawait safeRun(\"EvaluateSession\", main);","lineStart":1,"lineEnd":311,"totalLines":311,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts","time":{"start":1780929649390,"end":1780929649415}},"metadata":{"openai":{"itemId":"fc_0de7cd52ef5a02dd016a26d47132148191badf07007910402d"}},"id":"prt_ea7adda81001xciPI47IKSPvwK","sessionID":"ses_15852ff63ffejJtpJJJcia0535","messageID":"msg_ea7adacae001uuzBRtmJKmvHAb"}}
{"type":"tool_use","timestamp":1780929649467,"sessionID":"ses_15852ff63ffejJtpJJJcia0535","part":{"type":"tool","tool":"read","callID":"call_iDQKXd9ePxovScZSBLbZT9FT","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: import { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\n3: import { homedir } from \"os\";\n4: import { join } from \"path\";\n5: import { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\n6: import { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\n7: import { logHook, logEvent } from \"../lib/hookLogger.js\";\n8: import { EVENTS } from \"../lib/eventNames.js\";\n9: import { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n10: \n11: const TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\n12: const MAX_PROGRESS_LINES = 20;\n13: const MAX_DISPLAY_FILES = 5;\n14: const DB_PATH = getDbPath();\n15: \n16: function findTranscriptPath(\n17:   transcriptPath: string | undefined,\n18:   sessionId: string | undefined\n19: ): string | null {\n20:   if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;\n21: \n22:   const historyFile = join(CLAUDE_DIR, \"history.jsonl\");\n23:   if (!existsSync(historyFile)) return null;\n24: \n25:   const lines = readFileSync(historyFile, \"utf-8\").trim().split(\"\\n\");\n26:   let entry: Record<string, unknown> | null = null;\n27: \n28:   if (sessionId) {\n29:     for (let i = lines.length - 1; i >= 0; i--) {\n30:       try {\n31:         const parsed = JSON.parse(lines[i] ?? \"\") as Record<string, unknown>;\n32:         if (parsed.sessionId === sessionId) { entry = parsed; break; }\n33:       } catch {}\n34:     }\n35:   } else {\n36:     try { entry = JSON.parse(lines[lines.length - 1] ?? \"\") as Record<string, unknown>; } catch {}\n37:   }\n38: \n39:   if (!entry?.sessionId || !entry?.project) return null;\n40: \n41:   const filename = `${entry.sessionId}.jsonl`;\n42:   const { projectDir } = resolveProject(entry.project as string);\n43:   const primary = join(projectDir, filename);\n44:   if (existsSync(primary)) return primary;\n45: \n46:   try {\n47:     for (const dir of readdirSync(PROJECTS_DIR)) {\n48:       const candidate = join(PROJECTS_DIR, dir, filename);\n49:       if (existsSync(candidate)) return candidate;\n50:     }\n51:   } catch {}\n52: \n53:   return null;\n54: }\n55: \n56: function collectModifiedFiles(messages: Array<Record<string, unknown>>): Set<string> {\n57:   const files = new Set<string>();\n58:   for (const m of messages) {\n59:     const content = (m.message as Record<string, unknown> | undefined)?.content;\n60:     if (!Array.isArray(content)) continue;\n61:     for (const block of content as Array<Record<string, unknown>>) {\n62:       if (block.type === \"tool_use\" && TOOL_NAMES.has(block.name as string)) {\n63:         const input = block.input as Record<string, string> | undefined;\n64:         const p = input?.file_path || input?.path;\n65:         if (p) files.add(p);\n66:       }\n67:     }\n68:   }\n69:   return files;\n70: }\n71: \n72: function parseJsonLines(raw: string): Array<Record<string, unknown>> {\n73:   return raw.trim().split(\"\\n\")\n74:     .map(line => { try { return JSON.parse(line) as Record<string, unknown>; } catch { return null; } })\n75:     .filter(Boolean) as Array<Record<string, unknown>>;\n76: }\n77: \n78: async function main(): Promise<void> {\n79:   const raw = await readStdinPassthrough();\n80: \n81:   const parsed = parseHookInput(raw);\n82:   if (!parsed) return;\n83: \n84:   const { input, cwd } = parsed;\n85:   const { name, projectDir } = resolveProject(cwd);\n86:   if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n87: \n88:   const tPath = findTranscriptPath(\n89:     input.transcript_path as string | undefined,\n90:     input.session_id as string | undefined\n91:   );\n92:   if (!tPath) return;\n93: \n94:   const messages = parseJsonLines(readFileSync(tPath, \"utf-8\"));\n95:   if (messages.length < 3) return;\n96: \n97:   const sessionTag = input.session_id ? (input.session_id as string).substring(0, 8) : null;\n98:   const today = new Date().toISOString().split(\"T\")[0];\n99:   const tagPart = sessionTag ? ` [${sessionTag}]` : \"\";\n100: \n101:   const filesModified = collectModifiedFiles(messages);\n102:   const sessionLine = filesModified.size > 0\n103:     ? `✓ [${today}]${tagPart} Modified: ${[...filesModified].slice(0, MAX_DISPLAY_FILES).map(f => f.replace(homedir(), \"~\")).join(\", \")}`\n104:     : `✓ [${today}]${tagPart} Session (read-only, ${messages.length} messages)`;\n105: \n106:   // Write to DB if available, fall back to .md file\n107:   if (existsSync(DB_PATH)) {\n108:     try {\n109:       const prefixMatch = sessionLine.match(/^\\[(decision|gotcha)\\]\\s*/i);\n110:       if (prefixMatch) {\n111:         const type = prefixMatch[1]!.toLowerCase() as \"decision\" | \"gotcha\";\n112:         const strippedContent = sessionLine.slice(prefixMatch[0].length);\n113:         if (type === \"decision\") addDecision(name, strippedContent);\n114:         else addGotcha(name, strippedContent);\n115:       } else {\n116:         appendProgress(name, sessionLine, sessionTag ?? undefined);\n117:       }\n118:       logHook(\"UpdateContext\", \"info\", `context DB updated for ${name}`);\n119:       logEvent(\"UpdateContext\", EVENTS.CONTEXT_UPDATED, { project: name });\n120:       emitEvent({ hook: \"UpdateContext\", event: EVENTS.CONTEXT_UPDATED, project: name, ts: new Date().toISOString() });\n121:       return;\n122:     } catch (dbErr) {\n123:       logHook(\"UpdateContext\", \"warn\", \"DB write failed, falling back to .md\", String(dbErr));\n124:       process.stderr.write(`[UpdateContext] DB write failed, falling back to .md: ${dbErr}\\n`);\n125:     }\n126:   }\n127: \n128:   // Fallback: write to markdown file\n129:   const progressFile = join(projectDir, \"context-progress.md\");\n130:   const existing = readFileSafe(progressFile);\n131:   if (sessionTag && existing.includes(sessionTag)) return;\n132: \n133:   appendLine(progressFile, sessionLine);\n134: \n135:   const content = readFileSafe(progressFile);\n136:   const lines = content.split(\"\\n\").filter(Boolean);\n137:   if (lines.length > MAX_PROGRESS_LINES) {\n138:     writeFileSync(progressFile, trimToLines(content, MAX_PROGRESS_LINES));\n139:   }\n140: \n141:   logHook(\"UpdateContext\", \"info\", `context-progress.md updated for ${name}`);\n142: }\n143: \n144: await safeRun(\"UpdateContext\", main);\n\n(End of file - total 144 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\nimport { homedir } from \"os\";\nimport { join } from \"path\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n\nconst TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\nconst MAX_PROGRESS_LINES = 20;\nconst MAX_DISPLAY_FILES = 5;\nconst DB_PATH = getDbPath();\n\nfunction findTranscriptPath(\n  transcriptPath: string | undefined,\n  sessionId: string | undefined\n): string | null {\n  if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","text":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\nimport { homedir } from \"os\";\nimport { join } from \"path\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n\nconst TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\nconst MAX_PROGRESS_LINES = 20;\nconst MAX_DISPLAY_FILES = 5;\nconst DB_PATH = getDbPath();\n\nfunction findTranscriptPath(\n  transcriptPath: string | undefined,\n  sessionId: string | undefined\n): string | null {\n  if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;\n\n  const historyFile = join(CLAUDE_DIR, \"history.jsonl\");\n  if (!existsSync(historyFile)) return null;\n\n  const lines = readFileSync(historyFile, \"utf-8\").trim().split(\"\\n\");\n  let entry: Record<string, unknown> | null = null;\n\n  if (sessionId) {\n    for (let i = lines.length - 1; i >= 0; i--) {\n      try {\n        const parsed = JSON.parse(lines[i] ?? \"\") as Record<string, unknown>;\n        if (parsed.sessionId === sessionId) { entry = parsed; break; }\n      } catch {}\n    }\n  } else {\n    try { entry = JSON.parse(lines[lines.length - 1] ?? \"\") as Record<string, unknown>; } catch {}\n  }\n\n  if (!entry?.sessionId || !entry?.project) return null;\n\n  const filename = `${entry.sessionId}.jsonl`;\n  const { projectDir } = resolveProject(entry.project as string);\n  const primary = join(projectDir, filename);\n  if (existsSync(primary)) return primary;\n\n  try {\n    for (const dir of readdirSync(PROJECTS_DIR)) {\n      const candidate = join(PROJECTS_DIR, dir, filename);\n      if (existsSync(candidate)) return candidate;\n    }\n  } catch {}\n\n  return null;\n}\n\nfunction collectModifiedFiles(messages: Array<Record<string, unknown>>): Set<string> {\n  const files = new Set<string>();\n  for (const m of messages) {\n    const content = (m.message as Record<string, unknown> | undefined)?.content;\n    if (!Array.isArray(content)) continue;\n    for (const block of content as Array<Record<string, unknown>>) {\n      if (block.type === \"tool_use\" && TOOL_NAMES.has(block.name as string)) {\n        const input = block.input as Record<string, string> | undefined;\n        const p = input?.file_path || input?.path;\n        if (p) files.add(p);\n      }\n    }\n  }\n  return files;\n}\n\nfunction parseJsonLines(raw: string): Array<Record<string, unknown>> {\n  return raw.trim().split(\"\\n\")\n    .map(line => { try { return JSON.parse(line) as Record<string, unknown>; } catch { return null; } })\n    .filter(Boolean) as Array<Record<string, unknown>>;\n}\n\nasync function main(): Promise<void> {\n  const raw = await readStdinPassthrough();\n\n  const parsed = parseHookInput(raw);\n  if (!parsed) return;\n\n  const { input, cwd } = parsed;\n  const { name, projectDir } = resolveProject(cwd);\n  if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n\n  const tPath = findTranscriptPath(\n    input.transcript_path as string | undefined,\n    input.session_id as string | undefined\n  );\n  if (!tPath) return;\n\n  const messages = parseJsonLines(readFileSync(tPath, \"utf-8\"));\n  if (messages.length < 3) return;\n\n  const sessionTag = input.session_id ? (input.session_id as string).substring(0, 8) : null;\n  const today = new Date().toISOString().split(\"T\")[0];\n  const tagPart = sessionTag ? ` [${sessionTag}]` : \"\";\n\n  const filesModified = collectModifiedFiles(messages);\n  const sessionLine = filesModified.size > 0\n    ? `✓ [${today}]${tagPart} Modified: ${[...filesModified].slice(0, MAX_DISPLAY_FILES).map(f => f.replace(homedir(), \"~\")).join(\", \")}`\n    : `✓ [${today}]${tagPart} Session (read-only, ${messages.length} messages)`;\n\n  // Write to DB if available, fall back to .md file\n  if (existsSync(DB_PATH)) {\n    try {\n      const prefixMatch = sessionLine.match(/^\\[(decision|gotcha)\\]\\s*/i);\n      if (prefixMatch) {\n        const type = prefixMatch[1]!.toLowerCase() as \"decision\" | \"gotcha\";\n        const strippedContent = sessionLine.slice(prefixMatch[0].length);\n        if (type === \"decision\") addDecision(name, strippedContent);\n        else addGotcha(name, strippedContent);\n      } else {\n        appendProgress(name, sessionLine, sessionTag ?? undefined);\n      }\n      logHook(\"UpdateContext\", \"info\", `context DB updated for ${name}`);\n      logEvent(\"UpdateContext\", EVENTS.CONTEXT_UPDATED, { project: name });\n      emitEvent({ hook: \"UpdateContext\", event: EVENTS.CONTEXT_UPDATED, project: name, ts: new Date().toISOString() });\n      return;\n    } catch (dbErr) {\n      logHook(\"UpdateContext\", \"warn\", \"DB write failed, falling back to .md\", String(dbErr));\n      process.stderr.write(`[UpdateContext] DB write failed, falling back to .md: ${dbErr}\\n`);\n    }\n  }\n\n  // Fallback: write to markdown file\n  const progressFile = join(projectDir, \"context-progress.md\");\n  const existing = readFileSafe(progressFile);\n  if (sessionTag && existing.includes(sessionTag)) return;\n\n  appendLine(progressFile, sessionLine);\n\n  const content = readFileSafe(progressFile);\n  const lines = content.split(\"\\n\").filter(Boolean);\n  if (lines.length > MAX_PROGRESS_LINES) {\n    writeFileSync(progressFile, trimToLines(content, MAX_PROGRESS_LINES));\n  }\n\n  logHook(\"UpdateContext\", \"info\", `context-progress.md updated for ${name}`);\n}\n\nawait safeRun(\"UpdateContext\", main);","lineStart":1,"lineEnd":144,"totalLines":144,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","time":{"start":1780929649454,"end":1780929649464}},"metadata":{"openai":{"itemId":"fc_0de7cd52ef5a02dd016a26d471322881919f5b5f92ca62470a"}},"id":"prt_ea7addaf5001NTj30Q4VTuWbxE","sessionID":"ses_15852ff63ffejJtpJJJcia0535","messageID":"msg_ea7adacae001uuzBRtmJKmvHAb"}}
{"type":"tool_use","timestamp":1780929649510,"sessionID":"ses_15852ff63ffejJtpJJJcia0535","part":{"type":"tool","tool":"read","callID":"call_DD4qSsv3SHihrRTUuBui63OF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: /**\n3:  * GitCommit.ts — Post-commit hook that auto-extracts learnings from git diffs.\n4:  *\n5:  * Two modes:\n6:  *   hook mode (default):  validates config, spawns detached extractor, exits 0 immediately\n7:  *   extract mode:         --extract <json>  — runs LLM extraction and stores memories\n8:  *\n9:  * Installed globally via ~/.claude/hooks/git/post-commit\n10:  * Controlled by config.ltm.gitLearnEnabled (default: false)\n11:  */\n12: import { existsSync } from \"fs\";\n13: import { join } from \"path\";\n14: import { homedir } from \"os\";\n15: import { spawnSync } from \"child_process\";\n16: import { resolveProject, CLAUDE_DIR } from \"../lib/resolveProject.js\";\n17: import { safeRun } from \"../lib/hookUtils.js\";\n18: import { emitEvent } from \"@rohirik/openltm-core\";\n19: import { EVENTS } from \"../lib/eventNames.js\";\n20: import { readConfigSync } from \"../../src/config.js\";\n21: import type { Config } from \"../../src/config.js\";\n22: \n23: const PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"plugins\", \"ltm\");\n24: const MAX_DIFF_CHARS = 4000;\n25: \n26: // ── Git helpers ───────────────────────────────────────────────────────────────\n27: \n28: function getProjectRoot(): string {\n29:   // GIT_DIR is set to .git/ inside a hook — go one level up\n30:   const gitDir = process.env.GIT_DIR;\n31:   if (gitDir) return join(gitDir, \"..\") ;\n32:   return process.cwd();\n33: }\n34: \n35: function runGit(args: string[], cwd: string): string {\n36:   const result = spawnSync(\"git\", args, { cwd, encoding: \"utf-8\", env: process.env });\n37:   return result.stdout?.trim() ?? \"\";\n38: }\n39: \n40: function getCommitMeta(cwd: string): { hash: string; message: string; files: string[] } {\n41:   const hash = runGit([\"log\", \"-1\", \"--pretty=format:%H\"], cwd);\n42:   const message = runGit([\"log\", \"-1\", \"--pretty=format:%s\"], cwd);\n43:   const fileList = runGit([\"diff-tree\", \"--no-commit-id\", \"-r\", \"--name-only\", \"HEAD\"], cwd);\n44:   const files = fileList ? fileList.split(\"\\n\").filter(Boolean) : [];\n45:   return { hash, message, files };\n46: }\n47: \n48: function getDiffText(cwd: string, maxChars: number): string {\n49:   const diff = runGit([\"diff\", \"HEAD~1\", \"HEAD\", \"--unified=3\", \"--no-color\"], cwd);\n50:   if (!diff) return runGit([\"show\", \"--unified=3\", \"--no-color\", \"HEAD\"], cwd).slice(0, maxChars);\n51:   return diff.length > maxChars ? diff.slice(0, maxChars) : diff;\n52: }\n53: \n54: function matchesPattern(filename: string, pattern: string): boolean {\n55:   if (pattern.startsWith(\"*.\")) return filename.endsWith(pattern.slice(1));\n56:   if (pattern.endsWith(\"/\")) return filename.includes(pattern);\n57:   return filename.includes(pattern);\n58: }\n59: \n60: function applyIgnorePatterns(diff: string, patterns: string[]): string {\n61:   if (patterns.length === 0) return diff;\n62:   const lines = diff.split(\"\\n\");\n63:   let skip = false;\n64:   return lines.filter(line => {\n65:     if (line.startsWith(\"diff --git\")) {\n66:       // Extract filename from \"diff --git a/path b/path\"\n67:       const match = line.match(/diff --git a\\/.+ b\\/(.+)$/);\n68:       const filename = match?.[1] ?? line;\n69:       skip = patterns.some(p => matchesPattern(filename, p));\n70:     }\n71:     return !skip;\n72:   }).join(\"\\n\");\n73: }\n74: \n75: function shouldSkipRepo(projectRoot: string): boolean {\n76:   return existsSync(join(projectRoot, \".ltmignore\"));\n77: }\n78: \n79: // ── Extract mode ──────────────────────────────────────────────────────────────\n80: \n81: async function runExtract(payload: {\n82:   diff: string;\n83:   commitMsg: string;\n84:   hash: string;\n85:   files: string[];\n86:   projectName: string;\n87: }): Promise<void> {\n88:   const { extractAndLearn } = await import(\"../lib/llmExtract.js\");\n89: \n90:   const preamble = `Git commit: ${payload.commitMsg}\\nFiles changed: ${payload.files.slice(0, 5).join(\", \")}`;\n91: \n92:   await extractAndLearn(payload.diff, payload.projectName, {\n93:     source: `git-commit:${payload.hash}`,\n94:     tags: payload.files.slice(0, 5),\n95:     preamble,\n96:   });\n97: }\n98: \n99: // ── Hook mode (main entry) ────────────────────────────────────────────────────\n100: \n101: async function main(): Promise<void> {\n102:   // Extract mode — reads payload from stdin, called by detached subprocess\n103:   if (process.argv.includes(\"--extract\")) {\n104:     try {\n105:       let raw = \"\";\n106:       for await (const chunk of Bun.stdin.stream()) raw += new TextDecoder().decode(chunk);\n107:       const payload = JSON.parse(raw);\n108:       await runExtract(payload);\n109:     } catch (err) {\n110:       process.stderr.write(`[GitCommit] extract error: ${err}\\n`);\n111:     }\n112:     process.exit(0);\n113:   }\n114: \n115:   // Hook mode — must exit 0 immediately, never block git\n116:   try {\n117:     const cfg = readConfigSync() as Config;\n118:     if (!cfg.ltm?.gitLearnEnabled) process.exit(0);\n119: \n120:     const projectRoot = getProjectRoot();\n121:     if (shouldSkipRepo(projectRoot)) process.exit(0);\n122: \n123:     const { hash, message, files } = getCommitMeta(projectRoot);\n124:     if (!hash) process.exit(0);\n125: \n126:     const ignorePatterns = cfg.ltm?.gitLearnIgnorePatterns ?? [\"package-lock.json\", \"*.lock\", \"dist/\", \".min.js\"];\n127:     const minDiffChars = cfg.ltm?.gitLearnMinDiffChars ?? 200;\n128: \n129:     let diff = getDiffText(projectRoot, MAX_DIFF_CHARS);\n130:     diff = applyIgnorePatterns(diff, ignorePatterns);\n131: \n132:     if (diff.length < minDiffChars) process.exit(0);\n133: \n134:     const projectName = resolveProject(projectRoot).name;\n135: \n136:     const payload = { diff, commitMsg: message, hash, files, projectName };\n137: \n138:     // Spawn detached so git doesn't wait for LLM extraction — pipe payload via stdin\n139:     const child = Bun.spawn(\n140:       [\"bun\", join(PLUGIN_ROOT, \"hooks/GitCommit.bundle.mjs\"), \"--extract\"],\n141:       {\n142:         detached: true,\n143:         stdin: \"pipe\",\n144:         stdout: \"ignore\",\n145:         stderr: \"ignore\",\n146:         env: { ...process.env, CLAUDE_PLUGIN_ROOT: PLUGIN_ROOT },\n147:       },\n148:     );\n149:     child.stdin.write(JSON.stringify(payload));\n150:     child.stdin.end();\n151:     child.unref();\n152:   } catch (err) {\n153:     process.stderr.write(`[GitCommit] hook error: ${err}\\n`);\n154:   }\n155: \n156:   emitEvent({ hook: \"GitCommit\", event: EVENTS.GIT_COMMIT, ts: new Date().toISOString() });\n157:   process.exit(0);\n158: }\n159: \n160: await safeRun(\"GitCommit\", main);\n\n(End of file - total 160 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * GitCommit.ts — Post-commit hook that auto-extracts learnings from git diffs.\n *\n * Two modes:\n *   hook mode (default):  validates config, spawns detached extractor, exits 0 immediately\n *   extract mode:         --extract <json>  — runs LLM extraction and stores memories\n *\n * Installed globally via ~/.claude/hooks/git/post-commit\n * Controlled by config.ltm.gitLearnEnabled (default: false)\n */\nimport { existsSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { spawnSync } from \"child_process\";\nimport { resolveProject, CLAUDE_DIR } from \"../lib/resolveProject.js\";\nimport { safeRun } from \"../lib/hookUtils.js\";\nimport { emitEvent } from \"@rohirik/openltm-core\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { readConfigSync } from \"../../src/config.js\";","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts","text":"#!/usr/bin/env bun\n/**\n * GitCommit.ts — Post-commit hook that auto-extracts learnings from git diffs.\n *\n * Two modes:\n *   hook mode (default):  validates config, spawns detached extractor, exits 0 immediately\n *   extract mode:         --extract <json>  — runs LLM extraction and stores memories\n *\n * Installed globally via ~/.claude/hooks/git/post-commit\n * Controlled by config.ltm.gitLearnEnabled (default: false)\n */\nimport { existsSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { spawnSync } from \"child_process\";\nimport { resolveProject, CLAUDE_DIR } from \"../lib/resolveProject.js\";\nimport { safeRun } from \"../lib/hookUtils.js\";\nimport { emitEvent } from \"@rohirik/openltm-core\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { readConfigSync } from \"../../src/config.js\";\nimport type { Config } from \"../../src/config.js\";\n\nconst PLUGIN_ROOT = process.env.CLAUDE_PLUGIN_ROOT ?? join(CLAUDE_DIR, \"plugins\", \"ltm\");\nconst MAX_DIFF_CHARS = 4000;\n\n// ── Git helpers ───────────────────────────────────────────────────────────────\n\nfunction getProjectRoot(): string {\n  // GIT_DIR is set to .git/ inside a hook — go one level up\n  const gitDir = process.env.GIT_DIR;\n  if (gitDir) return join(gitDir, \"..\") ;\n  return process.cwd();\n}\n\nfunction runGit(args: string[], cwd: string): string {\n  const result = spawnSync(\"git\", args, { cwd, encoding: \"utf-8\", env: process.env });\n  return result.stdout?.trim() ?? \"\";\n}\n\nfunction getCommitMeta(cwd: string): { hash: string; message: string; files: string[] } {\n  const hash = runGit([\"log\", \"-1\", \"--pretty=format:%H\"], cwd);\n  const message = runGit([\"log\", \"-1\", \"--pretty=format:%s\"], cwd);\n  const fileList = runGit([\"diff-tree\", \"--no-commit-id\", \"-r\", \"--name-only\", \"HEAD\"], cwd);\n  const files = fileList ? fileList.split(\"\\n\").filter(Boolean) : [];\n  return { hash, message, files };\n}\n\nfunction getDiffText(cwd: string, maxChars: number): string {\n  const diff = runGit([\"diff\", \"HEAD~1\", \"HEAD\", \"--unified=3\", \"--no-color\"], cwd);\n  if (!diff) return runGit([\"show\", \"--unified=3\", \"--no-color\", \"HEAD\"], cwd).slice(0, maxChars);\n  return diff.length > maxChars ? diff.slice(0, maxChars) : diff;\n}\n\nfunction matchesPattern(filename: string, pattern: string): boolean {\n  if (pattern.startsWith(\"*.\")) return filename.endsWith(pattern.slice(1));\n  if (pattern.endsWith(\"/\")) return filename.includes(pattern);\n  return filename.includes(pattern);\n}\n\nfunction applyIgnorePatterns(diff: string, patterns: string[]): string {\n  if (patterns.length === 0) return diff;\n  const lines = diff.split(\"\\n\");\n  let skip = false;\n  return lines.filter(line => {\n    if (line.startsWith(\"diff --git\")) {\n      // Extract filename from \"diff --git a/path b/path\"\n      const match = line.match(/diff --git a\\/.+ b\\/(.+)$/);\n      const filename = match?.[1] ?? line;\n      skip = patterns.some(p => matchesPattern(filename, p));\n    }\n    return !skip;\n  }).join(\"\\n\");\n}\n\nfunction shouldSkipRepo(projectRoot: string): boolean {\n  return existsSync(join(projectRoot, \".ltmignore\"));\n}\n\n// ── Extract mode ──────────────────────────────────────────────────────────────\n\nasync function runExtract(payload: {\n  diff: string;\n  commitMsg: string;\n  hash: string;\n  files: string[];\n  projectName: string;\n}): Promise<void> {\n  const { extractAndLearn } = await import(\"../lib/llmExtract.js\");\n\n  const preamble = `Git commit: ${payload.commitMsg}\\nFiles changed: ${payload.files.slice(0, 5).join(\", \")}`;\n\n  await extractAndLearn(payload.diff, payload.projectName, {\n    source: `git-commit:${payload.hash}`,\n    tags: payload.files.slice(0, 5),\n    preamble,\n  });\n}\n\n// ── Hook mode (main entry) ────────────────────────────────────────────────────\n\nasync function main(): Promise<void> {\n  // Extract mode — reads payload from stdin, called by detached subprocess\n  if (process.argv.includes(\"--extract\")) {\n    try {\n      let raw = \"\";\n      for await (const chunk of Bun.stdin.stream()) raw += new TextDecoder().decode(chunk);\n      const payload = JSON.parse(raw);\n      await runExtract(payload);\n    } catch (err) {\n      process.stderr.write(`[GitCommit] extract error: ${err}\\n`);\n    }\n    process.exit(0);\n  }\n\n  // Hook mode — must exit 0 immediately, never block git\n  try {\n    const cfg = readConfigSync() as Config;\n    if (!cfg.ltm?.gitLearnEnabled) process.exit(0);\n\n    const projectRoot = getProjectRoot();\n    if (shouldSkipRepo(projectRoot)) process.exit(0);\n\n    const { hash, message, files } = getCommitMeta(projectRoot);\n    if (!hash) process.exit(0);\n\n    const ignorePatterns = cfg.ltm?.gitLearnIgnorePatterns ?? [\"package-lock.json\", \"*.lock\", \"dist/\", \".min.js\"];\n    const minDiffChars = cfg.ltm?.gitLearnMinDiffChars ?? 200;\n\n    let diff = getDiffText(projectRoot, MAX_DIFF_CHARS);\n    diff = applyIgnorePatterns(diff, ignorePatterns);\n\n    if (diff.length < minDiffChars) process.exit(0);\n\n    const projectName = resolveProject(projectRoot).name;\n\n    const payload = { diff, commitMsg: message, hash, files, projectName };\n\n    // Spawn detached so git doesn't wait for LLM extraction — pipe payload via stdin\n    const child = Bun.spawn(\n      [\"bun\", join(PLUGIN_ROOT, \"hooks/GitCommit.bundle.mjs\"), \"--extract\"],\n      {\n        detached: true,\n        stdin: \"pipe\",\n        stdout: \"ignore\",\n        stderr: \"ignore\",\n        env: { ...process.env, CLAUDE_PLUGIN_ROOT: PLUGIN_ROOT },\n      },\n    );\n    child.stdin.write(JSON.stringify(payload));\n    child.stdin.end();\n    child.unref();\n  } catch (err) {\n    process.stderr.write(`[GitCommit] hook error: ${err}\\n`);\n  }\n\n  emitEvent({ hook: \"GitCommit\", event: EVENTS.GIT_COMMIT, ts: new Date().toISOString() });\n  process.exit(0);\n}\n\nawait safeRun(\"GitCommit\", main);","lineStart":1,"lineEnd":160,"totalLines":160,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts","time":{"start":1780929649503,"end":1780929649507}},"metadata":{"openai":{"itemId":"fc_0de7cd52ef5a02dd016a26d47132348191903522ce6c48aded"}},"id":"prt_ea7addb49001jqUhXX20MbI05X","sessionID":"ses_15852ff63ffejJtpJJJcia0535","messageID":"msg_ea7adacae001uuzBRtmJKmvHAb"}}
{"type":"tool_use","timestamp":1780929649558,"sessionID":"ses_15852ff63ffejJtpJJJcia0535","part":{"type":"tool","tool":"read","callID":"call_1eoT9QWSyHt7qkfL7JKyn7w9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/llmExtract.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/llmExtract.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * llmExtract.ts — Shared LLM extraction logic for EvaluateSession and GitCommit.\n3:  * Sends text to an LLM and stores extracted decisions/gotchas/patterns as LTM memories.\n4:  */\n5: import type { MemoryProposal } from \"./proposalQueue.js\";\n6: \n7: import { learn, getLlmConfig, callLlm, type MemoryCategory } from \"@rohirik/openltm-core\";\n8: const SYSTEM_PROMPT = `Extract learnings from the provided text. Return ONLY valid JSON:\n9: {\"decisions\":[\"...\"],\"gotchas\":[\"...\"],\"patterns\":[\"...\"],\"progress\":\"...\"}\n10: - decisions: architectural choices made (max 5, <120 chars each)\n11: - gotchas: problems hit and how fixed (max 5, <120 chars each)\n12: - patterns: reusable patterns discovered (max 5, <120 chars each)\n13: - progress: single sentence of what was accomplished\n14: Empty array if nothing found. No markdown fences.`;\n15: \n16: const LEARN_ITEMS: Array<{ key: \"decisions\" | \"gotchas\" | \"patterns\"; category: MemoryCategory; importance: number }> = [\n17:   { key: \"decisions\", category: \"architecture\", importance: 3 },\n18:   { key: \"gotchas\",   category: \"gotcha\",       importance: 4 },\n19:   { key: \"patterns\",  category: \"pattern\",       importance: 3 },\n20: ];\n21: \n22: export interface ExtractOptions {\n23:   source: string;\n24:   tags?: string[];\n25:   sessionId?: string;\n26:   preamble?: string;\n27: }\n28: \n29: /** Returns the progress string if extracted, or undefined. */\n30: export async function extractAndLearn(\n31:   text: string,\n32:   projectName: string,\n33:   opts: ExtractOptions,\n34: ): Promise<string | undefined> {\n35:   const cfg = getLlmConfig();\n36:   if (!cfg) return;\n37: \n38:   const input = opts.preamble ? `${opts.preamble}\\n\\n${text}` : text;\n39: \n40:   const raw = await callLlm(cfg, input, { systemPrompt: SYSTEM_PROMPT, maxTokens: 800, raw: true });\n41:   if (!raw) return;\n42: \n43:   let extracted: { decisions: string[]; gotchas: string[]; patterns: string[]; progress: string };\n44:   try {\n45:     extracted = JSON.parse(raw.replace(/^```json\\s*/i, \"\").replace(/```\\s*$/, \"\").trim());\n46:   } catch {\n47:     return undefined; // silent: LLM returned non-JSON; caller treats undefined as no learnings\n48:   }\n49: \n50:   for (const { key, category, importance } of LEARN_ITEMS) {\n51:     for (const item of ((extracted[key] as string[]) ?? []).slice(0, 5)) {\n52:       if (item.length > 10) {\n53:         learn({\n54:           content: item,\n55:           category,\n56:           importance,\n57:           project_scope: projectName,\n58:           source: opts.source,\n59:           tags: opts.tags,\n60:           skipExport: true,\n61:         });\n62:       }\n63:     }\n64:   }\n65: \n66:   return extracted.progress?.length > 5 ? extracted.progress : undefined;\n67: }\n68: \n69: /** Returns memory proposals without writing to the DB. Caller decides what to persist. */\n70: export async function extractProposals(\n71:   text: string,\n72:   projectName: string,\n73:   opts: ExtractOptions,\n74: ): Promise<{ proposals: MemoryProposal[]; progress: string | undefined }> {\n75:   const cfg = getLlmConfig();\n76:   if (!cfg) return { proposals: [], progress: undefined };\n77: \n78:   const input = opts.preamble ? `${opts.preamble}\\n\\n${text}` : text;\n79: \n80:   const raw = await callLlm(cfg, input, { systemPrompt: SYSTEM_PROMPT, maxTokens: 800, raw: true });\n81:   if (!raw) return { proposals: [], progress: undefined };\n82: \n83:   let extracted: { decisions: string[]; gotchas: string[]; patterns: string[]; progress: string };\n84:   try {\n85:     extracted = JSON.parse(raw.replace(/^```json\\s*/i, \"\").replace(/```\\s*$/, \"\").trim());\n86:   } catch {\n87:     return { proposals: [], progress: undefined }; // silent: same as extractAndLearn — non-JSON LLM response\n88:   }\n89: \n90:   const proposals: MemoryProposal[] = [];\n91:   for (const { key, category, importance } of LEARN_ITEMS) {\n92:     for (const item of ((extracted[key] as string[]) ?? []).slice(0, 5)) {\n93:       if (item.length > 10) {\n94:         proposals.push({ content: item, category, importance, source: opts.source });\n95:       }\n96:     }\n97:   }\n98: \n99:   const progress = extracted.progress?.length > 5 ? extracted.progress : undefined;\n100:   return { proposals, progress };\n101: }\n\n(End of file - total 101 lines)\n</content>","metadata":{"preview":"/**\n * llmExtract.ts — Shared LLM extraction logic for EvaluateSession and GitCommit.\n * Sends text to an LLM and stores extracted decisions/gotchas/patterns as LTM memories.\n */\nimport type { MemoryProposal } from \"./proposalQueue.js\";\n\nimport { learn, getLlmConfig, callLlm, type MemoryCategory } from \"@rohirik/openltm-core\";\nconst SYSTEM_PROMPT = `Extract learnings from the provided text. Return ONLY valid JSON:\n{\"decisions\":[\"...\"],\"gotchas\":[\"...\"],\"patterns\":[\"...\"],\"progress\":\"...\"}\n- decisions: architectural choices made (max 5, <120 chars each)\n- gotchas: problems hit and how fixed (max 5, <120 chars each)\n- patterns: reusable patterns discovered (max 5, <120 chars each)\n- progress: single sentence of what was accomplished\nEmpty array if nothing found. No markdown fences.`;\n\nconst LEARN_ITEMS: Array<{ key: \"decisions\" | \"gotchas\" | \"patterns\"; category: MemoryCategory; importance: number }> = [\n  { key: \"decisions\", category: \"architecture\", importance: 3 },\n  { key: \"gotchas\",   category: \"gotcha\",       importance: 4 },\n  { key: \"patterns\",  category: \"pattern\",       importance: 3 },\n];","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/llmExtract.ts","text":"/**\n * llmExtract.ts — Shared LLM extraction logic for EvaluateSession and GitCommit.\n * Sends text to an LLM and stores extracted decisions/gotchas/patterns as LTM memories.\n */\nimport type { MemoryProposal } from \"./proposalQueue.js\";\n\nimport { learn, getLlmConfig, callLlm, type MemoryCategory } from \"@rohirik/openltm-core\";\nconst SYSTEM_PROMPT = `Extract learnings from the provided text. Return ONLY valid JSON:\n{\"decisions\":[\"...\"],\"gotchas\":[\"...\"],\"patterns\":[\"...\"],\"progress\":\"...\"}\n- decisions: architectural choices made (max 5, <120 chars each)\n- gotchas: problems hit and how fixed (max 5, <120 chars each)\n- patterns: reusable patterns discovered (max 5, <120 chars each)\n- progress: single sentence of what was accomplished\nEmpty array if nothing found. No markdown fences.`;\n\nconst LEARN_ITEMS: Array<{ key: \"decisions\" | \"gotchas\" | \"patterns\"; category: MemoryCategory; importance: number }> = [\n  { key: \"decisions\", category: \"architecture\", importance: 3 },\n  { key: \"gotchas\",   category: \"gotcha\",       importance: 4 },\n  { key: \"patterns\",  category: \"pattern\",       importance: 3 },\n];\n\nexport interface ExtractOptions {\n  source: string;\n  tags?: string[];\n  sessionId?: string;\n  preamble?: string;\n}\n\n/** Returns the progress string if extracted, or undefined. */\nexport async function extractAndLearn(\n  text: string,\n  projectName: string,\n  opts: ExtractOptions,\n): Promise<string | undefined> {\n  const cfg = getLlmConfig();\n  if (!cfg) return;\n\n  const input = opts.preamble ? `${opts.preamble}\\n\\n${text}` : text;\n\n  const raw = await callLlm(cfg, input, { systemPrompt: SYSTEM_PROMPT, maxTokens: 800, raw: true });\n  if (!raw) return;\n\n  let extracted: { decisions: string[]; gotchas: string[]; patterns: string[]; progress: string };\n  try {\n    extracted = JSON.parse(raw.replace(/^```json\\s*/i, \"\").replace(/```\\s*$/, \"\").trim());\n  } catch {\n    return undefined; // silent: LLM returned non-JSON; caller treats undefined as no learnings\n  }\n\n  for (const { key, category, importance } of LEARN_ITEMS) {\n    for (const item of ((extracted[key] as string[]) ?? []).slice(0, 5)) {\n      if (item.length > 10) {\n        learn({\n          content: item,\n          category,\n          importance,\n          project_scope: projectName,\n          source: opts.source,\n          tags: opts.tags,\n          skipExport: true,\n        });\n      }\n    }\n  }\n\n  return extracted.progress?.length > 5 ? extracted.progress : undefined;\n}\n\n/** Returns memory proposals without writing to the DB. Caller decides what to persist. */\nexport async function extractProposals(\n  text: string,\n  projectName: string,\n  opts: ExtractOptions,\n): Promise<{ proposals: MemoryProposal[]; progress: string | undefined }> {\n  const cfg = getLlmConfig();\n  if (!cfg) return { proposals: [], progress: undefined };\n\n  const input = opts.preamble ? `${opts.preamble}\\n\\n${text}` : text;\n\n  const raw = await callLlm(cfg, input, { systemPrompt: SYSTEM_PROMPT, maxTokens: 800, raw: true });\n  if (!raw) return { proposals: [], progress: undefined };\n\n  let extracted: { decisions: string[]; gotchas: string[]; patterns: string[]; progress: string };\n  try {\n    extracted = JSON.parse(raw.replace(/^```json\\s*/i, \"\").replace(/```\\s*$/, \"\").trim());\n  } catch {\n    return { proposals: [], progress: undefined }; // silent: same as extractAndLearn — non-JSON LLM response\n  }\n\n  const proposals: MemoryProposal[] = [];\n  for (const { key, category, importance } of LEARN_ITEMS) {\n    for (const item of ((extracted[key] as string[]) ?? []).slice(0, 5)) {\n      if (item.length > 10) {\n        proposals.push({ content: item, category, importance, source: opts.source });\n      }\n    }\n  }\n\n  const progress = extracted.progress?.length > 5 ? extracted.progress : undefined;\n  return { proposals, progress };\n}","lineStart":1,"lineEnd":101,"totalLines":101,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/lib/llmExtract.ts","time":{"start":1780929649550,"end":1780929649556}},"metadata":{"openai":{"itemId":"fc_0de7cd52ef5a02dd016a26d471324081919f9f41275ad6fd7f"}},"id":"prt_ea7addb650013hvFncW7L2OkCf","sessionID":"ses_15852ff63ffejJtpJJJcia0535","messageID":"msg_ea7adacae001uuzBRtmJKmvHAb"}}
