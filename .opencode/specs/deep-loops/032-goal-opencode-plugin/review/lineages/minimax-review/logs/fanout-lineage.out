{"type":"tool_use","timestamp":1783147647786,"sessionID":"ses_0d42abedcffewM196xEPACWSgW","part":{"type":"tool","tool":"read","callID":"call_function_s7qkcc0i4w92_2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/tests/mk-goal-export-contract.test.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/tests/mk-goal-export-contract.test.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ COMPONENT: mk-goal Export Contract Tests                               ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ PURPOSE: Pin the OpenCode plugin loader export shape.                  ║\n5: // ╚══════════════════════════════════════════════════════════════════════════╝\n6: 'use strict';\n7: \n8: const assert = require('node:assert/strict');\n9: const test = require('node:test');\n10: const { join } = require('node:path');\n11: const { pathToFileURL } = require('node:url');\n12: \n13: async function loadPluginModule() {\n14:   const pluginUrl = pathToFileURL(join(__dirname, '..', 'mk-goal.js')).href;\n15:   return import(pluginUrl);\n16: }\n17: \n18: test('module exports only the default plugin entrypoint', async () => {\n19:   const pluginModule = await loadPluginModule();\n20:   assert.deepEqual(Object.keys(pluginModule), ['default']);\n21: });\n22: \n23: test('default export is a plugin factory function', async () => {\n24:   const pluginModule = await loadPluginModule();\n25:   assert.equal(typeof pluginModule.default, 'function');\n26: });\n27: \n28: test('default export exposes the complete pinned __test seam list', async () => {\n29:   const pluginModule = await loadPluginModule();\n30:   assert.deepEqual(Object.keys(pluginModule.default.__test).sort(), [\n31:     'GoalError',\n32:     'accountUsage',\n33:     'buildEnhancedGoalPrompt',\n34:     'clearGoal',\n35:     'ensureGoalStateDir',\n36:     'executeGoalAction',\n37:     'executeGoalStatus',\n38:     'fsyncDirectory',\n39:     'goalPathForSession',\n40:     'markGoalStatus',\n41:     'maybeContinueGoal',\n42:     'maybeVerifyGoal',\n43:     'readGoal',\n44:     'renderGoalInjection',\n45:     'sessionKeyForSession',\n46:     'setGoal',\n47:     'writeGoalAtomic',\n48:   ]);\n49: });\n\n(End of file - total 49 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-goal Export Contract Tests                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Pin the OpenCode plugin loader export shape.                  ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\nconst assert = require('node:assert/strict');\nconst test = require('node:test');\nconst { join } = require('node:path');\nconst { pathToFileURL } = require('node:url');\n\nasync function loadPluginModule() {\n  const pluginUrl = pathToFileURL(join(__dirname, '..', 'mk-goal.js')).href;\n  return import(pluginUrl);\n}\n\ntest('module exports only the default plugin entrypoint', async () => {\n  const pluginModule = await loadPluginModule();\n  assert.deepEqual(Object.keys(pluginModule), ['default']);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/tests/mk-goal-export-contract.test.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-goal Export Contract Tests                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Pin the OpenCode plugin loader export shape.                  ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\nconst assert = require('node:assert/strict');\nconst test = require('node:test');\nconst { join } = require('node:path');\nconst { pathToFileURL } = require('node:url');\n\nasync function loadPluginModule() {\n  const pluginUrl = pathToFileURL(join(__dirname, '..', 'mk-goal.js')).href;\n  return import(pluginUrl);\n}\n\ntest('module exports only the default plugin entrypoint', async () => {\n  const pluginModule = await loadPluginModule();\n  assert.deepEqual(Object.keys(pluginModule), ['default']);\n});\n\ntest('default export is a plugin factory function', async () => {\n  const pluginModule = await loadPluginModule();\n  assert.equal(typeof pluginModule.default, 'function');\n});\n\ntest('default export exposes the complete pinned __test seam list', async () => {\n  const pluginModule = await loadPluginModule();\n  assert.deepEqual(Object.keys(pluginModule.default.__test).sort(), [\n    'GoalError',\n    'accountUsage',\n    'buildEnhancedGoalPrompt',\n    'clearGoal',\n    'ensureGoalStateDir',\n    'executeGoalAction',\n    'executeGoalStatus',\n    'fsyncDirectory',\n    'goalPathForSession',\n    'markGoalStatus',\n    'maybeContinueGoal',\n    'maybeVerifyGoal',\n    'readGoal',\n    'renderGoalInjection',\n    'sessionKeyForSession',\n    'setGoal',\n    'writeGoalAtomic',\n  ]);\n});","lineStart":1,"lineEnd":49,"totalLines":49,"truncated":false}},"title":".opencode/plugins/tests/mk-goal-export-contract.test.cjs","time":{"start":1783147647782,"end":1783147647785}},"id":"prt_f2be1d307001aB3Zbg8ystx49M","sessionID":"ses_0d42abedcffewM196xEPACWSgW","messageID":"msg_f2be1ba5b001qzgkxq94yjuKJC"}}
