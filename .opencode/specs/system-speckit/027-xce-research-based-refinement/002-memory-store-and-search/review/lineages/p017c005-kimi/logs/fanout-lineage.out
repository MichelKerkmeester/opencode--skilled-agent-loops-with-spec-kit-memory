{"type":"tool_use","timestamp":1781723719995,"sessionID":"ses_128ff49bbffeaBi7hiBur0TbQX","part":{"type":"tool","tool":"read","callID":"tool_4n68TuFYdAND9EioUo7yjeQ0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":2000,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n2000:     const adjustedBudget = Math.max(budgetResult.budget - headerOverhead, 200);\n2001: \n2002:     if (s3meta.tokenBudget) {\n2003:       s3meta.tokenBudget.headerOverhead = headerOverhead;\n2004:       s3meta.tokenBudget.adjustedBudget = adjustedBudget;\n2005:     }\n2006: \n2007:     const budgeted = truncateToBudget(reranked, adjustedBudget, {\n2008:       includeContent: options.includeContent ?? false,\n2009:       queryId: `hybrid-${Date.now()}`,\n2010:       limit: options.limit,\n2011:       query,\n2012:     });\n2013:     reranked = budgeted.results;\n2014:     budgetTruncated = budgeted.truncated;\n2015:     budgetLimit = budgetResult.budget;\n2016: \n2017:     // Cosine-primary head reorder (SPECKIT_COSINE_TOPN_REORDER, default-ON).\n2018:     // Must run AFTER truncateToBudget: that step re-sorts the survivors by the\n2019:     // fused `score`, so a pre-truncation reorder would be clobbered. Applied to\n2020:     // the budgeted survivors it is the last word on order without disturbing the\n2021:     // budget membership decision. Skipped in evaluationMode so the labeled-set\n2022:     // top-K window stays exactly as fused.\n2023:     if (isCosineTopnReorderEnabled() && reranked.length > 1) {\n2024:       reranked = reorderTopNByCosine(reranked);\n2025:     }\n2026:   }\n2027: \n2028:   if (reranked.length > 0) {\n2029:     reranked = reranked.map((row): HybridSearchResult => {\n20