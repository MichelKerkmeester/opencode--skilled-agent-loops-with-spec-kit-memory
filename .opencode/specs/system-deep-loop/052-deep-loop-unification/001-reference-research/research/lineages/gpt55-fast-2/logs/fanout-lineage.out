 1 } },\n250:     ]);\n251:     expect(result.summary.gauges).toEqual({ lag: 0, pending: 0, failed: 1 });\n252:   });\n253: \n254:   it('emits one stall warning without aborting when no lag action is configured', async () => {\n255:     // The lag-ceiling is a STALL detector: its metric is time since the pool last made\n256:     // progress while work is still queued. Here the active item is gated forever (a hung\n257:     // worker holding the only slot) while 'queued' waits, so nothing settles past the\n258:     // ceiling ŌĆö a genuine stall ŌĆö and the one-shot warning fires.\n259:     const events: Array<Record<string, unknown>> = [];\n260:     const gated = makeGatedWorker();\n261:     const run = runCappedPool({\n262:       items: [{ label: 'active' }, { label: 'queued' }],\n263:       concurrency: 1,\n264:       lagCeilingMs: 10,\n265:       worker: gated.worker,\n266:       onEvent: (event) => events.push(event),\n267:     });\n268: \n269:     await flush();\n270:     await sleep(30);\n271:     expect(gated.inFlight()).toEqual(['active']);\n272:     expect(events.filter((event) => event.event === 'lag_ceiling_exceeded')).toEqual([\n273:       expect.objectContaining({\n274:         severity: 'warning',\n275:         metric: 'time_since_last_completion',\n276:         lag_ceiling_ms: 10,\n277:         gauges: expect.objectContaining({ pending: 1 }),\n278:       }),\n279:     ]);\n280:     expect(events.filter((event) => event.event === 'retry_scheduled')).toEqual([]);\n281: \n282:     gated.releaseAll();\n283:     await flush();\n284:     gated.releaseAll();\n285:     const result = await run;\n286:     expect(result.summary).toMatchObject({ succeeded: 2, failed: 0 });\n287:   });\n288: \n289:   it('aborts and requeues a stalled item through the timeout retry ledger when opted in', async () => {\n290:     const events: Array<Record<string, unknown>> = [];\n291:     const calls = new Map<string, number>();\n292:     const abortedLabels: string[] = [];\n293:     let liveWorkers = 0;\n294:     let maxLiveWorkers = 0;\n295:     const worker = (item: { label: string }, ctx: { signal?: AbortSignal }) => {\n296:       const callCount = (calls.get(item.label) ?? 0) + 1;\n297:       calls.set(item.label, callCount);\n298:       liveWorkers += 1;\n299:       maxLiveWorkers = Math.max(maxLiveWorkers, liveWorkers);\n300: \n301:       if (item.label === 'active' && callCount === 1) {\n302:         ctx.signal?.addEventListener('abort', () => {\n303:           abortedLabels.push(item.label);\n304:           liveWorkers -= 1;\n305:         }, { once: true });\n306:         return new Promise(() => {});\n307:       }\n308: \n309:       return Promise.resolve().then(() => {\n310:         liveWorkers -= 1;\n311:         return { label: item.label, callCount };\n312:       });\n313:     };\n314: \n315:     const run = runCappedPool({\n316:       items: [{ label: 'active' }, { label: 'queued' }],\n317:       concurrency: 1,\n318:       maxRetries: 1,\n319:       lagCeilingMs: 10,\n320:       lagCeilingAction: 'abort-requeue',\n321:       worker,\n322:       onEvent: (event) => events.push(event),\n323:     });\n324: \n325:     await sleep(30);\n326:     const result = await run;\n327:     expect(abortedLabels).toEqual(['active']);\n328:     expect(calls.get('active')).toBe(2);\n329:     expect(calls.get('queued')).toBe(1);\n330:     expect(maxLiveWorkers).toBe(1);\n331:     expect(result.results[0]).toMatchObject({\n332:       status: 'fulfilled',\n333:       retry_attempts: 1,\n334:       output: { label: 'active', callCount: 2 },\n335:     });\n336:     expect(events.filter((event) => event.event === 'lag_ceiling_abort')).toEqual([\n337:       expect.objectContaining({\n338:         label: 'active',\n339:         action: 'abort-requeue',\n340:         lag_ceiling_ms: 10,\n341:       }),\n342:     ]);\n343:     expect(events.filter((event) => event.event === 'failed' && event.label === 'active')).toEqual([\n344:       expect.objectContaining({\n345:         terminal: false,\n346:         error: expect.objectContaining({\n347:           failure_class: 'timeout',\n348:           retry_verdict: 'transient',\n349:           retryable: true,\n350:           aborted: true,\n351:           abort_reason: 'lag_ceiling_exceeded',\n352:         }),\n353:       }),\n354:     ]);\n355:     expect(events.filter((event) => event.event === 'retry_scheduled')).toEqual([\n356:       expect.objectContaining({\n357:         label: 'active',\n358:         retry_count: 1,\n359:         next_attempt: 2,\n360:         failure_class: 'timeout',\n361:         retry_verdict: 'transient',\n362:       }),\n363:     ]);\n364:     expect(result.summary).toMatchObject({ total: 2, succeeded: 2, failed: 0 });\n365:   });\n366: \n367:   it('requires an explicit positive lag ceiling for abort-requeue', () => {\n368:     expect(() =>\n369:       runCappedPool({\n370:         items: [{ label: 'active' }, { label: 'queued' }],\n371:         concurrency: 1,\n372:         lagCeilingAction: 'abort-requeue',\n373:         worker: async () => ({}),\n374:       }),\n375:     ).toThrow('lagCeilingAction \"abort-requeue\" requires lagCeilingMs > 0');\n376:   });\n377: \n378:   it('stays silent on normal width>concurrency backpressure (steady completions reset the stall clock)', async () => {\n379:     // A HEALTHY pool wider than its concurrency: the queue tail waits for a slot (normal\n380:     // backpressure) but the pool keeps settling items, so time-since-last-completion never\n381:     // crosses the ceiling and the stall detector must NOT fire ŌĆö the false positive the old\n382:     // time-since-pool-start metric produced is gone. Driven deterministically with the gated\n383:     // worker: we release each in-flight item promptly (a completion lands within microtasks,\n384:     // far inside the generous 200ms ceiling), so the result does not depend on wall-clock\n385:     // race margins under parallel-test CPU contention.\n386:     const events: Array<Record<string, unknown>> = [];\n387:     const gated = makeGatedWorker();\n388:     const items = ['a', 'b', 'c', 'd', 'e', 'f'].map((label) => ({ label }));\n389:     const run = runCappedPool({\n390:       items,\n391:       concurrency: 2,\n392:       lagCeilingMs: 200,\n393:       worker: gated.worker,\n394:       onEvent: (event) => events.push(event),\n395:     });\n396: \n397:     // Drain the pool by releasing whatever is in flight, repeatedly. Each release settles an\n398:     // item (resetting the stall clock) and admits the next from the queue, modelling a\n399:     // healthy pool that keeps making progress while the tail is back-pressured.\n400:     for (let i = 0; i < items.length + 1; i += 1) {\n401:       await flush();\n402:       gated.releaseAll();\n403:     }\n404:     const result = await run;\n405: \n406:     expect(events.filter((event) => event.event === 'lag_ceiling_exceeded')).toEqual([]);\n407:     expect(result.summary).toMatchObject({ total: 6, succeeded: 6, failed: 0 });\n408:   });\n409: \n410:   it('keeps the lag-ceiling silent when the ceiling is left at the default (0)', async () => {\n411:     // Byte-silent when off: the gauge default is 0 (disabled). Even a genuine stall emits\n412:     // no lag warning and no oldest_pending_lag_ms gauge field when the ceiling is unset.\n413:     const events: Array<Record<string, unknown>> = [];\n414:     const gated = makeGatedWorker();\n415:     const run = runCappedPool({\n416:       items: [{ label: 'active' }, { label: 'queued' }],\n417:       concurrency: 1,\n418:       worker: gated.worker,\n419:       onEvent: (event) => events.push(event),\n420:     });\n421: \n422:     await flush();\n423:     await sleep(30);\n424:     expect(events.filter((event) => event.event === 'lag_ceiling_exceeded')).toEqual([]);\n425:     expect(events.every((event) => !('oldest_pending_lag_ms' in (event.gauges as object)))).toBe(true);\n426: \n427:     gated.releaseAll();\n428:     await flush();\n429:     gated.releaseAll();\n430:     const result = await run;\n431:     expect(result.summary).toMatchObject({ succeeded: 2, failed: 0 });\n432:   });\n433: \n434:   it('force-fails a dead subprocess attempt that never records a terminal ledger event', async () => {\n435:     const events: Array<Record<string, unknown>> = [];\n436:     const liveness = new Map<string, { alive: boolean; exitedAtMs?: number; pid?: number }>();\n437: \n438:     const result = await runCappedPool({\n439:       items: [{ label: 'orphan' }],\n440:       concurrency: 1,\n441:       postExitGraceMs: 10,\n442:       postExitPollMs: 2,\n443:       getAttemptLiveness: (attempt) => liveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n444:       worker: async (item: { label: string }, ctx: { attempt?: number }) => {\n445:         liveness.set(`${item.label}:${ctx.attempt ?? 1}`, { alive: false, exitedAtMs: Date.now() - 20, pid: 12345 });\n446:         return new Promise(() => {});\n447:       },\n448:       onEvent: (event) => events.push(event),\n449:     });\n450: \n451:     expect(result.summary).toMatchObject({ total: 1, succeeded: 0, failed: 1, all_failed: true });\n452:     expect(result.results[0]).toMatchObject({\n453:       status: 'rejected',\n454:       error: {\n455:         retryable: false,\n456:         reason: 'orphaned_after_subprocess_exit',\n457:         post_exit_grace_ms: 10,\n458:         pid: 12345,\n459:       },\n460:     });\n461:     expect(events.filter((event) => event.event === 'failed')).toEqual([\n462:       expect.objectContaining({\n463:         label: 'orphan',\n464:         terminal: true,\n465:         error: expect.objectContaining({ reason: 'orphaned_after_subprocess_exit' }),\n466:       }),\n467:     ]);\n468:   });\n469: \n470:   it('does not force-fail a genuinely alive worker inside the post-exit grace window', async () => {\n471:     const events: Array<Record<string, unknown>> = [];\n472:     const gated = makeGatedWorker();\n473:     const run = runCappedPool({\n474:       items: [{ label: 'alive' }],\n475:       concurrency: 1,\n476:       postExitGraceMs: 10,\n477:       postExitPollMs: 2,\n478:       getAttemptLiveness: () => ({ alive: true, pid: 23456 }),\n479:       worker: gated.worker,\n480:       onEvent: (event) => events.push(event),\n\n(Showing lines 221-480 of 709. Use offset=481 to continue.)\n</content>","metadata":{"preview":"      concurrency: 2,\n      worker: async (item: { label: string }) => {\n        if (item.label === 'boom') throw new Error('x');\n        return {};\n      },\n      onEvent: (event) => events.push(event),\n    });\n    const byLabel = (label: string) => events.filter((e) => e.label === label).map((e) => e.event);\n    expect(byLabel('ok')).toEqual(['started', 'completed']);\n    expect(byLabel('boom')).toEqual(['started', 'failed']);\n  });\n\n  it('attaches lag, pending, and failed gauges to events and final summary', async () => {\n    const events: Array<Record<string, unknown>> = [];\n    const result = await runCappedPool({\n      items: [{ label: 'ok' }, { label: 'boom' }],\n      concurrency: 1,\n      worker: async (item: { label: string }) => {\n        if (item.label === 'boom') throw new Error('x');\n        return {};","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/fanout-pool.vitest.ts","text":"      concurrency: 2,\n      worker: async (item: { label: string }) => {\n        if (item.label === 'boom') throw new Error('x');\n        return {};\n      },\n      onEvent: (event) => events.push(event),\n    });\n    const byLabel = (label: string) => events.filter((e) => e.label === label).map((e) => e.event);\n    expect(byLabel('ok')).toEqual(['started', 'completed']);\n    expect(byLabel('boom')).toEqual(['started', 'failed']);\n  });\n\n  it('attaches lag, pending, and failed gauges to events and final summary', async () => {\n    const events: Array<Record<string, unknown>> = [];\n    const result = await runCappedPool({\n      items: [{ label: 'ok' }, { label: 'boom' }],\n      concurrency: 1,\n      worker: async (item: { label: string }) => {\n        if (item.label === 'boom') throw new Error('x');\n        return {};\n      },\n      onEvent: (event) => events.push(event),\n    });\n\n    expect(events.map((event) => ({ event: event.event, gauges: event.gauges }))).toEqual([\n      { event: 'started', gauges: { lag: 2, pending: 1, failed: 0 } },\n      { event: 'completed', gauges: { lag: 1, pending: 1, failed: 0 } },\n      { event: 'started', gauges: { lag: 1, pending: 0, failed: 0 } },\n      { event: 'failed', gauges: { lag: 0, pending: 0, failed: 1 } },\n    ]);\n    expect(result.summary.gauges).toEqual({ lag: 0, pending: 0, failed: 1 });\n  });\n\n  it('emits one stall warning without aborting when no lag action is configured', async () => {\n    // The lag-ceiling is a STALL detector: its metric is time since the pool last made\n    // progress while work is still queued. Here the active item is gated forever (a hung\n    // worker holding the only slot) while 'queued' waits, so nothing settles past the\n    // ceiling ŌĆö a genuine stall ŌĆö and the one-shot warning fires.\n    const events: Array<Record<string, unknown>> = [];\n    const gated = makeGatedWorker();\n    const run = runCappedPool({\n      items: [{ label: 'active' }, { label: 'queued' }],\n      concurrency: 1,\n      lagCeilingMs: 10,\n      worker: gated.worker,\n      onEvent: (event) => events.push(event),\n    });\n\n    await flush();\n    await sleep(30);\n    expect(gated.inFlight()).toEqual(['active']);\n    expect(events.filter((event) => event.event === 'lag_ceiling_exceeded')).toEqual([\n      expect.objectContaining({\n        severity: 'warning',\n        metric: 'time_since_last_completion',\n        lag_ceiling_ms: 10,\n        gauges: expect.objectContaining({ pending: 1 }),\n      }),\n    ]);\n    expect(events.filter((event) => event.event === 'retry_scheduled')).toEqual([]);\n\n    gated.releaseAll();\n    await flush();\n    gated.releaseAll();\n    const result = await run;\n    expect(result.summary).toMatchObject({ succeeded: 2, failed: 0 });\n  });\n\n  it('aborts and requeues a stalled item through the timeout retry ledger when opted in', async () => {\n    const events: Array<Record<string, unknown>> = [];\n    const calls = new Map<string, number>();\n    const abortedLabels: string[] = [];\n    let liveWorkers = 0;\n    let maxLiveWorkers = 0;\n    const worker = (item: { label: string }, ctx: { signal?: AbortSignal }) => {\n      const callCount = (calls.get(item.label) ?? 0) + 1;\n      calls.set(item.label, callCount);\n      liveWorkers += 1;\n      maxLiveWorkers = Math.max(maxLiveWorkers, liveWorkers);\n\n      if (item.label === 'active' && callCount === 1) {\n        ctx.signal?.addEventListener('abort', () => {\n          abortedLabels.push(item.label);\n          liveWorkers -= 1;\n        }, { once: true });\n        return new Promise(() => {});\n      }\n\n      return Promise.resolve().then(() => {\n        liveWorkers -= 1;\n        return { label: item.label, callCount };\n      });\n    };\n\n    const run = runCappedPool({\n      items: [{ label: 'active' }, { label: 'queued' }],\n      concurrency: 1,\n      maxRetries: 1,\n      lagCeilingMs: 10,\n      lagCeilingAction: 'abort-requeue',\n      worker,\n      onEvent: (event) => events.push(event),\n    });\n\n    await sleep(30);\n    const result = await run;\n    expect(abortedLabels).toEqual(['active']);\n    expect(calls.get('active')).toBe(2);\n    expect(calls.get('queued')).toBe(1);\n    expect(maxLiveWorkers).toBe(1);\n    expect(result.results[0]).toMatchObject({\n      status: 'fulfilled',\n      retry_attempts: 1,\n      output: { label: 'active', callCount: 2 },\n    });\n    expect(events.filter((event) => event.event === 'lag_ceiling_abort')).toEqual([\n      expect.objectContaining({\n        label: 'active',\n        action: 'abort-requeue',\n        lag_ceiling_ms: 10,\n      }),\n    ]);\n    expect(events.filter((event) => event.event === 'failed' && event.label === 'active')).toEqual([\n      expect.objectContaining({\n        terminal: false,\n        error: expect.objectContaining({\n          failure_class: 'timeout',\n          retry_verdict: 'transient',\n          retryable: true,\n          aborted: true,\n          abort_reason: 'lag_ceiling_exceeded',\n        }),\n      }),\n    ]);\n    expect(events.filter((event) => event.event === 'retry_scheduled')).toEqual([\n      expect.objectContaining({\n        label: 'active',\n        retry_count: 1,\n        next_attempt: 2,\n        failure_class: 'timeout',\n        retry_verdict: 'transient',\n      }),\n    ]);\n    expect(result.summary).toMatchObject({ total: 2, succeeded: 2, failed: 0 });\n  });\n\n  it('requires an explicit positive lag ceiling for abort-requeue', () => {\n    expect(() =>\n      runCappedPool({\n        items: [{ label: 'active' }, { label: 'queued' }],\n        concurrency: 1,\n        lagCeilingAction: 'abort-requeue',\n        worker: async () => ({}),\n      }),\n    ).toThrow('lagCeilingAction \"abort-requeue\" requires lagCeilingMs > 0');\n  });\n\n  it('stays silent on normal width>concurrency backpressure (steady completions reset the stall clock)', async () => {\n    // A HEALTHY pool wider than its concurrency: the queue tail waits for a slot (normal\n    // backpressure) but the pool keeps settling items, so time-since-last-completion never\n    // crosses the ceiling and the stall detector must NOT fire ŌĆö the false positive the old\n    // time-since-pool-start metric produced is gone. Driven deterministically with the gated\n    // worker: we release each in-flight item promptly (a completion lands within microtasks,\n    // far inside the generous 200ms ceiling), so the result does not depend on wall-clock\n    // race margins under parallel-test CPU contention.\n    const events: Array<Record<string, unknown>> = [];\n    const gated = makeGatedWorker();\n    const items = ['a', 'b', 'c', 'd', 'e', 'f'].map((label) => ({ label }));\n    const run = runCappedPool({\n      items,\n      concurrency: 2,\n      lagCeilingMs: 200,\n      worker: gated.worker,\n      onEvent: (event) => events.push(event),\n    });\n\n    // Drain the pool by releasing whatever is in flight, repeatedly. Each release settles an\n    // item (resetting the stall clock) and admits the next from the queue, modelling a\n    // healthy pool that keeps making progress while the tail is back-pressured.\n    for (let i = 0; i < items.length + 1; i += 1) {\n      await flush();\n      gated.releaseAll();\n    }\n    const result = await run;\n\n    expect(events.filter((event) => event.event === 'lag_ceiling_exceeded')).toEqual([]);\n    expect(result.summary).toMatchObject({ total: 6, succeeded: 6, failed: 0 });\n  });\n\n  it('keeps the lag-ceiling silent when the ceiling is left at the default (0)', async () => {\n    // Byte-silent when off: the gauge default is 0 (disabled). Even a genuine stall emits\n    // no lag warning and no oldest_pending_lag_ms gauge field when the ceiling is unset.\n    const events: Array<Record<string, unknown>> = [];\n    const gated = makeGatedWorker();\n    const run = runCappedPool({\n      items: [{ label: 'active' }, { label: 'queued' }],\n      concurrency: 1,\n      worker: gated.worker,\n      onEvent: (event) => events.push(event),\n    });\n\n    await flush();\n    await sleep(30);\n    expect(events.filter((event) => event.event === 'lag_ceiling_exceeded')).toEqual([]);\n    expect(events.every((event) => !('oldest_pending_lag_ms' in (event.gauges as object)))).toBe(true);\n\n    gated.releaseAll();\n    await flush();\n    gated.releaseAll();\n    const result = await run;\n    expect(result.summary).toMatchObject({ succeeded: 2, failed: 0 });\n  });\n\n  it('force-fails a dead subprocess attempt that never records a terminal ledger event', async () => {\n    const events: Array<Record<string, unknown>> = [];\n    const liveness = new Map<string, { alive: boolean; exitedAtMs?: number; pid?: number }>();\n\n    const result = await runCappedPool({\n      items: [{ label: 'orphan' }],\n      concurrency: 1,\n      postExitGraceMs: 10,\n      postExitPollMs: 2,\n      getAttemptLiveness: (attempt) => liveness.get(`${attempt.label}:${attempt.attempt}`) ?? { alive: true },\n      worker: async (item: { label: string }, ctx: { attempt?: number }) => {\n        liveness.set(`${item.label}:${ctx.attempt ?? 1}`, { alive: false, exitedAtMs: Date.now() - 20, pid: 12345 });\n        return new Promise(() => {});\n      },\n      onEvent: (event) => events.push(event),\n    });\n\n    expect(result.summary).toMatchObject({ total: 1, succeeded: 0, failed: 1, all_failed: true });\n    expect(result.results[0]).toMatchObject({\n      status: 'rejected',\n      error: {\n        retryable: false,\n        reason: 'orphaned_after_subprocess_exit',\n        post_exit_grace_ms: 10,\n        pid: 12345,\n      },\n    });\n    expect(events.filter((event) => event.event === 'failed')).toEqual([\n      expect.objectContaining({\n        label: 'orphan',\n        terminal: true,\n        error: expect.objectContaining({ reason: 'orphaned_after_subprocess_exit' }),\n      }),\n    ]);\n  });\n\n  it('does not force-fail a genuinely alive worker inside the post-exit grace window', async () => {\n    const events: Array<Record<string, unknown>> = [];\n    const gated = makeGatedWorker();\n    const run = runCappedPool({\n      items: [{ label: 'alive' }],\n      concurrency: 1,\n      postExitGraceMs: 10,\n      postExitPollMs: 2,\n      getAttemptLiveness: () => ({ alive: true, pid: 23456 }),\n      worker: gated.worker,\n      onEvent: (event) => events.push(event),","lineStart":221,"lineEnd":480,"totalLines":709,"t