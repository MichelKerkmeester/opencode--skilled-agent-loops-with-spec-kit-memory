ites FSRS strengthening updates to the memory_index for each returned spec-doc record. Off by default to avoid write-on-read side effects.'\n      },\n      includeArchived: {\n        type: 'boolean',\n        default: false,\n        description: 'Include archived spec-doc records in search results. Default: false (archived excluded).'\n      },\n      mode: {\n        type: 'string',\n        enum: ['auto', 'deep'],\n        default: 'auto',\n        description: 'Search mode. \"auto\" uses standard retrieval. \"deep\" enables multi-query expansion for broader recall.'\n      },\n      includeTrace: {\n        type: 'boolean',\n        default: false,\n        description: 'When true (or when SPECKIT_RESPONSE_TRACE=true), include provenance-rich scores/source/trace envelope fields in each result.'\n      }\n    }\n  },\n};","lineStart":240,"lineEnd":354,"totalLines":955,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","time":{"start":1781762535734,"end":1781762535740}},"metadata":{"openai":{"itemId":"fc_0c79f0012f7c3c0e016a3389e796948191b8e73aad50cc9264"}},"id":"prt_ed952b132001baZzv3U36e6m47","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed9527256001OH75175VvPBTof"}}
{"type":"tool_use","timestamp":1781762535742,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_JPNvfRU0zePME2DOGBo6MuJ8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":900,"limit":40},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n900: }\n901: \n902: // Instructions are computed once at startup and NOT refreshed during the session.\n903: // This is by design — instruction updates require MCP protocol re-negotiation which most clients\n904: // Don't support. If index changes significantly, restart the server to refresh instructions.\n905: async function buildServerInstructions(): Promise<string> {\n906:   if (!isDynamicInitEnabled()) {\n907:     return '';\n908:   }\n909: \n910:   const stats = await getMemoryStats();\n911:   const channels: string[] = ['vector', 'fts5'];\n912:   if (bm25Index.isBm25Enabled()) channels.push('bm25');\n913:   if (isGraphUnifiedEnabled()) channels.push('graph');\n914:   if (isDegreeBoostEnabled()) channels.push('degree');\n915:   const staleWarning = stats.staleCount > 10\n916:     ? ` Warning: ${stats.staleCount} stale memories detected. Consider running memory_index_scan.`\n917:     : '';\n918: \n919:   const lines = [\n920:     `Spec Kit Memory MCP has ${stats.totalMemories} indexed memories across ${stats.specFolderCount} spec folders.`,\n921:     `Active memories: ${stats.activeCount}. Stale memories: ${stats.staleCount}.`,\n922:     `Search channels: ${channels.join(', ')}.`,\n923:     'Key tools: memory_context, memory_search, memory_save, memory_index_scan, memory_stats.',\n924:     'Graph retrieval: memory_search supports retrievalLevel (local/global/auto) for entity-level or community-level search. Graph provenance visible via graphEvidence in results.',\n925:     staleWarning.trim(),\n926:   ];\n927: \n928:   // Session recovery digest from\n929:   // session-snapshot. 'empty' recommends mcp__mk_code_index__code_graph_scan (graph absent);\n930:   // 'error' recommends memory_health because structural context is\n931:   // unavailable, not merely outdated.\n932:   try {\n933:     const { getSessionSnapshot } = await import('./lib/session/session-snapshot.js');\n934:     const snap = getSessionSnapshot();\n935:     const hasData = snap.specFolder || snap.graphFreshness !== 'error' || snap.sessionQuality !== 'unknown';\n936:     if (hasData) {\n937:       const recommended = !snap.primed ? 'call session_bootstrap()' :\n938:         snap.graphFreshness === 'empty' ? 'run mcp__mk_code_index__code_graph_scan' :\n939:           snap.graphFreshness === 'error' ? 'call memory_health (structural context unavailable)' :\n\n(Showing lines 900-939 of 2341. Use offset=940 to continue.)\n</content>","metadata":{"preview":"}\n\n// Instructions are computed once at startup and NOT refreshed during the session.\n// This is by design — instruction updates require MCP protocol re-negotiation which most clients\n// Don't support. If index changes significantly, restart the server to refresh instructions.\nasync function buildServerInstructions(): Promise<string> {\n  if (!isDynamicInitEnabled()) {\n    return '';\n  }\n\n  const stats = await getMemoryStats();\n  const channels: string[] = ['vector', 'fts5'];\n  if (bm25Index.isBm25Enabled()) channels.push('bm25');\n  if (isGraphUnifiedEnabled()) channels.push('graph');\n  if (isDegreeBoostEnabled()) channels.push('degree');\n  const staleWarning = stats.staleCount > 10\n    ? ` Warning: ${stats.staleCount} stale memories detected. Consider running memory_index_scan.`\n    : '';\n\n  const lines = [","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"}\n\n// Instructions are computed once at startup and NOT refreshed during the session.\n// This is by design — instruction updates require MCP protocol re-negotiation which most clients\n// Don't support. If index changes significantly, restart the server to refresh instructions.\nasync function buildServerInstructions(): Promise<string> {\n  if (!isDynamicInitEnabled()) {\n    return '';\n  }\n\n  const stats = await getMemoryStats();\n  const channels: string[] = ['vector', 'fts5'];\n  if (bm25Index.isBm25Enabled()) channels.push('bm25');\n  if (isGraphUnifiedEnabled()) channels.push('graph');\n  if (isDegreeBoostEnabled()) channels.push('degree');\n  const staleWarning = stats.staleCount > 10\n    ? ` Warning: ${stats.staleCount} stale memories detected. Consider running memory_index_scan.`\n    : '';\n\n  const lines = [\n    `Spec Kit Memory MCP has ${stats.totalMemories} indexed memories across ${stats.specFolderCount} spec folders.`,\n    `Active memories: ${stats.activeCount}. Stale memories: ${stats.staleCount}.`,\n    `Search channels: ${channels.join(', ')}.`,\n    'Key tools: memory_context, memory_search, memory_save, memory_index_scan, memory_stats.',\n    'Graph retrieval: memory_search supports retrievalLevel (local/global/auto) for entity-level or community-level search. Graph provenance visible via graphEvidence in results.',\n    staleWarning.trim(),\n  ];\n\n  // Session recovery digest from\n  // session-snapshot. 'empty' recommends mcp__mk_code_index__code_graph_scan (graph absent);\n  // 'error' recommends memory_health because structural context is\n  // unavailable, not merely outdated.\n  try {\n    const { getSessionSnapshot } = await import('./lib/session/session-snapshot.js');\n    const snap = getSessionSnapshot();\n    const hasData = snap.specFolder || snap.graphFreshness !== 'error' || snap.sessionQuality !== 'unknown';\n    if (hasData) {\n      const recommended = !snap.primed ? 'call session_bootstrap()' :\n        snap.graphFreshness === 'empty' ? 'run mcp__mk_code_index__code_graph_scan' :\n          snap.graphFreshness === 'error' ? 'call memory_health (structural context unavailable)' :","lineStart":900,"lineEnd":939,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781762535736,"end":1781762535741}},"metadata":{"openai":{"itemId":"fc_0c79f0012f7c3c0e016a3389e7969c81918220b2c013a5e889"}},"id":"prt_ed952b1370012uSxJB6Ky4Iqnv","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed9527256001OH75175VvPBTof"}}
