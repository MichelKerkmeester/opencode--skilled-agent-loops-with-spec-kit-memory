ol_id = edge.source_id\n359:     WHERE edge.source_id IN (${placeholders})\n360:   `).run(reason, deletedAt, ...sourceIds);\n361:   pruneTombstones(database);\n362: }\n363: \n364: function recordDanglingEdgeTombstones(\n365:   database: Database.Database,\n366:   reason: string,\n367:   deletedAt: string,\n368: ): void {\n369:   if (!codeGraphTombstonesEnabled()) {\n370:     return;\n371:   }\n372:   ensureTombstoneSchema(database);\n373:   database.prepare(`\n374:     INSERT INTO code_graph_tombstones (\n375:       entity_kind, entity_id, source_id, target_id, edge_type, file_path, reason, deleted_at\n376:     )\n377:     SELECT\n378:       'edge',\n379:       source_id || '->' || target_id || ':' || edge_type,\n380:       source_id,\n381:       target_id,\n382:       edge_type,\n383:       COALESCE(source_node.file_path, target_node.file_path),\n384:       ?,\n385:       ?\n386:     FROM code_edges edge\n387:     LEFT JOIN code_nodes source_node ON source_node.symbol_id = edge.source_id\n388:     LEFT JOIN code_nodes target_node ON target_node.symbol_id = edge.target_id\n389:     WHERE edge.source_id NOT IN (SELECT symbol_id FROM code_nodes)\n390:       OR edge.target_id NOT IN (SELECT symbol_id FROM code_nodes)\n391:   `).run(reason, deletedAt);\n392:   pruneTombstones(database);\n393: }\n394: \n395: function recordFileTombstone(\n396:   database: Database.Database,\n397:   filePath: string,\n398:   reason: string,\n399:   deletedAt: string,\n400: ): void {\n401:   if (!codeGraphTombstonesEnabled()) {\n402:     return;\n403:   }\n404:   ensureTombstoneSchema(database);\n405:   database.prepare(`\n406:     INSERT INTO code_graph_tombstones (entity_kind, entity_id, file_path, reason, deleted_at)\n407:     VALUES ('file', ?, ?, ?, ?)\n408:   `).run(filePath, filePath, reason, deletedAt);\n409:   pruneTombstones(database);\n410: }\n411: \n412: function mapTombstoneRow(row: Record<string, unknown>): CodeGraphTombstoneRecord {\n413:   return {\n414:     id: row.id as n