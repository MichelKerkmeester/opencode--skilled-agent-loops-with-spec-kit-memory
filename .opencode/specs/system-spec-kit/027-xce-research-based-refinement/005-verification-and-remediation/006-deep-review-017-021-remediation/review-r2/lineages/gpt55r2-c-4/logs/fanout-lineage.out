unSummary(\n3310:             preparedDryRun.sufficiencyResult,\n3311:             preparedDryRun.qualityLoopResult,\n3312:             preparedDryRun.templateContract,\n3313:           );\n3314: \n3315:     const wouldPass = preflightValidation.wouldPass\n3316:       && preparedDryRun.validation.valid\n3317:       && preparedDryRun.qualityLoopResult.rejected !== true\n3318:       && templateContractPass\n3319:       && preparedDryRun.sufficiencyResult.pass;\n3320: \n3321:     const hints: string[] = !preflightValidation.wouldPass\n3322:       ? ['Fix validation errors before saving', 'Use skipPreflight: true to bypass validation']\n3323:       : templateContractPass && preparedDryRun.sufficiencyResult.pass\n3324:         ? [\n3325:             'Dry-run complete - no changes made',\n3326:             ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n3327:             ...(bypassMode\n3328:               ? ['Manual-fallback mode would bypass the strict memory template contract for this save']\n3329:               : []),\n3330:           ]\n3331:         : [\n3332:             'Dry-run complete - no changes made',\n3333:             ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n3334:             ...(!preparedDryRun.templateContract.valid\n3335:               ? ['Rendered content must match the memory template contract before indexing']\n3336:               : []),\n3337:             'Not enough context was available to save a durable memory',\n3338:             ...(!preflightValidation.skipped\n3339:               ? ['Add concrete file, tool, decision, blocker, next action, or outcome evidence and retry']\n3340:               : []),\n3341:           ];\n3342: \n3343:     return createMCPSuccessResponse({\n3344:       tool: 'memory_save',\n3345:       summary: dryRunSummary,\n3346:       data: {\n3347:         status: 'dry_run',\n3348:         would_pass: would