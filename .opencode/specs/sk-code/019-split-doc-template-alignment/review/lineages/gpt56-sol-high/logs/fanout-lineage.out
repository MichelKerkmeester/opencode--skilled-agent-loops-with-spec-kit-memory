},\n            {\n              \"lane\": \"graph_causal\",\n              \"rawScore\": 0.30155582999999997,\n              \"weightedScore\": 0.039202257899999995,\n              \"weight\": 0.13,\n              \"shadowOnly\": false,\n              \"evidenceTypes\": [\n                \"workflow_signal\"\n              ],\n              \"evidenceCount\": 2\n            }\n          ],\n          \"matchedSkillFeatures\": [\n            {\n              \"lane\": \"explicit_author\",\n              \"feature\": \"phrase_match\"\n            },\n            {\n              \"lane\": \"explicit_author\",\n              \"feature\": \"workflow_signal\"\n            },\n            {\n              \"lane\": \"explicit_author\",\n              \"feature\": \"scorer_signal\"\n            },\n            {\n              \"lane\": \"derived_generated\",\n              \"feature\": \"derived_skill_signal\"\n            },\n            {\n              \"lane\": \"lexical\",\n              \"feature\": \"token_match\"\n            },\n            {\n              \"lane\": \"graph_causal\",\n              \"feature\": \"workflow_signal\"\n            }\n          ]\n        },\n        \"status\": \"active\",\n        \"workflowMode\": \"review\"\n      },\n      {\n        \"skillId\": \"cli-external\",\n        \"score\": 0.639786,\n        \"confidence\": 0.8639,\n        \"uncertainty\": 0.12,\n        \"dominantLane\": \"explicit_author\",\n        \"laneBreakdown\": [\n          {\n            \"lane\": \"explicit_author\",\n            \"rawScore\": 0.8799999999999999,\n            \"weightedScore\": 0.36959999999999993,\n            \"weight\": 0.42,\n            \"shadowOnly\": false\n          },\n          {\n            \"lane\": \"lexical\",\n            \"rawScore\": 0.403125,\n            \"weightedScore\": 0.11287500000000002,\n            \"weight\": 0.28,\n            \"shadowOnly\": false\n          },\n          {\n            \"lane\": \"graph_causal\",\n            \"rawScore\": 0.051875097312500014,\n            \"weightedScore\": 0.006743762650625002,\n            \"weight\": 0.13,\n            \"shadowOnly\": false\n          },\n          {\n            \"lane\": \"derived_generated\",\n            \"rawScore\": 0.979931,\n            \"weightedScore\": 0.11759172,\n            \"weight\": 0.12,\n            \"shadowOnly\": false\n          },\n          {\n            \"lane\": \"semantic_shadow\",\n            \"rawScore\": 0.659513,\n            \"weightedScore\": 0.03297565,\n            \"weight\": 0.05,\n            \"shadowOnly\": false\n          }\n        ],\n        \"why_recommended\": {\n          \"reason\": \"Recommended from ranker signals: explicit_author contributed the strongest live score.\",\n          \"dominantLane\": \"explicit_author\",\n          \"topLanes\": [\n            {\n              \"lane\": \"explicit_author\",\n              \"rawScore\": 0.8799999999999999,\n              \"weightedScore\": 0.36959999999999993,\n              \"weight\": 0.42,\n              \"shadowOnly\": false,\n              \"evidenceTypes\": [\n                \"scorer_signal\"\n              ],\n              \"evidenceCount\": 1\n            },\n            {\n              \"lane\": \"derived_generated\",\n              \"rawScore\": 0.979931,\n              \"weightedScore\": 0.11759172,\n              \"weight\": 0.12,\n              \"shadowOnly\": false,\n              \"evidenceTypes\": [\n                \"derived_skill_signal\"\n              ],\n              \"evidenceCount\": 3\n            },\n            {\n              \"lane\": \"lexical\",\n              \"rawScore\": 0.403125,\n              \"weightedScore\": 0.11287500000000002,\n              \"weight\": 0.28,\n              \"shadowOnly\": false,\n              \"evidenceTypes\": [\n                \"token_match\"\n              ],\n              \"evidenceCount\": 4\n            },\n            {\n              \"lane\": \"semantic_shadow\",\n              \"rawScore\": 0.659513,\n              \"weightedScore\": 0.03297565,\n              \"weight\": 0.05,\n              \"shadowOnly\": false,\n              \"evidenceTypes\": [\n                \"semantic_similarity\"\n              ],\n              \"evidenceCount\": 1\n            }\n          ],\n          \"matchedSkillFeatures\": [\n            {\n              \"lane\": \"explicit_author\",\n              \"feature\": \"scorer_signal\"\n            },\n            {\n              \"lane\": \"derived_generated\",\n              \"feature\": \"derived_skill_signal\"\n            },\n            {\n              \"lane\": \"lexical\",\n              \"feature\": \"token_match\"\n            },\n            {\n              \"lane\": \"semantic_shadow\",\n              \"feature\": \"semantic_similarity\"\n            }\n          ]\n        },\n        \"status\": \"active\"\n      }\n    ],\n    \"ambiguous\": true,\n    \"freshness\": \"live\",\n    \"trustState\": {\n      \"state\": \"live\",\n      \"reason\": null,\n      \"generation\": 11317,\n      \"checkedAt\": \"2026-07-13T03:10:33.719Z\",\n      \"lastLiveAt\": \"2026-07-13T03:10:18.703Z\"\n    },\n    \"generatedAt\": \"2026-07-13T03:10:34.062Z\",\n    \"cache\": {\n      \"hit\": false,\n      \"sourceSignaturePresent\": true\n    },\n    \"_shadow\": {\n      \"model\": \"advisor-shadow-learned-weights-v1\",\n      \"liveWeightsFrozen\": true,\n      \"recommendations\": [\n        {\n          \"skillId\": \"sk-code\",\n          \"liveScore\": 0.734074,\n          \"shadowScore\": 0.693252,\n          \"delta\": -0.040822,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"system-deep-loop\",\n          \"liveScore\": 0.649617,\n          \"shadowScore\": 0.62868,\n          \"delta\": -0.020937,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"cli-external\",\n          \"liveScore\": 0.639786,\n          \"shadowScore\": 0.594125,\n          \"delta\": -0.045661,\n          \"dominantShadowLane\": \"explicit_author\"\n        }\n      ]\n    }\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1783912233523,"end":1783912234066}},"metadata":{"openai":{"itemId":"fc_0c81ebeba1025eba016a54572975708191b37482f34cf14ec9"}},"id":"prt_f59747a31001xecwYuhHPbE60u","sessionID":"ses_0a68bc60effeJzWL51JC6bkniv","messageID":"msg_f59743bd70013rLNg2nv0uuIng"}}
{"type":"tool_use","timestamp":1783912293526,"sessionID":"ses_0a68bc60effeJzWL51JC6bkniv","part":{"type":"tool","tool":"mk-spec-memory_memory_match_triggers","callID":"call_Tt558dMdlPnyKs9DE3gkDZ79","state":{"status":"error","input":{"prompt":"Execute detached deep-review workflow against spec folder .opencode/specs/sk-code/019-split-doc-template-alignment, writing only to review/lineages/gpt56-sol-high, max 10 iterations, then synthesize.","specFolder":".opencode/specs/sk-code/019-split-doc-template-alignment","tenantId":"","userId":"","agentId":"","limit":3,"session_id":"fanout-gpt56-sol-high-1783912216470-zu43f5","turnNumber":1,"include_cognitive":true},"error":"MCP error -32001: Request timed out","time":{"start":1783912233519,"end":1783912293524}},"metadata":{"openai":{"itemId":"fc_0c81ebeba1025eba016a5457297560819193237f2c14731fae"}},"id":"prt_f59747a0a001NJ65BFjYZAK5P4","sessionID":"ses_0a68bc60effeJzWL51JC6bkniv","messageID":"msg_f59743bd70013rLNg2nv0uuIng"}}
