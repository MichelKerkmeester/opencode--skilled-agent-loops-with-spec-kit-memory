e that an executor dispatch is allowed.\n690:  *\n691:  * Checks stack, ancestry, runtime env, and lockfile layers for recursion\n692:  * guard violations per the deep-loop dispatch contract.\n693:  *\n694:  * @param config - Executor configuration.\n695:  * @param context - Optional environment, ancestry, and state path context.\n696:  * @returns Dispatch result indicating whether dispatch is allowed.\n697:  */\n698: export function validateExecutorDispatchAllowed(\n699:   config: ExecutorConfig,\n700:   context: ExecutorDispatchGuardContext = {},\n701: ): ExecutorDispatchAllowedResult {\n702:   const kind = getExecutorKind(config);\n703:   if (kind === 'native') {\n704:     return { allowed: true };\n705:   }\n706: \n707:   const env = context.env ?? process.env;\n708:   const stack = env[CLI_DISPATCH_STACK_ENV];\n709:   if (detectSameKindFromStack(stack, kind)) {\n710:     return {\n711:       allowed: false,\n712:       layer: 'stack',\n713:       reason: recursionReasonForLayer('stack'),\n714:       detail: `${kind} already appears in ${CLI_DISPATCH_STACK_ENV}`,\n715:     };\n716:   }\n717: \n718:   if (detectFromAncestry(kind, context.ancestryCmdlines)) {\n719:     return {\n720:       allowed: false,\n721:       layer: 'ancestry',\n722:       reason: recursionReasonForLayer('ancestry'),\n723:       detail: `${kind} executor binary appears in process ancestry`,\n724:     };\n725:   }\n726: \n727:   if (detectFromRuntimeEnv(kind, env)) {\n728:     const envName = EXECUTOR_SESSION_ENV_BY_KIND[kind] ?? 'runtime session env';\n729:     return {\n730:       allowed: false,\n731:       layer: 'env',\n732:       reason: recursionReasonForLayer('env'),\n733:       detail: `${envName} is set for ${kind}`,\n734:     };\n735:   }\n736: \n737:   const statePaths = context.statePaths ?? getDefaultStatePaths(kind, env);\n738:   if (detectFromLockfile(kind, statePaths)) {\n739:     return {\n740:       allowed: false,\n741:       layer: 'lockfile',\n742:       reason: recursionReasonForLayer('lockfile'),\n743:       detail: `${kind} dispatch lockfile exists in runtime state path`,\n744:     };\n745:   }\n746: \n747:   return { allowed: true };\n748: }\n749: \n750: /**\n751:  * Build the environment for a dispatched executor.\n752:  *\n753:  * Filters the parent environment to only include allowed keys per executor kind\n754:  * and appends the current kind to the dispatch stack.\n755:  *\n756:  * @param config - Executor configuration.\n757:  * @param parentEnv - Parent environment (defaults to process.env).\n758:  * @returns Filtered environment with dispatch stack updated.\n759:  */\n760: export function buildExecutorDispatchEnv(\n761:   config: ExecutorConfig,\n762:   parentEnv: Record<string, string | undefined> = process.env,\n763: ): Record<string, string | undefined> {\n764:   const kind = getExecutorKind(config);\n765:   if (kind === 'native') {\n766:     return { ...parentEnv };\n767:   }\n768: \n769:   const nextEnv: Record<string, string | undefined> = {};\n770:   for (const [key, value] of Object.entries(parentEnv)) {\n771:     if (value !== undefined && isAllowedExecutorEnvKey(key, kind)) {\n772:       nextEnv[key] = value;\n773:     }\n774:   }\n775:   nextEnv[CLI_DISPATCH_STACK_ENV] = [...splitDispatchStack(parentEnv[CLI_DISPATCH_STACK_ENV]), kind].join(':');\n776:   return nextEnv;\n777: }\n778: \n779: /**\n780:  * Build an executor audit record for provenance logging.\n781:  *\n782:  * @param executor - Executor configuration.\n783:  * @returns Audit record with kind, model, reasoning effort, and service tier.\n784:  */\n785: export function buildExecutorAuditRecord(executor: ExecutorConfig, lineageId?: string): Record<string, unknown> {\n786:   return {\n787:     kind: getExecutorKind(executor),\n788:     model: executor.model,\n789:     reasoningEffort: executor.reasoningEffort,\n\n(Showing lines 650-789 of 1169. Use offset=790 to continue.)\n</content>","metadata":{"preview":"): boolean {\n  const sessionEnvName = EXECUTOR_SESSION_ENV_BY_KIND[kind];\n  if (!sessionEnvName) {\n    return false;\n  }\n\n  return typeof env[sessionEnvName] === 'string' && env[sessionEnvName]?.trim() !== '';\n}\n\n/**\n * Detect whether a dispatch lockfile exists in executor state directories.\n *\n * @param kind - The executor kind to check.\n * @param statePaths - State directory paths to scan (defaults to auto-detected).\n * @returns True if a lockfile is found.\n */\nexport function detectFromLockfile(kind: ExecutorKind, statePaths: string[] = getDefaultStatePaths(kind, process.env)): boolean {\n  if (kind === 'native') {\n    return false;\n  }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts","text":"): boolean {\n  const sessionEnvName = EXECUTOR_SESSION_ENV_BY_KIND[kind];\n  if (!sessionEnvName) {\n    return false;\n  }\n\n  return typeof env[sessionEnvName] === 'string' && env[sessionEnvName]?.trim() !== '';\n}\n\n/**\n * Detect whether a dispatch lockfile exists in executor state directories.\n *\n * @param kind - The executor kind to check.\n * @param statePaths - State directory paths to scan (defaults to auto-detected).\n * @returns True if a lockfile is found.\n */\nexport function detectFromLockfile(kind: ExecutorKind, statePaths: string[] = getDefaultStatePaths(kind, process.env)): boolean {\n  if (kind === 'native') {\n    return false;\n  }\n\n  const names = candidateLockfileNames(kind);\n  for (const statePath of statePaths) {\n    const directories = [statePath, join(statePath, 'locks')];\n    for (const directory of directories) {\n      if (!pathIsReadableDirectory(directory)) {\n        continue;\n      }\n      const entries = new Set(readdirSync(directory));\n      if (names.some((name) => entries.has(name))) {\n        return true;\n      }\n    }\n  }\n\n  return false;\n}\n\n/**\n * Validate that an executor dispatch is allowed.\n *\n * Checks stack, ancestry, runtime env, and lockfile layers for recursion\n * guard violations per the deep-loop dispatch contract.\n *\n * @param config - Executor configuration.\n * @param context - Optional environment, ancestry, and state path context.\n * @returns Dispatch result indicating whether dispatch is allowed.\n */\nexport function validateExecutorDispatchAllowed(\n  config: ExecutorConfig,\n  context: ExecutorDispatchGuardContext = {},\n): ExecutorDispatchAllowedResult {\n  const kind = getExecutorKind(config);\n  if (kind === 'native') {\n    return { allowed: true };\n  }\n\n  const env = context.env ?? process.env;\n  const stack = env[CLI_DISPATCH_STACK_ENV];\n  if (detectSameKindFromStack(stack, kind)) {\n    return {\n      allowed: false,\n      layer: 'stack',\n      reason: recursionReasonForLayer('stack'),\n      detail: `${kind} already appears in ${CLI_DISPATCH_STACK_ENV}`,\n    };\n  }\n\n  if (detectFromAncestry(kind, context.ancestryCmdlines)) {\n    return {\n      allowed: false,\n      layer: 'ancestry',\n      reason: recursionReasonForLayer('ancestry'),\n      detail: `${kind} executor binary appears in process ancestry`,\n    };\n  }\n\n  if (detectFromRuntimeEnv(kind, env)) {\n    const envName = EXECUTOR_SESSION_ENV_BY_KIND[kind] ?? 'runtime session env';\n    return {\n      allowed: false,\n      layer: 'env',\n      reason: recursionReasonForLayer('env'),\n      detail: `${envName} is set for ${kind}`,\n    };\n  }\n\n  const statePaths = context.statePaths ?? getDefaultStatePaths(kind, env);\n  if (detectFromLockfile(kind, statePaths)) {\n    return {\n      allowed: false,\n      layer: 'lockfile',\n      reason: recursionReasonForLayer('lockfile'),\n      detail: `${kind} dispatch lockfile exists in runtime state path`,\n    };\n  }\n\n  return { allowed: true };\n}\n\n/**\n * Build the environment for a dispatched executor.\n *\n * Filters the parent environment to only include allowed keys per executor kind\n * and appends the current kind to the dispatch stack.\n *\n * @param config - Executor configuration.\n * @param parentEnv - Parent environment (defaults to process.env).\n * @returns Filtered environment with dispatch stack updated.\n */\nexport function buildExecutorDispatchEnv(\n  config: ExecutorConfig,\n  parentEnv: Record<string, string | undefined> = process.env,\n): Record<string, string | undefined> {\n  const kind = getExecutorKind(config);\n  if (kind === 'native') {\n    return { ...parentEnv };\n  }\n\n  const nextEnv: Record<string, string | undefined> = {};\n  for (const [key, value] of Object.entries(parentEnv)) {\n    if (value !== undefined && isAllowedExecutorEnvKey(key, kind)) {\n      nextEnv[key] = value;\n    }\n  }\n  nextEnv[CLI_DISPATCH_STACK_ENV] = [...splitDispatchStack(parentEnv[CLI_DISPATCH_STACK_ENV]), kind].join(':');\n  return nextEnv;\n}\n\n/**\n * Build an executor audit record for provenance logging.\n *\n * @param executor - Executor configuration.\n * @returns Audit record with kind, model, reasoning effort, and service tier.\n */\nexport function buildExecutorAuditRecord(executor: ExecutorConfig, lineageId?: string): Record<string, unknown> {\n  return {\n    kind: getExecutorKind(executor),\n    model: executor.model,\n    reasoningEffort: executor.reasoningEffort,","lineStart":650,"lineEnd":789,"totalLines":1169,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts","time":{"start":1784624219219,"end":1784624219230}},"metadata":{"openai":{"itemId":"fc_07384a97bd637ed8016a5f3459d9ec8191898e65dd5b56804f"}},"id":"prt_f83e47f15001aJEkWkvT9fZiv3","sessionID":"ses_07c1fcf6effe2YUDoq6jbB4HYf","messageID":"msg_f83e47508001AP4PtZWt23wav7"}}
