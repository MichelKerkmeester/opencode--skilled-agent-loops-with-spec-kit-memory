h(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n\n  Line 911:   // Review/context lineages scope by spec_folder but the auto-workflow preflight\n\n  Line 913:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n\n  Line 914:   // different setup contract than native lineages.\n\n  Line 925:           `lineage_mode: auto`,\n\n  Line 930:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n\n  Line 936:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n\n  Line 937:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n\n  Line 938:     `command; bind artifact_dir directly to the override value.`,\n\n  Line 941:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n\n  Line 943:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n\n  Line 947: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n\n  Line 948:   const maxIterations = lineage.iterations || 12;\n\n  Line 949:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n\n  Line 950:   const stopPolicy = options.stopPolicy || 'convergence';\n\n  Line 951:   const sessionId = options.sessionId || '';\n\n  Line 956:     `--max-iterations=${maxIterations}`,\n\n  Line 957:     `--convergence=${convergenceThreshold}`,\n\n  Line 958:     `--stop-policy=${stopPolicy}`,\n\n  Line 959:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n\n  Line 960:     '--lineage-mode=auto',\n\n  Line 974:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n\n  Line 976:     'lineage_mode: auto',\n\n  Line 977:     `maxIterations: ${maxIterations}`,\n\n  Line 978:     `convergenceThreshold: ${convergenceThreshold}`,\n\n  Line 979:     `stop_policy: ${stopPolicy}`,\n\n  Line 980:     `config.fanout