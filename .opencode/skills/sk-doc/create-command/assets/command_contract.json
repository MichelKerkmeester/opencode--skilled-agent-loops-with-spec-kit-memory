{
  "$schema": "./command_contract.schema.json",
  "version": "1.0.0",
  "metadata": {
    "purpose": "Single machine-readable source of behavioral truth for the six OpenCode command families. Templates, validators, benchmark adapters, and generated routers consume this instead of restating it as prose.",
    "confirm_auto_relationship": "The observed 'confirm == auto + checkpoints' relationship holds only for light single-pass mode-pair families (verified on design; inferred for create and speckit:plan). For autonomy-heavy commands (speckit:complete, all deep:*) the :auto workflow carries orchestration machinery the :confirm variant lacks, so the two are divergent siblings and must be modeled independently rather than derived. Downstream checks must not assume the invariant universally.",
    "granularity": "One entry per family; router_path is a directory glob for families whose per-operation routers share one uniform pattern (create, design, deep) and an explicit list for families whose routers differ (speckit, memory, doctor)."
  },
  "families": {
    "create": {
      "topology": "mode-pair",
      "router_path": ".opencode/commands/create/*.md",
      "input": {
        "required": true,
        "gate_owner": "router",
        "argument_hint": "<skill-name> [operation] [type] [--path <dir>] [--chained] [:auto|:confirm]"
      },
      "execution_targets": [
        { "selector": ":auto", "target": ".opencode/commands/create/assets/<name>_auto.yaml" },
        { "selector": ":confirm | omitted", "target": ".opencode/commands/create/assets/<name>_confirm.yaml" }
      ],
      "mode_matrix": {
        "default_policy": "confirm",
        "supported_modes": [":auto", ":confirm"]
      },
      "owned_assets": [
        { "purpose": "presentation", "path": ".opencode/commands/create/assets/<name>_presentation.txt" },
        { "purpose": "auto_workflow", "path": ".opencode/commands/create/assets/<name>_auto.yaml" },
        { "purpose": "confirm_workflow", "path": ".opencode/commands/create/assets/<name>_confirm.yaml" }
      ],
      "loader_requirements": [
        "Read the presentation asset before showing any startup question",
        "$ARGUMENTS trailer consumed at the router foot",
        ":auto honors a PRE-BOUND SETUP ANSWERS: marker block for non-interactive setup",
        "Stop and report the missing path if any referenced asset is absent"
      ],
      "presentation": { "owner": "presentation-asset", "exceptions": [] },
      "destructive_policy": {
        "has_destructive_ops": true,
        "gated": true,
        "operations": ["writes and overwrites skill and doc files", "full-update mutates existing docs"]
      },
      "timeout_bounds": null,
      "invocation_aliases": ["/create:skill", "/create:agent", "/create:<operation>", ":auto suffix", ":confirm suffix"],
      "workflow_schema_ref": null
    },
    "design": {
      "topology": "mode-pair",
      "router_path": ".opencode/commands/design/*.md",
      "input": {
        "required": true,
        "gate_owner": "router",
        "argument_hint": "<target> [--mode] [--register brand|product] [:auto|:confirm]"
      },
      "execution_targets": [
        { "selector": ":auto | no-suffix with complete args", "target": ".opencode/commands/design/assets/design_<mode>_auto.yaml" },
        { "selector": ":confirm | no-suffix with incomplete args", "target": ".opencode/commands/design/assets/design_<mode>_confirm.yaml" }
      ],
      "mode_matrix": {
        "default_policy": "conditional-auto",
        "supported_modes": [":auto", ":confirm"]
      },
      "owned_assets": [
        { "purpose": "presentation", "path": ".opencode/commands/design/assets/design_<mode>_presentation.txt" },
        { "purpose": "auto_workflow", "path": ".opencode/commands/design/assets/design_<mode>_auto.yaml" },
        { "purpose": "confirm_workflow", "path": ".opencode/commands/design/assets/design_<mode>_confirm.yaml" }
      ],
      "loader_requirements": [
        "Read the presentation asset before showing any startup question",
        "--mode and --register select internal task lanes, not execution modes",
        "Defer to the sk-design hub (STATUS=DEFER ROUTE=hub) when the request spans modes",
        "Never auto-chain to a sibling command; next steps are recommend-only"
      ],
      "presentation": { "owner": "presentation-asset", "exceptions": [] },
      "destructive_policy": {
        "has_destructive_ops": true,
        "gated": true,
        "operations": ["md-generator writes and overwrites DESIGN.md", "other modes emit specs and handoff manifests (additive)"]
      },
      "timeout_bounds": null,
      "invocation_aliases": ["/design:interface", "/design:foundations", "/design:motion", "/design:audit", "/design:md-generator", ":auto suffix", ":confirm suffix"],
      "workflow_schema_ref": null
    },
    "speckit": {
      "topology": "mode-pair",
      "router_path": [
        ".opencode/commands/speckit/plan.md",
        ".opencode/commands/speckit/implement.md",
        ".opencode/commands/speckit/complete.md",
        ".opencode/commands/speckit/resume.md"
      ],
      "input": {
        "required": true,
        "gate_owner": "router",
        "argument_hint": "<feature-description> [:auto|:confirm|:autopilot|:unattended|--unattended] [:with-context] [:with-phases]"
      },
      "execution_targets": [
        { "selector": ":auto", "target": ".opencode/commands/speckit/assets/speckit_<name>_auto.yaml" },
        { "selector": ":autopilot | :unattended | --unattended", "target": ".opencode/commands/speckit/assets/speckit_<name>_auto.yaml (bound to autopilot execution mode; not aliased to :auto)" },
        { "selector": ":confirm | interactive choice", "target": ".opencode/commands/speckit/assets/speckit_<name>_confirm.yaml" }
      ],
      "mode_matrix": {
        "default_policy": "ask",
        "supported_modes": [":auto", ":confirm", ":autopilot", ":unattended", "--unattended"],
        "overrides": [
          { "command": "/speckit:resume", "default_policy": "confirm" }
        ]
      },
      "owned_assets": [
        { "purpose": "presentation", "path": ".opencode/commands/speckit/assets/speckit_<name>_presentation.txt" },
        { "purpose": "auto_workflow", "path": ".opencode/commands/speckit/assets/speckit_<name>_auto.yaml" },
        { "purpose": "confirm_workflow", "path": ".opencode/commands/speckit/assets/speckit_<name>_confirm.yaml" }
      ],
      "loader_requirements": [
        "Read the presentation asset before showing any startup question",
        ":auto honors a PRE-BOUND SETUP ANSWERS: marker block",
        "Unattended planning writes per-task metadata (agent, deps, touched-files) into tasks.md",
        "Dispatched-agent I/O uses envelopes tagged schema_version agent-io/v1"
      ],
      "presentation": {
        "owner": "presentation-asset",
        "exceptions": [
          {
            "command": "/speckit:complete, /speckit:implement",
            "surface": "SPECKIT_AUTOPILOT_RESULT machine result line and fixed reason codes",
            "reason": "Router-owned machine status grammar for unattended runs, not a visible presentation block"
          }
        ]
      },
      "destructive_policy": {
        "has_destructive_ops": true,
        "gated": true,
        "operations": ["implement and complete mutate repository code", "run validation gates", "autopilot merges git branches after clean verification"]
      },
      "timeout_bounds": null,
      "invocation_aliases": ["/speckit:plan", "/speckit:implement", "/speckit:complete", "/speckit:resume", ":auto suffix", ":confirm suffix", ":autopilot suffix", ":unattended suffix", "--unattended flag"],
      "workflow_schema_ref": ".opencode/skills/system-spec-kit/references/workflows/agent-io-contract.md"
    },
    "memory": {
      "topology": "direct-dispatch",
      "router_path": [
        ".opencode/commands/memory/save.md",
        ".opencode/commands/memory/search.md",
        ".opencode/commands/memory/learn.md",
        ".opencode/commands/memory/manage.md"
      ],
      "input": {
        "required": false,
        "gate_owner": "router",
        "argument_hint": "per-command: save <spec-folder>; search <query> | preflight | dashboard; learn [rule] | list | edit | remove | budget; manage [scan] | [cleanup] | ..."
      },
      "execution_targets": [
        { "selector": "save", "target": "generate-context.js metadata refresh, then memory_index_scan / memory_save / memory_update" },
        { "selector": "search (retrieval)", "target": "memory_context / memory_quick_search / memory_search / memory_match_triggers" },
        { "selector": "search (analysis)", "target": "task_preflight / task_postflight / memory_drift_why / eval_run_ablation / eval_reporting_dashboard" },
        { "selector": "learn", "target": "constitutional-rule filesystem writes plus memory_save / memory_list / memory_delete" },
        { "selector": "manage", "target": "per-mode memory MCP tools (memory_stats / retention_sweep / checkpoint_* / ingest_*)" }
      ],
      "mode_matrix": {
        "default_policy": "non-mutating-default",
        "supported_modes": []
      },
      "owned_assets": [
        { "purpose": "presentation", "path": ".opencode/commands/memory/assets/<command>_presentation.txt" },
        { "purpose": "script", "path": ".opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js (consumed; owned by system-spec-kit)" }
      ],
      "loader_requirements": [
        "Read the presentation asset before showing any startup question",
        "memory/search runs an embedded bash pre-processing line before policy that emits ARGS_PRESENT and QUERY; the router binds control flow to that output rather than re-deriving argument presence",
        "Never query the database with raw sqlite3 or Bash"
      ],
      "presentation": {
        "owner": "presentation-asset",
        "exceptions": [
          {
            "command": "/memory:search",
            "surface": "Inline five-core-slot MEMORY:SEARCH render block (search.md render-fidelity reminder)",
            "reason": "Sanctioned render-fidelity exception: the presentation asset stays the source of truth; the router inlines only the compressed retrieval shape as a hard render reminder"
          }
        ]
      },
      "destructive_policy": {
        "has_destructive_ops": true,
        "gated": true,
        "operations": ["manage: delete, bulk-delete, cleanup, retention-sweep, learned-clear, checkpoint restore/delete", "learn remove deletes a constitutional rule"]
      },
      "timeout_bounds": null,
      "invocation_aliases": ["/memory:save", "/memory:search", "/memory:learn", "/memory:manage", "positional sub-actions (e.g. /memory:search preflight, /memory:manage checkpoint create)"],
      "workflow_schema_ref": null
    },
    "doctor": {
      "topology": "subaction-route-manifest",
      "router_path": [
        ".opencode/commands/doctor/speckit.md",
        ".opencode/commands/doctor/mcp.md",
        ".opencode/commands/doctor/update.md"
      ],
      "input": {
        "required": true,
        "gate_owner": "router",
        "argument_hint": "<target> [flags] | list | ? (speckit); <install|debug> [--server] [--runtime] [--fix] (mcp); [--force] [--no-snapshot] [--migrate] (update)"
      },
      "execution_targets": [
        { "selector": "<target> resolved via _routes.yaml", "target": ".opencode/commands/doctor/assets/doctor_<target>.yaml" },
        { "selector": "install | debug", "target": ".opencode/commands/doctor/assets/doctor_mcp_<sub>.yaml" },
        { "selector": "update", "target": ".opencode/commands/doctor/assets/doctor_update.yaml" }
      ],
      "mode_matrix": {
        "default_policy": "confirm-only",
        "supported_modes": []
      },
      "owned_assets": [
        { "purpose": "route_manifest", "path": ".opencode/commands/doctor/_routes.yaml" },
        { "purpose": "presentation", "path": ".opencode/commands/doctor/assets/doctor_<entry>_presentation.txt" },
        { "purpose": "other", "path": ".opencode/commands/doctor/assets/doctor_<target>.yaml (per-route target workflows)" },
        { "purpose": "script", "path": ".opencode/commands/doctor/scripts/route-validate.sh (validates _routes.yaml)" }
      ],
      "loader_requirements": [
        "Read the presentation asset and _routes.yaml before dispatch",
        "Parse the positional target before any flag; reject cross-target flags before loading the target YAML",
        "The manifest exposes each route's mutation class (read-only | add-only | mutates) and gate-3 location before acting",
        "update acquires a flock before database-rebuild probes and may end STATUS=RESTART_REQUIRED"
      ],
      "presentation": { "owner": "presentation-asset", "exceptions": [] },
      "destructive_policy": {
        "has_destructive_ops": true,
        "gated": true,
        "operations": ["skill-advisor target writes lib/scorer/lanes sources", "mcp install writes server dirs and runtime config", "update rebuilds spec-kit SQLite databases (snapshotted first unless --no-snapshot)"]
      },
      "timeout_bounds": { "warm_probe_timeout_ms": 500 },
      "invocation_aliases": ["/doctor <target>", "/doctor list", "/doctor ?", "/doctor:mcp <install|debug>", "/doctor:update"],
      "workflow_schema_ref": null
    },
    "deep": {
      "topology": "mode-pair",
      "router_path": ".opencode/commands/deep/*.md",
      "input": {
        "required": true,
        "gate_owner": "router",
        "argument_hint": "<topic> [:auto|:confirm] [--spec-folder=PATH] [--max-iterations=N] [--executor=<type>] [--concurrency=N] [--dry-run]"
      },
      "execution_targets": [
        { "selector": ":auto", "target": ".opencode/commands/deep/assets/deep_<name>_auto.yaml (dispatches LEAF iteration agents)" },
        { "selector": ":confirm | interactive choice", "target": ".opencode/commands/deep/assets/deep_<name>_confirm.yaml" }
      ],
      "mode_matrix": {
        "default_policy": "ask",
        "supported_modes": [":auto", ":confirm"]
      },
      "owned_assets": [
        { "purpose": "presentation", "path": ".opencode/commands/deep/assets/deep_<name>_presentation.txt" },
        { "purpose": "auto_workflow", "path": ".opencode/commands/deep/assets/deep_<name>_auto.yaml" },
        { "purpose": "confirm_workflow", "path": ".opencode/commands/deep/assets/deep_<name>_confirm.yaml" },
        { "purpose": "other", "path": ".opencode/commands/deep/assets/compiled/ (generated *.contract.md + manifest.jsonl digest ledger)" },
        { "purpose": "other", "path": ".opencode/commands/deep/assets/legacy/ (fallback injection bodies)" }
      ],
      "loader_requirements": [
        "Read the presentation asset before showing any startup question",
        "Two ordered hard-block gates: the Phase 0 dispatch-context check, then the BLOCKED unified setup phase (do not load YAML until all required inputs are bound)",
        ":auto honors a PRE-BOUND SETUP ANSWERS: marker block and persists a config json before loading YAML",
        "Acquire the research/review lock before folder-state classification",
        "--dry-run is a first-class flag on the confirm flow, not a third execution mode"
      ],
      "presentation": { "owner": "presentation-asset", "exceptions": [] },
      "destructive_policy": {
        "has_destructive_ops": false,
        "gated": true,
        "operations": ["add-only artifact writes (reports, iteration state, deltas, logs); routes code changes to speckit rather than mutating directly"]
      },
      "timeout_bounds": {
        "lineage_timeout_hours_default": 4,
        "executor_timeout": "bounded per-invocation by --executor-timeout=SECONDS"
      },
      "invocation_aliases": ["/deep:research", "/deep:review", "/deep:alignment", "/deep:ai-council", "/deep:agent-improvement", "/deep:model-benchmark", "/deep:skill-benchmark", "/deep:command-benchmark", "attached suffix (e.g. /deep:research:auto)", "--dry-run flag"],
      "workflow_schema_ref": ".opencode/skills/system-spec-kit/references/workflows/auto_mode_contract.md"
    }
  }
}
