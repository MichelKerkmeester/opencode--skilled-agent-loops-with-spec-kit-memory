{"type":"tool_use","timestamp":1781151321126,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_AErsem9wG5QrBilrCIbCue61","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Embedder Reindex Orchestrator\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { randomUUID } from 'node:crypto';\n6: import * as fs from 'node:fs';\n7: import * as path from 'node:path';\n8: \n9: import Database from 'better-sqlite3';\n10: import * as sqliteVec from 'sqlite-vec';\n11: \n12: import { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\n13: import { invalidateProviderSingleton } from '@spec-kit/shared/embeddings';\n14: \n15: import { attachActiveVectorShard, initializeDb } from '../search/vector-index-store.js';\n16: import { to_embedding_buffer } from '../search/vector-index-types.js';\n17: import {\n18:   ensureVecTableForDim,\n19:   getActiveEmbedder,\n20:   setActiveEmbedder,\n21:   vecTableNameForDim,\n22: } from './schema.js';\n23: import { getEmbedderAdapter, teardownEmbedderAfterSwap } from './execution-router.js';\n24: import { getManifest } from './registry.js';\n25: import { parseBoundedEnv } from '../util/env.js';\n26: import { createLogger } from '../utils/logger.js';\n27: import { getRestoreBarrierStatus } from '../storage/checkpoints.js';\n28: import { BetterSqliteMaintenance } from '../storage/ports/maintenance.js';\n29: import {\n30:   recordVectorShardRebuildCompleted,\n31:   recordVectorShardRebuildFailed,\n32:   recordVectorShardRebuildStarted,\n33: } from '../observability/retrieval-observability.js';\n34: \n35: // ───────────────────────────────────────────────────────────────\n36: // 1. TYPE DEFINITIONS\n37: // ───────────────────────────────────────────────────────────────\n38: \n39: export type ReindexJobStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n40: \n41: export interface ReindexJob {\n42:   readonly id: string;\n43:   readonly fromName: string;\n44:   readonly toName: string;\n45:   readonly toDim: number;\n46:   readonly total: number;\n47:   readonly processed: number;\n48:   readonly status: ReindexJobStatus;\n49:   readonly startedAt: string;\n50:   readonly updatedAt: string;\n51:   readonly error?: string;\n52: }\n53: \n54: export interface StartReindexOptions {\n55:   readonly toName: string;\n56: }\n57: \n58: export interface ReindexRuntimeOptions {\n59:   readonly db?: Database.Database;\n60: }\n61: \n62: interface ReindexInternalRuntimeOptions extends ReindexRuntimeOptions {\n63:   readonly autoStart?: boolean;\n64:   readonly vectorShardRepair?: {\n65:     readonly reason: string;\n66:     readonly shardPath: string;\n67:   };\n68: }\n69: \n70: type JobRow = Omit<ReindexJob, 'error'> & {\n71:   readonly error: string | null;\n72: };\n73: \n74: interface MemoryRow {\n75:   readonly id: number;\n76:   readonly content_text: string | null;\n77:   readonly title: string | null;\n78:   readonly file_path: string | null;\n79: }\n80: \n81: // ───────────────────────────────────────────────────────────────\n82: // 2. CONSTANTS\n83: // ───────────────────────────────────────────────────────────────\n84: \n85: const DEFAULT_BATCH_SIZE = 50;\n86: const MIN_BATCH_SIZE = 1;\n87: const MAX_BATCH_SIZE = 1_000;\n88: const RESTORE_REQUEUE_DELAY_MS = 100;\n89: const logger = createLogger('embedder-reindex');\n90: const JOB_TABLE_SQL = `\n91:   CREATE TABLE IF NOT EXISTS embedder_jobs (\n92:     id TEXT PRIMARY KEY,\n93:     from_name TEXT NOT NULL,\n94:     to_name TEXT NOT NULL,\n95:     to_dim INTEGER NOT NULL,\n96:     total INTEGER NOT NULL,\n97:     processed INTEGER NOT NULL DEFAULT 0,\n98:     status TEXT NOT NULL CHECK(status IN ('queued', 'running', 'completed', 'failed', 'cancelled')),\n99:     started_at TEXT NOT NULL,\n100:     updated_at TEXT NOT NULL,\n101:     error TEXT\n102:   )\n103: `;\n104: \n105: const JOB_SELECT_COLUMNS = `\n106:   id,\n107:   from_name AS fromName,\n108:   to_name AS toName,\n109:   to_dim AS toDim,\n110:   total,\n111:   processed,\n112:   status,\n113:   started_at AS startedAt,\n114:   updated_at AS updatedAt,\n115:   error\n116: `;\n117: \n118: const runningJobs = new Set<string>();\n119: const vectorShardRepairJobs = new Map<string, { readonly reason: string; readonly shardPath: string }>();\n120: \n121: // ───────────────────────────────────────────────────────────────\n122: // 3. HELPERS\n123: // ───────────────────────────────────────────────────────────────\n124: \n125: export class InvalidDatabaseDirError extends Error {\n126:   constructor(message: string) {\n127:     super(message);\n128:     this.name = 'InvalidDatabaseDirError';\n129:   }\n130: }\n131: \n132: function resolveDb(db?: Database.Database): Database.Database {\n133:   return db ?? initializeDb();\n134: }\n135: \n136: function nowIso(): string {\n137:   return new Date().toISOString();\n138: }\n139: \n140: function readJobStatus(db: Database.Database, jobId: string): ReindexJobStatus | null {\n141:   ensureJobTable(db);\n142:   const row = db.prepare('SELECT status FROM embedder_jobs WHERE id = ?').get(jobId) as\n143:     | { status?: ReindexJobStatus }\n144:     | undefined;\n145:   return row?.status ?? null;\n146: }\n147: \n148: function getBatchSize(): number {\n149:   return parseBoundedEnv('EMBEDDER_REINDEX_BATCH_SIZE', DEFAULT_BATCH_SIZE, MIN_BATCH_SIZE, MAX_BATCH_SIZE);\n150: }\n151: \n152: function jobFromRow(row: JobRow): ReindexJob {\n153:   const { error, ...job } = row;\n154:   return error ? { ...job, error } : job;\n155: }\n156: \n157: function ensureJobTable(db: Database.Database): void {\n158:   db.exec(JOB_TABLE_SQL);\n159: }\n160: \n161: function selectJob(db: Database.Database, jobId: string): ReindexJob | null {\n162:   ensureJobTable(db);\n163:   const row = db.prepare(`\n164:     SELECT ${JOB_SELECT_COLUMNS}\n165:     FROM embedder_jobs\n166:     WHERE id = ?\n167:   `).get(jobId) as JobRow | undefined;\n168: \n169:   return row ? jobFromRow(row) : null;\n170: }\n171: \n172: function selectActiveJob(db: Database.Database): ReindexJob | null {\n173:   ensureJobTable(db);\n174:   const row = db.prepare(`\n175:     SELECT ${JOB_SELECT_COLUMNS}\n176:     FROM embedder_jobs\n177:     WHERE status IN ('queued', 'running')\n178:     ORDER BY started_at DESC, id DESC\n179:     LIMIT 1\n180:   `).get() as JobRow | undefined;\n\n(Showing lines 1-180 of 821. Use offset=181 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embedder Reindex Orchestrator\n// ───────────────────────────────────────────────────────────────\n\nimport { randomUUID } from 'node:crypto';\nimport * as fs from 'node:fs';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { invalidateProviderSingleton } from '@spec-kit/shared/embeddings';\n\nimport { attachActiveVectorShard, initializeDb } from '../search/vector-index-store.js';\nimport { to_embedding_buffer } from '../search/vector-index-types.js';\nimport {\n  ensureVecTableForDim,\n  getActiveEmbedder,\n  setActiveEmbedder,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embedder Reindex Orchestrator\n// ───────────────────────────────────────────────────────────────\n\nimport { randomUUID } from 'node:crypto';\nimport * as fs from 'node:fs';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { invalidateProviderSingleton } from '@spec-kit/shared/embeddings';\n\nimport { attachActiveVectorShard, initializeDb } from '../search/vector-index-store.js';\nimport { to_embedding_buffer } from '../search/vector-index-types.js';\nimport {\n  ensureVecTableForDim,\n  getActiveEmbedder,\n  setActiveEmbedder,\n  vecTableNameForDim,\n} from './schema.js';\nimport { getEmbedderAdapter, teardownEmbedderAfterSwap } from './execution-router.js';\nimport { getManifest } from './registry.js';\nimport { parseBoundedEnv } from '../util/env.js';\nimport { createLogger } from '../utils/logger.js';\nimport { getRestoreBarrierStatus } from '../storage/checkpoints.js';\nimport { BetterSqliteMaintenance } from '../storage/ports/maintenance.js';\nimport {\n  recordVectorShardRebuildCompleted,\n  recordVectorShardRebuildFailed,\n  recordVectorShardRebuildStarted,\n} from '../observability/retrieval-observability.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────\n\nexport type ReindexJobStatus = 'queued' | 'running' | 'completed' | 'failed' | 'cancelled';\n\nexport interface ReindexJob {\n  readonly id: string;\n  readonly fromName: string;\n  readonly toName: string;\n  readonly toDim: number;\n  readonly total: number;\n  readonly processed: number;\n  readonly status: ReindexJobStatus;\n  readonly startedAt: string;\n  readonly updatedAt: string;\n  readonly error?: string;\n}\n\nexport interface StartReindexOptions {\n  readonly toName: string;\n}\n\nexport interface ReindexRuntimeOptions {\n  readonly db?: Database.Database;\n}\n\ninterface ReindexInternalRuntimeOptions extends ReindexRuntimeOptions {\n  readonly autoStart?: boolean;\n  readonly vectorShardRepair?: {\n    readonly reason: string;\n    readonly shardPath: string;\n  };\n}\n\ntype JobRow = Omit<ReindexJob, 'error'> & {\n  readonly error: string | null;\n};\n\ninterface MemoryRow {\n  readonly id: number;\n  readonly content_text: string | null;\n  readonly title: string | null;\n  readonly file_path: string | null;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ───────────────────────────────────────────────────────────────\n\nconst DEFAULT_BATCH_SIZE = 50;\nconst MIN_BATCH_SIZE = 1;\nconst MAX_BATCH_SIZE = 1_000;\nconst RESTORE_REQUEUE_DELAY_MS = 100;\nconst logger = createLogger('embedder-reindex');\nconst JOB_TABLE_SQL = `\n  CREATE TABLE IF NOT EXISTS embedder_jobs (\n    id TEXT PRIMARY KEY,\n    from_name TEXT NOT NULL,\n    to_name TEXT NOT NULL,\n    to_dim INTEGER NOT NULL,\n    total INTEGER NOT NULL,\n    processed INTEGER NOT NULL DEFAULT 0,\n    status TEXT NOT NULL CHECK(status IN ('queued', 'running', 'completed', 'failed', 'cancelled')),\n    started_at TEXT NOT NULL,\n    updated_at TEXT NOT NULL,\n    error TEXT\n  )\n`;\n\nconst JOB_SELECT_COLUMNS = `\n  id,\n  from_name AS fromName,\n  to_name AS toName,\n  to_dim AS toDim,\n  total,\n  processed,\n  status,\n  started_at AS startedAt,\n  updated_at AS updatedAt,\n  error\n`;\n\nconst runningJobs = new Set<string>();\nconst vectorShardRepairJobs = new Map<string, { readonly reason: string; readonly shardPath: string }>();\n\n// ───────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ───────────────────────────────────────────────────────────────\n\nexport class InvalidDatabaseDirError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'InvalidDatabaseDirError';\n  }\n}\n\nfunction resolveDb(db?: Database.Database): Database.Database {\n  return db ?? initializeDb();\n}\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction readJobStatus(db: Database.Database, jobId: string): ReindexJobStatus | null {\n  ensureJobTable(db);\n  const row = db.prepare('SELECT status FROM embedder_jobs WHERE id = ?').get(jobId) as\n    | { status?: ReindexJobStatus }\n    | undefined;\n  return row?.status ?? null;\n}\n\nfunction getBatchSize(): number {\n  return parseBoundedEnv('EMBEDDER_REINDEX_BATCH_SIZE', DEFAULT_BATCH_SIZE, MIN_BATCH_SIZE, MAX_BATCH_SIZE);\n}\n\nfunction jobFromRow(row: JobRow): ReindexJob {\n  const { error, ...job } = row;\n  return error ? { ...job, error } : job;\n}\n\nfunction ensureJobTable(db: Database.Database): void {\n  db.exec(JOB_TABLE_SQL);\n}\n\nfunction selectJob(db: Database.Database, jobId: string): ReindexJob | null {\n  ensureJobTable(db);\n  const row = db.prepare(`\n    SELECT ${JOB_SELECT_COLUMNS}\n    FROM embedder_jobs\n    WHERE id = ?\n  `).get(jobId) as JobRow | undefined;\n\n  return row ? jobFromRow(row) : null;\n}\n\nfunction selectActiveJob(db: Database.Database): ReindexJob | null {\n  ensureJobTable(db);\n  const row = db.prepare(`\n    SELECT ${JOB_SELECT_COLUMNS}\n    FROM embedder_jobs\n    WHERE status IN ('queued', 'running')\n    ORDER BY started_at DESC, id DESC\n    LIMIT 1\n  `).get() as JobRow | undefined;","lineStart":1,"lineEnd":180,"totalLines":821,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","time":{"start":1781151321122,"end":1781151321125}},"metadata":{"openai":{"itemId":"fc_0ae523c823a9a9e2016a2a36590d0881918da249bb92367765"}},"id":"prt_eb4e44c13001qzfA7eEYqh66Iz","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e42a00001cH5KuJQHL9VPKT"}}
{"type":"tool_use","timestamp":1781151321134,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_gET1YX1zDqg6O5WAGFmQlVL6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","offset":180,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts</path>\n<type>file</type>\n<content>\n180:   `).get() as JobRow | undefined;\n181: \n182:   return row ? jobFromRow(row) : null;\n183: }\n184: \n185: function setJobStatus(\n186:   db: Database.Database,\n187:   jobId: string,\n188:   status: ReindexJobStatus,\n189:   processed?: number,\n190:   error?: string,\n191: ): void {\n192:   const params = {\n193:     jobId,\n194:     status,\n195:     updatedAt: nowIso(),\n196:     processed,\n197:     error,\n198:   };\n199: \n200:   if (typeof processed === 'number' && typeof error === 'string') {\n201:     db.prepare(`\n202:       UPDATE embedder_jobs\n203:       SET status = @status,\n204:           updated_at = @updatedAt,\n205:           processed = @processed,\n206:           error = @error\n207:       WHERE id = @jobId\n208:     `).run(params);\n209:     return;\n210:   }\n211: \n212:   if (typeof processed === 'number') {\n213:     // A per-batch progress write must NOT clobber a terminal status set\n214:     // by a concurrent cancelJob(). The only caller that passes processed without an error\n215:     // is the in-loop 'running' progress update, which must only apply while the job is\n216:     // still 'running' (or being re-affirmed as 'running'); never resurrect a 'cancelled'\n217:     // (or 'completed'/'failed') row back to 'running'. Terminal transitions (completed /\n218:     // failed) always carry the other branches and stay unconditional.\n219:     if (status === 'running') {\n220:       db.prepare(`\n221:         UPDATE embedder_jobs\n222:         SET status = @status,\n223:             updated_at = @updatedAt,\n224:             processed = @processed\n225:         WHERE id = @jobId\n226:           AND status = 'running'\n227:       `).run(params);\n228:       return;\n229:     }\n230:     db.prepare(`\n231:       UPDATE embedder_jobs\n232:       SET status = @status,\n233:           updated_at = @updatedAt,\n234:           processed = @processed\n235:       WHERE id = @jobId\n236:     `).run(params);\n237:     return;\n238:   }\n239: \n240:   if (typeof error === 'string') {\n241:     db.prepare(`\n242:       UPDATE embedder_jobs\n243:       SET status = @status,\n244:           updated_at = @updatedAt,\n245:           error = @error\n246:       WHERE id = @jobId\n247:     `).run(params);\n248:     return;\n249:   }\n250: \n251:   db.prepare(`\n252:     UPDATE embedder_jobs\n253:     SET status = @status,\n254:         updated_at = @updatedAt\n255:     WHERE id = @jobId\n256:   `).run(params);\n257: }\n258: \n259: function selectMemoryBatch(db: Database.Database, offset: number, limit: number): MemoryRow[] {\n260:   return db.prepare(`\n261:     SELECT id, content_text, title, file_path\n262:     FROM memory_index\n263:     ORDER BY id ASC\n264:     LIMIT ? OFFSET ?\n265:   `).all(limit, offset) as MemoryRow[];\n266: }\n267: \n268: function memoryText(row: MemoryRow): string {\n269:   if (typeof row.content_text === 'string' && row.content_text.length > 0) {\n270:     return row.content_text;\n271:   }\n272:   if (typeof row.title === 'string' && row.title.length > 0) {\n273:     return row.title;\n274:   }\n275:   return row.file_path ?? '';\n276: }\n277: \n278: function getBatchPair(\n279:   rows: MemoryRow[],\n280:   embeddings: Float32Array[],\n281:   index: number,\n282: ): { readonly row: MemoryRow; readonly embedding: Float32Array } {\n283:   const row = rows[index];\n284:   const embedding = embeddings[index];\n285:   if (!row || !embedding) {\n286:     const missing: string[] = [];\n287:     if (!row) missing.push('row=undefined');\n288:     if (!embedding) missing.push('embedding=undefined');\n289:     throw new Error(\n290:       `Embedding batch entry missing at index ${index}: ${missing.join(', ')} ` +\n291:         `(rows.length=${rows.length}, embeddings.length=${embeddings.length})`,\n292:     );\n293:   }\n294:   return { row, embedding };\n295: }\n296: \n297: function writeVectors(\n298:   db: Database.Database,\n299:   tableName: string,\n300:   rows: MemoryRow[],\n301:   embeddings: Float32Array[],\n302: ): void {\n303:   const writeBatch = db.transaction(() => {\n304:     const stmt = db.prepare(`\n305:       INSERT OR REPLACE INTO ${tableName} (id, vec)\n306:       VALUES (?, ?)\n307:     `);\n308: \n309:     for (let i = 0; i < rows.length; i += 1) {\n310:       const { row, embedding } = getBatchPair(rows, embeddings, i);\n311:       stmt.run(row.id, to_embedding_buffer(embedding));\n312:     }\n313:   });\n314: \n315:   writeBatch();\n316: }\n317: \n318: function getDatabaseDir(db: Database.Database): string | null {\n319:   const row = (db.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>)\n320:     .find((entry) => entry.name === 'main');\n321:   if (!row?.file || row.file === ':memory:') {\n322:     return null;\n323:   }\n324:   return path.dirname(row.file);\n325: }\n326: \n327: function getDatabasePath(db: Database.Database): string | null {\n328:   try {\n329:     const row = (db.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>)\n330:       .find((entry) => entry.name === 'main');\n331:     if (!row?.file || row.file === ':memory:') {\n332:       return null;\n333:     }\n334:     return row.file;\n335:   } catch (_error: unknown) {\n336:     return null;\n337:   }\n338: }\n339: \n340: function isClosedDatabaseHandleError(error: unknown): boolean {\n341:   const message = error instanceof Error ? error.message : String(error);\n342:   return /database connection is not open|closed database|database handle is closed/i.test(message);\n343: }\n344: \n345: function scheduleJobAfterRestore(jobId: string, dbPath: string | null): void {\n346:   setTimeout(() => {\n347:     // Do not re-open the database while a checkpoint restore is still in\n348:     // progress: initialize_db runs interrupted-restore recovery, which would\n349:     // roll back the in-flight restore. Wait for the barrier to clear.\n350:     if (getRestoreBarrierStatus()) {\n351:       scheduleJobAfterRestore(jobId, dbPath);\n352:       return;\n353:     }\n354:     try {\n355:       enqueueJob(dbPath ? initializeDb(dbPath) : initializeDb(), jobId);\n356:     } catch (error: unknown) {\n357:       logger.warn('embedder reindex restore retry skipped', {\n358:         event: 'embedder_reindex_restore_retry_skipped',\n359:         jobId,\n360:         error: error instanceof Error ? error.message : String(error),\n361:       });\n362:     }\n363:   }, RESTORE_REQUEUE_DELAY_MS).unref?.();\n364: }\n365: \n366: function requireDatabaseDir(db: Database.Database, operation: string): string {\n367:   const databaseDir = getDatabaseDir(db);\n368:   if (!databaseDir) {\n369:     throw new InvalidDatabaseDirError(\n370:       `Embedder reindex ${operation} requires a file-backed database; received an in-memory or anonymous database without a database directory`,\n371:     );\n372:   }\n373:   return databaseDir;\n374: }\n375: \n376: function writeVectorsToKnn(\n377:   db: Database.Database,\n378:   rows: MemoryRow[],\n379:   embeddings: Float32Array[],\n380: ): void {\n381:   const writeBatch = db.transaction(() => {\n382:     const del = db.prepare('DELETE FROM vec_memories WHERE rowid = ?');\n383:     const ins = db.prepare('INSERT INTO vec_memories (rowid, embedding) VALUES (?, ?)');\n384:     for (let i = 0; i < rows.length; i += 1) {\n385:       const { row, embedding } = getBatchPair(rows, embeddings, i);\n386:       del.run(BigInt(row.id));\n387:       ins.run(BigInt(row.id), to_embedding_buffer(embedding));\n388:     }\n389:   });\n390: \n391:   writeBatch();\n392: }\n393: \n394: function ensureShardSchema(shard: Database.Database, profile: EmbeddingProfile, tableName: string): void {\n395:   shard.exec(`\n396:     CREATE TABLE IF NOT EXISTS vec_metadata (\n397:       key TEXT PRIMARY KEY,\n398:       value TEXT NOT NULL,\n399:       created_at TEXT DEFAULT (datetime('now'))\n400:     );\n401:     CREATE TABLE IF NOT EXISTS ${tableName} (\n402:       id INTEGER PRIMARY KEY,\n403:       vec BLOB NOT NULL\n404:     );\n405:   `);\n406: \n407:   const writeMetadata = shard.transaction(() => {\n408:     const stmt = shard.prepare('INSERT OR REPLACE INTO vec_metadata (key, value) VALUES (?, ?)');\n409:     stmt.run('provider', profile.provider);\n410:     stmt.run('model', profile.model);\n411:     stmt.run('dim', String(profile.dim));\n412:     stmt.run('embedding_dim', String(profile.dim));\n413:   });\n414:   writeMetadata();\n415: }\n416: \n417: function writeVectorsToShard(\n418:   db: Database.Database,\n419:   profile: EmbeddingProfile,\n420:   tableName: string,\n421:   rows: MemoryRow[],\n422:   embeddings: Float32Array[],\n423:   shardPath?: string,\n424: ): void {\n425:   const databaseDir = requireDatabaseDir(db, 'vector shard write');\n426: \n427:   // Writes target a caller-supplied STAGING shard path (default: the live\n428:   // active shard for backward compatibility). runJob writes every batch to the staging\n429:   // path and atomically renames staging -> active on success, so a mid-loop failure can\n430:   // never leave the live (active) shard half-written.\n431:   const shard = new Database(shardPath ?? profile.getVectorShardPath(databaseDir));\n432:   try {\n433:     shard.pragma('journal_mode = WAL');\n434: \n435:     // Load sqlite-vec so the runtime KNN virtual table can be created\n436:     // and populated alongside the canonical vec_<dim> blob table. When the extension\n437:     // is unavailable the runtime falls back to vec_<dim> only and search degrades to\n438:     // lexical signals; we surface that through the existing console.warn in vector-index-store.\n439:     let vecAvailable = true;\n\n(Showing lines 180-439 of 821. Use offset=440 to continue.)\n</content>","metadata":{"preview":"  `).get() as JobRow | undefined;\n\n  return row ? jobFromRow(row) : null;\n}\n\nfunction setJobStatus(\n  db: Database.Database,\n  jobId: string,\n  status: ReindexJobStatus,\n  processed?: number,\n  error?: string,\n): void {\n  const params = {\n    jobId,\n    status,\n    updatedAt: nowIso(),\n    processed,\n    error,\n  };\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","text":"  `).get() as JobRow | undefined;\n\n  return row ? jobFromRow(row) : null;\n}\n\nfunction setJobStatus(\n  db: Database.Database,\n  jobId: string,\n  status: ReindexJobStatus,\n  processed?: number,\n  error?: string,\n): void {\n  const params = {\n    jobId,\n    status,\n    updatedAt: nowIso(),\n    processed,\n    error,\n  };\n\n  if (typeof processed === 'number' && typeof error === 'string') {\n    db.prepare(`\n      UPDATE embedder_jobs\n      SET status = @status,\n          updated_at = @updatedAt,\n          processed = @processed,\n          error = @error\n      WHERE id = @jobId\n    `).run(params);\n    return;\n  }\n\n  if (typeof processed === 'number') {\n    // A per-batch progress write must NOT clobber a terminal status set\n    // by a concurrent cancelJob(). The only caller that passes processed without an error\n    // is the in-loop 'running' progress update, which must only apply while the job is\n    // still 'running' (or being re-affirmed as 'running'); never resurrect a 'cancelled'\n    // (or 'completed'/'failed') row back to 'running'. Terminal transitions (completed /\n    // failed) always carry the other branches and stay unconditional.\n    if (status === 'running') {\n      db.prepare(`\n        UPDATE embedder_jobs\n        SET status = @status,\n            updated_at = @updatedAt,\n            processed = @processed\n        WHERE id = @jobId\n          AND status = 'running'\n      `).run(params);\n      return;\n    }\n    db.prepare(`\n      UPDATE embedder_jobs\n      SET status = @status,\n          updated_at = @updatedAt,\n          processed = @processed\n      WHERE id = @jobId\n    `).run(params);\n    return;\n  }\n\n  if (typeof error === 'string') {\n    db.prepare(`\n      UPDATE embedder_jobs\n      SET status = @status,\n          updated_at = @updatedAt,\n          error = @error\n      WHERE id = @jobId\n    `).run(params);\n    return;\n  }\n\n  db.prepare(`\n    UPDATE embedder_jobs\n    SET status = @status,\n        updated_at = @updatedAt\n    WHERE id = @jobId\n  `).run(params);\n}\n\nfunction selectMemoryBatch(db: Database.Database, offset: number, limit: number): MemoryRow[] {\n  return db.prepare(`\n    SELECT id, content_text, title, file_path\n    FROM memory_index\n    ORDER BY id ASC\n    LIMIT ? OFFSET ?\n  `).all(limit, offset) as MemoryRow[];\n}\n\nfunction memoryText(row: MemoryRow): string {\n  if (typeof row.content_text === 'string' && row.content_text.length > 0) {\n    return row.content_text;\n  }\n  if (typeof row.title === 'string' && row.title.length > 0) {\n    return row.title;\n  }\n  return row.file_path ?? '';\n}\n\nfunction getBatchPair(\n  rows: MemoryRow[],\n  embeddings: Float32Array[],\n  index: number,\n): { readonly row: MemoryRow; readonly embedding: Float32Array } {\n  const row = rows[index];\n  const embedding = embeddings[index];\n  if (!row || !embedding) {\n    const missing: string[] = [];\n    if (!row) missing.push('row=undefined');\n    if (!embedding) missing.push('embedding=undefined');\n    throw new Error(\n      `Embedding batch entry missing at index ${index}: ${missing.join(', ')} ` +\n        `(rows.length=${rows.length}, embeddings.length=${embeddings.length})`,\n    );\n  }\n  return { row, embedding };\n}\n\nfunction writeVectors(\n  db: Database.Database,\n  tableName: string,\n  rows: MemoryRow[],\n  embeddings: Float32Array[],\n): void {\n  const writeBatch = db.transaction(() => {\n    const stmt = db.prepare(`\n      INSERT OR REPLACE INTO ${tableName} (id, vec)\n      VALUES (?, ?)\n    `);\n\n    for (let i = 0; i < rows.length; i += 1) {\n      const { row, embedding } = getBatchPair(rows, embeddings, i);\n      stmt.run(row.id, to_embedding_buffer(embedding));\n    }\n  });\n\n  writeBatch();\n}\n\nfunction getDatabaseDir(db: Database.Database): string | null {\n  const row = (db.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>)\n    .find((entry) => entry.name === 'main');\n  if (!row?.file || row.file === ':memory:') {\n    return null;\n  }\n  return path.dirname(row.file);\n}\n\nfunction getDatabasePath(db: Database.Database): string | null {\n  try {\n    const row = (db.prepare('PRAGMA database_list').all() as Array<{ name?: string; file?: string }>)\n      .find((entry) => entry.name === 'main');\n    if (!row?.file || row.file === ':memory:') {\n      return null;\n    }\n    return row.file;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction isClosedDatabaseHandleError(error: unknown): boolean {\n  const message = error instanceof Error ? error.message : String(error);\n  return /database connection is not open|closed database|database handle is closed/i.test(message);\n}\n\nfunction scheduleJobAfterRestore(jobId: string, dbPath: string | null): void {\n  setTimeout(() => {\n    // Do not re-open the database while a checkpoint restore is still in\n    // progress: initialize_db runs interrupted-restore recovery, which would\n    // roll back the in-flight restore. Wait for the barrier to clear.\n    if (getRestoreBarrierStatus()) {\n      scheduleJobAfterRestore(jobId, dbPath);\n      return;\n    }\n    try {\n      enqueueJob(dbPath ? initializeDb(dbPath) : initializeDb(), jobId);\n    } catch (error: unknown) {\n      logger.warn('embedder reindex restore retry skipped', {\n        event: 'embedder_reindex_restore_retry_skipped',\n        jobId,\n        error: error instanceof Error ? error.message : String(error),\n      });\n    }\n  }, RESTORE_REQUEUE_DELAY_MS).unref?.();\n}\n\nfunction requireDatabaseDir(db: Database.Database, operation: string): string {\n  const databaseDir = getDatabaseDir(db);\n  if (!databaseDir) {\n    throw new InvalidDatabaseDirError(\n      `Embedder reindex ${operation} requires a file-backed database; received an in-memory or anonymous database without a database directory`,\n    );\n  }\n  return databaseDir;\n}\n\nfunction writeVectorsToKnn(\n  db: Database.Database,\n  rows: MemoryRow[],\n  embeddings: Float32Array[],\n): void {\n  const writeBatch = db.transaction(() => {\n    const del = db.prepare('DELETE FROM vec_memories WHERE rowid = ?');\n    const ins = db.prepare('INSERT INTO vec_memories (rowid, embedding) VALUES (?, ?)');\n    for (let i = 0; i < rows.length; i += 1) {\n      const { row, embedding } = getBatchPair(rows, embeddings, i);\n      del.run(BigInt(row.id));\n      ins.run(BigInt(row.id), to_embedding_buffer(embedding));\n    }\n  });\n\n  writeBatch();\n}\n\nfunction ensureShardSchema(shard: Database.Database, profile: EmbeddingProfile, tableName: string): void {\n  shard.exec(`\n    CREATE TABLE IF NOT EXISTS vec_metadata (\n      key TEXT PRIMARY KEY,\n      value TEXT NOT NULL,\n      created_at TEXT DEFAULT (datetime('now'))\n    );\n    CREATE TABLE IF NOT EXISTS ${tableName} (\n      id INTEGER PRIMARY KEY,\n      vec BLOB NOT NULL\n    );\n  `);\n\n  const writeMetadata = shard.transaction(() => {\n    const stmt = shard.prepare('INSERT OR REPLACE INTO vec_metadata (key, value) VALUES (?, ?)');\n    stmt.run('provider', profile.provider);\n    stmt.run('model', profile.model);\n    stmt.run('dim', String(profile.dim));\n    stmt.run('embedding_dim', String(profile.dim));\n  });\n  writeMetadata();\n}\n\nfunction writeVectorsToShard(\n  db: Database.Database,\n  profile: EmbeddingProfile,\n  tableName: string,\n  rows: MemoryRow[],\n  embeddings: Float32Array[],\n  shardPath?: string,\n): void {\n  const databaseDir = requireDatabaseDir(db, 'vector shard write');\n\n  // Writes target a caller-supplied STAGING shard path (default: the live\n  // active shard for backward compatibility). runJob writes every batch to the staging\n  // path and atomically renames staging -> active on success, so a mid-loop failure can\n  // never leave the live (active) shard half-written.\n  const shard = new Database(shardPath ?? profile.getVectorShardPath(databaseDir));\n  try {\n    shard.pragma('journal_mode = WAL');\n\n    // Load sqlite-vec so the runtime KNN virtual table can be created\n    // and populated alongside the canonical vec_<dim> blob table. When the extension\n    // is unavailable the runtime falls back to vec_<dim> only and search degrades to\n    // lexical signals; we surface that through the existing console.warn in vector-index-store.\n    let vecAvailable = true;","lineStart":180,"lineEnd":439,"totalLines":821,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","time":{"start":1781151321130,"end":1781151321133}},"metadata":{"openai":{"itemId":"fc_0ae523c823a9a9e2016a2a36590d1081919d3c068aab63347c"}},"id":"prt_eb4e44c23001ByiiaQWx2HZqyo","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e42a00001cH5KuJQHL9VPKT"}}
{"type":"tool_use","timestamp":1781151321166,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_aWrp3IKbjuXzUTZ87B1LK8Rt","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","offset":440,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts</path>\n<type>file</type>\n<content>\n440:     try {\n441:       sqliteVec.load(shard);\n442:     } catch (_err) {\n443:       vecAvailable = false;\n444:     }\n445: \n446:     ensureShardSchema(shard, profile, tableName);\n447: \n448:     if (vecAvailable) {\n449:       shard.exec(`\n450:         CREATE VIRTUAL TABLE IF NOT EXISTS vec_memories USING vec0(\n451:           embedding FLOAT[${profile.dim}]\n452:         )\n453:       `);\n454:     }\n455: \n456:     writeVectors(shard, tableName, rows, embeddings);\n457:     if (vecAvailable) {\n458:       writeVectorsToKnn(shard, rows, embeddings);\n459:     }\n460:   } finally {\n461:     // WAL-durability: flush + TRUNCATE the shard WAL before close so the shard file is\n462:     // consistent at rest with an empty WAL — mirrors close_db's corruption-prevention.\n463:     // better-sqlite3 .close() only does a passive checkpoint; an abrupt later kill could otherwise\n464:     // corrupt un-checkpointed shard frames (vec0 / FTS segment writes). Best-effort; never block close.\n465:     new BetterSqliteMaintenance(shard).checkpoint({ mode: 'truncate' });\n466:     shard.close();\n467:   }\n468: }\n469: \n470: function enqueueJob(db: Database.Database, jobId: string): void {\n471:   if (runningJobs.has(jobId)) {\n472:     return;\n473:   }\n474: \n475:   runningJobs.add(jobId);\n476:   void runJob(db, jobId).finally(() => {\n477:     runningJobs.delete(jobId);\n478:   });\n479: }\n480: \n481: async function runJob(db: Database.Database, jobId: string): Promise<void> {\n482:   const dbPath = getDatabasePath(db);\n483:   let jobDb = db;\n484:   if (getRestoreBarrierStatus()) {\n485:     scheduleJobAfterRestore(jobId, dbPath);\n486:     return;\n487:   }\n488:   const resolveJobDb = (): Database.Database => {\n489:     const barrierStatus = getRestoreBarrierStatus();\n490:     if (barrierStatus) {\n491:       const error = new Error(barrierStatus.message);\n492:       error.name = barrierStatus.code;\n493:       throw error;\n494:     }\n495:     return jobDb;\n496:   };\n497:   jobDb = resolveJobDb();\n498:   const initialJob = selectJob(jobDb, jobId);\n499:   if (!initialJob || initialJob.status === 'completed' || initialJob.status === 'failed' || initialJob.status === 'cancelled') {\n500:     return;\n501:   }\n502: \n503:   const manifest = getManifest(initialJob.toName);\n504:   if (!manifest) {\n505:     setJobStatus(jobDb, jobId, 'failed', undefined, `UNKNOWN_EMBEDDER: ${initialJob.toName}`);\n506:     return;\n507:   }\n508:   const adapter = getEmbedderAdapter(manifest.backend, initialJob.toName, initialJob.toDim);\n509:   const targetProfile = new EmbeddingProfile({\n510:     provider: manifest.backend,\n511:     model: manifest.name,\n512:     dim: manifest.dim,\n513:     dtype: null,\n514:     baseUrl: null,\n515:   });\n516: \n517:   ensureVecTableForDim(jobDb, initialJob.toDim);\n518:   const tableName = vecTableNameForDim(initialJob.toDim);\n519:   const batchSize = getBatchSize();\n520:   let processed = initialJob.processed;\n521: \n522:   // Stage every shard write into a per-job staging file, then atomically\n523:   // rename it over the live active shard ONLY after the completion transaction commits.\n524:   // A mid-loop throw (or cancel) leaves the live (active) shard untouched; the partial\n525:   // staging artifact is unlinked in the catch/cancel paths. databaseDir is guaranteed\n526:   // file-backed here (startReindexInternal already called requireDatabaseDir).\n527:   const databaseDir = requireDatabaseDir(jobDb, 'reindex staging');\n528:   const activeShardPath = targetProfile.getVectorShardPath(databaseDir);\n529:   const stagingShardPath = `${activeShardPath}.reindex-${jobId}.staging`;\n530: \n531:   const cleanupStaging = (): void => {\n532:     for (const suffix of ['', '-wal', '-shm']) {\n533:       try {\n534:         fs.unlinkSync(`${stagingShardPath}${suffix}`);\n535:       } catch (_err: unknown) {\n536:         /* best-effort: staging may not exist */\n537:       }\n538:     }\n539:   };\n540: \n541:   try {\n542:     setJobStatus(jobDb, jobId, 'running');\n543:     const repairContext = vectorShardRepairJobs.get(jobId);\n544:     if (repairContext) {\n545:       recordVectorShardRebuildStarted({\n546:         jobId,\n547:         shardPath: repairContext.shardPath,\n548:         reason: repairContext.reason,\n549:       });\n550:     }\n551:     // Start each run from a clean staging slate (a prior crashed run may have left one).\n552:     cleanupStaging();\n553: \n554:     while (processed < initialJob.total) {\n555:       jobDb = resolveJobDb();\n556:       // Re-read the live cancel/status before each batch so cancelJob()\n557:       // during a run stops the worker before the next write. Abort cleanly: drop the\n558:       // staging artifact and leave the live shard + active pointer untouched.\n559:       if (readJobStatus(jobDb, jobId) === 'cancelled') {\n560:         cleanupStaging();\n561:         return;\n562:       }\n563: \n564:       const rows = selectMemoryBatch(jobDb, processed, batchSize);\n565:       if (rows.length === 0) {\n566:         break;\n567:       }\n568: \n569:       const embeddings = await adapter.embed(rows.map(memoryText));\n570:       jobDb = resolveJobDb();\n571:       if (embeddings.length !== rows.length) {\n572:         throw new Error(`Embedder returned ${embeddings.length} embeddings for ${rows.length} memories`);\n573:       }\n574: \n575:       writeVectors(jobDb, tableName, rows, embeddings);\n576:       writeVectorsToShard(jobDb, targetProfile, tableName, rows, embeddings, stagingShardPath);\n577:       processed += rows.length;\n578:       // Clobber-safe: only advances while status is still 'running' (never resurrects\n579:       // a concurrently-set 'cancelled').\n580:       setJobStatus(jobDb, jobId, 'running', processed);\n581:       await new Promise<void>((resolve) => {\n582:         setImmediate(resolve);\n583:       });\n584:     }\n585: \n586:     // Final cancel checkpoint before the irreversible swap/commit.\n587:     jobDb = resolveJobDb();\n588:     if (readJobStatus(jobDb, jobId) === 'cancelled') {\n589:       cleanupStaging();\n590:       return;\n591:     }\n592: \n593:     // Atomically swap the staged shard over the live active shard BEFORE the\n594:     // completion transaction flips the active-embedder pointer. rename(2) is atomic on\n595:     // the same filesystem; the staging file always lives beside the active shard, so the\n596:     // active shard either is the old file (failure) or the fully-staged new file (success),\n597:     // never a half-written mix. If no batch produced a staging file (e.g. zero rows), skip.\n598:     if (fs.existsSync(stagingShardPath)) {\n599:       // Drop any stale sidecars next to the active shard so the renamed WAL/SHM (already\n600:       // TRUNCATE-checkpointed at staging close) is the authoritative pair.\n601:       for (const suffix of ['-wal', '-shm']) {\n602:         try {\n603:           fs.unlinkSync(`${activeShardPath}${suffix}`);\n604:         } catch (_err: unknown) {\n605:           /* best-effort */\n606:         }\n607:       }\n608:       fs.renameSync(stagingShardPath, activeShardPath);\n609:     }\n610: \n611:     const complete = jobDb.transaction(() => {\n612:       // Persist the active-embedder provider pointer too; omitting it leaves the pointer empty,\n613:       // which readActiveEmbedderIfValid coerces to undefined and the next boot loses provider\n614:       // identity. 'api' backends are ambiguous (openai vs voyage) from the manifest alone, so\n615:       // leave the provider unset for those rather than guess.\n616:       const activeProvider = manifest.backend === 'ollama'\n617:         ? 'ollama'\n618:         : manifest.backend === 'sentence-transformers'\n619:           ? 'hf-local'\n620:           : undefined;\n621:       setActiveEmbedder(jobDb, initialJob.toName, initialJob.toDim, activeProvider);\n622:       // Commit embedding_status for rows now backed by an active-profile vector.\n623:       // A vector-only reindex previously wrote vectors but left memory_index.embedding_status\n624:       // stale, so a \"completed\" bulk re-embed never raised the success count. Reconcile the\n625:       // status for every row present in the just-written vec_<dim> table, inside the same\n626:       // atomic completion transaction so vectors and status flip together.\n627:       const completedAt = nowIso();\n628:       jobDb.prepare(`\n629:         UPDATE memory_index\n630:         SET embedding_status = 'success',\n631:             embedding_generated_at = COALESCE(embedding_generated_at, @ts),\n632:             updated_at = @ts,\n633:             failure_reason = NULL\n634:         WHERE embedding_status != 'success'\n635:           AND id IN (SELECT id FROM ${tableName})\n636:       `).run({ ts: completedAt });\n637:       setJobStatus(jobDb, jobId, 'completed', initialJob.total);\n638:     });\n639:     complete();\n640:     if (repairContext) {\n641:       recordVectorShardRebuildCompleted({ jobId, shardPath: repairContext.shardPath });\n642:       vectorShardRepairJobs.delete(jobId);\n643:     }\n644:     // The active-embedder pointer just flipped; drop the cached provider singleton so the\n645:     // next embedding re-resolves against the new pointer instead of the stale model/dim.\n646:     invalidateProviderSingleton();\n647:     void teardownEmbedderAfterSwap(manifest.backend, initialJob.toName).catch((error: unknown) => {\n648:       console.warn(`[embedder-reindex] embedder teardown after swap failed: ${error instanceof Error ? error.message : String(error)}`);\n649:     });\n650:     if (getDatabaseDir(jobDb)) {\n651:       attachActiveVectorShard(jobDb, targetProfile);\n652:     }\n653:   } catch (error: unknown) {\n654:     if (getRestoreBarrierStatus() || isClosedDatabaseHandleError(error)) {\n655:       cleanupStaging();\n656:       scheduleJobAfterRestore(jobId, dbPath);\n657:       logger.warn('embedder reindex paused for checkpoint restore', {\n658:         event: 'embedder_reindex_restore_paused',\n659:         jobId,\n660:         processed,\n661:       });\n662:       return;\n663:     }\n664:     // A failed run must not leave a half-written shard anywhere. The live active\n665:     // shard was never mutated (all writes went to staging); discard the partial staging\n666:     // artifact so the next attempt starts clean and the active shard stays the last-good one.\n667:     cleanupStaging();\n668:     const message = error instanceof Error ? error.message : String(error);\n669:     setJobStatus(jobDb, jobId, 'failed', processed, message);\n670:     const repairContext = vectorShardRepairJobs.get(jobId);\n671:     if (repairContext) {\n672:       recordVectorShardRebuildFailed({ jobId, shardPath: repairContext.shardPath, reason: message });\n673:       vectorShardRepairJobs.delete(jobId);\n674:     }\n675:     logger.error('embedder reindex job failed', {\n676:       event: 'embedder_reindex_failed',\n677:       jobId,\n678:       toName: initialJob.toName,\n679:       processed,\n680:       total: initialJob.total,\n681:       error: message,\n682:     });\n683:   }\n684: }\n685: \n686: // ───────────────────────────────────────────────────────────────\n687: // 4. CORE LOGIC\n688: // ───────────────────────────────────────────────────────────────\n689: \n690: export function startReindex(\n691:   options: StartReindexOptions,\n692:   runtimeOptions: ReindexRuntimeOptions = {},\n693: ): string {\n694:   return startReindexInternal(options, runtimeOptions);\n695: }\n696: \n697: function startReindexInternal(\n698:   options: StartReindexOptions,\n699:   runtimeOptions: ReindexInternalRuntimeOptions = {},\n700: ): string {\n701:   const db = resolveDb(runtimeOptions.db);\n702:   requireDatabaseDir(db, 'startup');\n703:   ensureJobTable(db);\n704: \n705:   const manifest = getManifest(options.toName);\n706:   if (!manifest) {\n707:     const error = new Error(`UNKNOWN_EMBEDDER: ${options.toName}`);\n708:     error.name = 'UNKNOWN_EMBEDDER';\n709:     throw error;\n710:   }\n711: \n712:   ensureVecTableForDim(db, manifest.dim);\n713:   const active = getActiveEmbedder(db);\n714:   const totalRow = db.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count?: number } | undefined;\n715:   const total = Number(totalRow?.count ?? 0);\n716:   const timestamp = nowIso();\n717:   const id = `emb-swap-${timestamp.replace(/[:.]/g, '-')}-${randomUUID().slice(0, 8)}`;\n718: \n719:   db.prepare(`\n720:     INSERT INTO embedder_jobs (\n721:       id, from_name, to_name, to_dim, total, processed, status, started_at, updated_at, error\n722:     ) VALUES (?, ?, ?, ?, ?, 0, 'queued', ?, ?, NULL)\n723:   `).run(id, active.name, manifest.name, manifest.dim, total, timestamp, timestamp);\n724: \n725:   if (runtimeOptions.vectorShardRepair) {\n726:     vectorShardRepairJobs.set(id, runtimeOptions.vectorShardRepair);\n727:   }\n728: \n729:   if (runtimeOptions.autoStart !== false) {\n730:     enqueueJob(db, id);\n731:   }\n732: \n733:   return id;\n734: }\n735: \n736: export function getJobStatus(jobId: string, db?: Database.Database): ReindexJob | null {\n737:   return selectJob(resolveDb(db), jobId);\n738: }\n739: \n\n(Showing lines 440-739 of 821. Use offset=740 to continue.)\n</content>","metadata":{"preview":"    try {\n      sqliteVec.load(shard);\n    } catch (_err) {\n      vecAvailable = false;\n    }\n\n    ensureShardSchema(shard, profile, tableName);\n\n    if (vecAvailable) {\n      shard.exec(`\n        CREATE VIRTUAL TABLE IF NOT EXISTS vec_memories USING vec0(\n          embedding FLOAT[${profile.dim}]\n        )\n      `);\n    }\n\n    writeVectors(shard, tableName, rows, embeddings);\n    if (vecAvailable) {\n      writeVectorsToKnn(shard, rows, embeddings);\n    }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","text":"    try {\n      sqliteVec.load(shard);\n    } catch (_err) {\n      vecAvailable = false;\n    }\n\n    ensureShardSchema(shard, profile, tableName);\n\n    if (vecAvailable) {\n      shard.exec(`\n        CREATE VIRTUAL TABLE IF NOT EXISTS vec_memories USING vec0(\n          embedding FLOAT[${profile.dim}]\n        )\n      `);\n    }\n\n    writeVectors(shard, tableName, rows, embeddings);\n    if (vecAvailable) {\n      writeVectorsToKnn(shard, rows, embeddings);\n    }\n  } finally {\n    // WAL-durability: flush + TRUNCATE the shard WAL before close so the shard file is\n    // consistent at rest with an empty WAL — mirrors close_db's corruption-prevention.\n    // better-sqlite3 .close() only does a passive checkpoint; an abrupt later kill could otherwise\n    // corrupt un-checkpointed shard frames (vec0 / FTS segment writes). Best-effort; never block close.\n    new BetterSqliteMaintenance(shard).checkpoint({ mode: 'truncate' });\n    shard.close();\n  }\n}\n\nfunction enqueueJob(db: Database.Database, jobId: string): void {\n  if (runningJobs.has(jobId)) {\n    return;\n  }\n\n  runningJobs.add(jobId);\n  void runJob(db, jobId).finally(() => {\n    runningJobs.delete(jobId);\n  });\n}\n\nasync function runJob(db: Database.Database, jobId: string): Promise<void> {\n  const dbPath = getDatabasePath(db);\n  let jobDb = db;\n  if (getRestoreBarrierStatus()) {\n    scheduleJobAfterRestore(jobId, dbPath);\n    return;\n  }\n  const resolveJobDb = (): Database.Database => {\n    const barrierStatus = getRestoreBarrierStatus();\n    if (barrierStatus) {\n      const error = new Error(barrierStatus.message);\n      error.name = barrierStatus.code;\n      throw error;\n    }\n    return jobDb;\n  };\n  jobDb = resolveJobDb();\n  const initialJob = selectJob(jobDb, jobId);\n  if (!initialJob || initialJob.status === 'completed' || initialJob.status === 'failed' || initialJob.status === 'cancelled') {\n    return;\n  }\n\n  const manifest = getManifest(initialJob.toName);\n  if (!manifest) {\n    setJobStatus(jobDb, jobId, 'failed', undefined, `UNKNOWN_EMBEDDER: ${initialJob.toName}`);\n    return;\n  }\n  const adapter = getEmbedderAdapter(manifest.backend, initialJob.toName, initialJob.toDim);\n  const targetProfile = new EmbeddingProfile({\n    provider: manifest.backend,\n    model: manifest.name,\n    dim: manifest.dim,\n    dtype: null,\n    baseUrl: null,\n  });\n\n  ensureVecTableForDim(jobDb, initialJob.toDim);\n  const tableName = vecTableNameForDim(initialJob.toDim);\n  const batchSize = getBatchSize();\n  let processed = initialJob.processed;\n\n  // Stage every shard write into a per-job staging file, then atomically\n  // rename it over the live active shard ONLY after the completion transaction commits.\n  // A mid-loop throw (or cancel) leaves the live (active) shard untouched; the partial\n  // staging artifact is unlinked in the catch/cancel paths. databaseDir is guaranteed\n  // file-backed here (startReindexInternal already called requireDatabaseDir).\n  const databaseDir = requireDatabaseDir(jobDb, 'reindex staging');\n  const activeShardPath = targetProfile.getVectorShardPath(databaseDir);\n  const stagingShardPath = `${activeShardPath}.reindex-${jobId}.staging`;\n\n  const cleanupStaging = (): void => {\n    for (const suffix of ['', '-wal', '-shm']) {\n      try {\n        fs.unlinkSync(`${stagingShardPath}${suffix}`);\n      } catch (_err: unknown) {\n        /* best-effort: staging may not exist */\n      }\n    }\n  };\n\n  try {\n    setJobStatus(jobDb, jobId, 'running');\n    const repairContext = vectorShardRepairJobs.get(jobId);\n    if (repairContext) {\n      recordVectorShardRebuildStarted({\n        jobId,\n        shardPath: repairContext.shardPath,\n        reason: repairContext.reason,\n      });\n    }\n    // Start each run from a clean staging slate (a prior crashed run may have left one).\n    cleanupStaging();\n\n    while (processed < initialJob.total) {\n      jobDb = resolveJobDb();\n      // Re-read the live cancel/status before each batch so cancelJob()\n      // during a run stops the worker before the next write. Abort cleanly: drop the\n      // staging artifact and leave the live shard + active pointer untouched.\n      if (readJobStatus(jobDb, jobId) === 'cancelled') {\n        cleanupStaging();\n        return;\n      }\n\n      const rows = selectMemoryBatch(jobDb, processed, batchSize);\n      if (rows.length === 0) {\n        break;\n      }\n\n      const embeddings = await adapter.embed(rows.map(memoryText));\n      jobDb = resolveJobDb();\n      if (embeddings.length !== rows.length) {\n        throw new Error(`Embedder returned ${embeddings.length} embeddings for ${rows.length} memories`);\n      }\n\n      writeVectors(jobDb, tableName, rows, embeddings);\n      writeVectorsToShard(jobDb, targetProfile, tableName, rows, embeddings, stagingShardPath);\n      processed += rows.length;\n      // Clobber-safe: only advances while status is still 'running' (never resurrects\n      // a concurrently-set 'cancelled').\n      setJobStatus(jobDb, jobId, 'running', processed);\n      await new Promise<void>((resolve) => {\n        setImmediate(resolve);\n      });\n    }\n\n    // Final cancel checkpoint before the irreversible swap/commit.\n    jobDb = resolveJobDb();\n    if (readJobStatus(jobDb, jobId) === 'cancelled') {\n      cleanupStaging();\n      return;\n    }\n\n    // Atomically swap the staged shard over the live active shard BEFORE the\n    // completion transaction flips the active-embedder pointer. rename(2) is atomic on\n    // the same filesystem; the staging file always lives beside the active shard, so the\n    // active shard either is the old file (failure) or the fully-staged new file (success),\n    // never a half-written mix. If no batch produced a staging file (e.g. zero rows), skip.\n    if (fs.existsSync(stagingShardPath)) {\n      // Drop any stale sidecars next to the active shard so the renamed WAL/SHM (already\n      // TRUNCATE-checkpointed at staging close) is the authoritative pair.\n      for (const suffix of ['-wal', '-shm']) {\n        try {\n          fs.unlinkSync(`${activeShardPath}${suffix}`);\n        } catch (_err: unknown) {\n          /* best-effort */\n        }\n      }\n      fs.renameSync(stagingShardPath, activeShardPath);\n    }\n\n    const complete = jobDb.transaction(() => {\n      // Persist the active-embedder provider pointer too; omitting it leaves the pointer empty,\n      // which readActiveEmbedderIfValid coerces to undefined and the next boot loses provider\n      // identity. 'api' backends are ambiguous (openai vs voyage) from the manifest alone, so\n      // leave the provider unset for those rather than guess.\n      const activeProvider = manifest.backend === 'ollama'\n        ? 'ollama'\n        : manifest.backend === 'sentence-transformers'\n          ? 'hf-local'\n          : undefined;\n      setActiveEmbedder(jobDb, initialJob.toName, initialJob.toDim, activeProvider);\n      // Commit embedding_status for rows now backed by an active-profile vector.\n      // A vector-only reindex previously wrote vectors but left memory_index.embedding_status\n      // stale, so a \"completed\" bulk re-embed never raised the success count. Reconcile the\n      // status for every row present in the just-written vec_<dim> table, inside the same\n      // atomic completion transaction so vectors and status flip together.\n      const completedAt = nowIso();\n      jobDb.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'success',\n            embedding_generated_at = COALESCE(embedding_generated_at, @ts),\n            updated_at = @ts,\n            failure_reason = NULL\n        WHERE embedding_status != 'success'\n          AND id IN (SELECT id FROM ${tableName})\n      `).run({ ts: completedAt });\n      setJobStatus(jobDb, jobId, 'completed', initialJob.total);\n    });\n    complete();\n    if (repairContext) {\n      recordVectorShardRebuildCompleted({ jobId, shardPath: repairContext.shardPath });\n      vectorShardRepairJobs.delete(jobId);\n    }\n    // The active-embedder pointer just flipped; drop the cached provider singleton so the\n    // next embedding re-resolves against the new pointer instead of the stale model/dim.\n    invalidateProviderSingleton();\n    void teardownEmbedderAfterSwap(manifest.backend, initialJob.toName).catch((error: unknown) => {\n      console.warn(`[embedder-reindex] embedder teardown after swap failed: ${error instanceof Error ? error.message : String(error)}`);\n    });\n    if (getDatabaseDir(jobDb)) {\n      attachActiveVectorShard(jobDb, targetProfile);\n    }\n  } catch (error: unknown) {\n    if (getRestoreBarrierStatus() || isClosedDatabaseHandleError(error)) {\n      cleanupStaging();\n      scheduleJobAfterRestore(jobId, dbPath);\n      logger.warn('embedder reindex paused for checkpoint restore', {\n        event: 'embedder_reindex_restore_paused',\n        jobId,\n        processed,\n      });\n      return;\n    }\n    // A failed run must not leave a half-written shard anywhere. The live active\n    // shard was never mutated (all writes went to staging); discard the partial staging\n    // artifact so the next attempt starts clean and the active shard stays the last-good one.\n    cleanupStaging();\n    const message = error instanceof Error ? error.message : String(error);\n    setJobStatus(jobDb, jobId, 'failed', processed, message);\n    const repairContext = vectorShardRepairJobs.get(jobId);\n    if (repairContext) {\n      recordVectorShardRebuildFailed({ jobId, shardPath: repairContext.shardPath, reason: message });\n      vectorShardRepairJobs.delete(jobId);\n    }\n    logger.error('embedder reindex job failed', {\n      event: 'embedder_reindex_failed',\n      jobId,\n      toName: initialJob.toName,\n      processed,\n      total: initialJob.total,\n      error: message,\n    });\n  }\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ───────────────────────────────────────────────────────────────\n\nexport function startReindex(\n  options: StartReindexOptions,\n  runtimeOptions: ReindexRuntimeOptions = {},\n): string {\n  return startReindexInternal(options, runtimeOptions);\n}\n\nfunction startReindexInternal(\n  options: StartReindexOptions,\n  runtimeOptions: ReindexInternalRuntimeOptions = {},\n): string {\n  const db = resolveDb(runtimeOptions.db);\n  requireDatabaseDir(db, 'startup');\n  ensureJobTable(db);\n\n  const manifest = getManifest(options.toName);\n  if (!manifest) {\n    const error = new Error(`UNKNOWN_EMBEDDER: ${options.toName}`);\n    error.name = 'UNKNOWN_EMBEDDER';\n    throw error;\n  }\n\n  ensureVecTableForDim(db, manifest.dim);\n  const active = getActiveEmbedder(db);\n  const totalRow = db.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count?: number } | undefined;\n  const total = Number(totalRow?.count ?? 0);\n  const timestamp = nowIso();\n  const id = `emb-swap-${timestamp.replace(/[:.]/g, '-')}-${randomUUID().slice(0, 8)}`;\n\n  db.prepare(`\n    INSERT INTO embedder_jobs (\n      id, from_name, to_name, to_dim, total, processed, status, started_at, updated_at, error\n    ) VALUES (?, ?, ?, ?, ?, 0, 'queued', ?, ?, NULL)\n  `).run(id, active.name, manifest.name, manifest.dim, total, timestamp, timestamp);\n\n  if (runtimeOptions.vectorShardRepair) {\n    vectorShardRepairJobs.set(id, runtimeOptions.vectorShardRepair);\n  }\n\n  if (runtimeOptions.autoStart !== false) {\n    enqueueJob(db, id);\n  }\n\n  return id;\n}\n\nexport function getJobStatus(jobId: string, db?: Database.Database): ReindexJob | null {\n  return selectJob(resolveDb(db), jobId);\n}\n","lineStart":440,"lineEnd":739,"totalLines":821,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/embedders/reindex.ts","time":{"start":1781151321163,"end":1781151321166}},"metadata":{"openai":{"itemId":"fc_0ae523c823a9a9e2016a2a36590d188191890654d312a4ac6a"}},"id":"prt_eb4e44c2b00137ZlxLfzsKc43P","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e42a00001cH5KuJQHL9VPKT"}}
{"type":"step_finish","timestamp":1781151321483,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"id":"prt_eb4e44d89001RW12f7NXekFHvz","reason":"tool-calls","snapshot":"bd0cc31ea69de12f342f1b80b2c1fed28d0b4f38","messageID":"msg_eb4e42a00001cH5KuJQHL9VPKT","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","type":"step-finish","tokens":{"total":121645,"input":3083,"output":271,"reasoning":19,"cache":{"write":0,"read":118272}},"cost":0}}
{"type":"step_start","timestamp":1781151324455,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"id":"prt_eb4e45926001XaPbkGKyh94d35","messageID":"msg_eb4e44e68001F5UkK4Dkmlw5Tp","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","snapshot":"bd0cc31ea69de12f342f1b80b2c1fed28d0b4f38","type":"step-start"}}
{"type":"tool_use","timestamp":1781151331066,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_BScGsat0bVYnmXxLQkj4F2qb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","offset":1,"limit":225},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Store\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // SEARCH: VECTOR INDEX\n6: // TypeScript port of the vector index implementation.\n7: // DECAY STRATEGY: Search-time temporal decay uses an\n8: // FSRS-preferred strategy. Memories with FSRS review data (last_review\n9: // IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n10: // R(t) = (1 + 0.2346 * t / S)^(-0.5)\n11: // Memories without review data fall back to half-life exponential:\n12: // Weight * 0.5^(days / half_life_days)\n13: // This ensures backward compatibility while aligning reviewed\n14: // Memories with the canonical FSRS algorithm.\n15: \n16: import * as fs from 'fs';\n17: import * as os from 'os';\n18: import * as path from 'path';\n19: \n20: import Database from 'better-sqlite3';\n21: import * as sqliteVec from 'sqlite-vec';\n22: \n23: import { getEmbeddingDimension } from '@spec-kit/shared/embeddings';\n24: import {\n25:   EmbeddingProfile,\n26: } from '@spec-kit/shared/embeddings/profile';\n27: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings/factory';\n28: \n29: import { resolveDatabasePaths, SERVER_DIR } from '../../core/config.js';\n30: import { computeInterferenceScoresBatch } from '../scoring/interference-scoring.js';\n31: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n32: import {\n33:   recordVectorShardProbeFailure,\n34:   recordVectorShardQuarantined,\n35:   recordVectorShardRebuildFailed,\n36: } from '../observability/retrieval-observability.js';\n37: import { validateFilePath } from '../utils/path-security.js';\n38: import {\n39:   get_error_code,\n40:   get_error_message,\n41:   parse_trigger_phrases,\n42:   VectorIndexError,\n43:   VectorIndexErrorCode,\n44: } from './vector-index-types.js';\n45: import {\n46:   create_schema,\n47:   ensure_schema_version,\n48: } from './vector-index-schema.js';\n49: import { migrateLegacySingleDbToShardSync } from './db-shard-migration.js';\n50: import type { MemoryRow } from './vector-index-types.js';\n51: \n52: type SearchWeightsConfig = {\n53:   maxTriggersPerMemory?: number;\n54:   smartRanking?: {\n55:     recencyWeight?: number;\n56:     accessWeight?: number;\n57:     relevanceWeight?: number;\n58:   };\n59: };\n60: \n61: type RestoreJournalPhase = 'swap-pending' | 'swap-done';\n62: \n63: type RestoreJournalFile = {\n64:   formatVersion: 1;\n65:   phase: RestoreJournalPhase;\n66:   createdAt: string;\n67:   checkpointName: string;\n68:   liveMainPath: string;\n69:   backupMainPath: string;\n70:   snapshotMainPath: string;\n71:   liveShardPath: string | null;\n72:   backupShardPath: string | null;\n73:   snapshotVecPath: string | null;\n74:   shouldRestoreVec: boolean;\n75:   liveShardPreexisted: boolean;\n76: };\n77: \n78: type InitializeDbOptions = {\n79:   skipRestoreRecovery?: boolean;\n80: };\n81: \n82: const RESTORE_JOURNAL_NAME = '.restore-journal.json';\n83: const NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\n84: \n85: function loadSearchWeights(): SearchWeightsConfig {\n86:   // SERVER_DIR points to dist/ at runtime; configs/ lives at the package root (dist/..)\n87:   const candidates = [\n88:     path.join(SERVER_DIR, 'configs', 'search-weights.json'),\n89:     path.join(SERVER_DIR, '..', 'configs', 'search-weights.json'),\n90:   ];\n91:   for (const candidate of candidates) {\n92:     try {\n93:       return JSON.parse(fs.readFileSync(candidate, 'utf-8')) as SearchWeightsConfig;\n94:     } catch {\n95:       // Try next candidate\n96:     }\n97:   }\n98:   return {};\n99: }\n100: \n101: let _search_weights: SearchWeightsConfig | null = null;\n102: \n103: function getSearchWeights(): SearchWeightsConfig {\n104:   if (_search_weights === null) {\n105:     _search_weights = loadSearchWeights();\n106:   }\n107:   return _search_weights;\n108: }\n109: \n110: /** Loaded search weight configuration for vector-index ranking (lazy-loaded). */\n111: export const search_weights: SearchWeightsConfig = {\n112:   get maxTriggersPerMemory() {\n113:     return getSearchWeights().maxTriggersPerMemory;\n114:   },\n115:   get smartRanking() {\n116:     return getSearchWeights().smartRanking;\n117:   },\n118: };\n119: \n120: /* ───────────────────────────────────────────────────────────────\n121:    1. CONFIGURATION — Embedding Dimension\n122: ----------------------------------------------------------------*/\n123: \n124: /** Default embedding dimension used by the vector index. */\n125: export const EMBEDDING_DIM = getEmbeddingDimension();\n126: \n127: /**\n128:  * Gets the active embedding dimension for the current provider.\n129:  * @returns The embedding dimension.\n130:  */\n131: export function get_embedding_dim(): number {\n132:   return getEmbeddingDimension();\n133: }\n134: \n135: /**\n136:  * Waits for the embedding provider to report a stable dimension.\n137:  * @param timeout_ms - The maximum time to wait in milliseconds.\n138:  * @returns A promise that resolves to the confirmed embedding dimension.\n139:  */\n140: export async function get_confirmed_embedding_dimension(timeout_ms = 5000): Promise<number> {\n141:   const start = Date.now();\n142:   while (Date.now() - start < timeout_ms) {\n143:     const dim = get_embedding_dim();\n144:     if (Number.isFinite(dim) && dim > 0) {\n145:       return dim;\n146:     }\n147:     await new Promise(resolve => setTimeout(resolve, 100));\n148:   }\n149:   const fallbackDim = get_embedding_dim();\n150:   console.warn(`[vector-index] Using embedding dimension ${fallbackDim} after timeout`);\n151:   return fallbackDim;\n152: }\n153: \n154: type EmbeddingDimensionValidation = {\n155:   valid: boolean;\n156:   stored: number | null;\n157:   current: number | null;\n158:   reason?: string;\n159:   warning?: string;\n160: };\n161: \n162: type StoredEmbeddingDimension = {\n163:   existing_db: boolean;\n164:   stored_dim: number | null;\n165:   source: 'vec_metadata' | 'active_embedder_profile' | 'startup_profile' | 'vec_memories' | null;\n166:   reason?: string;\n167: };\n168: \n169: function get_existing_embedding_dimension(\n170:   database: Database.Database,\n171:   options: { allowProfileFallback?: boolean } = {},\n172: ): StoredEmbeddingDimension {\n173:   const allowProfileFallback = options.allowProfileFallback !== false;\n174:   const schema_row = database.prepare(`\n175:     SELECT name FROM sqlite_master WHERE type='table' AND name='memory_index'\n176:   `).get();\n177: \n178:   if (!schema_row) {\n179:     return {\n180:       existing_db: false,\n181:       stored_dim: null,\n182:       source: null,\n183:       reason: 'No existing schema',\n184:     };\n185:   }\n186: \n187:   const attached = database.prepare('PRAGMA database_list').all() as Array<{ name?: string }>;\n188:   if (attached.some((entry) => entry.name === ACTIVE_VECTOR_SCHEMA)) {\n189:     const shard_metadata_table = database.prepare(`\n190:       SELECT name FROM ${ACTIVE_VECTOR_SCHEMA}.sqlite_master WHERE type='table' AND name='vec_metadata'\n191:     `).get();\n192: \n193:     if (shard_metadata_table) {\n194:       const stored_row = database.prepare(`\n195:         SELECT value FROM ${ACTIVE_VECTOR_SCHEMA}.vec_metadata WHERE key IN ('embedding_dim', 'dim')\n196:         ORDER BY CASE key WHEN 'embedding_dim' THEN 0 ELSE 1 END\n197:         LIMIT 1\n198:       `).get() as { value: string } | undefined;\n199: \n200:       if (stored_row) {\n201:         const stored_dim = parseInt(stored_row.value, 10);\n202:         if (Number.isFinite(stored_dim) && stored_dim > 0) {\n203:           return {\n204:             existing_db: true,\n205:             stored_dim,\n206:             source: 'vec_metadata',\n207:           };\n208:         }\n209:       }\n210:     }\n211:   }\n212: \n213:   const metadata_table = database.prepare(`\n214:     SELECT name FROM sqlite_master WHERE type='table' AND name='vec_metadata'\n215:   `).get();\n216: \n217:   if (metadata_table) {\n218:     const stored_row = database.prepare(`\n219:       SELECT key, value FROM vec_metadata WHERE key IN ('embedding_dim', 'dim', 'active_embedder_dim')\n220:       ORDER BY CASE key WHEN 'embedding_dim' THEN 0 WHEN 'dim' THEN 1 ELSE 2 END\n221:       LIMIT 1\n222:     `).get() as { key: string; value: string } | undefined;\n223: \n224:     if (stored_row) {\n225:       const stored_dim = parseInt(stored_row.value, 10);\n\n(Showing lines 1-225 of 1989. Use offset=226 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Store\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// SEARCH: VECTOR INDEX\n// TypeScript port of the vector index implementation.\n// DECAY STRATEGY: Search-time temporal decay uses an\n// FSRS-preferred strategy. Memories with FSRS review data (last_review\n// IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n// R(t) = (1 + 0.2346 * t / S)^(-0.5)\n// Memories without review data fall back to half-life exponential:\n// Weight * 0.5^(days / half_life_days)\n// This ensures backward compatibility while aligning reviewed\n// Memories with the canonical FSRS algorithm.\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Store\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// SEARCH: VECTOR INDEX\n// TypeScript port of the vector index implementation.\n// DECAY STRATEGY: Search-time temporal decay uses an\n// FSRS-preferred strategy. Memories with FSRS review data (last_review\n// IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n// R(t) = (1 + 0.2346 * t / S)^(-0.5)\n// Memories without review data fall back to half-life exponential:\n// Weight * 0.5^(days / half_life_days)\n// This ensures backward compatibility while aligning reviewed\n// Memories with the canonical FSRS algorithm.\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\n\nimport { getEmbeddingDimension } from '@spec-kit/shared/embeddings';\nimport {\n  EmbeddingProfile,\n} from '@spec-kit/shared/embeddings/profile';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings/factory';\n\nimport { resolveDatabasePaths, SERVER_DIR } from '../../core/config.js';\nimport { computeInterferenceScoresBatch } from '../scoring/interference-scoring.js';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport {\n  recordVectorShardProbeFailure,\n  recordVectorShardQuarantined,\n  recordVectorShardRebuildFailed,\n} from '../observability/retrieval-observability.js';\nimport { validateFilePath } from '../utils/path-security.js';\nimport {\n  get_error_code,\n  get_error_message,\n  parse_trigger_phrases,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  create_schema,\n  ensure_schema_version,\n} from './vector-index-schema.js';\nimport { migrateLegacySingleDbToShardSync } from './db-shard-migration.js';\nimport type { MemoryRow } from './vector-index-types.js';\n\ntype SearchWeightsConfig = {\n  maxTriggersPerMemory?: number;\n  smartRanking?: {\n    recencyWeight?: number;\n    accessWeight?: number;\n    relevanceWeight?: number;\n  };\n};\n\ntype RestoreJournalPhase = 'swap-pending' | 'swap-done';\n\ntype RestoreJournalFile = {\n  formatVersion: 1;\n  phase: RestoreJournalPhase;\n  createdAt: string;\n  checkpointName: string;\n  liveMainPath: string;\n  backupMainPath: string;\n  snapshotMainPath: string;\n  liveShardPath: string | null;\n  backupShardPath: string | null;\n  snapshotVecPath: string | null;\n  shouldRestoreVec: boolean;\n  liveShardPreexisted: boolean;\n};\n\ntype InitializeDbOptions = {\n  skipRestoreRecovery?: boolean;\n};\n\nconst RESTORE_JOURNAL_NAME = '.restore-journal.json';\nconst NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\n\nfunction loadSearchWeights(): SearchWeightsConfig {\n  // SERVER_DIR points to dist/ at runtime; configs/ lives at the package root (dist/..)\n  const candidates = [\n    path.join(SERVER_DIR, 'configs', 'search-weights.json'),\n    path.join(SERVER_DIR, '..', 'configs', 'search-weights.json'),\n  ];\n  for (const candidate of candidates) {\n    try {\n      return JSON.parse(fs.readFileSync(candidate, 'utf-8')) as SearchWeightsConfig;\n    } catch {\n      // Try next candidate\n    }\n  }\n  return {};\n}\n\nlet _search_weights: SearchWeightsConfig | null = null;\n\nfunction getSearchWeights(): SearchWeightsConfig {\n  if (_search_weights === null) {\n    _search_weights = loadSearchWeights();\n  }\n  return _search_weights;\n}\n\n/** Loaded search weight configuration for vector-index ranking (lazy-loaded). */\nexport const search_weights: SearchWeightsConfig = {\n  get maxTriggersPerMemory() {\n    return getSearchWeights().maxTriggersPerMemory;\n  },\n  get smartRanking() {\n    return getSearchWeights().smartRanking;\n  },\n};\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONFIGURATION — Embedding Dimension\n----------------------------------------------------------------*/\n\n/** Default embedding dimension used by the vector index. */\nexport const EMBEDDING_DIM = getEmbeddingDimension();\n\n/**\n * Gets the active embedding dimension for the current provider.\n * @returns The embedding dimension.\n */\nexport function get_embedding_dim(): number {\n  return getEmbeddingDimension();\n}\n\n/**\n * Waits for the embedding provider to report a stable dimension.\n * @param timeout_ms - The maximum time to wait in milliseconds.\n * @returns A promise that resolves to the confirmed embedding dimension.\n */\nexport async function get_confirmed_embedding_dimension(timeout_ms = 5000): Promise<number> {\n  const start = Date.now();\n  while (Date.now() - start < timeout_ms) {\n    const dim = get_embedding_dim();\n    if (Number.isFinite(dim) && dim > 0) {\n      return dim;\n    }\n    await new Promise(resolve => setTimeout(resolve, 100));\n  }\n  const fallbackDim = get_embedding_dim();\n  console.warn(`[vector-index] Using embedding dimension ${fallbackDim} after timeout`);\n  return fallbackDim;\n}\n\ntype EmbeddingDimensionValidation = {\n  valid: boolean;\n  stored: number | null;\n  current: number | null;\n  reason?: string;\n  warning?: string;\n};\n\ntype StoredEmbeddingDimension = {\n  existing_db: boolean;\n  stored_dim: number | null;\n  source: 'vec_metadata' | 'active_embedder_profile' | 'startup_profile' | 'vec_memories' | null;\n  reason?: string;\n};\n\nfunction get_existing_embedding_dimension(\n  database: Database.Database,\n  options: { allowProfileFallback?: boolean } = {},\n): StoredEmbeddingDimension {\n  const allowProfileFallback = options.allowProfileFallback !== false;\n  const schema_row = database.prepare(`\n    SELECT name FROM sqlite_master WHERE type='table' AND name='memory_index'\n  `).get();\n\n  if (!schema_row) {\n    return {\n      existing_db: false,\n      stored_dim: null,\n      source: null,\n      reason: 'No existing schema',\n    };\n  }\n\n  const attached = database.prepare('PRAGMA database_list').all() as Array<{ name?: string }>;\n  if (attached.some((entry) => entry.name === ACTIVE_VECTOR_SCHEMA)) {\n    const shard_metadata_table = database.prepare(`\n      SELECT name FROM ${ACTIVE_VECTOR_SCHEMA}.sqlite_master WHERE type='table' AND name='vec_metadata'\n    `).get();\n\n    if (shard_metadata_table) {\n      const stored_row = database.prepare(`\n        SELECT value FROM ${ACTIVE_VECTOR_SCHEMA}.vec_metadata WHERE key IN ('embedding_dim', 'dim')\n        ORDER BY CASE key WHEN 'embedding_dim' THEN 0 ELSE 1 END\n        LIMIT 1\n      `).get() as { value: string } | undefined;\n\n      if (stored_row) {\n        const stored_dim = parseInt(stored_row.value, 10);\n        if (Number.isFinite(stored_dim) && stored_dim > 0) {\n          return {\n            existing_db: true,\n            stored_dim,\n            source: 'vec_metadata',\n          };\n        }\n      }\n    }\n  }\n\n  const metadata_table = database.prepare(`\n    SELECT name FROM sqlite_master WHERE type='table' AND name='vec_metadata'\n  `).get();\n\n  if (metadata_table) {\n    const stored_row = database.prepare(`\n      SELECT key, value FROM vec_metadata WHERE key IN ('embedding_dim', 'dim', 'active_embedder_dim')\n      ORDER BY CASE key WHEN 'embedding_dim' THEN 0 WHEN 'dim' THEN 1 ELSE 2 END\n      LIMIT 1\n    `).get() as { key: string; value: string } | undefined;\n\n    if (stored_row) {\n      const stored_dim = parseInt(stored_row.value, 10);","lineStart":1,"lineEnd":225,"totalLines":1989,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","time":{"