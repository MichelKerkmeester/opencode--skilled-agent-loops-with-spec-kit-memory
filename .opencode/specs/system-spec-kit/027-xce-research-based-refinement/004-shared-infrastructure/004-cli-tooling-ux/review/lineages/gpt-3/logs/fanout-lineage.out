n44:   \"keywords\": [\n45:     \"mcp\",\n46:     \"claude\",\n47:     \"semantic-memory\",\n48:     \"vector-search\",\n49:     \"auto-indexing\"\n50:   ],\n\n(Showing lines 1-50 of 81. Use offset=51 to continue.)\n</content>","metadata":{"preview":"{\n  \"name\": \"@spec-kit/mcp-server\",\n  \"version\": \"1.8.0\",\n  \"description\": \"Semantic Memory MCP Server - provides 37 tools for semantic search, memory management, validation, embedder control, checkpoints, causal graphs, session learning, and auto-indexing\",\n  \"type\": \"module\",\n  \"main\": \"dist/api/index.js\",\n  \"exports\": {\n    \".\": \"./dist/api/index.js\",\n    \"./server\": \"./dist/context-server.js\",\n    \"./api\": \"./dist/api/index.js\",\n    \"./api/*\": \"./dist/api/*.js\"\n  },\n  \"bin\": {\n    \"context-server\": \"./dist/context-server.js\",\n    \"spec-kit-cli\": \"./dist/cli.js\",\n    \"spec-memory\": \"./dist/spec-memory-cli.js\"\n  },\n  \"scripts\": {\n    \"clean\": \"node -e \\\"require('node:fs').rmSync('dist', { recursive: true, force: true })\\\"\",\n    \"build\": \"tsc --build && node scripts/finalize-dist.mjs\",","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/package.json","text":"{\n  \"name\": \"@spec-kit/mcp-server\",\n  \"version\": \"1.8.0\",\n  \"description\": \"Semantic Memory MCP Server - provides 37 tools for semantic search, memory management, validation, embedder control, checkpoints, causal graphs, session learning, and auto-indexing\",\n  \"type\": \"module\",\n  \"main\": \"dist/api/index.js\",\n  \"exports\": {\n    \".\": \"./dist/api/index.js\",\n    \"./server\": \"./dist/context-server.js\",\n    \"./api\": \"./dist/api/index.js\",\n    \"./api/*\": \"./dist/api/*.js\"\n  },\n  \"bin\": {\n    \"context-server\": \"./dist/context-server.js\",\n    \"spec-kit-cli\": \"./dist/cli.js\",\n    \"spec-memory\": \"./dist/spec-