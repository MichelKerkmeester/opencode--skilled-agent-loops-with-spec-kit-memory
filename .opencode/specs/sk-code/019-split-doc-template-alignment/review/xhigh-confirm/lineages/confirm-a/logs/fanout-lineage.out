tionFailure[] {\n1134:   const failures: V2ValidationFailure[] = [];\n1135:   const applicability = record.reviewDepthApplicability;\n1136:   const targetSelection = record.targetSelection;\n1137:   const searchCoverage = record.searchCoverage;\n1138: \n1139:   if (!isObjectRecord(applicability)) {\n1140:     failures.push(v2Failure('jsonl_missing_fields', 'reviewDepthApplicability must be an object', 'reviewDepthApplicability'));\n1141:   } else {\n1142:     if (!V2_SCOPE_CLASSES.has(String(applicability.scopeClass))) {\n1143:       failures.push(v2Failure('jsonl_missing_fields', 'reviewDepthApplicability.scopeClass must be trivial, standard, or complex', 'reviewDepthApplicability.scopeClass'));\n1144:     }\n1145:     if (!V2_ENFORCEMENT_MODES.has(String(applicability.enforcement))) {\n1146:       failures.push(v2Failure('jsonl_missing_fields', 'reviewDepthApplicability.enforcement must be strict, warn, or skip', 'reviewDepthApplicability.enforcement'));\n1147:     }\n1148:   }\n1149: \n1150:   if (!isObjectRecord(targetSelection)) {\n1151:     failures.push(v2Failure('jsonl_missing_fields', 'targetSelection must be an object', 'targetSelection'));\n1152:   } else {\n1153:     if (!Array.isArray(targetSelection.selectedTargets)) {\n1154:       failures.push(v2Failure('jsonl_missing_fields', 'targetSelection.selectedTargets must be an array', 'targetSelection.selectedTargets'));\n1155:     }\n1156:     if (!Array.isArray(targetSelection.discoveryMethods)) {\n1157:       failures.push(v2Failure('jsonl_missing_fields', 'targetSelection.discoveryMethods must be an array', 'targetSelection.discoveryMethods'));\n1158:     }\n1159:   }\n1160: \n1161:   if (!isObjectRecord(searchCoverage)) {\n1162:     failures.push(v2Failure('jsonl_missing_fields', 'searchCoverage must be an object', 'searchCoverage'));\n1163:   } else {\n1164:     if (!V2_GRAPH_COVERAGE_MODES.has(String(searchCoverage.graphCoverageMode))) {\n1165:       failures.push(v2Failure('jsonl_missing_fields', 's