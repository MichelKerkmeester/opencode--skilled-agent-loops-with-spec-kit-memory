  "font": {
    "die-grotesk-b": {
      "$value": "Die Grotesk B",
      "$type": "fontFamily",
      "$description": "Primary workhorse grotesque used for body text, mid-scale headings, labels, captions, and links. Weight 500 across all sizes creates a uniform visual density — no weight contrast, hierarchy comes purely from size and color. Tighter letter-spacing at larger sizes (-0.03em at 60px) tightens the grotesque into near-condensed proportions."
    },
    "abc-gravity-variable": {
      "$value": "ABC Gravity Variable",
      "$type": "fontFamily",
      "$description": "Monument-scale super-condensed display face. Used only for hero statements and section openers that fill the viewport. The extremely tight line-height (0.74) lets massive 288px letters stack with minimal vertical air — letters physically touch or nearly touch, creating a wall of type. Variable weight axis allows subtle weight shifts even at this scale."
    },
    "ibm-plex-mono": {
      "$value": "IBM Plex Mono",
      "$type": "fontFamily",
      "$description": "Technical voice for metadata, timestamps, nav labels, status text, and icon-adjacent micro-copy. Always uppercase, always small (12–14px). The monospaced rhythm signals 'system data' and contrasts against the grotesque's proportional flow — it reads as a developer/designer interface layer over the editorial body."
    }
  },
