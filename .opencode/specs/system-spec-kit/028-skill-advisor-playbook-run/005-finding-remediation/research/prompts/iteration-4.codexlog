   183	function withTimeout(operation, timeoutMs, label) {
   184	  let timeout;
   185	  return new Promise((resolve, reject) => {
   186	    timeout = setTimeout(() => {
   187	      reject(Object.assign(new Error(`${label} timed out after ${timeoutMs}ms`), { code: 'ADVISOR_MCP_TIMEOUT' }));
   188	    }, timeoutMs);
   189	    timeout.unref?.();
   190	    operation.then(
   191	      (value) => {
   192	        if (timeout) clearTimeout(timeout);
   193	        resolve(value);
   194	      },
   195	      (error) => {
   196	        if (timeout) clearTimeout(timeout);
   197	        reject(error);
   198	      },
   199	    );
   200	  });
   201	}
