{"type":"tool_use","timestamp":1783921197656,"sessionID":"ses_0a6050605ffekKPL0ZIbz84Q5J","part":{"type":"tool","tool":"read","callID":"call_8HgJmZKfU9e39Npso3swwOmx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":900,"limit":650},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n900:   }\n901: \n902:   const normalized = normalizeWaitCheckpoint(raw, context);\n903:   if (normalized.migrated) {\n904:     atomicWriteJson(checkpointPath, normalized.checkpoint);\n905:   }\n906:   return { exists: true, ...normalized };\n907: }\n908: \n909: function sleepWaitChunk(ms) {\n910:   return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n911: }\n912: \n913: async function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n914:   const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n915:   let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n916: \n917:   while (remainingDelayMs > 0) {\n918:     atomicWriteJson(checkpointPath, {\n919:       ...checkpoint,\n920:       remainingDelayMs,\n921:       updatedAt: new Date().toISOString(),\n922:     });\n923:     await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n924:     remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n925:   }\n926: \n927:   atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n928: }\n929: \n930: async function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n931:   const context = { runId, loopType, specFolder, nowMs: Date.now() };\n932:   const loaded = readWaitCheckpoint(checkpointPath, context);\n933:   if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n934:     return { didWait: false, migrated: loaded.migrated };\n935:   }\n936: \n937:   appendFanoutStatusLedger(ledgerPath, {\n938:     event: 'resume_waiting',\n939:     at: new Date().toISOString(),\n940:     run_id: runId,\n941:     loop_type: loopType,\n942:     spec_folder: specFolder,\n943:     nextRunAt: loaded.checkpoint.nextRunAt,\n944:     remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n945:   });\n946: \n947:   await waitUntilCheckpointExpires({\n948:     checkpointPath,\n949:     checkpoint: loaded.checkpoint,\n950:     context: { runId, loopType, specFolder },\n951:   });\n952: \n953:   appendFanoutStatusLedger(ledgerPath, {\n954:     event: 'resume_waiting_complete',\n955:     at: new Date().toISOString(),\n956:     run_id: runId,\n957:     loop_type: loopType,\n958:     spec_folder: specFolder,\n959:   });\n960: \n961:   return { didWait: true, migrated: loaded.migrated };\n962: }\n963: \n964: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n965:   const durationMs = normalizeWaitDurationMs(waitMs);\n966:   if (durationMs <= 0) {\n967:     return { didWait: false };\n968:   }\n969: \n970:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n971:   atomicWriteJson(checkpointPath, checkpoint);\n972:   appendFanoutStatusLedger(ledgerPath, {\n973:     event: 'wait_checkpoint_persisted',\n974:     at: checkpoint.updatedAt,\n975:     run_id: runId,\n976:     loop_type: loopType,\n977:     spec_folder: specFolder,\n978:     nextRunAt: checkpoint.nextRunAt,\n979:     remainingDelayMs: checkpoint.remainingDelayMs,\n980:   });\n981: \n982:   await waitUntilCheckpointExpires({\n983:     checkpointPath,\n984:     checkpoint,\n985:     context: { runId, loopType, specFolder },\n986:   });\n987: \n988:   appendFanoutStatusLedger(ledgerPath, {\n989:     event: 'wait_checkpoint_cleared',\n990:     at: new Date().toISOString(),\n991:     run_id: runId,\n992:     loop_type: loopType,\n993:     spec_folder: specFolder,\n994:   });\n995: \n996:   return { didWait: true };\n997: }\n998: \n999: /**\n1000:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n1001:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n1002:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n1003:  */\n1004: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n1005:   assertActiveFanoutLoopType(loopType);\n1006:   const skillFile =\n1007:     loopType === 'review'\n1008:       ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n1009:       : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n1010:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n1011:   const detachedIntro = lineage.kind === 'cli-opencode'\n1012:     ? [\n1013:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n1014:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n1015:         ``,\n1016:       ]\n1017:     : lineage.kind === 'native'\n1018:       ? [\n1019:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n1020:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n1021:           ``,\n1022:         ]\n1023:       : [];\n1024:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n1025:   const stopPolicy = options.stopPolicy || 'convergence';\n1026:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n1027:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n1028:     : hasIterationCap\n1029:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n1030:       : 'to legal convergence';\n1031:   const params = [\n1032:     `  spec_folder: ${specFolder}`,\n1033:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1034:     `  session_id: ${sessionId}`,\n1035:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n1036:     `  loop_type: ${loopType}`,\n1037:     `  config.stopPolicy: ${stopPolicy}`,\n1038:   ];\n1039:   if (researchTopic) {\n1040:     // A research lineage's phase_init binds research_topic from this line. Without it a\n1041:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n1042:     // Review loops scope by spec_folder and intentionally pass no topic.\n1043:     params.push(`  research_topic: ${researchTopic}`);\n1044:   }\n1045:   if (hasIterationCap) {\n1046:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n1047:   }\n1048:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n1049:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n1050:   }\n1051:   // Review lineages scope by spec_folder but the auto-workflow preflight\n1052:   // still requires the same review setup bindings the native command path pre-binds.\n1053:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n1054:   // different setup contract than native lineages.\n1055:   const setupBindings =\n1056:     loopType === 'review'\n1057:       ? [\n1058:           ``,\n1059:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n1060:           `review_target: ${specFolder}`,\n1061:           `review_target_type: spec-folder`,\n1062:           `review_dimensions: all`,\n1063:           `spec_folder: ${specFolder}`,\n1064:           `execution_mode: AUTONOMOUS`,\n1065:           `lineage_mode: auto`,\n1066:           ``,\n1067:         ]\n1068:       : [];\n1069:   return [\n1070:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1071:     ...detachedIntro,\n1072:     ``,\n1073:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1074:     ...params,\n1075:     ...setupBindings,\n1076:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1077:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1078:     `command; bind artifact_dir directly to the override value.`,\n1079:     ``,\n1080:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1081:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1082:     ``,\n1083:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1084:   ].join('\\n');\n1085: }\n1086: \n1087: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1088:   assertActiveFanoutLoopType(loopType);\n1089:   const maxIterations = lineage.iterations || 12;\n1090:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1091:   const stopPolicy = options.stopPolicy || 'convergence';\n1092:   const sessionId = options.sessionId || '';\n1093:   const args = [\n1094:     ':auto',\n1095:     JSON.stringify(specFolder),\n1096:     `--spec-folder=${specFolder}`,\n1097:     `--max-iterations=${maxIterations}`,\n1098:     `--convergence=${convergenceThreshold}`,\n1099:     `--stop-policy=${stopPolicy}`,\n1100:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1101:     '--lineage-mode=auto',\n1102:   ];\n1103:   if (loopType === 'research' && options.researchTopic) {\n1104:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1105:   }\n1106: \n1107:   return [\n1108:     args.join(' '),\n1109:     '',\n1110:     'PRE-BOUND SETUP ANSWERS:',\n1111:     `review_target: ${specFolder}`,\n1112:     'review_target_type: spec-folder',\n1113:     'review_dimensions: all',\n1114:     `spec_folder: ${specFolder}`,\n1115:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1116:     'execution_mode: AUTONOMOUS',\n1117:     'lineage_mode: auto',\n1118:     `maxIterations: ${maxIterations}`,\n1119:     `convergenceThreshold: ${convergenceThreshold}`,\n1120:     `stop_policy: ${stopPolicy}`,\n1121:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1122:   ].join('\\n');\n1123: }\n1124: \n1125: // Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n1126: // ceiling and a positive override may only narrow it, never widen past it.\n1127: const LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n1128: \n1129: function assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n1130:   if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n1131:     throw inputError(\n1132:       `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n1133:         + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n1134:     );\n1135:   }\n1136: }\n1137: \n1138: /**\n1139:  * Compute a generous timeout for a full lineage loop run.\n1140:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1141:  * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n1142:  * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n1143:  */\n1144: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1145:   assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n1146:   const iters = lineage.iterations || 12;\n1147:   const perIterSecs = lineage.timeoutSeconds || 900;\n1148:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1149:     ? ceilingHoursOverride * 60 * 60 * 1000\n1150:     : LINEAGE_LIFETIME_HARD_MAX_HOURS * 60 * 60 * 1000;\n1151:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1152: }\n1153: \n1154: function normalizeProgressHeartbeatMs(seconds) {\n1155:   const value = Number(seconds);\n1156:   if (!Number.isFinite(value) || value <= 0) return 0;\n1157:   return Math.max(1, Math.floor(value * 1000));\n1158: }\n1159: \n1160: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1161:   const explicit = readRawConfigNumber(rawConfig, [\n1162:     'postExitGraceMs',\n1163:     'post_exit_grace_ms',\n1164:     'postSubprocessExitGraceMs',\n1165:     'post_subprocess_exit_grace_ms',\n1166:     'orchestratorPostExitGraceMs',\n1167:     'orchestrator_post_exit_grace_ms',\n1168:   ], 'postExitGraceMs');\n1169:   if (explicit !== null) return explicit;\n1170: \n1171:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1172:     ? progressHeartbeatMs * 2\n1173:     : 0;\n1174:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1175: }\n1176: \n1177: function slotDurationMsFromHrtime(hrStart) {\n1178:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1179:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1180: }\n1181: \n1182: function computeSkippedCount(slotDurationMs, intervalMs) {\n1183:   const elapsed = Number(slotDurationMs);\n1184:   const interval = Number(intervalMs);\n1185:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1186:     return 0;\n1187:   }\n1188:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1189: }\n1190: \n1191: function buildSlotAccounting(hrStart, intervalMs) {\n1192:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1193:   return {\n1194:     slotDurationMs,\n1195:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1196:   };\n1197: }\n1198: \n1199: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1200:   if (!event || typeof event.label !== 'string') return event;\n1201:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1202: \n1203:   const accounting = accountingByLabel.get(event.label);\n1204:   if (!accounting) return event;\n1205:   return {\n1206:     ...event,\n1207:     skippedCount: accounting.skippedCount,\n1208:     slotDurationMs: accounting.slotDurationMs,\n1209:   };\n1210: }\n1211: \n1212: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1213:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1214:     return () => {};\n1215:   }\n1216:   const startedAtMs = Date.now();\n1217:   const timer = setInterval(() => {\n1218:     appendFanoutStatusLedger(ledgerPath, {\n1219:       event: 'progress',\n1220:       label,\n1221:       at: new Date().toISOString(),\n1222:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1223:         gauges: getGauges(),\n1224:       });\n1225:       if (typeof onProgress === 'function') onProgress();\n1226:     }, cadenceMs);\n1227:   timer.unref?.();\n1228:   return () => clearInterval(timer);\n1229: }\n1230: \n1231: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1232:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1233:     return () => {};\n1234:   }\n1235: \n1236:   let timer = null;\n1237:   let fired = false;\n1238:   const schedule = () => {\n1239:     if (fired) return;\n1240:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1241:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1242:     timer = setTimeout(() => {\n1243:       timer = null;\n1244:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1245:       if (latestQuietMs >= thresholdMs) {\n1246:         fired = true;\n1247:         appendFanoutStatusLedger(ledgerPath, {\n1248:           event: 'stall_detected',\n1249:           label,\n1250:           at: new Date().toISOString(),\n1251:           severity: 'warning',\n1252:           metric: 'time_since_last_lineage_event',\n1253:           stall_watchdog_ms: thresholdMs,\n1254:           quiet_ms: Math.floor(latestQuietMs),\n1255:           gauges: getGauges(),\n1256:         });\n1257:         return;\n1258:       }\n1259:       schedule();\n1260:     }, delayMs);\n1261:     timer.unref?.();\n1262:   };\n1263: \n1264:   schedule();\n1265:   return () => {\n1266:     fired = true;\n1267:     if (timer) clearTimeout(timer);\n1268:   };\n1269: }\n1270: \n1271: /**\n1272:  * Run a lineage subprocess without blocking the Node event loop.\n1273:  *\n1274:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1275:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1276:  * thread until each child exited, serializing every lineage regardless of the\n1277:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1278:  *\n1279:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1280:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1281:  *\n1282:  * @param {string} command - Executable to run.\n1283:  * @param {string[]} cmdArgs - Arguments for the executable.\n1284:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1285:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1286:  */\n1287: function runLineageProcess(command, cmdArgs, opts) {\n1288:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1289:   const hasInput = typeof opts.input === 'string';\n1290: \n1291:   return new Promise((resolvePromise) => {\n1292:     let child;\n1293:     try {\n1294:       child = spawn(command, cmdArgs, {\n1295:         cwd,\n1296:         env,\n1297:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1298:         detached: process.platform !== 'win32',\n1299:       });\n1300:     } catch (error) {\n1301:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1302:       return;\n1303:     }\n1304:     activeLineageProcesses.add(child);\n1305:     if (typeof opts.onSpawn === 'function') {\n1306:       opts.onSpawn({ pid: child.pid });\n1307:     }\n1308: \n1309:     let stdout = '';\n1310:     let stdoutBytes = 0;\n1311:     let truncated = false;\n1312:     let timedOut = false;\n1313:     let settled = false;\n1314:     let spawnError;\n1315: \n1316:     const timer = setTimeout(() => {\n1317:       timedOut = true;\n1318:       terminateLineageProcess(child, 'SIGTERM');\n1319:     }, timeoutMs);\n1320:     timer.unref?.();\n1321: \n1322:     const abortHandler = () => {\n1323:       terminateLineageProcess(child, 'SIGTERM');\n1324:     };\n1325:     if (opts.abortSignal) {\n1326:       if (opts.abortSignal.aborted) {\n1327:         abortHandler();\n1328:       } else {\n1329:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1330:       }\n1331:     }\n1332: \n1333:     child.stdout?.setEncoding('utf8');\n1334:     child.stdout?.on('data', (chunk) => {\n1335:       if (typeof opts.onOutput === 'function') opts.onOutput();\n1336:       if (truncated) return;\n1337:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1338:       if (stdoutBytes > maxBuffer) {\n1339:         truncated = true;\n1340:         terminateLineageProcess(child, 'SIGTERM');\n1341:         return;\n1342:       }\n1343:       stdout += chunk;\n1344:     });\n1345:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1346:     child.stderr?.resume();\n1347: \n1348:     child.on('error', (error) => {\n1349:       spawnError = error;\n1350:     });\n1351: \n1352:     child.on('close', (code, signal) => {\n1353:       if (settled) return;\n1354:       settled = true;\n1355:       activeLineageProcesses.delete(child);\n1356:       clearTimeout(timer);\n1357:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1358:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1359:       if (typeof opts.onExit === 'function') {\n1360:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1361:       }\n1362:       resolvePromise({\n1363:         status: timedOut ? null : code,\n1364:         signal: effectiveSignal,\n1365:         stdout,\n1366:         ...(spawnError ? { error: spawnError } : {}),\n1367:       });\n1368:     });\n1369: \n1370:     if (hasInput) {\n1371:       child.stdin?.on('error', () => {});\n1372:       child.stdin?.end(opts.input);\n1373:     }\n1374:   });\n1375: }\n1376: \n1377: /**\n1378:  * Build the subprocess command for a fan-out lineage.\n1379:  * Returns { command, args, input?, env } where input is stdin content when applicable.\n1380:  */\n1381: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n1382:   const kind = lineage.kind;\n1383: \n1384:   if (kind === 'cli-claude-code') {\n1385:     const args = [\n1386:       '-p',\n1387:       prompt,\n1388:       '--model',\n1389:       lineage.model || 'claude-opus-4-8',\n1390:       '--permission-mode',\n1391:       resolvedPermission,\n1392:       '--output-format',\n1393:       'text',\n1394:     ];\n1395:     if (lineage.reasoningEffort) {\n1396:       args.push('--effort', lineage.reasoningEffort);\n1397:     }\n1398:     return { command: 'claude', args };\n1399:   }\n1400: \n1401:   if (kind === 'native') {\n1402:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n1403:     // For review runs this is the real deep/review command surface with a lineage\n1404:     // artifact override, so the command YAML owns init, loop, and synthesis.\n1405:     const args = [\n1406:       'run',\n1407:       '--format',\n1408:       'json',\n1409:       '--dangerously-skip-permissions',\n1410:       '--dir',\n1411:       process.cwd(),\n1412:       '--command',\n1413:       `deep/${options.loopType || 'review'}`,\n1414:     ];\n1415:     args.push(buildNativeCommandInput(\n1416:       options.loopType || 'review',\n1417:       options.specFolder || '',\n1418:       options.lineageDir || '',\n1419:       lineage,\n1420:       options,\n1421:     ));\n1422:     return { command: 'opencode', args, input: '' };\n1423:   }\n1424: \n1425:   if (kind === 'cli-opencode') {\n1426:     // No --agent: current opencode treats `general` as a subagent and rejects it\n1427:     // on a top-level `run`. The default agent runs when none is named, and a\n1428:     // specific agent profile can be requested in the prompt body instead.\n1429:     const args = [\n1430:       'run',\n1431:       '--model',\n1432:       lineage.model || 'anthropic/claude-opus-4-8',\n1433:       '--format',\n1434:       'json',\n1435:       '--pure',\n1436:       '--dir',\n1437:       process.cwd(),\n1438:     ];\n1439:     // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n1440:     // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n1441:     // --dangerously-skip-permissions so their writes are subject to the CLI permission\n1442:     // boundary. opencode has no path-scoped write flag, so a workspace-write review\n1443:     // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n1444:     // must now opt into full bypass rather than getting it silently by default.\n1445:     const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n1446:     if (useDangerousBypass) {\n1447:       args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n1448:       process.stderr.write(\n1449:         `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n1450:           + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n1451:       );\n1452:     }\n1453:     if (lineage.reasoningEffort) {\n1454:       args.push('--variant', lineage.reasoningEffort);\n1455:     }\n1456:     args.push(prompt);\n1457:     return { command: 'opencode', args, input: '' };\n1458:   }\n1459: \n1460:   throw inputError(`Unknown fan-out executor kind: ${kind}`);\n1461: }\n1462: \n1463: // ─────────────────────────────────────────────────────────────────────────────\n1464: // 4. CORE LOGIC\n1465: // ─────────────────────────────────────────────────────────────────────────────\n1466: \n1467: async function main() {\n1468:   const args = parseArgs();\n1469:   const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n1470:   const loopType = ensureString(args, 'loopType');\n1471:   assertActiveFanoutLoopType(loopType);\n1472:   // Optional shared research question, threaded into each lineage prompt so a research\n1473:   // fan-out can bind research_topic. Absent for review, which scopes by folder.\n1474:   const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n1475:     ? args.researchTopic.trim()\n1476:     : null;\n1477:   const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n1478:   const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n1479:   const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n1480:   const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n1481:   assertLineageTimeoutHoursOverrideWithinCeiling(lineageTimeoutHoursOverride);\n1482:   const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n1483: \n1484:   const {\n1485:     parseFanoutConfig,\n1486:     expandLineages,\n1487:     resolveSandboxMode,\n1488:     resolveClaudePermissionMode,\n1489:   } = await import('../lib/deep-loop/executor-config.ts');\n1490:   const { buildExecutorDispatchEnv, detectSame