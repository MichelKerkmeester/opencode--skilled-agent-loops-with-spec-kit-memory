pescript verification\", \"opencode\", \"system code\", \"system-code\", \"mcp\"]\n    },\n    \"code-opencode-runtime\": {\n      \"keywords\": [\"typescript\", \"python\", \"shell\", \"json\", \"jsonc\", \"config\"]\n    },\n    \"code-opencode-authoring\": {\n      \"keywords\": [\"skill authoring\", \"agent authoring\", \"command authoring\", \"mcp server authoring\"]\n    }\n  }\n}","lineStart":1,"lineEnd":76,"totalLines":76,"truncated":false}},"title":".opencode/skills/sk-code/hub-router.json","time":{"start":1783437244195,"end":1783437244204}},"metadata":{"openai":{"itemId":"fc_0076295aaea6008d016a4d17bc06688191ac69905576996da7"}},"id":"prt_f3d24b721001rsQPnU5Ck5ZmJX","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d248d2f001CSnH4zt1csBz6w"}}
