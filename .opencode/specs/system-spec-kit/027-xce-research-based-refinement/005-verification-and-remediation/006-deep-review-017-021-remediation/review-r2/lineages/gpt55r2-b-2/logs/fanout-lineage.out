{"type":"tool_use","timestamp":1781761555285,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_Huh4KTGqSiG3zUu4IiH1rc2B","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":1,"limit":340},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep\n3: // ───────────────────────────────────────────────────────────────\n4: // Enforces governed memory_index.delete_after metadata.\n5: import * as vectorIndex from '../search/vector-index.js';\n6: import * as mutationLedger from '../storage/mutation-ledger.js';\n7: import { init as initHistory, recordHistory } from '../storage/history.js';\n8: import { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\n9: import { recordGovernanceAudit } from './scope-governance.js';\n10: import { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\n11: import type { AggregatedSignal } from '../feedback/batch-learning.js';\n12: import {\n13:   evaluateFeedbackRetention,\n14:   isFeedbackRetentionLearningEnabled,\n15:   recordFeedbackRetentionAudit,\n16:   resolveFeedbackRetentionMode,\n17: } from '../feedback/feedback-retention-reducer.js';\n18: import type {\n19:   FeedbackRetentionDecisionResult,\n20:   FeedbackRetentionMode,\n21: } from '../feedback/feedback-retention-reducer.js';\n22: \n23: import type Database from 'better-sqlite3';\n24: \n25: /** Options for a governed memory retention sweep. */\n26: export interface MemoryRetentionSweepArgs {\n27:   dryRun?: boolean;\n28:   feedbackRetention?: FeedbackRetentionSweepArgs;\n29: }\n30: \n31: /** Options for the feedback-aware retention learning branch. */\n32: export interface FeedbackRetentionSweepArgs {\n33:   runAt?: number;\n34:   windowMs?: number;\n35:   extendDays?: number;\n36:   shadowEvaluationPassed?: boolean;\n37:   signals?: AggregatedSignal[];\n38: }\n39: \n40: /**\n41:  * Expired memory_index row selected for retention deletion.\n42:  *\n43:  * Beyond `delete_after`, the row carries tier and usage metadata so the\n44:  * destructive delete decision can protect high-tier and pinned records:\n45:  * deletion must never be driven by TTL expiry alone.\n46:  */\n47: export interface RetentionExpiredRow {\n48:   id: number;\n49:   specFolder: string | null;\n50:   filePath: string | null;\n51:   contentHash: string | null;\n52:   tenantId: string | null;\n53:   userId: string | null;\n54:   agentId: string | null;\n55:   sessionId: string | null;\n56:   deleteAfter: string;\n57:   importanceTier: string | null;\n58:   decayHalfLifeDays: number | null;\n59:   isPinned: number | null;\n60:   accessCount: number | null;\n61:   lastAccessed: string | number | null;\n62:   deletedAt: string | null;\n63: }\n64: \n65: /** Aggregate sweep counts returned to callers and audit logs. */\n66: export interface MemoryRetentionSweepSummary {\n67:   swept: number;\n68:   retained: number;\n69:   protectedCount: number;\n70:   dryRun: boolean;\n71:   durationMs: number;\n72: }\n73: \n74: /** Full sweep result including candidates, deletions, and ledger state. */\n75: export interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n76:   candidates: RetentionExpiredRow[];\n77:   deletedIds: number[];\n78:   protectedIds: number[];\n79:   extendedIds?: number[];\n80:   ledgerRecorded: boolean | null;\n81:   feedbackRetention?: FeedbackRetentionSweepReport;\n82:   tombstoneState: {\n83:     usesPurgeablePartition: boolean;\n84:     usingPurgeableIndex: boolean;\n85:     candidateCount: number;\n86:     deletedCount: number;\n87:   };\n88:   edgeState: {\n89:     causalEdgesTablePresent: boolean;\n90:     candidateEdgeCount: number;\n91:   };\n92: }\n93: \n94: /** Feedback-retention learning summary included only when the feature is enabled. */\n95: export interface FeedbackRetentionSweepReport {\n96:   mode: FeedbackRetentionMode;\n97:   activeGatePassed: boolean;\n98:   activeBlocked: boolean;\n99:   auditCount: number;\n100:   decisions: FeedbackRetentionDecisionResult[];\n101:   extendedIds: number[];\n102:   protectedIds: number[];\n103:   deletedIds: number[];\n104: }\n105: \n106: function hasTable(database: Database.Database, tableName: string): boolean {\n107:   const row = database.prepare(\n108:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n109:   ).get(tableName) as { present?: number } | undefined;\n110:   return row?.present === 1;\n111: }\n112: \n113: function hasIndex(database: Database.Database, indexName: string): boolean {\n114:   const row = database.prepare(\n115:     \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n116:   ).get(indexName) as { present?: number } | undefined;\n117:   return row?.present === 1;\n118: }\n119: \n120: /**\n121:  * Tier/usage columns may be absent on legacy databases that predate the\n122:  * corresponding migrations. Missing columns are selected as NULL so the\n123:  * protection decision degrades conservatively instead of crashing the sweep.\n124:  */\n125: const OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n126:   { column: 'importance_tier', alias: 'importanceTier' },\n127:   { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n128:   { column: 'is_pinned', alias: 'isPinned' },\n129:   { column: 'access_count', alias: 'accessCount' },\n130:   { column: 'last_accessed', alias: 'lastAccessed' },\n131: ];\n132: \n133: function isSoftDeleteTombstonesEnabled(): boolean {\n134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n135: }\n136: \n137: function selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n138:   const presentColumns = new Set(\n139:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n140:       .map((row) => row.name),\n141:   );\n142:   const hasDeletedAt = presentColumns.has('deleted_at');\n143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n144:   const memoryIndexSource = usePurgeableIndex\n145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n146:     : 'memory_index';\n147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n149:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n150:     .map(({ column, alias }) => (presentColumns.has(column)\n151:       ? `${column} AS ${alias}`\n152:       : `NULL AS ${alias}`))\n153:     .join(',\\n      ');\n154: \n155:   return database.prepare(`\n156:     SELECT\n157:       id,\n158:       spec_folder AS specFolder,\n159:       file_path AS filePath,\n160:       content_hash AS contentHash,\n161:       tenant_id AS tenantId,\n162:       user_id AS userId,\n163:       agent_id AS agentId,\n164:       session_id AS sessionId,\n165:       delete_after AS deleteAfter,\n166:       ${deletedAtSelect},\n167:       ${optionalSelects}\n168:     FROM ${memoryIndexSource}\n169:     WHERE delete_after IS NOT NULL\n170:       ${tombstonePredicate}\n171:       AND datetime(delete_after) < datetime('now')\n172:     ORDER BY datetime(delete_after) ASC, id ASC\n173:   `).all() as RetentionExpiredRow[];\n174: }\n175: \n176: /** Importance tiers that must never be deleted on TTL expiry alone. */\n177: const PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n178: \n179: /**\n180:  * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n181:  * Constitutional/critical tiers and pinned rows are protected from TTL-only\n182:  * deletion; a null or unknown tier falls back to the pre-existing behavior\n183:  * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n184:  */\n185: function isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n186:   const tier = typeof row.importanceTier === 'string'\n187:     ? row.importanceTier.trim().toLowerCase()\n188:     : null;\n189:   if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n190:     return true;\n191:   }\n192:   return row.isPinned != null && Number(row.isPinned) !== 0;\n193: }\n194: \n195: // Re-validate inside the delete transaction: a concurrent writer can raise or\n196: // clear delete_after between candidate selection and deletion, so a row that is\n197: // no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\n198: function getCurrentExpiredRow(\n199:   database: Database.Database,\n200:   id: number,\n201:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n202: ): RetentionExpiredRow | null {\n203:   const presentColumns = new Set(\n204:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n205:       .map((row) => row.name),\n206:   );\n207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n209:   const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n210:     .map(({ column, alias }) => (presentColumns.has(column)\n211:       ? `${column} AS ${alias}`\n212:       : `NULL AS ${alias}`))\n213:     .join(',\\n      ');\n214:   const row = database.prepare(`\n215:     SELECT\n216:       id,\n217:       spec_folder AS specFolder,\n218:       file_path AS filePath,\n219:       content_hash AS contentHash,\n220:       tenant_id AS tenantId,\n221:       user_id AS userId,\n222:       agent_id AS agentId,\n223:       session_id AS sessionId,\n224:       delete_after AS deleteAfter,\n225:       ${deletedAtSelect},\n226:       ${optionalSelects}\n227:     FROM memory_index\n228:     WHERE id = ?\n229:       AND delete_after IS NOT NULL\n230:       ${tombstonePredicate}\n231:       AND datetime(delete_after) < datetime('now')\n232:     LIMIT 1\n233:   `).get(id) as RetentionExpiredRow | undefined;\n234:   return row ?? null;\n235: }\n236: \n237: function isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n238:   return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n239: }\n240: \n241: /** Test-only surface for the retention TOCTOU guard. */\n242: export const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n243: \n244: function countRows(database: Database.Database): number {\n245:   const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n246:   return row.count;\n247: }\n248: \n249: function buildTombstoneState(\n250:   database: Database.Database,\n251:   candidateCount: number,\n252:   deletedCount: number,\n253:   useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n254: ): MemoryRetentionSweepResult['tombstoneState'] {\n255:   const columns = new Set(\n256:     (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n257:       .map((row) => row.name),\n258:   );\n259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n260:   return {\n261:     usesPurgeablePartition,\n262:     usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n263:     candidateCount,\n264:     deletedCount,\n265:   };\n266: }\n267: \n268: function buildEdgeState(\n269:   database: Database.Database,\n270:   candidates: RetentionExpiredRow[],\n271: ): MemoryRetentionSweepResult['edgeState'] {\n272:   if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n273:     return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n274:   }\n275:   const ids = candidates.map((candidate) => String(candidate.id));\n276:   const placeholders = ids.map(() => '?').join(', ');\n277:   const row = database.prepare(`\n278:     SELECT COUNT(*) AS count\n279:     FROM causal_edges\n280:     WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n281:   `).get(...ids, ...ids) as { count: number };\n282:   return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n283: }\n284: \n285: function buildFeedbackRetentionReport(\n286:   database: Database.Database,\n287:   candidates: RetentionExpiredRow[],\n288:   dryRun: boolean,\n289:   args: FeedbackRetentionSweepArgs = {},\n290: ): FeedbackRetentionSweepReport {\n291:   const mode = resolveFeedbackRetentionMode();\n292:   const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n293:   // Dry-run previews must evaluate the SAME real signal window the apply\n294:   // path would see — aggregation is a pure read, and an empty-signal preview\n295:   // told operators nothing about what apply would actually do. The audit\n296:   // write path stays unreachable in dry-run (the sweep returns before it).\n297:   const signals = args.signals ?? aggregateEvents(\n298:     database,\n299:     (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n300:     args.runAt ?? Date.now(),\n301:   );\n302:   const evaluation = evaluateFeedbackRetention(candidates, signals, {\n303:     runAt: args.runAt,\n304:     extendDays: args.extendDays,\n305:   });\n306: \n307:   return {\n308:     mode,\n309:     activeGatePassed,\n310:     activeBlocked: mode === 'active' && !activeGatePassed,\n311:     auditCount: 0,\n312:     decisions: evaluation.decisions,\n313:     extendedIds: [],\n314:     protectedIds: evaluation.decisions\n315:       .filter((decision) => decision.decision === 'protect')\n316:       .map((decision) => decision.memoryId),\n317:     deletedIds: [],\n318:   };\n319: }\n320: \n321: function recordFeedbackRetentionAudits(\n322:   database: Database.Database,\n323:   candidates: RetentionExpiredRow[],\n324:   report: FeedbackRetentionSweepReport,\n325:   applied: boolean,\n326: ): number {\n327:   const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n328:   let auditCount = 0;\n329:   for (const decision of report.decisions) {\n330:     const row = rowsById.get(decision.memoryId);\n331:     if (!row) continue;\n332:     recordFeedbackRetentionAudit(database, row, decision, {\n333:       mode: report.mode,\n334:       applied,\n335:       activeGatePassed: report.activeGatePassed,\n336:     });\n337:     auditCount += 1;\n338:   }\n339:   return auditCount;\n340: }\n\n(Showing lines 1-340 of 650. Use offset=341 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep\n// ───────────────────────────────────────────────────────────────\n// Enforces governed memory_index.delete_after metadata.\nimport * as vectorIndex from '../search/vector-index.js';\nimport * as mutationLedger from '../storage/mutation-ledger.js';\nimport { init as initHistory, recordHistory } from '../storage/history.js';\nimport { BetterSqliteMaintenance, type MaintenanceOperation } from '../storage/ports/index.js';\nimport { recordGovernanceAudit } from './scope-governance.js';\nimport { aggregateEvents, BATCH_WINDOW_MS } from '../feedback/batch-learning.js';\nimport type { AggregatedSignal } from '../feedback/batch-learning.js';\nimport {\n  evaluateFeedbackRetention,\n  isFeedbackRetentionLearningEnabled,\n  recordFeedbackRetentionAudit,\n  resolveFeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\nimport type {\n  FeedbackRetentionDecisionResult,\n  FeedbackRetentionMode,\n} from '../feedback/feedback-retention-reducer.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Options for a governed memory retention sweep. */\nexport interface MemoryRetentionSweepArgs {\n  dryRun?: boolean;\n  feedbackRetention?: FeedbackRetentionSweepArgs;\n}\n\n/** Options for the feedback-aware retention learning branch. */\nexport interface FeedbackRetentionSweepArgs {\n  runAt?: number;\n  windowMs?: number;\n  extendDays?: number;\n  shadowEvaluationPassed?: boolean;\n  signals?: AggregatedSignal[];\n}\n\n/**\n * Expired memory_index row selected for retention deletion.\n *\n * Beyond `delete_after`, the row carries tier and usage metadata so the\n * destructive delete decision can protect high-tier and pinned records:\n * deletion must never be driven by TTL expiry alone.\n */\nexport interface RetentionExpiredRow {\n  id: number;\n  specFolder: string | null;\n  filePath: string | null;\n  contentHash: string | null;\n  tenantId: string | null;\n  userId: string | null;\n  agentId: string | null;\n  sessionId: string | null;\n  deleteAfter: string;\n  importanceTier: string | null;\n  decayHalfLifeDays: number | null;\n  isPinned: number | null;\n  accessCount: number | null;\n  lastAccessed: string | number | null;\n  deletedAt: string | null;\n}\n\n/** Aggregate sweep counts returned to callers and audit logs. */\nexport interface MemoryRetentionSweepSummary {\n  swept: number;\n  retained: number;\n  protectedCount: number;\n  dryRun: boolean;\n  durationMs: number;\n}\n\n/** Full sweep result including candidates, deletions, and ledger state. */\nexport interface MemoryRetentionSweepResult extends MemoryRetentionSweepSummary {\n  candidates: RetentionExpiredRow[];\n  deletedIds: number[];\n  protectedIds: number[];\n  extendedIds?: number[];\n  ledgerRecorded: boolean | null;\n  feedbackRetention?: FeedbackRetentionSweepReport;\n  tombstoneState: {\n    usesPurgeablePartition: boolean;\n    usingPurgeableIndex: boolean;\n    candidateCount: number;\n    deletedCount: number;\n  };\n  edgeState: {\n    causalEdgesTablePresent: boolean;\n    candidateEdgeCount: number;\n  };\n}\n\n/** Feedback-retention learning summary included only when the feature is enabled. */\nexport interface FeedbackRetentionSweepReport {\n  mode: FeedbackRetentionMode;\n  activeGatePassed: boolean;\n  activeBlocked: boolean;\n  auditCount: number;\n  decisions: FeedbackRetentionDecisionResult[];\n  extendedIds: number[];\n  protectedIds: number[];\n  deletedIds: number[];\n}\n\nfunction hasTable(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'table' AND name = ? LIMIT 1\"\n  ).get(tableName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction hasIndex(database: Database.Database, indexName: string): boolean {\n  const row = database.prepare(\n    \"SELECT 1 AS present FROM sqlite_master WHERE type = 'index' AND name = ? LIMIT 1\"\n  ).get(indexName) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\n/**\n * Tier/usage columns may be absent on legacy databases that predate the\n * corresponding migrations. Missing columns are selected as NULL so the\n * protection decision degrades conservatively instead of crashing the sweep.\n */\nconst OPTIONAL_RETENTION_COLUMNS: ReadonlyArray<{ column: string; alias: string }> = [\n  { column: 'importance_tier', alias: 'importanceTier' },\n  { column: 'decay_half_life_days', alias: 'decayHalfLifeDays' },\n  { column: 'is_pinned', alias: 'isPinned' },\n  { column: 'access_count', alias: 'accessCount' },\n  { column: 'last_accessed', alias: 'lastAccessed' },\n];\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction selectExpiredRows(database: Database.Database, useSoftDeleteTombstones: boolean): RetentionExpiredRow[] {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const hasDeletedAt = presentColumns.has('deleted_at');\n  const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n  const memoryIndexSource = usePurgeableIndex\n    ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n    : 'memory_index';\n  const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n\n  return database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM ${memoryIndexSource}\n    WHERE delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    ORDER BY datetime(delete_after) ASC, id ASC\n  `).all() as RetentionExpiredRow[];\n}\n\n/** Importance tiers that must never be deleted on TTL expiry alone. */\nconst PROTECTED_RETENTION_TIERS = new Set(['constitutional', 'critical']);\n\n/**\n * Tier-aware deletion decision evaluated BEFORE the destructive delete path.\n * Constitutional/critical tiers and pinned rows are protected from TTL-only\n * deletion; a null or unknown tier falls back to the pre-existing behavior\n * (unprotected rows keep deleting) so legacy rows are handled without crashes.\n */\nfunction isProtectedFromRetentionDelete(row: RetentionExpiredRow): boolean {\n  const tier = typeof row.importanceTier === 'string'\n    ? row.importanceTier.trim().toLowerCase()\n    : null;\n  if (tier !== null && PROTECTED_RETENTION_TIERS.has(tier)) {\n    return true;\n  }\n  return row.isPinned != null && Number(row.isPinned) !== 0;\n}\n\n// Re-validate inside the delete transaction: a concurrent writer can raise or\n// clear delete_after between candidate selection and deletion, so a row that is\n// no longer expired must not be swept. Mirrors the selectExpiredRows predicate.\nfunction getCurrentExpiredRow(\n  database: Database.Database,\n  id: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): RetentionExpiredRow | null {\n  const presentColumns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n  const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n  const optionalSelects = OPTIONAL_RETENTION_COLUMNS\n    .map(({ column, alias }) => (presentColumns.has(column)\n      ? `${column} AS ${alias}`\n      : `NULL AS ${alias}`))\n    .join(',\\n      ');\n  const row = database.prepare(`\n    SELECT\n      id,\n      spec_folder AS specFolder,\n      file_path AS filePath,\n      content_hash AS contentHash,\n      tenant_id AS tenantId,\n      user_id AS userId,\n      agent_id AS agentId,\n      session_id AS sessionId,\n      delete_after AS deleteAfter,\n      ${deletedAtSelect},\n      ${optionalSelects}\n    FROM memory_index\n    WHERE id = ?\n      AND delete_after IS NOT NULL\n      ${tombstonePredicate}\n      AND datetime(delete_after) < datetime('now')\n    LIMIT 1\n  `).get(id) as RetentionExpiredRow | undefined;\n  return row ?? null;\n}\n\nfunction isStillExpired(database: Database.Database, id: number, useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled()): boolean {\n  return getCurrentExpiredRow(database, id, useSoftDeleteTombstones) !== null;\n}\n\n/** Test-only surface for the retention TOCTOU guard. */\nexport const __retentionSweepTestables = { getCurrentExpiredRow, isStillExpired };\n\nfunction countRows(database: Database.Database): number {\n  const row = database.prepare('SELECT COUNT(*) AS count FROM memory_index').get() as { count: number };\n  return row.count;\n}\n\nfunction buildTombstoneState(\n  database: Database.Database,\n  candidateCount: number,\n  deletedCount: number,\n  useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled(),\n): MemoryRetentionSweepResult['tombstoneState'] {\n  const columns = new Set(\n    (database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>)\n      .map((row) => row.name),\n  );\n  const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n  return {\n    usesPurgeablePartition,\n    usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n    candidateCount,\n    deletedCount,\n  };\n}\n\nfunction buildEdgeState(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n): MemoryRetentionSweepResult['edgeState'] {\n  if (!hasTable(database, 'causal_edges') || candidates.length === 0) {\n    return { causalEdgesTablePresent: hasTable(database, 'causal_edges'), candidateEdgeCount: 0 };\n  }\n  const ids = candidates.map((candidate) => String(candidate.id));\n  const placeholders = ids.map(() => '?').join(', ');\n  const row = database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM causal_edges\n    WHERE source_id IN (${placeholders}) OR target_id IN (${placeholders})\n  `).get(...ids, ...ids) as { count: number };\n  return { causalEdgesTablePresent: true, candidateEdgeCount: row.count };\n}\n\nfunction buildFeedbackRetentionReport(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  dryRun: boolean,\n  args: FeedbackRetentionSweepArgs = {},\n): FeedbackRetentionSweepReport {\n  const mode = resolveFeedbackRetentionMode();\n  const activeGatePassed = mode === 'active' && args.shadowEvaluationPassed === true;\n  // Dry-run previews must evaluate the SAME real signal window the apply\n  // path would see — aggregation is a pure read, and an empty-signal preview\n  // told operators nothing about what apply would actually do. The audit\n  // write path stays unreachable in dry-run (the sweep returns before it).\n  const signals = args.signals ?? aggregateEvents(\n    database,\n    (args.runAt ?? Date.now()) - (args.windowMs ?? BATCH_WINDOW_MS),\n    args.runAt ?? Date.now(),\n  );\n  const evaluation = evaluateFeedbackRetention(candidates, signals, {\n    runAt: args.runAt,\n    extendDays: args.extendDays,\n  });\n\n  return {\n    mode,\n    activeGatePassed,\n    activeBlocked: mode === 'active' && !activeGatePassed,\n    auditCount: 0,\n    decisions: evaluation.decisions,\n    extendedIds: [],\n    protectedIds: evaluation.decisions\n      .filter((decision) => decision.decision === 'protect')\n      .map((decision) => decision.memoryId),\n    deletedIds: [],\n  };\n}\n\nfunction recordFeedbackRetentionAudits(\n  database: Database.Database,\n  candidates: RetentionExpiredRow[],\n  report: FeedbackRetentionSweepReport,\n  applied: boolean,\n): number {\n  const rowsById = new Map(candidates.map((candidate) => [candidate.id, candidate]));\n  let auditCount = 0;\n  for (const decision of report.decisions) {\n    const row = rowsById.get(decision.memoryId);\n    if (!row) continue;\n    recordFeedbackRetentionAudit(database, row, decision, {\n      mode: report.mode,\n      applied,\n      activeGatePassed: report.activeGatePassed,\n    });\n    auditCount += 1;\n  }\n  return auditCount;\n}","lineStart":1,"lineEnd":340,"totalLines":650,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781761555251,"end":1781761555273}},"metadata":{"openai":{"itemId":"fc_0379653e1361df95016a33861319d881919afd331d01125ad3"}},"id":"prt_ed943baee0017ocTx6eJkyuO8t","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed943870e001i5qJ98c8GRiSJs"}}
{"type":"tool_use","timestamp":1781761555354,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_UBLFEQOQTZQDhffngDoetduP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","offset":1,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Idempotency Receipts\n3: // ───────────────────────────────────────────────────────────────\n4: import { createHash } from 'node:crypto';\n5: import type BetterSqlite3 from 'better-sqlite3';\n6: \n7: import type { MCPResponse } from '../../handlers/types.js';\n8: \n9: export type IdempotencyOperation = 'memory_save' | 'memory_update';\n10: \n11: export interface IdempotencyReceiptInput {\n12:   operation: IdempotencyOperation;\n13:   contentHash: string | null;\n14:   requestFingerprint: Record<string, unknown>;\n15:   payload: Record<string, unknown>;\n16: }\n17: \n18: export interface IdempotencyReceiptKey {\n19:   operation: IdempotencyOperation;\n20:   receiptKey: string;\n21:   contentHash: string | null;\n22:   requestFingerprintHash: string;\n23:   payloadHash: string;\n24: }\n25: \n26: export type IdempotencyLookupResult =\n27:   | { status: 'miss'; key: IdempotencyReceiptKey }\n28:   | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n29:   | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n30: \n31: interface ReceiptRow {\n32:   payload_hash: string;\n33:   response_payload: string;\n34: }\n35: \n36: interface MemorySaveReceiptCandidate {\n37:   id?: unknown;\n38:   status?: unknown;\n39: }\n40: \n41: const RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n42: \n43: const CLIENT_TOKEN_KEYS = new Set([\n44:   'idempotencykey',\n45:   'idempotency_key',\n46:   'idempotencytoken',\n47:   'idempotency_token',\n48:   'clientidempotencykey',\n49:   'client_idempotency_key',\n50:   'clientidempotencytoken',\n51:   'client_idempotency_token',\n52: ]);\n53: \n54: export function isMemoryIdempotencyEnabled(): boolean {\n55:   const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n56:   return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n57: }\n58: \n59: function normalizeForHash(value: unknown): unknown {\n60:   if (Array.isArray(value)) {\n61:     return value.map(normalizeForHash);\n62:   }\n63:   if (!value || typeof value !== 'object') {\n64:     return value;\n65:   }\n66: \n67:   const record = value as Record<string, unknown>;\n68:   const normalized: Record<string, unknown> = {};\n69:   for (const key of Object.keys(record).sort()) {\n70:     if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n71:       continue;\n72:     }\n73:     const normalizedValue = normalizeForHash(record[key]);\n74:     if (normalizedValue !== undefined) {\n75:       normalized[key] = normalizedValue;\n76:     }\n77:   }\n78:   return normalized;\n79: }\n80: \n81: function hashJson(value: unknown): string {\n82:   return createHash('sha256')\n83:     .update(JSON.stringify(normalizeForHash(value)))\n84:     .digest('hex');\n85: }\n86: \n87: export function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n88:   const requestFingerprintHash = hashJson(input.requestFingerprint);\n89:   const payloadHash = hashJson(input.payload);\n90:   const material = {\n91:     operation: input.operation,\n92:     contentHash: input.contentHash ?? null,\n93:     requestFingerprintHash,\n94:   };\n95:   return {\n96:     operation: input.operation,\n97:     receiptKey: hashJson(material),\n98:     contentHash: input.contentHash ?? null,\n99:     requestFingerprintHash,\n100:     payloadHash,\n101:   };\n102: }\n103: \n104: export function shouldStoreMemorySaveReceipt(\n105:   result: MemorySaveReceiptCandidate,\n106:   response: MCPResponse,\n107: ): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n108:   return response.isError !== true\n109:     && typeof result.id === 'number'\n110:     && Number.isInteger(result.id)\n111:     && result.id > 0\n112:     && typeof result.status === 'string'\n113:     && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n114: }\n115: \n116: export function lookupIdempotencyReceipt(\n117:   database: BetterSqlite3.Database,\n118:   input: IdempotencyReceiptInput,\n119: ): IdempotencyLookupResult {\n120:   return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n121: }\n122: \n123: export function lookupIdempotencyReceiptByKey(\n124:   database: BetterSqlite3.Database,\n125:   key: IdempotencyReceiptKey,\n126: ): IdempotencyLookupResult {\n127:   const row = database.prepare(`\n128:     SELECT payload_hash, response_payload\n129:     FROM memory_idempotency_receipts\n130:     WHERE receipt_key = ?\n131:   `).get(key.receiptKey) as ReceiptRow | undefined;\n132: \n133:   if (!row) {\n134:     return { status: 'miss', key };\n135:   }\n136:   if (row.payload_hash !== key.payloadHash) {\n137:     return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n138:   }\n139:   return {\n140:     status: 'replay',\n141:     key,\n142:     response: JSON.parse(row.response_payload) as MCPResponse,\n143:   };\n144: }\n145: \n146: /**\n147:  * Drops the receipt for a key so a follow-up store writes fresh.\n148:  *\n149:  * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n150:  * not a durable record. When a replay is rejected because the live index no\n151:  * longer matches the receipt's content_hash (the logical path moved on and\n152:  * came back, so the cached response now carries a superseded memory id), the\n153:  * cache entry is stale: leaving it lets the post-write store lose the\n154:  * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n155:  * it first lets the re-indexed write store its current response and keeps the\n156:  * cache consistent with the active row. Best-effort: a delete failure must\n157:  * never block serving the live write.\n158:  */\n159: export function deleteIdempotencyReceiptByKey(\n160:   database: BetterSqlite3.Database,\n161:   key: IdempotencyReceiptKey,\n162: ): void {\n163:   try {\n164:     database.prepare(`\n165:       DELETE FROM memory_idempotency_receipts\n166:       WHERE receipt_key = ?\n167:     `).run(key.receiptKey);\n168:   } catch {\n169:     // Best-effort cache eviction; serving the live write takes priority.\n170:   }\n171: }\n172: \n173: export function storeIdempotencyReceipt(\n174:   database: BetterSqlite3.Database,\n175:   key: IdempotencyReceiptKey,\n176:   response: MCPResponse,\n177:   memoryId?: number | null,\n178: ): boolean {\n179:   const info = database.prepare(`\n180:     INSERT INTO memory_idempotency_receipts (\n181:       receipt_key,\n182:       operation,\n183:       content_hash,\n184:       request_fingerprint,\n185:       payload_hash,\n186:       response_payload,\n187:       memory_id,\n188:       updated_at\n189:     ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n190:     ON CONFLICT(receipt_key) DO NOTHING\n191:   `).run(\n192:     key.receiptKey,\n193:     key.operation,\n194:     key.contentHash,\n195:     key.requestFingerprintHash,\n196:     key.payloadHash,\n197:     JSON.stringify(response),\n198:     memoryId ?? null,\n199:   );\n200:   // changes === 0 means a concurrent caller already stored the canonical receipt\n201:   // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n202:   return info.changes > 0;\n203: }\n204: \n205: /**\n206:  * Marks a mutated loser's response with an explicit store-race conflict.\n207:  *\n208:  * When a writer loses the first-store race to a concurrent SAME-KEY,\n209:  * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n210:  * already landed (so an error response would lie), and the winner's stored\n211:  * response answers a different payload (so replaying it would lie too).\n212:  * Rolling the landed mutation back from this late window is the dangerous\n213:  * non-option. What remains is the loser's own response carrying a visible\n214:  * conflict block, so callers know the canonical receipt for this key\n215:  * belongs to a different concurrent request and a later retry may replay\n216:  * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n217:  * original response is returned unmodified.\n218:  */\n219: export function markResponseWithReceiptStoreConflict(\n220:   response: MCPResponse,\n221:   key: IdempotencyReceiptKey,\n222:   storedPayloadHash: string | undefined,\n223: ): MCPResponse {\n224:   const first = response.content?.[0];\n225:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n226:     return response;\n227:   }\n228:   try {\n229:     const envelope = JSON.parse(first.text) as Record<string, unknown>;\n230:     const data = (envelope.data && typeof envelope.data === 'object')\n231:       ? envelope.data as Record<string, unknown>\n232:       : {};\n233:     data.idempotencyStoreConflict = {\n234:       receiptKey: key.receiptKey,\n235:       payloadHash: key.payloadHash,\n236:       storedPayloadHash: storedPayloadHash ?? null,\n237:     };\n238:     envelope.data = data;\n239:     const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n240:     hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n241:     envelope.hints = hints;\n242:     return {\n243:       ...response,\n244:       content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n245:     };\n246:   } catch {\n247:     return response;\n248:   }\n249: }\n250: \n251: /**\n252:  * Deletes receipts older than the retention window. Receipts are replay\n253:  * caches, not durable records: unbounded growth plus indefinite stale\n254:  * replays (including against deleted memories) is the failure mode this\n255:  * sweep bounds. Best-effort by contract — callers must never let a sweep\n256:  * failure block serving.\n257:  */\n258: export function pruneExpiredIdempotencyReceipts(\n259:   database: BetterSqlite3.Database,\n260:   ttlDays?: number,\n261: ): number {\n262:   const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n263:   const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n264:   try {\n265:     // Prune on created_at: it is indexed and, since receipts are insert-only\n266:     // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at —\n267:     // so this is behaviorally identical but avoids a full table scan.\n268:     const info = database.prepare(`\n269:       DELETE FROM memory_idempotency_receipts\n270:       WHERE created_at < datetime('now', ?)\n271:     `).run(`-${days} days`);\n272:     return info.changes;\n273:   } catch {\n274:     return 0;\n275:   }\n276: }\n277: \n278: export function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n279:   const first = response.content?.[0];\n280:   if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n\n(Showing lines 1-280 of 290. Use offset=281 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Idempotency Receipts\n// ───────────────────────────────────────────────────────────────\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Idempotency Receipts\n// ───────────────────────────────────────────────────────────────\nimport { createHash } from 'node:crypto';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport type { MCPResponse } from '../../handlers/types.js';\n\nexport type IdempotencyOperation = 'memory_save' | 'memory_update';\n\nexport interface IdempotencyReceiptInput {\n  operation: IdempotencyOperation;\n  contentHash: string | null;\n  requestFingerprint: Record<string, unknown>;\n  payload: Record<string, unknown>;\n}\n\nexport interface IdempotencyReceiptKey {\n  operation: IdempotencyOperation;\n  receiptKey: string;\n  contentHash: string | null;\n  requestFingerprintHash: string;\n  payloadHash: string;\n}\n\nexport type IdempotencyLookupResult =\n  | { status: 'miss'; key: IdempotencyReceiptKey }\n  | { status: 'replay'; key: IdempotencyReceiptKey; response: MCPResponse }\n  | { status: 'conflict'; key: IdempotencyReceiptKey; storedPayloadHash: string };\n\ninterface ReceiptRow {\n  payload_hash: string;\n  response_payload: string;\n}\n\ninterface MemorySaveReceiptCandidate {\n  id?: unknown;\n  status?: unknown;\n}\n\nconst RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES = new Set(['indexed', 'updated', 'deferred']);\n\nconst CLIENT_TOKEN_KEYS = new Set([\n  'idempotencykey',\n  'idempotency_key',\n  'idempotencytoken',\n  'idempotency_token',\n  'clientidempotencykey',\n  'client_idempotency_key',\n  'clientidempotencytoken',\n  'client_idempotency_token',\n]);\n\nexport function isMemoryIdempotencyEnabled(): boolean {\n  const raw = process.env.SPECKIT_MEMORY_IDEMPOTENCY?.trim().toLowerCase();\n  return raw === '1' || raw === 'true' || raw === 'yes' || raw === 'on';\n}\n\nfunction normalizeForHash(value: unknown): unknown {\n  if (Array.isArray(value)) {\n    return value.map(normalizeForHash);\n  }\n  if (!value || typeof value !== 'object') {\n    return value;\n  }\n\n  const record = value as Record<string, unknown>;\n  const normalized: Record<string, unknown> = {};\n  for (const key of Object.keys(record).sort()) {\n    if (CLIENT_TOKEN_KEYS.has(key.toLowerCase())) {\n      continue;\n    }\n    const normalizedValue = normalizeForHash(record[key]);\n    if (normalizedValue !== undefined) {\n      normalized[key] = normalizedValue;\n    }\n  }\n  return normalized;\n}\n\nfunction hashJson(value: unknown): string {\n  return createHash('sha256')\n    .update(JSON.stringify(normalizeForHash(value)))\n    .digest('hex');\n}\n\nexport function deriveIdempotencyReceiptKey(input: IdempotencyReceiptInput): IdempotencyReceiptKey {\n  const requestFingerprintHash = hashJson(input.requestFingerprint);\n  const payloadHash = hashJson(input.payload);\n  const material = {\n    operation: input.operation,\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n  };\n  return {\n    operation: input.operation,\n    receiptKey: hashJson(material),\n    contentHash: input.contentHash ?? null,\n    requestFingerprintHash,\n    payloadHash,\n  };\n}\n\nexport function shouldStoreMemorySaveReceipt(\n  result: MemorySaveReceiptCandidate,\n  response: MCPResponse,\n): result is MemorySaveReceiptCandidate & { id: number; status: string } {\n  return response.isError !== true\n    && typeof result.id === 'number'\n    && Number.isInteger(result.id)\n    && result.id > 0\n    && typeof result.status === 'string'\n    && RECEIPT_WRITABLE_MEMORY_SAVE_STATUSES.has(result.status);\n}\n\nexport function lookupIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  input: IdempotencyReceiptInput,\n): IdempotencyLookupResult {\n  return lookupIdempotencyReceiptByKey(database, deriveIdempotencyReceiptKey(input));\n}\n\nexport function lookupIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): IdempotencyLookupResult {\n  const row = database.prepare(`\n    SELECT payload_hash, response_payload\n    FROM memory_idempotency_receipts\n    WHERE receipt_key = ?\n  `).get(key.receiptKey) as ReceiptRow | undefined;\n\n  if (!row) {\n    return { status: 'miss', key };\n  }\n  if (row.payload_hash !== key.payloadHash) {\n    return { status: 'conflict', key, storedPayloadHash: row.payload_hash };\n  }\n  return {\n    status: 'replay',\n    key,\n    response: JSON.parse(row.response_payload) as MCPResponse,\n  };\n}\n\n/**\n * Drops the receipt for a key so a follow-up store writes fresh.\n *\n * A receipt is a replay cache keyed on (operation, contentHash, fingerprint),\n * not a durable record. When a replay is rejected because the live index no\n * longer matches the receipt's content_hash (the logical path moved on and\n * came back, so the cached response now carries a superseded memory id), the\n * cache entry is stale: leaving it lets the post-write store lose the\n * ON CONFLICT DO NOTHING race and re-serve the superseded response. Clearing\n * it first lets the re-indexed write store its current response and keeps the\n * cache consistent with the active row. Best-effort: a delete failure must\n * never block serving the live write.\n */\nexport function deleteIdempotencyReceiptByKey(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n): void {\n  try {\n    database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE receipt_key = ?\n    `).run(key.receiptKey);\n  } catch {\n    // Best-effort cache eviction; serving the live write takes priority.\n  }\n}\n\nexport function storeIdempotencyReceipt(\n  database: BetterSqlite3.Database,\n  key: IdempotencyReceiptKey,\n  response: MCPResponse,\n  memoryId?: number | null,\n): boolean {\n  const info = database.prepare(`\n    INSERT INTO memory_idempotency_receipts (\n      receipt_key,\n      operation,\n      content_hash,\n      request_fingerprint,\n      payload_hash,\n      response_payload,\n      memory_id,\n      updated_at\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, datetime('now'))\n    ON CONFLICT(receipt_key) DO NOTHING\n  `).run(\n    key.receiptKey,\n    key.operation,\n    key.contentHash,\n    key.requestFingerprintHash,\n    key.payloadHash,\n    JSON.stringify(response),\n    memoryId ?? null,\n  );\n  // changes === 0 means a concurrent caller already stored the canonical receipt\n  // for this key (ON CONFLICT DO NOTHING), so this writer lost the first-write race.\n  return info.changes > 0;\n}\n\n/**\n * Marks a mutated loser's response with an explicit store-race conflict.\n *\n * When a writer loses the first-store race to a concurrent SAME-KEY,\n * DIFFERENT-PAYLOAD request, neither honest option is silent: its mutation\n * already landed (so an error response would lie), and the winner's stored\n * response answers a different payload (so replaying it would lie too).\n * Rolling the landed mutation back from this late window is the dangerous\n * non-option. What remains is the loser's own response carrying a visible\n * conflict block, so callers know the canonical receipt for this key\n * belongs to a different concurrent request and a later retry may replay\n * or conflict against it. Fail-open: if the envelope cannot be parsed, the\n * original response is returned unmodified.\n */\nexport function markResponseWithReceiptStoreConflict(\n  response: MCPResponse,\n  key: IdempotencyReceiptKey,\n  storedPayloadHash: string | undefined,\n): MCPResponse {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {\n    return response;\n  }\n  try {\n    const envelope = JSON.parse(first.text) as Record<string, unknown>;\n    const data = (envelope.data && typeof envelope.data === 'object')\n      ? envelope.data as Record<string, unknown>\n      : {};\n    data.idempotencyStoreConflict = {\n      receiptKey: key.receiptKey,\n      payloadHash: key.payloadHash,\n      storedPayloadHash: storedPayloadHash ?? null,\n    };\n    envelope.data = data;\n    const hints = Array.isArray(envelope.hints) ? envelope.hints as unknown[] : [];\n    hints.push('A concurrent same-key request with a different payload holds the canonical idempotency receipt; this write landed but will not replay.');\n    envelope.hints = hints;\n    return {\n      ...response,\n      content: [{ ...first, text: JSON.stringify(envelope) }, ...response.content.slice(1)],\n    };\n  } catch {\n    return response;\n  }\n}\n\n/**\n * Deletes receipts older than the retention window. Receipts are replay\n * caches, not durable records: unbounded growth plus indefinite stale\n * replays (including against deleted memories) is the failure mode this\n * sweep bounds. Best-effort by contract — callers must never let a sweep\n * failure block serving.\n */\nexport function pruneExpiredIdempotencyReceipts(\n  database: BetterSqlite3.Database,\n  ttlDays?: number,\n): number {\n  const envRaw = Number.parseInt(process.env.SPECKIT_IDEMPOTENCY_RECEIPT_TTL_DAYS ?? '', 10);\n  const days = Math.max(1, ttlDays ?? (Number.isFinite(envRaw) && envRaw > 0 ? envRaw : 30));\n  try {\n    // Prune on created_at: it is indexed and, since receipts are insert-only\n    // (ON CONFLICT DO NOTHING), updated_at is immutable and equals created_at —\n    // so this is behaviorally identical but avoids a full table scan.\n    const info = database.prepare(`\n      DELETE FROM memory_idempotency_receipts\n      WHERE created_at < datetime('now', ?)\n    `).run(`-${days} days`);\n    return info.changes;\n  } catch {\n    return 0;\n  }\n}\n\nexport function extractMemoryIdFromResponse(response: MCPResponse): number | null {\n  const first = response.content?.[0];\n  if (!first || first.type !== 'text' || typeof first.text !== 'string') {","lineStart":1,"lineEnd":280,"totalLines":290,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/idempotency-receipts.ts","time":{"start":1781761555347,"end":1781761555352}},"metadata":{"openai":{"itemId":"fc_0379653e1361df95016a33861319f0819181e81ab831c40bca"}},"id":"prt_ed943bb5b001zH1Zwl0q7yrXRs","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed943870e001i5qJ98c8GRiSJs"}}
{"type":"tool_use","timestamp":1781761555531,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_iRn659G0WZlw7QtQxGE8tMTw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Mutation Ledger\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Append-only audit trail for all memory mutations\n6: // SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\n7: import { createHash } from 'crypto';\n8: import type Database from 'better-sqlite3';\n9: import { runInTransaction } from './transaction-manager.js';\n10: \n11: /* ───────────────────────────────────────────────────────────────\n12:    1. TYPES\n13: ----------------------------------------------------------------*/\n14: \n15: type MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n16: \n17: interface MutationLedgerEntry {\n18:   id: number;\n19:   timestamp: string;\n20:   mutation_type: MutationType;\n21:   reason: string;\n22:   prior_hash: string | null;\n23:   new_hash: string;\n24:   linked_memory_ids: string; // JSON array\n25:   decision_meta: string;     // JSON object\n26:   actor: string;\n27:   session_id: string | null;\n28: }\n29: \n30: interface AppendEntryInput {\n31:   mutation_type: MutationType;\n32:   reason: string;\n33:   prior_hash: string | null;\n34:   new_hash: string;\n35:   linked_memory_ids: number[];\n36:   decision_meta: Record<string, unknown>;\n37:   actor: string;\n38:   session_id?: string | null;\n39: }\n40: \n41: interface GetEntriesOptions {\n42:   mutation_type?: MutationType;\n43:   actor?: string;\n44:   session_id?: string;\n45:   since?: string;    // ISO timestamp\n46:   until?: string;    // ISO timestamp\n47:   limit?: number;\n48:   offset?: number;\n49: }\n50: \n51: interface DivergenceReconcilePolicy {\n52:   normalizedPath: string;\n53:   attemptsSoFar: number;\n54:   nextAttempt: number;\n55:   maxRetries: number;\n56:   shouldRetry: boolean;\n57:   exhausted: boolean;\n58: }\n59: \n60: interface DivergenceEscalationPayload {\n61:   code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED';\n62:   normalizedPath: string;\n63:   attempts: number;\n64:   maxRetries: number;\n65:   recommendation: 'manual_triage_required';\n66:   reason: string;\n67:   variants: string[];\n68: }\n69: \n70: interface RecordDivergenceReconcileInput {\n71:   normalizedPath: string;\n72:   variants?: string[];\n73:   actor?: string;\n74:   session_id?: string | null;\n75:   maxRetries?: number;\n76: }\n77: \n78: interface RecordDivergenceReconcileResult {\n79:   policy: DivergenceReconcilePolicy;\n80:   retryEntryId: number | null;\n81:   escalationEntryId: number | null;\n82:   escalation: DivergenceEscalationPayload | null;\n83: }\n84: \n85: interface AutomatedMutationAuditInput {\n86:   mutation_type?: MutationType;\n87:   actor: string;\n88:   source_kind: 'agent' | 'system' | 'import' | 'feedback';\n89:   reason: string;\n90:   linked_memory_ids?: number[];\n91:   session_id?: string | null;\n92:   decision_meta?: Record<string, unknown>;\n93: }\n94: \n95: interface AutomatedMutationAuditResult {\n96:   appended: boolean;\n97:   eventKey: string;\n98:   entry: MutationLedgerEntry | null;\n99: }\n100: \n101: /* ───────────────────────────────────────────────────────────────\n102:    2. SCHEMA SQL\n103: ----------------------------------------------------------------*/\n104: \n105: const LEDGER_SCHEMA_SQL = `\n106:   CREATE TABLE IF NOT EXISTS mutation_ledger (\n107:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n108:     timestamp TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),\n109:     mutation_type TEXT NOT NULL CHECK(mutation_type IN ('create','update','delete','merge','archive','restore','reindex')),\n110:     reason TEXT NOT NULL,\n111:     prior_hash TEXT,\n112:     new_hash TEXT NOT NULL,\n113:     linked_memory_ids TEXT NOT NULL DEFAULT '[]',\n114:     decision_meta TEXT NOT NULL DEFAULT '{}',\n115:     actor TEXT NOT NULL,\n116:     session_id TEXT\n117:   )\n118: `;\n119: \n120: const LEDGER_INDEX_SQL = `\n121:   CREATE INDEX IF NOT EXISTS idx_ledger_type ON mutation_ledger(mutation_type);\n122:   CREATE INDEX IF NOT EXISTS idx_ledger_actor ON mutation_ledger(actor);\n123:   CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON mutation_ledger(timestamp);\n124:   CREATE INDEX IF NOT EXISTS idx_ledger_session ON mutation_ledger(session_id);\n125:   CREATE INDEX IF NOT EXISTS idx_ledger_new_hash ON mutation_ledger(new_hash);\n126:   CREATE INDEX IF NOT EXISTS idx_ledger_memory_type_created_at ON mutation_ledger(\n127:     CAST(json_extract(linked_memory_ids, '$[0]') AS INTEGER),\n128:     mutation_type,\n129:     timestamp\n130:   )\n131: `;\n132: \n133: const LEDGER_TRIGGER_SQL = `\n134:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n135:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n136:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n137:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n138: `;\n139: \n140: /* ───────────────────────────────────────────────────────────────\n141:    3. INITIALIZATION\n142: ----------------------------------------------------------------*/\n143: \n144: function initLedger(db: Database.Database): void {\n145:   db.exec(LEDGER_SCHEMA_SQL);\n146:   db.exec(LEDGER_INDEX_SQL);\n147:   db.exec(LEDGER_TRIGGER_SQL);\n148: }\n149: \n150: /* ───────────────────────────────────────────────────────────────\n151:    4. HASH COMPUTATION\n152: ----------------------------------------------------------------*/\n153: \n154: function computeHash(content: string): string {\n155:   return createHash('sha256').update(content, 'utf8').digest('hex');\n156: }\n157: \n158: /* ───────────────────────────────────────────────────────────────\n159:    5. APPEND ENTRY\n160: ----------------------------------------------------------------*/\n161: \n162: function appendEntry(db: Database.Database, entry: AppendEntryInput): MutationLedgerEntry {\n163:   const linkedJson = JSON.stringify(entry.linked_memory_ids);\n164:   const metaJson = JSON.stringify(entry.decision_meta);\n165: \n166:   const stmt = db.prepare(`\n167:     INSERT INTO mutation_ledger (mutation_type, reason, prior_hash, new_hash, linked_memory_ids, decision_meta, actor, session_id)\n168:     VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n169:   `);\n170: \n171:   const result = stmt.run(\n172:     entry.mutation_type,\n173:     entry.reason,\n174:     entry.prior_hash,\n175:     entry.new_hash,\n176:     linkedJson,\n177:     metaJson,\n178:     entry.actor,\n179:     entry.session_id ?? null\n180:   );\n181: \n182:   const id = (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n183: \n184:   const row = db.prepare('SELECT * FROM mutation_ledger WHERE id = ?').get(id) as MutationLedgerEntry;\n185:   return row;\n186: }\n187: \n188: function buildAutomatedMutationEventKey(input: AutomatedMutationAuditInput): string {\n189:   const linkedMemoryIds = (input.linked_memory_ids ?? [])\n190:     .filter((id) => Number.isInteger(id) && id > 0)\n191:     .slice()\n192:     .sort((left, right) => left - right);\n193:   return computeHash(JSON.stringify({\n194:     actor: input.actor,\n195:     source_kind: input.source_kind,\n196:     reason: input.reason,\n197:     linked_memory_ids: linkedMemoryIds,\n198:   }));\n199: }\n200: \n201: function getAutomatedMutationAuditEntry(db: Database.Database, eventKey: string): MutationLedgerEntry | null {\n202:   const row = db.prepare(`\n203:     SELECT *\n204:     FROM mutation_ledger\n205:     WHERE new_hash = ?\n206:     ORDER BY id ASC\n207:     LIMIT 1\n208:   `).get(eventKey) as MutationLedgerEntry | undefined;\n209:   return row ?? null;\n210: }\n211: \n212: function appendAutomatedMutationAudit(\n213:   db: Database.Database,\n214:   input: AutomatedMutationAuditInput,\n215: ): AutomatedMutationAuditResult {\n216:   initLedger(db);\n217:   const eventKey = buildAutomatedMutationEventKey(input);\n218:   const existing = getAutomatedMutationAuditEntry(db, eventKey);\n219:   if (existing) {\n220:     return { appended: false, eventKey, entry: existing };\n221:   }\n222: \n223:   const entry = appendEntry(db, {\n224:     mutation_type: input.mutation_type ?? 'update',\n225:     reason: input.reason,\n226:     prior_hash: null,\n227:     new_hash: eventKey,\n228:     linked_memory_ids: input.linked_memory_ids ?? [],\n229:     decision_meta: {\n230:       ...(input.decision_meta ?? {}),\n231:       eventKey,\n232:       sourceKind: input.source_kind,\n233:       automated: true,\n234:     },\n235:     actor: input.actor,\n236:     session_id: input.session_id ?? null,\n237:   });\n238: \n239:   return { appended: true, eventKey, entry };\n240: }\n241: \n242: /* ───────────────────────────────────────────────────────────────\n243:    6. QUERY ENTRIES\n244: ----------------------------------------------------------------*/\n245: \n246: function getEntries(db: Database.Database, opts: GetEntriesOptions = {}): MutationLedgerEntry[] {\n247:   const conditions: string[] = [];\n248:   const params: Array<string | number> = [];\n249: \n250:   if (opts.mutation_type) {\n251:     conditions.push('mutation_type = ?');\n252:     params.push(opts.mutation_type);\n253:   }\n254:   if (opts.actor) {\n255:     conditions.push('actor = ?');\n256:     params.push(opts.actor);\n257:   }\n258:   if (opts.session_id) {\n259:     conditions.push('session_id = ?');\n260:     params.push(opts.session_id);\n\n(Showing lines 1-260 of 555. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Append-only audit trail for all memory mutations\n// SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\nimport { createHash } from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\ntype MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n\ninterface MutationLedgerEntry {\n  id: number;\n  timestamp: string;\n  mutation_type: MutationType;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Append-only audit trail for all memory mutations\n// SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\nimport { createHash } from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\ntype MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n\ninterface MutationLedgerEntry {\n  id: number;\n  timestamp: string;\n  mutation_type: MutationType;\n  reason: string;\n  prior_hash: string | null;\n  new_hash: string;\n  linked_memory_ids: string; // JSON array\n  decision_meta: string;     // JSON object\n  actor: string;\n  session_id: string | null;\n}\n\ninterface AppendEntryInput {\n  mutation_type: MutationType;\n  reason: string;\n  prior_hash: string | null;\n  new_hash: string;\n  linked_memory_ids: number[];\n  decision_meta: Record<string, unknown>;\n  actor: string;\n  session_id?: string | null;\n}\n\ninterface GetEntriesOptions {\n  mutation_type?: MutationType;\n  actor?: string;\n  session_id?: string;\n  since?: string;    // ISO timestamp\n  until?: string;    // ISO timestamp\n  limit?: number;\n  offset?: number;\n}\n\ninterface DivergenceReconcilePolicy {\n  normalizedPath: string;\n  attemptsSoFar: number;\n  nextAttempt: number;\n  maxRetries: number;\n  shouldRetry: boolean;\n  exhausted: boolean;\n}\n\ninterface DivergenceEscalationPayload {\n  code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED';\n  normalizedPath: string;\n  attempts: number;\n  maxRetries: number;\n  recommendation: 'manual_triage_required';\n  reason: string;\n  variants: string[];\n}\n\ninterface RecordDivergenceReconcileInput {\n  normalizedPath: string;\n  variants?: string[];\n  actor?: string;\n  session_id?: string | null;\n  maxRetries?: number;\n}\n\ninterface RecordDivergenceReconcileResult {\n  policy: DivergenceReconcilePolicy;\n  retryEntryId: number | null;\n  escalationEntryId: number | null;\n  escalation: DivergenceEscalationPayload | null;\n}\n\ninterface AutomatedMutationAuditInput {\n  mutation_type?: MutationType;\n  actor: string;\n  source_kind: 'agent' | 'system' | 'import' | 'feedback';\n  reason: string;\n  linked_memory_ids?: number[];\n  session_id?: string | null;\n  decision_meta?: Record<string, unknown>;\n}\n\ninterface AutomatedMutationAuditResult {\n  appended: boolean;\n  eventKey: string;\n  entry: MutationLedgerEntry | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. SCHEMA SQL\n----------------------------------------------------------------*/\n\nconst LEDGER_SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS mutation_ledger (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    timestamp TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),\n    mutation_type TEXT NOT NULL CHECK(mutation_type IN ('create','update','delete','merge','archive','restore','reindex')),\n    reason TEXT NOT NULL,\n    prior_hash TEXT,\n    new_hash TEXT NOT NULL,\n    linked_memory_ids TEXT NOT NULL DEFAULT '[]',\n    decision_meta TEXT NOT NULL DEFAULT '{}',\n    actor TEXT NOT NULL,\n    session_id TEXT\n  )\n`;\n\nconst LEDGER_INDEX_SQL = `\n  CREATE INDEX IF NOT EXISTS idx_ledger_type ON mutation_ledger(mutation_type);\n  CREATE INDEX IF NOT EXISTS idx_ledger_actor ON mutation_ledger(actor);\n  CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON mutation_ledger(timestamp);\n  CREATE INDEX IF NOT EXISTS idx_ledger_session ON mutation_ledger(session_id);\n  CREATE INDEX IF NOT EXISTS idx_ledger_new_hash ON mutation_ledger(new_hash);\n  CREATE INDEX IF NOT EXISTS idx_ledger_memory_type_created_at ON mutation_ledger(\n    CAST(json_extract(linked_memory_ids, '$[0]') AS INTEGER),\n    mutation_type,\n    timestamp\n  )\n`;\n\nconst LEDGER_TRIGGER_SQL = `\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   3. INITIALIZATION\n----------------------------------------------------------------*/\n\nfunction initLedger(db: Database.Database): void {\n  db.exec(LEDGER_SCHEMA_SQL);\n  db.exec(LEDGER_INDEX_SQL);\n  db.exec(LEDGER_TRIGGER_SQL);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HASH COMPUTATION\n----------------------------------------------------------------*/\n\nfunction computeHash(content: string): string {\n  return createHash('sha256').update(content, 'utf8').digest('hex');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. APPEND ENTRY\n----------------------------------------------------------------*/\n\nfunction appendEntry(db: Database.Database, entry: AppendEntryInput): MutationLedgerEntry {\n  const linkedJson = JSON.stringify(entry.linked_memory_ids);\n  const metaJson = JSON.stringify(entry.decision_meta);\n\n  const stmt = db.prepare(`\n    INSERT INTO mutation_ledger (mutation_type, reason, prior_hash, new_hash, linked_memory_ids, decision_meta, actor, session_id)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const result = stmt.run(\n    entry.mutation_type,\n    entry.reason,\n    entry.prior_hash,\n    entry.new_hash,\n    linkedJson,\n    metaJson,\n    entry.actor,\n    entry.session_id ?? null\n  );\n\n  const id = (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n\n  const row = db.prepare('SELECT * FROM mutation_ledger WHERE id = ?').get(id) as MutationLedgerEntry;\n  return row;\n}\n\nfunction buildAutomatedMutationEventKey(input: AutomatedMutationAuditInput): string {\n  const linkedMemoryIds = (input.linked_memory_ids ?? [])\n    .filter((id) => Number.isInteger(id) && id > 0)\n    .slice()\n    .sort((left, right) => left - right);\n  return computeHash(JSON.stringify({\n    actor: input.actor,\n    source_kind: input.source_kind,\n    reason: input.reason,\n    linked_memory_ids: linkedMemoryIds,\n  }));\n}\n\nfunction getAutomatedMutationAuditEntry(db: Database.Database, eventKey: string): MutationLedgerEntry | null {\n  const row = db.prepare(`\n    SELECT *\n    FROM mutation_ledger\n    WHERE new_hash = ?\n    ORDER BY id ASC\n    LIMIT 1\n  `).get(eventKey) as MutationLedgerEntry | undefined;\n  return row ?? null;\n}\n\nfunction appendAutomatedMutationAudit(\n  db: Database.Database,\n  input: AutomatedMutationAuditInput,\n): AutomatedMutationAuditResult {\n  initLedger(db);\n  const eventKey = buildAutomatedMutationEventKey(input);\n  const existing = getAutomatedMutationAuditEntry(db, eventKey);\n  if (existing) {\n    return { appended: false, eventKey, entry: existing };\n  }\n\n  const entry = appendEntry(db, {\n    mutation_type: input.mutation_type ?? 'update',\n    reason: input.reason,\n    prior_hash: null,\n    new_hash: eventKey,\n    linked_memory_ids: input.linked_memory_ids ?? [],\n    decision_meta: {\n      ...(input.decision_meta ?? {}),\n      eventKey,\n      sourceKind: input.source_kind,\n      automated: true,\n    },\n    actor: input.actor,\n    session_id: input.session_id ?? null,\n  });\n\n  return { appended: true, eventKey, entry };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. QUERY ENTRIES\n----------------------------------------------------------------*/\n\nfunction getEntries(db: Database.Database, opts: GetEntriesOptions = {}): MutationLedgerEntry[] {\n  const conditions: string[] = [];\n  const params: Array<string | number> = [];\n\n  if (opts.mutation_type) {\n    conditions.push('mutation_type = ?');\n    params.push(opts.mutation_type);\n  }\n  if (opts.actor) {\n    conditions.push('actor = ?');\n    params.push(opts.actor);\n  }\n  if (opts.session_id) {\n    conditions.push('session_id = ?');\n    params.push(opts.session_id);","lineStart":1,"lineEnd":260,"totalLines":555,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","time":{"start":1781761555526,"end":1781761555529}},"metadata":{"openai":{"itemId":"fc_0379653e1361df95016a33861319fc8191a989bf65d0a686ed"}},"id":"prt_ed943bba1001DqQyu9Si1QntY0","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed943870e001i5qJ98c8GRiSJs"}}
{"type":"tool_use","timestamp":1781761555635,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_d9bQUWP8bwtwZ8g19BNXOhKD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","offset":1,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Bulk Delete\n3: // ────────────────────────────────────────────────────────────────\n4: // Tier-based bulk deletion of memories with safety gates.\n5: // Eliminates the need for direct DB scripts when cleaning up\n6: // Deprecated/temporary memories at scale.\n7: import { checkDatabaseUpdated } from '../core/index.js';\n8: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n9: import * as vectorIndex from '../lib/search/vector-index.js';\n10: import * as checkpoints from '../lib/storage/checkpoints.js';\n11: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { createStatediffAction } from '../lib/storage/statediff.js';\n14: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { recordHistory } from '../lib/storage/history.js';\n18: import { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\n19: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: \n23: import type { MCPResponse } from './types.js';\n24: \n25: // Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n26: // Feature catalog: Per-memory history log\n27: \n28: /* ───────────────────────────────────────────────────────────────\n29:    1. TYPES\n30: ──────────────────────────────────────────────────────────────── */\n31: \n32: interface BulkDeleteArgs {\n33:   tier: string;\n34:   specFolder?: string;\n35:   confirm: boolean;\n36:   olderThanDays?: number;\n37:   skipCheckpoint?: boolean;\n38: }\n39: \n40: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n41:   if (!database || !('prepare' in database)) return false;\n42:   try {\n43:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n44:     return columns.some((column) => column.name === 'deleted_at');\n45:   } catch {\n46:     return false;\n47:   }\n48: }\n49: \n50: function isSoftDeleteTombstonesEnabled(): boolean {\n51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n52: }\n53: \n54: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n55:   if (!isSoftDeleteTombstonesEnabled()) {\n56:     return vectorIndex.deleteMemory(memoryId, database);\n57:   }\n58: \n59:   if (!hasDeletedAtColumn(database)) {\n60:     return vectorIndex.deleteMemory(memoryId, database);\n61:   }\n62: \n63:   const deletedAt = new Date().toISOString();\n64:   const result = database.prepare(`\n65:     UPDATE memory_index\n66:     SET deleted_at = COALESCE(deleted_at, ?),\n67:         updated_at = datetime('now')\n68:     WHERE id = ?\n69:   `).run(deletedAt, memoryId);\n70:   return result.changes > 0;\n71: }\n72: \n73: /* ───────────────────────────────────────────────────────────────\n74:     2. HANDLER\n75: ──────────────────────────────────────────────────────────────── */\n76: \n77: async function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n78:   await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n79:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n80:   if (restoreBarrier) {\n81:     return createMCPErrorResponse({\n82:       tool: 'memory_bulk_delete',\n83:       error: restoreBarrier.message,\n84:       code: restoreBarrier.code,\n85:       details: {\n86:         tier: args.tier ?? null,\n87:         specFolder: args.specFolder ?? null,\n88:       },\n89:       recovery: {\n90:         hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n91:         actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   await checkDatabaseUpdated();\n98: \n99:   const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n100: \n101:   // Validation\n102:   if (!tier || typeof tier !== 'string') {\n103:     throw new Error('tier is required and must be a string');\n104:   }\n105: \n106:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n107:   if (!validTiers.includes(tier)) {\n108:     throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n109:   }\n110: \n111:   if (!confirm) {\n112:     throw new Error('Bulk delete requires confirm: true as a safety gate');\n113:   }\n114: \n115:   // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n116:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n117:     throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n118:   }\n119: \n120:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n121:     throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n122:   }\n123: \n124:   if (\n125:     olderThanDays !== undefined\n126:     && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n127:   ) {\n128:     throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n129:   }\n130: \n131:   const database = vectorIndex.getDb();\n132:   if (!database) {\n133:     return createMCPErrorResponse({\n134:       tool: 'memory_bulk_delete',\n135:       error: 'Memory bulk delete aborted: database unavailable',\n136:       code: 'E_DB_UNAVAILABLE',\n137:       details: {\n138:         tier,\n139:         specFolder: specFolder || null,\n140:         olderThanDays: olderThanDays || null,\n141:       },\n142:       recovery: {\n143:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n144:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n145:         severity: 'error',\n146:       },\n147:     });\n148:   }\n149: \n150:   // Build query to count affected memories\n151:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n152:   const countParams: unknown[] = [tier];\n153: \n154:   if (specFolder) {\n155:     countSql += ' AND spec_folder = ?';\n156:     countParams.push(specFolder);\n157:   }\n158: \n159:   if (olderThanDays !== undefined) {\n160:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n161:     countParams.push(olderThanDays);\n162:   }\n163: \n164:   const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n165:   const affectedCount = countResult.count;\n166: \n167:   if (affectedCount === 0) {\n168:     return createMCPSuccessResponse({\n169:       tool: 'memory_bulk_delete',\n170:       summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n172:       hints: ['Use memory_list() to browse existing memories'],\n173:     });\n174:   }\n175: \n176:   // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n177:   let checkpointName: string | null = null;\n178:   if (!skipCheckpoint) {\n179:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n181: \n182:     try {\n183:       const checkpoint = checkpoints.createCheckpoint({\n184:         name: proposedCheckpointName,\n185:         specFolder,\n186:         metadata: {\n187:           reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n188:           tier,\n189:           affectedCount,\n190:           olderThanDays: olderThanDays || null,\n191:         },\n192:       });\n193: \n194:       if (!checkpoint) {\n195:         const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n196:         if (tier === 'constitutional' || tier === 'critical') {\n197:           throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n198:         }\n199:         console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n200:       } else {\n201:         checkpointName = checkpoint.name;\n202:         console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n203:       }\n204:     } catch (cpErr: unknown) {\n205:       const message = toErrorMessage(cpErr);\n206:       console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n207:       // High-safety tiers require a valid checkpoint.\n208:       if (tier === 'constitutional' || tier === 'critical') {\n209:         throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n210:       }\n211:       // Lower tiers can proceed with explicit no-rollback notice.\n212:       checkpointName = null;\n213:     }\n214:   } else {\n215:     console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n216:   }\n217: \n218:   // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n219:   let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n220:   const selectParams: unknown[] = [tier];\n221: \n222:   if (specFolder) {\n223:     selectSql += ' AND spec_folder = ?';\n224:     selectParams.push(specFolder);\n225:   }\n226: \n227:   if (olderThanDays !== undefined) {\n228:     selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n229:     selectParams.push(olderThanDays);\n230:   }\n231: \n232:   const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n233:     id: number;\n234:     content_hash: string | null;\n235:     file_path: string | null;\n236:     spec_folder: string | null;\n237:   }>;\n238: \n239:   // Perform deletion in a transaction\n240:   let deletedCount = 0;\n241:   const deletedIds: number[] = [];\n242: \n243:   causalEdges.init(database);\n244: \n245:   const bulkDeleteTx = database.transaction(() => {\n246:     for (const memory of memoriesToDelete) {\n247:       if (tombstoneMemory(database, memory.id)) {\n248:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n249:         try {\n250:           recordHistory(\n251:             memory.id,\n252:             'DELETE',\n253:             memory.file_path ?? null,\n254:             null,\n255:             'mcp:memory_bulk_delete',\n256:             memory.spec_folder ?? null,\n257:           );\n258:         } catch (_histErr: unknown) {\n259:           // History recording is best-effort inside bulk delete\n260:         }\n261:         deletedCount++;\n262:         deletedIds.push(memory.id);\n263: \n264:         // Clean up causal edges\n265:         // Propagate edge-cleanup errors to fail the transaction.\n266:         // Previously errors were caught and logged, leaving orphan causal edges\n267:         // When memory rows were successfully deleted but edge cleanup failed.\n268:         causalEdges.deleteEdgesForMemory(String(memory.id), {\n269:           reason: 'memory row mutation cleanup',\n270:           command: 'memory-bulk-delete.handleMemoryBulkDelete',\n271:           restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n272:         });\n273:       }\n274:     }\n275:   });\n276: \n277:   bulkDeleteTx();\n278: \n279:   // Record in mutation ledger (single entry for bulk operation)\n280:   const ledgerRecorded = appendMutationLedgerSafe(database, {\n281:     mutationType: 'delete',\n282:     reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n283:     priorHash: null,\n284:     newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n285:     linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n286:     decisionMeta: {\n287:       tool: 'memory_bulk_delete',\n288:       tier,\n289:       specFolder: specFolder || null,\n290:       olderThanDays: olderThanDays || null,\n291:       totalDeleted: deletedCount,\n292:       checkpoint: checkpointName,\n293:       skipCheckpoint,\n294:     },\n295:     actor: 'mcp:memory_bulk_delete',\n296:   });\n297: \n298:   // Invalidate caches\n299:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n300:   if (deletedCount > 0) {\n301:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n302:     try {\n303:       postMutationHooks = runPostMutationHooks('bulk-delete', {\n304:         specFolder,\n305:         tier,\n306:         deletedCount,\n307:         statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n308:           target: 'memory_index',\n309:           key: String(id),\n310:           sourceOperation: 'bulk-delete',\n311:           metadata: { tier, specFolder: specFolder ?? null },\n312:         })),\n313:       });\n314:     } catch (hookError: unknown) {\n315:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n316:       postMutationHooks = {\n317:         latencyMs: 0, triggerCacheCleared: false,\n318:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n319:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n320:         errors: [msg],\n321:       };\n322:     }\n323:     postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n324:   }\n325: \n326:   const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n327: \n328:   const hints: string[] = [];\n329:   if (checkpointName) {\n330:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n331:   } else if (skipCheckpoint) {\n332:     hints.push('Checkpoint skipped: restore is not available for this operation');\n333:   }\n334:   if (postMutationFeedback) {\n335:     hints.push(...postMutationFeedback.hints);\n336:   }\n337:   if (!ledgerRecorded) {\n338:     hints.push('Mutation ledger append failed; audit trail may be incomplete.');\n339:   }\n340:   hints.push(`Run memory_index_scan({ force: true }) to re-index if needed`);\n341: \n342:   const data: Record<string, unknown> = {\n343:     deleted: deletedCount,\n344:     tier,\n345:     specFolder: specFolder || null,\n346:     olderThanDays: olderThanDays || null,\n347:     skipCheckpoint,\n348:   };\n349:   if (checkpointName) {\n350:     data.checkpoint = checkpointName;\n351:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n352:   }\n353:   if (postMutationFeedback) {\n354:     data.postMutationHooks = postMutationFeedback.data;\n355:   }\n356:   if (!ledgerRecorded) {\n357:     data.warning = 'Mutation ledger append failed; audit trail may be incomplete.';\n358:   }\n359: \n360:   return createMCPSuccessResponse({\n361:     tool: 'memory_bulk_delete',\n362:     summary,\n363:     data,\n364:     hints,\n365:   });\n366: }\n367: \n368: /* ───────────────────────────────────────────────────────────────\n369:    3. EXPORTS\n370: ──────────────────────────────────────────────────────────────── */\n371: \n372: export { handleMemoryBulkDelete };\n\n(End of file - total 372 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Bulk Delete\n// ────────────────────────────────────────────────────────────────\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n// Feature catalog: Per-memory history log\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n    2. HANDLER\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        tier: args.tier ?? null,\n        specFolder: args.specFolder ?? null,\n      },\n      recovery: {\n        hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n\n  // Validation\n  if (!tier || typeof tier !== 'string') {\n    throw new Error('tier is required and must be a string');\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n  }\n\n  if (!confirm) {\n    throw new Error('Bulk delete requires confirm: true as a safety gate');\n  }\n\n  // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n  }\n\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n  }\n\n  if (\n    olderThanDays !== undefined\n    && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n  ) {\n    throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n  }\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: 'Memory bulk delete aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        tier,\n        specFolder: specFolder || null,\n        olderThanDays: olderThanDays || null,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Build query to count affected memories\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(olderThanDays);\n  }\n\n  const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  if (affectedCount === 0) {\n    return createMCPSuccessResponse({\n      tool: 'memory_bulk_delete',\n      summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n      data: { deleted: 0, tier, specFolder: specFolder || null },\n      hints: ['Use memory_list() to browse existing memories'],\n    });\n  }\n\n  // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n    try {\n      const checkpoint = checkpoints.createCheckpoint({\n        name: proposedCheckpointName,\n        specFolder,\n        metadata: {\n          reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n          tier,\n          affectedCount,\n          olderThanDays: olderThanDays || null,\n        },\n      });\n\n      if (!checkpoint) {\n        const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n        if (tier === 'constitutional' || tier === 'critical') {\n          throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n        }\n        console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n      } else {\n        checkpointName = checkpoint.name;\n        console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n      }\n    } catch (cpErr: unknown) {\n      const message = toErrorMessage(cpErr);\n      console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n      // High-safety tiers require a valid checkpoint.\n      if (tier === 'constitutional' || tier === 'critical') {\n        throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n      }\n      // Lower tiers can proceed with explicit no-rollback notice.\n      checkpointName = null;\n    }\n  } else {\n    console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n  }\n\n  // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n  let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n  const selectParams: unknown[] = [tier];\n\n  if (specFolder) {\n    selectSql += ' AND spec_folder = ?';\n    selectParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    selectParams.push(olderThanDays);\n  }\n\n  const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n    id: number;\n    content_hash: string | null;\n    file_path: string | null;\n    spec_folder: string | null;\n  }>;\n\n  // Perform deletion in a transaction\n  let deletedCount = 0;\n  const deletedIds: number[] = [];\n\n  causalEdges.init(database);\n\n  const bulkDeleteTx = database.transaction(() => {\n    for (const memory of memoriesToDelete) {\n      if (tombstoneMemory(database, memory.id)) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        try {\n          recordHistory(\n            memory.id,\n            'DELETE',\n            memory.file_path ?? null,\n            null,\n            'mcp:memory_bulk_delete',\n            memory.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort inside bulk delete\n        }\n        deletedCount++;\n        deletedIds.push(memory.id);\n\n        // Clean up causal edges\n        // Propagate edge-cleanup errors to fail the transaction.\n        // Previously errors were caught and logged, leaving orphan causal edges\n        // When memory rows were successfully deleted but edge cleanup failed.\n        causalEdges.deleteEdgesForMemory(String(memory.id), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-bulk-delete.handleMemoryBulkDelete',\n          restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n        });\n      }\n    }\n  });\n\n  bulkDeleteTx();\n\n  // Record in mutation ledger (single entry for bulk operation)\n  const ledgerRecorded = appendMutationLedgerSafe(database, {\n    mutationType: 'delete',\n    reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n    priorHash: null,\n    newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n    linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n    decisionMeta: {\n      tool: 'memory_bulk_delete',\n      tier,\n      specFolder: specFolder || null,\n      olderThanDays: olderThanDays || null,\n      totalDeleted: deletedCount,\n      checkpoint: checkpointName,\n      skipCheckpoint,\n    },\n    actor: 'mcp:memory_bulk_delete',\n  });\n\n  // Invalidate caches\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('bulk-delete', {\n        specFolder,\n        tier,\n        deletedCount,\n        statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n          target: 'memory_index',\n          key: String(id),\n          sourceOperation: 'bulk-delete',\n          metadata: { tier, specFolder: specFolder ?? null },\n        })),\n      });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n  }\n\n  const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  } else if (skipCheckpoint) {\n    hints.push('Checkpoint skipped: restore is not available for this operation');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (!ledgerRecorded) {\n    hints.push('Mutation ledger append failed; audit trail may be incomplete.');\n  }\n  hints.push(`Run memory_index_scan({ force: true }) to re-index if needed`);\n\n  const data: Record<string, unknown> = {\n    deleted: deletedCount,\n    tier,\n    specFolder: specFolder || null,\n    olderThanDays: olderThanDays || null,\n    skipCheckpoint,\n  };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (!ledgerRecorded) {\n    data.warning = 'Mutation ledger append failed; audit trail may be incomplete.';\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_bulk_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryBulkDelete };","lineStart":1,"lineEnd":372,"totalLines":372,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","time":{"start":1781761555623,"end":1781761555632}},"metadata":{"openai":{"itemId":"fc_0379653e1361df95016a3386131a08819193c83bb8d1bef342"}},"id":"prt_ed943bc520010xqan058YjX2N0","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed943870e001i5qJ98c8GRiSJs"}}
{"type":"tool_use","timestamp":1781761555728,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_ALZAiXE1JJcKY86oNKg0S7xl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Causal Edges\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Causal edge creation (memory_causal_link)\n5: // Causal relationship graph for memory lineage\n6: import type Database from 'better-sqlite3';\n7: import { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\n8: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n9: import { detectContradictions } from '../graph/contradiction-detection.js';\n10: import { ensureTemporalColumns } from '../graph/temporal-edges.js';\n11: import { isTemporalEdgesEnabled } from '../search/search-flags.js';\n12: import { runInTransaction } from './transaction-manager.js';\n13: import { sweepCausalEdges } from '../causal/sweep.js';\n14: import { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\n15: import type { CausalEdgeSweepResult } from '../causal/sweep.js';\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    1. CONSTANTS\n19: ----------------------------------------------------------------*/\n20: \n21: const RELATION_TYPES = Object.freeze({\n22:   CAUSED: 'caused',\n23:   ENABLED: 'enabled',\n24:   SUPERSEDES: 'supersedes',\n25:   CONTRADICTS: 'contradicts',\n26:   DERIVED_FROM: 'derived_from',\n27:   SUPPORTS: 'supports',\n28: } as const);\n29: \n30: type RelationType = typeof RELATION_TYPES[keyof typeof RELATION_TYPES];\n31: \n32: /**\n33:  * C138: Relation weight multipliers applied during traversal scoring.\n34:  * Higher values amplify the propagated strength; values < 1.0 dampen it.\n35:  */\n36: const RELATION_WEIGHTS: Record<string, number> = {\n37:   supersedes:   1.5,  // Strongest signal — new info replaces old\n38:   caused:       1.3,  // Strong causal link\n39:   enabled:      1.1,  // Weak causal link\n40:   supports:     1.0,  // Neutral / default\n41:   derived_from: 1.0,  // Neutral / default\n42:   contradicts:  0.8,  // Dampened — conflicting signals lower confidence\n43: };\n44: \n45: const DEFAULT_MAX_DEPTH = 3;\n46: const MAX_EDGES_LIMIT = 100;\n47: \n48: // Edge bounds for the lightweight runtime path (NFR-R01, SC-005)\n49: const MAX_EDGES_PER_NODE = 20;\n50: const MAX_AUTO_STRENGTH = 0.5;\n51: const MAX_STRENGTH_INCREASE_PER_CYCLE = 0.05;\n52: const WINDOW_MS = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_WINDOW_MS', 15 * 60 * 1000);\n53: const CAP_PER_WINDOW = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_CAP_PER_WINDOW', 100);\n54: const STALENESS_THRESHOLD_DAYS = 90;\n55: const DECAY_STRENGTH_AMOUNT = 0.1;\n56: const DECAY_PERIOD_DAYS = 30;\n57: \n58: function parsePositiveIntegerEnv(name: string, fallback: number): number {\n59:   const value = process.env[name];\n60:   if (!value) return fallback;\n61:   const parsed = Number.parseInt(value, 10);\n62:   return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;\n63: }\n64: \n65: function isFiniteNumber(value: unknown): value is number {\n66:   return typeof value === 'number' && Number.isFinite(value);\n67: }\n68: \n69: /**\n70:  * Classify edge provenance as automatic. Covers the legacy 'auto' creator and\n71:  * namespaced automatic creators such as 'auto-session'. Shared by the insert\n72:  * cap path and the consolidation strengthening cap so the two sites cannot\n73:  * drift. Non-auto values ('manual', 'automatic', 'author') must not match.\n74:  */\n75: function isAutoEdgeCreator(createdBy: string | null | undefined): boolean {\n76:   return createdBy === 'auto'\n77:     || (typeof createdBy === 'string' && createdBy.startsWith('auto-'));\n78: }\n79: \n80: function clampStrength(strength: number): number | null {\n81:   if (!Number.isFinite(strength)) return null;\n82:   return Math.max(0, Math.min(1, strength));\n83: }\n84: \n85: function normalizeCausalEdgeRow(row: Record<string, unknown>): CausalEdge {\n86:   return {\n87:     id: Number(row.id),\n88:     source_id: String(row.source_id),\n89:     target_id: String(row.target_id),\n90:     source_anchor: row.source_anchor == null ? null : String(row.source_anchor),\n91:     target_anchor: row.target_anchor == null ? null : String(row.target_anchor),\n92:     relation: String(row.relation) as RelationType,\n93:     strength: Number(row.strength),\n94:     evidence: row.evidence == null ? null : String(row.evidence),\n95:     extracted_at: String(row.extracted_at),\n96:     created_by: String(row.created_by ?? 'manual'),\n97:     last_accessed: row.last_accessed == null ? null : String(row.last_accessed),\n98:   };\n99: }\n100: \n101: /* ───────────────────────────────────────────────────────────────\n102:    2. INTERFACES\n103: ----------------------------------------------------------------*/\n104: \n105: interface CausalEdge {\n106:   id: number;\n107:   source_id: string;\n108:   target_id: string;\n109:   source_anchor: string | null;\n110:   target_anchor: string | null;\n111:   relation: RelationType;\n112:   strength: number;\n113:   evidence: string | null;\n114:   extracted_at: string;\n115:   created_by: string;\n116:   last_accessed: string | null;\n117: }\n118: \n119: interface CausalEdgeRow extends Record<string, unknown> {\n120:   id: number;\n121:   source_id: string;\n122:   target_id: string;\n123:   source_anchor?: string | null;\n124:   target_anchor?: string | null;\n125:   relation: RelationType;\n126:   strength: number;\n127:   evidence: string | null;\n128:   extracted_at: string;\n129:   created_by: string;\n130:   last_accessed: string | null;\n131: }\n132: \n133: type EdgeQueryResult = CausalEdge[] & {\n134:   truncated: boolean;\n135:   limit: number;\n136: };\n137: \n138: interface WeightHistoryEntry {\n139:   id: number;\n140:   edge_id: number;\n141:   old_strength: number;\n142:   new_strength: number;\n143:   changed_by: string;\n144:   changed_at: string;\n145:   reason: string | null;\n146: }\n147: \n148: interface GraphStats {\n149:   totalEdges: number;\n150:   byRelation: Record<string, number>;\n151:   avgStrength: number;\n152:   uniqueSources: number;\n153:   uniqueTargets: number;\n154: }\n155: \n156: interface DeleteEdgeOptions {\n157:   reason?: string;\n158:   command?: string;\n159:   restoreContext?: Record<string, unknown>;\n160: }\n161: \n162: interface InsertEdgeMetadataOptions {\n163:   confidence?: number;\n164:   extractionMethod?: string;\n165: }\n166: \n167: interface InsertEdgeOutcome {\n168:   status: 'inserted' | 'updated' | 'skipped';\n169:   reason: string | null;\n170:   edgeId: number | null;\n171: }\n172: \n173: interface CausalChainNode {\n174:   id: string;\n175:   edgeId?: number;          // Preserve causal_edges.id for unlink workflow\n176:   depth: number;\n177:   relation: RelationType;\n178:   strength: number;\n179:   children: CausalChainNode[];\n180:   truncated?: boolean;\n181:   truncationLimit?: number | null;\n182: }\n183: \n184: /* ───────────────────────────────────────────────────────────────\n185:    3. MODULE STATE\n186: ----------------------------------------------------------------*/\n187: \n188: let db: Database.Database | null = null;\n189: let lastInsertEdgeOutcome: InsertEdgeOutcome | null = null;\n190: \n191: /**\n192:  * Monotonically-increasing generation counter bumped on every causal-edge\n193:  * mutation (insert/update/delete/rollback). Read-only callers can include this\n194:  * value in cache keys (e.g. memory_search when `enableCausalBoost=true`) so\n195:  * cached responses derived from the causal graph become stale on the next\n196:  * lookup without requiring a wholesale tool-cache invalidation.\n197:  *\n198:  * targeted memory_search cache invalidation.\n199:  */\n200: // Counter lives in causal-generation.ts so the tombstone sweep (which this\n201: // module imports) can bump it without a circular import.\n202: \n203: function setLastInsertEdgeOutcome(outcome: InsertEdgeOutcome): void {\n204:   lastInsertEdgeOutcome = outcome;\n205: }\n206: \n207: function getLastInsertEdgeOutcome(): InsertEdgeOutcome | null {\n208:   return lastInsertEdgeOutcome;\n209: }\n210: \n211: function invalidateDegreeCache(): void {\n212:   // bump the causal-edges generation FIRST so any cache key that\n213:   // includes it (e.g. memory_search when enableCausalBoost=true) becomes\n214:   // stale on the next read without invalidating unrelated tool entries.\n215:   bumpCausalEdgesGeneration();\n216: \n217:   try {\n218:     // Use db-specific cache invalidation instead of the no-op global version\n219:     if (db) {\n220:       clearDegreeCacheForDb(db);\n221:     }\n222:   } catch (_error: unknown) {\n223:     // Cache invalidation is best-effort; never block edge mutations\n224:   }\n225:   try {\n226:     clearGraphSignalsCache();\n227:   } catch (_error: unknown) {\n228:     // Graph signals cache invalidation is best-effort\n229:   }\n230: }\n231: \n232: function enforceRelationWindowCap(\n233:   relation: string,\n234:   database: Database.Database,\n235:   windowMs: number = WINDOW_MS,\n236:   capPerWindow: number = CAP_PER_WINDOW,\n237: ): boolean {\n238:   try {\n239:     const windowStart = new Date(Date.now() - windowMs).toISOString();\n240:     const row = (database.prepare(`\n241:       SELECT COUNT(*) as count FROM causal_edges\n242:       WHERE relation = ?\n243:         AND datetime(extracted_at) >= datetime(?)\n244:     `) as Database.Statement).get(relation, windowStart) as { count: number };\n245:     const count = row.count;\n246:     if (count >= capPerWindow) {\n247:       console.warn(`[causal-edges] cap exceeded for relation ${relation}: ${count}/${capPerWindow} in ${windowMs}ms window`);\n248:       return false;\n249:     }\n250:     return true;\n251:   } catch (error: unknown) {\n252:     const msg = error instanceof Error ? error.message : String(error);\n253:     console.warn(`[causal-edges] relation cap check failed for ${relation}: ${msg}`);\n254:     return true;\n255:   }\n256: }\n257: \n258: /* ───────────────────────────────────────────────────────────────\n259:    4. INITIALIZATION\n260: ----------------------------------------------------------------*/\n261: \n262: function init(database: Database.Database): void {\n263:   db = database;\n264: \n265:   // Defensive traversal indexes — the canonical creation lives in\n266:   // Vector-index-impl.ts migration v8. These IF NOT EXISTS guards\n267:   // Ensure the indexes are present even when the module is initialised outside\n268:   // The normal migration path (e.g. tests, standalone scripts).\n269:   try {\n270:     database.exec('CREATE INDEX IF NOT EXISTS idx_causal_source ON causal_edges(source_id)');\n271:     database.exec('CREATE INDEX IF NOT EXISTS idx_causal_target ON causal_edges(target_id)');\n272:     ensureTemporalColumns(database);\n273:   } catch (_e: unknown) {\n274:     // Best-effort: table may not exist yet during early startup sequencing\n275:   }\n276: }\n277: \n278: /* ───────────────────────────────────────────────────────────────\n279:    5. EDGE OPERATIONS\n280: ----------------------------------------------------------------*/\n281: \n282: function insertEdge(\n283:   sourceId: string,\n284:   targetId: string,\n285:   relation: RelationType,\n286:   strength: number = 1.0,\n287:   evidence: string | null = null,\n288:   shouldInvalidateCache: boolean = true,\n289:   createdBy: string = 'manual',\n290:   anchors: { sourceAnchor?: string | null; targetAnchor?: string | null } = {},\n291:   metadata: InsertEdgeMetadataOptions = {},\n292: ): number | null {\n293:   lastInsertEdgeOutcome = null;\n294:   if (!db) {\n295:     console.warn('[causal-edges] Database not initialized. Server may still be starting up.');\n296:     setLastInsertEdgeOutcome({ status: 'skipped', reason: 'database not initialized', edgeId: null });\n297:     return null;\n298:   }\n299:   const database = db;\n300: \n301:   // NFR-R01: Auto edges capped at MAX_AUTO_STRENGTH\n302:   const effectiveStrength = isAutoEdgeCreator(createdBy)\n303:     ? Math.min(strength, MAX_AUTO_STRENGTH)\n304:     : strength;\n305: \n306:   // Prevent self-loops\n307:   if (sourceId === targetId) {\n308:     setLastInsertEdgeOutcome({ status: 'skipped', reason: 'self-loop', edgeId: null });\n309:     return null;\n310:   }\n311: \n312:   // FK check deferred — test environments use synthetic IDs not in memory_index.\n313:   // Implementing FK validation would require seeding memory_index in 20+ causal edge tests.\n314: \n315:   // NFR-R01: Edge bounds — reject if node already has MAX_EDGES_PER_NODE auto edges\n316:   if (isAutoEdgeCreator(createdBy)) {\n317:     const edgeCount = countEdgesForNode(sourceId);\n318:     if (edgeCount >= MAX_EDGES_PER_NODE) {\n319:       console.warn(`[causal-edges] Edge bounds: node ${sourceId} has ${edgeCount} edges (max ${MAX_EDGES_PER_NODE}), rejecting auto edge`);\n320:       setLastInsertEdgeOutcome({ status: 'skipped', reason: 'edge bounds exceeded', edgeId: null });\n\n(Showing lines 1-320 of 1216. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Edges\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Causal relationship graph for memory lineage\nimport type Database from 'better-sqlite3';\nimport { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { detectContradictions } from '../graph/contradiction-detection.js';\nimport { ensureTemporalColumns } from '../graph/temporal-edges.js';\nimport { isTemporalEdgesEnabled } from '../search/search-flags.js';\nimport { runInTransaction } from './transaction-manager.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\nimport type { CausalEdgeSweepResult } from '../causal/sweep.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Edges\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Causal relationship graph for memory lineage\nimport type Database from 'better-sqlite3';\nimport { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { detectContradictions } from '../graph/contradiction-detection.js';\nimport { ensureTemporalColumns } from '../graph/temporal-edges.js';\nimport { isTemporalEdgesEnabled } from '../search/search-flags.js';\nimport { runInTransaction } from './transaction-manager.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration, getCausalEdgesGeneration } from './causal-generation.js';\nimport type { CausalEdgeSweepResult } from '../causal/sweep.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst RELATION_TYPES = Object.freeze({\n  CAUSED: 'caused',\n  ENABLED: 'enabled',\n  SUPERSEDES: 'supersedes',\n  CONTRADICTS: 'contradicts',\n  DERIVED_FROM: 'derived_from',\n  SUPPORTS: 'supports',\n} as const);\n\ntype RelationType = typeof RELATION_TYPES[keyof typeof RELATION_TYPES];\n\n/**\n * C138: Relation weight multipliers applied during traversal scoring.\n * Higher values amplify the propagated strength; values < 1.0 dampen it.\n */\nconst RELATION_WEIGHTS: Record<string, number> = {\n  supersedes:   1.5,  // Strongest signal — new info replaces old\n  caused:       1.3,  // Strong causal link\n  enabled:      1.1,  // Weak causal link\n  supports:     1.0,  // Neutral / default\n  derived_from: 1.0,  // Neutral / default\n  contradicts:  0.8,  // Dampened — conflicting signals lower confidence\n};\n\nconst DEFAULT_MAX_DEPTH = 3;\nconst MAX_EDGES_LIMIT = 100;\n\n// Edge bounds for the lightweight runtime path (NFR-R01, SC-005)\nconst MAX_EDGES_PER_NODE = 20;\nconst MAX_AUTO_STRENGTH = 0.5;\nconst MAX_STRENGTH_INCREASE_PER_CYCLE = 0.05;\nconst WINDOW_MS = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_WINDOW_MS', 15 * 60 * 1000);\nconst CAP_PER_WINDOW = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_CAP_PER_WINDOW', 100);\nconst STALENESS_THRESHOLD_DAYS = 90;\nconst DECAY_STRENGTH_AMOUNT = 0.1;\nconst DECAY_PERIOD_DAYS = 30;\n\nfunction parsePositiveIntegerEnv(name: string, fallback: number): number {\n  const value = process.env[name];\n  if (!value) return fallback;\n  const parsed = Number.parseInt(value, 10);\n  return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isFiniteNumber(value: unknown): value is number {\n  return typeof value === 'number' && Number.isFinite(value);\n}\n\n/**\n * Classify edge provenance as automatic. Covers the legacy 'auto' creator and\n * namespaced automatic creators such as 'auto-session'. Shared by the insert\n * cap path and the consolidation strengthening cap so the two sites cannot\n * drift. Non-auto values ('manual', 'automatic', 'author') must not match.\n */\nfunction isAutoEdgeCreator(createdBy: string | null | undefined): boolean {\n  return createdBy === 'auto'\n    || (typeof createdBy === 'string' && createdBy.startsWith('auto-'));\n}\n\nfunction clampStrength(strength: number): number | null {\n  if (!Number.isFinite(strength)) return null;\n  return Math.max(0, Math.min(1, strength));\n}\n\nfunction normalizeCausalEdgeRow(row: Record<string, unknown>): CausalEdge {\n  return {\n    id: Number(row.id),\n    source_id: String(row.source_id),\n    target_id: String(row.target_id),\n    source_anchor: row.source_anchor == null ? null : String(row.source_anchor),\n    target_anchor: row.target_anchor == null ? null : String(row.target_anchor),\n    relation: String(row.relation) as RelationType,\n    strength: Number(row.strength),\n    evidence: row.evidence == null ? null : String(row.evidence),\n    extracted_at: String(row.extracted_at),\n    created_by: String(row.created_by ?? 'manual'),\n    last_accessed: row.last_accessed == null ? null : String(row.last_accessed),\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface CausalEdge {\n  id: number;\n  source_id: string;\n  target_id: string;\n  source_anchor: string | null;\n  target_anchor: string | null;\n  relation: RelationType;\n  strength: number;\n  evidence: string | null;\n  extracted_at: string;\n  created_by: string;\n  last_accessed: string | null;\n}\n\ninterface CausalEdgeRow extends Record<string, unknown> {\n  id: number;\n  source_id: string;\n  target_id: string;\n  source_anchor?: string | null;\n  target_anchor?: string | null;\n  relation: RelationType;\n  strength: number;\n  evidence: string | null;\n  extracted_at: string;\n  created_by: string;\n  last_accessed: string | null;\n}\n\ntype EdgeQueryResult = CausalEdge[] & {\n  truncated: boolean;\n  limit: number;\n};\n\ninterface WeightHistoryEntry {\n  id: number;\n  edge_id: number;\n  old_strength: number;\n  new_strength: number;\n  changed_by: string;\n  changed_at: string;\n  reason: string | null;\n}\n\ninterface GraphStats {\n  totalEdges: number;\n  byRelation: Record<string, number>;\n  avgStrength: number;\n  uniqueSources: number;\n  uniqueTargets: number;\n}\n\ninterface DeleteEdgeOptions {\n  reason?: string;\n  command?: string;\n  restoreContext?: Record<string, unknown>;\n}\n\ninterface InsertEdgeMetadataOptions {\n  confidence?: number;\n  extractionMethod?: string;\n}\n\ninterface InsertEdgeOutcome {\n  status: 'inserted' | 'updated' | 'skipped';\n  reason: string | null;\n  edgeId: number | null;\n}\n\ninterface CausalChainNode {\n  id: string;\n  edgeId?: number;          // Preserve causal_edges.id for unlink workflow\n  depth: number;\n  relation: RelationType;\n  strength: number;\n  children: CausalChainNode[];\n  truncated?: boolean;\n  truncationLimit?: number | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet lastInsertEdgeOutcome: InsertEdgeOutcome | null = null;\n\n/**\n * Monotonically-increasing generation counter bumped on every causal-edge\n * mutation (insert/update/delete/rollback). Read-only callers can include this\n * value in cache keys (e.g. memory_search when `enableCausalBoost=true`) so\n * cached responses derived from the causal graph become stale on the next\n * lookup without requiring a wholesale tool-cache invalidation.\n *\n * targeted memory_search cache invalidation.\n */\n// Counter lives in causal-generation.ts so the tombstone sweep (which this\n// module imports) can bump it without a circular import.\n\nfunction setLastInsertEdgeOutcome(outcome: InsertEdgeOutcome): void {\n  lastInsertEdgeOutcome = outcome;\n}\n\nfunction getLastInsertEdgeOutcome(): InsertEdgeOutcome | null {\n  return lastInsertEdgeOutcome;\n}\n\nfunction invalidateDegreeCache(): void {\n  // bump the causal-edges generation FIRST so any cache key that\n  // includes it (e.g. memory_search when enableCausalBoost=true) becomes\n  // stale on the next read without invalidating unrelated tool entries.\n  bumpCausalEdgesGeneration();\n\n  try {\n    // Use db-specific cache invalidation instead of the no-op global version\n    if (db) {\n      clearDegreeCacheForDb(db);\n    }\n  } catch (_error: unknown) {\n    // Cache invalidation is best-effort; never block edge mutations\n  }\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signals cache invalidation is best-effort\n  }\n}\n\nfunction enforceRelationWindowCap(\n  relation: string,\n  database: Database.Database,\n  windowMs: number = WINDOW_MS,\n  capPerWindow: number = CAP_PER_WINDOW,\n): boolean {\n  try {\n    const windowStart = new Date(Date.now() - windowMs).toISOString();\n    const row = (database.prepare(`\n      SELECT COUNT(*) as count FROM causal_edges\n      WHERE relation = ?\n        AND datetime(extracted_at) >= datetime(?)\n    `) as Database.Statement).get(relation, windowStart) as { count: number };\n    const count = row.count;\n    if (count >= capPerWindow) {\n      console.warn(`[causal-edges] cap exceeded for relation ${relation}: ${count}/${capPerWindow} in ${windowMs}ms window`);\n      return false;\n    }\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] relation cap check failed for ${relation}: ${msg}`);\n    return true;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. INITIALIZATION\n----------------------------------------------------------------*/\n\nfunction init(database: Database.Database): void {\n  db = database;\n\n  // Defensive traversal indexes — the canonical creation lives in\n  // Vector-index-impl.ts migration v8. These IF NOT EXISTS guards\n  // Ensure the indexes are present even when the module is initialised outside\n  // The normal migration path (e.g. tests, standalone scripts).\n  try {\n    database.exec('CREATE INDEX IF NOT EXISTS idx_causal_source ON causal_edges(source_id)');\n    database.exec('CREATE INDEX IF NOT EXISTS idx_causal_target ON causal_edges(target_id)');\n    ensureTemporalColumns(database);\n  } catch (_e: unknown) {\n    // Best-effort: table may not exist yet during early startup sequencing\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. EDGE OPERATIONS\n----------------------------------------------------------------*/\n\nfunction insertEdge(\n  sourceId: string,\n  targetId: string,\n  relation: RelationType,\n  strength: number = 1.0,\n  evidence: string | null = null,\n  shouldInvalidateCache: boolean = true,\n  createdBy: string = 'manual',\n  anchors: { sourceAnchor?: string | null; targetAnchor?: string | null } = {},\n  metadata: InsertEdgeMetadataOptions = {},\n): number | null {\n  lastInsertEdgeOutcome = null;\n  if (!db) {\n    console.warn('[causal-edges] Database not initialized. Server may still be starting up.');\n    setLastInsertEdgeOutcome({ status: 'skipped', reason: 'database not initialized', edgeId: null });\n    return null;\n  }\n  const database = db;\n\n  // NFR-R01: Auto edges capped at MAX_AUTO_STRENGTH\n  const effectiveStrength = isAutoEdgeCreator(createdBy)\n    ? Math.min(strength, MAX_AUTO_STRENGTH)\n    : strength;\n\n  // Prevent self-loops\n  if (sourceId === targetId) {\n    setLastInsertEdgeOutcome({ status: 'skipped', reason: 'self-loop', edgeId: null });\n    return null;\n  }\n\n  // FK check deferred — test environments use synthetic IDs not in memory_index.\n  // Implementing FK validation would require seeding memory_index in 20+ causal edge tests.\n\n  // NFR-R01: Edge bounds — reject if node already has MAX_EDGES_PER_NODE auto edges\n  if (isAutoEdgeCreator(createdBy)) {\n    const edgeCount = countEdgesForNode(sourceId);\n    if (edgeCount >= MAX_EDGES_PER_NODE) {\n      console.warn(`[causal-edges] Edge bounds: node ${sourceId} has ${edgeCount} edges (max ${MAX_EDGES_PER_NODE}), rejecting auto edge`);\n      setLastInsertEdgeOutcome({ status: 'skipped', reason: 'edge bounds exceeded', edgeId: null });","lineStart":1,"lineEnd":320,"totalLines":1216,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","time":{"start":1781761555722,"end":1781761555727}},"metadata":{"openai":{"itemId":"fc_0379653e1361df95016a3386131a148191beea3ffe04fbc4eb"}},"id":"prt_ed943bcb20012gDVZuMMRlBIh6","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed943870e001i5qJ98c8GRiSJs"}}
{"type":"tool_use","timestamp":1781761555775,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_O0l0eliHZUz7WBK31qFyWDB3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Causal Graph\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    0. DEPENDENCIES\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: // Lib modules\n10: import * as vectorIndex from '../lib/search/vector-index.js';\n11: import * as causalEdges from '../lib/storage/causal-edges.js';\n12: import type { CausalChainNode, CausalEdge } from '../lib/storage/causal-edges.js';\n13: import { buildRelationCoverageState } from '../lib/causal/relation-coverage.js';\n14: import { backfillRelationInference } from '../lib/causal/relation-backfill.js';\n15: \n16: // Core utilities\n17: import { checkDatabaseUpdated } from '../core/index.js';\n18: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n19: import { toErrorMessage } from '../utils/index.js';\n20: import { ErrorCodes, getRecoveryHint } from '../lib/errors.js';\n21: \n22: // Standardized response structure\n23: import { createMCPSuccessResponse, createMCPErrorResponse, createMCPEmptyResponse } from '../lib/response/envelope.js';\n24: \n25: // Governed retrieval scope (tenant/user/agent boundary — sessionId is NOT a boundary)\n26: import { createScopeFilterPredicate } from '../lib/governance/scope-governance.js';\n27: \n28: // Shared handler types\n29: import type { MCPResponse } from './types.js';\n30: \n31: // Shared post-mutation cache invalidation. A causal edge change alters graph\n32: // signals, node degree, and co-activation, so the graph-structure caches must be\n33: // cleared on link/unlink — otherwise they stay stale until their ~60s TTL.\n34: import { runPostMutationHooks } from './mutation-hooks.js';\n35: \n36: // Feature catalog: Causal graph statistics (memory_causal_stats)\n37: // Feature catalog: Causal chain tracing (memory_drift_why)\n38: \n39: \n40: /* ───────────────────────────────────────────────────────────────\n41:    1. TYPES\n42: ──────────────────────────────────────────────────────────────── */\n43: \n44: /** Flat edge representation for API responses */\n45: export interface FlatEdge {\n46:   id: number;               // causal_edges.id for unlink workflow\n47:   from: string;\n48:   to: string;\n49:   relation: string;\n50:   strength: number;\n51:   depth: number;\n52:   direction: 'incoming' | 'outgoing';\n53: }\n54: \n55: /** Flattened chain produced from CausalChainNode tree */\n56: export interface FlattenedChain {\n57:   all: FlatEdge[];\n58:   by_cause: FlatEdge[];\n59:   by_enabled: FlatEdge[];\n60:   by_supersedes: FlatEdge[];\n61:   by_contradicts: FlatEdge[];\n62:   by_derived_from: FlatEdge[];\n63:   by_supports: FlatEdge[];\n64:   total_edges: number;\n65:   max_depth_reached: boolean;\n66:   truncated: boolean;\n67:   truncation_limit: number | null;\n68: }\n69: \n70: interface DirectionalBuckets {\n71:   caused: FlatEdge[];\n72:   enabled: FlatEdge[];\n73:   supersedes: FlatEdge[];\n74:   contradicts: FlatEdge[];\n75:   derivedFrom: FlatEdge[];\n76:   supports: FlatEdge[];\n77:   allEdges: FlatEdge[];\n78:   totalEdges: number;\n79:   maxDepthReached: boolean;\n80:   truncated: boolean;\n81:   truncationLimit: number | null;\n82: }\n83: \n84: interface DriftWhyArgs {\n85:   memoryId: string | number;\n86:   maxDepth?: number;\n87:   direction?: string;\n88:   relations?: string[] | null;\n89:   includeMemoryDetails?: boolean;\n90:   // Optional governed retrieval scope. When supplied, traversal results are\n91:   // post-filtered so a caller cannot trace chains for out-of-scope memories.\n92:   tenantId?: string;\n93:   userId?: string;\n94:   agentId?: string;\n95: }\n96: \n97: interface CausalLinkArgs {\n98:   sourceId: string | number;\n99:   targetId: string | number;\n100:   relation: string;\n101:   strength?: number;\n102:   evidence?: string | null;\n103:   // Optional governed retrieval scope. When supplied, both endpoints must exist\n104:   // and match the scope before an edge is created.\n105:   tenantId?: string;\n106:   userId?: string;\n107:   agentId?: string;\n108: }\n109: \n110: interface CausalStatsArgs {\n111:   // Retained for structural compatibility with the tool-layer CausalStatsArgs\n112:   // (tools/types.ts), which the dispatcher passes through parseArgs.\n113:   _?: never;\n114:   /**\n115:    * Optional bounded relation-inference backfill. When present, the handler\n116:    * infers typed causal edges from strong existing signals (spec-document\n117:    * chains + lineage predecessor links) before computing stats. Defaults to a\n118:    * dry run (no writes); pass { dryRun: false } to commit bounded auto edges.\n119:    */\n120:   backfill?: {\n121:     dryRun?: boolean;\n122:     limit?: number;\n123:     actor?: string;\n124:     // OPT-IN collectors (default false): see backfillRelationInference.\n125:     similarity?: boolean;\n126:     contradicts?: boolean;\n127:     similarityThreshold?: number;\n128:   };\n129: }\n130: \n131: interface CausalUnlinkArgs {\n132:   edgeId: number;\n133: }\n134: \n135: type RelationBalance = {\n136:   deltaByRelation: Record<string, number>;\n137:   dominantRelation: string | null;\n138:   dominantRelationShare: number;\n139:   balanceStatus: 'balanced' | 'relation_skewed' | 'insufficient_data';\n140:   remediationHint?: string;\n141:   windowStartedAt: string;\n142: };\n143: \n144: const RELATION_BALANCE_WINDOW_MS = 15 * 60 * 1000;\n145: const RELATION_SKEW_SHARE_THRESHOLD = 0.80;\n146: const RELATION_SKEW_MIN_TOTAL = 50;\n147: const RELATION_INSUFFICIENT_TOTAL = 5;\n148: const VALID_CAUSAL_RELATIONS = Object.values(causalEdges.RELATION_TYPES) as string[];\n149: // Canonical relation vocabulary for zero-filled stats output. Matches RELATION_TYPES;\n150: // `produced`/`cited_by` are not valid edge relations under the schema CHECK and were dropped.\n151: const MEMORY_CAUSAL_OUTPUT_RELATIONS = [\n152:   'supersedes',\n153:   'caused',\n154:   'supports',\n155:   'contradicts',\n156:   'enabled',\n157:   'derived_from',\n158: ] as const;\n159: \n160: function createZeroFilledRelationCounts(seed: Record<string, number> = {}): Record<string, number> {\n161:   const counts: Record<string, number> = {};\n162:   for (const relation of MEMORY_CAUSAL_OUTPUT_RELATIONS) {\n163:     counts[relation] = seed[relation] ?? 0;\n164:   }\n165:   for (const relation of VALID_CAUSAL_RELATIONS) {\n166:     counts[relation] = seed[relation] ?? 0;\n167:   }\n168:   return counts;\n169: }\n170: \n171: function parseEdgeTimestampMs(timestamp: string): number | null {\n172:   const normalized = timestamp.includes('T')\n173:     ? timestamp\n174:     : `${timestamp.replace(' ', 'T')}Z`;\n175:   const parsed = Date.parse(normalized);\n176:   return Number.isFinite(parsed) ? parsed : null;\n177: }\n178: \n179: function computeRelationBalance(\n180:   edges: CausalEdge[],\n181:   windowMs: number = RELATION_BALANCE_WINDOW_MS,\n182: ): RelationBalance {\n183:   const nowMs = Date.now();\n184:   const windowStartMs = nowMs - windowMs;\n185:   const deltaByRelation = createZeroFilledRelationCounts();\n186: \n187:   for (const edge of edges) {\n188:     const edgeMs = parseEdgeTimestampMs(edge.extracted_at);\n189:     if (edgeMs === null || edgeMs < windowStartMs || edgeMs > nowMs) {\n190:       continue;\n191:     }\n192:     if (Object.prototype.hasOwnProperty.call(deltaByRelation, edge.relation)) {\n193:       deltaByRelation[edge.relation] += 1;\n194:     }\n195:   }\n196: \n197:   const entries = Object.entries(deltaByRelation);\n198:   const total = entries.reduce((sum, [, count]) => sum + count, 0);\n199:   const [dominantRelation, dominantCount] = entries.reduce<[string | null, number]>(\n200:     (current, [relation, count]) => count > current[1] ? [relation, count] : current,\n201:     [null, 0],\n202:   );\n203:   const dominantRelationShare = total > 0 ? dominantCount / total : 0;\n204:   const balanceStatus = total < RELATION_INSUFFICIENT_TOTAL\n205:     ? 'insufficient_data'\n206:     : dominantRelationShare >= RELATION_SKEW_SHARE_THRESHOLD && total >= RELATION_SKEW_MIN_TOTAL\n207:       ? 'relation_skewed'\n208:       : 'balanced';\n209: \n210:   const result: RelationBalance = {\n211:     deltaByRelation,\n212:     dominantRelation,\n213:     dominantRelationShare,\n214:     balanceStatus,\n215:     windowStartedAt: new Date(windowStartMs).toISOString(),\n216:   };\n217: \n218:   if (balanceStatus === 'relation_skewed' && dominantRelation === causalEdges.RELATION_TYPES.SUPERSEDES) {\n219:     result.remediationHint = 'prediction-error supersedes burst — review create-record producer';\n220:   }\n221: \n222:   return result;\n223: }\n224: \n225: function readTopUnlinkedRecords(\n226:   db: import('better-sqlite3').Database,\n227:   limit = 5,\n228: ): Array<{ id: number | string; title: string; specFolder: string | null }> {\n229:   try {\n230:     const safeLimit = Math.max(1, Math.min(20, Math.floor(limit)));\n231:     return (db.prepare(`\n232:       SELECT id, COALESCE(title, file_path, CAST(id AS TEXT)) AS title, spec_folder AS specFolder\n233:       FROM memory_index m\n234:       WHERE NOT EXISTS (\n235:         SELECT 1 FROM causal_edges ce\n236:         WHERE ce.source_id = CAST(m.id AS TEXT)\n237:            OR ce.target_id = CAST(m.id AS TEXT)\n238:       )\n239:       ORDER BY COALESCE(importance_weight, 0) DESC, updated_at DESC, id DESC\n240:       LIMIT ?\n241:     `) as import('better-sqlite3').Statement).all(safeLimit) as Array<{ id: number | string; title: string; specFolder: string | null }>;\n242:   } catch {\n243:     return [];\n244:   }\n245: }\n246: \n247: function logCausalHandlerError(tool: string, error: unknown): void {\n248:   const message = error instanceof Error ? error.message : String(error);\n249:   console.error(`[${tool}] ${message}`);\n250: }\n251: \n252: function createSanitizedCausalError(\n253:   tool: 'memory_drift_why' | 'memory_causal_link' | 'memory_causal_stats' | 'memory_causal_unlink',\n254:   error: unknown,\n255:   code: string,\n256:   details: Record<string, unknown>,\n257:   startTime: number,\n258:   publicMessage: string,\n259: ): MCPResponse {\n260:   logCausalHandlerError(tool, error);\n261:   return createMCPErrorResponse({\n262:     tool,\n263:     error: publicMessage,\n264:     code,\n265:     details,\n266:     recovery: getRecoveryHint(tool, code),\n267:     startTime,\n268:   });\n269: }\n270: \n271: /* ───────────────────────────────────────────────────────────────\n272:    2. TREE-TO-FLAT CONVERTER\n273: ──────────────────────────────────────────────────────────────── */\n274: \n275: /**\n276:  * Flatten a CausalChainNode tree into flat edge lists grouped by relation.\n277:  * The tree from getCausalChain() encodes parent→child relationships;\n278:  * for 'forward' direction: parent=source, child=target.\n279:  * For 'backward' direction: parent=target, child=source.\n280:  */\n281: function flattenCausalTree(\n282:   root: CausalChainNode,\n283:   maxDepth: number,\n284:   direction: 'forward' | 'backward'\n285: ): FlattenedChain {\n286:   const edgeDirection = direction === 'forward' ? 'outgoing' : 'incoming';\n287:   const result: FlattenedChain = {\n288:     all: [],\n289:     by_cause: [],\n290:     by_enabled: [],\n291:     by_supersedes: [],\n292:     by_contradicts: [],\n293:     by_derived_from: [],\n294:     by_supports: [],\n295:     total_edges: 0,\n296:     max_depth_reached: false,\n297:     truncated: Boolean(root.truncated),\n298:     truncation_limit: root.truncationLimit ?? null,\n299:   };\n300: \n301:   function traverse(node: CausalChainNode): void {\n302:     for (const child of node.children) {\n303:       const edge: FlatEdge = {\n304:         id: child.edgeId ?? 0,          // Edge ID from storage layer\n305:         from: direction === 'forward' ? node.id : child.id,\n306:         to: direction === 'forward' ? child.id : node.id,\n307:         relation: child.relation,\n308:         strength: child.strength,\n309:         depth: child.depth,\n310:         direction: edgeDirection,\n311:       };\n312: \n313:       result.all.push(edge);\n314: \n315:       // Group by relation type\n316:       const bucket = relationBucket(child.relation);\n317:       if (bucket) {\n318:         bucket.push(edge);\n319:       }\n320: \n321:       // Only flag max_depth_reached when a node exists at the depth limit.\n322:       // Nodes at maxDepth-1 with no children are natural leaves (edges were queried).\n323:       // Nodes at maxDepth were added but never explored (traverse returned early).\n324:       if (child.depth >= maxDepth) {\n325:         result.max_depth_reached = true;\n326:       }\n327: \n328:       traverse(child);\n329:     }\n330:   }\n331: \n332:   function relationBucket(relation: string): FlatEdge[] | null {\n333:     switch (relation) {\n334:       case 'caused': return result.by_cause;\n335:       case 'enabled': return result.by_enabled;\n336:       case 'supersedes': return result.by_supersedes;\n337:       case 'contradicts': return result.by_contradicts;\n338:       case 'derived_from': return result.by_derived_from;\n339:       case 'supports': return result.by_supports;\n340:       default: return null;\n341:     }\n342:   }\n343: \n344:   traverse(root);\n345:   result.total_edges = result.all.length;\n346:   return result;\n347: }\n348: \n349: /**\n350:  * Merge two flattened chains (used for 'both' direction).\n351:  * Deduplicates edges by direction+from+to+relation key.\n352:  */\n353: function mergeFlattenedChains(a: FlattenedChain, b: FlattenedChain): FlattenedChain {\n354:   const seen = new Set<string>();\n355:   const merged: FlattenedChain = {\n356:     all: [],\n357:     by_cause: [],\n358:     by_enabled: [],\n359:     by_supersedes: [],\n360:     by_contradicts: [],\n\n(Showing lines 1-360 of 1218. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Causal Graph\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   0. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\n// Lib modules\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport type { CausalChainNode, CausalEdge } from '../lib/storage/causal-edges.js';\nimport { buildRelationCoverageState } from '../lib/causal/relation-coverage.js';\nimport { backfillRelationInference } from '../lib/causal/relation-backfill.js';\n\n// Core utilities\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { ErrorCodes, getRecoveryHint } from '../lib/errors.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Causal Graph\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   0. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\n// Lib modules\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport type { CausalChainNode, CausalEdge } from '../lib/storage/causal-edges.js';\nimport { buildRelationCoverageState } from '../lib/causal/relation-coverage.js';\nimport { backfillRelationInference } from '../lib/causal/relation-backfill.js';\n\n// Core utilities\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { ErrorCodes, getRecoveryHint } from '../lib/errors.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse, createMCPEmptyResponse } from '../lib/response/envelope.js';\n\n// Governed retrieval scope (tenant/user/agent boundary — sessionId is NOT a boundary)\nimport { createScopeFilterPredicate } from '../lib/governance/scope-governance.js';\n\n// Shared handler types\nimport type { MCPResponse } from './types.js';\n\n// Shared post-mutation cache invalidation. A causal edge change alters graph\n// signals, node degree, and co-activation, so the graph-structure caches must be\n// cleared on link/unlink — otherwise they stay stale until their ~60s TTL.\nimport { runPostMutationHooks } from './mutation-hooks.js';\n\n// Feature catalog: Causal graph statistics (memory_causal_stats)\n// Feature catalog: Causal chain tracing (memory_drift_why)\n\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/** Flat edge representation for API responses */\nexport interface FlatEdge {\n  id: number;               // causal_edges.id for unlink workflow\n  from: string;\n  to: string;\n  relation: string;\n  strength: number;\n  depth: number;\n  direction: 'incoming' | 'outgoing';\n}\n\n/** Flattened chain produced from CausalChainNode tree */\nexport interface FlattenedChain {\n  all: FlatEdge[];\n  by_cause: FlatEdge[];\n  by_enabled: FlatEdge[];\n  by_supersedes: FlatEdge[];\n  by_contradicts: FlatEdge[];\n  by_derived_from: FlatEdge[];\n  by_supports: FlatEdge[];\n  total_edges: number;\n  max_depth_reached: boolean;\n  truncated: boolean;\n  truncation_limit: number | null;\n}\n\ninterface DirectionalBuckets {\n  caused: FlatEdge[];\n  enabled: FlatEdge[];\n  supersedes: FlatEdge[];\n  contradicts: FlatEdge[];\n  derivedFrom: FlatEdge[];\n  supports: FlatEdge[];\n  allEdges: FlatEdge[];\n  totalEdges: number;\n  maxDepthReached: boolean;\n  truncated: boolean;\n  truncationLimit: number | null;\n}\n\ninterface DriftWhyArgs {\n  memoryId: string | number;\n  maxDepth?: number;\n  direction?: string;\n  relations?: string[] | null;\n  includeMemoryDetails?: boolean;\n  // Optional governed retrieval scope. When supplied, traversal results are\n  // post-filtered so a caller cannot trace chains for out-of-scope memories.\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n}\n\ninterface CausalLinkArgs {\n  sourceId: string | number;\n  targetId: string | number;\n  relation: string;\n  strength?: number;\n  evidence?: string | null;\n  // Optional governed retrieval scope. When supplied, both endpoints must exist\n  // and match the scope before an edge is created.\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n}\n\ninterface CausalStatsArgs {\n  // Retained for structural compatibility with the tool-layer CausalStatsArgs\n  // (tools/types.ts), which the dispatcher passes through parseArgs.\n  _?: never;\n  /**\n   * Optional bounded relation-inference backfill. When present, the handler\n   * infers typed causal edges from strong existing signals (spec-document\n   * chains + lineage predecessor links) before computing stats. Defaults to a\n   * dry run (no writes); pass { dryRun: false } to commit bounded auto edges.\n   */\n  backfill?: {\n    dryRun?: boolean;\n    limit?: number;\n    actor?: string;\n    // OPT-IN collectors (default false): see backfillRelationInference.\n    similarity?: boolean;\n    contradicts?: boolean;\n    similarityThreshold?: number;\n  };\n}\n\ninterface CausalUnlinkArgs {\n  edgeId: number;\n}\n\ntype RelationBalance = {\n  deltaByRelation: Record<string, number>;\n  dominantRelation: string | null;\n  dominantRelationShare: number;\n  balanceStatus: 'balanced' | 'relation_skewed' | 'insufficient_data';\n  remediationHint?: string;\n  windowStartedAt: string;\n};\n\nconst RELATION_BALANCE_WINDOW_MS = 15 * 60 * 1000;\nconst RELATION_SKEW_SHARE_THRESHOLD = 0.80;\nconst RELATION_SKEW_MIN_TOTAL = 50;\nconst RELATION_INSUFFICIENT_TOTAL = 5;\nconst VALID_CAUSAL_RELATIONS = Object.values(causalEdges.RELATION_TYPES) as string[];\n// Canonical relation vocabulary for zero-filled stats output. Matches RELATION_TYPES;\n// `produced`/`cited_by` are not valid edge relations under the schema CHECK and were dropped.\nconst MEMORY_CAUSAL_OUTPUT_RELATIONS = [\n  'supersedes',\n  'caused',\n  'supports',\n  'contradicts',\n  'enabled',\n  'derived_from',\n] as const;\n\nfunction createZeroFilledRelationCounts(seed: Record<string, number> = {}): Record<string, number> {\n  const counts: Record<string, number> = {};\n  for (const relation of MEMORY_CAUSAL_OUTPUT_RELATIONS) {\n    counts[relation] = seed[relation] ?? 0;\n  }\n  for (const relation of VALID_CAUSAL_RELATIONS) {\n    counts[relation] = seed[relation] ?? 0;\n  }\n  return counts;\n}\n\nfunction parseEdgeTimestampMs(timestamp: string): number | null {\n  const normalized = timestamp.includes('T')\n    ? timestamp\n    : `${timestamp.replace(' ', 'T')}Z`;\n  const parsed = Date.parse(normalized);\n  return Number.isFinite(parsed) ? parsed : null;\n}\n\nfunction computeRelationBalance(\n  edges: CausalEdge[],\n  windowMs: number = RELATION_BALANCE_WINDOW_MS,\n): RelationBalance {\n  const nowMs = Date.now();\n  const windowStartMs = nowMs - windowMs;\n  const deltaByRelation = createZeroFilledRelationCounts();\n\n  for (const edge of edges) {\n    const edgeMs = parseEdgeTimestampMs(edge.extracted_at);\n    if (edgeMs === null || edgeMs < windowStartMs || edgeMs > nowMs) {\n      continue;\n    }\n    if (Object.prototype.hasOwnProperty.call(deltaByRelation, edge.relation)) {\n      deltaByRelation[edge.relation] += 1;\n    }\n  }\n\n  const entries = Object.entries(deltaByRelation);\n  const total = entries.reduce((sum, [, count]) => sum + count, 0);\n  const [dominantRelation, dominantCount] = entries.reduce<[string | null, number]>(\n    (current, [relation, count]) => count > current[1] ? [relation, count] : current,\n    [null, 0],\n  );\n  const dominantRelationShare = total > 0 ? dominantCount / total : 0;\n  const balanceStatus = total < RELATION_INSUFFICIENT_TOTAL\n    ? 'insufficient_data'\n    : dominantRelationShare >= RELATION_SKEW_SHARE_THRESHOLD && total >= RELATION_SKEW_MIN_TOTAL\n      ? 'relation_skewed'\n      : 'balanced';\n\n  const result: RelationBalance = {\n    deltaByRelation,\n    dominantRelation,\n    dominantRelationShare,\n    balanceStatus,\n    windowStartedAt: new Date(windowStartMs).toISOString(),\n  };\n\n  if (balanceStatus === 'relation_skewed' && dominantRelation === causalEdges.RELATION_TYPES.SUPERSEDES) {\n    result.remediationHint = 'prediction-error supersedes burst — review create-record producer';\n  }\n\n  return result;\n}\n\nfunction readTopUnlinkedRecords(\n  db: import('better-sqlite3').Database,\n  limit = 5,\n): Array<{ id: number | string; title: string; specFolder: string | null }> {\n  try {\n    const safeLimit = Math.max(1, Math.min(20, Math.floor(limit)));\n    return (db.prepare(`\n      SELECT id, COALESCE(title, file_path, CAST(id AS TEXT)) AS title, spec_folder AS specFolder\n      FROM memory_index m\n      WHERE NOT EXISTS (\n        SELECT 1 FROM causal_edges ce\n        WHERE ce.source_id = CAST(m.id AS TEXT)\n           OR ce.target_id = CAST(m.id AS TEXT)\n      )\n      ORDER BY COALESCE(importance_weight, 0) DESC, updated_at DESC, id DESC\n      LIMIT ?\n    `) as import('better-sqlite3').Statement).all(safeLimit) as Array<{ id: number | string; title: string; specFolder: string | null }>;\n  } catch {\n    return [];\n  }\n}\n\nfunction logCausalHandlerError(tool: string, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  console.error(`[${tool}] ${message}`);\n}\n\nfunction createSanitizedCausalError(\n  tool: 'memory_drift_why' | 'memory_causal_link' | 'memory_causal_stats' | 'memory_causal_unlink',\n  error: unknown,\n  code: string,\n  details: Record<string, unknown>,\n  startTime: number,\n  publicMessage: string,\n): MCPResponse {\n  logCausalHandlerError(tool, error);\n  return createMCPErrorResponse({\n    tool,\n    error: publicMessage,\n    code,\n    details,\n    recovery: getRecoveryHint(tool, code),\n    startTime,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. TREE-TO-FLAT CONVERTER\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Flatten a CausalChainNode tree into flat edge lists grouped by relation.\n * The tree from getCausalChain() encodes parent→child relationships;\n * for 'forward' direction: parent=source, child=target.\n * For 'backward' direction: parent=target, child=source.\n */\nfunction flattenCausalTree(\n  root: CausalChainNode,\n  maxDepth: number,\n  direction: 'forward' | 'backward'\n): FlattenedChain {\n  const edgeDirection = direction === 'forward' ? 'outgoing' : 'incoming';\n  const result: FlattenedChain = {\n    all: [],\n    by_cause: [],\n    by_enabled: [],\n    by_supersedes: [],\n    by_contradicts: [],\n    by_derived_from: [],\n    by_supports: [],\n    total_edges: 0,\n    max_depth_reached: false,\n    truncated: Boolean(root.truncated),\n    truncation_limit: root.truncationLimit ?? null,\n  };\n\n  function traverse(node: CausalChainNode): void {\n    for (const child of node.children) {\n      const edge: FlatEdge = {\n        id: child.edgeId ?? 0,          // Edge ID from storage layer\n        from: direction === 'forward' ? node.id : child.id,\n        to: direction === 'forward' ? child.id : node.id,\n        relation: child.relation,\n        strength: child.strength,\n        depth: child.depth,\n        direction: edgeDirection,\n      };\n\n      result.all.push(edge);\n\n      // Group by relation type\n      const bucket = relationBucket(child.relation);\n      if (bucket) {\n        bucket.push(edge);\n      }\n\n      // Only flag max_depth_reached when a node exists at the depth limit.\n      // Nodes at maxDepth-1 with no children are natural leaves (edges were queried).\n      // Nodes at maxDepth were added but never explored (traverse returned early).\n      if (child.depth >= maxDepth) {\n        result.max_depth_reached = true;\n      }\n\n      traverse(child);\n    }\n  }\n\n  function relationBucket(relation: string): FlatEdge[] | null {\n    switch (relation) {\n      case 'caused': return result.by_cause;\n      case 'enabled': return result.by_enabled;\n      case 'supersedes': return result.by_supersedes;\n      case 'contradicts': return result.by_contradicts;\n      case 'derived_from': return result.by_derived_from;\n      case 'supports': return result.by_supports;\n      default: return null;\n    }\n  }\n\n  traverse(root);\n  result.total_edges = result.all.length;\n  return result;\n}\n\n/**\n * Merge two flattened chains (used for 'both' direction).\n * Deduplicates edges by direction+from+to+relation key.\n */\nfunction mergeFlattenedChains(a: FlattenedChain, b: FlattenedChain): FlattenedChain {\n  const seen = new Set<string>();\n  const merged: FlattenedChain = {\n    all: [],\n    by_cause: [],\n    by_enabled: [],\n    by_supersedes: [],\n    by_contradicts: [],","lineStart":1,"lineEnd":360,"totalLines":1218,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","time":{"start":1781761555769,"end":1781761555773}},"metadata":{"openai":{"itemId":"fc_0379653e1361df95016a3386131a1c8191ae54a42981ce75a3"}},"id":"prt_ed943bd13001kd820A0YTE6q2F","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed943870e001i5qJ98c8GRiSJs"}}
