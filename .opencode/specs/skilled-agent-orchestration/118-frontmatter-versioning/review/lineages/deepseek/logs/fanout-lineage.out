{"type":"tool_use","timestamp":1782211026448,"sessionID":"ses_10bf585eeffeDIFj5xRNnSbPD5","part":{"type":"tool","tool":"read","callID":"call_00_fV8gti3oY3OFW7FA5Oez1069","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/scripts/frontmatter-version.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/scripts/frontmatter-version.mjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ───────────────────────────────────────────────────────────────\n3: // COMPONENT: Frontmatter Versioning Engine\n4: // ───────────────────────────────────────────────────────────────\n5: // Deterministic compute / insert / verify of the 4-part `version`\n6: // frontmatter field for in-scope skill docs.\n7: //\n8: // Standard: .opencode/skills/sk-doc/references/frontmatter_versioning.md\n9: //\n10: // Usage:\n11: //   node frontmatter-version.mjs compute [--skill <name>] [--manifest-out <path>]\n12: //   node frontmatter-version.mjs apply   [--skill <name>] [--paths <file>] [--update]\n13: //   node frontmatter-version.mjs verify  [--skill <name>] [--paths <file>]\n14: //\n15: // compute  : dry-run; writes nothing. Emits a CSV + JSON manifest and a summary.\n16: // apply    : inserts/updates `version` per the idempotency rules.\n17: // verify   : checks every in-scope file's version == computed and frontmatter is intact.\n18: //\n19: // Determinism: same git state + same selection => identical manifest and identical bytes.\n20: // ───────────────────────────────────────────────────────────────\n21: \n22: import fs from 'node:fs';\n23: import path from 'node:path';\n24: import { execFileSync, execFile } from 'node:child_process';\n25: import { promisify } from 'node:util';\n26: import process from 'node:process';\n27: \n28: const execFileP = promisify(execFile);\n29: const GIT_CONCURRENCY = 16;\n30: \n31: /** Run fn over items with a bounded concurrency pool, preserving order. */\n32: async function mapPool(items, limit, fn) {\n33:   const results = new Array(items.length);\n34:   let next = 0;\n35:   async function worker() {\n36:     while (next < items.length) {\n37:       const idx = next;\n38:       next += 1;\n39:       results[idx] = await fn(items[idx], idx);\n40:     }\n41:   }\n42:   await Promise.all(Array.from({ length: Math.min(limit, items.length || 1) }, worker));\n43:   return results;\n44: }\n45: \n46: const VERSION_RE = /^\\d+\\.\\d+\\.\\d+\\.\\d+$/;\n47: const W_CAP = 99;\n48: const EXCLUDED_DIRS = new Set(['changelog', 'scratch', 'node_modules', '.git', 'dist']);\n49: // In-scope doc-class globs under a skill directory (markdown only).\n50: const SCOPE_SUBTREES = ['references', 'assets', 'feature_catalog', 'manual_testing_playbook'];\n51: \n52: // ─── git helpers ───────────────────────────────────────────────\n53: \n54: function repoRoot() {\n55:   return execFileSync('git', ['rev-parse', '--show-toplevel'], { encoding: 'utf8' }).trim();\n56: }\n57: \n58: /**\n59:  * Count commits whose own added+deleted line count for this file is > 0.\n60:  * Traces the path with --follow but gates every commit on per-file numstat,\n61:  * which discards the historical rename + bulk-sweep inflation (3-5x).\n62:  */\n63: async function realEditCount(absFile, root) {\n64:   let out;\n65:   try {\n66:     const res = await execFileP(\n67:       'git',\n68:       ['log', '--follow', '--numstat', '--format=%H', '--', absFile],\n69:       { cwd: root, encoding: 'utf8', maxBuffer: 64 * 1024 * 1024 },\n70:     );\n71:     out = res.stdout;\n72:   } catch {\n73:     return 0; // untracked / no history\n74:   }\n75:   let count = 0;\n76:   let curHasEdit = false;\n77:   let sawCommit = false;\n78:   for (const line of out.split('\\n')) {\n79:     if (/^[0-9a-f]{40}$/.test(line)) {\n80:       if (sawCommit && curHasEdit) count += 1;\n81:       sawCommit = true;\n82:       curHasEdit = false;\n83:       continue;\n84:     }\n85:     const m = line.match(/^(\\d+|-)\\t(\\d+|-)\\t/);\n86:     if (m) {\n87:       const added = m[1] === '-' ? 0 : parseInt(m[1], 10);\n88:       const deleted = m[2] === '-' ? 0 : parseInt(m[2], 10);\n89:       if (added + deleted > 0) curHasEdit = true;\n90:     }\n91:   }\n92:   if (sawCommit && curHasEdit) count += 1; // flush last commit\n93:   return count;\n94: }\n95: \n96: // ─── version helpers ────────────────────────────────────────────\n97: \n98: /** Pad a 1-4 segment version to a 4-int tuple. Never shifts segments. */\n99: function normalize4(v) {\n100:   if (!v) return null;\n101:   const parts = String(v).trim().replace(/^[\"']|[\"']$/g, '').split('.').map((s) => s.trim());\n102:   if (parts.some((p) => !/^\\d+$/.test(p)) || parts.length < 1 || parts.length > 4) return null;\n103:   while (parts.length < 4) parts.push('0');\n104:   return parts.slice(0, 4).map((n) => parseInt(n, 10));\n105: }\n106: \n107: function cmpTuple(a, b) {\n108:   for (let i = 0; i < 4; i += 1) {\n109:     if (a[i] !== b[i]) return a[i] - b[i];\n110:   }\n111:   return 0;\n112: }\n113: \n114: function tupleStr(t) {\n115:   return t.join('.');\n116: }\n117: \n118: // ─── frontmatter parsing ────────────────────────────────────────\n119: \n120: /**\n121:  * Returns { hasFrontmatter, eol, lines, openIdx, closeIdx, versionLineIdx, versionValue }.\n122:  * lines excludes the trailing-newline split artifact handling (caller rejoins with eol).\n123:  */\n124: function parseFrontmatter(content) {\n125:   const eol = content.includes('\\r\\n') ? '\\r\\n' : '\\n';\n126:   const lines = content.split(/\\r?\\n/);\n127:   if (lines[0] !== '---') return { hasFrontmatter: false, eol, lines };\n128:   let closeIdx = -1;\n129:   for (let i = 1; i < lines.length; i += 1) {\n130:     if (lines[i] === '---') { closeIdx = i; break; }\n131:   }\n132:   if (closeIdx === -1) return { hasFrontmatter: false, eol, lines };\n133:   let versionLineIdx = -1;\n134:   let versionValue = null;\n135:   for (let i = 1; i < closeIdx; i += 1) {\n136:     const m = lines[i].match(/^version:\\s*(.+?)\\s*$/);\n137:     if (m) { versionLineIdx = i; versionValue = m[1].replace(/^[\"']|[\"']$/g, ''); break; }\n138:   }\n139:   return { hasFrontmatter: true, eol, lines, openIdx: 0, closeIdx, versionLineIdx, versionValue };\n140: }\n141: \n142: // ─── skill anchor resolution (cached per skill dir) ─────────────\n143: \n144: const anchorCache = new Map();\n145: \n146: /** Walk up from a file to the nearest directory containing SKILL.md (bounded by skills root). */\n147: function findSkillDir(absFile, skillsRoot) {\n148:   let dir = fs.statSync(absFile).isDirectory() ? absFile : path.dirname(absFile);\n149:   while (dir.startsWith(skillsRoot)) {\n150:     if (fs.existsSync(path.join(dir, 'SKILL.md'))) return dir;\n151:     const parent = path.dirname(dir);\n152:     if (parent === dir) break;\n153:     dir = parent;\n154:   }\n155:   return null;\n156: }\n157: \n158: function resolveAnchor(skillDir) {\n159:   if (anchorCache.has(skillDir)) return anchorCache.get(skillDir);\n160:   // frontmatter version\n161:   let fmTuple = null;\n162:   try {\n163:     const skillMd = fs.readFileSync(path.join(skillDir, 'SKILL.md'), 'utf8');\n164:     const fm = parseFrontmatter(skillMd);\n165:     if (fm.hasFrontmatter && fm.versionValue) fmTuple = normalize4(fm.versionValue);\n166:   } catch { /* ignore */ }\n167:   // changelog max\n168:   let clTuple = null;\n169:   const clDir = path.join(skillDir, 'changelog');\n170:   if (fs.existsSync(clDir)) {\n171:     for (const name of fs.readdirSync(clDir)) {\n172:       const m = name.match(/^v(\\d+(?:\\.\\d+){0,3})\\.md$/);\n173:       if (!m) continue;\n174:       const t = normalize4(m[1]);\n175:       if (t && (!clTuple || cmpTuple(t, clTuple) > 0)) clTuple = t;\n176:     }\n177:   }\n178:   let anchor;\n179:   let source;\n180:   if (fmTuple && clTuple) { anchor = cmpTuple(fmTuple, clTuple) >= 0 ? fmTuple : clTuple; source = 'max(fm,changelog)'; }\n181:   else if (clTuple) { anchor = clTuple; source = 'changelog'; }\n182:   else if (fmTuple) { anchor = fmTuple; source = 'frontmatter-only'; }\n183:   else { anchor = [1, 0, 0, 0]; source = 'default'; }\n184:   const result = { anchor, source };\n185:   anchorCache.set(skillDir, result);\n186:   return result;\n187: }\n188: \n189: // ─── file classification + scope discovery ─────────────────────\n190: \n191: function classify(absFile, skillsRoot) {\n192:   const base = path.basename(absFile);\n193:   if (base === 'SKILL.md') return 'skill-md';\n194:   if (base === 'README.md') return 'readme';\n195:   const rel = path.relative(skillsRoot, absFile).split(path.sep);\n196:   // rel = [skill, ...subtree...]; find first in-scope subtree segment\n197:   for (const seg of rel) {\n198:     if (seg === 'references') return 'reference';\n199:     if (seg === 'assets') return 'asset';\n200:     if (seg === 'feature_catalog') return 'feature-catalog';\n201:     if (seg === 'manual_testing_playbook') return 'playbook';\n202:   }\n203:   return null;\n204: }\n205: \n206: /** An in-scope markdown file: SKILL.md anywhere; any file under a scope subtree;\n207:  *  README.md only when adjacent to a SKILL.md (skill or mode-packet root). */\n208: function inScope(absFile, skillsRoot) {\n209:   const base = path.basename(absFile);\n210:   if (base === 'SKILL.md') return true;\n211:   const rel = path.relative(skillsRoot, absFile).split(path.sep);\n212:   for (const seg of rel) {\n213:     if (SCOPE_SUBTREES.includes(seg)) return true;\n214:   }\n215:   if (base === 'README.md') {\n216:     return fs.existsSync(path.join(path.dirname(absFile), 'SKILL.md'));\n217:   }\n218:   return false;\n219: }\n220: \n221: function walkAllMd(dir, acc) {\n222:   for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {\n223:     if (entry.isDirectory()) {\n224:       if (EXCLUDED_DIRS.has(entry.name)) continue;\n225:       walkAllMd(path.join(dir, entry.name), acc);\n226:     } else if (entry.isFile() && entry.name.endsWith('.md')) {\n227:       acc.push(path.join(dir, entry.name));\n228:     }\n229:   }\n230: }\n231: \n232: /** Discover all in-scope markdown files under the skills root (optionally one skill). */\n233: function discoverInScope(skillsRoot, onlySkill) {\n234:   const skills = fs.readdirSync(skillsRoot, { withFileTypes: true })\n235:     .filter((e) => e.isDirectory() && !EXCLUDED_DIRS.has(e.name))\n236:     .filter((e) => !onlySkill || e.name === onlySkill)\n237:     .map((e) => path.join(skillsRoot, e.name));\n238:   const all = [];\n239:   for (const s of skills) walkAllMd(s, all);\n240:   return [...new Set(all.filter((f) => inScope(f, skillsRoot)))].sort();\n241: }\n242: \n243: // ─── compute one file ───────────────────────────────────────────\n244: \n245: async function computeForFile(absFile, skillsRoot, root) {\n246:   const skillDir = findSkillDir(absFile, skillsRoot);\n247:   const skill = skillDir ? path.relative(skillsRoot, skillDir) : 'UNKNOWN';\n248:   const fileClass = classify(absFile, skillsRoot);\n249:   const { anchor, source } = skillDir ? resolveAnchor(skillDir) : { anchor: [1, 0, 0, 0], source: 'default' };\n250:   const base = path.basename(absFile);\n251:   let derived;\n252:   let realEdits = '';\n253:   if (base === 'SKILL.md') {\n254:     derived = anchor;\n255:   } else {\n256:     realEdits = await realEditCount(absFile, root);\n257:     derived = [anchor[0], anchor[1], 0, Math.min(realEdits, W_CAP)];\n258:   }\n259:   return {\n260:     path: path.relative(root, absFile),\n261:     fileClass,\n262:     skill,\n263:     anchor: tupleStr(anchor),\n264:     anchorSource: source,\n265:     realEditCount: realEdits,\n266:     derivedVersion: tupleStr(derived),\n267:     derivedTuple: derived,\n268:     absFile,\n269:   };\n270: }\n271: \n272: // ─── insertion (line-wise, idempotent) ─────────────────────────\n273: \n274: function applyVersion(absFile, derivedStr, opts) {\n275:   const content = fs.readFileSync(absFile, 'utf8');\n276:   const fm = parseFrontmatter(content);\n277:   if (!fm.hasFrontmatter) return 'skip-no-frontmatter';\n278:   if (fm.versionLineIdx !== -1) {\n279:     const rawExisting = fm.versionValue.trim().replace(/^[\"']|[\"']$/g, '');\n280:     if (rawExisting === derivedStr) return 'skip-equal'; // already the canonical 4-part string\n281:     const existing = normalize4(fm.versionValue);\n282:     const sameValue = existing && tupleStr(existing) === derivedStr;\n283:     // A genuinely different VALUE is a conflict — preserve a human-set version unless\n284:     // --update (or SKILL.md reconcile). A same-value-but-non-canonical raw (e.g. a 3-part\n285:     // 1.0.0 that means 1.0.0.0) is always normalized to the canonical 4-part form.\n286:     if (!sameValue && !opts.update && !opts.reconcile) return 'skip-conflict';\n287:     fm.lines[fm.versionLineIdx] = `version: ${derivedStr}`;\n288:   } else {\n289:     // insert as last key, immediately before closing ---\n290:     fm.lines.splice(fm.closeIdx, 0, `version: ${derivedStr}`);\n291:   }\n292:   const trailing = content.endsWith('\\n') ? '' : '';\n293:   let next = fm.lines.join(fm.eol);\n294:   if (content.endsWith('\\n') && !next.endsWith('\\n')) next += fm.eol;\n295:   fs.writeFileSync(absFile, next);\n296:   return fm.versionLineIdx !== -1 ? 'update' : 'insert';\n297: }\n298: \n299: function verifyVersion(absFile, derivedStr) {\n300:   const content = fs.readFileSync(absFile, 'utf8');\n301:   const fm = parseFrontmatter(content);\n302:   if (!fm.hasFrontmatter) return { ok: false, reason: 'no-frontmatter' };\n303:   if (fm.versionLineIdx === -1) return { ok: false, reason: 'missing-version' };\n304:   const existing = normalize4(fm.versionValue);\n305:   if (!existing) return { ok: false, reason: `malformed:${fm.versionValue}` };\n306:   if (tupleStr(existing) !== derivedStr) return { ok: false, reason: `mismatch:${tupleStr(existing)}!=${derivedStr}` };\n307:   // Note: new insertions are placed as the last key (see applyVersion), but a\n308:   // pre-existing version elsewhere in the block is valid — position is an\n309:   // insertion convention, not a correctness invariant. Verify checks value only.\n310:   return { ok: true };\n311: }\n312: \n313: // ─── manifest emit ──────────────────────────────────────────────\n314: \n315: function emitManifest(rows, outBase) {\n316:   const cols = ['path', 'fileClass', 'skill', 'anchor', 'anchorSource', 'realEditCount', 'derivedVersion', 'action'];\n317:   const csv = [cols.join(',')]\n318:     .concat(rows.map((r) => cols.map((c) => csvCell(r[c])).join(',')))\n319:     .join('\\n');\n320:   fs.writeFileSync(`${outBase}.csv`, csv + '\\n');\n321:   fs.writeFileSync(`${outBase}.json`, JSON.stringify(rows.map((r) => {\n322:     const { absFile, derivedTuple, ...rest } = r;\n323:     return rest;\n324:   }), null, 2) + '\\n');\n325: }\n326: \n327: function csvCell(v) {\n328:   const s = String(v ?? '');\n329:   return /[\",\\n]/.test(s) ? `\"${s.replace(/\"/g, '\"\"')}\"` : s;\n330: }\n331: \n332: // ─── main ───────────────────────────────────────────────────────\n333: \n334: function parseArgs(argv) {\n335:   const args = { mode: argv[0], skill: null, paths: null, manifestOut: null, update: false, skillsRoot: null, fromManifest: null, classes: null };\n336:   for (let i = 1; i < argv.length; i += 1) {\n337:     const a = argv[i];\n338:     if (a === '--skill') args.skill = argv[++i];\n339:     else if (a === '--paths') args.paths = argv[++i];\n340:     else if (a === '--manifest-out') args.manifestOut = argv[++i];\n341:     else if (a === '--skills-root') args.skillsRoot = argv[++i];\n342:     else if (a === '--from-manifest') args.fromManifest = argv[++i];\n343:     else if (a === '--classes') args.classes = argv[++i];\n344:     else if (a === '--update') args.update = true;\n345:     else if (a === '--help' || a === '-h') args.mode = 'help';\n346:   }\n347:   return args;\n348: }\n349: \n350: function helpText() {\n351:   return `frontmatter-version.mjs — 4-part version compute/apply/verify\n352: Modes: compute (dry-run), apply, verify\n353: Options: --skill <name>  --paths <file-list>  --manifest-out <base>  --update\n354: Standard: .opencode/skills/sk-doc/references/frontmatter_versioning.md`;\n355: }\n356: \n357: async function main() {\n358:   const args = parseArgs(process.argv.slice(2));\n359:   if (!args.mode || args.mode === 'help') { console.log(helpText()); process.exit(0); }\n360:   const root = repoRoot();\n361:   const skillsRoot = args.skillsRoot ? path.resolve(args.skillsRoot) : path.join(root, '.opencode', 'skills');\n362: \n363:   if (args.mode === 'gate') {\n364:     // Enforcement gate: every in-scope file must carry a 4-part version.\n365:     // Presence + format only — no git, no manifest. Exit 1 if any in-scope doc is missing/malformed.\n366:     const targets = args.fromManifest\n367:       ? JSON.parse(fs.readFileSync(args.fromManifest, 'utf8')).map((m) => (path.isAbsolute(m.path) ? m.path : path.join(root, m.path)))\n368:       : discoverInScope(skillsRoot, args.skill);\n369:     let grows = targets.map((f) => ({ path: path.relative(root, f), absFile: f, fileClass: classify(f, skillsRoot) }));\n370:     if (args.classes) { const set = new Set(args.classes.split(',')); grows = grows.filter((r) => set.has(r.fileClass)); }\n371:     let bad = 0;\n372:     for (const r of grows) {\n373:       const fm = parseFrontmatter(fs.readFileSync(r.absFile, 'utf8'));\n374:       if (!fm.hasFrontmatter) { r.action = 'skip-no-frontmatter'; continue; }\n375:       if (fm.versionLineIdx === -1) { r.action = 'FAIL:missing'; bad += 1; console.error(`  MISSING version: ${r.path}`); continue; }\n376:       if (!VERSION_RE.test(fm.versionValue)) { r.action = 'FAIL:malformed'; bad += 1; console.error(`  MALFORMED version '${fm.versionValue}': ${r.path}`); continue; }\n377:       r.action = 'ok';\n378:     }\n379:     summary('gate', grows, args.manifestOut);\n380:     process.exit(bad > 0 ? 1 : 0);\n381:   }\n382: \n383:   let rows;\n384:   if (args.fromManifest) {\n385:     // Source precomputed versions from a compute manifest (skips git re-computation).\n386:     const man = JSON.parse(fs.readFileSync(args.fromManifest, 'utf8'));\n387:     rows = man.map((m) => ({ ...m, absFile: path.isAbsolute(m.path) ? m.path : path.join(root, m.path), derivedTuple: normalize4(m.derivedVersion) }));\n388:     if (args.skill) rows = rows.filter((r) => r.skill === args.skill || String(r.skill).startsWith(`${args.skill}/`));\n389:   } else {\n390:     let targets;\n391:     if (args.paths) {\n392:       targets = fs.readFileSync(args.paths, 'utf8').split('\\n').map((s) => s.trim()).filter(Boolean)\n393:         .map((p) => (path.isAbsolute(p) ? p : path.join(root, p)));\n394:     } else {\n395:       targets = discoverInScope(skillsRoot, args.skill);\n396:     }\n397:     rows = await mapPool(targets, GIT_CONCURRENCY, (f) => computeForFile(f, skillsRoot, root));\n398:   }\n399:   if (args.classes) {\n400:     const set = new Set(args.classes.split(','));\n401:     rows = rows.filter((r) => set.has(r.fileClass));\n402:   }\n403: \n404:   if (args.mode === 'compute') {\n405:     for (const r of rows) r.action = 'compute';\n406:     const outBase = args.manifestOut || path.join(root, 'frontmatter-version-manifest');\n407:     emitManifest(rows, outBase);\n408:     summary('compute', rows, outBase);\n409:   } else if (args.mode === 'apply') {\n410:     for (const r of rows) {\n411:       r.action = applyVersion(r.absFile, r.derivedVersion, { update: args.update, reconcile: r.fileClass === 'skill-md' });\n412:     }\n413:     if (args.manifestOut) emitManifest(rows, args.manifestOut);\n414:     summary('apply', rows, args.manifestOut);\n415:   } else if (args.mode === 'verify') {\n416:     let failures = 0;\n417:     for (const r of rows) {\n418:       const v = verifyVersion(r.absFile, r.derivedVersion);\n419:       if (v.reason === 'no-frontmatter') { r.action = 'skip-no-frontmatter'; continue; }\n420:       r.action = v.ok ? 'ok' : `FAIL:${v.reason}`;\n421:       if (!v.ok) { failures += 1; console.error(`  FAIL ${r.path} -> ${v.reason} (expected ${r.derivedVersion})`); }\n422:     }\n423:     if (args.manifestOut) emitManifest(rows, args.manifestOut);\n424:     summary('verify', rows, args.manifestOut);\n425:     process.exit(failures > 0 ? 1 : 0);\n426:   } else {\n427:     console.error(`Unknown mode: ${args.mode}`);\n428:     process.exit(64);\n429:   }\n430: }\n431: \n432: function summary(mode, rows, outBase) {\n433:   const byAction = {};\n434:   for (const r of rows) byAction[r.action] = (byAction[r.action] || 0) + 1;\n435:   const parts = Object.entries(byAction).sort().map(([k, v]) => `${k}=${v}`).join('  ');\n436:   console.log(`[${mode}] ${rows.length} files | ${parts}`);\n437:   if (outBase) console.log(`manifest: ${outBase}.csv / ${outBase}.json`);\n438: }\n439: \n440: main().catch((e) => { console.error(e); process.exit(1); });\n\n(End of file - total 440 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// COMPONENT: Frontmatter Versioning Engine\n// ───────────────────────────────────────────────────────────────\n// Deterministic compute / insert / verify of the 4-part `version`\n// frontmatter field for in-scope skill docs.\n//\n// Standard: .opencode/skills/sk-doc/references/frontmatter_versioning.md\n//\n// Usage:\n//   node frontmatter-version.mjs compute [--skill <name>] [--manifest-out <path>]\n//   node frontmatter-version.mjs apply   [--skill <name>] [--paths <file>] [--update]\n//   node frontmatter-version.mjs verify  [--skill <name>] [--paths <file>]\n//\n// compute  : dry-run; writes nothing. Emits a CSV + JSON manifest and a summary.\n// apply    : inserts/updates `version` per the idempotency rules.\n// verify   : checks every in-scope file's version == computed and frontmatter is intact.\n//\n// Determinism: same git state + same selection => identical manifest and identical bytes.\n// ───────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/scripts/frontmatter-version.mjs","text":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// COMPONENT: Frontmatter Versioning Engine\n// ───────────────────────────────────────────────────────────────\n// Deterministic compute / insert / verify of the 4-part `version`\n// frontmatter field for in-scope skill docs.\n//\n// Standard: .opencode/skills/sk-doc/references/frontmatter_versioning.md\n//\n// Usage:\n//   node frontmatter-version.mjs compute [--skill <name>] [--manifest-out <path>]\n//   node frontmatter-version.mjs apply   [--skill <name>] [--paths <file>] [--update]\n//   node frontmatter-version.mjs verify  [--skill <name>] [--paths <file>]\n//\n// compute  : dry-run; writes nothing. Emits a CSV + JSON manifest and a summary.\n// apply    : inserts/updates `version` per the idempotency rules.\n// verify   : checks every in-scope file's version == computed and frontmatter is intact.\n//\n// Determinism: same git state + same selection => identical manifest and identical bytes.\n// ───────────────────────────────────────────────────────────────\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { execFileSync, execFile } from 'node:child_process';\nimport { promisify } from 'node:util';\nimport process from 'node:process';\n\nconst execFileP = promisify(execFile);\nconst GIT_CONCURRENCY = 16;\n\n/** Run fn over items with a bounded concurrency pool, preserving order. */\nasync function mapPool(items, limit, fn) {\n  const results = new Array(items.length);\n  let next = 0;\n  async function worker() {\n    while (next < items.length) {\n      const idx = next;\n      next += 1;\n      results[idx] = await fn(items[idx], idx);\n    }\n  }\n  await Promise.all(Array.from({ length: Math.min(limit, items.length || 1) }, worker));\n  return results;\n}\n\nconst VERSION_RE = /^\\d+\\.\\d+\\.\\d+\\.\\d+$/;\nconst W_CAP = 99;\nconst EXCLUDED_DIRS = new Set(['changelog', 'scratch', 'node_modules', '.git', 'dist']);\n// In-scope doc-class globs under a skill directory (markdown only).\nconst SCOPE_SUBTREES = ['references', 'assets', 'feature_catalog', 'manual_testing_playbook'];\n\n// ─── git helpers ───────────────────────────────────────────────\n\nfunction repoRoot() {\n  return execFileSync('git', ['rev-parse', '--show-toplevel'], { encoding: 'utf8' }).trim();\n}\n\n/**\n * Count commits whose own added+deleted line count for this file is > 0.\n * Traces the path with --follow but gates every commit on per-file numstat,\n * which discards the historical rename + bulk-sweep inflation (3-5x).\n */\nasync function realEditCount(absFile, root) {\n  let out;\n  try {\n    const res = await execFileP(\n      'git',\n      ['log', '--follow', '--numstat', '--format=%H', '--', absFile],\n      { cwd: root, encoding: 'utf8', maxBuffer: 64 * 1024 * 1024 },\n    );\n    out = res.stdout;\n  } catch {\n    return 0; // untracked / no history\n  }\n  let count = 0;\n  let curHasEdit = false;\n  let sawCommit = false;\n  for (const line of out.split('\\n')) {\n    if (/^[0-9a-f]{40}$/.test(line)) {\n      if (sawCommit && curHasEdit) count += 1;\n      sawCommit = true;\n      curHasEdit = false;\n      continue;\n    }\n    const m = line.match(/^(\\d+|-)\\t(\\d+|-)\\t/);\n    if (m) {\n      const added = m[1] === '-' ? 0 : parseInt(m[1], 10);\n      const deleted = m[2] === '-' ? 0 : parseInt(m[2], 10);\n      if (added + deleted > 0) curHasEdit = true;\n    }\n  }\n  if (sawCommit && curHasEdit) count += 1; // flush last commit\n  return count;\n}\n\n// ─── version helpers ────────────────────────────────────────────\n\n/** Pad a 1-4 segment version to a 4-int tuple. Never shifts segments. */\nfunction normalize4(v) {\n  if (!v) return null;\n  const parts = String(v).trim().replace(/^[\"']|[\"']$/g, '').split('.').map((s) => s.trim());\n  if (parts.some((p) => !/^\\d+$/.test(p)) || parts.length < 1 || parts.length > 4) return null;\n  while (parts.length < 4) parts.push('0');\n  return parts.slice(0, 4).map((n) => parseInt(n, 10));\n}\n\nfunction cmpTuple(a, b) {\n  for (let i = 0; i < 4; i += 1) {\n    if (a[i] !== b[i]) return a[i] - b[i];\n  }\n  return 0;\n}\n\nfunction tupleStr(t) {\n  return t.join('.');\n}\n\n// ─── frontmatter parsing ────────────────────────────────────────\n\n/**\n * Returns { hasFrontmatter, eol, lines, openIdx, closeIdx, versionLineIdx, versionValue }.\n * lines excludes the trailing-newline split artifact handling (caller rejoins with eol).\n */\nfunction parseFrontmatter(content) {\n  const eol = content.includes('\\r\\n') ? '\\r\\n' : '\\n';\n  const lines = content.split(/\\r?\\n/);\n  if (lines[0] !== '---') return { hasFrontmatter: false, eol, lines };\n  let closeIdx = -1;\n  for (let i = 1; i < lines.length; i += 1) {\n    if (lines[i] === '---') { closeIdx = i; break; }\n  }\n  if (closeIdx === -1) return { hasFrontmatter: false, eol, lines };\n  let versionLineIdx = -1;\n  let versionValue = null;\n  for (let i = 1; i < closeIdx; i += 1) {\n    const m = lines[i].match(/^version:\\s*(.+?)\\s*$/);\n    if (m) { versionLineIdx = i; versionValue = m[1].replace(/^[\"']|[\"']$/g, ''); break; }\n  }\n  return { hasFrontmatter: true, eol, lines, openIdx: 0, closeIdx, versionLineIdx, versionValue };\n}\n\n// ─── skill anchor resolution (cached per skill dir) ─────────────\n\nconst anchorCache = new Map();\n\n/** Walk up from a file to the nearest directory containing SKILL.md (bounded by skills root). */\nfunction findSkillDir(absFile, skillsRoot) {\n  let dir = fs.statSync(absFile).isDirectory() ? absFile : path.dirname(absFile);\n  while (dir.startsWith(skillsRoot)) {\n    if (fs.existsSync(path.join(dir, 'SKILL.md'))) return dir;\n    const parent = path.dirname(dir);\n    if (parent === dir) break;\n    dir = parent;\n  }\n  return null;\n}\n\nfunction resolveAnchor(skillDir) {\n  if (anchorCache.has(skillDir)) return anchorCache.get(skillDir);\n  // frontmatter version\n  let fmTuple = null;\n  try {\n    const skillMd = fs.readFileSync(path.join(skillDir, 'SKILL.md'), 'utf8');\n    const fm = parseFrontmatter(skillMd);\n    if (fm.hasFrontmatter && fm.versionValue) fmTuple = normalize4(fm.versionValue);\n  } catch { /* ignore */ }\n  // changelog max\n  let clTuple = null;\n  const clDir = path.join(skillDir, 'changelog');\n  if (fs.existsSync(clDir)) {\n    for (const name of fs.readdirSync(clDir)) {\n      const m = name.match(/^v(\\d+(?:\\.\\d+){0,3})\\.md$/);\n      if (!m) continue;\n      const t = normalize4(m[1]);\n      if (t && (!clTuple || cmpTuple(t, clTuple) > 0)) clTuple = t;\n    }\n  }\n  let anchor;\n  let source;\n  if (fmTuple && clTuple) { anchor = cmpTuple(fmTuple, clTuple) >= 0 ? fmTuple : clTuple; source = 'max(fm,changelog)'; }\n  else if (clTuple) { anchor = clTuple; source = 'changelog'; }\n  else if (fmTuple) { anchor = fmTuple; source = 'frontmatter-only'; }\n  else { anchor = [1, 0, 0, 0]; source = 'default'; }\n  const result = { anchor, source };\n  anchorCache.set(skillDir, result);\n  return result;\n}\n\n// ─── file classification + scope discovery ─────────────────────\n\nfunction classify(absFile, skillsRoot) {\n  const base = path.basename(absFile);\n  if (base === 'SKILL.md') return 'skill-md';\n  if (base === 'README.md') return 'readme';\n  const rel = path.relative(skillsRoot, absFile).split(path.sep);\n  // rel = [skill, ...subtree...]; find first in-scope subtree segment\n  for (const seg of rel) {\n    if (seg === 'references') return 'reference';\n    if (seg === 'assets') return 'asset';\n    if (seg === 'feature_catalog') return 'feature-catalog';\n    if (seg === 'manual_testing_playbook') return 'playbook';\n  }\n  return null;\n}\n\n/** An in-scope markdown file: SKILL.md anywhere; any file under a scope subtree;\n *  README.md only when adjacent to a SKILL.md (skill or mode-packet root). */\nfunction inScope(absFile, skillsRoot) {\n  const base = path.basename(absFile);\n  if (base === 'SKILL.md') return true;\n  const rel = path.relative(skillsRoot, absFile).split(path.sep);\n  for (const seg of rel) {\n    if (SCOPE_SUBTREES.includes(seg)) return true;\n  }\n  if (base === 'README.md') {\n    return fs.existsSync(path.join(path.dirname(absFile), 'SKILL.md'));\n  }\n  return false;\n}\n\nfunction walkAllMd(dir, acc) {\n  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {\n    if (entry.isDirectory()) {\n      if (EXCLUDED_DIRS.has(entry.name)) continue;\n      walkAllMd(path.join(dir, entry.name), acc);\n    } else if (entry.isFile() && entry.name.endsWith('.md')) {\n      acc.push(path.join(dir, entry.name));\n    }\n  }\n}\n\n/** Discover all in-scope markdown files under the skills root (optionally one skill). */\nfunction discoverInScope(skillsRoot, onlySkill) {\n  const skills = fs.readdirSync(skillsRoot, { withFileTypes: true })\n    .filter((e) => e.isDirectory() && !EXCLUDED_DIRS.has(e.name))\n    .filter((e) => !onlySkill || e.name === onlySkill)\n    .map((e) => path.join(skillsRoot, e.name));\n  const all = [];\n  for (const s of skills) walkAllMd(s, all);\n  return [...new Set(all.filter((f) => inScope(f, skillsRoot)))].sort();\n}\n\n// ─── compute one file ───────────────────────────────────────────\n\nasync function computeForFile(absFile, skillsRoot, root) {\n  const skillDir = findSkillDir(absFile, skillsRoot);\n  const skill = skillDir ? path.relative(skillsRoot, skillDir) : 'UNKNOWN';\n  const fileClass = classify(absFile, skillsRoot);\n  const { anchor, source } = skillDir ? resolveAnchor(skillDir) : { anchor: [1, 0, 0, 0], source: 'default' };\n  const base = path.basename(absFile);\n  let derived;\n  let realEdits = '';\n  if (base === 'SKILL.md') {\n    derived = anchor;\n  } else {\n    realEdits = await realEditCount(absFile, root);\n    derived = [anchor[0], anchor[1], 0, Math.min(realEdits, W_CAP)];\n  }\n  return {\n    path: path.relative(root, absFile),\n    fileClass,\n    skill,\n    anchor: tupleStr(anchor),\n    anchorSource: source,\n    realEditCount: realEdits,\n    derivedVersion: tupleStr(derived),\n    derivedTuple: derived,\n    absFile,\n  };\n}\n\n// ─── insertion (line-wise, idempotent) ─────────────────────────\n\nfunction applyVersion(absFile, derivedStr, opts) {\n  const content = fs.readFileSync(absFile, 'utf8');\n  const fm = parseFrontmatter(content);\n  if (!fm.hasFrontmatter) return 'skip-no-frontmatter';\n  if (fm.versionLineIdx !== -1) {\n    const rawExisting = fm.versionValue.trim().replace(/^[\"']|[\"']$/g, '');\n    if (rawExisting === derivedStr) return 'skip-equal'; // already the canonical 4-part string\n    const existing = normalize4(fm.versionValue);\n    const sameValue = existing && tupleStr(existing) === derivedStr;\n    // A genuinely different VALUE is a conflict — preserve a human-set version unless\n    // --update (or SKILL.md reconcile). A same-value-but-non-canonical raw (e.g. a 3-part\n    // 1.0.0 that means 1.0.0.0) is always normalized to the canonical 4-part form.\n    if (!sameValue && !opts.update && !opts.reconcile) return 'skip-conflict';\n    fm.lines[fm.versionLineIdx] = `version: ${derivedStr}`;\n  } else {\n    // insert as last key, immediately before closing ---\n    fm.lines.splice(fm.closeIdx, 0, `version: ${derivedStr}`);\n  }\n  const trailing = content.endsWith('\\n') ? '' : '';\n  let next = fm.lines.join(fm.eol);\n  if (content.endsWith('\\n') && !next.endsWith('\\n')) next += fm.eol;\n  fs.writeFileSync(absFile, next);\n  return fm.versionLineIdx !== -1 ? 'update' : 'insert';\n}\n\nfunction verifyVersion(absFile, derivedStr) {\n  const content = fs.readFileSync(absFile, 'utf8');\n  const fm = parseFrontmatter(content);\n  if (!fm.hasFrontmatter) return { ok: false, reason: 'no-frontmatter' };\n  if (fm.versionLineIdx === -1) return { ok: false, reason: 'missing-version' };\n  const existing = normalize4(fm.versionValue);\n  if (!existing) return { ok: false, reason: `malformed:${fm.versionValue}` };\n  if (tupleStr(existing) !== derivedStr) return { ok: false, reason: `mismatch:${tupleStr(existing)}!=${derivedStr}` };\n  // Note: new insertions are placed as the last key (see applyVersion), but a\n  // pre-existing version elsewhere in the block is valid — position is an\n  // insertion convention, not a correctness invariant. Verify checks value only.\n  return { ok: true };\n}\n\n// ─── manifest emit ──────────────────────────────────────────────\n\nfunction emitManifest(rows, outBase) {\n  const cols = ['path', 'fileClass', 'skill', 'anchor', 'anchorSource', 'realEditCount', 'derivedVersion', 'action'];\n  const csv = [cols.join(',')]\n    .concat(rows.map((r) => cols.map((c) => csvCell(r[c])).join(',')))\n    .join('\\n');\n  fs.writeFileSync(`${outBase}.csv`, csv + '\\n');\n  fs.writeFileSync(`${outBase}.json`, JSON.stringify(rows.map((r) => {\n    const { absFile, derivedTuple, ...rest } = r;\n    return rest;\n  }), null, 2) + '\\n');\n}\n\nfunction csvCell(v) {\n  const s = String(v ?? '');\n  return /[\",\\n]/.test(s) ? `\"${s.replace(/\"/g, '\"\"')}\"` : s;\n}\n\n// ─── main ───────────────────────────────────────────────────────\n\nfunction parseArgs(argv) {\n  const args = { mode: argv[0], skill: null, paths: null, manifestOut: null, update: false, skillsRoot: null, fromManifest: null, classes: null };\n  for (let i = 1; i < argv.length; i += 1) {\n    const a = argv[i];\n    if (a === '--skill') args.skill = argv[++i];\n    else if (a === '--paths') args.paths = argv[++i];\n    else if (a === '--manifest-out') args.manifestOut = argv[++i];\n    else if (a === '--skills-root') args.skillsRoot = argv[++i];\n    else if (a === '--from-manifest') args.fromManifest = argv[++i];\n    else if (a === '--classes') args.classes = argv[++i];\n    else if (a === '--update') args.update = true;\n    else if (a === '--help' || a === '-h') args.mode = 'help';\n  }\n  return args;\n}\n\nfunction helpText() {\n  return `frontmatter-version.mjs — 4-part version compute/apply/verify\nModes: compute (dry-run), apply, verify\nOptions: --skill <name>  --paths <file-list>  --manifest-out <base>  --update\nStandard: .opencode/skills/sk-doc/references/frontmatter_versioning.md`;\n}\n\nasync function main() {\n  const args = parseArgs(process.argv.slice(2));\n  if (!args.mode || args.mode === 'help') { console.log(helpText()); process.exit(0); }\n  const root = repoRoot();\n  const skillsRoot = args.skillsRoot ? path.resolve(args.skillsRoot) : path.join(root, '.opencode', 'skills');\n\n  if (args.mode === 'gate') {\n    // Enforcement gate: every in-scope file must carry a 4-part version.\n    // Presence + format only — no git, no manifest. Exit 1 if any in-scope doc is missing/malformed.\n    const targets = args.fromManifest\n      ? JSON.parse(fs.readFileSync(args.fromManifest, 'utf8')).map((m) => (path.isAbsolute(m.path) ? m.path : path.join(root, m.path)))\n      : discoverInScope(skillsRoot, args.skill);\n    let grows = targets.map((f) => ({ path: path.relative(root, f), absFile: f, fileClass: classify(f, skillsRoot) }));\n    if (args.classes) { const set = new Set(args.classes.split(',')); grows = grows.filter((r) => set.has(r.fileClass)); }\n    let bad = 0;\n    for (const r of grows) {\n      const fm = parseFrontmatter(fs.readFileSync(r.absFile, 'utf8'));\n      if (!fm.hasFrontmatter) { r.action = 'skip-no-frontmatter'; continue; }\n      if (fm.versionLineIdx === -1) { r.action = 'FAIL:missing'; bad += 1; console.error(`  MISSING version: ${r.path}`); continue; }\n      if (!VERSION_RE.test(fm.versionValue)) { r.action = 'FAIL:malformed'; bad += 1; console.error(`  MALFORMED version '${fm.versionValue}': ${r.path}`); continue; }\n      r.action = 'ok';\n    }\n    summary('gate', grows, args.manifestOut);\n    process.exit(bad > 0 ? 1 : 0);\n  }\n\n  let rows;\n  if (args.fromManifest) {\n    // Source precomputed versions from a compute manifest (skips git re-computation).\n    const man = JSON.parse(fs.readFileSync(args.fromManifest, 'utf8'));\n    rows = man.map((m) => ({ ...m, absFile: path.isAbsolute(m.path) ? m.path : path.join(root, m.path), derivedTuple: normalize4(m.derivedVersion) }));\n    if (args.skill) rows = rows.filter((r) => r.skill === args.skill || String(r.skill).startsWith(`${args.skill}/`));\n  } else {\n    let targets;\n    if (args.paths) {\n      targets = fs.readFileSync(args.paths, 'utf8').split('\\n').map((s) => s.trim()).filter(Boolean)\n        .map((p) => (path.isAbsolute(p) ? p : path.join(root, p)));\n    } else {\n      targets = discoverInScope(skillsRoot, args.skill);\n    }\n    rows = await mapPool(targets, GIT_CONCURRENCY, (f) => computeForFile(f, skillsRoot, root));\n  }\n  if (args.classes) {\n    const set = new Set(args.classes.split(','));\n    rows = rows.filter((r) => set.has(r.fileClass));\n  }\n\n  if (args.mode === 'compute') {\n    for (const r of rows) r.action = 'compute';\n    const outBase = args.manifestOut || path.join(root, 'frontmatter-version-manifest');\n    emitManifest(rows, outBase);\n    summary('compute', rows, outBase);\n  } else if (args.mode === 'apply') {\n    for (const r of rows) {\n      r.action = applyVersion(r.absFile, r.derivedVersion, { update: args.update, reconcile: r.fileClass === 'skill-md' });\n    }\n    if (args.manifestOut) emitManifest(rows, args.manifestOut);\n    summary('apply', rows, args.manifestOut);\n  } else if (args.mode === 'verify') {\n    let failures = 0;\n    for (const r of rows) {\n      const v = verifyVersion(r.absFile, r.derivedVersion);\n      if (v.reason === 'no-frontmatter') { r.action = 'skip-no-frontmatter'; continue; }\n      r.action = v.ok ? 'ok' : `FAIL:${v.reason}`;\n      if (!v.ok) { failures += 1; console.error(`  FAIL ${r.path} -> ${v.reason} (expected ${r.derivedVersion})`); }\n    }\n    if (args.manifestOut) emitManifest(rows, args.manifestOut);\n    summary('verify', rows, args.manifestOut);\n    process.exit(failures > 0 ? 1 : 0);\n  } else {\n    console.error(`Unknown mode: ${args.mode}`);\n    process.exit(64);\n  }\n}\n\nfunction summary(mode, rows, outBase) {\n  const byAction = {};\n  for (const r of rows) byAction[r.action] = (byAction[r.action] || 0) + 1;\n  const parts = Object.entries(byAction).sort().map(([k, v]) => `${k}=${v}`).join('  ');\n  console.log(`[${mode}] ${rows.length} files | ${parts}`);\n  if (outBase) console.log(`manifest: ${outBase}.csv / ${outBase}.json`);\n}\n\nmain().catch((e) => { console.error(e); process.exit(1); });","lineStart":1,"lineEnd":440,"totalLines":440,"truncated":false}},"title":".opencode/skills/sk-doc/scripts/frontmatter-version.mjs","time":{"start":1782211026442,"end":1782211026446}},"id":"prt_ef40e1c41001BWxFJsaCURQnAK","sessionID":"ses_10bf585eeffeDIFj5xRNnSbPD5","messageID":"msg_ef40e0dc8001jra72lTRsXXZKt"}}
