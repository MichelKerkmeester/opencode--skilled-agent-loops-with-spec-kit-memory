   327	function buildNamespaceWhere(ns: Namespace): { clause: string; params: unknown[] } {
   328	  const parts: string[] = ['spec_folder = ?', 'loop_type = ?'];
   329	  const params: unknown[] = [ns.specFolder, ns.loopType];
   330	  if (ns.sessionId) {
   331	    parts.push('session_id = ?');
   332	    params.push(ns.sessionId);
   333	  }
   334	  return { clause: parts.join(' AND '), params };
   335	}
