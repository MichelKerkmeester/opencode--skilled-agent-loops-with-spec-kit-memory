communityFallbackApplied = false;\n1160:     const shouldRunCommunitySearch = (\n1161:       isDualRetrievalEnabled() &&\n1162:       isCommunitySearchFallbackEnabled() &&\n1163:       effectiveQuery.length > 0 &&\n1164:       (retrievalLevel === 'global' || retrievalLevel === 'auto')\n1165:     );\n1166:     if (shouldRunCommunitySearch) {\n1167:       const isWeakResult = resultsForFormatting.length === 0 ||\n1168:         (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n1169:       if (isWeakResult) {\n1170:         try {\n1171:           const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n1172:           if (communityResults.totalMemberIds.length > 0) {\n1173:             // Fetch the actual memory rows for community member IDs\n1174:             const memberIds = communityResults.totalMemberIds.slice(0, 20);\n1175:             const placeholders = memberIds.map(() => '?').join(', ');\n1176:             const db = requireDb();\n1177:             const rawMemberRows = db.prepare(`\n1178:               SELECT id, title, similarity, content, file_path, anchor_id, document_type,\n1179:                      importance_tier, context_type, quality_score, created_at,\n1180:                      tenant_id, user_id, agent_id\n1181:               FROM memory_index\n1182:               WHERE id IN (${placeholders})\n1183:             `).all(...memberIds) as Array<Record<string, unknown> & { id: number }>;\n1184: \n1185:             // Apply governed retrieval scope to the community fallback so it cannot\n1186:             // bypass the tenant/user/agent boundary the canonical pipeline enforces.\n1187:             // sessionId is deliberately excluded — it is a dedup/continuity key, not\n1188:             // a row-access boundary. Unscoped (single-user) callers are unaffected.\n1189:             const hasGovernanceScope = Boolean(\n1190:               normalizedScope.tenantId || normalizedScope.userId || normalizedScope.agentId,\n1191:             );\n1192:             const memberRows = hasGovernanceScope\n1193:               ? filterRowsByScope(rawMemberRows, {\n1194:                   tenantId: normalizedScope.tenantId,\n1195:                   userId: normalizedScope.userId,\n1196:                   agentId: normalizedScope.agentId,\n1197:                 })\n1198:               : rawMemberRows;\n1199: \n1200:             if (memberRows.length > 0) {\n1201:               // Calibrate score from community match quality, bounded below pipeline threshold\n1202:               const communityScoreScale = 0.02; // aligns with pipeline's minimum quality floor\n1203:               const avgMatchScore = communityResults.results.length > 0\n1204:                 ? communityResults.results.reduce((sum, r) => sum + r.matchScore, 0) / communityResults.results.length\n1205:                 : 0.5;\n1206:               const calibratedScore = Math.max(0.001, avgMatchScore * communityScoreScale);\n1207:               // Mark community-sourced results and assign calibrated score\n1208:               const communityRows = memberRows.map((row) => ({\n1209:                 ...row,\n1210:                 similarity: typeof row.similarity === 'number' ? row.similarity : 0.5,\n1211:                 score: calibratedScore,\n1212:                 _communityFallback: true,\n1213:               }));\n1214:               // Merge: append community results not already in pipeline results\n1215:               const existingIds = new Set(resultsForFormatting.map((r) => (r as Record<string, unknown>).id as number));\n1216:               const newRows = communityRows.filter((r) => !existingIds.has(r.id));\n1217:               if (newRows.length > 0) {\n1218:                 resultsForFormatting = [...resultsForFormatting, ...newRows as unknown as SessionAwareResult[]];\n1219:                 communityFallbackApplied = true;\n1220:               }\n1221:             }\n1222:           }\n1223:         } catch (err: unknown) {\n1224:           const msg = err instanceof Error ? err.message : String(err);\n1225:           console.warn(`[memory-search] Community search fallback failed (fail-open): ${msg}`);\n1226:         }\n1227:       }\n1228:     }\n1229: \n1230:     const folderBoostRankingApplied = applyFolderBoostRanking(resultsForFormatting, folderBoost);\n1231: \n1232:     // Eval channel attribution should reflect the retrieval pipeline output\n1233:     // before canonical source filtering drops rows for response formatting.\n1234:     _evalChannelPayloads = buildEvalChannelPayloads(\n1235:       pipelineResult.results as unknown as Array<Record<string, unknown>>,\n1236:     );\n1237: \n1238:     const canonicalFilter = filterCanonicalSourceRows(resultsForFormatting);\n1239:     resultsForFormatting = canonicalFilter.results;\n1240:     const avgScore = computeAverageScore(resultsForFormatting as Array<Record<string, unknown>>);\n1241:     const requestQualityLabel = pipelineResult.metadata.stage4.evidenceGapDetected ? 'gap' : 'weak';\n1242:     const qualityGapRouting = routeQuery(effectiveQuery, undefined, {\n1243:       quality: requestQualityLabel,\n1244:       avgScore,\n1245:     });\n1246:     const qualityFallback = qualityGapRouting.qualityFallback;\n1247:     if (qualityFallback.engaged) {\n1248:       queryPlan = qualityGapRouting.queryPlan;\n1249:     }\n\n(Showing lines 1120-1249 of 1788. Use offset=1250 to continue.)\n</content>","metadata":{"preview":"      searchType: (hasValidConcepts && concepts!.length >= 2)\n        ? 'multi-concept'\n        : 'hybrid',\n      mode,\n      limit,\n      specFolder,\n      tenantId: normalizedScope.tenantId,\n      userId: normalizedScope.userId,\n      agentId: normalizedScope.agentId,\n      tier,\n      contextType,\n      includeArchived,\n      includeConstitutional,\n      includeContent,\n      anchors,\n      qualityThreshold,\n      minState: minState ?? '',\n      applyStateLimits,\n      useDecay,\n      rerank,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"      searchType: (hasValidConcepts && concepts!.length >= 2)\n        ? 'multi-concept'\n        : 'hybrid',\n      mode,\n      limit,\n      specFolder,\n      tenantId: normalizedScope.tenantId,\n      userId: normalizedScope.userId,\n      agentId: normalizedScope.agentId,\n      tier,\n      contextType,\n      includeArchived,\n      includeConstitutional,\n      includeContent,\n      anchors,\n      qualityThreshold,\n      minState: minState ?? '',\n      applyStateLimits,\n      useDecay,\n      rerank,\n      applyLengthPenalty,\n      sessionId,\n      enableDedup,\n      enableSessionBoost,\n      enableCausalBoost,\n      trackAccess,\n      detectedIntent,\n      adaptiveFusionIntent,\n      intentConfidence,\n      intentWeights: toIntentWeightsConfig(intentWeights),\n      artifactRouting: artifactRouting as unknown as PipelineConfig['artifactRouting'],\n      queryPlan,\n      trace,\n    };\n\n    const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n    let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n\n    // Community search fallback — inject community members on weak results\n    let communityFallbackApplied = false;\n    const shouldRunCommunitySearch = (\n      isDualRetrievalEnabled() &&\n      isCommunitySearchFallbackEnabled() &&\n      effectiveQuery.length > 0 &&\n      (retrievalLevel === 'global' || retrievalLevel === 'auto')\n    );\n    if (shouldRunCommunitySearch) {\n      const isWeakResult = resultsForFormatting.length === 0 ||\n        (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n      if (isWeakResult) {\n        try {\n          const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n          if (communityResults.totalMemberIds.length > 0) {\n            // Fetch the actual memory rows for community member IDs\n            const memberIds = communityResults.totalMemberIds.slice(0, 20);\n            const placeholders = memberIds.map(() => '?').join(', ');\n            const db = requireDb();\n            const rawMemberRows = db.prepare(`\n              SELECT id, title, similarity, content, file_path, anchor_id, document_type,\n                     importance_tier, context_type, quality_score, created_at,\n                     tenant_id, user_id, agent_id\n              FROM memory_index\n              WHERE id IN (${placeholders})\n            `).all(...memberIds) as Array<Record<string, unknown> & { id: number }>;\n\n            // Apply governed retrieval scope to the community fallback so it cannot\n            // bypass the tenant/user/agent boundary the canonical pipeline enforces.\n            // sessionId is deliberately excluded — it is a dedup/continuity key, not\n            // a row-access boundary. Unscoped (single-user) callers are unaffected.\n            const hasGovernanceScope = Boolean(\n              normalizedScope.tenantId || normalizedScope.userId || normalizedScope.agentId,\n            );\n            const memberRows = hasGovernanceScope\n              ? filterRowsByScope(rawMemberRows, {\n                  tenantId: normalizedScope.tenantId,\n                  userId: normalizedScope.userId,\n                  agentId: normalizedScope.agentId,\n                })\n              : rawMemberRows;\n\n            if (memberRows.length > 0) {\n              // Calibrate score from community match quality, bounded below pipeline threshold\n              const communityScoreScale = 0.02; // aligns with pipeline's minimum quality floor\n              const avgMatchScore = communityResults.results.length > 0\n                ? communityResults.results.reduce((sum, r) => sum + r.matchScore, 0) / communityResults.results.length\n                : 0.5;\n              const calibratedScore = Math.max(0.001, avgMatchScore * communityScoreScale);\n              // Mark community-sourced results and assign calibrated score\n              const communityRows = memberRows.map((row) => ({\n                ...row,\n                similarity: typeof row.similarity === 'number' ? row.similarity : 0.5,\n                score: calibratedScore,\n                _communityFallback: true,\n              }));\n              // Merge: append community results not already in pipeline results\n              const existingIds = new Set(resultsForFormatting.map((r) => (r as Record<string, unknown>).id as number));\n              const newRows = communityRows.filter((r) => !existingIds.has(r.id));\n              if (newRows.length > 0) {\n                resultsForFormatting = [...resultsForFormatting, ...newRows as unknown as SessionAwareResult[]];\n                communityFallbackApplied = true;\n              }\n            }\n          }\n        } catch (err: unknown) {\n          const msg = err instanceof Error ? err.message : String(err);\n          console.warn(`[memory-search] Community search fallback failed (fail-open): ${msg}`);\n        }\n      }\n    }\n\n    const folderBoostRankingApplied = applyFolderBoostRanking(resultsForFormatting, folderBoost);\n\n    // Eval channel attribution should reflect the retrieval pipeline output\n    // before canonical source filtering drops rows for response formatting.\n    _evalChannelPayloads = buildEvalChannelPayloads(\n      pipelineResult.results as unknown as Array<Record<string, unknown>>,\n    );\n\n    const canonicalFilter = filterCanonicalSourceRows(resultsForFormatting);\n    resultsForFormatting = canonicalFilter.results;\n    const avgScore = computeAverageScore(resultsForFormatting as Array<Record<string, unknown>>);\n    const requestQualityLabel = pipelineResult.metadata.stage4.evidenceGapDetected ? 'gap' : 'weak';\n    const qualityGapRouting = routeQuery(effectiveQuery, undefined, {\n      quality: requestQualityLabel,\n      avgScore,\n    });\n    const qualityFallback = qualityGapRouting.qualityFallback;\n    if (qualityFallback.engaged) {\n      queryPlan = qualityGapRouting.queryPlan;\n    }","lineStart":1120,"lineEnd":1249,"totalLines":1788,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781761986374,"end":1781761986384}},"metadata":{"openai":{"itemId":"fc_05fce0a1f1825a85016a3387c236cc81919bcef508e3049c13"}},"id":"prt_ed94a4f34001DmyIa9z5pu7qWQ","sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","messageID":"msg_ed94a12c5001SPqQudSq1aBJpq"}}
