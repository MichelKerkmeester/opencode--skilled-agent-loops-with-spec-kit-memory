   334	export function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {
   335	  const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);
   336	  const weights = effectiveScorerWeights(options.laneWeightsOverride);
   337	  const disabled = new Set(options.disabledLanes ?? []);
   338	  const affordances = normalize(options.affordances ?? []);
   339	  const laneScores = buildLaneScores(prompt, projection, disabled, affordances);
   340	  const laneScoreIndexes = Object.fromEntries(
   341	    SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),
   342	  ) as Record<ScorerLane, LaneMatchIndex>;
   343	  const liveTotal = SCORER_LANES
   344	    .filter((lane) => !disabled.has(lane))
   345	    .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();
   346	  if (isSpeckitMetricsEnabled() && liveTotal > 0) {
   347	    for (const lane of SCORER_LANES) {
   348	      if (!isLiveScorerLane(lane) || disabled.has(lane)) continue;
   349	      speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });
   350	    }
   351	  }
   352	  const promptLower = prompt.toLowerCase();
   353	  const readOnlyExplainer = isReadOnlyExplainer(promptLower);
   354	  const hasTaskIntent = TASK_INTENT.test(promptLower);
   355	  const recommendations: AdvisorScoredRecommendation[] = [];
   356	
   357	  for (const skill of projection.skills) {
   358	    if (!isDefaultRoutable(promptLower, skill)) continue;
   359	    const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {
   360	      const laneMatch = laneScoreIndexes[lane].get(skill.id);
   361	      const rawScore = laneMatch?.rawScore ?? 0;
   362	      const shadowOnly = !isLiveScorerLane(lane);
   363	      return {
   364	        lane,
   365	        rawScore,
   366	        weightedScore: shadowOnly || disabled.has(lane) ? 0 : rawScore * weights[lane],
   367	        weight: disabled.has(lane) ? 0 : weights[lane],
   368	        evidence: laneMatch?.evidence ?? [],
   369	        shadowOnly,
   370	      };
   371	    });
   372	    const score = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);
   373	    if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;
   374	    if (isSpeckitMetricsEnabled()) {
   375	      for (const contribution of contributions) {
   376	        if (contribution.weightedScore !== 0) {
   377	          speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });
   378	        }
   379	      }
   380	    }
   381	
   382	    const directScore = Math.max(
   383	      contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,
   384	      contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,
   385	    );
   386	    const derivedDominant = isDerivedDominant(contributions);
   387	    const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);
   388	    const liveNormalized = score / liveTotal;
   389	    let confidence = confidenceFor({
   390	      liveNormalized,
   391	      directScore,
   392	      readOnlyExplainer,
   393	      hasExplicitWorkflowSignal: explicitSignal,
   394	      hasTaskIntent,
   395	      readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),
   396	      derivedDominant,
   397	      skillId: skill.id,
   398	    });
   399	    if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {
   400	      confidence = Math.min(confidence, 0.49);
   401	    }
   402	    recommendations.push({
   403	      skill: skill.id,
   404	      kind: skill.kind,
   405	      confidence,
   406	      uncertainty: uncertaintyFor(contributions, confidence, 0),
   407	      passes_threshold: false,
   408	      reason: attributionReason(contributions),
   409	      score: Number(score.toFixed(6)),
   410	      laneContributions: contributions,
   411	      dominantLane: dominantLane(contributions),
   412	      redirectTo: skill.redirectTo ?? undefined,
   413	      redirectFrom: skill.redirectFrom,
   414	      lifecycleStatus: skill.lifecycleStatus,
   415	    });
   416	  }
   417	
   418	  if (isSpeckitMetricsEnabled()) {
   419	    for (const recommendation of recommendations) {
   420	      if (primaryIntentBonus(promptLower, recommendation) !== 0) {
   421	        speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });
   422	      }
   423	    }
   424	  }
   425	  let ranked = recommendations.sort((left, right) => {
   426	    const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;
   427	    const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;
   428	    const leftIntent = primaryIntentBonus(promptLower, left);
   429	    const rightIntent = primaryIntentBonus(promptLower, right);
   430	    return (right.score + rightCommandBonus + rightIntent) - (left.score + leftCommandBonus + leftIntent)
   431	      || right.confidence - left.confidence
   432	      || left.skill.localeCompare(right.skill);
   433	  });
   434	
   435	  ranked = ranked.map((recommendation, index) => {
   436	    const next = ranked[index + 1];
   437	    const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;
   438	    const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);
   439	    return {
   440	      ...recommendation,
   441	      uncertainty,
   442	      passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)
   443	        && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),
   444	    };
   445	  });
   446	  ranked = applyAmbiguity(ranked);
   447	
   448	  // Low-information ambiguity abstention: a short, intent-less prompt that lands
   449	  // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor
   450	  // every cluster member's uncertainty above the strict threshold so strict
   451	  // callers abstain, while confidence-only callers still surface the best guess
   452	  // (the disambiguated top-ranked candidate).
   453	  const meaningfulTokenCount = promptLower.split(/\s+/).filter((token) => token.length > 1).length;
   454	  const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');
   455	  if (lowInfoPrompt) {
   456	    const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);
   457	    // Only abstain when the cluster's lead is built from diffuse, shared
   458	    // single-word keyword matches rather than a distinctive multi-word phrase
   459	    // anchor (an explicit-author/derived phrase match such as "code audit").
   460	    // A multi-word anchor means the prompt does pin a specific skill, so it
   461	    // should route instead of abstaining.
   462	    const clusterHasPhraseAnchor = clusterMembers.some((recommendation) => (
   463	      recommendation.laneContributions.some((contribution) => (
   464	        (contribution.lane === 'explicit_author' || contribution.lane === 'derived_generated')
   465	        && contribution.evidence.some((entry) => entry.includes(' '))
   466	      ))
   467	    ));
   468	    if (clusterMembers.length >= 2 && !clusterHasPhraseAnchor) {
   469	      const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;
   470	      const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;
   471	      const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;
   472	      ranked = ranked.map((recommendation) => {
   473	        if ((recommendation.ambiguousWith?.length ?? 0) === 0) return recommendation;
   474	        const uncertainty = Math.max(recommendation.uncertainty, floor);
   475	        return {
   476	          ...recommendation,
   477	          uncertainty,
   478	          passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,
   479	        };
   480	      });
   481	    }
   482	  }
   483	
   484	  // Class C: breadth / multi-concern abstention. A broad greenfield build
   485	  // ("build full stack typescript service") or a multi-concern optimization
   486	  // ("optimize X execution speed and recommendation quality") is under-specified
   487	  // for single-skill routing. When the top code-like candidate carries that
   488	  // shape, floor every passing candidate's uncertainty so strict callers abstain.
   489	  // Narrow anchors (a file, failing test, named component/route, benchmark, or
   490	  // review intent) bypass the broad-build branch; the multi-concern branch
   491	  // requires two distinct concern classes, so a file + single concern still routes.
   492	  if (!promptLower.includes('/')) {
   493	    const concernClasses = (CONCERN_PERF.test(promptLower) ? 1 : 0) + (CONCERN_QUALITY.test(promptLower) ? 1 : 0);
   494	    const broadBuild = BREADTH_BUILD_VERB.test(promptLower) && BREADTH_NOUN.test(promptLower) && !BREADTH_NARROW_ANCHOR.test(promptLower);
   495	    const multiConcern = MULTI_CONCERN_VERB.test(promptLower) && concernClasses >= 2;
   496	    if (broadBuild || multiConcern) {
   497	      const topRec = ranked.find((recommendation) => recommendation.passes_threshold) ?? null;
   498	      if (topRec && (topRec.skill === 'sk-code' || topRec.skill === 'system-skill-advisor')) {
   499	        const confThreshold = options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD;
   500	        const uncThreshold = options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD;
   501	        const floor = SCORING_CALIBRATION.uncertainty.lowInfoAmbiguityFloor;
   502	        ranked = ranked.map((recommendation) => {
   503	          if (!recommendation.passes_threshold) return recommendation;
   504	          const uncertainty = Math.max(recommendation.uncertainty, floor);
   505	          return {
   506	            ...recommendation,
   507	            uncertainty,
   508	            passes_threshold: recommendation.confidence >= confThreshold && uncertainty <= uncThreshold,
   509	          };
   510	        });
   511	      }
   512	    }
   513	  }
   514	
   515	  const passing = ranked.filter((recommendation) => recommendation.passes_threshold);
   516	  const visible = options.includeAllCandidates ? ranked : passing;
   517	  const top = passing[0] ?? null;
   518	  if (isSpeckitMetricsEnabled() && top) {
   519	    const runtimeLabel = normalizeRuntimeLabel(process.env.SPECKIT_RUNTIME);
   520	    const freshnessLabel = normalizeFreshnessLabel(process.env.SPECKIT_ADVISOR_FRESHNESS);
   521	    if (runtimeLabel && freshnessLabel) {
   522	      speckitMetrics.incrementCounter('spec_kit.advisor.recommendation_emitted_total', { runtime: runtimeLabel, freshness_state: freshnessLabel });
   523	    }
   524	    speckitMetrics.recordConfidenceBracket(top.confidence);
   525	  }
   526	  return {
   527	    recommendations: visible,
   528	    topSkill: top?.skill ?? null,
   529	    unknown: !top,
   530	    ambiguous: isAmbiguousTopTwo(ranked),
   531	    metrics: {
   532	      candidateCount: ranked.length,
   533	      liveLaneCount: SCORER_LANES.filter((lane) => isLiveScorerLane(lane) && !disabled.has(lane)).length,
   534	    },
   535	  };
   536	}
