tring;\n40:   embedding_status: string | null;\n41:   trigger_phrases: string | null;\n42:   quality_score: number | null;\n43:   quality_flags: string | null;\n44: }\n45: \n46: interface DuplicateLookupRow {\n47:   id: number;\n48:   file_path: string;\n49:   title: string | null;\n50:   content_text?: string | null;\n51: }\n52: \n53: interface CheckExistingRowArgs {\n54:   targetAnchorId: string | null;\n55:   warnings: string[] | undefined;\n56:   scope: MemoryScopeMatch;\n57: }\n58: \n59: function buildScopedWhereClauses(scope: MemoryScopeMatch): {\n60:   clauses: string[];\n61:   params: Array<string>;\n62: } {\n63:   const normalizedScope: MemoryScopeMatch = {\n64:     tenantId: normalizeScopeMatchValue(scope.tenantId),\n65:     userId: normalizeScopeMatchValue(scope.userId),\n66:     agentId: normalizeScopeMatchValue(scope.agentId),\n67:     sessionId: normalizeScopeMatchValue(scope.sessionId),\n68:   };\n69:   const clauses: string[] = [];\n70:   const params: string[] = [];\n71: \n72:   for (const [column, key] of SCOPE_COLUMNS) {\n73:     const value = normalizedScope[key];\n74:     if (value === null || value === undefined) {\n75:       clauses.push(`${column} IS NULL`);\n76:       continue;\n77:     }\n78:     clauses.push(`${column} = ?`);\n79:     params.push(value);\n80:   }\n81: \n82:   return { clauses, params };\n83: }\n84: \n85: function selectLatestExistingRow(\n86:   database: Database.Database,\n87:   parsed: ParsedMemory,\n88:   pathColumn: ScopeColumnName | 'canonical_file_path' | 'file_path',\n89:   pathValue: string,\n90:   targetAnchorId: string | null,\n91:   scopeClauses: string[],\n92:   scopeParams: string[],\n93: ): LatestMemoryLookupRow | undefined {\n94:   const whereClauses = [\n95:     'spec_folder = ?',\n96:     'parent_id IS NULL',\n97:     `${pathColumn} = ?`,\n98:     targetAnchorId !== null ? 'anchor_id = ?' : 'anchor_id IS NULL',\n99:     ...scopeClauses,\n100:   ];\n101: \n102:   return database.prepare(`\n103:     SELECT id, content_hash, embedding_status, trigger_phrases, quality_score, quality_flags\n104:     FROM memory_index\n105:     WHERE ${whereClauses.join('\\n      AND ')}\n106:     ORDER BY id DESC\n107:     LIMIT 1\n108:   `).get(\n109:     parsed.specFolder,\n110:     pathValue,\n111:     ...(targetAnchorId !== null ? [targetAnchorId] : []),\n112:     ...scopeParams,\n113:   ) as LatestMemoryLookupRow | undefined;\n114: }\n115: \n116: function parseJsonStringArray(raw: string | null): string[] {\n117:   if (!raw) {\n118:     return [];\n119:   }\n120: \n121:   try {\n122:     const parsed = JSON.parse(raw) as unknown;\n123:     return Array.isArray(parsed)\n124:       ? parsed.filter((value): value is string => typeof value === 'string')\n125:       : [];\n126:   } catch {\n127:     return [];\n128:   }\n129: }\n130: \n131: function normalizeStringArray(values: string[]): string[] {\n132:   return [...new Set(values.map(value => value.trim()).filter(Boolean))].sort();\n133: }\n134: \n135: function areEquivalentStringArrays(left: string[], right: string[]): boolean {\n136:   const normalizedLeft = normalizeStringArray(left);\n137:   const normalizedRight = normalizeStringArray(right);\n138: \n139:   if (normalizedLeft.length !== normalizedRight.length) {\n140:     return false;\n141:   }\n142: \n143:   return normalizedLeft.every((value, index) => value === normalizedRight[index]);\n144: }\n145: \n146: function isSamePathMetadataEquivalent(\n147:   existing: {\n148:     trigger_phrases: string | null;\n149:     quality_score: number | null;\n150:     quality_flags: string | null;\n151:   },\n152:   parsed: ParsedMemory,\n153: ): boolean {\n154:   const persistedTriggerPhrases = parseJsonStringArray(existing.trigger_phrases);\n155:   if (!areEquivalentStringArrays(persistedTriggerPhrases, parsed.triggerPhrases)) {\n156:     return false;\n157:   }\n158: \n159:   const persistedQualityFlags = parseJsonStringArray(existing.quality_flags);\n160:   if (!areEquivalentStringArrays(persistedQualityFlags, parsed.qualityFlags ?? [])) {\n161:     return false;\n162:   }\n163: \n164:   const persistedQualityScore = existing.quality_score ?? 0;\n165:   const parsedQualityScore = parsed.qualityScore ?? 0;\n166:   return Math.abs(persistedQualityScore - parsedQualityScore) <= QUALITY_SCORE_EPSILON;\n167: }\n168: \n169: function verifyStoredContentMatch(\n170:   storedContent: string | null | undefined,\n171:   storedPath: string | null | undefined,\n172:   incomingContent: string,\n173: ): boolean | null {\n174:   if (typeof storedContent === 'string') {\n175:     return storedContent === incomingContent;\n176:   }\n177: \n178:   if (typeof storedPath === 'string' && storedPath.length > 0) {\n179:     try {\n180:       if (fs.existsSync(storedPath)) {\n181:         return fs.readFileSync(storedPath, 'utf-8') === incomingContent;\n182:       }\n183:     } catch {\n184:       return null;\n185:     }\n186:   }\n187: \n188:   return null;\n189: }\n190: \n191: function resolveCheckExistingRowArgs(\n192:   targetAnchorIdOrForce: string | null | boolean,\n193:   forceOrWarnings: boolean | string[] | undefined,\n194:   warningsOrScope: string[] | MemoryScopeMatch | undefined,\n195:   scope: MemoryScopeMatch,\n196: ): CheckExistingRowArgs {\n197:   if (typeof targetAnchorIdOrForce === 'boolean') {\n198:     return {\n199:       targetAnchorId: null,\n200:       warnings: Array.isArray(forceOrWarnings) ? forceOrWarnings : undefined,\n201:       scope: Array.isArray(warningsOrScope) || !warningsOrScope ? scope : warningsOrScope,\n202:     };\n203:   }\n204: \n205:   return {\n206:     targetAnchorId: targetAnchorIdOrForce ?? null,\n207:     warnings: Array.isArray(warningsOrScope)\n208:       ? warningsOrScope\n209:       : (Array.isArray(forceOrWarnings) ? forceOrWarnings : undefined),\n210:     scope: Array.isArray(warningsOrScope) || !warningsOrScope ? scope : warningsOrScope,\n211:   };\n212: }\n213: \n214: export function checkExistingRow(\n215:   database: Database.Database,\n216:   parsed: ParsedMemory,\n217:   canonicalFilePath: string,\n218:   filePath: string,\n219:   targetAnchorIdOrForce: string | null | boolean,\n220:   forceOrWarnings: boolean | string[] | undefined,\n221:   warningsOrScope?: string[] | MemoryScopeMatch,\n222:   scope: MemoryScopeMatch = {},\n223: ): IndexResult | null {\n224:   const {\n225:     targetAnchorId,\n226:     warnings,\n227:     scope: resolvedScope,\n228:   } = resolveCheckExistingRowArgs(targetAnchorIdOrForce, forceOrWarnings, warningsOrScope, scope);\n229:   const { clauses: scopeClauses, params: scopeParams } = buildScopedWhereClauses(resolvedScope);\n230:   const candidates = [\n231:     selectLatestExistingRow(\n232:       database,\n233:       parsed,\n234:       'canonical_file_path',\n235:       canonicalFilePath,\n236:       targetAnchorId,\n237:       scopeClauses,\n238:       scopeParams,\n239:     ),\n240:   ];\n241: \n242:   if (filePath !== canonicalFilePath) {\n243:     candidates.push(\n244:       selectLatestExistingRow(\n245:         database,\n246:         parsed,\n247:         'file_path',\n248:         filePath,\n249:         targetAnchorId,\n250:         scopeClauses,\n251:         scopeParams,\n252:       ),\n253:     );\n254:   }\n255: \n256:   const existing = candidates\n257:     .filter((candidate): candidate is LatestMemoryLookupRow => candidate !== undefined)\n258:     .sort((left, right) => right.id - left.id)[0];\n259: \n260:   const existingStatus = existing?.embedding_status ?? null;\n\n(Showing lines 1-260 of 357. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Dedup\n// ───────────────────────────────────────────────────────────────\nimport fs from 'fs';\nimport type Database from 'better-sqlite3';\n\nimport type { ParsedMemory } from '../../lib/parsing/memory-parser.js';\nimport type { IndexResult } from './types.js';\n\n// Feature catalog: SHA-256 content-hash deduplication\n// Feature catalog: Canonical ID dedup hardening\n// Feature catalog: Duplicate-save no-op feedback hardening\n\n\nconst UNCHANGED_EMBEDDING_STATUSES = new Set(['success', 'pending', 'partial']);\nconst DEDUP_ELIGIBLE_EMBEDDING_STATUSES = ['success', 'partial'] as const;\nexport const NEAR_DUPLICATE_SIMILARITY_THRESHOLD = 0.88;\nconst QUALITY_SCORE_EPSILON = 1e-9;\nconst SCOPE_COLUMNS = [\n  ['tenant_id', 'tenantId'],","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/dedup.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Dedup\n// ───────────────────────────────────────────────────────────────\nimport fs from 'fs';\nimport type Database from 'better-sqlite3';\n\nimport type { ParsedMemory } from '../../lib/parsing/memory-parser.js';\nimport type { IndexResult } from './types.js';\n\n// Feature catalog: SHA-256 content-hash deduplication\n// Feature catalog: Canonical ID dedup hardening\n// Feature catalog: Duplicate-save no-op feedback hardening\n\n\nconst UNCHANGED_EMBEDDING_STATUSES = new Set(['success', 'pending', 'partial']);\nconst DEDUP_ELIGIBLE_EMBEDDING_STATUSES = ['success', 'partial'] as const;\nexport const NEAR_DUPLICATE_SIMILARITY_THRESHOLD = 0.88;\nconst QUALITY_SCORE_EPSILON = 1e-9;\nconst SCOPE_COLUMNS = [\n  ['tenant_id', 'tenantId'],\n  ['user_id', 'userId'],\n  ['agent_id', 'agentId'],\n  ['session_id', 'sessionId'],\n] as const;\n\ninterface SamePathDedupExclusion {\n  canonicalFilePath: string;\n  filePath: string;\n  targetAnchorId?: string | null;\n}\n\nimport type { MemoryScopeMatch } from './types.js';\nimport { normalizeScopeMatchValue } from './types.js';\n\ntype ScopeColumnName = typeof SCOPE_COLUMNS[number][0];\n\ninterface LatestMemoryLookupRow {\n  id: number;\n  content_hash: string;\n  embedding_status: string | null;\n  trigger_phrases: string | null;\n  quality_score: number | null;\n  quality_flags: string | null;\n}\n\ninterface DuplicateLookupRow {\n  id: number;\n  file_path: string;\n  title: string | null;\n  content_text?: string | null;\n}\n\ninterface CheckExistingRowArgs {\n  targetAnchorId: string | null;\n  warnings: string[] | undefined;\n  scope: MemoryScopeMatch;\n}\n\nfunction buildScopedWhereClauses(scope: MemoryScopeMatch): {\n  clauses: string[];\n  params: Array<string>;\n} {\n  const normalizedScope: MemoryScopeMatch = {\n    tenantId: normalizeScopeMatchValue(scope.tenantId),\n    userId: normalizeScopeMatchValue(scope.userId),\n    agentId: normalizeScopeMatchValue(scope.agentId),\n    sessionId: normalizeScopeMatchValue(scope.sessionId),\n  };\n  const clauses: string[] = [];\n  const params: string[] = [];\n\n  for (const [column, key] of SCOPE_COLUMNS) {\n    const value = normalizedScope[key];\n    if (value === null || value === undefined) {\n      clauses.push(`${column} IS NULL`);\n      continue;\n    }\n    clauses.push(`${column} = ?`);\n    params.push(value);\n  }\n\n  return { clauses, params };\n}\n\nfunction selectLatestExistingRow(\n  database: Database.Database,\n  parsed: ParsedMemory,\n  pathColumn: ScopeColumnName | 'canonical_file_path' | 'file_path',\n  pathValue: string,\n  targetAnchorId: string | null,\n  scopeClauses: string[],\n  scopeParams: string[],\n): LatestMemoryLookupRow | undefined {\n  const whereClauses = [\n    'spec_folder = ?',\n    'parent_id IS NULL',\n    `${pathColumn} = ?`,\n    targetAnchorId !== null ? 'anchor_id = ?' : 'anchor_id IS NULL',\n    ...scopeClauses,\n  ];\n\n  return database.prepare(`\n    SELECT id, content_hash, embedding_status, trigger_phrases, quality_score, quality_flags\n    FROM memory_index\n    WHERE ${whereClauses.join('\\n      AND ')}\n    ORDER BY id DESC\n    LIMIT 1\n  `).get(\n    parsed.specFolder,\n    pathValue,\n    ...(targetAnchorId !== null ? [targetAnchorId] : []),\n    ...scopeParams,\n  ) as LatestMemoryLookupRow | undefined;\n}\n\nfunction parseJsonStringArray(raw: string | null): string[] {\n  if (!raw) {\n    return [];\n  }\n\n  try {\n    const parsed = JSON.parse(raw) as unknown;\n    return Array.isArray(parsed)\n      ? parsed.filter((value): value is string => typeof value === 'string')\n      : [];\n  } catch {\n    return [];\n  }\n}\n\nfunction normalizeStringArray(values: string[]): string[] {\n  return [...new Set(values.map(value => value.trim()).filter(Boolean))].sort();\n}\n\nfunction areEquivalentStringArrays(left: string[], right: string[]): boolean {\n  const normalizedLeft = normalizeStringArray(left);\n  const normalizedRight = normalizeStringArray(right);\n\n  if (normalizedLeft.length !== normalizedRight.length) {\n    return false;\n  }\n\n  return normalizedLeft.every((value, index) => value === normalizedRight[index]);\n}\n\nfunction isSamePathMetadataEquivalent(\n  existing: {\n    trigger_phrases: string | null;\n    quality_score: number | null;\n    quality_flags: string | null;\n  },\n  parsed: ParsedMemory,\n): boolean {\n  const persistedTriggerPhrases = parseJsonStringArray(existing.trigger_phrases);\n  if (!areEquivalentStringArrays(persistedTriggerPhrases, parsed.triggerPhrases)) {\n    return false;\n  }\n\n  const persistedQualityFlags = parseJsonStringArray(existing.quality_flags);\n  if (!areEquivalentStringArrays(persistedQualityFlags, parsed.qualityFlags ?? [])) {\n    return false;\n  }\n\n  const persistedQualityScore = existing.quality_score ?? 0;\n  const parsedQualityScore = parsed.qualityScore ?? 0;\n  return Math.abs(persistedQualityScore - parsedQualityScore) <= QUALITY_SCORE_EPSILON;\n}\n\nfunction verifyStoredContentMatch(\n  storedContent: string | null | undefined,\n  storedPath: string | null | undefined,\n  incomingContent: string,\n): boolean | null {\n  if (typeof storedContent === 'string') {\n    return storedContent === incomingContent;\n  }\n\n  if (typeof storedPath === 'string' && storedPath.length > 0) {\n    try {\n      if (fs.existsSync(storedPath)) {\n        return fs.readFileSync(storedPath, 'utf-8') === incomingContent;\n      }\n    } catch {\n      return null;\n    }\n  }\n\n  return null;\n}\n\nfunction resolveCheckExistingRowArgs(\n  targetAnchorIdOrForce: string | null | boolean,\n  forceOrWarnings: boolean | string[] | undefined,\n  warningsOrScope: string[] | MemoryScopeMatch | undefined,\n  scope: MemoryScopeMatch,\n): CheckExistingRowArgs {\n  if (typeof targetAnchorIdOrForce === 'boolean') {\n    return {\n      targetAnchorId: null,\n      warnings: Array.isArray(forceOrWarnings) ? forceOrWarnings : undefined,\n      scope: Array.isArray(warningsOrScope) || !warningsOrScope ? scope : warningsOrScope,\n    };\n  }\n\n  return {\n    targetAnchorId: targetAnchorIdOrForce ?? null,\n    warnings: Array.isArray(warningsOrScope)\n      ? warningsOrScope\n      : (Array.isArray(forceOrWarnings) ? forceOrWarnings : undefined),\n    scope: Array.isArray(warningsOrScope) || !warningsOrScope ? scope : warningsOrScope,\n  };\n}\n\nexport function checkExistingRow(\n  database: Database.Database,\n  parsed: ParsedMemory,\n  canonicalFilePath: string,\n  filePath: string,\n  targetAnchorIdOrForce: string | null | boolean,\n  forceOrWarnings: boolean | string[] | undefined,\n  warningsOrScope?: string[] | MemoryScopeMatch,\n  scope: MemoryScopeMatch = {},\n): IndexResult | null {\n  const {\n    targetAnchorId,\n    warnings,\n    scope: resolvedScope,\n  } = resolveCheckExistingRowArgs(targetAnchorIdOrForce, forceOrWarnings, warningsOrScope, scope);\n  const { clauses: scopeClauses, params: scopeParams } = buildScopedWhereClauses(resolvedScope);\n  const candidates = [\n    selectLatestExistingRow(\n      database,\n      parsed,\n      'canonical_file_path',\n      canonicalFilePath,\n      targetAnchorId,\n      scopeClauses,\n      scopeParams,\n    ),\n  ];\n\n  if (filePath !== canonicalFilePath) {\n    candidates.push(\n      selectLatestExistingRow(\n        database,\n        parsed,\n        'file_path',\n        filePath,\n        targetAnchorId,\n        scopeClauses,\n        scopeParams,\n      ),\n    );\n  }\n\n  const existing = candidates\n    .filter((candidate): candidate is LatestMemoryLookupRow => candidate !== undefined)\n    .sort((left, right) => right.id - left.id)[0];\n\n  const existingStatus = existing?.embedding_status ?? null;","lineStart":1,"lineEnd":260,"totalLines":357,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/dedup.ts","time":{"start":1781761693172,"end":1781761693176}},"metadata":{"openai":{"itemId":"fc_080cc7e967ed30dd016a33869cc60c8191926f21cccdf82a1e"}},"id":"prt_ed945d5df001c7bgIJyr39OM6d","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed945acc9001SMV0LBvG4y1962"}}
{"type":"tool_use","timestamp":1781761693200,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_D2bJ2xlv7vr2GugNbMOYUctc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Spec Folder Mutex\n3: // ───────────────────────────────────────────────────────────────\n4: // Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n5: \n6: import { createHash } from 'node:crypto';\n7: import fs from 'node:fs';\n8: import os from 'node:os';\n9: import path from 'node:path';\n10: \n11: // Feature catalog: Memory indexing (memory_save)\n12: // Feature catalog: Atomic-save parity and partial-indexing hints\n13: \n14: const SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\n15: const LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\n16: const LOCK_WAIT_MS = 25;\n17: const LOCK_TIMEOUT_MS = 30_000;\n18: const LOCK_STALE_MS = 5 * 60 * 1000;\n19: const LOCK_HEARTBEAT_MS = 60_000;\n20: \n21: type LockOwnerState = 'alive' | 'dead' | 'unknown';\n22: \n23: const lockHeartbeats = new Map<string, ReturnType<typeof setInterval>>();\n24: \n25: interface InterprocessLockHandle {\n26:   lockDir: string;\n27: }\n28: \n29: function sleep(ms: number): Promise<void> {\n30:   return new Promise((resolve) => setTimeout(resolve, ms));\n31: }\n32: \n33: function getLockDir(specFolder: string): string {\n34:   const digest = createHash('sha1').update(specFolder).digest('hex');\n35:   return path.join(LOCK_ROOT, digest);\n36: }\n37: \n38: function isExistingDirectoryError(error: unknown): boolean {\n39:   return Boolean(error && typeof error === 'object' && 'code' in error && (error as { code?: string }).code === 'EEXIST');\n40: }\n41: \n42: function getNodeErrorCode(error: unknown): string | null {\n43:   if (error && typeof error === 'object' && 'code' in error) {\n44:     const code = (error as { code?: unknown }).code;\n45:     return typeof code === 'string' ? code : null;\n46:   }\n47:   return null;\n48: }\n49: \n50: // Read back the lock owner pid and probe whether that process is still alive.\n51: // A live owner must never be reaped — that is the TOCTOU this mutex prevents.\n52: function getLockOwnerState(lockDir: string): LockOwnerState {\n53:   let ownerRaw: string;\n54:   try {\n55:     ownerRaw = fs.readFileSync(path.join(lockDir, 'owner.json'), 'utf8');\n56:   } catch {\n57:     return 'unknown';\n58:   }\n59: \n60:   let ownerPid: number;\n61:   try {\n62:     const parsed = JSON.parse(ownerRaw) as { pid?: unknown };\n63:     ownerPid = Number(parsed.pid);\n64:   } catch {\n65:     return 'unknown';\n66:   }\n67:   if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n68:     return 'unknown';\n69:   }\n70: \n71:   try {\n72:     process.kill(ownerPid, 0);\n73:     return 'alive';\n74:   } catch (error: unknown) {\n75:     const code = getNodeErrorCode(error);\n76:     if (code === 'ESRCH') {\n77:       return 'dead';\n78:     }\n79:     if (code === 'EPERM') {\n80:       return 'alive';\n81:     }\n82:     return 'unknown';\n83:   }\n84: }\n85: \n86: // A lock is reclaimable only when its owner is provably gone (dead), or when the\n87: // owner record is unreadable AND the dir has aged past the stale threshold.\n88: // An alive owner is never reclaimable, regardless of age.\n89: function isReclaimableLock(lockDir: string): boolean {\n90:   let ageMs: number;\n91:   try {\n92:     const stats = fs.statSync(lockDir);\n93:     ageMs = Date.now() - stats.mtimeMs;\n94:   } catch {\n95:     return false;\n96:   }\n97:   const ownerState = getLockOwnerState(lockDir);\n98:   return ownerState === 'dead' || (ownerState === 'unknown' && ageMs > LOCK_STALE_MS);\n99: }\n100: \n101: function stopHeartbeat(lockDir: string): void {\n102:   const heartbeat = lockHeartbeats.get(lockDir);\n103:   if (!heartbeat) {\n104:     return;\n105:   }\n106:   clearInterval(heartbeat);\n107:   lockHeartbeats.delete(lockDir);\n108: }\n109: \n110: // Refresh the lock dir mtime while fn() runs so a long-but-live save is never\n111: // mistaken for an abandoned lock by the stale-age fallback.\n112: function startHeartbeat(lockDir: string): void {\n113:   stopHeartbeat(lockDir);\n114:   const heartbeat = setInterval(() => {\n115:     try {\n116:       const now = new Date();\n117:       fs.utimesSync(lockDir, now, now);\n118:     } catch {\n119:       stopHeartbeat(lockDir);\n120:     }\n121:   }, LOCK_HEARTBEAT_MS);\n122:   const unref = (heartbeat as { unref?: () => void }).unref;\n123:   unref?.call(heartbeat);\n124:   lockHeartbeats.set(lockDir, heartbeat);\n125: }\n126: \n127: function createInterprocessLock(specFolder: string, lockDir: string): InterprocessLockHandle {\n128:   fs.mkdirSync(lockDir);\n129:   fs.writeFileSync(path.join(lockDir, 'owner.json'), JSON.stringify({\n130:     pid: process.pid,\n131:     specFolder,\n132:     acquiredAt: new Date().toISOString(),\n133:   }));\n134:   startHeartbeat(lockDir);\n135:   return { lockDir };\n136: }\n137: \n138: function releaseInterprocessLock(handle: InterprocessLockHandle): void {\n139:   stopHeartbeat(handle.lockDir);\n140:   try {\n141:     fs.rmSync(handle.lockDir, { recursive: true, force: true });\n142:   } catch (error: unknown) {\n143:     console.warn('[memory-save] failed to release interprocess spec-folder lock:', error);\n144:   }\n145: }\n146: \n147: async function acquireInterprocessLock(specFolder: string): Promise<InterprocessLockHandle> {\n148:   const lockDir = getLockDir(specFolder);\n149:   const deadline = Date.now() + LOCK_TIMEOUT_MS;\n150: \n151:   fs.mkdirSync(LOCK_ROOT, { recursive: true });\n152: \n153:   while (true) {\n154:     try {\n155:       return createInterprocessLock(specFolder, lockDir);\n156:     } catch (error: unknown) {\n157:       if (!isExistingDirectoryError(error)) {\n158:         throw error;\n159:       }\n160: \n161:       if (isReclaimableLock(lockDir)) {\n162:         fs.rmSync(lockDir, { recursive: true, force: true });\n163:         continue;\n164:       }\n165: \n166:       if (Date.now() >= deadline) {\n167:         throw new Error(`Timed out acquiring interprocess spec-folder lock for ${specFolder}`);\n168:       }\n169: \n170:       await sleep(LOCK_WAIT_MS);\n171:     }\n172:   }\n173: }\n174: \n175: async function withSpecFolderLock<T>(specFolder: string, fn: () => Promise<T>): Promise<T> {\n176:   const normalizedFolder = specFolder || '__global__';\n177:   const chain = (SPEC_FOLDER_LOCKS.get(normalizedFolder) ?? Promise.resolve())\n178:     .catch((error: unknown) => {\n179:       console.error('[memory-save] prior queued save failed:', error);\n180:     })\n181:     .then(async () => {\n182:       const interprocessLock = await acquireInterprocessLock(normalizedFolder);\n183:       try {\n184:         return await fn();\n185:       } finally {\n186:         releaseInterprocessLock(interprocessLock);\n187:       }\n188:     });\n189:   SPEC_FOLDER_LOCKS.set(normalizedFolder, chain);\n190:   try {\n191:     return await chain;\n192:   } finally {\n193:     if (SPEC_FOLDER_LOCKS.get(normalizedFolder) === chain) {\n194:       SPEC_FOLDER_LOCKS.delete(normalizedFolder);\n195:     }\n196:   }\n197: }\n198: \n199: export {\n200:   SPEC_FOLDER_LOCKS,\n201:   withSpecFolderLock,\n202:   // Exported for targeted lock-liveness tests; not part of the save flow API.\n203:   LOCK_STALE_MS,\n204:   LOCK_HEARTBEAT_MS,\n205:   getLockDir,\n206:   getLockOwnerState,\n207:   isReclaimableLock,\n208:   createInterprocessLock,\n209:   releaseInterprocessLock,\n210: };\n\n(End of file - total 210 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Spec Folder Mutex\n// ───────────────────────────────────────────────────────────────\n// Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n\nimport { createHash } from 'node:crypto';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport path from 'node:path';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\nconst SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\nconst LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\nconst LOCK_WAIT_MS = 25;\nconst LOCK_TIMEOUT_MS = 30_000;\nconst LOCK_STALE_MS = 5 * 60 * 1000;\nconst LOCK_HEARTBEAT_MS = 60_000;\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Spec Folder Mutex\n// ───────────────────────────────────────────────────────────────\n// Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n\nimport { createHash } from 'node:crypto';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport path from 'node:path';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\nconst SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\nconst LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\nconst LOCK_WAIT_MS = 25;\nconst LOCK_TIMEOUT_MS = 30_000;\nconst LOCK_STALE_MS = 5 * 60 * 1000;\nconst LOCK_HEARTBEAT_MS = 60_000;\n\ntype LockOwnerState = 'alive' | 'dead' | 'unknown';\n\nconst lockHeartbeats = new Map<string, ReturnType<typeof setInterval>>();\n\ninterface InterprocessLockHandle {\n  lockDir: string;\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction getLockDir(specFolder: string): string {\n  const digest = createHash('sha1').update(specFolder).digest('hex');\n  return path.join(LOCK_ROOT, digest);\n}\n\nfunction isExistingDirectoryError(error: unknown): boolean {\n  return Boolean(error && typeof error === 'object' && 'code' in error && (error as { code?: string }).code === 'EEXIST');\n}\n\nfunction getNodeErrorCode(error: unknown): string | null {\n  if (error && typeof error === 'object' && 'code' in error) {\n    const code = (error as { code?: unknown }).code;\n    return typeof code === 'string' ? code : null;\n  }\n  return null;\n}\n\n// Read back the lock owner pid and probe whether that process is still alive.\n// A live owner must never be reaped — that is the TOCTOU this mutex prevents.\nfunction getLockOwnerState(lockDir: string): LockOwnerState {\n  let ownerRaw: string;\n  try {\n    ownerRaw = fs.readFileSync(path.join(lockDir, 'owner.json'), 'utf8');\n  } catch {\n    return 'unknown';\n  }\n\n  let ownerPid: number;\n  try {\n    const parsed = JSON.parse(ownerRaw) as { pid?: unknown };\n    ownerPid = Number(parsed.pid);\n  } catch {\n    return 'unknown';\n  }\n  if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n    return 'unknown';\n  }\n\n  try {\n    process.kill(ownerPid, 0);\n    return 'alive';\n  } catch (error: unknown) {\n    const code = getNodeErrorCode(error);\n    if (code === 'ESRCH') {\n      return 'dead';\n    }\n    if (code === 'EPERM') {\n      return 'alive';\n    }\n    return 'unknown';\n  }\n}\n\n// A lock is reclaimable only when its owner is provably gone (dead), or when the\n// owner record is unreadable AND the dir has aged past the stale threshold.\n// An alive owner is never reclaimable, regardless of age.\nfunction isReclaimableLock(lockDir: string): boolean {\n  let ageMs: number;\n  try {\n    const stats = fs.statSync(lockDir);\n    ageMs = Date.now() - stats.mtimeMs;\n  } catch {\n    return false;\n  }\n  const ownerState = getLockOwnerState(lockDir);\n  return ownerState === 'dead' || (ownerState === 'unknown' && ageMs > LOCK_STALE_MS);\n}\n\nfunction stopHeartbeat(lockDir: string): void {\n  const heartbeat = lockHeartbeats.get(lockDir);\n  if (!heartbeat) {\n    return;\n  }\n  clearInterval(heartbeat);\n  lockHeartbeats.delete(lockDir);\n}\n\n// Refresh the lock dir mtime while fn() runs so a long-but-live save is never\n// mistaken for an abandoned lock by the stale-age fallback.\nfunction startHeartbeat(lockDir: string): void {\n  stopHeartbeat(lockDir);\n  const heartbeat = setInterval(() => {\n    try {\n      const now = new Date();\n      fs.utimesSync(lockDir, now, now);\n    } catch {\n      stopHeartbeat(lockDir);\n    }\n  }, LOCK_HEARTBEAT_MS);\n  const unref = (heartbeat as { unref?: () => void }).unref;\n  unref?.call(heartbeat);\n  lockHeartbeats.set(lockDir, heartbeat);\n}\n\nfunction createInterprocessLock(specFolder: string, lockDir: string): InterprocessLockHandle {\n  fs.mkdirSync(lockDir);\n  fs.writeFileSync(path.join(lockDir, 'owner.json'), JSON.stringify({\n    pid: process.pid,\n    specFolder,\n    acquiredAt: new Date().toISOString(),\n  }));\n  startHeartbeat(lockDir);\n  return { lockDir };\n}\n\nfunction releaseInterprocessLock(handle: InterprocessLockHandle): void {\n  stopHeartbeat(handle.lockDir);\n  try {\n    fs.rmSync(handle.lockDir, { recursive: true, force: true });\n  } catch (error: unknown) {\n    console.warn('[memory-save] failed to release interprocess spec-folder lock:', error);\n  }\n}\n\nasync function acquireInterprocessLock(specFolder: string): Promise<InterprocessLockHandle> {\n  const lockDir = getLockDir(specFolder);\n  const deadline = Date.now() + LOCK_TIMEOUT_MS;\n\n  fs.mkdirSync(LOCK_ROOT, { recursive: true });\n\n  while (true) {\n    try {\n      return createInterprocessLock(specFolder, lockDir);\n    } catch (error: unknown) {\n      if (!isExistingDirectoryError(error)) {\n        throw error;\n      }\n\n      if (isReclaimableLock(lockDir)) {\n        fs.rmSync(lockDir, { recursive: true, force: true });\n        continue;\n      }\n\n      if (Date.now() >= deadline) {\n        throw new Error(`Timed out acquiring interprocess spec-folder lock for ${specFolder}`);\n      }\n\n      await sleep(LOCK_WAIT_MS);\n    }\n  }\n}\n\nasync function withSpecFolderLock<T>(specFolder: string, fn: () => Promise<T>): Promise<T> {\n  const normalizedFolder = specFolder || '__global__';\n  const chain = (SPEC_FOLDER_LOCKS.get(normalizedFolder) ?? Promise.resolve())\n    .catch((error: unknown) => {\n      console.error('[memory-save] prior queued save failed:', error);\n    })\n    .then(async () => {\n      const interprocessLock = await acquireInterprocessLock(normalizedFolder);\n      try {\n        return await fn();\n      } finally {\n        releaseInterprocessLock(interprocessLock);\n      }\n    });\n  SPEC_FOLDER_LOCKS.set(normalizedFolder, chain);\n  try {\n    return await chain;\n  } finally {\n    if (SPEC_FOLDER_LOCKS.get(normalizedFolder) === chain) {\n      SPEC_FOLDER_LOCKS.delete(normalizedFolder);\n    }\n  }\n}\n\nexport {\n  SPEC_FOLDER_LOCKS,\n  withSpecFolderLock,\n  // Exported for targeted lock-liveness tests; not part of the save flow API.\n  LOCK_STALE_MS,\n  LOCK_HEARTBEAT_MS,\n  getLockDir,\n  getLockOwnerState,\n  isReclaimableLock,\n  createInterprocessLock,\n  releaseInterprocessLock,\n};","lineStart":1,"lineEnd":210,"totalLines":210,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","time":{"start":1781761693195,"end":1781761693198}},"metadata":{"openai":{"itemId":"fc_080cc7e967ed30dd016a33869cc6148191b5b637d70d890a43"}},"id":"prt_ed945d5fb001FOayfrzEdL9bd6","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed945acc9001SMV0LBvG4y1962"}}
