p(spreadResults.map(sr => [sr.id, sr.activationScore]));\n1871:         for (const result of reranked) {\n1872:           const boost = spreadMap.get(result.id as number);\n1873:           if (boost !== undefined) {\n1874:             // Update all score aliases so downstream consumers see the boost.\n1875:             const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n1876:             (result as Record<string, unknown>).score = boostedScore;\n1877:             if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n1878:             if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n1879:           }\n1880:         }\n1881:       }\n1882:       // Re-sort after co-activation boost to ensure boosted results\n1883:       // Are promoted to their correct position in the ranking\n1884:       reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n1885:     } catch (err: unknown) {\n1886:       // Non-critical enrichment — co-activation failure does not affect core ranking\n1887:       console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n1888:     }\n1889:   }\n1890: \n1891:   // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n1892:   if (db && isFolderScoringEnabled() && reranked.length > 0) {\n1893:     try {\n1894:       const numericIds = reranked\n1895:         .map(r => r.id)\n1896:         .filter((id): id is number => typeof id === 'number');\n1897: \n1898:       if (numericIds.length > 0) {\n1899:         const folderMap = lookupFolders(db, numericIds);\n\n(Showing lines 1150-1899 of 2972. Use offset=1900 to continue.)\n</content>","metadata":{"preview":"  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const {\n    limit = DEFAULT_LIMIT,\n    specFolder,\n    minSimilarity = 0,\n    useBm25 = isBm25Enabled(),\n    useFts = true,\n    useVector = true,\n    useGraph = true,\n    includeArchived = false,\n  } = options;\n\n  const results: HybridSearchResult[] = [];\n\n  // Vector search\n  if (useVector && embedding && vectorSearchFn) {\n    try {\n      const vectorResults = vectorSearchFn(embedding, {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const {\n    limit = DEFAULT_LIMIT,\n    specFolder,\n    minSimilarity = 0,\n    useBm25 = isBm25Enabled(),\n    useFts = true,\n    useVector = true,\n    useGraph = true,\n    includeArchived = false,\n  } = options;\n\n  const results: HybridSearchResult[] = [];\n\n  // Vector search\n  if (useVector && embedding && vectorSearchFn) {\n    try {\n      const vectorResults = vectorSearchFn(embedding, {\n        limit,\n        specFolder,\n        minSimilarity,\n        includeConstitutional: false, // Handler manages constitutional separately\n        includeArchived,\n      });\n      for (const r of vectorResults) {\n        results.push({\n          ...r,\n          id: r.id as number,\n          score: (r.similarity as number) || 0,\n          source: 'vector',\n        });\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n    }\n  }\n\n  // FTS search\n  if (useFts) {\n    const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n    results.push(...ftsResults);\n  }\n\n  // BM25 search\n  if (useBm25) {\n    const bm25Results = bm25Search(query, { limit, specFolder });\n    results.push(...bm25Results);\n  }\n\n  // Graph search\n  if (useGraph && graphSearchFn) {\n    try {\n      graphMetrics.totalQueries++;\n      const graphResults = graphSearchFn(query, { limit, specFolder });\n      for (const r of graphResults) {\n        results.push({\n          ...r,\n          id: r.id as number | string,\n          score: (r.score as number) || 0,\n          source: 'graph',\n        });\n      }\n      if (graphResults.length > 0) {\n        graphMetrics.graphHits++;\n        graphMetrics.graphResultCount += graphResults.length;\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n    }\n  }\n\n  // Normalize scores per source before merging so one method's raw scale\n  // Does not dominate others during final ranking.\n  const bySource = new Map<string, HybridSearchResult[]>();\n  for (const r of results) {\n    const src = r.source || 'unknown';\n    if (!bySource.has(src)) bySource.set(src, []);\n    bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n  }\n\n  const normalized: HybridSearchResult[] = [];\n  for (const [, group] of bySource) {\n    if (group.length === 0) continue;\n    const scores = group.map(r => r.score);\n    let min = Infinity;\n    let max = -Infinity;\n    for (const s of scores) {\n      if (s < min) min = s;\n      if (s > max) max = s;\n    }\n    const range = max - min;\n    for (const r of group) {\n      normalized.push({\n        ...r,\n        score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n      });\n    }\n  }\n\n  // Deduplicate by ID (keep highest normalized score)\n  // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n  // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n  // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n  // Field and downstream consumers would need to be updated accordingly.\n  const deduped = new Map<string, HybridSearchResult>();\n  for (const r of normalized) {\n    const canonicalId = canonicalResultId(r.id);\n    const existing = deduped.get(canonicalId);\n    if (!existing || r.score > existing.score) {\n      deduped.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(deduped.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, limit);\n}\n\n/**\n * Enhanced hybrid search with RRF fusion.\n * All search channels use synchronous better-sqlite3; sequential execution\n * is correct — Promise.all would add overhead without achieving parallelism.\n */\nasync function hybridSearchEnhanced(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const execution = await collectAndFuseHybridResults(query, embedding, options);\n  if (execution) {\n    if (options.stopAfterFusion) {\n      return applyResultLimit(execution.fusedResults, options.limit);\n    }\n\n    return enrichFusedResults(query, execution, options);\n  }\n\n  return hybridSearch(query, embedding, options);\n}\n\nasync function collectAndFuseHybridResults(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridFusionExecution | null> {\n  try {\n    const evaluationMode = options.evaluationMode === true;\n    const lists: HybridFusionExecution['lists'] = [];\n\n    // Pipeline metadata collector (populated by flag-gated stages)\n    const s3meta: Sprint3PipelineMeta = {};\n\n    // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n    // When enabled, classifies query complexity and restricts channels to a\n    // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n    const routeResult = routeQuery(query, options.triggerPhrases);\n    const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n    const activeChannels = options.forceAllChannels\n      ? new Set<ChannelName>(allPossibleChannels)\n      : new Set<ChannelName>(routeResult.channels);\n\n    // Respect explicit caller channel disables across both the primary route and\n    // every fallback tier. useGraph=false also disables the dependent degree lane.\n    const allowedChannels = getAllowedChannels(options);\n    for (const channel of allPossibleChannels) {\n      if (!allowedChannels.has(channel)) activeChannels.delete(channel);\n    }\n\n    const skippedChannels = allPossibleChannels.filter(ch => !activeChannels.has(ch));\n\n    if (skippedChannels.length > 0) {\n      s3meta.routing = {\n        tier: routeResult.tier,\n        channels: routeResult.channels,\n        skippedChannels,\n        featureFlagEnabled: isComplexityRouterEnabled(),\n        confidence: routeResult.classification.confidence,\n        features: routeResult.classification.features as Record<string, unknown>,\n      };\n    }\n\n    // -- Stage E: Dynamic Token Budget (SPECKIT_DYNAMIC_TOKEN_BUDGET) --\n    // Compute tier-aware budget early so it's available for downstream truncation.\n    // When disabled, getDynamicTokenBudget returns the default 4000 budget with applied=false.\n    // Weak / low-confidence queries keep the full budget so recall is not trimmed away.\n    const lowSignalQuery =\n      routeResult.classification.confidence === 'low' ||\n      routeResult.classification.confidence === 'fallback';\n    const budgetResult = getDynamicTokenBudget(routeResult.tier, undefined, {\n      lowSignal: lowSignalQuery,\n    });\n    if (budgetResult.applied && !evaluationMode) {\n      s3meta.tokenBudget = {\n        tier: budgetResult.tier,\n        budget: budgetResult.budget,\n        applied: budgetResult.applied,\n        featureFlagEnabled: isDynamicTokenBudgetEnabled(),\n        configValues: DEFAULT_TOKEN_BUDGET_CONFIG as unknown as Record<string, number>,\n        // headerOverhead and adjustedBudget are patched in below after they are computed\n        headerOverhead: 0,\n        adjustedBudget: budgetResult.budget,\n      };\n    }\n\n    // Channel results collected independently, merged after all complete\n    let semanticResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [];\n    let ftsChannelResults: HybridSearchResult[] = [];\n    let bm25ChannelResults: HybridSearchResult[] = [];\n    let triggerChannelResults: HybridSearchResult[] = [];\n    const vectorEmbeddingCache = new Map<number, Float32Array>();\n\n    // All channels use synchronous better-sqlite3; sequential execution\n    // Is correct — Promise.all adds overhead without parallelism.\n\n    // Vector channel — gated by query-complexity routing\n    if (activeChannels.has('vector') && embedding && vectorSearchFn) {\n      try {\n        const vectorResults = vectorSearchFn(embedding, {\n          limit: options.limit || DEFAULT_LIMIT,\n          specFolder: options.specFolder,\n          minSimilarity: options.minSimilarity || 0,\n          includeConstitutional: false,\n          includeArchived: options.includeArchived || false,\n          includeEmbeddings: true,\n        });\n        semanticResults = vectorResults.map((r: Record<string, unknown>): { id: number | string; source: string; [key: string]: unknown } => ({\n          ...r,\n          id: r.id as number | string,\n          source: 'vector',\n        }));\n        for (const result of semanticResults) {\n          if (typeof result.id !== 'number') continue;\n          const embeddingCandidate = toEmbeddingBufferView(\n            (result as Record<string, unknown>).embedding\n            ?? (result as Record<string, unknown>).embeddingBuffer\n          );\n          if (embeddingCandidate) {\n            vectorEmbeddingCache.set(result.id, embeddingCandidate);\n          }\n        }\n        lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n      } catch (_err: unknown) {\n        // Non-critical — vector channel failure does not block pipeline\n        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // FTS channel (internal error handling in ftsSearch) — gated by query-complexity routing\n    if (activeChannels.has('fts')) {\n      ftsChannelResults = ftsSearch(query, options);\n      if (ftsChannelResults.length > 0) {\n        // FTS weight reduced to 0.3 after ablation showed 0.8 was harmful,\n        // flooding top-K with noisy lexical matches despite its exact-match value.\n        lists.push({ source: 'fts', results: ftsChannelResults, weight: 0.3 });\n      }\n    }\n\n    // BM25 channel (internal error handling in bm25Search) — gated by query-complexity routing\n    if (activeChannels.has('bm25')) {\n      bm25ChannelResults = bm25Search(query, options);\n      if (bm25ChannelResults.length > 0) {\n        // BM25 weight 0.6 is lowest lexical channel — in-memory BM25 index\n        // Has less precise scoring than SQLite FTS5 BM25; kept for coverage breadth.\n        lists.push({ source: 'bm25', results: bm25ChannelResults, weight: 0.6 });\n      }\n    }\n\n    triggerChannelResults = exactTriggerSearch(query, options);\n    if (triggerChannelResults.length > 0) {\n      lists.push({ source: 'trigger', results: triggerChannelResults, weight: 1.4 });\n    }\n\n    // Graph channel — gated by query-complexity routing\n    const useGraph = (options.useGraph !== false) && activeChannels.has('graph');\n    if (useGraph && graphSearchFn) {\n      try {\n        graphMetrics.totalQueries++; // counted only if channel executes\n        const graphResults = graphSearchFn(query, {\n          limit: options.limit || DEFAULT_LIMIT,\n          specFolder: options.specFolder,\n          intent: options.intent,\n        });\n        if (graphResults.length > 0) {\n          graphMetrics.graphHits++;\n          graphMetrics.graphResultCount += graphResults.length;\n          lists.push({ source: 'graph', results: graphResults.map((r: Record<string, unknown>) => ({\n            ...r,\n            id: r.id as number | string,\n          })), weight: 0.5 });\n        }\n      } catch (_err: unknown) {\n        // Non-critical — graph channel failure does not block pipeline\n        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // Degree channel re-ranks based on causal-edge connectivity.\n    // Graduated: default-ON. Set SPECKIT_DEGREE_BOOST=false to disable.\n    // Degree channel — also gated by query-complexity routing\n    if (activeChannels.has('degree') && db && isDegreeBoostEnabled()) {\n      try {\n        graphMetrics.degreeQueries++;\n        // Collect all numeric IDs from existing channels\n        const allResultIds = new Set<number>();\n        for (const list of lists) {\n          for (const r of list.results) {\n            const id = r.id;\n            if (typeof id === 'number') allResultIds.add(id);\n          }\n        }\n\n        if (allResultIds.size > 0) {\n          const degreeScores = computeDegreeScores(db, Array.from(allResultIds));\n\n          // Build a ranked list sorted by degree score (highest first)\n          const degreeItems: Array<{ id: number; degreeScore: number }> = [];\n          for (const [idStr, score] of degreeScores) {\n            const numId = Number(idStr);\n            if (score > 0 && !isNaN(numId)) {\n              degreeItems.push({ id: numId, degreeScore: score });\n            }\n          }\n          degreeItems.sort((a, b) => b.degreeScore - a.degreeScore);\n\n          if (degreeItems.length > 0) {\n            graphMetrics.degreeHits++;\n            graphMetrics.degreeResultCount += degreeItems.length;\n            lists.push({\n              source: 'degree',\n              results: degreeItems.map(item => ({\n                id: item.id,\n                degreeScore: item.degreeScore,\n              })),\n              weight: DEGREE_CHANNEL_WEIGHT,\n            });\n          }\n        }\n      } catch (_err: unknown) {\n        // Non-critical — degree channel failure does not block pipeline\n        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // Merge keyword results after all channels complete\n    const keywordResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [\n      ...ftsChannelResults,\n      ...bm25ChannelResults,\n    ];\n\n    if (options.skipFusion) {\n      return {\n        evaluationMode,\n        intent: options.intent || classifyIntent(query).intent,\n        lists,\n        routeResult,\n        budgetResult,\n        s3meta,\n        vectorEmbeddingCache,\n        fusedResults: collectCandidatesFromLists(\n          lists.filter((list) => list.source !== 'degree'),\n          options.limit ?? DEFAULT_LIMIT\n        ),\n      };\n    }\n\n    if (lists.length === 0) {\n      return null;\n    }\n\n    // Track multi-source and graph-only results\n    const sourceMap = new Map<string, Set<string>>();\n    for (const list of lists) {\n      for (const r of list.results) {\n        const key = canonicalResultId(r.id);\n        if (!sourceMap.has(key)) sourceMap.set(key, new Set());\n        sourceMap.get(key)!.add(list.source); // non-null safe: has() guard above guarantees entry exists\n      }\n    }\n    for (const [, sources] of sourceMap) {\n      if (sources.size > 1) graphMetrics.multiSourceResults++;\n      if (sources.size > 1 && sources.has('graph')) graphMetrics.graphMultiSourceResults++;\n      if (sources.size === 1 && sources.has('graph')) graphMetrics.graphOnlyResults++;\n    }\n\n    // Build weighted fusion lists once from lightweight adaptive\n    // weights, avoiding the heavier hybridAdaptiveFuse() standard-first path.\n    const detectedIntent = classifyIntent(query).intent;\n    const intent = resolveFusionIntentContract({\n      detectedIntent,\n      adaptiveFusionIntent: options.intent ?? null,\n      query,\n    })\n      ?? detectedIntent;\n    const adaptiveEnabled = isAdaptiveFusionEnabled();\n    const documentType = resolveAdaptiveDocumentType(lists.map((list) => ({\n      results: list.results as Array<Record<string, unknown>>,\n    })));\n    const fusionWeights = adaptiveEnabled\n      ? getAdaptiveWeights(intent, documentType)\n      : { semanticWeight: 1.0, keywordWeight: 1.0, recencyWeight: 0 };\n    const { semanticWeight, keywordWeight, graphWeight: adaptiveGraphWeight } = fusionWeights;\n    const keywordFusionResults = keywordResults.map((result) => {\n      const originalSource = typeof result.source === 'string' ? result.source : null;\n      const existingSources = Array.isArray((result as Record<string, unknown>).sources)\n        ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n        : [];\n      return {\n        ...result,\n        source: 'keyword',\n        sources: Array.from(new Set([...existingSources, ...(originalSource ? [originalSource] : []), 'keyword'])),\n      };\n    });\n    const fusionLists = lists\n      .filter((list) => list.source !== 'fts' && list.source !== 'bm25')\n      .map((list) => {\n        if (list.source === 'vector') {\n          return { ...list, weight: semanticWeight };\n        }\n        if (list.source === 'graph' && typeof adaptiveGraphWeight === 'number') {\n          return { ...list, weight: adaptiveGraphWeight };\n        }\n        return { ...list };\n      });\n\n    if (keywordFusionResults.length > 0 && keywordWeight > 0) {\n      fusionLists.push({\n        source: 'keyword',\n        results: keywordFusionResults,\n        weight: keywordWeight,\n      });\n    }\n\n    const graphList = fusionLists.find((list) => list.source === 'graph');\n    const vectorList = fusionLists.find((list) => list.source === 'vector');\n    const passthroughLists = fusionLists.filter((list) => list.source !== 'graph' && list.source !== 'vector' && list.source !== 'keyword');\n    const fused = adaptiveEnabled\n      ? (adaptiveFuse as unknown as (\n        semanticResults: Array<Record<string, unknown>>,\n        keywordResults: Array<Record<string, unknown>>,\n        weights: typeof fusionWeights,\n        options: {\n          graphResults?: Array<Record<string, unknown>>;\n          additionalLists?: typeof passthroughLists;\n        },\n      ) => FusionResult[])(\n        (vectorList?.results ?? []) as Array<Record<string, unknown>>,\n        keywordFusionResults,\n        fusionWeights,\n        {\n          graphResults: (graphList?.results ?? []) as Array<Record<string, unknown>>,\n          additionalLists: passthroughLists,\n        },\n      )\n      : fuseResultsMulti(fusionLists);\n\n    const keywordSourceMap = new Map<string, string[]>();\n    for (const result of keywordFusionResults) {\n      const sources = Array.isArray((result as Record<string, unknown>).sources)\n        ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n        : [];\n      if (sources.length > 0) {\n        keywordSourceMap.set(canonicalResultId(result.id as number | string), sources);\n      }\n    }\n    const triggerScoreMap = new Map<string, number>();\n    for (const result of triggerChannelResults) {\n      if (typeof result.triggerScore === 'number' && Number.isFinite(result.triggerScore)) {\n        triggerScoreMap.set(canonicalResultId(result.id), result.triggerScore);\n      }\n    }\n\n    const fusedResults = fused.map(toHybridResult).map((row) => {\n      const keywordSources = keywordSourceMap.get(canonicalResultId(row.id));\n      if (keywordSources && keywordSources.length > 0) {\n        const rowSources = Array.isArray(row.sources)\n          ? row.sources.filter((source): source is string => typeof source === 'string')\n          : [];\n        const sources = Array.from(new Set([...rowSources, ...keywordSources]));\n        row = {\n          ...row,\n          sources,\n          channelAttribution: sources,\n          source: row.source === 'keyword'\n            ? (keywordSources.find((source) => source !== 'keyword') ?? row.source)\n            : row.source,\n        };\n      }\n      const triggerScore = triggerScoreMap.get(canonicalResultId(row.id));\n      if (triggerScore !== undefined && typeof row.triggerScore !== 'number') {\n        row = {\n          ...row,\n          triggerScore,\n          exactTriggerMatch: triggerScore >= 0.94,\n        };\n      }\n      const rowRecord = row as Record<string, unknown>;\n      if (rowRecord.parentMemoryId !== undefined) return row;\n      const normalizedParentMemoryId = rowRecord.parent_id ?? rowRecord.parentId;\n      if (normalizedParentMemoryId === undefined) return row;\n      return {\n        ...row,\n        parentMemoryId: normalizedParentMemoryId,\n      };\n    });\n\n    return {\n      evaluationMode,\n      intent,\n      lists,\n      routeResult,\n      budgetResult,\n      s3meta,\n      vectorEmbeddingCache,\n      fusedResults,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Enhanced search failed, falling back: ${msg}`);\n    return null;\n  }\n}\n\nasync function enrichFusedResults(\n  query: string,\n  execution: HybridFusionExecution,\n  options: HybridSearchOptions = {},\n  initialResults: HybridSearchResult[] = execution.fusedResults\n): Promise<HybridSearchResult[]> {\n  enrichFusedResultsObserver?.();\n\n  const {\n    evaluationMode,\n    intent,\n    lists,\n    routeResult,\n    budgetResult,\n    s3meta,\n    vectorEmbeddingCache,\n  } = execution;\n  let fusedHybridResults = initialResults;\n  const limit = options.limit || DEFAULT_LIMIT;\n\n  // -- Aggregation stage: MPAB chunk-to-memory aggregation (after fusion, before state filter) --\n  // When enabled, collapses chunk-level results back to their parent memory\n  // Documents using MPAB scoring (sMax + 0.3 * sum(remaining) / sqrt(N)). This prevents\n  // Multiple chunks from the same document dominating the result list.\n  // MINOR-1 fix: isMpabEnabled() and isDocscoreAggregationEnabled() check the same env var\n  if (isDocscoreAggregationEnabled()) {\n    try {\n      const chunkResults = fusedHybridResults.filter(\n        r => (r as Record<string, unknown>).parentMemoryId != null && (r as Record<string, unknown>).chunkIndex != null\n      );\n      if (chunkResults.length > 0) {\n        const nonChunkResults = fusedHybridResults.filter(\n          r => (r as Record<string, unknown>).parentMemoryId == null || (r as Record<string, unknown>).chunkIndex == null\n        );\n        const collapsed = collapseAndReassembleChunkResults(\n          chunkResults.map(r => ({\n            id: r.id,\n            parentMemoryId: (r as Record<string, unknown>).parentMemoryId as number | string,\n            chunkIndex: (r as Record<string, unknown>).chunkIndex as number,\n            score: r.score,\n          }))\n        );\n        // Merge collapsed chunk results with non-chunk results\n        fusedHybridResults = [\n          ...collapsed.map(c => ({\n            id: c.parentMemoryId,\n            score: c.mpabScore,\n            source: 'mpab' as string,\n            _chunkHits: c._chunkHits,\n          } as HybridSearchResult)),\n          ...nonChunkResults,\n        ];\n      }\n    } catch (_mpabErr: unknown) {\n      // Non-critical — MPAB failure does not block pipeline\n      const msg = _mpabErr instanceof Error ? _mpabErr.message : String(_mpabErr);\n      console.error('[hybrid-search] MPAB error (non-fatal):', msg);\n    }\n  }\n\n  // -- Stage C: Channel Enforcement (SPECKIT_CHANNEL_MIN_REP) --\n  // Ensures every channel that returned results has at least one representative\n  // In the top-k window. Prevents single-channel dominance in fusion output.\n  // When disabled, passes results through unchanged.\n  try {\n    const channelResultSets = new Map<string, Array<{ id: number | string; score: number; [key: string]: unknown }>>();\n    for (const list of lists) {\n      channelResultSets.set(list.source, list.results.map(r => ({\n        ...r,\n        id: r.id,\n        score: typeof (r as Record<string, unknown>).score === 'number'\n          ? (r as Record<string, unknown>).score as number\n          : typeof (r as Record<string, unknown>).similarity === 'number'\n            ? ((r as Record<string, unknown>).similarity as number) / 100\n            : 0,\n      })));\n    }\n\n    const enforcementResult: EnforcementResult = enforceChannelRepresentation(\n      fusedHybridResults.map(r => ({ ...r, source: r.source || 'hybrid' })),\n      channelResultSets,\n      limit,\n    );\n\n    if (enforcementResult.enforcement.applied) {\n      fusedHybridResults = dedupeResultsByCanonicalId(enforcementResult.results as HybridSearchResult[]);\n      s3meta.enforcement = {\n        applied: true,\n        promotedCount: enforcementResult.enforcement.promotedCount,\n        underRepresentedChannels: enforcementResult.enforcement.underRepresentedChannels,\n      };\n    }\n  } catch (err: unknown) {\n    // Non-critical — enforcement failure does not block pipeline\n    console.warn('[hybrid-search] channel enforcement failed:', err instanceof Error ? err.message : String(err));\n  }\n\n  // Preserve non-enumerable eval metadata across later array reallocations.\n  const shadowMeta = initialResults as HybridSearchResult[] & ShadowMetaArray;\n  const s4shadowMeta = shadowMeta._s4shadow;\n  const s4attributionMeta = shadowMeta._s4attribution;\n  const degradationMeta = shadowMeta._degradation;\n\n  // MMR reranking with request-scoped embedding cache.\n  // Reuse embeddings already returned by the vector channel when present and\n  // only query vec_memories for missing IDs.\n  let reranked: HybridSearchResult[] = fusedHybridResults.slice(0, limit);\n\n  if (db && isMMREnabled()) {\n    const numericIds = reranked\n      .map(r => r.id)\n      .filter((id): id is number => typeof id === 'number');\n\n    if (numericIds.length >= MMR_MIN_CANDIDATES) {\n      try {\n        const embeddingMap = new Map<number, Float32Array>(vectorEmbeddingCache);\n        const missingIds = numericIds.filter((id) => !embeddingMap.has(id));\n\n        if (missingIds.length > 0) {\n          const placeholders = missingIds.map(() => '?').join(', ');\n          const embRows = (db.prepare(\n            `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n          ) as Database.Statement).all(...missingIds) as Array<{ rowid: number; embedding: Buffer }>;\n\n          for (const row of embRows) {\n            if (Buffer.isBuffer(row.embedding)) {\n              embeddingMap.set(\n                row.rowid,\n                new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n              );\n            }\n          }\n        }\n\n        const mmrCandidates: MMRCandidate[] = [];\n        for (const r of reranked) {\n          const emb = embeddingMap.get(r.id as number);\n          if (emb) {\n            mmrCandidates.push({\n              id: r.id as number,\n              score: (r.score as number) ?? 0,\n              embedding: emb,\n            });\n          }\n        }\n\n        if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n          const mmrLambda = INTENT_LAMBDA_MAP[intent] ?? MMR_DEFAULT_LAMBDA;\n          const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit });\n\n          // FIX #6: Same fix as stage3-rerank FIX #5 — MMR can only diversify\n          // rows that have embeddings. Non-embedded rows (lexical-only hits,\n          // graph injections) must be preserved and merged back in their\n          // original relative order instead of being silently dropped.\n          const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n          const nonEmbeddedRows = reranked.filter(r => !embeddedIdSet.has(r.id as number));\n          const rerankedById = new Map<string, HybridSearchResult>(\n            reranked.map((result) => [canonicalResultId(result.id), result])\n          );\n\n          const diversifiedRows = diversified.map((candidate): HybridSearchResult => {\n            const existing = rerankedById.get(canonicalResultId(candidate.id));\n            if (existing) {\n              return existing;\n            }\n\n            return {\n              id: candidate.id,\n              score: candidate.score,\n              source: 'vector',\n            };\n          });\n\n          // Merge: diversified embedded rows first (MMR-ordered), then\n          // non-embedded rows in their original relative order.\n          reranked = [...diversifiedRows, ...nonEmbeddedRows];\n        }\n      } catch (embErr: unknown) {\n        const msg = embErr instanceof Error ? embErr.message : String(embErr);\n        console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n      }\n    }\n  }\n\n  // Co-activation spreading — enrich with temporal neighbors\n  const topIds = reranked\n    .slice(0, SPREAD_ACTIVATION_TOP_N)\n    .map(r => r.id)\n    .filter((id): id is number => typeof id === 'number');\n  if (topIds.length > 0) {\n    try {\n      const spreadResults: SpreadResult[] = spreadActivation(topIds);\n      // Boost scores of results that appear in co-activation graph\n      if (spreadResults.length > 0) {\n        const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n        for (const result of reranked) {\n          const boost = spreadMap.get(result.id as number);\n          if (boost !== undefined) {\n            // Update all score aliases so downstream consumers see the boost.\n            const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n            (result as Record<string, unknown>).score = boostedScore;\n            if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n            if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n          }\n        }\n      }\n      // Re-sort after co-activation boost to ensure boosted results\n      // Are promoted to their correct position in the ranking\n      reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n    } catch (err: unknown) {\n      // Non-critical enrichment — co-activation failure does not affect core ranking\n      console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n  if (db && isFolderScoringEnabled() && reranked.length > 0) {\n    try {\n      const numericIds = reranked\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length > 0) {\n        const folderMap = lookupFolders(db, numericIds);","lineStart":1150,"lineEnd":1899,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781762488119,"end":1781762488126}},"metadata":{"openai":{"itemId":"fc_04d5f3517b9f3ec5016a3389b7dad08191ad4de23d2ae1b67a"}},"id":"prt_ed951f719001G7Vgg2e4DGlJ3t","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed951b5a2001I2CZ6Z4HDN64s8"}}
{"type":"step_finish","timestamp":1781762488504,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"id":"prt_ed951f8b6001pkOhjdmd4y93kq","reason":"tool-calls","snapshot":"c53cc78c58efe34a6f719ec659d0a7eac7028a7c","messageID":"msg_ed951b5a2001I2CZ6Z4HDN64s8","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","type":"step-finish","tokens":{"total":100692,"input":9850,"output":525,"reasoning":205,"cache":{"write":0,"read":90112}},"cost":0}}
{"type":"step_start","timestamp":1781762490671,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"id":"prt_ed952012d001P2Btu7mLRxsslO","messageID":"msg_ed951f9f50011nSEI60i9v7yun","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","snapshot":"c53cc78c58efe34a6f719ec659d0a7eac7028a7c","type":"step-start"}}
{"type":"text","timestamp":1781762518706,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"id":"prt_ed9524b70001sjq82BZyvmW3zP","messageID":"msg_ed951f9f50011nSEI60i9v7yun","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","type":"text","text":"Initial read did not justify a P0/P1 yet; I’m expanding the pass to the handler/cache seam, fusion continuation, stage filters, and routing utilities where cross-module retrieval regressions are more likely.","time":{"start":1781762509680,"end":1781762518700},"metadata":{"openai":{"itemId":"msg_09fea31d49f1b9f7016a3389cda60c8191939b3d218f7cb504","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781762518781,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_w4gmOvA2laewlKsRgt76V5kL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage3 Rerank\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-Stage Retrieval Pipeline: Stage 3 of 4\n5: //\n6: // Responsibilities (in execution order):\n7: // 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n8: // 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n9: //\n10: // Pipeline position constraint:\n11: // MPAB MUST remain AFTER RRF fusion (Stage 2).\n12: // Stage 3 is the only stage that may change scores after Stage 2.\n13: //\n14: // I/O CONTRACT:\n15: // Input:  Stage3Input { scored: PipelineRow[], config }\n16: // Output: Stage3Output { reranked: PipelineRow[], metadata }\n17: // Key invariants:\n18: //     - reranked is sorted descending by effective score after all steps\n19: //     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n20: //     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'\n21: // Side effects:\n22: //     - DB reads to fetch parent content during MPAB reassembly\n23: //\n24: // Score changes: YES\n25: \n26: import { resolveEffectiveScore } from './types.js';\n27: import type { Stage3Input, Stage3Output, PipelineRow } from './types.js';\n28: import { isMMREnabled } from '../search-flags.js';\n29: import { computeMPAB } from '../../scoring/mpab-aggregation.js';\n30: import { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\n31: import type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\n32: import { INTENT_LAMBDA_MAP } from '../intent-classifier.js';\n33: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n34: import { requireDb } from '../../../utils/index.js';\n35: import { toErrorMessage } from '../../../utils/index.js';\n36: import type Database from 'better-sqlite3';\n37: import { compareDeterministicRows, sortDeterministicRows } from './ranking-contract.js';\n38: \n39: // Feature catalog: 4-stage pipeline architecture\n40: // Feature catalog: Hybrid search pipeline\n41: \n42: \n43: // -- Constants --------------------------------------------------\n44: \n45: /** Minimum number of candidates required before MMR diversity pruning is worthwhile. */\n46: const MMR_MIN_CANDIDATES = 2;\n47: \n48: /** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\n49: const MMR_DEFAULT_LAMBDA = 0.7;\n50: \n51: /**\n52:  * Enforce non-negative score outputs at Stage 3 boundaries.\n53:  */\n54: function floorScore(value: number): number {\n55:   return Math.max(0, value);\n56: }\n57: \n58: // -- Internal Interfaces ----------------------------------------\n59: \n60: /**\n61:  * Aggregated statistics from the MPAB chunk-collapse pass.\n62:  */\n63: interface ChunkReassemblyStats {\n64:   /** Number of child chunk rows removed from the result set. */\n65:   collapsedChunkHits: number;\n66:   /** Number of distinct parent IDs encountered among chunk hits. */\n67:   chunkParents: number;\n68:   /** Number of parents whose content was successfully reassembled from DB. */\n69:   reassembled: number;\n70:   /** Number of parents that fell back to using best-chunk content. */\n71:   fallback: number;\n72: }\n73: \n74: /**\n75:  * Internal representation of a chunk group — all chunks belonging\n76:  * to a single parent, ready for collapse and reassembly.\n77:  */\n78: interface ChunkGroup {\n79:   parentId: number;\n80:   chunks: PipelineRow[];\n81:   /** The chunk with the highest similarity/score — the representative row. */\n82:   bestChunk: PipelineRow;\n83:   /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n84:   parentScore: number;\n85: }\n86: \n87: type RerankProvider = 'fallback-sort' | 'none';\n88: \n89: // -- Stage 3 Entry Point ----------------------------------------\n90: \n91: /**\n92:  * Execute Stage 3: Rerank + Aggregate.\n93:  *\n94:  * Applies MMR diversity reranking (when enabled) and then collapses\n95:  * chunked memory hits into their parent documents (MPAB). Stage 3\n96:  * reduces near-duplicate chunks before parent reassembly aggregates\n97:  * the result set.\n98:  *\n99:  * @param input - Stage 3 input containing scored results from Stage 2\n100:  *   and the shared pipeline configuration.\n101:  * @returns Stage 3 output with reranked, aggregated results and metadata.\n102:  */\n103: export async function executeStage3(input: Stage3Input): Promise<Stage3Output> {\n104:   const stageStart = Date.now();\n105:   const { scored, config } = input;\n106: \n107:   let results = scored;\n108: \n109:   // -- Step 1: (removed) model-based cross-encoder reranking -----\n110:   // The cross-encoder / local-GGUF reranking layer was removed: it had no\n111:   // configured provider after the sidecar deprecation (isCrossEncoderEnabled()\n112:   // was hard-off), so it was an inactive no-op. Stage 3 now performs only\n113:   // algorithmic MMR diversity (Step 2) and MPAB chunk-collapse (Step 3).\n114:   // These constants preserve the unchanged metadata/envelope shape.\n115:   const rerankApplied = false;\n116:   const rerankProvider: RerankProvider = 'none';\n117: \n118:   // -- Step 2: MMR diversity pruning ----------------------------\n119:   // Gated behind SPECKIT_MMR feature flag. Retrieves embeddings from\n120:   // Vec_memories and applies Maximal Marginal Relevance to diversify\n121:   // The result set, matching the V1 hybrid-search behavior.\n122:   if (isMMREnabled() && results.length >= MMR_MIN_CANDIDATES) {\n123:     try {\n124:       const db = requireDb() as Database.Database;\n125:       const numericIds = results\n126:         .map(r => r.id)\n127:         .filter((id): id is number => typeof id === 'number');\n128: \n129:       if (numericIds.length >= MMR_MIN_CANDIDATES) {\n130:         const placeholders = numericIds.map(() => '?').join(', ');\n131:         const embRows = (db.prepare(\n132:           `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n133:         ) as Database.Statement).all(...numericIds) as Array<{ rowid: number; embedding: Buffer }>;\n134: \n135:         const embeddingMap = new Map<number, Float32Array>();\n136:         for (const row of embRows) {\n137:           if (Buffer.isBuffer(row.embedding)) {\n138:             embeddingMap.set(\n139:               row.rowid,\n140:               new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n141:             );\n142:           }\n143:         }\n144: \n145:         const mmrCandidates: MMRCandidate[] = [];\n146:         for (const r of results) {\n147:           const emb = embeddingMap.get(r.id);\n148:           if (emb) {\n149:             mmrCandidates.push({\n150:               id: r.id,\n151:               // Use effectiveScore() for consistent fallback chain\n152:               score: floorScore(effectiveScore(r)),\n153:               embedding: emb,\n154:             });\n155:           }\n156:         }\n157: \n158:         if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n159:           const originalPositionMap = new Map<number | string, number>();\n160:           results.forEach((row, index) => originalPositionMap.set(row.id, index));\n161:           const intent = config.adaptiveFusionIntent ?? config.detectedIntent ?? '';\n162:           const mmrLambda = (INTENT_LAMBDA_MAP as Record<string, number>)[intent] ?? MMR_DEFAULT_LAMBDA;\n163:           const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit: config.limit });\n164: \n165:           // FIX #5: MMR can only diversify rows that have embeddings. Non-embedded\n166:           // rows (lexical-only hits, graph injections) must be preserved and merged\n167:           // back in their original relative order instead of being silently dropped.\n168:           const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n169:           const nonEmbeddedRows = results.filter(r => !embeddedIdSet.has(r.id));\n170: \n171:           // Rebuild PipelineRow[] from diversified candidates, preserving all original fields\n172:           const rowMap = new Map<number | string, PipelineRow>();\n173:           for (const r of results) rowMap.set(r.id, r);\n174: \n175:           const diversifiedRows = diversified.map((candidate): PipelineRow => {\n176:             const existing = rowMap.get(candidate.id);\n177:             if (existing) return existing;\n178:             return { id: candidate.id as number, score: candidate.score };\n179:           });\n180: \n181:           const positioned: Array<{ row: PipelineRow; pos: number }> = [];\n182:           diversifiedRows.forEach((row, index) => positioned.push({ row, pos: index }));\n183:           nonEmbeddedRows.forEach((row) => {\n184:             const originalPosition = originalPositionMap.get(row.id) ?? results.length;\n185:             positioned.push({ row, pos: originalPosition });\n186:           });\n187: \n188:           positioned.sort((left, right) => left.pos - right.pos);\n189:           results = positioned.map(({ row }) => row);\n190:         }\n191:       }\n192:     } catch (mmrErr: unknown) {\n193:       // Non-critical — MMR failure does not block pipeline\n194:       console.warn(`[stage3-rerank] MMR diversity pruning failed: ${toErrorMessage(mmrErr)}`);\n195:     }\n196:   }\n197: \n198:   // -- Step 3: MPAB chunk collapse + parent reassembly -----------\n199:   //\n200:   // MPAB must remain AFTER RRF (Stage 2 constraint). This step runs\n201:   // Here in Stage 3 — never move it upstream.\n202:   const mpabStart = Date.now();\n203:   const beforeMpab = results.length;\n204: \n205:   const { results: aggregated, stats: chunkStats } =\n206:     await collapseAndReassembleChunkResults(results);\n207: \n208:   results = aggregated;\n209: \n210:   if (config.trace) {\n211:     addTraceEntry(\n212:       config.trace,\n213:       'final-rank',\n214:       beforeMpab,\n215:       results.length,\n216:       Date.now() - mpabStart,\n217:       {\n218:         collapsedChunkHits: chunkStats.collapsedChunkHits,\n219:         chunkParents: chunkStats.chunkParents,\n220:         reassembled: chunkStats.reassembled,\n221:         fallback: chunkStats.fallback,\n222:       }\n223:     );\n224:   }\n225: \n226:   const metadata = {\n227:     rerankApplied,\n228:     rerankProvider,\n229:     chunkReassemblyStats: chunkStats,\n230:     durationMs: Date.now() - stageStart,\n231:   };\n232: \n233:   return {\n234:     reranked: results,\n235:     metadata,\n236:   };\n237: }\n238: \n239: // -- Internal: MPAB Chunk Collapse + Parent Reassembly ---------\n240: \n241: /**\n242:  * Collapse chunk-level hits and reassemble parent memory documents.\n243:  *\n244:  * MPAB (Multi-Part Aggregation + Backfill) algorithm:\n245:  *   1. Separate rows into chunks (has `parent_id`) and non-chunks.\n246:  *   2. Group chunks by `parent_id`.\n247:  *   3. For each group, elect the best chunk (highest score).\n248:  *   4. Attempt to load the full parent content from the database.\n249:  *   5. If the DB query succeeds, emit a reassembled parent row.\n250:  *   6. If the DB query fails, fall back to the best-chunk content.\n251:  *   7. Merge non-chunks + reassembled parents, sort by score descending.\n252:  *\n253:  * Pipeline position constraint: this function MUST NOT be called before\n254:  * RRF fusion (Stage 2). It is intentionally placed in Stage 3.\n255:  *\n256:  * @param results - Scored pipeline rows from Stage 3.\n257:  * @returns Object with aggregated rows and chunk reassembly statistics.\n258:  */\n259: async function collapseAndReassembleChunkResults(\n260:   results: PipelineRow[]\n261: ): Promise<{ results: PipelineRow[]; stats: ChunkReassemblyStats }> {\n262:   const stats: ChunkReassemblyStats = {\n263:     collapsedChunkHits: 0,\n264:     chunkParents: 0,\n265:     reassembled: 0,\n266:     fallback: 0,\n267:   };\n268: \n269:   // Separate chunks from non-chunks\n270:   const nonChunks: PipelineRow[] = [];\n271:   const chunksByParent = new Map<number, PipelineRow[]>();\n272: \n273:   for (const row of results) {\n274:     const parentId = row.parent_id ?? row.parentId;\n275:     if (parentId != null && typeof parentId === 'number') {\n276:       // This row is a chunk — group by parent\n277:       const group = chunksByParent.get(parentId);\n278:       if (group) {\n279:         group.push(row);\n280:       } else {\n281:         chunksByParent.set(parentId, [row]);\n282:       }\n283:     } else {\n284:       nonChunks.push(row);\n285:     }\n286:   }\n287: \n288:   if (chunksByParent.size === 0) {\n289:     // No chunks to collapse — return results unchanged\n290:     return { results, stats };\n291:   }\n292: \n293:   stats.chunkParents = chunksByParent.size;\n294: \n295:   // Build chunk groups, electing the best chunk for each parent\n296:   const chunkGroups: ChunkGroup[] = [];\n297:   for (const [parentId, chunks] of chunksByParent) {\n298:     const bestChunk = electBestChunk(chunks);\n299:     const bestChunkScore = resolveEffectiveScore(bestChunk);\n300:     const chunkScores = chunks.map(c => resolveEffectiveScore(c));\n301:     const mpabScore = computeMPAB(chunkScores);\n302:     const parentScore = Math.max(mpabScore, bestChunkScore);\n303:     // Sort chunks by chunk_index (document order) for correct reassembly,\n304:     // Not by score order which is the default from upstream stages\n305:     chunks.sort((a, b) => {\n306:       const aIdx = ((a.chunk_index ?? a.chunkIndex) as number | undefined) ?? 0;\n307:       const bIdx = ((b.chunk_index ?? b.chunkIndex) as number | undefined) ?? 0;\n308:       return aIdx - bIdx;\n309:     });\n310:     chunkGroups.push({ parentId, chunks, bestChunk, parentScore });\n311:     // All chunks beyond the best one are collapsed\n312:     stats.collapsedChunkHits += chunks.length - 1;\n313:   }\n314: \n315:   // Attempt DB reassembly for each parent group (in parallel)\n316:   const reassembledRows = await Promise.all(\n317:     chunkGroups.map((group) => reassembleParentRow(group, stats))\n318:   );\n319: \n320:   // Merge non-chunks + reassembled parent rows, deduplicate by id (prefer highest score),\n321:   // Then sort by effective score.\n322:   // Parent rows could appear in both nonChunks and reassembledRows\n323:   // When a parent exists as a standalone row AND has chunk children.\n324:   const mergedMap = new Map<unknown, PipelineRow>();\n325:   for (const row of [...nonChunks, ...reassembledRows]) {\n326:     const existing = mergedMap.get(row.id);\n327:     if (!existing || floorScore(effectiveScore(row)) > floorScore(effectiveScore(existing))) {\n328:       mergedMap.set(row.id, row);\n329:     }\n330:   }\n331:   const merged = sortDeterministicRows(Array.from(mergedMap.values()) as Array<PipelineRow & { id: number }>);\n332: \n333:   return { results: merged, stats };\n334: }\n335: \n336: /**\n337:  * Elect the best representative chunk from a chunk group.\n338:  * Selection criteria: highest `score`, breaking ties by `similarity`.\n339:  *\n340:  * @param chunks - All chunk rows for a single parent.\n341:  * @returns The chunk with the highest effective score.\n342:  */\n343: function electBestChunk(chunks: PipelineRow[]): PipelineRow {\n344:   return chunks.reduce((best, current) => (\n345:     compareDeterministicRows(\n346:       { ...current, score: floorScore(effectiveScore(current)) } as Record<string, unknown> & { id: number },\n347:       { ...best, score: floorScore(effectiveScore(best)) } as Record<string, unknown> & { id: number },\n348:     ) < 0 ? current : best\n349:   ));\n350: }\n351: \n352: /**\n353:  * Compute the effective numeric score for a pipeline row.\n354:  * Checks all score fields in priority order to avoid silently\n355:  * discarding Stage 2 signal enrichment.\n356:  *\n357:  * Fallback chain expanded to include intentAdjustedScore\n358:  * and rrfScore before raw score/similarity, matching Stage 2's\n359:  * resolveBaseScore() pattern for defensive correctness.\n360:  *\n361:  * @param row - A pipeline result row.\n362:  * @returns Numeric score value in [0, 1] for comparison.\n363:  */\n364: // Replaced local implementation with\n365: // Shared resolveEffectiveScore() from types.ts for consistency with Stage 2.\n366: const effectiveScore = resolveEffectiveScore;\n367: \n368: /**\n369:  * Attempt to reassemble a full parent memory row from the database.\n370:  *\n371:  * On success, returns a PipelineRow that merges:\n372:  *   - All best-chunk fields as the base\n373:  *   - Parent-level content from the DB (if available)\n374:  *   - `contentSource: 'reassembled_chunks'` to mark provenance\n375:  *\n376:  * On failure, returns the best-chunk row with\n377:  *   `contentSource: 'file_read_fallback'`.\n378:  *\n379:  * @param group  - The chunk group (parentId + chunks + bestChunk).\n380:  * @param stats  - Mutable stats object updated in place.\n381:  * @returns A PipelineRow representing the parent document.\n382:  */\n383: async function reassembleParentRow(\n384:   group: ChunkGroup,\n385:   stats: ChunkReassemblyStats\n386: ): Promise<PipelineRow> {\n387:   const { parentId, bestChunk, parentScore } = group;\n388: \n389:   try {\n390:     const db = requireDb();\n391: \n392:     // Query the parent memory row for content and metadata\n393:     const parentRow = db\n394:       .prepare(\n395:         `SELECT id, file_path, content_text, importance_tier, importance_weight,\n396:                 quality_score, created_at, context_type\n397:          FROM memory_index\n398:          WHERE id = ?\n399:          LIMIT 1`\n400:       )\n401:       .get(parentId) as Record<string, unknown> | undefined;\n402: \n403:     if (!parentRow) {\n404:       // Parent not found in DB — use best chunk as fallback\n405:       stats.fallback++;\n406:       return markFallback(bestChunk, parentScore);\n407:     }\n408: \n409:     const reassembledContent =\n410:       (parentRow.content_text as string | undefined) ?? bestChunk.content;\n411: \n412:     // Merge parent metadata onto the best-chunk base row\n413:     const reassembled: PipelineRow = {\n414:       ...bestChunk,\n415:       // Override identity fields with parent values\n416:       id: parentId,\n417:       file_path: (parentRow.file_path as string | undefined) ?? bestChunk.file_path,\n418:       importance_tier: (parentRow.importance_tier as string | undefined) ?? bestChunk.importance_tier,\n419:       importance_weight: (parentRow.importance_weight as number | undefined) ?? bestChunk.importance_weight,\n420:       quality_score: (parentRow.quality_score as number | undefined) ?? bestChunk.quality_score,\n421:       created_at: (parentRow.created_at as string | undefined) ?? bestChunk.created_at,\n422:       context_type: (parentRow.context_type as string | undefined) ?? bestChunk.context_type,\n423:       // FIX #8: Sync content with precomputedContent after reassembly.\n424:       // Previously, `content` still had the chunk fragment while\n425:       // `precomputedContent` had the full reassembled parent text.\n426:       content: reassembledContent,\n427:       precomputedContent: reassembledContent,\n428:       contentSource: 'reassembled_chunks',\n429:       score: parentScore,\n430:       rrfScore: parentScore,\n431:       intentAdjustedScore: parentScore,\n432:       // Clear chunk-specific fields on the reassembled parent\n433:       parent_id: null,\n434:       parentId: null,\n435:       chunk_index: null,\n436:       chunkIndex: null,\n437:       chunk_label: null,\n438:       chunkLabel: null,\n439:       isChunk: false,\n440:     };\n441: \n442:     stats.reassembled++;\n443:     return reassembled;\n444:   } catch (err: unknown) {\n445:     // DB error — gracefully fall back to best-chunk content\n446:     console.warn(\n447:       `[stage3-rerank] MPAB DB reassembly failed for parent ${parentId}: ${toErrorMessage(err)} — using chunk fallback`\n448:     );\n449:     stats.fallback++;\n450:     return markFallback(bestChunk, parentScore);\n451:   }\n452: }\n453: \n454: /**\n455:  * Mark a pipeline row as a chunk-content fallback.\n456:  * Clears chunk-specific identity fields and marks the content source.\n457:  *\n458:  * @param chunk - The elected best-chunk row.\n459:  * @param parentScore - Parent-level score after MPAB aggregation.\n460:  * @returns A new PipelineRow annotated as a fallback parent representation.\n461:  */\n462: function markFallback(chunk: PipelineRow, parentScore: number): PipelineRow {\n463:   const parentId =\n464:     chunk.parent_id ??\n465:     chunk.parentId ??\n466:     (chunk as { parentMemoryId?: number | null }).parentMemoryId ??\n467:     chunk.id;\n468: \n469:   return {\n470:     ...chunk,\n471:     id: parentId,\n472:     contentSource: 'file_read_fallback',\n473:     score: parentScore,\n474:     rrfScore: parentScore,\n475:     intentAdjustedScore: parentScore,\n476:     // Promote chunk to parent-level identity by clearing chunk markers\n477:     parent_id: null,\n478:     parentId: null,\n479:     chunk_index: undefined,\n480:     chunkIndex: undefined,\n481:     chunk_label: null,\n482:     chunkLabel: null,\n483:     isChunk: false,\n484:     is_chunk: false,\n485:   };\n486: }\n487: \n488: // -- Test Exports -----------------------------------------------\n489: \n490: /**\n491:  * Internal functions exported for unit testing.\n492:  * Do not rely on these in production code — the API is not stable.\n493:  *\n494:  * @internal\n495:  */\n496: export const __testables = {\n497:   collapseAndReassembleChunkResults,\n498:   electBestChunk,\n499:   effectiveScore,\n500:   reassembleParentRow,\n501:   markFallback,\n502: };\n\n(End of file - total 502 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage3 Rerank\n// ───────────────────────────────────────────────────────────────\n// 4-Stage Retrieval Pipeline: Stage 3 of 4\n//\n// Responsibilities (in execution order):\n// 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n// 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n//\n// Pipeline position constraint:\n// MPAB MUST remain AFTER RRF fusion (Stage 2).\n// Stage 3 is the only stage that may change scores after Stage 2.\n//\n// I/O CONTRACT:\n// Input:  Stage3Input { scored: PipelineRow[], config }\n// Output: Stage3Output { reranked: PipelineRow[], metadata }\n// Key invariants:\n//     - reranked is sorted descending by effective score after all steps\n//     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n//     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage3 Rerank\n// ───────────────────────────────────────────────────────────────\n// 4-Stage Retrieval Pipeline: Stage 3 of 4\n//\n// Responsibilities (in execution order):\n// 1. MMR diversity pruning     — maximal marginal relevance (SPECKIT_MMR flag)\n// 2. MPAB chunk collapse       — dedup chunks, reassemble parents\n//\n// Pipeline position constraint:\n// MPAB MUST remain AFTER RRF fusion (Stage 2).\n// Stage 3 is the only stage that may change scores after Stage 2.\n//\n// I/O CONTRACT:\n// Input:  Stage3Input { scored: PipelineRow[], config }\n// Output: Stage3Output { reranked: PipelineRow[], metadata }\n// Key invariants:\n//     - reranked is sorted descending by effective score after all steps\n//     - Chunk rows (parent_id != null) are collapsed; only parent rows exit\n//     - contentSource is set to 'reassembled_chunks' or 'file_read_fallback'\n// Side effects:\n//     - DB reads to fetch parent content during MPAB reassembly\n//\n// Score changes: YES\n\nimport { resolveEffectiveScore } from './types.js';\nimport type { Stage3Input, Stage3Output, PipelineRow } from './types.js';\nimport { isMMREnabled } from '../search-flags.js';\nimport { computeMPAB } from '../../scoring/mpab-aggregation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP } from '../intent-classifier.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { requireDb } from '../../../utils/index.js';\nimport { toErrorMessage } from '../../../utils/index.js';\nimport type Database from 'better-sqlite3';\nimport { compareDeterministicRows, sortDeterministicRows } from './ranking-contract.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Hybrid search pipeline\n\n\n// -- Constants --------------------------------------------------\n\n/** Minimum number of candidates required before MMR diversity pruning is worthwhile. */\nconst MMR_MIN_CANDIDATES = 2;\n\n/** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\nconst MMR_DEFAULT_LAMBDA = 0.7;\n\n/**\n * Enforce non-negative score outputs at Stage 3 boundaries.\n */\nfunction floorScore(value: number): number {\n  return Math.max(0, value);\n}\n\n// -- Internal Interfaces ----------------------------------------\n\n/**\n * Aggregated statistics from the MPAB chunk-collapse pass.\n */\ninterface ChunkReassemblyStats {\n  /** Number of child chunk rows removed from the result set. */\n  collapsedChunkHits: number;\n  /** Number of distinct parent IDs encountered among chunk hits. */\n  chunkParents: number;\n  /** Number of parents whose content was successfully reassembled from DB. */\n  reassembled: number;\n  /** Number of parents that fell back to using best-chunk content. */\n  fallback: number;\n}\n\n/**\n * Internal representation of a chunk group — all chunks belonging\n * to a single parent, ready for collapse and reassembly.\n */\ninterface ChunkGroup {\n  parentId: number;\n  chunks: PipelineRow[];\n  /** The chunk with the highest similarity/score — the representative row. */\n  bestChunk: PipelineRow;\n  /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n  parentScore: number;\n}\n\ntype RerankProvider = 'fallback-sort' | 'none';\n\n// -- Stage 3 Entry Point ----------------------------------------\n\n/**\n * Execute Stage 3: Rerank + Aggregate.\n *\n * Applies MMR diversity reranking (when enabled) and then collapses\n * chunked memory hits into their parent documents (MPAB). Stage 3\n * reduces near-duplicate chunks before parent reassembly aggregates\n * the result set.\n *\n * @param input - Stage 3 input containing scored results from Stage 2\n *   and the shared pipeline configuration.\n * @returns Stage 3 output with reranked, aggregated results and metadata.\n */\nexport async function executeStage3(input: Stage3Input): Promise<Stage3Output> {\n  const stageStart = Date.now();\n  const { scored, config } = input;\n\n  let results = scored;\n\n  // -- Step 1: (removed) model-based cross-encoder reranking -----\n  // The cross-encoder / local-GGUF reranking layer was removed: it had no\n  // configured provider after the sidecar deprecation (isCrossEncoderEnabled()\n  // was hard-off), so it was an inactive no-op. Stage 3 now performs only\n  // algorithmic MMR diversity (Step 2) and MPAB chunk-collapse (Step 3).\n  // These constants preserve the unchanged metadata/envelope shape.\n  const rerankApplied = false;\n  const rerankProvider: RerankProvider = 'none';\n\n  // -- Step 2: MMR diversity pruning ----------------------------\n  // Gated behind SPECKIT_MMR feature flag. Retrieves embeddings from\n  // Vec_memories and applies Maximal Marginal Relevance to diversify\n  // The result set, matching the V1 hybrid-search behavior.\n  if (isMMREnabled() && results.length >= MMR_MIN_CANDIDATES) {\n    try {\n      const db = requireDb() as Database.Database;\n      const numericIds = results\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length >= MMR_MIN_CANDIDATES) {\n        const placeholders = numericIds.map(() => '?').join(', ');\n        const embRows = (db.prepare(\n          `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n        ) as Database.Statement).all(...numericIds) as Array<{ rowid: number; embedding: Buffer }>;\n\n        const embeddingMap = new Map<number, Float32Array>();\n        for (const row of embRows) {\n          if (Buffer.isBuffer(row.embedding)) {\n            embeddingMap.set(\n              row.rowid,\n              new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n            );\n          }\n        }\n\n        const mmrCandidates: MMRCandidate[] = [];\n        for (const r of results) {\n          const emb = embeddingMap.get(r.id);\n          if (emb) {\n            mmrCandidates.push({\n              id: r.id,\n              // Use effectiveScore() for consistent fallback chain\n              score: floorScore(effectiveScore(r)),\n              embedding: emb,\n            });\n          }\n        }\n\n        if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n          const originalPositionMap = new Map<number | string, number>();\n          results.forEach((row, index) => originalPositionMap.set(row.id, index));\n          const intent = config.adaptiveFusionIntent ?? config.detectedIntent ?? '';\n          const mmrLambda = (INTENT_LAMBDA_MAP as Record<string, number>)[intent] ?? MMR_DEFAULT_LAMBDA;\n          const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit: config.limit });\n\n          // FIX #5: MMR can only diversify rows that have embeddings. Non-embedded\n          // rows (lexical-only hits, graph injections) must be preserved and merged\n          // back in their original relative order instead of being silently dropped.\n          const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n          const nonEmbeddedRows = results.filter(r => !embeddedIdSet.has(r.id));\n\n          // Rebuild PipelineRow[] from diversified candidates, preserving all original fields\n          const rowMap = new Map<number | string, PipelineRow>();\n          for (const r of results) rowMap.set(r.id, r);\n\n          const diversifiedRows = diversified.map((candidate): PipelineRow => {\n            const existing = rowMap.get(candidate.id);\n            if (existing) return existing;\n            return { id: candidate.id as number, score: candidate.score };\n          });\n\n          const positioned: Array<{ row: PipelineRow; pos: number }> = [];\n          diversifiedRows.forEach((row, index) => positioned.push({ row, pos: index }));\n          nonEmbeddedRows.forEach((row) => {\n            const originalPosition = originalPositionMap.get(row.id) ?? results.length;\n            positioned.push({ row, pos: originalPosition });\n          });\n\n          positioned.sort((left, right) => left.pos - right.pos);\n          results = positioned.map(({ row }) => row);\n        }\n      }\n    } catch (mmrErr: unknown) {\n      // Non-critical — MMR failure does not block pipeline\n      console.warn(`[stage3-rerank] MMR diversity pruning failed: ${toErrorMessage(mmrErr)}`);\n    }\n  }\n\n  // -- Step 3: MPAB chunk collapse + parent reassembly -----------\n  //\n  // MPAB must remain AFTER RRF (Stage 2 constraint). This step runs\n  // Here in Stage 3 — never move it upstream.\n  const mpabStart = Date.now();\n  const beforeMpab = results.length;\n\n  const { results: aggregated, stats: chunkStats } =\n    await collapseAndReassembleChunkResults(results);\n\n  results = aggregated;\n\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'final-rank',\n      beforeMpab,\n      results.length,\n      Date.now() - mpabStart,\n      {\n        collapsedChunkHits: chunkStats.collapsedChunkHits,\n        chunkParents: chunkStats.chunkParents,\n        reassembled: chunkStats.reassembled,\n        fallback: chunkStats.fallback,\n      }\n    );\n  }\n\n  const metadata = {\n    rerankApplied,\n    rerankProvider,\n    chunkReassemblyStats: chunkStats,\n    durationMs: Date.now() - stageStart,\n  };\n\n  return {\n    reranked: results,\n    metadata,\n  };\n}\n\n// -- Internal: MPAB Chunk Collapse + Parent Reassembly ---------\n\n/**\n * Collapse chunk-level hits and reassemble parent memory documents.\n *\n * MPAB (Multi-Part Aggregation + Backfill) algorithm:\n *   1. Separate rows into chunks (has `parent_id`) and non-chunks.\n *   2. Group chunks by `parent_id`.\n *   3. For each group, elect the best chunk (highest score).\n *   4. Attempt to load the full parent content from the database.\n *   5. If the DB query succeeds, emit a reassembled parent row.\n *   6. If the DB query fails, fall back to the best-chunk content.\n *   7. Merge non-chunks + reassembled parents, sort by score descending.\n *\n * Pipeline position constraint: this function MUST NOT be called before\n * RRF fusion (Stage 2). It is intentionally placed in Stage 3.\n *\n * @param results - Scored pipeline rows from Stage 3.\n * @returns Object with aggregated rows and chunk reassembly statistics.\n */\nasync function collapseAndReassembleChunkResults(\n  results: PipelineRow[]\n): Promise<{ results: PipelineRow[]; stats: ChunkReassemblyStats }> {\n  const stats: ChunkReassemblyStats = {\n    collapsedChunkHits: 0,\n    chunkParents: 0,\n    reassembled: 0,\n    fallback: 0,\n  };\n\n  // Separate chunks from non-chunks\n  const nonChunks: PipelineRow[] = [];\n  const chunksByParent = new Map<number, PipelineRow[]>();\n\n  for (const row of results) {\n    const parentId = row.parent_id ?? row.parentId;\n    if (parentId != null && typeof parentId === 'number') {\n      // This row is a chunk — group by parent\n      const group = chunksByParent.get(parentId);\n      if (group) {\n        group.push(row);\n      } else {\n        chunksByParent.set(parentId, [row]);\n      }\n    } else {\n      nonChunks.push(row);\n    }\n  }\n\n  if (chunksByParent.size === 0) {\n    // No chunks to collapse — return results unchanged\n    return { results, stats };\n  }\n\n  stats.chunkParents = chunksByParent.size;\n\n  // Build chunk groups, electing the best chunk for each parent\n  const chunkGroups: ChunkGroup[] = [];\n  for (const [parentId, chunks] of chunksByParent) {\n    const bestChunk = electBestChunk(chunks);\n    const bestChunkScore = resolveEffectiveScore(bestChunk);\n    const chunkScores = chunks.map(c => resolveEffectiveScore(c));\n    const mpabScore = computeMPAB(chunkScores);\n    const parentScore = Math.max(mpabScore, bestChunkScore);\n    // Sort chunks by chunk_index (document order) for correct reassembly,\n    // Not by score order which is the default from upstream stages\n    chunks.sort((a, b) => {\n      const aIdx = ((a.chunk_index ?? a.chunkIndex) as number | undefined) ?? 0;\n      const bIdx = ((b.chunk_index ?? b.chunkIndex) as number | undefined) ?? 0;\n      return aIdx - bIdx;\n    });\n    chunkGroups.push({ parentId, chunks, bestChunk, parentScore });\n    // All chunks beyond the best one are collapsed\n    stats.collapsedChunkHits += chunks.length - 1;\n  }\n\n  // Attempt DB reassembly for each parent group (in parallel)\n  const reassembledRows = await Promise.all(\n    chunkGroups.map((group) => reassembleParentRow(group, stats))\n  );\n\n  // Merge non-chunks + reassembled parent rows, deduplicate by id (prefer highest score),\n  // Then sort by effective score.\n  // Parent rows could appear in both nonChunks and reassembledRows\n  // When a parent exists as a standalone row AND has chunk children.\n  const mergedMap = new Map<unknown, PipelineRow>();\n  for (const row of [...nonChunks, ...reassembledRows]) {\n    const existing = mergedMap.get(row.id);\n    if (!existing || floorScore(effectiveScore(row)) > floorScore(effectiveScore(existing))) {\n      mergedMap.set(row.id, row);\n    }\n  }\n  const merged = sortDeterministicRows(Array.from(mergedMap.values()) as Array<PipelineRow & { id: number }>);\n\n  return { results: merged, stats };\n}\n\n/**\n * Elect the best representative chunk from a chunk group.\n * Selection criteria: highest `score`, breaking ties by `similarity`.\n *\n * @param chunks - All chunk rows for a single parent.\n * @returns The chunk with the highest effective score.\n */\nfunction electBestChunk(chunks: PipelineRow[]): PipelineRow {\n  return chunks.reduce((best, current) => (\n    compareDeterministicRows(\n      { ...current, score: floorScore(effectiveScore(current)) } as Record<string, unknown> & { id: number },\n      { ...best, score: floorScore(effectiveScore(best)) } as Record<string, unknown> & { id: number },\n    ) < 0 ? current : best\n  ));\n}\n\n/**\n * Compute the effective numeric score for a pipeline row.\n * Checks all score fields in priority order to avoid silently\n * discarding Stage 2 signal enrichment.\n *\n * Fallback chain expanded to include intentAdjustedScore\n * and rrfScore before raw score/similarity, matching Stage 2's\n * resolveBaseScore() pattern for defensive correctness.\n *\n * @param row - A pipeline result row.\n * @returns Numeric score value in [0, 1] for comparison.\n */\n// Replaced local implementation with\n// Shared resolveEffectiveScore() from types.ts for consistency with Stage 2.\nconst effectiveScore = resolveEffectiveScore;\n\n/**\n * Attempt to reassemble a full parent memory row from the database.\n *\n * On success, returns a PipelineRow that merges:\n *   - All best-chunk fields as the base\n *   - Parent-level content from the DB (if available)\n *   - `contentSource: 'reassembled_chunks'` to mark provenance\n *\n * On failure, returns the best-chunk row with\n *   `contentSource: 'file_read_fallback'`.\n *\n * @param group  - The chunk group (parentId + chunks + bestChunk).\n * @param stats  - Mutable stats object updated in place.\n * @returns A PipelineRow representing the parent document.\n */\nasync function reassembleParentRow(\n  group: ChunkGroup,\n  stats: ChunkReassemblyStats\n): Promise<PipelineRow> {\n  const { parentId, bestChunk, parentScore } = group;\n\n  try {\n    const db = requireDb();\n\n    // Query the parent memory row for content and metadata\n    const parentRow = db\n      .prepare(\n        `SELECT id, file_path, content_text, importance_tier, importance_weight,\n                quality_score, created_at, context_type\n         FROM memory_index\n         WHERE id = ?\n         LIMIT 1`\n      )\n      .get(parentId) as Record<string, unknown> | undefined;\n\n    if (!parentRow) {\n      // Parent not found in DB — use best chunk as fallback\n      stats.fallback++;\n      return markFallback(bestChunk, parentScore);\n    }\n\n    const reassembledContent =\n      (parentRow.content_text as string | undefined) ?? bestChunk.content;\n\n    // Merge parent metadata onto the best-chunk base row\n    const reassembled: PipelineRow = {\n      ...bestChunk,\n      // Override identity fields with parent values\n      id: parentId,\n      file_path: (parentRow.file_path as string | undefined) ?? bestChunk.file_path,\n      importance_tier: (parentRow.importance_tier as string | undefined) ?? bestChunk.importance_tier,\n      importance_weight: (parentRow.importance_weight as number | undefined) ?? bestChunk.importance_weight,\n      quality_score: (parentRow.quality_score as number | undefined) ?? bestChunk.quality_score,\n      created_at: (parentRow.created_at as string | undefined) ?? bestChunk.created_at,\n      context_type: (parentRow.context_type as string | undefined) ?? bestChunk.context_type,\n      // FIX #8: Sync content with precomputedContent after reassembly.\n      // Previously, `content` still had the chunk fragment while\n      // `precomputedContent` had the full reassembled parent text.\n      content: reassembledContent,\n      precomputedContent: reassembledContent,\n      contentSource: 'reassembled_chunks',\n      score: parentScore,\n      rrfScore: parentScore,\n      intentAdjustedScore: parentScore,\n      // Clear chunk-specific fields on the reassembled parent\n      parent_id: null,\n      parentId: null,\n      chunk_index: null,\n      chunkIndex: null,\n      chunk_label: null,\n      chunkLabel: null,\n      isChunk: false,\n    };\n\n    stats.reassembled++;\n    return reassembled;\n  } catch (err: unknown) {\n    // DB error — gracefully fall back to best-chunk content\n    console.warn(\n      `[stage3-rerank] MPAB DB reassembly failed for parent ${parentId}: ${toErrorMessage(err)} — using chunk fallback`\n    );\n    stats.fallback++;\n    return markFallback(bestChunk, parentScore);\n  }\n}\n\n/**\n * Mark a pipeline row as a chunk-content fallback.\n * Clears chunk-specific identity fields and marks the content source.\n *\n * @param chunk - The elected best-chunk row.\n * @param parentScore - Parent-level score after MPAB aggregation.\n * @returns A new PipelineRow annotated as a fallback parent representation.\n */\nfunction markFallback(chunk: PipelineRow, parentScore: number): PipelineRow {\n  const parentId =\n    chunk.parent_id ??\n    chunk.parentId ??\n    (chunk as { parentMemoryId?: number | null }).parentMemoryId ??\n    chunk.id;\n\n  return {\n    ...chunk,\n    id: parentId,\n    contentSource: 'file_read_fallback',\n    score: parentScore,\n    rrfScore: parentScore,\n    intentAdjustedScore: parentScore,\n    // Promote chunk to parent-level identity by clearing chunk markers\n    parent_id: null,\n    parentId: null,\n    chunk_index: undefined,\n    chunkIndex: undefined,\n    chunk_label: null,\n    chunkLabel: null,\n    isChunk: false,\n    is_chunk: false,\n  };\n}\n\n// -- Test Exports -----------------------------------------------\n\n/**\n * Internal functions exported for unit testing.\n * Do not rely on these in production code — the API is not stable.\n *\n * @internal\n */\nexport const __testables = {\n  collapseAndReassembleChunkResults,\n  electBestChunk,\n  effectiveScore,\n  reassembleParentRow,\n  markFallback,\n};","lineStart":1,"lineEnd":502,"totalLines":502,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","time":{"start":1781762518769,"end":1781762518779}},"metadata":{"openai":{"itemId":"fc_09fea31d49f1b9f7016a3389d6a3448191ba5fc17790578bb5"}},"id":"prt_ed9526eef001UBE98aIpTp4fbk","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed951f9f50011nSEI60i9v7yun"}}
{"type":"tool_use","timestamp":1781762518782,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_0QYka3ljG97eQWMEDQh5VHTu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","offset":1240,"limit":950},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts</path>\n<type>file</type>\n<content>\n1240:   if (config.trackAccess) {\n1241:     try {\n1242:       const db = requireDb();\n1243:       applyTestingEffect(db, results);\n1244:       recordAdaptiveAccessSignals(db, results, config.query);\n1245:     } catch (err: unknown) {\n1246:       const message = err instanceof Error ? err.message : String(err);\n1247:       console.warn(`[stage2-fusion] testing effect skipped (db unavailable): ${message}`);\n1248:     }\n1249:   }\n1250: \n1251:   // -- 4. Intent weights --\n1252:   // G2 PREVENTION: Only apply for non-hybrid search types.\n1253:   // Hybrid search (RRF / RSF) incorporates intent weighting during fusion —\n1254:   // Applying it again here would double-count, causing the G2 bug.\n1255:   if (!isHybrid && config.intentWeights) {\n1256:     try {\n1257:       const weighted = applyIntentWeightsToResults(results, config.intentWeights);\n1258:       results = weighted.map((result) =>\n1259:         typeof result.intentAdjustedScore === 'number'\n1260:           ? withSyncedScoreAliases(result, result.intentAdjustedScore)\n1261:           : result\n1262:       );\n1263:       metadata.intentWeightsApplied = 'applied';\n1264:     } catch (err: unknown) {\n1265:       const message = err instanceof Error ? err.message : String(err);\n1266:       console.warn(`[stage2-fusion] intent weights failed: ${message}`);\n1267:       metadata.intentWeightsApplied = 'failed';\n1268:     }\n1269:   }\n1270: \n1271:   // -- 5. Artifact routing weights --\n1272:   if (config.artifactRouting && config.artifactRouting.confidence > 0) {\n1273:     try {\n1274:       const routed = applyArtifactRouting(results, config.artifactRouting);\n1275:       results = routed;\n1276:       metadata.artifactRoutingApplied = 'applied';\n1277:     } catch (err: unknown) {\n1278:       const message = err instanceof Error ? err.message : String(err);\n1279:       console.warn(`[stage2-fusion] artifact routing failed: ${message}`);\n1280:       metadata.artifactRoutingApplied = 'failed';\n1281:     }\n1282:   }\n1283: \n1284:   // -- 6. Feedback signals --\n1285:   try {\n1286:     const withFeedback = applyFeedbackSignals(results, config.query);\n1287:     // Detect if any score actually changed\n1288:     const changed = withFeedback.some((r, i) => r !== results[i]);\n1289:     if (changed) {\n1290:       results = withFeedback;\n1291:       metadata.feedbackSignalsApplied = 'applied';\n1292:     }\n1293:   } catch (err: unknown) {\n1294:     const message = err instanceof Error ? err.message : String(err);\n1295:     console.warn(`[stage2-fusion] feedback signals failed: ${message}`);\n1296:     metadata.feedbackSignalsApplied = 'failed';\n1297:   }\n1298: \n1299:   // -- 6a. Learned Stage 2 shadow scoring --\n1300:   // Runs the learned linear ranker in parallel with the manual combiner.\n1301:   // Shadow-only — scores are logged for comparison but never affect live ranking.\n1302:   // Gated behind SPECKIT_LEARNED_STAGE2_COMBINER (default ON, graduated).\n1303:   // When SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT is set in (0, 0.05],\n1304:   // a small guarded blend `(1-w)*manual + w*learned` is applied to the live\n1305:   // score. Default 0 preserves shadow-only behavior. The blend weight is\n1306:   // clamped at the source by resolveLearnedBlendWeight().\n1307:   if (isLearnedStage2CombinerEnabled()) {\n1308:     try {\n1309:       const learnedShadowModel = await loadPersistedLearnedStage2Model();\n1310:       // Weight resolved once per pipeline run; flag-gated and\n1311:       // clamped. Zero means shadow-only (today's behavior).\n1312:       const learnedBlendWeight = resolveLearnedBlendWeight();\n1313:       for (let rowIndex = 0; rowIndex < results.length; rowIndex++) {\n1314:         const row = results[rowIndex];\n1315:         const features = extractFeatureVector({\n1316:           rrfScore: row.rrfScore,\n1317:           overlapScore: typeof row.overlapScore === 'number' ? row.overlapScore : undefined,\n1318:           graphScore: (() => {\n1319:             const gc = row.graphContribution as Record<string, unknown> | undefined;\n1320:             const delta = typeof gc?.totalDelta === 'number' ? gc.totalDelta : 0;\n1321:             return Math.max(0, Math.min(1, delta + 0.5));\n1322:           })(),\n1323:           sessionScore: typeof row.sessionScore === 'number' ? row.sessionScore : undefined,\n1324:           causalScore: typeof row.causalScore === 'number' ? row.causalScore : undefined,\n1325:           feedbackScore: typeof row.feedbackScore === 'number' ? row.feedbackScore : undefined,\n1326:           validationScore: (() => {\n1327:             const vm = row.validationMetadata as Record<string, unknown> | undefined;\n1328:             return typeof vm?.qualityScore === 'number' ? vm.qualityScore : undefined;\n1329:           })(),\n1330:           artifactScore: typeof row.artifactBoostApplied === 'number'\n1331:             ? Math.min(1, row.artifactBoostApplied / 2)\n1332:             : undefined,\n1333:         });\n1334:         const shadow = shadowScore(learnedShadowModel, features, resolveBaseScore(row), true);\n1335:         if (shadow) {\n1336:           console.warn(\n1337:             `[stage2-fusion] shadow-learned id=${row.id} manual=${shadow.manualScore.toFixed(4)} learned=${shadow.learnedScore.toFixed(4)} delta=${shadow.delta.toFixed(4)}`\n1338:           );\n1339:           // Apply the small guarded blend when weight > 0 AND a\n1340:           // shadow result is available (model loaded successfully). Mutate\n1341:           // the row through withSyncedScoreAliases so all score aliases stay\n1342:           // aligned. When weight is 0 (default) or model failed to load, this\n1343:           // branch is skipped and behavior is identical to pre-fix.\n1344:           if (learnedBlendWeight > 0) {\n1345:             const blendedScore = (1 - learnedBlendWeight) * shadow.manualScore\n1346:               + learnedBlendWeight * shadow.learnedScore;\n1347:             results[rowIndex] = withSyncedScoreAliases(row, blendedScore);\n1348:           }\n1349:         }\n1350:       }\n1351:     } catch (err: unknown) {\n1352:       const message = err instanceof Error ? err.message : String(err);\n1353:       console.warn(`[stage2-fusion] learned stage2 shadow scoring failed: ${message}`);\n1354:     }\n1355:   }\n1356: \n1357:   // -- 6a. Retrieval rescue + 7. Artifact-based result limiting --\n1358:   // The routing strategy may specify a maxResults count stricter than the\n1359:   // Overall pipeline limit. Apply it here so Stage 3 reranks a pre-trimmed set.\n1360:   syncScoreAliasesInPlace(results);\n1361:   if (isRetrievalRescueEnabled()) {\n1362:     try {\n1363:       let rescueDb: Database.Database | null = null;\n1364:       try {\n1365:         rescueDb = requireDb();\n1366:       } catch {\n1367:         rescueDb = null;\n1368:       }\n1369:       results = applyRetrievalRescueLayer(config.query, results, {\n1370:         db: rescueDb,\n1371:         artifactClass: config.artifactRouting?.strategy?.artifactClass as string | undefined\n1372:           ?? config.artifactRouting?.detectedClass,\n1373:       });\n1374:       logger.debug('retrieval rescue layer completed', {\n1375:         event: 'stage2_retrieval_rescue_success',\n1376:         resultCount: results.length,\n1377:         hasDb: rescueDb !== null,\n1378:         artifactClass: config.artifactRouting?.strategy?.artifactClass\n1379:           ?? config.artifactRouting?.detectedClass\n1380:           ?? null,\n1381:       });\n1382:     } catch (err: unknown) {\n1383:       const message = err instanceof Error ? err.message : String(err);\n1384:       console.warn(`[stage2-fusion] retrieval rescue layer failed: ${message}`);\n1385:     }\n1386:   }\n1387:   results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n1388:   if (\n1389:     config.artifactRouting &&\n1390:     config.artifactRouting.confidence > 0 &&\n1391:     typeof config.artifactRouting.strategy?.maxResults === 'number' &&\n1392:     config.artifactRouting.strategy.maxResults > 0 &&\n1393:     results.length > config.artifactRouting.strategy.maxResults\n1394:   ) {\n1395:     results = results.slice(0, config.artifactRouting.strategy.maxResults);\n1396:   }\n1397: \n1398:   // -- Steps 8-9: Enrichment (extracted to stage2b-enrichment.ts) --\n1399:   // Pure annotation: anchor metadata + validation metadata.\n1400:   // Validation signal SCORING (applyValidationSignalScoring) stays here\n1401:   // because it's a scoring step, not a pure enrichment.\n1402:   results = executeStage2bEnrichment(results);\n1403:   try {\n1404:     results = applyValidationSignalScoring(results);\n1405:   } catch (err: unknown) {\n1406:     const message = err instanceof Error ? err.message : String(err);\n1407:     console.warn(`[stage2-fusion] validation signal scoring failed: ${message}`);\n1408:   }\n1409: \n1410:   // Keep all score aliases aligned after late-stage score mutations.\n1411:   syncScoreAliasesInPlace(results);\n1412:   if (metadata.graphContribution) {\n1413:     metadata.graphContribution.causalBoosted = countGraphContribution(results, 'causalDelta');\n1414:     metadata.graphContribution.coActivationBoosted = countGraphContribution(results, 'coActivationDelta');\n1415:     metadata.graphContribution.communityInjected = countGraphContribution(results, 'communityDelta');\n1416:     metadata.graphContribution.graphSignalsBoosted = countGraphContribution(results, 'graphSignalDelta');\n1417:     metadata.graphContribution.totalGraphInjected = countGraphInjected(results);\n1418: \n1419:     // P2 fix: Diagnostic when graph is activated but contributes nothing\n1420:     if (\n1421:       !metadata.graphContribution.killSwitchActive &&\n1422:       metadata.graphContribution.rolloutState === 'bounded_runtime' &&\n1423:       metadata.graphContribution.causalBoosted === 0 &&\n1424:       metadata.graphContribution.coActivationBoosted === 0 &&\n1425:       metadata.graphContribution.communityInjected === 0 &&\n1426:       metadata.graphContribution.graphSignalsBoosted === 0 &&\n1427:       results.length > 0\n1428:     ) {\n1429:       console.warn(\n1430:         '[stage2-fusion] Graph channel active (bounded_runtime) but zero contribution — causal_edges table may be sparse or candidates lack graph connectivity'\n1431:       );\n1432:     }\n1433:   }\n1434: \n1435:   // -- Trace --\n1436:   if (config.trace) {\n1437:     addTraceEntry(\n1438:       config.trace,\n1439:       'fusion',\n1440:       candidates.length,\n1441:       results.length,\n1442:       Date.now() - start,\n1443:       {\n1444:         sessionBoostApplied: metadata.sessionBoostApplied,\n1445:         causalBoostApplied: metadata.causalBoostApplied,\n1446:         intentWeightsApplied: metadata.intentWeightsApplied,\n1447:         artifactRoutingApplied: metadata.artifactRoutingApplied,\n1448:         feedbackSignalsApplied: metadata.feedbackSignalsApplied,\n1449:         graphContribution: metadata.graphContribution,\n1450:         searchType: config.searchType,\n1451:         isHybrid,\n1452:       }\n1453:     );\n1454:   }\n1455: \n1456:   metadata.durationMs = Date.now() - start;\n1457: \n1458:   return {\n1459:     scored: results,\n1460:     metadata,\n1461:   };\n1462: }\n1463: \n1464: // -- Test surface --\n1465: \n1466: /**\n1467:  * Internal functions exposed for unit testing.\n1468:  *\n1469:  * These are NOT part of the public API and may change without notice.\n1470:  * Access only from `*.test.ts` / `*.vitest.ts` files.\n1471:  */\n1472: export const __testables = {\n1473:   resolveBaseScore,\n1474:   strengthenOnAccess,\n1475:   applyIntentWeightsToResults,\n1476:   applyArtifactRouting,\n1477:   applyFeedbackSignals,\n1478:   applyUsageRankingBoost,\n1479:   applyTestingEffect,\n1480:   enrichResultsWithAnchorMetadata,\n1481:   enrichResultsWithValidationMetadata,\n1482:   applyValidationSignalScoring,\n1483:   // Learned blend weight resolver, exposed for unit testing\n1484:   // the env-var clamp and default-zero behavior.\n1485:   resolveLearnedBlendWeight,\n1486: };\n\n(End of file - total 1486 lines)\n</content>","metadata":{"preview":"  if (config.trackAccess) {\n    try {\n      const db = requireDb();\n      applyTestingEffect(db, results);\n      recordAdaptiveAccessSignals(db, results, config.query);\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] testing effect skipped (db unavailable): ${message}`);\n    }\n  }\n\n  // -- 4. Intent weights --\n  // G2 PREVENTION: Only apply for non-hybrid search types.\n  // Hybrid search (RRF / RSF) incorporates intent weighting during fusion —\n  // Applying it again here would double-count, causing the G2 bug.\n  if (!isHybrid && config.intentWeights) {\n    try {\n      const weighted = applyIntentWeightsToResults(results, config.intentWeights);\n      results = weighted.map((result) =>\n        typeof result.intentAdjustedScore === 'number'","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","text":"  if (config.trackAccess) {\n    try {\n      const db = requireDb();\n      applyTestingEffect(db, results);\n      recordAdaptiveAccessSignals(db, results, config.query);\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] testing effect skipped (db unavailable): ${message}`);\n    }\n  }\n\n  // -- 4. Intent weights --\n  // G2 PREVENTION: Only apply for non-hybrid search types.\n  // Hybrid search (RRF / RSF) incorporates intent weighting during fusion —\n  // Applying it again here would double-count, causing the G2 bug.\n  if (!isHybrid && config.intentWeights) {\n    try {\n      const weighted = applyIntentWeightsToResults(results, config.intentWeights);\n      results = weighted.map((result) =>\n        typeof result.intentAdjustedScore === 'number'\n          ? withSyncedScoreAliases(result, result.intentAdjustedScore)\n          : result\n      );\n      metadata.intentWeightsApplied = 'applied';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] intent weights failed: ${message}`);\n      metadata.intentWeightsApplied = 'failed';\n    }\n  }\n\n  // -- 5. Artifact routing weights --\n  if (config.artifactRouting && config.artifactRouting.confidence > 0) {\n    try {\n      const routed = applyArtifactRouting(results, config.artifactRouting);\n      results = routed;\n      metadata.artifactRoutingApplied = 'applied';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] artifact routing failed: ${message}`);\n      metadata.artifactRoutingApplied = 'failed';\n    }\n  }\n\n  // -- 6. Feedback signals --\n  try {\n    const withFeedback = applyFeedbackSignals(results, config.query);\n    // Detect if any score actually changed\n    const changed = withFeedback.some((r, i) => r !== results[i]);\n    if (changed) {\n      results = withFeedback;\n      metadata.feedbackSignalsApplied = 'applied';\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] feedback signals failed: ${message}`);\n    metadata.feedbackSignalsApplied = 'failed';\n  }\n\n  // -- 6a. Learned Stage 2 shadow scoring --\n  // Runs the learned linear ranker in parallel with the manual combiner.\n  // Shadow-only — scores are logged for comparison but never affect live ranking.\n  // Gated behind SPECKIT_LEARNED_STAGE2_COMBINER (default ON, graduated).\n  // When SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT is set in (0, 0.05],\n  // a small guarded blend `(1-w)*manual + w*learned` is applied to the live\n  // score. Default 0 preserves shadow-only behavior. The blend weight is\n  // clamped at the source by resolveLearnedBlendWeight().\n  if (isLearnedStage2CombinerEnabled()) {\n    try {\n      const learnedShadowModel = await loadPersistedLearnedStage2Model();\n      // Weight resolved once per pipeline run; flag-gated and\n      // clamped. Zero means shadow-only (today's behavior).\n      const learnedBlendWeight = resolveLearnedBlendWeight();\n      for (let rowIndex = 0; rowIndex < results.length; rowIndex++) {\n        const row = results[rowIndex];\n        const features = extractFeatureVector({\n          rrfScore: row.rrfScore,\n          overlapScore: typeof row.overlapScore === 'number' ? row.overlapScore : undefined,\n          graphScore: (() => {\n            const gc = row.graphContribution as Record<string, unknown> | undefined;\n            const delta = typeof gc?.totalDelta === 'number' ? gc.totalDelta : 0;\n            return Math.max(0, Math.min(1, delta + 0.5));\n          })(),\n          sessionScore: typeof row.sessionScore === 'number' ? row.sessionScore : undefined,\n          causalScore: typeof row.causalScore === 'number' ? row.causalScore : undefined,\n          feedbackScore: typeof row.feedbackScore === 'number' ? row.feedbackScore : undefined,\n          validationScore: (() => {\n            const vm = row.validationMetadata as Record<string, unknown> | undefined;\n            return typeof vm?.qualityScore === 'number' ? vm.qualityScore : undefined;\n          })(),\n          artifactScore: typeof row.artifactBoostApplied === 'number'\n            ? Math.min(1, row.artifactBoostApplied / 2)\n            : undefined,\n        });\n        const shadow = shadowScore(learnedShadowModel, features, resolveBaseScore(row), true);\n        if (shadow) {\n          console.warn(\n            `[stage2-fusion] shadow-learned id=${row.id} manual=${shadow.manualScore.toFixed(4)} learned=${shadow.learnedScore.toFixed(4)} delta=${shadow.delta.toFixed(4)}`\n          );\n          // Apply the small guarded blend when weight > 0 AND a\n          // shadow result is available (model loaded successfully). Mutate\n          // the row through withSyncedScoreAliases so all score aliases stay\n          // aligned. When weight is 0 (default) or model failed to load, this\n          // branch is skipped and behavior is identical to pre-fix.\n          if (learnedBlendWeight > 0) {\n            const blendedScore = (1 - learnedBlendWeight) * shadow.manualScore\n              + learnedBlendWeight * shadow.learnedScore;\n            results[rowIndex] = withSyncedScoreAliases(row, blendedScore);\n          }\n        }\n      }\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] learned stage2 shadow scoring failed: ${message}`);\n    }\n  }\n\n  // -- 6a. Retrieval rescue + 7. Artifact-based result limiting --\n  // The routing strategy may specify a maxResults count stricter than the\n  // Overall pipeline limit. Apply it here so Stage 3 reranks a pre-trimmed set.\n  syncScoreAliasesInPlace(results);\n  if (isRetrievalRescueEnabled()) {\n    try {\n      let rescueDb: Database.Database | null = null;\n      try {\n        rescueDb = requireDb();\n      } catch {\n        rescueDb = null;\n      }\n      results = applyRetrievalRescueLayer(config.query, results, {\n        db: rescueDb,\n        artifactClass: config.artifactRouting?.strategy?.artifactClass as string | undefined\n          ?? config.artifactRouting?.detectedClass,\n      });\n      logger.debug('retrieval rescue layer completed', {\n        event: 'stage2_retrieval_rescue_success',\n        resultCount: results.length,\n        hasDb: rescueDb !== null,\n        artifactClass: config.artifactRouting?.strategy?.artifactClass\n          ?? config.artifactRouting?.detectedClass\n          ?? null,\n      });\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] retrieval rescue layer failed: ${message}`);\n    }\n  }\n  results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n  if (\n    config.artifactRouting &&\n    config.artifactRouting.confidence > 0 &&\n    typeof config.artifactRouting.strategy?.maxResults === 'number' &&\n    config.artifactRouting.strategy.maxResults > 0 &&\n    results.length > config.artifactRouting.strategy.maxResults\n  ) {\n    results = results.slice(0, config.artifactRouting.strategy.maxResults);\n  }\n\n  // -- Steps 8-9: Enrichment (extracted to stage2b-enrichment.ts) --\n  // Pure annotation: anchor metadata + validation metadata.\n  // Validation signal SCORING (applyValidationSignalScoring) stays here\n  // because it's a scoring step, not a pure enrichment.\n  results = executeStage2bEnrichment(results);\n  try {\n    results = applyValidationSignalScoring(results);\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] validation signal scoring failed: ${message}`);\n  }\n\n  // Keep all score aliases aligned after late-stage score mutations.\n  syncScoreAliasesInPlace(results);\n  if (metadata.graphContribution) {\n    metadata.graphContribution.causalBoosted = countGraphContribution(results, 'causalDelta');\n    metadata.graphContribution.coActivationBoosted = countGraphContribution(results, 'coActivationDelta');\n    metadata.graphContribution.communityInjected = countGraphContribution(results, 'communityDelta');\n    metadata.graphContribution.graphSignalsBoosted = countGraphContribution(results, 'graphSignalDelta');\n    metadata.graphContribution.totalGraphInjected = countGraphInjected(results);\n\n    // P2 fix: Diagnostic when graph is activated but contributes nothing\n    if (\n      !metadata.graphContribution.killSwitchActive &&\n      metadata.graphContribution.rolloutState === 'bounded_runtime' &&\n      metadata.graphContribution.causalBoosted === 0 &&\n      metadata.graphContribution.coActivationBoosted === 0 &&\n      metadata.graphContribution.communityInjected === 0 &&\n      metadata.graphContribution.graphSignalsBoosted === 0 &&\n      results.length > 0\n    ) {\n      console.warn(\n        '[stage2-fusion] Graph channel active (bounded_runtime) but zero contribution — causal_edges table may be sparse or candidates lack graph connectivity'\n      );\n    }\n  }\n\n  // -- Trace --\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'fusion',\n      candidates.length,\n      results.length,\n      Date.now() - start,\n      {\n        sessionBoostApplied: metadata.sessionBoostApplied,\n        causalBoostApplied: metadata.causalBoostApplied,\n        intentWeightsApplied: metadata.intentWeightsApplied,\n        artifactRoutingApplied: metadata.artifactRoutingApplied,\n        feedbackSignalsApplied: metadata.feedbackSignalsApplied,\n        graphContribution: metadata.graphContribution,\n        searchType: config.searchType,\n        isHybrid,\n      }\n    );\n  }\n\n  metadata.durationMs = Date.now() - start;\n\n  return {\n    scored: results,\n    metadata,\n  };\n}\n\n// -- Test surface --\n\n/**\n * Internal functions exposed for unit testing.\n *\n * These are NOT part of the public API and may change without notice.\n * Access only from `*.test.ts` / `*.vitest.ts` files.\n */\nexport const __testables = {\n  resolveBaseScore,\n  strengthenOnAccess,\n  applyIntentWeightsToResults,\n  applyArtifactRouting,\n  applyFeedbackSignals,\n  applyUsageRankingBoost,\n  applyTestingEffect,\n  enrichResultsWithAnchorMetadata,\n  enrichResultsWithValidationMetadata,\n  applyValidationSignalScoring,\n  // Learned blend weight resolver, exposed for unit testing\n  // the env-var clamp and default-zero behavior.\n  resolveLearnedBlendWeight,\n};","lineStart":1240,"lineEnd":1486,"totalLines":1486,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","time":{"start":1781762518764,"end":1781762518781}},"metadata":{"openai":{"itemId":"fc_09fea31d49f1b9f7016a3389d6a3308191b5b042b972c3e369"}},"id":"prt_ed9526eb0001GvXfyK3iTSfKFW","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed951f9f50011nSEI60i9v7yun"}}
{"type":"tool_use","timestamp":1781762518785,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_jwPah2vNxToB6altDWV6wdfP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Stage4 Filter\n3: // ───────────────────────────────────────────────────────────────\n4: // Final stage of the 4-stage retrieval pipeline.\n5: //\n6: // ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n7: // Any ordering change after Stage 3 is a bug. Score fields on\n8: // Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n9: // Via captureScoreSnapshot / verifyScoreInvariant provides a second\n10: // Defence-in-depth layer.\n11: //\n12: // I/O CONTRACT:\n13: // Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n14: // Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n15: // Key invariants:\n16: //     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n17: // AttentionScore, importance_weight) may change between input and output\n18: //     - Ordering from Stage 3 is preserved for all surviving rows\n19: //     - final contains only rows at or above config.minState priority\n20: // Side effects:\n21: //     - None — this stage is read-only with respect to the database\n22: //\n23: // FILTER APPLICATION ORDER (within filterByMemoryState):\n24: // 1. memoryState priority filter — rows below minState are removed\n25: // 2. Per-tier hard limits        — STATE_LIMITS caps applied when applyStateLimits=true\n26: //\n27: // Responsibilities (in execution order):\n28: // 1. Capture score snapshot BEFORE any operations (runtime invariant)\n29: // 2. Apply memory-state filtering (filterByMemoryState)\n30: // 3. Apply evidence gap detection via TRM (Z-score confidence check)\n31: // 4. Add annotation metadata (feature flags, state stats, etc.)\n32: // 5. Verify score invariant AFTER all operations\n33: //\n34: // NOT in Stage 4: session dedup — that happens after cache in the\n35: // Main handler to avoid double-counting and cache pollution.\n36: \n37: import type { Stage4Input, Stage4Output, Stage4ReadonlyRow, PipelineRow } from './types.js';\n38: import { captureScoreSnapshot, verifyScoreInvariant, resolveEffectiveScore } from './types.js';\n39: import { isTRMEnabled, isMultiQueryEnabled } from '../search-flags.js';\n40: import { detectEvidenceGap, formatEvidenceGapWarning } from '../evidence-gap-detector.js';\n41: import { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n42: \n43: // Feature catalog: 4-stage pipeline architecture\n44: // Feature catalog: Confidence-based result truncation\n45: \n46: \n47: // ───────────────────────────────────────────────────────────────\n48: // 2. CONSTANTS\n49: \n50: \n51: // ───────────────────────────────────────────────────────────────\n52: /**\n53:  * Memory state priority map. Higher number = higher priority.\n54:  * Used to compare states numerically so filtering is O(1) per row.\n55:  */\n56: const STATE_PRIORITY: Record<string, number> = {\n57:   HOT: 5,\n58:   WARM: 4,\n59:   COLD: 3,\n60:   DORMANT: 2,\n61:   ARCHIVED: 1,\n62: };\n63: \n64: /**\n65:  * Per-tier hard limits applied when `applyStateLimits` is true.\n66:  * Prevents any single tier from monopolising the result window.\n67:  */\n68: export const STATE_LIMITS: Record<string, number> = {\n69:   HOT: 50,\n70:   WARM: 30,\n71:   COLD: 20,\n72:   DORMANT: 10,\n73:   ARCHIVED: 5,\n74: };\n75: \n76: /** Fallback priority for unknown/missing memoryState values.\n77:  * Set above HOT (5) so UNKNOWN memories always pass state filters.\n78:  * memoryState column doesn't exist yet — all memories are UNKNOWN.\n79:  * Reset to 0 when the TRM state column is implemented. */\n80: const UNKNOWN_STATE_PRIORITY = 6;\n81: \n82: function normalizeStateValue(state: unknown): string | null {\n83:   if (typeof state !== 'string') {\n84:     return null;\n85:   }\n86:   const normalizedState = state.toUpperCase();\n87:   return normalizedState in STATE_PRIORITY ? normalizedState : null;\n88: }\n89: \n90: function resolveStateForFiltering(row: Stage4ReadonlyRow): string {\n91:   const explicitState = normalizeStateValue(row.memoryState);\n92:   if (explicitState) {\n93:     return explicitState;\n94:   }\n95: \n96:   return 'UNKNOWN';\n97: }\n98: \n99: // ───────────────────────────────────────────────────────────────\n100: // 3. TYPES\n101: \n102: \n103: // ───────────────────────────────────────────────────────────────\n104: /**\n105:  * Per-state tally produced by `filterByMemoryState`.\n106:  * Keys are state names (e.g. \"HOT\", \"WARM\"); values are counts.\n107:  */\n108: export type StateStats = Record<string, number>;\n109: \n110: /**\n111:  * Return value of the internal `filterByMemoryState` function.\n112:  */\n113: export interface FilterResult {\n114:   /** Rows that survived state filtering, in original order. */\n115:   filtered: Stage4ReadonlyRow[];\n116:   /** Pre-filter per-state counts (includes removed rows). */\n117:   statsBefore: StateStats;\n118:   /** Post-filter per-state counts. */\n119:   statsAfter: StateStats;\n120:   /** Total number of rows removed. */\n121:   removedCount: number;\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    3. INTERNAL: filterByMemoryState\n126:    ──────────────────────────────────────────────────────────────── */\n127: \n128: /**\n129:  * Remove rows whose `memoryState` falls below `minState` priority and,\n130:  * optionally, enforce per-tier result limits via `STATE_LIMITS`.\n131:  *\n132:  * IMPORTANT: This function ONLY removes items — it never reorders or\n133:  * modifies score fields. The original ordering from Stage 3 is preserved\n134:  * for all rows that survive.\n135:  *\n136:  * @param results        - Read-only rows from Stage 3 output.\n137:  * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n138:  * @param applyStateLimits - When true, cap each tier to STATE_LIMITS[tier].\n139:  * @returns FilterResult with the surviving rows and before/after stats.\n140:  */\n141: export function filterByMemoryState(\n142:   results: Stage4ReadonlyRow[],\n143:   minState: string,\n144:   applyStateLimits: boolean,\n145: ): FilterResult {\n146:   const normalizedMinState = normalizeStateValue(minState);\n147:   const minPriority = STATE_PRIORITY[normalizedMinState ?? ''] ?? UNKNOWN_STATE_PRIORITY;\n148: \n149:   // -- 3a. Tally states before filtering --\n150:   const statsBefore: StateStats = {};\n151:   for (const row of results) {\n152:     const state = normalizeStateValue(row.memoryState) ?? 'UNKNOWN';\n153:     statsBefore[state] = (statsBefore[state] ?? 0) + 1;\n154:   }\n155: \n156:   // -- 3b. State-priority filter --\n157:   let passing = results.filter(row => {\n158:     const state = resolveStateForFiltering(row);\n159:     const priority = STATE_PRIORITY[state] ?? UNKNOWN_STATE_PRIORITY;\n160:     return priority >= minPriority;\n161:   });\n162: \n163:   // -- 3c. Per-tier limits (optional) --\n164:   if (applyStateLimits) {\n165:     const tierCounters: Record<string, number> = {};\n166:     const limitPassing: Stage4ReadonlyRow[] = [];\n167: \n168:     for (const row of passing) {\n169:       const state = resolveStateForFiltering(row);\n170:       const limit = STATE_LIMITS[state] ?? Infinity;\n171:       const count = tierCounters[state] ?? 0;\n172: \n173:       if (count < limit) {\n174:         tierCounters[state] = count + 1;\n175:         limitPassing.push(row);\n176:       }\n177:       // Rows exceeding the per-tier limit are silently dropped (no score change).\n178:     }\n179: \n180:     passing = limitPassing;\n181:   }\n182: \n183:   // -- 3d. Tally states after filtering --\n184:   const statsAfter: StateStats = {};\n185:   for (const row of passing) {\n186:     const state = resolveStateForFiltering(row);\n187:     statsAfter[state] = (statsAfter[state] ?? 0) + 1;\n188:   }\n189: \n190:   return {\n191:     filtered: passing,\n192:     statsBefore,\n193:     statsAfter,\n194:     removedCount: results.length - passing.length,\n195:   };\n196: }\n197: \n198: /* ───────────────────────────────────────────────────────────────\n199:    4. INTERNAL: extractScoringValues\n200:    ──────────────────────────────────────────────────────────────── */\n201: \n202: /**\n203:  * Extract the best available numeric score from a row for evidence-gap\n204:  * analysis. Delegates to resolveEffectiveScore (canonical chain in types.ts)\n205:  * so scoring, sorting, and filtering all agree on precedence and normalization.\n206:  *\n207:  * A1 FIX: Previously used a different precedence order (rrfScore first) and\n208:  * did NOT divide similarity by 100, causing a 100x scale mismatch on rows\n209:  * that only had the similarity field set.\n210:  *\n211:  * @param row - A Stage4ReadonlyRow to inspect.\n212:  * @returns The best available numeric score clamped to [0,1], or 0.\n213:  */\n214: export function extractScoringValue(row: Stage4ReadonlyRow): number {\n215:   return resolveEffectiveScore(row as unknown as PipelineRow);\n216: }\n217: \n218: /* ───────────────────────────────────────────────────────────────\n219:    5. MAIN: executeStage4\n220:    ──────────────────────────────────────────────────────────────── */\n221: \n222: /**\n223:  * Execute Stage 4 of the 4-stage retrieval pipeline: Filter + Annotate.\n224:  *\n225:  * Stage 4 is the final pipeline stage. It removes results that fall below\n226:  * the configured minimum memory state, runs the Transparent Reasoning Module\n227:  * (TRM) evidence-gap check, attaches annotation metadata, and verifies the\n228:  * score invariant before returning.\n229:  *\n230:  * **Score invariant:** No score fields are modified in Stage 4. The compile-time\n231:  * guarantee is enforced via Stage4ReadonlyRow readonly fields; the runtime check\n232:  * via captureScoreSnapshot / verifyScoreInvariant provides defence-in-depth. If\n233:  * verifyScoreInvariant throws, it indicates a Stage 4 implementation bug.\n234:  *\n235:  * **Session dedup:** Session deduplication is intentionally NOT performed here.\n236:  * It happens after the cache layer in the main handler to avoid cache pollution.\n237:  *\n238:  * @param input - Stage4Input containing read-only results and pipeline config.\n239:  * @returns Stage4Output with filtered/annotated results and metadata.\n240:  * @throws Error if verifyScoreInvariant detects any score mutation (Stage 4 bug).\n241:  */\n242: export async function executeStage4(input: Stage4Input): Promise<Stage4Output> {\n243:   const stageStart = Date.now();\n244:   const { results, config } = input;\n245: \n246:   // -- Step 1: Capture score snapshot (runtime invariant) --\n247:   //\n248:   // This snapshot is the source-of-truth for the \"no score changes\" assertion.\n249:   // It is taken over the FULL input set BEFORE any operations, so rows that\n250:   // Are subsequently filtered out are still in the before-snapshot. The\n251:   // VerifyScoreInvariant call skips rows not present in the after-set.\n252:   const scoresBefore = captureScoreSnapshot(results);\n253: \n254:   // -- Step 2: State filtering --\n255:   const filterResult = filterByMemoryState(\n256:     results,\n257:     config.minState,\n258:     config.applyStateLimits,\n259:   );\n260: \n261:   let workingResults: Stage4ReadonlyRow[] = filterResult.filtered;\n262:   const stateFiltered = filterResult.removedCount;\n263: \n264:   // -- Step 3: Evidence gap detection (TRM) --\n265:   let evidenceGapDetected = false;\n266:   let evidenceGapWarning: string | undefined;\n267: \n268:   if (isTRMEnabled()) {\n269:     const scores = workingResults.map(extractScoringValue);\n270:     const trm = detectEvidenceGap(scores);\n271: \n272:     evidenceGapDetected = trm.gapDetected;\n273: \n274:     if (trm.gapDetected) {\n275:       evidenceGapWarning = formatEvidenceGapWarning(trm);\n276: \n277:       // Annotate each result with the gap metadata (non-score field).\n278:       workingResults = workingResults.map(row => ({\n279:         ...row,\n280:         evidenceGap: { gapDetected: true, warning: evidenceGapWarning },\n281:       }));\n282:     }\n283:   }\n284: \n285:   // -- Step 4: Build annotation metadata --\n286:   const featureFlags: Record<string, boolean> = {\n287:     trmEnabled: isTRMEnabled(),\n288:     multiQueryEnabled: isMultiQueryEnabled(),\n289:     stateLimitsApplied: config.applyStateLimits,\n290:   };\n291: \n292:   const stateStats: Record<string, unknown> = {\n293:     minState: config.minState,\n294:     before: filterResult.statsBefore,\n295:     after: filterResult.statsAfter,\n296:     removed: stateFiltered,\n297:   };\n298: \n299:   const annotations: Stage4Output['annotations'] = {\n300:     evidenceGapWarning,\n301:     stateStats,\n302:     featureFlags,\n303:   };\n304: \n305:   // -- Step 4b: Final limit cap --\n306:   // Enforce caller's limit after all filtering to prevent degraded paths exceeding requested count\n307:   if (typeof config.limit === 'number' && config.limit > 0 && workingResults.length > config.limit) {\n308:     workingResults = workingResults.slice(0, config.limit);\n309:   }\n310: \n311:   // -- Step 5: Verify score invariant (defence-in-depth) --\n312:   //\n313:   // VerifyScoreInvariant checks every row that survived filtering.\n314:   // Rows removed by filterByMemoryState are absent from workingResults,\n315:   // So the function correctly skips them (see types.ts implementation).\n316:   // Throws [Stage4Invariant] Error if any score field was mutated.\n317:   verifyScoreInvariant(scoresBefore, workingResults);\n318: \n319:   const durationMs = Date.now() - stageStart;\n320: \n321:   // -- Trace entry --\n322:   if (config.trace) {\n323:     addTraceEntry(\n324:       config.trace,\n325:       'filter',\n326:       results.length,\n327:       workingResults.length,\n328:       durationMs,\n329:       {\n330:         stateFiltered,\n331:         evidenceGapDetected,\n332:         trmEnabled: isTRMEnabled(),\n333:         applyStateLimits: config.applyStateLimits,\n334:         minState: config.minState,\n335:       },\n336:     );\n337:   }\n338: \n339:   return {\n340:     final: workingResults,\n341:     metadata: {\n342:       stateFiltered,\n343:       // sessionDeduped removed; dedup is post-cache in main handler\n344:       // constitutionalInjected passed from Stage 1 metadata\n345:       constitutionalInjected: input.stage1Metadata?.constitutionalInjected ?? 0,\n346:       evidenceGapDetected,\n347:       durationMs,\n348:     },\n349:     annotations,\n350:   };\n351: }\n352: \n353: // ───────────────────────────────────────────────────────────────\n354: // 4. TEST SURFACE\n355: \n356: \n357: // ───────────────────────────────────────────────────────────────\n358: /**\n359:  * Exported internals for unit testing.\n360:  * Not intended for production use outside the test harness.\n361:  */\n362: export const __testables = {\n363:   filterByMemoryState,\n364:   resolveStateForFiltering,\n365:   normalizeStateValue,\n366:   extractScoringValue,\n367:   STATE_PRIORITY,\n368:   STATE_LIMITS,\n369:   UNKNOWN_STATE_PRIORITY,\n370: } as const;\n\n(End of file - total 370 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage4 Filter\n// ───────────────────────────────────────────────────────────────\n// Final stage of the 4-stage retrieval pipeline.\n//\n// ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n// Any ordering change after Stage 3 is a bug. Score fields on\n// Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n// Via captureScoreSnapshot / verifyScoreInvariant provides a second\n// Defence-in-depth layer.\n//\n// I/O CONTRACT:\n// Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n// Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n// Key invariants:\n//     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n// AttentionScore, importance_weight) may change between input and output\n//     - Ordering from Stage 3 is preserved for all surviving rows\n//     - final contains only rows at or above config.minState priority\n// Side effects:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Stage4 Filter\n// ───────────────────────────────────────────────────────────────\n// Final stage of the 4-stage retrieval pipeline.\n//\n// ARCHITECTURAL INVARIANT: Stage 4 MUST NOT modify scores.\n// Any ordering change after Stage 3 is a bug. Score fields on\n// Stage4ReadonlyRow are compile-time readonly; the runtime assertion\n// Via captureScoreSnapshot / verifyScoreInvariant provides a second\n// Defence-in-depth layer.\n//\n// I/O CONTRACT:\n// Input:  Stage4Input { results: Stage4ReadonlyRow[], config }\n// Output: Stage4Output { final: Stage4ReadonlyRow[], metadata, annotations }\n// Key invariants:\n//     - No score field (similarity, score, rrfScore, intentAdjustedScore,\n// AttentionScore, importance_weight) may change between input and output\n//     - Ordering from Stage 3 is preserved for all surviving rows\n//     - final contains only rows at or above config.minState priority\n// Side effects:\n//     - None — this stage is read-only with respect to the database\n//\n// FILTER APPLICATION ORDER (within filterByMemoryState):\n// 1. memoryState priority filter — rows below minState are removed\n// 2. Per-tier hard limits        — STATE_LIMITS caps applied when applyStateLimits=true\n//\n// Responsibilities (in execution order):\n// 1. Capture score snapshot BEFORE any operations (runtime invariant)\n// 2. Apply memory-state filtering (filterByMemoryState)\n// 3. Apply evidence gap detection via TRM (Z-score confidence check)\n// 4. Add annotation metadata (feature flags, state stats, etc.)\n// 5. Verify score invariant AFTER all operations\n//\n// NOT in Stage 4: session dedup — that happens after cache in the\n// Main handler to avoid double-counting and cache pollution.\n\nimport type { Stage4Input, Stage4Output, Stage4ReadonlyRow, PipelineRow } from './types.js';\nimport { captureScoreSnapshot, verifyScoreInvariant, resolveEffectiveScore } from './types.js';\nimport { isTRMEnabled, isMultiQueryEnabled } from '../search-flags.js';\nimport { detectEvidenceGap, formatEvidenceGapWarning } from '../evidence-gap-detector.js';\nimport { addTraceEntry } from '@spec-kit/shared/contracts/retrieval-trace';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Confidence-based result truncation\n\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Memory state priority map. Higher number = higher priority.\n * Used to compare states numerically so filtering is O(1) per row.\n */\nconst STATE_PRIORITY: Record<string, number> = {\n  HOT: 5,\n  WARM: 4,\n  COLD: 3,\n  DORMANT: 2,\n  ARCHIVED: 1,\n};\n\n/**\n * Per-tier hard limits applied when `applyStateLimits` is true.\n * Prevents any single tier from monopolising the result window.\n */\nexport const STATE_LIMITS: Record<string, number> = {\n  HOT: 50,\n  WARM: 30,\n  COLD: 20,\n  DORMANT: 10,\n  ARCHIVED: 5,\n};\n\n/** Fallback priority for unknown/missing memoryState values.\n * Set above HOT (5) so UNKNOWN memories always pass state filters.\n * memoryState column doesn't exist yet — all memories are UNKNOWN.\n * Reset to 0 when the TRM state column is implemented. */\nconst UNKNOWN_STATE_PRIORITY = 6;\n\nfunction normalizeStateValue(state: unknown): string | null {\n  if (typeof state !== 'string') {\n    return null;\n  }\n  const normalizedState = state.toUpperCase();\n  return normalizedState in STATE_PRIORITY ? normalizedState : null;\n}\n\nfunction resolveStateForFiltering(row: Stage4ReadonlyRow): string {\n  const explicitState = normalizeStateValue(row.memoryState);\n  if (explicitState) {\n    return explicitState;\n  }\n\n  return 'UNKNOWN';\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. TYPES\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Per-state tally produced by `filterByMemoryState`.\n * Keys are state names (e.g. \"HOT\", \"WARM\"); values are counts.\n */\nexport type StateStats = Record<string, number>;\n\n/**\n * Return value of the internal `filterByMemoryState` function.\n */\nexport interface FilterResult {\n  /** Rows that survived state filtering, in original order. */\n  filtered: Stage4ReadonlyRow[];\n  /** Pre-filter per-state counts (includes removed rows). */\n  statsBefore: StateStats;\n  /** Post-filter per-state counts. */\n  statsAfter: StateStats;\n  /** Total number of rows removed. */\n  removedCount: number;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. INTERNAL: filterByMemoryState\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Remove rows whose `memoryState` falls below `minState` priority and,\n * optionally, enforce per-tier result limits via `STATE_LIMITS`.\n *\n * IMPORTANT: This function ONLY removes items — it never reorders or\n * modifies score fields. The original ordering from Stage 3 is preserved\n * for all rows that survive.\n *\n * @param results        - Read-only rows from Stage 3 output.\n * @param minState       - Minimum acceptable state (e.g. \"WARM\").\n * @param applyStateLimits - When true, cap each tier to STATE_LIMITS[tier].\n * @returns FilterResult with the surviving rows and before/after stats.\n */\nexport function filterByMemoryState(\n  results: Stage4ReadonlyRow[],\n  minState: string,\n  applyStateLimits: boolean,\n): FilterResult {\n  const normalizedMinState = normalizeStateValue(minState);\n  const minPriority = STATE_PRIORITY[normalizedMinState ?? ''] ?? UNKNOWN_STATE_PRIORITY;\n\n  // -- 3a. Tally states before filtering --\n  const statsBefore: StateStats = {};\n  for (const row of results) {\n    const state = normalizeStateValue(row.memoryState) ?? 'UNKNOWN';\n    statsBefore[state] = (statsBefore[state] ?? 0) + 1;\n  }\n\n  // -- 3b. State-priority filter --\n  let passing = results.filter(row => {\n    const state = resolveStateForFiltering(row);\n    const priority = STATE_PRIORITY[state] ?? UNKNOWN_STATE_PRIORITY;\n    return priority >= minPriority;\n  });\n\n  // -- 3c. Per-tier limits (optional) --\n  if (applyStateLimits) {\n    const tierCounters: Record<string, number> = {};\n    const limitPassing: Stage4ReadonlyRow[] = [];\n\n    for (const row of passing) {\n      const state = resolveStateForFiltering(row);\n      const limit = STATE_LIMITS[state] ?? Infinity;\n      const count = tierCounters[state] ?? 0;\n\n      if (count < limit) {\n        tierCounters[state] = count + 1;\n        limitPassing.push(row);\n      }\n      // Rows exceeding the per-tier limit are silently dropped (no score change).\n    }\n\n    passing = limitPassing;\n  }\n\n  // -- 3d. Tally states after filtering --\n  const statsAfter: StateStats = {};\n  for (const row of passing) {\n    const state = resolveStateForFiltering(row);\n    statsAfter[state] = (statsAfter[state] ?? 0) + 1;\n  }\n\n  return {\n    filtered: passing,\n    statsBefore,\n    statsAfter,\n    removedCount: results.length - passing.length,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. INTERNAL: extractScoringValues\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Extract the best available numeric score from a row for evidence-gap\n * analysis. Delegates to resolveEffectiveScore (canonical chain in types.ts)\n * so scoring, sorting, and filtering all agree on precedence and normalization.\n *\n * A1 FIX: Previously used a different precedence order (rrfScore first) and\n * did NOT divide similarity by 100, causing a 100x scale mismatch on rows\n * that only had the similarity field set.\n *\n * @param row - A Stage4ReadonlyRow to inspect.\n * @returns The best available numeric score clamped to [0,1], or 0.\n */\nexport function extractScoringValue(row: Stage4ReadonlyRow): number {\n  return resolveEffectiveScore(row as unknown as PipelineRow);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. MAIN: executeStage4\n   ──────────────────────────────────────────────────────────────── */\n\n/**\n * Execute Stage 4 of the 4-stage retrieval pipeline: Filter + Annotate.\n *\n * Stage 4 is the final pipeline stage. It removes results that fall below\n * the configured minimum memory state, runs the Transparent Reasoning Module\n * (TRM) evidence-gap check, attaches annotation metadata, and verifies the\n * score invariant before returning.\n *\n * **Score invariant:** No score fields are modified in Stage 4. The compile-time\n * guarantee is enforced via Stage4ReadonlyRow readonly fields; the runtime check\n * via captureScoreSnapshot / verifyScoreInvariant provides defence-in-depth. If\n * verifyScoreInvariant throws, it indicates a Stage 4 implementation bug.\n *\n * **Session dedup:** Session deduplication is intentionally NOT performed here.\n * It happens after the cache layer in the main handler to avoid cache pollution.\n *\n * @param input - Stage4Input containing read-only results and pipeline config.\n * @returns Stage4Output with filtered/annotated results and metadata.\n * @throws Error if verifyScoreInvariant detects any score mutation (Stage 4 bug).\n */\nexport async function executeStage4(input: Stage4Input): Promise<Stage4Output> {\n  const stageStart = Date.now();\n  const { results, config } = input;\n\n  // -- Step 1: Capture score snapshot (runtime invariant) --\n  //\n  // This snapshot is the source-of-truth for the \"no score changes\" assertion.\n  // It is taken over the FULL input set BEFORE any operations, so rows that\n  // Are subsequently filtered out are still in the before-snapshot. The\n  // VerifyScoreInvariant call skips rows not present in the after-set.\n  const scoresBefore = captureScoreSnapshot(results);\n\n  // -- Step 2: State filtering --\n  const filterResult = filterByMemoryState(\n    results,\n    config.minState,\n    config.applyStateLimits,\n  );\n\n  let workingResults: Stage4ReadonlyRow[] = filterResult.filtered;\n  const stateFiltered = filterResult.removedCount;\n\n  // -- Step 3: Evidence gap detection (TRM) --\n  let evidenceGapDetected = false;\n  let evidenceGapWarning: string | undefined;\n\n  if (isTRMEnabled()) {\n    const scores = workingResults.map(extractScoringValue);\n    const trm = detectEvidenceGap(scores);\n\n    evidenceGapDetected = trm.gapDetected;\n\n    if (trm.gapDetected) {\n      evidenceGapWarning = formatEvidenceGapWarning(trm);\n\n      // Annotate each result with the gap metadata (non-score field).\n      workingResults = workingResults.map(row => ({\n        ...row,\n        evidenceGap: { gapDetected: true, warning: evidenceGapWarning },\n      }));\n    }\n  }\n\n  // -- Step 4: Build annotation metadata --\n  const featureFlags: Record<string, boolean> = {\n    trmEnabled: isTRMEnabled(),\n    multiQueryEnabled: isMultiQueryEnabled(),\n    stateLimitsApplied: config.applyStateLimits,\n  };\n\n  const stateStats: Record<string, unknown> = {\n    minState: config.minState,\n    before: filterResult.statsBefore,\n    after: filterResult.statsAfter,\n    removed: stateFiltered,\n  };\n\n  const annotations: Stage4Output['annotations'] = {\n    evidenceGapWarning,\n    stateStats,\n    featureFlags,\n  };\n\n  // -- Step 4b: Final limit cap --\n  // Enforce caller's limit after all filtering to prevent degraded paths exceeding requested count\n  if (typeof config.limit === 'number' && config.limit > 0 && workingResults.length > config.limit) {\n    workingResults = workingResults.slice(0, config.limit);\n  }\n\n  // -- Step 5: Verify score invariant (defence-in-depth) --\n  //\n  // VerifyScoreInvariant checks every row that survived filtering.\n  // Rows removed by filterByMemoryState are absent from workingResults,\n  // So the function correctly skips them (see types.ts implementation).\n  // Throws [Stage4Invariant] Error if any score field was mutated.\n  verifyScoreInvariant(scoresBefore, workingResults);\n\n  const durationMs = Date.now() - stageStart;\n\n  // -- Trace entry --\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'filter',\n      results.length,\n      workingResults.length,\n      durationMs,\n      {\n        stateFiltered,\n        evidenceGapDetected,\n        trmEnabled: isTRMEnabled(),\n        applyStateLimits: config.applyStateLimits,\n        minState: config.minState,\n      },\n    );\n  }\n\n  return {\n    final: workingResults,\n    metadata: {\n      stateFiltered,\n      // sessionDeduped removed; dedup is post-cache in main handler\n      // constitutionalInjected passed from Stage 1 metadata\n      constitutionalInjected: input.stage1Metadata?.constitutionalInjected ?? 0,\n      evidenceGapDetected,\n      durationMs,\n    },\n    annotations,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. TEST SURFACE\n\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Exported internals for unit testing.\n * Not intended for production use outside the test harness.\n */\nexport const __testables = {\n  filterByMemoryState,\n  resolveStateForFiltering,\n  normalizeStateValue,\n  extractScoringValue,\n  STATE_PRIORITY,\n  STATE_LIMITS,\n  UNKNOWN_STATE_PRIORITY,\n} as const;","lineStart":1,"lineEnd":370,"totalLines":370,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage4-filter.ts","time":{"start":1781762518773,"end":1781762518784}},"metadata":{"openai":{"itemId":"fc_09fea31d49f1b9f7016a3389d6a34c8191b047e0107aad9c6e"}},"id":"prt_ed9526ef2001MjHC2cejdJduid","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed951f9f50011nSEI60i9v7yun"}}
{"type":"tool_use","timestamp":1781762518800,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_qfoM9Hqg9XFLmRIKdlJyyULp","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Search Utilities\n3: // ───────────────────────────────────────────────────────────────\n4: // Extracted from handlers/memory-search.ts\n5: // Small, stateless utility functions used during search:\n6: // quality filtering, threshold resolution, cache key building,\n7: // context type resolution, and artifact routing helpers.\n8: \n9: import { applyRoutingWeights } from './artifact-routing.js';\n10: import type { RoutingResult, WeightedResult } from './artifact-routing.js';\n11: import { isContinuityQuery } from './intent-classifier.js';\n12: \n13: /* ───────────────────────────────────────────────────────────────\n14:    1. TYPES\n15: ──────────────────────────────────────────────────────────────── */\n16: \n17: /**\n18:  * Minimal row shape for search utility functions.\n19:  * Mirrors the subset of MemorySearchRow fields that these helpers access.\n20:  */\n21: interface SearchUtilRow extends Record<string, unknown> {\n22:   id: number;\n23:   contextType?: string;\n24:   context_type?: string;\n25:   quality_score?: number;\n26: }\n27: \n28: interface CacheArgsInput {\n29:   normalizedQuery: string | null;\n30:   hasValidConcepts: boolean;\n31:   concepts?: string[];\n32:   specFolder?: string;\n33:   tenantId?: string;\n34:   userId?: string;\n35:   agentId?: string;\n36:   limit: number;\n37:   mode?: string;\n38:   tier?: string;\n39:   contextType?: string;\n40:   useDecay: boolean;\n41:   includeArchived: boolean;\n42:   qualityThreshold?: number;\n43:   applyStateLimits: boolean | undefined;\n44:   includeContiguity: boolean;\n45:   includeConstitutional: boolean;\n46:   includeContent: boolean;\n47:   anchors?: string[] | string;\n48:   detectedIntent: string | null;\n49:   adaptiveFusionIntent?: string | null;\n50:   minState: string;\n51:   rerank: boolean;\n52:   applyLengthPenalty: boolean;\n53:   sessionId?: string;\n54:   enableSessionBoost: boolean;\n55:   enableCausalBoost: boolean;\n56:   includeTrace?: boolean;\n57:   cacheVersion?: string;\n58:   /**\n59:    * Causal-edges generation counter snapshot. When `enableCausalBoost`\n60:    * is true, callers should pass the current generation from\n61:    * `causalEdges.getCausalEdgesGeneration()` so that any causal-edge mutation\n62:    * naturally invalidates this cache key on the next lookup.\n63:    * Optional and ignored when undefined to keep cache keys stable for callers\n64:    * that do not depend on the causal graph.\n65:    */\n66:   causalEdgesGeneration?: number;\n67: }\n68: \n69: function resolveFusionIntentContract(\n70:   args: {\n71:     detectedIntent: string | null;\n72:     adaptiveFusionIntent?: string | null;\n73:     query?: string | null;\n74:   },\n75: ): string | null {\n76:   const { detectedIntent, adaptiveFusionIntent, query } = args;\n77:   if (typeof adaptiveFusionIntent === 'string' && adaptiveFusionIntent.trim().length > 0) {\n78:     return adaptiveFusionIntent;\n79:   }\n80:   if (typeof query === 'string' && isContinuityQuery(query)) {\n81:     return 'continuity';\n82:   }\n83:   if (typeof detectedIntent === 'string' && detectedIntent.trim().length > 0) {\n84:     return detectedIntent;\n85:   }\n86:   return null;\n87: }\n88: \n89: /* ───────────────────────────────────────────────────────────────\n90:    2. FUNCTIONS\n91: ──────────────────────────────────────────────────────────────── */\n92: \n93: /**\n94:  * Resolve the context type from a row, preferring camelCase over snake_case.\n95:  */\n96: function resolveRowContextType(row: SearchUtilRow): string | undefined {\n97:   if (typeof row.contextType === 'string' && row.contextType.length > 0) {\n98:     return row.contextType;\n99:   }\n100:   if (typeof row.context_type === 'string' && row.context_type.length > 0) {\n101:     return row.context_type;\n102:   }\n103:   return undefined;\n104: }\n105: \n106: /**\n107:  * Filter results by minimum quality score.\n108:  * Returns all results if no valid threshold is provided.\n109:  */\n110: function filterByMinQualityScore(results: SearchUtilRow[], minQualityScore?: number): SearchUtilRow[] {\n111:   if (typeof minQualityScore !== 'number' || !Number.isFinite(minQualityScore)) {\n112:     return results;\n113:   }\n114: \n115:   const threshold = Math.max(0, Math.min(1, minQualityScore));\n116:   return results.filter((result) => {\n117:     const rawScore = result.quality_score as number | undefined;\n118:     const score = typeof rawScore === 'number' && Number.isFinite(rawScore) ? rawScore : 0;\n119:     return score >= threshold;\n120:   });\n121: }\n122: \n123: /**\n124:  * Resolve the quality threshold from camelCase or snake_case parameter.\n125:  */\n126: function resolveQualityThreshold(minQualityScore?: number, minQualityScoreSnake?: number): number | undefined {\n127:   if (typeof minQualityScore === 'number' && Number.isFinite(minQualityScore)) {\n128:     return minQualityScore;\n129:   }\n130: \n131:   if (typeof minQualityScoreSnake === 'number' && Number.isFinite(minQualityScoreSnake)) {\n132:     return minQualityScoreSnake;\n133:   }\n134: \n135:   return undefined;\n136: }\n137: \n138: /**\n139:  * Build a cache key arguments object from search parameters.\n140:  */\n141: function buildCacheArgs({\n142:   normalizedQuery,\n143:   hasValidConcepts,\n144:   concepts,\n145:   specFolder,\n146:   tenantId,\n147:   userId,\n148:   agentId,\n149:   limit,\n150:   mode,\n151:   tier,\n152:   contextType,\n153:   useDecay,\n154:   includeArchived,\n155:   qualityThreshold,\n156:   applyStateLimits,\n157:   includeContiguity,\n158:   includeConstitutional,\n159:   includeContent,\n160:   anchors,\n161:   detectedIntent,\n162:   adaptiveFusionIntent,\n163:   minState,\n164:   rerank,\n165:   applyLengthPenalty,\n166:   sessionId,\n167:   enableSessionBoost,\n168:   enableCausalBoost,\n169:   includeTrace = false,\n170:   cacheVersion,\n171:   causalEdgesGeneration,\n172: }: CacheArgsInput): Record<string, unknown> {\n173:   const resolvedFusionIntent = resolveFusionIntentContract({\n174:     detectedIntent,\n175:     adaptiveFusionIntent,\n176:     query: normalizedQuery,\n177:   });\n178:   // Only include causal-edges generation in the cache key when the\n179:   // caller has actually opted into causal boost; otherwise cache keys remain\n180:   // stable for callers that do not consume the causal graph.\n181:   const includeCausalGeneration = enableCausalBoost === true\n182:     && typeof causalEdgesGeneration === 'number'\n183:     && Number.isFinite(causalEdgesGeneration);\n184:   return {\n185:     query: normalizedQuery,\n186:     concepts: hasValidConcepts ? concepts : undefined,\n187:     specFolder,\n188:     tenantId,\n189:     userId,\n190:     agentId,\n191:     limit,\n192:     mode,\n193:     tier,\n194:     contextType,\n195:     useDecay,\n196:     includeArchived,\n197:     qualityThreshold,\n198:     applyStateLimits,\n199:     includeContiguity,\n200:     includeConstitutional,\n201:     includeContent,\n202:     anchors,\n203:     intent: resolvedFusionIntent ?? detectedIntent,\n204:     fusionIntent: resolvedFusionIntent,\n205:     minState,\n206:     rerank,\n207:     applyLengthPenalty,\n208:     sessionId,\n209:     enableSessionBoost,\n210:     enableCausalBoost,\n211:     includeTrace,\n212:     cacheVersion,\n213:     causalEdgesGeneration: includeCausalGeneration ? causalEdgesGeneration : undefined,\n214:   };\n215: }\n216: \n217: /**\n218:  * Resolve the best available query string for artifact routing.\n219:  * Falls back to joining concepts if no query string is provided.\n220:  */\n221: function resolveArtifactRoutingQuery(query: string | null, concepts?: string[]): string {\n222:   if (typeof query === 'string' && query.trim().length > 0) {\n223:     return query;\n224:   }\n225: \n226:   if (Array.isArray(concepts) && concepts.length > 0) {\n227:     return concepts.join(' ');\n228:   }\n229: \n230:   return '';\n231: }\n232: \n233: /**\n234:  * Apply artifact routing weights to search results.\n235:  * No-op if routing result is absent, unknown, or zero-confidence.\n236:  */\n237: function applyArtifactRouting(results: SearchUtilRow[], routingResult?: RoutingResult): SearchUtilRow[] {\n238:   if (!Array.isArray(results) || results.length === 0) {\n239:     return results;\n240:   }\n241: \n242:   if (!routingResult || routingResult.detectedClass === 'unknown' || routingResult.confidence <= 0) {\n243:     return results;\n244:   }\n245: \n246:   return applyRoutingWeights(results as WeightedResult[], routingResult.strategy) as SearchUtilRow[];\n247: }\n248: \n249: /* ───────────────────────────────────────────────────────────────\n250:    3. EXPORTS\n251: ──────────────────────────────────────────────────────────────── */\n252: \n253: export {\n254:   resolveRowContextType,\n255:   filterByMinQualityScore,\n256:   resolveQualityThreshold,\n257:   resolveFusionIntentContract,\n258:   buildCacheArgs,\n259:   resolveArtifactRoutingQuery,\n260:   applyArtifactRouting,\n261: };\n262: \n263: export type {\n264:   SearchUtilRow,\n265:   CacheArgsInput,\n266: };\n\n(End of file - total 266 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Search Utilities\n// ───────────────────────────────────────────────────────────────\n// Extracted from handlers/memory-search.ts\n// Small, stateless utility functions used during search:\n// quality filtering, threshold resolution, cache key building,\n// context type resolution, and artifact routing helpers.\n\nimport { applyRoutingWeights } from './artifact-routing.js';\nimport type { RoutingResult, WeightedResult } from './artifact-routing.js';\nimport { isContinuityQuery } from './intent-classifier.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Minimal row shape for search utility functions.\n * Mirrors the subset of MemorySearchRow fields that these helpers access.\n */","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Search Utilities\n// ───────────────────────────────────────────────────────────────\n// Extracted from handlers/memory-search.ts\n// Small, stateless utility functions used during search:\n// quality filtering, threshold resolution, cache key building,\n// context type resolution, and artifact routing helpers.\n\nimport { applyRoutingWeights } from './artifact-routing.js';\nimport type { RoutingResult, WeightedResult } from './artifact-routing.js';\nimport { isContinuityQuery } from './intent-classifier.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Minimal row shape for search utility functions.\n * Mirrors the subset of MemorySearchRow fields that these helpers access.\n */\ninterface SearchUtilRow extends Record<string, unknown> {\n  id: number;\n  contextType?: string;\n  context_type?: string;\n  quality_score?: number;\n}\n\ninterface CacheArgsInput {\n  normalizedQuery: string | null;\n  hasValidConcepts: boolean;\n  concepts?: string[];\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit: number;\n  mode?: string;\n  tier?: string;\n  contextType?: string;\n  useDecay: boolean;\n  includeArchived: boolean;\n  qualityThreshold?: number;\n  applyStateLimits: boolean | undefined;\n  includeContiguity: boolean;\n  includeConstitutional: boolean;\n  includeContent: boolean;\n  anchors?: string[] | string;\n  detectedIntent: string | null;\n  adaptiveFusionIntent?: string | null;\n  minState: string;\n  rerank: boolean;\n  applyLengthPenalty: boolean;\n  sessionId?: string;\n  enableSessionBoost: boolean;\n  enableCausalBoost: boolean;\n  includeTrace?: boolean;\n  cacheVersion?: string;\n  /**\n   * Causal-edges generation counter snapshot. When `enableCausalBoost`\n   * is true, callers should pass the current generation from\n   * `causalEdges.getCausalEdgesGeneration()` so that any causal-edge mutation\n   * naturally invalidates this cache key on the next lookup.\n   * Optional and ignored when undefined to keep cache keys stable for callers\n   * that do not depend on the causal graph.\n   */\n  causalEdgesGeneration?: number;\n}\n\nfunction resolveFusionIntentContract(\n  args: {\n    detectedIntent: string | null;\n    adaptiveFusionIntent?: string | null;\n    query?: string | null;\n  },\n): string | null {\n  const { detectedIntent, adaptiveFusionIntent, query } = args;\n  if (typeof adaptiveFusionIntent === 'string' && adaptiveFusionIntent.trim().length > 0) {\n    return adaptiveFusionIntent;\n  }\n  if (typeof query === 'string' && isContinuityQuery(query)) {\n    return 'continuity';\n  }\n  if (typeof detectedIntent === 'string' && detectedIntent.trim().length > 0) {\n    return detectedIntent;\n  }\n  return null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. FUNCTIONS\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Resolve the context type from a row, preferring camelCase over snake_case.\n */\nfunction resolveRowContextType(row: SearchUtilRow): string | undefined {\n  if (typeof row.contextType === 'string' && row.contextType.length > 0) {\n    return row.contextType;\n  }\n  if (typeof row.context_type === 'string' && row.context_type.length > 0) {\n    return row.context_type;\n  }\n  return undefined;\n}\n\n/**\n * Filter results by minimum quality score.\n * Returns all results if no valid threshold is provided.\n */\nfunction filterByMinQualityScore(results: SearchUtilRow[], minQualityScore?: number): SearchUtilRow[] {\n  if (typeof minQualityScore !== 'number' || !Number.isFinite(minQualityScore)) {\n    return results;\n  }\n\n  const threshold = Math.max(0, Math.min(1, minQualityScore));\n  return results.filter((result) => {\n    const rawScore = result.quality_score as number | undefined;\n    const score = typeof rawScore === 'number' && Number.isFinite(rawScore) ? rawScore : 0;\n    return score >= threshold;\n  });\n}\n\n/**\n * Resolve the quality threshold from camelCase or snake_case parameter.\n */\nfunction resolveQualityThreshold(minQualityScore?: number, minQualityScoreSnake?: number): number | undefined {\n  if (typeof minQualityScore === 'number' && Number.isFinite(minQualityScore)) {\n    return minQualityScore;\n  }\n\n  if (typeof minQualityScoreSnake === 'number' && Number.isFinite(minQualityScoreSnake)) {\n    return minQualityScoreSnake;\n  }\n\n  return undefined;\n}\n\n/**\n * Build a cache key arguments object from search parameters.\n */\nfunction buildCacheArgs({\n  normalizedQuery,\n  hasValidConcepts,\n  concepts,\n  specFolder,\n  tenantId,\n  userId,\n  agentId,\n  limit,\n  mode,\n  tier,\n  contextType,\n  useDecay,\n  includeArchived,\n  qualityThreshold,\n  applyStateLimits,\n  includeContiguity,\n  includeConstitutional,\n  includeContent,\n  anchors,\n  detectedIntent,\n  adaptiveFusionIntent,\n  minState,\n  rerank,\n  applyLengthPenalty,\n  sessionId,\n  enableSessionBoost,\n  enableCausalBoost,\n  includeTrace = false,\n  cacheVersion,\n  causalEdgesGeneration,\n}: CacheArgsInput): Record<string, unknown> {\n  const resolvedFusionIntent = resolveFusionIntentContract({\n    detectedIntent,\n    adaptiveFusionIntent,\n    query: normalizedQuery,\n  });\n  // Only include causal-edges generation in the cache key when the\n  // caller has actually opted into causal boost; otherwise cache keys remain\n  // stable for callers that do not consume the causal graph.\n  const includeCausalGeneration = enableCausalBoost === true\n    && typeof causalEdgesGeneration === 'number'\n    && Number.isFinite(causalEdgesGeneration);\n  return {\n    query: normalizedQuery,\n    concepts: hasValidConcepts ? concepts : undefined,\n    specFolder,\n    tenantId,\n    userId,\n    agentId,\n    limit,\n    mode,\n    tier,\n    contextType,\n    useDecay,\n    includeArchived,\n    qualityThreshold,\n    applyStateLimits,\n    includeContiguity,\n    includeConstitutional,\n    includeContent,\n    anchors,\n    intent: resolvedFusionIntent ?? detectedIntent,\n    fusionIntent: resolvedFusionIntent,\n    minState,\n    rerank,\n    applyLengthPenalty,\n    sessionId,\n    enableSessionBoost,\n    enableCausalBoost,\n    includeTrace,\n    cacheVersion,\n    causalEdgesGeneration: includeCausalGeneration ? causalEdgesGeneration : undefined,\n  };\n}\n\n/**\n * Resolve the best available query string for artifact routing.\n * Falls back to joining concepts if no query string is provided.\n */\nfunction resolveArtifactRoutingQuery(query: string | null, concepts?: string[]): string {\n  if (typeof query === 'string' && query.trim().length > 0) {\n    return query;\n  }\n\n  if (Array.isArray(concepts) && concepts.length > 0) {\n    return concepts.join(' ');\n  }\n\n  return '';\n}\n\n/**\n * Apply artifact routing weights to search results.\n * No-op if routing result is absent, unknown, or zero-confidence.\n */\nfunction applyArtifactRouting(results: SearchUtilRow[], routingResult?: RoutingResult): SearchUtilRow[] {\n  if (!Array.isArray(results) || results.length === 0) {\n    return results;\n  }\n\n  if (!routingResult || routingResult.detectedClass === 'unknown' || routingResult.confidence <= 0) {\n    return results;\n  }\n\n  return applyRoutingWeights(results as WeightedResult[], routingResult.strategy) as SearchUtilRow[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  resolveRowContextType,\n  filterByMinQualityScore,\n  resolveQualityThreshold,\n  resolveFusionIntentContract,\n  buildCacheArgs,\n  resolveArtifactRoutingQuery,\n  applyArtifactRouting,\n};\n\nexport type {\n  SearchUtilRow,\n  CacheArgsInput,\n};","lineStart":1,"lineEnd":266,"totalLines":266,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/search-utils.ts","time":{"start":1781762518796,"end":1781762518799}},"metadata":{"openai":{"itemId":"fc_09fea31d49f1b9f7016a3389d6a3548191afbe5d3207a5158d"}},"id":"prt_ed9526ef6001VGeH5cImXq7Zj6","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed951f9f50011nSEI60i9v7yun"}}
{"type":"tool_use","timestamp":1781762518977,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_b28qEPV4rOeWrISho9DwceV8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Orchestrator\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-stage pipeline execution with per-stage error handling and timeouts.\n5: //\n6: // Each stage is wrapped in try/catch with withTimeout().\n7: // Stage 1 is mandatory (throws on failure — no candidates = no results).\n8: // Stages 2-4 fall back to previous stage output with degraded metadata.\n9: // Timing is recorded for latency observability.\n10: //\n11: // I/O CONTRACT:\n12: // Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n13: // Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n14: // Key invariants:\n15: //     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n16: //     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n17: //     - Stage metadata for all four stages is included for observability\n18: //     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n19: // Side effects:\n20: //     - Delegates to each stage; see individual stage modules for their side effects\n21: \n22: import type {\n23:   PipelineConfig,\n24:   PipelineResult,\n25:   Stage1Output,\n26:   Stage2Output,\n27:   Stage3Output,\n28:   Stage4Output,\n29:   Stage4ReadonlyRow,\n30:   SignalStatus,\n31: } from './types.js';\n32: \n33: import { executeStage1 } from './stage1-candidate-gen.js';\n34: import { executeStage2 } from './stage2-fusion.js';\n35: import { executeStage3 } from './stage3-rerank.js';\n36: import { executeStage4 } from './stage4-filter.js';\n37: import { MemoryError, withTimeout } from '../../errors/core.js';\n38: \n39: // Feature catalog: 4-stage pipeline architecture\n40: // Feature catalog: 4-stage pipeline refactor\n41: \n42: \n43: /** Per-stage timeout in milliseconds. */\n44: const STAGE_TIMEOUT_MS = 10_000;\n45: \n46: /**\n47:  * Execute the 4-stage retrieval pipeline with per-stage error handling.\n48:  *\n49:  * Stage 1: Candidate Generation — MANDATORY (throws on failure)\n50:  * Stage 2: Fusion + Signal Integration — falls back to unsorted candidates\n51:  * Stage 3: Rerank + Aggregate — falls back to unranked scored results\n52:  * Stage 4: Filter + Annotate — falls back to unfiltered results\n53:  *\n54:  * @param config Pipeline configuration derived from search args\n55:  * @returns Pipeline result with stage metadata and timing\n56:  */\n57: export async function executePipeline(config: PipelineConfig): Promise<PipelineResult> {\n58:   const timing: Record<string, number> = {};\n59:   const pipelineStart = Date.now();\n60:   let degraded = false;\n61: \n62:   // -- Stage 1: Candidate Generation (MANDATORY — no fallback possible) --\n63:   let stage1Result: Stage1Output;\n64:   try {\n65:     const t0 = Date.now();\n66:     stage1Result = await withTimeout(\n67:       executeStage1({ config }),\n68:       STAGE_TIMEOUT_MS,\n69:       'Stage 1: Candidate Generation',\n70:     );\n71:     timing.stage1 = Date.now() - t0;\n72:   } catch (err) {\n73:     throw new MemoryError(\n74:       'PIPELINE_STAGE1_FAILED',\n75:       `Candidate generation failed: ${err instanceof Error ? err.message : String(err)}`,\n76:       { cause: err instanceof Error ? err.message : String(err) },\n77:     );\n78:   }\n79: \n80:   // -- Stage 2: Fusion + Signal Integration (falls back to unsorted candidates) --\n81:   let stage2Result: Stage2Output;\n82:   try {\n83:     const t0 = Date.now();\n84:     stage2Result = await withTimeout(\n85:       executeStage2({\n86:         candidates: stage1Result.candidates,\n87:         config,\n88:         stage1Metadata: stage1Result.metadata,\n89:       }),\n90:       STAGE_TIMEOUT_MS,\n91:       'Stage 2: Fusion',\n92:     );\n93:     timing.stage2 = Date.now() - t0;\n94:   } catch (err) {\n95:     const msg = err instanceof Error ? err.message : String(err);\n96:     console.warn(`[pipeline] Stage 2 failed, returning unscored candidates: ${msg}`);\n97:     degraded = true;\n98:     stage2Result = {\n99:       scored: stage1Result.candidates,\n100:       metadata: {\n101:         sessionBoostApplied: 'failed' as SignalStatus,\n102:         causalBoostApplied: 'failed' as SignalStatus,\n103:         intentWeightsApplied: 'failed' as SignalStatus,\n104:         artifactRoutingApplied: 'failed' as SignalStatus,\n105:         feedbackSignalsApplied: 'failed' as SignalStatus,\n106:         qualityFiltered: 0,\n107:         durationMs: 0,\n108:       },\n109:     };\n110:     timing.stage2 = 0;\n111:   }\n112: \n113:   // -- Stage 3: Rerank + Aggregate (falls back to unranked scored results) --\n114:   let stage3Result: Stage3Output;\n115:   try {\n116:     const t0 = Date.now();\n117:     stage3Result = await withTimeout(\n118:       executeStage3({\n119:         scored: stage2Result.scored,\n120:         config,\n121:       }),\n122:       STAGE_TIMEOUT_MS,\n123:       'Stage 3: Rerank',\n124:     );\n125:     timing.stage3 = Date.now() - t0;\n126:   } catch (err) {\n127:     const msg = err instanceof Error ? err.message : String(err);\n128:     console.warn(`[pipeline] Stage 3 failed, returning unranked results: ${msg}`);\n129:     degraded = true;\n130:     stage3Result = {\n131:       reranked: stage2Result.scored,\n132:       metadata: {\n133:         rerankApplied: false,\n134:         chunkReassemblyStats: {\n135:           collapsedChunkHits: 0,\n136:           chunkParents: 0,\n137:           reassembled: 0,\n138:           fallback: 0,\n139:         },\n140:         durationMs: 0,\n141:       },\n142:     };\n143:     timing.stage3 = 0;\n144:   }\n145: \n146:   // -- Stage 4: Filter + Annotate (falls back to unfiltered results) --\n147:   let stage4Result: Stage4Output;\n148:   try {\n149:     const t0 = Date.now();\n150:     stage4Result = await withTimeout(\n151:       executeStage4({\n152:         results: stage3Result.reranked as Stage4ReadonlyRow[],\n153:         config,\n154:         stage1Metadata: { constitutionalInjected: stage1Result.metadata.constitutionalInjected },\n155:       }),\n156:       STAGE_TIMEOUT_MS,\n157:       'Stage 4: Filter',\n158:     );\n159:     timing.stage4 = Date.now() - t0;\n160:   } catch (err) {\n161:     const msg = err instanceof Error ? err.message : String(err);\n162:     console.warn(`[pipeline] Stage 4 failed, returning unfiltered results: ${msg}`);\n163:     degraded = true;\n164:     stage4Result = {\n165:       final: stage3Result.reranked as Stage4ReadonlyRow[],\n166:       metadata: {\n167:         stateFiltered: 0,\n168:         constitutionalInjected: stage1Result.metadata.constitutionalInjected,\n169:         evidenceGapDetected: false,\n170:         durationMs: 0,\n171:       },\n172:       annotations: {\n173:         stateStats: {},\n174:         featureFlags: {},\n175:       },\n176:     };\n177:     timing.stage4 = 0;\n178:   }\n179: \n180:   timing.total = Date.now() - pipelineStart;\n181: \n182:   return {\n183:     results: stage4Result.final,\n184:     metadata: {\n185:       stage1: stage1Result.metadata,\n186:       stage2: stage2Result.metadata,\n187:       stage3: stage3Result.metadata,\n188:       stage4: stage4Result.metadata,\n189:       timing,\n190:       degraded: degraded || undefined,\n191:     },\n192:     annotations: stage4Result.annotations,\n193:     trace: config.trace,\n194:   };\n195: }\n\n(End of file - total 195 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Orchestrator\n// ───────────────────────────────────────────────────────────────\n// 4-stage pipeline execution with per-stage error handling and timeouts.\n//\n// Each stage is wrapped in try/catch with withTimeout().\n// Stage 1 is mandatory (throws on failure — no candidates = no results).\n// Stages 2-4 fall back to previous stage output with degraded metadata.\n// Timing is recorded for latency observability.\n//\n// I/O CONTRACT:\n// Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n// Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n// Key invariants:\n//     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n//     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n//     - Stage metadata for all four stages is included for observability\n//     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n// Side effects:\n//     - Delegates to each stage; see individual stage modules for their side effects","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Orchestrator\n// ───────────────────────────────────────────────────────────────\n// 4-stage pipeline execution with per-stage error handling and timeouts.\n//\n// Each stage is wrapped in try/catch with withTimeout().\n// Stage 1 is mandatory (throws on failure — no candidates = no results).\n// Stages 2-4 fall back to previous stage output with degraded metadata.\n// Timing is recorded for latency observability.\n//\n// I/O CONTRACT:\n// Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n// Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n// Key invariants:\n//     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n//     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n//     - Stage metadata for all four stages is included for observability\n//     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n// Side effects:\n//     - Delegates to each stage; see individual stage modules for their side effects\n\nimport type {\n  PipelineConfig,\n  PipelineResult,\n  Stage1Output,\n  Stage2Output,\n  Stage3Output,\n  Stage4Output,\n  Stage4ReadonlyRow,\n  SignalStatus,\n} from './types.js';\n\nimport { executeStage1 } from './stage1-candidate-gen.js';\nimport { executeStage2 } from './stage2-fusion.js';\nimport { executeStage3 } from './stage3-rerank.js';\nimport { executeStage4 } from './stage4-filter.js';\nimport { MemoryError, withTimeout } from '../../errors/core.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: 4-stage pipeline refactor\n\n\n/** Per-stage timeout in milliseconds. */\nconst STAGE_TIMEOUT_MS = 10_000;\n\n/**\n * Execute the 4-stage retrieval pipeline with per-stage error handling.\n *\n * Stage 1: Candidate Generation — MANDATORY (throws on failure)\n * Stage 2: Fusion + Signal Integration — falls back to unsorted candidates\n * Stage 3: Rerank + Aggregate — falls back to unranked scored results\n * Stage 4: Filter + Annotate — falls back to unfiltered results\n *\n * @param config Pipeline configuration derived from search args\n * @returns Pipeline result with stage metadata and timing\n */\nexport async function executePipeline(config: PipelineConfig): Promise<PipelineResult> {\n  const timing: Record<string, number> = {};\n  const pipelineStart = Date.now();\n  let degraded = false;\n\n  // -- Stage 1: Candidate Generation (MANDATORY — no fallback possible) --\n  let stage1Result: Stage1Output;\n  try {\n    const t0 = Date.now();\n    stage1Result = await withTimeout(\n      executeStage1({ config }),\n      STAGE_TIMEOUT_MS,\n      'Stage 1: Candidate Generation',\n    );\n    timing.stage1 = Date.now() - t0;\n  } catch (err) {\n    throw new MemoryError(\n      'PIPELINE_STAGE1_FAILED',\n      `Candidate generation failed: ${err instanceof Error ? err.message : String(err)}`,\n      { cause: err instanceof Error ? err.message : String(err) },\n    );\n  }\n\n  // -- Stage 2: Fusion + Signal Integration (falls back to unsorted candidates) --\n  let stage2Result: Stage2Output;\n  try {\n    const t0 = Date.now();\n    stage2Result = await withTimeout(\n      executeStage2({\n        candidates: stage1Result.candidates,\n        config,\n        stage1Metadata: stage1Result.metadata,\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 2: Fusion',\n    );\n    timing.stage2 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 2 failed, returning unscored candidates: ${msg}`);\n    degraded = true;\n    stage2Result = {\n      scored: stage1Result.candidates,\n      metadata: {\n        sessionBoostApplied: 'failed' as SignalStatus,\n        causalBoostApplied: 'failed' as SignalStatus,\n        intentWeightsApplied: 'failed' as SignalStatus,\n        artifactRoutingApplied: 'failed' as SignalStatus,\n        feedbackSignalsApplied: 'failed' as SignalStatus,\n        qualityFiltered: 0,\n        durationMs: 0,\n      },\n    };\n    timing.stage2 = 0;\n  }\n\n  // -- Stage 3: Rerank + Aggregate (falls back to unranked scored results) --\n  let stage3Result: Stage3Output;\n  try {\n    const t0 = Date.now();\n    stage3Result = await withTimeout(\n      executeStage3({\n        scored: stage2Result.scored,\n        config,\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 3: Rerank',\n    );\n    timing.stage3 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 3 failed, returning unranked results: ${msg}`);\n    degraded = true;\n    stage3Result = {\n      reranked: stage2Result.scored,\n      metadata: {\n        rerankApplied: false,\n        chunkReassemblyStats: {\n          collapsedChunkHits: 0,\n          chunkParents: 0,\n          reassembled: 0,\n          fallback: 0,\n        },\n        durationMs: 0,\n      },\n    };\n    timing.stage3 = 0;\n  }\n\n  // -- Stage 4: Filter + Annotate (falls back to unfiltered results) --\n  let stage4Result: Stage4Output;\n  try {\n    const t0 = Date.now();\n    stage4Result = await withTimeout(\n      executeStage4({\n        results: stage3Result.reranked as Stage4ReadonlyRow[],\n        config,\n        stage1Metadata: { constitutionalInjected: stage1Result.metadata.constitutionalInjected },\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 4: Filter',\n    );\n    timing.stage4 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 4 failed, returning unfiltered results: ${msg}`);\n    degraded = true;\n    stage4Result = {\n      final: stage3Result.reranked as Stage4ReadonlyRow[],\n      metadata: {\n        stateFiltered: 0,\n        constitutionalInjected: stage1Result.metadata.constitutionalInjected,\n        evidenceGapDetected: false,\n        durationMs: 0,\n      },\n      annotations: {\n        stateStats: {},\n        featureFlags: {},\n      },\n    };\n    timing.stage4 = 0;\n  }\n\n  timing.total = Date.now() - pipelineStart;\n\n  return {\n    results: stage4Result.final,\n    metadata: {\n      stage1: stage1Result.metadata,\n      stage2: stage2Result.metadata,\n      stage3: stage3Result.metadata,\n      stage4: stage4Result.metadata,\n      timing,\n      degraded: degraded || undefined,\n    },\n    annotations: stage4Result.annotations,\n    trace: config.trace,\n  };\n}","lineStart":1,"lineEnd":195,"totalLines":195,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","time":{"start":1781762518962,"end":1781762518971}},"metadata":{"openai":{"itemId":"fc_09fea31d49f1b9f7016a3389d6a35c81918816f79cc2c1d13c"}},"id":"prt_ed9526f35001lKMstyp8hsf2Ri","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed951f9f50011nSEI60i9v7yun"}}
{"type":"tool_use","timestamp":1781762518980,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_NDZOimmGSaEmr18pJ9svJ5Oc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Types\n3: // ───────────────────────────────────────────────────────────────\n4: // Stage interfaces with the Stage 4 immutability invariant\n5: import type { RetrievalTrace } from '@spec-kit/shared/contracts/retrieval-trace';\n6: import type { QueryPlan } from '../../query/query-plan.js';\n7: \n8: // Feature catalog: 4-stage pipeline architecture\n9: \n10: \n11: /**\n12:  * Memory search row — the canonical internal result type flowing through the pipeline.\n13:  * Extends Record<string, unknown> for backward compatibility with existing code.\n14:  */\n15: export interface PipelineRow extends Record<string, unknown> {\n16:   id: number;\n17:   similarity?: number;\n18:   score?: number;\n19:   importance_tier?: string;\n20:   contextType?: string;\n21:   context_type?: string;\n22:   attentionScore?: number;\n23:   retrievability?: number;\n24:   stability?: number;\n25:   last_review?: string | null;\n26:   created_at?: string;\n27:   last_accessed?: number;\n28:   content?: string;\n29:   memoryState?: string;\n30:   file_path?: string;\n31:   parent_id?: number | null;\n32:   chunk_index?: number | null;\n33:   chunk_label?: string | null;\n34:   isChunk?: boolean;\n35:   parentId?: number | null;\n36:   chunkIndex?: number | null;\n37:   chunkLabel?: string | null;\n38:   chunkCount?: number | null;\n39:   contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n40:   precomputedContent?: string;\n41:   quality_score?: number;\n42:   quality_flags?: string | string[] | null;\n43:   qualityFlags?: string | string[] | null;\n44:   importance_weight?: number;\n45:   rrfScore?: number;\n46:   intentAdjustedScore?: number;\n47:   /** Stage 2 composite score preserved for auditability when Stage 3 overwrites score */\n48:   stage2Score?: number;\n49:   /** Graph evidence provenance — edges and communities that contributed to graph-based boosts. */\n50:   graphEvidence?: {\n51:     edges: Array<{ sourceId: number; targetId: number; relation: string; strength: number }>;\n52:     communities: Array<{ communityId: number; summary?: string }>;\n53:     boostFactors: Array<{ type: string; delta: number }>;\n54:   };\n55: }\n56: \n57: /**\n58:  * Shared score resolution function — canonical fallback chain for deriving the\n59:  * \"best available score\" from a PipelineRow. Used by Stage 2, Stage 3, and any\n60:  * code needing a consistent effective score.\n61:  *\n62:  * Previously Stage 2 and Stage 3 had\n63:  * separate implementations with different fallback orders and clamping. This shared\n64:  * function uses the correct chain: intentAdjustedScore → rrfScore → score → similarity/100,\n65:  * all clamped to [0,1] with isFinite guards.\n66:  */\n67: export function resolveEffectiveScore(row: PipelineRow): number {\n68:   if (typeof row.intentAdjustedScore === 'number' && Number.isFinite(row.intentAdjustedScore))\n69:     return Math.max(0, Math.min(1, row.intentAdjustedScore));\n70:   if (typeof row.rrfScore === 'number' && Number.isFinite(row.rrfScore))\n71:     return Math.max(0, Math.min(1, row.rrfScore));\n72:   if (typeof row.score === 'number' && Number.isFinite(row.score))\n73:     return Math.max(0, Math.min(1, row.score));\n74:   if (typeof row.similarity === 'number' && Number.isFinite(row.similarity))\n75:     return Math.max(0, Math.min(1, row.similarity / 100));\n76:   return 0;\n77: }\n78: \n79: /**\n80:  * Absolute 0–1 relevance for confidence calibration and result-set digests —\n81:  * NOT for ordering. Prefers cosine similarity (an absolute relevance signal)\n82:  * over the RRF fusion score, whose magnitude (~0.01–0.05) is only meaningful as\n83:  * relative rank and badly understates relevance when read as an absolute 0–1\n84:  * quality. Feeding RRF magnitudes into 0.7/0.4-scaled thresholds makes \"good\"\n85:  * unreachable, so every hybrid query degrades to \"weak\"/\"gap\". Vector hits carry\n86:  * a real cosine; lexical-only hits (no similarity) fall back to the effective\n87:  * score, preserving their current behavior.\n88:  */\n89: export function resolveAbsoluteRelevance(row: PipelineRow): number {\n90:   if (typeof row.similarity === 'number' && Number.isFinite(row.similarity)) {\n91:     // sqlite-vec emits cosine on a 0–100 scale; normalize. Already-0–1 inputs pass through.\n92:     const normalized = row.similarity > 1 ? row.similarity / 100 : row.similarity;\n93:     return Math.max(0, Math.min(1, normalized));\n94:   }\n95:   return resolveEffectiveScore(row);\n96: }\n97: \n98: /**\n99:  * Stage 4 read-only row — compile-time enforcement that Stage 4 cannot modify scores.\n100:  * OQ-S5-001 CLOSED: Primary enforcement via TypeScript read-only type guards.\n101:  * All score-related fields are Readonly to prevent mutation in Stage 4.\n102:  */\n103: export interface Stage4ReadonlyRow extends Readonly<Pick<PipelineRow,\n104:   'similarity' | 'score' | 'importance_weight' | 'rrfScore' | 'intentAdjustedScore' | 'attentionScore'\n105: >> {\n106:   readonly id: number;\n107:   // Non-score fields remain mutable for annotation purposes\n108:   importance_tier?: string;\n109:   contextType?: string;\n110:   context_type?: string;\n111:   retrievability?: number;\n112:   stability?: number;\n113:   last_review?: string | null;\n114:   created_at?: string;\n115:   last_accessed?: number;\n116:   content?: string;\n117:   memoryState?: string;\n118:   file_path?: string;\n119:   parent_id?: number | null;\n120:   chunk_index?: number | null;\n121:   chunk_label?: string | null;\n122:   isChunk?: boolean;\n123:   parentId?: number | null;\n124:   chunkIndex?: number | null;\n125:   chunkLabel?: string | null;\n126:   chunkCount?: number | null;\n127:   contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n128:   precomputedContent?: string;\n129:   quality_score?: number;\n130:   // Annotation fields (Stage 4 may add these)\n131:   channelAttribution?: string[];\n132:   evidenceGap?: { gapDetected: boolean; warning?: string };\n133: }\n134: \n135: // -- Pipeline Configuration --\n136: \n137: /**\n138:  * Normalized configuration consumed by the four-stage retrieval pipeline.\n139:  */\n140: export interface PipelineConfig {\n141:   query: string;\n142:   queryEmbedding?: Float32Array;\n143:   concepts?: string[];\n144:   searchType: 'hybrid' | 'vector' | 'multi-concept';\n145:   mode?: string;\n146: \n147:   // Limits and filtering\n148:   limit: number;\n149:   specFolder?: string;\n150:   tenantId?: string;\n151:   userId?: string;\n152:   agentId?: string;\n153:   tier?: string;\n154:   contextType?: string;\n155:   includeArchived: boolean;\n156:   includeConstitutional: boolean;\n157:   includeContent: boolean;\n158:   anchors?: string[];\n159:   qualityThreshold?: number;\n160: \n161:   // Scoring configuration\n162:   minState: string;\n163:   applyStateLimits: boolean;\n164:   useDecay: boolean;\n165:   rerank: boolean;\n166:   applyLengthPenalty: boolean;\n167: \n168:   // Session and boost\n169:   sessionId?: string;\n170:   enableDedup: boolean;\n171:   enableSessionBoost: boolean;\n172:   enableCausalBoost: boolean;\n173:   trackAccess: boolean;\n174: \n175:   // Intent\n176:   detectedIntent: string | null;\n177:   adaptiveFusionIntent?: string | null;\n178:   intentConfidence: number;\n179:   intentWeights: IntentWeightsConfig | null;\n180: \n181:   // Routing\n182:   artifactRouting?: ArtifactRoutingConfig;\n183:   queryPlan?: QueryPlan;\n184: \n185:   // Trace\n186:   trace?: RetrievalTrace;\n187: }\n188: \n189: /**\n190:  * Intent-aware weighting factors applied during fusion.\n191:  */\n192: export interface IntentWeightsConfig {\n193:   similarity: number;\n194:   importance: number;\n195:   recency: number;\n196: }\n197: \n198: /**\n199:  * Artifact-class routing decision passed into the pipeline.\n200:  */\n201: export interface ArtifactRoutingConfig {\n202:   detectedClass: string;\n203:   confidence: number;\n204:   strategy: {\n205:     maxResults: number;\n206:     [key: string]: unknown;\n207:   };\n208: }\n209: \n210: // -- Stage Interfaces --\n211: \n212: /**\n213:  * Stage 1: Candidate Generation\n214:  * Executes search channels (FTS5, semantic, trigger, graph, co-activation)\n215:  * and collects raw results. No scoring modifications.\n216:  */\n217: export interface Stage1Input {\n218:   config: PipelineConfig;\n219: }\n220: \n221: /**\n222:  * Stage 1 output containing candidate rows and generation metadata.\n223:  */\n224: export interface Stage1Output {\n225:   candidates: PipelineRow[];\n226:   metadata: {\n227:     searchType: string;\n228:     channelCount: number;\n229:     /** Actual retrieval channels active (vector=1, hybrid=2). Unlike channelCount which tracks query variants. */\n230:     activeChannels?: number;\n231:     candidateCount: number;\n232:     constitutionalInjected: number;\n233:     durationMs: number;\n234:   };\n235: }\n236: \n237: /**\n238:  * Tri-state for signal application metadata.\n239:  * Replaces boolean flags so callers can distinguish \"feature disabled\n240:  * by config\" ('off') from \"feature crashed\" ('failed') from \"feature applied\n241:  * successfully\" ('applied').\n242:  */\n243: export type SignalStatus = 'off' | 'applied' | 'enabled' | 'failed';\n244: \n245: /**\n246:  * Stage 2: Fusion + Signal Integration\n247:  * Single point for ALL scoring signals: RRF/RSF, causal boost, co-activation,\n248:  * composite, intent weights (applied ONCE — prevents G2 recurrence).\n249:  * Score changes: YES\n250:  */\n251: export interface Stage2Input {\n252:   candidates: PipelineRow[];\n253:   config: PipelineConfig;\n254:   stage1Metadata: Stage1Output['metadata'];\n255: }\n256: \n257: /**\n258:  * Stage 2 output containing scored rows and fusion metadata.\n259:  */\n260: export interface Stage2Output {\n261:   scored: PipelineRow[];\n262:   metadata: {\n263:     sessionBoostApplied: SignalStatus;\n264:     causalBoostApplied: SignalStatus;\n265:     intentWeightsApplied: SignalStatus;\n266:     artifactRoutingApplied: SignalStatus;\n267:     feedbackSignalsApplied: SignalStatus;\n268:     graphContribution?: {\n269:       killSwitchActive: boolean;\n270:       causalBoosted: number;\n271:       coActivationBoosted: number;\n272:       communityInjected: number;\n273:       graphSignalsBoosted: number;\n274:       totalGraphInjected: number;\n275:       rolloutState?: 'off' | 'trace_only' | 'bounded_runtime';\n276:     };\n277:     qualityFiltered: number;\n278:     durationMs: number;\n279:   };\n280: }\n281: \n282: /**\n283:  * Stage 3: Rerank + Aggregate\n284:  * Cross-encoder reranking, MMR diversity enforcement, MPAB chunk-to-memory aggregation.\n285:  * Score changes: YES\n286:  */\n287: export interface Stage3Input {\n288:   scored: PipelineRow[];\n289:   config: PipelineConfig;\n290: }\n291: \n292: /**\n293:  * Stage 3 output containing reranked rows and reranking metadata.\n294:  */\n295: export interface Stage3Output {\n296:   reranked: PipelineRow[];\n297:   metadata: {\n298:     rerankApplied: boolean;\n299:     rerankProvider?: string;\n300:     chunkReassemblyStats: {\n301:       collapsedChunkHits: number;\n302:       chunkParents: number;\n303:       reassembled: number;\n304:       fallback: number;\n305:     };\n306:     durationMs: number;\n307:   };\n308: }\n309: \n310: /**\n311:  * Stage 4: Filter + Annotate\n312:  * State filtering, session dedup, constitutional injection, channel attribution.\n313:  * Score changes: **NO** — Architectural invariant.\n314:  *\n315:  * Runtime assertion: scores at entry must equal scores at exit.\n316:  * Compile-time enforcement: input type uses Stage4ReadonlyRow with readonly score fields.\n317:  */\n318: export interface Stage4Input {\n319:   /** Results with read-only score fields — Stage 4 cannot modify scores */\n320:   results: Stage4ReadonlyRow[];\n321:   config: PipelineConfig;\n322:   /** Stage 1 metadata passed through for constitutional count */\n323:   stage1Metadata?: { constitutionalInjected?: number };\n324: }\n325: \n326: /**\n327:  * Stage 4 output containing final rows, filter metadata, and annotations.\n328:  */\n329: export interface Stage4Output {\n330:   final: Stage4ReadonlyRow[];\n331:   metadata: {\n332:     stateFiltered: number;\n333:     constitutionalInjected: number;\n334:     evidenceGapDetected: boolean;\n335:     durationMs: number;\n336:   };\n337:   annotations: {\n338:     evidenceGapWarning?: string;\n339:     stateStats: Record<string, unknown>;\n340:     featureFlags: Record<string, boolean>;\n341:   };\n342: }\n343: \n344: // -- Pipeline Result --\n345: \n346: /**\n347:  * Final pipeline response returned to retrieval callers.\n348:  */\n349: export interface PipelineResult {\n350:   results: Stage4ReadonlyRow[];\n351:   metadata: {\n352:     stage1: Stage1Output['metadata'];\n353:     stage2: Stage2Output['metadata'];\n354:     stage3: Stage3Output['metadata'];\n355:     stage4: Stage4Output['metadata'];\n356:     /** Per-stage and total timing in milliseconds for latency observability. */\n357:     timing?: Record<string, number>;\n358:     /** True when one or more stages fell back to degraded output. */\n359:     degraded?: boolean;\n360:   };\n361:   annotations: Stage4Output['annotations'];\n362:   trace?: RetrievalTrace;\n363: }\n364: \n365: // -- Stage Function Types --\n366: \n367: /**\n368:  * Executor signature for Stage 1 candidate generation.\n369:  */\n370: export type Stage1Fn = (input: Stage1Input) => Promise<Stage1Output>;\n371: /**\n372:  * Executor signature for Stage 2 fusion and signal integration.\n373:  */\n374: export type Stage2Fn = (input: Stage2Input) => Promise<Stage2Output>;\n375: /**\n376:  * Executor signature for Stage 3 reranking and aggregation.\n377:  */\n378: export type Stage3Fn = (input: Stage3Input) => Promise<Stage3Output>;\n379: /**\n380:  * Executor signature for Stage 4 filtering and annotation.\n381:  */\n382: export type Stage4Fn = (input: Stage4Input) => Promise<Stage4Output>;\n383: \n384: // -- Score Snapshot Utility (Runtime assertion for Stage 4 invariant) --\n385: \n386: /**\n387:  * Captures score values from results for invariant checking.\n388:  * Used to verify Stage 4 does not modify any scores.\n389:  */\n390: export interface ScoreSnapshot {\n391:   id: number;\n392:   similarity?: number;\n393:   score?: number;\n394:   importance_weight?: number;\n395:   rrfScore?: number;\n396:   intentAdjustedScore?: number;\n397:   attentionScore?: number;\n398: }\n399: \n400: /**\n401:  * Take a snapshot of score fields for later invariant verification.\n402:  */\n403: export function captureScoreSnapshot(results: Stage4ReadonlyRow[]): ScoreSnapshot[] {\n404:   return results.map(r => ({\n405:     id: r.id,\n406:     similarity: r.similarity,\n407:     score: r.score,\n408:     importance_weight: r.importance_weight,\n409:     rrfScore: r.rrfScore,\n410:     intentAdjustedScore: r.intentAdjustedScore,\n411:     attentionScore: r.attentionScore,\n412:   }));\n413: }\n414: \n415: /**\n416:  * Verify Stage 4 invariant: no score fields were modified.\n417:  * Throws if any score differs between before and after snapshots.\n418:  */\n419: export function verifyScoreInvariant(\n420:   before: ScoreSnapshot[],\n421:   after: Stage4ReadonlyRow[]\n422: ): void {\n423:   if (before.length !== after.length) {\n424:     // Length changes are allowed (filtering removes items), but we verify retained items\n425:   }\n426: \n427:   const afterMap = new Map(after.map(r => [r.id, r]));\n428: \n429:   for (const snap of before) {\n430:     const row = afterMap.get(snap.id);\n431:     if (!row) continue; // Filtered out — OK\n432: \n433:     if (row.similarity !== snap.similarity) {\n434:       throw new Error(\n435:         `[Stage4Invariant] Score mutation detected: id=${snap.id} similarity changed from ${snap.similarity} to ${row.similarity}`\n436:       );\n437:     }\n438:     if (row.score !== snap.score) {\n439:       throw new Error(\n440:         `[Stage4Invariant] Score mutation detected: id=${snap.id} score changed from ${snap.score} to ${row.score}`\n441:       );\n442:     }\n443:     if (row.rrfScore !== snap.rrfScore) {\n444:       throw new Error(\n445:         `[Stage4Invariant] Score mutation detected: id=${snap.id} rrfScore changed from ${snap.rrfScore} to ${row.rrfScore}`\n446:       );\n447:     }\n448:     if (row.intentAdjustedScore !== snap.intentAdjustedScore) {\n449:       throw new Error(\n450:         `[Stage4Invariant] Score mutation detected: id=${snap.id} intentAdjustedScore changed from ${snap.intentAdjustedScore} to ${row.intentAdjustedScore}`\n451:       );\n452:     }\n453:     if (row.importance_weight !== snap.importance_weight) {\n454:       throw new Error(\n455:         `[Stage4Invariant] Score mutation detected: id=${snap.id} importance_weight changed from ${snap.importance_weight} to ${row.importance_weight}`\n456:       );\n457:     }\n458:     if (row.attentionScore !== snap.attentionScore) {\n459:       throw new Error(\n460:         `[Stage4Invariant] Score mutation detected: id=${snap.id} attentionScore changed from ${snap.attentionScore} to ${row.attentionScore}`\n461:       );\n462:     }\n463:   }\n464: }\n\n(End of file - total 464 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Types\n// ───────────────────────────────────────────────────────────────\n// Stage interfaces with the Stage 4 immutability invariant\nimport type { RetrievalTrace } from '@spec-kit/shared/contracts/retrieval-trace';\nimport type { QueryPlan } from '../../query/query-plan.js';\n\n// Feature catalog: 4-stage pipeline architecture\n\n\n/**\n * Memory search row — the canonical internal result type flowing through the pipeline.\n * Extends Record<string, unknown> for backward compatibility with existing code.\n */\nexport interface PipelineRow extends Record<string, unknown> {\n  id: number;\n  similarity?: number;\n  score?: number;\n  importance_tier?: string;\n  contextType?: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Types\n// ───────────────────────────────────────────────────────────────\n// Stage interfaces with the Stage 4 immutability invariant\nimport type { RetrievalTrace } from '@spec-kit/shared/contracts/retrieval-trace';\nimport type { QueryPlan } from '../../query/query-plan.js';\n\n// Feature catalog: 4-stage pipeline architecture\n\n\n/**\n * Memory search row — the canonical internal result type flowing through the pipeline.\n * Extends Record<string, unknown> for backward compatibility with existing code.\n */\nexport interface PipelineRow extends Record<string, unknown> {\n  id: number;\n  similarity?: number;\n  score?: number;\n  importance_tier?: string;\n  contextType?: string;\n  context_type?: string;\n  attentionScore?: number;\n  retrievability?: number;\n  stability?: number;\n  last_review?: string | null;\n  created_at?: string;\n  last_accessed?: number;\n  content?: string;\n  memoryState?: string;\n  file_path?: string;\n  parent_id?: number | null;\n  chunk_index?: number | null;\n  chunk_label?: string | null;\n  isChunk?: boolean;\n  parentId?: number | null;\n  chunkIndex?: number | null;\n  chunkLabel?: string | null;\n  chunkCount?: number | null;\n  contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n  precomputedContent?: string;\n  quality_score?: number;\n  quality_flags?: string | string[] | null;\n  qualityFlags?: string | string[] | null;\n  importance_weight?: number;\n  rrfScore?: number;\n  intentAdjustedScore?: number;\n  /** Stage 2 composite score preserved for auditability when Stage 3 overwrites score */\n  stage2Score?: number;\n  /** Graph evidence provenance — edges and communities that contributed to graph-based boosts. */\n  graphEvidence?: {\n    edges: Array<{ sourceId: number; targetId: number; relation: string; strength: number }>;\n    communities: Array<{ communityId: number; summary?: string }>;\n    boostFactors: Array<{ type: string; delta: number }>;\n  };\n}\n\n/**\n * Shared score resolution function — canonical fallback chain for deriving the\n * \"best available score\" from a PipelineRow. Used by Stage 2, Stage 3, and any\n * code needing a consistent effective score.\n *\n * Previously Stage 2 and Stage 3 had\n * separate implementations with different fallback orders and clamping. This shared\n * function uses the correct chain: intentAdjustedScore → rrfScore → score → similarity/100,\n * all clamped to [0,1] with isFinite guards.\n */\nexport function resolveEffectiveScore(row: PipelineRow): number {\n  if (typeof row.intentAdjustedScore === 'number' && Number.isFinite(row.intentAdjustedScore))\n    return Math.max(0, Math.min(1, row.intentAdjustedScore));\n  if (typeof row.rrfScore === 'number' && Number.isFinite(row.rrfScore))\n    return Math.max(0, Math.min(1, row.rrfScore));\n  if (typeof row.score === 'number' && Number.isFinite(row.score))\n    return Math.max(0, Math.min(1, row.score));\n  if (typeof row.similarity === 'number' && Number.isFinite(row.similarity))\n    return Math.max(0, Math.min(1, row.similarity / 100));\n  return 0;\n}\n\n/**\n * Absolute 0–1 relevance for confidence calibration and result-set digests —\n * NOT for ordering. Prefers cosine similarity (an absolute relevance signal)\n * over the RRF fusion score, whose magnitude (~0.01–0.05) is only meaningful as\n * relative rank and badly understates relevance when read as an absolute 0–1\n * quality. Feeding RRF magnitudes into 0.7/0.4-scaled thresholds makes \"good\"\n * unreachable, so every hybrid query degrades to \"weak\"/\"gap\". Vector hits carry\n * a real cosine; lexical-only hits (no similarity) fall back to the effective\n * score, preserving their current behavior.\n */\nexport function resolveAbsoluteRelevance(row: PipelineRow): number {\n  if (typeof row.similarity === 'number' && Number.isFinite(row.similarity)) {\n    // sqlite-vec emits cosine on a 0–100 scale; normalize. Already-0–1 inputs pass through.\n    const normalized = row.similarity > 1 ? row.similarity / 100 : row.similarity;\n    return Math.max(0, Math.min(1, normalized));\n  }\n  return resolveEffectiveScore(row);\n}\n\n/**\n * Stage 4 read-only row — compile-time enforcement that Stage 4 cannot modify scores.\n * OQ-S5-001 CLOSED: Primary enforcement via TypeScript read-only type guards.\n * All score-related fields are Readonly to prevent mutation in Stage 4.\n */\nexport interface Stage4ReadonlyRow extends Readonly<Pick<PipelineRow,\n  'similarity' | 'score' | 'importance_weight' | 'rrfScore' | 'intentAdjustedScore' | 'attentionScore'\n>> {\n  readonly id: number;\n  // Non-score fields remain mutable for annotation purposes\n  importance_tier?: string;\n  contextType?: string;\n  context_type?: string;\n  retrievability?: number;\n  stability?: number;\n  last_review?: string | null;\n  created_at?: string;\n  last_accessed?: number;\n  content?: string;\n  memoryState?: string;\n  file_path?: string;\n  parent_id?: number | null;\n  chunk_index?: number | null;\n  chunk_label?: string | null;\n  isChunk?: boolean;\n  parentId?: number | null;\n  chunkIndex?: number | null;\n  chunkLabel?: string | null;\n  chunkCount?: number | null;\n  contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n  precomputedContent?: string;\n  quality_score?: number;\n  // Annotation fields (Stage 4 may add these)\n  channelAttribution?: string[];\n  evidenceGap?: { gapDetected: boolean; warning?: string };\n}\n\n// -- Pipeline Configuration --\n\n/**\n * Normalized configuration consumed by the four-stage retrieval pipeline.\n */\nexport interface PipelineConfig {\n  query: string;\n  queryEmbedding?: Float32Array;\n  concepts?: string[];\n  searchType: 'hybrid' | 'vector' | 'multi-concept';\n  mode?: string;\n\n  // Limits and filtering\n  limit: number;\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  tier?: string;\n  contextType?: string;\n  includeArchived: boolean;\n  includeConstitutional: boolean;\n  includeContent: boolean;\n  anchors?: string[];\n  qualityThreshold?: number;\n\n  // Scoring configuration\n  minState: string;\n  applyStateLimits: boolean;\n  useDecay: boolean;\n  rerank: boolean;\n  applyLengthPenalty: boolean;\n\n  // Session and boost\n  sessionId?: string;\n  enableDedup: boolean;\n  enableSessionBoost: boolean;\n  enableCausalBoost: boolean;\n  trackAccess: boolean;\n\n  // Intent\n  detectedIntent: string | null;\n  adaptiveFusionIntent?: string | null;\n  intentConfidence: number;\n  intentWeights: IntentWeightsConfig | null;\n\n  // Routing\n  artifactRouting?: ArtifactRoutingConfig;\n  queryPlan?: QueryPlan;\n\n  // Trace\n  trace?: RetrievalTrace;\n}\n\n/**\n * Intent-aware weighting factors applied during fusion.\n */\nexport interface IntentWeightsConfig {\n  similarity: number;\n  importance: number;\n  recency: number;\n}\n\n/**\n * Artifact-class routing decision passed into the pipeline.\n */\nexport interface ArtifactRoutingConfig {\n  detectedClass: string;\n  confidence: number;\n  strategy: {\n    maxResults: number;\n    [key: string]: unknown;\n  };\n}\n\n// -- Stage Interfaces --\n\n/**\n * Stage 1: Candidate Generation\n * Executes search channels (FTS5, semantic, trigger, graph, co-activation)\n * and collects raw results. No scoring modifications.\n */\nexport interface Stage1Input {\n  config: PipelineConfig;\n}\n\n/**\n * Stage 1 output containing candidate rows and generation metadata.\n */\nexport interface Stage1Output {\n  candidates: PipelineRow[];\n  metadata: {\n    searchType: string;\n    channelCount: number;\n    /** Actual retrieval channels active (vector=1, hybrid=2). Unlike channelCount which tracks query variants. */\n    activeChannels?: number;\n    candidateCount: number;\n    constitutionalInjected: number;\n    durationMs: number;\n  };\n}\n\n/**\n * Tri-state for signal application metadata.\n * Replaces boolean flags so callers can distinguish \"feature disabled\n * by config\" ('off') from \"feature crashed\" ('failed') from \"feature applied\n * successfully\" ('applied').\n */\nexport type SignalStatus = 'off' | 'applied' | 'enabled' | 'failed';\n\n/**\n * Stage 2: Fusion + Signal Integration\n * Single point for ALL scoring signals: RRF/RSF, causal boost, co-activation,\n * composite, intent weights (applied ONCE — prevents G2 recurrence).\n * Score changes: YES\n */\nexport interface Stage2Input {\n  candidates: PipelineRow[];\n  config: PipelineConfig;\n  stage1Metadata: Stage1Output['metadata'];\n}\n\n/**\n * Stage 2 output containing scored rows and fusion metadata.\n */\nexport interface Stage2Output {\n  scored: PipelineRow[];\n  metadata: {\n    sessionBoostApplied: SignalStatus;\n    causalBoostApplied: SignalStatus;\n    intentWeightsApplied: SignalStatus;\n    artifactRoutingApplied: SignalStatus;\n    feedbackSignalsApplied: SignalStatus;\n    graphContribution?: {\n      killSwitchActive: boolean;\n      causalBoosted: number;\n      coActivationBoosted: number;\n      communityInjected: number;\n      graphSignalsBoosted: number;\n      totalGraphInjected: number;\n      rolloutState?: 'off' | 'trace_only' | 'bounded_runtime';\n    };\n    qualityFiltered: number;\n    durationMs: number;\n  };\n}\n\n/**\n * Stage 3: Rerank + Aggregate\n * Cross-encoder reranking, MMR diversity enforcement, MPAB chunk-to-memory aggregation.\n * Score changes: YES\n */\nexport interface Stage3Input {\n  scored: PipelineRow[];\n  config: PipelineConfig;\n}\n\n/**\n * Stage 3 output containing reranked rows and reranking metadata.\n */\nexport interface Stage3Output {\n  reranked: PipelineRow[];\n  metadata: {\n    rerankApplied: boolean;\n    rerankProvider?: string;\n    chunkReassemblyStats: {\n      collapsedChunkHits: number;\n      chunkParents: number;\n      reassembled: number;\n      fallback: number;\n    };\n    durationMs: number;\n  };\n}\n\n/**\n * Stage 4: Filter + Annotate\n * State filtering, session dedup, constitutional injection, channel attribution.\n * Score changes: **NO** — Architectural invariant.\n *\n * Runtime assertion: scores at entry must equal scores at exit.\n * Compile-time enforcement: input type uses Stage4ReadonlyRow with readonly score fields.\n */\nexport interface Stage4Input {\n  /** Results with read-only score fields — Stage 4 cannot modify scores */\n  results: Stage4ReadonlyRow[];\n  config: PipelineConfig;\n  /** Stage 1 metadata passed through for constitutional count */\n  stage1Metadata?: { constitutionalInjected?: number };\n}\n\n/**\n * Stage 4 output containing final rows, filter metadata, and annotations.\n */\nexport interface Stage4Output {\n  final: Stage4ReadonlyRow[];\n  metadata: {\n    stateFiltered: number;\n    constitutionalInjected: number;\n    evidenceGapDetected: boolean;\n    durationMs: number;\n  };\n  annotations: {\n    evidenceGapWarning?: string;\n    stateStats: Record<string, unknown>;\n    featureFlags: Record<string, boolean>;\n  };\n}\n\n// -- Pipeline Result --\n\n/**\n * Final pipeline response returned to retrieval callers.\n */\nexport interface PipelineResult {\n  results: Stage4ReadonlyRow[];\n  metadata: {\n    stage1: Stage1Output['metadata'];\n    stage2: Stage2Output['metadata'];\n    stage3: Stage3Output['metadata'];\n    stage4: Stage4Output['metadata'];\n    /** Per-stage and total timing in milliseconds for latency observability. */\n    timing?: Record<string, number>;\n    /** True when one or more stages fell back to degraded output. */\n    degraded?: boolean;\n  };\n  annotations: Stage4Output['annotations'];\n  trace?: RetrievalTrace;\n}\n\n// -- Stage Function Types --\n\n/**\n * Executor signature for Stage 1 candidate generation.\n */\nexport type Stage1Fn = (input: Stage1Input) => Promise<Stage1Output>;\n/**\n * Executor signature for Stage 2 fusion and signal integration.\n */\nexport type Stage2Fn = (input: Stage2Input) => Promise<Stage2Output>;\n/**\n * Executor signature for Stage 3 reranking and aggregation.\n */\nexport type Stage3Fn = (input: Stage3Input) => Promise<Stage3Output>;\n/**\n * Executor signature for Stage 4 filtering and annotation.\n */\nexport type Stage4Fn = (input: Stage4Input) => Promise<Stage4Output>;\n\n// -- Score Snapshot Utility (Runtime assertion for Stage 4 invariant) --\n\n/**\n * Captures score values from results for invariant checking.\n * Used to verify Stage 4 does not modify any scores.\n */\nexport interface ScoreSnapshot {\n  id: number;\n  similarity?: number;\n  score?: number;\n  importance_weight?: number;\n  rrfScore?: number;\n  intentAdjustedScore?: number;\n  attentionScore?: number;\n}\n\n/**\n * Take a snapshot of score fields for later invariant verification.\n */\nexport function captureScoreSnapshot(results: Stage4ReadonlyRow[]): ScoreSnapshot[] {\n  return results.map(r => ({\n    id: r.id,\n    similarity: r.similarity,\n    score: r.score,\n    importance_weight: r.importance_weight,\n    rrfScore: r.rrfScore,\n    intentAdjustedScore: r.intentAdjustedScore,\n    attentionScore: r.attentionScore,\n  }));\n}\n\n/**\n * Verify Stage 4 invariant: no score fields were modified.\n * Throws if any score differs between before and after snapshots.\n */\nexport function verifyScoreInvariant(\n  before: ScoreSnapshot[],\n  after: Stage4ReadonlyRow[]\n): void {\n  if (before.length !== after.length) {\n    // Length changes are allowed (filtering removes items), but we verify retained items\n  }\n\n  const afterMap = new Map(after.map(r => [r.id, r]));\n\n  for (const snap of before) {\n    const row = afterMap.get(snap.id);\n    if (!row) continue; // Filtered out — OK\n\n    if (row.similarity !== snap.similarity) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} similarity changed from ${snap.similarity} to ${row.similarity}`\n      );\n    }\n    if (row.score !== snap.score) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} score changed from ${snap.score} to ${row.score}`\n      );\n    }\n    if (row.rrfScore !== snap.rrfScore) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} rrfScore changed from ${snap.rrfScore} to ${row.rrfScore}`\n      );\n    }\n    if (row.intentAdjustedScore !== snap.intentAdjustedScore) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} intentAdjustedScore changed from ${snap.intentAdjustedScore} to ${row.intentAdjustedScore}`\n      );\n    }\n    if (row.importance_weight !== snap.importance_weight) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} importance_weight changed from ${snap.importance_weight} to ${row.importance_weight}`\n      );\n    }\n    if (row.attentionScore !== snap.attentionScore) {\n      throw new Error(\n        `[Stage4Invariant] Score mutation detected: id=${snap.id} attentionScore changed from ${snap.attentionScore} to ${row.attentionScore}`\n      );\n    }\n  }\n}","lineStart":1,"lineEnd":464,"totalLines":464,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","time":{"start":1781762518974,"end":1781762518979}},"metadata":{"openai":{"itemId":"fc_09fea31d49f1b9f7016a3389d6a3608191a395f31574623da6"}},"id":"prt_ed9526fb60015GdOwNy3kSSRYu","sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","messageID":"msg_ed951f9f50011nSEI60i9v7yun"}}
{"type":"tool_use","timestamp":1781762519010,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_TIZ0o9GZ0j8NFLionPcQNaZF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","offset":1380,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts</path>\n<type>file</type>\n<content>\n1380:         extraData.adaptive_shadow = adaptiveShadow;\n1381:       }\n1382:     } catch (_error: unknown) {\n1383:       // Adaptive proposal logging is best-effort only\n1384:     }\n1385: \n1386:     const appliedBoosts: Record<string, unknown> = {\n1387:       session: { applied: pipelineResult.metadata.stage2.sessionBoostApplied },\n1388:       causal: { applied: pipelineResult.metadata.stage2.causalBoostApplied },\n1389:     };\n1390:     if (folderBoost && folderBoost.folder) {\n1391:       appliedBoosts.folder = { applied: true, folder: folderBoost.folder, factor: folderBoost.factor };\n1392:     }\n1393:     if (communityFallbackApplied) {\n1394:       appliedBoosts.communityFallback = { applied: true, retrievalLevel };\n1395:     }\n1396:     extraData.appliedBoosts = appliedBoosts;\n1397:     extraData.applied_boosts = appliedBoosts;\n1398: \n1399:     let formatted = await formatSearchResults(\n1400:       resultsForFormatting as RawSearchResult[],\n1401:       pipelineConfig.searchType,\n1402:       includeContent,\n1403:       anchors,\n1404:       null,\n1405:       null,\n1406:       extraData,\n1407:       includeTrace,\n1408:       normalizedQuery,   // pass query for recovery + confidence context\n1409:       specFolder ?? null // pass specFolder for recovery narrowing detection\n1410:     );\n1411: \n1412:     // Prepend evidence gap warning if present\n1413:     if (pipelineResult.annotations.evidenceGapWarning && formatted?.content?.[0]?.text) {\n1414:       try {\n1415:         const parsed = JSON.parse(formatted.content[0].text) as Record<string, unknown>;\n1416:         if (typeof parsed.summary === 'string') {\n1417:           parsed.summary = `${pipelineResult.annotations.evidenceGapWarning}\\n\\n${parsed.summary}`;\n1418:           formatted.content[0].text = JSON.stringify(parsed, null, 2);\n1419:         }\n1420:       } catch (_error: unknown) {\n1421:         // Non-fatal\n1422:       }\n1423:     }\n1424:     if (isProgressiveDisclosureEnabled()) {\n1425:       const parsedFormatted = parseResponseEnvelope(formatted);\n1426:       if (parsedFormatted) {\n1427:         const data = parsedFormatted.envelope.data && typeof parsedFormatted.envelope.data === 'object'\n1428:           ? parsedFormatted.envelope.data as Record<string, unknown>\n1429:           : {};\n1430:         data.progressiveDisclosure = buildProgressiveResponse(\n1431:           resultsForFormatting,\n1432:           undefined,\n1433:           effectiveQuery,\n1434:           { scopeKey: progressiveScopeKey },\n1435:         );\n1436:         parsedFormatted.envelope.data = data;\n1437:         formatted = replaceResponseEnvelope(formatted, parsedFormatted.firstEntry, parsedFormatted.envelope);\n1438:       }\n1439:     }\n1440: \n1441:     formatted = applyPublicationGateToResponse(formatted);\n1442: \n1443:     const cachePayload = extractSearchCachePayload(formatted);\n1444:     if (cachePayload && cacheEnabled) {\n1445:       toolCache.set(cacheKey, cachePayload, { toolName: 'memory_search' });\n1446:     }\n1447: \n1448:     responseToReturn = cachePayload\n1449:       ? buildSearchResponseFromPayload(cachePayload, _searchStartTime, false)\n1450:       : formatted;\n1451:   }\n1452: \n1453:   responseToReturn = applyPublicationGateToResponse(responseToReturn);\n1454: \n1455:   if (sessionId && isSessionRetrievalStateEnabled() && !sessionManager.isEnabled()) {\n1456:     const parsedResponse = parseResponseEnvelope(responseToReturn);\n1457:     const data = parsedResponse?.envelope.data && typeof parsedResponse.envelope.data === 'object'\n1458:       ? parsedResponse.envelope.data as Record<string, unknown>\n1459:       : null;\n1460:     const existingResults = Array.isArray(data?.results) ? data.results as SessionAwareResult[] : null;\n1461: \n1462:     if (parsedResponse && data && existingResults && existingResults.length > 0) {\n1463:       const deduped = deduplicateWithSessionState(existingResults, sessionId);\n1464:       reconcilePostFormatResultSet(data, deduped.results as Array<Record<string, unknown>>);\n1465:       data.sessionDedup = deduped.metadata;\n1466:       parsedResponse.envelope.data = data;\n1467:       responseToReturn = replaceResponseEnvelope(responseToReturn, parsedResponse.firstEntry, parsedResponse.envelope);\n1468:     }\n1469:   }\n1470: \n1471:   // Apply session deduplication AFTER cache\n1472:   if (sessionId && enableDedup && sessionManager.isEnabled()) {\n1473:     let resultsData: Record<string, unknown> | null = null;\n1474:     if (responseToReturn?.content?.[0]?.text && typeof responseToReturn.content[0].text === 'string') {\n1475:       try {\n1476:         resultsData = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n1477:       } catch (err: unknown) {\n1478:         const message = toErrorMessage(err);\n1479:         console.warn('[memory-search] Failed to parse cached response for dedup:', message);\n1480:         resultsData = null;\n1481:       }\n1482:     } else if (responseToReturn && typeof responseToReturn === 'object') {\n1483:       resultsData = responseToReturn as unknown as Record<string, unknown>;\n1484:     }\n1485: \n1486:     // Validate response shape before dedup. If the cached response\n1487:     // Doesn't have the expected data.results array, log a warning and skip dedup\n1488:     // Rather than silently falling through to the un-deduped response.\n1489:     const data = (resultsData && typeof resultsData.data === 'object' && resultsData.data !== null)\n1490:       ? resultsData.data as Record<string, unknown>\n1491:       : null;\n1492:     const existingResults = Array.isArray(data?.results) ? data.results as MemorySearchRow[] : null;\n1493: \n1494:     if (resultsData && !data) {\n1495:       console.warn('[memory-search] Cached response shape mismatch: missing \"data\" object, skipping dedup');\n1496:     } else if (data && !existingResults) {\n1497:       console.warn('[memory-search] Cached response shape mismatch: \"data.results\" is not an array, skipping dedup');\n1498:     }\n1499: \n1500:     if (resultsData && data && existingResults && existingResults.length > 0) {\n1501:       const { results: dedupedResults } = applySessionDedup(\n1502:         existingResults,\n1503:         sessionId,\n1504:         enableDedup\n1505:       );\n1506: \n1507:       const originalCount = existingResults.length;\n1508:       const dedupedCount = dedupedResults.length;\n1509:       const filteredCount = originalCount - dedupedCount;\n1510: \n1511:       const tokensSaved = filteredCount * 200;\n1512:       const savingsPercent = originalCount > 0\n1513:         ? Math.round((filteredCount / originalCount) * 100)\n1514:         : 0;\n1515: \n1516:       reconcilePostFormatResultSet(data, dedupedResults as Array<Record<string, unknown>>);\n1517: \n1518:       const dedupStats = {\n1519:         enabled: true,\n1520:         sessionId,\n1521:         originalCount: originalCount,\n1522:         returnedCount: dedupedCount,\n1523:         filteredCount: filteredCount,\n1524:         tokensSaved: tokensSaved,\n1525:         savingsPercent: savingsPercent,\n1526:         tokenSavingsEstimate: tokensSaved > 0 ? `~${tokensSaved} tokens` : '0'\n1527:       };\n1528:       resultsData.dedupStats = dedupStats;\n1529: \n1530:       if (resultsData.meta && typeof resultsData.meta === 'object') {\n1531:         (resultsData.meta as Record<string, unknown>).dedupStats = dedupStats;\n1532:       }\n1533: \n1534:       if (filteredCount > 0 && typeof resultsData.summary === 'string') {\n1535:         resultsData.summary += ` (${filteredCount} duplicates filtered, ~${tokensSaved} tokens saved)`;\n1536:       }\n1537: \n1538:       responseToReturn = {\n1539:         ...responseToReturn,\n1540:         content: [{ type: 'text', text: JSON.stringify(resultsData, null, 2) }]\n1541:       } as MCPResponse;\n1542:     }\n1543:   }\n1544: \n1545:   if (sessionId && isSessionRetrievalStateEnabled()) {\n1546:     const parsedResponse = parseResponseEnvelope(responseToReturn);\n1547:     const data = parsedResponse?.envelope.data && typeof parsedResponse.envelope.data === 'object'\n1548:       ? parsedResponse.envelope.data as Record<string, unknown>\n1549:       : null;\n1550:     const existingResults = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n1551: \n1552:     if (parsedResponse && data) {\n1553:       const returnedIds = existingResults\n1554:         .map((result) => result.id ?? result.resultId)\n1555:         .filter((id): id is string | number => typeof id === 'string' || typeof id === 'number');\n1556: \n1557:       if (returnedIds.length > 0) {\n1558:         retrievalSessionStateManager.markSeen(sessionId, returnedIds);\n1559:       }\n1560: \n1561:       data.sessionState = buildSessionStatePayload(sessionId);\n1562:       if (goalRefinementPayload) {\n1563:         data.goalRefinement = goalRefinementPayload;\n1564:       }\n1565: \n1566:       parsedResponse.envelope.data = data;\n1567:       responseToReturn = replaceResponseEnvelope(responseToReturn, parsedResponse.firstEntry, parsedResponse.envelope);\n1568:     }\n1569:   }\n1570: \n1571:   if (includeTrace && sessionTransition) {\n1572:     responseToReturn = attachSessionTransitionTrace(responseToReturn, sessionTransition);\n1573:   }\n1574: \n1575:   if (retrievalTel