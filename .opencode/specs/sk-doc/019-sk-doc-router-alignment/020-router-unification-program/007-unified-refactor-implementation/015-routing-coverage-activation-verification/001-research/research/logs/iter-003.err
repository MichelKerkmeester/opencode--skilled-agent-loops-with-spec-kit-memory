   277	      const busy = SQLITE_BUSY_PATTERN.test(attemptResult.stderr);
   278	      const budgetRemaining = timeoutMs - (performance.now() - startedAt);
   279	      if (busy && attempt === 0 && budgetRemaining >= 500) {
