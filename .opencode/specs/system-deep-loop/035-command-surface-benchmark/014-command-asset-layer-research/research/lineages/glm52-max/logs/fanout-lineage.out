xt\n./design/assets/design_audit_presentation.txt\n./design/assets/design_foundations_presentation.txt\n./design/assets/design_interface_presentation.txt\n./design/assets/design_md-generator_presentation.txt\n./design/assets/design_motion_presentation.txt\n./doctor/assets/doctor_mcp_presentation.txt\n./doctor/assets/doctor_speckit_presentation.txt\n./doctor/assets/doctor_update_presentation.txt\n./memory/assets/learn_presentation.txt\n./memory/assets/manage_presentation.txt\n./memory/assets/save_presentation.txt\n./memory/assets/search_presentation.txt\n./speckit/assets/speckit_complete_presentation.txt\n./speckit/assets/speckit_implement_presentation.txt\n./speckit/assets/speckit_plan_presentation.txt\n./speckit/assets/speckit_resume_presentation.txt\n\n=== family directories ===\n./create\n./deep\n./design\n./doctor\n./memory\n./scripts\n./speckit\n","exit":0,"truncated":false},"title":"cd /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands\necho \"=== .yaml files across commands ===\"\nfind . -name \"*.yaml\" -type f | sort\necho \"\"\necho \"=== _routes.yaml ===\"\nfind . -name \"_routes.yaml\" | sort\necho \"\"\necho \"=== _presentation.txt files ===\"\nfind . -name \"*_presentation.txt\" | sort\necho \"\"\necho \"=== family directories ===\"\nfind . -mindepth 1 -maxdepth 1 -type d | sort","time":{"start":1784188255406,"end":1784188255407}},"id":"prt_f69e83c95001CZpzOqZhMlW3Sg","sessionID":"ses_09619781bffeQ3oAZ5RFeTTgCJ","messageID":"msg_f69e7fb8d0017xbUFsJXImfI6B"}}
