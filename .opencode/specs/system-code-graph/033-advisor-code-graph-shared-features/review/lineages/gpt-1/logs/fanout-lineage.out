as c FROM code_files').get() as { c: number }).c;\n  const totalNodes = (d.prepare('SELECT COUNT(*) as c FROM code_nodes').get() as { c: number }).c;\n  const totalEdges = (d.prepare('SELECT COUNT(*) as c FROM code_edges').get() as { c: number }).c;\n\n  const nodesByKind: Record<string, number> = {};\n  const kindRows = d.prepare('SELECT kind, COUNT(*) as c FROM code_nodes GROUP BY kind').all() as { kind: string; c: number }[];\n  for (const r of kindRows) nodesByKind[r.kind] = r.c;\n\n  const edgesByType: Record<string, number> = {};\n  const typeRows = d.prepare('SELECT edge_type, COUNT(*) as c FROM code_edges GROUP BY edge_type').all() as { edge_type: string; c: number }[];\n  for (const r of typeRows) edgesByType[r.edge_type] = r.c;\n\n  const parseHealthSummary: Record<string, number> = {};\n  const healthRows = d.prepare('SELECT parse_health, COUNT(*) as c FROM code_files GROUP BY parse_health').all() as { parse_health: string; c: number }[];\n  for (const r of healthRows) parseHealthSummary[r.parse_health] = r.c;\n\n  // Last scan timestamp\n  const lastScan = d.prepare('SELECT MAX(indexed_at) as last FROM code_files').get() as { last: string | null } | undefined;\n  const lastScanTimestamp = lastScan?.last ?? null;\n  const lastGitHead = getLastGitHead();\n  const graphQualitySummary = getGraphQualitySummary();\n  const tombstones = getTombstoneSummary();\n\n  // DB file size\n  let dbFileSize: number | null = null;\n  if (dbPath) {\n    try { dbFileSize = statSync(dbPath).size; } catch { /* file may not exist yet */ }\n  }\n\n  return {\n    totalFiles, totalNodes, totalEdges, nodesByKind, edgesByType, parseHealthSummary,\n    tombstones, lastScanTimestamp, lastGitHead, dbFileSize, schemaVersion: SCHEMA_VERSION, graphQualitySummary,\n  };\n}\n\nexport function getTombstoneSummary(): CodeGraphTombstoneSummary {\n  const enabled = codeGraphTombstonesEnabled();\n  const retentionLimit = enabled ? getCodeGraphTombstoneLimit() : 0;\n  const empty: CodeGraphTombstoneSummary = {\n    enabled,\n    retentionLimit,\n    retainedRows: 0,\n    byKind: {},\n    byReason: {},\n    recent: [],\n  };\n\n  const d = getDb();\n  if (!enabled || !tombstoneTableExists(d)) {\n    return empty;\n  }\n\n  const retained = d.prepare('SELECT COUNT(*) AS count FROM code_graph_tombstones').get() as { count: number };\n  const kindRows = d.prepare(`\n    SELECT entity_kind, COUNT(*) AS count\n    FROM code_graph_tombstones\n    GROUP BY entity_kind\n  `).all() as Array<{ entity_kind: string; count: number }>;\n  const reasonRows = d.prepare(`\n    SELECT reason, COUNT(*) AS count\n    FROM code_graph_tombstones\n    GROUP BY reason\n  `).all() as Array<{ reason: string; count: number }>;\n  const recentRows = d.prepare(`\n    SELECT id, entity_kind, entity_id, source_id, target_id, edge_type, file_path, reason, deleted_at\n    FROM code_graph_tombstones\n    ORDER BY deleted_at DESC, id DESC\n    LIMIT 10\n  `).all() as Array<Record<string, unknown>>;\n\n  return {\n    enabled,\n    retentionLimit,\n    retainedRows: retained.count,\n    byKind: Object.fromEntries(kindRows.map((row) => [row.entity_kind, row.count])),\n    byReason: Object.fromEntries(reasonRows.map((row) => [row.reason, row.count])),\n    recent: recentRows.map(mapTombstoneRow),\n  };\n}\n\n/** Remove orphaned nodes whose files no longer exist in code_files */\nexport function cleanupOrphans(): number {\n  const d = getDb();\n  const deletedAt = new Date().toISOString();\n  recordDanglingEdgeTombstones(d, 'cleanup_orphans', deletedAt);\n  // Find node file_ids not in code_files\n  if (codeGraphTombstonesEnabled()) {\n    ensureTombstoneSchema(d);\n    d.prepare(`\n      INSERT INTO code_graph_tombstones (entity_kind, entity_id, file_path, reason, deleted_at)\n      SELECT 'node', symbol_id, file_path, 'cleanup_orphans', ?\n      FROM code_nodes\n      WHERE file_id NOT IN (SELECT id FROM code_files)\n    `).run(deletedAt);\n    pruneTombstones(d);\n  }","lineStart":1400,"lineEnd":1519,"totalLines":1626,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/lib/code-graph-db.ts","time":{"start":1781128845522,"end":1781128845538}},"metadata":{"openai":{"itemId":"fc_0b875351d25a55fc016a29de8d63b88191afe447075f0d42d7"}},"id":"prt_eb38d58d10017eYOwQCfuLt5ah","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d26020012Ew3caaFtbScAj"}}
{"type":"tool_use","timestamp":1781128845541,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_naQqbbftVi4sJjg88uAgA2Id","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/code-graph-db.ts","offset":220,"limit":210},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/code-graph-db.ts</path>\n<type>file</type>\n<content>\n220:   CREATE INDEX IF NOT EXISTS idx_edges_type ON code_edges(edge_type);\n221:   CREATE INDEX IF NOT EXISTS idx_files_path ON code_files(file_path);\n222:   CREATE INDEX IF NOT EXISTS idx_files_hash ON code_files(content_hash);\n223:   CREATE INDEX IF NOT EXISTS idx_parse_diagnostics_last_seen ON parse_diagnostics(last_seen_at);\n224:   CREATE INDEX IF NOT EXISTS idx_parser_skip_list_class ON parser_skip_list(error_class);\n225: `;\n226: \n227: const CODE_GRAPH_TOMBSTONES_ENV = 'SPECKIT_CODE_GRAPH_TOMBSTONES';\n228: const CODE_GRAPH_TOMBSTONE_LIMIT_ENV = 'SPECKIT_CODE_GRAPH_TOMBSTONE_LIMIT';\n229: const DEFAULT_TOMBSTONE_LIMIT = 100;\n230: const MAX_TOMBSTONE_LIMIT = 10_000;\n231: \n232: function codeGraphTombstonesEnabled(): boolean {\n233:   return process.env[CODE_GRAPH_TOMBSTONES_ENV] === 'true';\n234: }\n235: \n236: function getCodeGraphTombstoneLimit(): number {\n237:   const raw = process.env[CODE_GRAPH_TOMBSTONE_LIMIT_ENV];\n238:   const parsed = raw ? Number.parseInt(raw, 10) : DEFAULT_TOMBSTONE_LIMIT;\n239:   if (!Number.isFinite(parsed) || parsed <= 0) {\n240:     return DEFAULT_TOMBSTONE_LIMIT;\n241:   }\n242:   return Math.min(Math.trunc(parsed), MAX_TOMBSTONE_LIMIT);\n243: }\n244: \n245: function ensureTombstoneSchema(database: Database.Database): void {\n246:   database.exec(`\n247:     CREATE TABLE IF NOT EXISTS code_graph_tombstones (\n248:       id INTEGER PRIMARY KEY AUTOINCREMENT,\n249:       entity_kind TEXT NOT NULL CHECK (entity_kind IN ('file', 'node', 'edge')),\n250:       entity_id TEXT,\n251:       source_id TEXT,\n252:       target_id TEXT,\n253:       edge_type TEXT,\n254:       file_path TEXT,\n255:       reason TEXT NOT NULL,\n256:       deleted_at TEXT NOT NULL\n257:     );\n258:     CREATE INDEX IF NOT EXISTS idx_code_graph_tombstones_deleted_at ON code_graph_tombstones(deleted_at);\n259:     CREATE INDEX IF NOT EXISTS idx_code_graph_tombstones_kind_reason ON code_graph_tombstones(entity_kind, reason);\n260:   `);\n261: }\n262: \n263: function tombstoneTableExists(database: Database.Database): boolean {\n264:   const row = database.prepare(`\n265:     SELECT name FROM sqlite_master WHERE type = 'table' AND name = 'code_graph_tombstones'\n266:   `).get() as { name: string } | undefined;\n267:   return row !== undefined;\n268: }\n269: \n270: function pruneTombstones(database: Database.Database): void {\n271:   const limit = getCodeGraphTombstoneLimit();\n272:   database.prepare(`\n273:     DELETE FROM code_graph_tombstones\n274:     WHERE id NOT IN (\n275:       SELECT id FROM code_graph_tombstones\n276:       ORDER BY deleted_at DESC, id DESC\n277:       LIMIT ?\n278:     )\n279:   `).run(limit);\n280: }\n281: \n282: function recordNodeTombstones(\n283:   database: Database.Database,\n284:   fileId: number,\n285:   reason: string,\n286:   deletedAt: string,\n287: ): void {\n288:   if (!codeGraphTombstonesEnabled()) {\n289:     return;\n290:   }\n291:   ensureTombstoneSchema(database);\n292:   database.prepare(`\n293:     INSERT INTO code_graph_tombstones (entity_kind, entity_id, file_path, reason, deleted_at)\n294:     SELECT 'node', symbol_id, file_path, ?, ?\n295:     FROM code_nodes\n296:     WHERE file_id = ?\n297:   `).run(reason, deletedAt, fileId);\n298:   pruneTombstones(database);\n299: }\n300: \n301: function recordEdgeTombstonesForSymbols(\n302:   database: Database.Database,\n303:   symbolIds: string[],\n304:   reason: string,\