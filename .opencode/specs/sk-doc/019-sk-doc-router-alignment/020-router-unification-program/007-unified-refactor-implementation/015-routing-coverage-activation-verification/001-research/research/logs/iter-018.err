   672	function runCliRecommend(input, env, timeoutMs) {
   673	  // Thread the caller's thresholds into the subprocess payload so the CLI
   674	  // scorer applies the same floor/ceiling as the in-process path. Omitting
   675	  // them made the scorer fall back to its built-in defaults while the response
   676	  // metadata still reported the caller-supplied thresholds.
   677	  const payload = {
   678	    prompt: input.prompt,
   679	    options: {
   680	      topK: 3,
   681	      includeAttribution: false,
   682	      includeAbstainReasons: true,
   683	      confidenceThreshold: threshold(input.thresholdConfidence),
   684	      uncertaintyThreshold: DEFAULT_UNCERTAINTY_THRESHOLD,
   685	    },
   686	  };
   687	  return new Promise((resolvePromise) => {
   688	    let stdout = '';
   689	    let stderr = '';
   690	    let settled = false;
   691	    let timedOut = false;
   692	    const child = spawn(process.execPath, [
   693	      ADVISOR_CLI_PATH,
   694	      'advisor_recommend',
   695	      '--json',
   696	      JSON.stringify(payload),
   697	      '--format',
   698	      'json',
   699	      '--timeout-ms',
   700	      String(timeoutMs),
   701	      '--warm-only',
   702	    ], {
   703	      cwd: input.workspaceRoot,
   704	      env: createCliChildEnv(env),
   705	      stdio: ['ignore', 'pipe', 'pipe'],
   706	    });
   707	    const timer = setTimeout(() => {
   708	      timedOut = true;
   709	      child.kill('SIGKILL');
   710	    }, timeoutMs);
   711	    timer.unref?.();
   712	    const finish = (result) => {
   713	      if (settled) return;
   714	      settled = true;
   715	      clearTimeout(timer);
   716	      resolvePromise(result);
   717	    };
   718	    child.stdout?.setEncoding('utf8');
   719	    child.stdout?.on('data', (chunk) => {
   720	      stdout += chunk;
   721	    });
   722	    child.stderr?.setEncoding('utf8');
   723	    child.stderr?.on('data', (chunk) => {
   724	      if (stderr.length < MAX_CLI_STDERR_BYTES) {
   725	        stderr = (stderr + String(chunk)).slice(0, MAX_CLI_STDERR_BYTES);
   726	      }
   727	    });
   728	    child.once('error', (error) => {
   729	      finish({ stdout, stderr, exitCode: null, signal: null, timedOut, error: error.code ?? error.message });
   730	    });
   731	    child.once('close', (exitCode, signal) => {
   732	      finish({ stdout, stderr, exitCode, signal, timedOut, error: null });
   733	    });
   734	  });
   735	}
