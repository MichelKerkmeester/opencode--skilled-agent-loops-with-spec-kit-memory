/bin/zsh -lc "python3 - <<'PY'
from pathlib import Path
import re, unicodedata
root=Path('.opencode/specs/skilled-agent-orchestration/096-rename-opencode-dirs-to-plural')
files=sorted(root.rglob('*.md'))
heading_re=re.compile(r'"'^(#{1,6})'"\\s+(.+?)\\s*"'$'"')
link_re=re.compile(r'(?<"'!'"\\"'!)'"\\[["'^'"\\]]+\\]\\((["'^)]+)'"\\)')
def slug(s):
    s=re.sub(r'<["'^>]+>'"','',s)
    s=re.sub(r'"'`([''^`]*)`'"',r'\\1',s)
    s=s.strip().lower()
    s=''.join(c for c in unicodedata.normalize('NFKD',s) if not unicodedata.combining(c))
    s=re.sub(r'["'^a-z0-9'"\\s-]','',s)
    s=re.sub(r'\\s+','-',s)
    s=re.sub(r'-+','-',s).strip('-')
    return s
anchors={}
for f in files:
    ids=set()
    for line in f.read_text(errors='replace').splitlines():
        m=heading_re.match(line)
        if m: ids.add(slug(m.group(2)))
        for am in re.finditer(r'<"'!--'"\\s*ANCHOR:(["'^'"\\s]+)\\s*-->', line): ids.add(am.group(1))
    anchors[f]=ids
issues=[]
for f in files:
    lines=f.read_text(errors='replace').splitlines()
    for i,line in enumerate(lines,1):
        for m in link_re.finditer(line):
            href=m.group(1).strip()
            if not href or href.startswith(('http://','https://','mailto:')): continue
            href=href.split()[0]
            path_part, _, frag = href.partition('#')
            target=f if path_part=='' else (f.parent / path_part).resolve()
            try:
                target_rel=target.relative_to(Path.cwd().resolve())
            except Exception:
                target_rel=target
            if path_part and not target.exists():
                issues.append((str(f),i,'missing-file',href,str(target_rel)))
            elif frag:
                check=f if path_part=='' else Path(target)
                if check.exists():
                    a=frag.lower()
                    if a not in anchors.get(check,set()):
                        issues.append((str(f),i,'missing-anchor',href,a))
print('files', len(files), 'issues', len(issues))
for item in issues[:120]:
    print(':'.join(map(str,item)))
