{"type":"tool_use","timestamp":1784606411791,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d4c8727051ab8e5adb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Stage Telemetry Tests                                                    ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import assert from 'node:assert/strict';\n6: import { readFile } from 'node:fs/promises';\n7: import path from 'node:path';\n8: import test from 'node:test';\n9: \n10: import { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\n11: import { stableJson } from '../canonical.mjs';\n12: import { indexStyleCorpus } from '../indexer.mjs';\n13: import { queryPersistentStyles } from '../retrieval.mjs';\n14: import { openStyleDatabase } from '../schema.mjs';\n15: import { RESIDENCY, createStageRecorder } from '../stage-telemetry.mjs';\n16: import {\n17:   DEFAULT_GOLDEN_DIR,\n18:   buildOracleDatabase,\n19: } from '../oracle/differential-oracle.mjs';\n20: import { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';\n21: import { createIndexedFixture } from './fixtures.mjs';\n22: \n23: const RESIDENCY_VALUES = new Set(Object.values(RESIDENCY));\n24: \n25: function deterministicRecorder() {\n26:   let clock = 0;\n27:   let rss = 1_000;\n28:   return createStageRecorder({\n29:     now: () => { const value = clock; clock += 5; return value; },\n30:     memory: () => { const value = rss; rss += 32; return value; },\n31:   });\n32: }\n33: \n34: function assertResidencyHonest(recorder) {\n35:   const records = recorder.records();\n36:   assert.ok(records.length > 0, 'expected at least one stage record');\n37:   for (const record of records) {\n38:     assert.ok(RESIDENCY_VALUES.has(record.residency), `unattributed residency: ${record.residency}`);\n39:     assert.equal(typeof record.latencyMs, 'number');\n40:     assert.equal(typeof record.rssDeltaBytes, 'number');\n41:     assert.ok(record.throughputPerSecond === null || typeof record.throughputPerSecond === 'number');\n42:   }\n43:   const summary = recorder.summary();\n44:   assert.equal(summary.native + summary.jsResident, summary.total);\n45:   assert.ok(summary.unattributedMs >= 0, 'unattributed cost must never be negative');\n46:   assert.ok(summary.elapsedMs + 1e-9 >= summary.total, 'elapsed must cover attributed span cost');\n47:   assert.equal(summary.unattributedMs, Math.max(0, summary.elapsedMs - summary.total));\n48:   assert.equal(summary.stageCount, records.length);\n49:   return { records, summary };\n50: }\n51: \n52: test('the recorder attributes every span to one residency bucket', () => {\n53:   const recorder = deterministicRecorder();\n54:   recorder.span('a', RESIDENCY.NATIVE).end(10);\n55:   recorder.span('b', RESIDENCY.JS_RESIDENT).end(20);\n56:   const [first, second] = recorder.records();\n57:   assert.equal(first.latencyMs, 5);\n58:   assert.equal(first.throughputPerSecond, (10 / 5) * 1_000);\n59:   assert.equal(first.rssDeltaBytes, 32);\n60:   assert.equal(second.residency, RESIDENCY.JS_RESIDENT);\n61:   const summary = recorder.summary();\n62:   assert.equal(summary.native, 5);\n63:   assert.equal(summary.jsResident, 5);\n64:   assert.equal(summary.total, 10);\n65:   // The two spans start five ticks apart, so the wall window is 15 while only\n66:   // 10 was bracketed: the recorder must surface the 5-tick gap, not hide it.\n67:   assert.equal(summary.elapsedMs, 15);\n68:   assert.equal(summary.unattributedMs, 5);\n69: });\n70: \n71: test('summary measures wall time an explicit overall timer leaves outside every span', () => {\n72:   let clock = 0;\n73:   const recorder = createStageRecorder({ now: () => clock, memory: () => 0 });\n74:   const overall = recorder.overall();\n75:   clock = 100; // 100 ticks of work run before any span opens\n76:   const span = recorder.span('native-read', RESIDENCY.NATIVE);\n77:   clock = 130; // the span itself accounts for 30 ticks\n78:   span.end(1);\n79:   clock = 150; // 20 more ticks run after the span closes\n80:   overall.end();\n81:   const summary = recorder.summary();\n82:   assert.equal(summary.total, 30);\n83:   assert.equal(summary.native, 30);\n84:   assert.equal(summary.elapsedMs, 150);\n85:   assert.equal(summary.unattributedMs, 120);\n86: });\n87: \n88: test('summary attributes inter-span gaps to the unattributed bucket', () => {\n89:   let clock = 0;\n90:   const recorder = createStageRecorder({ now: () => clock, memory: () => 0 });\n91:   const first = recorder.span('a', RESIDENCY.NATIVE);\n92:   clock = 10;\n93:   first.end(1);\n94:   clock = 40; // a 30-tick gap runs outside any span\n95:   const second = recorder.span('b', RESIDENCY.JS_RESIDENT);\n96:   clock = 55;\n97:   second.end(1);\n98:   const summary = recorder.summary();\n99:   assert.equal(summary.total, 25);\n100:   assert.equal(summary.elapsedMs, 55);\n101:   assert.equal(summary.unattributedMs, 30);\n102: });\n103: \n104: test('an unknown residency cannot be recorded', () => {\n105:   const recorder = createStageRecorder();\n106:   assert.throws(() => recorder.span('x', 'blended'), /Unknown telemetry residency/);\n107: });\n108: \n109: test('query telemetry brackets each native SQL and JS-resident step in its true bucket', async (context) => {\n110:   const { database } = await createIndexedFixture(context);\n111:   const recorder = createStageRecorder();\n112:   const withTelemetry = queryPersistentStyles({ text: 'editorial serif' }, { database, telemetry: recorder });\n113:   const { records, summary } = assertResidencyHonest(recorder);\n114:   const residencyByStage = new Map(records.map((record) => [record.stage, record.residency]));\n115: \n116:   // Steps the faked instrumentation ran outside every span (fingerprint digest,\n117:   // BEGIN/COMMIT, opaque encoding) are now bracketed with their real residency.\n118:   assert.equal(residencyByStage.get('request.fingerprint'), RESIDENCY.JS_RESIDENT);\n119:   assert.equal(residencyByStage.get('transaction.begin'), RESIDENCY.NATIVE);\n120:   assert.equal(residencyByStage.get('transaction.commit'), RESIDENCY.NATIVE);\n121:   assert.equal(residencyByStage.get('cards.attribution.encode'), RESIDENCY.JS_RESIDENT);\n122:   // Steps that used to bracket both SQL and JS under one label are split honestly.\n123:   assert.equal(residencyByStage.get('generation.read'), RESIDENCY.NATIVE);\n124:   assert.equal(residencyByStage.get('generation.verify'), RESIDENCY.JS_RESIDENT);\n125:   assert.equal(residencyByStage.get('eligibility.load'), RESIDENCY.NATIVE);\n126:   assert.equal(residencyByStage.get('eligibility.facets.load'), RESIDENCY.NATIVE);\n127:   assert.equal(residencyByStage.get('eligibility.facets.assemble'), RESIDENCY.JS_RESIDENT);\n128:   assert.ok(records.map((record) => record.stage).includes('lane.fts'));\n129:   assert.ok(summary.native >= 0 && summary.jsResident >= 0);\n130: \n131:   // Telemetry is a pure side-channel: the returned DTO must be byte-identical.\n132:   const withoutTelemetry = queryPersistentStyles({ text: 'editorial serif' }, { database });\n133:   assert.deepEqual(withTelemetry, withoutTelemetry);\n134:   assert.equal(stableJson(withTelemetry), stableJson(withoutTelemetry));\n135: });\n136: \n137: test('the vector lane splits its native fetch from JS-resident cosine work', async (context) => {\n138:   const { database } = await createIndexedFixture(context);\n139:   const { drainVectorQueue } = await import('../vectors.mjs');\n140:   await drainVectorQueue(database, {\n141:     profileId: 'style-default-v1',\n142:     embedder: async (text) => (text.includes('Alpha Editorial') ? [1, 0] : [0, 1]),\n143:   });\n144:   const recorder = createStageRecorder();\n145:   queryPersistentStyles({\n146:     queryVector: [1, 0],\n147:     vectorProfile: 'style-default-v1',\n148:     disableFts: true,\n149:   }, { database, telemetry: recorder });\n150:   const stages = recorder.records().map((record) => record.stage);\n151:   assert.ok(stages.includes('lane.vector.fetch'));\n152:   assert.ok(stages.includes('lane.vector.cosine'));\n153:   const fetch = recorder.records().find((record) => record.stage === 'lane.vector.fetch');\n154:   const cosine = recorder.records().find((record) => record.stage === 'lane.vector.cosine');\n155:   assert.equal(fetch.residency, RESIDENCY.NATIVE);\n156:   assert.equal(cosine.residency, RESIDENCY.JS_RESIDENT);\n157: });\n158: \n159: test('telemetry-off leaves the retrieval DTO byte-identical to the oracle golden', async (context) => {\n160:   const fixture = await createFixtureCorpus();\n161:   context.after(fixture.cleanup);\n162:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n163:   context.after(() => database.close());\n164:   const scenario = ORACLE_QUERY_SET.find((entry) => entry.name === 'fts-text');\n165:   const golden = (await readFile(path.join(DEFAULT_GOLDEN_DIR, 'fts-text.canonical.json'), 'utf8'))\n166:     .replace(/\\n$/, '');\n167: \n168:   const withoutTelemetry = queryPersistentStyles(scenario.request, { database });\n169:   assert.equal(\n170:     stableJson({ name: scenario.name, request: scenario.request, result: withoutTelemetry }),\n171:     golden,\n172:   );\n173: \n174:   const recorder = createStageRecorder();\n175:   const withTelemetry = queryPersistentStyles(scenario.request, { database, telemetry: recorder });\n176:   assert.equal(\n177:     stableJson({ name: scenario.name, request: scenario.request, result: withTelemetry }),\n178:     golden,\n179:   );\n180:   assert.ok(recorder.records().length > 0);\n181: });\n182: \n183: test('indexer telemetry brackets each stage over the work it names', async (context) => {\n184:   const fixture = await createFixtureCorpus();\n185:   context.after(fixture.cleanup);\n186:   const database = openStyleDatabase();\n187:   context.after(() => database.close());\n188:   const recorder = createStageRecorder();\n189:   const result = await indexStyleCorpus({\n190:     corpusRoot: fixture.root,\n191:     database,\n192:     corpusWalkMode: 'migration',\n193:     telemetry: recorder,\n194:   });\n195:   assert.equal(result.published, true);\n196:   const { records, summary } = assertResidencyHonest(recorder);\n197:   const stages = records.map((record) => record.stage);\n198:   assert.deepEqual(stages, [\n199:     'discover', 'snapshot.load', 'verify.parse', 'plan.hash', 'plan.load',\n200:     'commit.write', 'publish.missing', 'publish.write',\n201:   ]);\n202:   const residencyByStage = new Map(records.map((record) => [record.stage, record.residency]));\n203:   // Discovery, artifact verification/parse, and hashing run on the JS heap.\n204:   assert.equal(residencyByStage.get('discover'), RESIDENCY.JS_RESIDENT);\n205:   assert.equal(residencyByStage.get('verify.parse'), RESIDENCY.JS_RESIDENT);\n206:   assert.equal(residencyByStage.get('plan.hash'), RESIDENCY.JS_RESIDENT);\n207:   // The SQL snapshot, planning reads, and transaction writes stay native.\n208:   assert.equal(residencyByStage.get('snapshot.load'), RESIDENCY.NATIVE);\n209:   assert.equal(residencyByStage.get('plan.load'), RESIDENCY.NATIVE);\n210:   assert.equal(residencyByStage.get('commit.write'), RESIDENCY.NATIVE);\n211:   assert.equal(residencyByStage.get('publish.write'), RESIDENCY.NATIVE);\n212:   assert.equal(summary.native + summary.jsResident, summary.total);\n213: });\n214: \n215: test('indexer telemetry books the JS-heavy embedder drain as js-resident', async (context) => {\n216:   const fixture = await createFixtureCorpus();\n217:   context.after(fixture.cleanup);\n218:   const database = openStyleDatabase();\n219:   context.after(() => database.close());\n220:   const recorder = createStageRecorder();\n221:   const result = await indexStyleCorpus({\n222:     corpusRoot: fixture.root,\n223:     database,\n224:     corpusWalkMode: 'migration',\n225:     telemetry: recorder,\n226:     embedder: async (text) => (text.includes('Alpha Editorial') ? [1, 0] : [0, 1]),\n227:   });\n228:   assert.equal(result.published, true);\n229:   const drain = recorder.records().find((record) => record.stage === 'vector.drain');\n230:   assert.ok(drain, 'expected a vector.drain span for the embedder drain');\n231:   assert.equal(drain.residency, RESIDENCY.JS_RESIDENT);\n232:   const publishWrite = recorder.records().find((record) => record.stage === 'publish.write');\n233:   assert.equal(publishWrite.residency, RESIDENCY.NATIVE);\n234: });\n\n(End of file - total 234 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Stage Telemetry Tests                                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { readFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { stableJson } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\nimport { RESIDENCY, createStageRecorder } from '../stage-telemetry.mjs';\nimport {\n  DEFAULT_GOLDEN_DIR,\n  buildOracleDatabase,\n} from '../oracle/differential-oracle.mjs';\nimport { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Stage Telemetry Tests                                                    ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { readFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { stableJson } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\nimport { RESIDENCY, createStageRecorder } from '../stage-telemetry.mjs';\nimport {\n  DEFAULT_GOLDEN_DIR,\n  buildOracleDatabase,\n} from '../oracle/differential-oracle.mjs';\nimport { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';\nimport { createIndexedFixture } from './fixtures.mjs';\n\nconst RESIDENCY_VALUES = new Set(Object.values(RESIDENCY));\n\nfunction deterministicRecorder() {\n  let clock = 0;\n  let rss = 1_000;\n  return createStageRecorder({\n    now: () => { const value = clock; clock += 5; return value; },\n    memory: () => { const value = rss; rss += 32; return value; },\n  });\n}\n\nfunction assertResidencyHonest(recorder) {\n  const records = recorder.records();\n  assert.ok(records.length > 0, 'expected at least one stage record');\n  for (const record of records) {\n    assert.ok(RESIDENCY_VALUES.has(record.residency), `unattributed residency: ${record.residency}`);\n    assert.equal(typeof record.latencyMs, 'number');\n    assert.equal(typeof record.rssDeltaBytes, 'number');\n    assert.ok(record.throughputPerSecond === null || typeof record.throughputPerSecond === 'number');\n  }\n  const summary = recorder.summary();\n  assert.equal(summary.native + summary.jsResident, summary.total);\n  assert.ok(summary.unattributedMs >= 0, 'unattributed cost must never be negative');\n  assert.ok(summary.elapsedMs + 1e-9 >= summary.total, 'elapsed must cover attributed span cost');\n  assert.equal(summary.unattributedMs, Math.max(0, summary.elapsedMs - summary.total));\n  assert.equal(summary.stageCount, records.length);\n  return { records, summary };\n}\n\ntest('the recorder attributes every span to one residency bucket', () => {\n  const recorder = deterministicRecorder();\n  recorder.span('a', RESIDENCY.NATIVE).end(10);\n  recorder.span('b', RESIDENCY.JS_RESIDENT).end(20);\n  const [first, second] = recorder.records();\n  assert.equal(first.latencyMs, 5);\n  assert.equal(first.throughputPerSecond, (10 / 5) * 1_000);\n  assert.equal(first.rssDeltaBytes, 32);\n  assert.equal(second.residency, RESIDENCY.JS_RESIDENT);\n  const summary = recorder.summary();\n  assert.equal(summary.native, 5);\n  assert.equal(summary.jsResident, 5);\n  assert.equal(summary.total, 10);\n  // The two spans start five ticks apart, so the wall window is 15 while only\n  // 10 was bracketed: the recorder must surface the 5-tick gap, not hide it.\n  assert.equal(summary.elapsedMs, 15);\n  assert.equal(summary.unattributedMs, 5);\n});\n\ntest('summary measures wall time an explicit overall timer leaves outside every span', () => {\n  let clock = 0;\n  const recorder = createStageRecorder({ now: () => clock, memory: () => 0 });\n  const overall = recorder.overall();\n  clock = 100; // 100 ticks of work run before any span opens\n  const span = recorder.span('native-read', RESIDENCY.NATIVE);\n  clock = 130; // the span itself accounts for 30 ticks\n  span.end(1);\n  clock = 150; // 20 more ticks run after the span closes\n  overall.end();\n  const summary = recorder.summary();\n  assert.equal(summary.total, 30);\n  assert.equal(summary.native, 30);\n  assert.equal(summary.elapsedMs, 150);\n  assert.equal(summary.unattributedMs, 120);\n});\n\ntest('summary attributes inter-span gaps to the unattributed bucket', () => {\n  let clock = 0;\n  const recorder = createStageRecorder({ now: () => clock, memory: () => 0 });\n  const first = recorder.span('a', RESIDENCY.NATIVE);\n  clock = 10;\n  first.end(1);\n  clock = 40; // a 30-tick gap runs outside any span\n  const second = recorder.span('b', RESIDENCY.JS_RESIDENT);\n  clock = 55;\n  second.end(1);\n  const summary = recorder.summary();\n  assert.equal(summary.total, 25);\n  assert.equal(summary.elapsedMs, 55);\n  assert.equal(summary.unattributedMs, 30);\n});\n\ntest('an unknown residency cannot be recorded', () => {\n  const recorder = createStageRecorder();\n  assert.throws(() => recorder.span('x', 'blended'), /Unknown telemetry residency/);\n});\n\ntest('query telemetry brackets each native SQL and JS-resident step in its true bucket', async (context) => {\n  const { database } = await createIndexedFixture(context);\n  const recorder = createStageRecorder();\n  const withTelemetry = queryPersistentStyles({ text: 'editorial serif' }, { database, telemetry: recorder });\n  const { records, summary } = assertResidencyHonest(recorder);\n  const residencyByStage = new Map(records.map((record) => [record.stage, record.residency]));\n\n  // Steps the faked instrumentation ran outside every span (fingerprint digest,\n  // BEGIN/COMMIT, opaque encoding) are now bracketed with their real residency.\n  assert.equal(residencyByStage.get('request.fingerprint'), RESIDENCY.JS_RESIDENT);\n  assert.equal(residencyByStage.get('transaction.begin'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('transaction.commit'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('cards.attribution.encode'), RESIDENCY.JS_RESIDENT);\n  // Steps that used to bracket both SQL and JS under one label are split honestly.\n  assert.equal(residencyByStage.get('generation.read'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('generation.verify'), RESIDENCY.JS_RESIDENT);\n  assert.equal(residencyByStage.get('eligibility.load'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('eligibility.facets.load'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('eligibility.facets.assemble'), RESIDENCY.JS_RESIDENT);\n  assert.ok(records.map((record) => record.stage).includes('lane.fts'));\n  assert.ok(summary.native >= 0 && summary.jsResident >= 0);\n\n  // Telemetry is a pure side-channel: the returned DTO must be byte-identical.\n  const withoutTelemetry = queryPersistentStyles({ text: 'editorial serif' }, { database });\n  assert.deepEqual(withTelemetry, withoutTelemetry);\n  assert.equal(stableJson(withTelemetry), stableJson(withoutTelemetry));\n});\n\ntest('the vector lane splits its native fetch from JS-resident cosine work', async (context) => {\n  const { database } = await createIndexedFixture(context);\n  const { drainVectorQueue } = await import('../vectors.mjs');\n  await drainVectorQueue(database, {\n    profileId: 'style-default-v1',\n    embedder: async (text) => (text.includes('Alpha Editorial') ? [1, 0] : [0, 1]),\n  });\n  const recorder = createStageRecorder();\n  queryPersistentStyles({\n    queryVector: [1, 0],\n    vectorProfile: 'style-default-v1',\n    disableFts: true,\n  }, { database, telemetry: recorder });\n  const stages = recorder.records().map((record) => record.stage);\n  assert.ok(stages.includes('lane.vector.fetch'));\n  assert.ok(stages.includes('lane.vector.cosine'));\n  const fetch = recorder.records().find((record) => record.stage === 'lane.vector.fetch');\n  const cosine = recorder.records().find((record) => record.stage === 'lane.vector.cosine');\n  assert.equal(fetch.residency, RESIDENCY.NATIVE);\n  assert.equal(cosine.residency, RESIDENCY.JS_RESIDENT);\n});\n\ntest('telemetry-off leaves the retrieval DTO byte-identical to the oracle golden', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const scenario = ORACLE_QUERY_SET.find((entry) => entry.name === 'fts-text');\n  const golden = (await readFile(path.join(DEFAULT_GOLDEN_DIR, 'fts-text.canonical.json'), 'utf8'))\n    .replace(/\\n$/, '');\n\n  const withoutTelemetry = queryPersistentStyles(scenario.request, { database });\n  assert.equal(\n    stableJson({ name: scenario.name, request: scenario.request, result: withoutTelemetry }),\n    golden,\n  );\n\n  const recorder = createStageRecorder();\n  const withTelemetry = queryPersistentStyles(scenario.request, { database, telemetry: recorder });\n  assert.equal(\n    stableJson({ name: scenario.name, request: scenario.request, result: withTelemetry }),\n    golden,\n  );\n  assert.ok(recorder.records().length > 0);\n});\n\ntest('indexer telemetry brackets each stage over the work it names', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = openStyleDatabase();\n  context.after(() => database.close());\n  const recorder = createStageRecorder();\n  const result = await indexStyleCorpus({\n    corpusRoot: fixture.root,\n    database,\n    corpusWalkMode: 'migration',\n    telemetry: recorder,\n  });\n  assert.equal(result.published, true);\n  const { records, summary } = assertResidencyHonest(recorder);\n  const stages = records.map((record) => record.stage);\n  assert.deepEqual(stages, [\n    'discover', 'snapshot.load', 'verify.parse', 'plan.hash', 'plan.load',\n    'commit.write', 'publish.missing', 'publish.write',\n  ]);\n  const residencyByStage = new Map(records.map((record) => [record.stage, record.residency]));\n  // Discovery, artifact verification/parse, and hashing run on the JS heap.\n  assert.equal(residencyByStage.get('discover'), RESIDENCY.JS_RESIDENT);\n  assert.equal(residencyByStage.get('verify.parse'), RESIDENCY.JS_RESIDENT);\n  assert.equal(residencyByStage.get('plan.hash'), RESIDENCY.JS_RESIDENT);\n  // The SQL snapshot, planning reads, and transaction writes stay native.\n  assert.equal(residencyByStage.get('snapshot.load'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('plan.load'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('commit.write'), RESIDENCY.NATIVE);\n  assert.equal(residencyByStage.get('publish.write'), RESIDENCY.NATIVE);\n  assert.equal(summary.native + summary.jsResident, summary.total);\n});\n\ntest('indexer telemetry books the JS-heavy embedder drain as js-resident', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = openStyleDatabase();\n  context.after(() => database.close());\n  const recorder = createStageRecorder();\n  const result = await indexStyleCorpus({\n    corpusRoot: fixture.root,\n    database,\n    corpusWalkMode: 'migration',\n    telemetry: recorder,\n    embedder: async (text) => (text.includes('Alpha Editorial') ? [1, 0] : [0, 1]),\n  });\n  assert.equal(result.published, true);\n  const drain = recorder.records().find((record) => record.stage === 'vector.drain');\n  assert.ok(drain, 'expected a vector.drain span for the embedder drain');\n  assert.equal(drain.residency, RESIDENCY.JS_RESIDENT);\n  const publishWrite = recorder.records().find((record) => record.stage === 'publish.write');\n  assert.equal(publishWrite.residency, RESIDENCY.NATIVE);\n});","lineStart":1,"lineEnd":234,"totalLines":234,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/__tests__/telemetry.test.mjs","time":{"start":1784606411786,"end":1784606411789}},"id":"prt_f82d4c93b001YMDJ64QuDxRKRc","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d4bc6d001EVfSYRjS2IgAch"}}
{"type":"step_finish","timestamp":1784606412180,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"id":"prt_f82d4cd92001pn2mlWSHPocrsr","reason":"tool-calls","snapshot":"f4ff26001c2c69cb83e93443d6b29fbb30affd7f","messageID":"msg_f82d4bc6d001EVfSYRjS2IgAch","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","type":"step-finish","tokens":{"total":123637,"input":13593,"output":92,"reasoning":0,"cache":{"write":0,"read":109952}},"cost":0.01078542}}
{"type":"step_start","timestamp":1784606414907,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"id":"prt_f82d4d839001ZCFn406xSHQtSn","messageID":"msg_f82d4cf25001CvF9YlFshjndNd","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","snapshot":"f4ff26001c2c69cb83e93443d6b29fbb30affd7f","type":"step-start"}}
{"type":"tool_use","timestamp":1784606421236,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d4ef087a118f7fe9f8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Differential Oracle Tests                                                ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import assert from 'node:assert/strict';\n6: import { mkdtemp, readFile, rm, writeFile } from 'node:fs/promises';\n7: import os from 'node:os';\n8: import path from 'node:path';\n9: import test from 'node:test';\n10: \n11: import { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\n12: import { stableJson } from '../canonical.mjs';\n13: import {\n14:   DEFAULT_GOLDEN_DIR,\n15:   buildOracleDatabase,\n16:   canonicalizeSnapshot,\n17:   captureOracle,\n18:   freezeOracle,\n19:   listGoldenScenarios,\n20:   replayOracle,\n21:   snapshotScenario,\n22: } from '../oracle/differential-oracle.mjs';\n23: import { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';\n24: import {\n25:   REPLAY_SCALES,\n26:   buildScaledOracleDatabase,\n27:   captureScaleOracle,\n28:   materializeReplayCorpus,\n29: } from '../oracle/replay-fixtures.mjs';\n30: import { queryPersistentStyles } from '../retrieval.mjs';\n31: \n32: async function goldenScratch() {\n33:   return mkdtemp(path.join(os.tmpdir(), 'style-oracle-golden-'));\n34: }\n35: \n36: async function loadScaleGolden() {\n37:   return JSON.parse(await readFile(path.join(DEFAULT_GOLDEN_DIR, 'scales.json'), 'utf8'));\n38: }\n39: \n40: function scenarioRequest(name) {\n41:   return ORACLE_QUERY_SET.find((scenario) => scenario.name === name).request;\n42: }\n43: \n44: test('replay reproduces the committed golden bytes for every scenario', async (context) => {\n45:   const fixture = await createFixtureCorpus();\n46:   context.after(fixture.cleanup);\n47:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n48:   context.after(() => database.close());\n49:   const outcome = await replayOracle({ database });\n50:   assert.equal(outcome.ok, true, JSON.stringify(outcome.mismatches));\n51:   assert.equal(outcome.captures.length, ORACLE_QUERY_SET.length);\n52: });\n53: \n54: test('freeze then replay round-trips in an isolated golden directory', async (context) => {\n55:   const fixture = await createFixtureCorpus();\n56:   context.after(fixture.cleanup);\n57:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n58:   context.after(() => database.close());\n59:   const goldenDir = await goldenScratch();\n60:   context.after(() => rm(goldenDir, { recursive: true, force: true }));\n61: \n62:   const frozen = await freezeOracle({ database, goldenDir });\n63:   assert.equal(frozen.length, ORACLE_QUERY_SET.length);\n64:   assert.deepEqual(await listGoldenScenarios(goldenDir), ORACLE_QUERY_SET.map((s) => s.name).sort());\n65: \n66:   const replay = await replayOracle({ database, goldenDir });\n67:   assert.equal(replay.ok, true, JSON.stringify(replay.mismatches));\n68: });\n69: \n70: test('a byte perturbation in a golden file fails the oracle', async (context) => {\n71:   const fixture = await createFixtureCorpus();\n72:   context.after(fixture.cleanup);\n73:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n74:   context.after(() => database.close());\n75:   const goldenDir = await goldenScratch();\n76:   context.after(() => rm(goldenDir, { recursive: true, force: true }));\n77: \n78:   await freezeOracle({ database, goldenDir });\n79:   const targetPath = path.join(goldenDir, 'fts-text.canonical.json');\n80:   const original = await readFile(targetPath, 'utf8');\n81:   await writeFile(targetPath, original.replace('\"ok\":true', '\"ok\":false'));\n82: \n83:   const replay = await replayOracle({ database, goldenDir });\n84:   assert.equal(replay.ok, false);\n85:   assert.deepEqual(replay.mismatches, [{ name: 'fts-text', reason: 'byte-mismatch', sha256: replay.captures.find((c) => c.name === 'fts-text').sha256 }]);\n86: });\n87: \n88: test('a missing golden file is reported rather than silently passing', async (context) => {\n89:   const fixture = await createFixtureCorpus();\n90:   context.after(fixture.cleanup);\n91:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n92:   context.after(() => database.close());\n93:   const goldenDir = await goldenScratch();\n94:   context.after(() => rm(goldenDir, { recursive: true, force: true }));\n95: \n96:   const replay = await replayOracle({ database, goldenDir });\n97:   assert.equal(replay.ok, false);\n98:   assert.equal(replay.mismatches.length, ORACLE_QUERY_SET.length);\n99:   assert.ok(replay.mismatches.every((mismatch) => mismatch.reason === 'missing-golden'));\n100: });\n101: \n102: test('an ordering or tie-break change alters the canonical bytes', async (context) => {\n103:   const fixture = await createFixtureCorpus();\n104:   context.after(fixture.cleanup);\n105:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n106:   context.after(() => database.close());\n107:   const scenario = ORACLE_QUERY_SET.find((entry) => entry.name === 'structured-only');\n108:   const snapshot = snapshotScenario(database, scenario);\n109:   const canonical = canonicalizeSnapshot(snapshot);\n110:   const perturbed = {\n111:     ...snapshot,\n112:     result: { ...snapshot.result, cards: [...snapshot.result.cards].reverse() },\n113:   };\n114:   assert.notEqual(stableJson(perturbed), canonical.canonical);\n115:   assert.ok(snapshot.result.cards.length >= 2, 'perturbation requires at least two cards');\n116: });\n117: \n118: test('every capture reuses the shared canonicalizer for a stable digest', async (context) => {\n119:   const fixture = await createFixtureCorpus();\n120:   context.after(fixture.cleanup);\n121:   const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n122:   context.after(() => database.close());\n123:   const first = captureOracle(database);\n124:   const second = captureOracle(database);\n125:   assert.deepEqual(first.map((c) => c.sha256), second.map((c) => c.sha256));\n126:   for (const capture of first) {\n127:     assert.ok(capture.sha256.startsWith('sha256:'));\n128:   }\n129: });\n130: \n131: test('the full oracle matrix replays with drained vectors at every replay scale', async (context) => {\n132:   const golden = await loadScaleGolden();\n133:   for (const [label, count] of Object.entries(REPLAY_SCALES)) {\n134:     const fixture = await materializeReplayCorpus(count);\n135:     context.after(fixture.cleanup);\n136:     assert.equal(\n137:       await captureScaleOracle(fixture.root),\n138:       golden.scales[label].oracleHash,\n139:       `full-matrix oracle drifted for ${label}`,\n140:     );\n141:   }\n142: });\n143: \n144: test('the scaled vector and hybrid lanes are genuinely exercised', async (context) => {\n145:   const fixture = await materializeReplayCorpus(REPLAY_SCALES['10x']);\n146:   context.after(fixture.cleanup);\n147:   const database = await buildScaledOracleDatabase(fixture.root);\n148:   context.after(() => database.close());\n149: \n150:   const vectorOnly = queryPersistentStyles(scenarioRequest('vector-only'), { database });\n151:   assert.equal(vectorOnly.channelHealth.vector.state, 'healthy');\n152:   assert.ok(vectorOnly.cards.length > 0, 'vector-only must rank cards from drained vectors at scale');\n153: \n154:   const hybrid = queryPersistentStyles(scenarioRequest('hybrid'), { database });\n155:   assert.equal(hybrid.rankingMode, 'hybrid');\n156:   assert.equal(hybrid.degraded, false);\n157: });\n\n(End of file - total 157 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Differential Oracle Tests                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { mkdtemp, readFile, rm, writeFile } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { stableJson } from '../canonical.mjs';\nimport {\n  DEFAULT_GOLDEN_DIR,\n  buildOracleDatabase,\n  canonicalizeSnapshot,\n  captureOracle,\n  freezeOracle,\n  listGoldenScenarios,\n  replayOracle,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Differential Oracle Tests                                                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport assert from 'node:assert/strict';\nimport { mkdtemp, readFile, rm, writeFile } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport test from 'node:test';\n\nimport { createFixtureCorpus } from '../../_engine/__tests__/fixtures.mjs';\nimport { stableJson } from '../canonical.mjs';\nimport {\n  DEFAULT_GOLDEN_DIR,\n  buildOracleDatabase,\n  canonicalizeSnapshot,\n  captureOracle,\n  freezeOracle,\n  listGoldenScenarios,\n  replayOracle,\n  snapshotScenario,\n} from '../oracle/differential-oracle.mjs';\nimport { ORACLE_QUERY_SET } from '../oracle/query-set.mjs';\nimport {\n  REPLAY_SCALES,\n  buildScaledOracleDatabase,\n  captureScaleOracle,\n  materializeReplayCorpus,\n} from '../oracle/replay-fixtures.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\n\nasync function goldenScratch() {\n  return mkdtemp(path.join(os.tmpdir(), 'style-oracle-golden-'));\n}\n\nasync function loadScaleGolden() {\n  return JSON.parse(await readFile(path.join(DEFAULT_GOLDEN_DIR, 'scales.json'), 'utf8'));\n}\n\nfunction scenarioRequest(name) {\n  return ORACLE_QUERY_SET.find((scenario) => scenario.name === name).request;\n}\n\ntest('replay reproduces the committed golden bytes for every scenario', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const outcome = await replayOracle({ database });\n  assert.equal(outcome.ok, true, JSON.stringify(outcome.mismatches));\n  assert.equal(outcome.captures.length, ORACLE_QUERY_SET.length);\n});\n\ntest('freeze then replay round-trips in an isolated golden directory', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const goldenDir = await goldenScratch();\n  context.after(() => rm(goldenDir, { recursive: true, force: true }));\n\n  const frozen = await freezeOracle({ database, goldenDir });\n  assert.equal(frozen.length, ORACLE_QUERY_SET.length);\n  assert.deepEqual(await listGoldenScenarios(goldenDir), ORACLE_QUERY_SET.map((s) => s.name).sort());\n\n  const replay = await replayOracle({ database, goldenDir });\n  assert.equal(replay.ok, true, JSON.stringify(replay.mismatches));\n});\n\ntest('a byte perturbation in a golden file fails the oracle', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const goldenDir = await goldenScratch();\n  context.after(() => rm(goldenDir, { recursive: true, force: true }));\n\n  await freezeOracle({ database, goldenDir });\n  const targetPath = path.join(goldenDir, 'fts-text.canonical.json');\n  const original = await readFile(targetPath, 'utf8');\n  await writeFile(targetPath, original.replace('\"ok\":true', '\"ok\":false'));\n\n  const replay = await replayOracle({ database, goldenDir });\n  assert.equal(replay.ok, false);\n  assert.deepEqual(replay.mismatches, [{ name: 'fts-text', reason: 'byte-mismatch', sha256: replay.captures.find((c) => c.name === 'fts-text').sha256 }]);\n});\n\ntest('a missing golden file is reported rather than silently passing', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const goldenDir = await goldenScratch();\n  context.after(() => rm(goldenDir, { recursive: true, force: true }));\n\n  const replay = await replayOracle({ database, goldenDir });\n  assert.equal(replay.ok, false);\n  assert.equal(replay.mismatches.length, ORACLE_QUERY_SET.length);\n  assert.ok(replay.mismatches.every((mismatch) => mismatch.reason === 'missing-golden'));\n});\n\ntest('an ordering or tie-break change alters the canonical bytes', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const scenario = ORACLE_QUERY_SET.find((entry) => entry.name === 'structured-only');\n  const snapshot = snapshotScenario(database, scenario);\n  const canonical = canonicalizeSnapshot(snapshot);\n  const perturbed = {\n    ...snapshot,\n    result: { ...snapshot.result, cards: [...snapshot.result.cards].reverse() },\n  };\n  assert.notEqual(stableJson(perturbed), canonical.canonical);\n  assert.ok(snapshot.result.cards.length >= 2, 'perturbation requires at least two cards');\n});\n\ntest('every capture reuses the shared canonicalizer for a stable digest', async (context) => {\n  const fixture = await createFixtureCorpus();\n  context.after(fixture.cleanup);\n  const database = await buildOracleDatabase({ corpusRoot: fixture.root });\n  context.after(() => database.close());\n  const first = captureOracle(database);\n  const second = captureOracle(database);\n  assert.deepEqual(first.map((c) => c.sha256), second.map((c) => c.sha256));\n  for (const capture of first) {\n    assert.ok(capture.sha256.startsWith('sha256:'));\n  }\n});\n\ntest('the full oracle matrix replays with drained vectors at every replay scale', async (context) => {\n  const golden = await loadScaleGolden();\n  for (const [label, count] of Object.entries(REPLAY_SCALES)) {\n    const fixture = await materializeReplayCorpus(count);\n    context.after(fixture.cleanup);\n    assert.equal(\n      await captureScaleOracle(fixture.root),\n      golden.scales[label].oracleHash,\n      `full-matrix oracle drifted for ${label}`,\n    );\n  }\n});\n\ntest('the scaled vector and hybrid lanes are genuinely exercised', async (context) => {\n  const fixture = await materializeReplayCorpus(REPLAY_SCALES['10x']);\n  context.after(fixture.cleanup);\n  const database = await buildScaledOracleDatabase(fixture.root);\n  context.after(() => database.close());\n\n  const vectorOnly = queryPersistentStyles(scenarioRequest('vector-only'), { database });\n  assert.equal(vectorOnly.channelHealth.vector.state, 'healthy');\n  assert.ok(vectorOnly.cards.length > 0, 'vector-only must rank cards from drained vectors at scale');\n\n  const hybrid = queryPersistentStyles(scenarioRequest('hybrid'), { database });\n  assert.equal(hybrid.rankingMode, 'hybrid');\n  assert.equal(hybrid.degraded, false);\n});","lineStart":1,"lineEnd":157,"totalLines":157,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/__tests__/oracle.test.mjs","time":{"start":1784606421229,"end":1784606421235}},"id":"prt_f82d4f0eb00113GvVQDcj24QSh","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d4cf25001CvF9YlFshjndNd"}}
{"type":"tool_use","timestamp":1784606421805,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d4ef087a118f7fea0b","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Pinned Differential Oracle                                              ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // Freeze the current retrieval/index output as canonical golden bytes, then\n6: // replay it byte-for-byte after any later change. Snapshots run through the same\n7: // shared canonicalizer production uses, so a golden file can never encode a\n8: // serialization the live code would not emit. Freezing happens before any\n9: // downstream phase touches retrieval, giving every subsequent change a stable,\n10: // pre-change reference to diff against.\n11: \n12: import { mkdir, readFile, readdir, writeFile } from 'node:fs/promises';\n13: import path from 'node:path';\n14: import { fileURLToPath } from 'node:url';\n15: \n16: import { digest, stableJson } from '../canonical.mjs';\n17: import { indexStyleCorpus } from '../indexer.mjs';\n18: import { queryPersistentStyles } from '../retrieval.mjs';\n19: import { openStyleDatabase } from '../schema.mjs';\n20: import { drainVectorQueue } from '../vectors.mjs';\n21: import { ORACLE_QUERY_SET, ORACLE_VECTOR_PROFILE, oracleEmbedder } from './query-set.mjs';\n22: \n23: export const DEFAULT_GOLDEN_DIR = path.join(path.dirname(fileURLToPath(import.meta.url)), 'golden');\n24: \n25: const VECTOR_DRAIN_BATCH = 100;\n26: \n27: /**\n28:  * Index a corpus and drain deterministic vectors into a query-ready database.\n29:  *\n30:  * The queue drains in bounded batches until it is empty so every active style\n31:  * is embedded, not just the first batch — a small fixture and a large scaled\n32:  * corpus both reach full vector coverage before the vector lane is queried.\n33:  *\n34:  * @param {Object} options - Build inputs.\n35:  * @param {string} options.corpusRoot - Authoritative corpus root.\n36:  * @param {import('node:sqlite').DatabaseSync} [options.database] - Existing connection.\n37:  * @param {boolean} [options.embed=true] - Drain deterministic vectors.\n38:  * @param {Function} [options.embedder=oracleEmbedder] - Deterministic text-to-vector callback.\n39:  * @returns {Promise<import('node:sqlite').DatabaseSync>} Ready database.\n40:  */\n41: export async function buildOracleDatabase({\n42:   corpusRoot,\n43:   database,\n44:   embed = true,\n45:   embedder = oracleEmbedder,\n46: }) {\n47:   const connection = database ?? openStyleDatabase();\n48:   await indexStyleCorpus({\n49:     corpusRoot,\n50:     database: connection,\n51:     corpusWalkMode: 'migration',\n52:     embeddingProfile: ORACLE_VECTOR_PROFILE,\n53:   });\n54:   if (embed) {\n55:     let drained;\n56:     do {\n57:       drained = await drainVectorQueue(connection, {\n58:         profileId: ORACLE_VECTOR_PROFILE.id,\n59:         embedder: async (text) => embedder(text),\n60:         limit: VECTOR_DRAIN_BATCH,\n61:       });\n62:     } while (drained.attempted > 0);\n63:   }\n64:   return connection;\n65: }\n66: \n67: /**\n68:  * Run one scenario, including its optional cursor follow-up.\n69:  *\n70:  * @param {import('node:sqlite').DatabaseSync} database - Query database.\n71:  * @param {Object} scenario - Query-set scenario.\n72:  * @returns {Object} Ordered snapshot of the scenario's outputs.\n73:  */\n74: export function snapshotScenario(database, scenario) {\n75:   const result = queryPersistentStyles(scenario.request, { database });\n76:   const snapshot = { name: scenario.name, request: scenario.request, result };\n77:   if (typeof scenario.follow === 'function' && result.nextCursor) {\n78:     snapshot.follow = queryPersistentStyles(scenario.follow(result), { database });\n79:   }\n80:   return snapshot;\n81: }\n82: \n83: /**\n84:  * Canonicalize a scenario snapshot into golden bytes and a digest.\n85:  *\n86:  * @param {Object} snapshot - Scenario snapshot.\n87:  * @returns {{name:string, canonical:string, sha256:string}} Canonical capture.\n88:  */\n89: export function canonicalizeSnapshot(snapshot) {\n90:   const canonical = stableJson(snapshot);\n91:   return { name: snapshot.name, canonical, sha256: digest(canonical) };\n92: }\n93: \n94: /**\n95:  * Capture the whole query matrix as canonical captures.\n96:  *\n97:  * @param {import('node:sqlite').DatabaseSync} database - Query database.\n98:  * @param {Object[]} [querySet=ORACLE_QUERY_SET] - Scenarios to capture.\n99:  * @returns {Array<{name:string, canonical:string, sha256:string}>} Captures.\n100:  */\n101: export function captureOracle(database, querySet = ORACLE_QUERY_SET) {\n102:   return querySet.map((scenario) => canonicalizeSnapshot(snapshotScenario(database, scenario)));\n103: }\n104: \n105: function goldenPathFor(goldenDir, name) {\n106:   return path.join(goldenDir, `${name}.canonical.json`);\n107: }\n108: \n109: /**\n110:  * Freeze the query matrix as canonical golden bytes on disk.\n111:  *\n112:  * @param {Object} options - Freeze inputs.\n113:  * @param {import('node:sqlite').DatabaseSync} options.database - Query database.\n114:  * @param {string} [options.goldenDir=DEFAULT_GOLDEN_DIR] - Golden output directory.\n115:  * @param {Object[]} [options.querySet=ORACLE_QUERY_SET] - Scenarios to freeze.\n116:  * @returns {Promise<Array>} The captures written.\n117:  */\n118: export async function freezeOracle({ database, goldenDir = DEFAULT_GOLDEN_DIR, querySet = ORACLE_QUERY_SET }) {\n119:   const captures = captureOracle(database, querySet);\n120:   await mkdir(goldenDir, { recursive: true });\n121:   const index = { version: 1, scenarios: captures.map(({ name, sha256 }) => ({ name, sha256 })) };\n122:   await writeFile(path.join(goldenDir, 'index.json'), `${JSON.stringify(index, null, 2)}\\n`);\n123:   for (const capture of captures) {\n124:     await writeFile(goldenPathFor(goldenDir, capture.name), `${capture.canonical}\\n`);\n125:   }\n126:   return captures;\n127: }\n128: \n129: /**\n130:  * Replay the query matrix and assert byte-for-byte parity with the golden set.\n131:  *\n132:  * @param {Object} options - Replay inputs.\n133:  * @param {import('node:sqlite').DatabaseSync} options.database - Query database.\n134:  * @param {string} [options.goldenDir=DEFAULT_GOLDEN_DIR] - Golden directory.\n135:  * @param {Object[]} [options.querySet=ORACLE_QUERY_SET] - Scenarios to replay.\n136:  * @returns {Promise<{ok:boolean, mismatches:Object[], captures:Array}>} Replay outcome.\n137:  */\n138: export async function replayOracle({ database, goldenDir = DEFAULT_GOLDEN_DIR, querySet = ORACLE_QUERY_SET }) {\n139:   const captures = captureOracle(database, querySet);\n140:   const mismatches = [];\n141:   for (const capture of captures) {\n142:     let golden;\n143:     try {\n144:       golden = await readFile(goldenPathFor(goldenDir, capture.name), 'utf8');\n145:     } catch {\n146:       mismatches.push({ name: capture.name, reason: 'missing-golden' });\n147:       continue;\n148:     }\n149:     if (golden !== `${capture.canonical}\\n`) {\n150:       mismatches.push({ name: capture.name, reason: 'byte-mismatch', sha256: capture.sha256 });\n151:     }\n152:   }\n153:   return { ok: mismatches.length === 0, mismatches, captures };\n154: }\n155: \n156: /**\n157:  * List the scenario names a golden directory currently pins.\n158:  *\n159:  * @param {string} [goldenDir=DEFAULT_GOLDEN_DIR] - Golden directory.\n160:  * @returns {Promise<string[]>} Sorted scenario names.\n161:  */\n162: export async function listGoldenScenarios(goldenDir = DEFAULT_GOLDEN_DIR) {\n163:   const entries = await readdir(goldenDir).catch(() => []);\n164:   return entries.filter((name) => name.endsWith('.canonical.json'))\n165:     .map((name) => name.replace('.canonical.json', ''))\n166:     .sort();\n167: }\n\n(End of file - total 167 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Pinned Differential Oracle                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Freeze the current retrieval/index output as canonical golden bytes, then\n// replay it byte-for-byte after any later change. Snapshots run through the same\n// shared canonicalizer production uses, so a golden file can never encode a\n// serialization the live code would not emit. Freezing happens before any\n// downstream phase touches retrieval, giving every subsequent change a stable,\n// pre-change reference to diff against.\n\nimport { mkdir, readFile, readdir, writeFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { digest, stableJson } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\nimport { drainVectorQueue } from '../vectors.mjs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Pinned Differential Oracle                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Freeze the current retrieval/index output as canonical golden bytes, then\n// replay it byte-for-byte after any later change. Snapshots run through the same\n// shared canonicalizer production uses, so a golden file can never encode a\n// serialization the live code would not emit. Freezing happens before any\n// downstream phase touches retrieval, giving every subsequent change a stable,\n// pre-change reference to diff against.\n\nimport { mkdir, readFile, readdir, writeFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { digest, stableJson } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\nimport { drainVectorQueue } from '../vectors.mjs';\nimport { ORACLE_QUERY_SET, ORACLE_VECTOR_PROFILE, oracleEmbedder } from './query-set.mjs';\n\nexport const DEFAULT_GOLDEN_DIR = path.join(path.dirname(fileURLToPath(import.meta.url)), 'golden');\n\nconst VECTOR_DRAIN_BATCH = 100;\n\n/**\n * Index a corpus and drain deterministic vectors into a query-ready database.\n *\n * The queue drains in bounded batches until it is empty so every active style\n * is embedded, not just the first batch — a small fixture and a large scaled\n * corpus both reach full vector coverage before the vector lane is queried.\n *\n * @param {Object} options - Build inputs.\n * @param {string} options.corpusRoot - Authoritative corpus root.\n * @param {import('node:sqlite').DatabaseSync} [options.database] - Existing connection.\n * @param {boolean} [options.embed=true] - Drain deterministic vectors.\n * @param {Function} [options.embedder=oracleEmbedder] - Deterministic text-to-vector callback.\n * @returns {Promise<import('node:sqlite').DatabaseSync>} Ready database.\n */\nexport async function buildOracleDatabase({\n  corpusRoot,\n  database,\n  embed = true,\n  embedder = oracleEmbedder,\n}) {\n  const connection = database ?? openStyleDatabase();\n  await indexStyleCorpus({\n    corpusRoot,\n    database: connection,\n    corpusWalkMode: 'migration',\n    embeddingProfile: ORACLE_VECTOR_PROFILE,\n  });\n  if (embed) {\n    let drained;\n    do {\n      drained = await drainVectorQueue(connection, {\n        profileId: ORACLE_VECTOR_PROFILE.id,\n        embedder: async (text) => embedder(text),\n        limit: VECTOR_DRAIN_BATCH,\n      });\n    } while (drained.attempted > 0);\n  }\n  return connection;\n}\n\n/**\n * Run one scenario, including its optional cursor follow-up.\n *\n * @param {import('node:sqlite').DatabaseSync} database - Query database.\n * @param {Object} scenario - Query-set scenario.\n * @returns {Object} Ordered snapshot of the scenario's outputs.\n */\nexport function snapshotScenario(database, scenario) {\n  const result = queryPersistentStyles(scenario.request, { database });\n  const snapshot = { name: scenario.name, request: scenario.request, result };\n  if (typeof scenario.follow === 'function' && result.nextCursor) {\n    snapshot.follow = queryPersistentStyles(scenario.follow(result), { database });\n  }\n  return snapshot;\n}\n\n/**\n * Canonicalize a scenario snapshot into golden bytes and a digest.\n *\n * @param {Object} snapshot - Scenario snapshot.\n * @returns {{name:string, canonical:string, sha256:string}} Canonical capture.\n */\nexport function canonicalizeSnapshot(snapshot) {\n  const canonical = stableJson(snapshot);\n  return { name: snapshot.name, canonical, sha256: digest(canonical) };\n}\n\n/**\n * Capture the whole query matrix as canonical captures.\n *\n * @param {import('node:sqlite').DatabaseSync} database - Query database.\n * @param {Object[]} [querySet=ORACLE_QUERY_SET] - Scenarios to capture.\n * @returns {Array<{name:string, canonical:string, sha256:string}>} Captures.\n */\nexport function captureOracle(database, querySet = ORACLE_QUERY_SET) {\n  return querySet.map((scenario) => canonicalizeSnapshot(snapshotScenario(database, scenario)));\n}\n\nfunction goldenPathFor(goldenDir, name) {\n  return path.join(goldenDir, `${name}.canonical.json`);\n}\n\n/**\n * Freeze the query matrix as canonical golden bytes on disk.\n *\n * @param {Object} options - Freeze inputs.\n * @param {import('node:sqlite').DatabaseSync} options.database - Query database.\n * @param {string} [options.goldenDir=DEFAULT_GOLDEN_DIR] - Golden output directory.\n * @param {Object[]} [options.querySet=ORACLE_QUERY_SET] - Scenarios to freeze.\n * @returns {Promise<Array>} The captures written.\n */\nexport async function freezeOracle({ database, goldenDir = DEFAULT_GOLDEN_DIR, querySet = ORACLE_QUERY_SET }) {\n  const captures = captureOracle(database, querySet);\n  await mkdir(goldenDir, { recursive: true });\n  const index = { version: 1, scenarios: captures.map(({ name, sha256 }) => ({ name, sha256 })) };\n  await writeFile(path.join(goldenDir, 'index.json'), `${JSON.stringify(index, null, 2)}\\n`);\n  for (const capture of captures) {\n    await writeFile(goldenPathFor(goldenDir, capture.name), `${capture.canonical}\\n`);\n  }\n  return captures;\n}\n\n/**\n * Replay the query matrix and assert byte-for-byte parity with the golden set.\n *\n * @param {Object} options - Replay inputs.\n * @param {import('node:sqlite').DatabaseSync} options.database - Query database.\n * @param {string} [options.goldenDir=DEFAULT_GOLDEN_DIR] - Golden directory.\n * @param {Object[]} [options.querySet=ORACLE_QUERY_SET] - Scenarios to replay.\n * @returns {Promise<{ok:boolean, mismatches:Object[], captures:Array}>} Replay outcome.\n */\nexport async function replayOracle({ database, goldenDir = DEFAULT_GOLDEN_DIR, querySet = ORACLE_QUERY_SET }) {\n  const captures = captureOracle(database, querySet);\n  const mismatches = [];\n  for (const capture of captures) {\n    let golden;\n    try {\n      golden = await readFile(goldenPathFor(goldenDir, capture.name), 'utf8');\n    } catch {\n      mismatches.push({ name: capture.name, reason: 'missing-golden' });\n      continue;\n    }\n    if (golden !== `${capture.canonical}\\n`) {\n      mismatches.push({ name: capture.name, reason: 'byte-mismatch', sha256: capture.sha256 });\n    }\n  }\n  return { ok: mismatches.length === 0, mismatches, captures };\n}\n\n/**\n * List the scenario names a golden directory currently pins.\n *\n * @param {string} [goldenDir=DEFAULT_GOLDEN_DIR] - Golden directory.\n * @returns {Promise<string[]>} Sorted scenario names.\n */\nexport async function listGoldenScenarios(goldenDir = DEFAULT_GOLDEN_DIR) {\n  const entries = await readdir(goldenDir).catch(() => []);\n  return entries.filter((name) => name.endsWith('.canonical.json'))\n    .map((name) => name.replace('.canonical.json', ''))\n    .sort();\n}","lineStart":1,"lineEnd":167,"totalLines":167,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs","time":{"start":1784606421799,"end":1784606421803}},"id":"prt_f82d4f0ee001XhQqTkI5V9O0Px","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d4cf25001CvF9YlFshjndNd"}}
{"type":"step_finish","timestamp":1784606422200,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"id":"prt_f82d4f4b60014ZX8dtAPTQJwxz","reason":"tool-calls","snapshot":"f4ff26001c2c69cb83e93443d6b29fbb30affd7f","messageID":"msg_f82d4cf25001CvF9YlFshjndNd","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","type":"step-finish","tokens":{"total":127616,"input":3420,"output":676,"reasoning":0,"cache":{"write":0,"read":123520}},"cost":0.0092484}}
{"type":"step_start","timestamp":1784606424821,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"id":"prt_f82d4fef4001tQQ1uY372yNuEn","messageID":"msg_f82d4f640001OwWs1nKh6Tu3py","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","snapshot":"f4ff26001c2c69cb83e93443d6b29fbb30affd7f","type":"step-start"}}
{"type":"tool_use","timestamp":1784606425869,"sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","part":{"type":"tool","tool":"read","callID":"call_019f82d502197bb18a972b7b","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/query-set.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/query-set.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Fixed Oracle Query Matrix                                               ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // A frozen matrix of retrieval requests that exercises each ranking path the\n6: // differential oracle must pin: structured-only, lexical FTS, facet filtering,\n7: // exclusions, vector-only, hybrid, channel-local degradation, exact-reuse\n8: // rights, and cursor pagination. The embedder is deterministic so the vector\n9: // lane reproduces byte-for-byte without a real embedding model.\n10: \n11: export const ORACLE_VECTOR_PROFILE = Object.freeze({\n12:   id: 'style-default-v1',\n13:   provider: 'external',\n14:   model: 'configured',\n15:   dimensions: 2,\n16:   configHash: 'style-default-v1',\n17: });\n18: \n19: /**\n20:  * Deterministically embed document text into a fixed two-dimensional vector.\n21:  *\n22:  * @param {string} text - Document text passed by the vector drain.\n23:  * @returns {number[]} A stable unit-basis vector.\n24:  */\n25: export function oracleEmbedder(text) {\n26:   return text.includes('Alpha Editorial') ? [1, 0] : [0, 1];\n27: }\n28: \n29: export const ORACLE_QUERY_SET = Object.freeze([\n30:   { name: 'structured-only', request: { text: '', requiredFacets: [] } },\n31:   { name: 'fts-text', request: { text: 'editorial serif' } },\n32:   { name: 'facet-filter', request: { text: 'motion animation transition kinetic', requiredFacets: ['warm-surface'] } },\n33:   { name: 'exclusions', request: { text: 'editorial serif interface', exclusions: ['motion'] } },\n34:   { name: 'vector-only', request: { queryVector: [1, 0], vectorProfile: 'style-default-v1', disableFts: true } },\n35:   { name: 'hybrid', request: { text: 'editorial serif', queryVector: [1, 0], vectorProfile: 'style-default-v1' } },\n36:   { name: 'degraded-disable-fts', request: { text: 'editorial serif', disableFts: true } },\n37:   { name: 'exact-reuse', request: { text: 'editorial', usage: 'exact-reuse' } },\n38:   {\n39:     name: 'paged',\n40:     request: { text: 'style reference', limit: 1 },\n41:     follow: (result) => ({ text: 'style reference', limit: 1, cursor: result.nextCursor }),\n42:   },\n43: ]);\n\n(End of file - total 43 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Fixed Oracle Query Matrix                                               ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// A frozen matrix of retrieval requests that exercises each ranking path the\n// differential oracle must pin: structured-only, lexical FTS, facet filtering,\n// exclusions, vector-only, hybrid, channel-local degradation, exact-reuse\n// rights, and cursor pagination. The embedder is deterministic so the vector\n// lane reproduces byte-for-byte without a real embedding model.\n\nexport const ORACLE_VECTOR_PROFILE = Object.freeze({\n  id: 'style-default-v1',\n  provider: 'external',\n  model: 'configured',\n  dimensions: 2,\n  configHash: 'style-default-v1',\n});\n\n/**\n * Deterministically embed document text into a fixed two-dimensional vector.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/query-set.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Fixed Oracle Query Matrix                                               ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// A frozen matrix of retrieval requests that exercises each ranking path the\n// differential oracle must pin: structured-only, lexical FTS, facet filtering,\n// exclusions, vector-only, hybrid, channel-local degradation, exact-reuse\n// rights, and cursor pagination. The embedder is deterministic so the vector\n// lane reproduces byte-for-byte without a real embedding model.\n\nexport const ORACLE_VECTOR_PROFILE = Object.freeze({\n  id: 'style-default-v1',\n  provider: 'external',\n  model: 'configured',\n  dimensions: 2,\n  configHash: 'style-default-v1',\n});\n\n/**\n * Deterministically embed document text into a fixed two-dimensional vector.\n *\n * @param {string} text - Document text passed by the vector drain.\n * @returns {number[]} A stable unit-basis vector.\n */\nexport function oracleEmbedder(text) {\n  return text.includes('Alpha Editorial') ? [1, 0] : [0, 1];\n}\n\nexport const ORACLE_QUERY_SET = Object.freeze([\n  { name: 'structured-only', request: { text: '', requiredFacets: [] } },\n  { name: 'fts-text', request: { text: 'editorial serif' } },\n  { name: 'facet-filter', request: { text: 'motion animation transition kinetic', requiredFacets: ['warm-surface'] } },\n  { name: 'exclusions', request: { text: 'editorial serif interface', exclusions: ['motion'] } },\n  { name: 'vector-only', request: { queryVector: [1, 0], vectorProfile: 'style-default-v1', disableFts: true } },\n  { name: 'hybrid', request: { text: 'editorial serif', queryVector: [1, 0], vectorProfile: 'style-default-v1' } },\n  { name: 'degraded-disable-fts', request: { text: 'editorial serif', disableFts: true } },\n  { name: 'exact-reuse', request: { text: 'editorial', usage: 'exact-reuse' } },\n  {\n    name: 'paged',\n    request: { text: 'style reference', limit: 1 },\n    follow: (result) => ({ text: 'style reference', limit: 1, cursor: result.nextCursor }),\n  },\n]);","lineStart":1,"lineEnd":43,"totalLines":43,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/oracle/query-set.mjs","time":{"start":1784606425863,"end":1784606425868}},"id":"prt_f82d502a9001ZuLoEbVpfdjAUq","sessionID":"ses_07d2d665dffedyOb0L7GbCTElX","messageID":"msg_f82d4f640001OwWs1nKh6Tu3py"}}
