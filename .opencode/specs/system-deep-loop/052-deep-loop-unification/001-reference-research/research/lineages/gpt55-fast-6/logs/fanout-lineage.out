name.endsWith('.md') ? [path] : [];\n  }).sort();\n}\n\nfunction walkVitest(dir: string): string[] {\n  return readdirSync(dir, { withFileTypes: true }).flatMap((entry) => {\n    const path = join(dir, entry.name);\n    if (entry.isDirectory()) return walkVitest(path);\n    return entry.isFile() && entry.name.endsWith('.vitest.ts') ? [path] : [];\n  }).sort();\n}\n\nfunction resolveTestReference(reference: string): string {\n  const normalizedReference = RENAMED_TEST_REFERENCES[reference] ?? reference;\n  if (normalizedReference === 'mcp_server/tests/scorer/native-scorer.vitest.ts') {\n    return join(SKILL_ADVISOR_TEST_ROOT, 'scorer/native-scorer.vitest.ts');\n  }\n  const withoutSkillPrefix = normalizedReference.replace(/^\\.opencode\\/skills\\/system-spec-kit\\//, '');\n  if (withoutSkillPrefix.startsWith('mcp_server/tests/')) {\n    return join(WORKSPACE_ROOT, '.opencode/skills/system-spec-kit', withoutSkillPrefix);\n  }\n  if (withoutSkillPrefix.startsWith('scripts/tests/')) {\n    return join(WORKSPACE_ROOT, '.opencode/skills/system-spec-kit', withoutSkillPrefix);\n  }\n  if (withoutSkillPrefix.startsWith('../scripts/tests/')) {\n    return resolve(MCP_SERVER_ROOT, withoutSkillPrefix);\n  }\n  if (normalizedReference.startsWith('.opencode/skills/deep-loop-runtime/tests/')) {\n    return join(WORKSPACE_ROOT, normalizedReference);\n  }\n  return join(WORKSPACE_ROOT, reference);\n}\n\nfunction read(path: string): string {\n  return readFileSync(path, 'utf8').replace(/\\r\\n/g, '\\n');\n}\n\nfunction extractStaticTestNames(source: string): Set<string> {\n  const names = new Set<string>();\n  for (const match of source.matchAll(TEST_CALL)) {\n    const name = match[1] ?? match[2] ?? match[3];\n    if (name) names.add(name);\n  }\n  return names;\n}\n\ndescribe('council playbook anchor integrity', () => {\n  it('every playbook anchor resolves to a real vitest test file and test name', () => {\n    const playbookFiles = walkMarkdown(PLAYBOOK_ROOT);\n    const availableTests = new Set([\n      ...walkVitest(join(MCP_SERVER_ROOT, 'tests')),\n      ...walkVitest(resolve(MCP_SERVER_ROOT, '../scripts/tests')),\n      ...walkVitest(SKILL_ADVISOR_TEST_ROOT),\n      ...walkVitest(DEEP_LOOP_RUNTIME_TEST_ROOT),","lineStart":1,"lineEnd":90,"totalLines":125,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/council-playbook-anchor-integrity.vitest.ts","time":{"start":1783487034782,"end":1783487034785}},"metadata":{"openai":{"itemId":"fc_01c3392baf414ff6016a4dda3ab3a48191bd14761a9b9841c0"}},"id":"prt_f401c75760015olyTe8R0AJ7r1","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f401c35aa001WAJ74AnWRLq08S"}}
{"type":"tool_use","timestamp":1783487034827,"sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","part":{"type":"tool","tool":"read","callID":"call_l5lqareBFaoW68RnCoVK6pL8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memory-runtime-retention.vitest.ts","offset":1,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memory-runtime-retention.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST: Memory Runtime Retention Stress Fixtures\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { existsSync, mkdtempSync, rmSync, writeFileSync } from 'node:fs';\n6: import { join } from 'node:path';\n7: import { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n8: \n9: import { acquireLoopLock, releaseLoopLock } from '../../../deep-loop-runtime/lib/deep-loop/loop-lock.js';\n10: import { BoundedMap, TtlMap } from '../lib/memory/bounded-cache.js';\n11: import { listRotatedAuditFiles, rotateIfNeeded } from '../lib/memory/audit-rotation.js';\n12: import { clearAllTimers, getRegisteredTimerCount, registerInterval } from '../lib/runtime/timer-registry.js';\n13: import { clearShutdownHooksForTests, registerShutdownHook, runShutdownHooks } from '../lib/runtime/shutdown-hooks.js';\n14: \n15: class MemoryRuntimeWorkloadHarness {\n16:   readonly saveRouting = new BoundedMap<string, number>(50);\n17:   readonly searchSessions = new TtlMap<string, string[]>(25);\n18:   readonly indexJobs = new BoundedMap<string, { state: string }>(10);\n19:   saveCalls = 0;\n20:   searchCalls = 0;\n21:   indexCalls = 0;\n22: \n23:   save(index: number): void {\n24:     this.saveCalls += 1;\n25:     this.saveRouting.set(`save-${index}`, index);\n26:   }\n27: \n28:   search(index: number): void {\n29:     this.searchCalls += 1;\n30:     this.searchSessions.set(`session-${index}`, [`result-${index}`], 60_000);\n31:   }\n32: \n33:   index(index: number): void {\n34:     this.indexCalls += 1;\n35:     this.indexJobs.set(`job-${index}`, { state: 'queued' });\n36:   }\n37: }\n38: \n39: describe('memory runtime retention stress fixtures', () => {\n40:   let tmpDir: string;\n41: \n42:   beforeEach(() => {\n43:     tmpDir = mkdtempSync(join('/private/tmp', 'memory-runtime-retention-'));\n44:   });\n45: \n46:   afterEach(() => {\n47:     clearAllTimers();\n48:     clearShutdownHooksForTests();\n49:     vi.useRealTimers();\n50:     rmSync(tmpDir, { recursive: true, force: true });\n51:   });\n52: \n53:   it('bounds save/search/index workload retention state under concurrent load', async () => {\n54:     const workload = new MemoryRuntimeWorkloadHarness();\n55:     const operations = 250;\n56: \n57:     await Promise.all(Array.from({ length: operations }, async (_value, index) => {\n58:       workload.save(index);\n59:       workload.search(index);\n60:       workload.index(index);\n61:     }));\n62: \n63:     expect(workload.saveCalls).toBe(operations);\n64:     expect(workload.searchCalls).toBe(operations);\n65:     expect(workload.indexCalls).toBe(operations);\n66:     expect(workload.saveRouting.size).toBe(50);\n67:     expect(workload.searchSessions.size).toBe(25);\n68:     expect(workload.indexJobs.size).toBe(10);\n69:   });\n70: \n71:   it('releases leases through shutdown hooks', async () => {\n72:     const lockPath = join(tmpDir, 'scan.lock');\n73:     const acquired = acquireLoopLock(lockPath, {\n74:       ownerPid: process.pid,\n75:       startedAtIso: new Date().toISOString(),\n76:       ttlMs: 1_000,\n77:       lastHeartbeatIso: new Date().toISOString(),\n78:       packetId: 'phase-009-test',\n79:       runtimeKind: 'main',\n80:     });\n\n(Showing lines 1-80 of 115. Use offset=81 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST: Memory Runtime Retention Stress Fixtures\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, mkdtempSync, rmSync, writeFileSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nimport { acquireLoopLock, releaseLoopLock } from '../../../deep-loop-runtime/lib/deep-loop/loop-lock.js';\nimport { BoundedMap, TtlMap } from '../lib/memory/bounded-cache.js';\nimport { listRotatedAuditFiles, rotateIfNeeded } from '../lib/memory/audit-rotation.js';\nimport { clearAllTimers, getRegisteredTimerCount, registerInterval } from '../lib/runtime/timer-registry.js';\nimport { clearShutdownHooksForTests, registerShutdownHook, runShutdownHooks } from '../lib/runtime/shutdown-hooks.js';\n\nclass MemoryRuntimeWorkloadHarness {\n  readonly saveRouting = new BoundedMap<string, number>(50);\n  readonly searchSessions = new TtlMap<string, string[]>(25);\n  readonly indexJobs = new BoundedMap<string, { state: string }>(10);\n  saveCalls = 0;\n  searchCalls = 0;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/memory-runtime-retention.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST: Memory Runtime Retention Stress Fixtures\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, mkdtempSync, rmSync, writeFileSync } from 'node:fs';\nimport { join } from 'node:path';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nimport { acquireLoopLock, releaseLoopLock } from '../../../deep-loop-runtime/lib/deep-loop/loop-lock.js';\nimport { BoundedMap, TtlMap } from '../lib/memory/bounded-cache.js';\nimport { listRotatedAuditFiles, rotateIfNeeded } from '../lib/memory/audit-rotation.js';\nimport { clearAllTimers, getRegisteredTimerCount, registerInterval } from '../lib/runtime/timer-registry.js';\nimport { clearShutdownHooksForTests, registerShutdownHook, runShutdownHooks } from '../lib/runtime/shutdown-hooks.js';\n\nclass MemoryRuntimeWorkloadHarness {\n  readonly saveRouting = new BoundedMap<string, number>(50);\n  readonly searchSessions = new TtlMap<string, string[]>(25);\n  readonly indexJobs = new BoundedMap<string, { state: string }>(10);\n  saveCalls = 0;\n  searchCalls = 0;\n  indexCalls = 0;\n\n  save(index: number): void {\n    this.saveCalls += 1;\n    this.saveRouting.set(`save-${index}`, index);\n  }\n\n  search(index: number): void {\n    this.searchCalls += 1;\n    this.searchSessions.set(`session-${index}`, [`result-${index}`], 60_000);\n  }\n\n  index(index: number): void {\n    this.indexCalls += 1;\n    this.indexJobs.set(`job-${index}`, { state: 'queued' });\n  }\n}\n\ndescribe('memory runtime retention stress fixtures', () => {\n  let tmpDir: string;\n\n  beforeEach(() => {\n    tmpDir = mkdtempSync(join('/private/tmp', 'memory-runtime-retention-'));\n  });\n\n  afterEach(() => {\n    clearAllTimers();\n    clearShutdownHooksForTests();\n    vi.useRealTimers();\n    rmSync(tmpDir, { recursive: true, force: true });\n  });\n\n  it('bounds save/search/index workload retention state under concurrent load', async () => {\n    const workload = new MemoryRuntimeWorkloadHarness();\n    const operations = 250;\n\n    await Promise.all(Array.from({ length: operations }, async (_value, index) => {\n      workload.save(index);\n      workload.search(index);\n      workload.index(index);\n    }));\n\n    expect(workload.saveCalls).toBe(operations);\n    expect(workload.searchCalls).toBe(operations);\n    expect(workload.indexCalls).toBe(operations);\n    expect(workload.saveRouting.size).toBe(50);\n    expect(workload.searchSessions.size).toBe(25);\n    expect(workload.indexJobs.size).toBe(10);\n  });\n\n  it('releases leases through shutdown hooks', async () => {\n    const lockPath = join(tmpDir, 'scan.lock');\n    const acquired = acquireLoopLock(lockPath, {\n      ownerPid: process.pid,\n      startedAtIso: new Date().toISOString(),\n      ttlMs: 1_000,\n      lastHeartbeatIso: new Date().toISOString(),\n      packetId: 'phase-009-test',\n      runtimeKind: 'main',\n    });","lineStart":1,"lineEnd":80,"totalLines":115,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/memory-runtime-retention.vitest.ts","time":{"start":1783487034822,"end":1783487034826}},"metadata":{"openai":{"itemId":"fc_01c3392baf414ff6016a4dda3ab3b88191a2fb7b42208c1c16"}},"id":"prt_f401c75b70018FHMMKu9sVwPLS","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f401c35aa001WAJ74AnWRLq08S"}}
{"type":"tool_use","timestamp":1783487034889,"sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","part":{"type":"tool","tool":"read","callID":"call_DpMe7lOdAkiu5DzVUCTJ6m4h","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/tests/deep-review-auto-restart-contract.vitest.ts","offset":1,"limit":70},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/tests/deep-review-auto-restart-contract.vitest.ts</path>\n<type>file</type>\n<content>\n1: import fs from 'node:fs';\n2: import path from 'node:path';\n3: import { fileURLToPath } from 'node:url';\n4: \n5: import { describe, expect, it } from 'vitest';\n6: \n7: const TEST_DIR = path.dirname(fileURLToPath(import.meta.url));\n8: const WORKSPACE_ROOT = path.resolve(TEST_DIR, '../../../../../');\n9: \n10: function readWorkspaceFile(relativePath: string): string {\n11:   return fs.readFileSync(path.join(WORKSPACE_ROOT, relativePath), 'utf8');\n12: }\n13: \n14: describe('deep-review auto restart command contract', () => {\n15:   it('exposes restart as a first-class auto setup input', () => {\n16:     const command = readWorkspaceFile('.opencode/commands/deep/review.md');\n17:     const presentation = readWorkspaceFile('.opencode/commands/deep/assets/deep_review_presentation.txt');\n18:     const autoWorkflow = readWorkspaceFile('.opencode/commands/deep/assets/deep_review_auto.yaml');\n19:     const fanoutRun = readWorkspaceFile('.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs');\n20: \n21:     expect(command).toContain('--restart|--lineage-mode=restart');\n22:     expect(command).toContain('--stop-policy=convergence|max-iterations');\n23:     expect(command).toContain('--fanout-lineage-artifact-dir');\n24:     expect(command).toContain('lineage_mode');\n25:     expect(command).toContain('stop_policy');\n26:     expect(command).toContain('Do not use the Task tool to spawn the general agent');\n27:     expect(command).toContain('Do not ask for a second confirmation');\n28:     expect(command).not.toContain('@general');\n29:     expect(command).not.toContain('@deep-review');\n30:     expect(presentation).toContain('lineage_mode: auto');\n31:     expect(presentation).toContain('| `lineage_mode` | Y |');\n32:     expect(presentation).toContain('| `stop_policy` | Y |');\n33:     expect(presentation).toContain('| `config.fanout_lineage_artifact_dir` | N |');\n34:     expect(presentation).toContain('|-- --restart -> lineage_mode = restart');\n35:     expect(presentation).toContain('|-- --stop-policy=convergence|max-iterations -> stop_policy = value');\n36:     expect(presentation).toContain('|-- --fanout-lineage-artifact-dir=PATH -> config.fanout_lineage_artifact_dir = PATH');\n37:     expect(presentation).toContain('A restart request must never silently downgrade to resume');\n38:     expect(presentation).toContain('an explicit `--restart` or `--lineage-mode=restart` flag is operator authorization');\n39:     expect(presentation).toContain('stop_policy=max-iterations');\n40:     expect(presentation).toContain('explicit parallel-detached OpenCode session');\n41:     expect(presentation).toContain('Native and CLI fan-out lineages run under `fanout-run.cjs`');\n42:     expect(presentation).toContain('calls the `deep/review` command with the internal `--fanout-lineage-artifact-dir` override');\n43:     expect(autoWorkflow).toContain('--convergence-threshold {convergence_threshold}');\n44:     expect(autoWorkflow).toContain('--stop-policy {stop_policy}');\n45:     expect(autoWorkflow).toContain('config.stopPolicy: {stop_policy}');\n46:     expect(autoWorkflow).toContain('config.fanout_lineage_artifact_dir: \"[optional internal path]');\n47:     expect(autoWorkflow).toContain('treat convergence signals as telemetry');\n48:     expect(autoWorkflow).toContain('the explicit restart flag is operator');\n49:     expect(autoWorkflow).toContain('A cli-opencode lineage inside this fan-out is an explicit parallel-detached OpenCode');\n50:     expect(autoWorkflow).toContain('fanout-run.cjs owns native and CLI lineage execution');\n51:     expect(autoWorkflow).toContain('deep/review command surface with config.fanout_lineage_artifact_dir');\n52:     expect(autoWorkflow).toContain('pasted phase-running prompt');\n53:     expect(autoWorkflow).not.toContain('step_fanout_spawn_native');\n54:     expect(autoWorkflow).toContain('this single-executor branch must only run from a non-OpenCode dispatch surface');\n55:     expect(fanoutRun).toContain('explicit parallel-detached OpenCode lineage');\n56:     expect(fanoutRun).toContain('buildNativeCommandInput');\n57:     expect(fanoutRun).toContain('--fanout-lineage-artifact-dir=');\n58:     expect(fanoutRun).toContain(\"'--command'\");\n59:     expect(fanoutRun).toContain('deep/review command surface');\n60:     expect(fanoutRun).toContain(\"if (kind === 'native')\");\n61:     expect(fanoutRun).toContain('const cliLineages = allLineages');\n62:     expect(fanoutRun).toContain('config.convergenceThreshold');\n63:     expect(fanoutRun).toContain('config.stopPolicy');\n64:     expect(fanoutRun).toContain('treat convergence before that as telemetry only');\n65:     expect(fanoutRun).toContain('findMaxIterationsPolicyViolation');\n66:     expect(fanoutRun).toContain('expected stopReason=maxIterationsReached');\n67:   });\n68: \n69:   it('applies restart before fan-out can spawn lineages', () => {\n70:     const autoWorkflow = readWorkspaceFile('.opencode/commands/deep/assets/deep_review_auto.yaml');\n\n(Showing lines 1-70 of 80. Use offset=71 to continue.)\n</content>","metadata":{"preview":"import fs from 'node:fs';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { describe, expect, it } from 'vitest';\n\nconst TEST_DIR = path.dirname(fileURLToPath(import.meta.url));\nconst WORKSPACE_ROOT = path.resolve(TEST_DIR, '../../../../../');\n\nfunction readWorkspaceFile(relativePath: string): string {\n  return fs.readFileSync(path.join(WORKSPACE_ROOT, relativePath), 'utf8');\n}\n\ndescribe('deep-review auto restart command contract', () => {\n  it('exposes restart as a first-class auto setup input', () => {\n    const command = readWorkspaceFile('.opencode/commands/deep/review.md');\n    const presentation = readWorkspaceFile('.opencode/commands/deep/assets/deep_review_presentation.txt');\n    const autoWorkflow = readWorkspaceFile('.opencode/commands/deep/assets/deep_review_auto.yaml');\n    const fanoutRun = readWorkspaceFile('.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs');\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/scripts/tests/deep-review-auto-restart-contract.vitest.ts","text":"import fs from 'node:fs';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { describe, expect, it } from 'vitest';\n\nconst TEST_DIR = path.dirname(fileURLToPath(import.meta.url));\nconst WORKSPACE_ROOT = path.resolve(TEST_DIR, '../../../../../');\n\nfunction readWorkspaceFile(relativePath: string): string {\n  return fs.readFileSync(path.join(WORKSPACE_ROOT, relativePath), 'utf8');\n}\n\ndescribe('deep-review auto restart command contract', () => {\n  it('exposes restart as a first-class auto setup input', () => {\n    const command = readWorkspaceFile('.opencode/commands/deep/review.md');\n    const presentation = readWorkspaceFile('.opencode/commands/deep/assets/deep_review_presentation.txt');\n    const autoWorkflow = readWorkspaceFile('.opencode/commands/deep/assets/deep_review_auto.yaml');\n    const fanoutRun = readWorkspaceFile('.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs');\n\n    expect(command).toContain('--restart|--lineage-mode=restart');\n    expect(command).toContain('--stop-policy=convergence|max-iterations');\n    expect(command).toContain('--fanout-lineage-artifact-dir');\n    expect(command).toContain('lineage_mode');\n    expect(command).toContain('stop_policy');\n    expect(command).toContain('Do not use the Task tool to spawn the general agent');\n    expect(command).toContain('Do not ask for a second confirmation');\n    expect(command).not.toContain('@general');\n    expect(command).not.toContain('@deep-review');\n    expect(presentation).toContain('lineage_mode: auto');\n    expect(presentation).toContain('| `lineage_mode` | Y |');\n    expect(presentation).toContain('| `stop_policy` | Y |');\n    expect(presentation).toContain('| `config.fanout_lineage_artifact_dir` | N |');\n    expect(presentation).toContain('|-- --restart -> lineage_mode = restart');\n    expect(presentation).toContain('|-- --stop-policy=convergence|max-iterations -> stop_policy = value');\n    expect(presentation).toContain('|-- --fanout-lineage-artifact-dir=PATH -> config.fanout_lineage_artifact_dir = PATH');\n    expect(presentation).toContain('A restart request must never silently downgrade to resume');\n    expect(presentation).toContain('an explicit `--restart` or `--lineage-mode=restart` flag is operator authorization');\n    expect(presentation).toContain('stop_policy=max-iterations');\n    expect(presentation).toContain('explicit parallel-detached OpenCode session');\n    expect(presentation).toContain('Native and CLI fan-out lineages run under `fanout-run.cjs`');\n    expect(presentation).toContain('calls the `deep/review` command with the internal `--fanout-lineage-artifact-dir` override');\n    expect(autoWorkflow).toContain('--convergence-threshold {convergence_threshold}');\n    expect(autoWorkflow).toContain('--stop-policy {stop_policy}');\n    expect(autoWorkflow).toContain('config.stopPolicy: {stop_policy}');\n    expect(autoWorkflow).toContain('config.fanout_lineage_artifact_dir: \"[optional internal path]');\n    expect(autoWorkflow).toContain('treat convergence signals as telemetry');\n    expect(autoWorkflow).toContain('the explicit restart flag is operator');\n    expect(autoWorkflow).toContain('A cli-opencode lineage inside this fan-out is an explicit parallel-detached OpenCode');\n    expect(autoWorkflow).toContain('fanout-run.cjs owns native and CLI lineage execution');\n    expect(autoWorkflow).toContain('deep/review command surface with config.fanout_lineage_artifact_dir');\n    expect(autoWorkflow).toContain('pasted phase-running prompt');\n    expect(autoWorkflow).not.toContain('step_fanout_spawn_native');\n    expect(autoWorkflow).toContain('this single-executor branch must only run from a non-OpenCode dispatch surface');\n    expect(fanoutRun).toContain('explicit parallel-detached OpenCode lineage');\n    expect(fanoutRun).toContain('buildNativeCommandInput');\n    expect(fanoutRun).toContain('--fanout-lineage-artifact-dir=');\n    expect(fanoutRun).toContain(\"'--command'\");\n    expect(fanoutRun).toContain('deep/review command surface');\n    expect(fanoutRun).toContain(\"if (kind === 'native')\");\n    expect(fanoutRun).toContain('const cliLineages = allLineages');\n    expect(fanoutRun).toContain('config.convergenceThreshold');\n    expect(fanoutRun).toContain('config.stopPolicy');\n    expect(fanoutRun).toContain('treat convergence before that as telemetry only');\n    expect(fanoutRun).toContain('findMaxIterationsPolicyViolation');\n    expect(fanoutRun).toContain('expected stopReason=maxIterationsReached');\n  });\n\n  it('applies restart before fan-out can spawn lineages', () => {\n    const autoWorkflow = readWorkspaceFile('.opencode/commands/deep/assets/deep_review_auto.yaml');","lineStart":1,"lineEnd":70,"totalLines":80,"truncated":true}},"title":".opencode/skills/system-spec-kit/scripts/tests/deep-review-auto-restart-contract.vitest.ts","time":{"start":1783487034885,"end":1783487034888}},"metadata":{"openai":{"itemId":"fc_01c3392baf414ff6016a4dda3ab3c48191bd5503128852caa7"}},"id":"prt_f401c75c8001IdYo34UmZH9oad","ses