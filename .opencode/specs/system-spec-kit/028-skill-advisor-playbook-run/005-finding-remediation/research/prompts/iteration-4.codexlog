    53	function bridgeStdioToSocket(socketPath, options = {}) {
    54	  const input = options.stdin ?? process.stdin;
    55	  const output = options.stdout ?? process.stdout;
    56	  const exit = options.exit ?? ((code) => process.exit(code));
    57	  const socket = net.createConnection(toConnectionOptions(socketPath));
    58	  let closed = false;
