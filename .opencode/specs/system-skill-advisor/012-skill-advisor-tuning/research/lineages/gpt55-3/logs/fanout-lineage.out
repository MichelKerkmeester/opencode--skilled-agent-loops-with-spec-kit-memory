SkillIds);\n354:   return new Map(matches.map((match) => [match.skillId, {\n355:     rawScore: match.score,\n356:   }]));\n357: }\n358: \n359: function exactSemanticRerankScore(\n360:   rerankIndex: ExactSemanticRerankIndex,\n361:   recommendation: AdvisorScoredRecommendation,\n362: ): number | null {\n363:   return rerankIndex.get(recommendation.skill)?.rawScore ?? null;\n364: }\n365: \n366: function rrfRankFor(\n367:   fusion: AdvisorRrfFusion | null,\n368:   recommendation: AdvisorScoredRecommendation,\n369: ): number {\n370:   return fusion?.rankBySkill.get(recommendation.skill) ?? NO_RRF_RANK;\n371: }\n372: \n373: function promptMentionsSkill(promptLower: string, skill: SkillProjection): boolean {\n374:   return [skill.id, skill.name, skill.id.replace(/-/g, ' ')].some((phrase) => matchesPhraseBoundary(promptLower, phrase.toLowerCase()));\n375: }\n376: \n377: function isDefaultRoutable(promptLower: string, skill: SkillProjection): boolean {\n378:   if (skill.lifecycleStatus === 'archived' || skill.lifecycleStatus === 'future') return false;\n379:   if (skill.lifecycleStatus === 'deprecated') return promptMentionsSkill(promptLower, skill);\n380:   return true;\n381: }\n382: \n383: function isAdvisorSelfRecommendationSkill(skillId: string): boolean {\n384:   return ADVISOR_SELF_RECOMMENDATION_SKILL_IDS.has(skillId);\n385: }\n386: \n387: function hasAdvisorSelfAuthoredSignal(skillId: string, explicitMatch: LaneMatchIndexEntry | undefined): boolean {\n388:   return isAdvisorSelfRecommendationSkill(skillId)\n389:     && explicitMatch?.producerSkillIds.some((producerSkillId) => producerSkillId === skillId) === true;\n390: }\n391: \n392: function shouldApplyAdvisorSelfRecommendationGuard(args: {\n393:   readonly skillId: string;\n394:   readonly guardEnabled: boolean;\n395:   readonly hasSelfAuthoredSignal?: boolean;\n396: }): boolean {\n397:   return args.guardEnabled\n398:     && isAdvisorSelfRecommendationSkill(args.skillId)\n399:     && (args.hasSelfAuthoredSignal ?? true);\n400: }\n401: \n402: function confidenceFor(args: {\n403:   liveNormalized: number;\n404:   directScore: number;\n405:   readOnlyExplainer: boolean;\n406:   hasExplicitWorkflowSignal: boolean;\n407:   hasTaskIntent: boolean;\n408:   readOnlyRouteAllowed: boolean;\n409:   derivedDominant: boolean;\n410:   skillId: string;\n411:   selfRecommendationGuardEnabled: boolean;\n412:   hasAdvisorSelfAuthoredSignal: boolean;\n413: }): number {\n414:   const C = SCORING_CALIBRATION.confidence;\n415:   if (!args.selfRecommendationGuardEnabled && args.readOnlyExplainer && args.skillId === 'skill-advisor') return C.readOnlyExplainerFloor;\n416:   if (args.readOnlyExplainer && shouldApplyAdvisorSelfRecommendationGuard({\n417:     skillId: args.skillId,\n418:     guardEnabled: args.selfRecommendationGuardEnabled,\n419:     hasSelfAuthoredSignal: args.hasAdvisorSelfAuthoredSignal,\n420:   })) {\n421:     return C.readOnlyExplainerFloor;\n422:   }\n423:   const base = C.baseConstant\n424:     + Math.min(1, args.liveNormalized * C.liveNormalizedRampGain) * C.liveNormalizedRampCoefficient;\n425:   if (args.readOnlyExplainer && !args.readOnlyRouteAllowed) return C.readOnlyExplainerFloor;\n426:   if (args.readOnlyRouteAllowed) {\n427:     return Number(Math.max(base, C.readOnlyRouteAllowedFloor).toFixed(4));\n428:   }\n429:   if (args.derivedDominant && args.directScore < C.derivedDominantDirectScoreCeiling) {\n\n(Showing lines 320-429 of 911. Use offset=430 to continue.)\n</content>","metadata":{"preview":"    convergenceBonus: 0,\n    calibratedOverlapBeta: 0,\n    bonusOverChannels: 'configured',\n  });\n  const scoreBySkill = new Map<string, number>();\n  const rankBySkill = new Map<string, number>();\n  fused.forEach((result, index) => {\n    const skillId = String(result.id);\n    scoreBySkill.set(skillId, result.rrfScore);\n    rankBySkill.set(skillId, index);\n  });\n  return { scoreBySkill, rankBySkill };\n}\n\nfunction graphConflictAdjustment(\n  conflictIndex: LaneMatchIndex,\n  recommendation: AdvisorScoredRecommendation,\n): number {\n  return conflictIndex.get(recommendation.skill)?.rawScore ?? 0;\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"    convergenceBonus: 0,\n    calibratedOverlapBeta: 0,\n    bonusOverChannels: 'configured',\n  });\n  const scoreBySkill = new Map<string, number>();\n  const rankBySkill = new Map<string, number>();\n  fused.forEach((result, index) => {\n    const skillId = String(result.id);\n    scoreBySkill.set(skillId, result.rrfScore);\n    rankBySkill.set(skillId, index);\n  });\n  return { scoreBySkill, rankBySkill };\n}\n\nfunction graphConflictAdjustment(\n  conflictIndex: LaneMatchIndex,\n  recommendation: AdvisorScoredRecommendation,\n): number {\n  return conflictIndex.get(recommendation.skill)?.rawScore ?? 0;\n}\n\nfunction buildExactSemanticRerankIndex(\n  prompt: string,\n  projection: AdvisorProjection,\n  recommendations: readonly AdvisorScoredRecommendation[],\n  fusion: AdvisorRrfFusion | null,\n): ExactSemanticRerankIndex {\n  if (!fusion) return new Map();\n  const topSkillIds = [...recommendations]\n    .filter((recommendation) => fusion.rankBySkill.has(recommendation.skill))\n    .sort((left, right) => rrfRankFor(fusion, left) - rrfRankFor(fusion, right))\n    .slice(0, ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K)\n    .map((recommendation) => recommendation.skill);\n  const matches = scoreSemanticShadowExactSubset(prompt, projection, topSkillIds);\n  return new Map(matches.map((match) => [match.skillId, {\n    rawScore: match.score,\n  }]));\n}\n\nfunction exactSemanticRerankScore(\n  rerankIndex: ExactSemanticRerankIndex,\n  recommendation: AdvisorScoredRecommendation,\n): number | null {\n  return rerankIndex.get(recommendation.skill)?.rawScore ?? null;\n}\n\nfunction rrfRankFor(\n  fusion: AdvisorRrfFusion | null,\n  recommendation: AdvisorScoredRecommendation,\n): number {\n  return fusion?.rankBySkill.get(recommendation.skill) ?? NO_RRF_RANK;\n}\n\nfunction promptMentionsSkill(promptLower: string, skill: SkillProjection): boolean {\n  return [skill.id, skill.name, skill.id.replace(/-/g, ' ')].some((phrase) => matchesPhraseBoundary(promptLower, phrase.toLowerCase()));\n}\n\nfunction isDefaultRoutable(promptLower: string, skill: SkillProjection): boolean {\n  if (skill.lifecycleStatus === 'archived' || skill.lifecycleStatus === 'future') return false;\n  if (skill.lifecycleStatus === 'deprecated') return promptMentionsSkill(promptLower, skill);\n  return true;\n}\n\nfunction isAdvisorSelfRecommendationSkill(skillId: string): boolean {\n  return ADVISOR_SELF_RECOMMENDATION_SKILL_IDS.has(skillId);\n}\n\nfunction hasAdvisorSelfAuthoredSignal(skillId: string, explicitMatch: LaneMatchIndexEntry | undefined): boolean {\n  return isAdvisorSelfRecommendationSkill(skillId)\n    && explicitMatch?.producerSkillIds.some((producerSkillId) => producerSkillId === skillId) === true;\n}\n\nfunction shouldApplyAdvisorSelfRecommendationGuard(args: {\n  readonly skillId: string;\n  readonly guardEnabled: boolean;\n  readonly hasSelfAuthoredSignal?: boolean;\n}): boolean {\n  return args.guardEnabled\n    && isAdvisorSelfRecommendationSkill(args.skillId)\n    && (args.hasSelfAuthoredSignal ?? true);\n}\n\nfunction confidenceFor(args: {\n  liveNormalized: number;\n  directScore: number;\n  readOnlyExplainer: boolean;\n  hasExplicitWorkflowSignal: boolean;\n  hasTaskIntent: boolean;\n  readOnlyRouteAllowed: boolean;\n  derivedDominant: boolean;\n  skillId: string;\n  selfRecommendationGuardEnabled: boolean;\n  hasAdvisorSelfAuthoredSignal: boolean;\n}): number {\n  const C = SCORING_CALIBRATION.confidence;\n  if (!args.selfRecommendationGuardEnabled && args.readOnlyExplainer && args.skillId === 'skill-advisor') return C.readOnlyExplainerFloor;\n  if (args.readOnlyExplainer && shouldApplyAdvisorSelfRecommendationGuard({\n    skillId: args.skillId,\n    guardEnabled: args.selfRecommendationGuardEnabled,\n    hasSelfAuthoredSignal: args.hasAdvisorSelfAuthoredSignal,\n  })) {\n    return C.readOnlyExplainerFloor;\n  }\n  const base = C.baseConstant\n    + Math.min(1, args.liveNormalized * C.liveNormalizedRampGain) * C.liveNormalizedRampCoefficient;\n  if (args.readOnlyExplainer && !args.readOnlyRouteAllowed) return C.readOnlyExplainerFloor;\n  if (args.readOnlyRouteAllowed) {\n    return Number(Math.max(base, C.readOnlyRouteAllowedFloor).toFixed(4));\n  }\n  if (args.derivedDominant && args.directScore < C.derivedDominantDirectScoreCeiling) {","lineStart":320,"lineEnd":429,"totalLines":911,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1783437267549,"end":1783437267553}},"metadata":{"openai":{"itemId":"fc_0b81288b6af006b9016a4d17d35c648191914a77730cc99079"}},"id":"prt_f3d2512330013nwhpVk0Wc4yzx","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d24e568001v7g5HAo6oWWDiT"}}
