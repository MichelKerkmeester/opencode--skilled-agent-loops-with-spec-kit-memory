  Line 630:           1. if iteration_count >= max_iterations: STOP (maxIterationsReached). This terminal cap bypasses quality-guard overrides; record failed guards/blockers as synthesis evidence instead of continuing.\n\n  Line 719:           skip_to: phase_synthesis\n\n  Line 721:           append_to_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n  Line 798:           canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n  Line 801:           canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n  Line 1286:   phase_synthesis:\n\n  Line 1287:     purpose: Compile all iteration findings into final research/research.md\n\n  Line 1301:         action: \"Hydrate summary metrics before synthesis\"\n\n  Line 1319:           - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n  Line 1337:         action: \"Compile or finalize research/research.md\"\n\n  Line 1339:           If research/research.md exists (progressive synthesis was active):\n\n  Line 1340:             1. Read current research/research.md\n\n  Line 1347:           If research/research.md does not exist:\n\n  Line 1348:             1. Create research/research.md following 17-section template\n\n  Line 1353:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n\n  Line 1472:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n\n  Line 1481:               event: 'synthesis_incomplete',\n\n  Line 1487:               stopReason: '{reason}',\n\n  Line 1488:               reason: 'synthesis_artifact_invariant_failed',\n\n  Line 1500:               event: 'synthesis_complete',\n\n  Line 1504:               stopReason: '{reason}',\n\n  Line 1523:           - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n\n  Line 1527:           - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n\n  Line 1528:         append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  Line 1530:       step_validate_post_synthesis_spec_doc:\n\n  Line 1538:         set_field: { status: \"complete\" }\n\n  Line 1576:           function terminalEvent(stopReason) {\n\n  Line 1577:             if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n\n  Line 1578:             if (stopReason === 'error') return 'failed';\n\n  Line 1622:           - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n\n  Line 1628:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  Line 1647:             \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n\n  Line 1685:         - research/research.md (compiled from {iteration_count} iterations)\n\n  Line 1702:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n\n  Line 1716:     - save_memory_context_after_synthesis\n","metadata":{"matches":46,"truncated":false},"title":"status.*complete|session_completed|stopReason|research.md|synthesis","time":{"start":1783487562047,"end":1783487562059}},"metadata":{"openai":{"itemId":"fc_0f774afd72a4fbab016a4ddc4849008191a6c4b72ddf9adf58"}},"id":"prt_f40247a560012Oek8E5w2I3qsn","sessionID":"ses_0bfe020b5ffeoZNo5CdAcudSTe","messageID":"msg_f402461a0001eshSrliMkNWcRu"}}
