d of deltaRecords) {\n\n  Line 655:     const finding = deltaRecordToFinding(record);\n\n  Line 657:     const run = isFiniteNumber(record.iteration) ? record.iteration : 0;\n\n  Line 658:     if (!deltaFindingsByRun.has(run)) {\n\n  Line 659:       deltaFindingsByRun.set(run, []);\n\n  Line 661:     deltaFindingsByRun.get(run).push(finding);\n\n  Line 664:   // Process deltas in iteration order so transitions reflect chronology.\n\n  Line 665:   // Cross-reference iteration markdown files for focus/dimensionsAddressed\n\n  Line 666:   // metadata (used by deriveDimension); pseudo iteration if no markdown match.\n\n  Line 667:   const iterationByRun = new Map(iterationFiles.map((it) => [it.run, it]));\n\n  Line 668:   const sortedRuns = [...deltaFindingsByRun.keys()].sort((a, b) => a - b);\n\n  Line 670:     const pseudoIteration = iterationByRun.get(run) || { focus: '', run, dimensionsAddressed: [] };\n\n  Line 671:     for (const finding of deltaFindingsByRun.get(run)) {\n\n  Line 688:               iteration: run,\n\n  Line 691:               reason: 'Initial discovery (delta)',\n\n  Line 700:             iteration: run,\n\n  Line 703:             reason: 'Severity adjusted in later delta',\n\n  Line 711:   for (const iteration of iterationFiles) {\n\n  Line 712:     for (const finding of iteration.findings) {\n\n  Line 720:           dimension: deriveDimension({ ...finding, severity: canonicalSeverity }, iteration),\n\n  Line 721:           firstSeen: iteration.run,\n\n  Line 722:           lastSeen: iteration.run,\n\n  Line 726:               iteration: iteration.run,\n\n  Line 735:         existing.lastSeen = iteration.run;\n\n  Line 738:             iteration: iteration.run,\n\n  Line 741:             reason: 'Severity adjusted in later iteration',\n\n  Line 753:   for (const record of iterationRecords) {\n\n  Line 794: function deriveDimension(finding, iteration) {\n\n  Line 795:   const focus = `${iteration.focus} ${finding.title} ${finding.description}`.to