{"type":"tool_use","timestamp":1783433127476,"sessionID":"ses_0c31ab9feffeYOKG73D8b3S1Zu","part":{"type":"tool","tool":"mk-spec-memory_memory_match_triggers","callID":"call_OEj8XCkWY2yWzFtFONwvVFRV","state":{"status":"error","input":{"prompt":"You are orchestrating the deep-review workflow YAML as a detached fan-out lineage. Read .opencode/skills/deep-loop-workflows/deep-review/SKILL.md and execute the review loop with specified spec_folder, fanout_lineage_artifact_dir, session_id, executor cli-opencode model=openai/gpt-5.5-fast, loop_type review, maxIterations 20, convergenceThreshold 0.1. Write outputs only to the lineage artifact dir and complete with FANOUT_LINEAGE_COMPLETE:gpt-1.","specFolder":".opencode/specs/system-skill-advisor/000-migration-from-system-speckit","tenantId":"","userId":"","agentId":"","limit":3,"session_id":"fanout-gpt-1-1783433085887-cah79b","turnNumber":1,"include_cognitive":false},"error":"{\n  \"summary\": \"Error: sessionId \\\"fanout-gpt-1-1783433085887-cah79b\\\" does not match a server-managed session. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.\",\n  \"data\": {\n    \"error\": \"sessionId \\\"fanout-gpt-1-1783433085887-cah79b\\\" does not match a server-managed session. Omit sessionId to start a new server-generated session and reuse the effectiveSessionId returned by the server.\",\n    \"code\": \"E_SESSION_SCOPE\",\n    \"details\": {\n      \"requestedSessionId\": \"fanout-gpt-1-1783433085887-cah79b\"\n    }\n  },\n  \"hints\": [\n    \"Omit session_id to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.\"\n  ],\n  \"meta\": {\n    \"tool\": \"memory_match_triggers\",\n    \"tokenCount\": 223,\n    \"cacheHit\": false,\n    \"isError\": true,\n    \"severity\": \"error\",\n    \"tokenBudget\": 3500\n  }\n}","time":{"start":1783433108193,"end":1783433127474}},"metadata":{"openai":{"itemId":"fc_03365aa14c2aab01016a4d