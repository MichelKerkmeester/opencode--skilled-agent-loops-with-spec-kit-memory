{"type":"tool_use","timestamp":1781761791851,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_ujYzjzLKNridChkXYD3I9afA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-list.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-list.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud List\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { randomUUID } from 'node:crypto';\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n13: import * as vectorIndex from '../lib/search/vector-index.js';\n14: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { safeJsonParseTyped } from '../utils/json-helpers.js';\n18: \n19: import type { MCPResponse } from './types.js';\n20: import type { ListArgs } from './memory-crud-types.js';\n21: \n22: // Feature catalog: Memory browser (memory_list)\n23: // Feature catalog: Validation feedback (memory_validate)\n24: \n25: \n26: /* ───────────────────────────────────────────────────────────────\n27:    CORE LOGIC\n28: ──────────────────────────────────────────────────────────────── */\n29: \n30: /** Handle memory_list tool -- returns paginated memory entries. */\n31: async function handleMemoryList(args: ListArgs): Promise<MCPResponse> {\n32:   await ensureMemoryRuntimeInitialized('handler:memory_list');\n33:   const startTime = Date.now();\n34:   const requestId = randomUUID();\n35:   try {\n36:     await checkDatabaseUpdated();\n37:   } catch (dbStateErr: unknown) {\n38:     const message = toErrorMessage(dbStateErr);\n39:     console.error(`[memory-list] Database refresh failed [requestId=${requestId}]: ${message}`);\n40:     return createMCPErrorResponse({\n41:       tool: 'memory_list',\n42:       error: 'Database refresh failed before query execution. Retry the request or restart the MCP server.',\n43:       code: 'E021',\n44:       details: { requestId },\n45:       startTime,\n46:     });\n47:   }\n48: \n49:   const {\n50:     limit: rawLimit = 20,\n51:     offset: rawOffset = 0,\n52:     specFolder,\n53:     sortBy = 'created_at',\n54:     includeChunks = false,\n55:   } = args;\n56: \n57:   if (specFolder !== undefined && typeof specFolder !== 'string') {\n58:     return createMCPErrorResponse({\n59:       tool: 'memory_list',\n60:       error: 'specFolder must be a string',\n61:       code: 'E_INVALID_INPUT',\n62:       details: { requestId },\n63:       startTime,\n64:     });\n65:   }\n66:   if (includeChunks !== undefined && typeof includeChunks !== 'boolean') {\n67:     return createMCPErrorResponse({\n68:       tool: 'memory_list',\n69:       error: 'includeChunks must be a boolean',\n70:       code: 'E_INVALID_INPUT',\n71:       details: { requestId },\n72:       startTime,\n73:     });\n74:   }\n75:   if (rawLimit !== undefined && (typeof rawLimit !== 'number' || !Number.isFinite(rawLimit))) {\n76:     return createMCPErrorResponse({\n77:       tool: 'memory_list',\n78:       error: 'limit must be a finite number',\n79:       code: 'E_INVALID_INPUT',\n80:       details: { requestId },\n81:       startTime,\n82:     });\n83:   }\n84:   if (rawOffset !== undefined && (typeof rawOffset !== 'number' || !Number.isFinite(rawOffset))) {\n85:     return createMCPErrorResponse({\n86:       tool: 'memory_list',\n87:       error: 'offset must be a finite number',\n88:       code: 'E_INVALID_INPUT',\n89:       details: { requestId },\n90:       startTime,\n91:     });\n92:   }\n93: \n94:   const safeLimit = Math.max(1, Math.min(Math.floor(rawLimit || 20), 100));\n95:   const safeOffset = Math.max(0, Math.floor(rawOffset || 0));\n96:   const database = vectorIndex.getDb();\n97: \n98:   if (!database) {\n99:     return createMCPErrorResponse({\n100:       tool: 'memory_list',\n101:       error: 'Database not initialized. Run memory_index_scan() to trigger schema creation, or restart the MCP server.',\n102:       code: 'E020',\n103:       details: { requestId },\n104:       startTime,\n105:     });\n106:   }\n107: \n108:   let total = 0;\n109:   let rows: unknown[];\n110:   const sortColumn = ['created_at', 'updated_at', 'importance_weight'].includes(sortBy)\n111:     ? sortBy\n112:     : 'created_at';\n113: \n114:   try {\n115:     const whereParts: string[] = [];\n116:     const baseParams: unknown[] = [];\n117: \n118:     if (!includeChunks) {\n119:       whereParts.push('parent_id IS NULL');\n120:     }\n121: \n122:     if (specFolder) {\n123:       whereParts.push('spec_folder = ?');\n124:       baseParams.push(specFolder);\n125:     }\n126: \n127:     const whereClause = whereParts.length > 0 ? `WHERE ${whereParts.join(' AND ')}` : '';\n128: \n129:     const countSql = `SELECT COUNT(*) as count FROM memory_index ${whereClause}`;\n130:     const countResult = database.prepare(countSql).get(...baseParams) as Record<string, unknown> | undefined;\n131:     total = (countResult && typeof countResult.count === 'number') ? countResult.count : 0;\n132: \n133:     const sql = `SELECT id, spec_folder, file_path, title, trigger_phrases, importance_weight, created_at, updated_at FROM memory_index ${whereClause} ORDER BY ${sortColumn} DESC LIMIT ? OFFSET ?`;\n134:     const params = [...baseParams, safeLimit, safeOffset];\n135:     rows = database.prepare(sql).all(...params);\n136:   } catch (dbErr: unknown) {\n137:     const message = toErrorMessage(dbErr);\n138:     console.error(`[memory-list] Database query failed: ${message}`);\n139:     return createMCPErrorResponse({\n140:       tool: 'memory_list',\n141:       error: `Database query failed: ${message}`,\n142:       code: 'E021',\n143:       details: { requestId },\n144:       startTime,\n145:     });\n146:   }\n147: \n148:   const memories = (rows as Record<string, unknown>[]).map((row: Record<string, unknown>) => ({\n149:     id: row.id,\n150:     specFolder: row.spec_folder,\n151:     title: (row.title as string) || '(untitled)',\n152:     createdAt: row.created_at,\n153:     updatedAt: row.updated_at,\n154:     importanceWeight: row.importance_weight,\n155:     triggerCount: safeJsonParseTyped<unknown[]>(row.trigger_phrases as string, 'array', []).length,\n156:     filePath: row.file_path,\n157:   }));\n158: \n159:   const summary = `Listed ${memories.length} of ${total} memories`;\n160:   const hints: string[] = [];\n161:   if (safeOffset + memories.length < total) {\n162:     hints.push(`More results available: use offset: ${safeOffset + safeLimit}`);\n163:   }\n164:   if (memories.length === 0 && total > 0) {\n165:     hints.push('Offset exceeds total count - try offset: 0');\n166:   }\n167: \n168:   return createMCPSuccessResponse({\n169:     tool: 'memory_list',\n170:     summary,\n171:     data: {\n172:       total,\n173:       offset: safeOffset,\n174:       limit: safeLimit,\n175:       sortBy: sortColumn,\n176:       includeChunks,\n177:       count: memories.length,\n178:       results: memories,\n179:     },\n180:     hints,\n181:     startTime,\n182:   });\n183: }\n184: \n185: /* ───────────────────────────────────────────────────────────────\n186:    EXPORTS\n187: ──────────────────────────────────────────────────────────────── */\n188: \n189: export { handleMemoryList };\n\n(End of file - total 189 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud List\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { safeJsonParseTyped } from '../utils/json-helpers.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { ListArgs } from './memory-crud-types.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-list.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud List\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { safeJsonParseTyped } from '../utils/json-helpers.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { ListArgs } from './memory-crud-types.js';\n\n// Feature catalog: Memory browser (memory_list)\n// Feature catalog: Validation feedback (memory_validate)\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_list tool -- returns paginated memory entries. */\nasync function handleMemoryList(args: ListArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_list');\n  const startTime = Date.now();\n  const requestId = randomUUID();\n  try {\n    await checkDatabaseUpdated();\n  } catch (dbStateErr: unknown) {\n    const message = toErrorMessage(dbStateErr);\n    console.error(`[memory-list] Database refresh failed [requestId=${requestId}]: ${message}`);\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'Database refresh failed before query execution. Retry the request or restart the MCP server.',\n      code: 'E021',\n      details: { requestId },\n      startTime,\n    });\n  }\n\n  const {\n    limit: rawLimit = 20,\n    offset: rawOffset = 0,\n    specFolder,\n    sortBy = 'created_at',\n    includeChunks = false,\n  } = args;\n\n  if (specFolder !== undefined && typeof specFolder !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'specFolder must be a string',\n      code: 'E_INVALID_INPUT',\n      details: { requestId },\n      startTime,\n    });\n  }\n  if (includeChunks !== undefined && typeof includeChunks !== 'boolean') {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'includeChunks must be a boolean',\n      code: 'E_INVALID_INPUT',\n      details: { requestId },\n      startTime,\n    });\n  }\n  if (rawLimit !== undefined && (typeof rawLimit !== 'number' || !Number.isFinite(rawLimit))) {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'limit must be a finite number',\n      code: 'E_INVALID_INPUT',\n      details: { requestId },\n      startTime,\n    });\n  }\n  if (rawOffset !== undefined && (typeof rawOffset !== 'number' || !Number.isFinite(rawOffset))) {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'offset must be a finite number',\n      code: 'E_INVALID_INPUT',\n      details: { requestId },\n      startTime,\n    });\n  }\n\n  const safeLimit = Math.max(1, Math.min(Math.floor(rawLimit || 20), 100));\n  const safeOffset = Math.max(0, Math.floor(rawOffset || 0));\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: 'Database not initialized. Run memory_index_scan() to trigger schema creation, or restart the MCP server.',\n      code: 'E020',\n      details: { requestId },\n      startTime,\n    });\n  }\n\n  let total = 0;\n  let rows: unknown[];\n  const sortColumn = ['created_at', 'updated_at', 'importance_weight'].includes(sortBy)\n    ? sortBy\n    : 'created_at';\n\n  try {\n    const whereParts: string[] = [];\n    const baseParams: unknown[] = [];\n\n    if (!includeChunks) {\n      whereParts.push('parent_id IS NULL');\n    }\n\n    if (specFolder) {\n      whereParts.push('spec_folder = ?');\n      baseParams.push(specFolder);\n    }\n\n    const whereClause = whereParts.length > 0 ? `WHERE ${whereParts.join(' AND ')}` : '';\n\n    const countSql = `SELECT COUNT(*) as count FROM memory_index ${whereClause}`;\n    const countResult = database.prepare(countSql).get(...baseParams) as Record<string, unknown> | undefined;\n    total = (countResult && typeof countResult.count === 'number') ? countResult.count : 0;\n\n    const sql = `SELECT id, spec_folder, file_path, title, trigger_phrases, importance_weight, created_at, updated_at FROM memory_index ${whereClause} ORDER BY ${sortColumn} DESC LIMIT ? OFFSET ?`;\n    const params = [...baseParams, safeLimit, safeOffset];\n    rows = database.prepare(sql).all(...params);\n  } catch (dbErr: unknown) {\n    const message = toErrorMessage(dbErr);\n    console.error(`[memory-list] Database query failed: ${message}`);\n    return createMCPErrorResponse({\n      tool: 'memory_list',\n      error: `Database query failed: ${message}`,\n      code: 'E021',\n      details: { requestId },\n      startTime,\n    });\n  }\n\n  const memories = (rows as Record<string, unknown>[]).map((row: Record<string, unknown>) => ({\n    id: row.id,\n    specFolder: row.spec_folder,\n    title: (row.title as string) || '(untitled)',\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    importanceWeight: row.importance_weight,\n    triggerCount: safeJsonParseTyped<unknown[]>(row.trigger_phrases as string, 'array', []).length,\n    filePath: row.file_path,\n  }));\n\n  const summary = `Listed ${memories.length} of ${total} memories`;\n  const hints: string[] = [];\n  if (safeOffset + memories.length < total) {\n    hints.push(`More results available: use offset: ${safeOffset + safeLimit}`);\n  }\n  if (memories.length === 0 && total > 0) {\n    hints.push('Offset exceeds total count - try offset: 0');\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_list',\n    summary,\n    data: {\n      total,\n      offset: safeOffset,\n      limit: safeLimit,\n      sortBy: sortColumn,\n      includeChunks,\n      count: memories.length,\n      results: memories,\n    },\n    hints,\n    startTime,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryList };","lineStart":1,"lineEnd":189,"totalLines":189,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-list.ts","time":{"start":1781761791845,"end":1781761791850}},"metadata":{"openai":{"itemId":"fc_09fa62c362694d78016a3386fe2f2c8191ba8486bb7012f13c"}},"id":"prt_ed94750f2001Mx6L5Ah04gDTfe","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed9473775001FVR2RVZaO07WXG"}}
