ts().filter((artifact) => !exists(artifact));\n752:   if (missing.length > 0) {\n753:     throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n754:   }\n755: }\n756: \n757: async function acquireBootstrapLock(options = {}) {\n758:   const requireLock = options.requireLock === true;\n759:   fs.mkdirSync(dbDir, { recursive: true });\n760:   const deadline = Date.now() + 120000;\n761:   const STALE_LOCK_MS = 5 * 60 * 1000; // 5 minutes — covers SIGKILL'd prior launchers\n762:   while (true) {\n763:     try {\n764:       fs.mkdirSync(lockDir);\n765:       return true;\n766:     } catch (error) {\n767:       if (error.code !== 'EEXIST') {\n768:         throw error;\n769:       }\n770:       if (artifactsReady() && !requireLock) {\n771:         return false;\n772:       }\n773:       // Detect stale lockdir from SIGKILL'd predecessor.\n774:       // Existing process should refresh the dir; an mtime older than 5min\n775:       // implies the holder is gone. Remove and retry.\n776:       try {\n777:         const lockStat = fs.statSync(lockDir);\n778:         if (Date.now() - lockStat.mtimeMs > STALE_LOCK_MS) {\n779:           process.stderr.write(\n780:             `[mk-code-index-launcher] stale bootstrap lock (mtime ${Math.round((Date.now() - lockStat.mtimeMs) / 1000)}s old); reclaiming ${rel(lockDir)}\\n`\n781:           );\n782:           // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n783:           // racer wins the rename; a successor that mkdir's a fresh lockDir after our stat creates\n784:           // a NEW inode that our rename/rmSync cannot touch, so we never delete a live successor\n785:           // lock. A losing racer's rename throws ENOENT and falls through to the outer retry.\n786:           const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n787:           fs.renameSync(lockDir, staleClaim);\n788:           fs.rmSync(staleClaim, { recursive: true, force: true });\n789:           continue;\n790:         }\n791:       } catch {\n792:         // stat/rename race — lock disappeared or was reclaimed by another launcher; retry mkdirSync\n793:       }\n794:       if (Date.now() > deadline) {\n795:         throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n796:       }\n797:       await sleep(1000);\n798:     }\n799:   }\n800: }\n801: \n802: function launchServer() {\n803:   if (launchStarted) {\n804:     log('launchServer skipped: launch already started in this launcher process');\n805:     return false;\n806:   }\n807:   launchStarted = true;\n808:   // Set DB dir for the child process (operator-set env var wins).\n809:   if (!process.env.SPECKIT_CODE_GRAPH_DB_DIR) {\n810:     process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedDbDir();\n811:   }\n812: \n813:   const server = path.join(kitDir, 'mcp_server', 'dist', 'index.js');\n814:   childProcess = spawn(process.execPath, [server], {\n815:     cwd: root,\n816:     env: buildChildEnv(),\n817:     stdio: 'inherit',\n818:   });\n819: \n820:   if (typeof childProcess.pid === 'number') {\n821:     const refreshed = refreshOwnerLeaseFile(process.pid, {\n822:       ownerPid: childProcess.pid,\n823:       ppid: process.pid,\n824:       executablePath: process.execPath,\n825:     });\n826:     if (!refreshed) {\n827:       log('owner lease refresh to child pid failed; launcher pid remains the recorded owner');\n828:     }\n829:   }\n830: \n831:   childProcess.on('exit', (code, signal) => {\n832:     if (signal) {\n833:       // Clear the lease before mirroring the signal; process.on('exit') does not fire on SIGKILL.\n834:       clearAllLeaseFiles();\n835:       process.kill(process.pid, signal);\n836:       return;\n837:     }\n838:     clearAllLeaseFiles();\n839:     process.exit(code ?? 0);\n840:   });\n841: \n842:   childProcess.on('error', (error) => {\n843:     log(error.stack || error.message);\n844:     process.exit(1);\n845:   });\n846:   return true;\n847: }\n84