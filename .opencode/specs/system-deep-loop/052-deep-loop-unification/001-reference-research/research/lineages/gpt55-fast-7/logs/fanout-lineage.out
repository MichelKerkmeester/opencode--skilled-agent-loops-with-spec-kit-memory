{"type":"tool_use","timestamp":1783487481942,"sessionID":"ses_0bfe020b5ffeoZNo5CdAcudSTe","part":{"type":"tool","tool":"read","callID":"call_TmoU30cCDEmhx86mF8aXTOCi","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts","offset":1,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Deep-Loop Executor Config\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: import { z } from 'zod';\n6: \n7: // ───────────────────────────────────────────────────────────────────\n8: // 1. TYPE DEFINITIONS\n9: // ───────────────────────────────────────────────────────────────────\n10: \n11: export const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\n12: export type ExecutorKind = typeof EXECUTOR_KINDS[number];\n13: \n14: export const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\n15: export type ReasoningEffort = typeof REASONING_EFFORTS[number];\n16: \n17: export const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\n18: export type ServiceTier = typeof SERVICE_TIERS[number];\n19: \n20: /** Fan-out assignment models accepted by the schema. */\n21: export const FANOUT_ASSIGNMENT_MODELS = ['flat_pool', 'wave'] as const;\n22: \n23: /** Fan-out assignment model selected for a lineage or fan-out block. */\n24: export type FanoutAssignmentModel = typeof FANOUT_ASSIGNMENT_MODELS[number];\n25: \n26: const SANDBOX_MODES = ['read-only', 'workspace-write', 'danger-full-access'] as const;\n27: export type SandboxMode = typeof SANDBOX_MODES[number];\n28: export type ClaudePermissionMode = 'plan' | 'acceptEdits' | 'bypassPermissions';\n29: \n30: // ───────────────────────────────────────────────────────────────────\n31: // 2. CONSTANTS\n32: // ───────────────────────────────────────────────────────────────────\n33: \n34: export const executorConfigSchema = z.object({\n35:   kind: z.enum(EXECUTOR_KINDS).default('native'),\n36:   model: z.string().min(1).nullable().default(null),\n37:   configDir: z.string().trim().min(1).nullable().default(null),\n38:   reasoningEffort: z.enum(REASONING_EFFORTS).nullable().default(null),\n39:   serviceTier: z.enum(SERVICE_TIERS).nullable().default(null),\n40:   sandboxMode: z.enum(SANDBOX_MODES).nullable().default(null),\n41:   timeoutSeconds: z.number().int().positive().default(900),\n42:   // Optional fable-5 governor capsule for this executor's prompts. Universal and\n43:   // kind-agnostic on purpose: intentionally absent from EXECUTOR_KIND_FLAG_SUPPORT\n44:   // and the unsupported-field scan, so any executor kind may carry it. null = none.\n45:   governor: z.string().min(1).nullable().default(null),\n46: });\n47: \n48: export type ExecutorConfig = z.infer<typeof executorConfigSchema>;\n49: \n50: export const EXECUTOR_KIND_FLAG_SUPPORT: Record<ExecutorKind, readonly (keyof ExecutorConfig)[]> = {\n51:   native: [],\n52:   'cli-claude-code': ['model', 'configDir', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n53:   'cli-opencode': ['model', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n54: };\n55: \n56: // ───────────────────────────────────────────────────────────────────\n57: // 3. DOMAIN ERRORS\n58: // ───────────────────────────────────────────────────────────────────\n59: \n60: type ExecutorConfigIssue = {\n61:   path: PropertyKey[];\n62:   message: string;\n63: };\n64: \n65: /** Error thrown when a reserved executor kind is selected before wiring exists. */\n66: export class ExecutorNotWiredError extends Error {\n67:   kind: Extract<ExecutorKind, 'cli-claude-code'>;\n68: \n69:   constructor(kind: Extract<ExecutorKind, 'cli-claude-code'>) {\n70:     super(`Executor kind '${kind}' is reserved in the schema but not yet wired. Awaiting future spec for ${kind} integration.`);\n71:     this.name = 'ExecutorNotWiredError';\n72:     this.kind = kind;\n73:   }\n74: }\n75: \n76: /** Error thrown when executor configuration validation fails. */\n77: export class ExecutorConfigError extends Error {\n78:   issues: ExecutorConfigIssue[];\n79: \n80:   constructor(input: { issues: ExecutorConfigIssue[] }) {\n81:     super(input.issues.map((issue) => `${issue.path.map(String).join('.') || '<root>'}: ${issue.message}`).join('; '));\n82:     this.name = 'ExecutorConfigError';\n83:     this.issues = input.issues;\n84:   }\n85: }\n86: \n87: // ───────────────────────────────────────────────────────────────────\n88: // 4. HELPERS\n89: // ───────────────────────────────────────────────────────────────────\n90: \n91: function isRecord(value: unknown): value is Record<string, unknown> {\n92:   return value !== null && !Array.isArray(value) && typeof value === 'object';\n93: }\n94: \n95: function normalizeSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n96:   return mode ?? 'workspace-write';\n97: }\n98: \n99: function normalizeExecutorConfigInput(raw: unknown): unknown {\n100:   if (!isRecord(raw) || !Object.prototype.hasOwnProperty.call(raw, 'type')) {\n101:     return raw;\n102:   }\n103: \n104:   const legacyKind = raw.type;\n105:   if (typeof legacyKind !== 'string') {\n106:     return raw;\n107:   }\n108: \n109:   if (typeof raw.kind === 'string' && raw.kind !== legacyKind) {\n110:     throw new ExecutorConfigError({\n111:       issues: [{\n112:         path: ['type'],\n113:         message: `deprecated executor field 'type' conflicts with canonical kind '${raw.kind}'`,\n114:       }],\n115:     });\n116:   }\n117: \n118:   console.warn(\"[executor-config] Deprecated executor field 'type' was provided; use 'kind' instead.\");\n119:   const { type: _legacyType, ...rest } = raw;\n120:   return {\n121:     ...rest,\n122:     kind: typeof raw.kind === 'string' ? raw.kind : legacyKind,\n123:   };\n124: }\n125: \n126: function normalizeIssues(error: z.ZodError<ExecutorConfig>): ExecutorConfigIssue[] {\n127:   return error.issues.map((issue) => ({\n128:     path: issue.path,\n129:     message: issue.message,\n130:   }));\n131: }\n132: \n133: // ───────────────────────────────────────────────────────────────────\n134: // 5. EXPORTS\n135: // ───────────────────────────────────────────────────────────────────\n136: \n137: /**\n138:  * Map a generic sandbox mode to the executor-agnostic CLI sandbox mode.\n139:  *\n140:  * @param mode - Generic sandbox mode or undefined.\n141:  * @returns CLI-compatible sandbox mode.\n142:  */\n143: export function resolveSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n144:   return normalizeSandboxMode(mode);\n145: }\n146: \n147: /**\n148:  * Map a generic sandbox mode to the Claude Code permission mode.\n149:  *\n150:  * @param mode - Generic sandbox mode or undefined.\n151:  * @returns Claude-compatible permission mode.\n152:  */\n153: export function resolveClaudePermissionMode(mode: SandboxMode | null | undefined): ClaudePermissionMode {\n154:   switch (normalizeSandboxMode(mode)) {\n155:     case 'read-only':\n156:       return 'plan';\n157:     case 'danger-full-access':\n158:       return 'bypassPermissions';\n159:     default:\n160:       return 'acceptEdits';\n161:   }\n162: }\n163: \n164: /**\n165:  * Parse and validate a raw executor configuration.\n166:  *\n167:  * Normalizes legacy `type` fields, validates against the Zod schema,\n168:  * and enforces executor-kind-specific field support.\n169:  *\n170:  * @param raw - Raw input to parse (JSON-parsed object).\n171:  * @returns Validated ExecutorConfig.\n172:  * @throws {@link ExecutorConfigError} If validation fails.\n173:  */\n174: export function parseExecutorConfig(raw: unknown): ExecutorConfig {\n175:   const parsed = executorConfigSchema.safeParse(normalizeExecutorConfigInput(raw));\n176:   if (!parsed.success) {\n177:     throw new ExecutorConfigError({\n178:       issues: normalizeIssues(parsed.error),\n179:     });\n180:   }\n181: \n182:   const config = parsed.data;\n183:   const supportedFlags = EXECUTOR_KIND_FLAG_SUPPORT[config.kind];\n184:   const unsupportedFields: string[] = [];\n185:   const allOptionalFields: (keyof ExecutorConfig)[] = [\n186:     'model',\n187:     'configDir',\n188:     'reasoningEffort',\n189:     'serviceTier',\n190:     'sandboxMode',\n191:     'timeoutSeconds',\n192:   ];\n193: \n194:   for (const field of allOptionalFields) {\n195:     if (!supportedFlags.includes(field) && config[field] !== null && !(field === 'timeoutSeconds' && config[field] === 900)) {\n196:       unsupportedFields.push(field);\n197:     }\n198:   }\n199: \n200:   if (unsupportedFields.length > 0) {\n201:     throw new ExecutorConfigError({\n202:       issues: unsupportedFields.map((field) => ({\n203:         path: [field],\n204:         message: `field '${field}' is not supported by executor kind '${config.kind}'. Supported fields for ${config.kind}: ${\n205:           supportedFlags.length ? supportedFlags.join(', ') : 'none'\n206:         }.`,\n207:       })),\n208:     });\n209:   }\n210: \n211:   return config;\n212: }\n213: \n214: /**\n215:  * Resolve an executor configuration by merging CLI and file sources.\n216:  *\n217:  * @param sources - CLI and file partial configs (CLI takes precedence).\n218:  * @returns Validated ExecutorConfig.\n219:  */\n220: export function resolveExecutorConfig(sources: {\n221:   cli?: Partial<ExecutorConfig>;\n222:   file?: Partial<ExecutorConfig>;\n223: }): ExecutorConfig {\n224:   const merged = {\n225:     ...(sources.file ?? {}),\n226:     ...(sources.cli ?? {}),\n227:   };\n228:   return parseExecutorConfig(merged);\n229: }\n230: \n231: // ───────────────────────────────────────────────────────────────────\n232: // 6. FAN-OUT CONFIG\n233: // ───────────────────────────────────────────────────────────────────\n234: //\n235: // Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n236: // the loop runs N executor \"lineages\" concurrently (capped), each running the\n237: // existing sequential loop in its own isolated sub-packet. The single-executor\n238: // path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n239: // default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n240: \n241: const LINEAGE_LABEL_PATTERN = /^[a-z0-9][a-z0-9-]*$/;\n242: \n243: /**\n244:  * One fan-out lineage: a single executor config plus fan-out metadata.\n245:  *\n246:  * - `label`: directory-safe id for the lineage's isolated sub-packet.\n247:  * - `count`: number of replicas of THIS config to run (e.g. 5x the same model).\n248:  * - `iterations`: per-lineage max-iterations override; null = packet default.\n249:  * - `promptFramework`: optional per-model prompt framing key (e.g. \"costar\",\n250:  *   \"tidd-ec\") resolved against sk-prompt-models when a consumer renders the\n251:  *   lineage prompt. null = consumer default. Loop-type-agnostic and optional, so\n252:  *   research/review lineages that omit it are unaffected.\n253:  * - `assignment_model`: defaults to the existing flat pool; `wave` is accepted\n254:  *   only so the runtime guard can reject activation attempts explicitly.\n255:  * - `depends_on` / `touches`: reserved dependency and path-domain metadata for\n256:  *   a future guarded planner; flat-pool execution ignores them after logging.\n257:  */\n258: export const lineageExecutorSchema = executorConfigSchema.extend({\n259:   label: z.string().min(1).regex(LINEAGE_LABEL_PATTERN, {\n260:     message: \"label must match /^[a-z0-9][a-z0-9-]*$/ (lowercase, digits, hyphens; dir-safe)\",\n261:   }),\n262:   count: z.number().int().positive().default(1),\n263:   iterations: z.number().int().positive().nullable().default(null),\n264:   promptFramework: z.string().min(1).nullable().default(null),\n265:   assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n266:   depends_on: z.array(z.string().trim().min(1)).default([]),\n267:   touches: z.array(z.string().trim().min(1)).default([]),\n268: });\n269: \n270: export type LineageExecutor = z.infer<typeof lineageExecutorSchema>;\n271: \n272: export const fanoutConfigSchema = z.object({\n273:   executors: z.array(lineageExecutorSchema).min(1),\n274:   assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n275:   concurrency: z.number().int().positive().default(2),\n276:   maxRetries: z.number().int().nonnegative().default(5),\n277:   // Stall detection defaults ON: a lineage that stops emitting progress is aborted and\n278:   // requeued within the ceiling and fails loud, instead of hanging silently at 0% CPU\n279:   // until the hours-scale subprocess timeout. Set 0 to opt out.\n280:   lagCeilingMs: z.number().int().nonnegative().default(300000),\n281:   progressHeartbeatSeconds: z.number().nonnegative().default(60),\n282: });\n283: \n284: export type FanoutConfig = z.infer<typeof fanoutConfigSchema>;\n285: \n286: /**\n287:  * Parse and validate a raw fan-out configuration.\n288:  *\n289:  * Each entry's executor subset is routed through {@link parseExecutorConfig} so\n290:  * ALL existing kind/model/flag rules apply per lineage with zero duplication.\n291:  * Labels must be unique and base-label (count>1) expansion must not collide.\n292:  *\n293:  * @param raw - Raw input to parse (JSON-parsed object).\n294:  * @returns Validated FanoutConfig.\n295:  * @throws {@link ExecutorConfigError} If validation fails.\n296:  */\n297: export function parseFanoutConfig(raw: unknown): FanoutConfig {\n298:   const parsed = fanoutConfigSchema.safeParse(raw);\n299:   if (!parsed.success) {\n300:     throw new ExecutorConfigError({ issues: parsed.error.issues.map((issue) => ({ path: issue.path, message: issue.message })) });\n\n(Showing lines 1-300 of 376. Use offset=301 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Executor Config\n// ───────────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\nexport type ExecutorKind = typeof EXECUTOR_KINDS[number];\n\nexport const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\nexport type ReasoningEffort = typeof REASONING_EFFORTS[number];\n\nexport const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\nexport type ServiceTier = typeof SERVICE_TIERS[number];\n\n/** Fan-out assignment models accepted by the schema. */","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Executor Config\n// ───────────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport const EXECUTOR_KINDS = ['native', 'cli-claude-code', 'cli-opencode'] as const;\nexport type ExecutorKind = typeof EXECUTOR_KINDS[number];\n\nexport const REASONING_EFFORTS = ['none', 'minimal', 'low', 'medium', 'high', 'xhigh', 'max'] as const;\nexport type ReasoningEffort = typeof REASONING_EFFORTS[number];\n\nexport const SERVICE_TIERS = ['priority', 'standard', 'fast'] as const;\nexport type ServiceTier = typeof SERVICE_TIERS[number];\n\n/** Fan-out assignment models accepted by the schema. */\nexport const FANOUT_ASSIGNMENT_MODELS = ['flat_pool', 'wave'] as const;\n\n/** Fan-out assignment model selected for a lineage or fan-out block. */\nexport type FanoutAssignmentModel = typeof FANOUT_ASSIGNMENT_MODELS[number];\n\nconst SANDBOX_MODES = ['read-only', 'workspace-write', 'danger-full-access'] as const;\nexport type SandboxMode = typeof SANDBOX_MODES[number];\nexport type ClaudePermissionMode = 'plan' | 'acceptEdits' | 'bypassPermissions';\n\n// ───────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ───────────────────────────────────────────────────────────────────\n\nexport const executorConfigSchema = z.object({\n  kind: z.enum(EXECUTOR_KINDS).default('native'),\n  model: z.string().min(1).nullable().default(null),\n  configDir: z.string().trim().min(1).nullable().default(null),\n  reasoningEffort: z.enum(REASONING_EFFORTS).nullable().default(null),\n  serviceTier: z.enum(SERVICE_TIERS).nullable().default(null),\n  sandboxMode: z.enum(SANDBOX_MODES).nullable().default(null),\n  timeoutSeconds: z.number().int().positive().default(900),\n  // Optional fable-5 governor capsule for this executor's prompts. Universal and\n  // kind-agnostic on purpose: intentionally absent from EXECUTOR_KIND_FLAG_SUPPORT\n  // and the unsupported-field scan, so any executor kind may carry it. null = none.\n  governor: z.string().min(1).nullable().default(null),\n});\n\nexport type ExecutorConfig = z.infer<typeof executorConfigSchema>;\n\nexport const EXECUTOR_KIND_FLAG_SUPPORT: Record<ExecutorKind, readonly (keyof ExecutorConfig)[]> = {\n  native: [],\n  'cli-claude-code': ['model', 'configDir', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n  'cli-opencode': ['model', 'reasoningEffort', 'sandboxMode', 'timeoutSeconds'],\n};\n\n// ───────────────────────────────────────────────────────────────────\n// 3. DOMAIN ERRORS\n// ───────────────────────────────────────────────────────────────────\n\ntype ExecutorConfigIssue = {\n  path: PropertyKey[];\n  message: string;\n};\n\n/** Error thrown when a reserved executor kind is selected before wiring exists. */\nexport class ExecutorNotWiredError extends Error {\n  kind: Extract<ExecutorKind, 'cli-claude-code'>;\n\n  constructor(kind: Extract<ExecutorKind, 'cli-claude-code'>) {\n    super(`Executor kind '${kind}' is reserved in the schema but not yet wired. Awaiting future spec for ${kind} integration.`);\n    this.name = 'ExecutorNotWiredError';\n    this.kind = kind;\n  }\n}\n\n/** Error thrown when executor configuration validation fails. */\nexport class ExecutorConfigError extends Error {\n  issues: ExecutorConfigIssue[];\n\n  constructor(input: { issues: ExecutorConfigIssue[] }) {\n    super(input.issues.map((issue) => `${issue.path.map(String).join('.') || '<root>'}: ${issue.message}`).join('; '));\n    this.name = 'ExecutorConfigError';\n    this.issues = input.issues;\n  }\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ───────────────────────────────────────────────────────────────────\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return value !== null && !Array.isArray(value) && typeof value === 'object';\n}\n\nfunction normalizeSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n  return mode ?? 'workspace-write';\n}\n\nfunction normalizeExecutorConfigInput(raw: unknown): unknown {\n  if (!isRecord(raw) || !Object.prototype.hasOwnProperty.call(raw, 'type')) {\n    return raw;\n  }\n\n  const legacyKind = raw.type;\n  if (typeof legacyKind !== 'string') {\n    return raw;\n  }\n\n  if (typeof raw.kind === 'string' && raw.kind !== legacyKind) {\n    throw new ExecutorConfigError({\n      issues: [{\n        path: ['type'],\n        message: `deprecated executor field 'type' conflicts with canonical kind '${raw.kind}'`,\n      }],\n    });\n  }\n\n  console.warn(\"[executor-config] Deprecated executor field 'type' was provided; use 'kind' instead.\");\n  const { type: _legacyType, ...rest } = raw;\n  return {\n    ...rest,\n    kind: typeof raw.kind === 'string' ? raw.kind : legacyKind,\n  };\n}\n\nfunction normalizeIssues(error: z.ZodError<ExecutorConfig>): ExecutorConfigIssue[] {\n  return error.issues.map((issue) => ({\n    path: issue.path,\n    message: issue.message,\n  }));\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 5. EXPORTS\n// ───────────────────────────────────────────────────────────────────\n\n/**\n * Map a generic sandbox mode to the executor-agnostic CLI sandbox mode.\n *\n * @param mode - Generic sandbox mode or undefined.\n * @returns CLI-compatible sandbox mode.\n */\nexport function resolveSandboxMode(mode: SandboxMode | null | undefined): SandboxMode {\n  return normalizeSandboxMode(mode);\n}\n\n/**\n * Map a generic sandbox mode to the Claude Code permission mode.\n *\n * @param mode - Generic sandbox mode or undefined.\n * @returns Claude-compatible permission mode.\n */\nexport function resolveClaudePermissionMode(mode: SandboxMode | null | undefined): ClaudePermissionMode {\n  switch (normalizeSandboxMode(mode)) {\n    case 'read-only':\n      return 'plan';\n    case 'danger-full-access':\n      return 'bypassPermissions';\n    default:\n      return 'acceptEdits';\n  }\n}\n\n/**\n * Parse and validate a raw executor configuration.\n *\n * Normalizes legacy `type` fields, validates against the Zod schema,\n * and enforces executor-kind-specific field support.\n *\n * @param raw - Raw input to parse (JSON-parsed object).\n * @returns Validated ExecutorConfig.\n * @throws {@link ExecutorConfigError} If validation fails.\n */\nexport function parseExecutorConfig(raw: unknown): ExecutorConfig {\n  const parsed = executorConfigSchema.safeParse(normalizeExecutorConfigInput(raw));\n  if (!parsed.success) {\n    throw new ExecutorConfigError({\n      issues: normalizeIssues(parsed.error),\n    });\n  }\n\n  const config = parsed.data;\n  const supportedFlags = EXECUTOR_KIND_FLAG_SUPPORT[config.kind];\n  const unsupportedFields: string[] = [];\n  const allOptionalFields: (keyof ExecutorConfig)[] = [\n    'model',\n    'configDir',\n    'reasoningEffort',\n    'serviceTier',\n    'sandboxMode',\n    'timeoutSeconds',\n  ];\n\n  for (const field of allOptionalFields) {\n    if (!supportedFlags.includes(field) && config[field] !== null && !(field === 'timeoutSeconds' && config[field] === 900)) {\n      unsupportedFields.push(field);\n    }\n  }\n\n  if (unsupportedFields.length > 0) {\n    throw new ExecutorConfigError({\n      issues: unsupportedFields.map((field) => ({\n        path: [field],\n        message: `field '${field}' is not supported by executor kind '${config.kind}'. Supported fields for ${config.kind}: ${\n          supportedFlags.length ? supportedFlags.join(', ') : 'none'\n        }.`,\n      })),\n    });\n  }\n\n  return config;\n}\n\n/**\n * Resolve an executor configuration by merging CLI and file sources.\n *\n * @param sources - CLI and file partial configs (CLI takes precedence).\n * @returns Validated ExecutorConfig.\n */\nexport function resolveExecutorConfig(sources: {\n  cli?: Partial<ExecutorConfig>;\n  file?: Partial<ExecutorConfig>;\n}): ExecutorConfig {\n  const merged = {\n    ...(sources.file ?? {}),\n    ...(sources.cli ?? {}),\n  };\n  return parseExecutorConfig(merged);\n}\n\n// ───────────────────────────────────────────────────────────────────\n// 6. FAN-OUT CONFIG\n// ───────────────────────────────────────────────────────────────────\n//\n// Opt-in layer ABOVE the single-executor path. When a fan-out config is present,\n// the loop runs N executor \"lineages\" concurrently (capped), each running the\n// existing sequential loop in its own isolated sub-packet. The single-executor\n// path (executorConfigSchema / parseExecutorConfig) is untouched and remains the\n// default; callers use EITHER a single `executor` OR a `fanout` block, never both.\n\nconst LINEAGE_LABEL_PATTERN = /^[a-z0-9][a-z0-9-]*$/;\n\n/**\n * One fan-out lineage: a single executor config plus fan-out metadata.\n *\n * - `label`: directory-safe id for the lineage's isolated sub-packet.\n * - `count`: number of replicas of THIS config to run (e.g. 5x the same model).\n * - `iterations`: per-lineage max-iterations override; null = packet default.\n * - `promptFramework`: optional per-model prompt framing key (e.g. \"costar\",\n *   \"tidd-ec\") resolved against sk-prompt-models when a consumer renders the\n *   lineage prompt. null = consumer default. Loop-type-agnostic and optional, so\n *   research/review lineages that omit it are unaffected.\n * - `assignment_model`: defaults to the existing flat pool; `wave` is accepted\n *   only so the runtime guard can reject activation attempts explicitly.\n * - `depends_on` / `touches`: reserved dependency and path-domain metadata for\n *   a future guarded planner; flat-pool execution ignores them after logging.\n */\nexport const lineageExecutorSchema = executorConfigSchema.extend({\n  label: z.string().min(1).regex(LINEAGE_LABEL_PATTERN, {\n    message: \"label must match /^[a-z0-9][a-z0-9-]*$/ (lowercase, digits, hyphens; dir-safe)\",\n  }),\n  count: z.number().int().positive().default(1),\n  iterations: z.number().int().positive().nullable().default(null),\n  promptFramework: z.string().min(1).nullable().default(null),\n  assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n  depends_on: z.array(z.string().trim().min(1)).default([]),\n  touches: z.array(z.string().trim().min(1)).default([]),\n});\n\nexport type LineageExecutor = z.infer<typeof lineageExecutorSchema>;\n\nexport const fanoutConfigSchema = z.object({\n  executors: z.array(lineageExecutorSchema).min(1),\n  assignment_model: z.enum(FANOUT_ASSIGNMENT_MODELS).default('flat_pool'),\n  concurrency: z.number().int().positive().default(2),\n  maxRetries: z.number().int().nonnegative().default(5),\n  // Stall detection defaults ON: a lineage that stops emitting progress is aborted and\n  // requeued within the ceiling and fails loud, instead of hanging silently at 0% CPU\n  // until the hours-scale subprocess timeout. Set 0 to opt out.\n  lagCeilingMs: z.number().int().nonnegative().default(300000),\n  progressHeartbeatSeconds: z.number().nonnegative().default(60),\n});\n\nexport type FanoutConfig = z.infer<typeof fanoutConfigSchema>;\n\n/**\n * Parse and validate a raw fan-out configuration.\n *\n * Each entry's executor subset is routed through {@link parseExecutorConfig} so\n * ALL existing kind/model/flag rules apply per lineage with zero duplication.\n * Labels must be unique and base-label (count>1) expansion must not collide.\n *\n * @param raw - Raw input to parse (JSON-parsed object).\n * @returns Validated FanoutConfig.\n * @throws {@link ExecutorConfigError} If validation fails.\n */\nexport function parseFanoutConfig(raw: unknown): FanoutConfig {\n  const parsed = fanoutConfigSchema.safeParse(raw);\n  if (!parsed.success) {\n    throw new ExecutorConfigError({ issues: parsed.error.issues.map((issue) => ({ path: issue.path, message: issue.message })) });","lineStart":1,"lineEnd":300,"totalLines":376,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts","time":{"start":1783487481927,"end":1783487481939}},"metadata":{"openai":{"itemId":"fc_0049ec1024c7bbc2016a4ddbf9d8708191b1d3ef746932bba6"}},"id":"prt_f4023482e001mS4MCczaWi7T8K","sessionID":"ses_0bfe020b5ffeoZNo5CdAcudSTe","messageID":"msg_f402312ad001vUkSy1SmM0dJA4"}}
{"type":"tool_use","timestamp":1783487482064,"sessionID":"ses_0bfe020b5ffeoZNo5CdAcudSTe","part":{"type":"tool","tool":"read","callID":"call_owQ2VS89CHx9y727GGYEXVlL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep Research State Reducer                                              ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: // ─────────────────────────────────────────────────────────────────────────────\n8: // 1. IMPORTS\n9: // ─────────────────────────────────────────────────────────────────────────────\n10: \n11: const fs = require('node:fs');\n12: const path = require('node:path');\n13: const crypto = require('node:crypto');\n14: const { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\n15: const { resolveArtifactRoot } = require('../../../deep-loop-runtime/lib/deep-loop/artifact-root.cjs');\n16: const {\n17:   buildCarriedForwardOpenQuestions,\n18:   deriveNextFocusFromContinuity,\n19:   formatCarriedForwardOpenQuestions,\n20: } = require('../../../deep-loop-runtime/lib/deep-loop/continuity-thread.cjs');\n21: const { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n22: \n23: // ─────────────────────────────────────────────────────────────────────────────\n24: // 2. HELPERS\n25: // ─────────────────────────────────────────────────────────────────────────────\n26: \n27: const DEFAULT_SPARKLINE_WIDTH = 20;\n28: const DEFAULT_TREND_FLATLINE_WINDOW = 3;\n29: const DEFAULT_REJECTED_PATTERN_CATEGORY = 'general';\n30: const DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD = 0.85;\n31: const DEFAULT_MIN_IDEA_OBSERVATIONS = 2;\n32: const MIN_IDEA_OBSERVATIONS = 1;\n33: const MAX_IDEA_OBSERVATIONS = 10;\n34: const INBOX_FILE_NAME = 'inbox.jsonl';\n35: const DEFAULT_INBOX_SOURCE = 'research-inbox';\n36: const LEGACY_IMPORT_ORIGIN = 'legacy-import';\n37: const LEGACY_IMPORT_SOURCE = 'key-questions';\n38: const QUESTION_CONFLICT_EVENT = 'question_conflict';\n39: const DEFAULT_QUESTION_DECISION = 'needs_decision';\n40: const MAX_REJECTED_PATTERNS = 100;\n41: const REJECTED_PATTERN_CANDIDATE_FIELDS = ['text', 'focus', 'nextFocus', 'pattern', 'idea', 'title'];\n42: const REJECTED_PATTERN_EVENT_FIELDS = ['pattern', 'idea', 'text', 'candidate'];\n43: const IDEA_EVENT_TEXT_FIELDS = ['idea', 'text', 'title', 'pattern', 'candidate'];\n44: const IDEA_OBSERVED_EVENTS = new Set(['idea_observed', 'ideaObserved']);\n45: const IDEA_PROMOTED_EVENTS = new Set(['idea_promoted', 'ideaPromoted']);\n46: const IDEA_REJECTED_EVENTS = new Set(['idea_rejected', 'ideaRejected']);\n47: const IDEA_REJECTED_REMOVED_EVENTS = new Set(['idea_rejected_removed', 'ideaRejectedRemoved']);\n48: const IDEA_REJECTED_RESET_EVENTS = new Set(['idea_rejected_reset', 'ideaRejectedReset']);\n49: const VALID_QUESTION_ORIGINS = new Set([\n50:   'angle-bank',\n51:   'analyst-strategy',\n52:   'operator',\n53:   LEGACY_IMPORT_ORIGIN,\n54: ]);\n55: const VALID_QUESTION_DECISIONS = new Set([\n56:   'accepted',\n57:   'rejected',\n58:   'superseded',\n59:   DEFAULT_QUESTION_DECISION,\n60: ]);\n61: const SPARKLINE_BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];\n62: \n63: function readUtf8(filePath) {\n64:   return fs.readFileSync(filePath, 'utf8');\n65: }\n66: \n67: function writeUtf8(filePath, content) {\n68:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n69:   fs.writeFileSync(filePath, content, 'utf8');\n70: }\n71: \n72: function readJson(filePath) {\n73:   return JSON.parse(readUtf8(filePath));\n74: }\n75: \n76: function getResourceMapEmitSetting(config) {\n77:   const nested = config && typeof config === 'object'\n78:     ? (config.resource_map || config.resourceMap || null)\n79:     : null;\n80:   if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n81:     return nested.emit;\n82:   }\n83:   return true;\n84: }\n85: \n86: function slugify(value) {\n87:   return value\n88:     .toLowerCase()\n89:     .replace(/[^a-z0-9]+/g, '-')\n90:     .replace(/^-+|-+$/g, '')\n91:     .slice(0, 80) || 'entry';\n92: }\n93: \n94: function normalizeText(value) {\n95:   return value.replace(/\\s+/g, ' ').trim();\n96: }\n97: \n98: function normalizeOptionalText(value) {\n99:   return typeof value === 'string' ? normalizeText(value) : '';\n100: }\n101: \n102: function normalizeQuestionOrigin(value) {\n103:   const origin = normalizeOptionalText(value).toLowerCase();\n104:   return VALID_QUESTION_ORIGINS.has(origin) ? origin : 'operator';\n105: }\n106: \n107: function normalizeQuestionSource(value, fallback) {\n108:   return normalizeOptionalText(value) || fallback;\n109: }\n110: \n111: function normalizeQuestionIteration(value) {\n112:   return isFiniteNumber(value) && value >= 0 ? Math.floor(value) : 0;\n113: }\n114: \n115: function normalizeQuestionId(value) {\n116:   const normalized = normalizeOptionalText(value);\n117:   return normalized || null;\n118: }\n119: \n120: function normalizeQuestionDecision(value) {\n\n(Showing lines 1-120 of 2758. Use offset=121 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Research State Reducer                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst crypto = require('node:crypto');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../../deep-loop-runtime/lib/deep-loop/artifact-root.cjs');\nconst {\n  buildCarriedForwardOpenQuestions,\n  deriveNextFocusFromContinuity,\n  formatCarriedForwardOpenQuestions,\n} = require('../../../deep-loop-runtime/lib/deep-loop/continuity-thread.cjs');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep Research State Reducer                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst crypto = require('node:crypto');\nconst { emitResourceMap } = require('../../shared/synthesis/resource-map.cjs');\nconst { resolveArtifactRoot } = require('../../../deep-loop-runtime/lib/deep-loop/artifact-root.cjs');\nconst {\n  buildCarriedForwardOpenQuestions,\n  deriveNextFocusFromContinuity,\n  formatCarriedForwardOpenQuestions,\n} = require('../../../deep-loop-runtime/lib/deep-loop/continuity-thread.cjs');\nconst { filterCompletionBearingRecords } = require('../../shared/progress/progress-record.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst DEFAULT_SPARKLINE_WIDTH = 20;\nconst DEFAULT_TREND_FLATLINE_WINDOW = 3;\nconst DEFAULT_REJECTED_PATTERN_CATEGORY = 'general';\nconst DEFAULT_REJECTED_PATTERN_FUZZY_THRESHOLD = 0.85;\nconst DEFAULT_MIN_IDEA_OBSERVATIONS = 2;\nconst MIN_IDEA_OBSERVATIONS = 1;\nconst MAX_IDEA_OBSERVATIONS = 10;\nconst INBOX_FILE_NAME = 'inbox.jsonl';\nconst DEFAULT_INBOX_SOURCE = 'research-inbox';\nconst LEGACY_IMPORT_ORIGIN = 'legacy-import';\nconst LEGACY_IMPORT_SOURCE = 'key-questions';\nconst QUESTION_CONFLICT_EVENT = 'question_conflict';\nconst DEFAULT_QUESTION_DECISION = 'needs_decision';\nconst MAX_REJECTED_PATTERNS = 100;\nconst REJECTED_PATTERN_CANDIDATE_FIELDS = ['text', 'focus', 'nextFocus', 'pattern', 'idea', 'title'];\nconst REJECTED_PATTERN_EVENT_FIELDS = ['pattern', 'idea', 'text', 'candidate'];\nconst IDEA_EVENT_TEXT_FIELDS = ['idea', 'text', 'title', 'pattern', 'candidate'];\nconst IDEA_OBSERVED_EVENTS = new Set(['idea_observed', 'ideaObserved']);\nconst IDEA_PROMOTED_EVENTS = new Set(['idea_promoted', 'ideaPromoted']);\nconst IDEA_REJECTED_EVENTS = new Set(['idea_rejected', 'ideaRejected']);\nconst IDEA_REJECTED_REMOVED_EVENTS = new Set(['idea_rejected_removed', 'ideaRejectedRemoved']);\nconst IDEA_REJECTED_RESET_EVENTS = new Set(['idea_rejected_reset', 'ideaRejectedReset']);\nconst VALID_QUESTION_ORIGINS = new Set([\n  'angle-bank',\n  'analyst-strategy',\n  'operator',\n  LEGACY_IMPORT_ORIGIN,\n]);\nconst VALID_QUESTION_DECISIONS = new Set([\n  'accepted',\n  'rejected',\n  'superseded',\n  DEFAULT_QUESTION_DECISION,\n]);\nconst SPARKLINE_BLOCKS = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];\n\nfunction readUtf8(filePath) {\n  return fs.readFileSync(filePath, 'utf8');\n}\n\nfunction writeUtf8(filePath, content) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.writeFileSync(filePath, content, 'utf8');\n}\n\nfunction readJson(filePath) {\n  return JSON.parse(readUtf8(filePath));\n}\n\nfunction getResourceMapEmitSetting(config) {\n  const nested = config && typeof config === 'object'\n    ? (config.resource_map || config.resourceMap || null)\n    : null;\n  if (nested && typeof nested === 'object' && typeof nested.emit === 'boolean') {\n    return nested.emit;\n  }\n  return true;\n}\n\nfunction slugify(value) {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/^-+|-+$/g, '')\n    .slice(0, 80) || 'entry';\n}\n\nfunction normalizeText(value) {\n  return value.replace(/\\s+/g, ' ').trim();\n}\n\nfunction normalizeOptionalText(value) {\n  return typeof value === 'string' ? normalizeText(value) : '';\n}\n\nfunction normalizeQuestionOrigin(value) {\n  const origin = normalizeOptionalText(value).toLowerCase();\n  return VALID_QUESTION_ORIGINS.has(origin) ? origin : 'operator';\n}\n\nfunction normalizeQuestionSource(value, fallback) {\n  return normalizeOptionalText(value) || fallback;\n}\n\nfunction normalizeQuestionIteration(value) {\n  return isFiniteNumber(value) && value >= 0 ? Math.floor(value) : 0;\n}\n\nfunction normalizeQuestionId(value) {\n  const normalized = normalizeOptionalText(value);\n  return normalized || null;\n}\n\nfunction normalizeQuestionDecision(value) {","lineStart":1,"lineEnd":120,"totalLines":2758,"truncated":true}},"title":".opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","time":{"start":1783487482048,"end":1783487482060}},"metadata":{"openai":{"itemId":"fc_0049ec1024c7bbc2016a4ddbf9d8848191afd3117d39a71523"}},"id":"prt_f4023487f001i69kd3EudlTH00","sessionID":"ses_0bfe020b5ffeoZNo5CdAcudSTe","messageID":"msg_f402312ad001vUkSy1SmM0dJA4"}}
