{
  "skill": "sk-doc",
  "version": "2.0.0.0",
  "description": "Declarative packet registry for the sk-doc parent hub: workflowMode + packetKind + backendKind + toolSurface + advisorRouting for each documentation-authoring workflow packet. The advisor routes the single sk-doc identity; the hub selects the workflow packet. Workflow-only hub (no surface axis), zero named extensions.",
  "discriminator": {
    "workflowMode": "Public hub/mode key; stable identity used by the hub router and this registry.",
    "packetKind": "Axis discriminator: workflow for all sk-doc packets (no surface packets).",
    "backendKind": "template-scaffold for the create-* document generators; create-quality-control for the validate/score/optimize-existing-doc workflow."
  },
  "advisorRoutingContract": {
    "routingClass": "metadata = resolved by hub membership (default for all sk-doc modes); command-bridge = reached only via its command, never advisor-scored. No lexical/alias-fold modes (avoids the advisor-projection extension + CI drift-guard).",
    "command": "The bound slash command for the mode, recorded even on metadata-routed modes; null when the mode has no dedicated command today.",
    "packetSkillName": "The packet SKILL.md name; folder == packetSkillName unless grandfatheredFolderMismatch is true.",
    "grandfatheredFolderMismatch": "false for every sk-doc mode (all folders are clean create-*/ names)."
  },
