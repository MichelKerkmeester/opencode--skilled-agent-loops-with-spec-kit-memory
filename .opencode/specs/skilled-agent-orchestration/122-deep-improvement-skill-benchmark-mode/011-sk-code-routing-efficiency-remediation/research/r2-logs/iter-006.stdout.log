{"type":"tool_use","timestamp":1780373229637,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"read","callID":"call_LmxUZ5EWfwDiycVKFWxPK2Xq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/browser-executor.cjs","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/browser-executor.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * browser-executor.cjs — Mode B executor for browser-gated scenarios (MR-*, CB-*).\n6:  *\n7:  * Those scenarios need a real browser (Motion CDN smoke, reduced-motion\n8:  * emulation, Core Web Vitals, GPU compositing), so they run through `bdg`\n9:  * (Chrome DevTools CLI), validated headless in the Phase 0 spike. Honesty is the\n10:  * hard rule: only scenarios whose pass-criteria map to a capturable signal get a\n11:  * PASS/FAIL; the rest report PARTIAL-NEEDS-ARTIFACT or SKIP-NO-BROWSER and NEVER\n12:  * a fabricated PASS. bdg is a single-session daemon, so scenarios run serially.\n13:  *\n14:  * Verdict → dims mapping (so aggregate's \"normalize over measured dims\" holds):\n15:  *   PASS → 1.0 · FAIL → 0 · PARTIAL → 0.5 (status: partial) · SKIP → null (non-penalizing)\n16:  */\n17: \n18: const fs = require('fs');\n19: const os = require('os');\n20: const path = require('path');\n21: const { spawnSync } = require('child_process');\n22: \n23: const BDG = process.env.BDG_BIN || 'bdg';\n24: \n25: function bdg(args, { timeout = 30000 } = {}) {\n26:   const res = spawnSync(BDG, args, { encoding: 'utf8', timeout, stdio: ['ignore', 'pipe', 'pipe'], maxBuffer: 8 * 1024 * 1024 });\n27:   return { status: res.status, stdout: (res.stdout || '').trim(), stderr: (res.stderr || '').trim() };\n28: }\n29: \n30: // Minimal Motion-CDN smoke page: imports the pinned Motion ESM bundle and\n31: // records export presence + a completed animate()/inView() on window.__skc.\n32: function motionSandboxHtml() {\n33:   return `<!doctype html><html><head><meta charset=\"utf-8\"></head><body><div id=\"t\">x</div>\n34: <script type=\"module\">\n35: window.__skc = { exportsOk: false, animateDone: false, error: null };\n36: try {\n37:   const m = await import('https://cdn.jsdelivr.net/npm/motion@12.15.0/+esm');\n38:   window.__skc.exportsOk = ['animate','inView','scroll'].every(k => typeof m[k] === 'function');\n39:   try { m.animate('#t', { opacity: [0,1] }, { duration: 0.01 }); window.__skc.animateDone = true; } catch(e) { window.__skc.error = String(e); }\n40: } catch (e) { window.__skc.error = String(e); }\n41: window.__skcReady = true;\n42: </script></body></html>`;\n43: }\n44: \n45: function verdictToDims(verdict) {\n46:   const v = verdict === 'PASS' ? 1 : verdict === 'FAIL' ? 0 : verdict.startsWith('PARTIAL') ? 0.5 : null;\n47:   const dim = (extra) => ({ score: v, ...(v === null ? { status: 'skip-needs-browser' } : {}), ...(extra || {}) });\n48:   return { d1intra: dim(), d2: dim(), d3: dim(), d1inter: { score: null, unscored: 'browser scenario' }, d4: { score: null, unscored: 'browser scenario' } };\n49: }\n50: \n51: function row(scenario, verdict, browser) {\n52:   const dims = verdictToDims(verdict);\n53:   const measured = [dims.d1intra.score, dims.d2.score, dims.d3.score].filter((s) => typeof s === 'number');\n54:   const modeAScore = measured.length ? Math.round((measured.reduce((a, b) => a + b, 0) / measured.length) * 100) : undefined;\n55:   return {\n56:     scenarioId: scenario.scenarioId, classKind: 'browser', tier: 'browser-gated',\n57:     modeAScore, firstFailingStage: verdict === 'PASS' ? null : 'browser',\n58:     dims, browser,\n59:   };\n60: }\n61: \n62: // Motion API smoke — the one fully-automatable browser scenario: load a Motion\n63: // sandbox headless and assert the API exports + a completed animation.\n64: function runMotionSmoke(scenario, sandboxDir) {\n65:   const page = path.join(sandboxDir, `skc-${scenario.scenarioId}.html`);\n66:   fs.writeFileSync(page, motionSandboxHtml());\n67:   const url = `file://${page}`;\n68:   const evidence = [page];\n69:   try {\n70:     const start = bdg([url, '--headless'], { timeout: 45000 });\n71:     if (start.status !== 0) return row(scenario, 'SKIP-NO-BROWSER', { verdict: 'SKIP-NO-BROWSER', reason: 'bdg failed to start', evidence, error: start.stderr.slice(0, 200) });\n72:     // wait for the module to settle, then read the smoke result\n73:     bdg(['dom', 'eval', 'new Promise(r=>{const t=setInterval(()=>{if(window.__skcReady){clearInterval(t);r(1)}},50);setTimeout(()=>r(1),4000)})'], { timeout: 8000 });\n74:     const smoke = bdg(['dom', 'eval', 'JSON.stringify(window.__skc||{})']);\n75:     const consoleErr = bdg(['console', '--list', '--level', 'error', '--json']);\n76:     let s = {};\n77:     try { s = JSON.parse(JSON.parse(smoke.stdout)); } catch { try { s = JSON.parse(smoke.stdout); } catch { s = {}; } }\n78:     const errCount = (() => { try { const j = JSON.parse(consoleErr.stdout); return Array.isArray(j) ? j.length : (j.entries ? j.entries.length : 0); } catch { return 0; } })();\n79:     const pass = s.exportsOk === true && s.animateDone === true && errCount === 0 && !s.error;\n80:     return row(scenario, pass ? 'PASS' : 'FAIL', {\n81:       verdict: pass ? 'PASS' : 'FAIL', signalsObserved: { ...s, consoleErrors: errCount }, evidence,\n82:     });\n83:   } finally {\n84:     bdg(['stop'], { timeout: 8000 });\n85:   }\n86: }\n87: \n88: /**\n89:  * Executor entrypoint (called by executor-dispatch.cjs browser branch).\n90:  * Honest per-scenario verdicts; never a fabricated PASS.\n91:  */\n92: function executeBrowserScenario({ scenario, sandboxDir } = {}) {\n93:   const dir = sandboxDir || fs.mkdtempSync(path.join(os.tmpdir(), 'skc-browser-'));\n94:   const id = scenario.scenarioId || '';\n95:   // Fully automatable: Motion API smoke.\n96:   if (id === 'MR-001') return runMotionSmoke(scenario, dir);\n97: \n98:   // The rest map to honest non-PASS verdicts pending the per-scenario harness:\n99:   //  - video-baseline diff: a harness can capture but not auto-judge.\n100:   //  - Safari/Firefox legs: bdg is Chrome-only -> escalate, never downgrade.\n101:   //  - CDN / reduced-motion / layout checks: partially capturable (rg/CWV/layout\n102:   //    counters) but the final judgement is assisted; report PARTIAL with\n103:   //    evidence, not a fabricated PASS.\n104:   const partial = {\n105:     'MR-002': { verdict: 'PARTIAL-NEEDS-ARTIFACT', reason: 'CDN @latest scan is CLI-checkable; export probe needs a per-URL harness' },\n106:     'MR-003': { verdict: 'PARTIAL-NEEDS-ARTIFACT', reason: 'reduced-motion media-query is checkable; motion-neutralization needs positional comparison' },\n107:     'MR-004': { verdict: 'PARTIAL-NEEDS-ARTIFACT', reason: 'video baseline diff is capture-only, not auto-judgeable' },\n108:     'CB-001': { verdict: 'PARTIAL-NEEDS-ARTIFACT', reason: 'Chrome leg automatable; Safari/Firefox out of bdg scope', escalation: 'cross-browser:safari,firefox' },\n109:     'CB-002': { verdict: 'PARTIAL-NEEDS-ARTIFACT', reason: 'LCP/CLS derivable via PerformanceObserver; INP needs a scripted interaction' },\n110:     'CB-003': { verdict: 'PARTIAL-NEEDS-ARTIFACT', reason: 'layout/recalc counters via Performance.getMetrics; compositor judgement assisted' },\n111:   }[id] || { verdict: 'SKIP-NO-BROWSER', reason: 'no browser-harness recipe for this scenario yet' };\n112:   return row(scenario, partial.verdict, { ...partial, evidence: [] });\n113: }\n114: \n115: module.exports = { executeBrowserScenario, verdictToDims, motionSandboxHtml };\n116: \n117: if (require.main === module) {\n118:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n119:   const out = executeBrowserScenario({ scenario: { scenarioId: args.scenario || 'MR-001' } });\n120:   process.stdout.write(JSON.stringify(out, null, 2) + '\\n');\n121:   process.exit(0);\n122: }\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * browser-executor.cjs — Mode B executor for browser-gated scenarios (MR-*, CB-*).\n *\n * Those scenarios need a real browser (Motion CDN smoke, reduced-motion\n * emulation, Core Web Vitals, GPU compositing), so they run through `bdg`\n * (Chrome DevTools CLI), validated headless in the Phase 0 spike. Honesty is the\n * hard rule: only scenarios whose pass-criteria map to a capturable signal get a\n * PASS/FAIL; the rest report PARTIAL-NEEDS-ARTIFACT or SKIP-NO-BROWSER and NEVER\n * a fabricated PASS. bdg is a single-session daemon, so scenarios run serially.\n *\n * Verdict → dims mapping (so aggregate's \"normalize over measured dims\" holds):\n *   PASS → 1.0 · FAIL → 0 · PARTIAL → 0.5 (status: partial) · SKIP → null (non-penalizing)\n */\n\nconst fs = require('fs');\nconst os = require('os');\nconst path = require('path');","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/browser-executor.cjs","time":{"start":1780373229612,"end":1780373229633}},"metadata":{"openai":{"itemId":"fc_03dfe1e62f9bf6f4016a1e56ed88f0819194a4347479858cc6"}},"id":"prt_e86839007001G5P09eavc51eAk","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e86836eb3001BmbrWTkhwIQvn3"}}
{"type":"tool_use","timestamp":1780373229638,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"read","callID":"call_k9YBVKPp76ezC15dHAqIJE5d","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/05--motion-dev-and-animation-regression/011-motion-api-smoke.md","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/05--motion-dev-and-animation-regression/011-motion-api-smoke.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"MR-001: Motion.dev API Smoke\"\n3: description: \"Verify a sandboxed Webflow-style page can load Motion via a pinned CDN module and smoke-test animate(), inView(), and spring() without console errors.\"\n4: ---\n5: \n6: # MR-001: Motion.dev API Smoke\n7: \n8: ## 1. OVERVIEW\n9: \n10: This scenario verifies the smallest useful motion.dev integration contract for sk-code Webflow work: a sandboxed page loads Motion from a pinned CDN URL, exposes the expected APIs, runs a basic `animate()` call, observes an `inView()` callback, and imports `spring()` without throwing.\n11: \n12: The scenario uses official Motion docs as API references:\n13: - `https://motion.dev/docs/quick-start`\n14: - `https://motion.dev/docs/animate`\n15: - `https://motion.dev/docs/inview`\n16: - `https://motion.dev/docs/spring`\n17: \n18: ---\n19: \n20: ## 2. SCENARIO CONTRACT\n21: \n22: Operators run the exact prompt and command sequence for `MR-001` and confirm the expected signals without contradictory browser evidence.\n23: \n24: | Feature ID | Feature Name | Scenario Name / Objective | Exact Prompt | Exact Command Sequence | Expected Signals | Evidence | Pass/Fail Criteria | Failure Triage |\n25: |---|---|---|---|---|---|---|---|---|\n26: | `MR-001` | Motion.dev API Smoke | Prove pinned CDN Motion exports and basic runtime calls work in a Webflow-style sandbox | `Create a Webflow-style Motion smoke page using pinned CDN animate, inView, and spring exports; return PASS/FAIL with console evidence.` | create `/tmp/skc-MR001-motion-smoke.html` -> open in Chrome -> inspect console -> click/run visible target -> save transcript | pinned `motion@<version>` URL; `typeof animate`, `typeof inView`, `typeof spring` are `function`; `animate()` resolves or completes; no uncaught console errors | `/tmp/skc-MR001-console.txt`, screenshot of animated element, smoke HTML path | PASS iff all exports are functions, `animate()` completes without throwing, `inView()` fires when target enters viewport, and console has no uncaught errors | If import fails, verify CDN URL and network; if export missing, compare with official Motion docs; if callback fails, verify element visibility and IntersectionObserver support |\n27: \n28: ## 3. TEST EXECUTION\n29: \n30: ### Prompt\n31: \n32: ```text\n33: Create a Webflow-style Motion smoke page using pinned CDN animate, inView, and spring exports; return PASS/FAIL with console evidence.\n34: ```\n35: \n36: ### Commands\n37: \n38: 1. Create `/tmp/skc-MR001-motion-smoke.html` with a minimal page that imports from `https://cdn.jsdelivr.net/npm/motion@12.15.0/+esm`.\n39: 2. In that page, run:\n40:    ```js\n41:    import { animate, inView, spring } from \"https://cdn.jsdelivr.net/npm/motion@12.15.0/+esm\";\n42:    console.log(\"MR-001 exports\", typeof animate, typeof inView, typeof spring);\n43:    const controls = animate(\"#mr-box\", { opacity: [0.2, 1], transform: [\"translateX(0px)\", \"translateX(24px)\"] }, { duration: 0.2 });\n44:    if (controls?.finished) controls.finished.then(() => console.log(\"MR-001 animate complete\"));\n45:    inView(\"#mr-box\", () => console.log(\"MR-001 inView fired\"));\n46:    console.log(\"MR-001 spring\", typeof spring);\n47:    ```\n48: 3. Open the file in Chrome with DevTools Console visible.\n49: 4. Save the console output to `/tmp/skc-MR001-console.txt`.\n50: \n51: ### Expected\n52: \n53: - Console includes `MR-001 exports function function function`.\n54: - Console includes `MR-001 animate complete` or equivalent animation-completion evidence.\n55: - Console includes `MR-001 inView fired`.\n56: - No uncaught `TypeError`, module import error, CSP error, or network error appears.\n57: \n58: ### Evidence\n59: \n60: - `/tmp/skc-MR001-console.txt`\n61: - Screenshot or short recording showing the box moved and opacity changed.\n62: - The exact CDN URL used in the sandbox file.\n63: \n64: ### Pass / Fail\n65: \n66: - **Pass**: all expected signals appear and no uncaught console errors are present.\n67: - **Fail**: any expected export is missing, `animate()` throws, `inView()` never fires after the element is visible, or the CDN import uses `@latest`.\n68: \n69: ### Failure Triage\n70: \n71: 1. If imports fail, verify the browser can reach `https://cdn.jsdelivr.net/npm/motion@12.15.0/+esm`.\n72: 2. If `spring` is missing, compare the pinned version against `https://motion.dev/docs/spring`.\n73: 3. If `inView()` does not fire, confirm the target selector exists and is in the viewport.\n74: 4. If the animation throws, reduce the target to only `opacity` and `transform` and retry.\n75: \n76: ---\n77: \n78: ## 4. SOURCE FILES\n79: \n80: ### Playbook Sources\n81: \n82: | File | Role |\n83: |---|---|\n84: | `../manual_testing_playbook.md` | Root directory page and scenario summary |\n85: | `../../references/motion_dev/quick_start.md` | Local Motion install and import-mode reference |\n86: | `../../references/motion_dev/animate_and_timelines.md` | Local `animate()` and sequence guidance |\n87: | `../../references/motion_dev/scroll_and_gestures.md` | Local `inView()` and viewport trigger guidance |\n88: | `https://motion.dev/docs/quick-start` | Official install and first-animation reference |\n89: | `https://motion.dev/docs/animate` | Official `animate()` reference |\n90: | `https://motion.dev/docs/inview` | Official `inView()` reference |\n91: | `https://motion.dev/docs/spring` | Official `spring()` reference |\n92: \n93: ### Implementation Anchors\n94: \n95: | File | Role |\n96: |---|---|\n97: | `../../../../../a_nobel_en_zn/2_javascript/slider/testimonial.js` | In-repo pinned ESM import pattern |\n98: | `../../../../../a_nobel_en_zn/2_javascript/navigation/nav_dropdown.js` | In-repo `window.Motion` runtime availability pattern |\n99: \n100: ---\n101: \n102: ## 5. SOURCE METADATA\n103: \n104: - Group: Motion.dev And Animation Regression\n105: - Playbook ID: MR-001\n106: - Critical path: Yes\n107: - Destructive: No\n108: - Sandbox: `/tmp/skc-MR001-motion-smoke.html`\n109: - Concurrent-safe: Yes\n110: - Last validated: pending first manual run\n\n(End of file - total 110 lines)\n</content>","metadata":{"preview":"---\ntitle: \"MR-001: Motion.dev API Smoke\"\ndescription: \"Verify a sandboxed Webflow-style page can load Motion via a pinned CDN module and smoke-test animate(), inView(), and spring() without console errors.\"\n---\n\n# MR-001: Motion.dev API Smoke\n\n## 1. OVERVIEW\n\nThis scenario verifies the smallest useful motion.dev integration contract for sk-code Webflow work: a sandboxed page loads Motion from a pinned CDN URL, exposes the expected APIs, runs a basic `animate()` call, observes an `inView()` callback, and imports `spring()` without throwing.\n\nThe scenario uses official Motion docs as API references:\n- `https://motion.dev/docs/quick-start`\n- `https://motion.dev/docs/animate`\n- `https://motion.dev/docs/inview`\n- `https://motion.dev/docs/spring`\n\n---\n\n## 2. SCENARIO CONTRACT","truncated":false,"loaded":[]},"title":".opencode/skills/sk-code/manual_testing_playbook/05--motion-dev-and-animation-regression/011-motion-api-smoke.md","time":{"start":1780373229619,"end":1780373229635}},"metadata":{"openai":{"itemId":"fc_03dfe1e62f9bf6f4016a1e56ed89048191a2be0aafdf5f37cf"}},"id":"prt_e8683902f001N5yNzP5PwkzPoo","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e86836eb3001BmbrWTkhwIQvn3"}}
{"type":"tool_use","timestamp":1780373229638,"sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","part":{"type":"tool","tool":"read","callID":"call_YjZMiSkiTVwP3G77puGGFU9r","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/01--surface-detection/002-opencode-detection.md","offset":1,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-code/manual_testing_playbook/01--surface-detection/002-opencode-detection.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"SD-002: OPENCODE Surface Detection\"\n3: description: \"Verify sk-code routes system-code prompts (paths under .opencode/) to the OPENCODE surface and loads the opencode/* reference and asset trees with correct sub-language detection.\"\n4: ---\n5: \n6: # SD-002: OPENCODE Surface Detection\n7: \n8: ## 1. OVERVIEW\n9: \n10: This scenario verifies that sk-code's smart router identifies OPENCODE as the active code surface when the prompt's CWD or target file path contains `/.opencode/`. OPENCODE covers all `.opencode/` system code across JavaScript, TypeScript, Python, Shell, and JSON/JSONC.\n11: \n12: When OPENCODE is detected, the router proceeds to language sub-detection (handled separately by LS-* scenarios) and loads the appropriate sub-language reference set.\n13: \n14: Detection markers are defined verbatim in `references/stack_detection.md:39-40` and SKILL.md smart router pseudocode lines 62-64.\n15: \n16: ## 2. SCENARIO CONTRACT\n17: \n18: **Realistic user request**: A maintainer working on the spec-kit MCP server asks the AI to harden a TypeScript scoring lane to handle empty input prompts gracefully.\n19: \n20: **Exact prompt**:\n21: ```\n22: Handle empty prompts in .opencode/skills/system-spec-kit/mcp_server/lib/scorer/lanes/explicit.ts with a TypeScript console.error fallback.\n23: ```\n24: \n25: **Expected detection**:\n26: - Surface: `OPENCODE` (target path contains `/.opencode/`)\n27: - Sub-language: `TYPESCRIPT` (target file extension `.ts`)\n28: \n29: **Expected references loaded**:\n30: - `references/stack_detection.md`\n31: - `references/smart_routing.md`\n32: - `references/smart_routing.md`\n33: - `references/universal/code_quality_standards.md`\n34: - `references/opencode/shared/code_organization.md`\n35: - `references/opencode/shared/universal_patterns.md`\n36: - `references/opencode/typescript/style_guide.md`\n37: - `references/opencode/typescript/quality_standards.md`\n38: - `references/opencode/typescript/quick_reference.md`\n39: \n40: **Expected assets loaded**:\n41: - `assets/opencode/checklists/typescript_checklist.md`\n42: - `assets/opencode/checklists/universal_checklist.md`\n43: \n44: **Expected NOT loaded**: any `references/webflow/*`, `references/opencode/python/*`, `references/opencode/shell/*`, `references/opencode/config/*`.\n45: \n46: **Expected agent dispatch**: `@code` (LEAF) for the edit, via `@orchestrate` (Depth: 1 marker), per the orchestrator-only convention in §0 of `.opencode/agents/code.md`.\n47: \n48: **Desired user-visible outcome**: The AI applies the edit to `.opencode/skills/system-spec-kit/mcp_server/lib/scorer/lanes/explicit.ts`, runs `verify_alignment_drift.py` for OPENCODE alignment evidence, and confirms the modification with a TypeScript-aware fix (early-return + console.error).\n49: \n50: ## 3. TEST EXECUTION\n51: \n52: ### Preconditions\n53: \n54: 1. `.opencode/skills/sk-code/SKILL.md` is at HEAD-of-main.\n55: 2. The target file exists: `bash: test -f .opencode/skills/system-spec-kit/mcp_server/lib/scorer/lanes/explicit.ts`.\n56: 3. The sub-language reference set exists: `bash: ls .opencode/skills/sk-code/references/opencode/typescript/` returns `style_guide.md quality_standards.md quick_reference.md`.\n57: 4. Skill advisor callable.\n58: \n59: ### Exact Command Sequence\n60: \n61: 1. **Advisor probe**:\n62:    ```\n63:    bash: python3 .opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py \"Handle empty prompts in .opencode/skills/system-spec-kit/mcp_server/lib/scorer/lanes/explicit.ts with a TypeScript console.error fallback.\" --threshold 0.8 > /tmp/skc-SD002-advisor.txt\n64:    ```\n65: 2. **Verify**: top-1 == `sk-code`, score ≥ 0.80.\n66: 3. **Invoke sk-code** with the same prompt.\n67: 4. **Capture surface + sub-language**: the AI's surface-detection log line should read `SURFACE: OPENCODE`, `LANGUAGE: TYPESCRIPT`.\n68: 5. **Capture loaded refs**: must include all 3 typescript/* refs, both shared/* refs, and the universal_checklist.md asset.\n69: 6. **Persist evidence** to `/tmp/skc-SD002-loaded-refs.txt`.\n70: \n71: ### Expected Signals\n72: \n73: | Step | Signal |\n74: |---|---|\n75: | 1 | Advisor: top_skill == sk-code, score ≥ 0.80. |\n76: | 3 | sk-code router emits `SURFACE: OPENCODE`. |\n77: | 4 | sk-code language sub-detection emits `LANGUAGE: TYPESCRIPT`. |\n78: | 5 | Loaded refs include `references/opencode/typescript/style_guide.md`, `quality_standards.md`, `quick_reference.md`, `references/opencode/shared/code_organization.md`, `assets/opencode/checklists/typescript_checklist.md`, `assets/opencode/checklists/universal_checklist.md`. NO `references/webflow/*`, NO `references/opencode/python/*`. |\n79: \n80: ### Pass/Fail Criteria\n81: \n82: - **PASS** iff: advisor wins sk-code AND surface == OPENCODE AND sub-language == TYPESCRIPT AND all 3 typescript/* refs + 2 shared/* refs loaded AND no other-surface or other-language refs loaded.\n83: - **PARTIAL** iff: surface + sub-language correct but quick_reference.md or one shared/* ref is missed (acceptable drift if all critical refs present).\n84: - **FAIL** iff: surface != OPENCODE OR sub-language != TYPESCRIPT OR any webflow/* OR python/* OR shell/* ref is loaded.\n85: \n86: ### Failure Triage\n87: \n88: 1. If advisor doesn't win sk-code: check `skill-graph.json` for sk-code signals \"opencode\", \"system code\", \"typescript\".\n89: 2. If surface != OPENCODE: verify target path detection in `references/stack_detection.md:39-40`. The path `.opencode/...` should match.\n90: 3. If sub-language != TYPESCRIPT: verify `.ts` extension is in the TYPESCRIPT extension list in SKILL.md sub-detection table (lines 78-90).\n91: 4. If `references/webflow/*` is loaded: the router has a leak — the WEBFLOW markers (motion.dev, GSAP, etc.) MUST NOT match this prompt. Verify the marker grep patterns are anchored correctly.\n92: \n93: ## 4. SOURCE FILES\n94: \n95: - `.opencode/skills/sk-code/SKILL.md` — Smart router + sub-detection table (lines 53-90).\n96: - `.opencode/skills/sk-code/references/stack_detection.md` — OPENCODE marker definition (lines 39-40).\n97: - `.opencode/skills/sk-code/references/opencode/typescript/` — Expected-loaded TypeScript references.\n98: - `.opencode/skills/sk-code/references/opencode/shared/` — Expected-loaded shared OPENCODE references.\n99: - `.opencode/skills/sk-code/assets/scripts/verify_alignment_drift.py` — OPENCODE alignment verifier (run after the edit for evidence).\n100: - `.opencode/agents/code.md` — @code agent dispatch convention.\n101: \n102: ## 5. SOURCE METADATA\n103: \n104: - **Created**: 2026-05-04\n105: - **Critical path**: Yes\n106: - **Destructive**: No (read-only routing test; the target file edit is described but not actually applied in routing tests)\n107: - **Sandbox**: production read-only; do not actually edit `.opencode/skills/system-spec-kit/mcp_server/lib/scorer/lanes/explicit.ts` during the routing test.\n108: - **Concurrent-safe**: Yes\n109: - **Last validated**: pending first manual run\n\n(End of file - total 109 lines)\n</content>","metadata":{"preview":"---\ntitle: \"SD-002: OPENCODE Surface Detection\"\ndescription: \"Verify sk-code routes system-code prompts (paths under .opencode/) to the OPENCODE surface and loads the opencode/* reference and asset trees with correct sub-language detection.\"\n---\n\n# SD-002: OPENCODE Surface Detection\n\n## 1. OVERVIEW\n\nThis scenario verifies that sk-code's smart router identifies OPENCODE as the active code surface when the prompt's CWD or target file path contains `/.opencode/`. OPENCODE covers all `.opencode/` system code across JavaScript, TypeScript, Python, Shell, and JSON/JSONC.\n\nWhen OPENCODE is detected, the router proceeds to language sub-detection (handled separately by LS-* scenarios) and loads the appropriate sub-language reference set.\n\nDetection markers are defined verbatim in `references/stack_detection.md:39-40` and SKILL.md smart router pseudocode lines 62-64.\n\n## 2. SCENARIO CONTRACT\n\n**Realistic user request**: A maintainer working on the spec-kit MCP server asks the AI to harden a TypeScript scoring lane to handle empty input prompts gracefully.\n\n**Exact prompt**:","truncated":false,"loaded":[]},"title":".opencode/skills/sk-code/manual_testing_playbook/01--surface-detection/002-opencode-detection.md","time":{"start":1780373229623,"end":1780373229636}},"metadata":{"openai":{"itemId":"fc_03dfe1e62f9bf6f4016a1e56ed890c819194af14a0ac8a1d05"}},"id":"prt_e86839035001Swco2pyHoADMpH","sessionID":"ses_1797e0d22ffeXZXWmRS3UmbrPG","messageID":"msg_e86836eb3001BmbrWTkhwIQvn3"}}
