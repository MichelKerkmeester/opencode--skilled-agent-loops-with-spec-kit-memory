isor-brief.ts\"\n21:     completion_pct: 5\n22:     open_questions: []\n23:     answered_questions:\n24:       - \"Gate 3 spec folder was pre-approved by the user for the full packet.\"\n25: template_source_hint: \"<!-- SPECKIT_TEMPLATE_SOURCE: plan-core + level2-verify | v2.2 -->\"\n26: ---\n27: # Implementation Plan: Smart-Router Remediation + OpenCode Plugin\n28: \n29: <!-- SPECKIT_LEVEL: 2 -->\n30: <!-- SPECKIT_TEMPLATE_SOURCE: plan-core + level2-verify | v2.2 -->\n31: \n32: ---\n33: \n34: <!-- ANCHOR:summary -->\n35: ## 1. SUMMARY\n36: \n37: ### Technical Context\n38: \n39: | Aspect | Value |\n40: |--------|-------|\n41: | **Language/Stack** | Markdown, Bash, TypeScript, JavaScript, Node.js |\n42: | **Framework** | OpenCode plugin API, Vitest, Spec Kit Memory MCP server |\n43: | **Storage** | JSONL telemetry under `.opencode/skills/.smart-router-telemetry/` |\n44: | **Testing** | Vitest, `tsc --noEmit`, static router check, spec validation |\n45: \n46: ### Overview\n47: \n48: Phase 023 turns the 021 smart-router research into concrete safeguards and a plugin. The work is ordered to reduce breakage: fix broken router paths first, add the static checker that proves path hygiene, tune conservative ON_DEMAND keywords from the corpus, replace unsafe CLI fallbacks, then add observe-only telemetry and the OpenCode advisor plugin.\n49: <!-- /ANCHOR:summary -->\n50: \n51: ---\n52: \n53: <!-- ANCHOR:quality-gates -->\n54: ## 2. QUALITY GATES\n55: \n56: ### Definition of Ready\n57: - [x] Problem statement clear and scope documented in `spec.md`\n58: - [x] Success criteria measurable across Areas A-F\n59: - [x] Required research and plugin/runtime reference files read before coding\n60: \n61: ### Definition of Done\n62: - [ ] Area A stale paths fixed and Area D check exits 0 for missing paths\n63: - [ ] Area B ON_DEMAND hit rate measured before and after with target >= 15%\n64: - [ ] Area C updates all 4 CLI skills to UNKNOWN fallback\n65: - [ ] Area E telemetry helper and tests pass\n66: - [ ] Area F plugin, bridge, and tests pass\n67: - [ ] Phase 020 tests remain green, `tsc --noEmit` is clean, and 023 validation is strict-clean\n68: <!-- /ANCHOR:quality-gates -->\n69: \n70: ---\n\n(Showing lines 1-70 of 213. Use offset=71 to continue.)\n</content>","metadata":{"preview":"---\ntitle: \".../026-graph-and-context-optimization/006-skill-advisor/003-smart-remediation-opencode-plugin/plan]\"\ndescription: \"Implements the six research recommendations from 021/002 and the 021/001 V8/V9 OpenCode plugin proposal. The plan keeps Phase 020 runtime code unchanged while adding router validation, telemetry, plugin integration, tests, and phase documentation.\"\ntrigger_phrases:\n  - \"023 smart router remediation plan\"\n  - \"spec-kit-skill-advisor plugin plan\"\nimportance_tier: \"important\"\ncontextType: \"implementation\"\n_memory:\n  continuity:\n    packet_pointer: \"system-spec-kit/026-graph-and-context-optimization/006-skill-advisor/003-smart-remediation-opencode-plugin\"\n    last_updated_at: \"2026-04-19T00:00:00Z\"\n    last_updated_by: \"codex\"\n    recent_action: \"Initialized Phase 023 implementation plan\"\n    next_safe_action: \"Execute Area A stale path remediation first, then Area D checker\"\n    blockers: []\n    key_files:\n      - \".opencode/specs/system-spec-kit/026-graph-and-context-optimization/006-skill-advisor/003-smart-remediation-opencode-plugin/spec.md\"\n      - \".opencode/plugins/spec-kit-compact-code-graph.js\"\n      - \".opencode/skills/system-spec-kit/mcp_server/lib/skill-advisor/skill-advisor-brief.ts\"","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-skill-advisor/003-skill-advisor-routing-engine/003-smart-remediation-opencode-plugin/plan.md","text":"---\ntitle: \".../026-graph-and-context-optimization/006-skill-advisor/003-smart-remediation-opencode-plugin/plan]\"\ndescription: \"Implements the six research recommendations from 021/002 and the 021/001 V8/V9 OpenCode plugin proposal. The plan keeps Phase 020 runtime code unchanged while adding router validation, telemetry, plugin integration, tests, and phase documentation.\"\ntrigger_phrases:\n  - \"023 smart router remediation plan\"\n  - \"spec-kit-skill-advisor plugin plan\"\nimportance_tier: \"important\"\ncontextType: \"implementation\"\n_memory:\n  continuity:\n    packet_pointer: \"system-spec-kit/026-graph-and-context-optimization/006-skill-advisor/003-smart-remediation-opencode-plugin\"\n    last_updated_at: \"2026-04-19T00:00:00Z\"\n    last_updated_by: \"codex\"\n    recent_action: \"Initialized Phase 023 implementation plan\"\n    next_safe_action: \"Execute Area A stale path remediation first, then Area D checker\"\n    blockers: []\n    key_files:\n      - \".opencode/specs/system-spec-kit/026-graph-and-context-optimization/006-skill-advisor/003-smart-remediation-opencode-plugin/spec.md\"\n      - \".opencode/plugins/spec-kit-compact-code-graph.js\"\n      - \".opencode/skills/system-spec-kit/mcp_server/lib/skill-advisor/skill-advisor-brief.ts\"\n    completion_pct: 5\n    open_questions: []\n    answered_questions:\n      - \"Gate 3 spec folder was pre-approved by the user for the full packet.\"\ntemplate_source_hint: \"<!-- SPECKIT_TEMPLATE_SOURCE: plan-core + level2-verify | v2.2 -->\"\n---\n# Implementation Plan: Smart-Router Remediation + OpenCode Plugin\n\n<!-- SPECKIT_LEVEL: 2 -->\n<!-- SPECKIT_TEMPLATE_SOURCE: plan-core + level2-verify | v2.2 -->\n\n---\n\n<!-- ANCHOR:summary -->\n## 1. SUMMARY\n\n### Technical Context\n\n| Aspect | Value |\n|--------|-------|\n| **Language/Stack** | Markdown, Bash, TypeScript, JavaScript, Node.js |\n| **Framework** | OpenCode plugin API, Vitest, Spec Kit Memory MCP server |\n| **Storage** | JSONL telemetry under `.opencode/skills/.smart-router-telemetry/` |\n| **Testing** | Vitest, `tsc --noEmit`, static router check, spec validation |\n\n### Overview\n\nPhase 023 turns the 021 smart-router research into concrete safeguards and a plugin. The work is ordered to reduce breakage: fix broken router paths first, add the static checker that proves path hygiene, tune conservative ON_DEMAND keywords from the corpus, replace unsafe CLI fallbacks, then add observe-only telemetry and the OpenCode advisor plugin.\n<!-- /ANCHOR:summary -->\n\n---\n\n<!-- ANCHOR:quality-gates -->\n## 2. QUALITY GATES\n\n### Definition of Ready\n- [x] Problem statement clear and scope documented in `spec.md`\n- [x] Success criteria measurable across Areas A-F\n- [x] Required research and plugin/runtime reference files read before coding\n\n### Definition of Done\n- [ ] Area A stale paths fixed and Area D check exits 0 for missing paths\n- [ ] Area B ON_DEMAND hit rate measured before and after with target >= 15%\n- [ ] Area C updates all 4 CLI skills to UNKNOWN fallback\n- [ ] Area E telemetry helper and tests pass\n- [ ] Area F plugin, bridge, and tests pass\n- [ ] Phase 020 tests remain green, `tsc --noEmit` is clean, and 023 validation is strict-clean\n<!-- /ANCHOR:quality-gates -->\n\n---","lineStart":1,"lineEnd":70,"totalLines":213,"truncated":true}},"title":".opencode/specs/system-skill-advisor/003-skill-advisor-routing-engine/003-smart-remediation-opencode-plugin/plan.md","time":{"start":1783433298348,"end":1783433298393}},"metadata":{"openai":{"itemId":"fc_04c66664f5c2d053016a4d08523e6c8191bb1d19bf42696074"}},"id":"prt_f3ce881ab001RNzwwugiyvK5EY","sessionID":"ses_0c31ab9feffeYOKG73D8b3S1Zu","messageID":"msg_f3ce84ebe0012tdzj1BzXU9FcO"}}
