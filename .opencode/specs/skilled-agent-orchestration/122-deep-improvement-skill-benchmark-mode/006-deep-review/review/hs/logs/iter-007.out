{"type":"tool_use","timestamp":1780205028245,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"type":"tool","tool":"read","callID":"call_function_ccafv2fgqadt_1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/advisor-probe.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/advisor-probe.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * advisor-probe.cjs — D1-inter signal: does the skill-advisor route a domain\n6:  * prompt to the target skill?\n7:  *\n8:  * Captured OUT-OF-BAND (the advisor never sees that it is being benchmarked):\n9:  * we run the in-repo Python advisor CLI (`skill_advisor.py`) over the PUBLIC\n10:  * prompt and read its ranked recommendations. This is DETERMINISTIC — the Python\n11:  * scorer reads the compiled SQLite skill graph, not an LLM — so it belongs in the\n12:  * Mode A deterministic core, not live mode. (The TS `scoreAdvisorPrompt` is the\n13:  * other entry point; the Python CLI is chosen here because it is process-isolated\n14:  * and needs no cross-language bridge from CJS.)\n15:  *\n16:  * Probing is opt-in (the orchestrator calls it only when --advisor-mode=python)\n17:  * so the pure-router Mode A default stays dependency-free and fast.\n18:  */\n19: \n20: const path = require('path');\n21: const { spawnSync } = require('child_process');\n22: \n23: const SKILLS_DIR = path.resolve(__dirname, '..', '..', '..'); // .opencode/skills\n24: const DEFAULT_ADVISOR_PY = path.join(\n25:   SKILLS_DIR, 'system-skill-advisor', 'mcp_server', 'scripts', 'skill_advisor.py',\n26: );\n27: \n28: /**\n29:  * Run the advisor over a prompt and return its ranked recommendations.\n30:  * @returns {{ ok: boolean, recommendations: Array<{skill:string,confidence:number}>,\n31:  *   topSkill: string|null, error?: string }}\n32:  */\n33: function probeAdvisor({ prompt, advisorPy, timeoutMs }) {\n34:   const py = advisorPy || DEFAULT_ADVISOR_PY;\n35:   const res = spawnSync('python3', [py, String(prompt || '')], {\n36:     encoding: 'utf8',\n37:     timeout: timeoutMs || 60000,\n38:     maxBuffer: 8 * 1024 * 1024,\n39:   });\n40:   if (res.status !== 0 || !res.stdout) {\n41:     return { ok: false, recommendations: [], topSkill: null, error: (res.stderr || `exit ${res.status}`).slice(0, 200) };\n42:   }\n43:   let parsed;\n44:   try {\n45:     parsed = JSON.parse(res.stdout);\n46:   } catch (err) {\n47:     return { ok: false, recommendations: [], topSkill: null, error: `unparseable advisor output: ${err.message}` };\n48:   }\n49:   const recs = (Array.isArray(parsed) ? parsed : []).map((r) => ({\n50:     skill: r.skill, confidence: typeof r.confidence === 'number' ? r.confidence : null,\n51:   }));\n52:   return { ok: true, recommendations: recs, topSkill: recs.length ? recs[0].skill : null };\n53: }\n54: \n55: /**\n56:  * Score the D1-inter dimension for one scenario from an advisor probe result.\n57:  * Rank-weighted: top-1 = 1.0, top-3 = 0.75, top-5 = 0.5, else 0. Negative\n58:  * scenarios invert: the target must NOT appear in the recommendations.\n59:  * @returns {{ score: number|null, rank: number|null, topSkill: string|null, ok: boolean }}\n60:  */\n61: function scoreD1Inter({ advisorResult, expectedSkillId, negative }) {\n62:   if (!advisorResult || !advisorResult.ok) return { score: null, rank: null, topSkill: null, ok: false };\n63:   const recs = advisorResult.recommendations;\n64:   const rankIdx = expectedSkillId ? recs.findIndex((r) => r.skill === expectedSkillId) : -1;\n65:   const rank = rankIdx === -1 ? null : rankIdx + 1;\n66:   if (negative) {\n67:     // should NOT activate: success = target absent from (or low in) the list.\n68:     return { score: rank === null || rank > 5 ? 1 : 0, rank, topSkill: advisorResult.topSkill, ok: true };\n69:   }\n70:   let score = 0;\n71:   if (rank === 1) score = 1;\n72:   else if (rank !== null && rank <= 3) score = 0.75;\n73:   else if (rank !== null && rank <= 5) score = 0.5;\n74:   return { score, rank, topSkill: advisorResult.topSkill, ok: true };\n75: }\n76: \n77: module.exports = { probeAdvisor, scoreD1Inter, DEFAULT_ADVISOR_PY };\n78: \n79: if (require.main === module) {\n80:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n81:   if (!args.prompt) {\n82:     process.stderr.write('usage: advisor-probe.cjs --prompt \"<text>\" [--advisor-py <path>]\\n');\n83:     process.exit(2);\n84:   }\n85:   const out = probeAdvisor({ prompt: args.prompt, advisorPy: args['advisor-py'] });\n86:   process.stdout.write(JSON.stringify(out, null, 2) + '\\n');\n87:   process.exit(out.ok ? 0 : 1);\n88: }\n\n(End of file - total 88 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * advisor-probe.cjs — D1-inter signal: does the skill-advisor route a domain\n * prompt to the target skill?\n *\n * Captured OUT-OF-BAND (the advisor never sees that it is being benchmarked):\n * we run the in-repo Python advisor CLI (`skill_advisor.py`) over the PUBLIC\n * prompt and read its ranked recommendations. This is DETERMINISTIC — the Python\n * scorer reads the compiled SQLite skill graph, not an LLM — so it belongs in the\n * Mode A deterministic core, not live mode. (The TS `scoreAdvisorPrompt` is the\n * other entry point; the Python CLI is chosen here because it is process-isolated\n * and needs no cross-language bridge from CJS.)\n *\n * Probing is opt-in (the orchestrator calls it only when --advisor-mode=python)\n * so the pure-router Mode A default stays dependency-free and fast.\n */\n\nconst path = require('path');","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/advisor-probe.cjs","time":{"start":1780205028228,"end":1780205028243}},"id":"prt_e7c7d0156001hWyX3opqqM2LB1","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","messageID":"msg_e7c7cf014001Ge4SKR7eSHzD73"}}
{"type":"tool_use","timestamp":1780205028302,"sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","part":{"type":"tool","tool":"read","callID":"call_function_ccafv2fgqadt_2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/d5-connectivity.cjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/d5-connectivity.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * d5-connectivity.cjs — static structural scan, the D5 hard gate.\n6:  *\n7:  * Runs BEFORE any dispatch and caps the verdict regardless of weighted score.\n8:  * Catches the failure class that makes a skill structurally unusable: a\n9:  * RESOURCE_MAP path that does not exist (dead route), a RESOURCE_MAP key absent\n10:  * from INTENT_SIGNALS (dead intent key), a routed path escaping the skill root,\n11:  * and references present on disk but never reachable from any RESOURCE_MAP entry\n12:  * (orphans — reported, not gated). A router that cannot be parsed at all is the\n13:  * strongest gate failure.\n14:  */\n15: \n16: const fs = require('fs');\n17: const path = require('path');\n18: const { parseRouter } = require('./router-replay.cjs');\n19: \n20: function listMarkdownRefs(skillRoot) {\n21:   const out = [];\n22:   for (const dir of ['references', 'assets']) {\n23:     const base = path.join(skillRoot, dir);\n24:     if (!fs.existsSync(base)) continue;\n25:     const stack = [base];\n26:     while (stack.length) {\n27:       const cur = stack.pop();\n28:       for (const entry of fs.readdirSync(cur, { withFileTypes: true })) {\n29:         const full = path.join(cur, entry.name);\n30:         if (entry.isDirectory()) stack.push(full);\n31:         else if (entry.isFile() && /\\.md$/.test(entry.name)) out.push(path.relative(skillRoot, full));\n32:       }\n33:     }\n34:   }\n35:   return out;\n36: }\n37: \n38: /**\n39:  * @returns {{ score:number, gateFailed:boolean, findings:Array,\n40:  *   deadResourcePaths:string[], deadIntentKeys:string[], orphanReferences:string[],\n41:  *   pathEscapes:string[], routerParseable:boolean }}\n42:  */\n43: function scanConnectivity({ skillRoot }) {\n44:   const findings = [];\n45:   const skillMdPath = path.join(skillRoot, 'SKILL.md');\n46:   if (!fs.existsSync(skillMdPath)) {\n47:     return {\n48:       score: 0, gateFailed: true, routerParseable: false,\n49:       deadResourcePaths: [], deadIntentKeys: [], orphanReferences: [], pathEscapes: [],\n50:       findings: [{ class: 'missing_skill_md', severity: 'P0', detail: 'SKILL.md not found' }],\n51:     };\n52:   }\n53:   const router = parseRouter(fs.readFileSync(skillMdPath, 'utf8'));\n54:   const intentKeys = new Set(Object.keys(router.intentSignals));\n55:   const deadResourcePaths = [];\n56:   const deadIntentKeys = [];\n57:   const pathEscapes = [];\n58:   const routedRefs = new Set();\n59: \n60:   for (const [intent, resources] of Object.entries(router.resourceMap)) {\n61:     if (!intentKeys.has(intent)) {\n62:       deadIntentKeys.push(intent);\n63:       findings.push({ class: 'dead_intent_key', severity: 'P1', locus: `RESOURCE_MAP.${intent}`, detail: `${intent} has no INTENT_SIGNALS entry` });\n64:     }\n65:     for (const r of resources) {\n66:       routedRefs.add(r);\n67:       const resolved = path.resolve(skillRoot, r);\n68:       if (!resolved.startsWith(path.resolve(skillRoot))) {\n69:         pathEscapes.push(r);\n70:         findings.push({ class: 'path_escape', severity: 'P0', locus: r, detail: `${r} resolves outside skill root` });\n71:       } else if (!fs.existsSync(resolved)) {\n72:         deadResourcePaths.push(r);\n73:         findings.push({ class: 'dead_resource_path', severity: 'P0', locus: r, detail: `routed path ${r} does not exist` });\n74:       }\n75:     }\n76:   }\n77: \n78:   const orphanReferences = listMarkdownRefs(skillRoot).filter((ref) => !routedRefs.has(ref));\n79:   for (const orphan of orphanReferences) {\n80:     findings.push({ class: 'orphan_reference', severity: 'P2', locus: orphan, detail: `${orphan} is not reachable from any RESOURCE_MAP intent` });\n81:   }\n82: \n83:   // Hard gate: any P0 (dead path / escape / unparseable). Dead intent keys (P1)\n84:   // and orphans (P2) lower the score but do not gate by themselves.\n85:   const p0 = findings.filter((f) => f.severity === 'P0').length;\n86:   const gateFailed = p0 > 0 || !router.parseable;\n87:   if (!router.parseable) {\n88:     findings.push({ class: 'router_unparseable', severity: 'P0', detail: 'INTENT_SIGNALS / RESOURCE_MAP could not be parsed from SKILL.md' });\n89:   }\n90:   // Score: start at 100, subtract per finding by severity, floor 0.\n91:   const penalty = findings.reduce((acc, f) => acc + ({ P0: 40, P1: 12, P2: 3 }[f.severity] || 0), 0);\n92:   const score = Math.max(0, 100 - penalty);\n93: \n94:   return { score, gateFailed, routerParseable: router.parseable, deadResourcePaths, deadIntentKeys, orphanReferences, pathEscapes, findings };\n95: }\n96: \n97: module.exports = { scanConnectivity, listMarkdownRefs };\n98: \n99: if (require.main === module) {\n100:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n101:   if (!args.skill) {\n102:     process.stderr.write('usage: d5-connectivity.cjs --skill <skill-root>\\n');\n103:     process.exit(2);\n104:   }\n105:   const res = scanConnectivity({ skillRoot: args.skill });\n106:   process.stdout.write(JSON.stringify(res, null, 2) + '\\n');\n107:   process.exit(res.gateFailed ? 1 : 0);\n108: }\n\n(End of file - total 108 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * d5-connectivity.cjs — static structural scan, the D5 hard gate.\n *\n * Runs BEFORE any dispatch and caps the verdict regardless of weighted score.\n * Catches the failure class that makes a skill structurally unusable: a\n * RESOURCE_MAP path that does not exist (dead route), a RESOURCE_MAP key absent\n * from INTENT_SIGNALS (dead intent key), a routed path escaping the skill root,\n * and references present on disk but never reachable from any RESOURCE_MAP entry\n * (orphans — reported, not gated). A router that cannot be parsed at all is the\n * strongest gate failure.\n */\n\nconst fs = require('fs');\nconst path = require('path');\nconst { parseRouter } = require('./router-replay.cjs');\n\nfunction listMarkdownRefs(skillRoot) {","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/d5-connectivity.cjs","time":{"start":1780205028288,"end":1780205028301}},"id":"prt_e7c7d0388001qfAAXw69rSCt42","sessionID":"ses_183834ea7ffeDt0PIETO3s5f2J","messageID":"msg_e7c7cf014001Ge4SKR7eSHzD73"}}
