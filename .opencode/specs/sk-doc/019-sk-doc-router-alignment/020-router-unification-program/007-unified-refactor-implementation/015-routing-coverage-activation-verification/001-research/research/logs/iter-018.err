   234	 *   3 when the D5 structural/registry gate blocked the verdict).
   235	 */
   236	function run(args) {
   237	  const skillRoot = resolveSkillRoot(args.skill);
   238	  const skillId = resolveSkillId(skillRoot);
   239	  const outputsDir = path.resolve(args['outputs-dir']);
   240	  fs.mkdirSync(outputsDir, { recursive: true });
   241	  const advisorMode = args['advisor-mode'] || 'off';
   242	  // The internal fallback stays 'router' so direct run() calls (the test suite)
   243	  // are deterministic; the live default is injected by loop-host for operators.
   244	  const traceMode = args['trace-mode'] || 'router';
