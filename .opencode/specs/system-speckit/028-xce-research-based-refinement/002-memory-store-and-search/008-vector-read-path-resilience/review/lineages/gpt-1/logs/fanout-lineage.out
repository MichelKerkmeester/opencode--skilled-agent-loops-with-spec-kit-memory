{"type":"tool_use","timestamp":1781151353140,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_ZpcYCTa3jV4w9gE7gECgnLDu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-health.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-health.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Health\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { randomUUID } from 'node:crypto';\n10: import { existsSync, readFileSync, statSync } from 'node:fs';\n11: import { resolve } from 'node:path';\n12: import type Database from 'better-sqlite3';\n13: \n14: import { checkDatabaseUpdated } from '../core/index.js';\n15: import { INDEX_SCAN_COOLDOWN } from '../core/config.js';\n16: import { getLastScanTime } from '../core/db-state.js';\n17: import * as vectorIndex from '../lib/search/vector-index.js';\n18: import { isMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n19: import * as embeddings from '../lib/providers/embeddings.js';\n20: import * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\n21: import { getRedactionStats } from '../lib/parsing/secret-scrubber.js';\n22: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n23: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n24: import { toErrorMessage } from '../utils/index.js';\n25: \n26: import { summarizeAliasConflicts } from './memory-index.js';\n27: import * as causalEdges from '../lib/storage/causal-edges.js';\n28: import { getCircuitFlapState, getEmbeddingRetryStats, getRetryStats } from '../lib/providers/retry-manager.js';\n29: import {\n30:   getSnapshot as getRoutingTelemetrySnapshot,\n31:   WINDOW_SIZE as ROUTING_TELEMETRY_WINDOW_SIZE,\n32: } from '../lib/search/routing-telemetry.js';\n33: import {\n34:   getByteEstimate as getEmbeddingCacheByteEstimate,\n35:   getEmbeddingCacheByProfileStats,\n36:   type EmbeddingCacheProfileStats,\n37: } from '../lib/cache/embedding-cache.js';\n38: import {\n39:   getCacheByteEstimates,\n40:   getDetailedMemorySnapshot,\n41:   type CacheByteEstimates,\n42:   type DetailedMemorySnapshot,\n43: } from '../lib/telemetry/heap-profiler.js';\n44: import { getBm25EngineStatus } from '../lib/search/bm25-index.js';\n45: import { getIpcBridgeStats, type IpcBridgeStats } from '../lib/ipc/socket-server.js';\n46: import {\n47:   getHardExclusionPredicates,\n48:   type HardExclusionPredicate,\n49:   type HardExclusionSource,\n50: } from '../lib/search/hybrid-search.js';\n51: import {\n52:   buildVectorDegradationSignal,\n53:   getMaintenanceObservabilitySnapshot,\n54: } from '../lib/observability/retrieval-observability.js';\n55: \n56: import type { MCPResponse, EmbeddingProfile } from './types.js';\n57: import type { HealthArgs, PartialProviderMetadata } from './memory-crud-types.js';\n58: \n59: // Feature catalog: Health diagnostics (memory_health)\n60: // Feature catalog: Validation feedback (memory_validate)\n61: // Feature catalog: Memory health autoRepair metadata\n62: \n63: \n64: /** Strip absolute paths, stack traces, and truncate for safe user-facing hints. */\n65: function sanitizeErrorForHint(msg: string): string {\n66:   return msg\n67:     .replace(/(^|[\\s(])\\/(?:[^/\\n]+\\/)*[^:\\n)\"'\\]]+/g, (_match, prefix: string) => `${prefix}[path]`)\n68:     .replace(/(^|[\\s(])[A-Za-z]:\\\\(?:[^\\\\\\n]+\\\\)*[^:\\n)\"'\\]]+/g, (_match, prefix: string) => `${prefix}[path]`)\n69:     .replace(/^[ \\t]*at .+$/gm, '')            // strip stack trace lines\n70:     .replace(/\\n{2,}/g, '\\n')                   // collapse blank lines left by stripping\n71:     .trim()\n72:     .slice(0, 200);\n73: }\n74: \n75: /** Redact absolute paths: keep only project-relative portion or basename. */\n76: function redactPath(absolutePath: string): string {\n77:   const normalizedPath = toNormalizedPath(absolutePath);\n78:   if (normalizedPath.startsWith('.opencode/')) return normalizedPath;\n79:   if (normalizedPath.startsWith('specs/')) return normalizedPath;\n80:   const opencodeIdx = normalizedPath.indexOf('/.opencode/');\n81:   const specsIdx = normalizedPath.indexOf('/specs/');\n82:   if (opencodeIdx !== -1) return normalizedPath.slice(opencodeIdx + 1);\n83:   if (specsIdx !== -1) return normalizedPath.slice(specsIdx + 1);\n84:   // Fallback: basename only\n85:   const lastSlash = normalizedPath.lastIndexOf('/');\n86:   return lastSlash !== -1 ? normalizedPath.slice(lastSlash + 1) : normalizedPath;\n87: }\n88: \n89: /* ───────────────────────────────────────────────────────────────\n90:    CONSTANTS\n91: ──────────────────────────────────────────────────────────────── */\n92: \n93: // Read version from package.json at module load time using ESM-relative paths.\n94: // WHY try-catch: if package.json is missing or malformed, the server should still start\n95: const SERVER_VERSION: string = (() => {\n96:   const packageCandidates = [\n97:     resolve(import.meta.dirname, '../package.json'),\n98:     resolve(import.meta.dirname, '../../package.json'),\n99:   ];\n100: \n101:   try {\n102:     for (const candidate of packageCandidates) {\n103:       if (!existsSync(candidate)) {\n104:         continue;\n105:       }\n106:       const pkg = JSON.parse(readFileSync(candidate, 'utf-8'));\n107:       if (pkg?.version) {\n108:         return pkg.version;\n109:       }\n110:     }\n111:     return 'unknown';\n112:   } catch (_error: unknown) {\n113:     return 'unknown';\n114:   }\n115: })();\n116: \n117: const DIVERGENT_ALIAS_REPORT_MODE = 'divergent_aliases';\n118: const DEFAULT_DIVERGENT_ALIAS_LIMIT = 20;\n119: const MAX_DIVERGENT_ALIAS_LIMIT = 200;\n120: const DOT_OPENCODE_SPECS_SEGMENT = '/.opencode/specs/';\n121: const SPECS_SEGMENT = '/specs/';\n122: const INDEX_HEALTH_STALENESS_MS = 24 * 60 * 60 * 1000;\n123: const INDEX_HEALTH_ORPHAN_SAMPLE_LIMIT = 200;\n124: const INDEX_SCAN_LEASE_EXPIRY_MS = INDEX_SCAN_COOLDOWN * 2;\n125: \n126: type IndexHealthSummary =\n127:   | 'healthy_fresh'\n128:   | 'healthy_lagging_vectors'\n129:   | 'stale_needs_scan'\n130:   | 'degraded_needs_repair'\n131:   | 'unavailable';\n132: \n133: interface IndexHealthBlock {\n134:   summary: IndexHealthSummary;\n135:   indexedRows: number;\n136:   pendingVectors: number;\n137:   retryVectors: number;\n138:   failedVectors: number;\n139:   orphanFiles: number | null;\n140:   lastScanAgeMs: number | null;\n141:   activeScanJob: boolean;\n142:   activeEmbedderJob: boolean;\n143:   note?: string;\n144: }\n145: \n146: interface AliasConflictDbRow {\n147:   file_path: string;\n148:   content_hash: string | null;\n149:   spec_folder?: string | null;\n150: }\n151: \n152: interface DivergentAliasVariant {\n153:   filePath: string;\n154:   contentHash: string | null;\n155: }\n156: \n157: interface DivergentAliasGroup {\n158:   normalizedPath: string;\n159:   specFolders: string[];\n160:   distinctHashCount: number;\n161:   variants: DivergentAliasVariant[];\n162: }\n163: \n164: interface DivergentAliasBucket {\n165:   hasDotOpencodeVariant: boolean;\n166:   hasSpecsVariant: boolean;\n167:   variants: Map<string, string | null>;\n168:   hashes: Set<string>;\n169:   specFolders: Set<string>;\n170: }\n171: \n172: interface FullMemoryReport {\n173:   includeFullReport: true;\n174:   memory_snapshot: DetailedMemorySnapshot;\n175:   cache_byte_estimates: CacheByteEstimates & {\n176:     embedding_cache_by_profile: Record<string, EmbeddingCacheProfileStats>;\n177:   };\n178:   ipc_bridge: IpcBridgeStats;\n179:   db_split: {\n180:     canonical_path: string;\n181:     canonical_size_mb: number;\n182:     shard_path: string;\n183:     shard_size_mb: number;\n184:     attached: boolean;\n185:     profile: {\n186:       provider: string;\n187:       model: string;\n188:       dim: number;\n189:       dtype?: string | null;\n190:     };\n191:     lexical_engine: 'auto' | 'sqlite' | 'packed-inmemory' | 'legacy-inmemory';\n192:     bm25_warm_status: {\n193:       enabled: boolean;\n194:       fts5_available: boolean;\n195:       warms_in_memory_bm25: boolean;\n196:     };\n197:   };\n198:   recommended_action: string;\n199: }\n200: \n201: type ExclusionAuditStatus = 'ok' | 'risk' | 'unclassified' | 'unavailable';\n202: type ExclusionAuditClassification = 'intended' | 'silent-risk' | 'unclassified';\n203: \n204: interface IntendedExclusionPolicy {\n205:   version: string;\n206:   intendedSources: HardExclusionSource[];\n207:   silentRiskSources: HardExclusionSource[];\n208: }\n209: \n210: interface ExclusionAuditEntry {\n211:   predicateId: string;\n212:   source: HardExclusionSource;\n213:   channel: string;\n214:   classification: ExclusionAuditClassification;\n215:   candidateRows: number | null;\n216: }\n217: \n218: interface ExclusionAuditDiagnostic {\n219:   code: 'hard-exclusion-risk' | 'exclusion-unclassified' | 'exclusion-audit-unavailable';\n220:   severity: 'info' | 'medium' | 'high';\n221:   message: string;\n222:   predicateId?: string;\n223:   source?: HardExclusionSource;\n224:   candidateRows?: number | null;\n225: }\n226: \n227: interface ExclusionAuditReport {\n228:   status: ExclusionAuditStatus;\n229:   policyVersion: string | null;\n230:   entries: ExclusionAuditEntry[];\n231:   diagnostics: ExclusionAuditDiagnostic[];\n232: }\n233: \n234: const DEFAULT_INTENDED_EXCLUSION_POLICY: IntendedExclusionPolicy = Object.freeze({\n235:   version: 'hard-exclusion-v1',\n236:   intendedSources: ['archived-tier'] as HardExclusionSource[],\n237:   silentRiskSources: ['deprecated-tier'] as HardExclusionSource[],\n238: });\n239: \n240: function toNormalizedPath(filePath: string): string {\n241:   return filePath.replace(/\\\\/g, '/');\n242: }\n243: \n244: function toSpecAliasKey(filePath: string): string {\n245:   const normalizedPath = toNormalizedPath(filePath);\n246:   return normalizedPath\n247:     .replace(/\\/\\.opencode\\/specs\\//g, '/specs/')\n248:     .replace(/^\\.opencode\\/specs\\//, 'specs/');\n249: }\n250: \n251: function isSpecsAliasPath(filePath: string): boolean {\n252:   const normalizedPath = toNormalizedPath(filePath);\n253:   return (\n254:     normalizedPath.includes(DOT_OPENCODE_SPECS_SEGMENT) ||\n255:     normalizedPath.includes(SPECS_SEGMENT) ||\n256:     normalizedPath.startsWith('.opencode/specs/') ||\n257:     normalizedPath.startsWith('specs/')\n258:   );\n259: }\n260: \n\n(Showing lines 1-260 of 1275. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Health\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\nimport { existsSync, readFileSync, statSync } from 'node:fs';\nimport { resolve } from 'node:path';\nimport type Database from 'better-sqlite3';\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN } from '../core/config.js';\nimport { getLastScanTime } from '../core/db-state.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { isMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-health.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Health\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomUUID } from 'node:crypto';\nimport { existsSync, readFileSync, statSync } from 'node:fs';\nimport { resolve } from 'node:path';\nimport type Database from 'better-sqlite3';\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN } from '../core/config.js';\nimport { getLastScanTime } from '../core/db-state.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { isMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport { getRedactionStats } from '../lib/parsing/secret-scrubber.js';\nimport * as incrementalIndex from '../lib/storage/incremental-index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { summarizeAliasConflicts } from './memory-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { getCircuitFlapState, getEmbeddingRetryStats, getRetryStats } from '../lib/providers/retry-manager.js';\nimport {\n  getSnapshot as getRoutingTelemetrySnapshot,\n  WINDOW_SIZE as ROUTING_TELEMETRY_WINDOW_SIZE,\n} from '../lib/search/routing-telemetry.js';\nimport {\n  getByteEstimate as getEmbeddingCacheByteEstimate,\n  getEmbeddingCacheByProfileStats,\n  type EmbeddingCacheProfileStats,\n} from '../lib/cache/embedding-cache.js';\nimport {\n  getCacheByteEstimates,\n  getDetailedMemorySnapshot,\n  type CacheByteEstimates,\n  type DetailedMemorySnapshot,\n} from '../lib/telemetry/heap-profiler.js';\nimport { getBm25EngineStatus } from '../lib/search/bm25-index.js';\nimport { getIpcBridgeStats, type IpcBridgeStats } from '../lib/ipc/socket-server.js';\nimport {\n  getHardExclusionPredicates,\n  type HardExclusionPredicate,\n  type HardExclusionSource,\n} from '../lib/search/hybrid-search.js';\nimport {\n  buildVectorDegradationSignal,\n  getMaintenanceObservabilitySnapshot,\n} from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse, EmbeddingProfile } from './types.js';\nimport type { HealthArgs, PartialProviderMetadata } from './memory-crud-types.js';\n\n// Feature catalog: Health diagnostics (memory_health)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Memory health autoRepair metadata\n\n\n/** Strip absolute paths, stack traces, and truncate for safe user-facing hints. */\nfunction sanitizeErrorForHint(msg: string): string {\n  return msg\n    .replace(/(^|[\\s(])\\/(?:[^/\\n]+\\/)*[^:\\n)\"'\\]]+/g, (_match, prefix: string) => `${prefix}[path]`)\n    .replace(/(^|[\\s(])[A-Za-z]:\\\\(?:[^\\\\\\n]+\\\\)*[^:\\n)\"'\\]]+/g, (_match, prefix: string) => `${prefix}[path]`)\n    .replace(/^[ \\t]*at .+$/gm, '')            // strip stack trace lines\n    .replace(/\\n{2,}/g, '\\n')                   // collapse blank lines left by stripping\n    .trim()\n    .slice(0, 200);\n}\n\n/** Redact absolute paths: keep only project-relative portion or basename. */\nfunction redactPath(absolutePath: string): string {\n  const normalizedPath = toNormalizedPath(absolutePath);\n  if (normalizedPath.startsWith('.opencode/')) return normalizedPath;\n  if (normalizedPath.startsWith('specs/')) return normalizedPath;\n  const opencodeIdx = normalizedPath.indexOf('/.opencode/');\n  const specsIdx = normalizedPath.indexOf('/specs/');\n  if (opencodeIdx !== -1) return normalizedPath.slice(opencodeIdx + 1);\n  if (specsIdx !== -1) return normalizedPath.slice(specsIdx + 1);\n  // Fallback: basename only\n  const lastSlash = normalizedPath.lastIndexOf('/');\n  return lastSlash !== -1 ? normalizedPath.slice(lastSlash + 1) : normalizedPath;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\n// Read version from package.json at module load time using ESM-relative paths.\n// WHY try-catch: if package.json is missing or malformed, the server should still start\nconst SERVER_VERSION: string = (() => {\n  const packageCandidates = [\n    resolve(import.meta.dirname, '../package.json'),\n    resolve(import.meta.dirname, '../../package.json'),\n  ];\n\n  try {\n    for (const candidate of packageCandidates) {\n      if (!existsSync(candidate)) {\n        continue;\n      }\n      const pkg = JSON.parse(readFileSync(candidate, 'utf-8'));\n      if (pkg?.version) {\n        return pkg.version;\n      }\n    }\n    return 'unknown';\n  } catch (_error: unknown) {\n    return 'unknown';\n  }\n})();\n\nconst DIVERGENT_ALIAS_REPORT_MODE = 'divergent_aliases';\nconst DEFAULT_DIVERGENT_ALIAS_LIMIT = 20;\nconst MAX_DIVERGENT_ALIAS_LIMIT = 200;\nconst DOT_OPENCODE_SPECS_SEGMENT = '/.opencode/specs/';\nconst SPECS_SEGMENT = '/specs/';\nconst INDEX_HEALTH_STALENESS_MS = 24 * 60 * 60 * 1000;\nconst INDEX_HEALTH_ORPHAN_SAMPLE_LIMIT = 200;\nconst INDEX_SCAN_LEASE_EXPIRY_MS = INDEX_SCAN_COOLDOWN * 2;\n\ntype IndexHealthSummary =\n  | 'healthy_fresh'\n  | 'healthy_lagging_vectors'\n  | 'stale_needs_scan'\n  | 'degraded_needs_repair'\n  | 'unavailable';\n\ninterface IndexHealthBlock {\n  summary: IndexHealthSummary;\n  indexedRows: number;\n  pendingVectors: number;\n  retryVectors: number;\n  failedVectors: number;\n  orphanFiles: number | null;\n  lastScanAgeMs: number | null;\n  activeScanJob: boolean;\n  activeEmbedderJob: boolean;\n  note?: string;\n}\n\ninterface AliasConflictDbRow {\n  file_path: string;\n  content_hash: string | null;\n  spec_folder?: string | null;\n}\n\ninterface DivergentAliasVariant {\n  filePath: string;\n  contentHash: string | null;\n}\n\ninterface DivergentAliasGroup {\n  normalizedPath: string;\n  specFolders: string[];\n  distinctHashCount: number;\n  variants: DivergentAliasVariant[];\n}\n\ninterface DivergentAliasBucket {\n  hasDotOpencodeVariant: boolean;\n  hasSpecsVariant: boolean;\n  variants: Map<string, string | null>;\n  hashes: Set<string>;\n  specFolders: Set<string>;\n}\n\ninterface FullMemoryReport {\n  includeFullReport: true;\n  memory_snapshot: DetailedMemorySnapshot;\n  cache_byte_estimates: CacheByteEstimates & {\n    embedding_cache_by_profile: Record<string, EmbeddingCacheProfileStats>;\n  };\n  ipc_bridge: IpcBridgeStats;\n  db_split: {\n    canonical_path: string;\n    canonical_size_mb: number;\n    shard_path: string;\n    shard_size_mb: number;\n    attached: boolean;\n    profile: {\n      provider: string;\n      model: string;\n      dim: number;\n      dtype?: string | null;\n    };\n    lexical_engine: 'auto' | 'sqlite' | 'packed-inmemory' | 'legacy-inmemory';\n    bm25_warm_status: {\n      enabled: boolean;\n      fts5_available: boolean;\n      warms_in_memory_bm25: boolean;\n    };\n  };\n  recommended_action: string;\n}\n\ntype ExclusionAuditStatus = 'ok' | 'risk' | 'unclassified' | 'unavailable';\ntype ExclusionAuditClassification = 'intended' | 'silent-risk' | 'unclassified';\n\ninterface IntendedExclusionPolicy {\n  version: string;\n  intendedSources: HardExclusionSource[];\n  silentRiskSources: HardExclusionSource[];\n}\n\ninterface ExclusionAuditEntry {\n  predicateId: string;\n  source: HardExclusionSource;\n  channel: string;\n  classification: ExclusionAuditClassification;\n  candidateRows: number | null;\n}\n\ninterface ExclusionAuditDiagnostic {\n  code: 'hard-exclusion-risk' | 'exclusion-unclassified' | 'exclusion-audit-unavailable';\n  severity: 'info' | 'medium' | 'high';\n  message: string;\n  predicateId?: string;\n  source?: HardExclusionSource;\n  candidateRows?: number | null;\n}\n\ninterface ExclusionAuditReport {\n  status: ExclusionAuditStatus;\n  policyVersion: string | null;\n  entries: ExclusionAuditEntry[];\n  diagnostics: ExclusionAuditDiagnostic[];\n}\n\nconst DEFAULT_INTENDED_EXCLUSION_POLICY: IntendedExclusionPolicy = Object.freeze({\n  version: 'hard-exclusion-v1',\n  intendedSources: ['archived-tier'] as HardExclusionSource[],\n  silentRiskSources: ['deprecated-tier'] as HardExclusionSource[],\n});\n\nfunction toNormalizedPath(filePath: string): string {\n  return filePath.replace(/\\\\/g, '/');\n}\n\nfunction toSpecAliasKey(filePath: string): string {\n  const normalizedPath = toNormalizedPath(filePath);\n  return normalizedPath\n    .replace(/\\/\\.opencode\\/specs\\//g, '/specs/')\n    .replace(/^\\.opencode\\/specs\\//, 'specs/');\n}\n\nfunction isSpecsAliasPath(filePath: string): boolean {\n  const normalizedPath = toNormalizedPath(filePath);\n  return (\n    normalizedPath.includes(DOT_OPENCODE_SPECS_SEGMENT) ||\n    normalizedPath.includes(SPECS_SEGMENT) ||\n    normalizedPath.startsWith('.opencode/specs/') ||\n    normalizedPath.startsWith('specs/')\n  );\n}\n","lineStart":1,"lineEnd":260,"totalLines":1275,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-health.ts","time":{"start":1781151353136,"end":1781151353139}},"metadata":{"openai":{"itemId":"fc_0de7b06352951b6c016a2a3679098081918aef0664da2a5aee"}},"id":"prt_eb4e4c920001YYN6wpHAvT7XM4","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e4a9e1001r90WyQiRd15CmV"}}
{"type":"tool_use","timestamp":1781151353149,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_pxeVafbCPn153w4liLzHELco","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/openltm-retrieval-observability.vitest.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/openltm-retrieval-observability.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { afterAll, afterEach, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest';\n2: \n3: import { formatSearchResults } from '../formatters/search-results.js';\n4: import { handleMemoryHealth } from '../handlers/memory-crud-health.js';\n5: import {\n6:   buildVectorDegradationSignal,\n7:   buildWhyRankedTrace,\n8:   getMaintenanceObservabilitySnapshot,\n9:   recordMaintenanceRun,\n10: } from '../lib/observability/retrieval-observability.js';\n11: import * as core from '../core/index.js';\n12: import * as vectorIndex from '../lib/search/vector-index.js';\n13: \n14: function parseResponse(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n15:   return JSON.parse(response.content[0]?.text ?? '{}') as Record<string, unknown>;\n16: }\n17: \n18: function dataFrom(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n19:   return parseResponse(response).data as Record<string, unknown>;\n20: }\n21: \n22: describe('OpenLTM retrieval observability', () => {\n23:   beforeAll(() => {\n24:     vectorIndex.closeDb();\n25:     vectorIndex.initializeDb(':memory:');\n26:   });\n27: \n28:   beforeEach(() => {\n29:     vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n30:   });\n31: \n32:   afterEach(() => {\n33:     vi.restoreAllMocks();\n34:   });\n35: \n36:   afterAll(() => {\n37:     vectorIndex.closeDb();\n38:   });\n39: \n40:   it('derives why_ranked from ranker intermediates without recomputing a display formula', async () => {\n41:     const rows = [\n42:       {\n43:         id: 11,\n44:         file_path: '/tmp/doc-a.md',\n45:         anchor_id: 'summary',\n46:         title: 'Doc A',\n47:         spec_folder: 'specs/test',\n48:         rrfScore: 0.91,\n49:         score: 0.91,\n50:         sourceScores: { vector: 0.8, fts: 0.2, bm25: 0.1, graph: 0.4, trigger: 0.6 },\n51:         importance_weight: 0.7,\n52:       },\n53:       {\n54:         id: 12,\n55:         file_path: '/tmp/doc-b.md',\n56:         anchor_id: 'decision',\n57:         title: 'Doc B',\n58:         spec_folder: 'specs/test',\n59:         rrfScore: 0.52,\n60:         score: 0.52,\n61:         sourceScores: { vector: 0.1, fts: 0.7, bm25: 0.3, graph: 0.1, trigger: 0.0 },\n62:         importance_weight: 0.4,\n63:       },\n64:     ];\n65: \n66:     const response = await formatSearchResults(rows, 'hybrid', false, null, null, null, {}, true);\n67:     const results = dataFrom(response).results as Array<Record<string, unknown>>;\n68:     const whyA = results[0].why_ranked as Record<string, unknown>;\n69:     const channelsA = whyA.channels as Record<string, number>;\n70: \n71:     expect(results.map((row) => row.filePath)).toEqual(['/tmp/doc-a.md', '/tmp/doc-b.md']);\n72:     expect(whyA).toMatchObject({\n73:       rank: 1,\n74:       effectiveScore: 0.91,\n75:       scoreSource: 'fusion',\n76:       source: 'ranker_intermediates',\n77:       document: { path: '/tmp/doc-a.md', anchor: 'summary' },\n78:     });\n79:     expect(channelsA).toMatchObject(rows[0].sourceScores);\n80:     expect(\n81:       Object.values(channelsA).reduce((sum, value) => sum + value, 0),\n82:     ).toBeGreaterThan(\n83:       Object.values((results[1].why_ranked as Record<string, unknown>).channels as Record<string, number>)\n84:         .reduce((sum, value) => sum + value, 0),\n85:     );\n86:   });\n87: \n88:   it('surfaces one inline warning for a returned contradicts or supersedes pair', async () => {\n89:     const db = vectorIndex.getDb();\n90:     db.prepare(`\n91:       INSERT INTO causal_edges(source_id, target_id, relation, strength, evidence)\n92:       VALUES (?, ?, 'contradicts', 1, ?)\n93:     `).run('21', '22', 'test edge');\n94: \n95:     const response = await formatSearchResults([\n96:       { id: 21, file_path: '/tmp/source.md', anchor_id: 'state', title: 'Source', spec_folder: 'specs/test', rrfScore: 0.8 },\n97:       { id: 22, file_path: '/tmp/target.md', anchor_id: 'state', title: 'Target', spec_folder: 'specs/test', rrfScore: 0.7 },\n98:     ], 'hybrid', false, null, null, null, {}, true);\n99:     const data = dataFrom(response);\n100:     const warnings = data.inlineWarnings as Array<Record<string, unknown>>;\n101: \n102:     expect(warnings).toHaveLength(1);\n103:     expect(warnings[0]).toMatchObject({\n104:       type: 'verify_before_applying',\n105:       relation: 'contradicts',\n106:     });\n107:     expect(warnings[0].documents).toEqual([\n108:       { path: '/tmp/source.md', anchor: 'state' },\n109:       { path: '/tmp/target.md', anchor: 'state' },\n110:     ]);\n111:   });\n112: \n113:   it('reports degraded-vector state in trace helpers and memory_health', async () => {\n114:     expect(buildVectorDegradationSignal(false)).toMatchObject({\n115:       degraded: true,\n116:       vectorSearchAvailable: false,\n117:       mode: 'lexical_only',\n118:       reason: 'vector_search_unavailable',\n119:     });\n120: \n121:     vi.spyOn(vectorIndex, 'isVectorSearchAvailable').mockReturnValue(false);\n122:     const response = await handleMemoryHealth({});\n123:     const data = dataFrom(response);\n124: \n125:     expect(data.vectorSearchAvailable).toBe(false);\n126:     expect(data.recallDegradation).toMatchObject({\n127:       degraded: true,\n128:       mode: 'lexical_only',\n129:       reason: 'vector_search_unavailable',\n130:     });\n131:   });\n132: \n133:   it('reports maintenance last-run counters and stale-candidate totals via memory_health', async () => {\n134:     recordMaintenanceRun('memory_index_scan', {\n135:       status: 'success',\n136:       counts: { scanned: 5, indexed: 2, staleDeleted: 1 },\n137:       staleCandidates: 3,\n138:     });\n139:     recordMaintenanceRun('memory_embedding_reconcile', {\n140:       status: 'success',\n141:       counts: { vectorPresentStatusStale: 4, missingActiveVectorRetryEligible: 1 },\n142:       staleCandidates: 5,\n143:     });\n144:     recordMaintenanceRun('memory_retention_sweep', {\n145:       status: 'success',\n146:       counts: { candidates: 2, swept: 2 },\n147:       staleCandidates: 2,\n148:     });\n149: \n150:     const response = await handleMemoryHealth({});\n151:     const maintenance = dataFrom(response).maintenance as ReturnType<typeof getMaintenanceObservabilitySnapshot>;\n152: \n153:     expect(maintenance.memory_index_scan.counts.scanned).toBe(5);\n154:     expect(maintenance.memory_index_scan.staleCandidates).toBe(3);\n155:     expect(maintenance.memory_embedding_reconcile.counts.vectorPresentStatusStale).toBe(4);\n156:     expect(maintenance.memory_embedding_reconcile.staleCandidates).toBe(5);\n157:     expect(maintenance.memory_retention_sweep.counts.swept).toBe(2);\n158:     expect(maintenance.memory_retention_sweep.staleCandidates).toBe(2);\n159:   });\n160: \n161:   it('does not alter ranking, decay fields, or persisted state when observability is enabled', async () => {\n162:     const rows = [\n163:       { id: 31, file_path: '/tmp/a.md', anchor_id: 'a', title: 'A', spec_folder: 'specs/test', rrfScore: 0.6, attentionScore: 0.2 },\n164:       { id: 32, file_path: '/tmp/b.md', anchor_id: 'b', title: 'B', spec_folder: 'specs/test', rrfScore: 0.5, attentionScore: 0.1 },\n165:     ];\n166:     const beforeRows = JSON.stringify(rows);\n167:     const db = vectorIndex.getDb();\n168:     const beforeEdges = (db.prepare('SELECT COUNT(*) AS count FROM causal_edges').get() as { count: number }).count;\n169: \n170:     const plain = await formatSearchResults(rows, 'hybrid', false, null, null, null, {}, false);\n171:     const traced = await formatSearchResults(rows, 'hybrid', false, null, null, null, {}, true);\n172:     const plainResults = dataFrom(plain).results as Array<Record<string, unknown>>;\n173:     const tracedResults = dataFrom(traced).results as Array<Record<string, unknown>>;\n174:     const afterEdges = (db.prepare('SELECT COUNT(*) AS count FROM causal_edges').get() as { count: number }).count;\n175: \n176:     expect(tracedResults.map((row) => row.filePath)).toEqual(plainResults.map((row) => row.filePath));\n177:     expect(JSON.stringify(rows)).toBe(beforeRows);\n178:     expect(afterEdges).toBe(beforeEdges);\n179:   });\n180: });\n181: \n182: describe('retrieval observability helper shape', () => {\n183:   it('keys why_ranked to document path and anchor, not the row identifier', () => {\n184:     const why = buildWhyRankedTrace({ id: 99, file_path: '/tmp/keyed.md', anchor_id: 'anchor', rrfScore: 0.7 }, 1);\n185: \n186:     expect(why.document).toEqual({ path: '/tmp/keyed.md', anchor: 'anchor' });\n187:     expect(JSON.stringify(why)).not.toContain('99');\n188:   });\n189: });\n\n(End of file - total 189 lines)\n</content>","metadata":{"preview":"import { afterAll, afterEach, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest';\n\nimport { formatSearchResults } from '../formatters/search-results.js';\nimport { handleMemoryHealth } from '../handlers/memory-crud-health.js';\nimport {\n  buildVectorDegradationSignal,\n  buildWhyRankedTrace,\n  getMaintenanceObservabilitySnapshot,\n  recordMaintenanceRun,\n} from '../lib/observability/retrieval-observability.js';\nimport * as core from '../core/index.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\n\nfunction parseResponse(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n  return JSON.parse(response.content[0]?.text ?? '{}') as Record<string, unknown>;\n}\n\nfunction dataFrom(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n  return parseResponse(response).data as Record<string, unknown>;\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/openltm-retrieval-observability.vitest.ts","text":"import { afterAll, afterEach, beforeAll, beforeEach, describe, expect, it, vi } from 'vitest';\n\nimport { formatSearchResults } from '../formatters/search-results.js';\nimport { handleMemoryHealth } from '../handlers/memory-crud-health.js';\nimport {\n  buildVectorDegradationSignal,\n  buildWhyRankedTrace,\n  getMaintenanceObservabilitySnapshot,\n  recordMaintenanceRun,\n} from '../lib/observability/retrieval-observability.js';\nimport * as core from '../core/index.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\n\nfunction parseResponse(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n  return JSON.parse(response.content[0]?.text ?? '{}') as Record<string, unknown>;\n}\n\nfunction dataFrom(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n  return parseResponse(response).data as Record<string, unknown>;\n}\n\ndescribe('OpenLTM retrieval observability', () => {\n  beforeAll(() => {\n    vectorIndex.closeDb();\n    vectorIndex.initializeDb(':memory:');\n  });\n\n  beforeEach(() => {\n    vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n  });\n\n  afterEach(() => {\n    vi.restoreAllMocks();\n  });\n\n  afterAll(() => {\n    vectorIndex.closeDb();\n  });\n\n  it('derives why_ranked from ranker intermediates without recomputing a display formula', async () => {\n    const rows = [\n      {\n        id: 11,\n        file_path: '/tmp/doc-a.md',\n        anchor_id: 'summary',\n        title: 'Doc A',\n        spec_folder: 'specs/test',\n        rrfScore: 0.91,\n        score: 0.91,\n        sourceScores: { vector: 0.8, fts: 0.2, bm25: 0.1, graph: 0.4, trigger: 0.6 },\n        importance_weight: 0.7,\n      },\n      {\n        id: 12,\n        file_path: '/tmp/doc-b.md',\n        anchor_id: 'decision',\n        title: 'Doc B',\n        spec_folder: 'specs/test',\n        rrfScore: 0.52,\n        score: 0.52,\n        sourceScores: { vector: 0.1, fts: 0.7, bm25: 0.3, graph: 0.1, trigger: 0.0 },\n        importance_weight: 0.4,\n      },\n    ];\n\n    const response = await formatSearchResults(rows, 'hybrid', false, null, null, null, {}, true);\n    const results = dataFrom(response).results as Array<Record<string, unknown>>;\n    const whyA = results[0].why_ranked as Record<string, unknown>;\n    const channelsA = whyA.channels as Record<string, number>;\n\n    expect(results.map((row) => row.filePath)).toEqual(['/tmp/doc-a.md', '/tmp/doc-b.md']);\n    expect(whyA).toMatchObject({\n      rank: 1,\n      effectiveScore: 0.91,\n      scoreSource: 'fusion',\n      source: 'ranker_intermediates',\n      document: { path: '/tmp/doc-a.md', anchor: 'summary' },\n    });\n    expect(channelsA).toMatchObject(rows[0].sourceScores);\n    expect(\n      Object.values(channelsA).reduce((sum, value) => sum + value, 0),\n    ).toBeGreaterThan(\n      Object.values((results[1].why_ranked as Record<string, unknown>).channels as Record<string, number>)\n        .reduce((sum, value) => sum + value, 0),\n    );\n  });\n\n  it('surfaces one inline warning for a returned contradicts or supersedes pair', async () => {\n    const db = vectorIndex.getDb();\n    db.prepare(`\n      INSERT INTO causal_edges(source_id, target_id, relation, strength, evidence)\n      VALUES (?, ?, 'contradicts', 1, ?)\n    `).run('21', '22', 'test edge');\n\n    const response = await formatSearchResults([\n      { id: 21, file_path: '/tmp/source.md', anchor_id: 'state', title: 'Source', spec_folder: 'specs/test', rrfScore: 0.8 },\n      { id: 22, file_path: '/tmp/target.md', anchor_id: 'state', title: 'Target', spec_folder: 'specs/test', rrfScore: 0.7 },\n    ], 'hybrid', false, null, null, null, {}, true);\n    const data = dataFrom(response);\n    const warnings = data.inlineWarnings as Array<Record<string, unknown>>;\n\n    expect(warnings).toHaveLength(1);\n    expect(warnings[0]).toMatchObject({\n      type: 'verify_before_applying',\n      relation: 'contradicts',\n    });\n    expect(warnings[0].documents).toEqual([\n      { path: '/tmp/source.md', anchor: 'state' },\n      { path: '/tmp/target.md', anchor: 'state' },\n    ]);\n  });\n\n  it('reports degraded-vector state in trace helpers and memory_health', async () => {\n    expect(buildVectorDegradationSignal(false)).toMatchObject({\n      degraded: true,\n      vectorSearchAvailable: false,\n      mode: 'lexical_only',\n      reason: 'vector_search_unavailable',\n    });\n\n    vi.spyOn(vectorIndex, 'isVectorSearchAvailable').mockReturnValue(false);\n    const response = await handleMemoryHealth({});\n    const data = dataFrom(response);\n\n    expect(data.vectorSearchAvailable).toBe(false);\n    expect(data.recallDegradation).toMatchObject({\n      degraded: true,\n      mode: 'lexical_only',\n      reason: 'vector_search_unavailable',\n    });\n  });\n\n  it('reports maintenance last-run counters and stale-candidate totals via memory_health', async () => {\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'success',\n      counts: { scanned: 5, indexed: 2, staleDeleted: 1 },\n      staleCandidates: 3,\n    });\n    recordMaintenanceRun('memory_embedding_reconcile', {\n      status: 'success',\n      counts: { vectorPresentStatusStale: 4, missingActiveVectorRetryEligible: 1 },\n      staleCandidates: 5,\n    });\n    recordMaintenanceRun('memory_retention_sweep', {\n      status: 'success',\n      counts: { candidates: 2, swept: 2 },\n      staleCandidates: 2,\n    });\n\n    const response = await handleMemoryHealth({});\n    const maintenance = dataFrom(response).maintenance as ReturnType<typeof getMaintenanceObservabilitySnapshot>;\n\n    expect(maintenance.memory_index_scan.counts.scanned).toBe(5);\n    expect(maintenance.memory_index_scan.staleCandidates).toBe(3);\n    expect(maintenance.memory_embedding_reconcile.counts.vectorPresentStatusStale).toBe(4);\n    expect(maintenance.memory_embedding_reconcile.staleCandidates).toBe(5);\n    expect(maintenance.memory_retention_sweep.counts.swept).toBe(2);\n    expect(maintenance.memory_retention_sweep.staleCandidates).toBe(2);\n  });\n\n  it('does not alter ranking, decay fields, or persisted state when observability is enabled', async () => {\n    const rows = [\n      { id: 31, file_path: '/tmp/a.md', anchor_id: 'a', title: 'A', spec_folder: 'specs/test', rrfScore: 0.6, attentionScore: 0.2 },\n      { id: 32, file_path: '/tmp/b.md', anchor_id: 'b', title: 'B', spec_folder: 'specs/test', rrfScore: 0.5, attentionScore: 0.1 },\n    ];\n    const beforeRows = JSON.stringify(rows);\n    const db = vectorIndex.getDb();\n    const beforeEdges = (db.prepare('SELECT COUNT(*) AS count FROM causal_edges').get() as { count: number }).count;\n\n    const plain = await formatSearchResults(rows, 'hybrid', false, null, null, null, {}, false);\n    const traced = await formatSearchResults(rows, 'hybrid', false, null, null, null, {}, true);\n    const plainResults = dataFrom(plain).results as Array<Record<string, unknown>>;\n    const tracedResults = dataFrom(traced).results as Array<Record<string, unknown>>;\n    const afterEdges = (db.prepare('SELECT COUNT(*) AS count FROM causal_edges').get() as { count: number }).count;\n\n    expect(tracedResults.map((row) => row.filePath)).toEqual(plainResults.map((row) => row.filePath));\n    expect(JSON.stringify(rows)).toBe(beforeRows);\n    expect(afterEdges).toBe(beforeEdges);\n  });\n});\n\ndescribe('retrieval observability helper shape', () => {\n  it('keys why_ranked to document path and anchor, not the row identifier', () => {\n    const why = buildWhyRankedTrace({ id: 99, file_path: '/tmp/keyed.md', anchor_id: 'anchor', rrfScore: 0.7 }, 1);\n\n    expect(why.document).toEqual({ path: '/tmp/keyed.md', anchor: 'anchor' });\n    expect(JSON.stringify(why)).not.toContain('99');\n  });\n});","lineStart":1,"lineEnd":189,"totalLines":189,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/openltm-retrieval-observability.vitest.ts","time":{"start":1781151353146,"end":1781151353148}},"metadata":{"openai":{"itemId":"fc_0de7b06352951b6c016a2a36790988819190eeed2551655cdf"}},"id":"prt_eb4e4c932001goF2QCgZ06DqUw","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e4a9e1001r90WyQiRd15CmV"}}
