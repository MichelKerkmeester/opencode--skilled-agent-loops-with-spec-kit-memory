   114	function confidenceFor(args: {
   115	  liveNormalized: number;
   116	  directScore: number;
   117	  readOnlyExplainer: boolean;
   118	  hasExplicitWorkflowSignal: boolean;
   119	  hasTaskIntent: boolean;
   120	  readOnlyRouteAllowed: boolean;
   121	  derivedDominant: boolean;
   122	  skillId: string;
   123	}): number {
   124	  const C = SCORING_CALIBRATION.confidence;
   125	  if (args.readOnlyExplainer && args.skillId === 'skill-advisor') return C.readOnlyExplainerFloor;
   126	  const base = C.baseConstant
   127	    + Math.min(1, args.liveNormalized * C.liveNormalizedRampGain) * C.liveNormalizedRampCoefficient;
   128	  if (args.readOnlyExplainer && !args.readOnlyRouteAllowed) return C.readOnlyExplainerFloor;
   129	  if (args.readOnlyRouteAllowed) {
   130	    return Number(Math.max(base, C.readOnlyRouteAllowedFloor).toFixed(4));
   131	  }
   132	  if (args.derivedDominant && args.directScore < C.derivedDominantDirectScoreCeiling) {
   133	    return C.derivedDominantConfidence;
   134	  }
   135	  if (args.hasTaskIntent
   136	    && (args.directScore >= C.taskIntentDirectScoreFloor
   137	      || args.liveNormalized >= C.taskIntentLiveNormalizedFloor)) {
   138	    // F-012-C2-03: Token-stuffing dispersion guard. Without this, a prompt
   139	    // with task-intent + many weak signals (saturating liveNormalized) but
   140	    // no strong direct anchor would force confidence to taskIntentFloor for
   141	    // many unrelated skills. The guard fires when liveNormalized is near-
   142	    // saturated AND directScore is below the directScoreLiftThreshold —
   143	    // the precise signature of a token-stuffed prompt. Legitimate task-intent
   144	    // prompts have at least one strong direct hit and pass via directScore;
   145	    // they don't hit this branch. When the guard fires we fall through to
   146	    // the standard `base + directBonus` math below.
   147	    const dispersionGuardTripped = args.liveNormalized >= 0.95
   148	      && args.directScore < C.directScoreLiftThreshold;
   149	    if (!dispersionGuardTripped) {
   150	      return Number(Math.max(base, C.taskIntentFloor).toFixed(4));
   151	    }
   152	  }
   153	  if (args.directScore >= C.directScoreLiftThreshold) {
   154	    return Number(Math.max(base, C.directScoreFloor).toFixed(4));
   155	  }
   156	  const directBonus = args.directScore >= C.directScoreBonusThreshold ? C.directScoreBonus : 0;
   157	  return Number(Math.max(0, Math.min(C.hardCeiling, base + directBonus)).toFixed(4));
   158	}
