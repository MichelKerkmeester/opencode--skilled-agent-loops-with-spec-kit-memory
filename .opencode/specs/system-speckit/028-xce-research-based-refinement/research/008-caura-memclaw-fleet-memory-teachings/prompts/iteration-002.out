ATE in\n2760:             # a single writer session — guarantees read-your-writes against\n2761:             # the row we just collided with, and avoids the prior\n2762:             # two-session window where the racing writer could DELETE\n2763:             # between our SELECT and our UPDATE.\n2764:             payload: dict[str, Any] = {\n2765:                 \"tenant_id\": item[\"tenant_id\"],\n2766:                 \"fleet_id\": item.get(\"fleet_id\"),\n2767:                 \"entity_type\": item[\"entity_type\"],\n2768:                 \"canonical_name\": item[\"canonical_name\"],\n2769:                 \"attributes\": item[\"attributes\"],\n2770:             }\n2771:             if item.get(\"name_embedding\") is not None:\n2772:                 payload[\"name_embedding\"] = item[\"name_embedding\"]\n2773: \n2774:             try:\n2775:                 async with get_session() as session:\n2776:                     new_entity = Entity(**payload)\n2777:                     session.add(new_entity)\n2778:                     await session.flush()\n2779:                     new_id = new_entity.id\n2780:                 results[item[\"input_idx\"]] = {\n2781:                     \"input_idx\": item[\"input_idx\"],\n2782:                     \"entity_id\": str(new_id),\n2783:                     \"action\": \"created\",\n2784:                 }\n2785:             except IntegrityError:\n2786:                 # TOCTOU recovery — SELECT + UPDATE in one writer session.\n2787:                 logger.info(\n2788:                     \"Entity bulk-upsert race: '%s' created concurrently, re-selecting\",\n2789:                     item[\"canonical_name\"],\n2790:                 )\n2791:                 async with get_session() as session:\n2792:                     sel = select(Entity).where(\n2793:                         Entity.tenant_id == item[\"tenant_id\"],\n2794:                         Entity.entity_type == item[\"entity_type\"],\n2795:                         f