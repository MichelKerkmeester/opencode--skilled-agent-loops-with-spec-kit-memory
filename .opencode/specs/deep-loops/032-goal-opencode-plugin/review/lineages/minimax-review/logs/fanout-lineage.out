inModule, stateDir }) => {\n469:      throw new Error('verifier failed with sk-secret123456 token=plain AKIA123456789012 Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxMjMifQ.signature eyJhbGciOiJIUzI1NiJ9.eyJmb28iOiJiYXIifQ.signature');\n474:  assert.doesNotMatch(verifierResult.reason, /sk-secret123456|token=plain|AKIA123456789012|Bearer eyJ|eyJhbGci/);\n475:  assert.match(verifierResult.reason, /\\[secret-redacted\\]/);\n480:  assert.doesNotMatch(rawVerifierState, /sk-secret123456|token=plain|AKIA123456789012|Bearer eyJ|eyJhbGci/);\n481:  assert.match(rawVerifierState, /\\[secret-redacted\\]/);\n","exit":0,"truncated":false},"title":"grep -nE \"secret|redact|bearer|sk-|api[_-]?key\" /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/tests/mk-goal-state.test.cjs | head -10","time":{"start":1783147400453,"end":1783147400454}},"id":"prt_f2bde084d001SZfM1bAjNoNVYy","sessionID":"ses_0d42abedcffewM196xEPACWSgW","messageID":"msg_f2bddf891001N46VN7GwUAsyf1"}}
