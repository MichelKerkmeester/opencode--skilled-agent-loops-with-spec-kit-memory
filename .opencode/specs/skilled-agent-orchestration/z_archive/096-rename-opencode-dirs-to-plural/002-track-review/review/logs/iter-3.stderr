codex
The security picture is taking shape. Hook command paths resolve and use `dist/hooks/*`, but the workflow write boundary is weaker than its prose says: `{spec_folder}` is fed raw into a resolver that accepts any path and then makes `{artifact_dir}` from it. I’m going to verify that with concrete resolver outputs before writing the finding.
exec
/bin/zsh -lc "{
  printf '%s\\n' 'RESOLVER HOSTILE INPUT DRY RUN';
  node - <<'NODE'
const { resolveArtifactRoot, normalizeSpecFolderReference } = require('./.opencode/skills/system-spec-kit/shared/review-research-paths.cjs');
for (const input of [
  '.opencode/specs/skilled-agent-orchestration/097-track-review',
  '.',
  '   ',
  '.opencode/specs/../../..',
  '/tmp/dr-escape',
  '{spec_folder}',
  '.opencode/specs/skilled-agent-orchestration/097-track-review/review/../..'
]) {
  try { console.log(JSON.stringify({input, normalized: normalizeSpecFolderReference(input), resolved: resolveArtifactRoot(input, 'review')})); }
  catch (e) { console.log(JSON.stringify({input, error: String(e.message || e)})); }
}
NODE
  printf '%s\\n' 'CODEX PRE TOOL POLICY'; nl -ba .opencode/skills/system-spec-kit/mcp_server/hooks/codex/pre-tool-use.ts | sed -n '1,240p';
  printf '%s\\n' 'DIST CODEX PRE TOOL POLICY'; nl -ba .opencode/skills/system-spec-kit/mcp_server/dist/hooks/codex/pre-tool-use.js | sed -n '1,180p';
  printf '%s\\n' 'HOOK SESSION STOP ENV SCRIPT'; nl -ba .opencode/skills/system-spec-kit/mcp_server/hooks/claude/session-stop.ts | sed -n '24,70p'; nl -ba .opencode/skills/system-spec-kit/mcp_server/hooks/claude/session-stop.ts | sed -n '180,215p';
