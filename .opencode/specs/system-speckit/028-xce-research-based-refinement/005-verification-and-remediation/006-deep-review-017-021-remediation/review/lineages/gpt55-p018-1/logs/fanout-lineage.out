514:       try {\n1515:         await setJobState(jobId, 'running');\n1516:         const response = await runIndexScan(args, {\n1517:           isCancelled: () => isCancelRequestedFast(jobId),\n1518:           onPhase: (phase) => {\n1519:             // Refresh at each phase boundary so a long synchronous tail phase (which\n1520:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1521:             maintenance.refresh();\n1522:             void setJobPhase(jobId, phase).catch(() => {});\n1523:           },\n1524:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1525:         });\n1526:         const scanData = extractEnvelopeData(response);\n1527:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1528:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1529:         if (wasCancelled) {\n1530:           // The run itself short-circuited on cancellation. A cancel that arrives\n1531:           // after the scan already finished does not retroactively cancel it.\n1532:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1533:         } else if (response.isError === true) {\n1534:           // An error envelope (not a thrown error) still means the scan failed.\n1535:           await appendJobError(jobId, '__scan__', scanData);\n1536:           await setJobState(jobId, 'failed');\n1537:         } else {\n1538:           await completeJob(jobId, { state: 'complete', result: scanData });\n1539:         }\n1540:       } catch (error: unknown) {\n1541:         try {\n1542:           await appendJobError(jobId, '__job__', error);\n1543:           await setJobState(jobId, 'failed');\n1544:         } catch (_secondaryError: unknown) {\n1545:           // Best-effort failure record; never surface a background unhandled rejection.\n1546:         }\n1547:       } finally {\n1548:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1549:         // Release this scan's hold; the marker stays present only while the\n1550:         // background-embedding queue still holds it.\n1551:         maintenance.end();\n1552:       }\n1553:     })();\n1554:   });\n1555: \n1556:   return createMCPSuccessResponse({\n1557:     tool: 'memory_index_scan',\n1558:     summary: `Queued background index scan ${jobId}`,\n1559:     data: { jobId, state: 'queued', background: true },\n1560:     hints: [\n1561:       'Use memory_index_scan_status with jobId to poll progress',\n1562:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1563:     ],\n1564:   });\n1565: }\n1566: \n1567: /* ───────────────────────────────────────────────────────────────\n1568:    9. EXPORTS\n1569: ──────────────────────────────────────────────────────────────── */\n\n(Showing lines 1480-1569 of 1598. Use offset=1570 to continue.)\n</content>","metadata":{"preview":"    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */","lineStart":1480,"lineEnd":1569,"totalLines":1598,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781756176326,"end":1781756176343}},"metadata":{"openai":{"itemId":"fc_0f2508451567dae5016a337110417881918aa82387c2744016"}},"id":"prt_ed8f1a7c4001cPOEMu31y471TV","sessionID":"ses_1270ff808ffewqP1i1p6C1RaMp","messageID":"msg_ed8f17dce001jVC62DlO25xYdb"}}
{"type":"tool_use","timestamp":1781756176345,"sessionID":"ses_1270ff808ffewqP1i1p6C1RaMp","part":{"type":"tool","tool":"read","callID":"call_Sauk1gGTegA8GgSguQFH7YoP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","offset":1010,"limit":350},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1010:     })),\n1011:   ];\n1012:   if (plannedScanActions.length > 0) {\n1013:     console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n1014:   }\n1015: \n1016:   // Track successfully indexed files for post-indexing mtime update.\n1017:   // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n1018:   // Failed files keep their old mtime so shouldReindex() returns 'modified'\n1019:   // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n1020:   // Before indexing would cause silent data loss — a failed file would be\n1021:   // Marked \"already indexed\" and permanently skipped.\n1022:   const successfullyIndexedFiles: string[] = [];\n1023:   const scanBatchSize = BATCH_SIZE;\n1024: \n1025:   ctx.onPhase?.('indexing');\n1026:   ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n1027: \n1028:   if (filesToIndex.length > 0) {\n1029:     let processedInScan = 0;\n1030:     const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n1031:       // Cancellation is checked between files (mirrors ingest). A cancelled file is\n1032:       // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n1033:       if (ctx.isCancelled?.()) {\n1034:         return { status: 'cancelled' } as IndexResult;\n1035:       }\n1036:       const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n1037:       // Constitutional markdown is policy text, not evidence-bearing memory.\n1038:       // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n1039:       // strict sufficiency gate would always reject it. Treat constitutional files like\n1040:       // spec docs and pass them through warn-only mode so they index against the same\n1041:       // pipeline without the document-evidence requirements.\n1042:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1043:       // During force reindex, use warn-only for all files — the goal is to index\n1044:       // everything that has valid frontmatter, not to enforce template contracts on\n1045:       // older files created before current templates were established.\n1046:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n1047:       const indexResult = await indexSingleFile(filePath, force, {\n1048:         ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n1049:         fromScan: true,\n1050:         asyncEmbedding: true,\n1051:         governance: governedIngest ? governanceDecision : undefined,\n1052:       });\n1053:       processedInScan += 1;\n1054:       ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n1055:       return indexResult;\n1056:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n1057: \n1058:     for (let i = 0; i < batchResults.length; i++) {\n1059:       const result = batchResults[i];\n1060:       const filePath = filesToIndex[i];\n1061:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1062: \n1063:       if (result.error) {\n1064:         results.failed++;\n1065:         results.files.push({\n1066:           file: path.basename(filePath),\n1067:           filePath,\n1068:           status: 'failed',\n1069:           error: result.error,\n1070:           errorDetail: result.errorDetail\n1071:         });\n1072:       } else if (isIndexResult(result)) {\n1073:         const isSuccessfulStatus =\n1074:           result.status === 'success' ||\n1075:           result.status === 'indexed' ||\n1076:           result.status === 'updated' ||\n1077:           result.status === 'unchanged' ||\n1078:           result.status === 'reinforced' ||\n1079:           result.status === 'duplicate' ||\n1080:           result.status === 'deferred';\n1081:         // A cancelled file was never indexed and was never going to be: counting it\n1082:         // as a failure would attribute an operator-requested stop to a file error.\n1083:         // It is neither success nor failure, so it falls through both tallies.\n1084:         if (!isSuccessfulStatus && result.status !== 'cancelled') {\n1085:           results.failed++;\n1086:         }\n1087: \n1088:         if (result.status === 'indexed') {\n1089:           results.indexed++;\n1090:           successfullyIndexedFiles.push(filePath);\n1091:           scanAppliedActions.push(createStatediffAction('insert', {\n1092:             target: 'memory_index',\n1093:             key: String(result.id ?? getCachedKey(filePath)),\n1094:             sourceOperation: 'scan',\n1095:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1096:           }));\n1097:         } else if (result.status === 'updated') {\n1098:           results.updated++;\n1099:           successfullyIndexedFiles.push(filePath);\n1100:           scanAppliedActions.push(createStatediffAction('upsert', {\n1101:             target: 'memory_index',\n1102:             key: String(result.id ?? getCachedKey(filePath)),\n1103:             sourceOperation: 'scan',\n1104:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1105:           }));\n1106:         } else if (result.status === 'unchanged') {\n1107:           results.unchanged++;\n1108:           successfullyIndexedFiles.push(filePath);\n1109:         } else if (result.status === 'reinforced') {\n1110:           results.updated++;\n1111:           successfullyIndexedFiles.push(filePath);\n1112:           scanAppliedActions.push(createStatediffAction('upsert', {\n1113:             target: 'memory_index',\n1114:             key: String(result.id ?? getCachedKey(filePath)),\n1115:             sourceOperation: 'scan',\n1116:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1117:           }));\n1118:         } else if (result.status === 'duplicate') {\n1119:           results.unchanged++;\n1120:           successfullyIndexedFiles.push(filePath);\n1121:         } else if (result.status === 'deferred') {\n1122:           results.indexed++;\n1123:           results.deferred++;\n1124:           successfullyIndexedFiles.push(filePath);\n1125:           scanAppliedActions.push(createStatediffAction('insert', {\n1126:             target: 'memory_index',\n1127:             key: String(result.id ?? getCachedKey(filePath)),\n1128:             sourceOperation: 'scan',\n1129:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1130:           }));\n1131:         }\n1132: \n1133:         if (isConstitutional) {\n1134:           if (result.status === 'indexed') {\n1135:             results.constitutional.indexed++;\n1136:           } else if (result.status === 'unchanged') {\n1137:             results.constitutional.alreadyIndexed++;\n1138:           }\n1139:         }\n1140: \n1141:         if (result.status !== 'unchanged') {\n1142:           const rejectionDetail = !isSuccessfulStatus\n1143:             ? {\n1144:                 ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n1145:                   ? { rejectionCode: result.rejectionCode }\n1146:                   : {}),\n1147:                 ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n1148:                   ? { rejectionReason: result.rejectionReason }\n1149:                   : (typeof result.message === 'string' && result.message.length > 0\n1150:                     ? { rejectionReason: result.message }\n1151:                     : {})),\n1152:                 ...(typeof result.error === 'string' && result.error.length > 0\n1153:                   ? { error: result.error }\n1154:                   : {}),\n1155:               }\n1156:             : {};\n1157: \n1158:           results.files.push({\n1159:             file: path.basename(filePath),\n1160:             filePath,\n1161:             specFolder: result.specFolder,\n1162:             status: result.status,\n1163:             id: result.id,\n1164:             isConstitutional,\n1165:             ...rejectionDetail,\n1166:           });\n1167:         }\n1168:       } else {\n1169:         results.failed++;\n1170:         results.files.push({\n1171:           file: path.basename(filePath),\n1172:           filePath,\n1173:           status: 'failed',\n1174:           error: 'Unexpected batch result shape',\n1175:           errorDetail: JSON.stringify(result),\n1176:         });\n1177:       }\n1178:     }\n1179:   }\n1180: \n1181:   // Update mtimes ONLY for successfully indexed files, not before indexing.\n1182:   // Failed files keep their old mtime so they are retried on next scan.\n1183:   // This is the ONLY place where scan-triggered mtime updates occur.\n1184:   // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n1185:   // Which rolls back atomically on failure — a complementary safety mechanism.\n1186:   if (successfullyIndexedFiles.length > 0) {\n1187:     const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n1188:     results.mtimeUpdates = mtimeUpdateResult.updated;\n1189:   }\n1190: \n1191:   if (include_spec_docs) {\n1192:     const database = requireDb();\n1193:     let promoterYieldCount = 0;\n1194:     for (const fileResult of results.files) {\n1195:       // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n1196:       // that is the whole corpus, so without a periodic macrotask yield the event\n1197:       // loop is starved for the duration and no IPC (status, cancel, health,\n1198:       // search) can be serviced. Yield and re-check cancellation between rows; the\n1199:       // yield lands between self-contained promoteMetadataEdges transactions, never\n1200:       // inside one, so atomicity on the shared connection is preserved.\n1201:       if (++promoterYieldCount % 200 === 0) {\n1202:         if (ctx.isCancelled?.()) {\n1203:           return cancelledScanEnvelope(scanKey);\n1204:         }\n1205:         await new Promise<void>((resolve) => setImmediate(resolve));\n1206:       }\n1207:       if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n1208:         continue;\n1209:       }\n1210:       try {\n1211:         const promotion = promoteMetadataEdges(database, {\n1212:           memoryId: fileResult.id,\n1213:           filePath: fileResult.filePath,\n1214:         });\n1215:         results.incremental.metadataPromoter.processed += promotion.processed;\n1216:         results.incremental.metadataPromoter.resolved += promotion.resolved;\n1217:         results.incremental.metadataPromoter.inserted += promotion.inserted;\n1218:         results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n1219:         results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n1220:         results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n1221:         results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n1222:         for (const warning of promotion.warnings) {\n1223:           results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n1224:         }\n1225:       } catch (error: unknown) {\n1226:         results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n1227:       }\n1228:     }\n1229:   }\n1230: \n1231:   if (ctx.isCancelled?.()) {\n1232:     return cancelledScanEnvelope(scanKey);\n1233:   }\n1234:   ctx.onPhase?.('post-processing');\n1235: \n1236:   if (filesToDelete.length > 0) {\n1237:     if (results.failed === 0) {\n1238:       const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n1239:       results.staleDeleted = staleDeleteResult.deleted;\n1240:       results.staleDeleteFailed = staleDeleteResult.failed;\n1241:       scanAppliedActions.push(...staleDeleteResult.actions);\n1242:     } else {\n1243:       console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n1244:     }\n1245:   }\n1246: \n1247:   const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n1248:   results.orphanSwept = orphanSweepResult.swept;\n1249:   results.orphanSweepFailed = orphanSweepResult.failed;\n1250:   results.orphanSweepScanned = orphanSweepResult.scannedRows;\n1251:   results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n1252:   scanAppliedActions.push(...orphanSweepResult.actions);\n1253: \n1254:   results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n1255:   if (results.postInsertEnrichmentRepaired > 0) {\n1256:     scanAppliedActions.push(createStatediffAction('upsert', {\n1257:       target: 'graph_edge',\n1258:       key: 'post-insert-enrichment-repair',\n1259:       sourceOperation: 'scan',\n1260:       metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n1261:     }));\n1262:   }\n1263: \n1264:   results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n1265:     runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n1266:   if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1267:     scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n1268:   }\n1269:   results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n1270: \n1271:   // Create causal chains between spec folder documents.\n1272:   // Includes deferred indexing outcomes and incremental single-file updates.\n1273:   if (include_spec_docs) {\n1274:     try {\n1275:       // Determine which spec folders had spec document changes in this scan.\n1276:       // We use parsed document type (not basename) to avoid false positives\n1277:       // From memory/plan.md or similar filenames.\n1278:       const affectedSpecFolders = new Set<string>();\n1279:       for (const fileResult of results.files) {\n1280:         if (!fileResult.specFolder || fileResult.status === 'failed') {\n1281:           continue;\n1282:         }\n1283: \n1284:         if (!fileResult.filePath) {\n1285:           continue;\n1286:         }\n1287: \n1288:         const docType = memoryParser.extractDocumentType(fileResult.filePath);\n1289:         if (\n1290:           docType !== 'memory' &&\n1291:           docType !== 'constitutional'\n1292:         ) {\n1293:           affectedSpecFolders.add(fileResult.specFolder);\n1294:         }\n1295:       }\n1296: \n1297:       if (affectedSpecFolders.size > 0) {\n1298:         const database = requireDb();\n1299:         const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n1300:         initCausalEdges(database);\n1301: \n1302:         // Build full per-folder document map from DB (not just this scan's files).\n1303:         const selectDocIds = database.prepare(`\n1304:           SELECT document_type, MAX(id) AS id\n1305:           FROM memory_index\n1306:           WHERE spec_folder = ?\n1307:             AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n1308:           GROUP BY document_type\n1309:         `);\n1310: \n1311:         let chainsCreated = 0;\n1312:         let foldersProcessed = 0;\n1313:         let chainYieldCount = 0;\n1314: \n1315:         for (const folder of affectedSpecFolders) {\n1316:           // Per-folder synchronous DB work; yield + cancel-check between folders so a\n1317:           // large affected set cannot block the event loop (same rationale as the\n1318:           // metadata-edge sweep above).\n1319:           if (++chainYieldCount % 50 === 0) {\n1320:             if (ctx.isCancelled?.()) {\n1321:               return cancelledScanEnvelope(scanKey);\n1322:             }\n1323:             await new Promise<void>((resolve) => setImmediate(resolve));\n1324:           }\n1325:           const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n1326:           const docIds: Record<string, number> = {};\n1327: \n1328:           for (const row of rows) {\n1329:             if (row.document_type && typeof row.id === 'number') {\n1330:               docIds[row.document_type] = row.id;\n1331:             }\n1332:           }\n1333: \n1334:           if (Object.keys(docIds).length >= 2) {\n1335:             const chainResult = createSpecDocumentChain(docIds);\n1336:             chainsCreated += chainResult.inserted;\n1337:             foldersProcessed++;\n1338:           }\n1339:         }\n1340: \n1341:         if (chainsCreated > 0) {\n1342:           console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n1343:         }\n1344:       }\n1345:     } catch (err: unknown) {\n1346:       const message = toErrorMessage(err);\n1347:       console.warn('[memory-index-scan] Causal chain creation failed:', message);\n1348:     }\n1349:   }\n1350: \n1351:   if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1352:     runScanInvalidationHooks({\n1353:       indexed: results.indexed,\n1354:       updated: results.updated,\n1355:       staleDeleted: results.staleDeleted,\n1356:       staleDeleteFailed: results.staleDeleteFailed,\n1357:       ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n1358:         ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n1359:         : {}),\n\n(Showing lines 1010-1359 of 1598. Use offset=1360 to continue.)\n</content>","metadata":{"preview":"    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss — a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss — a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;\n    const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n      // Cancellation is checked between files (mirrors ingest). A cancelled file is\n      // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n      if (ctx.isCancelled?.()) {\n        return { status: 'cancelled' } as IndexResult;\n      }\n      const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n      // Constitutional markdown is policy text, not evidence-bearing memory.\n      // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n      // strict sufficiency gate would always reject it. Treat constitutional files like\n      // spec docs and pass them through warn-only mode so they index against the same\n      // pipeline without the document-evidence requirements.\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n      // During force reindex, use warn-only for all files — the goal is to index\n      // everything that has valid frontmatter, not to enforce template contracts on\n      // older files created before current templates were established.\n      const useWarnOnly = force || isSpecDoc || isConstitutional;\n      const indexResult = await indexSingleFile(filePath, force, {\n        ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n        fromScan: true,\n        asyncEmbedding: true,\n        governance: governedIngest ? governanceDecision : undefined,\n      });\n      processedInScan += 1;\n      ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n      return indexResult;\n    }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n    for (let i = 0; i < batchResults.length; i++) {\n      const result = batchResults[i];\n      const filePath = filesToIndex[i];\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n\n      if (result.error) {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: result.error,\n          errorDetail: result.errorDetail\n        });\n      } else if (isIndexResult(result)) {\n        const isSuccessfulStatus =\n          result.status === 'success' ||\n          result.status === 'indexed' ||\n          result.status === 'updated' ||\n          result.status === 'unchanged' ||\n          result.status === 'reinforced' ||\n          result.status === 'duplicate' ||\n          result.status === 'deferred';\n        // A cancelled file was never indexed and was never going to be: counting it\n        // as a failure would attribute an operator-requested stop to a file error.\n        // It is neither success nor failure, so it falls through both tallies.\n        if (!isSuccessfulStatus && result.status !== 'cancelled') {\n          results.failed++;\n        }\n\n        if (result.status === 'indexed') {\n          results.indexed++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'updated') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'unchanged') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'reinforced') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'duplicate') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'deferred') {\n          results.indexed++;\n          results.deferred++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        }\n\n        if (isConstitutional) {\n          if (result.status === 'indexed') {\n            results.constitutional.indexed++;\n          } else if (result.status === 'unchanged') {\n            results.constitutional.alreadyIndexed++;\n          }\n        }\n\n        if (result.status !== 'unchanged') {\n          const rejectionDetail = !isSuccessfulStatus\n            ? {\n                ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n                  ? { rejectionCode: result.rejectionCode }\n                  : {}),\n                ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n                  ? { rejectionReason: result.rejectionReason }\n                  : (typeof result.message === 'string' && result.message.length > 0\n                    ? { rejectionReason: result.message }\n                    : {})),\n                ...(typeof result.error === 'string' && result.error.length > 0\n                  ? { error: result.error }\n                  : {}),\n              }\n            : {};\n\n          results.files.push({\n            file: path.basename(filePath),\n            filePath,\n            specFolder: result.specFolder,\n            status: result.status,\n            id: result.id,\n            isConstitutional,\n            ...rejectionDetail,\n          });\n        }\n      } else {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: 'Unexpected batch result shape',\n          errorDetail: JSON.stringify(result),\n        });\n      }\n    }\n  }\n\n  // Update mtimes ONLY for successfully indexed files, not before indexing.\n  // Failed files keep their old mtime so they are retried on next scan.\n  // This is the ONLY place where scan-triggered mtime updates occur.\n  // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n  // Which rolls back atomically on failure — a complementary safety mechanism.\n  if (successfullyIndexedFiles.length > 0) {\n    const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n    results.mtimeUpdates = mtimeUpdateResult.updated;\n  }\n\n  if (include_spec_docs) {\n    const database = requireDb();\n    let promoterYieldCount = 0;\n    for (const fileResult of results.files) {\n      // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n      // that is the whole corpus, so without a periodic macrotask yield the event\n      // loop is starved for the duration and no IPC (status, cancel, health,\n      // search) can be serviced. Yield and re-check cancellation between rows; the\n      // yield lands between self-contained promoteMetadataEdges transactions, never\n      // inside one, so atomicity on the shared connection is preserved.\n      if (++promoterYieldCount % 200 === 0) {\n        if (ctx.isCancelled?.()) {\n          return cancelledScanEnvelope(scanKey);\n        }\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n        continue;\n      }\n      try {\n        const promotion = promoteMetadataEdges(database, {\n          memoryId: fileResult.id,\n          filePath: fileResult.filePath,\n        });\n        results.incremental.metadataPromoter.processed += promotion.processed;\n        results.incremental.metadataPromoter.resolved += promotion.resolved;\n        results.incremental.metadataPromoter.inserted += promotion.inserted;\n        results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n        results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n        results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n        results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n        for (const warning of promotion.warnings) {\n          results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n        }\n      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }\n  }\n\n  const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n  results.orphanSwept = orphanSweepResult.swept;\n  results.orphanSweepFailed = orphanSweepResult.failed;\n  results.orphanSweepScanned = orphanSweepResult.scannedRows;\n  results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n  scanAppliedActions.push(...orphanSweepResult.actions);\n\n  results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n  if (results.postInsertEnrichmentRepaired > 0) {\n    scanAppliedActions.push(createStatediffAction('upsert', {\n      target: 'graph_edge',\n      key: 'post-insert-enrichment-repair',\n      sourceOperation: 'scan',\n      metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n    }));\n  }\n\n  results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n    runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n  if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n  }\n  results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n  // Create causal chains between spec folder documents.\n  // Includes deferred indexing outcomes and incremental single-file updates.\n  if (include_spec_docs) {\n    try {\n      // Determine which spec folders had spec document changes in this scan.\n      // We use parsed document type (not basename) to avoid false positives\n      // From memory/plan.md or similar filenames.\n      const affectedSpecFolders = new Set<string>();\n      for (const fileResult of results.files) {\n        if (!fileResult.specFolder || fileResult.status === 'failed') {\n          continue;\n        }\n\n        if (!fileResult.filePath) {\n          continue;\n        }\n\n        const docType = memoryParser.extractDocumentType(fileResult.filePath);\n        if (\n          docType !== 'memory' &&\n          docType !== 'constitutional'\n        ) {\n          affectedSpecFolders.add(fileResult.specFolder);\n        }\n      }\n\n      if (affectedSpecFolders.size > 0) {\n        const database = requireDb();\n        const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n        initCausalEdges(database);\n\n        // Build full per-folder document map from DB (not just this scan's files).\n        const selectDocIds = database.prepare(`\n          SELECT document_type, MAX(id) AS id\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n          GROUP BY document_type\n        `);\n\n        let chainsCreated = 0;\n        let foldersProcessed = 0;\n        let chainYieldCount = 0;\n\n        for (const folder of affectedSpecFolders) {\n          // Per-folder synchronous DB work; yield + cancel-check between folders so a\n          // large affected set cannot block the event loop (same rationale as the\n          // metadata-edge sweep above).\n          if (++chainYieldCount % 50 === 0) {\n            if (ctx.isCancelled?.()) {\n              return cancelledScanEnvelope(scanKey);\n            }\n            await new Promise<void>((resolve) => setImmediate(resolve));\n          }\n          const rows = selectDocIds.all(folder) as Array<{ document_type: string; id: number }>;\n          const docIds: Record<string, number> = {};\n\n          for (const row of rows) {\n            if (row.document_type && typeof row.id === 'number') {\n              docIds[row.document_type] = row.id;\n            }\n          }\n\n          if (Object.keys(docIds).length >= 2) {\n            const chainResult = createSpecDocumentChain(docIds);\n            chainsCreated += chainResult.inserted;\n            foldersProcessed++;\n          }\n        }\n\n        if (chainsCreated > 0) {\n          console.error(`[memory-index-scan] Created ${chainsCreated} causal chain edges across ${foldersProcessed} spec folders`);\n        }\n      }\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      console.warn('[memory-index-scan] Causal chain creation failed:', message);\n    }\n  }\n\n  if (results.indexed > 0 || results.updated > 0 || results.staleDeleted > 0 || results.orphanSwept > 0 || results.postInsertEnrichmentRepaired > 0 || triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    runScanInvalidationHooks({\n      indexed: results.indexed,\n      updated: results.updated,\n      staleDeleted: results.staleDeleted,\n      staleDeleteFailed: results.staleDeleteFailed,\n      ...(triggerBackfillChangedRows(results.triggerEmbeddingBackfill)\n        ? { triggerEmbeddingBackfill: results.triggerEmbeddingBackfill }\n        : {}),","lineStart":1010,"lineEnd":1359,"totalLines":1598,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781756176323,"end":1781756176344}},"metadata":{"openai":{"itemId":"fc_0f2508451567dae5016a337110417081918515f6a7ae624e16"}},"id":"prt_ed8f1a7be001XqKDqq7sRqEtGB","sessionID":"ses_1270ff808ffewqP1i1p6C1RaMp","messageID":"msg_ed8f17dce001jVC62DlO25xYdb"}}
