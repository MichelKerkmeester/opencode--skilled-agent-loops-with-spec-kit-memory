QualityScore(row),\n    };\n  });\n}\n\nfunction applyArchiveFilter(\n  results: PipelineRow[],\n  _includeArchived: boolean\n): PipelineRow[] {\n  return results;\n}\n\nfunction applyFolderFilter(","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","text":"  return results.map((row) => {\n    if (row.quality_score !== 0 && row.quality_score != null) {\n      return row;\n    }\n\n    return {\n      ...row,\n      quality_score: computeBackfillQualityScore(row),\n    };\n  });\n}\n\nfunction applyArchiveFilter(\n  results: PipelineRow[],\n  _includeArchived: boolean\n): PipelineRow[] {\n  return results;\n}\n\nfunction applyFolderFilter(\n  results: PipelineRow[],\n  specFolder?: string\n): PipelineRow[] {\n  if (!specFolder) return results;\n  return results.filter((row) => {\n    const rowSpecFolder = row.spec_folder ?? row.specFolder;\n    return rowSpecFolder === specFolder;\n  });\n}\n\nfunction applyTierFilter(\n  results: PipelineRow[],\n  tier?: string\n): PipelineRow[] {\n  if (!tier) return results;\n  return results.filter((row) => row.importance_tier === tier);\n}\n\n/**\n * Resolve the effective context type from a pipeline row.","lineStart":120,"lineEnd":159,"totalLines":1510,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","time":{"start":1781761986577,"end":1781761986581}},"metadata":{"openai":{"itemId":"fc_05fce0a1f1825a85016a3387c236dc819196108c8420ffa53a"}},"id":"prt_ed94a5004001B86GIh2hba4XTK","sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","messageID":"msg_ed94a12c5001SPqQudSq1aBJpq"}}
