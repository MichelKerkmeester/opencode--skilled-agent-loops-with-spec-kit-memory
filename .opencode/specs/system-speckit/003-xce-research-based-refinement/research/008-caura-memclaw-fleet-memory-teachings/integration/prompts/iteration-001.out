  database.exec('CREATE INDEX IF NOT EXISTS idx_causal_target ON causal_edges(target_id)');\n740:         database.exec('CREATE INDEX IF NOT EXISTS idx_causal_relation ON causal_edges(relation)');\n741:         database.exec('CREATE INDEX IF NOT EXISTS idx_causal_strength ON causal_edges(strength DESC)');\n742:         database.exec('CREATE INDEX IF NOT EXISTS idx_causal_edges_source_anchor ON causal_edges(source_anchor)');\n743:         database.exec('CREATE INDEX IF NOT EXISTS idx_causal_edges_target_anchor ON causal_edges(target_anchor)');\n744:         logger.info('Migration v8: Created causal_edges indexes');\n745:       } catch (e: unknown) {\n746:         console.warn('[VectorIndex] Migration v8 warning (indexes):', get_error_message(e));\n747:       }\n748:     },\n749:     9: () => {\n750:       // V8 -> v9: Create memory_corrections table for Learning from Corrections\n751:       try {\n752:         database.exec(`\n753:           CREATE TABLE IF NOT EXISTS memory_corrections (\n754:             id INTEGER PRIMARY KEY AUTOINCREMENT,\n755:             original_memory_id INTEGER NOT NULL,\n756:             correction_memory_id INTEGER,\n757:             correction_type TEXT NOT NULL CHECK(correction_type IN (\n758:               'superseded', 'deprecated', 'refined', 'merged'\n759:             )),\n760:             original_stability_before REAL,\n761:             original_stability_after REAL,\n762:             correction_stability_before REAL,\n763:             correction_stability_after REAL,\n764:             reason TEXT,\n765:             corrected_by TEXT,\n766:             created_at TEXT DEFAULT CURRENT_TIMESTAMP,\n767:             is_undone INTEGER DEFAULT 0,\n768:             undone_at TEXT,\n769:             FOREIGN KEY (original_memory_id) REFERENCES memory_index(id) ON DELETE CASCADE,\n770:             FOREIGN KEY (correction_memory_id) REFERENCES memory_index(id) ON DELETE SET NULL\n771:           )\n772:         `);\n773:         logger.info('