     {\n1495:                 imported_file_path: 'src/a.ts',\n1496:                 importer_file_path: 'src/b.ts',\n1497:                 weight: 1,\n1498:                 metadata: JSON.stringify({ confidence: 0.9 }),\n1499:               },\n1500:               {\n1501:                 imported_file_path: 'src/b.ts',\n1502:                 importer_file_path: 'src/c.ts',\n1503:                 weight: 1,\n1504:                 metadata: JSON.stringify({ confidence: 0.8 }),\n1505:               },\n1506:               {\n1507:                 imported_file_path: 'src/c.ts',\n1508:                 importer_file_path: 'src/d.ts',\n1509:                 weight: 1,\n1510:                 metadata: JSON.stringify({ confidence: 0.7 }),\n1511:               },\n1512:             ];\n1513:           }\n1514:           return [];\n1515:         }),\n1516:         get: vi.fn(() => undefined),\n1517:       })),\n1518:     });\n1519: \n1520:     const compactResult = await handleCodeGraphQuery({\n1521:       operation: 'blast_radius',\n1522:       subject: 'src/a.ts',\n1523:       includeTransitive: true,\n1524:       maxDepth: 2,\n1525:       minConfidence: 0.5,\n1526:     });\n1527:     const compactParsed = JSON.parse(compactResult.content[0].text);\n1528:     expect(compactParsed.data.nodes[0]).not.toHaveProperty('why_included');\n1529:     expect(compactParsed.data.affectedFiles[0]).not.toHaveProperty('why_included');\n1530: \n1531:     const tracedResult = await handleCodeGraphQuery({\n1532:       operation: 'blast_radius',\n1533:       subject: 'src/a.ts',\n1534:       includeTransitive: true,\n1535:       includeTrace: true,\n1536:       maxDepth: 2,\n1537:       minConfidence: 0.5,\n1538:     });\n1539:     const tracedParsed = JSON.parse(tracedResult.content[0].text);\n1540: \n1541:     expect(tracedParsed.data.nodes[0]).toMatchObject({\n1542:       filePath: 'src/a.ts',\n1543:       depth: 0,\n1544:       isSeed: true,\n1545:       why_included: {\n1546:         d