{"type":"tool_use","timestamp":1781764002276,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_53l4HUoirYIy4baximCzNJEQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/core/config.ts","offset":120,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/core/config.ts</path>\n<type>file</type>\n<content>\n120: \n121: // ────────────────────────────────────────────────────────────────\n122: // 4. RATE LIMITING CONFIGURATION \n123: \n124: // ────────────────────────────────────────────────────────────────\n125: \n126: export const INDEX_SCAN_COOLDOWN: number = 30000;\n127: \n128: // ────────────────────────────────────────────────────────────────\n129: // 5. QUERY VALIDATION LIMITS \n130: \n131: // ────────────────────────────────────────────────────────────────\n132: \n133: export const MAX_QUERY_LENGTH: number = 10000;\n134: \n135: export const INPUT_LIMITS: Readonly<InputLimitsConfig> = {\n136:   query: 10000,\n137:   title: 500,\n138:   specFolder: 200,\n139:   contextType: 100,\n140:   name: 200,\n141:   prompt: 10000,\n142:   filePath: 500\n143: } as const;\n144: \n145: // ────────────────────────────────────────────────────────────────\n146: // 6. PATH VALIDATION \n147: \n148: // ────────────────────────────────────────────────────────────────\n149: \n150: export const DEFAULT_BASE_PATH: string = process.env.MEMORY_BASE_PATH || process.cwd();\n151: \n152: export const ALLOWED_BASE_PATHS: string[] = [\n153:   path.join(os.homedir(), '.claude'),\n154:   DEFAULT_BASE_PATH,\n155:   process.cwd()\n156: ]\n157:   .filter(Boolean)\n158:   .map(base => path.resolve(base));\n159: \n160: // ────────────────────────────────────────────────────────────────\n161: // 7. CACHE CONFIGURATION \n162: \n163: // ────────────────────────────────────────────────────────────────\n164: \n165: export const CONSTITUTIONAL_CACHE_TTL: number = 60000;\n166: \n167: // ────────────────────────────────────────────────────────────────\n168: // 8. COGNITIVE CONFIGURATION \n169: \n170: // ────────────────────────────────────────────────────────────────\n171: \n172: function parseCognitiveConfig(): CognitiveConfig {\n173:   return loadCognitiveConfigFromEnv(process.env);\n174: }\n175: \n176: let _cognitiveConfig: CognitiveConfig | null = null;\n177: \n178: export function getCognitiveConfig(): CognitiveConfig {\n179:   if (!_cognitiveConfig) {\n180:     _cognitiveConfig = parseCognitiveConfig();\n181:   }\n182:   return _cognitiveConfig;\n183: }\n184: \n185: const COGNITIVE_CONFIG_LAZY: CognitiveConfig = {} as CognitiveConfig;\n186: Object.defineProperties(COGNITIVE_CONFIG_LAZY, {\n187:   coActivationPattern: {\n188:     enumerable: true,\n189:     get: () => getCognitiveConfig().coActivationPattern,\n190:   },\n191:   coActivationPatternSource: {\n192:     enumerable: true,\n193:     get: () => getCognitiveConfig().coActivationPatternSource,\n194:   },\n195:   coActivationPatternFlags: {\n196:     enumerable: true,\n197:     get: () => getCognitiveConfig().coActivationPatternFlags,\n198:   },\n199: });\n\n(Showing lines 120-199 of 206. Use offset=200 to continue.)\n</content>","metadata":{"preview":"\n// ────────────────────────────────────────────────────────────────\n// 4. RATE LIMITING CONFIGURATION \n\n// ────────────────────────────────────────────────────────────────\n\nexport const INDEX_SCAN_COOLDOWN: number = 30000;\n\n// ────────────────────────────────────────────────────────────────\n// 5. QUERY VALIDATION LIMITS \n\n// ────────────────────────────────────────────────────────────────\n\nexport const MAX_QUERY_LENGTH: number = 10000;\n\nexport const INPUT_LIMITS: Readonly<InputLimitsConfig> = {\n  query: 10000,\n  title: 500,\n  specFolder: 200,\n  contextType: 100,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/core/config.ts","text":"\n// ────────────────────────────────────────────────────────────────\n// 4. RATE LIMITING CONFIGURATION \n\n// ────────────────────────────────────────────────────────────────\n\nexport const INDEX_SCAN_COOLDOWN: number = 30000;\n\n// ────────────────────────────────────────────────────────────────\n// 5. QUERY VALIDATION LIMITS \n\n// ────────────────────────────────────────────────────────────────\n\nexport const MAX_QUERY_LENGTH: number = 10000;\n\nexport const INPUT_LIMITS: Readonly<InputLimitsConfig> = {\n  query: 10000,\n  title: 500,\n  specFolder: 200,\n  contextType: 100,\n  name: 200,\n  prompt: 10000,\n  filePath: 500\n} as const;\n\n// ────────────────────────────────────────────────────────────────\n// 6. PATH VALIDATION \n\n// ────────────────────────────────────────────────────────────────\n\nexport const DEFAULT_BASE_PATH: string = process.env.MEMORY_BASE_PATH || process.cwd();\n\nexport const ALLOWED_BASE_PATHS: string[] = [\n  path.join(os.homedir(), '.claude'),\n  DEFAULT_BASE_PATH,\n  process.cwd()\n]\n  .filter(Boolean)\n  .map(base => path.resolve(base));\n\n// ────────────────────────────────────────────────────────────────\n// 7. CACHE CONFIGURATION \n\n// ────────────────────────────────────────────────────────────────\n\nexport const CONSTITUTIONAL_CACHE_TTL: number = 60000;\n\n// ────────────────────────────────────────────────────────────────\n// 8. COGNITIVE CONFIGURATION \n\n// ────────────────────────────────────────────────────────────────\n\nfunction parseCognitiveConfig(): CognitiveConfig {\n  return loadCognitiveConfigFromEnv(process.env);\n}\n\nlet _cognitiveConfig: CognitiveConfig | null = null;\n\nexport function getCognitiveConfig(): CognitiveConfig {\n  if (!_cognitiveConfig) {\n    _cognitiveConfig = parseCognitiveConfig();\n  }\n  return _cognitiveConfig;\n}\n\nconst COGNITIVE_CONFIG_LAZY: CognitiveConfig = {} as CognitiveConfig;\nObject.defineProperties(COGNITIVE_CONFIG_LAZY, {\n  coActivationPattern: {\n    enumerable: true,\n    get: () => getCognitiveConfig().coActivationPattern,\n  },\n  coActivationPatternSource: {\n    enumerable: true,\n    get: () => getCognitiveConfig().coActivationPatternSource,\n  },\n  coActivationPatternFlags: {\n    enumerable: true,\n    get: () => getCognitiveConfig().coActivationPatternFlags,\n  },\n});","lineStart":120,"lineEnd":199,"totalLines":206,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/core/config.ts","time":{"start":1781764002261,"end":1781764002272}},"metadata":{"openai":{"itemId":"fc_0bf1af54bbde9eac016a338fa0b1a881919824caa0207acb63"}},"id":"prt_ed9690bcd001Sl0ff9SDFKAfAR","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed968fe9b0012pLm8y2XroQVig"}}
