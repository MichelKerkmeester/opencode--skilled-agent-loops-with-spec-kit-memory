{"type":"tool_use","timestamp":1784606343494,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_00_gtTaMTpObDDnW55ykbGq0510","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/generation-manifest.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/generation-manifest.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Versioned Multi-Artifact Generation Manifest                            ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // A generation's published state is a single content-addressed pointer that can\n6: // span more than one immutable artifact (the SQLite projection plus, when they\n7: // exist, screenshot features, model profiles, and an optional index). Publishing\n8: // is one atomic pointer flip; a reader either sees the whole prior manifest or\n9: // the whole new one, never a torn mixture. Legacy single-file pointers still\n10: // resolve so older publishers keep opening.\n11: \n12: import {\n13:   existsSync,\n14:   readFileSync,\n15:   realpathSync,\n16: } from 'node:fs';\n17: import { open, readFile, rename, rm } from 'node:fs/promises';\n18: import path from 'node:path';\n19: \n20: import { digest } from './canonical.mjs';\n21: \n22: export const MANIFEST_VERSION = 1;\n23: export const LEGACY_POINTER_VERSION = 1;\n24: \n25: // Roles the manifest may span. `sqlite` is mandatory today; the rest are\n26: // optional and additive so a sqlite-only publisher stays byte-compatible.\n27: export const MANIFEST_ARTIFACT_ROLES = Object.freeze([\n28:   'sqlite',\n29:   'screenshotFeatures',\n30:   'modelProfiles',\n31:   'index',\n32: ]);\n33: \n34: const ARTIFACT_SIDECAR_SUFFIXES = Object.freeze(['', '-wal', '-shm']);\n35: \n36: function manifestError(code, message, cause) {\n37:   const error = cause ? new Error(message, { cause }) : new Error(message);\n38:   error.code = code;\n39:   return error;\n40: }\n41: \n42: function isContained(rootPath, candidatePath) {\n43:   const relative = path.relative(rootPath, candidatePath);\n44:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n45: }\n46: \n47: function isBasename(value) {\n48:   return typeof value === 'string' && value.length > 0 && path.basename(value) === value;\n49: }\n50: \n51: /**\n52:  * Content-address a single artifact file by SHA-256 and byte length.\n53:  *\n54:  * @param {string} filePath - Absolute or relative artifact path.\n55:  * @returns {Promise<{sha256:string, bytes:number}>} Content identity.\n56:  */\n57: export async function hashArtifactFile(filePath) {\n58:   const buffer = await readFile(filePath);\n59:   return { sha256: digest([buffer]), bytes: buffer.byteLength };\n60: }\n61: \n62: /**\n63:  * Assemble a validated, immutable manifest document.\n64:  *\n65:  * @param {Object} input - Manifest fields.\n66:  * @param {string} input.generationHash - Generation identity hash.\n67:  * @param {string} input.createdAt - ISO timestamp for the publish event.\n68:  * @param {Object} input.artifacts - Role-keyed `{file, sha256, bytes}` entries.\n69:  * @param {string|null} [input.parentGenerationHash] - Prior generation identity.\n70:  * @returns {Object} Frozen manifest document.\n71:  */\n72: export function buildManifest({ generationHash, createdAt, artifacts, parentGenerationHash = null }) {\n73:   if (typeof generationHash !== 'string' || generationHash.length === 0) {\n74:     throw manifestError('manifest-invalid', 'Manifest requires a generation hash.');\n75:   }\n76:   if (!artifacts || typeof artifacts !== 'object' || !artifacts.sqlite) {\n77:     throw manifestError('manifest-invalid', 'Manifest requires at least a sqlite artifact.');\n78:   }\n79:   const normalizedArtifacts = {};\n80:   for (const role of MANIFEST_ARTIFACT_ROLES) {\n81:     const entry = artifacts[role];\n82:     if (!entry) continue;\n83:     if (!isBasename(entry.file)) {\n84:       throw manifestError('manifest-invalid', `Manifest artifact ${role} file must be a basename.`);\n85:     }\n86:     if (typeof entry.sha256 !== 'string' || !Number.isInteger(entry.bytes) || entry.bytes < 0) {\n87:       throw manifestError('manifest-invalid', `Manifest artifact ${role} needs sha256 and byte length.`);\n88:     }\n89:     normalizedArtifacts[role] = { role, file: entry.file, sha256: entry.sha256, bytes: entry.bytes };\n90:   }\n91:   return Object.freeze({\n92:     manifestVersion: MANIFEST_VERSION,\n93:     generationHash,\n94:     createdAt: typeof createdAt === 'string' ? createdAt : new Date(0).toISOString(),\n95:     parentGenerationHash: parentGenerationHash ?? null,\n96:     artifacts: normalizedArtifacts,\n97:   });\n98: }\n99: \n100: /**\n101:  * Render a manifest document as a stable, human-readable pointer payload.\n102:  *\n103:  * @param {Object} doc - Manifest document.\n104:  * @returns {string} Serialized manifest with a trailing newline.\n105:  */\n106: export function serializeManifest(doc) {\n107:   const artifacts = {};\n108:   for (const role of MANIFEST_ARTIFACT_ROLES) {\n109:     if (doc.artifacts[role]) artifacts[role] = doc.artifacts[role];\n110:   }\n111:   const ordered = {\n112:     manifestVersion: doc.manifestVersion,\n113:     generationHash: doc.generationHash,\n114:     createdAt: doc.createdAt,\n115:     parentGenerationHash: doc.parentGenerationHash ?? null,\n116:     artifacts,\n117:   };\n118:   return `${JSON.stringify(ordered, null, 2)}\\n`;\n119: }\n120: \n121: /**\n122:  * Normalize a parsed pointer payload, accepting manifest and legacy shapes.\n123:  *\n124:  * @param {*} raw - Parsed pointer JSON.\n125:  * @returns {{generationHash:string, sqliteFile:string, artifacts:Object, legacy:boolean}} Normalized pointer.\n126:  */\n127: export function normalizePointer(raw) {\n128:   if (raw && raw.manifestVersion === MANIFEST_VERSION) {\n129:     if (typeof raw.generationHash !== 'string'\n130:       || !raw.artifacts\n131:       || typeof raw.artifacts !== 'object'\n132:       || !raw.artifacts.sqlite\n133:       || !isBasename(raw.artifacts.sqlite.file)) {\n134:       throw manifestError('generation-pointer-invalid', 'Generation manifest has an invalid shape.');\n135:     }\n136:     return {\n137:       generationHash: raw.generationHash,\n138:       sqliteFile: raw.artifacts.sqlite.file,\n139:       artifacts: raw.artifacts,\n140:       legacy: false,\n141:     };\n142:   }\n143:   if (raw && raw.schemaVersion === LEGACY_POINTER_VERSION\n144:     && typeof raw.generationHash === 'string'\n145:     && isBasename(raw.databaseFile)) {\n146:     return {\n147:       generationHash: raw.generationHash,\n148:       sqliteFile: raw.databaseFile,\n149:       artifacts: { sqlite: { role: 'sqlite', file: raw.databaseFile } },\n150:       legacy: true,\n151:     };\n152:   }\n153:   throw manifestError('generation-pointer-invalid', 'Style database generation pointer has an invalid shape.');\n154: }\n155: \n156: /**\n157:  * Resolve the published SQLite target selected by an atomic pointer file.\n158:  *\n159:  * Containment and existence are always enforced; the SQLite artifact is bound\n160:  * to its generation hash by the caller rather than re-hashed on every open.\n161:  *\n162:  * @param {string} databasePath - Logical database path.\n163:  * @param {string} pointerSuffix - Pointer filename suffix.\n164:  * @returns {{databasePath:string, generationHash:string|null}} Resolved target.\n165:  */\n166: export function resolvePublishedTarget(databasePath, pointerSuffix) {\n167:   const pointerPath = `${databasePath}${pointerSuffix}`;\n168:   if (!existsSync(pointerPath)) return { databasePath, generationHash: null };\n169:   let raw;\n170:   try {\n171:     raw = JSON.parse(readFileSync(pointerPath, 'utf8'));\n172:   } catch (cause) {\n173:     throw manifestError('generation-pointer-invalid', 'Style database generation pointer is invalid JSON.', cause);\n174:   }\n175:   const normalized = normalizePointer(raw);\n176:   const publishedPath = path.join(path.dirname(databasePath), normalized.sqliteFile);\n177:   if (!existsSync(publishedPath)) {\n178:     throw manifestError('generation-unavailable', 'Published style database generation is unavailable.');\n179:   }\n180:   const generationDirectory = realpathSync(path.dirname(databasePath));\n181:   const publishedRealPath = realpathSync(publishedPath);\n182:   if (!isContained(generationDirectory, publishedRealPath)) {\n183:     throw manifestError('generation-pointer-escape', 'Published style database generation escapes its directory.');\n184:   }\n185:   return { databasePath: publishedPath, generationHash: normalized.generationHash };\n186: }\n187: \n188: /**\n189:  * Read and normalize a pointer file without opening any artifact.\n190:  *\n191:  * @param {string} pointerPath - Absolute pointer path.\n192:  * @returns {Promise<Object>} Normalized pointer plus the manifest document.\n193:  */\n194: export async function readManifest(pointerPath) {\n195:   let raw;\n196:   try {\n197:     raw = JSON.parse(await readFile(pointerPath, 'utf8'));\n198:   } catch (cause) {\n199:     throw manifestError('generation-pointer-invalid', 'Style database generation pointer is invalid JSON.', cause);\n200:   }\n201:   return { ...normalizePointer(raw), document: raw };\n202: }\n203: \n204: /**\n205:  * Validate every artifact a manifest references for a reader that binds it.\n206:  *\n207:  * @param {string} pointerPath - Absolute pointer path.\n208:  * @param {Object} [options] - Validation controls.\n209:  * @param {boolean} [options.verifyDigests=false] - Re-hash each artifact file.\n210:  * @returns {Promise<Object>} Resolved, validated artifact set.\n211:  */\n212: export async function resolveManifestArtifacts(pointerPath, { verifyDigests = false } = {}) {\n213:   const { generationHash, artifacts, legacy } = await readManifest(pointerPath);\n214:   const directory = path.dirname(pointerPath);\n215:   const directoryRealPath = realpathSync(directory);\n216:   const resolved = {};\n217:   for (const [role, entry] of Object.entries(artifacts)) {\n218:     const artifactPath = path.join(directory, entry.file);\n219:     if (!existsSync(artifactPath)) {\n220:       throw manifestError('generation-unavailable', `Manifest artifact ${role} is unavailable.`);\n221:     }\n222:     const artifactRealPath = realpathSync(artifactPath);\n223:     if (!isContained(directoryRealPath, artifactRealPath)) {\n224:       throw manifestError('generation-pointer-escape', `Manifest artifact ${role} escapes its directory.`);\n225:     }\n226:     if (verifyDigests && entry.sha256) {\n227:       const { sha256 } = await hashArtifactFile(artifactRealPath);\n228:       if (sha256 !== entry.sha256) {\n229:         throw manifestError('generation-artifact-tampered', `Manifest artifact ${role} failed digest verification.`);\n230:       }\n231:     }\n232:     resolved[role] = { role, file: entry.file, path: artifactPath, sha256: entry.sha256 ?? null };\n233:   }\n234:   return { generationHash, legacy, artifacts: resolved };\n235: }\n236: \n237: /**\n238:  * Atomically flip the pointer to a new manifest with fsync durability.\n239:  *\n240:  * The payload is written to a fresh temp file, fsynced, then renamed over the\n241:  * pointer, and the containing directory is fsynced so the flip survives crash.\n242:  *\n243:  * @param {string} pointerPath - Absolute pointer path.\n244:  * @param {Object} doc - Manifest document to publish.\n245:  * @param {Object} [options] - Hooks.\n246:  * @param {Function} [options.afterRename] - Invoked after the atomic rename.\n247:  * @returns {Promise<void>}\n248:  */\n249: export async function writeManifestPointer(pointerPath, doc, { afterRename } = {}) {\n250:   const serialized = serializeManifest(doc);\n251:   const temporaryPath = `${pointerPath}.tmp-${process.pid}-${Date.now()}`;\n252:   let temporaryHandle;\n253:   try {\n254:     temporaryHandle = await open(temporaryPath, 'wx');\n255:     await temporaryHandle.writeFile(serialized);\n256:     await temporaryHandle.sync();\n257:     await temporaryHandle.close();\n258:     temporaryHandle = null;\n259:     await rename(temporaryPath, pointerPath);\n260:     afterRename?.({ pointerPath, generationHash: doc.generationHash });\n261:     const directoryHandle = await open(path.dirname(pointerPath), 'r');\n262:     try {\n263:       await directoryHandle.sync();\n264:     } finally {\n265:       await directoryHandle.close();\n266:     }\n267:   } finally {\n268:     if (temporaryHandle) await temporaryHandle.close();\n269:     await rm(temporaryPath, { force: true });\n270:   }\n271: }\n272: \n273: /**\n274:  * List the artifact basenames a manifest document references.\n275:  *\n276:  * @param {Object} doc - Manifest document.\n277:  * @returns {string[]} Artifact basenames.\n278:  */\n279: export function manifestArtifactFiles(doc) {\n280:   return Object.values(doc.artifacts).map((artifact) => artifact.file);\n281: }\n282: \n283: /**\n284:  * Prune whole generations, keeping every artifact of the retained manifests.\n285:  *\n286:  * An artifact file is removed only when no retained manifest references it, so a\n287:  * generation is dropped as a unit rather than leaving orphaned artifacts.\n288:  *\n289:  * @param {Object} options - Retention inputs.\n290:  * @param {string} options.directory - Directory holding the artifact files.\n291:  * @param {Object[]} options.retain - Manifests to keep intact.\n292:  * @param {Object[]} options.prune - Manifests eligible for removal.\n293:  * @returns {Promise<{kept:string[], removed:string[]}>} Retention outcome.\n294:  */\n295: export async function pruneManifestGenerations({ directory, retain, prune }) {\n296:   const keep = new Set(retain.flatMap(manifestArtifactFiles));\n297:   const removed = [];\n298:   for (const doc of prune) {\n299:     for (const file of manifestArtifactFiles(doc)) {\n300:       if (keep.has(file)) continue;\n301:       for (const suffix of ARTIFACT_SIDECAR_SUFFIXES) {\n302:         await rm(path.join(directory, `${file}${suffix}`), { force: true });\n303:       }\n304:       removed.push(file);\n305:     }\n306:   }\n307:   return { kept: [...keep], removed };\n308: }\n\n(End of file - total 308 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Versioned Multi-Artifact Generation Manifest                            ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// A generation's published state is a single content-addressed pointer that can\n// span more than one immutable artifact (the SQLite projection plus, when they\n// exist, screenshot features, model profiles, and an optional index). Publishing\n// is one atomic pointer flip; a reader either sees the whole prior manifest or\n// the whole new one, never a torn mixture. Legacy single-file pointers still\n// resolve so older publishers keep opening.\n\nimport {\n  existsSync,\n  readFileSync,\n  realpathSync,\n} from 'node:fs';\nimport { open, readFile, rename, rm } from 'node:fs/promises';\nimport path from 'node:path';\n\nimport { digest } from './canonical.mjs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/generation-manifest.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Versioned Multi-Artifact Generation Manifest                            ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// A generation's published state is a single content-addressed pointer that can\n// span more than one immutable artifact (the SQLite projection plus, when they\n// exist, screenshot features, model profiles, and an optional index). Publishing\n// is one atomic pointer flip; a reader either sees the whole prior manifest or\n// the whole new one, never a torn mixture. Legacy single-file pointers still\n// resolve so older publishers keep opening.\n\nimport {\n  existsSync,\n  readFileSync,\n  realpathSync,\n} from 'node:fs';\nimport { open, readFile, rename, rm } from 'node:fs/promises';\nimport path from 'node:path';\n\nimport { digest } from './canonical.mjs';\n\nexport const MANIFEST_VERSION = 1;\nexport const LEGACY_POINTER_VERSION = 1;\n\n// Roles the manifest may span. `sqlite` is mandatory today; the rest are\n// optional and additive so a sqlite-only publisher stays byte-compatible.\nexport const MANIFEST_ARTIFACT_ROLES = Object.freeze([\n  'sqlite',\n  'screenshotFeatures',\n  'modelProfiles',\n  'index',\n]);\n\nconst ARTIFACT_SIDECAR_SUFFIXES = Object.freeze(['', '-wal', '-shm']);\n\nfunction manifestError(code, message, cause) {\n  const error = cause ? new Error(message, { cause }) : new Error(message);\n  error.code = code;\n  return error;\n}\n\nfunction isContained(rootPath, candidatePath) {\n  const relative = path.relative(rootPath, candidatePath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction isBasename(value) {\n  return typeof value === 'string' && value.length > 0 && path.basename(value) === value;\n}\n\n/**\n * Content-address a single artifact file by SHA-256 and byte length.\n *\n * @param {string} filePath - Absolute or relative artifact path.\n * @returns {Promise<{sha256:string, bytes:number}>} Content identity.\n */\nexport async function hashArtifactFile(filePath) {\n  const buffer = await readFile(filePath);\n  return { sha256: digest([buffer]), bytes: buffer.byteLength };\n}\n\n/**\n * Assemble a validated, immutable manifest document.\n *\n * @param {Object} input - Manifest fields.\n * @param {string} input.generationHash - Generation identity hash.\n * @param {string} input.createdAt - ISO timestamp for the publish event.\n * @param {Object} input.artifacts - Role-keyed `{file, sha256, bytes}` entries.\n * @param {string|null} [input.parentGenerationHash] - Prior generation identity.\n * @returns {Object} Frozen manifest document.\n */\nexport function buildManifest({ generationHash, createdAt, artifacts, parentGenerationHash = null }) {\n  if (typeof generationHash !== 'string' || generationHash.length === 0) {\n    throw manifestError('manifest-invalid', 'Manifest requires a generation hash.');\n  }\n  if (!artifacts || typeof artifacts !== 'object' || !artifacts.sqlite) {\n    throw manifestError('manifest-invalid', 'Manifest requires at least a sqlite artifact.');\n  }\n  const normalizedArtifacts = {};\n  for (const role of MANIFEST_ARTIFACT_ROLES) {\n    const entry = artifacts[role];\n    if (!entry) continue;\n    if (!isBasename(entry.file)) {\n      throw manifestError('manifest-invalid', `Manifest artifact ${role} file must be a basename.`);\n    }\n    if (typeof entry.sha256 !== 'string' || !Number.isInteger(entry.bytes) || entry.bytes < 0) {\n      throw manifestError('manifest-invalid', `Manifest artifact ${role} needs sha256 and byte length.`);\n    }\n    normalizedArtifacts[role] = { role, file: entry.file, sha256: entry.sha256, bytes: entry.bytes };\n  }\n  return Object.freeze({\n    manifestVersion: MANIFEST_VERSION,\n    generationHash,\n    createdAt: typeof createdAt === 'string' ? createdAt : new Date(0).toISOString(),\n    parentGenerationHash: parentGenerationHash ?? null,\n    artifacts: normalizedArtifacts,\n  });\n}\n\n/**\n * Render a manifest document as a stable, human-readable pointer payload.\n *\n * @param {Object} doc - Manifest document.\n * @returns {string} Serialized manifest with a trailing newline.\n */\nexport function serializeManifest(doc) {\n  const artifacts = {};\n  for (const role of MANIFEST_ARTIFACT_ROLES) {\n    if (doc.artifacts[role]) artifacts[role] = doc.artifacts[role];\n  }\n  const ordered = {\n    manifestVersion: doc.manifestVersion,\n    generationHash: doc.generationHash,\n    createdAt: doc.createdAt,\n    parentGenerationHash: doc.parentGenerationHash ?? null,\n    artifacts,\n  };\n  return `${JSON.stringify(ordered, null, 2)}\\n`;\n}\n\n/**\n * Normalize a parsed pointer payload, accepting manifest and legacy shapes.\n *\n * @param {*} raw - Parsed pointer JSON.\n * @returns {{generationHash:string, sqliteFile:string, artifacts:Object, legacy:boolean}} Normalized pointer.\n */\nexport function normalizePointer(raw) {\n  if (raw && raw.manifestVersion === MANIFEST_VERSION) {\n    if (typeof raw.generationHash !== 'string'\n      || !raw.artifacts\n      || typeof raw.artifacts !== 'object'\n      || !raw.artifacts.sqlite\n      || !isBasename(raw.artifacts.sqlite.file)) {\n      throw manifestError('generation-pointer-invalid', 'Generation manifest has an invalid shape.');\n    }\n    return {\n      generationHash: raw.generationHash,\n      sqliteFile: raw.artifacts.sqlite.file,\n      artifacts: raw.artifacts,\n      legacy: false,\n    };\n  }\n  if (raw && raw.schemaVersion === LEGACY_POINTER_VERSION\n    && typeof raw.generationHash === 'string'\n    && isBasename(raw.databaseFile)) {\n    return {\n      generationHash: raw.generationHash,\n      sqliteFile: raw.databaseFile,\n      artifacts: { sqlite: { role: 'sqlite', file: raw.databaseFile } },\n      legacy: true,\n    };\n  }\n  throw manifestError('generation-pointer-invalid', 'Style database generation pointer has an invalid shape.');\n}\n\n/**\n * Resolve the published SQLite target selected by an atomic pointer file.\n *\n * Containment and existence are always enforced; the SQLite artifact is bound\n * to its generation hash by the caller rather than re-hashed on every open.\n *\n * @param {string} databasePath - Logical database path.\n * @param {string} pointerSuffix - Pointer filename suffix.\n * @returns {{databasePath:string, generationHash:string|null}} Resolved target.\n */\nexport function resolvePublishedTarget(databasePath, pointerSuffix) {\n  const pointerPath = `${databasePath}${pointerSuffix}`;\n  if (!existsSync(pointerPath)) return { databasePath, generationHash: null };\n  let raw;\n  try {\n    raw = JSON.parse(readFileSync(pointerPath, 'utf8'));\n  } catch (cause) {\n    throw manifestError('generation-pointer-invalid', 'Style database generation pointer is invalid JSON.', cause);\n  }\n  const normalized = normalizePointer(raw);\n  const publishedPath = path.join(path.dirname(databasePath), normalized.sqliteFile);\n  if (!existsSync(publishedPath)) {\n    throw manifestError('generation-unavailable', 'Published style database generation is unavailable.');\n  }\n  const generationDirectory = realpathSync(path.dirname(databasePath));\n  const publishedRealPath = realpathSync(publishedPath);\n  if (!isContained(generationDirectory, publishedRealPath)) {\n    throw manifestError('generation-pointer-escape', 'Published style database generation escapes its directory.');\n  }\n  return { databasePath: publishedPath, generationHash: normalized.generationHash };\n}\n\n/**\n * Read and normalize a pointer file without opening any artifact.\n *\n * @param {string} pointerPath - Absolute pointer path.\n * @returns {Promise<Object>} Normalized pointer plus the manifest document.\n */\nexport async function readManifest(pointerPath) {\n  let raw;\n  try {\n    raw = JSON.parse(await readFile(pointerPath, 'utf8'));\n  } catch (cause) {\n    throw manifestError('generation-pointer-invalid', 'Style database generation pointer is invalid JSON.', cause);\n  }\n  return { ...normalizePointer(raw), document: raw };\n}\n\n/**\n * Validate every artifact a manifest references for a reader that binds it.\n *\n * @param {string} pointerPath - Absolute pointer path.\n * @param {Object} [options] - Validation controls.\n * @param {boolean} [options.verifyDigests=false] - Re-hash each artifact file.\n * @returns {Promise<Object>} Resolved, validated artifact set.\n */\nexport async function resolveManifestArtifacts(pointerPath, { verifyDigests = false } = {}) {\n  const { generationHash, artifacts, legacy } = await readManifest(pointerPath);\n  const directory = path.dirname(pointerPath);\n  const directoryRealPath = realpathSync(directory);\n  const resolved = {};\n  for (const [role, entry] of Object.entries(artifacts)) {\n    const artifactPath = path.join(directory, entry.file);\n    if (!existsSync(artifactPath)) {\n      throw manifestError('generation-unavailable', `Manifest artifact ${role} is unavailable.`);\n    }\n    const artifactRealPath = realpathSync(artifactPath);\n    if (!isContained(directoryRealPath, artifactRealPath)) {\n      throw manifestError('generation-pointer-escape', `Manifest artifact ${role} escapes its directory.`);\n    }\n    if (verifyDigests && entry.sha256) {\n      const { sha256 } = await hashArtifactFile(artifactRealPath);\n      if (sha256 !== entry.sha256) {\n        throw manifestError('generation-artifact-tampered', `Manifest artifact ${role} failed digest verification.`);\n      }\n    }\n    resolved[role] = { role, file: entry.file, path: artifactPath, sha256: entry.sha256 ?? null };\n  }\n  return { generationHash, legacy, artifacts: resolved };\n}\n\n/**\n * Atomically flip the pointer to a new manifest with fsync durability.\n *\n * The payload is written to a fresh temp file, fsynced, then renamed over the\n * pointer, and the containing directory is fsynced so the flip survives crash.\n *\n * @param {string} pointerPath - Absolute pointer path.\n * @param {Object} doc - Manifest document to publish.\n * @param {Object} [options] - Hooks.\n * @param {Function} [options.afterRename] - Invoked after the atomic rename.\n * @returns {Promise<void>}\n */\nexport async function writeManifestPointer(pointerPath, doc, { afterRename } = {}) {\n  const serialized = serializeManifest(doc);\n  const temporaryPath = `${pointerPath}.tmp-${process.pid}-${Date.now()}`;\n  let temporaryHandle;\n  try {\n    temporaryHandle = await open(temporaryPath, 'wx');\n    await temporaryHandle.writeFile(serialized);\n    await temporaryHandle.sync();\n    await temporaryHandle.close();\n    temporaryHandle = null;\n    await rename(temporaryPath, pointerPath);\n    afterRename?.({ pointerPath, generationHash: doc.generationHash });\n    const directoryHandle = await open(path.dirname(pointerPath), 'r');\n    try {\n      await directoryHandle.sync();\n    } finally {\n      await directoryHandle.close();\n    }\n  } finally {\n    if (temporaryHandle) await temporaryHandle.close();\n    await rm(temporaryPath, { force: true });\n  }\n}\n\n/**\n * List the artifact basenames a manifest document references.\n *\n * @param {Object} doc - Manifest document.\n * @returns {string[]} Artifact basenames.\n */\nexport function manifestArtifactFiles(doc) {\n  return Object.values(doc.artifacts).map((artifact) => artifact.file);\n}\n\n/**\n * Prune whole generations, keeping every artifact of the retained manifests.\n *\n * An artifact file is removed only when no retained manifest references it, so a\n * generation is dropped as a unit rather than leaving orphaned artifacts.\n *\n * @param {Object} options - Retention inputs.\n * @param {string} options.directory - Directory holding the artifact files.\n * @param {Object[]} options.retain - Manifests to keep intact.\n * @param {Object[]} options.prune - Manifests eligible for removal.\n * @returns {Promise<{kept:string[], removed:string[]}>} Retention outcome.\n */\nexport async function pruneManifestGenerations({ directory, retain, prune }) {\n  const keep = new Set(retain.flatMap(manifestArtifactFiles));\n  const removed = [];\n  for (const doc of prune) {\n    for (const file of manifestArtifactFiles(doc)) {\n      if (keep.has(file)) continue;\n      for (const suffix of ARTIFACT_SIDECAR_SUFFIXES) {\n        await rm(path.join(directory, `${file}${suffix}`), { force: true });\n      }\n      removed.push(file);\n    }\n  }\n  return { kept: [...keep], removed };\n}","lineStart":1,"lineEnd":308,"totalLines":308,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/generation-manifest.mjs","time":{"start":1784606343487,"end":1784606343493}},"id":"prt_f82d3bec80014mhG0crzlgocOE","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ad19001fpLJRYE1hhoSZH"}}
{"type":"tool_use","timestamp":1784606344124,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_01_d02THupkJ358IgHBmY5Y8200","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/stage-telemetry.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/stage-telemetry.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Residency-Honest Stage Telemetry                                        ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // Every recorded stage is tagged with where its wall time was spent: `native`\n6: // for work executed inside the node:sqlite / FTS5 boundary, `js-resident` for\n7: // work executed on the JS heap and event loop (fs orchestration, JSON decode,\n8: // cosine, sort, RRF, card assembly). There is no blended or opaque bucket — a\n9: // record without a valid residency cannot be created.\n10: //\n11: // Attribution is measured, not assumed: the summary compares a real elapsed\n12: // wall span (an explicit overall timer, or the first span start through the\n13: // last span end) against the sum of the recorded span durations and reports the\n14: // remainder as `unattributedMs`. Work that runs outside every span therefore\n15: // surfaces honestly instead of being silently folded into a residency bucket.\n16: \n17: import { performance } from 'node:perf_hooks';\n18: \n19: export const RESIDENCY = Object.freeze({\n20:   NATIVE: 'native',\n21:   JS_RESIDENT: 'js-resident',\n22: });\n23: \n24: const RESIDENCY_VALUES = new Set(Object.values(RESIDENCY));\n25: \n26: function assertResidency(residency) {\n27:   if (!RESIDENCY_VALUES.has(residency)) {\n28:     throw new TypeError(`Unknown telemetry residency: ${String(residency)}`);\n29:   }\n30: }\n31: \n32: /**\n33:  * Create a stage recorder with injectable clock and memory probes.\n34:  *\n35:  * @param {Object} [options] - Probe overrides for deterministic tests.\n36:  * @param {Function} [options.now] - Monotonic millisecond clock.\n37:  * @param {Function} [options.memory] - Resident-set byte probe.\n38:  * @returns {Object} Recorder with span/record/overall/summary access.\n39:  */\n40: export function createStageRecorder({ now, memory } = {}) {\n41:   const clock = typeof now === 'function' ? now : () => performance.now();\n42:   const readRss = typeof memory === 'function' ? memory : () => process.memoryUsage().rss;\n43:   const records = [];\n44:   let firstStartedAt = null;\n45:   let lastEndedAt = null;\n46:   let rootStartedAt = null;\n47:   let rootEndedAt = null;\n48: \n49:   function observeWindow(startedAt, endedAt) {\n50:     if (firstStartedAt === null || startedAt < firstStartedAt) firstStartedAt = startedAt;\n51:     if (lastEndedAt === null || endedAt > lastEndedAt) lastEndedAt = endedAt;\n52:   }\n53: \n54:   function record(stage, residency, startedAt, startedRss, items = 0) {\n55:     assertResidency(residency);\n56:     const endedAt = clock();\n57:     const latencyMs = endedAt - startedAt;\n58:     const rssDeltaBytes = readRss() - startedRss;\n59:     observeWindow(startedAt, endedAt);\n60:     records.push(Object.freeze({\n61:       stage,\n62:       residency,\n63:       latencyMs,\n64:       items,\n65:       throughputPerSecond: latencyMs > 0 ? (items / latencyMs) * 1_000 : null,\n66:       rssDeltaBytes,\n67:     }));\n68:   }\n69: \n70:   return {\n71:     clock,\n72:     memory: readRss,\n73:     record,\n74:     /**\n75:      * Open a bracketed span; call `end(items)` once the stage work completes.\n76:      *\n77:      * @param {string} stage - Stage label.\n78:      * @param {string} residency - `native` or `js-resident`.\n79:      * @returns {{end: Function}} Span handle.\n80:      */\n81:     span(stage, residency) {\n82:       assertResidency(residency);\n83:       const startedAt = clock();\n84:       const startedRss = readRss();\n85:       return { end(items = 0) { record(stage, residency, startedAt, startedRss, items); } };\n86:     },\n87:     /**\n88:      * Bracket the whole instrumented region so the summary can measure the wall\n89:      * time that no individual span accounted for.\n90:      *\n91:      * @returns {{end: Function}} Overall-timer handle.\n92:      */\n93:     overall() {\n94:       rootStartedAt = clock();\n95:       return { end() { rootEndedAt = clock(); } };\n96:     },\n97:     records: () => records.slice(),\n98:     /**\n99:      * Decompose recorded latency into native and JS-resident buckets and report\n100:      * the wall time that fell outside every span.\n101:      *\n102:      * @returns {Object} Bucketed totals plus measured elapsed and unattributed cost.\n103:      */\n104:     summary() {\n105:       const buckets = { [RESIDENCY.NATIVE]: 0, [RESIDENCY.JS_RESIDENT]: 0 };\n106:       let items = 0;\n107:       for (const entry of records) {\n108:         buckets[entry.residency] += entry.latencyMs;\n109:         items += entry.items;\n110:       }\n111:       const native = buckets[RESIDENCY.NATIVE];\n112:       const jsResident = buckets[RESIDENCY.JS_RESIDENT];\n113:       const total = native + jsResident;\n114:       const windowStart = rootStartedAt ?? firstStartedAt;\n115:       const windowEnd = rootEndedAt ?? lastEndedAt;\n116:       const elapsedMs = windowStart !== null && windowEnd !== null && windowEnd > windowStart\n117:         ? windowEnd - windowStart\n118:         : total;\n119:       const unattributedMs = Math.max(0, elapsedMs - total);\n120:       return {\n121:         native,\n122:         jsResident,\n123:         total,\n124:         elapsedMs,\n125:         unattributedMs,\n126:         stageCount: records.length,\n127:         items,\n128:       };\n129:     },\n130:   };\n131: }\n\n(End of file - total 131 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Residency-Honest Stage Telemetry                                        ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Every recorded stage is tagged with where its wall time was spent: `native`\n// for work executed inside the node:sqlite / FTS5 boundary, `js-resident` for\n// work executed on the JS heap and event loop (fs orchestration, JSON decode,\n// cosine, sort, RRF, card assembly). There is no blended or opaque bucket — a\n// record without a valid residency cannot be created.\n//\n// Attribution is measured, not assumed: the summary compares a real elapsed\n// wall span (an explicit overall timer, or the first span start through the\n// last span end) against the sum of the recorded span durations and reports the\n// remainder as `unattributedMs`. Work that runs outside every span therefore\n// surfaces honestly instead of being silently folded into a residency bucket.\n\nimport { performance } from 'node:perf_hooks';\n\nexport const RESIDENCY = Object.freeze({\n  NATIVE: 'native',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/stage-telemetry.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Residency-Honest Stage Telemetry                                        ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Every recorded stage is tagged with where its wall time was spent: `native`\n// for work executed inside the node:sqlite / FTS5 boundary, `js-resident` for\n// work executed on the JS heap and event loop (fs orchestration, JSON decode,\n// cosine, sort, RRF, card assembly). There is no blended or opaque bucket — a\n// record without a valid residency cannot be created.\n//\n// Attribution is measured, not assumed: the summary compares a real elapsed\n// wall span (an explicit overall timer, or the first span start through the\n// last span end) against the sum of the recorded span durations and reports the\n// remainder as `unattributedMs`. Work that runs outside every span therefore\n// surfaces honestly instead of being silently folded into a residency bucket.\n\nimport { performance } from 'node:perf_hooks';\n\nexport const RESIDENCY = Object.freeze({\n  NATIVE: 'native',\n  JS_RESIDENT: 'js-resident',\n});\n\nconst RESIDENCY_VALUES = new Set(Object.values(RESIDENCY));\n\nfunction assertResidency(residency) {\n  if (!RESIDENCY_VALUES.has(residency)) {\n    throw new TypeError(`Unknown telemetry residency: ${String(residency)}`);\n  }\n}\n\n/**\n * Create a stage recorder with injectable clock and memory probes.\n *\n * @param {Object} [options] - Probe overrides for deterministic tests.\n * @param {Function} [options.now] - Monotonic millisecond clock.\n * @param {Function} [options.memory] - Resident-set byte probe.\n * @returns {Object} Recorder with span/record/overall/summary access.\n */\nexport function createStageRecorder({ now, memory } = {}) {\n  const clock = typeof now === 'function' ? now : () => performance.now();\n  const readRss = typeof memory === 'function' ? memory : () => process.memoryUsage().rss;\n  const records = [];\n  let firstStartedAt = null;\n  let lastEndedAt = null;\n  let rootStartedAt = null;\n  let rootEndedAt = null;\n\n  function observeWindow(startedAt, endedAt) {\n    if (firstStartedAt === null || startedAt < firstStartedAt) firstStartedAt = startedAt;\n    if (lastEndedAt === null || endedAt > lastEndedAt) lastEndedAt = endedAt;\n  }\n\n  function record(stage, residency, startedAt, startedRss, items = 0) {\n    assertResidency(residency);\n    const endedAt = clock();\n    const latencyMs = endedAt - startedAt;\n    const rssDeltaBytes = readRss() - startedRss;\n    observeWindow(startedAt, endedAt);\n    records.push(Object.freeze({\n      stage,\n      residency,\n      latencyMs,\n      items,\n      throughputPerSecond: latencyMs > 0 ? (items / latencyMs) * 1_000 : null,\n      rssDeltaBytes,\n    }));\n  }\n\n  return {\n    clock,\n    memory: readRss,\n    record,\n    /**\n     * Open a bracketed span; call `end(items)` once the stage work completes.\n     *\n     * @param {string} stage - Stage label.\n     * @param {string} residency - `native` or `js-resident`.\n     * @returns {{end: Function}} Span handle.\n     */\n    span(stage, residency) {\n      assertResidency(residency);\n      const startedAt = clock();\n      const startedRss = readRss();\n      return { end(items = 0) { record(stage, residency, startedAt, startedRss, items); } };\n    },\n    /**\n     * Bracket the whole instrumented region so the summary can measure the wall\n     * time that no individual span accounted for.\n     *\n     * @returns {{end: Function}} Overall-timer handle.\n     */\n    overall() {\n      rootStartedAt = clock();\n      return { end() { rootEndedAt = clock(); } };\n    },\n    records: () => records.slice(),\n    /**\n     * Decompose recorded latency into native and JS-resident buckets and report\n     * the wall time that fell outside every span.\n     *\n     * @returns {Object} Bucketed totals plus measured elapsed and unattributed cost.\n     */\n    summary() {\n      const buckets = { [RESIDENCY.NATIVE]: 0, [RESIDENCY.JS_RESIDENT]: 0 };\n      let items = 0;\n      for (const entry of records) {\n        buckets[entry.residency] += entry.latencyMs;\n        items += entry.items;\n      }\n      const native = buckets[RESIDENCY.NATIVE];\n      const jsResident = buckets[RESIDENCY.JS_RESIDENT];\n      const total = native + jsResident;\n      const windowStart = rootStartedAt ?? firstStartedAt;\n      const windowEnd = rootEndedAt ?? lastEndedAt;\n      const elapsedMs = windowStart !== null && windowEnd !== null && windowEnd > windowStart\n        ? windowEnd - windowStart\n        : total;\n      const unattributedMs = Math.max(0, elapsedMs - total);\n      return {\n        native,\n        jsResident,\n        total,\n        elapsedMs,\n        unattributedMs,\n        stageCount: records.length,\n        items,\n      };\n    },\n  };\n}","lineStart":1,"lineEnd":131,"totalLines":131,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/stage-telemetry.mjs","time":{"start":1784606344118,"end":1784606344123}},"id":"prt_f82d3c197001kGYGaJmpquW8wL","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ad19001fpLJRYE1hhoSZH"}}
{"type":"tool_use","timestamp":1784606344710,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_02_zP5QdIOrPVniBFhY4b0Z8632","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/canonical.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/canonical.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Shared Canonical Serialization                                          ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // Single source of truth for stable-key JSON and length-framed SHA-256 digests.\n6: // The indexer, retrieval, and the differential oracle all serialize identity\n7: // through these primitives so a golden byte reference can never drift from the\n8: // bytes production actually emits.\n9: \n10: import { createHash } from 'node:crypto';\n11: \n12: export const HASH_PREFIX = 'sha256:';\n13: \n14: /**\n15:  * Order strings by raw code-unit comparison so serialization stays locale-free.\n16:  *\n17:  * @param {*} left - Left comparand.\n18:  * @param {*} right - Right comparand.\n19:  * @returns {number} -1, 0, or 1.\n20:  */\n21: export function compareRawStrings(left, right) {\n22:   return String(left) < String(right) ? -1 : String(left) > String(right) ? 1 : 0;\n23: }\n24: \n25: /**\n26:  * Serialize a value with lexicographically sorted object keys.\n27:  *\n28:  * @param {*} value - Any JSON-compatible value.\n29:  * @returns {string} Canonical, key-sorted JSON string.\n30:  */\n31: export function stableJson(value) {\n32:   if (Array.isArray(value)) return `[${value.map(stableJson).join(',')}]`;\n33:   if (value && typeof value === 'object') {\n34:     const entries = Object.keys(value).sort(compareRawStrings)\n35:       .map((key) => `${JSON.stringify(key)}:${stableJson(value[key])}`);\n36:     return `{${entries.join(',')}}`;\n37:   }\n38:   return JSON.stringify(value);\n39: }\n40: \n41: /**\n42:  * Prefix a value's bytes with an unsigned 64-bit big-endian length frame.\n43:  *\n44:  * Length framing makes concatenated hash inputs unambiguous: no crafted value\n45:  * can span a field boundary and collide with a different field layout.\n46:  *\n47:  * @param {string|Buffer} value - Value to frame.\n48:  * @returns {[Buffer, Buffer]} The length prefix followed by the value bytes.\n49:  */\n50: export function lengthFrame(value) {\n51:   const buffer = Buffer.isBuffer(value) ? value : Buffer.from(String(value), 'utf8');\n52:   const length = Buffer.allocUnsafe(8);\n53:   length.writeBigUInt64BE(BigInt(buffer.byteLength));\n54:   return [length, buffer];\n55: }\n56: \n57: /**\n58:  * Hash one value or an ordered list of framed parts into a prefixed hex digest.\n59:  *\n60:  * A single string/Buffer hashes its own bytes; an array hashes each element in\n61:  * order, matching the framed-parts convention used across the module.\n62:  *\n63:  * @param {string|Buffer|Array<string|Buffer>} parts - Hash input.\n64:  * @returns {string} `sha256:`-prefixed lowercase hex digest.\n65:  */\n66: export function digest(parts) {\n67:   const hash = createHash('sha256');\n68:   for (const part of Array.isArray(parts) ? parts : [parts]) hash.update(part);\n69:   return `${HASH_PREFIX}${hash.digest('hex')}`;\n70: }\n\n(End of file - total 70 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Shared Canonical Serialization                                          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Single source of truth for stable-key JSON and length-framed SHA-256 digests.\n// The indexer, retrieval, and the differential oracle all serialize identity\n// through these primitives so a golden byte reference can never drift from the\n// bytes production actually emits.\n\nimport { createHash } from 'node:crypto';\n\nexport const HASH_PREFIX = 'sha256:';\n\n/**\n * Order strings by raw code-unit comparison so serialization stays locale-free.\n *\n * @param {*} left - Left comparand.\n * @param {*} right - Right comparand.\n * @returns {number} -1, 0, or 1.\n */","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/canonical.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Shared Canonical Serialization                                          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Single source of truth for stable-key JSON and length-framed SHA-256 digests.\n// The indexer, retrieval, and the differential oracle all serialize identity\n// through these primitives so a golden byte reference can never drift from the\n// bytes production actually emits.\n\nimport { createHash } from 'node:crypto';\n\nexport const HASH_PREFIX = 'sha256:';\n\n/**\n * Order strings by raw code-unit comparison so serialization stays locale-free.\n *\n * @param {*} left - Left comparand.\n * @param {*} right - Right comparand.\n * @returns {number} -1, 0, or 1.\n */\nexport function compareRawStrings(left, right) {\n  return String(left) < String(right) ? -1 : String(left) > String(right) ? 1 : 0;\n}\n\n/**\n * Serialize a value with lexicographically sorted object keys.\n *\n * @param {*} value - Any JSON-compatible value.\n * @returns {string} Canonical, key-sorted JSON string.\n */\nexport function stableJson(value) {\n  if (Array.isArray(value)) return `[${value.map(stableJson).join(',')}]`;\n  if (value && typeof value === 'object') {\n    const entries = Object.keys(value).sort(compareRawStrings)\n      .map((key) => `${JSON.stringify(key)}:${stableJson(value[key])}`);\n    return `{${entries.join(',')}}`;\n  }\n  return JSON.stringify(value);\n}\n\n/**\n * Prefix a value's bytes with an unsigned 64-bit big-endian length frame.\n *\n * Length framing makes concatenated hash inputs unambiguous: no crafted value\n * can span a field boundary and collide with a different field layout.\n *\n * @param {string|Buffer} value - Value to frame.\n * @returns {[Buffer, Buffer]} The length prefix followed by the value bytes.\n */\nexport function lengthFrame(value) {\n  const buffer = Buffer.isBuffer(value) ? value : Buffer.from(String(value), 'utf8');\n  const length = Buffer.allocUnsafe(8);\n  length.writeBigUInt64BE(BigInt(buffer.byteLength));\n  return [length, buffer];\n}\n\n/**\n * Hash one value or an ordered list of framed parts into a prefixed hex digest.\n *\n * A single string/Buffer hashes its own bytes; an array hashes each element in\n * order, matching the framed-parts convention used across the module.\n *\n * @param {string|Buffer|Array<string|Buffer>} parts - Hash input.\n * @returns {string} `sha256:`-prefixed lowercase hex digest.\n */\nexport function digest(parts) {\n  const hash = createHash('sha256');\n  for (const part of Array.isArray(parts) ? parts : [parts]) hash.update(part);\n  return `${HASH_PREFIX}${hash.digest('hex')}`;\n}","lineStart":1,"lineEnd":70,"totalLines":70,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/canonical.mjs","time":{"start":1784606344702,"end":1784606344709}},"id":"prt_f82d3c40f001oCvLYUPnyfPrGA","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ad19001fpLJRYE1hhoSZH"}}
{"type":"tool_use","timestamp":1784606345387,"sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","part":{"type":"tool","tool":"read","callID":"call_03_n6PPBszX2xijWPuNsdO62967","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Pinned Differential Oracle                                              ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: // Freeze the current retrieval/index output as canonical golden bytes, then\n6: // replay it byte-for-byte after any later change. Snapshots run through the same\n7: // shared canonicalizer production uses, so a golden file can never encode a\n8: // serialization the live code would not emit. Freezing happens before any\n9: // downstream phase touches retrieval, giving every subsequent change a stable,\n10: // pre-change reference to diff against.\n11: \n12: import { mkdir, readFile, readdir, writeFile } from 'node:fs/promises';\n13: import path from 'node:path';\n14: import { fileURLToPath } from 'node:url';\n15: \n16: import { digest, stableJson } from '../canonical.mjs';\n17: import { indexStyleCorpus } from '../indexer.mjs';\n18: import { queryPersistentStyles } from '../retrieval.mjs';\n19: import { openStyleDatabase } from '../schema.mjs';\n20: import { drainVectorQueue } from '../vectors.mjs';\n21: import { ORACLE_QUERY_SET, ORACLE_VECTOR_PROFILE, oracleEmbedder } from './query-set.mjs';\n22: \n23: export const DEFAULT_GOLDEN_DIR = path.join(path.dirname(fileURLToPath(import.meta.url)), 'golden');\n24: \n25: const VECTOR_DRAIN_BATCH = 100;\n26: \n27: /**\n28:  * Index a corpus and drain deterministic vectors into a query-ready database.\n29:  *\n30:  * The queue drains in bounded batches until it is empty so every active style\n31:  * is embedded, not just the first batch — a small fixture and a large scaled\n32:  * corpus both reach full vector coverage before the vector lane is queried.\n33:  *\n34:  * @param {Object} options - Build inputs.\n35:  * @param {string} options.corpusRoot - Authoritative corpus root.\n36:  * @param {import('node:sqlite').DatabaseSync} [options.database] - Existing connection.\n37:  * @param {boolean} [options.embed=true] - Drain deterministic vectors.\n38:  * @param {Function} [options.embedder=oracleEmbedder] - Deterministic text-to-vector callback.\n39:  * @returns {Promise<import('node:sqlite').DatabaseSync>} Ready database.\n40:  */\n41: export async function buildOracleDatabase({\n42:   corpusRoot,\n43:   database,\n44:   embed = true,\n45:   embedder = oracleEmbedder,\n46: }) {\n47:   const connection = database ?? openStyleDatabase();\n48:   await indexStyleCorpus({\n49:     corpusRoot,\n50:     database: connection,\n51:     corpusWalkMode: 'migration',\n52:     embeddingProfile: ORACLE_VECTOR_PROFILE,\n53:   });\n54:   if (embed) {\n55:     let drained;\n56:     do {\n57:       drained = await drainVectorQueue(connection, {\n58:         profileId: ORACLE_VECTOR_PROFILE.id,\n59:         embedder: async (text) => embedder(text),\n60:         limit: VECTOR_DRAIN_BATCH,\n61:       });\n62:     } while (drained.attempted > 0);\n63:   }\n64:   return connection;\n65: }\n66: \n67: /**\n68:  * Run one scenario, including its optional cursor follow-up.\n69:  *\n70:  * @param {import('node:sqlite').DatabaseSync} database - Query database.\n71:  * @param {Object} scenario - Query-set scenario.\n72:  * @returns {Object} Ordered snapshot of the scenario's outputs.\n73:  */\n74: export function snapshotScenario(database, scenario) {\n75:   const result = queryPersistentStyles(scenario.request, { database });\n76:   const snapshot = { name: scenario.name, request: scenario.request, result };\n77:   if (typeof scenario.follow === 'function' && result.nextCursor) {\n78:     snapshot.follow = queryPersistentStyles(scenario.follow(result), { database });\n79:   }\n80:   return snapshot;\n81: }\n82: \n83: /**\n84:  * Canonicalize a scenario snapshot into golden bytes and a digest.\n85:  *\n86:  * @param {Object} snapshot - Scenario snapshot.\n87:  * @returns {{name:string, canonical:string, sha256:string}} Canonical capture.\n88:  */\n89: export function canonicalizeSnapshot(snapshot) {\n90:   const canonical = stableJson(snapshot);\n91:   return { name: snapshot.name, canonical, sha256: digest(canonical) };\n92: }\n93: \n94: /**\n95:  * Capture the whole query matrix as canonical captures.\n96:  *\n97:  * @param {import('node:sqlite').DatabaseSync} database - Query database.\n98:  * @param {Object[]} [querySet=ORACLE_QUERY_SET] - Scenarios to capture.\n99:  * @returns {Array<{name:string, canonical:string, sha256:string}>} Captures.\n100:  */\n101: export function captureOracle(database, querySet = ORACLE_QUERY_SET) {\n102:   return querySet.map((scenario) => canonicalizeSnapshot(snapshotScenario(database, scenario)));\n103: }\n104: \n105: function goldenPathFor(goldenDir, name) {\n106:   return path.join(goldenDir, `${name}.canonical.json`);\n107: }\n108: \n109: /**\n110:  * Freeze the query matrix as canonical golden bytes on disk.\n111:  *\n112:  * @param {Object} options - Freeze inputs.\n113:  * @param {import('node:sqlite').DatabaseSync} options.database - Query database.\n114:  * @param {string} [options.goldenDir=DEFAULT_GOLDEN_DIR] - Golden output directory.\n115:  * @param {Object[]} [options.querySet=ORACLE_QUERY_SET] - Scenarios to freeze.\n116:  * @returns {Promise<Array>} The captures written.\n117:  */\n118: export async function freezeOracle({ database, goldenDir = DEFAULT_GOLDEN_DIR, querySet = ORACLE_QUERY_SET }) {\n119:   const captures = captureOracle(database, querySet);\n120:   await mkdir(goldenDir, { recursive: true });\n121:   const index = { version: 1, scenarios: captures.map(({ name, sha256 }) => ({ name, sha256 })) };\n122:   await writeFile(path.join(goldenDir, 'index.json'), `${JSON.stringify(index, null, 2)}\\n`);\n123:   for (const capture of captures) {\n124:     await writeFile(goldenPathFor(goldenDir, capture.name), `${capture.canonical}\\n`);\n125:   }\n126:   return captures;\n127: }\n128: \n129: /**\n130:  * Replay the query matrix and assert byte-for-byte parity with the golden set.\n131:  *\n132:  * @param {Object} options - Replay inputs.\n133:  * @param {import('node:sqlite').DatabaseSync} options.database - Query database.\n134:  * @param {string} [options.goldenDir=DEFAULT_GOLDEN_DIR] - Golden directory.\n135:  * @param {Object[]} [options.querySet=ORACLE_QUERY_SET] - Scenarios to replay.\n136:  * @returns {Promise<{ok:boolean, mismatches:Object[], captures:Array}>} Replay outcome.\n137:  */\n138: export async function replayOracle({ database, goldenDir = DEFAULT_GOLDEN_DIR, querySet = ORACLE_QUERY_SET }) {\n139:   const captures = captureOracle(database, querySet);\n140:   const mismatches = [];\n141:   for (const capture of captures) {\n142:     let golden;\n143:     try {\n144:       golden = await readFile(goldenPathFor(goldenDir, capture.name), 'utf8');\n145:     } catch {\n146:       mismatches.push({ name: capture.name, reason: 'missing-golden' });\n147:       continue;\n148:     }\n149:     if (golden !== `${capture.canonical}\\n`) {\n150:       mismatches.push({ name: capture.name, reason: 'byte-mismatch', sha256: capture.sha256 });\n151:     }\n152:   }\n153:   return { ok: mismatches.length === 0, mismatches, captures };\n154: }\n155: \n156: /**\n157:  * List the scenario names a golden directory currently pins.\n158:  *\n159:  * @param {string} [goldenDir=DEFAULT_GOLDEN_DIR] - Golden directory.\n160:  * @returns {Promise<string[]>} Sorted scenario names.\n161:  */\n162: export async function listGoldenScenarios(goldenDir = DEFAULT_GOLDEN_DIR) {\n163:   const entries = await readdir(goldenDir).catch(() => []);\n164:   return entries.filter((name) => name.endsWith('.canonical.json'))\n165:     .map((name) => name.replace('.canonical.json', ''))\n166:     .sort();\n167: }\n\n(End of file - total 167 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Pinned Differential Oracle                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Freeze the current retrieval/index output as canonical golden bytes, then\n// replay it byte-for-byte after any later change. Snapshots run through the same\n// shared canonicalizer production uses, so a golden file can never encode a\n// serialization the live code would not emit. Freezing happens before any\n// downstream phase touches retrieval, giving every subsequent change a stable,\n// pre-change reference to diff against.\n\nimport { mkdir, readFile, readdir, writeFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { digest, stableJson } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\nimport { drainVectorQueue } from '../vectors.mjs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Pinned Differential Oracle                                              ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n// Freeze the current retrieval/index output as canonical golden bytes, then\n// replay it byte-for-byte after any later change. Snapshots run through the same\n// shared canonicalizer production uses, so a golden file can never encode a\n// serialization the live code would not emit. Freezing happens before any\n// downstream phase touches retrieval, giving every subsequent change a stable,\n// pre-change reference to diff against.\n\nimport { mkdir, readFile, readdir, writeFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { digest, stableJson } from '../canonical.mjs';\nimport { indexStyleCorpus } from '../indexer.mjs';\nimport { queryPersistentStyles } from '../retrieval.mjs';\nimport { openStyleDatabase } from '../schema.mjs';\nimport { drainVectorQueue } from '../vectors.mjs';\nimport { ORACLE_QUERY_SET, ORACLE_VECTOR_PROFILE, oracleEmbedder } from './query-set.mjs';\n\nexport const DEFAULT_GOLDEN_DIR = path.join(path.dirname(fileURLToPath(import.meta.url)), 'golden');\n\nconst VECTOR_DRAIN_BATCH = 100;\n\n/**\n * Index a corpus and drain deterministic vectors into a query-ready database.\n *\n * The queue drains in bounded batches until it is empty so every active style\n * is embedded, not just the first batch — a small fixture and a large scaled\n * corpus both reach full vector coverage before the vector lane is queried.\n *\n * @param {Object} options - Build inputs.\n * @param {string} options.corpusRoot - Authoritative corpus root.\n * @param {import('node:sqlite').DatabaseSync} [options.database] - Existing connection.\n * @param {boolean} [options.embed=true] - Drain deterministic vectors.\n * @param {Function} [options.embedder=oracleEmbedder] - Deterministic text-to-vector callback.\n * @returns {Promise<import('node:sqlite').DatabaseSync>} Ready database.\n */\nexport async function buildOracleDatabase({\n  corpusRoot,\n  database,\n  embed = true,\n  embedder = oracleEmbedder,\n}) {\n  const connection = database ?? openStyleDatabase();\n  await indexStyleCorpus({\n    corpusRoot,\n    database: connection,\n    corpusWalkMode: 'migration',\n    embeddingProfile: ORACLE_VECTOR_PROFILE,\n  });\n  if (embed) {\n    let drained;\n    do {\n      drained = await drainVectorQueue(connection, {\n        profileId: ORACLE_VECTOR_PROFILE.id,\n        embedder: async (text) => embedder(text),\n        limit: VECTOR_DRAIN_BATCH,\n      });\n    } while (drained.attempted > 0);\n  }\n  return connection;\n}\n\n/**\n * Run one scenario, including its optional cursor follow-up.\n *\n * @param {import('node:sqlite').DatabaseSync} database - Query database.\n * @param {Object} scenario - Query-set scenario.\n * @returns {Object} Ordered snapshot of the scenario's outputs.\n */\nexport function snapshotScenario(database, scenario) {\n  const result = queryPersistentStyles(scenario.request, { database });\n  const snapshot = { name: scenario.name, request: scenario.request, result };\n  if (typeof scenario.follow === 'function' && result.nextCursor) {\n    snapshot.follow = queryPersistentStyles(scenario.follow(result), { database });\n  }\n  return snapshot;\n}\n\n/**\n * Canonicalize a scenario snapshot into golden bytes and a digest.\n *\n * @param {Object} snapshot - Scenario snapshot.\n * @returns {{name:string, canonical:string, sha256:string}} Canonical capture.\n */\nexport function canonicalizeSnapshot(snapshot) {\n  const canonical = stableJson(snapshot);\n  return { name: snapshot.name, canonical, sha256: digest(canonical) };\n}\n\n/**\n * Capture the whole query matrix as canonical captures.\n *\n * @param {import('node:sqlite').DatabaseSync} database - Query database.\n * @param {Object[]} [querySet=ORACLE_QUERY_SET] - Scenarios to capture.\n * @returns {Array<{name:string, canonical:string, sha256:string}>} Captures.\n */\nexport function captureOracle(database, querySet = ORACLE_QUERY_SET) {\n  return querySet.map((scenario) => canonicalizeSnapshot(snapshotScenario(database, scenario)));\n}\n\nfunction goldenPathFor(goldenDir, name) {\n  return path.join(goldenDir, `${name}.canonical.json`);\n}\n\n/**\n * Freeze the query matrix as canonical golden bytes on disk.\n *\n * @param {Object} options - Freeze inputs.\n * @param {import('node:sqlite').DatabaseSync} options.database - Query database.\n * @param {string} [options.goldenDir=DEFAULT_GOLDEN_DIR] - Golden output directory.\n * @param {Object[]} [options.querySet=ORACLE_QUERY_SET] - Scenarios to freeze.\n * @returns {Promise<Array>} The captures written.\n */\nexport async function freezeOracle({ database, goldenDir = DEFAULT_GOLDEN_DIR, querySet = ORACLE_QUERY_SET }) {\n  const captures = captureOracle(database, querySet);\n  await mkdir(goldenDir, { recursive: true });\n  const index = { version: 1, scenarios: captures.map(({ name, sha256 }) => ({ name, sha256 })) };\n  await writeFile(path.join(goldenDir, 'index.json'), `${JSON.stringify(index, null, 2)}\\n`);\n  for (const capture of captures) {\n    await writeFile(goldenPathFor(goldenDir, capture.name), `${capture.canonical}\\n`);\n  }\n  return captures;\n}\n\n/**\n * Replay the query matrix and assert byte-for-byte parity with the golden set.\n *\n * @param {Object} options - Replay inputs.\n * @param {import('node:sqlite').DatabaseSync} options.database - Query database.\n * @param {string} [options.goldenDir=DEFAULT_GOLDEN_DIR] - Golden directory.\n * @param {Object[]} [options.querySet=ORACLE_QUERY_SET] - Scenarios to replay.\n * @returns {Promise<{ok:boolean, mismatches:Object[], captures:Array}>} Replay outcome.\n */\nexport async function replayOracle({ database, goldenDir = DEFAULT_GOLDEN_DIR, querySet = ORACLE_QUERY_SET }) {\n  const captures = captureOracle(database, querySet);\n  const mismatches = [];\n  for (const capture of captures) {\n    let golden;\n    try {\n      golden = await readFile(goldenPathFor(goldenDir, capture.name), 'utf8');\n    } catch {\n      mismatches.push({ name: capture.name, reason: 'missing-golden' });\n      continue;\n    }\n    if (golden !== `${capture.canonical}\\n`) {\n      mismatches.push({ name: capture.name, reason: 'byte-mismatch', sha256: capture.sha256 });\n    }\n  }\n  return { ok: mismatches.length === 0, mismatches, captures };\n}\n\n/**\n * List the scenario names a golden directory currently pins.\n *\n * @param {string} [goldenDir=DEFAULT_GOLDEN_DIR] - Golden directory.\n * @returns {Promise<string[]>} Sorted scenario names.\n */\nexport async function listGoldenScenarios(goldenDir = DEFAULT_GOLDEN_DIR) {\n  const entries = await readdir(goldenDir).catch(() => []);\n  return entries.filter((name) => name.endsWith('.canonical.json'))\n    .map((name) => name.replace('.canonical.json', ''))\n    .sort();\n}","lineStart":1,"lineEnd":167,"totalLines":167,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs","time":{"start":1784606345378,"end":1784606345386}},"id":"prt_f82d3c657001oteS44KHAmyg8X","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d3ad19001fpLJRYE1hhoSZH"}}
