   814	          }
   815	        }
   816	        return;
   817	      }
   818	
   819	      if (eventType === 'server.instance.disposed' || eventType === 'global.disposed') {
   820	        resetRuntimeState();
   821	      }
   822	    },
   823	
   824	    'experimental.chat.system.transform': appendAdvisorBrief,
   825	
   826	    tool: {
   827	      spec_kit_skill_advisor_status: tool({
   828	        description: 'Show Spec Kit skill advisor plugin prompt-safe cache status',
   829	        args: {},
   830	        async execute() {
   831	          return [
   832	            `plugin_id=${PLUGIN_ID}`,
   833	            `enabled=${options.enabled}`,
   834	            `disabled_reason=${state.disabledReason ?? 'none'}`,
   835	            `config_status=${state.configStatus}`,
   836	            `config_error_code=${state.configErrorCode ?? 'none'}`,
   837	            `cache_ttl_ms=${options.cacheTTLMs}`,
   838	            `threshold_confidence=${options.thresholdConfidence}`,
   839	            `max_tokens=${options.maxTokens}`,
   840	            `max_prompt_bytes=${options.maxPromptBytes}`,
   841	            `max_brief_chars=${options.maxBriefChars}`,
   842	            `max_cache_entries=${options.maxCacheEntries}`,
   843	            `runtime_ready=${state.runtimeReady}`,
   844	            `node_binary=${statusSafeBinary(options.nodeBinary)}`,
   845	            `bridge_timeout_ms=${options.bridgeTimeoutMs}`,
   846	            `bridge_path=${statusSafePath('skill-advisor-bridge')}`,
   847	            `last_bridge_status=${state.lastBridgeStatus}`,
   848	            `last_runtime_status=${state.lastBridgeStatus}`,
   849	            `last_error_code=${state.lastErrorCode ?? 'none'}`,
   850	            `last_runtime_error=${state.lastErrorCode ?? 'none'}`,
   851	            `last_duration_ms=${state.lastDurationMs}`,
