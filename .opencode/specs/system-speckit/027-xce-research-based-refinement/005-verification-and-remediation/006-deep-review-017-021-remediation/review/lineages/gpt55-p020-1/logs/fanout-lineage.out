{"type":"tool_use","timestamp":1781756762186,"sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","part":{"type":"tool","tool":"read","callID":"call_lJuCvXEVHPja4psULcdM8FNd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Transaction Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Atomic file + index operations with pending file recovery\n6: import type Database from 'better-sqlite3';\n7: import * as fs from 'fs';\n8: import * as path from 'path';\n9: import { resolveDatabasePaths } from '../../core/config.js';\n10: \n11: /* ───────────────────────────────────────────────────────────────\n12:    1. CONSTANTS\n13: ----------------------------------------------------------------*/\n14: \n15: const PENDING_SUFFIX = '_pending';\n16: const TEMP_SUFFIX = '.tmp';\n17: const PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n18: \n19: /* ───────────────────────────────────────────────────────────────\n20:    2. INTERFACES\n21: ----------------------------------------------------------------*/\n22: \n23: interface TransactionMetrics {\n24:   totalAtomicWrites: number;\n25:   totalDeletes: number;\n26:   totalRecoveries: number;\n27:   totalErrors: number;\n28:   lastOperationTime: string | null;\n29:   [key: string]: unknown;\n30: }\n31: \n32: interface AtomicSaveResult {\n33:   success: boolean;\n34:   filePath: string;\n35:   error?: string;\n36:   /** Set when DB committed but rename failed, indicating partial state */\n37:   dbCommitted?: boolean;\n38: }\n39: \n40: interface RecoveryResult {\n41:   path: string;\n42:   recovered: boolean;\n43:   error?: string;\n44: }\n45: \n46: /**\n47:  * Optional database probe used during pending-file recovery.\n48:  * Return `true` when the original path already has a committed `memory_index` row.\n49:  * Return `false` to leave the `_pending` file in place for manual review.\n50:  * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n51:  */\n52: type IsCommittedCheck = (originalPath: string) => boolean;\n53: \n54: /* ───────────────────────────────────────────────────────────────\n55:    3. MODULE STATE\n56: ----------------------------------------------------------------*/\n57: \n58: const metrics: TransactionMetrics = {\n59:   totalAtomicWrites: 0,\n60:   totalDeletes: 0,\n61:   totalRecoveries: 0,\n62:   totalErrors: 0,\n63:   lastOperationTime: null,\n64: };\n65: \n66: const activeTransactions = new WeakMap<object, number>();\n67: \n68: /* ───────────────────────────────────────────────────────────────\n69:    4. METRICS\n70: ----------------------------------------------------------------*/\n71: \n72: function getMetrics(): TransactionMetrics {\n73:   return { ...metrics };\n74: }\n75: \n76: function resetMetrics(): void {\n77:   metrics.totalAtomicWrites = 0;\n78:   metrics.totalDeletes = 0;\n79:   metrics.totalRecoveries = 0;\n80:   metrics.totalErrors = 0;\n81:   metrics.lastOperationTime = null;\n82: }\n83: \n84: /* ───────────────────────────────────────────────────────────────\n85:    5. PATH HELPERS\n86: ----------------------------------------------------------------*/\n87: \n88: function getPendingPath(filePath: string): string {\n89:   const dir = path.dirname(filePath);\n90:   const ext = path.extname(filePath);\n91:   const base = path.basename(filePath, ext);\n92:   return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n93: }\n94: \n95: interface PendingPathInfo {\n96:   originalPath: string;\n97:   basePendingPath: string;\n98:   uniqueSuffix: string | null;\n99: }\n100: \n101: function parsePendingPath(filePath: string): PendingPathInfo | null {\n102:   const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n103:     const dir = path.dirname(candidatePath);\n104:     const ext = path.extname(candidatePath);\n105:     const base = path.basename(candidatePath, ext);\n106:     if (!base.endsWith(PENDING_SUFFIX)) {\n107:       return null;\n108:     }\n109: \n110:     const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n111:     return {\n112:       originalPath: path.join(dir, `${originalBase}${ext}`),\n113:       basePendingPath: candidatePath,\n114:       uniqueSuffix: null,\n115:     };\n116:   };\n117: \n118:   const suffixExt = path.extname(filePath);\n119:   if (suffixExt) {\n120:     const uniqueSuffix = suffixExt.slice(1);\n121:     const basePendingPath = filePath.slice(0, -suffixExt.length);\n122:     const suffixedMatch = parseBasePendingPath(basePendingPath);\n123:     if (\n124:       suffixedMatch &&\n125:       path.extname(suffixedMatch.basePendingPath) &&\n126:       PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n127:     ) {\n128:       return {\n129:         ...suffixedMatch,\n130:         uniqueSuffix,\n131:       };\n132:     }\n133:   }\n134: \n135:   return parseBasePendingPath(filePath);\n136: }\n137: \n138: function isPendingFile(filePath: string): boolean {\n139:   return parsePendingPath(filePath) !== null;\n140: }\n141: \n142: function getOriginalPath(pendingPath: string): string {\n143:   return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n144: }\n145: \n146: function runInTransaction<T>(database: Database.Database, callback: () => T): T {\n147:   const runCallback = (): T => {\n148:     const depth = activeTransactions.get(database) ?? 0;\n149:     activeTransactions.set(database, depth + 1);\n150:     try {\n151:       return callback();\n152:     } finally {\n153:       const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n154:       if (nextDepth > 0) {\n155:         activeTransactions.set(database, nextDepth);\n156:       } else {\n157:         activeTransactions.delete(database);\n158:       }\n159:     }\n160:   };\n161: \n162:   if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n163:     return runCallback();\n164:   }\n165: \n166:   return database.transaction(() => runCallback())();\n167: }\n168: \n169: /* ───────────────────────────────────────────────────────────────\n170:    6. ATOMIC FILE OPERATIONS\n171: ----------------------------------------------------------------*/\n172: \n173: /**\n174:  * Write a file atomically using write-to-temp-then-rename pattern.\n175:  * This prevents partial writes if the process crashes mid-write.\n176:  */\n177: function atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n178:   const tempPath = filePath + TEMP_SUFFIX;\n179: \n180:   try {\n181:     // Ensure directory exists\n182:     const dir = path.dirname(filePath);\n183:     if (!fs.existsSync(dir)) {\n184:       fs.mkdirSync(dir, { recursive: true });\n185:     }\n186: \n187:     // Write to temp file\n188:     fs.writeFileSync(tempPath, content, encoding);\n189: \n190:     // Atomic rename\n191:     fs.renameSync(tempPath, filePath);\n192: \n193:     metrics.totalAtomicWrites++;\n194:     metrics.lastOperationTime = new Date().toISOString();\n195:     return true;\n196:   } catch (error: unknown) {\n197:     const msg = error instanceof Error ? error.message : String(error);\n198:     console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n199:     metrics.totalErrors++;\n200: \n201:     // Clean up temp file\n202:     try {\n203:       if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n204:     } catch { /* ignore cleanup errors */ }\n205: \n206:     return false;\n207:   }\n208: }\n209: \n210: /**\n211:  * Delete a file if it exists.\n212:  */\n213: function deleteFileIfExists(filePath: string): boolean {\n214:   try {\n215:     if (fs.existsSync(filePath)) {\n216:       fs.unlinkSync(filePath);\n217:       metrics.totalDeletes++;\n218:       metrics.lastOperationTime = new Date().toISOString();\n219:       return true;\n220:     }\n221:     return false;\n222:   } catch (error: unknown) {\n223:     const msg = error instanceof Error ? error.message : String(error);\n224:     console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n225:     metrics.totalErrors++;\n226:     return false;\n227:   }\n228: }\n229: \n230: /**\n231:  * Execute an atomic save with pending file pattern.\n232:  * 1. Write to pending path\n233:  * 2. Execute database operations\n234:  * 3. Rename pending to final\n235:  *\n236:  * This function provides file-system-level atomicity (write-to-pending + rename),\n237:  * NOT database transaction isolation. Callers needing transactional guarantees for\n238:  * dbOperation() must wrap it in their own db.transaction() call. The rename step\n239:  * ensures the file is either fully written or not present, but the DB operation\n240:  * is not rolled back if the rename fails (extremely rare on local filesystems).\n\n(Showing lines 1-240 of 470. Use offset=241 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Transaction Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Transaction Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface TransactionMetrics {\n  totalAtomicWrites: number;\n  totalDeletes: number;\n  totalRecoveries: number;\n  totalErrors: number;\n  lastOperationTime: string | null;\n  [key: string]: unknown;\n}\n\ninterface AtomicSaveResult {\n  success: boolean;\n  filePath: string;\n  error?: string;\n  /** Set when DB committed but rename failed, indicating partial state */\n  dbCommitted?: boolean;\n}\n\ninterface RecoveryResult {\n  path: string;\n  recovered: boolean;\n  error?: string;\n}\n\n/**\n * Optional database probe used during pending-file recovery.\n * Return `true` when the original path already has a committed `memory_index` row.\n * Return `false` to leave the `_pending` file in place for manual review.\n * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n */\ntype IsCommittedCheck = (originalPath: string) => boolean;\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nconst metrics: TransactionMetrics = {\n  totalAtomicWrites: 0,\n  totalDeletes: 0,\n  totalRecoveries: 0,\n  totalErrors: 0,\n  lastOperationTime: null,\n};\n\nconst activeTransactions = new WeakMap<object, number>();\n\n/* ───────────────────────────────────────────────────────────────\n   4. METRICS\n----------------------------------------------------------------*/\n\nfunction getMetrics(): TransactionMetrics {\n  return { ...metrics };\n}\n\nfunction resetMetrics(): void {\n  metrics.totalAtomicWrites = 0;\n  metrics.totalDeletes = 0;\n  metrics.totalRecoveries = 0;\n  metrics.totalErrors = 0;\n  metrics.lastOperationTime = null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. PATH HELPERS\n----------------------------------------------------------------*/\n\nfunction getPendingPath(filePath: string): string {\n  const dir = path.dirname(filePath);\n  const ext = path.extname(filePath);\n  const base = path.basename(filePath, ext);\n  return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n}\n\ninterface PendingPathInfo {\n  originalPath: string;\n  basePendingPath: string;\n  uniqueSuffix: string | null;\n}\n\nfunction parsePendingPath(filePath: string): PendingPathInfo | null {\n  const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n    const dir = path.dirname(candidatePath);\n    const ext = path.extname(candidatePath);\n    const base = path.basename(candidatePath, ext);\n    if (!base.endsWith(PENDING_SUFFIX)) {\n      return null;\n    }\n\n    const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n    return {\n      originalPath: path.join(dir, `${originalBase}${ext}`),\n      basePendingPath: candidatePath,\n      uniqueSuffix: null,\n    };\n  };\n\n  const suffixExt = path.extname(filePath);\n  if (suffixExt) {\n    const uniqueSuffix = suffixExt.slice(1);\n    const basePendingPath = filePath.slice(0, -suffixExt.length);\n    const suffixedMatch = parseBasePendingPath(basePendingPath);\n    if (\n      suffixedMatch &&\n      path.extname(suffixedMatch.basePendingPath) &&\n      PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n    ) {\n      return {\n        ...suffixedMatch,\n        uniqueSuffix,\n      };\n    }\n  }\n\n  return parseBasePendingPath(filePath);\n}\n\nfunction isPendingFile(filePath: string): boolean {\n  return parsePendingPath(filePath) !== null;\n}\n\nfunction getOriginalPath(pendingPath: string): string {\n  return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n}\n\nfunction runInTransaction<T>(database: Database.Database, callback: () => T): T {\n  const runCallback = (): T => {\n    const depth = activeTransactions.get(database) ?? 0;\n    activeTransactions.set(database, depth + 1);\n    try {\n      return callback();\n    } finally {\n      const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n      if (nextDepth > 0) {\n        activeTransactions.set(database, nextDepth);\n      } else {\n        activeTransactions.delete(database);\n      }\n    }\n  };\n\n  if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n    return runCallback();\n  }\n\n  return database.transaction(() => runCallback())();\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. ATOMIC FILE OPERATIONS\n----------------------------------------------------------------*/\n\n/**\n * Write a file atomically using write-to-temp-then-rename pattern.\n * This prevents partial writes if the process crashes mid-write.\n */\nfunction atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n  const tempPath = filePath + TEMP_SUFFIX;\n\n  try {\n    // Ensure directory exists\n    const dir = path.dirname(filePath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n\n    // Write to temp file\n    fs.writeFileSync(tempPath, content, encoding);\n\n    // Atomic rename\n    fs.renameSync(tempPath, filePath);\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n    metrics.totalErrors++;\n\n    // Clean up temp file\n    try {\n      if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n    } catch { /* ignore cleanup errors */ }\n\n    return false;\n  }\n}\n\n/**\n * Delete a file if it exists.\n */\nfunction deleteFileIfExists(filePath: string): boolean {\n  try {\n    if (fs.existsSync(filePath)) {\n      fs.unlinkSync(filePath);\n      metrics.totalDeletes++;\n      metrics.lastOperationTime = new Date().toISOString();\n      return true;\n    }\n    return false;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n    metrics.totalErrors++;\n    return false;\n  }\n}\n\n/**\n * Execute an atomic save with pending file pattern.\n * 1. Write to pending path\n * 2. Execute database operations\n * 3. Rename pending to final\n *\n * This function provides file-system-level atomicity (write-to-pending + rename),\n * NOT database transaction isolation. Callers needing transactional guarantees for\n * dbOperation() must wrap it in their own db.transaction() call. The rename step\n * ensures the file is either fully written or not present, but the DB operation\n * is not rolled back if the rename fails (extremely rare on local filesystems).","lineStart":1,"lineEnd":240,"totalLines":470,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","time":{"start":1781756762179,"end":1781756762185}},"metadata":{"openai":{"itemId":"fc_063b1ce441418689016a33735a15748191b2cdcfb5838b64c6"}},"id":"prt_ed8fa980b001FkEvn4T17urFNY","sessionID":"ses_1270761e3ffewfNQvkGMF3JgBO","messageID":"msg_ed8fa580b001q5k754wm0QrP90"}}
