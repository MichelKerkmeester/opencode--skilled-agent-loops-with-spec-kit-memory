   266	
   267	function createChildEnv(sourceEnv = process.env) {
   268	  const filtered = Object.fromEntries(
   269	    Object.entries(sourceEnv).filter(([key, value]) => CHILD_ENV_ALLOWLIST.has(key) && typeof value === 'string'),
   270	  );
   271	  // Without an explicit MEMORY_DB_PATH, shared/embeddings/factory.ts's
   272	  // resolveConfiguredDatabaseCandidates() falls back to walking up from its own
   273	  // on-disk realpath, which resolves through the @spec-kit/shared symlink to
   274	  // mk-spec-memory's package root — not this advisor's own database. Compute
   275	  // the child's MEMORY_DB_PATH explicitly from the dedicated skill-advisor
   276	  // override var (never from a blindly-forwarded ambient MEMORY_DB_PATH — that
   277	  // name's repo-wide established meaning is mk-spec-memory's own database, so
   278	  // treating it as "already configured for skill-advisor" would silently
   279	  // reopen the exact leak this pointer exists to prevent).
   280	  const explicitOverride = typeof sourceEnv.MK_SKILL_ADVISOR_MEMORY_DB_PATH === 'string'
   281	    && sourceEnv.MK_SKILL_ADVISOR_MEMORY_DB_PATH.length > 0
   282	    ? sourceEnv.MK_SKILL_ADVISOR_MEMORY_DB_PATH
   283	    : undefined;
   284	  filtered.MEMORY_DB_PATH = explicitOverride ?? advisorDbPath();
   285	  return filtered;
   286	}
   287	
   288	function refreshPaths() {
   289	  skillsDir = path.join(opencodeDir, 'skills');
   290	  kitDir = path.join(skillsDir, 'system-skill-advisor');
   291	  mcpDir = path.join(kitDir, 'mcp-server');
   292	  dbDir = path.join(mcpDir, 'database');
   293	  lockDir = path.join(dbDir, '.mk-skill-advisor-launcher.lockdir');
   294	  stateFile = path.join(dbDir, PID_FILE_NAME);
   295	  systemSpecKitDbDir = path.join(skillsDir, 'system-spec-kit', 'mcp-server', 'database');
   296	}
   297	
   298	function exists(p) {
   299	  return fs.existsSync(p);
   300	}
   301	
   302	function canonicalizePath(pathValue) {
   303	  const resolvedPath = path.resolve(pathValue);
   304	  try {
   305	    return fs.realpathSync.native(resolvedPath);
   306	  } catch (error) {
   307	    if (error.code === 'ENOENT') return resolvedPath;
   308	    throw error;
   309	  }
   310	}
   311	
   312	function ensureCanonicalDir(dirPath) {
   313	  fs.mkdirSync(canonicalizePath(dirPath), { recursive: true, mode: 0o700 });
   314	  return canonicalizePath(dirPath);
   315	}
   316	
   317	function advisorDbPath() {
   318	  return path.join(resolvedAdvisorDbDir(), 'skill-graph.sqlite');
   319	}
   320	
   321	function resolvedAdvisorDbDir() {
   322	  const overrideDbDir = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;
   323	  return overrideDbDir
   324	    ? canonicalizePath(overrideDbDir)
   325	    : canonicalizePath(dbDir);
   326	}
   327	
   328	function writeState(payload) {
   329	  ensureCanonicalDir(dbDir);
   330	  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\n`);
   331	}
   332	
   333	function leasePath() {
   334	  return path.join(resolvedAdvisorDbDir(), PID_FILE_NAME);
   335	}
   336	
   337	function ownerLeasePath() {
   338	  return path.join(resolvedAdvisorDbDir(), OWNER_LEASE_FILE_NAME);
   339	}
   340	
   341	function readLeaseFile(filePath = leasePath()) {
   342	  try {
   343	    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));
   344	    if (typeof parsed.pid === 'number') return parsed;
   345	  } catch {
   346	    // Missing or corrupt launcher lease files are treated as already clear.
   347	  }
   348	  return null;
   349	}
   350	
   351	function leaseHeldFromFile(filePath = leasePath(), legacyPath = null) {
   352	  const lease = readLeaseFile(filePath);
   353	  if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath, socketPath: null };
   354	  const startedAt = lease.startedAt ?? new Date(0).toISOString();
   355	  const socketPath = typeof lease.socketPath === 'string' && lease.socketPath.length > 0 ? lease.socketPath : null;
   356	  try {
   357	    process.kill(lease.pid, 0);
   358	    return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };
   359	  } catch (error) {
   360	    if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath, socketPath };
   360	    if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath, socketPath };
   361	    if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };
   362	    throw error;
   363	  }
   364	}
   365	
   366	function readOwnerLeaseFile(filePath = ownerLeasePath()) {
   367	  try {
   368	    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));
   369	    if (
   370	      Number.isInteger(parsed.ownerPid) &&
   371	      Number.isInteger(parsed.ppid) &&
   372	      typeof parsed.executablePath === 'string' &&
   373	      typeof parsed.startedAtIso === 'string' &&
   374	      typeof parsed.lastHeartbeatIso === 'string' &&
   375	      Number.isInteger(parsed.ttlMs) &&
   376	      typeof parsed.canonicalDbDir === 'string'
   377	    ) {
   378	      return parsed;
   379	    }
   380	  } catch {
   381	    // Missing or corrupt owner leases are treated as no active owner.
   382	  }
   383	  return null;
   384	}
   385	
   386	function writeOwnerLeaseFile(lease) {
   387	  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);
   388	  const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;
   389	  let fd;
   390	  try {
   391	    fd = fs.openSync(tmp, 'wx', 0o600);
   392	    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\n`, 'utf8');
   393	    fs.fsyncSync(fd);
   394	  } finally {
   395	    if (typeof fd === 'number') fs.closeSync(fd);
   396	  }
   397	  fs.renameSync(tmp, currentLeasePath);
   398	}
   399	
   400	function writeOwnerLeaseFileExclusive(lease) {
   401	  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);
   402	  let fd;
   403	  try {
   404	    fd = fs.openSync(currentLeasePath, 'wx', 0o600);
   405	    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\n`, 'utf8');
   406	    fs.fsyncSync(fd);
   407	    return true;
   408	  } catch (error) {
   409	    if (error.code === 'EEXIST') return false;
   410	    throw error;
   411	  } finally {
   412	    if (typeof fd === 'number') fs.closeSync(fd);
   413	  }
   414	}
   415	
   416	function buildOwnerLease(ownerPid = process.pid) {
   417	  return {
   418	    ownerPid,
   419	    ppid: process.ppid,
   420	    executablePath: process.execPath,
   421	    startedAtIso: new Date().toISOString(),
   422	    lastHeartbeatIso: new Date().toISOString(),
   423	    ttlMs: 60000,
   424	    canonicalDbDir: resolvedAdvisorDbDir(),
   425	  };
   426	}
   427	
   428	// ─────────────────────────────────────────────────────────────────────────────
   429	// 7. PROCESS LIVENESS & REAP HELPERS
   430	// ─────────────────────────────────────────────────────────────────────────────
   431	
   432	function processLiveness(pid) {
   433	  if (!Number.isInteger(pid) || pid <= 0) return 'dead';
   434	  try {
   435	    process.kill(pid, 0);
   436	    return 'alive';
   437	  } catch (error) {
   438	    if (error.code === 'ESRCH') return 'dead';
   439	    if (error.code === 'EPERM') return 'unknown-eperm';
   440	    return 'alive';
   441	  }
   442	}
   443	
   444	async function waitForPidExit(pid, timeoutMs) {
   445	  const deadline = Date.now() + timeoutMs;
   446	  while (Date.now() <= deadline) {
   447	    if (processLiveness(pid) === 'dead') return true;
   448	    await sleep(100);
   449	  }
   450	  return processLiveness(pid) === 'dead';
   451	}
   452	
   453	// Best-effort read of a live process's executable basename (comm). Returns null
   454	// when it cannot be determined (no ps, permission error, or the pid is gone), so
   455	// callers treat "cannot prove it is the wrong process" as "do not skip the reap".
   456	function readProcessExecutableBasename(pid) {
   457	  if (!Number.isInteger(pid) || pid <= 0) return null;
   458	  try {
   459	    const result = spawnSync('ps', ['-p', String(pid), '-o', 'comm='], {
   460	      encoding: 'utf8',
   461	      stdio: ['ignore', 'pipe', 'pipe'],
   462	    });
   463	    if (result.error || result.status !== 0) return null;
   464	    const comm = String(result.stdout || '').trim();
   465	    if (!comm) return null;
   466	    return path.basename(comm);
   467	  } catch {
   468	    return null;
   469	  }
   470	}
   471	
   472	async function reapOwnerBeforeRespawn(ownerPid, expectedExecutablePath = null) {
   473	  const liveness = processLiveness(ownerPid);
   474	  if (liveness === 'unknown-eperm') {
   475	    return { allowed: false, reason: 'owner-liveness-unknown-eperm' };
   476	  }
   477	  if (liveness === 'dead') {
   478	    return { allowed: true, reason: 'owner-already-dead' };
   479	  }
   480	
   481	  // Guard against PID reuse: if the recorded lease carried an executablePath and
   482	  // the live pid's executable basename provably differs, the OS recycled the pid
   483	  // to an unrelated process. Treat it as already-dead rather than SIGKILLing an
   484	  // innocent process. An indeterminate read (null) does not skip the reap.
   485	  if (typeof expectedExecutablePath === 'string' && expectedExecutablePath.length > 0) {
   486	    const expectedBasename = path.basename(expectedExecutablePath);
   487	    const actualBasename = readProcessExecutableBasename(ownerPid);
   488	    if (actualBasename !== null && actualBasename !== expectedBasename) {
   489	      log(`skill-advisor reap skipped; pid ${ownerPid} executable '${actualBasename}' != recorded '${expectedBasename}' (pid reused)`);
   490	      return { allowed: true, reason: 'owner-pid-reused' };
   491	    }
   492	  }
   493	
   494	  log(`confirmed-dead socket; reaping recorded skill-advisor daemon pid ${ownerPid} before respawn`);
   495	  try {
   496	    process.kill(ownerPid, 'SIGTERM');
   497	  } catch (error) {
   498	    if (error.code !== 'ESRCH') throw error;
   499	  }
   500	  const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);
   501	  if (!exitedAfterTerm) {
