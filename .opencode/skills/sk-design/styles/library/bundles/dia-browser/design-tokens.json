  "font": {
    "exposure-variable": {
      "$value": "Exposure Variable",
      "$type": "fontFamily",
      "$description": "Display headlines — the 112px whisper-weight serif that anchors hero and section titles. Its 0.85 line-height vertically compresses letters, making headlines feel carved and monumental rather than airy. Signature choice: anti-convention weight (300, not 700) and negative letter-spacing (-0.03em) create authority through restraint. Substitute: Playfair Display or DM Serif Display at weight 400 with tight tracking."
    },
    "exposure-var": {
      "$value": "Exposure VAR",
      "$type": "fontFamily",
      "$description": "Section headings and large nav — the bold companion to Exposure Variable. Used for 'Dia reads between the tabs' and feature titles. Tighter tracking at -0.05em at 48px gives headline density. Substitute: Inter Tight or a condensed grotesque."
    },
    "abc-oracle": {
      "$value": "ABC Oracle",
      "$type": "fontFamily",
      "$description": "Body text, UI labels, subheadings, and large feature headlines (54px at weight 300). The workhorse font — its humanist sans quality keeps long-form copy legible at generous line-heights (2.19 for body). Weight 500 used sparingly for emphasis. The 54px weight 300 headline is the secondary display voice, lighter than Exposure VAR but in the same serif-adjacent register. Substitute: Söhne or Inter at matching weights."
    },
    "abc-oracle-triple": {
      "$value": "ABC Oracle Triple",
      "$type": "fontFamily",
      "$description": "Button text, inline labels, UI microcopy — a narrower variant of Oracle designed for button and tag contexts. The wide line-height (2.19) suggests single-line button use with internal padding breathing. Substitute: Inter at 16px weight 400."
    },
    "abc-favorit-mono": {
      "$value": "ABC Favorit Mono",
      "$type": "fontFamily",
      "$description": "Eyebrow labels, step numbers (01, 02, 03), navigation metadata — all-caps at 13px with 0.1em tracking creates the editorial chapter-marker effect. The mono face contrasts with Oracle's humanist sans, creating typographic tension."
    }
  },
