{"type":"tool_use","timestamp":1781761692932,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_tdW0Xy94KzRppDn7jdLkogoy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","offset":200,"limit":430},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts</path>\n<type>file</type>\n<content>\n200:       'importanceWeight must be a number between 0 and 1',\n201:       { param: 'importanceWeight', value: importanceWeight }\n202:     );\n203:   }\n204: \n205:   if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n206:     throw new MemoryError(\n207:       ErrorCodes.INVALID_PARAMETER,\n208:       `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n209:       { param: 'importanceTier', value: importanceTier }\n210:     );\n211:   }\n212: \n213:   const existing = vectorIndex.getMemory(id);\n214:   if (!existing) {\n215:     throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n216:   }\n217: \n218:   const database = vectorIndex.getDb();\n219:   const priorSnapshot = getMemoryHashSnapshot(database, id);\n220: \n221:   const guard = buildGuardedUpdateParams({ ...args, title, triggerPhrases }, existing as Record<string, unknown>);\n222:   const updateParams = guard.updateParams;\n223:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n224: \n225:   if (database && isMemoryIdempotencyEnabled()) {\n226:     try {\n227:       const contentHash = typeof existing.content_hash === 'string' ? existing.content_hash : null;\n228:       const logicalMutation = {\n229:         id,\n230:         title: updateParams.title ?? null,\n231:         triggerPhrases: updateParams.triggerPhrases ?? null,\n232:         importanceWeight: updateParams.importanceWeight ?? null,\n233:         importanceTier: updateParams.importanceTier ?? null,\n234:         contentHash,\n235:       };\n236:       const lookup = lookupIdempotencyReceipt(database, {\n237:         operation: 'memory_update',\n238:         contentHash,\n239:         requestFingerprint: {\n240:           id,\n241:           contentHash,\n242:           logicalMutation,\n243:         },\n244:         // The compared payload is a STRUCTURAL COPY of the fingerprint above, so\n245:         // payloadHash always equals requestFingerprintHash and the receiptKey is\n246:         // derived from it. Consequence: distinct logical updates always produce\n247:         // distinct keys, so the same-key/different-payload 'conflict' status can\n248:         // never fire from this caller; the conflict branch below is fail-safe\n249:         // defense-in-depth, not active protection. To make conflicts detectable\n250:         // the payload would have to carry MORE than the key material (e.g.\n251:         // execution-mode flags like allowPartialUpdate); it deliberately does\n252:         // not, so a benign flag flip cannot become a false hard conflict.\n253:         payload: {\n254:           id,\n255:           contentHash,\n256:           logicalMutation,\n257:         },\n258:       });\n259:       idempotencyKey = lookup.key;\n260:       if (lookup.status === 'replay') {\n261:         // A receipt is a replay cache, not proof the cached response still\n262:         // describes the live row. Re-read this id's current content_hash and\n263:         // honor the replay ONLY when it still matches the receipt's content_hash\n264:         // AND the cached response still reports this same id; an A->B->A content\n265:         // revert leaves the receipt for A intact while the row moved on, and a\n266:         // delete-then-recreate can leave the cached response naming a stale id,\n267:         // so replaying it would diverge from the row.\n268:         const liveRow = database\n269:           .prepare('SELECT content_hash FROM memory_index WHERE id = ?')\n270:           .get(id) as { content_hash: string | null } | undefined;\n271:         const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n272:         if (\n273:           liveRow\n274:           && liveRow.content_hash === lookup.key.contentHash\n275:           && (replayMemoryId == null || replayMemoryId === id)\n276:         ) {\n277:           return lookup.response;\n278:         }\n279:         // Stale receipt for this attempt: drop the cache entry so the live\n280:         // update stores its current response (the post-write store uses\n281:         // ON CONFLICT DO NOTHING and would otherwise lose to and re-serve the\n282:         // stale receipt), then fall through to the normal update path.\n283:         deleteIdempotencyReceiptByKey(database, lookup.key);\n284:       } else if (lookup.status === 'conflict') {\n285:         // Unreachable from this caller: payload is a structural copy of\n286:         // requestFingerprint (above), so a key match implies a payload match and\n287:         // lookup never returns 'conflict'. Kept as fail-safe defense-in-depth in\n288:         // case the key material and payload ever diverge.\n289:         return createMCPErrorResponse({\n290:           tool: 'memory_update',\n291:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n292:           code: 'idempotency_key_conflict',\n293:           details: { requestId, receiptKey: lookup.key.receiptKey, id },\n294:           recovery: {\n295:             hint: 'Retry the original byte-identical request or submit a fresh logical update.',\n296:             severity: 'warning',\n297:           },\n298:         });\n299:       }\n300:     } catch (error: unknown) {\n301:       console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n302:       idempotencyKey = null;\n303:     }\n304:   }\n305: \n306:   let embeddingRegenerated = false;\n307:   let embeddingMarkedForReindex = false;\n308:   let embeddingStatusNeedsPendingWrite = false;\n309:   let mutationLedgerWarning: string | null = null;\n310: \n311:   if (updateParams.title !== undefined && updateParams.title !== existing.title) {\n312:     console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n313:     let newEmbedding: Float32Array | null = null;\n314: \n315:     try {\n316:       // Embed title + content_text, not title alone.\n317:       // This produces better semantic embeddings that capture the full memory context.\n318:       const contentText = existing.content_text || '';\n319:       const embeddingInput = contentText ? `${updateParams.title}\\n\\n${contentText}` : updateParams.title;\n320:       newEmbedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n321:     } catch (err: unknown) {\n322:       const message = toErrorMessage(err);\n323:       if (allowPartialUpdate) {\n324:         console.warn(`[memory-update] Embedding regeneration failed, marking for re-index [requestId=${requestId}]: ${message}`);\n325:         embeddingStatusNeedsPendingWrite = true;\n326:         embeddingMarkedForReindex = true;\n327:       } else {\n328:         console.error(`[memory-update] Embedding regeneration failed, rolling back update [requestId=${requestId}]: ${message}`);\n329:         throw new MemoryError(\n330:           ErrorCodes.EMBEDDING_FAILED,\n331:           'Embedding regeneration failed, update rolled back. No changes were made.',\n332:           { originalError: message, memoryId: id }\n333:         );\n334:       }\n335:     }\n336: \n337:     if (newEmbedding) {\n338:       updateParams.embedding = newEmbedding;\n339:       embeddingRegenerated = true;\n340:     } else if (!embeddingMarkedForReindex) {\n341:       if (allowPartialUpdate) {\n342:         console.warn('[memory-update] Embedding returned null, marking for re-index');\n343:         embeddingStatusNeedsPendingWrite = true;\n344:         embeddingMarkedForReindex = true;\n345:       } else {\n346:         throw new MemoryError(\n347:           ErrorCodes.EMBEDDING_FAILED,\n348:           'Failed to regenerate embedding (null result), update rolled back. No changes were made.',\n349:           { memoryId: id }\n350:         );\n351:       }\n352:     }\n353:   }\n354: \n355:   // transaction wrapper — wraps all synchronous mutation steps (DB update,\n356:   // Cache invalidation, BM25 re-index, ledger append) in a single transaction for atomicity.\n357:   // Embedding generation (async) runs before this block; its result feeds into updateParams.\n358:   const fields = guard.persistedFields;\n359: \n360:   if (database) {\n361:     runInTransaction(database, () => {\n362:       if (embeddingStatusNeedsPendingWrite) {\n363:         vectorIndex.updateEmbeddingStatus(id, 'pending');\n364:       }\n365: \n366:       if (fields.length > 0 || updateParams.embedding !== undefined) {\n367:         vectorIndex.updateMemory(updateParams);\n368:       }\n369:       persistSourceKind(database, id, guard.storedSourceKind);\n370:       persistProvenanceMetadata(database, id, getInternalProvenanceContext(args));\n371: \n372:       if (updateParams.importanceTier !== undefined) {\n373:         const updated = vectorIndex.getMemory(id) as (Record<string, unknown> | null);\n374:         const previousTier = typeof existing.importance_tier === 'string'\n375:           ? existing.importance_tier\n376:           : undefined;\n377:         const nextTier = typeof updated?.importance_tier === 'string'\n378:           ? updated.importance_tier\n379:           : (previousTier ?? updateParams.importanceTier);\n380:         const guardPathCandidate = [\n381:           updated?.canonical_file_path,\n382:           updated?.file_path,\n383:           existing.canonical_file_path,\n384:           existing.file_path,\n385:         ].find((value) => typeof value === 'string' && value.length > 0);\n386:         const guardPath = typeof guardPathCandidate === 'string' ? guardPathCandidate : null;\n387: \n388:         if (\n389:           guardPath\n390:           && !isConstitutionalPath(guardPath)\n391:           && previousTier === 'constitutional'\n392:           && nextTier !== 'constitutional'\n393:         ) {\n394:           try {\n395:             const specFolder = typeof updated?.spec_folder === 'string'\n396:               ? updated.spec_folder\n397:               : (typeof existing.spec_folder === 'string' ? existing.spec_folder : null);\n398:             const anchorIdCandidate = typeof updated?.anchor_id === 'string'\n399:               ? updated.anchor_id\n400:               : (typeof existing.anchor_id === 'string' ? existing.anchor_id : null);\n401:             const anchorId = typeof anchorIdCandidate === 'string' ? anchorIdCandidate : null;\n402:             const updatedFilePath = typeof updated?.file_path === 'string'\n403:               ? updated.file_path\n404:               : (typeof existing.file_path === 'string' ? existing.file_path : null);\n405:             const updatedCanonicalFilePath = typeof updated?.canonical_file_path === 'string'\n406:               ? updated.canonical_file_path\n407:               : (typeof existing.canonical_file_path === 'string' ? existing.canonical_file_path : null);\n408:             recordTierDowngradeAudit(database, {\n409:               memoryId: id,\n410:               logicalKey: buildGovernanceLogicalKey(specFolder, guardPath, anchorId),\n411:               requestedTier: updateParams.importanceTier,\n412:               previousTier,\n413:               nextTier,\n414:               source: 'memory_update',\n415:               filePath: updatedFilePath,\n416:               canonicalFilePath: updatedCanonicalFilePath,\n417:             });\n418:           } catch (error: unknown) {\n419:             console.warn(\n420:               `[memory-crud-update] governance_audit insert failed for memory ${id}: ${toErrorMessage(error)}`,\n421:             );\n422:           }\n423:         }\n424:       }\n425: \n426:       // BM25 index stores title + trigger phrases; must re-index when either changes\n427:       // so keyword search reflects the updated content.\n428:       // BM25 re-index failure now rolls back the transaction when the index is operational.\n429:       // Infrastructure failures (BM25 not available, DB missing prepare) are non-fatal warnings.\n430:       if ((updateParams.title !== undefined || updateParams.triggerPhrases !== undefined) && bm25Index.isBm25Enabled()) {\n431:         try {\n432:           const bm25Idx = bm25Index.getIndex();\n433:           const row = database.prepare(\n434:             'SELECT title, content_text, trigger_phrases, file_path FROM memory_index WHERE id = ?'\n435:           ).get(id) as { title: string | null; content_text: string | null; trigger_phrases: string | null; file_path: string | null } | undefined;\n436:           if (row) {\n437:             const text = bm25Index.buildBm25DocumentText(row);\n438:             if (text.trim()) {\n439:               bm25Idx.addDocument(String(id), text);\n440:             }\n441:           }\n442:         } catch (e: unknown) {\n443:           const bm25ErrMsg = e instanceof Error ? e.message : String(e);\n444:           // Distinguish infrastructure failures from data failures.\n445:           // Infrastructure failures mean the BM25 subsystem is unavailable or torn down —\n446:           // These are non-fatal warnings. Data failures mean the index IS operational but rejected\n447:           // The input — those must re-throw to roll back the transaction.\n448:           const isBm25InfraFailure = (msg: string): boolean =>\n449:             msg.includes('not a function') ||\n450:             msg.includes('not initialized') ||\n451:             msg.includes('Cannot read properties') ||\n452:             msg.includes('is not defined') ||\n453:             msg.includes('database is closed') ||\n454:             msg.includes('no such table');\n455:           if (isBm25InfraFailure(bm25ErrMsg)) {\n456:             console.warn(`[memory-crud-update] BM25 infrastructure unavailable, skipping re-index [requestId=${requestId}]: ${bm25ErrMsg}`);\n457:           } else {\n458:             console.error(`[memory-crud-update] BM25 re-index failed, rolling back update [requestId=${requestId}]: ${bm25ErrMsg}`);\n459:             throw new Error(`BM25 re-index failed: ${bm25ErrMsg}`);\n460:           }\n461:         }\n462:       }\n463: \n464:       // Record UPDATE history after successful mutation\n465:       try {\n466:         recordHistory(\n467:           id, 'UPDATE',\n468:           existing.title ?? null,\n469:           updateParams.title ?? existing.title ?? null,\n470:           'mcp:memory_update'\n471:         );\n472:       } catch (_histErr: unknown) {\n473:         // History recording is best-effort\n474:       }\n475: \n476:       const ledgerRecorded = appendMutationLedgerSafe(database, {\n477:         mutationType: 'update',\n478:         reason: 'memory_update: metadata update',\n479:         priorHash: priorSnapshot?.content_hash ?? (existing.content_hash as string | null) ?? null,\n480:         newHash: mutationLedger.computeHash(JSON.stringify({\n481:           id,\n482:           title: updateParams.title ?? existing.title ?? null,\n483:           triggerPhrases: updateParams.triggerPhrases ?? null,\n484:           importanceWeight: updateParams.importanceWeight ?? null,\n485:           importanceTier: updateParams.importanceTier ?? null,\n486:         })),\n487:         linkedMemoryIds: [id],\n488:         decisionMeta: {\n489:           tool: 'memory_update',\n490:           fields,\n491:           requestedFields: guard.requestedFields,\n492:           skippedFields: guard.skippedFields,\n493:           sourceKind: guard.sourceKind,\n494:           storedSourceKind: guard.storedSourceKind,\n495:           embeddingRegenerated,\n496:           embeddingMarkedForReindex,\n497:           allowPartialUpdate,\n498:         },\n499:         actor: 'mcp:memory_update',\n500:       });\n501:       if (!ledgerRecorded) {\n502:         mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n503:       }\n504:     });\n505:   } else {\n506:     // No database handle means we cannot guarantee transactional\n507:     // Consistency. Abort early rather than risk partial state.\n508:     console.warn('[memory-crud-update] No database handle, aborting update to prevent partial state');\n509:     return createMCPErrorResponse({\n510:       tool: 'memory_update',\n511:       error: `Memory ${id} update aborted: database unavailable`,\n512:       code: 'E_DB_UNAVAILABLE',\n513:       details: { updated: null, fields, skippedFields: guard.skippedFields },\n514:       recovery: {\n515:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n516:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n517:         severity: 'error',\n518:       },\n519:     });\n520:   }\n521: \n522:   let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n523:   try {\n524:     postMutationHooks = runPostMutationHooks('update', {\n525:       database,\n526:       memoryId: id,\n527:       sourceKind: guard.sourceKind,\n528:       actor: 'mcp:memory_update',\n529:       auditReason: `memory_update:${id}:${fields.slice().sort().join(',') || 'source_kind'}`,\n530:     });\n531:   } catch (hookError: unknown) {\n532:     const msg = hookError instanceof Error ? hookError.message : String(hookError);\n533:     postMutationHooks = {\n534:       latencyMs: 0, triggerCacheCleared: false,\n535:       constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n536:       graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n537:       errors: [msg],\n538:     };\n539:   }\n540:   const postMutationFeedback = buildMutationHookFeedback('update', postMutationHooks);\n541: \n542:   const summary = embeddingMarkedForReindex\n543:     ? `Memory ${id} updated (embedding pending re-index)`\n544:     : `Memory ${id} updated successfully`;\n545: \n546:   const hints: string[] = [];\n547:   if (embeddingMarkedForReindex) {\n548:     hints.push('Run memory_index_scan() to regenerate embeddings');\n549:   }\n550:   if (embeddingRegenerated) {\n551:     hints.push('Embedding regenerated - search results may differ');\n552:   }\n553:   if (mutationLedgerWarning) {\n554:     hints.push(mutationLedgerWarning);\n555:   }\n556:   if (guard.hint) {\n557:     hints.push(guard.hint);\n558:   }\n559:   hints.push(...postMutationFeedback.hints);\n560: \n561:   const data: Record<string, unknown> = {\n562:     updated: id,\n563:     fields,\n564:     skippedFields: guard.skippedFields,\n565:     provenance: {\n566:       sourceKind: guard.sourceKind,\n567:       storedSourceKind: guard.storedSourceKind,\n568:     },\n569:     embeddingRegenerated,\n570:     postMutationHooks: postMutationFeedback.data,\n571:   };\n572: \n573:   if (embeddingMarkedForReindex) {\n574:     data.warning = 'Embedding regeneration failed, memory marked for re-indexing';\n575:     data.embeddingStatus = 'pending';\n576:   }\n577:   if (mutationLedgerWarning) {\n578:     data.mutationLedgerWarning = mutationLedgerWarning;\n579:   }\n580: \n581:   const response = createMCPSuccessResponse({\n582:     tool: 'memory_update',\n583:     summary,\n584:     data,\n585:     hints,\n586:   });\n587:   if (database && idempotencyKey) {\n588:     try {\n589:       const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n590:       if (!won) {\n591:         // Same lost-store semantics as memory_save: a same-payload loser\n592:         // replays the canonical winner; a different-payload loser already\n593:         // mutated, so it returns its own response with the conflict made\n594:         // visible rather than silently diverging from the receipt.\n595:         const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n596:         if (winner.status === 'replay') {\n597:           return winner.response;\n598:         }\n599:         if (winner.status === 'conflict') {\n600:           return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n601:         }\n602:       }\n603:     } catch (error: unknown) {\n604:       console.warn(`[memory-crud-update] idempotency receipt store failed; continuing without replay receipt: ${toErrorMessage(error)}`);\n605:     }\n606:   }\n607:   return response;\n608: }\n609: \n610: /* ───────────────────────────────────────────────────────────────\n611:    EXPORTS\n612: ──────────────────────────────────────────────────────────────── */\n613: \n614: export { handleMemoryUpdate };\n\n(End of file - total 614 lines)\n</content>","metadata":{"preview":"      'importanceWeight must be a number between 0 and 1',\n      { param: 'importanceWeight', value: importanceWeight }\n    );\n  }\n\n  if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n    throw new MemoryError(\n      ErrorCodes.INVALID_PARAMETER,\n      `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n      { param: 'importanceTier', value: importanceTier }\n    );\n  }\n\n  const existing = vectorIndex.getMemory(id);\n  if (!existing) {\n    throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n  }\n\n  const database = vectorIndex.getDb();\n  const priorSnapshot = getMemoryHashSnapshot(database, id);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","text":"      'importanceWeight must be a number between 0 and 1',\n      { param: 'importanceWeight', value: importanceWeight }\n    );\n  }\n\n  if (importanceTier !== undefined && !isValidTier(importanceTier)) {\n    throw new MemoryError(\n      ErrorCodes.INVALID_PARAMETER,\n      `Invalid importance tier: ${importanceTier}. Valid tiers: ${VALID_TIERS.join(', ')}`,\n      { param: 'importanceTier', value: importanceTier }\n    );\n  }\n\n  const existing = vectorIndex.getMemory(id);\n  if (!existing) {\n    throw new MemoryError(ErrorCodes.FILE_NOT_FOUND, `Memory not found: ${id}`, { id });\n  }\n\n  const database = vectorIndex.getDb();\n  const priorSnapshot = getMemoryHashSnapshot(database, id);\n\n  const guard = buildGuardedUpdateParams({ ...args, title, triggerPhrases }, existing as Record<string, unknown>);\n  const updateParams = guard.updateParams;\n  let idempotencyKey: IdempotencyReceiptKey | null = null;\n\n  if (database && isMemoryIdempotencyEnabled()) {\n    try {\n      const contentHash = typeof existing.content_hash === 'string' ? existing.content_hash : null;\n      const logicalMutation = {\n        id,\n        title: updateParams.title ?? null,\n        triggerPhrases: updateParams.triggerPhrases ?? null,\n        importanceWeight: updateParams.importanceWeight ?? null,\n        importanceTier: updateParams.importanceTier ?? null,\n        contentHash,\n      };\n      const lookup = lookupIdempotencyReceipt(database, {\n        operation: 'memory_update',\n        contentHash,\n        requestFingerprint: {\n          id,\n          contentHash,\n          logicalMutation,\n        },\n        // The compared payload is a STRUCTURAL COPY of the fingerprint above, so\n        // payloadHash always equals requestFingerprintHash and the receiptKey is\n        // derived from it. Consequence: distinct logical updates always produce\n        // distinct keys, so the same-key/different-payload 'conflict' status can\n        // never fire from this caller; the conflict branch below is fail-safe\n        // defense-in-depth, not active protection. To make conflicts detectable\n        // the payload would have to carry MORE than the key material (e.g.\n        // execution-mode flags like allowPartialUpdate); it deliberately does\n        // not, so a benign flag flip cannot become a false hard conflict.\n        payload: {\n          id,\n          contentHash,\n          logicalMutation,\n        },\n      });\n      idempotencyKey = lookup.key;\n      if (lookup.status === 'replay') {\n        // A receipt is a replay cache, not proof the cached response still\n        // describes the live row. Re-read this id's current content_hash and\n        // honor the replay ONLY when it still matches the receipt's content_hash\n        // AND the cached response still reports this same id; an A->B->A content\n        // revert leaves the receipt for A intact while the row moved on, and a\n        // delete-then-recreate can leave the cached response naming a stale id,\n        // so replaying it would diverge from the row.\n        const liveRow = database\n          .prepare('SELECT content_hash FROM memory_index WHERE id = ?')\n          .get(id) as { content_hash: string | null } | undefined;\n        const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n        if (\n          liveRow\n          && liveRow.content_hash === lookup.key.contentHash\n          && (replayMemoryId == null || replayMemoryId === id)\n        ) {\n          return lookup.response;\n        }\n        // Stale receipt for this attempt: drop the cache entry so the live\n        // update stores its current response (the post-write store uses\n        // ON CONFLICT DO NOTHING and would otherwise lose to and re-serve the\n        // stale receipt), then fall through to the normal update path.\n        deleteIdempotencyReceiptByKey(database, lookup.key);\n      } else if (lookup.status === 'conflict') {\n        // Unreachable from this caller: payload is a structural copy of\n        // requestFingerprint (above), so a key match implies a payload match and\n        // lookup never returns 'conflict'. Kept as fail-safe defense-in-depth in\n        // case the key material and payload ever diverge.\n        return createMCPErrorResponse({\n          tool: 'memory_update',\n          error: 'Idempotency key conflict: same server-derived key with changed payload',\n          code: 'idempotency_key_conflict',\n          details: { requestId, receiptKey: lookup.key.receiptKey, id },\n          recovery: {\n            hint: 'Retry the original byte-identical request or submit a fresh logical update.',\n            severity: 'warning',\n          },\n        });\n      }\n    } catch (error: unknown) {\n      console.warn(`[memory-crud-update] idempotency receipt lookup skipped: ${toErrorMessage(error)}`);\n      idempotencyKey = null;\n    }\n  }\n\n  let embeddingRegenerated = false;\n  let embeddingMarkedForReindex = false;\n  let embeddingStatusNeedsPendingWrite = false;\n  let mutationLedgerWarning: string | null = null;\n\n  if (updateParams.title !== undefined && updateParams.title !== existing.title) {\n    console.error(`[memory-update] Title changed, regenerating embedding for memory ${id} [requestId=${requestId}]`);\n    let newEmbedding: Float32Array | null = null;\n\n    try {\n      // Embed title + content_text, not title alone.\n      // This produces better semantic embeddings that capture the full memory context.\n      const contentText = existing.content_text || '';\n      const embeddingInput = contentText ? `${updateParams.title}\\n\\n${contentText}` : updateParams.title;\n      newEmbedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      if (allowPartialUpdate) {\n        console.warn(`[memory-update] Embedding regeneration failed, marking for re-index [requestId=${requestId}]: ${message}`);\n        embeddingStatusNeedsPendingWrite = true;\n        embeddingMarkedForReindex = true;\n      } else {\n        console.error(`[memory-update] Embedding regeneration failed, rolling back update [requestId=${requestId}]: ${message}`);\n        throw new MemoryError(\n          ErrorCodes.EMBEDDING_FAILED,\n          'Embedding regeneration failed, update rolled back. No changes were made.',\n          { originalError: message, memoryId: id }\n        );\n      }\n    }\n\n    if (newEmbedding) {\n      updateParams.embedding = newEmbedding;\n      embeddingRegenerated = true;\n    } else if (!embeddingMarkedForReindex) {\n      if (allowPartialUpdate) {\n        console.warn('[memory-update] Embedding returned null, marking for re-index');\n        embeddingStatusNeedsPendingWrite = true;\n        embeddingMarkedForReindex = true;\n      } else {\n        throw new MemoryError(\n          ErrorCodes.EMBEDDING_FAILED,\n          'Failed to regenerate embedding (null result), update rolled back. No changes were made.',\n          { memoryId: id }\n        );\n      }\n    }\n  }\n\n  // transaction wrapper — wraps all synchronous mutation steps (DB update,\n  // Cache invalidation, BM25 re-index, ledger append) in a single transaction for atomicity.\n  // Embedding generation (async) runs before this block; its result feeds into updateParams.\n  const fields = guard.persistedFields;\n\n  if (database) {\n    runInTransaction(database, () => {\n      if (embeddingStatusNeedsPendingWrite) {\n        vectorIndex.updateEmbeddingStatus(id, 'pending');\n      }\n\n      if (fields.length > 0 || updateParams.embedding !== undefined) {\n        vectorIndex.updateMemory(updateParams);\n      }\n      persistSourceKind(database, id, guard.storedSourceKind);\n      persistProvenanceMetadata(database, id, getInternalProvenanceContext(args));\n\n      if (updateParams.importanceTier !== undefined) {\n        const updated = vectorIndex.getMemory(id) as (Record<string, unknown> | null);\n        const previousTier = typeof existing.importance_tier === 'string'\n          ? existing.importance_tier\n          : undefined;\n        const nextTier = typeof updated?.importance_tier === 'string'\n          ? updated.importance_tier\n          : (previousTier ?? updateParams.importanceTier);\n        const guardPathCandidate = [\n          updated?.canonical_file_path,\n          updated?.file_path,\n          existing.canonical_file_path,\n          existing.file_path,\n        ].find((value) => typeof value === 'string' && value.length > 0);\n        const guardPath = typeof guardPathCandidate === 'string' ? guardPathCandidate : null;\n\n        if (\n          guardPath\n          && !isConstitutionalPath(guardPath)\n          && previousTier === 'constitutional'\n          && nextTier !== 'constitutional'\n        ) {\n          try {\n            const specFolder = typeof updated?.spec_folder === 'string'\n              ? updated.spec_folder\n              : (typeof existing.spec_folder === 'string' ? existing.spec_folder : null);\n            const anchorIdCandidate = typeof updated?.anchor_id === 'string'\n              ? updated.anchor_id\n              : (typeof existing.anchor_id === 'string' ? existing.anchor_id : null);\n            const anchorId = typeof anchorIdCandidate === 'string' ? anchorIdCandidate : null;\n            const updatedFilePath = typeof updated?.file_path === 'string'\n              ? updated.file_path\n              : (typeof existing.file_path === 'string' ? existing.file_path : null);\n            const updatedCanonicalFilePath = typeof updated?.canonical_file_path === 'string'\n              ? updated.canonical_file_path\n              : (typeof existing.canonical_file_path === 'string' ? existing.canonical_file_path : null);\n            recordTierDowngradeAudit(database, {\n              memoryId: id,\n              logicalKey: buildGovernanceLogicalKey(specFolder, guardPath, anchorId),\n              requestedTier: updateParams.importanceTier,\n              previousTier,\n              nextTier,\n              source: 'memory_update',\n              filePath: updatedFilePath,\n              canonicalFilePath: updatedCanonicalFilePath,\n            });\n          } catch (error: unknown) {\n            console.warn(\n              `[memory-crud-update] governance_audit insert failed for memory ${id}: ${toErrorMessage(error)}`,\n            );\n          }\n        }\n      }\n\n      // BM25 index stores title + trigger phrases; must re-index when either changes\n      // so keyword search reflects the updated content.\n      // BM25 re-index failure now rolls back the transaction when the index is operational.\n      // Infrastructure failures (BM25 not available, DB missing prepare) are non-fatal warnings.\n      if ((updateParams.title !== undefined || updateParams.triggerPhrases !== undefined) && bm25Index.isBm25Enabled()) {\n        try {\n          const bm25Idx = bm25Index.getIndex();\n          const row = database.prepare(\n            'SELECT title, content_text, trigger_phrases, file_path FROM memory_index WHERE id = ?'\n          ).get(id) as { title: string | null; content_text: string | null; trigger_phrases: string | null; file_path: string | null } | undefined;\n          if (row) {\n            const text = bm25Index.buildBm25DocumentText(row);\n            if (text.trim()) {\n              bm25Idx.addDocument(String(id), text);\n            }\n          }\n        } catch (e: unknown) {\n          const bm25ErrMsg = e instanceof Error ? e.message : String(e);\n          // Distinguish infrastructure failures from data failures.\n          // Infrastructure failures mean the BM25 subsystem is unavailable or torn down —\n          // These are non-fatal warnings. Data failures mean the index IS operational but rejected\n          // The input — those must re-throw to roll back the transaction.\n          const isBm25InfraFailure = (msg: string): boolean =>\n            msg.includes('not a function') ||\n            msg.includes('not initialized') ||\n            msg.includes('Cannot read properties') ||\n            msg.includes('is not defined') ||\n            msg.includes('database is closed') ||\n            msg.includes('no such table');\n          if (isBm25InfraFailure(bm25ErrMsg)) {\n            console.warn(`[memory-crud-update] BM25 infrastructure unavailable, skipping re-index [requestId=${requestId}]: ${bm25ErrMsg}`);\n          } else {\n            console.error(`[memory-crud-update] BM25 re-index failed, rolling back update [requestId=${requestId}]: ${bm25ErrMsg}`);\n            throw new Error(`BM25 re-index failed: ${bm25ErrMsg}`);\n          }\n        }\n      }\n\n      // Record UPDATE history after successful mutation\n      try {\n        recordHistory(\n          id, 'UPDATE',\n          existing.title ?? null,\n          updateParams.title ?? existing.title ?? null,\n          'mcp:memory_update'\n        );\n      } catch (_histErr: unknown) {\n        // History recording is best-effort\n      }\n\n      const ledgerRecorded = appendMutationLedgerSafe(database, {\n        mutationType: 'update',\n        reason: 'memory_update: metadata update',\n        priorHash: priorSnapshot?.content_hash ?? (existing.content_hash as string | null) ?? null,\n        newHash: mutationLedger.computeHash(JSON.stringify({\n          id,\n          title: updateParams.title ?? existing.title ?? null,\n          triggerPhrases: updateParams.triggerPhrases ?? null,\n          importanceWeight: updateParams.importanceWeight ?? null,\n          importanceTier: updateParams.importanceTier ?? null,\n        })),\n        linkedMemoryIds: [id],\n        decisionMeta: {\n          tool: 'memory_update',\n          fields,\n          requestedFields: guard.requestedFields,\n          skippedFields: guard.skippedFields,\n          sourceKind: guard.sourceKind,\n          storedSourceKind: guard.storedSourceKind,\n          embeddingRegenerated,\n          embeddingMarkedForReindex,\n          allowPartialUpdate,\n        },\n        actor: 'mcp:memory_update',\n      });\n      if (!ledgerRecorded) {\n        mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n      }\n    });\n  } else {\n    // No database handle means we cannot guarantee transactional\n    // Consistency. Abort early rather than risk partial state.\n    console.warn('[memory-crud-update] No database handle, aborting update to prevent partial state');\n    return createMCPErrorResponse({\n      tool: 'memory_update',\n      error: `Memory ${id} update aborted: database unavailable`,\n      code: 'E_DB_UNAVAILABLE',\n      details: { updated: null, fields, skippedFields: guard.skippedFields },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n  try {\n    postMutationHooks = runPostMutationHooks('update', {\n      database,\n      memoryId: id,\n      sourceKind: guard.sourceKind,\n      actor: 'mcp:memory_update',\n      auditReason: `memory_update:${id}:${fields.slice().sort().join(',') || 'source_kind'}`,\n    });\n  } catch (hookError: unknown) {\n    const msg = hookError instanceof Error ? hookError.message : String(hookError);\n    postMutationHooks = {\n      latencyMs: 0, triggerCacheCleared: false,\n      constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n      graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n      errors: [msg],\n    };\n  }\n  const postMutationFeedback = buildMutationHookFeedback('update', postMutationHooks);\n\n  const summary = embeddingMarkedForReindex\n    ? `Memory ${id} updated (embedding pending re-index)`\n    : `Memory ${id} updated successfully`;\n\n  const hints: string[] = [];\n  if (embeddingMarkedForReindex) {\n    hints.push('Run memory_index_scan() to regenerate embeddings');\n  }\n  if (embeddingRegenerated) {\n    hints.push('Embedding regenerated - search results may differ');\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n  if (guard.hint) {\n    hints.push(guard.hint);\n  }\n  hints.push(...postMutationFeedback.hints);\n\n  const data: Record<string, unknown> = {\n    updated: id,\n    fields,\n    skippedFields: guard.skippedFields,\n    provenance: {\n      sourceKind: guard.sourceKind,\n      storedSourceKind: guard.storedSourceKind,\n    },\n    embeddingRegenerated,\n    postMutationHooks: postMutationFeedback.data,\n  };\n\n  if (embeddingMarkedForReindex) {\n    data.warning = 'Embedding regeneration failed, memory marked for re-indexing';\n    data.embeddingStatus = 'pending';\n  }\n  if (mutationLedgerWarning) {\n    data.mutationLedgerWarning = mutationLedgerWarning;\n  }\n\n  const response = createMCPSuccessResponse({\n    tool: 'memory_update',\n    summary,\n    data,\n    hints,\n  });\n  if (database && idempotencyKey) {\n    try {\n      const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n      if (!won) {\n        // Same lost-store semantics as memory_save: a same-payload loser\n        // replays the canonical winner; a different-payload loser already\n        // mutated, so it returns its own response with the conflict made\n        // visible rather than silently diverging from the receipt.\n        const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n        if (winner.status === 'replay') {\n          return winner.response;\n        }\n        if (winner.status === 'conflict') {\n          return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n        }\n      }\n    } catch (error: unknown) {\n      console.warn(`[memory-crud-update] idempotency receipt store failed; continuing without replay receipt: ${toErrorMessage(error)}`);\n    }\n  }\n  return response;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryUpdate };","lineStart":200,"lineEnd":614,"totalLines":614,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-update.ts","time":{"start":1781761692921,"end":1781761692929}},"metadata":{"openai":{"itemId":"fc_080cc7e967ed30dd016a33869cc5e081919677e7d2fbb22929"}},"id":"prt_ed945d4f7001xhvf8D0NLh1Fvp","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed945acc9001SMV0LBvG4y1962"}}
{"type":"tool_use","timestamp":1781761692935,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_ak1HpgoGiiuXu94pVfud0QtS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":3360,"limit":460},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n3360:         },\n3361:         templateContract: preparedDryRun.templateContract,\n3362:         sufficiency: preparedDryRun.sufficiencyResult,\n3363:         specDocHealth: preparedDryRun.specDocHealth,\n3364:         rejectionCode: preparedDryRun.sufficiencyResult.pass ? undefined : MEMORY_SUFFICIENCY_REJECTION_CODE,\n3365:         message: dryRunSummary,\n3366:       },\n3367:       hints,\n3368:     });\n3369:   }\n3370: \n3371:   // DryRun must remain non-mutating even when preflight is explicitly skipped.\n3372:   if (dryRun && skipPreflight) {\n3373:     const parsedForDryRun = memoryParser.parseMemoryFile(validatedPath);\n3374:     const preparedDryRun = prepareParsedMemoryForIndexing(parsedForDryRun, database, {\n3375:       emitEvalMetrics: false,\n3376:       qualityLoopMode: 'advisory',\n3377:     });\n3378:     return buildDryRunResponse(preparedDryRun, parsedForDryRun, {\n3379:       skipped: true, errors: [], warnings: [], details: {}, wouldPass: true,\n3380:     });\n3381:   }\n3382: \n3383:   const saveScope: MemoryScopeMatch = {\n3384:     tenantId: governanceDecision.normalized.tenantId,\n3385:     userId: governanceDecision.normalized.userId ?? null,\n3386:     agentId: governanceDecision.normalized.agentId ?? null,\n3387:     sessionId: governanceDecision.normalized.sessionId,\n3388:   };\n3389:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n3390: \n3391:   // PRE-FLIGHT VALIDATION\n3392:   let parsedForPreflight: ReturnType<typeof memoryParser.parseMemoryFile> | null = null;\n3393:   if (!skipPreflight) {\n3394:     parsedForPreflight = memoryParser.parseMemoryFile(validatedPath);\n3395: \n3396:     const preflightResult = preflight.runPreflight(\n3397:       {\n3398:         content: parsedForPreflight.content,\n3399:         file_path: validatedPath,\n3400:         spec_folder: parsedForPreflight.specFolder,\n3401:         database: database,\n3402:         find_similar: findSimilarMemories as Parameters<typeof preflight.runPreflight>[0]['find_similar'],\n3403:         tenantId: saveScope.tenantId ?? undefined,\n3404:         userId: saveScope.userId ?? undefined,\n3405:         agentId: saveScope.agentId ?? undefined,\n3406:       },\n3407:       {\n3408:         dry_run: dryRun,\n3409:         check_anchors: true,\n3410:         check_duplicates: !force,\n3411:         check_similar: false,\n3412:         check_tokens: true,\n3413:         check_size: true,\n3414:         strict_anchors: false,\n3415:       }\n3416:     );\n3417: \n3418:     if (dryRun) {\n3419:       let preparedDryRun: PreparedParsedMemory;\n3420:       try {\n3421:         preparedDryRun = prepareParsedMemoryForIndexing(parsedForPreflight, database, {\n3422:           emitEvalMetrics: false,\n3423:           qualityLoopMode: 'advisory',\n3424:         });\n3425:       } catch (error: unknown) {\n3426:         if (error instanceof VRuleUnavailableError) {\n3427:           return createMCPErrorResponse({\n3428:             tool: 'memory_save',\n3429:             error: error.message,\n3430:             code: 'E_RUNTIME',\n3431:             details: { requestId },\n3432:             recovery: {\n3433:               hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3434:               actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3435:               severity: 'warning',\n3436:             },\n3437:           });\n3438:         }\n3439:         // Classify dry-run preparation failures so even validation-only runs surface the\n3440:         // specific cause instead of the generic E081 catch-all at the dispatcher.\n3441:         const dryRunErrorMessage = error instanceof Error ? error.message : String(error);\n3442:         return createMCPErrorResponse({\n3443:           tool: 'memory_save',\n3444:           error: dryRunErrorMessage,\n3445:           code: classifySaveErrorCode(dryRunErrorMessage),\n3446:           details: { requestId, ...extractSaveErrorDetails(dryRunErrorMessage) },\n3447:           recovery: {\n3448:             hint: 'Inspect the error message for the specific dry-run preparation failure.',\n3449:             actions: ['Resolve the reported cause', 'Retry memory_save'],\n3450:             severity: 'warning',\n3451:           },\n3452:         });\n3453:       }\n3454:       return buildDryRunResponse(preparedDryRun, parsedForPreflight, {\n3455:         skipped: false,\n3456:         errors: preflightResult.errors,\n3457:         warnings: preflightResult.warnings,\n3458:         details: preflightResult.details,\n3459:         wouldPass: preflightResult.dry_run_would_pass ?? preflightResult.pass,\n3460:       });\n3461:     }\n3462: \n3463:     if (!preflightResult.pass) {\n3464:       if (shouldPlanCanonicalSave) {\n3465:         return buildPlannerResponse({\n3466:           planner: {\n3467:             filePath: validatedPath,\n3468:             specFolder: parsedForPreflight.specFolder,\n3469:             title: parsedForPreflight.title ?? path.basename(validatedPath),\n3470:             status: 'blocked',\n3471:             message: 'Planner found blocker(s) during pre-flight validation.',\n3472:             plannerMode: 'plan-only',\n3473:             routeTarget: serializePlannerRouteTarget({\n3474:               routeCategory: routeAs ?? 'drop',\n3475:               targetDocPath: validatedPath,\n3476:               targetAnchorId: targetAnchorId ?? null,\n3477:               mergeMode: mergeModeHint,\n3478:             }),\n3479:             proposedEdits: [],\n3480:             blockers: preflightResult.errors.map((entry: string | { message: string; code?: string }) =>\n3481:               serializePlannerBlocker(buildPlannerBlocker({\n3482:                 code: typeof entry === 'string' ? 'PREFLIGHT_BLOCKER' : (entry.code ?? 'PREFLIGHT_BLOCKER'),\n3483:                 message: typeof entry === 'string' ? entry : entry.message,\n3484:                 routeCategory: routeAs ?? undefined,\n3485:                 targetDocPath: validatedPath,\n3486:                 targetAnchorId: targetAnchorId ?? null,\n3487:               }))\n3488:             ),\n3489:             advisories: preflightResult.warnings.map((entry: string | { message: string }) =>\n3490:               serializePlannerAdvisory(buildPlannerAdvisory({\n3491:                 code: 'PREFLIGHT_WARNING',\n3492:                 message: typeof entry === 'string' ? entry : entry.message,\n3493:                 routeCategory: routeAs ?? undefined,\n3494:                 targetDocPath: validatedPath,\n3495:                 targetAnchorId: targetAnchorId ?? null,\n3496:               }))\n3497:             ),\n3498:             followUpActions: [\n3499:               serializePlannerFollowUpAction({\n3500:                 action: 'apply',\n3501:                 title: 'Retry with full-auto after fixing pre-flight blockers',\n3502:                 description: 'Fix the reported blockers, then request explicit full-auto mode.',\n3503:                 args: {\n3504:                   filePath: validatedPath,\n3505:                   plannerMode: 'full-auto',\n3506:                   ...(routeAs ? { routeAs } : {}),\n3507:                   ...(mergeModeHint ? { mergeModeHint } : {}),\n3508:                   ...(targetAnchorId ? { targetAnchorId } : {}),\n3509:                 },\n3510:               }),\n3511:             ],\n3512:           },\n3513:         });\n3514:       }\n3515: \n3516:       const errorMessages = preflightResult.errors.map((e: string | { message: string }) =>\n3517:         typeof e === 'string' ? e : e.message\n3518:       ).join('; ');\n3519: \n3520:       // Use the actual error code from the\n3521:       // First validation error instead of hardcoding ANCHOR_FORMAT_INVALID.\n3522:       const firstError = preflightResult.errors[0];\n3523:       const errorCode = (typeof firstError === 'object' && firstError?.code)\n3524:         ? firstError.code\n3525:         : preflight.PreflightErrorCodes.ANCHOR_FORMAT_INVALID;\n3526:       throw new preflight.PreflightError(\n3527:         errorCode,\n3528:         `Pre-flight validation failed: ${errorMessages}`,\n3529:         {\n3530:           errors: preflightResult.errors,\n3531:           warnings: preflightResult.warnings,\n3532:           recoverable: true,\n3533:           suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n3534:         }\n3535:       );\n3536:     }\n3537: \n3538:     if (preflightResult.warnings.length > 0) {\n3539:       console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n3540:       preflightResult.warnings.forEach((w: string | { message: string }) => {\n3541:         const msg = typeof w === 'string' ? w : w.message;\n3542:         console.warn(`[preflight]   - ${msg}`);\n3543:       });\n3544:     }\n3545:   }\n3546: \n3547:   if (!shouldPlanCanonicalSave && isMemoryIdempotencyEnabled()) {\n3548:     try {\n3549:       const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);\n3550:       // The compared payload IS the fingerprint object: both lookup inputs\n3551:       // below point at this same idempotencySemantics value, so payloadHash\n3552:       // always equals requestFingerprintHash and the receiptKey is derived from\n3553:       // it. Consequence: distinct logical requests always produce distinct\n3554:       // keys, so the same-key/different-payload 'conflict' status can never fire\n3555:       // from this caller (a force-flip yields a key MISS, not a conflict). The\n3556:       // conflict branch below is fail-safe defense-in-depth, not active\n3557:       // protection. To make conflicts detectable, the payload would have to\n3558:       // carry MORE than the key material (e.g. execution-mode flags); it\n3559:       // deliberately does not, so a benign flag flip cannot become a false\n3560:       // hard conflict.\n3561:       const idempotencySemantics = {\n3562:         filePath: canonicalValidatedPath,\n3563:         contentHash: parsedForIdempotency.contentHash,\n3564:         routeAs: routeAs ?? null,\n3565:         mergeModeHint: mergeModeHint ?? null,\n3566:         targetAnchorId: targetAnchorId ?? null,\n3567:         scope: saveScope,\n3568:         // A force-flipped retry is a DIFFERENT logical request: keeping force in\n3569:         // the key material makes it a distinct key (a clean MISS that re-runs),\n3570:         // never a collision with the non-forced receipt.\n3571:         force: force === true,\n3572:       };\n3573:       const lookup = lookupIdempotencyReceipt(database, {\n3574:         operation: 'memory_save',\n3575:         contentHash: parsedForIdempotency.contentHash,\n3576:         requestFingerprint: idempotencySemantics,\n3577:         payload: idempotencySemantics,\n3578:       });\n3579:       idempotencyKey = lookup.key;\n3580:       if (lookup.status === 'replay') {\n3581:         // A receipt is a replay cache, not proof the cached response still\n3582:         // describes the live state. After an A->B->A revert the receipt for A\n3583:         // is intact but the active row now holds B (or, after deletion, a\n3584:         // superseded row), so replaying A's old response would diverge from\n3585:         // the index. Honor the replay ONLY when the active row for this logical\n3586:         // identity still carries the receipt's content_hash AND is the same row\n3587:         // the cached response reports. Content alone is insufficient: a planner\n3588:         // re-create of identical content (the planner branch skips this whole\n3589:         // block and never refreshes the receipt) produces a NEW id, so a\n3590:         // content-only match would replay a response naming a deleted id and\n3591:         // strand a follow-up update by that id. Mirror the handler's own\n3592:         // active-row identity (findSamePathExistingMemory) and exclude retired\n3593:         // tiers so a deprecated/archived predecessor cannot satisfy the match.\n3594:         const activeRow = database.prepare(`\n3595:           SELECT id, content_hash\n3596:           FROM memory_index\n3597:           WHERE spec_folder = ?\n3598:             AND parent_id IS NULL\n3599:             AND (canonical_file_path = ? OR file_path = ?)\n3600:             AND ${targetAnchorId != null ? 'anchor_id = ?' : 'anchor_id IS NULL'}\n3601:             AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n3602:             AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n3603:             AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n3604:             AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n3605:             AND COALESCE(importance_tier, 'normal') NOT IN ('deprecated', 'archived')\n3606:           ORDER BY id DESC\n3607:           LIMIT 1\n3608:         `).get(\n3609:           parsedForIdempotency.specFolder,\n3610:           canonicalValidatedPath,\n3611:           validatedPath,\n3612:           ...(targetAnchorId != null ? [targetAnchorId] : []),\n3613:           saveScope.tenantId ?? null, saveScope.tenantId ?? null,\n3614:           saveScope.userId ?? null, saveScope.userId ?? null,\n3615:           saveScope.agentId ?? null, saveScope.agentId ?? null,\n3616:           saveScope.sessionId ?? null, saveScope.sessionId ?? null,\n3617:         ) as { id: number; content_hash: string } | undefined;\n3618: \n3619:         const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n3620:         if (\n3621:           activeRow\n3622:           && activeRow.content_hash === lookup.key.contentHash\n3623:           && (replayMemoryId == null || activeRow.id === replayMemoryId)\n3624:         ) {\n3625:           return lookup.response;\n3626:         }\n3627:         // Stale receipt for this attempt: drop the cache entry so the\n3628:         // re-indexed write stores its current response (the post-write store\n3629:         // uses ON CONFLICT DO NOTHING and would otherwise lose to and re-serve\n3630:         // the stale receipt), then fall through to the normal save/reindex path.\n3631:         deleteIdempotencyReceiptByKey(database, lookup.key);\n3632:       } else if (lookup.status === 'conflict') {\n3633:         // Unreachable from this caller: payload === requestFingerprint (above),\n3634:         // so a key match implies a payload match and lookup never returns\n3635:         // 'conflict'. Kept as fail-safe defense-in-depth in case the key\n3636:         // material and payload ever diverge.\n3637:         return createMCPErrorResponse({\n3638:           tool: 'memory_save',\n3639:           error: 'Idempotency key conflict: same server-derived key with changed payload',\n3640:           code: 'idempotency_key_conflict',\n3641:           details: { requestId, receiptKey: lookup.key.receiptKey },\n3642:           recovery: {\n3643:             hint: 'Retry the original byte-identical request or submit a fresh logical write.',\n3644:             severity: 'warning',\n3645:           },\n3646:         });\n3647:       }\n3648:     } catch (error: unknown) {\n3649:       const message = error instanceof Error ? error.message : String(error);\n3650:       console.warn(`[memory-save] idempotency receipt lookup skipped: ${message}`);\n3651:       idempotencyKey = null;\n3652:     }\n3653:   }\n3654: \n3655:   if (shouldPlanCanonicalSave) {\n3656:     const plannerResult = await atomicSaveMemory({\n3657:       file_path: validatedPath,\n3658:       content: fs.readFileSync(validatedPath, 'utf8'),\n3659:       plannerMode,\n3660:       ...(routeAs ? { routeAs } : {}),\n3661:       ...(mergeModeHint ? { mergeModeHint } : {}),\n3662:       ...(targetAnchorId ? { targetAnchorId } : {}),\n3663:     }, { force });\n3664: \n3665:     return buildPlannerResponse({\n3666:       planner: {\n3667:         filePath: validatedPath,\n3668:         specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n3669:         title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n3670:         status: plannerResult.status === 'blocked' ? 'blocked' : 'planned',\n3671:         message: plannerResult.message ?? 'Planner prepared a non-mutating canonical save plan.',\n3672:         plannerMode: 'plan-only',\n3673:         routeTarget: plannerResult.routeTarget ?? serializePlannerRouteTarget({\n3674:           routeCategory: routeAs ?? 'drop',\n3675:           targetDocPath: plannerResult.targetDocPath ?? validatedPath,\n3676:           targetAnchorId: plannerResult.targetAnchorId ?? targetAnchorId ?? null,\n3677:           mergeMode: plannerResult.mergeMode ?? mergeModeHint,\n3678:         }),\n3679:         proposedEdits: plannerResult.proposedEdits ?? [],\n3680:         blockers: plannerResult.blockers ?? [],\n3681:         advisories: plannerResult.advisories ?? [],\n3682:         followUpActions: plannerResult.followUpActions ?? [],\n3683:       },\n3684:     });\n3685:   }\n3686: \n3687:   let result: IndexResult;\n3688:   try {\n3689:     result = await indexMemoryFile(validatedPath, {\n3690:       force,\n3691:       parsedOverride: parsedForPreflight,\n3692:       asyncEmbedding,\n3693:       plannerMode,\n3694:       scope: saveScope,\n3695:       routing: buildRoutedSaveOptions(validatedPath, routeAs, mergeModeHint, targetAnchorId),\n3696:       provenance: (provenanceSource || provenanceActor)\n3697:         ? { provenanceSource, provenanceActor, tool: 'memory_save' }\n3698:         : undefined,\n3699:     });\n3700:   } catch (error: unknown) {\n3701:     if (error instanceof VRuleUnavailableError) {\n3702:       return createMCPErrorResponse({\n3703:         tool: 'memory_save',\n3704:         error: error.message,\n3705:         code: 'E_RUNTIME',\n3706:         details: { requestId },\n3707:         recovery: {\n3708:           hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3709:           actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3710:           severity: 'warning',\n3711:         },\n3712:       });\n3713:     }\n3714:     // Classify deep save/index failures (sqlite busy, embedding, db error, etc.) so the\n3715:     // response code points at the actual failure mode instead of the generic E081 catch-all.\n3716:     const indexErrorMessage = error instanceof Error ? error.message : String(error);\n3717:     return createMCPErrorResponse({\n3718:       tool: 'memory_save',\n3719:       error: indexErrorMessage,\n3720:       code: classifySaveErrorCode(indexErrorMessage),\n3721:       details: { requestId, ...extractSaveErrorDetails(indexErrorMessage) },\n3722:       recovery: {\n3723:         hint: 'Inspect the error message for the specific failure; transient DB/embedding issues are usually retryable.',\n3724:         actions: ['Resolve the reported cause', 'Retry memory_save'],\n3725:         severity: 'warning',\n3726:       },\n3727:     });\n3728:   }\n3729: \n3730:   if (typeof result.id === 'number' && result.id > 0 && result.status !== 'unchanged' && result.status !== 'duplicate') {\n3731:     // Wrap governance metadata in a transaction with rollback on failure.\n3732:     // If governance application fails, delete the orphaned memory row to prevent\n3733:     // persisted rows without tenant/session/retention metadata.\n3734:     const applyGovernanceTx = database.transaction(() => {\n3735:       applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n3736:       recordGovernanceAudit(database, {\n3737:         action: 'memory_save',\n3738:         decision: 'allow',\n3739:         memoryId: result.id,\n3740:         tenantId,\n3741:         userId,\n3742:         agentId,\n3743:         sessionId,\n3744:         reason: 'governed_ingest',\n3745:         metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n3746:       });\n3747:     });\n3748:     try {\n3749:       applyGovernanceTx();\n3750:     } catch (govErr: unknown) {\n3751:       // C2 FIX: Use full delete helper to clean up ALL ancillary records\n3752:       // (vec_memories, BM25 index, causal edges, projections, etc.)\n3753:       // not just memory_index, to prevent orphaned search phantoms.\n3754:       const govErrorMessage = govErr instanceof Error ? govErr.message : String(govErr);\n3755:       console.error('[memory-save] Governance metadata failed, removing orphaned memory:', govErrorMessage);\n3756:       try { delete_memory_from_database(database, result.id); } catch (_: unknown) { /* best-effort cleanup */ }\n3757:       // The orphan rollback above already ran; return a classified error (sqlite-busy / db\n3758:       // failures map to E087/E088) instead of a bare throw the dispatcher would surface as the\n3759:       // generic E081 catch-all.\n3760:       return createMCPErrorResponse({\n3761:         tool: 'memory_save',\n3762:         error: govErrorMessage,\n3763:         code: classifySaveErrorCode(govErrorMessage),\n3764:         details: { requestId, ...extractSaveErrorDetails(govErrorMessage) },\n3765:         recovery: {\n3766:           hint: 'The memory was rolled back after a post-insert metadata write failed; transient DB locks are retryable.',\n3767:           actions: ['Resolve the reported cause', 'Retry memory_save'],\n3768:           severity: 'warning',\n3769:         },\n3770:       });\n3771:     }\n3772:   }\n3773: \n3774:   const response = buildSaveResponse({ result, filePath: file_path, asyncEmbedding, requestId });\n3775:   if (idempotencyKey && shouldStoreMemorySaveReceipt(result, response)) {\n3776:     try {\n3777:       const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n3778:       if (!won) {\n3779:         // A concurrent same-key save already stored the canonical receipt. Replay the\n3780:         // first winner's response so this mutating loser returns the idempotent result\n3781:         // instead of its own separately-created response.\n3782:         const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n3783:         if (winner.status === 'replay') {\n3784:           return winner.response;\n3785:         }\n3786:         if (winner.status === 'conflict') {\n3787:           // Different-payload winner: this loser's mutation landed, so an\n3788:           // error would lie and replaying the winner would answer a\n3789:           // different request — return the loser's response with the\n3790:           // conflict made visible instead of silent.\n3791:           return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n3792:         }\n3793:       }\n3794:     } catch (error: unknown) {\n3795:       const message = error instanceof Error ? error.message : String(error);\n3796:       console.warn(`[memory-save] idempotency receipt store failed; continuing without replay receipt: ${message}`);\n3797:     }\n3798:   }\n3799:   return response;\n3800: }\n3801: \n3802: /* --- 10. ATOMIC MEMORY SAVE --- */\n3803: \n3804: /**\n3805:  * Save memory content to disk with retry + rollback guarded indexing.\n3806:  *\n3807:  * The file write promotes a pending file while holding the per-spec-folder\n3808:  * mutex so concurrent saves cannot overwrite each other between disk\n3809:  * promotion and indexing. If indexing later fails, the original file content\n3810:  * is restored before the error is returned and before the lock is released.\n3811:  */\n3812: async function atomicSaveMemory(params: AtomicSaveParams, options: AtomicSaveOptions = {}): Promise<AtomicSaveResult> {\n3813:   // Scrub once at the entry so every durably persisted artifact (canonical\n3814:   // markdown, continuity merge, pending-file promotion) carries redacted text,\n3815:   // not only the parsed/index copy the parser scrubs. Fail-closed: a scrubber\n3816:   // failure throws and refuses the write rather than persisting raw content.\n3817:   if (typeof params.content === 'string' && params.content.length > 0) {\n3818:     const scrubResult = scrubSecretsDetailed(params.content);\n3819:     if (scrubResult.redactions > 0) {\n\n(Showing lines 3360-3819 of 4082. Use offset=3820 to continue.)\n</content>","metadata":{"preview":"        },\n        templateContract: preparedDryRun.templateContract,\n        sufficiency: preparedDryRun.sufficiencyResult,\n        specDocHealth: preparedDryRun.specDocHealth,\n        rejectionCode: preparedDryRun.sufficiencyResult.pass ? undefined : MEMORY_SUFFICIENCY_REJECTION_CODE,\n        message: dryRunSummary,\n      },\n      hints,\n    });\n  }\n\n  // DryRun must remain non-mutating even when preflight is explicitly skipped.\n  if (dryRun && skipPreflight) {\n    const parsedForDryRun = memoryParser.parseMemoryFile(validatedPath);\n    const preparedDryRun = prepareParsedMemoryForIndexing(parsedForDryRun, database, {\n      emitEvalMetrics: false,\n      qualityLoopMode: 'advisory',\n    });\n    return buildDryRunResponse(preparedDryRun, parsedForDryRun, {\n      skipped: true, errors: [], warnings: [], details: {}, wouldPass: true,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"        },\n        templateContract: preparedDryRun.templateContract,\n        sufficiency: preparedDryRun.sufficiencyResult,\n        specDocHealth: preparedDryRun.specDocHealth,\n        rejectionCode: preparedDryRun.sufficiencyResult.pass ? undefined : MEMORY_SUFFICIENCY_REJECTION_CODE,\n        message: dryRunSummary,\n      },\n      hints,\n    });\n  }\n\n  // DryRun must remain non-mutating even when preflight is explicitly skipped.\n  if (dryRun && skipPreflight) {\n    const parsedForDryRun = memoryParser.parseMemoryFile(validatedPath);\n    const preparedDryRun = prepareParsedMemoryForIndexing(parsedForDryRun, database, {\n      emitEvalMetrics: false,\n      qualityLoopMode: 'advisory',\n    });\n    return buildDryRunResponse(preparedDryRun, parsedForDryRun, {\n      skipped: true, errors: [], warnings: [], details: {}, wouldPass: true,\n    });\n  }\n\n  const saveScope: MemoryScopeMatch = {\n    tenantId: governanceDecision.normalized.tenantId,\n    userId: governanceDecision.normalized.userId ?? null,\n    agentId: governanceDecision.normalized.agentId ?? null,\n    sessionId: governanceDecision.normalized.sessionId,\n  };\n  let idempotencyKey: IdempotencyReceiptKey | null = null;\n\n  // PRE-FLIGHT VALIDATION\n  let parsedForPreflight: ReturnType<typeof memoryParser.parseMemoryFile> | null = null;\n  if (!skipPreflight) {\n    parsedForPreflight = memoryParser.parseMemoryFile(validatedPath);\n\n    const preflightResult = preflight.runPreflight(\n      {\n        content: parsedForPreflight.content,\n        file_path: validatedPath,\n        spec_folder: parsedForPreflight.specFolder,\n        database: database,\n        find_similar: findSimilarMemories as Parameters<typeof preflight.runPreflight>[0]['find_similar'],\n        tenantId: saveScope.tenantId ?? undefined,\n        userId: saveScope.userId ?? undefined,\n        agentId: saveScope.agentId ?? undefined,\n      },\n      {\n        dry_run: dryRun,\n        check_anchors: true,\n        check_duplicates: !force,\n        check_similar: false,\n        check_tokens: true,\n        check_size: true,\n        strict_anchors: false,\n      }\n    );\n\n    if (dryRun) {\n      let preparedDryRun: PreparedParsedMemory;\n      try {\n        preparedDryRun = prepareParsedMemoryForIndexing(parsedForPreflight, database, {\n          emitEvalMetrics: false,\n          qualityLoopMode: 'advisory',\n        });\n      } catch (error: unknown) {\n        if (error instanceof VRuleUnavailableError) {\n          return createMCPErrorResponse({\n            tool: 'memory_save',\n            error: error.message,\n            code: 'E_RUNTIME',\n            details: { requestId },\n            recovery: {\n              hint: 'Build the Spec Kit scripts workspace and retry the save.',\n              actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n              severity: 'warning',\n            },\n          });\n        }\n        // Classify dry-run preparation failures so even validation-only runs surface the\n        // specific cause instead of the generic E081 catch-all at the dispatcher.\n        const dryRunErrorMessage = error instanceof Error ? error.message : String(error);\n        return createMCPErrorResponse({\n          tool: 'memory_save',\n          error: dryRunErrorMessage,\n          code: classifySaveErrorCode(dryRunErrorMessage),\n          details: { requestId, ...extractSaveErrorDetails(dryRunErrorMessage) },\n          recovery: {\n            hint: 'Inspect the error message for the specific dry-run preparation failure.',\n            actions: ['Resolve the reported cause', 'Retry memory_save'],\n            severity: 'warning',\n          },\n        });\n      }\n      return buildDryRunResponse(preparedDryRun, parsedForPreflight, {\n        skipped: false,\n        errors: preflightResult.errors,\n        warnings: preflightResult.warnings,\n        details: preflightResult.details,\n        wouldPass: preflightResult.dry_run_would_pass ?? preflightResult.pass,\n      });\n    }\n\n    if (!preflightResult.pass) {\n      if (shouldPlanCanonicalSave) {\n        return buildPlannerResponse({\n          planner: {\n            filePath: validatedPath,\n            specFolder: parsedForPreflight.specFolder,\n            title: parsedForPreflight.title ?? path.basename(validatedPath),\n            status: 'blocked',\n            message: 'Planner found blocker(s) during pre-flight validation.',\n            plannerMode: 'plan-only',\n            routeTarget: serializePlannerRouteTarget({\n              routeCategory: routeAs ?? 'drop',\n              targetDocPath: validatedPath,\n              targetAnchorId: targetAnchorId ?? null,\n              mergeMode: mergeModeHint,\n            }),\n            proposedEdits: [],\n            blockers: preflightResult.errors.map((entry: string | { message: string; code?: string }) =>\n              serializePlannerBlocker(buildPlannerBlocker({\n                code: typeof entry === 'string' ? 'PREFLIGHT_BLOCKER' : (entry.code ?? 'PREFLIGHT_BLOCKER'),\n                message: typeof entry === 'string' ? entry : entry.message,\n                routeCategory: routeAs ?? undefined,\n                targetDocPath: validatedPath,\n                targetAnchorId: targetAnchorId ?? null,\n              }))\n            ),\n            advisories: preflightResult.warnings.map((entry: string | { message: string }) =>\n              serializePlannerAdvisory(buildPlannerAdvisory({\n                code: 'PREFLIGHT_WARNING',\n                message: typeof entry === 'string' ? entry : entry.message,\n                routeCategory: routeAs ?? undefined,\n                targetDocPath: validatedPath,\n                targetAnchorId: targetAnchorId ?? null,\n              }))\n            ),\n            followUpActions: [\n              serializePlannerFollowUpAction({\n                action: 'apply',\n                title: 'Retry with full-auto after fixing pre-flight blockers',\n                description: 'Fix the reported blockers, then request explicit full-auto mode.',\n                args: {\n                  filePath: validatedPath,\n                  plannerMode: 'full-auto',\n                  ...(routeAs ? { routeAs } : {}),\n                  ...(mergeModeHint ? { mergeModeHint } : {}),\n                  ...(targetAnchorId ? { targetAnchorId } : {}),\n                },\n              }),\n            ],\n          },\n        });\n      }\n\n      const errorMessages = preflightResult.errors.map((e: string | { message: string }) =>\n        typeof e === 'string' ? e : e.message\n      ).join('; ');\n\n      // Use the actual error code from the\n      // First validation error instead of hardcoding ANCHOR_FORMAT_INVALID.\n      const firstError = preflightResult.errors[0];\n      const errorCode = (typeof firstError === 'object' && firstError?.code)\n        ? firstError.code\n        : preflight.PreflightErrorCodes.ANCHOR_FORMAT_INVALID;\n      throw new preflight.PreflightError(\n        errorCode,\n        `Pre-flight validation failed: ${errorMessages}`,\n        {\n          errors: preflightResult.errors,\n          warnings: preflightResult.warnings,\n          recoverable: true,\n          suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n        }\n      );\n    }\n\n    if (preflightResult.warnings.length > 0) {\n      console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n      preflightResult.warnings.forEach((w: string | { message: string }) => {\n        const msg = typeof w === 'string' ? w : w.message;\n        console.warn(`[preflight]   - ${msg}`);\n      });\n    }\n  }\n\n  if (!shouldPlanCanonicalSave && isMemoryIdempotencyEnabled()) {\n    try {\n      const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);\n      // The compared payload IS the fingerprint object: both lookup inputs\n      // below point at this same idempotencySemantics value, so payloadHash\n      // always equals requestFingerprintHash and the receiptKey is derived from\n      // it. Consequence: distinct logical requests always produce distinct\n      // keys, so the same-key/different-payload 'conflict' status can never fire\n      // from this caller (a force-flip yields a key MISS, not a conflict). The\n      // conflict branch below is fail-safe defense-in-depth, not active\n      // protection. To make conflicts detectable, the payload would have to\n      // carry MORE than the key material (e.g. execution-mode flags); it\n      // deliberately does not, so a benign flag flip cannot become a false\n      // hard conflict.\n      const idempotencySemantics = {\n        filePath: canonicalValidatedPath,\n        contentHash: parsedForIdempotency.contentHash,\n        routeAs: routeAs ?? null,\n        mergeModeHint: mergeModeHint ?? null,\n        targetAnchorId: targetAnchorId ?? null,\n        scope: saveScope,\n        // A force-flipped retry is a DIFFERENT logical request: keeping force in\n        // the key material makes it a distinct key (a clean MISS that re-runs),\n        // never a collision with the non-forced receipt.\n        force: force === true,\n      };\n      const lookup = lookupIdempotencyReceipt(database, {\n        operation: 'memory_save',\n        contentHash: parsedForIdempotency.contentHash,\n        requestFingerprint: idempotencySemantics,\n        payload: idempotencySemantics,\n      });\n      idempotencyKey = lookup.key;\n      if (lookup.status === 'replay') {\n        // A receipt is a replay cache, not proof the cached response still\n        // describes the live state. After an A->B->A revert the receipt for A\n        // is intact but the active row now holds B (or, after deletion, a\n        // superseded row), so replaying A's old response would diverge from\n        // the index. Honor the replay ONLY when the active row for this logical\n        // identity still carries the receipt's content_hash AND is the same row\n        // the cached response reports. Content alone is insufficient: a planner\n        // re-create of identical content (the planner branch skips this whole\n        // block and never refreshes the receipt) produces a NEW id, so a\n        // content-only match would replay a response naming a deleted id and\n        // strand a follow-up update by that id. Mirror the handler's own\n        // active-row identity (findSamePathExistingMemory) and exclude retired\n        // tiers so a deprecated/archived predecessor cannot satisfy the match.\n        const activeRow = database.prepare(`\n          SELECT id, content_hash\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND parent_id IS NULL\n            AND (canonical_file_path = ? OR file_path = ?)\n            AND ${targetAnchorId != null ? 'anchor_id = ?' : 'anchor_id IS NULL'}\n            AND ((? IS NULL AND tenant_id IS NULL) OR tenant_id = ?)\n            AND ((? IS NULL AND user_id IS NULL) OR user_id = ?)\n            AND ((? IS NULL AND agent_id IS NULL) OR agent_id = ?)\n            AND ((? IS NULL AND session_id IS NULL) OR session_id = ?)\n            AND COALESCE(importance_tier, 'normal') NOT IN ('deprecated', 'archived')\n          ORDER BY id DESC\n          LIMIT 1\n        `).get(\n          parsedForIdempotency.specFolder,\n          canonicalValidatedPath,\n          validatedPath,\n          ...(targetAnchorId != null ? [targetAnchorId] : []),\n          saveScope.tenantId ?? null, saveScope.tenantId ?? null,\n          saveScope.userId ?? null, saveScope.userId ?? null,\n          saveScope.agentId ?? null, saveScope.agentId ?? null,\n          saveScope.sessionId ?? null, saveScope.sessionId ?? null,\n        ) as { id: number; content_hash: string } | undefined;\n\n        const replayMemoryId = extractMemoryIdFromResponse(lookup.response);\n        if (\n          activeRow\n          && activeRow.content_hash === lookup.key.contentHash\n          && (replayMemoryId == null || activeRow.id === replayMemoryId)\n        ) {\n          return lookup.response;\n        }\n        // Stale receipt for this attempt: drop the cache entry so the\n        // re-indexed write stores its current response (the post-write store\n        // uses ON CONFLICT DO NOTHING and would otherwise lose to and re-serve\n        // the stale receipt), then fall through to the normal save/reindex path.\n        deleteIdempotencyReceiptByKey(database, lookup.key);\n      } else if (lookup.status === 'conflict') {\n        // Unreachable from this caller: payload === requestFingerprint (above),\n        // so a key match implies a payload match and lookup never returns\n        // 'conflict'. Kept as fail-safe defense-in-depth in case the key\n        // material and payload ever diverge.\n        return createMCPErrorResponse({\n          tool: 'memory_save',\n          error: 'Idempotency key conflict: same server-derived key with changed payload',\n          code: 'idempotency_key_conflict',\n          details: { requestId, receiptKey: lookup.key.receiptKey },\n          recovery: {\n            hint: 'Retry the original byte-identical request or submit a fresh logical write.',\n            severity: 'warning',\n          },\n        });\n      }\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(`[memory-save] idempotency receipt lookup skipped: ${message}`);\n      idempotencyKey = null;\n    }\n  }\n\n  if (shouldPlanCanonicalSave) {\n    const plannerResult = await atomicSaveMemory({\n      file_path: validatedPath,\n      content: fs.readFileSync(validatedPath, 'utf8'),\n      plannerMode,\n      ...(routeAs ? { routeAs } : {}),\n      ...(mergeModeHint ? { mergeModeHint } : {}),\n      ...(targetAnchorId ? { targetAnchorId } : {}),\n    }, { force });\n\n    return buildPlannerResponse({\n      planner: {\n        filePath: validatedPath,\n        specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n        title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n        status: plannerResult.status === 'blocked' ? 'blocked' : 'planned',\n        message: plannerResult.message ?? 'Planner prepared a non-mutating canonical save plan.',\n        plannerMode: 'plan-only',\n        routeTarget: plannerResult.routeTarget ?? serializePlannerRouteTarget({\n          routeCategory: routeAs ?? 'drop',\n          targetDocPath: plannerResult.targetDocPath ?? validatedPath,\n          targetAnchorId: plannerResult.targetAnchorId ?? targetAnchorId ?? null,\n          mergeMode: plannerResult.mergeMode ?? mergeModeHint,\n        }),\n        proposedEdits: plannerResult.proposedEdits ?? [],\n        blockers: plannerResult.blockers ?? [],\n        advisories: plannerResult.advisories ?? [],\n        followUpActions: plannerResult.followUpActions ?? [],\n      },\n    });\n  }\n\n  let result: IndexResult;\n  try {\n    result = await indexMemoryFile(validatedPath, {\n      force,\n      parsedOverride: parsedForPreflight,\n      asyncEmbedding,\n      plannerMode,\n      scope: saveScope,\n      routing: buildRoutedSaveOptions(validatedPath, routeAs, mergeModeHint, targetAnchorId),\n      provenance: (provenanceSource || provenanceActor)\n        ? { provenanceSource, provenanceActor, tool: 'memory_save' }\n        : undefined,\n    });\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n    // Classify deep save/index failures (sqlite busy, embedding, db error, etc.) so the\n    // response code points at the actual failure mode instead of the generic E081 catch-all.\n    const indexErrorMessage = error instanceof Error ? error.message : String(error);\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: indexErrorMessage,\n      code: classifySaveErrorCode(indexErrorMessage),\n      details: { requestId, ...extractSaveErrorDetails(indexErrorMessage) },\n      recovery: {\n        hint: 'Inspect the error message for the specific failure; transient DB/embedding issues are usually retryable.',\n        actions: ['Resolve the reported cause', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (typeof result.id === 'number' && result.id > 0 && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    // Wrap governance metadata in a transaction with rollback on failure.\n    // If governance application fails, delete the orphaned memory row to prevent\n    // persisted rows without tenant/session/retention metadata.\n    const applyGovernanceTx = database.transaction(() => {\n      applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n      recordGovernanceAudit(database, {\n        action: 'memory_save',\n        decision: 'allow',\n        memoryId: result.id,\n        tenantId,\n        userId,\n        agentId,\n        sessionId,\n        reason: 'governed_ingest',\n        metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n      });\n    });\n    try {\n      applyGovernanceTx();\n    } catch (govErr: unknown) {\n      // C2 FIX: Use full delete helper to clean up ALL ancillary records\n      // (vec_memories, BM25 index, causal edges, projections, etc.)\n      // not just memory_index, to prevent orphaned search phantoms.\n      const govErrorMessage = govErr instanceof Error ? govErr.message : String(govErr);\n      console.error('[memory-save] Governance metadata failed, removing orphaned memory:', govErrorMessage);\n      try { delete_memory_from_database(database, result.id); } catch (_: unknown) { /* best-effort cleanup */ }\n      // The orphan rollback above already ran; return a classified error (sqlite-busy / db\n      // failures map to E087/E088) instead of a bare throw the dispatcher would surface as the\n      // generic E081 catch-all.\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: govErrorMessage,\n        code: classifySaveErrorCode(govErrorMessage),\n        details: { requestId, ...extractSaveErrorDetails(govErrorMessage) },\n        recovery: {\n          hint: 'The memory was rolled back after a post-insert metadata write failed; transient DB locks are retryable.',\n          actions: ['Resolve the reported cause', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  const response = buildSaveResponse({ result, filePath: file_path, asyncEmbedding, requestId });\n  if (idempotencyKey && shouldStoreMemorySaveReceipt(result, response)) {\n    try {\n      const won = storeIdempotencyReceipt(database, idempotencyKey, response, extractMemoryIdFromResponse(response));\n      if (!won) {\n        // A concurrent same-key save already stored the canonical receipt. Replay the\n        // first winner's response so this mutating loser returns the idempotent result\n        // instead of its own separately-created response.\n        const winner = lookupIdempotencyReceiptByKey(database, idempotencyKey);\n        if (winner.status === 'replay') {\n          return winner.response;\n        }\n        if (winner.status === 'conflict') {\n          // Different-payload winner: this loser's mutation landed, so an\n          // error would lie and replaying the winner would answer a\n          // different request — return the loser's response with the\n          // conflict made visible instead of silent.\n          return markResponseWithReceiptStoreConflict(response, idempotencyKey, winner.storedPayloadHash);\n        }\n      }\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(`[memory-save] idempotency receipt store failed; continuing without replay receipt: ${message}`);\n    }\n  }\n  return response;\n}\n\n/* --- 10. ATOMIC MEMORY SAVE --- */\n\n/**\n * Save memory content to disk with retry + rollback guarded indexing.\n *\n * The file write promotes a pending file while holding the per-spec-folder\n * mutex so concurrent saves cannot overwrite each other between disk\n * promotion and indexing. If indexing later fails, the original file content\n * is restored before the error is returned and before the lock is released.\n */\nasync function atomicSaveMemory(params: AtomicSaveParams, options: AtomicSaveOptions = {}): Promise<AtomicSaveResult> {\n  // Scrub once at the entry so every durably persisted artifact (canonical\n  // markdown, continuity merge, pending-file promotion) carries redacted text,\n  // not only the parsed/index copy the parser scrubs. Fail-closed: a scrubber\n  // failure throws and refuses the write rather than persisting raw content.\n  if (typeof params.content === 'string' && params.content.length > 0) {\n    const scrubResult = scrubSecretsDetailed(params.content);\n    if (scrubResult.redactions > 0) {","lineStart":3360,"lineEnd":3819,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781761692919,"end":1781761692934}},"metadata":{"openai":{"itemId":"fc_080cc7e967ed30dd016a33869cc5d481918fe904310a965784"}},"id":"prt_ed945d4e8001v7b9ckPHDFzgm5","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed945acc9001SMV0LBvG4y1962"}}
{"type":"tool_use","timestamp":1781761692938,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_icNDVvFIbjZhWNL6ASCxUBD4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Create Record\n3: // ───────────────────────────────────────────────────────────────\n4: import path from 'path';\n5: import type BetterSqlite3 from 'better-sqlite3';\n6: \n7: import * as vectorIndex from '../../lib/search/vector-index.js';\n8: import * as bm25Index from '../../lib/search/bm25-index.js';\n9: import * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\n10: import * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\n11: import * as incrementalIndex from '../../lib/storage/incremental-index.js';\n12: import * as causalEdges from '../../lib/storage/causal-edges.js';\n13: import type * as memoryParser from '../../lib/parsing/memory-parser.js';\n14: import { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\n15: import { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\n16: import { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\n17: import { toErrorMessage } from '../../utils/index.js';\n18: \n19: import { recordHistory } from '../../lib/storage/history.js';\n20: import { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';\n21: import { detectSpecLevelFromParsed } from '../handler-utils.js';\n22: import { classifyEncodingIntent } from '../../lib/search/encoding-intent.js';\n23: import { isEncodingIntentEnabled } from '../../lib/search/search-flags.js';\n24: import { applyPostInsertMetadata } from './db-helpers.js';\n25: import { inferDocumentTypeFromPath } from '../../lib/config/memory-types.js';\n26: import {\n27:   applyWriteProvenance,\n28:   deriveSourceKindFromContext,\n29:   normalizeSourceKind,\n30:   persistSourceKind,\n31:   type SourceKind,\n32:   type WriteProvenanceContext,\n33: } from '../../lib/storage/write-provenance.js';\n34: \n35: // Feature catalog: Memory indexing (memory_save)\n36: // Feature catalog: Per-memory history log\n37: // Feature catalog: Prediction-error save arbitration\n38: \n39: \n40: import type { PeDecision, MemoryScopeMatch } from './types.js';\n41: import { normalizeScopeMatchValue } from './types.js';\n42: export type { MemoryScopeMatch };\n43: \n44: export const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n45: \n46: export interface CreateRecordIdentityHints {\n47:   targetDocPath?: string | null;\n48:   canonicalFilePath?: string | null;\n49:   targetAnchorId?: string | null;\n50:   routeAs?: string | null;\n51:   continuitySourceKey?: string | null;\n52: }\n53: \n54: export interface ResolvedCreateRecordIdentity {\n55:   targetDocPath: string;\n56:   canonicalFilePath: string;\n57:   targetAnchorId: string | null;\n58:   routeAs: string | null;\n59:   continuitySourceKey: string | null;\n60: }\n61: \n62: interface LineageRoutingDecision {\n63:   predecessorMemoryId: number | null;\n64:   transitionEvent: 'CREATE' | 'UPDATE' | 'SUPERSEDE';\n65:   causalSupersedesMemoryId: number | null;\n66: }\n67: \n68: type ScopePostInsertMetadata = Partial<{\n69:   tenant_id: string;\n70:   user_id: string;\n71:   agent_id: string;\n72:   session_id: string;\n73: }>;\n74: \n75: export {\n76:   deriveSourceKindFromContext,\n77:   normalizeSourceKind,\n78:   type SourceKind,\n79: };\n80: \n81: function normalizeOptionalString(value: unknown): string | null {\n82:   if (typeof value !== 'string') {\n83:     return null;\n84:   }\n85:   const normalized = value.trim();\n86:   return normalized.length > 0 ? normalized : null;\n87: }\n88: \n89: function pickFirstString(...values: unknown[]): string | null {\n90:   for (const value of values) {\n91:     const normalized = normalizeOptionalString(value);\n92:     if (normalized) {\n93:       return normalized;\n94:     }\n95:   }\n96:   return null;\n97: }\n98: \n99: function getParsedIdentityValue(parsed: ReturnType<typeof memoryParser.parseMemoryFile>, ...keys: string[]): string | null {\n100:   const parsedRecord = parsed as unknown as Record<string, unknown>;\n101:   for (const key of keys) {\n102:     const normalized = normalizeOptionalString(parsedRecord[key]);\n103:     if (normalized) {\n104:       return normalized;\n105:     }\n106:   }\n107:   return null;\n108: }\n109: \n110: export function resolveCreateRecordIdentity(\n111:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n112:   filePath: string,\n113:   hints: CreateRecordIdentityHints = {},\n114: ): ResolvedCreateRecordIdentity {\n115:   const targetDocPath = pickFirstString(\n116:     hints.targetDocPath,\n117:     getParsedIdentityValue(parsed, 'targetDocPath', 'target_doc_path', 'targetFilePath', 'target_file_path', 'routedDocPath', 'routed_doc_path'),\n118:     filePath,\n119:   ) ?? filePath;\n120: \n121:   const routeAs = pickFirstString(\n122:     hints.routeAs,\n123:     getParsedIdentityValue(parsed, 'routeAs', 'route_as'),\n124:   );\n125:   const continuitySourceKey = pickFirstString(\n126:     hints.continuitySourceKey,\n127:     getParsedIdentityValue(parsed, 'continuitySourceKey', 'continuity_source_key', 'sourceKey', 'source_key'),\n128:   );\n129:   const targetAnchorId = pickFirstString(\n130:     hints.targetAnchorId,\n131:     getParsedIdentityValue(parsed, 'targetAnchorId', 'target_anchor_id', 'anchorId', 'anchor_id'),\n132:   ) ?? ((routeAs === 'metadata_only' || continuitySourceKey !== null) ? CONTINUITY_ANCHOR_ID : null);\n133: \n134:   return {\n135:     targetDocPath,\n136:     canonicalFilePath: pickFirstString(hints.canonicalFilePath, getCanonicalPathKey(targetDocPath)) ?? getCanonicalPathKey(targetDocPath),\n137:     targetAnchorId,\n138:     routeAs,\n139:     continuitySourceKey,\n140:   };\n141: }\n142: \n143: export function resolveCreateRecordLineage(\n144:   peDecision: PeDecision,\n145:   samePathExistingId: number | null,\n146: ): LineageRoutingDecision {\n147:   if (peDecision.action === predictionErrorGate.ACTION.SUPERSEDE && peDecision.existingMemoryId != null) {\n148:     return {\n149:       predecessorMemoryId: samePathExistingId,\n150:       transitionEvent: samePathExistingId != null ? 'SUPERSEDE' : 'CREATE',\n151:       causalSupersedesMemoryId: samePathExistingId === peDecision.existingMemoryId\n152:         ? null\n153:         : peDecision.existingMemoryId,\n154:     };\n155:   }\n156: \n157:   if (samePathExistingId != null) {\n158:     return {\n159:       predecessorMemoryId: samePathExistingId,\n160:       transitionEvent: 'UPDATE',\n161:       causalSupersedesMemoryId: null,\n162:     };\n163:   }\n164: \n165:   return {\n166:     predecessorMemoryId: null,\n167:     transitionEvent: 'CREATE',\n168:     causalSupersedesMemoryId: null,\n169:   };\n170: }\n171: \n172: export function buildScopePostInsertMetadata(\n173:   scope: MemoryScopeMatch = {},\n174: ): ScopePostInsertMetadata {\n175:   const tenantId = normalizeScopeMatchValue(scope.tenantId);\n176:   const userId = normalizeScopeMatchValue(scope.userId);\n177:   const agentId = normalizeScopeMatchValue(scope.agentId);\n178:   const sessionId = normalizeScopeMatchValue(scope.sessionId);\n179: \n180:   return {\n181:     ...(tenantId ? { tenant_id: tenantId } : {}),\n182:     ...(userId ? { user_id: userId } : {}),\n183:     ...(agentId ? { agent_id: agentId } : {}),\n184:     ...(sessionId ? { session_id: sessionId } : {}),\n185:   };\n186: }\n187: \n188: function recordCrossPathSupersedesEdge(\n189:   database: BetterSqlite3.Database,\n190:   memoryId: number,\n191:   supersededMemoryId: number | null,\n192:   reason: string | null | undefined,\n193: ): void {\n194:   if (supersededMemoryId == null) {\n195:     return;\n196:   }\n197: \n198:   causalEdges.init(database);\n199:   const evidence = reason && reason.trim().length > 0\n200:     ? reason.trim()\n201:     : 'Prediction-error contradiction across different file paths';\n202:   causalEdges.insertEdge(\n203:     String(memoryId),\n204:     String(supersededMemoryId),\n205:     causalEdges.RELATION_TYPES.SUPERSEDES,\n206:     1.0,\n207:     evidence,\n208:     true,\n209:     'auto',\n210:   );\n211: }\n212: \n213: export function findSamePathExistingMemory(\n214:   database: BetterSqlite3.Database,\n215:   specFolder: string,\n216:   canonicalFilePath: string,\n217:   filePath: string,\n218:   scope: MemoryScopeMatch = {},\n219:   identityHints: CreateRecordIdentityHints = {},\n220: ): { id: number; title: string | null; content_hash?: string | null } | undefined {\n221:   const tenantId = normalizeScopeMatchValue(scope.tenantId);\n222:   const userId = normalizeScopeMatchValue(scope.userId);\n223:   const agentId = normalizeScopeMatchValue(scope.agentId);\n224:   const sessionId = normalizeScopeMatchValue(scope.sessionId);\n225:   const resolvedCanonicalFilePath = normalizeOptionalString(identityHints.canonicalFilePath) ?? canonicalFilePath;\n226:   const resolvedFilePath = normalizeOptionalString(identityHints.targetDocPath) ?? filePath;\n227:   const resolvedAnchorId = normalizeOptionalString(identityHints.targetAnchorId);\n228:   const hasIdentityOverride = resolvedCanonicalFilePath !== canonicalFilePath\n229:     || resolvedFilePath !== filePath\n230:     || identityHints.targetAnchorId !== undefined\n231:     || identityHints.canonicalFilePath !== undefined\n232:     || identityHints.targetDocPath !== undefined;\n233: \n234:   const anchorClause = resolvedAnchorId !== null\n235:     ? 'AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))'\n236:     : hasIdentityOverride\n237:       ? 'AND anchor_id IS NULL'\n238:       : '';\n239: \n240:   const params: Array<string | null> = [\n241:     specFolder,\n242:     resolvedCanonicalFilePath,\n243:     resolvedFilePath,\n244:   ];\n245:   if (resolvedAnchorId !== null) {\n246:     params.push(resolvedAnchorId, resolvedAnchorId);\n247:   }\n248:   params.push(\n249:     tenantId,\n250:     tenantId,\n251:     userId,\n252:     userId,\n253:     agentId,\n254:     agentId,\n255:     sessionId,\n256:     sessionId,\n257:   );\n258: \n259:   return database.prepare(`\n260:     SELECT id, title, content_hash\n\n(Showing lines 1-260 of 466. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Create Record\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport * as vectorIndex from '../../lib/search/vector-index.js';\nimport * as bm25Index from '../../lib/search/bm25-index.js';\nimport * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\nimport * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\nimport * as incrementalIndex from '../../lib/storage/incremental-index.js';\nimport * as causalEdges from '../../lib/storage/causal-edges.js';\nimport type * as memoryParser from '../../lib/parsing/memory-parser.js';\nimport { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\nimport { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\nimport { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\nimport { toErrorMessage } from '../../utils/index.js';\n\nimport { recordHistory } from '../../lib/storage/history.js';\nimport { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Create Record\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport type BetterSqlite3 from 'better-sqlite3';\n\nimport * as vectorIndex from '../../lib/search/vector-index.js';\nimport * as bm25Index from '../../lib/search/bm25-index.js';\nimport * as predictionErrorGate from '../../lib/cognitive/prediction-error-gate.js';\nimport * as fsrsScheduler from '../../lib/cognitive/fsrs-scheduler.js';\nimport * as incrementalIndex from '../../lib/storage/incremental-index.js';\nimport * as causalEdges from '../../lib/storage/causal-edges.js';\nimport type * as memoryParser from '../../lib/parsing/memory-parser.js';\nimport { sanitizeEmbeddingFailureMessage } from '../../lib/providers/retry-manager.js';\nimport { getCanonicalPathKey } from '../../lib/utils/canonical-path.js';\nimport { recordLineageTransition, retirePredecessorForActiveReindex } from '../../lib/storage/lineage-state.js';\nimport { toErrorMessage } from '../../utils/index.js';\n\nimport { recordHistory } from '../../lib/storage/history.js';\nimport { calculateDocumentWeight, isSpecDocumentType } from '../pe-gating.js';\nimport { detectSpecLevelFromParsed } from '../handler-utils.js';\nimport { classifyEncodingIntent } from '../../lib/search/encoding-intent.js';\nimport { isEncodingIntentEnabled } from '../../lib/search/search-flags.js';\nimport { applyPostInsertMetadata } from './db-helpers.js';\nimport { inferDocumentTypeFromPath } from '../../lib/config/memory-types.js';\nimport {\n  applyWriteProvenance,\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  persistSourceKind,\n  type SourceKind,\n  type WriteProvenanceContext,\n} from '../../lib/storage/write-provenance.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Per-memory history log\n// Feature catalog: Prediction-error save arbitration\n\n\nimport type { PeDecision, MemoryScopeMatch } from './types.js';\nimport { normalizeScopeMatchValue } from './types.js';\nexport type { MemoryScopeMatch };\n\nexport const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n\nexport interface CreateRecordIdentityHints {\n  targetDocPath?: string | null;\n  canonicalFilePath?: string | null;\n  targetAnchorId?: string | null;\n  routeAs?: string | null;\n  continuitySourceKey?: string | null;\n}\n\nexport interface ResolvedCreateRecordIdentity {\n  targetDocPath: string;\n  canonicalFilePath: string;\n  targetAnchorId: string | null;\n  routeAs: string | null;\n  continuitySourceKey: string | null;\n}\n\ninterface LineageRoutingDecision {\n  predecessorMemoryId: number | null;\n  transitionEvent: 'CREATE' | 'UPDATE' | 'SUPERSEDE';\n  causalSupersedesMemoryId: number | null;\n}\n\ntype ScopePostInsertMetadata = Partial<{\n  tenant_id: string;\n  user_id: string;\n  agent_id: string;\n  session_id: string;\n}>;\n\nexport {\n  deriveSourceKindFromContext,\n  normalizeSourceKind,\n  type SourceKind,\n};\n\nfunction normalizeOptionalString(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction pickFirstString(...values: unknown[]): string | null {\n  for (const value of values) {\n    const normalized = normalizeOptionalString(value);\n    if (normalized) {\n      return normalized;\n    }\n  }\n  return null;\n}\n\nfunction getParsedIdentityValue(parsed: ReturnType<typeof memoryParser.parseMemoryFile>, ...keys: string[]): string | null {\n  const parsedRecord = parsed as unknown as Record<string, unknown>;\n  for (const key of keys) {\n    const normalized = normalizeOptionalString(parsedRecord[key]);\n    if (normalized) {\n      return normalized;\n    }\n  }\n  return null;\n}\n\nexport function resolveCreateRecordIdentity(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  filePath: string,\n  hints: CreateRecordIdentityHints = {},\n): ResolvedCreateRecordIdentity {\n  const targetDocPath = pickFirstString(\n    hints.targetDocPath,\n    getParsedIdentityValue(parsed, 'targetDocPath', 'target_doc_path', 'targetFilePath', 'target_file_path', 'routedDocPath', 'routed_doc_path'),\n    filePath,\n  ) ?? filePath;\n\n  const routeAs = pickFirstString(\n    hints.routeAs,\n    getParsedIdentityValue(parsed, 'routeAs', 'route_as'),\n  );\n  const continuitySourceKey = pickFirstString(\n    hints.continuitySourceKey,\n    getParsedIdentityValue(parsed, 'continuitySourceKey', 'continuity_source_key', 'sourceKey', 'source_key'),\n  );\n  const targetAnchorId = pickFirstString(\n    hints.targetAnchorId,\n    getParsedIdentityValue(parsed, 'targetAnchorId', 'target_anchor_id', 'anchorId', 'anchor_id'),\n  ) ?? ((routeAs === 'metadata_only' || continuitySourceKey !== null) ? CONTINUITY_ANCHOR_ID : null);\n\n  return {\n    targetDocPath,\n    canonicalFilePath: pickFirstString(hints.canonicalFilePath, getCanonicalPathKey(targetDocPath)) ?? getCanonicalPathKey(targetDocPath),\n    targetAnchorId,\n    routeAs,\n    continuitySourceKey,\n  };\n}\n\nexport function resolveCreateRecordLineage(\n  peDecision: PeDecision,\n  samePathExistingId: number | null,\n): LineageRoutingDecision {\n  if (peDecision.action === predictionErrorGate.ACTION.SUPERSEDE && peDecision.existingMemoryId != null) {\n    return {\n      predecessorMemoryId: samePathExistingId,\n      transitionEvent: samePathExistingId != null ? 'SUPERSEDE' : 'CREATE',\n      causalSupersedesMemoryId: samePathExistingId === peDecision.existingMemoryId\n        ? null\n        : peDecision.existingMemoryId,\n    };\n  }\n\n  if (samePathExistingId != null) {\n    return {\n      predecessorMemoryId: samePathExistingId,\n      transitionEvent: 'UPDATE',\n      causalSupersedesMemoryId: null,\n    };\n  }\n\n  return {\n    predecessorMemoryId: null,\n    transitionEvent: 'CREATE',\n    causalSupersedesMemoryId: null,\n  };\n}\n\nexport function buildScopePostInsertMetadata(\n  scope: MemoryScopeMatch = {},\n): ScopePostInsertMetadata {\n  const tenantId = normalizeScopeMatchValue(scope.tenantId);\n  const userId = normalizeScopeMatchValue(scope.userId);\n  const agentId = normalizeScopeMatchValue(scope.agentId);\n  const sessionId = normalizeScopeMatchValue(scope.sessionId);\n\n  return {\n    ...(tenantId ? { tenant_id: tenantId } : {}),\n    ...(userId ? { user_id: userId } : {}),\n    ...(agentId ? { agent_id: agentId } : {}),\n    ...(sessionId ? { session_id: sessionId } : {}),\n  };\n}\n\nfunction recordCrossPathSupersedesEdge(\n  database: BetterSqlite3.Database,\n  memoryId: number,\n  supersededMemoryId: number | null,\n  reason: string | null | undefined,\n): void {\n  if (supersededMemoryId == null) {\n    return;\n  }\n\n  causalEdges.init(database);\n  const evidence = reason && reason.trim().length > 0\n    ? reason.trim()\n    : 'Prediction-error contradiction across different file paths';\n  causalEdges.insertEdge(\n    String(memoryId),\n    String(supersededMemoryId),\n    causalEdges.RELATION_TYPES.SUPERSEDES,\n    1.0,\n    evidence,\n    true,\n    'auto',\n  );\n}\n\nexport function findSamePathExistingMemory(\n  database: BetterSqlite3.Database,\n  specFolder: string,\n  canonicalFilePath: string,\n  filePath: string,\n  scope: MemoryScopeMatch = {},\n  identityHints: CreateRecordIdentityHints = {},\n): { id: number; title: string | null; content_hash?: string | null } | undefined {\n  const tenantId = normalizeScopeMatchValue(scope.tenantId);\n  const userId = normalizeScopeMatchValue(scope.userId);\n  const agentId = normalizeScopeMatchValue(scope.agentId);\n  const sessionId = normalizeScopeMatchValue(scope.sessionId);\n  const resolvedCanonicalFilePath = normalizeOptionalString(identityHints.canonicalFilePath) ?? canonicalFilePath;\n  const resolvedFilePath = normalizeOptionalString(identityHints.targetDocPath) ?? filePath;\n  const resolvedAnchorId = normalizeOptionalString(identityHints.targetAnchorId);\n  const hasIdentityOverride = resolvedCanonicalFilePath !== canonicalFilePath\n    || resolvedFilePath !== filePath\n    || identityHints.targetAnchorId !== undefined\n    || identityHints.canonicalFilePath !== undefined\n    || identityHints.targetDocPath !== undefined;\n\n  const anchorClause = resolvedAnchorId !== null\n    ? 'AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))'\n    : hasIdentityOverride\n      ? 'AND anchor_id IS NULL'\n      : '';\n\n  const params: Array<string | null> = [\n    specFolder,\n    resolvedCanonicalFilePath,\n    resolvedFilePath,\n  ];\n  if (resolvedAnchorId !== null) {\n    params.push(resolvedAnchorId, resolvedAnchorId);\n  }\n  params.push(\n    tenantId,\n    tenantId,\n    userId,\n    userId,\n    agentId,\n    agentId,\n    sessionId,\n    sessionId,\n  );\n\n  return database.prepare(`\n    SELECT id, title, content_hash","lineStart":1,"lineEnd":260,"totalLines":466,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/create-record.ts","time":{"start":1781761692931,"end":1781761692937}},"metadata":{"openai":{"itemId":"fc_080cc7e967ed30dd016a33869cc5e881919f170c7fef57dd0d"}},"id":"prt_ed945d4f9001gRBbFdYr83R7rW","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed945acc9001SMV0LBvG4y1962"}}
