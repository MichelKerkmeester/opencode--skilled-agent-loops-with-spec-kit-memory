   {\n143:         \"name\": \"Feature Specification\",\n144:         \"kind\": \"proper_noun\",\n145:         \"path\": \"spec.md\",\n146:         \"source\": \"derived\"\n147:       },\n148:       {\n149:         \"name\": \"Parent Spec\",\n150:         \"kind\": \"proper_noun\",\n151:         \"path\": \"spec.md\",\n152:         \"source\": \"derived\"\n153:       },\n154:       {\n155:         \"name\": \"Handoff Criteria\",\n156:         \"kind\": \"proper_noun\",\n157:         \"path\": \"spec.md\",\n158:         \"source\": \"derived\"\n159:       },\n160:       {\n161:         \"name\": \"Phase Context This\",\n162:         \"kind\": \"proper_noun\",\n163:         \"path\": \"spec.md\",\n164:         \"source\": \"derived\"\n165:       },\n166:       {\n167:         \"name\": \"Scope Boundary\",\n168:         \"kind\": \"proper_noun\",\n169:         \"path\": \"spec.md\",\n170:         \"source\": \"derived\"\n171:       },\n172:       {\n173:         \"name\": \"Problem Statement\",\n174:         \"kind\": \"proper_noun\",\n175:         \"path\": \"spec.md\",\n176:         \"source\": \"derived\"\n177:       },\n178:       {\n179:         \"name\": \"Implementation Plan\",\n180:         \"kind\": \"proper_noun\",\n181:         \"path\": \"plan.md\",\n182:         \"source\": \"derived\"\n183:       },\n184:       {\n185:         \"name\": \"Uses Node\",\n186:         \"kind\": \"proper_noun\",\n187:         \"path\": \"plan.md\",\n188:         \"source\": \"derived\"\n189:       },\n190:       {\n191:         \"name\": \"an\",\n192:         \"kind\": \"key_phrase\",\n193:         \"path\": \"plan.md\",\n194:         \"source\": \"derived\"\n195:       },\n196:       {\n197:         \"name\": \"the\",\n198:         \"kind\": \"key_phrase\",\n199:         \"path\": \"plan.md\",\n200:         \"source\": \"derived\"\n201:       },\n202:       {\n203:         \"name\": \"a\",\n204:         \"kind\": \"key_phrase\",\n205:         \"path\": \"plan.md\",\n206:         \"source\": \"derived\"\n207:       }\n208:     ],\n209:     \"causal_summary\": \"This phase is the direct follow-on to 020. 018 made the reindex scan cancellable and added cooperative `setImmediate` yields to its two big tail loops. 019 wrote a `.maintenance-active.json` marker so a competing launcher adopts a busy daemon instead of reaping it. 020 extended that marker to the post-scan background-embedding queue. 020's own limitation closes the loop being opened here: *\\\"The marker makes the daemon un-reaped while busy, it does not make it responsive.\\\"* A daemon whose event loop is blocked can neither answer a competing launcher's probe/bridge nor fire the marker's 20s self-refresh timer; if a single synchronous phase blocks longer than the 180s TTL, the marker goes stale and a second daemon spawns anyway. 020 noted the longest blocking tail phase observed (~79s) but never pinned which phase it was.\",\n210:     \"created_at\": \"2026-06-17T17:15:00.000Z\",\n211:     \"last_save_at\": \"2026-06-17T19:57:25.114Z\",\n212:     \"save_lineage\": \"graph_only\",\n213:     \"last_accessed_at\": null,\n214:     \"source_docs\": [\n215:       \"spec.md\",\n216:       \"plan.md\",\n217:       \"tasks.md\",\n218:       \"implementation-summary.md\"\n219:     ],\n220:     \"last_active_child_id\": null,\n221:     \"last_active_at\": null\n222:   }\n223: }\n\n(End of file - total 223 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/021-cooperative-heavy-phases\",\n  \"spec_folder\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/021-cooperative-heavy-phases\",\n  \"parent_id\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search\",\n  \"children_ids\": [],\n  \"migrated\": true,\n  \"migration_source\": \"legacy\",\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"cooperative heavy phases daemon responsiveness\",\n      \"event loop lag instrumentation reindex scan\",\n      \"trigger embedding backfill chunk and yield\",\n      \"027 002/021\",\n      \"cooperative heavy phases plan\",","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/021-cooperative-heavy-phases/graph-metadata.json","text":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/021-cooperative-heavy-phases\",\n  \"spec_folder\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/021-cooperative-heavy-phases\",\n  \"parent_id\": \"system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search\",\n  \"children_ids\": [],\n  \"migrated\": true,\n  \"migration_source\": \"legacy\",\n  \"manual\": {\n    \"depends_on\": [],\n    \"supersedes\": [],\n    \"related_to\": []\n  },\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"cooperative heavy phases daemon responsiveness\",\n      \"event loop lag instrumentation reindex scan\",\n      \"trigger embedding backfill chunk and yield\",\n      \"027 002/021\",\n      \"cooperative heavy phases plan\",\n      \"event loop lag sampler trigger backfill chunk plan\",\n      \"027 002/021 plan\",\n      \"cooperative heavy phases tasks\",\n      \"027 002/021 tasks\",\n      \"cooperative heavy phases shipped\",\n      \"event loop lag sampler trigger backfill chunk shipped\",\n      \"027 002/021 shipped\"\n    ],\n    \"key_topics\": [\n      \"cooperative\",\n      \"heavy\",\n      \"phases\",\n      \"daemon\",\n      \"responsiveness\",\n      \"event\",\n      \"loop\",\n      \"lag\",\n      \"instrumentation\",\n      \"reindex\",\n      \"scan\