tion Workflow Separation\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Phase Parent\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Parent Spec\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Parent Packet\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"Handoff Criteria\",\n        \"kind\": \"proper_noun\",\n        \"path\": \"spec.md\",\n        \"source\": \"derived\"\n      }\n    ],\n    \"causal_summary\": \"Command files under `.opencode/commands/<group>/<name>.md` currently mix workflow logic with presentation contracts. Startup questions, dashboard layouts, and results-display templates are buried inline in large instruction files, so assistants may skip questions, improvise dashboards, or return cluttered results instead of following a reliable display contract.\",\n    \"created_at\": \"2026-06-10T00:00:00Z\",\n    \"last_save_at\": \"2026-06-10T14:24:35.927Z\",\n    \"save_lineage\": \"graph_only\",\n    \"last_accessed_at\": null,\n    \"source_docs\": [\n      \"spec.md\"\n    ],\n    \"last_active_child_id\": null,\n    \"last_active_at\": null\n  },\n  \"parent_packet\": \"system-spec-kit/027-xce-research-based-refinement\"\n}","lineStart":1,"lineEnd":98,"totalLines":98,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/011-command-presentation-workflow-separation/graph-metadata.json","time":{"start":1781143386806,"end":1781143386808}},"metadata":{"openai":{"itemId":"fc_0a44a2ef2827f506016a2a175ab8388191a16e5d2f5b1cd4ad"}},"id":"prt_eb46b3ab0001JPXMTwRY706uNM","sessionID":"ses_14b95d469ffeS9sQY1uDV505eH","messageID":"msg_eb46b1