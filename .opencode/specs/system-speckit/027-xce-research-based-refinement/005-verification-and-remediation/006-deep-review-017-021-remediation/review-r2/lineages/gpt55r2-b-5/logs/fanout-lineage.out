cessBatches(\n\n  Line 169:       const results = await processBatches(\n\n  Line 188:       const results = await processBatches(\n\n  Line 206:       const results = await processBatches(['only'], async (x: string) => x.length, 5, 0);\n\n  Line 217:       const results = await processBatches([1, 2, 3], async (x: number) => x, 100, 0);\n\n  Line 224:       const results = await processBatches([42], async (x: number) => x, 10000, 0);\n\n  Line 239:       const results = await processBatches(items, async (x: number) => x, MAX_BATCH_SIZE * 10, 0);\n\n  Line 255:       const results = await processBatches([1, 2, 3, 4, 5, 6], async (x: number) => x, 3, 0);\n\n  Line 379:       await processBatches([1, 2, 3, 4], async (x: number) => x, 2, 0);\n\n  Line 386:       await processBatches([1, 2], async (x: number) => x, 2, 500);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/safety.vitest.ts:\n  Line 24:       await expect(processBatches([1, 2, 3], identity, 0)).rejects.toThrow('positive integer');\n\n  Line 28:       await expect(processBatches([1], identity, -1)).rejects.toThrow();\n\n  Line 32:       await expect(processBatches([1, 2], identity, NaN)).rejects.toThrow('positive integer');\n\n  Line 36:       await expect(processBatches([1], identity, Infinity)).rejects.toThrow();\n\n  Line 40:       await expect(processBatches([1], identity, -Infinity)).rejects.toThrow();\n\n  Line 44:       await expect(processBatches([1, 2, 3], identity, 2.5)).rejects.toThrow();\n\n  Line 48:       await expect(processBatches([1], identity, 0.5)).rejects.toThrow();\n\n  Line 52:       const results = await processBatches([42], identity, 1, 0);\n\n  Line 59:       const results = await processBatches(items, identity, 10, 0);\n\n  Line 65:       const results = await processBatches(items, identity, 100, 0);\n\n  Line 70:       await expect(processBatches([], identity, 0)).rejects.toThrow();\n\n  Line 75:       await e