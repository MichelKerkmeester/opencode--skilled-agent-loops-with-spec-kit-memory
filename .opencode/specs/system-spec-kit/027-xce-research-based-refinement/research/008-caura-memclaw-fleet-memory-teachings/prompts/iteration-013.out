s_bulk(db, bulk_data, bulk_attempt_id=run_id)\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/routes/memories.py:\n  Line 959: BULK_ATTEMPT_ID_HEADER = \"X-Bulk-Attempt-Id\"\n\n  Line 961: # concatenated with ``:{i}`` to form the per-row ``client_request_id``\n\n  Line 989:     bulk_attempt_id: str | None = Header(None, alias=BULK_ATTEMPT_ID_HEADER),\n\n  Line 993:     Required header ``X-Bulk-Attempt-Id`` identifies the *attempt*. A\n\n  Line 1017:     *response*-level replay; ``X-Bulk-Attempt-Id`` is a separate\n\n  Line 1037:         if not bulk_attempt_id:\n\n  Line 1040:             bulk_attempt_id = f\"broker-{auth.install_uuid or 'unknown'}-{_uuid.uuid4()}\"\n\n  Line 1043:     if not bulk_attempt_id:\n\n  Line 1052:     if not _BULK_ATTEMPT_ID_PATTERN.match(bulk_attempt_id):\n\n  Line 1068:         return await _write_memories_bulk_inner(body, response, auth, db, _idem, bulk_attempt_id)\n\n  Line 1104:     bulk_attempt_id: str,\n\n  Line 1119:             create_memories_bulk(db, body, bulk_attempt_id=bulk_attempt_id),\n\n  Line 1137:         # ``X-Bulk-Attempt-Id`` retry contract recovers it.\n\n  Line 1170:         # ``X-Bulk-Attempt-Id`` retry contract intact. 4xx escapes here\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/auth.py:\n  Line 80:         # drive an ``X-Bulk-Attempt-Id`` header and don't have an\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/schemas.py:\n  Line 102:     - ``\"duplicate_attempt\"``: same ``X-Bulk-Attempt-Id``+index already\n\n  Line 119:     client_request_id: str | None = None\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/config.py:\n  Line 125:     # constraint on ``memories.client_request_id`` makes a 504-here\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/clients/storage_client.py:\n  Line 203:         a 504 with the ``X-Bulk-Attempt-Id`` retry hint, and the\n\n  Line 372:         Every input item must include ``client_request_id`` — the\n\n  Line 373:         bulk endpoint derives it from ``X-Bulk-Attempt-Id`` upstream;\n\n  Line 378:             {\"client_request_id\": str, \"id\": str | None, \"was_inserted\": bool}\n\n  Line 381:         ``False`` means the same ``(tenant_id, fleet_id, client_request_id)``\n\n  Line 508:         Returns ``{content_hash: {\"id\": str, \"client_request_id\": str | None}}``.\n\n  Line 509:         ``client_request_id`` lets the bulk path tell ``duplicate_attempt``\n","metadata":{"matches":59,"truncated":false},"title":"X-Bulk-Attempt-Id|client_request_id|bulk_attempt","time":{"start":1780728886729,"end":1780728886745}},"metadata":{"openai":{"itemId":"fc_03fe2d5d57e93fde016a23c4369fc88191924754071e05fbcd"}},"id":"prt_e9bb675b2001hgWKSZMKtIdnCd","sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","messageID":"msg_e9bb6577d001GzLKQCqdD3MpgA"}}
