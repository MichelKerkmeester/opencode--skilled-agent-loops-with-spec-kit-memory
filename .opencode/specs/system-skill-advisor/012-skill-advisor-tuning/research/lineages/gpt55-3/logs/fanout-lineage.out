{"type":"tool_use","timestamp":1783437204127,"sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","part":{"type":"tool","tool":"read","callID":"call_N0eiWCxywlC2GbAgDV0nL8Dg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Skill Projection\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { existsSync, readFileSync, readdirSync } from 'node:fs';\n6: import { dirname, isAbsolute, join, resolve } from 'node:path';\n7: \n8: import Database from 'better-sqlite3';\n9: \n10: import { getManifest } from '../embedders/registry.js';\n11: import type { BackendKind } from '../embedders/types.js';\n12: import { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\n13: import { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\n14: import { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\n15: import { providerModelId } from '../skill-graph/skill-graph-db.js';\n16: import { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\n17: import { parseSkillFrontmatter } from '../utils/skill-markdown.js';\n18: import type {\n19:   AdvisorEmbeddingSignature,\n20:   AdvisorEmbeddingStalenessVerdict,\n21:   AdvisorProjection,\n22:   SkillDocTriggerProjection,\n23:   SkillEdgeProjection,\n24:   SkillLifecycleStatus,\n25:   SkillProjection,\n26: } from './types.js';\n27: import { phraseVariants, unique } from './text.js';\n28: \n29: interface SkillNodeRow {\n30:   readonly id: string;\n31:   readonly family: string;\n32:   readonly category: string;\n33:   readonly domains: string | null;\n34:   readonly intent_signals: string | null;\n35:   readonly derived: string | null;\n36:   readonly source_path: string;\n37: }\n38: \n39: interface SkillEdgeRow {\n40:   readonly source_id: string;\n41:   readonly target_id: string;\n42:   readonly edge_type: SkillEdgeProjection['edgeType'];\n43:   readonly weight: number;\n44:   readonly context: string;\n45: }\n46: \n47: interface SkillMarkdownMetadata {\n48:   readonly name: string;\n49:   readonly description: string;\n50:   readonly keywords: readonly string[];\n51: }\n52: \n53: const advisorDbDirOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n54: const SKILL_GRAPH_DB = advisorDbDirOverride\n55:   ? join(advisorDbDirOverride, 'skill-graph.sqlite')\n56:   : join('.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database', 'skill-graph.sqlite');\n57: \n58: const COMMAND_BRIDGES: readonly SkillProjection[] = [\n59:   {\n60:     id: 'command-spec-kit',\n61:     kind: 'command',\n62:     family: 'system',\n63:     category: 'command',\n64:     name: 'command-spec-kit',\n65:     description: 'Spec Kit command bridge for /spec_kit workflows.',\n66:     keywords: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n67:     domains: ['spec-kit', 'command'],\n68:     intentSignals: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n69:     derivedTriggers: [],\n70:     derivedKeywords: [],\n71:     sourcePath: null,\n72:     lifecycleStatus: 'active',\n73:   },\n74:   {\n75:     id: 'memory:save',\n76:     kind: 'command',\n77:     family: 'system',\n78:     category: 'command',\n79:     name: 'memory:save',\n80:     description: 'Memory save command bridge for /memory:save context preservation.',\n81:     keywords: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n82:     domains: ['memory', 'command'],\n83:     intentSignals: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n84:     derivedTriggers: [],\n85:     derivedKeywords: [],\n86:     sourcePath: null,\n87:     lifecycleStatus: 'active',\n88:   },\n89:   {\n90:     id: 'command-memory-save',\n91:     kind: 'command',\n92:     family: 'system',\n93:     category: 'command',\n94:     name: 'command-memory-save',\n95:     description: 'Memory save command bridge for /memory:save context preservation.',\n96:     keywords: ['/memory:save', 'save context', 'save memory'],\n97:     domains: ['memory', 'command'],\n98:     intentSignals: ['/memory:save', 'save context', 'save memory'],\n99:     derivedTriggers: [],\n100:     derivedKeywords: [],\n101:     sourcePath: null,\n102:     lifecycleStatus: 'active',\n103:   },\n104:   {\n105:     id: 'create:agent',\n106:     kind: 'command',\n107:     family: 'system',\n108:     category: 'command',\n109:     name: 'create:agent',\n110:     description: 'Create command bridge for /create:agent OpenCode agent scaffolding.',\n111:     keywords: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n112:     domains: ['create', 'agent', 'command'],\n113:     intentSignals: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n114:     derivedTriggers: [],\n115:     derivedKeywords: [],\n116:     sourcePath: null,\n117:     lifecycleStatus: 'active',\n118:   },\n119:   {\n120:     id: 'create:manual-testing-playbook',\n121:     kind: 'command',\n122:     family: 'system',\n123:     category: 'command',\n124:     name: 'create:manual-testing-playbook',\n125:     description: 'Create command bridge for /create:manual-testing-playbook manual testing playbook scaffolding.',\n126:     keywords: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n127:     domains: ['create', 'testing', 'playbook', 'command'],\n128:     intentSignals: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n129:     derivedTriggers: [],\n130:     derivedKeywords: [],\n131:     sourcePath: null,\n132:     lifecycleStatus: 'active',\n133:   },\n134:   {\n135:     id: 'deep-model-benchmark',\n136:     kind: 'command',\n137:     family: 'system',\n138:     category: 'command',\n139:     name: 'deep-model-benchmark',\n140:     description: 'Deep command bridge for /deep:start-model-benchmark-loop model and prompt-framework benchmarking.',\n141:     keywords: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n142:     domains: ['deep', 'benchmark', 'model', 'command'],\n143:     intentSignals: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n144:     derivedTriggers: [],\n145:     derivedKeywords: [],\n146:     sourcePath: null,\n147:     lifecycleStatus: 'active',\n148:   },\n149: ];\n150: \n151: function jsonArray(value: string | null | undefined): string[] {\n152:   return value ? parseJsonStringArray(value) : [];\n153: }\n154: \n155: function jsonObject(value: string | null | undefined): Record<string, unknown> {\n156:   return value ? parseJsonObject(value) ?? {} : {};\n157: }\n158: \n159: function stringArray(value: unknown): string[] {\n160:   return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n161: }\n162: \n163: function boundedDemotion(value: unknown): number | undefined {\n164:   return typeof value === 'number' && Number.isFinite(value)\n165:     ? Math.max(0, Math.min(1, value))\n166:     : undefined;\n167: }\n168: \n169: function readJson(filePath: string): Record<string, unknown> {\n170:   return readJsonObject(filePath) ?? {};\n171: }\n172: \n173: function parseSkillMarkdown(skillMdPath: string, fallbackId: string): SkillMarkdownMetadata {\n174:   if (!existsSync(skillMdPath)) {\n175:     return { name: fallbackId, description: '', keywords: [] };\n176:   }\n177:   const { frontmatter, keywords } = parseSkillFrontmatter(readFileSync(skillMdPath, 'utf8'));\n178:   return {\n179:     name: frontmatter.name || fallbackId,\n180:     description: frontmatter.description || '',\n181:     keywords,\n182:   };\n183: }\n184: \n185: function lifecycleStatus(raw: unknown, sourcePath: string): SkillLifecycleStatus {\n186:   if (raw === 'deprecated' || raw === 'archived' || raw === 'future' || raw === 'active') return raw;\n187:   const pathStatus = lifecycleStatusForPath(sourcePath);\n188:   return pathStatus === 'archived' || pathStatus === 'future' ? pathStatus : 'active';\n189: }\n190: \n191: function projectionFromRow(row: SkillNodeRow): SkillProjection {\n192:   const derived = sanitizeDerivedMetadata(jsonObject(row.derived), row.source_path) ?? {};\n193:   const graphMetadata = readJson(row.source_path);\n194:   const skillDir = dirname(row.source_path);\n195:   const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), row.id);\n196:   const lifecycle = lifecycleStatus(\n197:     graphMetadata.lifecycle_status ?? derived.lifecycle_status,\n198:     row.source_path,\n199:   );\n200:   const redirectTo = typeof graphMetadata.redirect_to === 'string'\n201:     ? graphMetadata.redirect_to\n202:     : (typeof derived.redirect_to === 'string' ? derived.redirect_to : null);\n203:   const redirectFrom = stringArray(graphMetadata.redirect_from ?? derived.redirect_from);\n204:   // Distinguish derivedTriggers (intent-shaped phrases) from\n205:   // derivedKeywords (entity-shaped concepts). Previously both fields were\n206:   // assigned the same array (value-by-reference), which double-counted the\n207:   // same evidence into two scoring inputs. Triggers now come from\n208:   // `derived.trigger_phrases` only; keywords come from `derived.key_topics`\n209:   // + `derived.entities` + `derived.key_files` + `derived.source_docs`. Each\n210:   // pipeline still passes through `phraseVariants` and `unique`. The two\n211:   // arrays may overlap when authors duplicate entries, but they are no longer\n212:   // assigned the same value-by-reference.\n213:   const derivedTriggers = unique(\n214:     stringArray(derived.trigger_phrases).flatMap((entry) => phraseVariants(entry)),\n215:   );\n216:   const derivedKeywords = unique([\n217:     ...stringArray(derived.key_topics),\n218:     ...stringArray(derived.entities),\n219:     ...stringArray(derived.key_files),\n220:     ...stringArray(derived.source_docs),\n221:   ].flatMap((entry) => phraseVariants(entry)));\n222: \n223:   return {\n224:     id: row.id,\n225:     kind: 'skill',\n226:     family: row.family,\n227:     category: row.category,\n228:     name: skillMd.name,\n229:     description: skillMd.description,\n230:     keywords: unique(skillMd.keywords.flatMap((entry) => phraseVariants(entry))),\n231:     domains: unique(sanitizeMetadataStringArray(jsonArray(row.domains), row.source_path).flatMap((entry) => phraseVariants(entry))),\n232:     intentSignals: unique(sanitizeMetadataStringArray(jsonArray(row.intent_signals), row.source_path).flatMap((entry) => phraseVariants(entry))),\n233:     derivedTriggers,\n234:     derivedKeywords,\n235:     derivedDemotion: boundedDemotion(derived.demotion),\n236:     // V2 derived sync stamps generated_at (the canonical author/sync time of\n237:     // the derived block); older shapes carried last_updated_at/created_at.\n238:     // generated_at leads the chain so a V2 block's real freshness wins over a\n239:     // stray legacy field. This value is AUTHOR-TIME, not runtime: rebuild\n240:     // re-indexes the existing block without re-stamping it; only a\n241:     // derived-content change through sync re-stamps generated_at.\n242:     derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n243:     sourcePath: row.source_path,\n244:     lifecycleStatus: lifecycle,\n245:     redirectTo,\n246:     redirectFrom,\n247:   };\n248: }\n249: \n250: function isoTimestampOrNull(value: unknown): string | null {\n251:   if (typeof value !== 'string' || value.trim().length === 0) return null;\n252:   return Number.isNaN(Date.parse(value)) ? null : value;\n253: }\n254: \n255: interface SkillDocRow {\n256:   readonly skill_id: string;\n257:   readonly doc_path: string;\n258:   readonly trigger_phrases: string;\n259:   readonly importance_tier: string | null;\n260: }\n\n(Showing lines 1-260 of 733. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Skill Projection\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, readdirSync } from 'node:fs';\nimport { dirname, isAbsolute, join, resolve } from 'node:path';\n\nimport Database from 'better-sqlite3';\n\nimport { getManifest } from '../embedders/registry.js';\nimport type { BackendKind } from '../embedders/types.js';\nimport { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\nimport { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\nimport { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\nimport { providerModelId } from '../skill-graph/skill-graph-db.js';\nimport { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\nimport { parseSkillFrontmatter } from '../utils/skill-markdown.js';\nimport type {\n  AdvisorEmbeddingSignature,\n  AdvisorEmbeddingStalenessVerdict,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Skill Projection\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, readdirSync } from 'node:fs';\nimport { dirname, isAbsolute, join, resolve } from 'node:path';\n\nimport Database from 'better-sqlite3';\n\nimport { getManifest } from '../embedders/registry.js';\nimport type { BackendKind } from '../embedders/types.js';\nimport { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\nimport { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\nimport { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\nimport { providerModelId } from '../skill-graph/skill-graph-db.js';\nimport { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\nimport { parseSkillFrontmatter } from '../utils/skill-markdown.js';\nimport type {\n  AdvisorEmbeddingSignature,\n  AdvisorEmbeddingStalenessVerdict,\n  AdvisorProjection,\n  SkillDocTriggerProjection,\n  SkillEdgeProjection,\n  SkillLifecycleStatus,\n  SkillProjection,\n} from './types.js';\nimport { phraseVariants, unique } from './text.js';\n\ninterface SkillNodeRow {\n  readonly id: string;\n  readonly family: string;\n  readonly category: string;\n  readonly domains: string | null;\n  readonly intent_signals: string | null;\n  readonly derived: string | null;\n  readonly source_path: string;\n}\n\ninterface SkillEdgeRow {\n  readonly source_id: string;\n  readonly target_id: string;\n  readonly edge_type: SkillEdgeProjection['edgeType'];\n  readonly weight: number;\n  readonly context: string;\n}\n\ninterface SkillMarkdownMetadata {\n  readonly name: string;\n  readonly description: string;\n  readonly keywords: readonly string[];\n}\n\nconst advisorDbDirOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\nconst SKILL_GRAPH_DB = advisorDbDirOverride\n  ? join(advisorDbDirOverride, 'skill-graph.sqlite')\n  : join('.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database', 'skill-graph.sqlite');\n\nconst COMMAND_BRIDGES: readonly SkillProjection[] = [\n  {\n    id: 'command-spec-kit',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'command-spec-kit',\n    description: 'Spec Kit command bridge for /spec_kit workflows.',\n    keywords: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n    domains: ['spec-kit', 'command'],\n    intentSignals: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'memory:save',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'memory:save',\n    description: 'Memory save command bridge for /memory:save context preservation.',\n    keywords: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n    domains: ['memory', 'command'],\n    intentSignals: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'command-memory-save',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'command-memory-save',\n    description: 'Memory save command bridge for /memory:save context preservation.',\n    keywords: ['/memory:save', 'save context', 'save memory'],\n    domains: ['memory', 'command'],\n    intentSignals: ['/memory:save', 'save context', 'save memory'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'create:agent',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'create:agent',\n    description: 'Create command bridge for /create:agent OpenCode agent scaffolding.',\n    keywords: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n    domains: ['create', 'agent', 'command'],\n    intentSignals: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'create:manual-testing-playbook',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'create:manual-testing-playbook',\n    description: 'Create command bridge for /create:manual-testing-playbook manual testing playbook scaffolding.',\n    keywords: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n    domains: ['create', 'testing', 'playbook', 'command'],\n    intentSignals: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'deep-model-benchmark',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'deep-model-benchmark',\n    description: 'Deep command bridge for /deep:start-model-benchmark-loop model and prompt-framework benchmarking.',\n    keywords: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n    domains: ['deep', 'benchmark', 'model', 'command'],\n    intentSignals: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n];\n\nfunction jsonArray(value: string | null | undefined): string[] {\n  return value ? parseJsonStringArray(value) : [];\n}\n\nfunction jsonObject(value: string | null | undefined): Record<string, unknown> {\n  return value ? parseJsonObject(value) ?? {} : {};\n}\n\nfunction stringArray(value: unknown): string[] {\n  return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n}\n\nfunction boundedDemotion(value: unknown): number | undefined {\n  return typeof value === 'number' && Number.isFinite(value)\n    ? Math.max(0, Math.min(1, value))\n    : undefined;\n}\n\nfunction readJson(filePath: string): Record<string, unknown> {\n  return readJsonObject(filePath) ?? {};\n}\n\nfunction parseSkillMarkdown(skillMdPath: string, fallbackId: string): SkillMarkdownMetadata {\n  if (!existsSync(skillMdPath)) {\n    return { name: fallbackId, description: '', keywords: [] };\n  }\n  const { frontmatter, keywords } = parseSkillFrontmatter(readFileSync(skillMdPath, 'utf8'));\n  return {\n    name: frontmatter.name || fallbackId,\n    description: frontmatter.description || '',\n    keywords,\n  };\n}\n\nfunction lifecycleStatus(raw: unknown, sourcePath: string): SkillLifecycleStatus {\n  if (raw === 'deprecated' || raw === 'archived' || raw === 'future' || raw === 'active') return raw;\n  const pathStatus = lifecycleStatusForPath(sourcePath);\n  return pathStatus === 'archived' || pathStatus === 'future' ? pathStatus : 'active';\n}\n\nfunction projectionFromRow(row: SkillNodeRow): SkillProjection {\n  const derived = sanitizeDerivedMetadata(jsonObject(row.derived), row.source_path) ?? {};\n  const graphMetadata = readJson(row.source_path);\n  const skillDir = dirname(row.source_path);\n  const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), row.id);\n  const lifecycle = lifecycleStatus(\n    graphMetadata.lifecycle_status ?? derived.lifecycle_status,\n    row.source_path,\n  );\n  const redirectTo = typeof graphMetadata.redirect_to === 'string'\n    ? graphMetadata.redirect_to\n    : (typeof derived.redirect_to === 'string' ? derived.redirect_to : null);\n  const redirectFrom = stringArray(graphMetadata.redirect_from ?? derived.redirect_from);\n  // Distinguish derivedTriggers (intent-shaped phrases) from\n  // derivedKeywords (entity-shaped concepts). Previously both fields were\n  // assigned the same array (value-by-reference), which double-counted the\n  // same evidence into two scoring inputs. Triggers now come from\n  // `derived.trigger_phrases` only; keywords come from `derived.key_topics`\n  // + `derived.entities` + `derived.key_files` + `derived.source_docs`. Each\n  // pipeline still passes through `phraseVariants` and `unique`. The two\n  // arrays may overlap when authors duplicate entries, but they are no longer\n  // assigned the same value-by-reference.\n  const derivedTriggers = unique(\n    stringArray(derived.trigger_phrases).flatMap((entry) => phraseVariants(entry)),\n  );\n  const derivedKeywords = unique([\n    ...stringArray(derived.key_topics),\n    ...stringArray(derived.entities),\n    ...stringArray(derived.key_files),\n    ...stringArray(derived.source_docs),\n  ].flatMap((entry) => phraseVariants(entry)));\n\n  return {\n    id: row.id,\n    kind: 'skill',\n    family: row.family,\n    category: row.category,\n    name: skillMd.name,\n    description: skillMd.description,\n    keywords: unique(skillMd.keywords.flatMap((entry) => phraseVariants(entry))),\n    domains: unique(sanitizeMetadataStringArray(jsonArray(row.domains), row.source_path).flatMap((entry) => phraseVariants(entry))),\n    intentSignals: unique(sanitizeMetadataStringArray(jsonArray(row.intent_signals), row.source_path).flatMap((entry) => phraseVariants(entry))),\n    derivedTriggers,\n    derivedKeywords,\n    derivedDemotion: boundedDemotion(derived.demotion),\n    // V2 derived sync stamps generated_at (the canonical author/sync time of\n    // the derived block); older shapes carried last_updated_at/created_at.\n    // generated_at leads the chain so a V2 block's real freshness wins over a\n    // stray legacy field. This value is AUTHOR-TIME, not runtime: rebuild\n    // re-indexes the existing block without re-stamping it; only a\n    // derived-content change through sync re-stamps generated_at.\n    derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n    sourcePath: row.source_path,\n    lifecycleStatus: lifecycle,\n    redirectTo,\n    redirectFrom,\n  };\n}\n\nfunction isoTimestampOrNull(value: unknown): string | null {\n  if (typeof value !== 'string' || value.trim().length === 0) return null;\n  return Number.isNaN(Date.parse(value)) ? null : value;\n}\n\ninterface SkillDocRow {\n  readonly skill_id: string;\n  readonly doc_path: string;\n  readonly trigger_phrases: string;\n  readonly importance_tier: string | null;\n}","lineStart":1,"lineEnd":260,"totalLines":733,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","time":{"start":1783437204123,"end":1783437204126}},"metadata":{"openai":{"itemId":"fc_01433b4e1c6a40b2016a4d1793f14c81919130470c79f530b7"}},"id":"prt_f3d241a45001z7uc2LMvwGoP4q","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d23ed9f0012KwRthplxOVxFx"}}
{"type":"tool_use","timestamp":1783437204138,"sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","part":{"type":"tool","tool":"read","callID":"call_nTC85FrOuSGtwfrQtcV6ZmEZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor 5-Lane Fusion\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n6: \n7: import { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\n8: import { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\n9: import {\n10:   ADVISOR_HOOK_FRESHNESS_VALUES,\n11:   ADVISOR_RUNTIME_VALUES,\n12:   isSpeckitMetricsEnabled,\n13:   speckitMetrics,\n14: } from '../metrics.js';\n15: import { normalize } from '../affordance-normalizer.js';\n16: import { scoreDerivedLane } from './lanes/derived.js';\n17: import { scoreExplicitLane } from './lanes/explicit.js';\n18: import { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\n19: import { scoreLexicalLane } from './lanes/lexical.js';\n20: import { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\n21: import { applyExecutorDelegationOverride } from './executor-delegation.js';\n22: import { loadAdvisorProjection } from './projection.js';\n23: import { SCORING_CALIBRATION } from './scoring-constants.js';\n24: import { isReadOnlyExplainer, matchesPhraseBoundary } from './text.js';\n25: import {\n26:   DEFAULT_SCORER_WEIGHTS,\n27:   SCORER_LANES,\n28:   liveWeightTotal,\n29: } from './weights-config.js';\n30: import { isLiveScorerLane } from './lane-registry.js';\n31: import { SKILL_ADVISOR_COMPAT_CONTRACT, resolvedConfidenceThreshold, resolvedUncertaintyThreshold } from '../compat/contract.js';\n32: import type {\n33:   AdvisorProjection,\n34:   AdvisorScoredRecommendation,\n35:   AdvisorScoringOptions,\n36:   AdvisorScoringResult,\n37:   LaneContribution,\n38:   LaneMatch,\n39:   LaneRuntimeHealth,\n40:   LaneScores,\n41:   ScorerLane,\n42:   SkillProjection,\n43: } from './types.js';\n44: import type { NormalizedAffordance } from '../affordance-normalizer.js';\n45: import type { RankedList, RrfItem } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n46: \n47: const DEFAULT_CONFIDENCE_THRESHOLD = resolvedConfidenceThreshold();\n48: const DEFAULT_UNCERTAINTY_THRESHOLD = resolvedUncertaintyThreshold();\n49: export const ADVISOR_RRF_FUSION_FLAG = 'SPECKIT_ADVISOR_RRF_FUSION';\n50: export const ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG = 'SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD';\n51: export const ADVISOR_QUERY_CLASS_ROUTING_FLAG = 'SPECKIT_ADVISOR_QUERY_CLASS_ROUTING';\n52: export const ADVISOR_EXACT_SEMANTIC_RERANK_FLAG = 'SPECKIT_ADVISOR_EXACT_SEMANTIC_RERANK';\n53: export const ADVISOR_RRF_K = 8;\n54: export const ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K = 10;\n55: const ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW = 0.05;\n56: const TASK_INTENT = /\\b(add|append|build|change|configure|create|edit|fix|generate|implement|modify|move|patch|refactor|rename|replace|run|start|sweep|update|write)\\b/;\n57: const DEEP_RESEARCH_CYCLE = /\\b(automated research cycle|looped investigation|continue iteration|resume iteration|overnight run|overnight research run|packet-local iteration|delta record|canonical jsonl|same lineage)\\b/;\n58: const FILE_SAVE_OPERATION = /\\bsave\\b.{0,48}\\b(file|files|document|documents|buffer|tab|workspace)\\b|\\b(file|files|document|documents|buffer|tab|workspace)\\b.{0,48}\\bsave\\b/;\n59: const MEMORY_SAVE_CONTEXT_ANCHOR = /\\b(memory|context|conversation|session|handover|checkpoint|resume|preserve|remember|capture|store)\\b|\\/memory:save|memory:save/;\n60: // Class C breadth/multi-concern abstention gates. A broad greenfield build or a\n61: // multi-concern optimization is under-specified for single-skill routing.\n62: const BREADTH_BUILD_VERB = /\\b(build|create|implement|generate|scaffold)\\b/;\n63: const BREADTH_NOUN = /\\b(full[- ]?stack|service|platform|application|microservice|saas|backend|whole (app|system))\\b/;\n64: // Narrow anchors that make a broad-build prompt specific enough to route.\n65: const BREADTH_NARROW_ANCHOR = /\\.[a-z]{2,4}\\b|\\b(test|tests|error|bug|failure|failing|handler|component|function|route|endpoint|class|method|benchmark|review|audit|migration|schema)\\b/;\n66: const MULTI_CONCERN_VERB = /\\b(optimize|improve|enhance|harden|speed up)\\b/;\n67: const CONCERN_PERF = /\\b(speed|latency|execution|throughput|performance|startup|memory|cpu)\\b/;\n68: const CONCERN_QUALITY = /\\b(quality|accuracy|recommendation|recommendations|correctness|reliability|coverage)\\b/;\n69: const TRUE_FLAG_VALUES = new Set(['1', 'true', 'yes', 'on', 'enabled']);\n70: const NO_RRF_RANK = Number.MAX_SAFE_INTEGER;\n71: const ADVISOR_SELF_RECOMMENDATION_SKILL_IDS = new Set(['system-skill-advisor', 'skill-advisor']);\n72: \n73: type MutableLaneScores = {\n74:   -readonly [K in keyof LaneScores]: LaneMatch[];\n75: };\n76: \n77: interface LaneScoreBundle {\n78:   readonly laneScores: LaneScores;\n79:   readonly graphConflictMatches: readonly LaneMatch[];\n80: }\n81: \n82: interface AdvisorRrfFusion {\n83:   readonly scoreBySkill: ReadonlyMap<string, number>;\n84:   readonly rankBySkill: ReadonlyMap<string, number>;\n85: }\n86: \n87: type AdvisorRuntimeLabel = (typeof ADVISOR_RUNTIME_VALUES)[number];\n88: type AdvisorFreshnessLabel = (typeof ADVISOR_HOOK_FRESHNESS_VALUES)[number];\n89: export type AdvisorQueryClass = 'implementation' | 'review' | 'documentation' | 'memory' | 'tooling' | 'unknown';\n90: \n91: interface ExactSemanticRerankEntry {\n92:   readonly rawScore: number;\n93: }\n94: \n95: type ExactSemanticRerankIndex = ReadonlyMap<string, ExactSemanticRerankEntry>;\n96: \n97: function emptyLaneScores(): MutableLaneScores {\n98:   return Object.fromEntries(SCORER_LANES.map((lane) => [lane, []])) as unknown as MutableLaneScores;\n99: }\n100: \n101: export function isAdvisorRrfFusionEnabled(): boolean {\n102:   const value = process.env[ADVISOR_RRF_FUSION_FLAG]?.trim().toLowerCase();\n103:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n104: }\n105: \n106: export function isAdvisorSelfRecommendationGuardEnabled(): boolean {\n107:   const value = process.env[ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG]?.trim().toLowerCase();\n108:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n109: }\n110: \n111: export function isAdvisorQueryClassRoutingEnabled(): boolean {\n112:   const value = process.env[ADVISOR_QUERY_CLASS_ROUTING_FLAG]?.trim().toLowerCase();\n113:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n114: }\n115: \n116: export function isAdvisorExactSemanticRerankEnabled(): boolean {\n117:   const value = process.env[ADVISOR_EXACT_SEMANTIC_RERANK_FLAG]?.trim().toLowerCase();\n118:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n119: }\n120: \n121: export function classifyAdvisorQuery(prompt: string): AdvisorQueryClass {\n122:   const promptLower = prompt.toLowerCase();\n123:   if (/\\b(save context|save memory|handover|resume|checkpoint|spec folder|implementation summary|packet docs?)\\b/.test(promptLower)) {\n124:     return 'memory';\n125:   }\n126:   if (/\\b(review|audit|findings|regression|pull request|pr readiness|release readiness)\\b/.test(promptLower)) {\n127:     return 'review';\n128:   }\n129:   if (/\\b(readme|markdown|documentation|docs|manual testing playbook|feature catalog|taxonomy)\\b/.test(promptLower)) {\n130:     return 'documentation';\n131:   }\n132:   if (/\\b(call_tool_chain|code mode|tool ?chain|chrome devtools|browser console|figma|github|clickup)\\b/.test(promptLower)) {\n133:     return 'tooling';\n134:   }\n135:   if (TASK_INTENT.test(promptLower) || /\\b(typescript|javascript|python|vitest|mcp|handler|schema|fixture)\\b/.test(promptLower)) {\n136:     return 'implementation';\n137:   }\n138:   return 'unknown';\n139: }\n140: \n141: export function queryClassLaneMultipliers(queryClass: AdvisorQueryClass): Readonly<Partial<Record<ScorerLane, number>>> {\n142:   switch (queryClass) {\n143:     case 'implementation':\n144:       return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.98, semantic_shadow: 1.00 };\n145:     case 'review':\n146:       return { explicit_author: 1.03, lexical: 1.02, graph_causal: 0.96, derived_generated: 0.98, semantic_shadow: 1.00 };\n147:     case 'documentation':\n148:       return { explicit_author: 1.03, lexical: 0.98, graph_causal: 0.95, derived_generated: 1.04, semantic_shadow: 1.00 };\n149:     case 'memory':\n150:       return { explicit_author: 1.04, lexical: 0.98, graph_causal: 1.02, derived_generated: 1.00, semantic_shadow: 0.96 };\n151:     case 'tooling':\n152:       return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.96, semantic_shadow: 1.00 };\n153:     case 'unknown':\n154:       return {};\n155:   }\n156: }\n157: \n158: export function applyQueryClassLaneMultipliers(\n159:   weights: Readonly<Record<ScorerLane, number>>,\n160:   queryClass: AdvisorQueryClass,\n161: ): Readonly<Record<ScorerLane, number>> {\n162:   const multipliers = queryClassLaneMultipliers(queryClass);\n163:   if (Object.keys(multipliers).length === 0) return weights;\n164:   const next = { ...weights };\n165:   for (const lane of SCORER_LANES) {\n166:     const multiplier = multipliers[lane];\n167:     if (typeof multiplier === 'number' && Number.isFinite(multiplier)) {\n168:       next[lane] = Number((next[lane] * multiplier).toFixed(6));\n169:     }\n170:   }\n171:   const strongestOther = Math.max(...SCORER_LANES\n172:     .filter((lane) => lane !== 'explicit_author')\n173:     .map((lane) => next[lane]));\n174:   if (next.explicit_author < strongestOther) {\n175:     next.explicit_author = Number(strongestOther.toFixed(6));\n176:   }\n177:   return next;\n178: }\n179: \n180: function effectiveScorerWeights(\n181:   override: AdvisorScoringOptions['laneWeightsOverride'] | undefined,\n182:   queryClass: AdvisorQueryClass = 'unknown',\n183: ): Readonly<Record<ScorerLane, number>> {\n184:   const base = !override ? DEFAULT_SCORER_WEIGHTS : (() => {\n185:     const weights: Record<ScorerLane, number> = { ...DEFAULT_SCORER_WEIGHTS };\n186:     const runtimeOverride = override as Partial<Record<string, number>>;\n187:     for (const lane of SCORER_LANES) {\n188:       const value = runtimeOverride[lane];\n189:       if (typeof value === 'number' && Number.isFinite(value)) {\n190:         weights[lane] = value;\n191:       }\n192:     }\n193:     return weights;\n194:   })();\n195:   if (queryClass === 'unknown') return base;\n196:   return applyQueryClassLaneMultipliers(base, queryClass);\n197: }\n198: \n199: function normalizeRuntimeLabel(value: string | undefined): AdvisorRuntimeLabel | null {\n200:   if (value === undefined) {\n201:     return null;\n202:   }\n203:   return ADVISOR_RUNTIME_VALUES.includes(value as AdvisorRuntimeLabel) ? value as AdvisorRuntimeLabel : null;\n204: }\n205: \n206: function normalizeFreshnessLabel(value: string | undefined): AdvisorFreshnessLabel | null {\n207:   if (value === undefined) {\n208:     return 'unavailable';\n209:   }\n210:   return ADVISOR_HOOK_FRESHNESS_VALUES.includes(value as AdvisorFreshnessLabel) ? value as AdvisorFreshnessLabel : null;\n211: }\n212: \n213: interface LaneMatchIndexEntry {\n214:   rawScore: number;\n215:   evidence: string[];\n216:   producerSkillIds: string[];\n217: }\n218: \n219: type LaneMatchIndex = Map<string, LaneMatchIndexEntry>;\n220: \n221: function buildLaneRuntimeHealth(\n222:   laneScores: LaneScores,\n223:   disabled: ReadonlySet<ScorerLane>,\n224:   runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n225: ): readonly LaneRuntimeHealth[] {\n226:   return SCORER_LANES.map((lane): LaneRuntimeHealth => {\n227:     const matchCount = laneScores[lane].length;\n228:     const signal = runtimeLaneHealth?.[lane];\n229:     if (!disabled.has(lane) && signal?.status === 'runtime_degraded' && matchCount === 0) {\n230:       return {\n231:         lane,\n232:         status: 'runtime_degraded',\n233:         matchCount,\n234:         ...(signal.reason ? { reason: signal.reason } : {}),\n235:       };\n236:     }\n237:     return {\n238:       lane,\n239:       status: matchCount > 0 ? 'healthy' : 'matched_nothing',\n240:       matchCount,\n241:       ...(signal?.reason && signal.status === 'healthy' ? { reason: signal.reason } : {}),\n242:     };\n243:   });\n244: }\n245: \n246: function projectionRuntimeLaneHealth(\n247:   projection: AdvisorProjection,\n248:   runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n249: ): AdvisorScoringOptions['runtimeLaneHealth'] | undefined {\n250:   if (!projection.embeddingStaleness?.stale) {\n251:     return runtimeLaneHealth;\n252:   }\n253:   return {\n254:     ...runtimeLaneHealth,\n255:     semantic_shadow: runtimeLaneHealth?.semantic_shadow ?? {\n256:       status: 'runtime_degraded',\n257:       reason: projection.embeddingStaleness.reason ?? 'projection_embedding_stale',\n258:     },\n259:   };\n260: }\n\n(Showing lines 1-260 of 911. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor 5-Lane Fusion\n// ───────────────────────────────────────────────────────────────\n\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nimport { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\nimport { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\nimport {\n  ADVISOR_HOOK_FRESHNESS_VALUES,\n  ADVISOR_RUNTIME_VALUES,\n  isSpeckitMetricsEnabled,\n  speckitMetrics,\n} from '../metrics.js';\nimport { normalize } from '../affordance-normalizer.js';\nimport { scoreDerivedLane } from './lanes/derived.js';\nimport { scoreExplicitLane } from './lanes/explicit.js';\nimport { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\nimport { scoreLexicalLane } from './lanes/lexical.js';\nimport { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor 5-Lane Fusion\n// ───────────────────────────────────────────────────────────────\n\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nimport { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\nimport { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\nimport {\n  ADVISOR_HOOK_FRESHNESS_VALUES,\n  ADVISOR_RUNTIME_VALUES,\n  isSpeckitMetricsEnabled,\n  speckitMetrics,\n} from '../metrics.js';\nimport { normalize } from '../affordance-normalizer.js';\nimport { scoreDerivedLane } from './lanes/derived.js';\nimport { scoreExplicitLane } from './lanes/explicit.js';\nimport { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\nimport { scoreLexicalLane } from './lanes/lexical.js';\nimport { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\nimport { applyExecutorDelegationOverride } from './executor-delegation.js';\nimport { loadAdvisorProjection } from './projection.js';\nimport { SCORING_CALIBRATION } from './scoring-constants.js';\nimport { isReadOnlyExplainer, matchesPhraseBoundary } from './text.js';\nimport {\n  DEFAULT_SCORER_WEIGHTS,\n  SCORER_LANES,\n  liveWeightTotal,\n} from './weights-config.js';\nimport { isLiveScorerLane } from './lane-registry.js';\nimport { SKILL_ADVISOR_COMPAT_CONTRACT, resolvedConfidenceThreshold, resolvedUncertaintyThreshold } from '../compat/contract.js';\nimport type {\n  AdvisorProjection,\n  AdvisorScoredRecommendation,\n  AdvisorScoringOptions,\n  AdvisorScoringResult,\n  LaneContribution,\n  LaneMatch,\n  LaneRuntimeHealth,\n  LaneScores,\n  ScorerLane,\n  SkillProjection,\n} from './types.js';\nimport type { NormalizedAffordance } from '../affordance-normalizer.js';\nimport type { RankedList, RrfItem } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nconst DEFAULT_CONFIDENCE_THRESHOLD = resolvedConfidenceThreshold();\nconst DEFAULT_UNCERTAINTY_THRESHOLD = resolvedUncertaintyThreshold();\nexport const ADVISOR_RRF_FUSION_FLAG = 'SPECKIT_ADVISOR_RRF_FUSION';\nexport const ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG = 'SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD';\nexport const ADVISOR_QUERY_CLASS_ROUTING_FLAG = 'SPECKIT_ADVISOR_QUERY_CLASS_ROUTING';\nexport const ADVISOR_EXACT_SEMANTIC_RERANK_FLAG = 'SPECKIT_ADVISOR_EXACT_SEMANTIC_RERANK';\nexport const ADVISOR_RRF_K = 8;\nexport const ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K = 10;\nconst ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW = 0.05;\nconst TASK_INTENT = /\\b(add|append|build|change|configure|create|edit|fix|generate|implement|modify|move|patch|refactor|rename|replace|run|start|sweep|update|write)\\b/;\nconst DEEP_RESEARCH_CYCLE = /\\b(automated research cycle|looped investigation|continue iteration|resume iteration|overnight run|overnight research run|packet-local iteration|delta record|canonical jsonl|same lineage)\\b/;\nconst FILE_SAVE_OPERATION = /\\bsave\\b.{0,48}\\b(file|files|document|documents|buffer|tab|workspace)\\b|\\b(file|files|document|documents|buffer|tab|workspace)\\b.{0,48}\\bsave\\b/;\nconst MEMORY_SAVE_CONTEXT_ANCHOR = /\\b(memory|context|conversation|session|handover|checkpoint|resume|preserve|remember|capture|store)\\b|\\/memory:save|memory:save/;\n// Class C breadth/multi-concern abstention gates. A broad greenfield build or a\n// multi-concern optimization is under-specified for single-skill routing.\nconst BREADTH_BUILD_VERB = /\\b(build|create|implement|generate|scaffold)\\b/;\nconst BREADTH_NOUN = /\\b(full[- ]?stack|service|platform|application|microservice|saas|backend|whole (app|system))\\b/;\n// Narrow anchors that make a broad-build prompt specific enough to route.\nconst BREADTH_NARROW_ANCHOR = /\\.[a-z]{2,4}\\b|\\b(test|tests|error|bug|failure|failing|handler|component|function|route|endpoint|class|method|benchmark|review|audit|migration|schema)\\b/;\nconst MULTI_CONCERN_VERB = /\\b(optimize|improve|enhance|harden|speed up)\\b/;\nconst CONCERN_PERF = /\\b(speed|latency|execution|throughput|performance|startup|memory|cpu)\\b/;\nconst CONCERN_QUALITY = /\\b(quality|accuracy|recommendation|recommendations|correctness|reliability|coverage)\\b/;\nconst TRUE_FLAG_VALUES = new Set(['1', 'true', 'yes', 'on', 'enabled']);\nconst NO_RRF_RANK = Number.MAX_SAFE_INTEGER;\nconst ADVISOR_SELF_RECOMMENDATION_SKILL_IDS = new Set(['system-skill-advisor', 'skill-advisor']);\n\ntype MutableLaneScores = {\n  -readonly [K in keyof LaneScores]: LaneMatch[];\n};\n\ninterface LaneScoreBundle {\n  readonly laneScores: LaneScores;\n  readonly graphConflictMatches: readonly LaneMatch[];\n}\n\ninterface AdvisorRrfFusion {\n  readonly scoreBySkill: ReadonlyMap<string, number>;\n  readonly rankBySkill: ReadonlyMap<string, number>;\n}\n\ntype AdvisorRuntimeLabel = (typeof ADVISOR_RUNTIME_VALUES)[number];\ntype AdvisorFreshnessLabel = (typeof ADVISOR_HOOK_FRESHNESS_VALUES)[number];\nexport type AdvisorQueryClass = 'implementation' | 'review' | 'documentation' | 'memory' | 'tooling' | 'unknown';\n\ninterface ExactSemanticRerankEntry {\n  readonly rawScore: number;\n}\n\ntype ExactSemanticRerankIndex = ReadonlyMap<string, ExactSemanticRerankEntry>;\n\nfunction emptyLaneScores(): MutableLaneScores {\n  return Object.fromEntries(SCORER_LANES.map((lane) => [lane, []])) as unknown as MutableLaneScores;\n}\n\nexport function isAdvisorRrfFusionEnabled(): boolean {\n  const value = process.env[ADVISOR_RRF_FUSION_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorSelfRecommendationGuardEnabled(): boolean {\n  const value = process.env[ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorQueryClassRoutingEnabled(): boolean {\n  const value = process.env[ADVISOR_QUERY_CLASS_ROUTING_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorExactSemanticRerankEnabled(): boolean {\n  const value = process.env[ADVISOR_EXACT_SEMANTIC_RERANK_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function classifyAdvisorQuery(prompt: string): AdvisorQueryClass {\n  const promptLower = prompt.toLowerCase();\n  if (/\\b(save context|save memory|handover|resume|checkpoint|spec folder|implementation summary|packet docs?)\\b/.test(promptLower)) {\n    return 'memory';\n  }\n  if (/\\b(review|audit|findings|regression|pull request|pr readiness|release readiness)\\b/.test(promptLower)) {\n    return 'review';\n  }\n  if (/\\b(readme|markdown|documentation|docs|manual testing playbook|feature catalog|taxonomy)\\b/.test(promptLower)) {\n    return 'documentation';\n  }\n  if (/\\b(call_tool_chain|code mode|tool ?chain|chrome devtools|browser console|figma|github|clickup)\\b/.test(promptLower)) {\n    return 'tooling';\n  }\n  if (TASK_INTENT.test(promptLower) || /\\b(typescript|javascript|python|vitest|mcp|handler|schema|fixture)\\b/.test(promptLower)) {\n    return 'implementation';\n  }\n  return 'unknown';\n}\n\nexport function queryClassLaneMultipliers(queryClass: AdvisorQueryClass): Readonly<Partial<Record<ScorerLane, number>>> {\n  switch (queryClass) {\n    case 'implementation':\n      return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.98, semantic_shadow: 1.00 };\n    case 'review':\n      return { explicit_author: 1.03, lexical: 1.02, graph_causal: 0.96, derived_generated: 0.98, semantic_shadow: 1.00 };\n    case 'documentation':\n      return { explicit_author: 1.03, lexical: 0.98, graph_causal: 0.95, derived_generated: 1.04, semantic_shadow: 1.00 };\n    case 'memory':\n      return { explicit_author: 1.04, lexical: 0.98, graph_causal: 1.02, derived_generated: 1.00, semantic_shadow: 0.96 };\n    case 'tooling':\n      return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.96, semantic_shadow: 1.00 };\n    case 'unknown':\n      return {};\n  }\n}\n\nexport function applyQueryClassLaneMultipliers(\n  weights: Readonly<Record<ScorerLane, number>>,\n  queryClass: AdvisorQueryClass,\n): Readonly<Record<ScorerLane, number>> {\n  const multipliers = queryClassLaneMultipliers(queryClass);\n  if (Object.keys(multipliers).length === 0) return weights;\n  const next = { ...weights };\n  for (const lane of SCORER_LANES) {\n    const multiplier = multipliers[lane];\n    if (typeof multiplier === 'number' && Number.isFinite(multiplier)) {\n      next[lane] = Number((next[lane] * multiplier).toFixed(6));\n    }\n  }\n  const strongestOther = Math.max(...SCORER_LANES\n    .filter((lane) => lane !== 'explicit_author')\n    .map((lane) => next[lane]));\n  if (next.explicit_author < strongestOther) {\n    next.explicit_author = Number(strongestOther.toFixed(6));\n  }\n  return next;\n}\n\nfunction effectiveScorerWeights(\n  override: AdvisorScoringOptions['laneWeightsOverride'] | undefined,\n  queryClass: AdvisorQueryClass = 'unknown',\n): Readonly<Record<ScorerLane, number>> {\n  const base = !override ? DEFAULT_SCORER_WEIGHTS : (() => {\n    const weights: Record<ScorerLane, number> = { ...DEFAULT_SCORER_WEIGHTS };\n    const runtimeOverride = override as Partial<Record<string, number>>;\n    for (const lane of SCORER_LANES) {\n      const value = runtimeOverride[lane];\n      if (typeof value === 'number' && Number.isFinite(value)) {\n        weights[lane] = value;\n      }\n    }\n    return weights;\n  })();\n  if (queryClass === 'unknown') return base;\n  return applyQueryClassLaneMultipliers(base, queryClass);\n}\n\nfunction normalizeRuntimeLabel(value: string | undefined): AdvisorRuntimeLabel | null {\n  if (value === undefined) {\n    return null;\n  }\n  return ADVISOR_RUNTIME_VALUES.includes(value as AdvisorRuntimeLabel) ? value as AdvisorRuntimeLabel : null;\n}\n\nfunction normalizeFreshnessLabel(value: string | undefined): AdvisorFreshnessLabel | null {\n  if (value === undefined) {\n    return 'unavailable';\n  }\n  return ADVISOR_HOOK_FRESHNESS_VALUES.includes(value as AdvisorFreshnessLabel) ? value as AdvisorFreshnessLabel : null;\n}\n\ninterface LaneMatchIndexEntry {\n  rawScore: number;\n  evidence: string[];\n  producerSkillIds: string[];\n}\n\ntype LaneMatchIndex = Map<string, LaneMatchIndexEntry>;\n\nfunction buildLaneRuntimeHealth(\n  laneScores: LaneScores,\n  disabled: ReadonlySet<ScorerLane>,\n  runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n): readonly LaneRuntimeHealth[] {\n  return SCORER_LANES.map((lane): LaneRuntimeHealth => {\n    const matchCount = laneScores[lane].length;\n    const signal = runtimeLaneHealth?.[lane];\n    if (!disabled.has(lane) && signal?.status === 'runtime_degraded' && matchCount === 0) {\n      return {\n        lane,\n        status: 'runtime_degraded',\n        matchCount,\n        ...(signal.reason ? { reason: signal.reason } : {}),\n      };\n    }\n    return {\n      lane,\n      status: matchCount > 0 ? 'healthy' : 'matched_nothing',\n      matchCount,\n      ...(signal?.reason && signal.status === 'healthy' ? { reason: signal.reason } : {}),\n    };\n  });\n}\n\nfunction projectionRuntimeLaneHealth(\n  projection: AdvisorProjection,\n  runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n): AdvisorScoringOptions['runtimeLaneHealth'] | undefined {\n  if (!projection.embeddingStaleness?.stale) {\n    return runtimeLaneHealth;\n  }\n  return {\n    ...runtimeLaneHealth,\n    semantic_shadow: runtimeLaneHealth?.semantic_shadow ?? {\n      status: 'runtime_degraded',\n      reason: projection.embeddingStaleness.reason ?? 'projection_embedding_stale',\n    },\n  };\n}","lineStart":1,"lineEnd":260,"totalLines":911,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1783437204132,"end":1783437204137}},"metadata":{"openai":{"itemId":"fc_01433b4e1c6a40b2016a4d1793f160819199bc2b3a0b41433e"}},"id":"prt_f3d241a9c001dLNbQ8cXGH4Jkk","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d23ed9f0012KwRthplxOVxFx"}}
