 options.researchTopic) {\n1038:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1039:   }\n1040: \n1041:   return [\n1042:     args.join(' '),\n1043:     '',\n1044:     'PRE-BOUND SETUP ANSWERS:',\n1045:     `review_target: ${specFolder}`,\n1046:     'review_target_type: spec-folder',\n1047:     'review_dimensions: all',\n1048:     `spec_folder: ${specFolder}`,\n1049:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1050:     'execution_mode: AUTONOMOUS',\n1051:     'lineage_mode: auto',\n1052:     `maxIterations: ${maxIterations}`,\n1053:     `convergenceThreshold: ${convergenceThreshold}`,\n1054:     `stop_policy: ${stopPolicy}`,\n1055:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1056:   ].join('\\n');\n1057: }\n1058: \n1059: /**\n1060:  * Compute a generous timeout for a full lineage loop run.\n1061:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1062:  * We double it for safety and cap at 4 hours.\n1063:  */\n1064: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1065:   const iters = lineage.iterations || 12;\n1066:   const perIterSecs = lineage.timeoutSeconds || 900;\n1067:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1068:     ? ceilingHoursOverride * 60 * 60 * 1000\n1069:     : 4 * 60 * 60 * 1000;\n1070:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1071: }\n1072: \n1073: function normalizeProgressHeartbeatMs(seconds) {\n1074:   const value = Number(seconds);\n1075:   if (!Number.isFinite(value) || value <= 0) return 0;\n1076:   return Math.max(1, Math.floor(value * 1000));\n1077: }\n1078: \n1079: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1080:   const explicit = readRawConfigNumber(rawConfig, [\n1081:     'postExitGraceMs',\n1082:     'post_exit_grace_ms',\n1083:     'postSubprocessExitGraceMs',\n1084:     'post_subprocess_exit_grace_ms',\n1085:     'orchestratorPostExitGraceMs',\n1086:     'orchestrator_post_exit_grace_ms',\n1087:   ], 'postExitGraceMs');\n1088:   if (explicit !== null) return explicit;\n1089: \n1090:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1091:     ? progressHeartbeatMs * 2\n1092:     : 0;\n1093:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1094: }\n1095: \n1096: function slotDurationMsFromHrtime(hrStart) {\n1097:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1098:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1099: }\n1100: \n1101: function computeSkippedCount(slotDurationMs, intervalMs) {\n1102:   const elapsed = Number(slotDurationMs);\n1103:   const interval = Number(intervalMs);\n1104:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1105:     return 0;\n1106:   }\n1107:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1108: }\n1109: \n1110: function buildSlotAccounting(hrStart, intervalMs) {\n1111:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1112:   return {\n1113:     slotDurationMs,\n1114:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1115:   };\n1116: }\n1117: \n1118: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1119:   if (!event || typeof event.label !== 'string') return event;\n1120:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1121: \n1122:   const accounting = accountingByLabel.get(event.label);\n1123:   if (!accounting) return event;\n1124:   return {\n1125:     ...event,\n1126:     skippedCount: accounting.skippedCount,\n1127:     slotDurationMs: accounting.slotDurationMs,\n1128:   };\n1129: }\n1130: \n1131: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1132:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1133:     return () => {};\n1134:   }\n1135:   const startedAtMs = Date.now();\n1136:   const timer = setInterval(() => {\n1137:     appendFanoutStatusLedger(ledgerPath, {\n1138:       event: 'progress',\n1139:       label,\n1140:       at: new Date().toISOString(),\n1141:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1142:         gauges: getGauges(),\n1143:       });\n1144:       if (typeof onProgress === 'function') onProgress();\n1145:     }, cadenceMs);\n1146:   timer.unref?.();\n1147:   return () => clearInterval(timer);\n1148: }\n1149: \n1150: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1151:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1152:     return () => {};\n1153:   }\n1154: \n1155:   let timer = null;\n1156:   let fired = false;\n1157:   const schedule = () => {\n1158:     if (fired) return;\n1159:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n\n(Showing lines 1010-1159 of 1871. Use offset=1160 to continue.)\n</content>","metadata":{"preview":"    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : 4 * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n  const explicit = readRawConfigNumber(rawConfig, [\n    'postExitGraceMs',\n    'post_exit_grace_ms',\n    'postSubprocessExitGraceMs',\n    'post_subprocess_exit_grace_ms',\n    'orchestratorPostExitGraceMs',\n    'orchestrator_post_exit_grace_ms',\n  ], 'postExitGraceMs');\n  if (explicit !== null) return explicit;\n\n  const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n    ? progressHeartbeatMs * 2\n    : 0;\n  return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n}\n\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,\n      at: new Date().toISOString(),\n      duration_ms: Math.max(0, Date.now() - startedAtMs),\n        gauges: getGauges(),\n      });\n      if (typeof onProgress === 'function') onProgress();\n    }, cadenceMs);\n  timer.unref?.();\n  return () => clearInterval(timer);\n}\n\nfunction startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n  if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n    return () => {};\n  }\n\n  let timer = null;\n  let fired = false;\n  const schedule = () => {\n    if (fired) return;\n    const quietMs = Math.max(0, Date.now() - getLastEventAtMs());","lineStart":1010,"lineEnd":1159,"totalLines":1871,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783487742261,"end":1783487742288}},"metadata":{"openai":{"itemId":"fc_052459e0b1e9bdef016a4ddcfe1e188191a142870c0c8f3b76"}},"id":"prt_f4027411f0016oPtMopE07ZhEs","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f402702d4001mwmUsz8AwO4zF7"}}
{"type":"tool_use","timestamp":1783487742290,"sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","part":{"type":"tool","tool":"read","callID":"call_WCt8eXZBUmn0QjAuaNVwAFLY","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","offset":1160,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1160:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1161:     timer = setTimeout(() => {\n1162:       timer = null;\n1163:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1164:       if (latestQuietMs >= thresholdMs) {\n1165:         fired = true;\n1166:         appendFanoutStatusLedger(ledgerPath, {\n1167:           event: 'stall_detected',\n1168:           label,\n1169:           at: new Date().toISOString(),\n1170:           severity: 'warning',\n1171:           metric: 'time_since_last_lineage_event',\n1172:           stall_watchdog_ms: thresholdMs,\n1173:           quiet_ms: Math.floor(latestQuietMs),\n1174:           gauges: getGauges(),\n1175:         });\n1176:         return;\n1177:       }\n1178:       schedule();\n1179:     }, delayMs);\n1180:     timer.unref?.();\n1181:   };\n1182: \n1183:   schedule();\n1184:   return () => {\n1185:     fired = true;\n1186:     if (timer) clearTimeout(timer);\n1187:   };\n1188: }\n1189: \n1190: /**\n1191:  * Run a lineage subprocess without blocking the Node event loop.\n1192:  *\n1193:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1194:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1195:  * thread until each child exited, serializing every lineage regardless of the\n1196:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1197:  *\n1198:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1199:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1200:  *\n1201:  * @param {string} command - Executable to run.\n1202:  * @param {string[]} cmdArgs - Arguments for the executable.\n1203:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1204:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1205:  */\n1206: function runLineageProcess(command, cmdArgs, opts) {\n1207:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1208:   const hasInput = typeof opts.input === 'string';\n1209: \n1210:   return new Promise((resolvePromise) => {\n1211:     let child;\n1212:     try {\n1213:       child = spawn(command, cmdArgs, {\n1214:         cwd,\n1215:         env,\n1216:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1217:         detached: process.platform !== 'win32',\n1218:       });\n1219:     } catch (error) {\n1220:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1221:       return;\n1222:     }\n1223:     activeLineageProcesses.add(child);\n1224:     if (typeof opts.onSpawn === 'function') {\n1225:       opts.onSpawn({ pid: child.pid });\n1226:     }\n1227: \n1228:     let stdout = '';\n1229:     let stdoutBytes = 0;\n1230:     let truncated = false;\n1231:     let timedOut = false;\n1232:     let settled = false;\n1233:     let spawnError;\n1234: \n1235:     const timer = setTimeout(() => {\n1236:       timedOut = true;\n1237:       terminateLineageProcess(child, 'SIGTERM');\n1238:     }, timeoutMs);\n1239:     timer.unref?.();\n1240: \n1241:     const abortHandler = () => {\n1242:       terminateLineageProcess(child, 'SIGTERM');\n1243:     };\n1244:     if (opts.abortSignal) {\n1245:       if (opts.abortSignal.aborted) {\n1246:         abortHandler();\n1247:       } else {\n1248:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1249:       }\n1250:     }\n1251: \n1252:     child.stdout?.setEncoding('utf8');\n1253:     child.stdout?.on('data', (chunk) => {\n1254:       if (truncated) return;\n1255:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1256:       if (stdoutBytes > maxBuffer) {\n1257:         truncated = true;\n1258:         terminateLineageProcess(child, 'SIGTERM');\n1259:         return;\n1260:       }\n1261:       stdout += chunk;\n1262:     });\n1263:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1264:     child.stderr?.resume();\n1265: \n1266:     child.on('error', (error) => {\n1267:       spawnError = error;\n1268:     });\n1269: \n1270:     child.on('close', (code, signal) => {\n1271:       if (settled) return;\n1272:       settled = true;\n1273:       activeLineageProcesses.delete(child);\n1274:       clearTimeout(timer);\n1275:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1276:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1277:       if (typeof opts.onExit === 'function') {\n1278:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1279:       }\n1280:       resolvePromise({\n1281:         status: timedOut ? null : code,\n1282:         signal: effectiveSignal,\n1283:         stdout,\n1284:         ...(spawnError ? { error: spawnError } : {}),\n1285:       });\n1286:     });\n1287: \n1288:     if (hasInput) {\n1289:       child.stdin?.on('error', () => {});\n1290:       child.stdin?.end(opts.input);\n1291:     }\n1292:   });\n1293: }\n1294: \n1295: /**\n1296:  * Build the subprocess command for a fan-out lineage.\n1297:  * Returns { command, args, input?, env } where input is stdin content when applicable.\n1298:  */\n1299: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n1300:   const kind = lineage.kind;\n1301: \n1302:   if (kind === 'cli-claude-code') {\n1303:     const args = [\n1304:       '-p',\n1305:       prompt,\n1306:       '--model',\n1307:       lineage.model || 'claude-opus-4-8',\n1308:       '--permission-mode',\n1309:       resolvedPermission,\n1310:       '--output-format',\n1311:       'text',\n1312:     ];\n1313:     if (lineage.reasoningEffort) {\n1314:       args.push('--effort', lineage.reasoningEffort);\n1315:     }\n1316:     return { command: 'claude', args };\n1317:   }\n1318: \n1319:   if (kind === 'native') {\n1320:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n1321:     // For review runs this is the real deep/review command surface with a lineage\n1322:     // artifact override, so the command YAML owns init, loop, and synthesis.\n1323:     const args = [\n1324:       'run',\n1325:       '--format',\n1326:       'json',\n1327:       '--dangerously-skip-permissions',\n1328:       '--dir',\n1329:       process.cwd(),\n1330:       '--command',\n1331:       `deep/${options.loopType || 'review'}`,\n1332:     ];\n1333:     args.push(buildNativeCommandInput(\n1334:       options.loopType || 'review',\n1335:       options.specFolder || '',\n1336:       options.lineageDir || '',\n1337:       lineage,\n1338:       options,\n1339:     ));\n\n(Showing lines 1160-1339 of 1871. Use offset=1340 to continue.)\n</content>","metadata":{"preview":"    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);\n    timer.unref?.();\n  };\n\n  schedule();\n  return () => {\n    fired = true;\n    if (timer) clearTimeout(timer);\n  };\n}\n\n/**\n * Run a lineage subprocess without blocking the Node event loop.\n *\n * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n * thread until each child exited, serializing every lineage regardless of the\n * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n *\n * On timeout the child is killed with SIGTERM and result.signal is set to\n * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n *\n * @param {string} command - Executable to run.\n * @param {string[]} cmdArgs - Arguments for the executable.\n * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n */\nfunction runLineageProcess(command, cmdArgs, opts) {\n  const { cwd, env, timeoutMs, maxBuffer } = opts;\n  const hasInput = typeof opts.input === 'string';\n\n  return new Promise((resolvePromise) => {\n    let child;\n    try {\n      child = spawn(command, cmdArgs, {\n        cwd,\n        env,\n        stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n        detached: process.platform !== 'win32',\n      });\n    } catch (error) {\n      resolvePromise({ status: null, signal: null, stdout: '', error });\n      return;\n    }\n    activeLineageProcesses.add(child);\n    if (typeof opts.onSpawn === 'function') {\n      opts.onSpawn({ pid: child.pid });\n    }\n\n    let stdout = '';\n    let stdoutBytes = 0;\n    let truncated = false;\n    let timedOut = false;\n    let settled = false;\n    let spawnError;\n\n    const timer = setTimeout(() => {\n      timedOut = true;\n      terminateLineageProcess(child, 'SIGTERM');\n    }, timeoutMs);\n    timer.unref?.();\n\n    const abortHandler = () => {\n      terminateLineageProcess(child, 'SIGTERM');\n    };\n    if (opts.abortSignal) {\n      if (opts.abortSignal.aborted) {\n        abortHandler();\n      } else {\n        opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n      }\n    }\n\n    child.stdout?.setEncoding('utf8');\n    child.stdout?.on('data', (chunk) => {\n      if (truncated) return;\n      stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n      if (stdoutBytes > maxBuffer) {\n        truncated = true;\n        terminateLineageProcess(child, 'SIGTERM');\n        return;\n      }\n      stdout += chunk;\n    });\n    // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n    child.stderr?.resume();\n\n    child.on('error', (error) => {\n      spawnError = error;\n    });\n\n    child.on('close', (code, signal) => {\n      if (settled) return;\n      settled = true;\n      activeLineageProcesses.delete(child);\n      clearTimeout(timer);\n      opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n      const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n      if (typeof opts.onExit === 'function') {\n        opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n      }\n      resolvePromise({\n        status: timedOut ? null : code,\n        signal: effectiveSignal,\n        stdout,\n        ...(spawnError ? { error: spawnError } : {}),\n      });\n    });\n\n    if (hasInput) {\n      child.stdin?.on('error', () => {});\n      child.stdin?.end(opts.input);\n    }\n  });\n}\n\n/**\n * Build the subprocess command for a fan-out lineage.\n * Returns { command, args, input?, env } where input is stdin content when applicable.\n */\nfunction buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n  const kind = lineage.kind;\n\n  if (kind === 'cli-claude-code') {\n    const args = [\n      '-p',\n      prompt,\n      '--model',\n      lineage.model || 'claude-opus-4-8',\n      '--permission-mode',\n      resolvedPermission,\n      '--output-format',\n      'text',\n    ];\n    if (lineage.reasoningEffort) {\n      args.push('--effort', lineage.reasoningEffort);\n    }\n    return { command: 'claude', args };\n  }\n\n  if (kind === 'native') {\n    // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n    // For review runs this is the real deep/review command surface with a lineage\n    // artifact override, so the command YAML owns init, loop, and synthesis.\n    const args = [\n      'run',\n      '--format',\n      'json',\n      '--dangerously-skip-permissions',\n      '--dir',\n      process.cwd(),\n      '--command',\n      `deep/${options.loopType || 'review'}`,\n    ];\n    args.push(buildNativeCommandInput(\n      options.loopType || 'review',\n      options.specFolder || '',\n      options.lineageDir || '',\n      lineage,\n      options,\n    ));","lineStart":1160,"lineEnd":1339,"totalLines":1871,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783487742262,"end":1783487742289}},"metadata":{"openai":{"itemId":"fc_052459e0b1e9bdef016a4ddcfe1e1c81919879351739d3f44f"}},"id":"prt_f40274135001m2HOBrliOuV7oD","sessionID":"ses_0bfdf923effeJgm1s2MxRoJ0VL","messageID":"msg_f402702d4001mwmUsz8AwO4zF7"}}
