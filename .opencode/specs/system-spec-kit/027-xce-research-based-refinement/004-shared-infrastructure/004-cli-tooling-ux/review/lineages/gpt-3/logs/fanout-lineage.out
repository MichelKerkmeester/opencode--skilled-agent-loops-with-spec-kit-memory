n exitCode === null ? 'exit_unknown' : `exit_${exitCode}`;\n}\n\nexport function skillAdvisorCliFallbackEnvelope(input: WarmSkillAdvisorCliFallbackEnvelopeInput): WarmSkillAdvisorCliFallbackEnvelope {\n  const exitCode = input.exitCode ?? null;\n  const reason = normalizeSkillAdvisorCliFallbackReason(input.reason, exitCode, input.status);\n  return {\n    status: input.status,\n    reason,\n    exitCode,\n    retryable: input.status !== 'ok' && (input.timedOut === true || exitCode === EXIT_RETRYABLE || RETRYABLE_REASONS.has(reason)),\n  };\n}\n\nfunction withCliFallbackEnvelope(\n  result: AdvisorHookResult,\n  envelope: WarmSkillAdvisorCliFallbackEnvelope,","lineStart":1,"lineEnd":130,"totalLines":578,"truncated":true}},"title":".opencode/skills/system-skill-advisor/hooks/lib/skill-advisor-cli-fallback.ts","time":{"start":1781145082411,"end":1781145082417}},"metadata":{"openai":{"itemId":"fc_07a5db29582ce64d016a2a1dfa023481919ccb55c552a10360"}},"id":"prt_eb48519f4001jagejLOz34TxMK","sessionID":"ses_14b7dcdd9ffeTUJ25ZqyT2Zeky","messageID":"msg_eb484efb1001TWV6Nj7P0tWdiX"}}
