ll() as { kind: string; c: number }[];\n1430:   for (const r of kindRows) nodesByKind[r.kind] = r.c;\n1431: \n1432:   const edgesByType: Record<string, number> = {};\n1433:   const typeRows = d.prepare('SELECT edge_type, COUNT(*) as c FROM code_edges GROUP BY edge_type').all() as { edge_type: string; c: number }[];\n1434:   for (const r of typeRows) edgesByType[r.edge_type] = r.c;\n1435: \n1436:   const parseHealthSummary: Record<string, number> = {};\n1437:   const healthRows = d.prepare('SELECT parse_health, COUNT(*) as c FROM code_files GROUP BY parse_health').all() as { parse_health: string; c: number }[];\n1438:   for (const r of healthRows) parseHealthSummary[r.parse_health] = r.c;\n1439: \n1440:   // Last scan timestamp\n1441:   const lastScan = d.prepare('SELECT MAX(indexed_at) as last FROM code_files').get() as { last: string | null } | undefined;\n1442:   const lastScanTimestamp = lastScan?.last ?? null;\n1443:   const lastGitHead = getLastGitHead();\n1444:   const graphQualitySummary = getGraphQualitySummary();\n1445:   const tombstones = getTombstoneSummary();\n1446: \n1447:   // DB file size\n1448:   let dbFileSize: number | null = null;\n1449:   if (dbPath) {\n1450:     try { dbFileSize = statSync(dbPath).size; } catch { /* file may not exist yet */ }\n1451:   }\n1452: \n1453:   return {\n1454:     totalFiles, totalNodes, totalEdges, nodesByKind, edgesByType, parseHealthSummary,\n1455:     tombstones, lastScanTimestamp, lastGitHead, dbFileSize, schemaVersion: SCHEMA_VERSION, graphQualitySummary,\n1456:   };\n1457: }\n1458: \n1459: export function getTombstoneSummary(): CodeGraphTombstoneSummary {\n1460:   const enabled = codeGraphTombstonesEnabled();\n1461:   const retentionLimit = enabled ? getCodeGraphTombstoneLimit() : 0;\n1462:   const empty: CodeGraphTombstoneSummary = {\n1463:     enabled,\n1464:     retentionLimit,\n1465:     retainedRows: 0,\n1466:     byKind: {},\n1467:     byReason: {},\n1468:     recent: [],\n1469:   };\n1470: \n1471:   const d = getDb();\n1472:   if (!enabled || !tombstoneTableExists(d)) {\n1473:     return empty;\n1474:   }\n1475: \n1476:   const retained = d.prepare('SELECT COUNT(*) AS count FROM code_graph_tombstones').get() as { count: number };\n1477:   const kindRows = d.prepare(`\n1478:     SELECT entity_kind, COUNT(*) AS count\n1479:     FROM code_graph_tombstones\n1480:     GROUP BY entity_kind\n1481:   `).all() as Array<{ entity_kind: string; count: number }>;\n1482:   const reasonRows = d.prepare(`\n1483:     SELECT reason, COUNT(*) AS count\n1484:     FROM code_graph_tombstones\n1485:     GROUP BY reason\n1486:   `).all() as Array<{ reason: string; count: number }>;\n1487:   const recentRows = d.prepare(`\n1488:     SELECT id, entity_kind, entity_id, source_id, target_id, edge_type, file_path, reason, deleted_at\n1489:     FROM code_graph_tombstones\n1490:     ORDER BY deleted_at DESC, id DESC\n1491:     LIMIT 10\n1492:   `).all() as Array<Record<string, unknown>>;\n1493: \n1494:   return {\n1495:     enabled,\n1496:     retentionLimit,\n1497:     retainedRows: retained.count,\n1498:     byKind: Object.fromEntries(kindRows.map((row) => [row.entity_kind, row.count])),\n1499:     byReason: Object.fromEntries(reasonRows.map((row) => [row.reason, row.count])),\n1500:     recent: recentRows.map(mapTombstoneRow),\n1501:   };\n1502: }\n1503: \n1504: /** Remove orphaned nodes whose files no longer exist in code_files */\n1505: export function cleanupOrphans(): number {\n1506:   const d = getDb();\n1507:   const deletedAt = new Date().toISOString();\n1508:   recordDanglingEdgeTombstones(d, 'cleanup_orphans', deletedAt);\n1509:   // Find node file_ids not in code_files\n1510:   if (codeGraphTombstonesEnabled()) {\n1511:     ensureTombstoneSchema(d);\n1512:     d.prepare(`\n1513:       INSERT INTO code_graph_tombstones (entity_kind, entity_id, file_path, reason, deleted_at)\n1514:       SELECT 'node', symbol_id, file_path, 'cleanup_orphans', ?\n1515:       FROM code_nodes\n1516:     