    83	
    84	def summarize(samples_ms: List[float]) -> Dict[str, float]:
    85	    """Summarize latency samples using median, p95, and mean statistics."""
    86	    if not samples_ms:
    87	        return {"count": 0, "p50_ms": 0.0, "p95_ms": 0.0, "min_ms": 0.0, "max_ms": 0.0, "mean_ms": 0.0}
    88	
    89	    p95 = statistics.quantiles(samples_ms, n=20)[18] if len(samples_ms) >= 20 else max(samples_ms)
    90	    return {
    91	        "count": len(samples_ms),
    92	        "p50_ms": round(statistics.median(samples_ms), 4),
    93	        "p95_ms": round(p95, 4),
    94	        "min_ms": round(min(samples_ms), 4),
    95	        "max_ms": round(max(samples_ms), 4),
    96	        "mean_ms": round(statistics.mean(samples_ms), 4),
    97	    }
    98	
