:       \"runtimeLoopType\": \"council\",\n68:       \"backendKind\": \"runtime-loop-type\",\n69:       \"packet\": \"deep-ai-council\",\n70:       \"command\": \"/deep:ai-council\",\n71:       \"agent\": \"ai-council\",\n72:       \"artifactRoot\": \"ai-council/\",\n73:       \"aliases\": [\"deep-ai-council\", \"ai council deliberation\", \"multi-seat planning council\", \"council convergence\", \"planning council\"],\n74:       \"advisorRouting\": {\n75:         \"routingClass\": \"lexical\",\n76:         \"legacyAdvisorId\": \"deep-ai-council\",\n77:         \"legacyAliases\": [\"@deep-ai-council\", \"deep-ai-council\", \"deep ai council\", \"ai council\", \"planning council\", \"council deliberation\", \"multi-ai-council\"],\n78:         \"packetSkillName\": \"deep-ai-council\"\n79:       }\n80:     },\n81:     {\n82:       \"workflowMode\": \"agent-improvement\",\n83:       \"runtimeLoopType\": null,\n84:       \"backendKind\": \"improvement-host\",\n85:       \"packet\": \"deep-improvement\",\n86:       \"loopHostMode\": \"agent-improvement\",\n87:       \"command\": \"/deep:agent-improvement\",\n88:       \"agent\": \"deep-improvement\",\n89:       \"artifactRoot\": \"improvement/\",\n90:       \"mutating\": true,\n91:       \"aliases\": [\"improve agent\", \"evaluate agent\", \"agent scoring\", \"score agent candidate\", \"promote or rollback agent change\", \"agent-improvement\"],\n92:       \"advisorRouting\": {\n93:         \"routingClass\": \"alias-fold\",\n94:         \"legacyAdvisorId\": \"deep-improvement\",\n95:         \"advisorDefaultMode\": true,\n96:         \"legacyAliases\": [\"command-spec-kit-deep-agent-improvement\", \"/deep:start-agent-improvement-loop\", \"deep-agent-improvement\", \"sk-deep-agent-improvement\"],\n97:         \"packetSkillName\": \"deep-improvement\"\n98:       }\n99:     },\n100:     {\n101:       \"workflowMode\": \"model-benchmark\",\n102:       \"runtimeLoopType\": null,\n103:       \"backendKind\": \"improvement-host\",\n104:       \"packet\": \"deep-improvement\",\n105:       \"loopHostMode\": \"model-benchmark\",\n106:       \"command\": \"/deep:model-benchmark\",\n107:       \"agent\": \"deep-improvement\",\n108:       \"artifactRoot\": \"improvement/\",\n109:       \"aliases\": [\"model benchmark\", \"benchmark a model\", \"prompt framework benchmark\", \"benchmark-harness\"],\n110:       \"advisorRouting\": {\n111:         \"routingClass\": \"command-bridge\",\n112:         \"packetSkillName\": \"deep-improvement\"\n113:       }\n114:     },\n115:     {\n116:       \"workflowMode\": \"skill-benchmark\",\n117:       \"runtimeLoopType\": null,\n118:       \"backendKind\": \"improvement-host\",\n119:       \"packet\": \"deep-improvement\",\n120:       \"loopHostMode\": \"skill-benchmark\",\n121:       \"command\": \"/deep:skill-benchmark\",\n122:       \"agent\": \"deep-improvement\",\n123:       \"artifactRoot\": \"improvement/\",\n124:       \"aliases\": [\"skill benchmark\", \"benchmark a skill\", \"skill routing benchmark\"],\n125:       \"advisorRouting\": {\n126:         \"routingClass\": \"command-bridge\",\n127:         \"packetSkillName\": \"deep-improvement\"\n128:       }\n129:     },\n130:     {\n131:       \"workflowMode\": \"ai-system-improvement\",\n132:       \"runtimeLoopType\": null,\n133:       \"backendKind\": \"external-adapter\",\n134:       \"packet\": \"deep-improvement\",\n135:       \"loopHostMode\": \"non-dev-ai-system-refine\",\n136:       \"command\": \"/deep:ai-system-improvement\",\n137:       \"agent\": \"deep-improvement\",\n138:       \"artifactRoot\": \"improvement/\",\n139:       \"externalLoopOwner\": \"external packaging (e.g. Barter Copywriter) owns the Python loop, gates, scoring, and kill-switches\",\n140:       \"aliases\": [\"non-dev ai system\", \"non-dev-ai-system\", \"package ai system benchmark\"],\n141:       \"advisorRouting\": {\n142:         \"routingClass\": \"command-bridge\",\n143:         \"packetSkillName\": \"deep-improv