/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/check-contract-drift.cjs","text":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Contract Drift Checker                                                   ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst compiler = require('./compile-command-contracts.cjs');\n\nconst {\n  COMMANDS,\n  GENERATED_HEADER_END,\n  GENERATED_HEADER_START,\n  WORKSPACE_ROOT,\n  buildContract,\n  computeCompiledBodyDigest,\n  getCommandDefinition,\n  normalizeCompiledBody,\n  outputPathFor,\n  parseDigestHeader,\n  sha256,\n  sha256File,\n  stripGeneratedHeader,\n} = compiler;\n\nconst EXIT_DRIFT = 2;\n\nconst DRIFT_CLASSES = Object.freeze({\n  STALE_SOURCE_DIGEST: 'STALE_SOURCE_DIGEST',\n  STALE_COMPILED_BODY: 'STALE_COMPILED_BODY',\n  UNRESOLVED_MARKERS: 'UNRESOLVED_MARKERS',\n  TOOL_ALLOWLIST_OVERFLOW: 'TOOL_ALLOWLIST_OVERFLOW',\n  ENUMERATED_SOURCE_GAP: 'ENUMERATED_SOURCE_GAP',\n});\n\nconst SHARED_AUTHORITY_SOURCES = [\n  '.opencode/skills/system-spec-kit/references/workflows/auto_mode_contract.md',\n  '.opencode/skills/deep-loop-workflows/mode-registry.json',\n  '.opencode/skills/deep-loop-workflows/SKILL.md',\n  '.opencode/skills/deep-loop-workflows/shared/rollout/resolve-injection-mode.cjs',\n];\n\nconst DECLARED_MODE_AUTHORITY_EXTENSIONS = [\n  '.md',\n  '.yaml',\n  '.yml',\n  '.json',\n];\n\nconst AUTHORITY_EXTENSIONS = [\n  '.md',\n  '.yaml',\n  '.yml',\n  '.json',\n  '.txt',\n  '.tmpl',\n];\n\nconst REQUIRED_RENDER_BLOCKS = ['auto', 'confirm'];\n\nconst PLACEHOLDER_PATTERN = /\\[[A-Z][A-Z0-9_]*(?:[- ][A-Z0-9_]+)*\\]/g;\nconst RELATIVE_PATH_PATTERN = /(?:^|[\"'`\\s:=({])((?:\\.opencode|specs)\\/[^\\s\"'`)},]+(?:\\.md\\.tmpl|\\.[A-Za-z0-9_-]+))/g;\nconst DECLARED_MODE_PATH_PATTERN = /(?:^|[\"'`\\s:=({\\[])((?:\\.opencode\\/|\\.\\.?\\/|[A-Za-z0-9_-]+\\/)[A-Za-z0-9_./-]+\\.(?:md|ya?ml|json)(?:#[A-Za-z0-9_.-]+)?)/g;\n\nfunction toPosixPath(inputPath) {\n  return inputPath.split(path.sep).join('/');\n}\n\nfunction relPath(inputPath) {\n  return toPosixPath(path.relative(WORKSPACE_ROOT, inputPath));\n}\n\nfunction absolutePath(sourcePath) {\n  return path.resolve(WORKSPACE_ROOT, sourcePath);\n}\n\nfunction readText(sourcePath) {\n  return fs.readFileSync(absolutePath(sourcePath), 'utf8');","lineStart":1,"lineEnd":80,"totalLines":607,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/check-contract-drift.cjs","time":{"start":1783486836086,"end":1783486836092}},"metadata":{"openai":{"itemId":"fc_00a26a4e812c18da016a4dd973e8f88191b590f179e70cffbe"}},"id":"prt_f40196d4e001wq6JEKtzDaHU5Q","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40193240001Igs8DxvmCRQYZ3"}}
{"type":"tool_use","timestamp":1783486836176,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_sHKaalC9shnIogP40Pj4rK2q","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","offset":930,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n930:   return { didWait: true };\n931: }\n932: \n933: /**\n934:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n935:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n936:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n937:  */\n938: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n939:   assertActiveFanoutLoopType(loopType);\n940:   const skillFile =\n941:     loopType === 'review'\n942:       ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n943:       : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n944:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n945:   const detachedIntro = lineage.kind === 'cli-opencode'\n946:     ? [\n947:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n948:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n949:         ``,\n950:       ]\n951:     : lineage.kind === 'native'\n952:       ? [\n953:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n954:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n955:           ``,\n956:         ]\n957:       : [];\n958:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n959:   const stopPolicy = options.stopPolicy || 'convergence';\n960:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n961:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n962:     : hasIterationCap\n963:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n964:       : 'to legal convergence';\n965:   const params = [\n966:     `  spec_folder: ${specFolder}`,\n967:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n968:     `  session_id: ${sessionId}`,\n969:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n970:     `  loop_type: ${loopType}`,\n971:     `  config.stopPolicy: ${stopPolicy}`,\n972:   ];\n973:   if (researchTopic) {\n974:     // A research lineage's phase_init binds research_topic from this line. Without it a\n975:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n976:     // Review loops scope by spec_folder and intentionally pass no topic.\n977:     params.push(`  research_topic: ${researchTopic}`);\n978:   }\n979:   if (hasIterationCap) {\n980:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n981:   }\n982:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n983:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n984:   }\n985:   // Review lineages scope by spec_folder but the auto-workflow preflight\n986:   // still requires the same review setup bindings the native command path pre-binds.\n987:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n988:   // different setup contract than native lineages.\n989:   const setupBindings =\n990:     loopType === 'review'\n991:       ? [\n992:           ``,\n993:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n994:           `review_target: ${specFolder}`,\n995:           `review_target_type: spec-folder`,\n996:           `review_dimensions: all`,\n997:           `spec_folder: ${specFolder}`,\n998:           `execution_mode: AUTONOMOUS`,\n999:           `lineage_mode: auto`,\n1000:           ``,\n1001:         ]\n1002:       : [];\n1003:   return [\n1004:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1005:     ...detachedIntro,\n1006:     ``,\n1007:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1008:     ...params,\n1009:     ...setupBindings,\n1010:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1011:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1012:     `command; bind artifact_dir directly to the override value.`,\n1013:     ``,\n1014:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1015:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1016:     ``,\n1017:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1018:   ].join('\\n');\n1019: }\n\n(Showing lines 930-1019 of 1871. Use offset=1020 to continue.)\n</content>","metadata":{"preview":"  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n      : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n      : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}","lineStart":930,"lineEnd":1019,"totalLines":1871,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783486836171,"end":1783486836175}},"metadata":{"openai":{"itemId":"fc_00a26a4e812c18da016a4dd973e9008191934c5091d1906d5e"}},"id":"prt_f40196d7e0013M0t5cwHA7jv2B","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40193240001Igs8DxvmCRQYZ3"}}
{"type":"tool_use","timestamp":1783486836193,"sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","part":{"type":"tool","tool":"read","callID":"call_d6gTlZAF5YttK5YlXLOawx99","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts","offset":1,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vitest Config\n3: // ───────────────────────────────────────────────────────────────\n4: // ───────────────────────────────────────────────────────────────\n5: // 1. VITEST\n6: \n7: // ───────────────────────────────────────────────────────────────\n8: import { defineConfig } from 'vitest/config';\n9: import path from 'path';\n10: \n11: const TEST_TIMEOUT_MS = 30_000; // 30s default, increase for CI if needed\n12: const TEARDOWN_TIMEOUT_MS = 1_000;\n13: const _INCLUDE_BENCHES = process.env.SPECKIT_RUN_BENCHES === 'true';\n14: \n15: export default defineConfig({\n16:   root: path.resolve(import.meta.dirname, '..'),\n17:   test: {\n18:     include: [\n19:       'mcp_server/tests/**/*.{vitest,test}.ts',\n20:       '../deep-loop-runtime/tests/**/*.{vitest,test}.ts',\n21:       'scripts/tests/**/*.{vitest,test}.ts',\n22:     ],\n23:     exclude: [\n24:       'mcp_server/tests/memory-save.vitest.ts',\n25:       'mcp_server/tests/archive/**',\n26:     ],\n27:     setupFiles: [\n28:       path.resolve(import.meta.dirname, 'tests', '_support', 'vitest-setup.ts'),\n29:     ],\n30:     // Several script suites mutate shared process-level state and temp project roots.\n31:     // Run files serially so the combined config remains deterministic.\n32:     fileParallelism: false,\n33:     globals: true,\n34:     environment: 'node',\n35:     testTimeout: TEST_TIMEOUT_MS,\n36:     teardownTimeout: TEARDOWN_TIMEOUT_MS,\n37:     alias: {\n38:       '@lib': path.resolve(import.meta.dirname, 'lib'),\n39:       '@spec-kit/shared': path.resolve(import.meta.dirname, '..', 'shared'),\n40:     },\n41:   },\n42: });\n\n(End of file - total 42 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vitest Config\n// ───────────────────────────────────────────────────────────────\n// ───────────────────────────────────────────────────────────────\n// 1. VITEST\n\n// ───────────────────────────────────────────────────────────────\nimport { defineConfig } from 'vitest/config';\nimport path from 'path';\n\nconst TEST_TIMEOUT_MS = 30_000; // 30s default, increase for CI if needed\nconst TEARDOWN_TIMEOUT_MS = 1_000;\nconst _INCLUDE_BENCHES = process.env.SPECKIT_RUN_BENCHES === 'true';\n\nexport default defineConfig({\n  root: path.resolve(import.meta.dirname, '..'),\n  test: {\n    include: [\n      'mcp_server/tests/**/*.{vitest,test}.ts',\n      '../deep-loop-runtime/tests/**/*.{vitest,test}.ts',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vitest Config\n// ───────────────────────────────────────────────────────────────\n// ───────────────────────────────────────────────────────────────\n// 1. VITEST\n\n// ───────────────────────────────────────────────────────────────\nimport { defineConfig } from 'vitest/config';\nimport path from 'path';\n\nconst TEST_TIMEOUT_MS = 30_000; // 30s default, increase for CI if needed\nconst TEARDOWN_TIMEOUT_MS = 1_000;\nconst _INCLUDE_BENCHES = process.env.SPECKIT_RUN_BENCHES === 'true';\n\nexport default defineConfig({\n  root: path.resolve(import.meta.dirname, '..'),\n  test: {\n    include: [\n      'mcp_server/tests/**/*.{vitest,test}.ts',\n      '../deep-loop-runtime/tests/**/*.{vitest,test}.ts',\n      'scripts/tests/**/*.{vitest,test}.ts',\n    ],\n    exclude: [\n      'mcp_server/tests/memory-save.vitest.ts',\n      'mcp_server/tests/archive/**',\n    ],\n    setupFiles: [\n      path.resolve(import.meta.dirname, 'tests', '_support', 'vitest-setup.ts'),\n    ],\n    // Several script suites mutate shared process-level state and temp project roots.\n    // Run files serially so the combined config remains deterministic.\n    fileParallelism: false,\n    globals: true,\n    environment: 'node',\n    testTimeout: TEST_TIMEOUT_MS,\n    teardownTimeout: TEARDOWN_TIMEOUT_MS,\n    alias: {\n      '@lib': path.resolve(import.meta.dirname, 'lib'),\n      '@spec-kit/shared': path.resolve(import.meta.dirname, '..', 'shared'),\n    },\n  },\n});","lineStart":1,"lineEnd":42,"totalLines":42,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/vitest.config.ts","time":{"start":1783486836184,"end":1783486836189}},"metadata":{"openai":{"itemId":"fc_00a26a4e812c18da016a4dd973e9288191b43cb88944f78676"}},"id":"prt_f40196dd8001bZG4oqB1ea6yCj","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f40193240001Igs8DxvmCRQYZ3"}}
