 \"CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING\": \"1\",\n    \"ENABLE_PROMPT_CACHING_1H\": \"true\",\n    \"ENABLE_TOOL_SEARCH\": \"true\",\n    \"MAX_THINKING_TOKENS\": \"999999\"\n  },\n  \"statusLine\": {\n    \"type\": \"command\",\n    \"command\": \"bash .claude/statusline-command.sh\"\n  },\n  \"skillListingBudgetFraction\": 0.02,\n  \"hooks\": {\n    \"PreToolUse\": [\n      {\n        \"matcher\": \"Bash\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && node .opencode/skills/cli-external/cli-opencode/scripts/hooks/dispatch-preflight-lint.mjs'\",","truncated":false,"loaded":["/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.claude/CLAUDE.md"],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.claude/settings.json","text":"{\n  \"env\": {\n    \"CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING\": \"1\",\n    \"ENABLE_PROMPT_CACHING_1H\": \"true\",\n    \"ENABLE_TOOL_SEARCH\": \"true\",\n    \"MAX_THINKING_TOKENS\": \"999999\"\n  },\n  \"statusLine\": {\n    \"type\": \"command\",\n    \"command\": \"bash .claude/statusline-command.sh\"\n  },\n  \"skillListingBudgetFraction\": 0.02,\n  \"hooks\": {\n    \"PreToolUse\": [\n      {\n        \"matcher\": \"Bash\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && node .opencode/skills/cli-external/cli-opencode/scripts/hooks/dispatch-preflight-lint.mjs'\",\n            \"timeout\": 5\n          }\n        ]\n      },\n      {\n        \"matcher\": \"Task\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"bash -c 'cd \\\"${CLAUDE_PROJECT_DIR:-$PWD}\\\" && node .opencode/skills/system-deep-loop/runtime/hooks/claude/task-dispatch-guard.cjs'\",\n            \"timeout\": 5\n          }\n        ]\n      }\n    ],\n    \