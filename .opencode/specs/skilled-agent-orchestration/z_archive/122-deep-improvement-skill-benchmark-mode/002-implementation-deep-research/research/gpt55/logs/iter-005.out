    88	// Ported verbatim from score-variant.cjs (acceptance is the only check 120/003
    89	// did not ship as a standalone det-script). Operates on an absolute cwd.
    90	function scoreAcceptanceDeterministic(acceptance, cwdAbs) {
    91	  const acc = acceptance || [];
    92	  if (acc.length === 0) return { score: 1.0, details: { count: 0, note: 'no acceptance defined' } };
    93	  const results = [];
    94	  let pass = 0;
    95	  for (const a of acc) {
    96	    let ok = false;
    97	    let detail = '';
    98	    try {
