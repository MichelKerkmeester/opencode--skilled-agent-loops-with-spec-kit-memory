yMs\": 969\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781373027021,"end":1781373028016}},"metadata":{"openai":{"itemId":"fc_0e788725b331374b016a2d98608bc881919dca35866832fb45"}},"id":"prt_ec21b392a0017ViBskzSpfrljB","sessionID":"ses_13de52a52ffewkjJmOhc1a75oH","messageID":"msg_ec21b2830001f3l0vHK8xyCSer"}}
