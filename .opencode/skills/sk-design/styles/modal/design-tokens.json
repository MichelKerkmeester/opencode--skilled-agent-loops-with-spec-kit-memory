  "font": {
    "goga": {
      "$value": "Goga",
      "$type": "fontFamily",
      "$description": "Display and heading face — used for all H1–H4 and card titles. Goga is a custom geometric sans with tight apertures and slightly squared terminals. The medium weight (500) is reserved for emphasis on card-level titles; the regular weight (400) handles hero and section headings. Its 'ss01' stylistic set should be enabled to access alternate glyph forms that define Modal's identity. Negative tracking tightens progressively from -0.007em at 48px to -0.017em at 21px."
    },
    "inter-variable": {
      "$value": "Inter Variable",
      "$type": "fontFamily",
      "$description": "UI and body face — nav, buttons, body copy, labels, footer. Medium weight (500) is the default for interactive elements and nav; regular (400) for paragraphs. Tracking is notably tight even at small sizes (-0.026em at 14px, -0.022em at 16px) giving the UI a compressed, terminal-like density. The 'cv11' character variant should be enabled for alternate punctuation. Uppercase eyebrow labels at 12px use +0.05em tracking as a counter-rhythm to the body tightness."
    }
  },
