{"type":"tool_use","timestamp":1781128832055,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_F8A1wX90ybz9BYKpjWLWytwu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","offset":1,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Cross-Skill Edges Apply Patch\n3: // ───────────────────────────────────────────────────────────────\n4: // Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n5: \n6: import { readFile, writeFile } from 'node:fs/promises';\n7: import { basename, resolve, sep } from 'node:path';\n8: import type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n9: \n10: // ───────────────────────────────────────────────────────────────\n11: // 1. APPLY EDGE\n12: // ───────────────────────────────────────────────────────────────\n13: \n14: const PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n15: \n16: function deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n17:   return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n18: }\n19: \n20: function readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {\n21:   const value = edge.source_kind;\n22:   if (value === 'automated' || value === 'manual' || value === 'trusted') {\n23:     return value;\n24:   }\n25:   return null;\n26: }\n27: \n28: function buildAutomatedReason(candidate: InboundEnhanceCandidate): string {\n29:   return candidate.rules.map(r => `${r.rule}:${r.contribution.toFixed(2)}`).join(' + ');\n30: }\n31: \n32: /**\n33:  * Validate that the source path is a graph-metadata.json file under the trusted skills root.\n34:  * Prevents path traversal in apply mode.\n35:  */\n36: function isPathWithin(candidatePath: string, trustedRoot: string): boolean {\n37:   const resolvedCandidate = resolve(candidatePath);\n38:   const resolvedRoot = resolve(trustedRoot);\n39:   const rootWithSep = resolvedRoot.endsWith(sep) ? resolvedRoot : resolvedRoot + sep;\n40:   return resolvedCandidate.startsWith(rootWithSep) && basename(resolvedCandidate) === 'graph-metadata.json';\n41: }\n42: \n43: /**\n44:  * Apply an enhance edge to the source skill's graph-metadata.json.\n45:  * Idempotent for automated writes and protects manually maintained provenance.\n46:  *\n47:  * @param candidate - The candidate to apply\n48:  * @param skillsRoot - Optional trusted workspace root. When provided, candidate.sourcePath\n49:  *                    MUST resolve under this root and have basename 'graph-metadata.json'.\n50:  * This guards against path traversal in apply mode.\n51:  */\n52: export async function applyEnhanceEdge(\n53:   candidate: InboundEnhanceCandidate,\n54:   skillsRoot?: string,\n55:   writeIntent: EdgeWriteIntent = 'automated',\n56: ): Promise<{ applied: boolean; reason: string }> {\n57:   if (!candidate.applyable) {\n58:     return { applied: false, reason: `not applyable: ${candidate.blockers.join('; ')}` };\n59:   }\n60: \n61:   if (skillsRoot && !isPathWithin(candidate.sourcePath, skillsRoot)) {\n62:     return {\n63:       applied: false,\n64:       reason: `path-boundary violation: ${candidate.sourcePath} not under ${skillsRoot}`,\n65:     };\n66:   }\n67: \n68:   try {\n69:     const raw = await readFile(candidate.sourcePath, 'utf-8');\n70:     const parsed = JSON.parse(raw);\n71: \n72:     if (!parsed.edges) {\n73:       parsed.edges = {};\n74:     }\n75:     if (!parsed.edges.enhances) {\n76:       parsed.edges.enhances = [];\n77:     }\n78: \n79:     const enhances: Array<Record<string, unknown>> = parsed.edges.enhances;\n80:     const sourceKind = deriveSourceKind(writeIntent);\n81:     const existingEdge = enhances.find(e => e.target === candidate.targetSkillId);\n82: \n83:     if (existingEdge && writeIntent === 'automated') {\n84:       const existingSourceKind = readSourceKind(existingEdge);\n85:       if (existingSourceKind && PROTECTED_SOURCE_KINDS.has(existingSourceKind)) {\n86:         return { applied: false, reason: 'edge already exists: manual provenance protected' };\n87:       }\n88:       return { applied: false, reason: 'edge already exists' };\n89:     }\n90: \n91:     if (existingEdge) {\n92:       existingEdge.weight = candidate.weight;\n93:       existingEdge.context = candidate.context;\n94:       existingEdge.source_kind = sourceKind;\n95:       await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n96:       return { applied: true, reason: 'edge updated by trusted maintainer' };\n97:     }\n98: \n99:     const newEdge = {\n100:       target: candidate.targetSkillId,\n101:       weight: candidate.weight,\n102:       context: candidate.context,\n103:       source_kind: sourceKind,\n104:     };\n105: \n106:     if (writeIntent === 'automated') {\n107:       Object.assign(newEdge, {\n108:         auto_added_at: new Date().toISOString(),\n109:         auto_added_reason: buildAutomatedReason(candidate),\n110:       });\n111:     }\n112: \n113:     enhances.push(newEdge);\n114:     parsed.edges.enhances = enhances;\n115: \n116:     await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n117:     return { applied: true, reason: `edge added with ${sourceKind} provenance` };\n118:   } catch (error) {\n119:     const message = error instanceof Error ? error.message : String(error);\n120:     return { applied: false, reason: `failed to apply edge: ${message}` };\n121:   }\n122: }\n\n(End of file - total 122 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Cross-Skill Edges Apply Patch\n// ───────────────────────────────────────────────────────────────\n// Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n\nimport { readFile, writeFile } from 'node:fs/promises';\nimport { basename, resolve, sep } from 'node:path';\nimport type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. APPLY EDGE\n// ───────────────────────────────────────────────────────────────\n\nconst PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n\nfunction deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n  return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n}\n\nfunction readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Cross-Skill Edges Apply Patch\n// ───────────────────────────────────────────────────────────────\n// Idempotent JSON patching for applying enhance edges to graph-metadata.json.\n\nimport { readFile, writeFile } from 'node:fs/promises';\nimport { basename, resolve, sep } from 'node:path';\nimport type { EdgeSourceKind, EdgeWriteIntent, InboundEnhanceCandidate } from './types.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. APPLY EDGE\n// ───────────────────────────────────────────────────────────────\n\nconst PROTECTED_SOURCE_KINDS = new Set<EdgeSourceKind>(['manual', 'trusted']);\n\nfunction deriveSourceKind(writeIntent: EdgeWriteIntent): EdgeSourceKind {\n  return writeIntent === 'trusted-maintainer' ? 'trusted' : 'automated';\n}\n\nfunction readSourceKind(edge: Record<string, unknown>): EdgeSourceKind | null {\n  const value = edge.source_kind;\n  if (value === 'automated' || value === 'manual' || value === 'trusted') {\n    return value;\n  }\n  return null;\n}\n\nfunction buildAutomatedReason(candidate: InboundEnhanceCandidate): string {\n  return candidate.rules.map(r => `${r.rule}:${r.contribution.toFixed(2)}`).join(' + ');\n}\n\n/**\n * Validate that the source path is a graph-metadata.json file under the trusted skills root.\n * Prevents path traversal in apply mode.\n */\nfunction isPathWithin(candidatePath: string, trustedRoot: string): boolean {\n  const resolvedCandidate = resolve(candidatePath);\n  const resolvedRoot = resolve(trustedRoot);\n  const rootWithSep = resolvedRoot.endsWith(sep) ? resolvedRoot : resolvedRoot + sep;\n  return resolvedCandidate.startsWith(rootWithSep) && basename(resolvedCandidate) === 'graph-metadata.json';\n}\n\n/**\n * Apply an enhance edge to the source skill's graph-metadata.json.\n * Idempotent for automated writes and protects manually maintained provenance.\n *\n * @param candidate - The candidate to apply\n * @param skillsRoot - Optional trusted workspace root. When provided, candidate.sourcePath\n *                    MUST resolve under this root and have basename 'graph-metadata.json'.\n * This guards against path traversal in apply mode.\n */\nexport async function applyEnhanceEdge(\n  candidate: InboundEnhanceCandidate,\n  skillsRoot?: string,\n  writeIntent: EdgeWriteIntent = 'automated',\n): Promise<{ applied: boolean; reason: string }> {\n  if (!candidate.applyable) {\n    return { applied: false, reason: `not applyable: ${candidate.blockers.join('; ')}` };\n  }\n\n  if (skillsRoot && !isPathWithin(candidate.sourcePath, skillsRoot)) {\n    return {\n      applied: false,\n      reason: `path-boundary violation: ${candidate.sourcePath} not under ${skillsRoot}`,\n    };\n  }\n\n  try {\n    const raw = await readFile(candidate.sourcePath, 'utf-8');\n    const parsed = JSON.parse(raw);\n\n    if (!parsed.edges) {\n      parsed.edges = {};\n    }\n    if (!parsed.edges.enhances) {\n      parsed.edges.enhances = [];\n    }\n\n    const enhances: Array<Record<string, unknown>> = parsed.edges.enhances;\n    const sourceKind = deriveSourceKind(writeIntent);\n    const existingEdge = enhances.find(e => e.target === candidate.targetSkillId);\n\n    if (existingEdge && writeIntent === 'automated') {\n      const existingSourceKind = readSourceKind(existingEdge);\n      if (existingSourceKind && PROTECTED_SOURCE_KINDS.has(existingSourceKind)) {\n        return { applied: false, reason: 'edge already exists: manual provenance protected' };\n      }\n      return { applied: false, reason: 'edge already exists' };\n    }\n\n    if (existingEdge) {\n      existingEdge.weight = candidate.weight;\n      existingEdge.context = candidate.context;\n      existingEdge.source_kind = sourceKind;\n      await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n      return { applied: true, reason: 'edge updated by trusted maintainer' };\n    }\n\n    const newEdge = {\n      target: candidate.targetSkillId,\n      weight: candidate.weight,\n      context: candidate.context,\n      source_kind: sourceKind,\n    };\n\n    if (writeIntent === 'automated') {\n      Object.assign(newEdge, {\n        auto_added_at: new Date().toISOString(),\n        auto_added_reason: buildAutomatedReason(candidate),\n      });\n    }\n\n    enhances.push(newEdge);\n    parsed.edges.enhances = enhances;\n\n    await writeFile(candidate.sourcePath, JSON.stringify(parsed, null, 2) + '\\n', 'utf-8');\n    return { applied: true, reason: `edge added with ${sourceKind} provenance` };\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    return { applied: false, reason: `failed to apply edge: ${message}` };\n  }\n}","lineStart":1,"lineEnd":122,"totalLines":122,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/cross-skill-edges/apply-graph-metadata-patch.ts","time":{"start":1781128832045,"end":1781128832053}},"metadata":{"openai":{"itemId":"fc_02508314844ac467016a29de7fea8c8191979377941c32637a"}},"id":"prt_eb38d242c001ah1LxLtnK7Q5yd","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38cec4d0010WXvLEynEAUnvm"}}
{"type":"tool_use","timestamp":1781128832055,"sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","part":{"type":"tool","tool":"read","callID":"call_l4AVZDYlsWtgVPm49PKp20Qh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","offset":130,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts</path>\n<type>file</type>\n<content>\n130:   if (!args.attributed) return 'no_lane_attribution_excluded';\n131:   return 'supported_shadow_candidate';\n132: }\n133: \n134: function laneRecords(\n135:   lane: ScorerLane,\n136:   records: readonly AdvisorHookOutcomeRecord[],\n137:   laneAttributionBySkill: Readonly<Record<string, ScorerLane>>,\n138: ): AdvisorHookOutcomeRecord[] {\n139:   return records.filter((record) => laneAttributionBySkill[record.skillLabel] === lane);\n140: }\n141: \n142: export function isAdvisorFeedbackCalibrationEnabled(\n143:   env: Record<string, string | undefined> = process.env,\n144: ): boolean {\n145:   const raw = env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_SHADOW?.trim().toLowerCase();\n146:   return raw !== undefined && TRUE_VALUES.has(raw);\n147: }\n148: \n149: export function advisorFeedbackCalibrationRecordsPath(workspaceRoot: string): string {\n150:   return process.env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_PATH\n151:     ?? join(RECORD_ROOT, `${workspaceHash(workspaceRoot)}-feedback-calibration.jsonl`);\n152: }\n153: \n154: export function reduceAdvisorFeedbackCalibration(\n155:   records: readonly AdvisorHookOutcomeRecord[],\n156:   options: AdvisorFeedbackCalibrationOptions,\n157: ): AdvisorFeedbackCalibrationReport {\n158:   const minSamples = options.minSamples ?? DEFAULT_MIN_SAMPLES;\n159:   const maxShare = options.maxSkillShare ?? DEFAULT_MAX_SKILL_SHARE;\n160:   const totals = countOutcomes(records);\n161:   const skillShare = round4(maxSkillShare(records));\n162:   const concentrated = records.length > 0 && skillShare > maxShare;\n163:   const laneAttributionBySkill = options.laneAttributionBySkill ?? {};\n164:   const hasAttribution = Object.keys(laneAttributionBySkill).length > 0;\n165:   const weightDeltas: Partial<Record<ScorerLane, number>> = {};\n166: \n167:   const laneSignals = SCORER_LANES.map((lane): AdvisorFeedbackCalibrationLaneSignal => {\n168:     const attributedRecords = laneRecords(lane, records, laneAttributionBySkill);\n169:     const laneTotals = hasAttribution ? countOutcomes(attributedRecords) : totals;\n170:     const sampleCount = hasAttribution ? attributedRecords.length : records.length;\n171:     const reason = signalReason({ sampleCount, minSamples, concentrated, attributed: hasAttribution });\n172:     const status: AdvisorFeedbackCalibrationLaneStatus = reason === 'supported_shadow_candidate' ? 'candidate' : 'excluded';\n173:     const correctionPressure = sampleCount > 0 ? laneTotals.corrected / sampleCount : 0;\n174:     const acceptancePressure = sampleCount > 0 ? laneTotals.accepted / sampleCount : 0;\n175:     const proposedDelta = status === 'candidate' && isLiveScorerLane(lane)\n176:       ? round4(clamp((acceptancePressure - correctionPressure) * MAX_WEIGHT_DELTA, MAX_WEIGHT_DELTA))\n177:       : 0;\n178:     if (proposedDelta !== 0) weightDeltas[lane] = proposedDelta;\n179:     return {\n180:       lane,\n181:       status,\n182:       sampleCount,\n183:       accepted: laneTotals.accepted,\n184:       corrected: laneTotals.corrected,\n185:       ignored: laneTotals.ignored,\n186:       proposedDelta,\n187:       reason,\n188:     };\n189:   });\n190: \n191:   const correctionRate = records.length > 0 ? totals.corrected / records.length : 0;\n192:   const ignoredRate = records.length > 0 ? totals.ignored / records.length : 0;\n193:   const thresholdSignals = records.length < minSamples || concentrated\n194:     ? {\n195:       confidenceThresholdDelta: 0,\n196:       uncertaintyThresholdDelta: 0,\n197:       reason: records.length < minSamples ? 'low_sample_excluded' : 'sample_concentration_excluded',\n198:     }\n199:     : {\n200:       confidenceThresholdDelta: round4(clamp(correctionRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n201:       uncertaintyThresholdDelta: round4(clamp(-ignoredRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n202:       reason: 'supported_shadow_candidate',\n203:     };\n204: \n205:   return {\n206:     model: 'advisor-feedback-calibration-shadow-v1',\n207:     generatedAt: options.generatedAt ?? new Date().toISOString(),\n208:     scope: {\n209:       kind: options.skillSlug === null || options.skillSlug === undefined ? 'workspace' : 'skill',\n210:       skillSlug: options.skillSlug ?? null,\n211:     },\n212:     sample: {\n213:       total: records.length,\n214:       accepted: totals.accepted,\n215:       corrected: totals.corrected,\n216:       ignored: totals.ignored,\n217:       distinctSkills: distinctSkillCount(records),\n218:       maxSkillShare: skillShare,\n219:     },\n220:     laneSignals,\n221:     thresholdSignals,\n222:     proposal: buildReadOnlyScorerCalibrationProposal({\n223:       proposedWeightDeltas: weightDeltas,\n224:       currentThresholds: options.currentThresholds,\n225:       proposedThresholdDeltas: {\n226:         confidenceThreshold: thresholdSignals.confidenceThresholdDelta,\n227:         uncertaintyThreshold: thresholdSignals.uncertaintyThresholdDelta,\n228:       },\n229:     }),\n230:     guardrails: {\n231:       defaultOff: true,\n232:       shadowOnly: true,\n233:       liveWeightsFrozen: true,\n234:       autoPromotion: false,\n235:       heldOutValidationRequired: true,\n236:       noLaneAttributionFallback: !hasAttribution,\n237:     },\n238:   };\n239: }\n240: \n241: export function persistAdvisorFeedbackCalibrationRecord(\n242:   workspaceRoot: string,\n243:   report: AdvisorFeedbackCalibrationReport,\n244: ): string {\n245:   const path = advisorFeedbackCalibrationRecordsPath(workspaceRoot);\n246:   mkdirSync(dirname(path), { recursive: true });\n247:   const existing = existsSync(path)\n248:     ? readFileSync(path, 'utf8').split('\\n').map((line) => line.trim()).filter(Boolean)\n249:     : [];\n250:   existing.push(JSON.stringify(report));\n251:   writeFileSync(path, `${existing.slice(-MAX_RECORDS).join('\\n')}\\n`, 'utf8');\n252:   return path;\n253: }\n254: \n255: export function recordAdvisorFeedbackCalibrationIfEnabled(input: {\n256:   readonly workspaceRoot: string;\n257:   readonly records: readonly AdvisorHookOutcomeRecord[];\n258:   readonly options: AdvisorFeedbackCalibrationOptions;\n259:   readonly env?: Record<string, string | undefined>;\n\n(Showing lines 130-259 of 265. Use offset=260 to continue.)\n</content>","metadata":{"preview":"  if (!args.attributed) return 'no_lane_attribution_excluded';\n  return 'supported_shadow_candidate';\n}\n\nfunction laneRecords(\n  lane: ScorerLane,\n  records: readonly AdvisorHookOutcomeRecord[],\n  laneAttributionBySkill: Readonly<Record<string, ScorerLane>>,\n): AdvisorHookOutcomeRecord[] {\n  return records.filter((record) => laneAttributionBySkill[record.skillLabel] === lane);\n}\n\nexport function isAdvisorFeedbackCalibrationEnabled(\n  env: Record<string, string | undefined> = process.env,\n): boolean {\n  const raw = env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_SHADOW?.trim().toLowerCase();\n  return raw !== undefined && TRUE_VALUES.has(raw);\n}\n\nexport function advisorFeedbackCalibrationRecordsPath(workspaceRoot: string): string {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","text":"  if (!args.attributed) return 'no_lane_attribution_excluded';\n  return 'supported_shadow_candidate';\n}\n\nfunction laneRecords(\n  lane: ScorerLane,\n  records: readonly AdvisorHookOutcomeRecord[],\n  laneAttributionBySkill: Readonly<Record<string, ScorerLane>>,\n): AdvisorHookOutcomeRecord[] {\n  return records.filter((record) => laneAttributionBySkill[record.skillLabel] === lane);\n}\n\nexport function isAdvisorFeedbackCalibrationEnabled(\n  env: Record<string, string | undefined> = process.env,\n): boolean {\n  const raw = env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_SHADOW?.trim().toLowerCase();\n  return raw !== undefined && TRUE_VALUES.has(raw);\n}\n\nexport function advisorFeedbackCalibrationRecordsPath(workspaceRoot: string): string {\n  return process.env.SPECKIT_ADVISOR_FEEDBACK_CALIBRATION_PATH\n    ?? join(RECORD_ROOT, `${workspaceHash(workspaceRoot)}-feedback-calibration.jsonl`);\n}\n\nexport function reduceAdvisorFeedbackCalibration(\n  records: readonly AdvisorHookOutcomeRecord[],\n  options: AdvisorFeedbackCalibrationOptions,\n): AdvisorFeedbackCalibrationReport {\n  const minSamples = options.minSamples ?? DEFAULT_MIN_SAMPLES;\n  const maxShare = options.maxSkillShare ?? DEFAULT_MAX_SKILL_SHARE;\n  const totals = countOutcomes(records);\n  const skillShare = round4(maxSkillShare(records));\n  const concentrated = records.length > 0 && skillShare > maxShare;\n  const laneAttributionBySkill = options.laneAttributionBySkill ?? {};\n  const hasAttribution = Object.keys(laneAttributionBySkill).length > 0;\n  const weightDeltas: Partial<Record<ScorerLane, number>> = {};\n\n  const laneSignals = SCORER_LANES.map((lane): AdvisorFeedbackCalibrationLaneSignal => {\n    const attributedRecords = laneRecords(lane, records, laneAttributionBySkill);\n    const laneTotals = hasAttribution ? countOutcomes(attributedRecords) : totals;\n    const sampleCount = hasAttribution ? attributedRecords.length : records.length;\n    const reason = signalReason({ sampleCount, minSamples, concentrated, attributed: hasAttribution });\n    const status: AdvisorFeedbackCalibrationLaneStatus = reason === 'supported_shadow_candidate' ? 'candidate' : 'excluded';\n    const correctionPressure = sampleCount > 0 ? laneTotals.corrected / sampleCount : 0;\n    const acceptancePressure = sampleCount > 0 ? laneTotals.accepted / sampleCount : 0;\n    const proposedDelta = status === 'candidate' && isLiveScorerLane(lane)\n      ? round4(clamp((acceptancePressure - correctionPressure) * MAX_WEIGHT_DELTA, MAX_WEIGHT_DELTA))\n      : 0;\n    if (proposedDelta !== 0) weightDeltas[lane] = proposedDelta;\n    return {\n      lane,\n      status,\n      sampleCount,\n      accepted: laneTotals.accepted,\n      corrected: laneTotals.corrected,\n      ignored: laneTotals.ignored,\n      proposedDelta,\n      reason,\n    };\n  });\n\n  const correctionRate = records.length > 0 ? totals.corrected / records.length : 0;\n  const ignoredRate = records.length > 0 ? totals.ignored / records.length : 0;\n  const thresholdSignals = records.length < minSamples || concentrated\n    ? {\n      confidenceThresholdDelta: 0,\n      uncertaintyThresholdDelta: 0,\n      reason: records.length < minSamples ? 'low_sample_excluded' : 'sample_concentration_excluded',\n    }\n    : {\n      confidenceThresholdDelta: round4(clamp(correctionRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n      uncertaintyThresholdDelta: round4(clamp(-ignoredRate * MAX_THRESHOLD_DELTA, MAX_THRESHOLD_DELTA)),\n      reason: 'supported_shadow_candidate',\n    };\n\n  return {\n    model: 'advisor-feedback-calibration-shadow-v1',\n    generatedAt: options.generatedAt ?? new Date().toISOString(),\n    scope: {\n      kind: options.skillSlug === null || options.skillSlug === undefined ? 'workspace' : 'skill',\n      skillSlug: options.skillSlug ?? null,\n    },\n    sample: {\n      total: records.length,\n      accepted: totals.accepted,\n      corrected: totals.corrected,\n      ignored: totals.ignored,\n      distinctSkills: distinctSkillCount(records),\n      maxSkillShare: skillShare,\n    },\n    laneSignals,\n    thresholdSignals,\n    proposal: buildReadOnlyScorerCalibrationProposal({\n      proposedWeightDeltas: weightDeltas,\n      currentThresholds: options.currentThresholds,\n      proposedThresholdDeltas: {\n        confidenceThreshold: thresholdSignals.confidenceThresholdDelta,\n        uncertaintyThreshold: thresholdSignals.uncertaintyThresholdDelta,\n      },\n    }),\n    guardrails: {\n      defaultOff: true,\n      shadowOnly: true,\n      liveWeightsFrozen: true,\n      autoPromotion: false,\n      heldOutValidationRequired: true,\n      noLaneAttributionFallback: !hasAttribution,\n    },\n  };\n}\n\nexport function persistAdvisorFeedbackCalibrationRecord(\n  workspaceRoot: string,\n  report: AdvisorFeedbackCalibrationReport,\n): string {\n  const path = advisorFeedbackCalibrationRecordsPath(workspaceRoot);\n  mkdirSync(dirname(path), { recursive: true });\n  const existing = existsSync(path)\n    ? readFileSync(path, 'utf8').split('\\n').map((line) => line.trim()).filter(Boolean)\n    : [];\n  existing.push(JSON.stringify(report));\n  writeFileSync(path, `${existing.slice(-MAX_RECORDS).join('\\n')}\\n`, 'utf8');\n  return path;\n}\n\nexport function recordAdvisorFeedbackCalibrationIfEnabled(input: {\n  readonly workspaceRoot: string;\n  readonly records: readonly AdvisorHookOutcomeRecord[];\n  readonly options: AdvisorFeedbackCalibrationOptions;\n  readonly env?: Record<string, string | undefined>;","lineStart":130,"lineEnd":259,"totalLines":265,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/feedback-calibration.ts","time":{"start":1781128832048,"end":1781128832054}},"metadata":{"openai":{"itemId":"fc_02508314844ac467016a29de7fea9881919f9674650c7ec569"}},"id":"prt_eb38d242f001LVaJwwOf3dcaux","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38cec4d0010WXvLEynEAUnvm"}}
