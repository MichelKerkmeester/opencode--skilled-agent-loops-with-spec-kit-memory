{"type":"tool_use","timestamp":1781756292386,"sessionID":"ses_1270ff7ffffeghChHIr0qZoieH","part":{"type":"tool","tool":"read","callID":"call_G9QOxyNMlBGsYZw5aLmR7urk","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/job-store-cancel-lifecycle.vitest.ts","offset":1,"limit":230},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/job-store-cancel-lifecycle.vitest.ts</path>\n<type>file</type>\n<content>\n1: // TEST: Cancellation primitives — processBatches early-abort + job-store cancel-mirror lifecycle\n2: //\n3: // Direct unit coverage for the two cooperative-cancel primitives that previously\n4: // shipped without it: the real processBatches `shouldAbort` early-abort path, and\n5: // the real in-process `cancelledJobIds` Set lifecycle behind isCancelRequestedFast\n6: // (the handler suite only exercises a vi.fn mock of the helper). Includes the\n7: // cancel-then-fail-while-running leak case: the mirror must be empty after a\n8: // cancelled-then-failed job.\n9: import { afterEach, describe, expect, it, vi } from 'vitest';\n10: \n11: import Database from 'better-sqlite3';\n12: \n13: import { processBatches } from '../utils/batch-processor';\n14: \n15: type JobStoreModule = typeof import('../lib/ops/job-store');\n16: \n17: // ──────────────────────────────────────────────────────────────\n18: // processBatches shouldAbort early-abort\n19: // ──────────────────────────────────────────────────────────────\n20: \n21: describe('processBatches shouldAbort early-abort', () => {\n22:   it('breaks the loop before the first batch when shouldAbort is already true', async () => {\n23:     const processed: number[] = [];\n24:     const items = [1, 2, 3, 4, 5, 6];\n25: \n26:     const results = await processBatches(\n27:       items,\n28:       async (item: number) => {\n29:         processed.push(item);\n30:         return item;\n31:       },\n32:       2, // batchSize → 3 batches\n33:       0, // delayMs\n34:       { shouldAbort: () => true },\n35:     );\n36: \n37:     // No batch ran; no result accumulated.\n38:     expect(processed).toEqual([]);\n39:     expect(results).toEqual([]);\n40:   });\n41: \n42:   it('stops at the next batch top and skips remaining batches once aborted', async () => {\n43:     const processed: number[] = [];\n44:     const items = [1, 2, 3, 4, 5, 6];\n45:     let batchTops = 0;\n46: \n47:     // shouldAbort is evaluated at the top of each batch iteration. It returns\n48:     // false for the first batch, then true once the first batch has run — the\n49:     // loop must break before starting the second batch, leaving batches 2-3\n50:     // (items 3-6) unprocessed.\n51:     const results = await processBatches(\n52:       items,\n53:       async (item: number) => {\n54:         processed.push(item);\n55:         return item;\n56:       },\n57:       2, // batchSize → 3 batches without abort\n58:       0, // delayMs — kept 0 so the suite stays fast; the skip behavior is asserted via processed/results\n59:       {\n60:         shouldAbort: () => {\n61:           batchTops += 1;\n62:           return processed.length >= 2;\n63:         },\n64:       },\n65:     );\n66: \n67:     // Only the first batch's two items ran; remaining batches were skipped.\n68:     expect(processed).toEqual([1, 2]);\n69:     expect(results).toEqual([1, 2]);\n70:     // Checked at each batch top: false (batch 1), then true (batch 2 → break). The\n71:     // third batch's top is never reached, proving remaining batches are skipped.\n72:     expect(batchTops).toBe(2);\n73:   });\n74: \n75:   it('processes every batch when shouldAbort stays false', async () => {\n76:     const processed: number[] = [];\n77:     const items = [1, 2, 3, 4, 5];\n78: \n79:     const results = await processBatches(\n80:       items,\n81:       async (item: number) => {\n82:         processed.push(item);\n83:         return item;\n84:       },\n85:       2,\n86:       0,\n87:       { shouldAbort: () => false },\n88:     );\n89: \n90:     expect(processed.sort((a, b) => a - b)).toEqual([1, 2, 3, 4, 5]);\n91:     expect(results).toHaveLength(5);\n92:   });\n93: });\n94: \n95: // ──────────────────────────────────────────────────────────────\n96: // isCancelRequestedFast / cancelledJobIds Set lifecycle (real semantics)\n97: // ──────────────────────────────────────────────────────────────\n98: \n99: const databases: Array<Database.Database> = [];\n100: \n101: function createTestDb(): Database.Database {\n102:   const db = new Database(':memory:');\n103:   databases.push(db);\n104:   return db;\n105: }\n106: \n107: // Each load runs against a fresh module instance (vi.resetModules), so the\n108: // module-private cancelledJobIds Set is isolated per test — exactly what we need\n109: // to assert add-on-request / clear-on-terminal without cross-test bleed.\n110: async function loadJobStoreModule(db: Database.Database): Promise<JobStoreModule> {\n111:   vi.resetModules();\n112:   vi.doMock('../utils', () => ({\n113:     requireDb: () => db,\n114:     toErrorMessage: (error: unknown) => (error instanceof Error ? error.message : String(error)),\n115:   }));\n116:   return await import('../lib/ops/job-store');\n117: }\n118: \n119: afterEach(() => {\n120:   while (databases.length > 0) {\n121:     const db = databases.pop();\n122:     if (db) db.close();\n123:   }\n124:   vi.resetModules();\n125:   vi.restoreAllMocks();\n126: });\n127: \n128: describe('isCancelRequestedFast cancel-mirror lifecycle', () => {\n129:   it('requestCancel populates the fast mirror and isCancelRequestedFast returns true', async () => {\n130:     const db = createTestDb();\n131:     const mod = await loadJobStoreModule(db);\n132:     mod.ensureMaintenanceJobsTable();\n133: \n134:     await mod.createMaintenanceJob({ id: 'job_fast', kind: 'index_scan' });\n135:     await mod.setJobState('job_fast', 'running');\n136: \n137:     expect(mod.isCancelRequestedFast('job_fast')).toBe(false);\n138:     await mod.requestCancel('job_fast');\n139:     expect(mod.isCancelRequestedFast('job_fast')).toBe(true);\n140:   });\n141: \n142:   it('completeJob clears the fast mirror', async () => {\n143:     const db = createTestDb();\n144:     const mod = await loadJobStoreModule(db);\n145:     mod.ensureMaintenanceJobsTable();\n146: \n147:     await mod.createMaintenanceJob({ id: 'job_complete', kind: 'index_scan' });\n148:     await mod.setJobState('job_complete', 'running');\n149:     await mod.requestCancel('job_complete');\n150:     expect(mod.isCancelRequestedFast('job_complete')).toBe(true);\n151: \n152:     await mod.completeJob('job_complete', { state: 'complete', result: { indexed: 1 } });\n153:     expect(mod.isCancelRequestedFast('job_complete')).toBe(false);\n154:   });\n155: \n156:   it('transition to cancelled via setJobState clears the fast mirror', async () => {\n157:     const db = createTestDb();\n158:     const mod = await loadJobStoreModule(db);\n159:     mod.ensureMaintenanceJobsTable();\n160: \n161:     await mod.createMaintenanceJob({ id: 'job_cancelled', kind: 'index_scan' });\n162:     await mod.setJobState('job_cancelled', 'running');\n163:     await mod.requestCancel('job_cancelled');\n164:     expect(mod.isCancelRequestedFast('job_cancelled')).toBe(true);\n165: \n166:     await mod.setJobState('job_cancelled', 'cancelled');\n167:     expect(mod.isCancelRequestedFast('job_cancelled')).toBe(false);\n168:   });\n169: \n170:   it('cancel-then-fail-while-running clears the fast mirror (leak fix)', async () => {\n171:     const db = createTestDb();\n172:     const mod = await loadJobStoreModule(db);\n173:     mod.ensureMaintenanceJobsTable();\n174: \n175:     // The race: a running job is cancel-requested, then a still-running phase\n176:     // throws and the runner routes it through setJobState('failed'). Before the\n177:     // fix the job-id stayed in cancelledJobIds permanently.\n178:     await mod.createMaintenanceJob({ id: 'job_race', kind: 'index_scan' });\n179:     await mod.setJobState('job_race', 'running');\n180:     await mod.requestCancel('job_race');\n181:     expect(mod.isCancelRequestedFast('job_race')).toBe(true);\n182: \n183:     await mod.setJobState('job_race', 'failed');\n184:     expect(mod.isCancelRequestedFast('job_race')).toBe(false);\n185:   });\n186: \n187:   it('resetRunningJobsForKind clears the fast mirror on crash-recovery reset', async () => {\n188:     const db = createTestDb();\n189:     const mod = await loadJobStoreModule(db);\n190:     mod.ensureMaintenanceJobsTable();\n191: \n192:     await mod.createMaintenanceJob({ id: 'job_recover', kind: 'index_scan' });\n193:     await mod.setJobState('job_recover', 'running');\n194:     await mod.requestCancel('job_recover');\n195:     expect(mod.isCancelRequestedFast('job_recover')).toBe(true);\n196: \n197:     const reset = mod.resetRunningJobsForKind('index_scan', { to: 'failed' });\n198:     expect(reset).toContain('job_recover');\n199:     expect(mod.isCancelRequestedFast('job_recover')).toBe(false);\n200:   });\n201: });\n\n(End of file - total 201 lines)\n</content>","metadata":{"preview":"// TEST: Cancellation primitives — processBatches early-abort + job-store cancel-mirror lifecycle\n//\n// Direct unit coverage for the two cooperative-cancel primitives that previously\n// shipped without it: the real processBatches `shouldAbort` early-abort path, and\n// the real in-process `cancelledJobIds` Set lifecycle behind isCancelRequestedFast\n// (the handler suite only exercises a vi.fn mock of the helper). Includes the\n// cancel-then-fail-while-running leak case: the mirror must be empty after a\n// cancelled-then-failed job.\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport Database from 'better-sqlite3';\n\nimport { processBatches } from '../utils/batch-processor';\n\ntype JobStoreModule = typeof import('../lib/ops/job-store');\n\n// ──────────────────────────────────────────────────────────────\n// processBatches shouldAbort early-abort\n// ──────────────────────────────────────────────────────────────\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/job-store-cancel-lifecycle.vitest.ts","text":"// TEST: Cancellation primitives — processBatches early-abort + job-store cancel-mirror lifecycle\n//\n// Direct unit coverage for the two cooperative-cancel primitives that previously\n// shipped without it: the real processBatches `shouldAbort` early-abort path, and\n// the real in-process `cancelledJobIds` Set lifecycle behind isCancelRequestedFast\n// (the handler suite only exercises a vi.fn mock of the helper). Includes the\n// cancel-then-fail-while-running leak case: the mirror must be empty after a\n// cancelled-then-failed job.\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport Database from 'better-sqlite3';\n\nimport { processBatches } from '../utils/batch-processor';\n\ntype JobStoreModule = typeof import('../lib/ops/job-store');\n\n// ──────────────────────────────────────────────────────────────\n// processBatches shouldAbort early-abort\n// ──────────────────────────────────────────────────────────────\n\ndescribe('processBatches shouldAbort early-abort', () => {\n  it('breaks the loop before the first batch when shouldAbort is already true', async () => {\n    const processed: number[] = [];\n    const items = [1, 2, 3, 4, 5, 6];\n\n    const results = await processBatches(\n      items,\n      async (item: number) => {\n        processed.push(item);\n        return item;\n      },\n      2, // batchSize → 3 batches\n      0, // delayMs\n      { shouldAbort: () => true },\n    );\n\n    // No batch ran; no result accumulated.\n    expect(processed).toEqual([]);\n    expect(results).toEqual([]);\n  });\n\n  it('stops at the next batch top and skips remaining batches once aborted', async () => {\n    const processed: number[] = [];\n    const items = [1, 2, 3, 4, 5, 6];\n    let batchTops = 0;\n\n    // shouldAbort is evaluated at the top of each batch iteration. It returns\n    // false for the first batch, then true once the first batch has run — the\n    // loop must break before starting the second batch, leaving batches 2-3\n    // (items 3-6) unprocessed.\n    const results = await processBatches(\n      items,\n      async (item: number) => {\n        processed.push(item);\n        return item;\n      },\n      2, // batchSize → 3 batches without abort\n      0, // delayMs — kept 0 so the suite stays fast; the skip behavior is asserted via processed/results\n      {\n        shouldAbort: () => {\n          batchTops += 1;\n          return processed.length >= 2;\n        },\n      },\n    );\n\n    // Only the first batch's two items ran; remaining batches were skipped.\n    expect(processed).toEqual([1, 2]);\n    expect(results).toEqual([1, 2]);\n    // Checked at each batch top: false (batch 1), then true (batch 2 → break). The\n    // third batch's top is never reached, proving remaining batches are skipped.\n    expect(batchTops).toBe(2);\n  });\n\n  it('processes every batch when shouldAbort stays false', async () => {\n    const processed: number[] = [];\n    const items = [1, 2, 3, 4, 5];\n\n    const results = await processBatches(\n      items,\n      async (item: number) => {\n        processed.push(item);\n        return item;\n      },\n      2,\n      0,\n      { shouldAbort: () => false },\n    );\n\n    expect(processed.sort((a, b) => a - b)).toEqual([1, 2, 3, 4, 5]);\n    expect(results).toHaveLength(5);\n  });\n});\n\n// ──────────────────────────────────────────────────────────────\n// isCancelRequestedFast / cancelledJobIds Set lifecycle (real semantics)\n// ──────────────────────────────────────────────────────────────\n\nconst databases: Array<Database.Database> = [];\n\nfunction createTestDb(): Database.Database {\n  const db = new Database(':memory:');\n  databases.push(db);\n  return db;\n}\n\n// Each load runs against a fresh module instance (vi.resetModules), so the\n// module-private cancelledJobIds Set is isolated per test — exactly what we need\n// to assert add-on-request / clear-on-terminal without cross-test bleed.\nasync function loadJobStoreModule(db: Database.Database): Promise<JobStoreModule> {\n  vi.resetModules();\n  vi.doMock('../utils', () => ({\n    requireDb: () => db,\n    toErrorMessage: (error: unknown) => (error instanceof Error ? error.message : String(error)),\n  }));\n  return await import('../lib/ops/job-store');\n}\n\nafterEach(() => {\n  while (databases.length > 0) {\n    const db = databases.pop();\n    if (db) db.close();\n  }\n  vi.resetModules();\n  vi.restoreAllMocks();\n});\n\ndescribe('isCancelRequestedFast cancel-mirror lifecycle', () => {\n  it('requestCancel populates the fast mirror and isCancelRequestedFast returns true', async () => {\n    const db = createTestDb();\n    const mod = await loadJobStoreModule(db);\n    mod.ensureMaintenanceJobsTable();\n\n    await mod.createMaintenanceJob({ id: 'job_fast', kind: 'index_scan' });\n    await mod.setJobState('job_fast', 'running');\n\n    expect(mod.isCancelRequestedFast('job_fast')).toBe(false);\n    await mod.requestCancel('job_fast');\n    expect(mod.isCancelRequestedFast('job_fast')).toBe(true);\n  });\n\n  it('completeJob clears the fast mirror', async () => {\n    const db = createTestDb();\n    const mod = await loadJobStoreModule(db);\n    mod.ensureMaintenanceJobsTable();\n\n    await mod.createMaintenanceJob({ id: 'job_complete', kind: 'index_scan' });\n    await mod.setJobState('job_complete', 'running');\n    await mod.requestCancel('job_complete');\n    expect(mod.isCancelRequestedFast('job_complete')).toBe(true);\n\n    await mod.completeJob('job_complete', { state: 'complete', result: { indexed: 1 } });\n    expect(mod.isCancelRequestedFast('job_complete')).toBe(false);\n  });\n\n  it('transition to cancelled via setJobState clears the fast mirror', async () => {\n    const db = createTestDb();\n    const mod = await loadJobStoreModule(db);\n    mod.ensureMaintenanceJobsTable();\n\n    await mod.createMaintenanceJob({ id: 'job_cancelled', kind: 'index_scan' });\n    await mod.setJobState('job_cancelled', 'running');\n    await mod.requestCancel('job_cancelled');\n    expect(mod.isCancelRequestedFast('job_cancelled')).toBe(true);\n\n    await mod.setJobState('job_cancelled', 'cancelled');\n    expect(mod.isCancelRequestedFast('job_cancelled')).toBe(false);\n  });\n\n  it('cancel-then-fail-while-running clears the fast mirror (leak fix)', async () => {\n    const db = createTestDb();\n    const mod = await loadJobStoreModule(db);\n    mod.ensureMaintenanceJobsTable();\n\n    // The race: a running job is cancel-requested, then a still-running phase\n    // throws and the runner routes it through setJobState('failed'). Before the\n    // fix the job-id stayed in cancelledJobIds permanently.\n    await mod.createMaintenanceJob({ id: 'job_race', kind: 'index_scan' });\n    await mod.setJobState('job_race', 'running');\n    await mod.requestCancel('job_race');\n    expect(mod.isCancelRequestedFast('job_race')).toBe(true);\n\n    await mod.setJobState('job_race', 'failed');\n    expect(mod.isCancelRequestedFast('job_race')).toBe(false);\n  });\n\n  it('resetRunningJobsForKind clears the fast mirror on crash-recovery reset', async () => {\n    const db = createTestDb();\n    const mod = await loadJobStoreModule(db);\n    mod.ensureMaintenanceJobsTable();\n\n    await mod.createMaintenanceJob({ id: 'job_recover', kind: 'index_scan' });\n    await mod.setJobState('job_recover', 'running');\n    await mod.requestCancel('job_recover');\n    expect(mod.isCancelRequestedFast('job_recover')).toBe(true);\n\n    const reset = mod.resetRunningJobsForKind('index_scan', { to: 'failed' });\n    expect(reset).toContain('job_recover');\n    expect(mod.isCancelRequestedFast('job_recover')).toBe(false);\n  });\n});","lineStart":1,"lineEnd":201,"totalLines":201,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/job-store-cancel-lifecycle.vitest.ts","time":{"start":1781756292372,"end":1781756292385}},"metadata":{"openai":{"itemId":"fc_0cdb60167c7e219c016a3371835a608191960bbc03b30078de"}},"id":"prt_ed8f3691d001qgm3i4G2xZtTUn","sessionID":"ses_1270ff7ffffeghChHIr0qZoieH","messageID":"msg_ed8f358c7001WbLnXHgmAPYOp4"}}
