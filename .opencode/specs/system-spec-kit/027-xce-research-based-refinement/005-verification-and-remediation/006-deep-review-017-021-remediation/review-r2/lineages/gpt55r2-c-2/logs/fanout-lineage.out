t = new PassThrough();\n205:     const output = new PassThrough();\n206:     let outputText = '';\n207:     output.on('data', (chunk) => { outputText += chunk.toString('utf8'); });\n208:     bridgeModule.bridgeStdioToSocket(sock, { stdin: input, stdout: output, exit: () => undefined });\n209: \n210:     input.write('{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\"}\\n');\n211:     await waitFor(() => outputText.includes('echo:'), 'echoed bridge output');\n212:     expect(outputText).toContain('\"method\":\"tools/list\"');\n213:     serverSocket?.destroy();\n214:   });\n215: \n216:   it('lease-held with socket present enters bridge mode and stays attached', async () => {\n217:     const root = tempDir('launcher-bridge-present-');\n218:     const launcherPath = copyLauncherFixture(root, '.opencode/bin/mk-spec-memory-launcher.cjs');\n219:     const dbDir = join(root, '.opencode/skills/system-spec-kit/mcp_server/database');\n220:     mkdirSync(dbDir, { recursive: true });\n221:     writeFileSync(join(dbDir, '.mk-spec-memory-launcher.json'), JSON.stringify({ pid: process.pid, startedAt: '2026-05-19T00:00:00.000Z' }));\n222:     const server = net.createServer(() => undefined);\n223:     const socketEndpoint = await listenTcp(server);\n224:     if (!socketEndpoint) return;\n225: \n226:     const run = spawnLauncher(root, launcherPath, { SPECKIT_IPC_SOCKET_DIR: socketEndpoint });\n227:     await waitFor(() => run.stderr.includes('bridging to lease holder'), 'bridge log');\n228:     expect(run.child.exitCode).toBeNull();\n229:   });\n230: \n231:   it('lease-held with missing socket exits with no-bridge-socket marker', async () => {\n232:     const root = tempDir('launcher-bridge-missing-');\n233:     const launcherPath = copyLauncherFixture(root, '.opencode/bin/mk-spec-memory-launcher.cjs');\n234:     const dbDir = join(root, '.opencode/skills/system-spec-kit/mcp_server/database');\n235:     mkdirSync(dbDir, { recursive: true });\n236:     writeFileSync(join(dbDir, '.mk-spec-memory-launcher.json'), JSON.stringify({ pid: process.pid, startedAt: '2026-05-19T00:00:00.000Z' }));\n237: \n238:     const run = spawnLauncher(root, launcherPath);\n239:     await waitForExit(run.child);\n240:     expect(run.stdout).toContain(`LEASE_HELD_BY:${process.pid} startedAt=2026-05-19T00:00:00.000Z (no-bridge-socket)`);\n241:   });\n242: \n243:   it('SPECKIT_LAUNCHER_BRIDGE_DISABLED forces legacy lease-held output', async () => {\n244:     const root = tempDir('launcher-bridge-disabled-');\n245:     const launcherPath = copyLauncherFixture(root, '.opencode/bin/mk-spec-memory-launcher.cjs');\n246:     const dbDir = join(root, '.opencode/skills/system-spec-kit/mcp_server/database');\n247:     mkdirSync(dbDir, { recursive: true });\n248:     writeFileSync(join(dbDir, '.mk-spec-memory-launcher.json'), JSON.stringify({ pid: process.pid, startedAt: '2026-05-19T00:00:00.000Z' }));\n\n(Showing lines 169-248 of 337. Use offset=249 to continue.)\n</content>","metadata":{"preview":"// SKIP: requires stable local IPC socket lifecycle — defer to integration env\ndescribe.skip('launcher IPC bridge', () => {\n  afterEach(async () => {\n    while (children.length > 0) {\n      const child = children.pop();\n      if (child && child.exitCode === null && child.signalCode === null) {\n        child.kill('SIGTERM');\n      }\n    }\n    while (handles.length > 0) {\n      const handle = handles.pop();\n      if (handle) await handle.close();\n    }\n    while (servers.length > 0) {\n      const server = servers.pop();\n      if (server) await new Promise<void>((resolvePromise) => server.close(() => resolvePromise()));\n    }\n    while (tempDirs.length > 0) {\n      const dir = tempDirs.pop();\n      if (dir) rmSync(dir, { recursive: true, force: true });","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/launcher-ipc-bridge.vitest.ts","text":"// SKIP: requires stable local IPC socket lifecycle — defer to integration env\ndescribe.skip('launcher IPC bridge', () => {\n  afterEach(async () => {\n    while (children.length > 0) {\n      const child = children.pop();\n      if (child && child.exitCode === null && child.signalCode === null) {\n        child.kill('SIGTERM');\n      }\n    }\n    while (handles.length > 0) {\n      const handle = handles.pop();\n      if (handle) await handle.close();\n    }\n    while (servers.length > 0) {\n      const server = servers.pop();\n      if (server) await new Promise<void>((resolvePromise) => server.close(() => resolvePromise()));\n    }\n    while (tempDirs.length > 0) {\n      const dir = tempDirs.pop();\n      if (dir) rmSync(dir, { recursive: true, force: true });\n    }\n  });\n\n  it('pipes stdin to a unix socket and socket responses to stdout', async () => {\n    let sock = '';\n    let serverSocket: net.Socket | null = null;\n    const server = net.createServer((socket) => {\n      serverSocket = socket;\n      socket.once('data', (chunk) => {\n        socket.write(`echo:${chunk.toString('utf8')}`);\n      });\n    });\n    sock = await listenTcp(server) ?? '';\n    if (!sock) return;\n\n    const input = new PassThrough();\n    const output = new PassThrough();\n    let outputText = '';\n    output.on('data', (chunk) => { outputText += chunk.toString('utf8'); });\n    bridgeModule.bridgeStdioToSocket(sock, { stdin: input, stdout: output, exit: () => undefined });\n\n    input.write('{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/list\"}\\n');\n    await waitFor(() => outputText.includes('echo:'), 'echoed bridge output');\n    expect(outputText).toContain('\"method\":\"tools/list\"');\n    serverSocket?.destroy();\n  });\n\n  it('lease-held with socket present enters bridge mode and stays attached', async () => {\n    const root = tempDir('launcher-bridge-present-');\n    const launcherPath = copyLauncherFixture(root, '.opencode/bin/mk-spec-memory-launcher.cjs');\n    const dbDir = join(root, '.opencode/skills/system-spec-kit/mcp_server/database');\n    mkdirSync(dbDir, { recursive: true });\n    writeFileSync(join(dbDir, '.mk-spec-memory-launcher.json'), JSON.stringify({ pid: process.pid, startedAt: '2026-05-19T00:00:00.000Z' }));\n    const server = net.createServer(() => undefined);\n    const socketEndpoint = await listenTcp(server);\n    if (!socketEndpoint) return;\n\n    const run = spawnLauncher(root, launcherPath, { SPECKIT_IPC_SOCKET_DIR: socketEndpoint });\n    await waitFor(() => run.stderr.includes('bridging to lease holder'), 'bridge log');\n    expect(run.child.exitCode).toBeNull();\n  });\n\n  it('lease-held with missing socket exits with no-bridge-socket marker', async () => {\n    const root = tempDir('launcher-bridge-missing-');\n    const launcherPath = copyLauncherFixture(root, '.opencode/bin/mk-spec-memory-launcher.cjs');\n    const dbDir = join(root, '.opencode/skills/system-spec-kit/mcp_server/database');\n    mkdirSync(dbDir, { recursive: true });\n    writeFileSync(join(dbDir, '.mk-spec-memory-launcher.json'), JSON.stringify({ pid: process.pid, startedAt: '2026-05-19T00:00:00.000Z' }));\n\n    const run = spawnLauncher(root, launcherPath);\n    await waitForExit(run.child);\n    expect(run.stdout).toContain(`LEASE_HELD_BY:${process.pid} startedAt=2026-05-19T00:00:00.000Z (no-bridge-socket)`);\n  });\n\n  it('SPECKIT_LAUNCHER_BRIDGE_DISABLED forces legacy lease-held output', async () => {\n    const root = tempDir('launcher-bridge-disabled-');\n    const launcherPath = copyLauncherFixture(root, '.opencode/bin/mk-spec-memory-launcher.cjs');\n    const dbDir = join(root, '.opencode/skills/system-spec-kit/mcp_server/database');\n    mkdirSync(dbDir, { recursive: true });\n    writeFileSync(join(dbDir, '.mk-spec-memory-launcher.json'), JSON.stringify({ pid: process.pid, startedAt: '2026-05-19T00:00:00.000Z' }));","lineStart":169,"lineEnd":248,"totalLines":337,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/launcher-ipc-bridge.vitest.ts","time":{"start":1781761641840,"end":1781761641844}},"metadata":{"openai":{"itemId":"fc_0998e928192d5a7f016a3386696c0481918d7a818aea011203"}},"id":"prt_ed9450bd4001COPO67pJJSK5Mo","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed944f8ed001wxgX2d82LyeIyQ"}}
