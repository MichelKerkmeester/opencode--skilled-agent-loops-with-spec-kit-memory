   206	      : Math.round(35 * (((fixture.requiredPatterns || []).length - missingPatterns.length) / (fixture.requiredPatterns || []).length));
   207	  const cleanScore =
   208	    (fixture.forbiddenPatterns || []).length === 0
   209	      ? 20
   210	      : Math.round(20 * (((fixture.forbiddenPatterns || []).length - forbiddenMatches.length) / (fixture.forbiddenPatterns || []).length));
