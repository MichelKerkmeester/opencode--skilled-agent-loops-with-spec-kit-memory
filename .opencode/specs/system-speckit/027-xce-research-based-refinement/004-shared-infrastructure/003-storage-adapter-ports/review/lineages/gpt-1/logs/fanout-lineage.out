8. Use offset=180 to continue.)\n</content>","metadata":{"preview":"  complete: new Set<IngestJobState>([]),\n  failed: new Set<IngestJobState>([]),\n  cancelled: new Set<IngestJobState>([]),\n};\n\n// SQLITE_BUSY retry delays that match the file-watcher pattern.\nconst RETRY_DELAYS_MS = [50, 200, 500];\n\n/* ───────────────────────────────────────────────────────────────\n   5. STATE MANAGEMENT\n──────────────────────────────────────────────────────────────── */\n\n// True sequential queue — only one job processes at a time.\nconst pendingQueue: string[] = [];\nlet workerActive = false;\n// Drain fence. Once set, the worker stops draining and refuses to touch the\n// database. This prevents the worker from reopening a connection that shutdown\n// has already checkpointed and closed, which would otherwise re-dirty the WAL\n// and the unclean-shutdown marker at rest.\nlet shuttingDown = false;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","text":"  complete: new Set<IngestJobState>([]),\n  failed: new Set<IngestJobState>([]),\n  cancelled: new Set<IngestJobState>([]),\n};\n\n// SQLITE_BUSY retry delays that match the file-watcher pattern.\nconst RETRY_DELAYS_MS = [50, 200, 500];\n\n/* ───────────────────────────────────────────────────────────────\n   5. STATE MANAGEMENT\n──────────────────────────────────────────────────────────────── */\n\n// True sequential queue — only one job processes at a time.\nconst pendingQueue: string[] = [];\nlet workerActive = false;\n// Drain fence. Once set, the worker stops draining and refuses to touch the\n// database. This prevents the worker from reopening a connection that shutdown\n// has already checkpointed and closed, which would otherwise re-dirty the WAL\n// and the unclean-shutdown marker at rest.\nlet shuttingDown = false;\nlet processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\nconst MAX_STORED_ERRORS = 50;\nconst MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\nconst busyRetryPolicy = new BetterSqliteContentionPolicy({ retryable: isSqliteBusyError });\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isSqliteBusyError(error: unknown): boolean {\n  const message = error instanceof Error ? error.message : String(error);\n  const code = (error as { code?: unknown })?.code;\n  return code === 'SQLITE_BUSY' || /SQLITE_BUSY/i.test(message);\n}\n\nasync function withBusyRetry<T>(operation: () => T): Promise<T> {\n  return busyRetryPolicy.withRetry(operation, { retryDelaysMs: RETRY_DELAYS_MS }) as Promise<T>;\n}\n\nfunction withBusyRetrySync<T>(operation: () => T): T {\n  return busyRetryPolicy.withRetry(operation, {\n    retryDelaysMs: RETRY_DELAYS_MS,\n    sleepSync: busyWait,\n    sync: true,\n  }) as T;\n}\n\nfunction busyWait(ms: number): void {\n  const end = Date.now() + ms;\n  while (Date.now() < end) { /* busy-wait */ }\n}\n\nfunction parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n  if (!value) return fallback;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n  if (!value) return null;","lineStart":100,"lineEnd":179,"totalLines":818,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","time":{"start":1781144237379,"end":1781144237383}},"metadata":{"openai":{"itemId":"fc_0ba4003d6e39c28e016a2a1aad41108191afa3e8ec888a845f"}},"id":"prt_eb478353e0013hAte7cGqsJT7T","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb47811510012rL7rI5MYVyN06"}}
{"type":"tool_use","timestamp":1781144237385,"sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","part":{"type":"tool","tool":"read","callID":"call_pkKay8VGiJPFcRljOasC4vlO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/file-watcher.ts","offset":40,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/file-watcher.ts</path>\n<type>file</type>\n<content>\n40: interface ChokidarModule {\n41:   default: {\n42:     watch: (paths: string[], options: Record<string, unknown>) => FSWatcher;\n43:   };\n44: }\n45: \n46: /* ───────────────────────────────────────────────────────────────\n47:    3. CONSTANTS\n48: ──────────────────────────────────────────────────────────────── */\n49: \n50: const DEFAULT_DEBOUNCE_MS = 2000;\n51: const RETRY_DELAYS_MS = [1000, 2000, 4000];\n52: const MAX_BUSY_RETRIES = RETRY_DELAYS_MS.length;\n53: const busyRetryPolicy = new BetterSqliteContentionPolicy({ retryable: isSqliteBusyError });\n54: \n55: // Watcher metrics counters\n56: let filesReindexed = 0;\n57: let totalReindexTimeMs = 0;\n58: let chokidarModule: ChokidarModule | null = null;\n59: let chokidarModulePromise: Promise<ChokidarModule | null> | null = null;\n60: let chokidarModuleLoadError: string | null = null;\n61: \n62: /** Return accumulated watcher metrics for diagnostics. */\n63: export function getWatcherMetrics(): { filesReindexed: number; avgReindexTimeMs: number } {\n64:   return {\n65:     filesReindexed,\n66:     avgReindexTimeMs: filesReindexed > 0 ? Math.round(totalReindexTimeMs / filesReindexed) : 0,\n67:   };\n68: }\n69: \n70: export function resetWatcherMetrics(): void {\n71:   filesReindexed = 0;\n72:   totalReindexTimeMs = 0;\n73: }\n74: \n75: /* ───────────────────────────────────────────────────────────────\n76:    4. HELPERS\n77: ──────────────────────────────────────────────────────────────── */\n78: \n79: function sleep(ms: number): Promise<void> {\n80:   return new Promise((resolve) => setTimeout(resolve, ms));\n81: }\n82: \n83: /**\n84:  * Coordinates early wake-up of in-flight retry sleeps so a watcher shutdown\n85:  * never has to wait for a pending backoff timer to expire. A retry sleep\n86:  * registers a `wake` callback; `wakeAll()` settles every outstanding sleep\n87:  * immediately, letting each one re-check its abort condition. This keeps\n88:  * `close()` from blocking on a non-cancellable timer (and from deadlocking\n89:  * under fake timers, where the backoff timeout would otherwise never fire).\n90:  */\n91: interface RetryWaker {\n92:   register(wake: () => void): () => void;\n93:   wakeAll(): void;\n94: }\n95: \n96: function createRetryWaker(): RetryWaker {\n97:   const waiters = new Set<() => void>();\n98:   let woken = false;\n99:   return {\n100:     register(wake: () => void): () => void {\n101:       // Sticky after wakeAll(): a sleep entered after shutdown began is woken\n102:       // at once, so a task that hits SQLITE_BUSY mid-close still exits promptly\n103:       // instead of stalling close() on a fresh retry timer.\n104:       if (woken) {\n105:         wake();\n106:         return () => undefined;\n107:       }\n108:       waiters.add(wake);\n109:       return () => { waiters.delete(wake); };\n110:     },\n111:     wakeAll(): void {\n112:       woken = true;\n113:       const pending = Array.from(waiters);\n114:       waiters.clear();\n115:       for (const wake of pending) {\n116:         wake();\n117:       }\n118:     },\n119:   };\n\n(Showing lines 40-119 of 616. Use offset=120 to continue.)\n</content>","metadata":{"preview":"interface ChokidarModule {\n  default: {\n    watch: (paths: string[], options: Record<string, unknown>) => FSWatcher;\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nconst DEFAULT_DEBOUNCE_MS = 2000;\nconst RETRY_DELAYS_MS = [1000, 2000, 4000];\nconst MAX_BUSY_RETRIES = RETRY_DELAYS_MS.length;\nconst busyRetryPolicy = new BetterSqliteContentionPolicy({ retryable: isSqliteBusyError });\n\n// Watcher metrics counters\nlet filesReindexed = 0;\nlet totalReindexTimeMs = 0;\nlet chokidarModule: ChokidarModule | null = null;\nlet chokidarModulePromise: Promise<ChokidarModule | null> | null = null;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/file-watcher.ts","text":"interface ChokidarModule {\n  default: {\n    watch: (paths: string[], options: Record<string, unknown>) => FSWatcher;\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nconst DEFAULT_DEBOUNCE_MS = 2000;\nconst RETRY_DELAYS_MS = [1000, 2000, 4000];\nconst MAX_BUSY_RETRIES = RETRY_DELAYS_MS.length;\nconst busyRetryPolicy = new BetterSqliteContentionPolicy({ retryable: isSqliteBusyError });\n\n// Watcher metrics counters\nlet filesReindexed = 0;\nlet totalReindexTimeMs = 0;\nlet chokidarModule: ChokidarModule | null = null;\nlet chokidarModulePromise: Promise<ChokidarModule | null> | null = null;\nlet chokidarModuleLoadError: string | null = null;\n\n/** Return accumulated watcher metrics for diagnostics. */\nexport function getWatcherMetrics(): { filesReindexed: number; avgReindexTimeMs: number } {\n  return {\n    filesReindexed,\n    avgReindexTimeMs: filesReindexed > 0 ? Math.round(totalReindexTimeMs / filesReindexed) : 0,\n  };\n}\n\nexport function resetWatcherMetrics(): void {\n  filesReindexed = 0;\n  totalReindexTimeMs = 0;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\n/**\n * Coordinates early wake-up of in-flight retry sleeps so a watcher shutdown\n * never has to wait for a pending backoff timer to expire. A retry sleep\n * registers a `wake` callback; `wakeAll()` settles every outstanding sleep\n * immediately, letting each one re-check its abort condition. This keeps\n * `close()` from blocking on a non-cancellable timer (and from deadlocking\n * under fake timers, where the backoff timeout would otherwise never fire).\n */\ninterface RetryWaker {\n  register(wake: () => void): () => void;\n  wakeAll(): void;\n}\n\nfunction createRetryWaker(): RetryWaker {\n  const waiters = new Set<() => void>();\n  let woken = false;\n  return {\n    register(wake: () => void): () => void {\n      // Sticky after wakeAll(): a sleep entered after shutdown began is woken\n      // at once, so a task that hits SQLITE_BUSY mid-close still exits promptly\n      // instead of stalling close() on a fresh retry timer.\n      if (woken) {\n        wake();\n        return () => undefined;\n      }\n      waiters.add(wake);\n      return () => { waiters.delete(wake); };\n    },\n    wakeAll(): void {\n      woken = true;\n      const pending = Array.from(waiters);\n      waiters.clear();\n      for (const wake of pending) {\n        wake();\n      }\n    },\n  };","lineStart":40,"lineEnd":119,"totalLines":616,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/file-watcher.ts","time":{"start":1781144237381,"end":1781144237384}},"metadata":{"openai":{"itemId":"fc_0ba4003d6e39c28e016a2a1aad411481919c9a6d5e9b19eae8"}},"id":"prt_eb4783544001tjpTJYLhemMeUz","sessionID":"ses_14b8a0226ffeqM34sND4WLFHSs","messageID":"msg_eb47811510012rL7rI5MYVyN06"}}
