   307	/**
   308	 * Find claim nodes whose metadata verification_status is not 'verified'.
   309	 *
   310	 * For research: CLAIM nodes with status != 'verified'.
   311	 * For review: FINDING nodes with no RESOLVES edges.
   312	 *
   313	 * @param ns - Namespace identifying the coverage graph.
   314	 * @returns Array of unverified coverage nodes.
   315	 */
   316	export function findUnverifiedClaims(ns: Namespace): CoverageNode[] {
   317	  const d = getDb();
   318	  const { loopType } = ns;
   319	
   320	  if (loopType === 'research') {
   321	    const nodeNamespace = buildNamespacePredicate('', ns);
   322	    const rows = d.prepare(`
   323	      SELECT * FROM coverage_nodes
   324	      WHERE ${nodeNamespace.clause}
   325	        AND kind = 'CLAIM'
   326	    `).all(...nodeNamespace.params) as Record<string, unknown>[];
   327	
   328	    return rows
   329	      .map(r => ({
   330	        id: r.id as string,
   331	        specFolder: r.spec_folder as string,
   332	        loopType: r.loop_type as string,
   333	        sessionId: r.session_id as string,
   334	        kind: r.kind as string,
   335	        name: r.name as string,
   336	        contentHash: r.content_hash as string | undefined,
   337	        iteration: r.iteration as number | undefined,
   338	        metadata: r.metadata ? JSON.parse(r.metadata as string) : undefined,
   339	        createdAt: r.created_at as string | undefined,
   340	        updatedAt: r.updated_at as string | undefined,
   341	      }))
   342	      .filter(n => {
   343	        const status = n.metadata?.verification_status;
   344	        return status !== 'verified';
   345	      }) as CoverageNode[];
   346	  }
   347	
   348	  const reviewNodeNamespace = buildNamespacePredicate('n', ns);
   349	  const reviewEdgeNamespace = buildNamespacePredicate('e', ns);
   350	  const rows = d.prepare(`
   351	    SELECT n.* FROM coverage_nodes n
   352	    WHERE ${reviewNodeNamespace.clause}
   353	      AND n.kind = 'FINDING'
   354	      AND NOT EXISTS (
   355	        SELECT 1 FROM coverage_edges e
   356	        WHERE ${reviewEdgeNamespace.clause}
   357	          AND e.target_id = n.id
   358	          AND e.relation = 'RESOLVES'
   359	      )
   360	  `).all(
   361	    ...reviewNodeNamespace.params,
   362	    ...reviewEdgeNamespace.params,
   363	  ) as Record<string, unknown>[];
   364	
   365	  return rows.map(r => ({
   366	    id: r.id as string,
   367	    specFolder: r.spec_folder as string,
   368	    loopType: r.loop_type as string,
   369	    sessionId: r.session_id as string,
   370	    kind: r.kind as string,
   371	    name: r.name as string,
   372	    contentHash: r.content_hash as string | undefined,
   373	    iteration: r.iteration as number | undefined,
   374	    metadata: r.metadata ? JSON.parse(r.metadata as string) : undefined,
   375	    createdAt: r.created_at as string | undefined,
   376	    updatedAt: r.updated_at as string | undefined,
   377	  })) as CoverageNode[];
   378	}
