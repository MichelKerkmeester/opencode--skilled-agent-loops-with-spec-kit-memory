{"type":"tool_use","timestamp":1781722672924,"sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","part":{"type":"tool","tool":"read","callID":"call_00_CbszJ0MZ61WaSwJmnuRf5841","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Hybrid Search\n3: // ───────────────────────────────────────────────────────────────\n4: // Combines vector, FTS, and BM25 search with fallback\n5: \n6: // 1. IMPORTS\n7: \n8: // Local\n9: import {\n10:   getIndex,\n11:   isBm25Enabled,\n12:   shouldUseSqliteLexicalEngine,\n13: } from './bm25-index.js';\n14: import { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\n15: import { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\n16: import { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\n17: import { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\n18: import { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\n19: import { fts5Bm25Search } from './sqlite-fts.js';\n20: import { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';\n21: import {\n22:   isMMREnabled,\n23:   isSearchFallbackEnabled,\n24:   isDocscoreAggregationEnabled,\n25:   isDegreeBoostEnabled,\n26:   isContextHeadersEnabled,\n27:   isArchivedRetrievalIncludedByDefault,\n28:   isCosineTopnReorderEnabled,\n29: } from './search-flags.js';\n30: import { resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\n31: import { computeDegreeScores } from './graph-search-fn.js';\n32: import type { GraphSearchFn } from './search-types.js';\n33: \n34: // Feature catalog: Hybrid search pipeline\n35: \n36: export type { GraphSearchFn } from './search-types.js';\n37: \n38: import { routeQuery } from './query-router.js';\n39: import { isComplexityRouterEnabled } from './query-classifier.js';\n40: import { enforceChannelRepresentation } from './channel-enforcement.js';\n41: import {\n42:   truncateByConfidence,\n43:   isConfidenceTruncationEnabled,\n44:   DEFAULT_MIN_RESULTS,\n45:   GAP_THRESHOLD_MULTIPLIER,\n46: } from './confidence-truncation.js';\n47: import {\n48:   getDynamicTokenBudget,\n49:   isDynamicTokenBudgetEnabled,\n50:   DEFAULT_TOKEN_BUDGET_CONFIG,\n51: } from './dynamic-token-budget.js';\n52: import {\n53:   buildProgressiveResponse,\n54:   DEFAULT_PAGE_SIZE,\n55: } from './progressive-disclosure.js';\n56: import type {\n57:   ProgressiveResponse,\n58:   DisclosureResult,\n59: } from './progressive-disclosure.js';\n60: import { resolveFusionIntentContract } from './search-utils.js';\n61: import { ensureDescriptionCache, getSpecsBasePaths } from './folder-discovery.js';\n62: import {\n63:   isFolderScoringEnabled,\n64:   lookupFolders,\n65:   computeFolderRelevanceScores,\n66:   enrichResultsWithFolderScores,\n67:   twoPhaseRetrieval,\n68: } from './folder-relevance.js';\n69: import { parse_trigger_phrases, specFolderLikePattern } from './vector-index-types.js';\n70: \n71: import { collapseAndReassembleChunkResults } from '../scoring/mpab-aggregation.js';\n72: \n73: // Type-only\n74: import type Database from 'better-sqlite3';\n75: import type { SpreadResult } from '../cognitive/co-activation.js';\n76: import type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\n77: import type { FusionResult } from '@spec-kit/shared/algorithms/rrf-fusion';\n78: import type { ChannelName } from './query-router.js';\n79: import type { EnforcementResult } from './channel-enforcement.js';\n80: import type { TruncationResult } from './confidence-truncation.js';\n81: \n82: // 2. INTERFACES\n83: \n84: type VectorSearchFn = (\n85:   embedding: Float32Array | number[],\n86:   options: Record<string, unknown>\n87: ) => Array<Record<string, unknown>>;\n88: \n89: interface HybridSearchOptions {\n90:   limit?: number;\n91:   specFolder?: string;\n92:   minSimilarity?: number;\n93:   useBm25?: boolean;\n94:   useFts?: boolean;\n95:   useVector?: boolean;\n96:   useGraph?: boolean;\n97:   includeArchived?: boolean;\n98:   includeContent?: boolean;\n99:   /**\n100:    * Evaluation-only mode.\n101:    * When true, preserve the requested top-K window by bypassing confidence\n102:    * truncation and token-budget truncation without changing live defaults.\n103:    */\n104:   evaluationMode?: boolean;\n105:   /** Classified query intent for adaptive fusion weight selection (e.g. 'understand', 'fix_bug'). */\n106:   intent?: string;\n107:   /** Optional trigger phrases for query-classifier trigger-match routing path. */\n108:   triggerPhrases?: string[];\n109:   /**\n110:    * Internal fallback override: when true, bypass complexity routing and\n111:    * enable all retrieval channels for this search call.\n112:    */\n113:   forceAllChannels?: boolean;\n114:   /**\n115:    * Internal raw-candidate mode used by the Stage 1 pipeline.\n116:    * When true, stop after channel collection and return pre-fusion candidates.\n117:    */\n118:   skipFusion?: boolean;\n119:   /**\n120:    * Internal pipeline handoff mode.\n121:    * When true, return immediately after adaptive/RRF fusion so Stage 2/3 can\n122:    * apply the remaining pipeline scoring and aggregation steps.\n123:    */\n124:   stopAfterFusion?: boolean;\n125: }\n126: \n127: interface HybridSearchResult {\n128:   id: number | string;\n129:   /**\n130:    * Normalized relevance score (0-1). Semantics depend on `source`:\n131:    * - `'vector'` — cosine similarity from sqlite-vec (normalized from 0-100 to 0-1)\n132:    * - `'bm25'` — BM25 term-frequency relevance (min-max normalized per source group)\n133:    * - `'fts'` — FTS5 rank score (absolute value, min-max normalized per source group)\n134:    * - `'graph'` — graph traversal relevance\n135:    *\n136:    * After hybrid merge, all source scores are min-max normalized to 0-1 within\n137:    * their source group to ensure fair cross-method comparison.\n138:    */\n139:   score: number;\n140:   source: string;\n141:   title?: string;\n142:   [key: string]: unknown;\n143: }\n144: \n145: type HardExclusionSource = 'archived-tier' | 'deprecated-tier';\n146: type HardExclusionClassification = 'intended' | 'silent-risk' | 'unclassified';\n147: \n148: interface HardExclusionPredicate {\n149:   id: string;\n150:   source: HardExclusionSource;\n151:   channel: string;\n152:   predicate: string;\n153:   defaultApplied: boolean;\n154:   classification: HardExclusionClassification;\n155: }\n156: \n157: const HARD_EXCLUSION_PREDICATES: readonly HardExclusionPredicate[] = Object.freeze([\n158:   {\n159:     id: 'includeArchived-default',\n160:     source: 'archived-tier',\n161:     channel: 'vector/fts',\n162:     predicate: 'includeArchived defaults to false',\n163:     defaultApplied: true,\n164:     classification: 'intended',\n165:   },\n166:   {\n167:     id: 'fts-deprecated-tier',\n168:     source: 'deprecated-tier',\n169:     channel: 'fts',\n170:     predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n171:     defaultApplied: true,\n172:     classification: 'silent-risk',\n173:   },\n174:   {\n175:     id: 'bm25-deprecated-tier',\n176:     source: 'deprecated-tier',\n177:     channel: 'bm25',\n178:     predicate: \"importance_tier != 'deprecated'\",\n179:     defaultApplied: true,\n180:     classification: 'silent-risk',\n181:   },\n182:   {\n183:     id: 'trigger-deprecated-tier',\n184:     source: 'deprecated-tier',\n185:     channel: 'trigger',\n186:     predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n187:     defaultApplied: true,\n188:     classification: 'silent-risk',\n189:   },\n190:   {\n191:     id: 'structural-deprecated-archived-tier',\n192:     source: 'deprecated-tier',\n193:     channel: 'structural',\n194:     predicate: \"importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived')\",\n195:     defaultApplied: true,\n196:     classification: 'silent-risk',\n197:   },\n198: ]);\n199: \n200: /** Return recall-path exclusion metadata without executing or changing search. */\n201: function getHardExclusionPredicates(): HardExclusionPredicate[] {\n202:   return HARD_EXCLUSION_PREDICATES.map((predicate) => ({ ...predicate }));\n203: }\n204: \n205: type Bm25MemoryMetadata = {\n206:   specFolder: string | null;\n207:   importanceTier: string | null;\n208: };\n209: \n210: /** Non-enumerable shadow metadata attached to result arrays via Object.defineProperty. */\n211: interface ShadowMetaArray {\n212:   _s4shadow?: unknown;\n213:   _s4attribution?: unknown;\n214:   _degradation?: unknown;\n215: }\n216: \n217: /** Normalize a fused RRF result to the HybridSearchResult contract. */\n218: function toHybridResult(result: FusionResult): HybridSearchResult {\n219:   const sourceCandidate = (result as { source?: unknown }).source;\n220:   const primarySource = result.sources[0] ?? 'hybrid';\n221:   const scoreCandidate = (result as { score?: unknown }).score;\n222: \n223:   return {\n224:     ...result,\n225:     id: result.id,\n226:     score: typeof scoreCandidate === 'number' ? scoreCandidate : result.rrfScore,\n227:     source: typeof sourceCandidate === 'string' ? sourceCandidate : primarySource,\n228:   };\n229: }\n230: \n231: // PIPELINE METADATA\n232: \n233: /**\n234:  * Optional metadata about pipeline stages attached to enhanced search results.\n235:  * Only populated when the corresponding feature flags are enabled.\n236:  */\n237: interface Sprint3PipelineMeta {\n238:   /** Query complexity routing result (SPECKIT_COMPLEXITY_ROUTER). */\n239:   routing?: {\n240:     tier: string;\n241:     channels: string[];\n242:     skippedChannels: string[];\n243:     featureFlagEnabled: boolean;\n244:     confidence: string;\n245:     features: Record<string, unknown>;\n246:   };\n247:   /** Channel enforcement result (SPECKIT_CHANNEL_MIN_REP). */\n248:   enforcement?: { applied: boolean; promotedCount: number; underRepresentedChannels: string[] };\n249:   /** Confidence truncation result (SPECKIT_CONFIDENCE_TRUNCATION). */\n250:   truncation?: {\n251:     truncated: boolean;\n252:     originalCount: number;\n253:     truncatedCount: number;\n254:     medianGap: number;\n255:     cutoffGap: number;\n256:     cutoffIndex: number;\n257:     thresholdMultiplier: number;\n258:     minResultsGuaranteed: number;\n259:     featureFlagEnabled: boolean;\n260:   };\n261:   /** Dynamic token budget result (SPECKIT_DYNAMIC_TOKEN_BUDGET). */\n262:   tokenBudget?: {\n263:     tier: string;\n264:     budget: number;\n265:     applied: boolean;\n266:     featureFlagEnabled: boolean;\n267:     configValues: Record<string, number>;\n268:     headerOverhead: number;\n269:     adjustedBudget: number;\n270:   };\n271: }\n272: \n273: // 4. PI-A2: DEGRADATION TYPES\n274: \n275: /** Fallback tier in the 3-tier degradation chain. */\n276: type FallbackTier = 1 | 2 | 3;\n277: \n278: /** Why degradation was triggered at a given tier. */\n279: interface DegradationTrigger {\n280:   reason: 'low_quality' | 'insufficient_results' | 'both';\n281:   topScore: number;\n282:   resultCount: number;\n283:   relativeGap?: number;\n284: }\n285: \n286: /** Record of a single degradation event during tiered fallback. */\n287: interface DegradationEvent {\n288:   tier: FallbackTier;\n289:   trigger: DegradationTrigger;\n290:   resultCountBefore: number;\n291:   resultCountAfter: number;\n292: }\n293: \n294: /**\n295:  * Absolute quality floor for degradation checks.\n296:  *\n297:  * Raw RRF scores are typically small decimals (often <0.05), so a\n298:  * high fixed threshold causes false degradations. Use a conservative floor and\n299:  * pair it with a relative-gap check to avoid score-scale coupling.\n300:  */\n301: const DEGRADATION_QUALITY_THRESHOLD = 0.02;\n302: \n303: /** Minimum relative separation between top-1 and top-2 scores. */\n304: const DEGRADATION_MIN_RELATIVE_GAP = 0.2;\n305: \n306: /** Minimum result count: must have >= this many results to stay at current tier. */\n307: const DEGRADATION_MIN_RESULTS = 3;\n308: \n309: // 5. MODULE STATE\n310: \n311: /** Default result limit when none is specified by the caller. */\n312: const DEFAULT_LIMIT = 20;\n313: /** Primary vector similarity floor for hybrid fallback passes (percentage units). */\n314: const PRIMARY_FALLBACK_MIN_SIMILARITY = 30;\n315: /** Secondary vector similarity floor for adaptive retry passes (percentage units). */\n316: const SECONDARY_FALLBACK_MIN_SIMILARITY = 17;\n317: /** Tier-2 vector similarity floor for quality-aware fallback (percentage units). */\n318: const TIERED_FALLBACK_MIN_SIMILARITY = 10;\n319: \n320: /** Minimum MMR candidates required for diversity reranking to be worthwhile. */\n321: const MMR_MIN_CANDIDATES = 2;\n322: \n323: /** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\n324: const MMR_DEFAULT_LAMBDA = 0.7;\n325: \n326: /** Number of top results used as seeds for co-activation spreading. */\n327: const SPREAD_ACTIVATION_TOP_N = 5;\n328: \n329: /** Maximum contextual tree header length prepended to content (including brackets). */\n330: const CONTEXT_HEADER_MAX_CHARS = 100;\n331: /** Header/content separator characters added during contextual tree injection. */\n332: const CONTEXT_HEADER_SEPARATOR_CHARS = 1;\n333: /** Reserved token overhead per contextual header, calibrated to max header length. */\n334: const CONTEXT_HEADER_TOKEN_OVERHEAD = Math.ceil(\n335:   (CONTEXT_HEADER_MAX_CHARS + CONTEXT_HEADER_SEPARATOR_CHARS) / 4\n336: );\n337: \n338: let db: Database.Database | null = null;\n339: let vectorSearchFn: VectorSearchFn | null = null;\n340: let graphSearchFn: GraphSearchFn | null = null;\n341: let enrichFusedResultsObserver: (() => void) | null = null;\n342: \n343: // 6. GRAPH CHANNEL METRICS\n344: \n345: interface GraphChannelMetrics {\n346:   totalQueries: number;\n347:   graphHits: number;\n348:   graphResultCount: number;\n349:   graphOnlyResults: number;\n350:   graphMultiSourceResults: number;\n351:   multiSourceResults: number;\n352:   degreeQueries: number;\n353:   degreeHits: number;\n354:   degreeResultCount: number;\n355: }\n356: \n357: const graphMetrics: GraphChannelMetrics = {\n358:   totalQueries: 0,\n359:   graphHits: 0,\n360:   graphResultCount: 0,\n361:   graphOnlyResults: 0,\n362:   graphMultiSourceResults: 0,\n363:   multiSourceResults: 0,\n364:   degreeQueries: 0,\n365:   degreeHits: 0,\n366:   degreeResultCount: 0,\n367: };\n368: \n369: /**\n370:  * Return current graph channel metrics for health check reporting.\n371:  * graphHitRate is computed as graphHits / totalQueries.\n372:  */\n373: function getGraphMetrics(): GraphChannelMetrics & { graphHitRate: number; degreeHitRate: number } {\n374:   return {\n375:     ...graphMetrics,\n376:     graphHitRate: graphMetrics.totalQueries > 0\n377:       ? graphMetrics.graphHits / graphMetrics.totalQueries\n378:       : 0,\n379:     degreeHitRate: graphMetrics.degreeQueries > 0\n380:       ? graphMetrics.degreeHits / graphMetrics.degreeQueries\n381:       : 0,\n382:   };\n383: }\n384: \n385: /** Reset all graph channel metrics counters to zero. */\n386: function resetGraphMetrics(): void {\n387:   graphMetrics.totalQueries = 0;\n388:   graphMetrics.graphHits = 0;\n389:   graphMetrics.graphResultCount = 0;\n390:   graphMetrics.graphOnlyResults = 0;\n391:   graphMetrics.graphMultiSourceResults = 0;\n392:   graphMetrics.multiSourceResults = 0;\n393:   graphMetrics.degreeQueries = 0;\n394:   graphMetrics.degreeHits = 0;\n395:   graphMetrics.degreeResultCount = 0;\n396: }\n397: \n398: // 7. INITIALIZATION\n399: \n400: /**\n401:  * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n402:  * @param database - The better-sqlite3 database instance for FTS and graph queries.\n403:  * @param vectorFn - Optional vector search function for semantic similarity.\n404:  * @param graphFn - Optional graph search function for causal/structural retrieval.\n405:  */\n406: function init(\n407:   database: Database.Database,\n408:   vectorFn: VectorSearchFn | null = null,\n409:   graphFn: GraphSearchFn | null = null\n410: ): void {\n411:   db = database;\n412:   vectorSearchFn = vectorFn;\n413:   graphSearchFn = graphFn;\n414: }\n415: \n416: // 8. BM25 SEARCH\n417: \n418: /**\n419:  * Search the BM25 index with optional spec folder filtering.\n420:  * @param query - The search query string.\n421:  * @param options - Optional limit and specFolder filter.\n422:  * @returns Array of BM25-scored results tagged with source 'bm25'.\n423:  */\n424: function bm25Search(\n425:   query: string,\n426:   options: { limit?: number; specFolder?: string } = {}\n427: ): HybridSearchResult[] {\n428:   if (!isBm25Enabled()) {\n429:     console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n430:     return [];\n431:   }\n432: \n433:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n434: \n435:   try {\n436:     if (shouldUseSqliteLexicalEngine(db)) {\n437:       return ftsSearch(query, {\n438:         limit,\n439:         specFolder,\n440:       }).map((result) => ({\n441:         ...result,\n442:         bm25_score: result.score,\n443:         source: 'bm25',\n444:         sources: Array.from(new Set([\n445:           ...(\n446:             Array.isArray((result as Record<string, unknown>).sources)\n447:               ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n448:               : []\n449:           ),\n450:           'fts',\n451:           'bm25',\n452:         ])),\n453:       }));\n454:     }\n455: \n456:     // Spec-folder scope can only be resolved from DB metadata; fail closed before\n457:     // searching when the DB is unavailable rather than over-fetching the whole\n458:     // corpus and then discarding it.\n459:     if (specFolder && !db) {\n460:       console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n461:       return [];\n462:     }\n463: \n464:     const index = getIndex();\n465:     const candidateLimit = (specFolder || db)\n466:       ? index.getStats().documentCount\n467:       : limit;\n468:     // Metadata filters run after in-memory scoring, so fetch the corpus-bounded\n469:     // candidate set whenever those filters can remove otherwise top-ranked hits.\n470:     const results = index.search(query, candidateLimit);\n471: \n472:     // BM25 document IDs are stringified\n473:     // Numeric memory IDs (e.g., \"42\"), not spec folder paths. The old filter compared\n474:     // R.id against specFolder which never matched. Use DB lookup to resolve spec_folder.\n475: \n476:     // Batch-resolve metadata for all result IDs (was N+1 individual queries)\n477:     // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n478:     // resolution returns [] rather than leaking unscoped BM25 candidates.\n479:     let memoryMetadataMap: Map<number, Bm25MemoryMetadata> | null = null;\n480:     if (results.length > 0) {\n481:       if (!db) {\n482:         if (specFolder) {\n483:           const error = new Error('Database unavailable for spec-folder scope lookup');\n484:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n485:           return [];\n486:         }\n487:       } else {\n488:         try {\n489:           const ids = results.map((r: { id: string }) => Number(r.id));\n490:           memoryMetadataMap = new Map();\n491:           // Resolve metadata in bounded batches. The candidate set can now be\n492:           // corpus-sized (over-fetch for scope/tier filtering), and a single\n493:           // IN (...) with one bind per id would exceed SQLite's parameter limit\n494:           // and throw — which the catch below turns into an empty result.\n495:           const METADATA_BATCH = 500;\n496:           for (let offset = 0; offset < ids.length; offset += METADATA_BATCH) {\n497:             const batch = ids.slice(offset, offset + METADATA_BATCH);\n498:             const placeholders = batch.map(() => '?').join(',');\n499:             const rows = db.prepare(\n500:               `SELECT id, spec_folder, importance_tier FROM memory_index WHERE id IN (${placeholders})`\n501:             ).all(...batch) as Array<{ id: number; spec_folder: string | null; importance_tier: string | null }>;\n502:             for (const row of rows) {\n503:               memoryMetadataMap.set(row.id, {\n504:                 specFolder: row.spec_folder,\n505:                 importanceTier: row.importance_tier,\n506:               });\n507:             }\n508:           }\n509:         } catch (error: unknown) {\n510:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n511:           return [];\n512:         }\n513:       }\n514: \n515:       // DEFENSE-IN-DEPTH: If specFolder was requested but metadata resolution\n516:       // is still null after the resolution block, something unexpected happened.\n517:       // Fail closed rather than falling through to unscoped results.\n518:       if (specFolder && !memoryMetadataMap) {\n519:         const error = new Error('memoryMetadataMap unexpectedly null after scope resolution');\n520:         console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n521:         return [];\n522:       }\n523:     }\n524: \n525:     const excludeCold = !isArchivedRetrievalIncludedByDefault();\n526:     return results\n527:       .filter((r: { id: string }) => {\n528:         const metadata = memoryMetadataMap?.get(Number(r.id));\n529:         // Cold/deprecated rows are included by default (FSRS ranks them lower);\n530:         // only drop them when archived retrieval is disabled.\n531:         if (excludeCold && metadata?.importanceTier === 'deprecated') return false;\n532:         if (!specFolder) return true;\n533:         if (!metadata) return false;\n534:         const folder = metadata.specFolder;\n535:         if (!folder) return false;\n536:         return folder === specFolder || folder.startsWith(specFolder + '/');\n537:       })\n538:       .slice(0, limit)\n539:       .map((r: { id: string; score: number }) => ({\n540:         ...r,\n541:         source: 'bm25',\n542:       }));\n543:   } catch (error: unknown) {\n544:     const msg = error instanceof Error ? error.message : String(error);\n545:     console.warn(`[hybrid-search] BM25 search failed: ${msg}`);\n546:     return [];\n547:   }\n548: }\n549: \n550: /**\n551:  * Check whether the BM25 index is populated and available for search.\n552:  * @returns True if the BM25 index exists and contains at least one document.\n553:  */\n554: function isBm25Available(): boolean {\n555:   if (!isBm25Enabled()) {\n556:     return false;\n557:   }\n558: \n559:   try {\n560:     const index = getIndex();\n561:     return index.getStats().documentCount > 0;\n562:   } catch (_err: unknown) {\n563:     // Swallow index-not-initialized errors; caller treats absence as unavailable\n564:     return false;\n565:   }\n566: }\n567: \n568: // 9. FTS SEARCH\n569: \n570: /**\n571:  * Check whether the FTS5 full-text search table exists in the database.\n572:  * @returns True if the memory_fts table exists in the connected database.\n573:  */\n574: function isFtsAvailable(): boolean {\n575:   if (!db) {\n576:     console.warn('[hybrid-search] db not initialized — isFtsAvailable returning false');\n577:     return false;\n578:   }\n579: \n580:   try {\n581:     const result = (db.prepare(`\n582:       SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'\n583:     `) as Database.Statement).get() as { name: string } | undefined;\n584:     return !!result;\n585:   } catch (_err: unknown) {\n586:     // Swallow DB errors; caller treats absence as unavailable\n587:     return false;\n588:   }\n589: }\n590: \n591: /**\n592:  * Run FTS5 full-text search with weighted BM25 scoring and optional spec folder filtering.\n593:  * @param query - The search query string.\n594:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n595:  * @returns Array of FTS-scored results tagged with source 'fts'.\n596:  */\n597: function ftsSearch(\n598:   query: string,\n599:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n600: ): HybridSearchResult[] {\n601:   if (!db || !isFtsAvailable()) {\n602:     console.warn('[hybrid-search] db not initialized or FTS unavailable — returning empty ftsSearch results');\n603:     return [];\n604:   }\n605: \n606:   const { limit = DEFAULT_LIMIT, specFolder, includeArchived = false } = options;\n607: \n608:   try {\n609:     // Delegate to weighted BM25 FTS5 search from sqlite-fts.ts\n610:     // Uses bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) for per-column weighting\n611:     // (title 10x, trigger_phrases 5x, file_path 2x, content 1x)\n612:     // Filters: deprecated-tier exclusion and spec-folder matching handled by fts5Bm25Search\n613:     const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n614: \n615:     return bm25Results.map(row => ({\n616:       ...row,\n617:       id: row.id as number,\n618:       score: row.fts_score || 0,\n619:       source: 'fts',\n620:     }));\n621:   } catch (error: unknown) {\n622:     const msg = error instanceof Error ? error.message : String(error);\n623:     console.warn(`[hybrid-search] FTS search failed: ${msg}`);\n624:     return [];\n625:   }\n626: }\n627: \n628: // 10. COMBINED LEXICAL SEARCH\n629: \n630: /**\n631:  * Merge FTS and BM25 search results, deduplicating by ID and preferring FTS scores.\n632:  * @param query - The search query string.\n633:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n634:  * @returns Deduplicated array of merged results sorted by score descending.\n635:  */\n636: function combinedLexicalSearch(\n637:   query: string,\n638:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n639: ): HybridSearchResult[] {\n640:   const ftsResults = ftsSearch(query, options);\n641:   const bm25Results = bm25Search(query, options);\n642: \n643:   // Merge by canonical ID, prefer FTS scores.\n644:   // CanonicalResultId() prevents duplicate rows when one channel emits\n645:   // Numeric IDs (42) and another emits string IDs (\"42\" or \"mem:42\").\n646:   const merged = new Map<string, HybridSearchResult>();\n647: \n648:   for (const r of ftsResults) {\n649:     merged.set(canonicalResultId(r.id), r);\n650:   }\n651: \n652:   for (const r of bm25Results) {\n653:     const canonicalId = canonicalResultId(r.id);\n654:     if (!merged.has(canonicalId)) {\n655:       merged.set(canonicalId, r);\n656:     }\n657:   }\n658: \n659:   return Array.from(merged.values())\n660:     .sort((a, b) => b.score - a.score)\n661:     .slice(0, options.limit || DEFAULT_LIMIT);\n662: }\n663: \n664: function normalizeTriggerText(value: string): string {\n665:   return value\n666:     .toLowerCase()\n667:     .replace(/[^a-z0-9]+/g, ' ')\n668:     .replace(/\\s+/g, ' ')\n669:     .trim();\n670: }\n671: \n672: function triggerQueryTokens(query: string): string[] {\n673:   return Array.from(new Set(\n674:     normalizeTriggerText(query)\n675:       .split(/\\s+/)\n676:       .filter((token) => token.length >= 2)\n677:   ));\n678: }\n679: \n680: function computeTriggerMatchScore(query: string, phrase: string): number {\n681:   const normalizedQuery = normalizeTriggerText(query);\n682:   const normalizedPhrase = normalizeTriggerText(phrase);\n683:   if (!normalizedQuery || !normalizedPhrase) return 0;\n684:   if (normalizedPhrase === normalizedQuery) return 1.0;\n685: \n686:   const queryTokens = triggerQueryTokens(normalizedQuery);\n687:   const phraseTokens = new Set(triggerQueryTokens(normalizedPhrase));\n688:   if (phraseTokens.size < 2) return 0;\n689:   if (normalizedPhrase.includes(normalizedQuery)) return 0.94;\n690:   if (normalizedQuery.includes(normalizedPhrase)) return 0.88;\n691:   if (queryTokens.length === 0) return 0;\n692:   const overlap = queryTokens.filter((token) => phraseTokens.has(token)).length;\n693:   const coverage = overlap / queryTokens.length;\n694:   return coverage >= 0.8 ? coverage * 0.75 : 0;\n695: }\n696: \n697: function timestampBoost(value: unknown): number {\n698:   if (typeof value !== 'string' || value.length === 0) return 0;\n699:   const parsed = Date.parse(value);\n700:   if (!Number.isFinite(parsed)) return 0;\n701:   const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n702:   return 1 / (1 + ageDays / 30);\n703: }\n704: \n705: function exactTriggerSearch(\n706:   query: string,\n707:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n708: ): HybridSearchResult[] {\n709:   if (!db) return [];\n710: \n711:   const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n712:   if (tokens.length === 0) return [];\n713: \n714:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n715:   const normalizedQuery = normalizeTriggerText(query);\n716:   const exactPhraseLike = `%${normalizedQuery}%`;\n717:   const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n718:   const conditions = [\n719:     `m.trigger_phrases IS NOT NULL`,\n720:     `m.trigger_phrases != ''`,\n721:     `m.trigger_phrases != '[]'`,\n722:     // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n723:     // them below hot memories); the hard exclusion only applies when archived\n724:     // retrieval is disabled.\n725:     ...(isArchivedRetrievalIncludedByDefault()\n726:       ? []\n727:       : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n728:     `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n729:     `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n730:   ];\n731:   const params: unknown[] = tokens.map((token) => `%${token}%`);\n732: \n733:   if (specFolder) {\n734:     conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n735:     params.push(specFolder, specFolderLikePattern(specFolder));\n736:   }\n737: \n738:   try {\n739:     const rows = db.prepare(`\n740:       SELECT m.*\n741:       FROM memory_index m\n742:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n743:       WHERE ${conditions.join(' AND ')}\n744:       ORDER BY\n745:         CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n746:         COALESCE(m.updated_at, m.created_at, '') DESC\n747:       LIMIT ${candidateLimit}\n748:     `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n749: \n750:     return rows\n751:       .map((row): HybridSearchResult | null => {\n752:         const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n753:         const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n754:         if (matchScore <= 0) return null;\n755: \n756:         const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n757:           ? Math.max(0, Math.min(1, row.importance_weight))\n758:           : 0.5;\n759:         const recency = timestampBoost(row.updated_at ?? row.created_at);\n760:         const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n761: \n762:         return {\n763:           ...row,\n764:           id: row.id as number,\n765:           score,\n766:           triggerScore: matchScore,\n767:           source: 'trigger',\n768:         };\n769:       })\n770:       .filter((row): row is HybridSearchResult => row !== null)\n771:       .sort((a, b) => {\n772:         const scoreDelta = b.score - a.score;\n773:         if (scoreDelta !== 0) return scoreDelta;\n774:         const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n775:         const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n776:         return bTime - aTime;\n777:       })\n778:       .slice(0, limit);\n779:   } catch (error: unknown) {\n780:     const msg = error instanceof Error ? error.message : String(error);\n781:     console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n782:     return [];\n783:   }\n784: }\n785: \n786: type RawChannelList = {\n787:   source: string;\n788:   results: Array<{ id: number | string; [key: string]: unknown }>;\n789: };\n790: \n791: function resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n792:   if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n793:     return result.score;\n794:   }\n795:   if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n796:     return result.similarity / 100;\n797:   }\n798:   return 0;\n799: }\n800: \n801: function getCandidateSources(result: HybridSearchResult): string[] {\n802:   const sourceList = (result as { sources?: unknown }).sources;\n803:   if (Array.isArray(sourceList)) {\n804:     return sourceList.filter((value): value is string => typeof value === 'string');\n805:   }\n806:   return typeof result.source === 'string' && result.source.length > 0\n807:     ? [result.source]\n808:     : [];\n809: }\n810: \n811: function getCandidateSourceScores(result: HybridSearchResult): Record<string, number> {\n812:   const sourceScores = (result as { sourceScores?: unknown }).sourceScores;\n813:   if (sourceScores && typeof sourceScores === 'object' && !Array.isArray(sourceScores)) {\n814:     const normalizedScores: Record<string, number> = {};\n815:     for (const [source, score] of Object.entries(sourceScores as Record<string, unknown>)) {\n816:       if (typeof score === 'number' && Number.isFinite(score)) {\n817:         normalizedScores[source] = score;\n818:       }\n819:     }\n820:     return normalizedScores;\n821:   }\n822: \n823:   const fallbackScores: Record<string, number> = {};\n824:   const resultScore = typeof result.score === 'number' && Number.isFinite(result.score)\n825:     ? result.score\n826:     : 0;\n827:   for (const source of getCandidateSources(result)) {\n828:     fallbackScores[source] = resultScore;\n829:   }\n830:   return fallbackScores;\n831: }\n832: \n833: function mergeRawCandidate(\n834:   existing: HybridSearchResult | undefined,\n835:   incoming: HybridSearchResult\n836: ): HybridSearchResult {\n837:   if (!existing) {\n838:     const sources = getCandidateSources(incoming);\n839:     const channelCount = sources.length;\n840:     return {\n841:       ...incoming,\n842:       sources,\n843:       channelCount,\n844:       sourceScores: getCandidateSourceScores(incoming),\n845:       channelAttribution: sources,\n846:     };\n847:   }\n848: \n849:   const existingScore = typeof existing.score === 'number' && Number.isFinite(existing.score)\n850:     ? existing.score\n851:     : 0;\n852:   const incomingScore = typeof incoming.score === 'number' && Number.isFinite(incoming.score)\n853:     ? incoming.score\n854:     : 0;\n855:   const primary = incomingScore > existingScore ? incoming : existing;\n856:   const secondary = primary === incoming ? existing : incoming;\n857:   const sources = Array.from(new Set([\n858:     ...getCandidateSources(existing),\n859:     ...getCandidateSources(incoming),\n860:   ]));\n861:   const channelCount = sources.length;\n862:   const crossChannelBonus = Math.min(0.06, 0.02 * Math.max(0, channelCount - 1));\n863:   const mergedScore = Math.max(0, Math.min(1, Math.max(existingScore, incomingScore) + crossChannelBonus));\n864: \n865:   return {\n866:     ...(secondary ?? {}),\n867:     ...primary,\n868:     score: mergedScore,\n869:     source: typeof primary.source === 'string' ? primary.source : (sources[0] ?? 'hybrid'),\n870:     sources,\n871:     channelCount,\n872:     sourceScores: {\n873:       ...getCandidateSourceScores(existing),\n874:       ...getCandidateSourceScores(incoming),\n875:     },\n876:     channelAttribution: sources,\n877:   };\n878: }\n879: \n880: function collectCandidatesFromLists(\n881:   lists: RawChannelList[],\n882:   limit?: number\n883: ): HybridSearchResult[] {\n884:   const deduped = new Map<string, HybridSearchResult>();\n885: \n886:   for (const list of lists) {\n887:     if (!Array.isArray(list.results) || list.results.length === 0) continue;\n888: \n889:     const scored = list.results.map((result) => {\n890:       const rawScore = resolveRawCandidateScore(result as { score?: unknown; similarity?: unknown });\n891:       return { result, rawScore };\n892:     });\n893: \n894:     let min = Infinity;\n895:     let max = -Infinity;\n896:     for (const { rawScore } of scored) {\n897:       if (rawScore < min) min = rawScore;\n898:       if (rawScore > max) max = rawScore;\n899:     }\n900:     const range = max - min;\n901: \n902:     for (const { result, rawScore } of scored) {\n903:       const normalizedScore = range > 0 ? (rawScore - min) / range : (rawScore > 0 ? 1.0 : 0);\n904:       const candidate: HybridSearchResult = {\n905:         ...result,\n906:         id: result.id,\n907:         source: list.source,\n908:         score: normalizedScore,\n909:         sources: [list.source],\n910:         sourceScores: { [list.source]: normalizedScore },\n911:         channelAttribution: [list.source],\n912:       };\n913:       const key = canonicalResultId(candidate.id);\n914:       deduped.set(key, mergeRawCandidate(deduped.get(key), candidate));\n915:     }\n916:   }\n917: \n918:   return applyResultLimit(\n919:     Array.from(deduped.values()).sort((a, b) => {\n920:       const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n921:       const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n922:       return bScore - aScore;\n923:     }),\n924:     limit\n925:   );\n926: }\n927: \n928: function mergeRawCandidateSets(\n929:   existing: HybridSearchResult[],\n930:   incoming: HybridSearchResult[],\n931:   limit?: number\n932: ): HybridSearchResult[] {\n933:   const merged = new Map<string, HybridSearchResult>();\n934: \n935:   for (const result of [...existing, ...incoming]) {\n936:     const key = canonicalResultId(result.id);\n937:     merged.set(key, mergeRawCandidate(merged.get(key), result));\n938:   }\n939: \n940:   return applyResultLimit(\n941:     Array.from(merged.values()).sort((a, b) => {\n942:       const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n943:       const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n944:       return bScore - aScore;\n945:     }),\n946:     limit\n947:   );\n948: }\n949: \n950: function getAllowedChannels(options: HybridSearchOptions): Set<ChannelName> {\n951:   const allowed = new Set<ChannelName>(['vector', 'fts', 'graph', 'degree']);\n952: \n953:   if (isBm25Enabled()) {\n954:     allowed.add('bm25');\n955:   }\n956: \n957:   if (options.useVector === false) allowed.delete('vector');\n958:   if (options.useBm25 === false) allowed.delete('bm25');\n959:   if (options.useFts === false) allowed.delete('fts');\n960:   if (options.useGraph === false) {\n961:     allowed.delete('graph');\n962:     allowed.delete('degree');\n963:   }\n964: \n965:   return allowed;\n966: }\n967: \n968: function applyAllowedChannelOverrides(\n969:   options: HybridSearchOptions,\n970:   allowedChannels: Set<ChannelName>,\n971:   overrides: Partial<HybridSearchOptions> = {}\n972: ): HybridSearchOptions {\n973:   return {\n974:     ...options,\n975:     ...overrides,\n976:     useVector: allowedChannels.has('vector'),\n977:     useBm25: allowedChannels.has('bm25'),\n978:     useFts: allowedChannels.has('fts'),\n979:     useGraph: allowedChannels.has('graph'),\n980:   };\n981: }\n982: \n983: type FallbackPlanKind = 'adaptive' | 'tiered';\n984: type FallbackStageName = 'primary' | 'retry';\n985: \n986: interface FallbackPlanStage {\n987:   stage: FallbackStageName;\n988:   options: HybridSearchOptions;\n989:   results: HybridSearchResult[];\n990:   execution: HybridFusionExecution | null;\n991:   trigger?: 'empty' | DegradationTrigger;\n992: }\n993: \n994: interface FallbackPlanExecution {\n995:   allowedChannels: Set<ChannelName>;\n996:   stages: FallbackPlanStage[];\n997: }\n998: \n999: interface HybridFusionExecution {\n1000:   evaluationMode: boolean;\n1001:   intent: string;\n1002:   lists: Array<{\n1003:     source: string;\n1004:     results: Array<{ id: number | string; [key: string]: unknown }>;\n1005:     weight?: number;\n1006:   }>;\n1007:   routeResult: ReturnType<typeof routeQuery>;\n1008:   budgetResult: ReturnType<typeof getDynamicTokenBudget>;\n1009:   s3meta: Sprint3PipelineMeta;\n1010:   fusedResults: HybridSearchResult[];\n1011:   vectorEmbeddingCache: Map<number, Float32Array>;\n1012: }\n1013: \n1014: function resolveAdaptiveDocumentType(\n1015:   lists: Array<{ results: Array<Record<string, unknown>> }>,\n1016: ): string | undefined {\n1017:   const counts = new Map<string, number>();\n1018:   for (const list of lists) {\n1019:     for (const result of list.results.slice(0, 3)) {\n1020:       const candidate = result.documentType ?? result.document_type;\n1021:       if (typeof candidate !== 'string' || candidate.length === 0) {\n1022:         continue;\n1023:       }\n1024:       counts.set(candidate, (counts.get(candidate) ?? 0) + 1);\n1025:     }\n1026:   }\n1027: \n1028:   let topType: string | undefined;\n1029:   let topCount = 0;\n1030:   for (const [documentType, count] of counts) {\n1031:     if (count > topCount) {\n1032:       topType = documentType;\n1033:       topCount = count;\n1034:     }\n1035:   }\n1036: \n1037:   return topType;\n1038: }\n1039: \n1040: function markFallbackRetry(results: HybridSearchResult[]): HybridSearchResult[] {\n1041:   for (const result of results) {\n1042:     (result as Record<string, unknown>).fallbackRetry = true;\n1043:   }\n1044: \n1045:   return results;\n1046: }\n1047: \n1048: function toEmbeddingBufferView(value: unknown): Float32Array | null {\n1049:   if (value instanceof Float32Array) {\n1050:     return value;\n1051:   }\n1052: \n1053:   if (Array.isArray(value)) {\n1054:     const asNumbers = value.every((entry) => typeof entry === 'number' && Number.isFinite(entry));\n1055:     return asNumbers ? new Float32Array(value) : null;\n1056:   }\n1057: \n1058:   if (Buffer.isBuffer(value)) {\n1059:     return new Float32Array(value.buffer, value.byteOffset, value.byteLength / 4);\n1060:   }\n1061: \n1062:   return null;\n1063: }\n1064: \n1065: async function executeFallbackPlan(\n1066:   query: string,\n1067:   embedding: Float32Array | number[] | null,\n1068:   options: HybridSearchOptions = {},\n1069:   planKind: FallbackPlanKind,\n1070:   overrides: Partial<HybridSearchOptions> = {}\n1071: ): Promise<FallbackPlanExecution> {\n1072:   const allowedChannels = getAllowedChannels(options);\n1073:   const stages: FallbackPlanStage[] = [];\n1074: \n1075:   const primaryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1076:     minSimilarity: options.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY,\n1077:     ...overrides,\n1078:   });\n1079:   const primaryExecution = await collectAndFuseHybridResults(query, embedding, primaryOptions);\n1080:   const primaryResults = primaryExecution\n1081:     ? applyResultLimit(primaryExecution.fusedResults, primaryOptions.limit)\n1082:     : await hybridSearch(query, embedding, primaryOptions);\n1083:   stages.push({\n1084:     stage: 'primary',\n1085:     options: primaryOptions,\n1086:     results: primaryResults,\n1087:     execution: primaryExecution,\n1088:   });\n1089: \n1090:   if (planKind === 'tiered') {\n1091:     const trigger = checkDegradation(primaryResults);\n1092:     if (!trigger) {\n1093:       return { allowedChannels, stages };\n1094:     }\n1095: \n1096:     const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1097:       ...overrides,\n1098:       minSimilarity: TIERED_FALLBACK_MIN_SIMILARITY,\n1099:       forceAllChannels: true,\n1100:     });\n1101:     const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n1102:     const retryResults = retryExecution\n1103:       ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n1104:       : await hybridSearch(query, embedding, retryOptions);\n1105:     stages.push({\n1106:       stage: 'retry',\n1107:       options: retryOptions,\n1108:       results: retryResults,\n1109:       execution: retryExecution,\n1110:       trigger,\n1111:     });\n1112:     return { allowedChannels, stages };\n1113:   }\n1114: \n1115:   const primaryMinSimilarity = primaryOptions.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY;\n1116:   if (primaryResults.length === 0 && primaryMinSimilarity >= SECONDARY_FALLBACK_MIN_SIMILARITY) {\n1117:     const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1118:       ...overrides,\n1119:       minSimilarity: SECONDARY_FALLBACK_MIN_SIMILARITY,\n1120:     });\n1121:     const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n1122:     const retryResultsBase = retryExecution\n1123:       ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n1124:       : await hybridSearch(query, embedding, retryOptions);\n1125:     const retryResults = retryResultsBase.length > 0\n1126:       ? markFallbackRetry(retryResultsBase)\n1127:       : retryResultsBase;\n1128:     stages.push({\n1129:       stage: 'retry',\n1130:       options: retryOptions,\n1131:       results: retryResults,\n1132:       execution: retryExecution,\n1133:       trigger: 'empty',\n1134:     });\n1135:   }\n1136: \n1137:   return { allowedChannels, stages };\n1138: }\n1139: \n1140: // 11. HYBRID SEARCH\n1141: \n1142: /**\n1143:  * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n1144:  * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n1145:  * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n1146:  * Retained as internal fallback only.\n1147:  */\n1148: async function hybridSearch(\n1149:   query: string,\n1150:   embedding: Float32Array | number[] | null,\n1151:   options: HybridSearchOptions = {}\n1152: ): Promise<HybridSearchResult[]> {\n1153:   const {\n1154:     limit = DEFAULT_LIMIT,\n1155:     specFolder,\n1156:     minSimilarity = 0,\n1157:     useBm25 = isBm25Enabled(),\n1158:     useFts = true,\n1159:     useVector = true,\n1160:     useGraph = true,\n1161:     includeArchived = false,\n1162:   } = options;\n1163: \n1164:   const results: HybridSearchResult[] = [];\n1165: \n1166:   // Vector search\n1167:   if (useVector && embedding && vectorSearchFn) {\n1168:     try {\n1169:       const vectorResults = vectorSearchFn(embedding, {\n1170:         limit,\n1171:         specFolder,\n1172:         minSimilarity,\n1173:         includeConstitutional: false, // Handler manages constitutional separately\n1174:         includeArchived,\n1175:       });\n1176:       for (const r of vectorResults) {\n1177:         results.push({\n1178:           ...r,\n1179:           id: r.id as number,\n1180:           score: (r.similarity as number) || 0,\n1181:           source: 'vector',\n1182:         });\n1183:       }\n1184:     } catch (error: unknown) {\n1185:       const msg = error instanceof Error ? error.message : String(error);\n1186:       console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n1187:     }\n1188:   }\n1189: \n1190:   // FTS search\n1191:   if (useFts) {\n1192:     const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n1193:     results.push(...ftsResults);\n1194:   }\n1195: \n1196:   // BM25 search\n1197:   if (useBm25) {\n1198:     const bm25Results = bm25Search(query, { limit, specFolder });\n1199:     results.push(...bm25Results);\n1200:   }\n1201: \n1202:   // Graph search\n1203:   if (useGraph && graphSearchFn) {\n1204:     try {\n1205:       graphMetrics.totalQueries++;\n1206:       const graphResults = graphSearchFn(query, { limit, specFolder });\n1207:       for (const r of graphResults) {\n1208:         results.push({\n1209:           ...r,\n1210:           id: r.id as number | string,\n1211:           score: (r.score as number) || 0,\n1212:           source: 'graph',\n1213:         });\n1214:       }\n1215:       if (graphResults.length > 0) {\n1216:         graphMetrics.graphHits++;\n1217:         graphMetrics.graphResultCount += graphResults.length;\n1218:       }\n1219:     } catch (error: unknown) {\n1220:       const msg = error instanceof Error ? error.message : String(error);\n1221:       console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n1222:     }\n1223:   }\n1224: \n1225:   // Normalize scores per source before merging so one method's raw scale\n1226:   // Does not dominate others during final ranking.\n1227:   const bySource = new Map<string, HybridSearchResult[]>();\n1228:   for (const r of results) {\n1229:     const src = r.source || 'unknown';\n1230:     if (!bySource.has(src)) bySource.set(src, []);\n1231:     bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n1232:   }\n1233: \n1234:   const normalized: HybridSearchResult[] = [];\n1235:   for (const [, group] of bySource) {\n1236:     if (group.length === 0) continue;\n1237:     const scores = group.map(r => r.score);\n1238:     let min = Infinity;\n1239:     let max = -Infinity;\n1240:     for (const s of scores) {\n1241:       if (s < min) min = s;\n1242:       if (s > max) max = s;\n1243:     }\n1244:     const range = max - min;\n1245:     for (const r of group) {\n1246:       normalized.push({\n1247:         ...r,\n1248:         score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n1249:       });\n1250:     }\n1251:   }\n1252: \n1253:   // Deduplicate by ID (keep highest normalized score)\n1254:   // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n1255:   // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n1256:   // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n1257:   // Field and downstream consumers would need to be updated accordingly.\n1258:   const deduped = new Map<string, HybridSearchResult>();\n1259:   for (const r of normalized) {\n1260:     const canonicalId = canonicalResultId(r.id);\n1261:     const existing = deduped.get(canonicalId);\n1262:     if (!existing || r.score > existing.score) {\n1263:       deduped.set(canonicalId, r);\n1264:     }\n1265:   }\n1266: \n1267:   return Array.from(deduped.values())\n1268:     .sort((a, b) => b.score - a.score)\n1269:     .slice(0, limit);\n1270: }\n1271: \n1272: /**\n1273:  * Enhanced hybrid search with RRF fusion.\n1274:  * All search channels use synchronous better-sqlite3; sequential execution\n1275:  * is correct — Promise.all would add overhead without achieving parallelism.\n1276:  */\n1277: async function hybridSearchEnhanced(\n1278:   query: string,\n1279:   embedding: Float32Array | number[] | null,\n1280:   options: HybridSearchOptions = {}\n1281: ): Promise<HybridSearchResult[]> {\n1282:   const execution = await collectAndFuseHybridResults(query, embedding, options);\n1283:   if (execution) {\n1284:     if (options.stopAfterFusion) {\n1285:       return applyResultLimit(execution.fusedResults, options.limit);\n1286:     }\n1287: \n1288:     return enrichFusedResults(query, execution, options);\n1289:   }\n1290: \n1291:   return hybridSearch(query, embedding, options);\n1292: }\n1293: \n1294: async function collectAndFuseHybridResults(\n1295:   query: string,\n1296:   embedding: Float32Array | number[] | null,\n1297:   options: HybridSearchOptions = {}\n1298: ): Promise<HybridFusionExecution | null> {\n1299:   try {\n1300:     const evaluationMode = options.evaluationMode === true;\n1301:     const lists: HybridFusionExecution['lists'] = [];\n1302: \n1303:     // Pipeline metadata collector (populated by flag-gated stages)\n1304:     const s3meta: Sprint3PipelineMeta = {};\n1305: \n1306:     // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n1307:     // When enabled, classifies query complexity and restricts channels to a\n1308:     // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n1309:     const routeResult = routeQuery(query, options.triggerPhrases);\n1310:     const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n1311:     const activeChannels = options.forceAllChannels\n1312:       ? new Set<ChannelName>(allPossibleChannels)\n1313:       : new Set<ChannelName>(routeResult.channels);\n1314: \n1315:     // Respect explicit caller channel disables across both the primary route and\n1316:     // every fallback tier. useGraph=false also disables the dependent degree lane.\n1317:     const allowedChannels = getAllowedChannels(options);\n1318:     for (const channel of allPossibleChannels) {\n1319:       if (!allowedChannels.has(channel)) activeChannels.delete(channel);\n1320:     }\n1321: \n1322:     const skippedChannels = allPossibleChannels.filter(ch => !activeChannels.has(ch));\n1323: \n1324:     if (skippedChannels.length > 0) {\n1325:       s3meta.routing = {\n1326:         tier: routeResult.tier,\n1327:         channels: routeResult.channels,\n1328:         skippedChannels,\n1329:         featureFlagEnabled: isComplexityRouterEnabled(),\n1330:         confidence: routeResult.classification.confidence,\n1331:         features: routeResult.classification.features as Record<string, unknown>,\n1332:       };\n1333:     }\n1334: \n1335:     // -- Stage E: Dynamic Token Budget (SPECKIT_DYNAMIC_TOKEN_BUDGET) --\n1336:     // Compute tier-aware budget early so it's available for downstream truncation.\n1337:     // When disabled, getDynamicTokenBudget returns the default 4000 budget with applied=false.\n1338:     // Weak / low-confidence queries keep the full budget so recall is not trimmed away.\n1339:     const lowSignalQuery =\n1340:       routeResult.classification.confidence === 'low' ||\n1341:       routeResult.classification.confidence === 'fallback';\n1342:     const budgetResult = getDynamicTokenBudget(routeResult.tier, undefined, {\n1343:       lowSignal: lowSignalQuery,\n1344:     });\n1345:     if (budgetResult.applied && !evaluationMode) {\n1346:       s3meta.tokenBudget = {\n1347:         tier: budgetResult.tier,\n1348:         budget: budgetResult.budget,\n1349:         applied: budgetResult.applied,\n1350:         featureFlagEnabled: isDynamicTokenBudgetEnabled(),\n1351:         configValues: DEFAULT_TOKEN_BUDGET_CONFIG as unknown as Record<string, number>,\n1352:         // headerOverhead and adjustedBudget are patched in below after they are computed\n1353:         headerOverhead: 0,\n1354:         adjustedBudget: budgetResult.budget,\n1355:       };\n1356:     }\n1357: \n1358:     // Channel results collected independently, merged after all complete\n1359:     let semanticResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [];\n1360:     let ftsChannelResults: HybridSearchResult[] = [];\n1361:     let bm25ChannelResults: HybridSearchResult[] = [];\n1362:     let triggerChannelResults: HybridSearchResult[] = [];\n1363:     const vectorEmbeddingCache = new Map<number, Float32Array>();\n1364: \n1365:     // All channels use synchronous better-sqlite3; sequential execution\n1366:     // Is correct — Promise.all adds overhead without parallelism.\n1367: \n1368:     // Vector channel — gated by query-complexity routing\n1369:     if (activeChannels.has('vector') && embedding && vectorSearchFn) {\n1370:       try {\n1371:         const vectorResults = vectorSearchFn(embedding, {\n1372:           limit: options.limit || DEFAULT_LIMIT,\n1373:           specFolder: options.specFolder,\n1374:           minSimilarity: options.minSimilarity || 0,\n1375:           includeConstitutional: false,\n1376:           includeArchived: options.includeArchived || false,\n1377:           includeEmbeddings: true,\n1378:         });\n1379:         semanticResults = vectorResults.map((r: Record<string, unknown>): { id: number | string; source: string; [key: string]: unknown } => ({\n1380:           ...r,\n1381:           id: r.id as number | string,\n1382:           source: 'vector',\n1383:         }));\n1384:         for (const result of semanticResults) {\n1385:           if (typeof result.id !== 'number') continue;\n1386:           const embeddingCandidate = toEmbeddingBufferView(\n1387:             (result as Record<string, unknown>).embedding\n1388:             ?? (result as Record<string, unknown>).embeddingBuffer\n1389:           );\n1390:           if (embeddingCandidate) {\n1391:             vectorEmbeddingCache.set(result.id, embeddingCandidate);\n1392:           }\n1393:         }\n1394:         lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n1395:       } catch (_err: unknown) {\n1396:         // Non-critical — vector channel failure does not block pipeline\n1397:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1398:       }\n1399:     }\n1400: \n1401:     // FTS channel (internal error handling in ftsSearch) — gated by query-complexity routing\n1402:     if (activeChannels.has('fts')) {\n1403:       ftsChannelResults = ftsSearch(query, options);\n1404:       if (ftsChannelResults.length > 0) {\n1405:         // FTS weight reduced to 0.3 after ablation showed 0.8 was harmful,\n1406:         // flooding top-K with noisy lexical matches despite its exact-match value.\n1407:         lists.push({ source: 'fts', results: ftsChannelResults, weight: 0.3 });\n1408:       }\n1409:     }\n1410: \n1411:     // BM25 channel (internal error handling in bm25Search) — gated by query-complexity routing\n1412:     if (activeChannels.has('bm25')) {\n1413:       bm25ChannelResults = bm25Search(query, options);\n1414:       if (bm25ChannelResults.length > 0) {\n1415:         // BM25 weight 0.6 is lowest lexical channel — in-memory BM25 index\n1416:         // Has less precise scoring than SQLite FTS5 BM25; kept for coverage breadth.\n1417:         lists.push({ source: 'bm25', results: bm25ChannelResults, weight: 0.6 });\n1418:       }\n1419:     }\n1420: \n1421:     triggerChannelResults = exactTriggerSearch(query, options);\n1422:     if (triggerChannelResults.length > 0) {\n1423:       lists.push({ source: 'trigger', results: triggerChannelResults, weight: 1.4 });\n1424:     }\n1425: \n1426:     // Graph channel — gated by query-complexity routing\n1427:     const useGraph = (options.useGraph !== false) && activeChannels.has('graph');\n1428:     if (useGraph && graphSearchFn) {\n1429:       try {\n1430:         graphMetrics.totalQueries++; // counted only if channel executes\n1431:         const graphResults = graphSearchFn(query, {\n1432:           limit: options.limit || DEFAULT_LIMIT,\n1433:           specFolder: options.specFolder,\n1434:           intent: options.intent,\n1435:         });\n1436:         if (graphResults.length > 0) {\n1437:           graphMetrics.graphHits++;\n1438:           graphMetrics.graphResultCount += graphResults.length;\n1439:           lists.push({ source: 'graph', results: graphResults.map((r: Record<string, unknown>) => ({\n1440:             ...r,\n1441:             id: r.id as number | string,\n1442:           })), weight: 0.5 });\n1443:         }\n1444:       } catch (_err: unknown) {\n1445:         // Non-critical — graph channel failure does not block pipeline\n\n(Output capped at 50 KB. Showing lines 1-1445. Use offset=1446 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Hybrid Search\n// ───────────────────────────────────────────────────────────────\n// Combines vector, FTS, and BM25 search with fallback\n\n// 1. IMPORTS\n\n// Local\nimport {\n  getIndex,\n  isBm25Enabled,\n  shouldUseSqliteLexicalEngine,\n} from './bm25-index.js';\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\nimport { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\nimport { fts5Bm25Search } from './sqlite-fts.js';\nimport { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Hybrid Search\n// ───────────────────────────────────────────────────────────────\n// Combines vector, FTS, and BM25 search with fallback\n\n// 1. IMPORTS\n\n// Local\nimport {\n  getIndex,\n  isBm25Enabled,\n  shouldUseSqliteLexicalEngine,\n} from './bm25-index.js';\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\nimport { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\nimport { fts5Bm25Search } from './sqlite-fts.js';\nimport { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';\nimport {\n  isMMREnabled,\n  isSearchFallbackEnabled,\n  isDocscoreAggregationEnabled,\n  isDegreeBoostEnabled,\n  isContextHeadersEnabled,\n  isArchivedRetrievalIncludedByDefault,\n  isCosineTopnReorderEnabled,\n} from './search-flags.js';\nimport { resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\nimport { computeDegreeScores } from './graph-search-fn.js';\nimport type { GraphSearchFn } from './search-types.js';\n\n// Feature catalog: Hybrid search pipeline\n\nexport type { GraphSearchFn } from './search-types.js';\n\nimport { routeQuery } from './query-router.js';\nimport { isComplexityRouterEnabled } from './query-classifier.js';\nimport { enforceChannelRepresentation } from './channel-enforcement.js';\nimport {\n  truncateByConfidence,\n  isConfidenceTruncationEnabled,\n  DEFAULT_MIN_RESULTS,\n  GAP_THRESHOLD_MULTIPLIER,\n} from './confidence-truncation.js';\nimport {\n  getDynamicTokenBudget,\n  isDynamicTokenBudgetEnabled,\n  DEFAULT_TOKEN_BUDGET_CONFIG,\n} from './dynamic-token-budget.js';\nimport {\n  buildProgressiveResponse,\n  DEFAULT_PAGE_SIZE,\n} from './progressive-disclosure.js';\nimport type {\n  ProgressiveResponse,\n  DisclosureResult,\n} from './progressive-disclosure.js';\nimport { resolveFusionIntentContract } from './search-utils.js';\nimport { ensureDescriptionCache, getSpecsBasePaths } from './folder-discovery.js';\nimport {\n  isFolderScoringEnabled,\n  lookupFolders,\n  computeFolderRelevanceScores,\n  enrichResultsWithFolderScores,\n  twoPhaseRetrieval,\n} from './folder-relevance.js';\nimport { parse_trigger_phrases, specFolderLikePattern } from './vector-index-types.js';\n\nimport { collapseAndReassembleChunkResults } from '../scoring/mpab-aggregation.js';\n\n// Type-only\nimport type Database from 'better-sqlite3';\nimport type { SpreadResult } from '../cognitive/co-activation.js';\nimport type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport type { FusionResult } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport type { ChannelName } from './query-router.js';\nimport type { EnforcementResult } from './channel-enforcement.js';\nimport type { TruncationResult } from './confidence-truncation.js';\n\n// 2. INTERFACES\n\ntype VectorSearchFn = (\n  embedding: Float32Array | number[],\n  options: Record<string, unknown>\n) => Array<Record<string, unknown>>;\n\ninterface HybridSearchOptions {\n  limit?: number;\n  specFolder?: string;\n  minSimilarity?: number;\n  useBm25?: boolean;\n  useFts?: boolean;\n  useVector?: boolean;\n  useGraph?: boolean;\n  includeArchived?: boolean;\n  includeContent?: boolean;\n  /**\n   * Evaluation-only mode.\n   * When true, preserve the requested top-K window by bypassing confidence\n   * truncation and token-budget truncation without changing live defaults.\n   */\n  evaluationMode?: boolean;\n  /** Classified query intent for adaptive fusion weight selection (e.g. 'understand', 'fix_bug'). */\n  intent?: string;\n  /** Optional trigger phrases for query-classifier trigger-match routing path. */\n  triggerPhrases?: string[];\n  /**\n   * Internal fallback override: when true, bypass complexity routing and\n   * enable all retrieval channels for this search call.\n   */\n  forceAllChannels?: boolean;\n  /**\n   * Internal raw-candidate mode used by the Stage 1 pipeline.\n   * When true, stop after channel collection and return pre-fusion candidates.\n   */\n  skipFusion?: boolean;\n  /**\n   * Internal pipeline handoff mode.\n   * When true, return immediately after adaptive/RRF fusion so Stage 2/3 can\n   * apply the remaining pipeline scoring and aggregation steps.\n   */\n  stopAfterFusion?: boolean;\n}\n\ninterface HybridSearchResult {\n  id: number | string;\n  /**\n   * Normalized relevance score (0-1). Semantics depend on `source`:\n   * - `'vector'` — cosine similarity from sqlite-vec (normalized from 0-100 to 0-1)\n   * - `'bm25'` — BM25 term-frequency relevance (min-max normalized per source group)\n   * - `'fts'` — FTS5 rank score (absolute value, min-max normalized per source group)\n   * - `'graph'` — graph traversal relevance\n   *\n   * After hybrid merge, all source scores are min-max normalized to 0-1 within\n   * their source group to ensure fair cross-method comparison.\n   */\n  score: number;\n  source: string;\n  title?: string;\n  [key: string]: unknown;\n}\n\ntype HardExclusionSource = 'archived-tier' | 'deprecated-tier';\ntype HardExclusionClassification = 'intended' | 'silent-risk' | 'unclassified';\n\ninterface HardExclusionPredicate {\n  id: string;\n  source: HardExclusionSource;\n  channel: string;\n  predicate: string;\n  defaultApplied: boolean;\n  classification: HardExclusionClassification;\n}\n\nconst HARD_EXCLUSION_PREDICATES: readonly HardExclusionPredicate[] = Object.freeze([\n  {\n    id: 'includeArchived-default',\n    source: 'archived-tier',\n    channel: 'vector/fts',\n    predicate: 'includeArchived defaults to false',\n    defaultApplied: true,\n    classification: 'intended',\n  },\n  {\n    id: 'fts-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'fts',\n    predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'bm25-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'bm25',\n    predicate: \"importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'trigger-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'trigger',\n    predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'structural-deprecated-archived-tier',\n    source: 'deprecated-tier',\n    channel: 'structural',\n    predicate: \"importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived')\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n]);\n\n/** Return recall-path exclusion metadata without executing or changing search. */\nfunction getHardExclusionPredicates(): HardExclusionPredicate[] {\n  return HARD_EXCLUSION_PREDICATES.map((predicate) => ({ ...predicate }));\n}\n\ntype Bm25MemoryMetadata = {\n  specFolder: string | null;\n  importanceTier: string | null;\n};\n\n/** Non-enumerable shadow metadata attached to result arrays via Object.defineProperty. */\ninterface ShadowMetaArray {\n  _s4shadow?: unknown;\n  _s4attribution?: unknown;\n  _degradation?: unknown;\n}\n\n/** Normalize a fused RRF result to the HybridSearchResult contract. */\nfunction toHybridResult(result: FusionResult): HybridSearchResult {\n  const sourceCandidate = (result as { source?: unknown }).source;\n  const primarySource = result.sources[0] ?? 'hybrid';\n  const scoreCandidate = (result as { score?: unknown }).score;\n\n  return {\n    ...result,\n    id: result.id,\n    score: typeof scoreCandidate === 'number' ? scoreCandidate : result.rrfScore,\n    source: typeof sourceCandidate === 'string' ? sourceCandidate : primarySource,\n  };\n}\n\n// PIPELINE METADATA\n\n/**\n * Optional metadata about pipeline stages attached to enhanced search results.\n * Only populated when the corresponding feature flags are enabled.\n */\ninterface Sprint3PipelineMeta {\n  /** Query complexity routing result (SPECKIT_COMPLEXITY_ROUTER). */\n  routing?: {\n    tier: string;\n    channels: string[];\n    skippedChannels: string[];\n    featureFlagEnabled: boolean;\n    confidence: string;\n    features: Record<string, unknown>;\n  };\n  /** Channel enforcement result (SPECKIT_CHANNEL_MIN_REP). */\n  enforcement?: { applied: boolean; promotedCount: number; underRepresentedChannels: string[] };\n  /** Confidence truncation result (SPECKIT_CONFIDENCE_TRUNCATION). */\n  truncation?: {\n    truncated: boolean;\n    originalCount: number;\n    truncatedCount: number;\n    medianGap: number;\n    cutoffGap: number;\n    cutoffIndex: number;\n    thresholdMultiplier: number;\n    minResultsGuaranteed: number;\n    featureFlagEnabled: boolean;\n  };\n  /** Dynamic token budget result (SPECKIT_DYNAMIC_TOKEN_BUDGET). */\n  tokenBudget?: {\n    tier: string;\n    budget: number;\n    applied: boolean;\n    featureFlagEnabled: boolean;\n    configValues: Record<string, number>;\n    headerOverhead: number;\n    adjustedBudget: number;\n  };\n}\n\n// 4. PI-A2: DEGRADATION TYPES\n\n/** Fallback tier in the 3-tier degradation chain. */\ntype FallbackTier = 1 | 2 | 3;\n\n/** Why degradation was triggered at a given tier. */\ninterface DegradationTrigger {\n  reason: 'low_quality' | 'insufficient_results' | 'both';\n  topScore: number;\n  resultCount: number;\n  relativeGap?: number;\n}\n\n/** Record of a single degradation event during tiered fallback. */\ninterface DegradationEvent {\n  tier: FallbackTier;\n  trigger: DegradationTrigger;\n  resultCountBefore: number;\n  resultCountAfter: number;\n}\n\n/**\n * Absolute quality floor for degradation checks.\n *\n * Raw RRF scores are typically small decimals (often <0.05), so a\n * high fixed threshold causes false degradations. Use a conservative floor and\n * pair it with a relative-gap check to avoid score-scale coupling.\n */\nconst DEGRADATION_QUALITY_THRESHOLD = 0.02;\n\n/** Minimum relative separation between top-1 and top-2 scores. */\nconst DEGRADATION_MIN_RELATIVE_GAP = 0.2;\n\n/** Minimum result count: must have >= this many results to stay at current tier. */\nconst DEGRADATION_MIN_RESULTS = 3;\n\n// 5. MODULE STATE\n\n/** Default result limit when none is specified by the caller. */\nconst DEFAULT_LIMIT = 20;\n/** Primary vector similarity floor for hybrid fallback passes (percentage units). */\nconst PRIMARY_FALLBACK_MIN_SIMILARITY = 30;\n/** Secondary vector similarity floor for adaptive retry passes (percentage units). */\nconst SECONDARY_FALLBACK_MIN_SIMILARITY = 17;\n/** Tier-2 vector similarity floor for quality-aware fallback (percentage units). */\nconst TIERED_FALLBACK_MIN_SIMILARITY = 10;\n\n/** Minimum MMR candidates required for diversity reranking to be worthwhile. */\nconst MMR_MIN_CANDIDATES = 2;\n\n/** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\nconst MMR_DEFAULT_LAMBDA = 0.7;\n\n/** Number of top results used as seeds for co-activation spreading. */\nconst SPREAD_ACTIVATION_TOP_N = 5;\n\n/** Maximum contextual tree header length prepended to content (including brackets). */\nconst CONTEXT_HEADER_MAX_CHARS = 100;\n/** Header/content separator characters added during contextual tree injection. */\nconst CONTEXT_HEADER_SEPARATOR_CHARS = 1;\n/** Reserved token overhead per contextual header, calibrated to max header length. */\nconst CONTEXT_HEADER_TOKEN_OVERHEAD = Math.ceil(\n  (CONTEXT_HEADER_MAX_CHARS + CONTEXT_HEADER_SEPARATOR_CHARS) / 4\n);\n\nlet db: Database.Database | null = null;\nlet vectorSearchFn: VectorSearchFn | null = null;\nlet graphSearchFn: GraphSearchFn | null = null;\nlet enrichFusedResultsObserver: (() => void) | null = null;\n\n// 6. GRAPH CHANNEL METRICS\n\ninterface GraphChannelMetrics {\n  totalQueries: number;\n  graphHits: number;\n  graphResultCount: number;\n  graphOnlyResults: number;\n  graphMultiSourceResults: number;\n  multiSourceResults: number;\n  degreeQueries: number;\n  degreeHits: number;\n  degreeResultCount: number;\n}\n\nconst graphMetrics: GraphChannelMetrics = {\n  totalQueries: 0,\n  graphHits: 0,\n  graphResultCount: 0,\n  graphOnlyResults: 0,\n  graphMultiSourceResults: 0,\n  multiSourceResults: 0,\n  degreeQueries: 0,\n  degreeHits: 0,\n  degreeResultCount: 0,\n};\n\n/**\n * Return current graph channel metrics for health check reporting.\n * graphHitRate is computed as graphHits / totalQueries.\n */\nfunction getGraphMetrics(): GraphChannelMetrics & { graphHitRate: number; degreeHitRate: number } {\n  return {\n    ...graphMetrics,\n    graphHitRate: graphMetrics.totalQueries > 0\n      ? graphMetrics.graphHits / graphMetrics.totalQueries\n      : 0,\n    degreeHitRate: graphMetrics.degreeQueries > 0\n      ? graphMetrics.degreeHits / graphMetrics.degreeQueries\n      : 0,\n  };\n}\n\n/** Reset all graph channel metrics counters to zero. */\nfunction resetGraphMetrics(): void {\n  graphMetrics.totalQueries = 0;\n  graphMetrics.graphHits = 0;\n  graphMetrics.graphResultCount = 0;\n  graphMetrics.graphOnlyResults = 0;\n  graphMetrics.graphMultiSourceResults = 0;\n  graphMetrics.multiSourceResults = 0;\n  graphMetrics.degreeQueries = 0;\n  graphMetrics.degreeHits = 0;\n  graphMetrics.degreeResultCount = 0;\n}\n\n// 7. INITIALIZATION\n\n/**\n * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n * @param database - The better-sqlite3 database instance for FTS and graph queries.\n * @param vectorFn - Optional vector search function for semantic similarity.\n * @param graphFn - Optional graph search function for causal/structural retrieval.\n */\nfunction init(\n  database: Database.Database,\n  vectorFn: VectorSearchFn | null = null,\n  graphFn: GraphSearchFn | null = null\n): void {\n  db = database;\n  vectorSearchFn = vectorFn;\n  graphSearchFn = graphFn;\n}\n\n// 8. BM25 SEARCH\n\n/**\n * Search the BM25 index with optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit and specFolder filter.\n * @returns Array of BM25-scored results tagged with source 'bm25'.\n */\nfunction bm25Search(\n  query: string,\n  options: { limit?: number; specFolder?: string } = {}\n): HybridSearchResult[] {\n  if (!isBm25Enabled()) {\n    console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n    return [];\n  }\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n\n  try {\n    if (shouldUseSqliteLexicalEngine(db)) {\n      return ftsSearch(query, {\n        limit,\n        specFolder,\n      }).map((result) => ({\n        ...result,\n        bm25_score: result.score,\n        source: 'bm25',\n        sources: Array.from(new Set([\n          ...(\n            Array.isArray((result as Record<string, unknown>).sources)\n              ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n              : []\n          ),\n          'fts',\n          'bm25',\n        ])),\n      }));\n    }\n\n    // Spec-folder scope can only be resolved from DB metadata; fail closed before\n    // searching when the DB is unavailable rather than over-fetching the whole\n    // corpus and then discarding it.\n    if (specFolder && !db) {\n      console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n      return [];\n    }\n\n    const index = getIndex();\n    const candidateLimit = (specFolder || db)\n      ? index.getStats().documentCount\n      : limit;\n    // Metadata filters run after in-memory scoring, so fetch the corpus-bounded\n    // candidate set whenever those filters can remove otherwise top-ranked hits.\n    const results = index.search(query, candidateLimit);\n\n    // BM25 document IDs are stringified\n    // Numeric memory IDs (e.g., \"42\"), not spec folder paths. The old filter compared\n    // R.id against specFolder which never matched. Use DB lookup to resolve spec_folder.\n\n    // Batch-resolve metadata for all result IDs (was N+1 individual queries)\n    // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n    // resolution returns [] rather than leaking unscoped BM25 candidates.\n    let memoryMetadataMap: Map<number, Bm25MemoryMetadata> | null = null;\n    if (results.length > 0) {\n      if (!db) {\n        if (specFolder) {\n          const error = new Error('Database unavailable for spec-folder scope lookup');\n          console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n          return [];\n        }\n      } else {\n        try {\n          const ids = results.map((r: { id: string }) => Number(r.id));\n          memoryMetadataMap = new Map();\n          // Resolve metadata in bounded batches. The candidate set can now be\n          // corpus-sized (over-fetch for scope/tier filtering), and a single\n          // IN (...) with one bind per id would exceed SQLite's parameter limit\n          // and throw — which the catch below turns into an empty result.\n          const METADATA_BATCH = 500;\n          for (let offset = 0; offset < ids.length; offset += METADATA_BATCH) {\n            const batch = ids.slice(offset, offset + METADATA_BATCH);\n            const placeholders = batch.map(() => '?').join(',');\n            const rows = db.prepare(\n              `SELECT id, spec_folder, importance_tier FROM memory_index WHERE id IN (${placeholders})`\n            ).all(...batch) as Array<{ id: number; spec_folder: string | null; importance_tier: string | null }>;\n            for (const row of rows) {\n              memoryMetadataMap.set(row.id, {\n                specFolder: row.spec_folder,\n                importanceTier: row.importance_tier,\n              });\n            }\n          }\n        } catch (error: unknown) {\n          console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n          return [];\n        }\n      }\n\n      // DEFENSE-IN-DEPTH: If specFolder was requested but metadata resolution\n      // is still null after the resolution block, something unexpected happened.\n      // Fail closed rather than falling through to unscoped results.\n      if (specFolder && !memoryMetadataMap) {\n        const error = new Error('memoryMetadataMap unexpectedly null after scope resolution');\n        console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n        return [];\n      }\n    }\n\n    const excludeCold = !isArchivedRetrievalIncludedByDefault();\n    return results\n      .filter((r: { id: string }) => {\n        const metadata = memoryMetadataMap?.get(Number(r.id));\n        // Cold/deprecated rows are included by default (FSRS ranks them lower);\n        // only drop them when archived retrieval is disabled.\n        if (excludeCold && metadata?.importanceTier === 'deprecated') return false;\n        if (!specFolder) return true;\n        if (!metadata) return false;\n        const folder = metadata.specFolder;\n        if (!folder) return false;\n        return folder === specFolder || folder.startsWith(specFolder + '/');\n      })\n      .slice(0, limit)\n      .map((r: { id: string; score: number }) => ({\n        ...r,\n        source: 'bm25',\n      }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] BM25 search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Check whether the BM25 index is populated and available for search.\n * @returns True if the BM25 index exists and contains at least one document.\n */\nfunction isBm25Available(): boolean {\n  if (!isBm25Enabled()) {\n    return false;\n  }\n\n  try {\n    const index = getIndex();\n    return index.getStats().documentCount > 0;\n  } catch (_err: unknown) {\n    // Swallow index-not-initialized errors; caller treats absence as unavailable\n    return false;\n  }\n}\n\n// 9. FTS SEARCH\n\n/**\n * Check whether the FTS5 full-text search table exists in the database.\n * @returns True if the memory_fts table exists in the connected database.\n */\nfunction isFtsAvailable(): boolean {\n  if (!db) {\n    console.warn('[hybrid-search] db not initialized — isFtsAvailable returning false');\n    return false;\n  }\n\n  try {\n    const result = (db.prepare(`\n      SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'\n    `) as Database.Statement).get() as { name: string } | undefined;\n    return !!result;\n  } catch (_err: unknown) {\n    // Swallow DB errors; caller treats absence as unavailable\n    return false;\n  }\n}\n\n/**\n * Run FTS5 full-text search with weighted BM25 scoring and optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Array of FTS-scored results tagged with source 'fts'.\n */\nfunction ftsSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db || !isFtsAvailable()) {\n    console.warn('[hybrid-search] db not initialized or FTS unavailable — returning empty ftsSearch results');\n    return [];\n  }\n\n  const { limit = DEFAULT_LIMIT, specFolder, includeArchived = false } = options;\n\n  try {\n    // Delegate to weighted BM25 FTS5 search from sqlite-fts.ts\n    // Uses bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) for per-column weighting\n    // (title 10x, trigger_phrases 5x, file_path 2x, content 1x)\n    // Filters: deprecated-tier exclusion and spec-folder matching handled by fts5Bm25Search\n    const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n\n    return bm25Results.map(row => ({\n      ...row,\n      id: row.id as number,\n      score: row.fts_score || 0,\n      source: 'fts',\n    }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] FTS search failed: ${msg}`);\n    return [];\n  }\n}\n\n// 10. COMBINED LEXICAL SEARCH\n\n/**\n * Merge FTS and BM25 search results, deduplicating by ID and preferring FTS scores.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Deduplicated array of merged results sorted by score descending.\n */\nfunction combinedLexicalSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  const ftsResults = ftsSearch(query, options);\n  const bm25Results = bm25Search(query, options);\n\n  // Merge by canonical ID, prefer FTS scores.\n  // CanonicalResultId() prevents duplicate rows when one channel emits\n  // Numeric IDs (42) and another emits string IDs (\"42\" or \"mem:42\").\n  const merged = new Map<string, HybridSearchResult>();\n\n  for (const r of ftsResults) {\n    merged.set(canonicalResultId(r.id), r);\n  }\n\n  for (const r of bm25Results) {\n    const canonicalId = canonicalResultId(r.id);\n    if (!merged.has(canonicalId)) {\n      merged.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(merged.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, options.limit || DEFAULT_LIMIT);\n}\n\nfunction normalizeTriggerText(value: string): string {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction triggerQueryTokens(query: string): string[] {\n  return Array.from(new Set(\n    normalizeTriggerText(query)\n      .split(/\\s+/)\n      .filter((token) => token.length >= 2)\n  ));\n}\n\nfunction computeTriggerMatchScore(query: string, phrase: string): number {\n  const normalizedQuery = normalizeTriggerText(query);\n  const normalizedPhrase = normalizeTriggerText(phrase);\n  if (!normalizedQuery || !normalizedPhrase) return 0;\n  if (normalizedPhrase === normalizedQuery) return 1.0;\n\n  const queryTokens = triggerQueryTokens(normalizedQuery);\n  const phraseTokens = new Set(triggerQueryTokens(normalizedPhrase));\n  if (phraseTokens.size < 2) return 0;\n  if (normalizedPhrase.includes(normalizedQuery)) return 0.94;\n  if (normalizedQuery.includes(normalizedPhrase)) return 0.88;\n  if (queryTokens.length === 0) return 0;\n  const overlap = queryTokens.filter((token) => phraseTokens.has(token)).length;\n  const coverage = overlap / queryTokens.length;\n  return coverage >= 0.8 ? coverage * 0.75 : 0;\n}\n\nfunction timestampBoost(value: unknown): number {\n  if (typeof value !== 'string' || value.length === 0) return 0;\n  const parsed = Date.parse(value);\n  if (!Number.isFinite(parsed)) return 0;\n  const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n  return 1 / (1 + ageDays / 30);\n}\n\nfunction exactTriggerSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db) return [];\n\n  const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n  if (tokens.length === 0) return [];\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n  const normalizedQuery = normalizeTriggerText(query);\n  const exactPhraseLike = `%${normalizedQuery}%`;\n  const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n  const conditions = [\n    `m.trigger_phrases IS NOT NULL`,\n    `m.trigger_phrases != ''`,\n    `m.trigger_phrases != '[]'`,\n    // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n    // them below hot memories); the hard exclusion only applies when archived\n    // retrieval is disabled.\n    ...(isArchivedRetrievalIncludedByDefault()\n      ? []\n      : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n    `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n    `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n  ];\n  const params: unknown[] = tokens.map((token) => `%${token}%`);\n\n  if (specFolder) {\n    conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  try {\n    const rows = db.prepare(`\n      SELECT m.*\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE ${conditions.join(' AND ')}\n      ORDER BY\n        CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n        COALESCE(m.updated_at, m.created_at, '') DESC\n      LIMIT ${candidateLimit}\n    `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n\n    return rows\n      .map((row): HybridSearchResult | null => {\n        const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n        const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n        if (matchScore <= 0) return null;\n\n        const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n          ? Math.max(0, Math.min(1, row.importance_weight))\n          : 0.5;\n        const recency = timestampBoost(row.updated_at ?? row.created_at);\n        const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n\n        return {\n          ...row,\n          id: row.id as number,\n          score,\n          triggerScore: matchScore,\n          source: 'trigger',\n        };\n      })\n      .filter((row): row is HybridSearchResult => row !== null)\n      .sort((a, b) => {\n        const scoreDelta = b.score - a.score;\n        if (scoreDelta !== 0) return scoreDelta;\n        const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n        const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n        return bTime - aTime;\n      })\n      .slice(0, limit);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n    return [];\n  }\n}\n\ntype RawChannelList = {\n  source: string;\n  results: Array<{ id: number | string; [key: string]: unknown }>;\n};\n\nfunction resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n  if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n    return result.score;\n  }\n  if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n    return result.similarity / 100;\n  }\n  return 0;\n}\n\nfunction getCandidateSources(result: HybridSearchResult): string[] {\n  const sourceList = (result as { sources?: unknown }).sources;\n  if (Array.isArray(sourceList)) {\n    return sourceList.filter((value): value is string => typeof value === 'string');\n  }\n  return typeof result.source === 'string' && result.source.length > 0\n    ? [result.source]\n    : [];\n}\n\nfunction getCandidateSourceScores(result: HybridSearchResult): Record<string, number> {\n  const sourceScores = (result as { sourceScores?: unknown }).sourceScores;\n  if (sourceScores && typeof sourceScores === 'object' && !Array.isArray(sourceScores)) {\n    const normalizedScores: Record<string, number> = {};\n    for (const [source, score] of Object.entries(sourceScores as Record<string, unknown>)) {\n      if (typeof score === 'number' && Number.isFinite(score)) {\n        normalizedScores[source] = score;\n      }\n    }\n    return normalizedScores;\n  }\n\n  const fallbackScores: Record<string, number> = {};\n  const resultScore = typeof result.score === 'number' && Number.isFinite(result.score)\n    ? result.score\n    : 0;\n  for (const source of getCandidateSources(result)) {\n    fallbackScores[source] = resultScore;\n  }\n  return fallbackScores;\n}\n\nfunction mergeRawCandidate(\n  existing: HybridSearchResult | undefined,\n  incoming: HybridSearchResult\n): HybridSearchResult {\n  if (!existing) {\n    const sources = getCandidateSources(incoming);\n    const channelCount = sources.length;\n    return {\n      ...incoming,\n      sources,\n      channelCount,\n      sourceScores: getCandidateSourceScores(incoming),\n      channelAttribution: sources,\n    };\n  }\n\n  const existingScore = typeof existing.score === 'number' && Number.isFinite(existing.score)\n    ? existing.score\n    : 0;\n  const incomingScore = typeof incoming.score === 'number' && Number.isFinite(incoming.score)\n    ? incoming.score\n    : 0;\n  const primary = incomingScore > existingScore ? incoming : existing;\n  const secondary = primary === incoming ? existing : incoming;\n  const sources = Array.from(new Set([\n    ...getCandidateSources(existing),\n    ...getCandidateSources(incoming),\n  ]));\n  const channelCount = sources.length;\n  const crossChannelBonus = Math.min(0.06, 0.02 * Math.max(0, channelCount - 1));\n  const mergedScore = Math.max(0, Math.min(1, Math.max(existingScore, incomingScore) + crossChannelBonus));\n\n  return {\n    ...(secondary ?? {}),\n    ...primary,\n    score: mergedScore,\n    source: typeof primary.source === 'string' ? primary.source : (sources[0] ?? 'hybrid'),\n    sources,\n    channelCount,\n    sourceScores: {\n      ...getCandidateSourceScores(existing),\n      ...getCandidateSourceScores(incoming),\n    },\n    channelAttribution: sources,\n  };\n}\n\nfunction collectCandidatesFromLists(\n  lists: RawChannelList[],\n  limit?: number\n): HybridSearchResult[] {\n  const deduped = new Map<string, HybridSearchResult>();\n\n  for (const list of lists) {\n    if (!Array.isArray(list.results) || list.results.length === 0) continue;\n\n    const scored = list.results.map((result) => {\n      const rawScore = resolveRawCandidateScore(result as { score?: unknown; similarity?: unknown });\n      return { result, rawScore };\n    });\n\n    let min = Infinity;\n    let max = -Infinity;\n    for (const { rawScore } of scored) {\n      if (rawScore < min) min = rawScore;\n      if (rawScore > max) max = rawScore;\n    }\n    const range = max - min;\n\n    for (const { result, rawScore } of scored) {\n      const normalizedScore = range > 0 ? (rawScore - min) / range : (rawScore > 0 ? 1.0 : 0);\n      const candidate: HybridSearchResult = {\n        ...result,\n        id: result.id,\n        source: list.source,\n        score: normalizedScore,\n        sources: [list.source],\n        sourceScores: { [list.source]: normalizedScore },\n        channelAttribution: [list.source],\n      };\n      const key = canonicalResultId(candidate.id);\n      deduped.set(key, mergeRawCandidate(deduped.get(key), candidate));\n    }\n  }\n\n  return applyResultLimit(\n    Array.from(deduped.values()).sort((a, b) => {\n      const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n      const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n      return bScore - aScore;\n    }),\n    limit\n  );\n}\n\nfunction mergeRawCandidateSets(\n  existing: HybridSearchResult[],\n  incoming: HybridSearchResult[],\n  limit?: number\n): HybridSearchResult[] {\n  const merged = new Map<string, HybridSearchResult>();\n\n  for (const result of [...existing, ...incoming]) {\n    const key = canonicalResultId(result.id);\n    merged.set(key, mergeRawCandidate(merged.get(key), result));\n  }\n\n  return applyResultLimit(\n    Array.from(merged.values()).sort((a, b) => {\n      const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n      const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n      return bScore - aScore;\n    }),\n    limit\n  );\n}\n\nfunction getAllowedChannels(options: HybridSearchOptions): Set<ChannelName> {\n  const allowed = new Set<ChannelName>(['vector', 'fts', 'graph', 'degree']);\n\n  if (isBm25Enabled()) {\n    allowed.add('bm25');\n  }\n\n  if (options.useVector === false) allowed.delete('vector');\n  if (options.useBm25 === false) allowed.delete('bm25');\n  if (options.useFts === false) allowed.delete('fts');\n  if (options.useGraph === false) {\n    allowed.delete('graph');\n    allowed.delete('degree');\n  }\n\n  return allowed;\n}\n\nfunction applyAllowedChannelOverrides(\n  options: HybridSearchOptions,\n  allowedChannels: Set<ChannelName>,\n  overrides: Partial<HybridSearchOptions> = {}\n): HybridSearchOptions {\n  return {\n    ...options,\n    ...overrides,\n    useVector: allowedChannels.has('vector'),\n    useBm25: allowedChannels.has('bm25'),\n    useFts: allowedChannels.has('fts'),\n    useGraph: allowedChannels.has('graph'),\n  };\n}\n\ntype FallbackPlanKind = 'adaptive' | 'tiered';\ntype FallbackStageName = 'primary' | 'retry';\n\ninterface FallbackPlanStage {\n  stage: FallbackStageName;\n  options: HybridSearchOptions;\n  results: HybridSearchResult[];\n  execution: HybridFusionExecution | null;\n  trigger?: 'empty' | DegradationTrigger;\n}\n\ninterface FallbackPlanExecution {\n  allowedChannels: Set<ChannelName>;\n  stages: FallbackPlanStage[];\n}\n\ninterface HybridFusionExecution {\n  evaluationMode: boolean;\n  intent: string;\n  lists: Array<{\n    source: string;\n    results: Array<{ id: number | string; [key: string]: unknown }>;\n    weight?: number;\n  }>;\n  routeResult: ReturnType<typeof routeQuery>;\n  budgetResult: ReturnType<typeof getDynamicTokenBudget>;\n  s3meta: Sprint3PipelineMeta;\n  fusedResults: HybridSearchResult[];\n  vectorEmbeddingCache: Map<number, Float32Array>;\n}\n\nfunction resolveAdaptiveDocumentType(\n  lists: Array<{ results: Array<Record<string, unknown>> }>,\n): string | undefined {\n  const counts = new Map<string, number>();\n  for (const list of lists) {\n    for (const result of list.results.slice(0, 3)) {\n      const candidate = result.documentType ?? result.document_type;\n      if (typeof candidate !== 'string' || candidate.length === 0) {\n        continue;\n      }\n      counts.set(candidate, (counts.get(candidate) ?? 0) + 1);\n    }\n  }\n\n  let topType: string | undefined;\n  let topCount = 0;\n  for (const [documentType, count] of counts) {\n    if (count > topCount) {\n      topType = documentType;\n      topCount = count;\n    }\n  }\n\n  return topType;\n}\n\nfunction markFallbackRetry(results: HybridSearchResult[]): HybridSearchResult[] {\n  for (const result of results) {\n    (result as Record<string, unknown>).fallbackRetry = true;\n  }\n\n  return results;\n}\n\nfunction toEmbeddingBufferView(value: unknown): Float32Array | null {\n  if (value instanceof Float32Array) {\n    return value;\n  }\n\n  if (Array.isArray(value)) {\n    const asNumbers = value.every((entry) => typeof entry === 'number' && Number.isFinite(entry));\n    return asNumbers ? new Float32Array(value) : null;\n  }\n\n  if (Buffer.isBuffer(value)) {\n    return new Float32Array(value.buffer, value.byteOffset, value.byteLength / 4);\n  }\n\n  return null;\n}\n\nasync function executeFallbackPlan(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {},\n  planKind: FallbackPlanKind,\n  overrides: Partial<HybridSearchOptions> = {}\n): Promise<FallbackPlanExecution> {\n  const allowedChannels = getAllowedChannels(options);\n  const stages: FallbackPlanStage[] = [];\n\n  const primaryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n    minSimilarity: options.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY,\n    ...overrides,\n  });\n  const primaryExecution = await collectAndFuseHybridResults(query, embedding, primaryOptions);\n  const primaryResults = primaryExecution\n    ? applyResultLimit(primaryExecution.fusedResults, primaryOptions.limit)\n    : await hybridSearch(query, embedding, primaryOptions);\n  stages.push({\n    stage: 'primary',\n    options: primaryOptions,\n    results: primaryResults,\n    execution: primaryExecution,\n  });\n\n  if (planKind === 'tiered') {\n    const trigger = checkDegradation(primaryResults);\n    if (!trigger) {\n      return { allowedChannels, stages };\n    }\n\n    const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n      ...overrides,\n      minSimilarity: TIERED_FALLBACK_MIN_SIMILARITY,\n      forceAllChannels: true,\n    });\n    const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n    const retryResults = retryExecution\n      ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n      : await hybridSearch(query, embedding, retryOptions);\n    stages.push({\n      stage: 'retry',\n      options: retryOptions,\n      results: retryResults,\n      execution: retryExecution,\n      trigger,\n    });\n    return { allowedChannels, stages };\n  }\n\n  const primaryMinSimilarity = primaryOptions.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY;\n  if (primaryResults.length === 0 && primaryMinSimilarity >= SECONDARY_FALLBACK_MIN_SIMILARITY) {\n    const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n      ...overrides,\n      minSimilarity: SECONDARY_FALLBACK_MIN_SIMILARITY,\n    });\n    const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n    const retryResultsBase = retryExecution\n      ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n      : await hybridSearch(query, embedding, retryOptions);\n    const retryResults = retryResultsBase.length > 0\n      ? markFallbackRetry(retryResultsBase)\n      : retryResultsBase;\n    stages.push({\n      stage: 'retry',\n      options: retryOptions,\n      results: retryResults,\n      execution: retryExecution,\n      trigger: 'empty',\n    });\n  }\n\n  return { allowedChannels, stages };\n}\n\n// 11. HYBRID SEARCH\n\n/**\n * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n * Retained as internal fallback only.\n */\nasync function hybridSearch(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const {\n    limit = DEFAULT_LIMIT,\n    specFolder,\n    minSimilarity = 0,\n    useBm25 = isBm25Enabled(),\n    useFts = true,\n    useVector = true,\n    useGraph = true,\n    includeArchived = false,\n  } = options;\n\n  const results: HybridSearchResult[] = [];\n\n  // Vector search\n  if (useVector && embedding && vectorSearchFn) {\n    try {\n      const vectorResults = vectorSearchFn(embedding, {\n        limit,\n        specFolder,\n        minSimilarity,\n        includeConstitutional: false, // Handler manages constitutional separately\n        includeArchived,\n      });\n      for (const r of vectorResults) {\n        results.push({\n          ...r,\n          id: r.id as number,\n          score: (r.similarity as number) || 0,\n          source: 'vector',\n        });\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n    }\n  }\n\n  // FTS search\n  if (useFts) {\n    const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n    results.push(...ftsResults);\n  }\n\n  // BM25 search\n  if (useBm25) {\n    const bm25Results = bm25Search(query, { limit, specFolder });\n    results.push(...bm25Results);\n  }\n\n  // Graph search\n  if (useGraph && graphSearchFn) {\n    try {\n      graphMetrics.totalQueries++;\n      const graphResults = graphSearchFn(query, { limit, specFolder });\n      for (const r of graphResults) {\n        results.push({\n          ...r,\n          id: r.id as number | string,\n          score: (r.score as number) || 0,\n          source: 'graph',\n        });\n      }\n      if (graphResults.length > 0) {\n        graphMetrics.graphHits++;\n        graphMetrics.graphResultCount += graphResults.length;\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n    }\n  }\n\n  // Normalize scores per source before merging so one method's raw scale\n  // Does not dominate others during final ranking.\n  const bySource = new Map<string, HybridSearchResult[]>();\n  for (const r of results) {\n    const src = r.source || 'unknown';\n    if (!bySource.has(src)) bySource.set(src, []);\n    bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n  }\n\n  const normalized: HybridSearchResult[] = [];\n  for (const [, group] of bySource) {\n    if (group.length === 0) continue;\n    const scores = group.map(r => r.score);\n    let min = Infinity;\n    let max = -Infinity;\n    for (const s of scores) {\n      if (s < min) min = s;\n      if (s > max) max = s;\n    }\n    const range = max - min;\n    for (const r of group) {\n      normalized.push({\n        ...r,\n        score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n      });\n    }\n  }\n\n  // Deduplicate by ID (keep highest normalized score)\n  // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n  // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n  // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n  // Field and downstream consumers would need to be updated accordingly.\n  const deduped = new Map<string, HybridSearchResult>();\n  for (const r of normalized) {\n    const canonicalId = canonicalResultId(r.id);\n    const existing = deduped.get(canonicalId);\n    if (!existing || r.score > existing.score) {\n      deduped.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(deduped.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, limit);\n}\n\n/**\n * Enhanced hybrid search with RRF fusion.\n * All search channels use synchronous better-sqlite3; sequential execution\n * is correct — Promise.all would add overhead without achieving parallelism.\n */\nasync function hybridSearchEnhanced(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const execution = await collectAndFuseHybridResults(query, embedding, options);\n  if (execution) {\n    if (options.stopAfterFusion) {\n      return applyResultLimit(execution.fusedResults, options.limit);\n    }\n\n    return enrichFusedResults(query, execution, options);\n  }\n\n  return hybridSearch(query, embedding, options);\n}\n\nasync function collectAndFuseHybridResults(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridFusionExecution | null> {\n  try {\n    const evaluationMode = options.evaluationMode === true;\n    const lists: HybridFusionExecution['lists'] = [];\n\n    // Pipeline metadata collector (populated by flag-gated stages)\n    const s3meta: Sprint3PipelineMeta = {};\n\n    // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n    // When enabled, classifies query complexity and restricts channels to a\n    // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n    const routeResult = routeQuery(query, options.triggerPhrases);\n    const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n    const activeChannels = options.forceAllChannels\n      ? new Set<ChannelName>(allPossibleChannels)\n      : new Set<ChannelName>(routeResult.channels);\n\n    // Respect explicit caller channel disables across both the primary route and\n    // every fallback tier. useGraph=false also disables the dependent degree lane.\n    const allowedChannels = getAllowedChannels(options);\n    for (const channel of allPossibleChannels) {\n      if (!allowedChannels.has(channel)) activeChannels.delete(channel);\n    }\n\n    const skippedChannels = allPossibleChannels.filter(ch => !activeChannels.has(ch));\n\n    if (skippedChannels.length > 0) {\n      s3meta.routing = {\n        tier: routeResult.tier,\n        channels: routeResult.channels,\n        skippedChannels,\n        featureFlagEnabled: isComplexityRouterEnabled(),\n        confidence: routeResult.classification.confidence,\n        features: routeResult.classification.features as Record<string, unknown>,\n      };\n    }\n\n    // -- Stage E: Dynamic Token Budget (SPECKIT_DYNAMIC_TOKEN_BUDGET) --\n    // Compute tier-aware budget early so it's available for downstream truncation.\n    // When disabled, getDynamicTokenBudget returns the default 4000 budget with applied=false.\n    // Weak / low-confidence queries keep the full budget so recall is not trimmed away.\n    const lowSignalQuery =\n      routeResult.classification.confidence === 'low' ||\n      routeResult.classification.confidence === 'fallback';\n    const budgetResult = getDynamicTokenBudget(routeResult.tier, undefined, {\n      lowSignal: lowSignalQuery,\n    });\n    if (budgetResult.applied && !evaluationMode) {\n      s3meta.tokenBudget = {\n        tier: budgetResult.tier,\n        budget: budgetResult.budget,\n        applied: budgetResult.applied,\n        featureFlagEnabled: isDynamicTokenBudgetEnabled(),\n        configValues: DEFAULT_TOKEN_BUDGET_CONFIG as unknown as Record<string, number>,\n        // headerOverhead and adjustedBudget are patched in below after they are computed\n        headerOverhead: 0,\n        adjustedBudget: budgetResult.budget,\n      };\n    }\n\n    // Channel results collected independently, merged after all complete\n    let semanticResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [];\n    let ftsChannelResults: HybridSearchResult[] = [];\n    let bm25ChannelResults: HybridSearchResult[] = [];\n    let triggerChannelResults: HybridSearchResult[] = [];\n    const vectorEmbeddingCache = new Map<number, Float32Array>();\n\n    // All channels use synchronous better-sqlite3; sequential execution\n    // Is correct — Promise.all adds overhead without parallelism.\n\n    // Vector channel — gated by query-complexity routing\n    if (activeChannels.has('vector') && embedding && vectorSearchFn) {\n      try {\n        const vectorResults = vectorSearchFn(embedding, {\n          limit: options.limit || DEFAULT_LIMIT,\n          specFolder: options.specFolder,\n          minSimilarity: options.minSimilarity || 0,\n          includeConstitutional: false,\n          includeArchived: options.includeArchived || false,\n          includeEmbeddings: true,\n        });\n        semanticResults = vectorResults.map((r: Record<string, unknown>): { id: number | string; source: string; [key: string]: unknown } => ({\n          ...r,\n          id: r.id as number | string,\n          source: 'vector',\n        }));\n        for (const result of semanticResults) {\n          if (typeof result.id !== 'number') continue;\n          const embeddingCandidate = toEmbeddingBufferView(\n            (result as Record<string, unknown>).embedding\n            ?? (result as Record<string, unknown>).embeddingBuffer\n          );\n          if (embeddingCandidate) {\n            vectorEmbeddingCache.set(result.id, embeddingCandidate);\n          }\n        }\n        lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n      } catch (_err: unknown) {\n        // Non-critical — vector channel failure does not block pipeline\n        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // FTS channel (internal error handling in ftsSearch) — gated by query-complexity routing\n    if (activeChannels.has('fts')) {\n      ftsChannelResults = ftsSearch(query, options);\n      if (ftsChannelResults.length > 0) {\n        // FTS weight reduced to 0.3 after ablation showed 0.8 was harmful,\n        // flooding top-K with noisy lexical matches despite its exact-match value.\n        lists.push({ source: 'fts', results: ftsChannelResults, weight: 0.3 });\n      }\n    }\n\n    // BM25 channel (internal error handling in bm25Search) — gated by query-complexity routing\n    if (activeChannels.has('bm25')) {\n      bm25ChannelResults = bm25Search(query, options);\n      if (bm25ChannelResults.length > 0) {\n        // BM25 weight 0.6 is lowest lexical channel — in-memory BM25 index\n        // Has less precise scoring than SQLite FTS5 BM25; kept for coverage breadth.\n        lists.push({ source: 'bm25', results: bm25ChannelResults, weight: 0.6 });\n      }\n    }\n\n    triggerChannelResults = exactTriggerSearch(query, options);\n    if (triggerChannelResults.length > 0) {\n      lists.push({ source: 'trigger', results: triggerChannelResults, weight: 1.4 });\n    }\n\n    // Graph channel — gated by query-complexity routing\n    const useGraph = (options.useGraph !== false) && activeChannels.has('graph');\n    if (useGraph && graphSearchFn) {\n      try {\n        graphMetrics.totalQueries++; // counted only if channel executes\n        const graphResults = graphSearchFn(query, {\n          limit: options.limit || DEFAULT_LIMIT,\n          specFolder: options.specFolder,\n          intent: options.intent,\n        });\n        if (graphResults.length > 0) {\n          graphMetrics.graphHits++;\n          graphMetrics.graphResultCount += graphResults.length;\n          lists.push({ source: 'graph', results: graphResults.map((r: Record<string, unknown>) => ({\n            ...r,\n            id: r.id as number | string,\n          })), weight: 0.5 });\n        }\n      } catch (_err: unknown) {\n        // Non-critical — graph channel failure does not block pipeline","lineStart":1,"lineEnd":1445,"totalLines":1446,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781722672906,"end":1781722672921}},"id":"prt_ed6f26d880014gP5AXdztEAldi","sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","messageID":"msg_ed6f2656c001F7tqFYFZkzeVc5"}}
{"type":"tool_use","timestamp":1781722673299,"sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","part":{"type":"tool","tool":"read","callID":"call_01_PP6x7cjPN6sCKWEs0yn04046","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/dynamic-token-budget.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/dynamic-token-budget.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Dynamic Token Budget\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // ADVISORY-ONLY: This module computes a token budget for a query\n6: // Based on its complexity tier, but does NOT enforce that budget\n7: // Downstream. The returned BudgetResult is handed to callers who\n8: // Are solely responsible for respecting it (e.g. by trimming\n9: // Result sets or truncating content before sending to the LLM).\n10: import { type QueryComplexityTier } from './query-classifier.js';\n11: import { isDynamicTokenBudgetEnabled } from './search-flags.js';\n12: \n13: // Feature catalog: Dynamic token budget allocation\n14: \n15: \n16: /* --- 1. TYPES & CONSTANTS --- */\n17: \n18: /** Budget (in tokens) allocated per complexity tier. */\n19: interface TokenBudgetConfig {\n20:   /** Simple query budget: 1500 tokens. */\n21:   simple: number;\n22:   /** Moderate query budget: 2500 tokens. */\n23:   moderate: number;\n24:   /** Complex query budget: 4000 tokens. */\n25:   complex: number;\n26: }\n27: \n28: /** Result of a token budget lookup. */\n29: interface BudgetResult {\n30:   /** The complexity tier that determined the budget. */\n31:   tier: QueryComplexityTier;\n32:   /** The allocated token budget. */\n33:   budget: number;\n34:   /** Whether the dynamic flag was active (false = default fallback used). */\n35:   applied: boolean;\n36: }\n37: \n38: /** Default budget when the feature flag is disabled — treat everything as complex. */\n39: const DEFAULT_BUDGET = 4000;\n40: \n41: /** Default tier-to-budget mapping when dynamic allocation is enabled.\n42:  * 1500/2500/4000 tiers balance context window cost vs. recall —\n43:  * simple queries need fewer tokens, complex queries need the full budget. */\n44: const DEFAULT_TOKEN_BUDGET_CONFIG: TokenBudgetConfig = {\n45:   simple: 1500,\n46:   moderate: 2500,\n47:   complex: 4000,\n48: };\n49: \n50: /* --- 2. FEATURE FLAG --- */\n51: \n52: /* --- 3. BUDGET RESOLUTION --- */\n53: \n54: /**\n55:  * Get the token budget for a given query complexity tier.\n56:  *\n57:  * When SPECKIT_DYNAMIC_TOKEN_BUDGET is disabled (default), returns the DEFAULT_BUDGET\n58:  * (4000) for all queries regardless of tier, with applied=false.\n59:  *\n60:  * When enabled, maps tier to the configured budget:\n61:  *   simple   → 1500 tokens\n62:  *   moderate → 2500 tokens\n63:  *   complex  → 4000 tokens\n64:  *\n65:  * Low-signal / weak queries are never trimmed below the full budget: they\n66:  * carry the least relevance signal and depend on breadth to recover anything,\n67:  * so shrinking their budget would truncate away the recall they most need.\n68:  *\n69:  * @param tier    - The complexity tier from the query classifier\n70:  * @param config  - Optional custom budget config (overrides DEFAULT_TOKEN_BUDGET_CONFIG)\n71:  * @param options - Optional flags; lowSignal floors the budget at DEFAULT_BUDGET\n72:  * @returns BudgetResult with tier, budget, and applied flag\n73:  */\n74: function getDynamicTokenBudget(\n75:   tier: QueryComplexityTier,\n76:   config?: TokenBudgetConfig,\n77:   options?: { lowSignal?: boolean },\n78: ): BudgetResult {\n79:   // Feature flag gate: return default when disabled\n80:   if (!isDynamicTokenBudgetEnabled()) {\n81:     return {\n82:       tier,\n83:       budget: DEFAULT_BUDGET,\n84:       applied: false,\n85:     };\n86:   }\n87: \n88:   const effectiveConfig = config ?? DEFAULT_TOKEN_BUDGET_CONFIG;\n89:   const tierBudget = effectiveConfig[tier] ?? DEFAULT_BUDGET;\n90:   const budget = options?.lowSignal\n91:     ? Math.max(tierBudget, DEFAULT_BUDGET)\n92:     : tierBudget;\n93: \n94:   return {\n95:     tier,\n96:     budget,\n97:     applied: true,\n98:   };\n99: }\n100: \n101: /* --- 4. EXPORTS --- */\n102: \n103: export {\n104:   // Types\n105:   type TokenBudgetConfig,\n106:   type BudgetResult,\n107: \n108:   // Constants\n109:   DEFAULT_BUDGET,\n110:   DEFAULT_TOKEN_BUDGET_CONFIG,\n111: \n112:   // Functions\n113:   getDynamicTokenBudget,\n114:   isDynamicTokenBudgetEnabled,\n115: };\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Dynamic Token Budget\n// ───────────────────────────────────────────────────────────────\n//\n// ADVISORY-ONLY: This module computes a token budget for a query\n// Based on its complexity tier, but does NOT enforce that budget\n// Downstream. The returned BudgetResult is handed to callers who\n// Are solely responsible for respecting it (e.g. by trimming\n// Result sets or truncating content before sending to the LLM).\nimport { type QueryComplexityTier } from './query-classifier.js';\nimport { isDynamicTokenBudgetEnabled } from './search-flags.js';\n\n// Feature catalog: Dynamic token budget allocation\n\n\n/* --- 1. TYPES & CONSTANTS --- */\n\n/** Budget (in tokens) allocated per complexity tier. */\ninterface TokenBudgetConfig {\n  /** Simple query budget: 1500 tokens. */","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/dynamic-token-budget.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Dynamic Token Budget\n// ───────────────────────────────────────────────────────────────\n//\n// ADVISORY-ONLY: This module computes a token budget for a query\n// Based on its complexity tier, but does NOT enforce that budget\n// Downstream. The returned BudgetResult is handed to callers who\n// Are solely responsible for respecting it (e.g. by trimming\n// Result sets or truncating content before sending to the LLM).\nimport { type QueryComplexityTier } from './query-classifier.js';\nimport { isDynamicTokenBudgetEnabled } from './search-flags.js';\n\n// Feature catalog: Dynamic token budget allocation\n\n\n/* --- 1. TYPES & CONSTANTS --- */\n\n/** Budget (in tokens) allocated per complexity tier. */\ninterface TokenBudgetConfig {\n  /** Simple query budget: 1500 tokens. */\n  simple: number;\n  /** Moderate query budget: 2500 tokens. */\n  moderate: number;\n  /** Complex query budget: 4000 tokens. */\n  complex: number;\n}\n\n/** Result of a token budget lookup. */\ninterface BudgetResult {\n  /** The complexity tier that determined the budget. */\n  tier: QueryComplexityTier;\n  /** The allocated token budget. */\n  budget: number;\n  /** Whether the dynamic flag was active (false = default fallback used). */\n  applied: boolean;\n}\n\n/** Default budget when the feature flag is disabled — treat everything as complex. */\nconst DEFAULT_BUDGET = 4000;\n\n/** Default tier-to-budget mapping when dynamic allocation is enabled.\n * 1500/2500/4000 tiers balance context window cost vs. recall —\n * simple queries need fewer tokens, complex queries need the full budget. */\nconst DEFAULT_TOKEN_BUDGET_CONFIG: TokenBudgetConfig = {\n  simple: 1500,\n  moderate: 2500,\n  complex: 4000,\n};\n\n/* --- 2. FEATURE FLAG --- */\n\n/* --- 3. BUDGET RESOLUTION --- */\n\n/**\n * Get the token budget for a given query complexity tier.\n *\n * When SPECKIT_DYNAMIC_TOKEN_BUDGET is disabled (default), returns the DEFAULT_BUDGET\n * (4000) for all queries regardless of tier, with applied=false.\n *\n * When enabled, maps tier to the configured budget:\n *   simple   → 1500 tokens\n *   moderate → 2500 tokens\n *   complex  → 4000 tokens\n *\n * Low-signal / weak queries are never trimmed below the full budget: they\n * carry the least relevance signal and depend on breadth to recover anything,\n * so shrinking their budget would truncate away the recall they most need.\n *\n * @param tier    - The complexity tier from the query classifier\n * @param config  - Optional custom budget config (overrides DEFAULT_TOKEN_BUDGET_CONFIG)\n * @param options - Optional flags; lowSignal floors the budget at DEFAULT_BUDGET\n * @returns BudgetResult with tier, budget, and applied flag\n */\nfunction getDynamicTokenBudget(\n  tier: QueryComplexityTier,\n  config?: TokenBudgetConfig,\n  options?: { lowSignal?: boolean },\n): BudgetResult {\n  // Feature flag gate: return default when disabled\n  if (!isDynamicTokenBudgetEnabled()) {\n    return {\n      tier,\n      budget: DEFAULT_BUDGET,\n      applied: false,\n    };\n  }\n\n  const effectiveConfig = config ?? DEFAULT_TOKEN_BUDGET_CONFIG;\n  const tierBudget = effectiveConfig[tier] ?? DEFAULT_BUDGET;\n  const budget = options?.lowSignal\n    ? Math.max(tierBudget, DEFAULT_BUDGET)\n    : tierBudget;\n\n  return {\n    tier,\n    budget,\n    applied: true,\n  };\n}\n\n/* --- 4. EXPORTS --- */\n\nexport {\n  // Types\n  type TokenBudgetConfig,\n  type BudgetResult,\n\n  // Constants\n  DEFAULT_BUDGET,\n  DEFAULT_TOKEN_BUDGET_CONFIG,\n\n  // Functions\n  getDynamicTokenBudget,\n  isDynamicTokenBudgetEnabled,\n};","lineStart":1,"lineEnd":115,"totalLines":115,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/dynamic-token-budget.ts","time":{"start":1781722673288,"end":1781722673297}},"id":"prt_ed6f26f4a001aj0ITgm1SFARIq","sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","messageID":"msg_ed6f2656c001F7tqFYFZkzeVc5"}}
{"type":"tool_use","timestamp":1781722673708,"sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","part":{"type":"tool","tool":"read","callID":"call_02_Te8YiI086e4ODlNJRsnS0552","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/token-budget-skip-and-floor.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/token-budget-skip-and-floor.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST — TOKEN BUDGET: SKIP-AND-CONTINUE + DETAILED-COUNT FLOOR\n3: // ───────────────────────────────────────────────────────────────\n4: // Proves the budget truncator no longer collapses a populated search to a\n5: // single result: a too-large top result is skipped (not hard-stopped) so\n6: // smaller lower-ranked results still fit, and the detailed count is floored\n7: // at min(limit, 3) by promoting overflow as token-cheap summaries — even when\n8: // includeContent is false (the common metadata-only call).\n9: \n10: import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n11: import {\n12:   estimateResultTokens,\n13:   truncateToBudget,\n14: } from '../lib/search/hybrid-search';\n15: import type { HybridSearchResult } from '../lib/search/hybrid-search';\n16: \n17: /** Helper: minimal result with optional content. */\n18: function makeResult(\n19:   overrides: Partial<HybridSearchResult> & { id: number; score: number },\n20: ): HybridSearchResult {\n21:   return { source: 'test', ...overrides };\n22: }\n23: \n24: describe('truncateToBudget — skip-and-continue + floor', () => {\n25:   beforeEach(() => {\n26:     vi.spyOn(console, 'warn').mockImplementation(() => {});\n27:   });\n28:   afterEach(() => {\n29:     vi.restoreAllMocks();\n30:   });\n31: \n32:   it('keeps smaller fitting results when the top result overflows (no hard break)', () => {\n33:     const huge = makeResult({\n34:       id: 1,\n35:       score: 0.95,\n36:       title: 'Huge top match',\n37:       content: 'x'.repeat(40000),\n38:     });\n39:     const small2 = makeResult({ id: 2, score: 0.8, title: 'Small B' });\n40:     const small3 = makeResult({ id: 3, score: 0.7, title: 'Small C' });\n41:     const small4 = makeResult({ id: 4, score: 0.6, title: 'Small D' });\n42: \n43:     // Budget fits the three small results but not the huge one.\n44:     const budget =\n45:       estimateResultTokens(small2) +\n46:       estimateResultTokens(small3) +\n47:       estimateResultTokens(small4) +\n48:       5;\n49: \n50:     const { results, truncated } = truncateToBudget(\n51:       [huge, small2, small3, small4],\n52:       budget,\n53:       { includeContent: false, queryId: 'skip-test', limit: 10 },\n54:     );\n55: \n56:     expect(truncated).toBe(true);\n57:     // The headline bug: a single large top memory must NOT starve the tail.\n58:     // All three smaller results survive at full detail.\n59:     const ids = results.map((r) => r.id);\n60:     expect(ids).toContain(2);\n61:     expect(ids).toContain(3);\n62:     expect(ids).toContain(4);\n63:     expect(results.length).toBeGreaterThanOrEqual(3);\n64:     // Output stays highest-score-first.\n65:     for (let i = 1; i < results.length; i++) {\n66:       expect(results[i - 1]!.score).toBeGreaterThanOrEqual(results[i]!.score);\n67:     }\n68:   });\n69: \n70:   it('floors the detailed count at min(limit, 3) by promoting summaries, even when includeContent=false', () => {\n71:     // Five results that each individually fit, but only one fits the budget at\n72:     // full detail. Without the floor this collapses toward one result.\n73:     const big = makeResult({\n74:       id: 1,\n75:       score: 0.95,\n76:       title: 'Big A',\n77:       content: 'a'.repeat(2400),\n78:     });\n79:     const rest = [2, 3, 4, 5].map((id) =>\n80:       makeResult({\n81:         id,\n82:         score: 1 - id * 0.1,\n83:         title: `Doc ${id}`,\n84:         content: 'b'.repeat(2400),\n85:       }),\n86:     );\n87: \n88:     const budget = estimateResultTokens(big) + 10;\n89: \n90:     const { results, truncated, progressive } = truncateToBudget(\n91:       [big, ...rest],\n92:       budget,\n93:       { includeContent: false, queryId: 'floor-test', limit: 10 },\n94:     );\n95: \n96:     expect(truncated).toBe(true);\n97:     // Floor honored: at least 3 results returned despite the tight budget.\n98:     expect(results.length).toBeGreaterThanOrEqual(3);\n99:     // The promoted results are token-cheap summaries (summary-first applies\n100:     // regardless of includeContent).\n101:     const summarized = results.filter((r) => r['_summarized'] === true);\n102:     expect(summarized.length).toBeGreaterThanOrEqual(2);\n103:     // Whatever did not fit the floor is routed to progressive disclosure, not\n104:     // discarded.\n105:     expect(progressive).toBeDefined();\n106:     expect(progressive!.summaryLayer.count).toBeGreaterThan(0);\n107:   });\n108: \n109:   it('honors a small explicit limit as the floor (min(limit, 3))', () => {\n110:     const a = makeResult({ id: 1, score: 0.9, title: 'A', content: 'x'.repeat(8000) });\n111:     const b = makeResult({ id: 2, score: 0.8, title: 'B', content: 'x'.repeat(8000) });\n112:     const c = makeResult({ id: 3, score: 0.7, title: 'C', content: 'x'.repeat(8000) });\n113: \n114:     const { results } = truncateToBudget([a, b, c], 50, {\n115:       includeContent: false,\n116:       limit: 2,\n117:     });\n118: \n119:     // limit=2 → floor is min(2, 3) = 2, not 3.\n120:     expect(results).toHaveLength(2);\n121:     expect(results.map((r) => r.id)).toEqual([1, 2]);\n122:   });\n123: });\n\n(End of file - total 123 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST — TOKEN BUDGET: SKIP-AND-CONTINUE + DETAILED-COUNT FLOOR\n// ───────────────────────────────────────────────────────────────\n// Proves the budget truncator no longer collapses a populated search to a\n// single result: a too-large top result is skipped (not hard-stopped) so\n// smaller lower-ranked results still fit, and the detailed count is floored\n// at min(limit, 3) by promoting overflow as token-cheap summaries — even when\n// includeContent is false (the common metadata-only call).\n\nimport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\nimport {\n  estimateResultTokens,\n  truncateToBudget,\n} from '../lib/search/hybrid-search';\nimport type { HybridSearchResult } from '../lib/search/hybrid-search';\n\n/** Helper: minimal result with optional content. */\nfunction makeResult(\n  overrides: Partial<HybridSearchResult> & { id: number; score: number },\n): HybridSearchResult {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/token-budget-skip-and-floor.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST — TOKEN BUDGET: SKIP-AND-CONTINUE + DETAILED-COUNT FLOOR\n// ───────────────────────────────────────────────────────────────\n// Proves the budget truncator no longer collapses a populated search to a\n// single result: a too-large top result is skipped (not hard-stopped) so\n// smaller lower-ranked results still fit, and the detailed count is floored\n// at min(limit, 3) by promoting overflow as token-cheap summaries — even when\n// includeContent is false (the common metadata-only call).\n\nimport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\nimport {\n  estimateResultTokens,\n  truncateToBudget,\n} from '../lib/search/hybrid-search';\nimport type { HybridSearchResult } from '../lib/search/hybrid-search';\n\n/** Helper: minimal result with optional content. */\nfunction makeResult(\n  overrides: Partial<HybridSearchResult> & { id: number; score: number },\n): HybridSearchResult {\n  return { source: 'test', ...overrides };\n}\n\ndescribe('truncateToBudget — skip-and-continue + floor', () => {\n  beforeEach(() => {\n    vi.spyOn(console, 'warn').mockImplementation(() => {});\n  });\n  afterEach(() => {\n    vi.restoreAllMocks();\n  });\n\n  it('keeps smaller fitting results when the top result overflows (no hard break)', () => {\n    const huge = makeResult({\n      id: 1,\n      score: 0.95,\n      title: 'Huge top match',\n      content: 'x'.repeat(40000),\n    });\n    const small2 = makeResult({ id: 2, score: 0.8, title: 'Small B' });\n    const small3 = makeResult({ id: 3, score: 0.7, title: 'Small C' });\n    const small4 = makeResult({ id: 4, score: 0.6, title: 'Small D' });\n\n    // Budget fits the three small results but not the huge one.\n    const budget =\n      estimateResultTokens(small2) +\n      estimateResultTokens(small3) +\n      estimateResultTokens(small4) +\n      5;\n\n    const { results, truncated } = truncateToBudget(\n      [huge, small2, small3, small4],\n      budget,\n      { includeContent: false, queryId: 'skip-test', limit: 10 },\n    );\n\n    expect(truncated).toBe(true);\n    // The headline bug: a single large top memory must NOT starve the tail.\n    // All three smaller results survive at full detail.\n    const ids = results.map((r) => r.id);\n    expect(ids).toContain(2);\n    expect(ids).toContain(3);\n    expect(ids).toContain(4);\n    expect(results.length).toBeGreaterThanOrEqual(3);\n    // Output stays highest-score-first.\n    for (let i = 1; i < results.length; i++) {\n      expect(results[i - 1]!.score).toBeGreaterThanOrEqual(results[i]!.score);\n    }\n  });\n\n  it('floors the detailed count at min(limit, 3) by promoting summaries, even when includeContent=false', () => {\n    // Five results that each individually fit, but only one fits the budget at\n    // full detail. Without the floor this collapses toward one result.\n    const big = makeResult({\n      id: 1,\n      score: 0.95,\n      title: 'Big A',\n      content: 'a'.repeat(2400),\n    });\n    const rest = [2, 3, 4, 5].map((id) =>\n      makeResult({\n        id,\n        score: 1 - id * 0.1,\n        title: `Doc ${id}`,\n        content: 'b'.repeat(2400),\n      }),\n    );\n\n    const budget = estimateResultTokens(big) + 10;\n\n    const { results, truncated, progressive } = truncateToBudget(\n      [big, ...rest],\n      budget,\n      { includeContent: false, queryId: 'floor-test', limit: 10 },\n    );\n\n    expect(truncated).toBe(true);\n    // Floor honored: at least 3 results returned despite the tight budget.\n    expect(results.length).toBeGreaterThanOrEqual(3);\n    // The promoted results are token-cheap summaries (summary-first applies\n    // regardless of includeContent).\n    const summarized = results.filter((r) => r['_summarized'] === true);\n    expect(summarized.length).toBeGreaterThanOrEqual(2);\n    // Whatever did not fit the floor is routed to progressive disclosure, not\n    // discarded.\n    expect(progressive).toBeDefined();\n    expect(progressive!.summaryLayer.count).toBeGreaterThan(0);\n  });\n\n  it('honors a small explicit limit as the floor (min(limit, 3))', () => {\n    const a = makeResult({ id: 1, score: 0.9, title: 'A', content: 'x'.repeat(8000) });\n    const b = makeResult({ id: 2, score: 0.8, title: 'B', content: 'x'.repeat(8000) });\n    const c = makeResult({ id: 3, score: 0.7, title: 'C', content: 'x'.repeat(8000) });\n\n    const { results } = truncateToBudget([a, b, c], 50, {\n      includeContent: false,\n      limit: 2,\n    });\n\n    // limit=2 → floor is min(2, 3) = 2, not 3.\n    expect(results).toHaveLength(2);\n    expect(results.map((r) => r.id)).toEqual([1, 2]);\n  });\n});","lineStart":1,"lineEnd":123,"totalLines":123,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/token-budget-skip-and-floor.vitest.ts","time":{"start":1781722673696,"end":1781722673707}},"id":"prt_ed6f270c7001waS6RfzPL4SNtK","sessionID":"ses_1290e89f7ffeyM2EsIheDgT9ja","messageID":"msg_ed6f2656c001F7tqFYFZkzeVc5"}}
