    39	  'console', 'Array', 'Object', 'Map', 'Set', 'JSON', 'Math', 'Date', 'Promise', 'Error',
    40	  'parseInt', 'parseFloat', 'isNaN', 'String', 'Number', 'Boolean',
    41	  // Number methods
    42	  'toFixed', 'toString', 'toPrecision', 'valueOf',
    43	  // Node fs
    44	  'readFile', 'writeFile', 'readFileSync', 'writeFileSync', 'readdir', 'readdirSync',
    45	  'existsSync', 'mkdir', 'mkdirSync', 'rm', 'rmSync', 'stat', 'statSync', 'rename', 'renameSync',
    46	  'appendFile', 'appendFileSync', 'createReadStream', 'createWriteStream',
    47	  // Node path
    48	  'join', 'resolve', 'dirname', 'basename', 'extname', 'normalize', 'relative',
    49	  // Node crypto
    50	  'createHash', 'randomBytes', 'randomUUID', 'createCipheriv', 'createDecipheriv',
    51	  // child_process
    52	  'execSync', 'spawn', 'spawnSync', 'execFile', 'execFileSync',
    53	  // test frameworks (vitest/jest/mocha matchers)
