nt\n    .toLowerCase()\n    .replace(/[^\\w\\s]/g, \" \")   // strip punctuation\n    .replace(/\\s+/g, \" \")       // collapse whitespace\n    .trim()\n    .substring(0, 200);          // cap length\n}","lineStart":1,"lineEnd":12,"totalLines":12,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/dedup.ts","time":{"start":1780929019138,"end":1780929019157}},"metadata":{"openai":{"itemId":"fc_005cd536f68b603f016a26d1faf8f48193b9f5c2ac5f24a81b"}},"id":"prt_ea7a43cfb0017nb1WTS86En1SK","sessionID":"ses_1585c7ef3ffeE8bQgxmNtEsbEj","messageID":"msg_ea7a3fe4e001smg5LNfKR1Zsmi"}}
