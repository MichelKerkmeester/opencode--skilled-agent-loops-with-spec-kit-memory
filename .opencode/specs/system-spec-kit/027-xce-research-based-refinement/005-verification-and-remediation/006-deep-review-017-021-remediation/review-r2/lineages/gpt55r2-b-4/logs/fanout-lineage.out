",\n          \"matched_phrases\": [\n            \"lineage\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-06-18T05:56:02.709Z\",\n      \"latencyMs\": 555\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781762162041,"end":1781762162836}},"metadata":{"openai":{"itemId":"fc_011f997272e37591016a33887018648191b1986f25f638f91b"}},"id":"prt_ed94cf5f5001EBjUdOUxBgzPyf","sessionID":"ses_126b3c392ffeqmVxmFv45c0QTG","messageID":"msg_ed94ce0040017N0vCNRg3G4uvz"}}
