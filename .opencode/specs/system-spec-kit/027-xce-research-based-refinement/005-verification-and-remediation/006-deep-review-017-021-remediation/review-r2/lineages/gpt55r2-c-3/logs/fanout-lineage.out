{"type":"tool_use","timestamp":1781762156500,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_bsTUQp37NQCuWSGXaeWPVdrj","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":1030,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n1030: }\n1031: \n1032: const server = createContextMcpServer();\n1033: const serverWithInstructions = server as unknown as { setInstructions?: (instructions: string) => void };\n1034: const KNOWN_TOOL_NAMES = new Set(TOOL_DEFINITIONS.map((tool) => tool.name));\n1035: \n1036: /* ───────────────────────────────────────────────────────────────\n1037:    TOOL DEFINITIONS\n1038: ──────────────────────────────────────────────────────────────── */\n1039: \n1040: function registerContextServerHandlers(targetServer: Server): void {\n1041:   targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n1042:     tools: TOOL_DEFINITIONS\n1043:   }));\n1044: \n1045: /* ───────────────────────────────────────────────────────────────\n1046:    TOOL DISPATCH\n1047: ──────────────────────────────────────────────────────────────── */\n1048: \n1049: // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1050:   targetServer.setRequestHandler(CallToolRequestSchema, async (request, _extra: unknown): Promise<any> => {\n1051:   const requestParams = request.params as { name: string; arguments?: Record<string, unknown> };\n1052:   const { name } = requestParams;\n1053:   const args: Record<string, unknown> = requestParams.arguments ?? {};\n1054:   const callId = resolveToolCallId(request as { id?: unknown });\n1055:   const sessionTrackingId = resolveSessionTrackingId(args, _extra);\n1056:   const callerContext = buildCallerContext(_extra);\n1057:   if (sessionTrackingId) lastKnownSessionId = sessionTrackingId;\n1058: \n1059:   try {\n1060:     // SEC-003: Validate input lengths before processing (CWE-400 mitigation)\n1061:     validateInputLengths(args);\n1062:     // Validate at the server boundary before metrics, session priming, and\n1063:     // auto-surface logic can observe malformed raw tool arguments.\n1064:     const validatedArgs: Record<string, unknown> = KNOWN_TOOL_NAMES.has(name)\n1065:       ? validateToolArgs(name, args) as Record<string, unknown>\n1066:       : args;\n1067: \n1068:     // Track last tool call timestamp for all tools except session_health.\n1069:     if (name !== 'session_health') {\n1070:       recordToolCall(sessionTrackingId);\n1071: \n1072:       // Record metric event for context quality tracking\n1073:       recordMetricEvent({ kind: 'tool_call', toolName: name });\n1074:     }\n1075:     // Classify specific tool calls for finer-grained metrics\n1076:     if (name === 'memory_context' && validatedArgs.mode === 'resume') {\n1077:       recordMetricEvent({ kind: 'memory_recovery' });\n1078:     }\n1079:     // Code-graph MCP metrics now originate from standalone mk-code-index\n1080:     if (typeof validatedArgs.specFolder === 'string' && validatedArgs.specFolder) {\n1081:       recordMetricEvent({ kind: 'spec_folder_change', specFolder: validatedArgs.specFolder as string });\n1082:     }\n1083: \n1084:     const memoryRuntimeRequired = MEMORY_RUNTIME_TOOL_NAMES.has(name);\n1085:     if (memoryRuntimeRequired) {\n1086:       await ensureMemoryRuntimeInitialized(`handler:${name}`);\n1087:     }\n1088: \n1089:     const dbReinitialized = memoryRuntimeRequired\n1090:       ? await checkDatabaseUpdated()\n1091:       : false;\n1092:     if (dbReinitialized) {\n1093:       await invalidateReinitializedDbCaches();\n1094:     }\n1095: \n1096:     let sessionPrimeContext: AutoSurfaceResult | null = null;\n1097:     const memoryRuntimeAvailable = memoryRuntimeRequired || isMemoryRuntimeInitialized();\n1098:     if (memoryRuntimeAvailable) {\n1099:       try {\n1100:         sessionPrimeContext = await primeSessionIfNeeded(\n1101:           name,\n1102:           validatedArgs,\n1103:           sessionTrackingId,\n1104:         );\n1105:       } catch (primeErr: unknown) {\n1106:         const msg = primeErr instanceof Error ? primeErr.message : String(primeErr);\n1107:         console.error(`[context-server] Session priming failed (non-fatal): ${msg}`);\n1108:       }\n1109:     }\n1110: \n1111:     // Auto-surface memories before dispatch (after validation)\n1112:     let autoSurfacedContext: AutoSurfaceResult | null = null;\n1113:     const isCompactionLifecycleCall =\n1114:       name === 'memory_context' && validatedArgs.mode === 'resume';\n1115: \n1116:     const autoSurfaceStart = Date.now();\n1117:     if (MEMORY_AWARE_TOOLS.has(name) && memoryRuntimeAvailable) {\n1118:       const contextHint: string | null = extractContextHint(validatedArgs);\n1119:       if (contextHint) {\n1120:         try {\n1121:           if (isCompactionLifecycleCall) {\n1122:             autoSurfacedContext = await autoSurfaceAtCompaction(contextHint);\n1123:           } else {\n1124:             autoSurfacedContext = await autoSurfaceMemories(contextHint);\n1125:           }\n1126:         } catch (surfaceErr: unknown) {\n1127:           const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n1128:           console.error(`[context-server] Auto-surface failed (non-fatal): ${msg}`);\n1129:         }\n1130:       }\n1131:     } else if (memoryRuntimeAvailable) {\n1132:       try {\n1133:         autoSurfacedContext = await autoSurfaceAtToolDispatch(name, validatedArgs);\n1134:       } catch (surfaceErr: unknown) {\n1135:         const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n1136:         console.error(`[context-server] Tool-dispatch auto-surface failed (non-fatal): ${msg}`);\n1137:       }\n1138:     }\n1139:     const autoSurfaceLatencyMs = Date.now() - autoSurfaceStart;\n1140:     if (autoSurfaceLatencyMs > 250) {\n1141:       console.warn(`[context-server] Auto-surface precheck exceeded p95 target: ${autoSurfaceLatencyMs}ms`);\n1142:     }\n1143: \n1144:     // Dispatch to tool modules\n1145:     const result = await runWithCallerContext(\n1146:       callerContext,\n1147:       async () => dispatchTool(name, validatedArgs, callerContext),\n1148:     ) as ToolCallResponse | null;\n1149:     if (!result) {\n1150:       throw new Error(`Unknown tool: ${name}`);\n1151:     }\n1152: \n1153:     let dispatchGraphContext: DispatchGraphContextMeta | null = null;\n1154:     if (!result.isError) {\n1155:       dispatchGraphContext = await resolveDispatchGraphContext(name, validatedArgs);\n1156:     }\n1157: \n1158:     runAfterToolCallbacks(name, callId, structuredClone(result));\n1159: \n1160:     // Log follow_on_tool_use when a non-search tool is called after a recent search\n1161:     // Shadow-only: no ranking side effects. Fail-safe, never throws.\n1162:     if (isMemoryRuntimeInitialized() && name !== 'memory_search' && name !== 'memory_context' && name !== 'session_health') {\n1163:       try {\n1164:         const { logFollowOnToolUse } = await import('./lib/feedback/query-flow-tracker.js');\n1165:         const { requireDb } = await import('./utils/index.js');\n1166:         const db = (() => { try { return requireDb(); } catch { return null; } })();\n1167:         const followOnSessionId = sessionTrackingId ?? lastKnownSessionId;\n1168:         if (db && followOnSessionId) {\n1169:           logFollowOnToolUse(db, followOnSessionId);\n1170:         }\n1171:       } catch { /* follow_on_tool_use logging must never break dispatch */ }\n1172:     }\n1173: \n1174:     // Code-search redirect hint for memory tools\n1175:     if ((name === 'memory_search' || name === 'memory_context') && result && !result.isError && result.content?.[0]?.text) {\n1176:       const queryStr = typeof args.query === 'string' ? args.query : typeof args.input === 'string' ? args.input : '';\n1177:       const codeSearchPattern = /\\b(find code|implementation of|function that|where is|how does .+ work|class that|method for)\\b/i;\n1178:       if (queryStr && codeSearchPattern.test(queryStr)) {\n1179:         try {\n1180:           const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n1181:           if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n1182:             const existingHints = Array.isArray(envelope.hints) ? envelope.hints as string[] : [];\n1183:             existingHints.push('Tip: For code search queries, use mcp__mk_code_index__code_graph_query for structural lookups and Grep for exact text or token searches.');\n1184:             envelope.hints = existingHints;\n1185:             result.content[0].text = JSON.stringify(envelope, null, 2);\n1186:           }\n1187:         } catch {\n1188:           // Response is not JSON envelope — skip hint injection\n1189:         }\n1190:       }\n1191: \n1192:       if (queryStr) {\n1193:         try {\n1194:           const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n1195:           if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n1196:             const meta = typeof envelope.meta === 'object' && envelope.meta !== null && !Array.isArray(envelope.meta)\n1197:               ? envelope.meta as Record<string, unknown>\n1198:               : {};\n1199:             const snapshot = getSessionSnapshot();\n1200:             const nudge = meta.structuralRoutingNudge\n1201:               ? null\n1202:               : maybeStructuralNudge(queryStr, {\n1203:                 graphReady: snapshot.graphFreshness === 'fresh',\n1204:                 activationScaffoldReady: snapshot.primed,\n1205:                 surface: 'response-hints',\n1206:               });\n1207:             if (nudge) {\n1208:               injectStructuralRoutingNudge(envelope, nudge);\n1209:               result.content[0].text = JSON.stringify(envelope, null, 2);\n1210:             }\n1211:           }\n1212:         } catch {\n1213:           // Response is not JSON envelope — skip structural nudge injection\n1214:         }\n1215:       }\n1216:     }\n1217: \n1218:     // Passive context enrichment pipeline — adds code graph symbols\n1219:     // near mentioned file paths and session continuity warnings.\n1220:     if (result && !result.isError && result.content?.[0]?.text) {\n1221:       try {\n1222:         const { runPassiveEnrichment } = await import('./lib/enrichment/passive-enrichment.js');\n1223:         const enrichment = await runPassiveEnrichment(result.content[0].text);\n1224:         if (!enrichment.skipped && enrichment.hints.length > 0) {\n1225:           try {\n1226:             const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n1227:             if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n1228:               const existingHints = Array.isArray(envelope.hints) ? envelope.hints as string[] : [];\n1229:               envelope.hints = [...existingHints, ...enrichment.hints];\n1230:               result.content[0].text = JSON.stringify(envelope, null, 2);\n1231:             }\n1232:           } catch {\n1233:             // Response is not JSON envelope — skip enrichment injection\n1234:           }\n1235:         }\n1236:       } catch (enrichErr: unknown) {\n1237:         // Passive enrichment is strictly non-fatal\n1238:         const msg = enrichErr instanceof Error ? enrichErr.message : String(enrichErr);\n1239:         console.warn(`[context-server] Passive enrichment failed (non-fatal): ${msg}`);\n1240:       }\n1241:     }\n1242: \n1243:     // Inject auto-surface hints before token-budget enforcement so\n1244:     // The final envelope metadata reflects the fully decorated response.\n1245:     if (autoSurfacedContext && result && !result.isError) {\n1246:       appendAutoSurfaceHints(result, autoSurfacedContext);\n1247:     }\n1248: \n1249:     // Token Budget Hybrid: Inject tokenBudget into response metadata\n1250:     // Enforce per-layer token budgets with actual truncation\n1251:     if (result && result.content && result.content[0]?.text) {\n1252:       try {\n1253:         const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n1254:         if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n1255:           const metaValue = envelope.meta;\n1256:           const meta = isRecord(metaValue)\n1257:             ? metaValue as Record<string, unknown>\n1258:             : {};\n1259:           const dataValue = envelope.data;\n1260:           const data = isRecord(dataValue)\n1261:             ? dataValue as Record<string, unknown>\n1262:             : null;\n1263:           envelope.meta = meta;\n1264:           if (sessionPrimeContext && !result.isError) {\n1265:             injectSessionPrimeHints(envelope, meta, sessionPrimeContext);\n1266:           }\n1267:           if (autoSurfacedContext && !result.isError) {\n1268:             meta.autoSurfacedContext = autoSurfacedContext;\n1269:           }\n1270:           if (dispatchGraphContext && !result.isError) {\n1271:             meta.graphContext = dispatchGraphContext;\n1272:           }\n1273:           const budget = getTokenBudget(name);\n1274:           meta.tokenBudget = budget;\n1275:           syncEnvelopeTokenCount(envelope);\n1276: \n1277:           if (typeof meta.tokenCount === 'number' && meta.tokenCount > budget) {\n1278:             console.error(`[token-budget] ${name} response (${meta.tokenCount} tokens) exceeds budget (${budget})`);\n1279: \n1280:             // First-call session priming rides along in meta and can dwarf a\n1281:             // small tool's own payload. Slim it BEFORE touching the tool's\n1282:             // results: the tool's answer is the caller's data, the priming\n1283:             // payload is recoverable via memory_search/memory_context.\n1284:             if (isRecord(meta.sessionPriming)) {\n1285:               const priming = meta.sessionPriming as Record<string, unknown>;\n1286:               const alreadyTrimmed = priming.trimmed === true;\n1287:               if (!alreadyTrimmed) {\n1288:                 const constitutionalCount = Array.isArray(priming.constitutional)\n1289:                   ? priming.constitutional.length\n1290:                   : 0;\n1291:                 meta.sessionPriming = {\n1292:                   trimmed: true,\n1293:                   constitutionalCount,\n1294:                   ...(isRecord(priming.primePackage) ? { primePackage: priming.primePackage } : {}),\n1295:                 };\n1296:                 syncEnvelopeTokenCount(envelope);\n1297:                 if (Array.isArray(envelope.hints)) {\n1298:                   envelope.hints.push(`Session priming trimmed to fit the ${budget} token budget; full constitutional content remains retrievable via memory_search`);\n1299:                 }\n1300:                 meta.sessionPrimingTrimmed = true;\n1301:               }\n1302:             }\n1303: \n1304:             // Attempt to truncate results array to fit within budget — only\n1305:             // when still over after the priming slim above, because the loop\n1306:             // below pops a result before it re-measures.\n1307:             const stillOverBudget = typeof meta.tokenCount === 'number' && meta.tokenCount > budget;\n1308:             const innerResults = data?.results;\n1309:             if (stillOverBudget && Array.isArray(innerResults) && innerResults.length > 1) {\n1310:               const originalCount = innerResults.length;\n1311:               // Results are typically sorted by score (highest first)\n1312:               // Remove from end (lowest-scored) until within budget\n1313:               while (innerResults.length > 1) {\n1314:                 innerResults.pop();\n1315:                 // Recalculate token count from the full envelope\n1316:                 // (not just results) so trace metadata is included in the budget.\n1317:                 syncEnvelopeTokenCount(envelope);\n1318:                 if (typeof meta.tokenCount === 'number' && meta.tokenCount <= budget) break;\n1319:               }\n1320:               if (data && data.count !== undefined) {\n1321:                 data.count = innerResults.length;\n1322:               }\n1323:               // Recompute constitutionalCount from the results that survived truncation\n1324:               // so consumers reading data.constitutionalCount or envelope.summary see\n1325:               // counts that agree with data.results.length.\n1326:               if (data) {\n1327:                 const survivingConstitutionalCount = innerResults.filter(\n1328:                   (r: unknown) => r !== null && typeof r === 'object' && (r as Record<string, unknown>).isConstitutional === true\n1329:                 ).length;\n1330:                 data.constitutionalCount = survivingConstitutionalCount;\n1331:                 if (typeof envelope.summary === 'string') {\n1332:                   envelope.summary = survivingConstitutionalCount > 0\n1333:                     ? `Found ${innerResults.length} memories (${survivingConstitutionalCount} constitutional)`\n1334:                     : `Found ${innerResults.length} memories`;\n1335:                 }\n1336:               }\n1337:               if (Array.isArray(envelope.hints)) {\n1338:                 envelope.hints.push(`Token budget enforced: truncated ${originalCount} → ${innerResults.length} results to fit ${budget} token budget`);\n1339:               }\n1340:               meta.tokenBudgetTruncated = true;\n1341:               meta.originalResultCount = originalCount;\n1342:               meta.returnedResultCount = innerResults.length;\n1343:             } else if (stillOverBudget) {\n1344:               // No truncatable results array — add warning hint only\n1345:               if (Array.isArray(envelope.hints)) {\n1346:                 envelope.hints.push(`Response exceeds token budget (${meta.tokenCount}/${budget})`);\n1347:               }\n1348:             }\n1349:           }\n1350:           result.content[0].text = serializeEnvelopeWithTokenCount(envelope);\n1351:         }\n1352:       } catch (_parseErr: unknown) {\n1353:         // Non-JSON response, skip token budget injection\n1354:       }\n1355:     }\n1356: \n1357:     return result;\n1358:   } catch (error: unknown) {\n1359:     // Include recovery hints in all error responses\n1360:     const err = error instanceof Error ? error : new Error(String(error));\n1361:     try {\n1362:       const errorResponse = buildErrorResponse(name, err, args);\n1363:       // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1364:       return wrapForMCP(errorResponse as any, true);\n1365:     } catch (wrapError: unknown) {\n1366:       const fallbackError = wrapError instanceof Error ? wrapError.message : String(wrapError);\n1367:       console.error(`[context-server] Failed to build MCP error envelope for '${name}': ${fallbackError}`);\n1368:       const fallbackCode = getDefaultErrorCodeForTool(name);\n1369:       return createMCPErrorResponse({\n1370:         tool: name,\n1371:         error: 'Request failed.',\n1372:         code: fallbackCode,\n1373:         recovery: getRecoveryHint(name, fallbackCode),\n1374:       });\n1375:     }\n1376:   }\n1377:   });\n1378: }\n1379: \n1380: registerContextServerHandlers(server);\n1381: \n1382: /* ───────────────────────────────────────────────────────────────\n1383:    6. STARTUP SCAN & PENDING FILE RECOVERY\n1384: ──────────────────────────────────────────────────────────────── */\n1385: \n1386: let startupScanInProgress = false;\n1387: // Tracked (not fire-and-forget) so fatalShutdown can await the scan to a safe stopping point before\n1388: // closeDb — a resuming scan writes through the DB and would otherwise reopen a closed connection.\n1389: let startupScanPromise: Promise<void> | null = null;\n\n(Showing lines 1030-1389 of 2341. Use offset=1390 to continue.)\n</content>","metadata":{"preview":"}\n\nconst server = createContextMcpServer();\nconst serverWithInstructions = server as unknown as { setInstructions?: (instructions: string) => void };\nconst KNOWN_TOOL_NAMES = new Set(TOOL_DEFINITIONS.map((tool) => tool.name));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nfunction registerContextServerHandlers(targetServer: Server): void {\n  targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n    tools: TOOL_DEFINITIONS\n  }));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DISPATCH\n──────────────────────────────────────────────────────────────── */\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"}\n\nconst server = createContextMcpServer();\nconst serverWithInstructions = server as unknown as { setInstructions?: (instructions: string) => void };\nconst KNOWN_TOOL_NAMES = new Set(TOOL_DEFINITIONS.map((tool) => tool.name));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nfunction registerContextServerHandlers(targetServer: Server): void {\n  targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n    tools: TOOL_DEFINITIONS\n  }));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DISPATCH\n──────────────────────────────────────────────────────────────── */\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\n  targetServer.setRequestHandler(CallToolRequestSchema, async (request, _extra: unknown): Promise<any> => {\n  const requestParams = request.params as { name: string; arguments?: Record<string, unknown> };\n  const { name } = requestParams;\n  const args: Record<string, unknown> = requestParams.arguments ?? {};\n  const callId = resolveToolCallId(request as { id?: unknown });\n  const sessionTrackingId = resolveSessionTrackingId(args, _extra);\n  const callerContext = buildCallerContext(_extra);\n  if (sessionTrackingId) lastKnownSessionId = sessionTrackingId;\n\n  try {\n    // SEC-003: Validate input lengths before processing (CWE-400 mitigation)\n    validateInputLengths(args);\n    // Validate at the server boundary before metrics, session priming, and\n    // auto-surface logic can observe malformed raw tool arguments.\n    const validatedArgs: Record<string, unknown> = KNOWN_TOOL_NAMES.has(name)\n      ? validateToolArgs(name, args) as Record<string, unknown>\n      : args;\n\n    // Track last tool call timestamp for all tools except session_health.\n    if (name !== 'session_health') {\n      recordToolCall(sessionTrackingId);\n\n      // Record metric event for context quality tracking\n      recordMetricEvent({ kind: 'tool_call', toolName: name });\n    }\n    // Classify specific tool calls for finer-grained metrics\n    if (name === 'memory_context' && validatedArgs.mode === 'resume') {\n      recordMetricEvent({ kind: 'memory_recovery' });\n    }\n    // Code-graph MCP metrics now originate from standalone mk-code-index\n    if (typeof validatedArgs.specFolder === 'string' && validatedArgs.specFolder) {\n      recordMetricEvent({ kind: 'spec_folder_change', specFolder: validatedArgs.specFolder as string });\n    }\n\n    const memoryRuntimeRequired = MEMORY_RUNTIME_TOOL_NAMES.has(name);\n    if (memoryRuntimeRequired) {\n      await ensureMemoryRuntimeInitialized(`handler:${name}`);\n    }\n\n    const dbReinitialized = memoryRuntimeRequired\n      ? await checkDatabaseUpdated()\n      : false;\n    if (dbReinitialized) {\n      await invalidateReinitializedDbCaches();\n    }\n\n    let sessionPrimeContext: AutoSurfaceResult | null = null;\n    const memoryRuntimeAvailable = memoryRuntimeRequired || isMemoryRuntimeInitialized();\n    if (memoryRuntimeAvailable) {\n      try {\n        sessionPrimeContext = await primeSessionIfNeeded(\n          name,\n          validatedArgs,\n          sessionTrackingId,\n        );\n      } catch (primeErr: unknown) {\n        const msg = primeErr instanceof Error ? primeErr.message : String(primeErr);\n        console.error(`[context-server] Session priming failed (non-fatal): ${msg}`);\n      }\n    }\n\n    // Auto-surface memories before dispatch (after validation)\n    let autoSurfacedContext: AutoSurfaceResult | null = null;\n    const isCompactionLifecycleCall =\n      name === 'memory_context' && validatedArgs.mode === 'resume';\n\n    const autoSurfaceStart = Date.now();\n    if (MEMORY_AWARE_TOOLS.has(name) && memoryRuntimeAvailable) {\n      const contextHint: string | null = extractContextHint(validatedArgs);\n      if (contextHint) {\n        try {\n          if (isCompactionLifecycleCall) {\n            autoSurfacedContext = await autoSurfaceAtCompaction(contextHint);\n          } else {\n            autoSurfacedContext = await autoSurfaceMemories(contextHint);\n          }\n        } catch (surfaceErr: unknown) {\n          const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n          console.error(`[context-server] Auto-surface failed (non-fatal): ${msg}`);\n        }\n      }\n    } else if (memoryRuntimeAvailable) {\n      try {\n        autoSurfacedContext = await autoSurfaceAtToolDispatch(name, validatedArgs);\n      } catch (surfaceErr: unknown) {\n        const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n        console.error(`[context-server] Tool-dispatch auto-surface failed (non-fatal): ${msg}`);\n      }\n    }\n    const autoSurfaceLatencyMs = Date.now() - autoSurfaceStart;\n    if (autoSurfaceLatencyMs > 250) {\n      console.warn(`[context-server] Auto-surface precheck exceeded p95 target: ${autoSurfaceLatencyMs}ms`);\n    }\n\n    // Dispatch to tool modules\n    const result = await runWithCallerContext(\n      callerContext,\n      async () => dispatchTool(name, validatedArgs, callerContext),\n    ) as ToolCallResponse | null;\n    if (!result) {\n      throw new Error(`Unknown tool: ${name}`);\n    }\n\n    let dispatchGraphContext: DispatchGraphContextMeta | null = null;\n    if (!result.isError) {\n      dispatchGraphContext = await resolveDispatchGraphContext(name, validatedArgs);\n    }\n\n    runAfterToolCallbacks(name, callId, structuredClone(result));\n\n    // Log follow_on_tool_use when a non-search tool is called after a recent search\n    // Shadow-only: no ranking side effects. Fail-safe, never throws.\n    if (isMemoryRuntimeInitialized() && name !== 'memory_search' && name !== 'memory_context' && name !== 'session_health') {\n      try {\n        const { logFollowOnToolUse } = await import('./lib/feedback/query-flow-tracker.js');\n        const { requireDb } = await import('./utils/index.js');\n        const db = (() => { try { return requireDb(); } catch { return null; } })();\n        const followOnSessionId = sessionTrackingId ?? lastKnownSessionId;\n        if (db && followOnSessionId) {\n          logFollowOnToolUse(db, followOnSessionId);\n        }\n      } catch { /* follow_on_tool_use logging must never break dispatch */ }\n    }\n\n    // Code-search redirect hint for memory tools\n    if ((name === 'memory_search' || name === 'memory_context') && result && !result.isError && result.content?.[0]?.text) {\n      const queryStr = typeof args.query === 'string' ? args.query : typeof args.input === 'string' ? args.input : '';\n      const codeSearchPattern = /\\b(find code|implementation of|function that|where is|how does .+ work|class that|method for)\\b/i;\n      if (queryStr && codeSearchPattern.test(queryStr)) {\n        try {\n          const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n          if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n            const existingHints = Array.isArray(envelope.hints) ? envelope.hints as string[] : [];\n            existingHints.push('Tip: For code search queries, use mcp__mk_code_index__code_graph_query for structural lookups and Grep for exact text or token searches.');\n            envelope.hints = existingHints;\n            result.content[0].text = JSON.stringify(envelope, null, 2);\n          }\n        } catch {\n          // Response is not JSON envelope — skip hint injection\n        }\n      }\n\n      if (queryStr) {\n        try {\n          const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n          if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n            const meta = typeof envelope.meta === 'object' && envelope.meta !== null && !Array.isArray(envelope.meta)\n              ? envelope.meta as Record<string, unknown>\n              : {};\n            const snapshot = getSessionSnapshot();\n            const nudge = meta.structuralRoutingNudge\n              ? null\n              : maybeStructuralNudge(queryStr, {\n                graphReady: snapshot.graphFreshness === 'fresh',\n                activationScaffoldReady: snapshot.primed,\n                surface: 'response-hints',\n              });\n            if (nudge) {\n              injectStructuralRoutingNudge(envelope, nudge);\n              result.content[0].text = JSON.stringify(envelope, null, 2);\n            }\n          }\n        } catch {\n          // Response is not JSON envelope — skip structural nudge injection\n        }\n      }\n    }\n\n    // Passive context enrichment pipeline — adds code graph symbols\n    // near mentioned file paths and session continuity warnings.\n    if (result && !result.isError && result.content?.[0]?.text) {\n      try {\n        const { runPassiveEnrichment } = await import('./lib/enrichment/passive-enrichment.js');\n        const enrichment = await runPassiveEnrichment(result.content[0].text);\n        if (!enrichment.skipped && enrichment.hints.length > 0) {\n          try {\n            const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n            if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n              const existingHints = Array.isArray(envelope.hints) ? envelope.hints as string[] : [];\n              envelope.hints = [...existingHints, ...enrichment.hints];\n              result.content[0].text = JSON.stringify(envelope, null, 2);\n            }\n          } catch {\n            // Response is not JSON envelope — skip enrichment injection\n          }\n        }\n      } catch (enrichErr: unknown) {\n        // Passive enrichment is strictly non-fatal\n        const msg = enrichErr instanceof Error ? enrichErr.message : String(enrichErr);\n        console.warn(`[context-server] Passive enrichment failed (non-fatal): ${msg}`);\n      }\n    }\n\n    // Inject auto-surface hints before token-budget enforcement so\n    // The final envelope metadata reflects the fully decorated response.\n    if (autoSurfacedContext && result && !result.isError) {\n      appendAutoSurfaceHints(result, autoSurfacedContext);\n    }\n\n    // Token Budget Hybrid: Inject tokenBudget into response metadata\n    // Enforce per-layer token budgets with actual truncation\n    if (result && result.content && result.content[0]?.text) {\n      try {\n        const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n        if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n          const metaValue = envelope.meta;\n          const meta = isRecord(metaValue)\n            ? metaValue as Record<string, unknown>\n            : {};\n          const dataValue = envelope.data;\n          const data = isRecord(dataValue)\n            ? dataValue as Record<string, unknown>\n            : null;\n          envelope.meta = meta;\n          if (sessionPrimeContext && !result.isError) {\n            injectSessionPrimeHints(envelope, meta, sessionPrimeContext);\n          }\n          if (autoSurfacedContext && !result.isError) {\n            meta.autoSurfacedContext = autoSurfacedContext;\n          }\n          if (dispatchGraphContext && !result.isError) {\n            meta.graphContext = dispatchGraphContext;\n          }\n          const budget = getTokenBudget(name);\n          meta.tokenBudget = budget;\n          syncEnvelopeTokenCount(envelope);\n\n          if (typeof meta.tokenCount === 'number' && meta.tokenCount > budget) {\n            console.error(`[token-budget] ${name} response (${meta.tokenCount} tokens) exceeds budget (${budget})`);\n\n            // First-call session priming rides along in meta and can dwarf a\n            // small tool's own payload. Slim it BEFORE touching the tool's\n            // results: the tool's answer is the caller's data, the priming\n            // payload is recoverable via memory_search/memory_context.\n            if (isRecord(meta.sessionPriming)) {\n              const priming = meta.sessionPriming as Record<string, unknown>;\n              const alreadyTrimmed = priming.trimmed === true;\n              if (!alreadyTrimmed) {\n                const constitutionalCount = Array.isArray(priming.constitutional)\n                  ? priming.constitutional.length\n                  : 0;\n                meta.sessionPriming = {\n                  trimmed: true,\n                  constitutionalCount,\n                  ...(isRecord(priming.primePackage) ? { primePackage: priming.primePackage } : {}),\n                };\n                syncEnvelopeTokenCount(envelope);\n                if (Array.isArray(envelope.hints)) {\n                  envelope.hints.push(`Session priming trimmed to fit the ${budget} token budget; full constitutional content remains retrievable via memory_search`);\n                }\n                meta.sessionPrimingTrimmed = true;\n              }\n            }\n\n            // Attempt to truncate results array to fit within budget — only\n            // when still over after the priming slim above, because the loop\n            // below pops a result before it re-measures.\n            const stillOverBudget = typeof meta.tokenCount === 'number' && meta.tokenCount > budget;\n            const innerResults = data?.results;\n            if (stillOverBudget && Array.isArray(innerResults) && innerResults.length > 1) {\n              const originalCount = innerResults.length;\n              // Results are typically sorted by score (highest first)\n              // Remove from end (lowest-scored) until within budget\n              while (innerResults.length > 1) {\n                innerResults.pop();\n                // Recalculate token count from the full envelope\n                // (not just results) so trace metadata is included in the budget.\n                syncEnvelopeTokenCount(envelope);\n                if (typeof meta.tokenCount === 'number' && meta.tokenCount <= budget) break;\n              }\n              if (data && data.count !== undefined) {\n                data.count = innerResults.length;\n              }\n              // Recompute constitutionalCount from the results that survived truncation\n              // so consumers reading data.constitutionalCount or envelope.summary see\n              // counts that agree with data.results.length.\n              if (data) {\n                const survivingConstitutionalCount = innerResults.filter(\n                  (r: unknown) => r !== null && typeof r === 'object' && (r as Record<string, unknown>).isConstitutional === true\n                ).length;\n                data.constitutionalCount = survivingConstitutionalCount;\n                if (typeof envelope.summary === 'string') {\n                  envelope.summary = survivingConstitutionalCount > 0\n                    ? `Found ${innerResults.length} memories (${survivingConstitutionalCount} constitutional)`\n                    : `Found ${innerResults.length} memories`;\n                }\n              }\n              if (Array.isArray(envelope.hints)) {\n                envelope.hints.push(`Token budget enforced: truncated ${originalCount} → ${innerResults.length} results to fit ${budget} token budget`);\n              }\n              meta.tokenBudgetTruncated = true;\n              meta.originalResultCount = originalCount;\n              meta.returnedResultCount = innerResults.length;\n            } else if (stillOverBudget) {\n              // No truncatable results array — add warning hint only\n              if (Array.isArray(envelope.hints)) {\n                envelope.hints.push(`Response exceeds token budget (${meta.tokenCount}/${budget})`);\n              }\n            }\n          }\n          result.content[0].text = serializeEnvelopeWithTokenCount(envelope);\n        }\n      } catch (_parseErr: unknown) {\n        // Non-JSON response, skip token budget injection\n      }\n    }\n\n    return result;\n  } catch (error: unknown) {\n    // Include recovery hints in all error responses\n    const err = error instanceof Error ? error : new Error(String(error));\n    try {\n      const errorResponse = buildErrorResponse(name, err, args);\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return wrapForMCP(errorResponse as any, true);\n    } catch (wrapError: unknown) {\n      const fallbackError = wrapError instanceof Error ? wrapError.message : String(wrapError);\n      console.error(`[context-server] Failed to build MCP error envelope for '${name}': ${fallbackError}`);\n      const fallbackCode = getDefaultErrorCodeForTool(name);\n      return createMCPErrorResponse({\n        tool: name,\n        error: 'Request failed.',\n        code: fallbackCode,\n        recovery: getRecoveryHint(name, fallbackCode),\n      });\n    }\n  }\n  });\n}\n\nregisterContextServerHandlers(server);\n\n/* ───────────────────────────────────────────────────────────────\n   6. STARTUP SCAN & PENDING FILE RECOVERY\n──────────────────────────────────────────────────────────────── */\n\nlet startupScanInProgress = false;\n// Tracked (not fire-and-forget) so fatalShutdown can await the scan to a safe stopping point before\n// closeDb — a resuming scan writes through the DB and would otherwise reopen a closed connection.\nlet startupScanPromise: Promise<void> | null = null;","lineStart":1030,"lineEnd":1389,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781762156494,"end":1781762156499}},"metadata":{"openai":{"itemId":"fc_053b828d4b1aaf69016a33886b57fc8191bb0cb477cd782ac5"}},"id":"prt_ed94ce363001dla2DGN1ac0tn1","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94cd7fe001t39g8VIuc0knOf"}}
