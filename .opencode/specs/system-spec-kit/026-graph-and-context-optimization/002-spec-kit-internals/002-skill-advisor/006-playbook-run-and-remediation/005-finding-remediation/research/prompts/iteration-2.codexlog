   272	
   273	def _file_url(path: str) -> str:
   274	    """Return a minimal file URL for Node ESM dynamic imports."""
   275	    return Path(path).resolve().as_uri()
   276	
   277	
   278	def _native_bridge_source() -> str:
   279	    """Render the inline Node bridge with absolute module URLs."""
   280	    return (
   281	        NATIVE_ADVISOR_BRIDGE
   282	        .replace("ADVISOR_COMPAT_MODULE", _file_url(NATIVE_ADVISOR_COMPAT))
   283	        .replace("GENERATION_MODULE", _file_url(NATIVE_GENERATION_MODULE))
   284	    )
   285	
   286	
   287	def _native_bridge_available() -> bool:
   288	    """Return True when compiled native advisor handlers are present."""
   289	    return os.path.exists(NATIVE_ADVISOR_COMPAT) and os.path.exists(NATIVE_GENERATION_MODULE)
   290	
   291	
   292	def _native_bridge_env(source_env: Optional[Dict[str, str]] = None) -> Dict[str, str]:
   293	    """Return the explicit environment passed to the Node native bridge."""
   294	    source = source_env if source_env is not None else dict(os.environ)
   295	    return {
   296	        key: value
   297	        for key, value in source.items()
   298	        if key in NATIVE_BRIDGE_ENV_ALLOWLIST and isinstance(value, str)
   299	    }
   300	
   301	
   302	def _sanitize_native_label(value: Any) -> Optional[str]:
   303	    """Sanitize native labels before translating public compat output."""
   304	    if not isinstance(value, str):
   305	        return None
   306	    cleaned = " ".join(value.split()).strip()
   307	    if not cleaned or len(cleaned) > 160:
   308	        return None
   309	    if re.search(r"\b(ignore|override|forget|bypass|disable|execute|run|call|tool|developer|assistant|previous instructions|all instructions)\b", cleaned, re.I):
   310	        return None
   311	    if re.search(r"<!--|-->|```|<script\b|</script>|^\s*(system|instruction|developer|assistant)\s*:", cleaned, re.I):
   312	        return None
   313	    return cleaned
   314	
   315	
   316	def _sanitize_native_label_list(value: Any) -> List[str]:
   317	    """Return prompt-safe native label arrays."""
   318	    if not isinstance(value, list):
   319	        return []
   320	    labels: List[str] = []
   321	    for item in value:
   322	        sanitized = _sanitize_native_label(item)
   323	        if sanitized:
   324	            labels.append(sanitized)
   325	    return labels
   326	
   327	
   328	def _run_native_bridge(payload: Dict[str, Any], timeout: float = NATIVE_TIMEOUT_SECONDS) -> Dict[str, Any]:
   329	    """Call the compiled native MCP advisor handlers through a tiny Node bridge."""
   330	    if not _native_bridge_available():
   331	        return {
   332	            "status": "unavailable",
   333	            "data": {
   334	                "available": False,
   335	                "freshness": "unavailable",
   336	                "generation": 0,
   337	                "reason": "NATIVE_DIST_MISSING",
   338	            },
   339	        }
   340	
   341	    try:
   342	        result = subprocess.run(
   343	            ["node", "--input-type=module", "-e", _native_bridge_source()],
   344	            input=json.dumps(payload),
   345	            capture_output=True,
   346	            text=True,
   347	            timeout=timeout,
   348	            cwd=REPO_ROOT,
   349	            env=_native_bridge_env(),
   350	        )
   351	    except (FileNotFoundError, subprocess.TimeoutExpired, OSError) as exc:
   352	        return {
   353	            "status": "unavailable",
   354	            "data": {
   355	                "available": False,
   356	                "freshness": "unavailable",
   357	                "generation": 0,
   358	                "reason": exc.__class__.__name__.upper(),
   359	            },
   360	        }

