{"type":"tool_use","timestamp":1782925288057,"sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","part":{"type":"tool","tool":"read","callID":"call_RfTYUMveSSjf9w4DYwNtnVJF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/node_modules/@opencode-ai/plugin/dist/index.d.ts","offset":180,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/node_modules/@opencode-ai/plugin/dist/index.d.ts</path>\n<type>file</type>\n<content>\n180:         [key: string]: ToolDefinition;\n181:     };\n182:     auth?: AuthHook;\n183:     provider?: ProviderHook;\n184:     /**\n185:      * Called when a new message is received\n186:      */\n187:     \"chat.message\"?: (input: {\n188:         sessionID: string;\n189:         agent?: string;\n190:         model?: {\n191:             providerID: string;\n192:             modelID: string;\n193:         };\n194:         messageID?: string;\n195:         variant?: string;\n196:     }, output: {\n197:         message: UserMessage;\n198:         parts: Part[];\n199:     }) => Promise<void>;\n200:     /**\n201:      * Modify parameters sent to LLM\n202:      */\n203:     \"chat.params\"?: (input: {\n204:         sessionID: string;\n205:         agent: string;\n206:         model: Model;\n207:         provider: ProviderContext;\n208:         message: UserMessage;\n209:     }, output: {\n210:         temperature: number;\n211:         topP: number;\n212:         topK: number;\n213:         maxOutputTokens: number | undefined;\n214:         options: Record<string, any>;\n215:     }) => Promise<void>;\n216:     \"chat.headers\"?: (input: {\n217:         sessionID: string;\n218:         agent: string;\n219:         model: Model;\n220:         provider: ProviderContext;\n221:         message: UserMessage;\n222:     }, output: {\n223:         headers: Record<string, string>;\n224:     }) => Promise<void>;\n225:     \"permission.ask\"?: (input: Permission, output: {\n226:         status: \"ask\" | \"deny\" | \"allow\";\n227:     }) => Promise<void>;\n228:     \"command.execute.before\"?: (input: {\n229:         command: string;\n230:         sessionID: string;\n231:         arguments: string;\n232:     }, output: {\n233:         parts: Part[];\n234:     }) => Promise<void>;\n235:     \"tool.execute.before\"?: (input: {\n236:         tool: string;\n237:         sessionID: string;\n238:         callID: string;\n239:     }, output: {\n240:         args: any;\n241:     }) => Promise<void>;\n242:     \"shell.env\"?: (input: {\n243:         cwd: string;\n244:         sessionID?: string;\n245:         callID?: string;\n246:     }, output: {\n247:         env: Record<string, string>;\n248:     }) => Promise<void>;\n249:     \"tool.execute.after\"?: (input: {\n250:         tool: string;\n251:         sessionID: string;\n252:         callID: string;\n253:         args: any;\n254:     }, output: {\n255:         title: string;\n256:         output: string;\n257:         metadata: any;\n258:     }) => Promise<void>;\n259:     \"experimental.chat.messages.transform\"?: (input: {}, output: {\n260:         messages: {\n261:             info: Message;\n262:             parts: Part[];\n263:         }[];\n264:     }) => Promise<void>;\n265:     \"experimental.chat.system.transform\"?: (input: {\n266:         sessionID?: string;\n267:         model: Model;\n268:     }, output: {\n269:         system: string[];\n270:     }) => Promise<void>;\n271:     /**\n272:      * Called before session compaction starts. Allows plugins to customize\n273:      * the compaction prompt.\n274:      *\n275:      * - `context`: Additional context strings appended to the default prompt\n276:      * - `prompt`: If set, replaces the default compaction prompt entirely\n277:      */\n278:     \"experimental.session.compacting\"?: (input: {\n279:         sessionID: string;\n280:     }, output: {\n281:         context: string[];\n282:         prompt?: string;\n283:     }) => Promise<void>;\n284:     /**\n285:      * Called after compaction succeeds and before a synthetic user\n286:      * auto-continue message is added.\n287:      *\n288:      * - `enabled`: Defaults to `true`. Set to `false` to skip the synthetic\n289:      *   user \"continue\" turn.\n290:      */\n291:     \"experimental.compaction.autocontinue\"?: (input: {\n292:         sessionID: string;\n293:         agent: string;\n294:         model: Model;\n295:         provider: ProviderContext;\n296:         message: UserMessage;\n297:         overflow: boolean;\n298:     }, output: {\n299:         enabled: boolean;\n300:     }) => Promise<void>;\n301:     \"experimental.text.complete\"?: (input: {\n302:         sessionID: string;\n303:         messageID: string;\n304:         partID: string;\n305:     }, output: {\n306:         text: string;\n307:     }) => Promise<void>;\n308:     /**\n309:      * Modify tool definitions (description and parameters) sent to LLM\n310:      */\n311:     \"tool.definition\"?: (input: {\n312:         toolID: string;\n313:     }, output: {\n314:         description: string;\n315:         parameters: any;\n316:     }) => Promise<void>;\n317: }\n\n(End of file - total 317 lines)\n</content>","metadata":{"preview":"        [key: string]: ToolDefinition;\n    };\n    auth?: AuthHook;\n    provider?: ProviderHook;\n    /**\n     * Called when a new message is received\n     */\n    \"chat.message\"?: (input: {\n        sessionID: string;\n        agent?: string;\n        model?: {\n            providerID: string;\n            modelID: string;\n        };\n        messageID?: string;\n        variant?: string;\n    }, output: {\n        message: UserMessage;\n        parts: Part[];\n    }) => Promise<void>;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/node_modules/@opencode-ai/plugin/dist/index.d.ts","text":"        [key: string]: ToolDefinition;\n    };\n    auth?: AuthHook;\n    provider?: ProviderHook;\n    /**\n     * Called when a new message is received\n     */\n    \"chat.message\"?: (input: {\n        sessionID: string;\n        agent?: string;\n        model?: {\n            providerID: string;\n            modelID: string;\n        };\n        messageID?: string;\n        variant?: string;\n    }, output: {\n        message: UserMessage;\n        parts: Part[];\n    }) => Promise<void>;\n    /**\n     * Modify parameters sent to LLM\n     */\n    \"chat.params\"?: (input: {\n        sessionID: string;\n        agent: string;\n        model: Model;\n        provider: ProviderContext;\n        message: UserMessage;\n    }, output: {\n        temperature: number;\n        topP: number;\n        topK: number;\n        maxOutputTokens: number | undefined;\n        options: Record<string, any>;\n    }) => Promise<void>;\n    \"chat.headers\"?: (input: {\n        sessionID: string;\n        agent: string;\n        model: Model;\n        provider: ProviderContext;\n        message: UserMessage;\n    }, output: {\n        headers: Record<string, string>;\n    }) => Promise<void>;\n    \"permission.ask\"?: (input: Permission, output: {\n        status: \"ask\" | \"deny\" | \"allow\";\n    }) => Promise<void>;\n    \"command.execute.before\"?: (input: {\n        command: string;\n        sessionID: string;\n        arguments: string;\n    }, output: {\n        parts: Part[];\n    }) => Promise<void>;\n    \"tool.execute.before\"?: (input: {\n        tool: string;\n        sessionID: string;\n        callID: string;\n    }, output: {\n        args: any;\n    }) => Promise<void>;\n    \"shell.env\"?: (input: {\n        cwd: string;\n        sessionID?: string;\n        callID?: string;\n    }, output: {\n        env: Record<string, string>;\n    }) => Promise<void>;\n    \"tool.execute.after\"?: (input: {\n        tool: string;\n        sessionID: string;\n        callID: string;\n        args: any;\n    }, output: {\n        title: string;\n        output: string;\n        metadata: any;\n    }) => Promise<void>;\n    \"experimental.chat.messages.transform\"?: (input: {}, output: {\n        messages: {\n            info: Message;\n            parts: Part[];\n        }[];\n    }) => Promise<void>;\n    \"experimental.chat.system.transform\"?: (input: {\n        sessionID?: string;\n        model: Model;\n    }, output: {\n        system: string[];\n    }) => Promise<void>;\n    /**\n     * Called before session compaction starts. Allows plugins to customize\n     * the compaction prompt.\n     *\n     * - `context`: Additional context strings appended to the default prompt\n     * - `prompt`: If set, replaces the default compaction prompt entirely\n     */\n    \"experimental.session.compacting\"?: (input: {\n        sessionID: string;\n    }, output: {\n        context: string[];\n        prompt?: string;\n    }) => Promise<void>;\n    /**\n     * Called after compaction succeeds and before a synthetic user\n     * auto-continue message is added.\n     *\n     * - `enabled`: Defaults to `true`. Set to `false` to skip the synthetic\n     *   user \"continue\" turn.\n     */\n    \"experimental.compaction.autocontinue\"?: (input: {\n        sessionID: string;\n        agent: string;\n        model: Model;\n        provider: ProviderContext;\n        message: UserMessage;\n        overflow: boolean;\n    }, output: {\n        enabled: boolean;\n    }) => Promise<void>;\n    \"experimental.text.complete\"?: (input: {\n        sessionID: string;\n        messageID: string;\n        partID: string;\n    }, output: {\n        text: string;\n    }) => Promise<void>;\n    /**\n     * Modify tool definitions (description and parameters) sent to LLM\n     */\n    \"tool.definition\"?: (input: {\n        toolID: string;\n    }, output: {\n        description: string;\n        parameters: any;\n    }) => Promise<void>;\n}","lineStart":180,"lineEnd":317,"totalLines":317,"truncated":false}},"title":".opencode/node_modules/@opencode-ai/plugin/dist/index.d.ts","time":{"start":1782925288048,"end":1782925288055}},"metadata":{"openai":{"itemId":"fc_0d42db50e07cd532016a4547e7e724819193c9d5a8a2020d24"}},"id":"prt_f1ea0e23a001h8yuTWJKxwSGlp","sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","messageID":"msg_f1ea08aa3001vwnjDmi0SD59yF"}}
{"type":"tool_use","timestamp":1782925288198,"sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","part":{"type":"tool","tool":"read","callID":"call_z7o3Qh1BISqOB5Q09GGRtqWd","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/README.md","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/README.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"OpenCode Plugin Entrypoints\"\n3: description: \"Six plugin entrypoint files OpenCode auto-loads at startup. Helper bridge modules live with their owning skills, not in this folder.\"\n4: ---\n5: \n6: # OpenCode Plugin Entrypoints\n7: \n8: OpenCode 1.3.17+ auto-loads JavaScript files in `.opencode/plugins/` at session start. This folder is intentionally limited to those entrypoint files so helper modules cannot be mistaken for plugins. Helpers and bridges live alongside their owning skills under `.opencode/skills/.../mcp_server/`.\n9: \n10: ---\n11: \n12: ## TABLE OF CONTENTS\n13: \n14: - [1. OVERVIEW](#1--overview)\n15: - [2. QUICK START](#2--quick-start)\n16: - [3. CURRENT ENTRYPOINTS](#3--current-entrypoints)\n17: - [4. BRIDGE MODULES](#4--bridge-modules)\n18: - [5. CONFIGURATION](#5--configuration)\n19: - [6. UPGRADE NOTES](#6--upgrade-notes)\n20: - [7. RELATED](#7--related)\n21: \n22: ---\n23: \n24: ## 1. OVERVIEW\n25: \n26: This folder is OpenCode's local-plugin mounting point. Every `.js` file here is auto-loaded once per session and must export a default plugin factory **and nothing else**.\n27: \n28: > **Default-export only — load-bearing.** OpenCode treats *every* export of a plugin module as its own plugin and invokes each one. A stray named export (a helper function, a constant, even a test surface) is loaded as a plugin, throws when invoked, and silently drops the **entire file** — including its real default plugin, which then never registers its tools or hooks. Keep the only `export` the `default`; hang any test surface off the default function as a property (e.g. `MyPlugin.__test = {...}`). Helper code, transports, schemas, and bridges live elsewhere so the auto-loader cannot pick up non-plugin modules.\n29: \n30: ---\n31: \n32: ## 2. QUICK START\n33: \n34: When OpenCode boots, every `.js` file in this folder is invoked once. To add a new plugin:\n35: \n36: 1. Create the entrypoint here (`my-plugin.js`) with a **default export only** — no named exports (every named export is loaded as its own plugin; see Overview). Attach any test surface as a property on the default function.\n37: 2. Co-locate any bridge / transport / schema modules under the owning skill, not here.\n38: 3. Smoke-test from both the project root and any symlinked workspace before shipping.\n39: \n40: ---\n41: \n42: ## 3. CURRENT ENTRYPOINTS\n43: \n44: | File | Role |\n45: |---|---|\n46: | `mk-skill-advisor.js` | Prompt-time Skill Advisor plugin. Surfaces a compact skill recommendation when a user prompt arrives. Routes via `mk-skill-advisor-bridge.mjs`. |\n47: | `mk-code-graph.js` | Transport-backed code-graph context plugin (OpenCode session integration). Routes context requests via `mk-code-graph-bridge.mjs`. The underlying MCP server name stays `mk-code-index` for stable tool-prefix `mcp__mk_code_index__*`. |\n48: | `mk-spec-memory.js` | Prompt-time Spec Kit Memory continuity plugin. Injects a continuity brief via `experimental.chat.system.transform` and exposes `mk_spec_memory_status`. Routes via the spec-kit warm CLI bridge. |\n49: | `mk-goal.js` | The `/goal` plugin. Owns per-session goal state (atomic, hex(sessionID)-keyed, fail-closed), injects the active goal each turn via `experimental.chat.system.transform`, exposes `mk_goal`/`mk_goal_status` tools, accounts usage over the `event()` lifecycle, and (default-off) can drive guarded autonomous continuation. Default-export only; test surface on `MkGoalPlugin.__test`. |\n50: | `mk-deep-loop-guard.js` | Detection-layer `tool.execute.before` plugin for Task-tool dispatches targeting deep-loop sub-agents. Flags (default) or blocks (`MK_DEEP_LOOP_GUARD_REJECT=1`) a Deep Route header whose declared `mode` disagrees with `mode-registry.json`'s entry for the actual `subagent_type` being dispatched. Fails open on registry read errors. |\n51: | `session-cleanup.js` | Session-end MCP cleanup plugin. OpenCode has no JSON SessionEnd hook, so this listens for the `server.instance.disposed` / `global.disposed` dispose lifecycle events and runs `.opencode/scripts/session-cleanup.sh` to reclaim the session's MCP helper descendants. Best-effort and bounded; never blocks teardown. |\n52: \n53: ---\n54: \n55: ## 4. BRIDGE MODULES\n56: \n57: Helper bridge modules are co-located with their owning skill, not in this folder:\n58: \n59: - **mk-skill-advisor** bridge: `.opencode/skills/system-skill-advisor/mcp_server/plugin_bridges/mk-skill-advisor-bridge.mjs`\n60: - **mk-code-graph** bridge: `.opencode/skills/system-code-graph/mcp_server/plugin_bridges/mk-code-graph-bridge.mjs`\n61: - **opencode message schema**: `.opencode/skills/system-spec-kit/mcp_server/plugin_bridges/spec-kit-opencode-message-schema.mjs`\n62: \n63: This keeps plugin entrypoints minimal and lets owning skills own their bridge contracts.\n64: \n65: **Naming asymmetry note:** The plugin and bridge are named `mk-code-graph` (matching the `system-code-graph` skill folder). The underlying MCP server name remains `mk-code-index` (tool prefix `mcp__mk_code_index__*`), kept stable to avoid breaking tool consumers.\n66: \n67: ---\n68: \n69: ## 5. CONFIGURATION\n70: \n71: Both plugins support a **4-tier configuration precedence** (highest to lowest):\n72: \n73: 1. **Raw plugin options** (passed programmatically at plugin registration)\n74: 2. **Config file** (`~/.config/opencode/plugin/<plugin-name>.json`)\n75: 3. **Environment variables** (plugin-specific prefix, see tables below)\n76: 4. **Defaults** (hardcoded in each plugin)\n77: \n78: ### 5.1 mk-skill-advisor config\n79: \n80: | Config File Path | `~/.config/opencode/plugin/mk-skill-advisor.json` |\n81: |---|---|\n82: \n83: | Field | Env Var | Default | Description |\n84: |---|---|---|---|\n85: | `cacheTTLMs` | `MK_SKILL_ADVISOR_CACHE_TTL_MS` | `300000` (5 min) | Advisor cache TTL in ms |\n86: | `thresholdConfidence` | `MK_SKILL_ADVISOR_THRESHOLD_CONFIDENCE` | `0.8` | Minimum advisor confidence |\n87: | `maxTokens` | `MK_SKILL_ADVISOR_MAX_TOKENS` | `80` | Maximum brief tokens |\n88: | `nodeBinaryOverride` | `MK_SKILL_ADVISOR_NODE_BINARY` | `node` (falls back to `SPEC_KIT_PLUGIN_NODE_BINARY`) | Node binary for bridge subprocess |\n89: | `bridgeTimeoutMs` | `MK_SKILL_ADVISOR_BRIDGE_TIMEOUT_MS` | `10000` | Bridge subprocess timeout in ms |\n90: | `maxPromptBytes` | `MK_SKILL_ADVISOR_MAX_PROMPT_BYTES` | `65536` (64 KiB) | Maximum bridge prompt payload bytes |\n91: | `maxBriefChars` | `MK_SKILL_ADVISOR_MAX_BRIEF_CHARS` | `2048` (2 KiB) | Maximum injected brief character count |\n92: | `maxCacheEntries` | `MK_SKILL_ADVISOR_MAX_CACHE_ENTRIES` | `1000` | Maximum advisor cache entries |\n93: | `enabled` | — (use `MK_SKILL_ADVISOR_HOOK_DISABLED=1` / `MK_SKILL_ADVISOR_PLUGIN_DISABLED=1`) | `true` | Plugin enabled state |\n94: \n95: Config file fields use the **camelCase** option names shown above. Example:\n96: \n97: ```json\n98: {\n99:   \"cacheTTLMs\": 600000,\n100:   \"thresholdConfidence\": 0.7,\n101:   \"maxTokens\": 120\n102: }\n103: ```\n104: \n105: ### 5.2 mk-code-graph config\n106: \n107: | Config File Path | `~/.config/opencode/plugin/mk-code-graph.json` |\n108: |---|---|\n109: \n110: | Field | Env Var | Default | Description |\n111: |---|---|---|---|\n112: | `cacheTtlMs` | `MK_CODE_GRAPH_CACHE_TTL_MS` | `5000` | Transport cache TTL in ms |\n113: | `specFolder` | `MK_CODE_GRAPH_SPEC_FOLDER` | _(auto-detect)_ | Override spec folder |\n114: | `nodeBinary` | `MK_CODE_GRAPH_NODE_BINARY` | `node` (falls back to `SPEC_KIT_PLUGIN_NODE_BINARY`) | Node binary for bridge subprocess |\n115: | `bridgeTimeoutMs` | `MK_CODE_GRAPH_BRIDGE_TIMEOUT_MS` | `15000` | Bridge subprocess timeout in ms |\n116: \n117: Example config file:\n118: \n119: ```json\n120: {\n\n(Showing lines 1-120 of 150. Use offset=121 to continue.)\n</content>","metadata":{"preview":"---\ntitle: \"OpenCode Plugin Entrypoints\"\ndescription: \"Six plugin entrypoint files OpenCode auto-loads at startup. Helper bridge modules live with their owning skills, not in this folder.\"\n---\n\n# OpenCode Plugin Entrypoints\n\nOpenCode 1.3.17+ auto-loads JavaScript files in `.opencode/plugins/` at session start. This folder is intentionally limited to those entrypoint files so helper modules cannot be mistaken for plugins. Helpers and bridges live alongside their owning skills under `.opencode/skills/.../mcp_server/`.\n\n---\n\n## TABLE OF CONTENTS\n\n- [1. OVERVIEW](#1--overview)\n- [2. QUICK START](#2--quick-start)\n- [3. CURRENT ENTRYPOINTS](#3--current-entrypoints)\n- [4. BRIDGE MODULES](#4--bridge-modules)\n- [5. CONFIGURATION](#5--configuration)\n- [6. UPGRADE NOTES](#6--upgrade-notes)\n- [7. RELATED](#7--related)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/README.md","text":"---\ntitle: \"OpenCode Plugin Entrypoints\"\ndescription: \"Six plugin entrypoint files OpenCode auto-loads at startup. Helper bridge modules live with their owning skills, not in this folder.\"\n---\n\n# OpenCode Plugin Entrypoints\n\nOpenCode 1.3.17+ auto-loads JavaScript files in `.opencode/plugins/` at session start. This folder is intentionally limited to those entrypoint files so helper modules cannot be mistaken for plugins. Helpers and bridges live alongside their owning skills under `.opencode/skills/.../mcp_server/`.\n\n---\n\n## TABLE OF CONTENTS\n\n- [1. OVERVIEW](#1--overview)\n- [2. QUICK START](#2--quick-start)\n- [3. CURRENT ENTRYPOINTS](#3--current-entrypoints)\n- [4. BRIDGE MODULES](#4--bridge-modules)\n- [5. CONFIGURATION](#5--configuration)\n- [6. UPGRADE NOTES](#6--upgrade-notes)\n- [7. RELATED](#7--related)\n\n---\n\n## 1. OVERVIEW\n\nThis folder is OpenCode's local-plugin mounting point. Every `.js` file here is auto-loaded once per session and must export a default plugin factory **and nothing else**.\n\n> **Default-export only — load-bearing.** OpenCode treats *every* export of a plugin module as its own plugin and invokes each one. A stray named export (a helper function, a constant, even a test surface) is loaded as a plugin, throws when invoked, and silently drops the **entire file** — including its real default plugin, which then never registers its tools or hooks. Keep the only `export` the `default`; hang any test surface off the default function as a property (e.g. `MyPlugin.__test = {...}`). Helper code, transports, schemas, and bridges live elsewhere so the auto-loader cannot pick up non-plugin modules.\n\n---\n\n## 2. QUICK START\n\nWhen OpenCode boots, every `.js` file in this folder is invoked once. To add a new plugin:\n\n1. Create the entrypoint here (`my-plugin.js`) with a **default export only** — no named exports (every named export is loaded as its own plugin; see Overview). Attach any test surface as a property on the default function.\n2. Co-locate any bridge / transport / schema modules under the owning skill, not here.\n3. Smoke-test from both the project root and any symlinked workspace before shipping.\n\n---\n\n## 3. CURRENT ENTRYPOINTS\n\n| File | Role |\n|---|---|\n| `mk-skill-advisor.js` | Prompt-time Skill Advisor plugin. Surfaces a compact skill recommendation when a user prompt arrives. Routes via `mk-skill-advisor-bridge.mjs`. |\n| `mk-code-graph.js` | Transport-backed code-graph context plugin (OpenCode session integration). Routes context requests via `mk-code-graph-bridge.mjs`. The underlying MCP server name stays `mk-code-index` for stable tool-prefix `mcp__mk_code_index__*`. |\n| `mk-spec-memory.js` | Prompt-time Spec Kit Memory continuity plugin. Injects a continuity brief via `experimental.chat.system.transform` and exposes `mk_spec_memory_status`. Routes via the spec-kit warm CLI bridge. |\n| `mk-goal.js` | The `/goal` plugin. Owns per-session goal state (atomic, hex(sessionID)-keyed, fail-closed), injects the active goal each turn via `experimental.chat.system.transform`, exposes `mk_goal`/`mk_goal_status` tools, accounts usage over the `event()` lifecycle, and (default-off) can drive guarded autonomous continuation. Default-export only; test surface on `MkGoalPlugin.__test`. |\n| `mk-deep-loop-guard.js` | Detection-layer `tool.execute.before` plugin for Task-tool dispatches targeting deep-loop sub-agents. Flags (default) or blocks (`MK_DEEP_LOOP_GUARD_REJECT=1`) a Deep Route header whose declared `mode` disagrees with `mode-registry.json`'s entry for the actual `subagent_type` being dispatched. Fails open on registry read errors. |\n| `session-cleanup.js` | Session-end MCP cleanup plugin. OpenCode has no JSON SessionEnd hook, so this listens for the `server.instance.disposed` / `global.disposed` dispose lifecycle events and runs `.opencode/scripts/session-cleanup.sh` to reclaim the session's MCP helper descendants. Best-effort and bounded; never blocks teardown. |\n\n---\n\n## 4. BRIDGE MODULES\n\nHelper bridge modules are co-located with their owning skill, not in this folder:\n\n- **mk-skill-advisor** bridge: `.opencode/skills/system-skill-advisor/mcp_server/plugin_bridges/mk-skill-advisor-bridge.mjs`\n- **mk-code-graph** bridge: `.opencode/skills/system-code-graph/mcp_server/plugin_bridges/mk-code-graph-bridge.mjs`\n- **opencode message schema**: `.opencode/skills/system-spec-kit/mcp_server/plugin_bridges/spec-kit-opencode-message-schema.mjs`\n\nThis keeps plugin entrypoints minimal and lets owning skills own their bridge contracts.\n\n**Naming asymmetry note:** The plugin and bridge are named `mk-code-graph` (matching the `system-code-graph` skill folder). The underlying MCP server name remains `mk-code-index` (tool prefix `mcp__mk_code_index__*`), kept stable to avoid breaking tool consumers.\n\n---\n\n## 5. CONFIGURATION\n\nBoth plugins support a **4-tier configuration precedence** (highest to lowest):\n\n1. **Raw plugin options** (passed programmatically at plugin registration)\n2. **Config file** (`~/.config/opencode/plugin/<plugin-name>.json`)\n3. **Environment variables** (plugin-specific prefix, see tables below)\n4. **Defaults** (hardcoded in each plugin)\n\n### 5.1 mk-skill-advisor config\n\n| Config File Path | `~/.config/opencode/plugin/mk-skill-advisor.json` |\n|---|---|\n\n| Field | Env Var | Default | Description |\n|---|---|---|---|\n| `cacheTTLMs` | `MK_SKILL_ADVISOR_CACHE_TTL_MS` | `300000` (5 min) | Advisor cache TTL in ms |\n| `thresholdConfidence` | `MK_SKILL_ADVISOR_THRESHOLD_CONFIDENCE` | `0.8` | Minimum advisor confidence |\n| `maxTokens` | `MK_SKILL_ADVISOR_MAX_TOKENS` | `80` | Maximum brief tokens |\n| `nodeBinaryOverride` | `MK_SKILL_ADVISOR_NODE_BINARY` | `node` (falls back to `SPEC_KIT_PLUGIN_NODE_BINARY`) | Node binary for bridge subprocess |\n| `bridgeTimeoutMs` | `MK_SKILL_ADVISOR_BRIDGE_TIMEOUT_MS` | `10000` | Bridge subprocess timeout in ms |\n| `maxPromptBytes` | `MK_SKILL_ADVISOR_MAX_PROMPT_BYTES` | `65536` (64 KiB) | Maximum bridge prompt payload bytes |\n| `maxBriefChars` | `MK_SKILL_ADVISOR_MAX_BRIEF_CHARS` | `2048` (2 KiB) | Maximum injected brief character count |\n| `maxCacheEntries` | `MK_SKILL_ADVISOR_MAX_CACHE_ENTRIES` | `1000` | Maximum advisor cache entries |\n| `enabled` | — (use `MK_SKILL_ADVISOR_HOOK_DISABLED=1` / `MK_SKILL_ADVISOR_PLUGIN_DISABLED=1`) | `true` | Plugin enabled state |\n\nConfig file fields use the **camelCase** option names shown above. Example:\n\n```json\n{\n  \"cacheTTLMs\": 600000,\n  \"thresholdConfidence\": 0.7,\n  \"maxTokens\": 120\n}\n```\n\n### 5.2 mk-code-graph config\n\n| Config File Path | `~/.config/opencode/plugin/mk-code-graph.json` |\n|---|---|\n\n| Field | Env Var | Default | Description |\n|---|---|---|---|\n| `cacheTtlMs` | `MK_CODE_GRAPH_CACHE_TTL_MS` | `5000` | Transport cache TTL in ms |\n| `specFolder` | `MK_CODE_GRAPH_SPEC_FOLDER` | _(auto-detect)_ | Override spec folder |\n| `nodeBinary` | `MK_CODE_GRAPH_NODE_BINARY` | `node` (falls back to `SPEC_KIT_PLUGIN_NODE_BINARY`) | Node binary for bridge subprocess |\n| `bridgeTimeoutMs` | `MK_CODE_GRAPH_BRIDGE_TIMEOUT_MS` | `15000` | Bridge subprocess timeout in ms |\n\nExample config file:\n\n```json\n{","lineStart":1,"lineEnd":120,"totalLines":150,"truncated":true}},"title":".opencode/plugins/README.md","time":{"start":1782925288193,"end":1782925288197}},"metadata":{"openai":{"itemId":"fc_0d42db50e07cd532016a4547e7e73c8191b052fc0aba7722d5"}},"id":"prt_f1ea0e2b7001NO8yPnl7SRV36Z","sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","messageID":"msg_f1ea08aa3001vwnjDmi0SD59yF"}}
{"type":"tool_use","timestamp":1782925288261,"sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","part":{"type":"tool","tool":"read","callID":"call_aOI47enALivYUkTZkhL42gck","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js","offset":145,"limit":60},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js</path>\n<type>file</type>\n<content>\n145: \n146: function normalizeSessionID(value) {\n147:   if (value === null || value === undefined) return null;\n148:   const normalized = typeof value === 'object' ? stableStringify(value) : String(value);\n149:   const trimmed = normalized.trim();\n150:   return trimmed ? trimmed : null;\n151: }\n152: \n153: function requireSessionID(value) {\n154:   const sessionID = normalizeSessionID(value);\n155:   if (!sessionID) {\n156:     throw new GoalError('MISSING_SESSION_ID', 'Missing session id; refusing to read or write shared goal state');\n157:   }\n158:   return sessionID;\n159: }\n160: \n161: function sessionIdFromInput(input) {\n162:   if (!input || typeof input !== 'object') return null;\n163:   return normalizeSessionID(\n164:     input.sessionID\n165:       || input.sessionId\n166:       || input.session?.id\n167:       || input.properties?.sessionID\n168:       || input.properties?.info?.sessionID\n169:       || null,\n170:   );\n171: }\n172: \n173: function sessionIdFromContext(context) {\n174:   if (!context || typeof context !== 'object') return null;\n175:   return normalizeSessionID(context.sessionID || context.sessionId || context.session?.id || null);\n176: }\n177: \n178: function sessionKeyForSession(sessionID) {\n179:   return Buffer.from(requireSessionID(sessionID), 'utf8').toString('hex');\n180: }\n181: \n182: function clampText(value, maxChars) {\n183:   const text = String(value ?? '');\n184:   const limit = Number.isFinite(maxChars) ? Math.max(0, Math.trunc(maxChars)) : text.length;\n185:   if (text.length <= limit) return text;\n186:   if (limit <= 0) return '';\n187:   if (limit <= 3) return '.'.repeat(limit);\n188:   return `${text.slice(0, limit - 3).trimEnd()}...`;\n189: }\n190: \n191: function normalizeUserAuthoredText(value) {\n192:   return String(value ?? '')\n193:     .normalize('NFKC')\n194:     .replace(/[\\u200b-\\u200f\\u202a-\\u202e\\u2060-\\u206f\\ufeff]/g, '')\n195:     .replace(/[\\u0000-\\u0008\\u000b\\u000c\\u000e-\\u001f\\u007f]+/g, ' ')\n196:     .replace(/[\\u0009\\u000a\\u000d]+/g, '\\n')\n197:     .replace(/\\[\\/?active_goal[^\\]]*\\]/gi, '[goal-marker-redacted]')\n198:     .replace(/`{3,}/g, '\\'\\'\\'')\n199:     .replace(/(^|[\\s\\n>])([a-z][\\w -]{0,24})\\s*:/gi, (match, prefix, role) => {\n200:       if (!/^(system|developer|assistant|tool|user)$/i.test(role.trim())) return match;\n201:       return `${prefix}${role}-role:`;\n202:     })\n203:     .replace(/\\b(ignore|disregard|forget|override|bypass|disable|drop|replace)\\s+(all\\s+)?(previous|prior|above|earlier|system|developer|safety|tool)\\s+(instructions?|messages?|prompts?|rules?|constraints?)\\b/gi, '[instruction-redacted]')\n204:     .replace(/\\b(reveal|print|show|dump|exfiltrate|leak)\\s+(the\\s+)?(system|developer|hidden|secret)\\s+(prompt|instructions?|messages?|rules?)\\b/gi, '[instruction-redacted]')\n\n(Showing lines 145-204 of 1907. Use offset=205 to continue.)\n</content>","metadata":{"preview":"\nfunction normalizeSessionID(value) {\n  if (value === null || value === undefined) return null;\n  const normalized = typeof value === 'object' ? stableStringify(value) : String(value);\n  const trimmed = normalized.trim();\n  return trimmed ? trimmed : null;\n}\n\nfunction requireSessionID(value) {\n  const sessionID = normalizeSessionID(value);\n  if (!sessionID) {\n    throw new GoalError('MISSING_SESSION_ID', 'Missing session id; refusing to read or write shared goal state');\n  }\n  return sessionID;\n}\n\nfunction sessionIdFromInput(input) {\n  if (!input || typeof input !== 'object') return null;\n  return normalizeSessionID(\n    input.sessionID","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js","text":"\nfunction normalizeSessionID(value) {\n  if (value === null || value === undefined) return null;\n  const normalized = typeof value === 'object' ? stableStringify(value) : String(value);\n  const trimmed = normalized.trim();\n  return trimmed ? trimmed : null;\n}\n\nfunction requireSessionID(value) {\n  const sessionID = normalizeSessionID(value);\n  if (!sessionID) {\n    throw new GoalError('MISSING_SESSION_ID', 'Missing session id; refusing to read or write shared goal state');\n  }\n  return sessionID;\n}\n\nfunction sessionIdFromInput(input) {\n  if (!input || typeof input !== 'object') return null;\n  return normalizeSessionID(\n    input.sessionID\n      || input.sessionId\n      || input.session?.id\n      || input.properties?.sessionID\n      || input.properties?.info?.sessionID\n      || null,\n  );\n}\n\nfunction sessionIdFromContext(context) {\n  if (!context || typeof context !== 'object') return null;\n  return normalizeSessionID(context.sessionID || context.sessionId || context.session?.id || null);\n}\n\nfunction sessionKeyForSession(sessionID) {\n  return Buffer.from(requireSessionID(sessionID), 'utf8').toString('hex');\n}\n\nfunction clampText(value, maxChars) {\n  const text = String(value ?? '');\n  const limit = Number.isFinite(maxChars) ? Math.max(0, Math.trunc(maxChars)) : text.length;\n  if (text.length <= limit) return text;\n  if (limit <= 0) return '';\n  if (limit <= 3) return '.'.repeat(limit);\n  return `${text.slice(0, limit - 3).trimEnd()}...`;\n}\n\nfunction normalizeUserAuthoredText(value) {\n  return String(value ?? '')\n    .normalize('NFKC')\n    .replace(/[\\u200b-\\u200f\\u202a-\\u202e\\u2060-\\u206f\\ufeff]/g, '')\n    .replace(/[\\u0000-\\u0008\\u000b\\u000c\\u000e-\\u001f\\u007f]+/g, ' ')\n    .replace(/[\\u0009\\u000a\\u000d]+/g, '\\n')\n    .replace(/\\[\\/?active_goal[^\\]]*\\]/gi, '[goal-marker-redacted]')\n    .replace(/`{3,}/g, '\\'\\'\\'')\n    .replace(/(^|[\\s\\n>])([a-z][\\w -]{0,24})\\s*:/gi, (match, prefix, role) => {\n      if (!/^(system|developer|assistant|tool|user)$/i.test(role.trim())) return match;\n      return `${prefix}${role}-role:`;\n    })\n    .replace(/\\b(ignore|disregard|forget|override|bypass|disable|drop|replace)\\s+(all\\s+)?(previous|prior|above|earlier|system|developer|safety|tool)\\s+(instructions?|messages?|prompts?|rules?|constraints?)\\b/gi, '[instruction-redacted]')\n    .replace(/\\b(reveal|print|show|dump|exfiltrate|leak)\\s+(the\\s+)?(system|developer|hidden|secret)\\s+(prompt|instructions?|messages?|rules?)\\b/gi, '[instruction-redacted]')","lineStart":145,"lineEnd":204,"totalLines":1907,"truncated":true}},"title":".opencode/plugins/mk-goal.js","time":{"start":1782925288257,"end":1782925288260}},"metadata":{"openai":{"itemId":"fc_0d42db50e07cd532016a4547e7e7548191846431b900dab414"}},"id":"prt_f1ea0e309001j4dw64FVGb1htP","sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","messageID":"msg_f1ea08aa3001vwnjDmi0SD59yF"}}
{"type":"tool_use","timestamp":1782925288363,"sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","part":{"type":"tool","tool":"read","callID":"call_qIsMB3PQaC9ejwRkFoNhVvke","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js","offset":640,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js</path>\n<type>file</type>\n<content>\n640: /**\n641:  * Resolve a per-session goal state file path.\n642:  *\n643:  * @param {string} sessionID - OpenCode session id\n644:  * @param {Object} [rawOptions] - State helper options\n645:  * @returns {string} Absolute JSON file path\n646:  */\n647: function goalPathForSession(sessionID, rawOptions = {}) {\n648:   const options = normalizeOptions(rawOptions);\n649:   return join(options.stateDir, `${sessionKeyForSession(sessionID)}.json`);\n650: }\n651: \n652: function normalizeStoredGoal(rawGoal, fallbackSessionID, rawOptions = {}) {\n653:   if (!rawGoal || typeof rawGoal !== 'object') {\n654:     throw new GoalError('INVALID_GOAL_STATE', 'Goal state is not a JSON object');\n655:   }\n656:   const options = normalizeOptions(rawOptions);\n657:   const sessionID = requireSessionID(rawGoal.sessionId ?? fallbackSessionID);\n658:   const objective = sanitizeInlineText(rawGoal.objective, options.maxObjectiveChars);\n659:   if (!objective) {\n660:     throw new GoalError('INVALID_GOAL_STATE', 'Goal state is missing an objective');\n661:   }\n662:   if (!VALID_STATUSES.has(rawGoal.status)) {\n663:     throw new GoalError('INVALID_GOAL_STATE', `Goal state has invalid status: ${rawGoal.status}`);\n664:   }\n665: \n666:   const createdAtMs = Number.isFinite(rawGoal.createdAtMs) ? Math.trunc(rawGoal.createdAtMs) : nowMs(options);\n667:   const updatedAtMs = Number.isFinite(rawGoal.updatedAtMs) ? Math.trunc(rawGoal.updatedAtMs) : createdAtMs;\n668:   const promptFields = normalizeGoalPromptFields(rawGoal, objective, options);\n669: \n670:   return {\n671:     ...rawGoal,\n672:     sessionId: sessionID,\n673:     goalId: sanitizeInlineText(rawGoal.goalId || goalIdFromFactory(options), 160).replace(/\\s+/g, '-'),\n674:     objective,\n675:     goalPrompt: promptFields.goalPrompt,\n676:     promptEnhancement: promptFields.promptEnhancement,\n677:     status: rawGoal.status,\n678:     tokenBudget: rawGoal.tokenBudget === undefined ? null : rawGoal.tokenBudget,\n679:     tokensUsed: Number.isFinite(rawGoal.tokensUsed) ? Math.max(0, Math.trunc(rawGoal.tokensUsed)) : 0,\n680:     timeUsedSeconds: Number.isFinite(rawGoal.timeUsedSeconds) ? Math.max(0, Math.trunc(rawGoal.timeUsedSeconds)) : 0,\n681:     createdAtMs,\n682:     updatedAtMs,\n683:     createdAt: typeof rawGoal.createdAt === 'string' ? rawGoal.createdAt : isoFromMs(createdAtMs),\n684:     updatedAt: typeof rawGoal.updatedAt === 'string' ? rawGoal.updatedAt : isoFromMs(updatedAtMs),\n685:     continuationSuppressed: rawGoal.continuationSuppressed === true,\n686:     autoTurnsUsed: normalizeAutoTurns(rawGoal.autoTurnsUsed),\n687:     maxAutoTurns: Number.isFinite(rawGoal.maxAutoTurns)\n688:       ? Math.max(0, Math.min(DEFAULT_MAX_AUTO_TURNS, Math.trunc(rawGoal.maxAutoTurns)))\n689:       : DEFAULT_MAX_AUTO_TURNS,\n690:     startedAtMs: Number.isFinite(rawGoal.startedAtMs) ? Math.max(0, Math.trunc(rawGoal.startedAtMs)) : createdAtMs,\n691:     lastActivityAtMs: Number.isFinite(rawGoal.lastActivityAtMs) ? Math.max(0, Math.trunc(rawGoal.lastActivityAtMs)) : 0,\n692:     lastActivityMessageID: rawGoal.lastActivityMessageID === null || rawGoal.lastActivityMessageID === undefined\n693:       ? null\n694:       : sanitizeInlineText(rawGoal.lastActivityMessageID, 160),\n695:     lastContinuationAtMs: Number.isFinite(rawGoal.lastContinuationAtMs)\n696:       ? Math.max(0, Math.trunc(rawGoal.lastContinuationAtMs))\n697:       : 0,\n698:     lastContinuationMessageId: rawGoal.lastContinuationMessageId === null || rawGoal.lastContinuationMessageId === undefined\n699:       ? null\n700:       : sanitizeInlineText(rawGoal.lastContinuationMessageId, 160),\n701:     lastContinuationError: rawGoal.lastContinuationError === null || rawGoal.lastContinuationError === undefined\n702:       ? null\n703:       : sanitizeInlineText(rawGoal.lastContinuationError, DEFAULT_MAX_REASON_CHARS),\n704:     continuationSuppressedReason: rawGoal.continuationSuppressedReason === null || rawGoal.continuationSuppressedReason === undefined\n705:       ? null\n706:       : sanitizeInlineText(rawGoal.continuationSuppressedReason, DEFAULT_MAX_REASON_CHARS),\n707:     blockedByPrompt: rawGoal.blockedByPrompt === true,\n708:     iterations: Number.isFinite(rawGoal.iterations) ? Math.max(0, Math.trunc(rawGoal.iterations)) : 0,\n709:     lastVerifierVerdict: sanitizeInlineText(rawGoal.lastVerifierVerdict || 'not_evaluated', 80),\n710:     lastVerifierReason: rawGoal.lastVerifierReason === null || rawGoal.lastVerifierReason === undefined\n711:       ? null\n712:       : redactEvidence(rawGoal.lastVerifierReason, DEFAULT_MAX_REASON_CHARS),\n713:     lastVerifierConfidence: Number.isFinite(rawGoal.lastVerifierConfidence)\n714:       ? Math.max(0, Math.min(1, Number(rawGoal.lastVerifierConfidence)))\n715:       : null,\n716:     lastCheckAtMs: Number.isFinite(rawGoal.lastCheckAtMs) ? Math.max(0, Math.trunc(rawGoal.lastCheckAtMs)) : 0,\n717:     lastEvidence: rawGoal.lastEvidence === null || rawGoal.lastEvidence === undefined\n718:       ? null\n719:       : redactEvidence(rawGoal.lastEvidence, options.maxEvidenceChars),\n720:     completionSource: rawGoal.completionSource === null || rawGoal.completionSource === undefined\n721:       ? null\n722:       : sanitizeInlineText(rawGoal.completionSource, 80),\n723:     verifierRunID: rawGoal.verifierRunID === null || rawGoal.verifierRunID === undefined\n724:       ? null\n725:       : sanitizeInlineText(rawGoal.verifierRunID, 160),\n726:     lastAccountedMessageID: rawGoal.lastAccountedMessageID === null || rawGoal.lastAccountedMessageID === undefined\n727:       ? null\n728:       : sanitizeInlineText(rawGoal.lastAccountedMessageID, 160),\n729:     usageSource: sanitizeInlineText(rawGoal.usageSource || 'unavailable', 80),\n730:   };\n731: }\n732: \n733: /**\n734:  * Read the current goal for a session.\n735:  *\n736:  * @param {string} sessionID - OpenCode session id\n737:  * @param {Object} [rawOptions] - State helper options\n738:  * @returns {Promise<Object|null>} Goal record, or null when none is set\n739:  */\n740: async function readGoal(sessionID, rawOptions = {}) {\n741:   const path = goalPathForSession(sessionID, rawOptions);\n742:   try {\n743:     const raw = await readFile(path, 'utf8');\n744:     return normalizeStoredGoal(JSON.parse(raw), sessionID, rawOptions);\n745:   } catch (error) {\n746:     if (error?.code === 'ENOENT') return null;\n747:     if (error instanceof GoalError) throw error;\n748:     throw new GoalError('READ_GOAL_FAILED', `Failed to read goal state: ${error.message}`);\n749:   }\n750: }\n751: \n752: async function fsyncDirectory(directoryPath, rawOptions = {}) {\n753:   let handle = null;\n754:   try {\n755:     handle = await open(directoryPath, 'r');\n756:     await handle.sync();\n757:   } catch (error) {\n758:     if (process.env[DEBUG_ENV] === '1') {\n759:       await appendGoalJsonl(GOAL_EVENTS_LOG_FILENAME, {\n760:         type: 'fsync_directory_error',\n761:         directory: sanitizeInlineText(directoryPath, 1000),\n762:         error: redactEvidence(error?.message || 'unknown error', DEFAULT_MAX_REASON_CHARS),\n763:       }, { ...rawOptions, stateDir: directoryPath });\n764:     }\n765:     return;\n766:   } finally {\n767:     if (handle) await handle.close().catch(() => {});\n768:   }\n769: }\n770: \n771: /**\n772:  * Atomically write a goal record.\n773:  *\n774:  * @param {Object} goal - Goal record to persist\n775:  * @param {Object} [rawOptions] - State helper options\n776:  * @returns {Promise<Object>} Written goal record\n777:  */\n778: async function writeGoalAtomic(goal, rawOptions = {}) {\n779:   const options = normalizeOptions(rawOptions);\n780:   const normalized = normalizeStoredGoal(goal, goal?.sessionId, options);\n781:   const stateDir = await ensureGoalStateDir(options);\n782:   const finalPath = goalPathForSession(normalized.sessionId, options);\n783:   const tempPath = `${finalPath}.${process.pid}.${Date.now()}.${Math.random().toString(16).slice(2)}.tmp`;\n784:   let handle = null;\n785: \n786:   try {\n787:     handle = await open(tempPath, 'w', 0o600);\n788:     await handle.writeFile(`${JSON.stringify(normalized, null, 2)}\\n`, 'utf8');\n789:     await handle.sync();\n790:     await handle.close();\n791:     handle = null;\n792:     await rename(tempPath, finalPath);\n793:     await fsyncDirectory(stateDir, options);\n794:     return normalized;\n795:   } catch (error) {\n796:     if (handle) await handle.close().catch(() => {});\n797:     await unlink(tempPath).catch(() => {});\n798:     if (error instanceof GoalError) throw error;\n799:     throw new GoalError('WRITE_GOAL_FAILED', `Failed to write goal state: ${error.message}`);\n800:   }\n801: }\n802: \n803: async function deleteGoalFile(sessionID, rawOptions = {}) {\n804:   const path = goalPathForSession(sessionID, rawOptions);\n805:   try {\n806:     await unlink(path);\n807:   } catch (error) {\n808:     if (error?.code !== 'ENOENT') {\n809:       throw new GoalError('CLEAR_GOAL_FAILED', `Failed to clear goal state: ${error.message}`);\n810:     }\n811:   }\n812:   await fsyncDirectory(normalizeOptions(rawOptions).stateDir);\n813:   return null;\n814: }\n815: \n816: function retentionDaysFromEnv(name, fallback) {\n817:   return normalizePositiveInt(Number(process.env[name]), fallback);\n818: }\n819: \n\n(Showing lines 640-819 of 1907. Use offset=820 to continue.)\n</content>","metadata":{"preview":"/**\n * Resolve a per-session goal state file path.\n *\n * @param {string} sessionID - OpenCode session id\n * @param {Object} [rawOptions] - State helper options\n * @returns {string} Absolute JSON file path\n */\nfunction goalPathForSession(sessionID, rawOptions = {}) {\n  const options = normalizeOptions(rawOptions);\n  return join(options.stateDir, `${sessionKeyForSession(sessionID)}.json`);\n}\n\nfunction normalizeStoredGoal(rawGoal, fallbackSessionID, rawOptions = {}) {\n  if (!rawGoal || typeof rawGoal !== 'object') {\n    throw new GoalError('INVALID_GOAL_STATE', 'Goal state is not a JSON object');\n  }\n  const options = normalizeOptions(rawOptions);\n  const sessionID = requireSessionID(rawGoal.sessionId ?? fallbackSessionID);\n  const objective = sanitizeInlineText(rawGoal.objective, options.maxObjectiveChars);\n  if (!objective) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/mk-goal.js","text":"/**\n * Resolve a per-session goal state file path.\n *\n * @param {string} sessionID - OpenCode session id\n * @param {Object} [rawOptions] - State helper options\n * @returns {string} Absolute JSON file path\n */\nfunction goalPathForSession(sessionID, rawOptions = {}) {\n  const options = normalizeOptions(rawOptions);\n  return join(options.stateDir, `${sessionKeyForSession(sessionID)}.json`);\n}\n\nfunction normalizeStoredGoal(rawGoal, fallbackSessionID, rawOptions = {}) {\n  if (!rawGoal || typeof rawGoal !== 'object') {\n    throw new GoalError('INVALID_GOAL_STATE', 'Goal state is not a JSON object');\n  }\n  const options = normalizeOptions(rawOptions);\n  const sessionID = requireSessionID(rawGoal.sessionId ?? fallbackSessionID);\n  const objective = sanitizeInlineText(rawGoal.objective, options.maxObjectiveChars);\n  if (!objective) {\n    throw new GoalError('INVALID_GOAL_STATE', 'Goal state is missing an objective');\n  }\n  if (!VALID_STATUSES.has(rawGoal.status)) {\n    throw new GoalError('INVALID_GOAL_STATE', `Goal state has invalid status: ${rawGoal.status}`);\n  }\n\n  const createdAtMs = Number.isFinite(rawGoal.createdAtMs) ? Math.trunc(rawGoal.createdAtMs) : nowMs(options);\n  const updatedAtMs = Number.isFinite(rawGoal.updatedAtMs) ? Math.trunc(rawGoal.updatedAtMs) : createdAtMs;\n  const promptFields = normalizeGoalPromptFields(rawGoal, objective, options);\n\n  return {\n    ...rawGoal,\n    sessionId: sessionID,\n    goalId: sanitizeInlineText(rawGoal.goalId || goalIdFromFactory(options), 160).replace(/\\s+/g, '-'),\n    objective,\n    goalPrompt: promptFields.goalPrompt,\n    promptEnhancement: promptFields.promptEnhancement,\n    status: rawGoal.status,\n    tokenBudget: rawGoal.tokenBudget === undefined ? null : rawGoal.tokenBudget,\n    tokensUsed: Number.isFinite(rawGoal.tokensUsed) ? Math.max(0, Math.trunc(rawGoal.tokensUsed)) : 0,\n    timeUsedSeconds: Number.isFinite(rawGoal.timeUsedSeconds) ? Math.max(0, Math.trunc(rawGoal.timeUsedSeconds)) : 0,\n    createdAtMs,\n    updatedAtMs,\n    createdAt: typeof rawGoal.createdAt === 'string' ? rawGoal.createdAt : isoFromMs(createdAtMs),\n    updatedAt: typeof rawGoal.updatedAt === 'string' ? rawGoal.updatedAt : isoFromMs(updatedAtMs),\n    continuationSuppressed: rawGoal.continuationSuppressed === true,\n    autoTurnsUsed: normalizeAutoTurns(rawGoal.autoTurnsUsed),\n    maxAutoTurns: Number.isFinite(rawGoal.maxAutoTurns)\n      ? Math.max(0, Math.min(DEFAULT_MAX_AUTO_TURNS, Math.trunc(rawGoal.maxAutoTurns)))\n      : DEFAULT_MAX_AUTO_TURNS,\n    startedAtMs: Number.isFinite(rawGoal.startedAtMs) ? Math.max(0, Math.trunc(rawGoal.startedAtMs)) : createdAtMs,\n    lastActivityAtMs: Number.isFinite(rawGoal.lastActivityAtMs) ? Math.max(0, Math.trunc(rawGoal.lastActivityAtMs)) : 0,\n    lastActivityMessageID: rawGoal.lastActivityMessageID === null || rawGoal.lastActivityMessageID === undefined\n      ? null\n      : sanitizeInlineText(rawGoal.lastActivityMessageID, 160),\n    lastContinuationAtMs: Number.isFinite(rawGoal.lastContinuationAtMs)\n      ? Math.max(0, Math.trunc(rawGoal.lastContinuationAtMs))\n      : 0,\n    lastContinuationMessageId: rawGoal.lastContinuationMessageId === null || rawGoal.lastContinuationMessageId === undefined\n      ? null\n      : sanitizeInlineText(rawGoal.lastContinuationMessageId, 160),\n    lastContinuationError: rawGoal.lastContinuationError === null || rawGoal.lastContinuationError === undefined\n      ? null\n      : sanitizeInlineText(rawGoal.lastContinuationError, DEFAULT_MAX_REASON_CHARS),\n    continuationSuppressedReason: rawGoal.continuationSuppressedReason === null || rawGoal.continuationSuppressedReason === undefined\n      ? null\n      : sanitizeInlineText(rawGoal.continuationSuppressedReason, DEFAULT_MAX_REASON_CHARS),\n    blockedByPrompt: rawGoal.blockedByPrompt === true,\n    iterations: Number.isFinite(rawGoal.iterations) ? Math.max(0, Math.trunc(rawGoal.iterations)) : 0,\n    lastVerifierVerdict: sanitizeInlineText(rawGoal.lastVerifierVerdict || 'not_evaluated', 80),\n    lastVerifierReason: rawGoal.lastVerifierReason === null || rawGoal.lastVerifierReason === undefined\n      ? null\n      : redactEvidence(rawGoal.lastVerifierReason, DEFAULT_MAX_REASON_CHARS),\n    lastVerifierConfidence: Number.isFinite(rawGoal.lastVerifierConfidence)\n      ? Math.max(0, Math.min(1, Number(rawGoal.lastVerifierConfidence)))\n      : null,\n    lastCheckAtMs: Number.isFinite(rawGoal.lastCheckAtMs) ? Math.max(0, Math.trunc(rawGoal.lastCheckAtMs)) : 0,\n    lastEvidence: rawGoal.lastEvidence === null || rawGoal.lastEvidence === undefined\n      ? null\n      : redactEvidence(rawGoal.lastEvidence, options.maxEvidenceChars),\n    completionSource: rawGoal.completionSource === null || rawGoal.completionSource === undefined\n      ? null\n      : sanitizeInlineText(rawGoal.completionSource, 80),\n    verifierRunID: rawGoal.verifierRunID === null || rawGoal.verifierRunID === undefined\n      ? null\n      : sanitizeInlineText(rawGoal.verifierRunID, 160),\n    lastAccountedMessageID: rawGoal.lastAccountedMessageID === null || rawGoal.lastAccountedMessageID === undefined\n      ? null\n      : sanitizeInlineText(rawGoal.lastAccountedMessageID, 160),\n    usageSource: sanitizeInlineText(rawGoal.usageSource || 'unavailable', 80),\n  };\n}\n\n/**\n * Read the current goal for a session.\n *\n * @param {string} sessionID - OpenCode session id\n * @param {Object} [rawOptions] - State helper options\n * @returns {Promise<Object|null>} Goal record, or null when none is set\n */\nasync function readGoal(sessionID, rawOptions = {}) {\n  const path = goalPathForSession(sessionID, rawOptions);\n  try {\n    const raw = await readFile(path, 'utf8');\n    return normalizeStoredGoal(JSON.parse(raw), sessionID, rawOptions);\n  } catch (error) {\n    if (error?.code === 'ENOENT') return null;\n    if (error instanceof GoalError) throw error;\n    throw new GoalError('READ_GOAL_FAILED', `Failed to read goal state: ${error.message}`);\n  }\n}\n\nasync function fsyncDirectory(directoryPath, rawOptions = {}) {\n  let handle = null;\n  try {\n    handle = await open(directoryPath, 'r');\n    await handle.sync();\n  } catch (error) {\n    if (process.env[DEBUG_ENV] === '1') {\n      await appendGoalJsonl(GOAL_EVENTS_LOG_FILENAME, {\n        type: 'fsync_directory_error',\n        directory: sanitizeInlineText(directoryPath, 1000),\n        error: redactEvidence(error?.message || 'unknown error', DEFAULT_MAX_REASON_CHARS),\n      }, { ...rawOptions, stateDir: directoryPath });\n    }\n    return;\n  } finally {\n    if (handle) await handle.close().catch(() => {});\n  }\n}\n\n/**\n * Atomically write a goal record.\n *\n * @param {Object} goal - Goal record to persist\n * @param {Object} [rawOptions] - State helper options\n * @returns {Promise<Object>} Written goal record\n */\nasync function writeGoalAtomic(goal, rawOptions = {}) {\n  const options = normalizeOptions(rawOptions);\n  const normalized = normalizeStoredGoal(goal, goal?.sessionId, options);\n  const stateDir = await ensureGoalStateDir(options);\n  const finalPath = goalPathForSession(normalized.sessionId, options);\n  const tempPath = `${finalPath}.${process.pid}.${Date.now()}.${Math.random().toString(16).slice(2)}.tmp`;\n  let handle = null;\n\n  try {\n    handle = await open(tempPath, 'w', 0o600);\n    await handle.writeFile(`${JSON.stringify(normalized, null, 2)}\\n`, 'utf8');\n    await handle.sync();\n    await handle.close();\n    handle = null;\n    await rename(tempPath, finalPath);\n    await fsyncDirectory(stateDir, options);\n    return normalized;\n  } catch (error) {\n    if (handle) await handle.close().catch(() => {});\n    await unlink(tempPath).catch(() => {});\n    if (error instanceof GoalError) throw error;\n    throw new GoalError('WRITE_GOAL_FAILED', `Failed to write goal state: ${error.message}`);\n  }\n}\n\nasync function deleteGoalFile(sessionID, rawOptions = {}) {\n  const path = goalPathForSession(sessionID, rawOptions);\n  try {\n    await unlink(path);\n  } catch (error) {\n    if (error?.code !== 'ENOENT') {\n      throw new GoalError('CLEAR_GOAL_FAILED', `Failed to clear goal state: ${error.message}`);\n    }\n  }\n  await fsyncDirectory(normalizeOptions(rawOptions).stateDir);\n  return null;\n}\n\nfunction retentionDaysFromEnv(name, fallback) {\n  return normalizePositiveInt(Number(process.env[name]), fallback);\n}\n","lineStart":640,"lineEnd":819,"totalLines":1907,"truncated":true}},"title":".opencode/plugins/mk-goal.js","time":{"start":1782925288358,"end":1782925288362}},"metadata":{"openai":{"itemId":"fc_0d42db50e07cd532016a4547e7e764819184da83dcb4c0f9f5"}},"id":"prt_f1ea0e379001OnU6V0c2k8dpKV","sessionID":"ses_0e161b9f6ffe75vhj1ifiw59Va","messageID":"msg_f1ea08aa3001vwnjDmi0SD59yF"}}
