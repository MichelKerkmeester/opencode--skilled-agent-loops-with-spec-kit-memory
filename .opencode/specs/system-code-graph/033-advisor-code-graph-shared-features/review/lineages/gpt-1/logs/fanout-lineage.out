Depth === undefined ? 3 : Number(args.maxDepth);\n1335:   const maxDepth = Math.max(0, Math.min(Number.isFinite(rawMaxDepth) ? rawMaxDepth : 3, 20));\n1336: \n1337:   if (edgeTypeError) {\n1338:     return {\n1339:       content: [{\n1340:         type: 'text',\n1341:         text: JSON.stringify({ status: 'error', error: edgeTypeError }),\n1342:       }],\n1343:     };\n1344:   }\n1345: \n1346:   if (shouldBlockReadPath(readiness, args.verificationGateBypass === 'gold-query-verifier')) {\n1347:     return {\n1348:       content: [{\n1349:         type: 'text',\n1350:         text: JSON.stringify(buildBlockedReadPayload(readiness, operation, subject), null, 2),\n1351:       }],\n1352:     };\n1353:   }\n1354: \n1355:   if (operation === 'outline') {\n1356:     const resolvedSubject = graphDb.resolveSubjectFilePath(subject);\n1357:     if (typeof resolvedSubject !== 'string' || resolvedSubject.length === 0) {\n1358:       return {\n1359:         content: [{\n1360:           type: 'text',\n1361:           text: JSON.stringify({\n1362:             status: 'error',\n1363:             error: `Could not resolve outline subject: ${subject}`,\n1364:           }),\n1365:         }],\n1366:       };\n1367:     }\n1368: \n1369:     const nodes = graphDb.queryOutline(resolvedSubject);\n1370:     const limited = nodes.slice(0, limit);\n1371:     const outlineNodes: OutlineQueryNode[] = limited.map(n => ({\n1372:       name: n.name,\n1373:       kind: n.kind,\n1374:       fqName: n.fqName,\n1375:       line: n.startLine,\n1376:       signature: n.signature,\n1377:       symbolId: n.symbolId,\n1378:     }));\n\n(Showing lines 1259-1378 of 1766. Use offset=1379 to continue.)\n</content>","metadata":{"preview":"    // Omitted when the traversal reached the full depth horizon, mirroring the\n    // `overflowed`-driven conditional spread below so the field is absent\n    // (rather than `false`) in the common, complete case.\n    ...(depthTruncated ? { depthTruncated: true } : {}),\n    ...(overflowed\n      ? {\n        failureFallback: {\n          reason: 'limit_reached',\n          code: 'limit_reached',\n          partialResult: buildPartialBlastRadiusResult(\n            normalizedSources,\n            [...seedNodes, ...affectedFiles],\n            affectedFiles,\n            depthGroups,\n          ),\n        } satisfies BlastRadiusFailureFallback,\n      }\n      : {}),\n  };\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/handlers/query.ts","text":"    // Omitted when the traversal reached the full depth horizon, mirroring the\n    // `overflowed`-driven conditional spread below so the field is absent\n    // (rather than `false`) in the common, complete case.\n    ...(depthTruncated ? { depthTruncated: true } : {}),\n    ...(overflowed\n      ? {\n        failureFallback: {\n          reason: 'limit_reached',\n          code: 'limit_reached',\n          partialResult: buildPartialBlastRadiusResult(\n            normalizedSources,\n            [...seedNodes, ...affectedFiles],\n            affectedFiles,\n            depthGroups,\n          ),\n        } satisfies BlastRadiusFailureFallback,\n      }\n      : {}),\n  };\n}\n\n/** Handle code_graph_query tool call */\nexport async function handleCodeGraphQuery(args: QueryArgs): Promise<{ content: Array<{ type: string; text: string }> }> {\n  let readiness: ReadyResult = {\n    freshness: 'empty' as const,\n    action: 'none' as const,\n    inlineIndexPerformed: false,\n    reason: 'readiness check not run',\n  };\n\n  // Auto-trigger: ensure graph is fresh before querying\n  try {\n    readiness = await ensureCodeGraphReady(process.cwd(), {\n      allowInlineIndex: true,\n      allowInlineFullScan: false,\n      allowGuardedInlineFullScan: true,\n    });\n  } catch (error) {\n    // Emit 'unavailable' trust-state on readiness-crash so query consumers\n    // see the same canonical vocabulary\n    // as code_graph_context. Previously this path dropped the readiness\n    // block entirely and only returned a status:'error' string.\n    const reason = error instanceof Error ? error.message : String(error);\n    const crashReadiness: ReadyResult = {\n      freshness: 'error' as const,\n      action: 'none' as const,\n      inlineIndexPerformed: false,\n      reason: 'readiness_check_crashed',\n    };\n    const crashBlock = buildReadinessBlock(crashReadiness);\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify({\n          // BUG-07: align with code_graph_context + detect_changes — a non-fresh\n          // / unavailable graph (here: readiness probe crashed) refuses with\n          // status:'blocked', not 'error', so all three read handlers share one\n          // refusal token. The structured readiness block + rg fallback are\n          // preserved so consumers still see the crash detail.\n          status: 'blocked',\n          message: `code_graph_not_ready: ${reason}`,\n          data: {\n            readiness: crashBlock,\n            canonicalReadiness: crashBlock.canonicalReadiness,\n            trustState: crashBlock.trustState,\n            fallbackDecision: buildFallbackDecision(crashReadiness),\n          },\n        }),\n      }],\n    };\n  }\n\n  const { operation, subject } = args;\n  const limit = Math.max(1, Math.min(Number(args.limit) || 50, 1000));\n  const { edgeType: requestedEdgeType, error: edgeTypeError } = resolveRequestedEdgeType(args);\n  const rawMaxDepth = args.maxDepth === undefined ? 3 : Number(args.maxDepth);\n  const maxDepth = Math.max(0, Math.min(Number.isFinite(rawMaxDepth) ? rawMaxDepth : 3, 20));\n\n  if (edgeTypeError) {\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify({ status: 'error', error: edgeTypeError }),\n      }],\n    };\n  }\n\n  if (shouldBlockReadPath(readiness, args.verificationGateBypass === 'gold-query-verifier')) {\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify(buildBlockedReadPayload(readiness, operation, subject), null, 2),\n      }],\n    };\n  }\n\n  if (operation === 'outline') {\n    const resolvedSubject = graphDb.resolveSubjectFilePath(subject);\n    if (typeof resolvedSubject !== 'string' || resolvedSubject.length === 0) {\n      return {\n        content: [{\n          type: 'text',\n          text: JSON.stringify({\n            status: 'error',\n            error: `Could not resolve outline subject: ${subject}`,\n          }),\n        }],\n      };\n    }\n\n    const nodes = graphDb.queryOutline(resolvedSubject);\n    const limited = nodes.slice(0, limit);\n    const outlineNodes: OutlineQueryNode[] = limited.map(n => ({\n      name: n.name,\n      kind: n.kind,\n      fqName: n.fqName,\n      line: n.startLine,\n      signature: n.signature,\n      symbolId: n.symbolId,\n    }));","lineStart":1259,"lineEnd":1378,"totalLines":1766,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/handlers/query.ts","time":{"start":1781128845512,"end":1781128845537}},"metadata":{"openai":{"itemId":"fc_0b875351d25a55fc016a29de8d639c8191bb8a7c83808b4679"}},"id":"prt_eb38d58c7001PgP3RIPS9csKcz","sessionID":"ses_14c74eea6ffemTvYGOsUhNiPQp","messageID":"msg_eb38d26020012Ew3caaFtbScAj"}}
