n  const current = scores.get(skillId) ?? { score: 0, evidence: [], producerSkillIds: new Set<string>() };\n  current.score += amount;\n  current.evidence.push(evidence);\n  if (producerSkillId) {\n    current.producerSkillIds.add(producerSkillId);\n  }\n  scores.set(skillId, current);\n}\n\nexport function scoreExplicitLane(\n  prompt: string,\n  projection: AdvisorProjection,\n  options: ExplicitLaneOptions = {},","lineStart":1,"lineEnd":260,"totalLines":350,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","time":{"start":1783437204931,"end":1783437204942}},"metadata":{"openai":{"itemId":"fc_093d4b70614d3caf016a4d1794d5ac8191a55a0bcd395a7d0e"}},"id":"prt_f3d241d9d001kD46TUNDz30S8m","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d23eb48001Teq8BrJ3T5JLlh"}}
{"type":"tool_use","timestamp":1783437204946,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_GjVRNM3ibX56aopYbVJ8yFEW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","offset":1,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor 5-Lane Fusion\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n6: \n7: import { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\n8: import { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\n9: import {\n10:   ADVISOR_HOOK_FRESHNESS_VALUES,\n11:   ADVISOR_RUNTIME_VALUES,\n12:   isSpeckitMetricsEnabled,\n13:   speckitMetrics,\n14: } from '../metrics.js';\n15: import { normalize } from '../affordance-normalizer.js';\n16: import { scoreDerivedLane } from './lanes/derived.js';\n17: import { scoreExplicitLane } from './lanes/explicit.js';\n18: import { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\n19: import { scoreLexicalLane } from './lanes/lexical.js';\n20: import { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\n21: import { applyExecutorDelegationOverride } from './executor-delegation.js';\n22: import { loadAdvisorProjection } from './projection.js';\n23: import { SCORING_CALIBRATION } from './scoring-constants.js';\n24: import { isReadOnlyExplainer, matchesPhraseBoundary } from './text.js';\n25: import {\n26:   DEFAULT_SCORER_WEIGHTS,\n27:   SCORER_LANES,\n28:   liveWeightTotal,\n29: } from './weights-config.js';\n30: import { isLiveScorerLane } from './lane-registry.js';\n31: import { SKILL_ADVISOR_COMPAT_CONTRACT, resolvedConfidenceThreshold, resolvedUncertaintyThreshold } from '../compat/contract.js';\n32: import type {\n33:   AdvisorProjection,\n34:   AdvisorScoredRecommendation,\n35:   AdvisorScoringOptions,\n36:   AdvisorScoringResult,\n37:   LaneContribution,\n38:   LaneMatch,\n39:   LaneRuntimeHealth,\n40:   LaneScores,\n41:   ScorerLane,\n42:   SkillProjection,\n43: } from './types.js';\n44: import type { NormalizedAffordance } from '../affordance-normalizer.js';\n45: import type { RankedList, RrfItem } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n46: \n47: const DEFAULT_CONFIDENCE_THRESHOLD = resolvedConfidenceThreshold();\n48: const DEFAULT_UNCERTAINTY_THRESHOLD = resolvedUncertaintyThreshold();\n49: export const ADVISOR_RRF_FUSION_FLAG = 'SPECKIT_ADVISOR_RRF_FUSION';\n50: export const ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG = 'SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD';\n51: export const ADVISOR_QUERY_CLASS_ROUTING_FLAG = 'SPECKIT_ADVISOR_QUERY_CLASS_ROUTING';\n52: export const ADVISOR_EXACT_SEMANTIC_RERANK_FLAG = 'SPECKIT_ADVISOR_EXACT_SEMANTIC_RERANK';\n53: export const ADVISOR_RRF_K = 8;\n54: export const ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K = 10;\n55: const ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW = 0.05;\n56: const TASK_INTENT = /\\b(add|append|build|change|configure|create|edit|fix|generate|implement|modify|move|patch|refactor|rename|replace|run|start|sweep|update|write)\\b/;\n57: const DEEP_RESEARCH_CYCLE = /\\b(automated research cycle|looped investigation|continue iteration|resume iteration|overnight run|overnight research run|packet-local iteration|delta record|canonical jsonl|same lineage)\\b/;\n58: const FILE_SAVE_OPERATION = /\\bsave\\b.{0,48}\\b(file|files|document|documents|buffer|tab|workspace)\\b|\\b(file|files|document|documents|buffer|tab|workspace)\\b.{0,48}\\bsave\\b/;\n59: const MEMORY_SAVE_CONTEXT_ANCHOR = /\\b(memory|context|conversation|session|handover|checkpoint|resume|preserve|remember|capture|store)\\b|\\/memory:save|memory:save/;\n60: // Class C breadth/multi-concern abstention gates. A broad greenfield build or a\n61: // multi-concern optimization is under-specified for single-skill routing.\n62: const BREADTH_BUILD_VERB = /\\b(build|create|implement|generate|scaffold)\\b/;\n63: const BREADTH_NOUN = /\\b(full[- ]?stack|service|platform|application|microservice|saas|backend|whole (app|system))\\b/;\n64: // Narrow anchors that make a broad-build prompt specific enough to route.\n65: const BREADTH_NARROW_ANCHOR = /\\.[a-z]{2,4}\\b|\\b(test|tests|error|bug|failure|failing|handler|component|function|route|endpoint|class|method|benchmark|review|audit|migration|schema)\\b/;\n66: const MULTI_CONCERN_VERB = /\\b(optimize|improve|enhance|harden|speed up)\\b/;\n67: const CONCERN_PERF = /\\b(speed|latency|execution|throughput|performance|startup|memory|cpu)\\b/;\n68: const CONCERN_QUALITY = /\\b(quality|accuracy|recommendation|recommendations|correctness|reliability|coverage)\\b/;\n69: const TRUE_FLAG_VALUES = new Set(['1', 'true', 'yes', 'on', 'enabled']);\n70: const NO_RRF_RANK = Number.MAX_SAFE_INTEGER;\n71: const ADVISOR_SELF_RECOMMENDATION_SKILL_IDS = new Set(['system-skill-advisor', 'skill-advisor']);\n72: \n73: type MutableLaneScores = {\n74:   -readonly [K in keyof LaneScores]: LaneMatch[];\n75: };\n76: \n77: interface LaneScoreBundle {\n78:   readonly laneScores: LaneScores;\n79:   readonly graphConflictMatches: readonly LaneMatch[];\n80: }\n81: \n82: interface AdvisorRrfFusion {\n83:   readonly scoreBySkill: ReadonlyMap<string, number>;\n84:   readonly rankBySkill: ReadonlyMap<string, number>;\n85: }\n86: \n87: type AdvisorRuntimeLabel = (typeof ADVISOR_RUNTIME_VALUES)[number];\n88: type AdvisorFreshnessLabel = (typeof ADVISOR_HOOK_FRESHNESS_VALUES)[number];\n89: export type AdvisorQueryClass = 'implementation' | 'review' | 'documentation' | 'memory' | 'tooling' | 'unknown';\n90: \n91: interface ExactSemanticRerankEntry {\n92:   readonly rawScore: number;\n93: }\n94: \n95: type ExactSemanticRerankIndex = ReadonlyMap<string, ExactSemanticRerankEntry>;\n96: \n97: function emptyLaneScores(): MutableLaneScores {\n98:   return Object.fromEntries(SCORER_LANES.map((lane) => [lane, []])) as unknown as MutableLaneScores;\n99: }\n100: \n101: export function isAdvisorRrfFusionEnabled(): boolean {\n102:   const value = process.env[ADVISOR_RRF_FUSION_FLAG]?.trim().toLowerCase();\n103:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n104: }\n105: \n106: export function isAdvisorSelfRecommendationGuardEnabled(): boolean {\n107:   const value = process.env[ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG]?.trim().toLowerCase();\n108:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n109: }\n110: \n111: export function isAdvisorQueryClassRoutingEnabled(): boolean {\n112:   const value = process.env[ADVISOR_QUERY_CLASS_ROUTING_FLAG]?.trim().toLowerCase();\n113:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n114: }\n115: \n116: export function isAdvisorExactSemanticRerankEnabled(): boolean {\n117:   const value = process.env[ADVISOR_EXACT_SEMANTIC_RERANK_FLAG]?.trim().toLowerCase();\n118:   return value ? TRUE_FLAG_VALUES.has(value) : false;\n119: }\n120: \n121: export function classifyAdvisorQuery(prompt: string): AdvisorQueryClass {\n122:   const promptLower = prompt.toLowerCase();\n123:   if (/\\b(save context|save memory|handover|resume|checkpoint|spec folder|implementation summary|packet docs?)\\b/.test(promptLower)) {\n124:     return 'memory';\n125:   }\n126:   if (/\\b(review|audit|findings|regression|pull request|pr readiness|release readiness)\\b/.test(promptLower)) {\n127:     return 'review';\n128:   }\n129:   if (/\\b(readme|markdown|documentation|docs|manual testing playbook|feature catalog|taxonomy)\\b/.test(promptLower)) {\n130:     return 'documentation';\n131:   }\n132:   if (/\\b(call_tool_chain|code mode|tool ?chain|chrome devtools|browser console|figma|github|clickup)\\b/.test(promptLower)) {\n133:     return 'tooling';\n134:   }\n135:   if (TASK_INTENT.test(promptLower) || /\\b(typescript|javascript|python|vitest|mcp|handler|schema|fixture)\\b/.test(promptLower)) {\n136:     return 'implementation';\n137:   }\n138:   return 'unknown';\n139: }\n140: \n141: export function queryClassLaneMultipliers(queryClass: AdvisorQueryClass): Readonly<Partial<Record<ScorerLane, number>>> {\n142:   switch (queryClass) {\n143:     case 'implementation':\n144:       return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.98, semantic_shadow: 1.00 };\n145:     case 'review':\n146:       return { explicit_author: 1.03, lexical: 1.02, graph_causal: 0.96, derived_generated: 0.98, semantic_shadow: 1.00 };\n147:     case 'documentation':\n148:       return { explicit_author: 1.03, lexical: 0.98, graph_causal: 0.95, derived_generated: 1.04, semantic_shadow: 1.00 };\n149:     case 'memory':\n150:       return { explicit_author: 1.04, lexical: 0.98, graph_causal: 1.02, derived_generated: 1.00, semantic_shadow: 0.96 };\n151:     case 'tooling':\n152:       return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.96, semantic_shadow: 1.00 };\n153:     case 'unknown':\n154:       return {};\n155:   }\n156: }\n157: \n158: export function applyQueryClassLaneMultipliers(\n159:   weights: Readonly<Record<ScorerLane, number>>,\n160:   queryClass: AdvisorQueryClass,\n161: ): Readonly<Record<ScorerLane, number>> {\n162:   const multipliers = queryClassLaneMultipliers(queryClass);\n163:   if (Object.keys(multipliers).length === 0) return weights;\n164:   const next = { ...weights };\n165:   for (const lane of SCORER_LANES) {\n166:     const multiplier = multipliers[lane];\n167:     if (typeof multiplier === 'number' && Number.isFinite(multiplier)) {\n168:       next[lane] = Number((next[lane] * multiplier).toFixed(6));\n169:     }\n170:   }\n171:   const strongestOther = Math.max(...SCORER_LANES\n172:     .filter((lane) => lane !== 'explicit_author')\n173:     .map((lane) => next[lane]));\n174:   if (next.explicit_author < strongestOther) {\n175:     next.explicit_author = Number(strongestOther.toFixed(6));\n176:   }\n177:   return next;\n178: }\n179: \n180: function effectiveScorerWeights(\n181:   override: AdvisorScoringOptions['laneWeightsOverride'] | undefined,\n182:   queryClass: AdvisorQueryClass = 'unknown',\n183: ): Readonly<Record<ScorerLane, number>> {\n184:   const base = !override ? DEFAULT_SCORER_WEIGHTS : (() => {\n185:     const weights: Record<ScorerLane, number> = { ...DEFAULT_SCORER_WEIGHTS };\n186:     const runtimeOverride = override as Partial<Record<string, number>>;\n187:     for (const lane of SCORER_LANES) {\n188:       const value = runtimeOverride[lane];\n189:       if (typeof value === 'number' && Number.isFinite(value)) {\n190:         weights[lane] = value;\n191:       }\n192:     }\n193:     return weights;\n194:   })();\n195:   if (queryClass === 'unknown') return base;\n196:   return applyQueryClassLaneMultipliers(base, queryClass);\n197: }\n198: \n199: function normalizeRuntimeLabel(value: string | undefined): AdvisorRuntimeLabel | null {\n200:   if (value === undefined) {\n201:     return null;\n202:   }\n203:   return ADVISOR_RUNTIME_VALUES.includes(value as AdvisorRuntimeLabel) ? value as AdvisorRuntimeLabel : null;\n204: }\n205: \n206: function normalizeFreshnessLabel(value: string | undefined): AdvisorFreshnessLabel | null {\n207:   if (value === undefined) {\n208:     return 'unavailable';\n209:   }\n210:   return ADVISOR_HOOK_FRESHNESS_VALUES.includes(value as AdvisorFreshnessLabel) ? value as AdvisorFreshnessLabel : null;\n211: }\n212: \n213: interface LaneMatchIndexEntry {\n214:   rawScore: number;\n215:   evidence: string[];\n216:   producerSkillIds: string[];\n217: }\n218: \n219: type LaneMatchIndex = Map<string, LaneMatchIndexEntry>;\n220: \n221: function buildLaneRuntimeHealth(\n222:   laneScores: LaneScores,\n223:   disabled: ReadonlySet<ScorerLane>,\n224:   runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n225: ): readonly LaneRuntimeHealth[] {\n226:   return SCORER_LANES.map((lane): LaneRuntimeHealth => {\n227:     const matchCount = laneScores[lane].length;\n228:     const signal = runtimeLaneHealth?.[lane];\n229:     if (!disabled.has(lane) && signal?.status === 'runtime_degraded' && matchCount === 0) {\n230:       return {\n231:         lane,\n232:         status: 'runtime_degraded',\n233:         matchCount,\n234:         ...(signal.reason ? { reason: signal.reason } : {}),\n235:       };\n236:     }\n237:     return {\n238:       lane,\n239:       status: matchCount > 0 ? 'healthy' : 'matched_nothing',\n240:       matchCount,\n241:       ...(signal?.reason && signal.status === 'healthy' ? { reason: signal.reason } : {}),\n242:     };\n243:   });\n244: }\n245: \n246: function projectionRuntimeLaneHealth(\n247:   projection: AdvisorProjection,\n248:   runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n249: ): AdvisorScoringOptions['runtimeLaneHealth'] | undefined {\n250:   if (!projection.embeddingStaleness?.stale) {\n251:     return runtimeLaneHealth;\n252:   }\n253:   return {\n254:     ...runtimeLaneHealth,\n255:     semantic_shadow: runtimeLaneHealth?.semantic_shadow ?? {\n256:       status: 'runtime_degraded',\n257:       reason: projection.embeddingStaleness.reason ?? 'projection_embedding_stale',\n258:     },\n259:   };\n260: }\n261: \n262: function degradedLaneReason(degradedLanes: readonly ScorerLane[]): string | null {\n263:   if (degradedLanes.length === 0) return null;\n264:   return `Runtime-degraded scorer lanes omitted from confidence normalization: ${degradedLanes.join(', ')}.`;\n265: }\n266: \n267: function buildLaneMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {\n268:   const index: LaneMatchIndex = new Map();\n269:   for (const match of matches) {\n270:     const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [], producerSkillIds: [] };\n271:     existing.rawScore = Math.max(existing.rawScore, match.score);\n272:     if (existing.evidence.length < 6) {\n273:       existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));\n274:     }\n275:     for (const producerSkillId of match.producerSkillIds ?? []) {\n276:       if (!existing.producerSkillIds.includes(producerSkillId)) {\n277:         existing.producerSkillIds.push(producerSkillId);\n278:       }\n279:     }\n280:     index.set(match.skillId, existing);\n\n(Showing lines 1-280 of 911. Use offset=281 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor 5-Lane Fusion\n// ───────────────────────────────────────────────────────────────\n\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nimport { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\nimport { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\nimport {\n  ADVISOR_HOOK_FRESHNESS_VALUES,\n  ADVISOR_RUNTIME_VALUES,\n  isSpeckitMetricsEnabled,\n  speckitMetrics,\n} from '../metrics.js';\nimport { normalize } from '../affordance-normalizer.js';\nimport { scoreDerivedLane } from './lanes/derived.js';\nimport { scoreExplicitLane } from './lanes/explicit.js';\nimport { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\nimport { scoreLexicalLane } from './lanes/lexical.js';\nimport { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor 5-Lane Fusion\n// ───────────────────────────────────────────────────────────────\n\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nimport { applyAmbiguity, isAmbiguousTopTwo } from './ambiguity.js';\nimport { attributionReason, dominantLane, isDerivedDominant } from './attribution.js';\nimport {\n  ADVISOR_HOOK_FRESHNESS_VALUES,\n  ADVISOR_RUNTIME_VALUES,\n  isSpeckitMetricsEnabled,\n  speckitMetrics,\n} from '../metrics.js';\nimport { normalize } from '../affordance-normalizer.js';\nimport { scoreDerivedLane } from './lanes/derived.js';\nimport { scoreExplicitLane } from './lanes/explicit.js';\nimport { scoreGraphCausalLaneSplit } from './lanes/graph-causal.js';\nimport { scoreLexicalLane } from './lanes/lexical.js';\nimport { scoreSemanticShadowExactSubset, scoreSemanticShadowLane } from './lanes/semantic-shadow.js';\nimport { applyExecutorDelegationOverride } from './executor-delegation.js';\nimport { loadAdvisorProjection } from './projection.js';\nimport { SCORING_CALIBRATION } from './scoring-constants.js';\nimport { isReadOnlyExplainer, matchesPhraseBoundary } from './text.js';\nimport {\n  DEFAULT_SCORER_WEIGHTS,\n  SCORER_LANES,\n  liveWeightTotal,\n} from './weights-config.js';\nimport { isLiveScorerLane } from './lane-registry.js';\nimport { SKILL_ADVISOR_COMPAT_CONTRACT, resolvedConfidenceThreshold, resolvedUncertaintyThreshold } from '../compat/contract.js';\nimport type {\n  AdvisorProjection,\n  AdvisorScoredRecommendation,\n  AdvisorScoringOptions,\n  AdvisorScoringResult,\n  LaneContribution,\n  LaneMatch,\n  LaneRuntimeHealth,\n  LaneScores,\n  ScorerLane,\n  SkillProjection,\n} from './types.js';\nimport type { NormalizedAffordance } from '../affordance-normalizer.js';\nimport type { RankedList, RrfItem } from '@spec-kit/shared/algorithms/rrf-fusion.js';\n\nconst DEFAULT_CONFIDENCE_THRESHOLD = resolvedConfidenceThreshold();\nconst DEFAULT_UNCERTAINTY_THRESHOLD = resolvedUncertaintyThreshold();\nexport const ADVISOR_RRF_FUSION_FLAG = 'SPECKIT_ADVISOR_RRF_FUSION';\nexport const ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG = 'SPECKIT_ADVISOR_SELF_RECOMMENDATION_GUARD';\nexport const ADVISOR_QUERY_CLASS_ROUTING_FLAG = 'SPECKIT_ADVISOR_QUERY_CLASS_ROUTING';\nexport const ADVISOR_EXACT_SEMANTIC_RERANK_FLAG = 'SPECKIT_ADVISOR_EXACT_SEMANTIC_RERANK';\nexport const ADVISOR_RRF_K = 8;\nexport const ADVISOR_EXACT_SEMANTIC_RERANK_TOP_K = 10;\nconst ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW = 0.05;\nconst TASK_INTENT = /\\b(add|append|build|change|configure|create|edit|fix|generate|implement|modify|move|patch|refactor|rename|replace|run|start|sweep|update|write)\\b/;\nconst DEEP_RESEARCH_CYCLE = /\\b(automated research cycle|looped investigation|continue iteration|resume iteration|overnight run|overnight research run|packet-local iteration|delta record|canonical jsonl|same lineage)\\b/;\nconst FILE_SAVE_OPERATION = /\\bsave\\b.{0,48}\\b(file|files|document|documents|buffer|tab|workspace)\\b|\\b(file|files|document|documents|buffer|tab|workspace)\\b.{0,48}\\bsave\\b/;\nconst MEMORY_SAVE_CONTEXT_ANCHOR = /\\b(memory|context|conversation|session|handover|checkpoint|resume|preserve|remember|capture|store)\\b|\\/memory:save|memory:save/;\n// Class C breadth/multi-concern abstention gates. A broad greenfield build or a\n// multi-concern optimization is under-specified for single-skill routing.\nconst BREADTH_BUILD_VERB = /\\b(build|create|implement|generate|scaffold)\\b/;\nconst BREADTH_NOUN = /\\b(full[- ]?stack|service|platform|application|microservice|saas|backend|whole (app|system))\\b/;\n// Narrow anchors that make a broad-build prompt specific enough to route.\nconst BREADTH_NARROW_ANCHOR = /\\.[a-z]{2,4}\\b|\\b(test|tests|error|bug|failure|failing|handler|component|function|route|endpoint|class|method|benchmark|review|audit|migration|schema)\\b/;\nconst MULTI_CONCERN_VERB = /\\b(optimize|improve|enhance|harden|speed up)\\b/;\nconst CONCERN_PERF = /\\b(speed|latency|execution|throughput|performance|startup|memory|cpu)\\b/;\nconst CONCERN_QUALITY = /\\b(quality|accuracy|recommendation|recommendations|correctness|reliability|coverage)\\b/;\nconst TRUE_FLAG_VALUES = new Set(['1', 'true', 'yes', 'on', 'enabled']);\nconst NO_RRF_RANK = Number.MAX_SAFE_INTEGER;\nconst ADVISOR_SELF_RECOMMENDATION_SKILL_IDS = new Set(['system-skill-advisor', 'skill-advisor']);\n\ntype MutableLaneScores = {\n  -readonly [K in keyof LaneScores]: LaneMatch[];\n};\n\ninterface LaneScoreBundle {\n  readonly laneScores: LaneScores;\n  readonly graphConflictMatches: readonly LaneMatch[];\n}\n\ninterface AdvisorRrfFusion {\n  readonly scoreBySkill: ReadonlyMap<string, number>;\n  readonly rankBySkill: ReadonlyMap<string, number>;\n}\n\ntype AdvisorRuntimeLabel = (typeof ADVISOR_RUNTIME_VALUES)[number];\ntype AdvisorFreshnessLabel = (typeof ADVISOR_HOOK_FRESHNESS_VALUES)[number];\nexport type AdvisorQueryClass = 'implementation' | 'review' | 'documentation' | 'memory' | 'tooling' | 'unknown';\n\ninterface ExactSemanticRerankEntry {\n  readonly rawScore: number;\n}\n\ntype ExactSemanticRerankIndex = ReadonlyMap<string, ExactSemanticRerankEntry>;\n\nfunction emptyLaneScores(): MutableLaneScores {\n  return Object.fromEntries(SCORER_LANES.map((lane) => [lane, []])) as unknown as MutableLaneScores;\n}\n\nexport function isAdvisorRrfFusionEnabled(): boolean {\n  const value = process.env[ADVISOR_RRF_FUSION_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorSelfRecommendationGuardEnabled(): boolean {\n  const value = process.env[ADVISOR_SELF_RECOMMENDATION_GUARD_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorQueryClassRoutingEnabled(): boolean {\n  const value = process.env[ADVISOR_QUERY_CLASS_ROUTING_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function isAdvisorExactSemanticRerankEnabled(): boolean {\n  const value = process.env[ADVISOR_EXACT_SEMANTIC_RERANK_FLAG]?.trim().toLowerCase();\n  return value ? TRUE_FLAG_VALUES.has(value) : false;\n}\n\nexport function classifyAdvisorQuery(prompt: string): AdvisorQueryClass {\n  const promptLower = prompt.toLowerCase();\n  if (/\\b(save context|save memory|handover|resume|checkpoint|spec folder|implementation summary|packet docs?)\\b/.test(promptLower)) {\n    return 'memory';\n  }\n  if (/\\b(review|audit|findings|regression|pull request|pr readiness|release readiness)\\b/.test(promptLower)) {\n    return 'review';\n  }\n  if (/\\b(readme|markdown|documentation|docs|manual testing playbook|feature catalog|taxonomy)\\b/.test(promptLower)) {\n    return 'documentation';\n  }\n  if (/\\b(call_tool_chain|code mode|tool ?chain|chrome devtools|browser console|figma|github|clickup)\\b/.test(promptLower)) {\n    return 'tooling';\n  }\n  if (TASK_INTENT.test(promptLower) || /\\b(typescript|javascript|python|vitest|mcp|handler|schema|fixture)\\b/.test(promptLower)) {\n    return 'implementation';\n  }\n  return 'unknown';\n}\n\nexport function queryClassLaneMultipliers(queryClass: AdvisorQueryClass): Readonly<Partial<Record<ScorerLane, number>>> {\n  switch (queryClass) {\n    case 'implementation':\n      return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.98, semantic_shadow: 1.00 };\n    case 'review':\n      return { explicit_author: 1.03, lexical: 1.02, graph_causal: 0.96, derived_generated: 0.98, semantic_shadow: 1.00 };\n    case 'documentation':\n      return { explicit_author: 1.03, lexical: 0.98, graph_causal: 0.95, derived_generated: 1.04, semantic_shadow: 1.00 };\n    case 'memory':\n      return { explicit_author: 1.04, lexical: 0.98, graph_causal: 1.02, derived_generated: 1.00, semantic_shadow: 0.96 };\n    case 'tooling':\n      return { explicit_author: 1.04, lexical: 1.00, graph_causal: 0.98, derived_generated: 0.96, semantic_shadow: 1.00 };\n    case 'unknown':\n      return {};\n  }\n}\n\nexport function applyQueryClassLaneMultipliers(\n  weights: Readonly<Record<ScorerLane, number>>,\n  queryClass: AdvisorQueryClass,\n): Readonly<Record<ScorerLane, number>> {\n  const multipliers = queryClassLaneMultipliers(queryClass);\n  if (Object.keys(multipliers).length === 0) return weights;\n  const next = { ...weights };\n  for (const lane of SCORER_LANES) {\n    const multiplier = multipliers[lane];\n    if (typeof multiplier === 'number' && Number.isFinite(multiplier)) {\n      next[lane] = Number((next[lane] * multiplier).toFixed(6));\n    }\n  }\n  const strongestOther = Math.max(...SCORER_LANES\n    .filter((lane) => lane !== 'explicit_author')\n    .map((lane) => next[lane]));\n  if (next.explicit_author < strongestOther) {\n    next.explicit_author = Number(strongestOther.toFixed(6));\n  }\n  return next;\n}\n\nfunction effectiveScorerWeights(\n  override: AdvisorScoringOptions['laneWeightsOverride'] | undefined,\n  queryClass: AdvisorQueryClass = 'unknown',\n): Readonly<Record<ScorerLane, number>> {\n  const base = !override ? DEFAULT_SCORER_WEIGHTS : (() => {\n    const weights: Record<ScorerLane, number> = { ...DEFAULT_SCORER_WEIGHTS };\n    const runtimeOverride = override as Partial<Record<string, number>>;\n    for (const lane of SCORER_LANES) {\n      const value = runtimeOverride[lane];\n      if (typeof value === 'number' && Number.isFinite(value)) {\n        weights[lane] = value;\n      }\n    }\n    return weights;\n  })();\n  if (queryClass === 'unknown') return base;\n  return applyQueryClassLaneMultipliers(base, queryClass);\n}\n\nfunction normalizeRuntimeLabel(value: string | undefined): AdvisorRuntimeLabel | null {\n  if (value === undefined) {\n    return null;\n  }\n  return ADVISOR_RUNTIME_VALUES.includes(value as AdvisorRuntimeLabel) ? value as AdvisorRuntimeLabel : null;\n}\n\nfunction normalizeFreshnessLabel(value: string | undefined): AdvisorFreshnessLabel | null {\n  if (value === undefined) {\n    return 'unavailable';\n  }\n  return ADVISOR_HOOK_FRESHNESS_VALUES.includes(value as AdvisorFreshnessLabel) ? value as AdvisorFreshnessLabel : null;\n}\n\ninterface LaneMatchIndexEntry {\n  rawScore: number;\n  evidence: string[];\n  producerSkillIds: string[];\n}\n\ntype LaneMatchIndex = Map<string, LaneMatchIndexEntry>;\n\nfunction buildLaneRuntimeHealth(\n  laneScores: LaneScores,\n  disabled: ReadonlySet<ScorerLane>,\n  runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n): readonly LaneRuntimeHealth[] {\n  return SCORER_LANES.map((lane): LaneRuntimeHealth => {\n    const matchCount = laneScores[lane].length;\n    const signal = runtimeLaneHealth?.[lane];\n    if (!disabled.has(lane) && signal?.status === 'runtime_degraded' && matchCount === 0) {\n      return {\n        lane,\n        status: 'runtime_degraded',\n        matchCount,\n        ...(signal.reason ? { reason: signal.reason } : {}),\n      };\n    }\n    return {\n      lane,\n      status: matchCount > 0 ? 'healthy' : 'matched_nothing',\n      matchCount,\n      ...(signal?.reason && signal.status === 'healthy' ? { reason: signal.reason } : {}),\n    };\n  });\n}\n\nfunction projectionRuntimeLaneHealth(\n  projection: AdvisorProjection,\n  runtimeLaneHealth: AdvisorScoringOptions['runtimeLaneHealth'] | undefined,\n): AdvisorScoringOptions['runtimeLaneHealth'] | undefined {\n  if (!projection.embeddingStaleness?.stale) {\n    return runtimeLaneHealth;\n  }\n  return {\n    ...runtimeLaneHealth,\n    semantic_shadow: runtimeLaneHealth?.semantic_shadow ?? {\n      status: 'runtime_degraded',\n      reason: projection.embeddingStaleness.reason ?? 'projection_embedding_stale',\n    },\n  };\n}\n\nfunction degradedLaneReason(degradedLanes: readonly ScorerLane[]): string | null {\n  if (degradedLanes.length === 0) return null;\n  return `Runtime-degraded scorer lanes omitted from confidence normalization: ${degradedLanes.join(', ')}.`;\n}\n\nfunction buildLaneMatchIndex(matches: readonly LaneMatch[]): LaneMatchIndex {\n  const index: LaneMatchIndex = new Map();\n  for (const match of matches) {\n    const existing = index.get(match.skillId) ?? { rawScore: 0, evidence: [], producerSkillIds: [] };\n    existing.rawScore = Math.max(existing.rawScore, match.score);\n    if (existing.evidence.length < 6) {\n      existing.evidence.push(...match.evidence.slice(0, 6 - existing.evidence.length));\n    }\n    for (const producerSkillId of match.producerSkillIds ?? []) {\n      if (!existing.producerSkillIds.includes(producerSkillId)) {\n        existing.producerSkillIds.push(producerSkillId);\n      }\n    }\n    index.set(match.skillId, existing);","lineStart":1,"lineEnd":280,"totalLines":911,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1783437204936,"end":1783437204945}},"metadata":{"openai":{"itemId":"fc_093d4b70614d3caf016a4d1794d5c4819195c0476579de6b5d"}},"id":"prt_f3d241dc5001aVI3vvFOwQR668","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d23eb48001Teq8BrJ3T5JLlh"}}
{"type":"tool_use","timestamp":1783437204960,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_7xnoRQ4bhhtRDCqi0tutb2P5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Skill Projection\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { existsSync, readFileSync, readdirSync } from 'node:fs';\n6: import { dirname, isAbsolute, join, resolve } from 'node:path';\n7: \n8: import Database from 'better-sqlite3';\n9: \n10: import { getManifest } from '../embedders/registry.js';\n11: import type { BackendKind } from '../embedders/types.js';\n12: import { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\n13: import { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\n14: import { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\n15: import { providerModelId } from '../skill-graph/skill-graph-db.js';\n16: import { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\n17: import { parseSkillFrontmatter } from '../utils/skill-markdown.js';\n18: import type {\n19:   AdvisorEmbeddingSignature,\n20:   AdvisorEmbeddingStalenessVerdict,\n21:   AdvisorProjection,\n22:   SkillDocTriggerProjection,\n23:   SkillEdgeProjection,\n24:   SkillLifecycleStatus,\n25:   SkillProjection,\n26: } from './types.js';\n27: import { phraseVariants, unique } from './text.js';\n28: \n29: interface SkillNodeRow {\n30:   readonly id: string;\n31:   readonly family: string;\n32:   readonly category: string;\n33:   readonly domains: string | null;\n34:   readonly intent_signals: string | null;\n35:   readonly derived: string | null;\n36:   readonly source_path: string;\n37: }\n38: \n39: interface SkillEdgeRow {\n40:   readonly source_id: string;\n41:   readonly target_id: string;\n42:   readonly edge_type: SkillEdgeProjection['edgeType'];\n43:   readonly weight: number;\n44:   readonly context: string;\n45: }\n46: \n47: interface SkillMarkdownMetadata {\n48:   readonly name: string;\n49:   readonly description: string;\n50:   readonly keywords: readonly string[];\n51: }\n52: \n53: const advisorDbDirOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\n54: const SKILL_GRAPH_DB = advisorDbDirOverride\n55:   ? join(advisorDbDirOverride, 'skill-graph.sqlite')\n56:   : join('.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database', 'skill-graph.sqlite');\n57: \n58: const COMMAND_BRIDGES: readonly SkillProjection[] = [\n59:   {\n60:     id: 'command-spec-kit',\n61:     kind: 'command',\n62:     family: 'system',\n63:     category: 'command',\n64:     name: 'command-spec-kit',\n65:     description: 'Spec Kit command bridge for /spec_kit workflows.',\n66:     keywords: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n67:     domains: ['spec-kit', 'command'],\n68:     intentSignals: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n69:     derivedTriggers: [],\n70:     derivedKeywords: [],\n71:     sourcePath: null,\n72:     lifecycleStatus: 'active',\n73:   },\n74:   {\n75:     id: 'memory:save',\n76:     kind: 'command',\n77:     family: 'system',\n78:     category: 'command',\n79:     name: 'memory:save',\n80:     description: 'Memory save command bridge for /memory:save context preservation.',\n81:     keywords: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n82:     domains: ['memory', 'command'],\n83:     intentSignals: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n84:     derivedTriggers: [],\n85:     derivedKeywords: [],\n86:     sourcePath: null,\n87:     lifecycleStatus: 'active',\n88:   },\n89:   {\n90:     id: 'command-memory-save',\n91:     kind: 'command',\n92:     family: 'system',\n93:     category: 'command',\n94:     name: 'command-memory-save',\n95:     description: 'Memory save command bridge for /memory:save context preservation.',\n96:     keywords: ['/memory:save', 'save context', 'save memory'],\n97:     domains: ['memory', 'command'],\n98:     intentSignals: ['/memory:save', 'save context', 'save memory'],\n99:     derivedTriggers: [],\n100:     derivedKeywords: [],\n101:     sourcePath: null,\n102:     lifecycleStatus: 'active',\n103:   },\n104:   {\n105:     id: 'create:agent',\n106:     kind: 'command',\n107:     family: 'system',\n108:     category: 'command',\n109:     name: 'create:agent',\n110:     description: 'Create command bridge for /create:agent OpenCode agent scaffolding.',\n111:     keywords: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n112:     domains: ['create', 'agent', 'command'],\n113:     intentSignals: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n114:     derivedTriggers: [],\n115:     derivedKeywords: [],\n116:     sourcePath: null,\n117:     lifecycleStatus: 'active',\n118:   },\n119:   {\n120:     id: 'create:manual-testing-playbook',\n121:     kind: 'command',\n122:     family: 'system',\n123:     category: 'command',\n124:     name: 'create:manual-testing-playbook',\n125:     description: 'Create command bridge for /create:manual-testing-playbook manual testing playbook scaffolding.',\n126:     keywords: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n127:     domains: ['create', 'testing', 'playbook', 'command'],\n128:     intentSignals: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n129:     derivedTriggers: [],\n130:     derivedKeywords: [],\n131:     sourcePath: null,\n132:     lifecycleStatus: 'active',\n133:   },\n134:   {\n135:     id: 'deep-model-benchmark',\n136:     kind: 'command',\n137:     family: 'system',\n138:     category: 'command',\n139:     name: 'deep-model-benchmark',\n140:     description: 'Deep command bridge for /deep:start-model-benchmark-loop model and prompt-framework benchmarking.',\n141:     keywords: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n142:     domains: ['deep', 'benchmark', 'model', 'command'],\n143:     intentSignals: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n144:     derivedTriggers: [],\n145:     derivedKeywords: [],\n146:     sourcePath: null,\n147:     lifecycleStatus: 'active',\n148:   },\n149: ];\n150: \n151: function jsonArray(value: string | null | undefined): string[] {\n152:   return value ? parseJsonStringArray(value) : [];\n153: }\n154: \n155: function jsonObject(value: string | null | undefined): Record<string, unknown> {\n156:   return value ? parseJsonObject(value) ?? {} : {};\n157: }\n158: \n159: function stringArray(value: unknown): string[] {\n160:   return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n161: }\n162: \n163: function boundedDemotion(value: unknown): number | undefined {\n164:   return typeof value === 'number' && Number.isFinite(value)\n165:     ? Math.max(0, Math.min(1, value))\n166:     : undefined;\n167: }\n168: \n169: function readJson(filePath: string): Record<string, unknown> {\n170:   return readJsonObject(filePath) ?? {};\n171: }\n172: \n173: function parseSkillMarkdown(skillMdPath: string, fallbackId: string): SkillMarkdownMetadata {\n174:   if (!existsSync(skillMdPath)) {\n175:     return { name: fallbackId, description: '', keywords: [] };\n176:   }\n177:   const { frontmatter, keywords } = parseSkillFrontmatter(readFileSync(skillMdPath, 'utf8'));\n178:   return {\n179:     name: frontmatter.name || fallbackId,\n180:     description: frontmatter.description || '',\n181:     keywords,\n182:   };\n183: }\n184: \n185: function lifecycleStatus(raw: unknown, sourcePath: string): SkillLifecycleStatus {\n186:   if (raw === 'deprecated' || raw === 'archived' || raw === 'future' || raw === 'active') return raw;\n187:   const pathStatus = lifecycleStatusForPath(sourcePath);\n188:   return pathStatus === 'archived' || pathStatus === 'future' ? pathStatus : 'active';\n189: }\n190: \n191: function projectionFromRow(row: SkillNodeRow): SkillProjection {\n192:   const derived = sanitizeDerivedMetadata(jsonObject(row.derived), row.source_path) ?? {};\n193:   const graphMetadata = readJson(row.source_path);\n194:   const skillDir = dirname(row.source_path);\n195:   const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), row.id);\n196:   const lifecycle = lifecycleStatus(\n197:     graphMetadata.lifecycle_status ?? derived.lifecycle_status,\n198:     row.source_path,\n199:   );\n200:   const redirectTo = typeof graphMetadata.redirect_to === 'string'\n201:     ? graphMetadata.redirect_to\n202:     : (typeof derived.redirect_to === 'string' ? derived.redirect_to : null);\n203:   const redirectFrom = stringArray(graphMetadata.redirect_from ?? derived.redirect_from);\n204:   // Distinguish derivedTriggers (intent-shaped phrases) from\n205:   // derivedKeywords (entity-shaped concepts). Previously both fields were\n206:   // assigned the same array (value-by-reference), which double-counted the\n207:   // same evidence into two scoring inputs. Triggers now come from\n208:   // `derived.trigger_phrases` only; keywords come from `derived.key_topics`\n209:   // + `derived.entities` + `derived.key_files` + `derived.source_docs`. Each\n210:   // pipeline still passes through `phraseVariants` and `unique`. The two\n211:   // arrays may overlap when authors duplicate entries, but they are no longer\n212:   // assigned the same value-by-reference.\n213:   const derivedTriggers = unique(\n214:     stringArray(derived.trigger_phrases).flatMap((entry) => phraseVariants(entry)),\n215:   );\n216:   const derivedKeywords = unique([\n217:     ...stringArray(derived.key_topics),\n218:     ...stringArray(derived.entities),\n219:     ...stringArray(derived.key_files),\n220:     ...stringArray(derived.source_docs),\n221:   ].flatMap((entry) => phraseVariants(entry)));\n222: \n223:   return {\n224:     id: row.id,\n225:     kind: 'skill',\n226:     family: row.family,\n227:     category: row.category,\n228:     name: skillMd.name,\n229:     description: skillMd.description,\n230:     keywords: unique(skillMd.keywords.flatMap((entry) => phraseVariants(entry))),\n231:     domains: unique(sanitizeMetadataStringArray(jsonArray(row.domains), row.source_path).flatMap((entry) => phraseVariants(entry))),\n232:     intentSignals: unique(sanitizeMetadataStringArray(jsonArray(row.intent_signals), row.source_path).flatMap((entry) => phraseVariants(entry))),\n233:     derivedTriggers,\n234:     derivedKeywords,\n235:     derivedDemotion: boundedDemotion(derived.demotion),\n236:     // V2 derived sync stamps generated_at (the canonical author/sync time of\n237:     // the derived block); older shapes carried last_updated_at/created_at.\n238:     // generated_at leads the chain so a V2 block's real freshness wins over a\n239:     // stray legacy field. This value is AUTHOR-TIME, not runtime: rebuild\n240:     // re-indexes the existing block without re-stamping it; only a\n241:     // derived-content change through sync re-stamps generated_at.\n242:     derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n243:     sourcePath: row.source_path,\n244:     lifecycleStatus: lifecycle,\n245:     redirectTo,\n246:     redirectFrom,\n247:   };\n248: }\n249: \n250: function isoTimestampOrNull(value: unknown): string | null {\n251:   if (typeof value !== 'string' || value.trim().length === 0) return null;\n252:   return Number.isNaN(Date.parse(value)) ? null : value;\n253: }\n254: \n255: interface SkillDocRow {\n256:   readonly skill_id: string;\n257:   readonly doc_path: string;\n258:   readonly trigger_phrases: string;\n259:   readonly importance_tier: string | null;\n260: }\n261: \n262: interface MetadataRow {\n263:   readonly key: string;\n264:   readonly value: string;\n265: }\n266: \n267: interface TableNameRow {\n268:   readonly name: string;\n269: }\n270: \n271: interface EmbeddingModelRow {\n272:   readonly model_id: string | null;\n273: }\n274: \n275: interface StoredEmbeddingSummary {\n276:   readonly vectorCount: number;\n277:   readonly missingModelCount: number;\n278:   readonly modelIds: readonly string[];\n279:   readonly dim: number | null;\n280: }\n281: \n282: interface ActiveEmbeddingPointer {\n283:   readonly name: string;\n284:   readonly dim: number;\n285:   readonly provider: string | null;\n286: }\n287: \n288: const ACTIVE_EMBEDDER_NAME_KEY = 'active_embedder_name';\n289: const ACTIVE_EMBEDDER_DIM_KEY = 'active_embedder_dim';\n290: const ACTIVE_EMBEDDER_PROVIDER_KEY = 'active_embedder_provider';\n291: \n292: function sqliteTableExists(db: Database.Database, tableName: string): boolean {\n293:   const row = db.prepare(`\n294:     SELECT 1 AS present\n295:     FROM sqlite_master\n296:     WHERE type = 'table' AND name = ?\n297:     LIMIT 1\n298:   `).get(tableName) as { present: number } | undefined;\n299:   return Boolean(row);\n300: }\n301: \n302: function readMetadataMap(db: Database.Database): Map<string, string> {\n303:   if (!sqliteTableExists(db, 'vec_metadata')) return new Map();\n304:   const rows = db.prepare(`\n305:     SELECT key, value\n306:     FROM vec_metadata\n307:     WHERE key IN (?, ?, ?)\n308:   `).all(ACTIVE_EMBEDDER_NAME_KEY, ACTIVE_EMBEDDER_DIM_KEY, ACTIVE_EMBEDDER_PROVIDER_KEY) as MetadataRow[];\n309:   return new Map(rows.map((row) => [row.key, row.value]));\n310: }\n311: \n312: function providerForBackend(backend: BackendKind | undefined): string | null {\n313:   switch (backend) {\n314:     case 'ollama':\n315:       return 'ollama';\n316:     case 'api':\n317:       return 'openai';\n318:     case 'sentence-transformers':\n319:       return 'hf-local';\n320:     default:\n\n(Showing lines 1-320 of 733. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Skill Projection\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, readdirSync } from 'node:fs';\nimport { dirname, isAbsolute, join, resolve } from 'node:path';\n\nimport Database from 'better-sqlite3';\n\nimport { getManifest } from '../embedders/registry.js';\nimport type { BackendKind } from '../embedders/types.js';\nimport { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\nimport { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\nimport { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\nimport { providerModelId } from '../skill-graph/skill-graph-db.js';\nimport { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\nimport { parseSkillFrontmatter } from '../utils/skill-markdown.js';\nimport type {\n  AdvisorEmbeddingSignature,\n  AdvisorEmbeddingStalenessVerdict,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Skill Projection\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, readdirSync } from 'node:fs';\nimport { dirname, isAbsolute, join, resolve } from 'node:path';\n\nimport Database from 'better-sqlite3';\n\nimport { getManifest } from '../embedders/registry.js';\nimport type { BackendKind } from '../embedders/types.js';\nimport { lifecycleStatusForPath } from '../lifecycle/archive-handling.js';\nimport { sanitizeDerivedMetadata, sanitizeMetadataStringArray } from '../skill-graph/metadata-sanitizer.js';\nimport { docTierWeight, isDocTriggerHarvestEnabled } from '../skill-graph/doc-frontmatter.js';\nimport { providerModelId } from '../skill-graph/skill-graph-db.js';\nimport { parseJsonObject, parseJsonStringArray, readJsonObject } from '../utils/json-guard.js';\nimport { parseSkillFrontmatter } from '../utils/skill-markdown.js';\nimport type {\n  AdvisorEmbeddingSignature,\n  AdvisorEmbeddingStalenessVerdict,\n  AdvisorProjection,\n  SkillDocTriggerProjection,\n  SkillEdgeProjection,\n  SkillLifecycleStatus,\n  SkillProjection,\n} from './types.js';\nimport { phraseVariants, unique } from './text.js';\n\ninterface SkillNodeRow {\n  readonly id: string;\n  readonly family: string;\n  readonly category: string;\n  readonly domains: string | null;\n  readonly intent_signals: string | null;\n  readonly derived: string | null;\n  readonly source_path: string;\n}\n\ninterface SkillEdgeRow {\n  readonly source_id: string;\n  readonly target_id: string;\n  readonly edge_type: SkillEdgeProjection['edgeType'];\n  readonly weight: number;\n  readonly context: string;\n}\n\ninterface SkillMarkdownMetadata {\n  readonly name: string;\n  readonly description: string;\n  readonly keywords: readonly string[];\n}\n\nconst advisorDbDirOverride = process.env.MK_SKILL_ADVISOR_DB_DIR ?? process.env.SYSTEM_SKILL_ADVISOR_DB_DIR;\nconst SKILL_GRAPH_DB = advisorDbDirOverride\n  ? join(advisorDbDirOverride, 'skill-graph.sqlite')\n  : join('.opencode', 'skills', 'system-skill-advisor', 'mcp_server', 'database', 'skill-graph.sqlite');\n\nconst COMMAND_BRIDGES: readonly SkillProjection[] = [\n  {\n    id: 'command-spec-kit',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'command-spec-kit',\n    description: 'Spec Kit command bridge for /spec_kit workflows.',\n    keywords: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n    domains: ['spec-kit', 'command'],\n    intentSignals: ['/speckit:plan', '/speckit:resume', '/deep:start-research-loop', '/deep:start-review-loop'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'memory:save',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'memory:save',\n    description: 'Memory save command bridge for /memory:save context preservation.',\n    keywords: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n    domains: ['memory', 'command'],\n    intentSignals: ['/memory:save', 'save context', 'save memory', 'preserve session context'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'command-memory-save',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'command-memory-save',\n    description: 'Memory save command bridge for /memory:save context preservation.',\n    keywords: ['/memory:save', 'save context', 'save memory'],\n    domains: ['memory', 'command'],\n    intentSignals: ['/memory:save', 'save context', 'save memory'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'create:agent',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'create:agent',\n    description: 'Create command bridge for /create:agent OpenCode agent scaffolding.',\n    keywords: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n    domains: ['create', 'agent', 'command'],\n    intentSignals: ['/create:agent', 'create new agent', 'create agent', 'new agent', 'make new agent'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'create:manual-testing-playbook',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'create:manual-testing-playbook',\n    description: 'Create command bridge for /create:manual-testing-playbook manual testing playbook scaffolding.',\n    keywords: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n    domains: ['create', 'testing', 'playbook', 'command'],\n    intentSignals: ['/create:manual-testing-playbook', 'create testing playbook', 'create test playbook', 'testing playbook'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n  {\n    id: 'deep-model-benchmark',\n    kind: 'command',\n    family: 'system',\n    category: 'command',\n    name: 'deep-model-benchmark',\n    description: 'Deep command bridge for /deep:start-model-benchmark-loop model and prompt-framework benchmarking.',\n    keywords: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n    domains: ['deep', 'benchmark', 'model', 'command'],\n    intentSignals: ['/deep:start-model-benchmark-loop', 'benchmark a model', 'benchmark a prompt framework', 'optimize a model', 'model benchmark loop'],\n    derivedTriggers: [],\n    derivedKeywords: [],\n    sourcePath: null,\n    lifecycleStatus: 'active',\n  },\n];\n\nfunction jsonArray(value: string | null | undefined): string[] {\n  return value ? parseJsonStringArray(value) : [];\n}\n\nfunction jsonObject(value: string | null | undefined): Record<string, unknown> {\n  return value ? parseJsonObject(value) ?? {} : {};\n}\n\nfunction stringArray(value: unknown): string[] {\n  return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n}\n\nfunction boundedDemotion(value: unknown): number | undefined {\n  return typeof value === 'number' && Number.isFinite(value)\n    ? Math.max(0, Math.min(1, value))\n    : undefined;\n}\n\nfunction readJson(filePath: string): Record<string, unknown> {\n  return readJsonObject(filePath) ?? {};\n}\n\nfunction parseSkillMarkdown(skillMdPath: string, fallbackId: string): SkillMarkdownMetadata {\n  if (!existsSync(skillMdPath)) {\n    return { name: fallbackId, description: '', keywords: [] };\n  }\n  const { frontmatter, keywords } = parseSkillFrontmatter(readFileSync(skillMdPath, 'utf8'));\n  return {\n    name: frontmatter.name || fallbackId,\n    description: frontmatter.description || '',\n    keywords,\n  };\n}\n\nfunction lifecycleStatus(raw: unknown, sourcePath: string): SkillLifecycleStatus {\n  if (raw === 'deprecated' || raw === 'archived' || raw === 'future' || raw === 'active') return raw;\n  const pathStatus = lifecycleStatusForPath(sourcePath);\n  return pathStatus === 'archived' || pathStatus === 'future' ? pathStatus : 'active';\n}\n\nfunction projectionFromRow(row: SkillNodeRow): SkillProjection {\n  const derived = sanitizeDerivedMetadata(jsonObject(row.derived), row.source_path) ?? {};\n  const graphMetadata = readJson(row.source_path);\n  const skillDir = dirname(row.source_path);\n  const skillMd = parseSkillMarkdown(join(skillDir, 'SKILL.md'), row.id);\n  const lifecycle = lifecycleStatus(\n    graphMetadata.lifecycle_status ?? derived.lifecycle_status,\n    row.source_path,\n  );\n  const redirectTo = typeof graphMetadata.redirect_to === 'string'\n    ? graphMetadata.redirect_to\n    : (typeof derived.redirect_to === 'string' ? derived.redirect_to : null);\n  const redirectFrom = stringArray(graphMetadata.redirect_from ?? derived.redirect_from);\n  // Distinguish derivedTriggers (intent-shaped phrases) from\n  // derivedKeywords (entity-shaped concepts). Previously both fields were\n  // assigned the same array (value-by-reference), which double-counted the\n  // same evidence into two scoring inputs. Triggers now come from\n  // `derived.trigger_phrases` only; keywords come from `derived.key_topics`\n  // + `derived.entities` + `derived.key_files` + `derived.source_docs`. Each\n  // pipeline still passes through `phraseVariants` and `unique`. The two\n  // arrays may overlap when authors duplicate entries, but they are no longer\n  // assigned the same value-by-reference.\n  const derivedTriggers = unique(\n    stringArray(derived.trigger_phrases).flatMap((entry) => phraseVariants(entry)),\n  );\n  const derivedKeywords = unique([\n    ...stringArray(derived.key_topics),\n    ...stringArray(derived.entities),\n    ...stringArray(derived.key_files),\n    ...stringArray(derived.source_docs),\n  ].flatMap((entry) => phraseVariants(entry)));\n\n  return {\n    id: row.id,\n    kind: 'skill',\n    family: row.family,\n    category: row.category,\n    name: skillMd.name,\n    description: skillMd.description,\n    keywords: unique(skillMd.keywords.flatMap((entry) => phraseVariants(entry))),\n    domains: unique(sanitizeMetadataStringArray(jsonArray(row.domains), row.source_path).flatMap((entry) => phraseVariants(entry))),\n    intentSignals: unique(sanitizeMetadataStringArray(jsonArray(row.intent_signals), row.source_path).flatMap((entry) => phraseVariants(entry))),\n    derivedTriggers,\n    derivedKeywords,\n    derivedDemotion: boundedDemotion(derived.demotion),\n    // V2 derived sync stamps generated_at (the canonical author/sync time of\n    // the derived block); older shapes carried last_updated_at/created_at.\n    // generated_at leads the chain so a V2 block's real freshness wins over a\n    // stray legacy field. This value is AUTHOR-TIME, not runtime: rebuild\n    // re-indexes the existing block without re-stamping it; only a\n    // derived-content change through sync re-stamps generated_at.\n    derivedGeneratedAt: isoTimestampOrNull(derived.generated_at ?? derived.last_updated_at ?? derived.created_at),\n    sourcePath: row.source_path,\n    lifecycleStatus: lifecycle,\n    redirectTo,\n    redirectFrom,\n  };\n}\n\nfunction isoTimestampOrNull(value: unknown): string | null {\n  if (typeof value !== 'string' || value.trim().length === 0) return null;\n  return Number.isNaN(Date.parse(value)) ? null : value;\n}\n\ninterface SkillDocRow {\n  readonly skill_id: string;\n  readonly doc_path: string;\n  readonly trigger_phrases: string;\n  readonly importance_tier: string | null;\n}\n\ninterface MetadataRow {\n  readonly key: string;\n  readonly value: string;\n}\n\ninterface TableNameRow {\n  readonly name: string;\n}\n\ninterface EmbeddingModelRow {\n  readonly model_id: string | null;\n}\n\ninterface StoredEmbeddingSummary {\n  readonly vectorCount: number;\n  readonly missingModelCount: number;\n  readonly modelIds: readonly string[];\n  readonly dim: number | null;\n}\n\ninterface ActiveEmbeddingPointer {\n  readonly name: string;\n  readonly dim: number;\n  readonly provider: string | null;\n}\n\nconst ACTIVE_EMBEDDER_NAME_KEY = 'active_embedder_name';\nconst ACTIVE_EMBEDDER_DIM_KEY = 'active_embedder_dim';\nconst ACTIVE_EMBEDDER_PROVIDER_KEY = 'active_embedder_provider';\n\nfunction sqliteTableExists(db: Database.Database, tableName: string): boolean {\n  const row = db.prepare(`\n    SELECT 1 AS present\n    FROM sqlite_master\n    WHERE type = 'table' AND name = ?\n    LIMIT 1\n  `).get(tableName) as { present: number } | undefined;\n  return Boolean(row);\n}\n\nfunction readMetadataMap(db: Database.Database): Map<string, string> {\n  if (!sqliteTableExists(db, 'vec_metadata')) return new Map();\n  const rows = db.prepare(`\n    SELECT key, value\n    FROM vec_metadata\n    WHERE key IN (?, ?, ?)\n  `).all(ACTIVE_EMBEDDER_NAME_KEY, ACTIVE_EMBEDDER_DIM_KEY, ACTIVE_EMBEDDER_PROVIDER_KEY) as MetadataRow[];\n  return new Map(rows.map((row) => [row.key, row.value]));\n}\n\nfunction providerForBackend(backend: BackendKind | undefined): string | null {\n  switch (backend) {\n    case 'ollama':\n      return 'ollama';\n    case 'api':\n      return 'openai';\n    case 'sentence-transformers':\n      return 'hf-local';\n    default:","lineStart":1,"lineEnd":320,"totalLines":733,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/projection.ts","time":{"start":1783437204956,"end":1783437204959}},"metadata":{"openai":{"itemId":"fc_093d4b70614d3caf016a4d1794d5d08191a98df8c09bc31306"}},"id":"prt_f3d241dca001pZLSr5sULolc5n","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d23eb48001Teq8BrJ3T5JLlh"}}
{"type":"tool_use","timestamp":1783437204984,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_WgeEg7U1ZIEBfonSbpv2aPkF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Ambiguity\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type { AdvisorScoredRecommendation } from './types.js';\n6: \n7: export const AMBIGUITY_MARGIN = 0.05;\n8: export const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n9: \n10: // Compute ambiguity from ranking `score` so the cluster aligns\n11: // with the score-based fusion ranking (top-two-by-confidence may not match\n12: // top-two-by-score).\n13: //\n14: // Also compute on `confidence` and union the two\n15: // clusters. Score-margin keeps ranking alignment; confidence-margin restores\n16: // the documented \"0.05 confidence window\" and catches\n17: // cross-domain prompts where confidence is near-tied (user-visible signal)\n18: // even when score gaps just exceed the score margin. A candidate is in the\n19: // ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n20: // \"outside both margins\" is required to be unambiguously ranked.\n21: \n22: function ambiguousCluster(\n23:   recommendations: readonly AdvisorScoredRecommendation[],\n24: ): AdvisorScoredRecommendation[] {\n25:   const passing = recommendations.filter((recommendation) => recommendation.passes_threshold);\n26:   const [top] = passing;\n27:   if (!top) return [];\n28:   return passing.filter((recommendation) => {\n29:     const scoreGap = Math.abs(top.score - recommendation.score);\n30:     const confidenceGap = Math.abs(top.confidence - recommendation.confidence);\n31:     return (\n32:       scoreGap <= AMBIGUITY_MARGIN + Number.EPSILON\n33:       || confidenceGap <= AMBIGUITY_CONFIDENCE_MARGIN + Number.EPSILON\n34:     );\n35:   });\n36: }\n37: \n38: export function isAmbiguousTopTwo(recommendations: readonly AdvisorScoredRecommendation[]): boolean {\n39:   // Name preserved for back-compat with existing call sites; semantics are\n40:   // now \"is the passing top a member of an ambiguity cluster of size >= 2\".\n41:   return ambiguousCluster(recommendations).length >= 2;\n42: }\n43: \n44: export function applyAmbiguity(\n45:   recommendations: readonly AdvisorScoredRecommendation[],\n46: ): AdvisorScoredRecommendation[] {\n47:   const cluster = ambiguousCluster(recommendations);\n48:   if (cluster.length < 2) return [...recommendations];\n49:   const ambiguousSet = new Set(cluster.map((recommendation) => recommendation.skill));\n50:   return recommendations.map((recommendation) => (\n51:     ambiguousSet.has(recommendation.skill)\n52:       ? {\n53:         ...recommendation,\n54:         ambiguousWith: [...ambiguousSet].filter((skill) => skill !== recommendation.skill),\n55:       }\n56:       : recommendation\n57:   ));\n58: }\n\n(End of file - total 58 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Ambiguity\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorScoredRecommendation } from './types.js';\n\nexport const AMBIGUITY_MARGIN = 0.05;\nexport const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n\n// Compute ambiguity from ranking `score` so the cluster aligns\n// with the score-based fusion ranking (top-two-by-confidence may not match\n// top-two-by-score).\n//\n// Also compute on `confidence` and union the two\n// clusters. Score-margin keeps ranking alignment; confidence-margin restores\n// the documented \"0.05 confidence window\" and catches\n// cross-domain prompts where confidence is near-tied (user-visible signal)\n// even when score gaps just exceed the score margin. A candidate is in the\n// ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n// \"outside both margins\" is required to be unambiguously ranked.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Ambiguity\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorScoredRecommendation } from './types.js';\n\nexport const AMBIGUITY_MARGIN = 0.05;\nexport const AMBIGUITY_CONFIDENCE_MARGIN = 0.05;\n\n// Compute ambiguity from ranking `score` so the cluster aligns\n// with the score-based fusion ranking (top-two-by-confidence may not match\n// top-two-by-score).\n//\n// Also compute on `confidence` and union the two\n// clusters. Score-margin keeps ranking alignment; confidence-margin restores\n// the documented \"0.05 confidence window\" and catches\n// cross-domain prompts where confidence is near-tied (user-visible signal)\n// even when score gaps just exceed the score margin. A candidate is in the\n// ambiguity cluster when EITHER gap is within its respective 0.05 margin —\n// \"outside both margins\" is required to be unambiguously ranked.\n\nfunction ambiguousCluster(\n  recommendations: readonly AdvisorScoredRecommendation[],\n): AdvisorScoredRecommendation[] {\n  const passing = recommendations.filter((recommendation) => recommendation.passes_threshold);\n  const [top] = passing;\n  if (!top) return [];\n  return passing.filter((recommendation) => {\n    const scoreGap = Math.abs(top.score - recommendation.score);\n    const confidenceGap = Math.abs(top.confidence - recommendation.confidence);\n    return (\n      scoreGap <= AMBIGUITY_MARGIN + Number.EPSILON\n      || confidenceGap <= AMBIGUITY_CONFIDENCE_MARGIN + Number.EPSILON\n    );\n  });\n}\n\nexport function isAmbiguousTopTwo(recommendations: readonly AdvisorScoredRecommendation[]): boolean {\n  // Name preserved for back-compat with existing call sites; semantics are\n  // now \"is the passing top a member of an ambiguity cluster of size >= 2\".\n  return ambiguousCluster(recommendations).length >= 2;\n}\n\nexport function applyAmbiguity(\n  recommendations: readonly AdvisorScoredRecommendation[],\n): AdvisorScoredRecommendation[] {\n  const cluster = ambiguousCluster(recommendations);\n  if (cluster.length < 2) return [...recommendations];\n  const ambiguousSet = new Set(cluster.map((recommendation) => recommendation.skill));\n  return recommendations.map((recommendation) => (\n    ambiguousSet.has(recommendation.skill)\n      ? {\n        ...recommendation,\n        ambiguousWith: [...ambiguousSet].filter((skill) => skill !== recommendation.skill),\n      }\n      : recommendation\n  ));\n}","lineStart":1,"lineEnd":58,"totalLines":58,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/ambiguity.ts","time":{"start":1783437204979,"end":1783437204983}},"metadata":{"openai":{"itemId":"fc_093d4b70614d3caf016a4d1794d5dc819190cef3e1db499a16"}},"id":"prt_f3d241df1001o8clwWbz7XK9Be","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d23eb48001Teq8BrJ3T5JLlh"}}
{"type":"tool_use","timestamp":1783437205006,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_2UQuEj2m42pQeNQR418Wby6R","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/ambiguity-slice.vitest.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/ambiguity-slice.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Ambiguity Slice Gate\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: // Scores the frozen ambiguity slice — the hardest, lowest top-2-margin corpus\n6: // prompts — and holds its top-1 accuracy at or above the committed baseline. The\n7: // aggregate corpus number can stay flat while contested prompts silently\n8: // regress; this slice makes that regression visible. The slice and its margin\n9: // threshold tau are frozen so the set never re-derives implicitly on a corpus\n10: // edit; each row keeps its existing gold label (no new labels invented).\n11: \n12: import { mkdtempSync, readFileSync } from 'node:fs';\n13: import { tmpdir } from 'node:os';\n14: import { dirname, join, resolve } from 'node:path';\n15: import { fileURLToPath } from 'node:url';\n16: \n17: import { beforeAll, describe, expect, it } from 'vitest';\n18: import type { AdvisorScoringOptions, AdvisorScoringResult } from '../../lib/scorer/types.js';\n19: \n20: // A frozen slice that collapses to a handful of rows is not a meaningful gate.\n21: const MIN_SLICE_ROWS = 10;\n22: \n23: interface AmbiguityRow {\n24:   readonly id: string;\n25:   readonly prompt: string;\n26:   readonly skill_top_1: string;\n27:   readonly bucket: string;\n28:   readonly source_type: string;\n29:   readonly margin_at_capture: number;\n30:   readonly tau: number;\n31: }\n32: \n33: interface Baseline {\n34:   readonly metrics: { readonly ambiguity_top1: { readonly correct: number; readonly total: number; readonly tau: number } };\n35: }\n36: \n37: const HERE = dirname(fileURLToPath(import.meta.url));\n38: const ROUTING = resolve(HERE, '../../scripts/routing-accuracy');\n39: const BASELINE_PATH = join(ROUTING, 'scorer-eval-baseline.json');\n40: const AMBIGUITY_PATH = join(ROUTING, 'ambiguity-prompts.jsonl');\n41: const SENTINEL = '.opencode/skills/system-spec-kit/SKILL.md';\n42: \n43: function readJsonl<T>(path: string): T[] {\n44:   return readFileSync(path, 'utf8').trim().split('\\n').filter(Boolean).map((line) => JSON.parse(line) as T);\n45: }\n46: \n47: function freezeEvalEnv(): void {\n48:   process.env.MK_SKILL_ADVISOR_DB_DIR = mkdtempSync(join(tmpdir(), 'advisor-ambiguity-gate-'));\n49:   process.env.SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC = '1';\n50:   process.env.SPECKIT_SKILL_ADVISOR_FORCE_LOCAL = '1';\n51:   delete process.env.SPECKIT_ADVISOR_LANE_WEIGHTS_JSON;\n52:   delete process.env.SPECKIT_ADVISOR_LANE_SHADOW_WEIGHTS_JSON;\n53:   delete process.env.SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW;\n54: }\n55: \n56: let scoreAdvisorPrompt: (prompt: string, options: AdvisorScoringOptions) => AdvisorScoringResult;\n57: let mergedSkillForAlias: (skillId: string) => string;\n58: let skillMatchesAlias: (actual: string, expected: string) => boolean;\n59: let workspaceRoot = '';\n60: \n61: function isTop1Correct(top: string | null, goldRaw: string): boolean {\n62:   const gold = goldRaw === 'none' ? null : goldRaw;\n63:   const expected = gold === null ? null : mergedSkillForAlias(gold);\n64:   const actual = top === null ? null : mergedSkillForAlias(top);\n65:   return actual === expected\n66:     || (actual !== null && expected !== null && skillMatchesAlias(actual, expected));\n67: }\n68: \n69: let SLICE: AmbiguityRow[] = [];\n70: let BASELINE: Baseline;\n71: let SLICE_CORRECT = 0;\n72: \n73: describe('ambiguity slice gate', () => {\n74:   beforeAll(async () => {\n75:     freezeEvalEnv();\n76:     const fusion = await import('../../lib/scorer/fusion.js');\n77:     const aliases = await import('../../lib/scorer/aliases.js');\n78:     const workspace = await import('../../lib/utils/workspace-root.js');\n79:     scoreAdvisorPrompt = fusion.scoreAdvisorPrompt;\n80:     mergedSkillForAlias = aliases.mergedSkillForAlias;\n81:     skillMatchesAlias = aliases.skillMatchesAlias;\n82:     workspaceRoot = workspace.findAdvisorWorkspaceRoot(HERE, { maxDepth: 14, sentinel: SENTINEL });\n83: \n84:     SLICE = readJsonl<AmbiguityRow>(AMBIGUITY_PATH);\n85:     BASELINE = JSON.parse(readFileSync(BASELINE_PATH, 'utf8')) as Baseline;\n86: \n87:     SLICE_CORRECT = SLICE.filter((row) => (\n88:       isTop1Correct(scoreAdvisorPrompt(row.prompt, { workspaceRoot }).topSkill, row.skill_top_1)\n89:     )).length;\n90:   }, 120_000);\n91: \n92:   it('is a non-empty, meaningful minority carrying its existing gold labels', () => {\n93:     expect(SLICE.length).toBeGreaterThanOrEqual(MIN_SLICE_ROWS);\n94:     for (const row of SLICE) {\n95:       expect(row.skill_top_1.length, `missing gold on ${row.id}`).toBeGreaterThan(0);\n96:       expect(row.bucket.length).toBeGreaterThan(0);\n97:     }\n98:   });\n99: \n100:   it('has a single frozen tau matching the baseline', () => {\n101:     const taus = new Set(SLICE.map((row) => row.tau));\n102:     expect(taus.size, 'ambiguity slice must carry a single frozen tau').toBe(1);\n103:     expect(SLICE[0].tau).toBe(BASELINE.metrics.ambiguity_top1.tau);\n104:   });\n105: \n106:   it('holds top-1 at or above the committed baseline', () => {\n107:     const baselineCorrect = BASELINE.metrics.ambiguity_top1.correct;\n108:     expect(\n109:       SLICE_CORRECT,\n110:       `ambiguity top-1 regressed: live=${SLICE_CORRECT}/${SLICE.length} baseline=${baselineCorrect}. `\n111:       + 'A drop means a scorer or metadata change hurt the hardest contested prompts.',\n112:     ).toBeGreaterThanOrEqual(baselineCorrect);\n113:   });\n114: });\n\n(End of file - total 114 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Ambiguity Slice Gate\n// ───────────────────────────────────────────────────────────────\n\n// Scores the frozen ambiguity slice — the hardest, lowest top-2-margin corpus\n// prompts — and holds its top-1 accuracy at or above the committed baseline. The\n// aggregate corpus number can stay flat while contested prompts silently\n// regress; this slice makes that regression visible. The slice and its margin\n// threshold tau are frozen so the set never re-derives implicitly on a corpus\n// edit; each row keeps its existing gold label (no new labels invented).\n\nimport { mkdtempSync, readFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { beforeAll, describe, expect, it } from 'vitest';\nimport type { AdvisorScoringOptions, AdvisorScoringResult } from '../../lib/scorer/types.js';\n\n// A frozen slice that collapses to a handful of rows is not a meaningful gate.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/ambiguity-slice.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Ambiguity Slice Gate\n// ───────────────────────────────────────────────────────────────\n\n// Scores the frozen ambiguity slice — the hardest, lowest top-2-margin corpus\n// prompts — and holds its top-1 accuracy at or above the committed baseline. The\n// aggregate corpus number can stay flat while contested prompts silently\n// regress; this slice makes that regression visible. The slice and its margin\n// threshold tau are frozen so the set never re-derives implicitly on a corpus\n// edit; each row keeps its existing gold label (no new labels invented).\n\nimport { mkdtempSync, readFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join, resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { beforeAll, describe, expect, it } from 'vitest';\nimport type { AdvisorScoringOptions, AdvisorScoringResult } from '../../lib/scorer/types.js';\n\n// A frozen slice that collapses to a handful of rows is not a meaningful gate.\nconst MIN_SLICE_ROWS = 10;\n\ninterface AmbiguityRow {\n  readonly id: string;\n  readonly prompt: string;\n  readonly skill_top_1: string;\n  readonly bucket: string;\n  readonly source_type: string;\n  readonly margin_at_capture: number;\n  readonly tau: number;\n}\n\ninterface Baseline {\n  readonly metrics: { readonly ambiguity_top1: { readonly correct: number; readonly total: number; readonly tau: number } };\n}\n\nconst HERE = dirname(fileURLToPath(import.meta.url));\nconst ROUTING = resolve(HERE, '../../scripts/routing-accuracy');\nconst BASELINE_PATH = join(ROUTING, 'scorer-eval-baseline.json');\nconst AMBIGUITY_PATH = join(ROUTING, 'ambiguity-prompts.jsonl');\nconst SENTINEL = '.opencode/skills/system-spec-kit/SKILL.md';\n\nfunction readJsonl<T>(path: string): T[] {\n  return readFileSync(path, 'utf8').trim().split('\\n').filter(Boolean).map((line) => JSON.parse(line) as T);\n}\n\nfunction freezeEvalEnv(): void {\n  process.env.MK_SKILL_ADVISOR_DB_DIR = mkdtempSync(join(tmpdir(), 'advisor-ambiguity-gate-'));\n  process.env.SKILL_ADVISOR_DISABLE_BUILTIN_SEMANTIC = '1';\n  process.env.SPECKIT_SKILL_ADVISOR_FORCE_LOCAL = '1';\n  delete process.env.SPECKIT_ADVISOR_LANE_WEIGHTS_JSON;\n  delete process.env.SPECKIT_ADVISOR_LANE_SHADOW_WEIGHTS_JSON;\n  delete process.env.SPECKIT_ADVISOR_BM25_LEXICAL_SHADOW;\n}\n\nlet scoreAdvisorPrompt: (prompt: string, options: AdvisorScoringOptions) => AdvisorScoringResult;\nlet mergedSkillForAlias: (skillId: string) => string;\nlet skillMatchesAlias: (actual: string, expected: string) => boolean;\nlet workspaceRoot = '';\n\nfunction isTop1Correct(top: string | null, goldRaw: string): boolean {\n  const gold = goldRaw === 'none' ? null : goldRaw;\n  const expected = gold === null ? null : mergedSkillForAlias(gold);\n  const actual = top === null ? null : mergedSkillForAlias(top);\n  return actual === expected\n    || (actual !== null && expected !== null && skillMatchesAlias(actual, expected));\n}\n\nlet SLICE: AmbiguityRow[] = [];\nlet BASELINE: Baseline;\nlet SLICE_CORRECT = 0;\n\ndescribe('ambiguity slice gate', () => {\n  beforeAll(async () => {\n    freezeEvalEnv();\n    const fusion = await import('../../lib/scorer/fusion.js');\n    const aliases = await import('../../lib/scorer/aliases.js');\n    const workspace = await import('../../lib/utils/workspace-root.js');\n    scoreAdvisorPrompt = fusion.scoreAdvisorPrompt;\n    mergedSkillForAlias = aliases.mergedSkillForAlias;\n    skillMatchesAlias = aliases.skillMatchesAlias;\n    workspaceRoot = workspace.findAdvisorWorkspaceRoot(HERE, { maxDepth: 14, sentinel: SENTINEL });\n\n    SLICE = readJsonl<AmbiguityRow>(AMBIGUITY_PATH);\n    BASELINE = JSON.parse(readFileSync(BASELINE_PATH, 'utf8')) as Baseline;\n\n    SLICE_CORRECT = SLICE.filter((row) => (\n      isTop1Correct(scoreAdvisorPrompt(row.prompt, { workspaceRoot }).topSkill, row.skill_top_1)\n    )).length;\n  }, 120_000);\n\n  it('is a non-empty, meaningful minority carrying its existing gold labels', () => {\n    expect(SLICE.length).toBeGreaterThanOrEqual(MIN_SLICE_ROWS);\n    for (const row of SLICE) {\n      expect(row.skill_top_1.length, `missing gold on ${row.id}`).toBeGreaterThan(0);\n      expect(row.bucket.length).toBeGreaterThan(0);\n    }\n  });\n\n  it('has a single frozen tau matching the baseline', () => {\n    const taus = new Set(SLICE.map((row) => row.tau));\n    expect(taus.size, 'ambiguity slice must carry a single frozen tau').toBe(1);\n    expect(SLICE[0].tau).toBe(BASELINE.metrics.ambiguity_top1.tau);\n  });\n\n  it('holds top-1 at or above the committed baseline', () => {\n    const baselineCorrect = BASELINE.metrics.ambiguity_top1.correct;\n    expect(\n      SLICE_CORRECT,\n      `ambiguity top-1 regressed: live=${SLICE_CORRECT}/${SLICE.length} baseline=${baselineCorrect}. `\n      + 'A drop means a scorer or metadata change hurt the hardest contested prompts.',\n    ).toBeGreaterThanOrEqual(baselineCorrect);\n  });\n});","lineStart":1,"lineEnd":114,"totalLines":114,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/tests/scorer/ambiguity-slice.vitest.ts","time":{"start":1783437204989,"end":1783437205003}},"metadata":{"openai":{"itemId":"fc_093d4b70614d3caf016a4d1794d5ec8191830a203b46ec25da"}},"id":"prt_f3d241dfb001bJRDdXXyhTb8tp","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d23eb48001Teq8BrJ3T5JLlh"}}
{"type":"tool_use","timestamp":1783437205006,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_dDEE8zeitK1y3XY6rWSs9Xv1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/derived/extract.ts","offset":1,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/derived/extract.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Derived Metadata Extractor\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { existsSync, readFileSync, readdirSync, statSync } from 'node:fs';\n6: import { basename, extname, join, relative, resolve } from 'node:path';\n7: import { applyAntiStuffing } from './anti-stuffing.js';\n8: import { computeProvenanceFingerprint, fileDependency, workspaceRelativeFilePath, type ProvenanceBuckets } from './provenance.js';\n9: import { sanitizeDerivedArray } from './sanitizer.js';\n10: import { readJsonObject } from '../utils/json-guard.js';\n11: import { parseSkillFrontmatter } from '../utils/skill-markdown.js';\n12: import type { DerivedSourceCategory } from './trust-lanes.js';\n13: \n14: // ───────────────────────────────────────────────────────────────\n15: // 1. TYPES\n16: // ───────────────────────────────────────────────────────────────\n17: \n18: export interface ExtractDerivedOptions {\n19:   readonly workspaceRoot: string;\n20:   readonly skillDir: string;\n21:   readonly now?: Date;\n22: }\n23: \n24: export interface DerivedExtractionResult {\n25:   readonly triggerPhrases: string[];\n26:   readonly keywords: string[];\n27:   readonly sourceDocs: string[];\n28:   readonly keyFiles: string[];\n29:   readonly buckets: ProvenanceBuckets;\n30:   readonly provenanceFingerprint: string;\n31:   readonly diagnostics: string[];\n32: }\n33: \n34: // ───────────────────────────────────────────────────────────────\n35: // 2. CONSTANTS\n36: // ───────────────────────────────────────────────────────────────\n37: \n38: const SKILL_MD = ['SKILL', 'md'].join('.');\n39: const GRAPH_METADATA = 'graph-metadata.json';\n40: const STOP_WORDS = new Set([\n41:   'the', 'and', 'for', 'with', 'from', 'that', 'this', 'into', 'when', 'then', 'than', 'use',\n42:   'uses', 'using', 'your', 'you', 'are', 'can', 'all', 'not', 'must', 'should', 'will', 'skill',\n43:   'skills', 'file', 'files', 'code', 'system', 'workflow', 'workflows',\n44: ]);\n45: // ───────────────────────────────────────────────────────────────\n46: // 3. PARSING HELPERS\n47: // ───────────────────────────────────────────────────────────────\n48: \n49: function emptyBuckets(): Record<DerivedSourceCategory, string[]> {\n50:   return {\n51:     frontmatter: [],\n52:     headings: [],\n53:     body: [],\n54:     examples: [],\n55:     references: [],\n56:     assets: [],\n57:     intent_signals: [],\n58:     source_docs: [],\n59:     key_files: [],\n60:   };\n61: }\n62: \n63: function readJson(filePath: string): Record<string, unknown> {\n64:   return readJsonObject(filePath) ?? {};\n65: }\n66: \n67: function splitSkillMarkdown(raw: string): { frontmatter: Record<string, string>; body: string; keywords: string[] } {\n68:   return parseSkillFrontmatter(raw);\n69: }\n70: \n71: function markdownHeadings(markdown: string): string[] {\n72:   const headings: string[] = [];\n73:   let inFence = false;\n74:   for (const line of markdown.split(/\\r?\\n/)) {\n75:     if (/^\\s*```/.test(line)) {\n76:       inFence = !inFence;\n77:       continue;\n78:     }\n79:     if (inFence) continue;\n80:     const match = /^\\s{0,3}#{1,6}\\s+(.+?)\\s*$/.exec(line);\n81:     if (match) headings.push(match[1].replace(/[#*_`]/g, '').trim());\n82:   }\n83:   return headings;\n84: }\n85: \n86: function codeBlocks(markdown: string): string[] {\n87:   const blocks: string[] = [];\n88:   const regex = /```[A-Za-z0-9_-]*\\n([\\s\\S]*?)```/g;\n89:   let match: RegExpExecArray | null;\n90:   while ((match = regex.exec(markdown)) !== null) {\n91:     blocks.push(match[1]);\n92:   }\n93:   return blocks;\n94: }\n95: \n96: function stripMarkdown(markdown: string): string {\n97:   return markdown\n98:     .replace(/```[\\s\\S]*?```/g, ' ')\n99:     .replace(/<!--[\\s\\S]*?-->/g, ' ')\n100:     .replace(/`([^`]+)`/g, '$1')\n101:     .replace(/[>#*_~()[\\]{}:]/g, ' ');\n102: }\n103: \n104: function normalizePhrase(value: string): string {\n105:   return value\n106:     .replace(/([a-z])([A-Z])/g, '$1 $2')\n107:     .replace(/[_./-]+/g, ' ')\n108:     .replace(/[^A-Za-z0-9 ]+/g, ' ')\n109:     .replace(/\\s+/g, ' ')\n110:     .trim()\n111:     .toLowerCase();\n112: }\n113: \n114: function ngrams(text: string): string[] {\n115:   const tokens = normalizePhrase(text)\n116:     .split(' ')\n117:     .filter((token) => token.length >= 3 && !STOP_WORDS.has(token));\n118:   const phrases: string[] = [];\n119:   for (let size = 1; size <= 3; size += 1) {\n120:     for (let index = 0; index <= tokens.length - size; index += 1) {\n121:       phrases.push(tokens.slice(index, index + size).join(' '));\n122:     }\n123:   }\n124:   return phrases;\n125: }\n126: \n127: function walkFiles(root: string): string[] {\n128:   if (!existsSync(root)) return [];\n129:   const found: string[] = [];\n130:   const stack = [root];\n131:   while (stack.length > 0) {\n132:     // stack.length was checked immediately before popping the next directory.\n133:     const current = stack.pop()!;\n134:     for (const entry of readdirSync(current, { withFileTypes: true })) {\n135:       const path = join(current, entry.name);\n136:       if (entry.isDirectory()) stack.push(path);\n137:       if (entry.isFile()) found.push(path);\n138:     }\n139:   }\n140:   return found.sort((left, right) => left.localeCompare(right));\n141: }\n142: \n143: function stringArray(value: unknown): string[] {\n144:   return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n145: }\n146: \n147: function workspaceKeyFiles(workspaceRoot: string, value: unknown): string[] {\n148:   return stringArray(value)\n149:     .map((entry) => workspaceRelativeFilePath(workspaceRoot, entry))\n150:     .filter((entry): entry is string => entry !== null);\n151: }\n152: \n153: // ───────────────────────────────────────────────────────────────\n154: // 4. CORE LOGIC\n155: // ───────────────────────────────────────────────────────────────\n156: \n157: export function extractDerivedMetadata(options: ExtractDerivedOptions): DerivedExtractionResult {\n158:   const workspaceRoot = resolve(options.workspaceRoot);\n159:   const skillDir = resolve(options.skillDir);\n160:   const skillMdPath = join(skillDir, SKILL_MD);\n161:   const graphMetadataPath = join(skillDir, GRAPH_METADATA);\n162:   const rawSkill = existsSync(skillMdPath) ? readFileSync(skillMdPath, 'utf8') : '';\n163:   const parsedSkill = splitSkillMarkdown(rawSkill);\n164:   const graphMetadata = readJson(graphMetadataPath);\n165:   const priorDerived = typeof graphMetadata.derived === 'object' && graphMetadata.derived !== null\n166:     ? graphMetadata.derived as Record<string, unknown>\n167:     : {};\n168:   const priorKeyFiles = workspaceKeyFiles(workspaceRoot, priorDerived.key_files);\n169:   const buckets = emptyBuckets();\n170: \n171:   buckets.frontmatter.push(...Object.values(parsedSkill.frontmatter), ...parsedSkill.keywords);\n172:   buckets.headings.push(...markdownHeadings(parsedSkill.body));\n173:   buckets.body.push(...ngrams(stripMarkdown(parsedSkill.body)));\n174:   buckets.examples.push(...codeBlocks(parsedSkill.body).flatMap((block) => ngrams(block)));\n175: \n176:   const referenceFiles = walkFiles(join(skillDir, 'references')).filter((file) => extname(file).toLowerCase() === '.md');\n177:   for (const file of referenceFiles) {\n178:     buckets.references.push(...markdownHeadings(readFileSync(file, 'utf8')));\n179:   }\n180: \n181:   const assetFiles = walkFiles(join(skillDir, 'assets'));\n182:   buckets.assets.push(...assetFiles.map((file) => basename(file, extname(file))));\n183:   buckets.intent_signals.push(...stringArray(graphMetadata.intent_signals));\n184:   // Note: priorDerived.source_docs and priorKeyFiles are merged into the final\n185:   // `sourceDocs` and `keyFiles` arrays below to preserve stickiness, but they\n186:   // are NOT pushed into the buckets here. Re-feeding them into the bucket\n187:   // pipeline produces path-derived ngrams in trigger_phrases/keywords on every\n188:   // resync, breaking idempotence for unchanged SKILL.md content.\n189: \n190:   const rawTriggerCandidates = [\n191:     ...buckets.frontmatter,\n192:     ...buckets.headings,\n193:     ...buckets.references,\n194:     ...buckets.intent_signals,\n195:     ...buckets.assets,\n196:     ...buckets.source_docs,\n197:     ...buckets.key_files,\n198:   ].flatMap((value) => [value, ...ngrams(value)]).map(normalizePhrase);\n199:   const rawKeywordCandidates = [\n200:     ...rawTriggerCandidates,\n201:     ...buckets.body,\n202:     ...buckets.examples,\n203:   ].map(normalizePhrase);\n204: \n205:   const sourceDocs = sanitizeDerivedArray([\n206:     SKILL_MD,\n207:     ...referenceFiles.map((file) => relative(skillDir, file)),\n208:     ...stringArray(priorDerived.source_docs),\n209:   ], 'graph-metadata', 64);\n210:   const keyFiles = sanitizeDerivedArray([\n211:     relative(workspaceRoot, skillMdPath),\n212:     relative(workspaceRoot, graphMetadataPath),\n213:     ...assetFiles.map((file) => relative(workspaceRoot, file)),\n214:     ...priorKeyFiles,\n215:   ], 'graph-metadata', 64);\n216: \n217:   const antiStuffing = applyAntiStuffing(rawTriggerCandidates, rawKeywordCandidates);\n218:   // graph-metadata.json is intentionally excluded from the provenance hash:\n219:   // syncDerivedMetadata writes the derived block back into it, so including\n220:   // its hash would break idempotence (the second sync would see a different\n221:   // hash because the first sync mutated the file). Authored graph-metadata\n222:   // content (e.g. intent_signals) is already represented in the buckets.\n223:   // Dependencies are deduplicated by path so priorKeyFiles entries that\n224:   // overlap with the explicit SKILL.md / reference / asset list don't\n225:   // double-count in the fingerprint.\n226:   const graphMetadataRel = relative(workspaceRoot, graphMetadataPath);\n227:   const dependencyMap = new Map<string, ReturnType<typeof fileDependency>>();\n228:   const addDep = (relPath: string): void => {\n229:     if (relPath === graphMetadataRel) return;\n230:     if (dependencyMap.has(relPath)) return;\n231:     dependencyMap.set(relPath, fileDependency(workspaceRoot, relPath));\n232:   };\n233:   addDep(relative(workspaceRoot, skillMdPath));\n234:   for (const file of referenceFiles) addDep(relative(workspaceRoot, file));\n235:   for (const file of assetFiles) {\n236:     if (statSync(file).isFile()) addDep(relative(workspaceRoot, file));\n237:   }\n238:   for (const file of priorKeyFiles) addDep(file);\n239:   const dependencies = [...dependencyMap.values()];\n240:   const provenance = computeProvenanceFingerprint(buckets, dependencies);\n241: \n242:   return {\n243:     triggerPhrases: antiStuffing.triggerPhrases,\n244:     keywords: antiStuffing.keywords,\n245:     sourceDocs,\n246:     keyFiles,\n247:     buckets,\n248:     provenanceFingerprint: provenance.provenanceFingerprint,\n249:     diagnostics: antiStuffing.diagnostics,\n250:   };\n251: }\n\n(End of file - total 251 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Derived Metadata Extractor\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, readdirSync, statSync } from 'node:fs';\nimport { basename, extname, join, relative, resolve } from 'node:path';\nimport { applyAntiStuffing } from './anti-stuffing.js';\nimport { computeProvenanceFingerprint, fileDependency, workspaceRelativeFilePath, type ProvenanceBuckets } from './provenance.js';\nimport { sanitizeDerivedArray } from './sanitizer.js';\nimport { readJsonObject } from '../utils/json-guard.js';\nimport { parseSkillFrontmatter } from '../utils/skill-markdown.js';\nimport type { DerivedSourceCategory } from './trust-lanes.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n// ───────────────────────────────────────────────────────────────\n\nexport interface ExtractDerivedOptions {\n  readonly workspaceRoot: string;\n  readonly skillDir: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/derived/extract.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Derived Metadata Extractor\n// ───────────────────────────────────────────────────────────────\n\nimport { existsSync, readFileSync, readdirSync, statSync } from 'node:fs';\nimport { basename, extname, join, relative, resolve } from 'node:path';\nimport { applyAntiStuffing } from './anti-stuffing.js';\nimport { computeProvenanceFingerprint, fileDependency, workspaceRelativeFilePath, type ProvenanceBuckets } from './provenance.js';\nimport { sanitizeDerivedArray } from './sanitizer.js';\nimport { readJsonObject } from '../utils/json-guard.js';\nimport { parseSkillFrontmatter } from '../utils/skill-markdown.js';\nimport type { DerivedSourceCategory } from './trust-lanes.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n// ───────────────────────────────────────────────────────────────\n\nexport interface ExtractDerivedOptions {\n  readonly workspaceRoot: string;\n  readonly skillDir: string;\n  readonly now?: Date;\n}\n\nexport interface DerivedExtractionResult {\n  readonly triggerPhrases: string[];\n  readonly keywords: string[];\n  readonly sourceDocs: string[];\n  readonly keyFiles: string[];\n  readonly buckets: ProvenanceBuckets;\n  readonly provenanceFingerprint: string;\n  readonly diagnostics: string[];\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ───────────────────────────────────────────────────────────────\n\nconst SKILL_MD = ['SKILL', 'md'].join('.');\nconst GRAPH_METADATA = 'graph-metadata.json';\nconst STOP_WORDS = new Set([\n  'the', 'and', 'for', 'with', 'from', 'that', 'this', 'into', 'when', 'then', 'than', 'use',\n  'uses', 'using', 'your', 'you', 'are', 'can', 'all', 'not', 'must', 'should', 'will', 'skill',\n  'skills', 'file', 'files', 'code', 'system', 'workflow', 'workflows',\n]);\n// ───────────────────────────────────────────────────────────────\n// 3. PARSING HELPERS\n// ───────────────────────────────────────────────────────────────\n\nfunction emptyBuckets(): Record<DerivedSourceCategory, string[]> {\n  return {\n    frontmatter: [],\n    headings: [],\n    body: [],\n    examples: [],\n    references: [],\n    assets: [],\n    intent_signals: [],\n    source_docs: [],\n    key_files: [],\n  };\n}\n\nfunction readJson(filePath: string): Record<string, unknown> {\n  return readJsonObject(filePath) ?? {};\n}\n\nfunction splitSkillMarkdown(raw: string): { frontmatter: Record<string, string>; body: string; keywords: string[] } {\n  return parseSkillFrontmatter(raw);\n}\n\nfunction markdownHeadings(markdown: string): string[] {\n  const headings: string[] = [];\n  let inFence = false;\n  for (const line of markdown.split(/\\r?\\n/)) {\n    if (/^\\s*```/.test(line)) {\n      inFence = !inFence;\n      continue;\n    }\n    if (inFence) continue;\n    const match = /^\\s{0,3}#{1,6}\\s+(.+?)\\s*$/.exec(line);\n    if (match) headings.push(match[1].replace(/[#*_`]/g, '').trim());\n  }\n  return headings;\n}\n\nfunction codeBlocks(markdown: string): string[] {\n  const blocks: string[] = [];\n  const regex = /```[A-Za-z0-9_-]*\\n([\\s\\S]*?)```/g;\n  let match: RegExpExecArray | null;\n  while ((match = regex.exec(markdown)) !== null) {\n    blocks.push(match[1]);\n  }\n  return blocks;\n}\n\nfunction stripMarkdown(markdown: string): string {\n  return markdown\n    .replace(/```[\\s\\S]*?```/g, ' ')\n    .replace(/<!--[\\s\\S]*?-->/g, ' ')\n    .replace(/`([^`]+)`/g, '$1')\n    .replace(/[>#*_~()[\\]{}:]/g, ' ');\n}\n\nfunction normalizePhrase(value: string): string {\n  return value\n    .replace(/([a-z])([A-Z])/g, '$1 $2')\n    .replace(/[_./-]+/g, ' ')\n    .replace(/[^A-Za-z0-9 ]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .toLowerCase();\n}\n\nfunction ngrams(text: string): string[] {\n  const tokens = normalizePhrase(text)\n    .split(' ')\n    .filter((token) => token.length >= 3 && !STOP_WORDS.has(token));\n  const phrases: string[] = [];\n  for (let size = 1; size <= 3; size += 1) {\n    for (let index = 0; index <= tokens.length - size; index += 1) {\n      phrases.push(tokens.slice(index, index + size).join(' '));\n    }\n  }\n  return phrases;\n}\n\nfunction walkFiles(root: string): string[] {\n  if (!existsSync(root)) return [];\n  const found: string[] = [];\n  const stack = [root];\n  while (stack.length > 0) {\n    // stack.length was checked immediately before popping the next directory.\n    const current = stack.pop()!;\n    for (const entry of readdirSync(current, { withFileTypes: true })) {\n      const path = join(current, entry.name);\n      if (entry.isDirectory()) stack.push(path);\n      if (entry.isFile()) found.push(path);\n    }\n  }\n  return found.sort((left, right) => left.localeCompare(right));\n}\n\nfunction stringArray(value: unknown): string[] {\n  return Array.isArray(value) ? value.filter((entry): entry is string => typeof entry === 'string') : [];\n}\n\nfunction workspaceKeyFiles(workspaceRoot: string, value: unknown): string[] {\n  return stringArray(value)\n    .map((entry) => workspaceRelativeFilePath(workspaceRoot, entry))\n    .filter((entry): entry is string => entry !== null);\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ───────────────────────────────────────────────────────────────\n\nexport function extractDerivedMetadata(options: ExtractDerivedOptions): DerivedExtractionResult {\n  const workspaceRoot = resolve(options.workspaceRoot);\n  const skillDir = resolve(options.skillDir);\n  const skillMdPath = join(skillDir, SKILL_MD);\n  const graphMetadataPath = join(skillDir, GRAPH_METADATA);\n  const rawSkill = existsSync(skillMdPath) ? readFileSync(skillMdPath, 'utf8') : '';\n  const parsedSkill = splitSkillMarkdown(rawSkill);\n  const graphMetadata = readJson(graphMetadataPath);\n  const priorDerived = typeof graphMetadata.derived === 'object' && graphMetadata.derived !== null\n    ? graphMetadata.derived as Record<string, unknown>\n    : {};\n  const priorKeyFiles = workspaceKeyFiles(workspaceRoot, priorDerived.key_files);\n  const buckets = emptyBuckets();\n\n  buckets.frontmatter.push(...Object.values(parsedSkill.frontmatter), ...parsedSkill.keywords);\n  buckets.headings.push(...markdownHeadings(parsedSkill.body));\n  buckets.body.push(...ngrams(stripMarkdown(parsedSkill.body)));\n  buckets.examples.push(...codeBlocks(parsedSkill.body).flatMap((block) => ngrams(block)));\n\n  const referenceFiles = walkFiles(join(skillDir, 'references')).filter((file) => extname(file).toLowerCase() === '.md');\n  for (const file of referenceFiles) {\n    buckets.references.push(...markdownHeadings(readFileSync(file, 'utf8')));\n  }\n\n  const assetFiles = walkFiles(join(skillDir, 'assets'));\n  buckets.assets.push(...assetFiles.map((file) => basename(file, extname(file))));\n  buckets.intent_signals.push(...stringArray(graphMetadata.intent_signals));\n  // Note: priorDerived.source_docs and priorKeyFiles are merged into the final\n  // `sourceDocs` and `keyFiles` arrays below to preserve stickiness, but they\n  // are NOT pushed into the buckets here. Re-feeding them into the bucket\n  // pipeline produces path-derived ngrams in trigger_phrases/keywords on every\n  // resync, breaking idempotence for unchanged SKILL.md content.\n\n  const rawTriggerCandidates = [\n    ...buckets.frontmatter,\n    ...buckets.headings,\n    ...buckets.references,\n    ...buckets.intent_signals,\n    ...buckets.assets,\n    ...buckets.source_docs,\n    ...buckets.key_files,\n  ].flatMap((value) => [value, ...ngrams(value)]).map(normalizePhrase);\n  const rawKeywordCandidates = [\n    ...rawTriggerCandidates,\n    ...buckets.body,\n    ...buckets.examples,\n  ].map(normalizePhrase);\n\n  const sourceDocs = sanitizeDerivedArray([\n    SKILL_MD,\n    ...referenceFiles.map((file) => relative(skillDir, file)),\n    ...stringArray(priorDerived.source_docs),\n  ], 'graph-metadata', 64);\n  const keyFiles = sanitizeDerivedArray([\n    relative(workspaceRoot, skillMdPath),\n    relative(workspaceRoot, graphMetadataPath),\n    ...assetFiles.map((file) => relative(workspaceRoot, file)),\n    ...priorKeyFiles,\n  ], 'graph-metadata', 64);\n\n  const antiStuffing = applyAntiStuffing(rawTriggerCandidates, rawKeywordCandidates);\n  // graph-metadata.json is intentionally excluded from the provenance hash:\n  // syncDerivedMetadata writes the derived block back into it, so including\n  // its hash would break idempotence (the second sync would see a different\n  // hash because the first sync mutated the file). Authored graph-metadata\n  // content (e.g. intent_signals) is already represented in the buckets.\n  // Dependencies are deduplicated by path so priorKeyFiles entries that\n  // overlap with the explicit SKILL.md / reference / asset list don't\n  // double-count in the fingerprint.\n  const graphMetadataRel = relative(workspaceRoot, graphMetadataPath);\n  const dependencyMap = new Map<string, ReturnType<typeof fileDependency>>();\n  const addDep = (relPath: string): void => {\n    if (relPath === graphMetadataRel) return;\n    if (dependencyMap.has(relPath)) return;\n    dependencyMap.set(relPath, fileDependency(workspaceRoot, relPath));\n  };\n  addDep(relative(workspaceRoot, skillMdPath));\n  for (const file of referenceFiles) addDep(relative(workspaceRoot, file));\n  for (const file of assetFiles) {\n    if (statSync(file).isFile()) addDep(relative(workspaceRoot, file));\n  }\n  for (const file of priorKeyFiles) addDep(file);\n  const dependencies = [...dependencyMap.values()];\n  const provenance = computeProvenanceFingerprint(buckets, dependencies);\n\n  return {\n    triggerPhrases: antiStuffing.triggerPhrases,\n    keywords: antiStuffing.keywords,\n    sourceDocs,\n    keyFiles,\n    buckets,\n    provenanceFingerprint: provenance.provenanceFingerprint,\n    diagnostics: antiStuffing.diagnostics,\n  };\n}","lineStart":1,"lineEnd":251,"totalLines":251,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/derived/extract.ts","time":{"start":1783437204986,"end":1783437205004}},"metadata":{"openai":{"itemId":"fc_093d4b70614d3caf016a4d1794d5e48191bf518aec9d787cc0"}},"id":"prt_f3d241df800132qD36dANuo3ko","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d23eb48001Teq8BrJ3T5JLlh"}}
{"type":"tool_use","timestamp":1783437205008,"sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","part":{"type":"tool","tool":"read","callID":"call_fcCwvE8Q7owCYULyBShvbnDQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/projection-fallback-049-005.vitest.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/projection-fallback-049-005.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Projection SQLite-Fallback Test\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // Asserts that loadAdvisorProjection() distinguishes three cases:\n6: //   1. SQLite read succeeds → source: 'sqlite'.\n7: //   2. SQLite DB does not exist → source: 'filesystem' (legitimate first run).\n8: //   3. SQLite read THROWS → source: 'filesystem-fallback' with fallbackReason\n9: //      populated AND a console.warn surfaced for operator visibility.\n10: \n11: import { mkdirSync, rmSync, writeFileSync } from 'node:fs';\n12: import { tmpdir } from 'node:os';\n13: import { dirname, join } from 'node:path';\n14: import { afterEach, describe, expect, it, vi } from 'vitest';\n15: import { loadAdvisorProjection } from '../../lib/scorer/projection.js';\n16: \n17: const workspaces: string[] = [];\n18: const ADVISOR_DB_RELATIVE_PATH = join(\n19:   '.opencode',\n20:   'skills',\n21:   'system-skill-advisor',\n22:   'mcp_server',\n23:   'database',\n24:   'skill-graph.sqlite',\n25: );\n26: \n27: function workspace(name: string): string {\n28:   const root = join(tmpdir(), `${name}-${process.pid}-${Date.now()}-${Math.random().toString(16).slice(2)}`);\n29:   workspaces.push(root);\n30:   return root;\n31: }\n32: \n33: function write(filePath: string, content: string | Buffer): void {\n34:   mkdirSync(dirname(filePath), { recursive: true });\n35:   writeFileSync(filePath, content);\n36: }\n37: \n38: afterEach(() => {\n39:   vi.restoreAllMocks();\n40:   for (const root of workspaces.splice(0)) {\n41:     rmSync(root, { recursive: true, force: true });\n42:   }\n43: });\n44: \n45: describe('F-004-A4-01: loadAdvisorProjection surfaces SQLite failures explicitly', () => {\n46:   it('returns source=filesystem when the SQLite DB does not exist (legitimate first run)', () => {\n47:     const root = workspace('advisor-projection-no-db');\n48:     // Create a single skill on disk so the filesystem projection has content.\n49:     const skillDir = join(root, '.opencode', 'skills', 'sample-skill');\n50:     write(join(skillDir, 'SKILL.md'), [\n51:       '---',\n52:       'name: sample-skill',\n53:       'description: Sample test skill',\n54:       '---',\n55:       '# sample-skill',\n56:       '',\n57:     ].join('\\n'));\n58:     write(join(skillDir, 'graph-metadata.json'), JSON.stringify({\n59:       schema_version: 1,\n60:       skill_id: 'sample-skill',\n61:       family: 'system',\n62:       category: 'test',\n63:       domains: ['test'],\n64:       intent_signals: ['test'],\n65:     }));\n66: \n67:     const projection = loadAdvisorProjection(root);\n68:     expect(projection.source).toBe('filesystem');\n69:     expect(projection.fallbackReason).toBeUndefined();\n70:   });\n71: \n72:   // drift: verified against shipped behavior during Unit H\n73:   it('returns source=filesystem-fallback with a reason when the SQLite DB is corrupt', () => {\n74:     const root = workspace('advisor-projection-corrupt-db');\n75:     // Write a corrupt sqlite file at the path that loadSqliteProjection looks\n76:     // for. better-sqlite3 will throw when it tries to open this.\n77:     const dbPath = join(root, ADVISOR_DB_RELATIVE_PATH);\n78:     write(dbPath, Buffer.from('this is not a valid SQLite database'));\n79:     // Also add a filesystem skill so the fallback has content to return.\n80:     const skillDir = join(root, '.opencode', 'skills', 'sample-skill');\n81:     write(join(skillDir, 'SKILL.md'), [\n82:       '---',\n83:       'name: sample-skill',\n84:       'description: Sample test skill',\n85:       '---',\n86:       '# sample-skill',\n87:       '',\n88:     ].join('\\n'));\n89:     write(join(skillDir, 'graph-metadata.json'), JSON.stringify({\n90:       schema_version: 1,\n91:       skill_id: 'sample-skill',\n92:       family: 'system',\n93:       category: 'test',\n94:     }));\n95: \n96:     const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => undefined);\n97: \n98:     const projection = loadAdvisorProjection(root);\n99:     expect(projection.source).toBe('filesystem-fallback');\n100:     expect(projection.fallbackReason).toBeDefined();\n101:     expect(projection.fallbackReason!.length).toBeGreaterThan(0);\n102:     expect(warnSpy).toHaveBeenCalled();\n103:     expect(warnSpy.mock.calls[0]?.[0]).toContain('SQLite projection failed');\n104:     // Filesystem fallback still returns the on-disk skill content.\n105:     expect(projection.skills.some((entry) => entry.id === 'sample-skill')).toBe(true);\n106:   });\n107: });\n\n(End of file - total 107 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Projection SQLite-Fallback Test\n// ───────────────────────────────────────────────────────────────\n//\n// Asserts that loadAdvisorProjection() distinguishes three cases:\n//   1. SQLite read succeeds → source: 'sqlite'.\n//   2. SQLite DB does not exist → source: 'filesystem' (legitimate first run).\n//   3. SQLite read THROWS → source: 'filesystem-fallback' with fallbackReason\n//      populated AND a console.warn surfaced for operator visibility.\n\nimport { mkdirSync, rmSync, writeFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join } from 'node:path';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\nimport { loadAdvisorProjection } from '../../lib/scorer/projection.js';\n\nconst workspaces: string[] = [];\nconst ADVISOR_DB_RELATIVE_PATH = join(\n  '.opencode',\n  'skills',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/tests/scorer/projection-fallback-049-005.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Projection SQLite-Fallback Test\n// ───────────────────────────────────────────────────────────────\n//\n// Asserts that loadAdvisorProjection() distinguishes three cases:\n//   1. SQLite read succeeds → source: 'sqlite'.\n//   2. SQLite DB does not exist → source: 'filesystem' (legitimate first run).\n//   3. SQLite read THROWS → source: 'filesystem-fallback' with fallbackReason\n//      populated AND a console.warn surfaced for operator visibility.\n\nimport { mkdirSync, rmSync, writeFileSync } from 'node:fs';\nimport { tmpdir } from 'node:os';\nimport { dirname, join } from 'node:path';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\nimport { loadAdvisorProjection } from '../../lib/scorer/projection.js';\n\nconst workspaces: string[] = [];\nconst ADVISOR_DB_RELATIVE_PATH = join(\n  '.opencode',\n  'skills',\n  'system-skill-advisor',\n  'mcp_server',\n  'database',\n  'skill-graph.sqlite',\n);\n\nfunction workspace(name: string): string {\n  const root = join(tmpdir(), `${name}-${process.pid}-${Date.now()}-${Math.random().toString(16).slice(2)}`);\n  workspaces.push(root);\n  return root;\n}\n\nfunction write(filePath: string, content: string | Buffer): void {\n  mkdirSync(dirname(filePath), { recursive: true });\n  writeFileSync(filePath, content);\n}\n\nafterEach(() => {\n  vi.restoreAllMocks();\n  for (const root of workspaces.splice(0)) {\n    rmSync(root, { recursive: true, force: true });\n  }\n});\n\ndescribe('F-004-A4-01: loadAdvisorProjection surfaces SQLite failures explicitly', () => {\n  it('returns source=filesystem when the SQLite DB does not exist (legitimate first run)', () => {\n    const root = workspace('advisor-projection-no-db');\n    // Create a single skill on disk so the filesystem projection has content.\n    const skillDir = join(root, '.opencode', 'skills', 'sample-skill');\n    write(join(skillDir, 'SKILL.md'), [\n      '---',\n      'name: sample-skill',\n      'description: Sample test skill',\n      '---',\n      '# sample-skill',\n      '',\n    ].join('\\n'));\n    write(join(skillDir, 'graph-metadata.json'), JSON.stringify({\n      schema_version: 1,\n      skill_id: 'sample-skill',\n      family: 'system',\n      category: 'test',\n      domains: ['test'],\n      intent_signals: ['test'],\n    }));\n\n    const projection = loadAdvisorProjection(root);\n    expect(projection.source).toBe('filesystem');\n    expect(projection.fallbackReason).toBeUndefined();\n  });\n\n  // drift: verified against shipped behavior during Unit H\n  it('returns source=filesystem-fallback with a reason when the SQLite DB is corrupt', () => {\n    const root = workspace('advisor-projection-corrupt-db');\n    // Write a corrupt sqlite file at the path that loadSqliteProjection looks\n    // for. better-sqlite3 will throw when it tries to open this.\n    const dbPath = join(root, ADVISOR_DB_RELATIVE_PATH);\n    write(dbPath, Buffer.from('this is not a valid SQLite database'));\n    // Also add a filesystem skill so the fallback has content to return.\n    const skillDir = join(root, '.opencode', 'skills', 'sample-skill');\n    write(join(skillDir, 'SKILL.md'), [\n      '---',\n      'name: sample-skill',\n      'description: Sample test skill',\n      '---',\n      '# sample-skill',\n      '',\n    ].join('\\n'));\n    write(join(skillDir, 'graph-metadata.json'), JSON.stringify({\n      schema_version: 1,\n      skill_id: 'sample-skill',\n      family: 'system',\n      category: 'test',\n    }));\n\n    const warnSpy = vi.spyOn(console, 'warn').mockImplementation(() => undefined);\n\n    const projection = loadAdvisorProjection(root);\n    expect(projection.source).toBe('filesystem-fallback');\n    expect(projection.fallbackReason).toBeDefined();\n    expect(projection.fallbackReason!.length).toBeGreaterThan(0);\n    expect(warnSpy).toHaveBeenCalled();\n    expect(warnSpy.mock.calls[0]?.[0]).toContain('SQLite projection failed');\n    // Filesystem fallback still returns the on-disk skill content.\n    expect(projection.skills.some((entry) => entry.id === 'sample-skill')).toBe(true);\n  });\n});","lineStart":1,"lineEnd":107,"totalLines":107,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/tests/scorer/projection-fallback-049-005.vitest.ts","time":{"start":1783437204990,"end":1783437205007}},"metadata":{"openai":{"itemId":"fc_093d4b70614d3caf016a4d1794d5f48191bff6e423d4310f40"}},"id":"prt_f3d241dfd001JpzRet51aO2kKD","sessionID":"ses_0c2dd1dfdffet6Vx3PotxpyX20","messageID":"msg_f3d23eb48001Teq8BrJ3T5JLlh"}}
