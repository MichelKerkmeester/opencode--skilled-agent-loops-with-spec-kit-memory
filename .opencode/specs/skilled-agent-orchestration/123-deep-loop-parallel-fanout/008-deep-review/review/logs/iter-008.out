   160	describe('coverage-graph per-sessionId isolation', () => {
   161	  it('two lineages with distinct session_ids do not collide in the shared sqlite', async () => {
   162	    const nsA = uniqueNamespace('upsert', 'research');
   163	    const nsB = { ...uniqueNamespace('upsert', 'research'), specFolder: nsA.specFolder }; // same spec, different session
   164	
