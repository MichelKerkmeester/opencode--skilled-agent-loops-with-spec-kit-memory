   167	// ─────────────────────────────────────────────────────────────────────────────
   168	// 3. FIXTURE SCORING
   169	// ─────────────────────────────────────────────────────────────────────────────
   170	
   171	function scoreFixture(fixture, outputPath) {
   172	  if (!fs.existsSync(outputPath)) {
   173	    return {
   174	      id: fixture.id,
   175	      outputPath,
   176	      score: 0,
   177	      maxScore: 100,
   178	      passed: false,
   179	      missingHeadings: fixture.requiredHeadings || [],
   180	      missingPatterns: fixture.requiredPatterns || [],
   181	      forbiddenMatches: [],
   182	      failureModes: ['missing-output'],
   183	    };
   184	  }
   185	
   186	  const content = fs.readFileSync(outputPath, 'utf8');
   187	  const missingHeadings = (fixture.requiredHeadings || []).filter((heading) => !content.includes(heading));
   188	  const patternRegexes = compilePatterns(fixture.requiredPatterns);
   189	  const missingPatterns = patternRegexes
   190	    .map((regex, index) => ({ regex, source: fixture.requiredPatterns[index] }))
   191	    .filter((entry) => !safeRegexTest(entry.regex, content))
   192	    .map((entry) => entry.source);
   193	  const forbiddenRegexes = compilePatterns(fixture.forbiddenPatterns);
   194	  const forbiddenMatches = forbiddenRegexes
   195	    .map((regex, index) => ({ regex, source: fixture.forbiddenPatterns[index] }))
   196	    .filter((entry) => safeRegexTest(entry.regex, content))
   197	    .map((entry) => entry.source);
   198	
   199	  const headingScore =
   200	    (fixture.requiredHeadings || []).length === 0
   201	      ? 45
   202	      : Math.round(45 * (((fixture.requiredHeadings || []).length - missingHeadings.length) / (fixture.requiredHeadings || []).length));
   203	  const patternScore =
   204	    (fixture.requiredPatterns || []).length === 0
