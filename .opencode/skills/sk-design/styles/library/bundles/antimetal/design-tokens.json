    "chartreuse-whisper": {
      "$value": "#e2e67d",
      "$type": "color",
      "$description": "Chartreuse Whisper — Sole chromatic accent — appears as a small punctuation mark, badge fill, or highlight wash; deliberately desaturated so it never dominates"
