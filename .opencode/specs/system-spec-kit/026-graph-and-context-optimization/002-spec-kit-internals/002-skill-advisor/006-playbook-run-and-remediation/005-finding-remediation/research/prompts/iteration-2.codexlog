   954	
   955	        for target, weight in edges.get("enhances", {}).items():
   956	            transitive = current_boost * weight * 0.3
   957	            if snapshot.get(target, 0) <= 0:
   958	                continue
   959	            if transitive >= 0.1:
   960	                skill_boosts[target] = skill_boosts.get(target, 0) + transitive
   961	                boost_reasons.setdefault(target, []).append(
   962	                    f"!graph:enhances({skill_name},{weight:.1f})"
   963	                )
   964	
   965	        for target, weight in edges.get("siblings", {}).items():
   966	            transitive = current_boost * weight * 0.15
   967	            if snapshot.get(target, 0) <= 0:
   968	                continue
   969	            if transitive >= 0.1:
   970	                skill_boosts[target] = skill_boosts.get(target, 0) + transitive
   971	                boost_reasons.setdefault(target, []).append(
   972	                    f"!graph:sibling({skill_name},{weight:.1f})"
   973	                )
   974	
   975	        for target, weight in edges.get("depends_on", {}).items():
   976	            transitive = current_boost * weight * 0.2
   977	            if snapshot.get(target, 0) <= 0:
   978	                continue
   979	            if transitive >= 0.1:
   980	                skill_boosts[target] = skill_boosts.get(target, 0) + transitive
   981	                boost_reasons.setdefault(target, []).append(
   982	                    f"!graph:depends({skill_name},{weight:.1f})"
   983	                )
