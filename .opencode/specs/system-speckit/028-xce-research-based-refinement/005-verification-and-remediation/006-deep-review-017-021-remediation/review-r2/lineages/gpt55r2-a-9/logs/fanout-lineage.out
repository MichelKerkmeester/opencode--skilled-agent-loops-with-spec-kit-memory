'../lib/feedback/query-flow-tracker.js';\n60: \n61: // Core utilities\n62: import { checkDatabaseUpdated } from '../core/index.js';\n63: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n64: import { validateQuery, requireDb, toErrorMessage } from '../utils/index.js';\n65: \n66: // Response envelope + formatters\n67: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n68: import { formatSearchResults } from '../formatters/index.js';\n69: \n70: // Shared handler types\n71: import type { MCPResponse, IntentClassification } from './types.js';\n72: \n73: // Retrieval trace contracts (C136-08)\n74: import { createTrace } from '@spec-kit/shared/contracts/retrieval-trace';\n75: import { buildAdaptiveShadowProposal } from '../lib/cognitive/adaptive-ranking.js';\n76: import { normalizeScopeContext, filterRowsByScope } from '../lib/governance/scope-governance.js';\n77: import {\n78:   attachSessionTransitionTrace,\n79:   type SessionTransitionTrace,\n80: } from '../lib/search/session-transition.js';\n81: \n82: // Mode-Aware Response Shape\n83: import {\n84:   applyProfileToEnvelope,\n85:   isResponseProfileEnabled,\n86: } from '../lib/response/profile-formatters.js';\n87: import {\n88:   buildProgressiveResponse,\n89:   extractSnippets,\n90:   isProgressiveDisclosureEnabled,\n91:   resolveCursor,\n92: } from '../lib/search/progressive-disclosure.js';\n93: import {\n94:   SPEC_DOCUMENT_FILENAMES,\n95:   canClassifyAsSpecDocument,\n96:   normalizeSpecPath,\n97: } from '../lib/config/spec-doc-paths.js';\n98: import {\n99:   getLastLexicalCapabilitySnapshot,\n100:   resetLastLexicalCapabilitySnapshot,\n101: } from '../lib/search/sqlite-fts.js';\n102: import * as vectorIndex from '../lib/search/vector-index.js';\n103: import type { LexicalCapabilitySnapshot } from '../lib/search/sqlite-fts.js';\n104: import { buildVectorDegradationSignal } from '../lib/observability/retrieval-observability.js';\n105: import { evaluatePublicationGate } from '../lib/context/publication-gate.js';\n106: import {\n107:   deduplicateResults as deduplicateWithSessionState,\n108:   isSessionRetrievalStateEnabled,\n109:   manager as retrievalSessionStateManager,\n110:   refineForGoal,\n111: } from '../lib/search/session-state.js';\n112: \n113: // Type imports for casting\n114: import type { IntentType, IntentWeights as IntentClassifierWeights } from '../lib/search/intent-classifier.js';\n115: import type { RawSearchResult } from '../formatters/index.js';\n116: // RoutingResult, WeightedResult — now used internally by lib/search/search-utils.ts\n117: \n118: // Feature catalog: Semantic and lexical search (memory_search)\n119: // Feature catalog: Hybrid search pipeline\n120: // Feature catalog: 4-stage pipeline architecture\n121: // Feature catalog: Quality-aware 3-tier search fallback\n122: \n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    2. TYPES\n126: ──────────────────────────────────────────────────────────────── */\n127: \n128: /**\n129:  * Internal search result row — enriched DB row used within this handler.\n130:  * NOT the same as the canonical SearchResult in shared/types.ts.\n131:  * Self-contained: uses local types instead of the deprecated MemoryRow/MemoryRecord shapes.\n132:  * This can migrate to MemoryDbRow & Record<string, unknown> later without changing the handler contract.\n133:  */\n134: interface MemorySearchRow extends Record<string, unknown> {\n135:   id: number;\n136:   similarity?: number;\n137:   importance_tier?: string;\n138:   contextType?: string;\n139:   context_type?: string;\n140:   attentionScore?: number;\n141:   retrievability?: number;\n142:   stability?: number;\n143:   last_review?: string | null;\n144:   created_at?: string;\n145:   last_accessed?: number;\n146:   content?: string;\n147:   memoryState?: string;\n148:   file_path?: string;\n149:   parent_id?: number | null;\n150:   chunk_index?: number | null;\n151:   chunk_label?: string | null;\n152:   isChunk?: boolean;\n153:   parentId?: number | null;\n154:   chunkIndex?: number | null;\n155:   chunkLabel?: string | null;\n156:   chunkCount?: number | null;\n157:   contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n158:   precomputedContent?: string;\n159: }\n160: \n161: interface DedupResult {\n162:   results: MemorySearchRow[];\n163:   dedupStats: Record<string, unknown>;\n164: }\n165: \n166: interface FolderBoost {\n167:   folder: string;\n168:   factor: number;\n169: }\n170: \n171: interface SearchCachePayload {\n172:   summary: string;\n173:   data: Record<string, unknown>;\n174:   hints: string[];\n175: }\n176: \n177: type SessionAwareResult = Record<string, unknown> & {\n178:   id: number | string;\n179:   score?: number;\n180:   content?: string;\n181: };\n182: \n183: type CanonicalSourceKind = 'spec_doc' | 'continuity' | 'constitutional';\n184: \n185: interface CanonicalSourceStats {\n186:   retained: number;\n187:   dropped: number;\n188:   bySourceKind: Record<CanonicalSourceKind, number>;\n189: }\n190: \n191: const CONTINUITY_ANCHOR_ID = '_memory.continuity';\n192: const CANONICAL_READER_CACHE_VERSION = 'gate-d-reader-ready-v1';\n193: const CANONICAL_SPEC_DOC_DOCUMENT_TYPES = new Set([\n194:   'spec',\n195:   'plan',\n196:   'tasks',\n197:   'checklist',\n198:   'decision_record',\n199:   'implementation_summary',\n200:   'research',\n201:   'handover',\n202:   'graph_metadata',\n203:   'spec_doc',\n204: ]);\n205: const NON_CANONICAL_DOCUMENT_TYPES = new Set([\n206:   'memory',\n207:   'scratch',\n208: ]);\n209: \n210: function normalizeDocumentType(value: unknown): string | null {\n211:   if (typeof value !== 'string') {\n212:     return null;\n213:   }\n214:   const normalized = value.trim().toLowerCase();\n215:   return normalized.length > 0 ? normalized : null;\n216: }\n217: \n218: function resolveAnchorId(row: Record<string, unknown>): string | null {\n219:   const value = row.anchor_id ?? row.anchorId;\n220:   return typeof value === 'string' && value.trim().length > 0\n221:     ? value.trim()\n222:     : null;\n223: }\n224: \n225: function resolveFilePath(row: Record<string, unknown>): string | null {\n226:   const value = row.file_path ?? row.filePath;\n227:   return typeof value === 'string' && value.trim().length > 0\n228:     ? value\n229:     : null;\n230: }\n231: \n232: function resolveCanonicalSourceKind(row: Record<string, unknown>): CanonicalSourceKind | null {\n233:   const documentType = normalizeDocumentType(row.document_type ?? row.documentType);\n234:   const importanceTier = normalizeDocumentType(row.importance_tier ?? row.importanceTier);\n235:   const anchorId = resolveAnchorId(row);\n236: \n237:   if (importanceTier === 'constitutional' || documentType === 'constitutional') {\n238:     return 'constitutional';\n239:   }\n240: \n241:   if (anchorId === CONTINUITY_ANCHOR_ID || documentType === 'continuity') {\n242:     return 'continuity';\n243:   }\n244: \n245:   if (documentType && CANONICAL_SPEC_DOC_DOCUMENT_TYPES.has(documentType)) {\n246:     return 'spec_doc';\n247:   }\n248: \n249:   if (documentType && NON_CANONICAL_DOCUMENT_TYPES.has(documentType)) {\n250:     return null;\n251:   }\n252: \n253:   const filePath = resolveFilePath(row);\n254:   if (!filePath) {\n255:     return null;\n256:   }\n257:   const normalizedPath = normalizeSpecPath(filePath);\n258:   const basename = normalizedPath.split('/').filter(Boolean).pop() ?? '';\n259: \n260:   if (\n261:     basename.length > 0 &&\n262:     SPEC_DOCUMENT_FILENAMES.has(basename) &&\n263:     canClassifyAsSpecDocument(normalizedPath)\n264:   ) {\n265:     return anchorId === CONTINUITY_ANCHOR_ID ? 'continuity' : 'spec_doc';\n266:   }\n267: \n268:   return null;\n269: }\n270: \n271: function filterCanonicalSourceRows<T extends SessionAwareResult>(\n272:   results: T[],\n273: ): { results: T[]; stats: CanonicalSourceStats } {\n274:   const stats: CanonicalSourceStats = {\n275:     retained: 0,\n276:     dropped: 0,\n277:     bySourceKind: {\n278:       spec_doc: 0,\n279:       continuity: 0,\n280:       constitutional: 0,\n\n(Showing lines 1-280 of 1788. Use offset=281 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Search\n// ───────────────────────────────────────────────────────────────\n/* ───────────────────────────────────────────────────────────────\n   1. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\nimport * as intentClassifier from '../lib/search/intent-classifier.js';\n// TierClassifier, crossEncoder imports removed — only used by legacy V1 pipeline.\nimport { isSessionBoostEnabled, isCausalBoostEnabled, isCommunitySearchFallbackEnabled, isDualRetrievalEnabled, isIntentAutoProfileEnabled } from '../lib/search/search-flags.js';\nimport { searchCommunities } from '../lib/search/community-search.js';\n// 4-stage pipeline architecture\nimport { executePipeline } from '../lib/search/pipeline/index.js';\nimport type { PipelineConfig, PipelineResult } from '../lib/search/pipeline/index.js';\nimport type { IntentWeightsConfig } from '../lib/search/pipeline/types.js';\nimport { initConsumptionLog, logConsumptionEvent } from '../lib/telemetry/consumption-logger.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Search\n// ───────────────────────────────────────────────────────────────\n/* ───────────────────────────────────────────────────────────────\n   1. DEPENDENCIES\n──────────────────────────────────────────────────────────────── */\n\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\nimport * as intentClassifier from '../lib/search/intent-classifier.js';\n// TierClassifier, crossEncoder imports removed — only used by legacy V1 pipeline.\nimport { isSessionBoostEnabled, isCausalBoostEnabled, isCommunitySearchFallbackEnabled, isDualRetrievalEnabled, isIntentAutoProfileEnabled } from '../lib/search/search-flags.js';\nimport { searchCommunities } from '../lib/search/community-search.js';\n// 4-stage pipeline architecture\nimport { executePipeline } from '../lib/search/pipeline/index.js';\nimport type { PipelineConfig, PipelineResult } from '../lib/search/pipeline/index.js';\nimport type { IntentWeightsConfig } from '../lib/search/pipeline/types.js';\nimport { initConsumptionLog, logConsumptionEvent } from '../lib/telemetry/consumption-logger.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\n// Artifact-class routing (spec/plan/tasks/checklist/memory)\nimport { getStrategyForQuery } from '../lib/search/artifact-routing.js';\nimport { routeQuery } from '../lib/search/query-router.js';\nimport { createEmptyQueryPlan, type QueryPlan } from '../lib/query/query-plan.js';\nimport { getGraphReadinessSnapshotFromMarker } from '../lib/code-graph-boundary.js';\nimport { mapGraphReadinessToTelemetry } from '../lib/search/graph-readiness-mapper.js';\nimport {\n  buildSearchDecisionEnvelope,\n  type SearchDecisionEnvelope,\n} from '../lib/search/search-decision-envelope.js';\nimport { recordSearchDecision } from '../lib/search/decision-audit.js';\n// Chunk reassembly (extracted from this file)\nimport { collapseAndReassembleChunkResults } from '../lib/search/chunk-reassembly.js';\n// Search utilities (extracted from this file)\nimport {\n  filterByMinQualityScore,\n  resolveQualityThreshold,\n  buildCacheArgs,\n  resolveRowContextType,\n  resolveArtifactRoutingQuery,\n  applyArtifactRouting,\n} from '../lib/search/search-utils.js';\n// CacheArgsInput used internally by buildCacheArgs (lib/search/search-utils.ts)\n// Eval channel tracking (extracted from this file)\nimport {\n  collectEvalChannelsFromRow,\n  buildEvalChannelPayloads,\n  summarizeGraphWalkDiagnostics,\n} from '../lib/telemetry/eval-channel-tracking.js';\nimport type { EvalChannelPayload } from '../lib/telemetry/eval-channel-tracking.js';\n\n// Eval logger — fail-safe, no-op when SPECKIT_EVAL_LOGGING !== \"true\"\nimport { logSearchQuery, logChannelResult, logFinalResult } from '../lib/eval/eval-logger.js';\nimport {\n  logFeedbackEvents,\n  isImplicitFeedbackLogEnabled,\n} from '../lib/feedback/feedback-ledger.js';\nimport type { FeedbackEvent } from '../lib/feedback/feedback-ledger.js';\nimport { trackQueryAndDetect, logResultCited } from '../lib/feedback/query-flow-tracker.js';\n\n// Core utilities\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { validateQuery, requireDb, toErrorMessage } from '../utils/index.js';\n\n// Response envelope + formatters\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { formatSearchResults } from '../formatters/index.js';\n\n// Shared handler types\nimport type { MCPResponse, IntentClassification } from './types.js';\n\n// Retrieval trace contracts (C136-08)\nimport { createTrace } from '@spec-kit/shared/contracts/retrieval-trace';\nimport { buildAdaptiveShadowProposal } from '../lib/cognitive/adaptive-ranking.js';\nimport { normalizeScopeContext, filterRowsByScope } from '../lib/governance/scope-governance.js';\nimport {\n  attachSessionTransitionTrace,\n  type SessionTransitionTrace,\n} from '../lib/search/session-transition.js';\n\n// Mode-Aware Response Shape\nimport {\n  applyProfileToEnvelope,\n  isResponseProfileEnabled,\n} from '../lib/response/profile-formatters.js';\nimport {\n  buildProgressiveResponse,\n  extractSnippets,\n  isProgressiveDisclosureEnabled,\n  resolveCursor,\n} from '../lib/search/progressive-disclosure.js';\nimport {\n  SPEC_DOCUMENT_FILENAMES,\n  canClassifyAsSpecDocument,\n  normalizeSpecPath,\n} from '../lib/config/spec-doc-paths.js';\nimport {\n  getLastLexicalCapabilitySnapshot,\n  resetLastLexicalCapabilitySnapshot,\n} from '../lib/search/sqlite-fts.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport type { LexicalCapabilitySnapshot } from '../lib/search/sqlite-fts.js';\nimport { buildVectorDegradationSignal } from '../lib/observability/retrieval-observability.js';\nimport { evaluatePublicationGate } from '../lib/context/publication-gate.js';\nimport {\n  deduplicateResults as deduplicateWithSessionState,\n  isSessionRetrievalStateEnabled,\n  manager as retrievalSessionStateManager,\n  refineForGoal,\n} from '../lib/search/session-state.js';\n\n// Type imports for casting\nimport type { IntentType, IntentWeights as IntentClassifierWeights } from '../lib/search/intent-classifier.js';\nimport type { RawSearchResult } from '../formatters/index.js';\n// RoutingResult, WeightedResult — now used internally by lib/search/search-utils.ts\n\n// Feature catalog: Semantic and lexical search (memory_search)\n// Feature catalog: Hybrid search pipeline\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: Quality-aware 3-tier search fallback\n\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Internal search result row — enriched DB row used within this handler.\n * NOT the same as the canonical SearchResult in shared/types.ts.\n * Self-contained: uses local types instead of the deprecated MemoryRow/MemoryRecord shapes.\n * This can migrate to MemoryDbRow & Record<string, unknown> later without changing the handler contract.\n */\ninterface MemorySearchRow extends Record<string, unknown> {\n  id: number;\n  similarity?: number;\n  importance_tier?: string;\n  contextType?: string;\n  context_type?: string;\n  attentionScore?: number;\n  retrievability?: number;\n  stability?: number;\n  last_review?: string | null;\n  created_at?: string;\n  last_accessed?: number;\n  content?: string;\n  memoryState?: string;\n  file_path?: string;\n  parent_id?: number | null;\n  chunk_index?: number | null;\n  chunk_label?: string | null;\n  isChunk?: boolean;\n  parentId?: number | null;\n  chunkIndex?: number | null;\n  chunkLabel?: string | null;\n  chunkCount?: number | null;\n  contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n  precomputedContent?: string;\n}\n\ninterface DedupResult {\n  results: MemorySearchRow[];\n  dedupStats: Record<string, unknown>;\n}\n\ninterface FolderBoost {\n  folder: string;\n  factor: number;\n}\n\ninterface SearchCachePayload {\n  summary: string;\n  data: Record<string, unknown>;\n  hints: string[];\n}\n\ntype SessionAwareResult = Record<string, unknown> & {\n  id: number | string;\n  score?: number;\n  content?: string;\n};\n\ntype CanonicalSourceKind = 'spec_doc' | 'continuity' | 'constitutional';\n\ninterface CanonicalSourceStats {\n  retained: number;\n  dropped: number;\n  bySourceKind: Record<CanonicalSourceKind, number>;\n}\n\nconst CONTINUITY_ANCHOR_ID = '_memory.continuity';\nconst CANONICAL_READER_CACHE_VERSION = 'gate-d-reader-ready-v1';\nconst CANONICAL_SPEC_DOC_DOCUMENT_TYPES = new Set([\n  'spec',\n  'plan',\n  'tasks',\n  'checklist',\n  'decision_record',\n  'implementation_summary',\n  'research',\n  'handover',\n  'graph_metadata',\n  'spec_doc',\n]);\nconst NON_CANONICAL_DOCUMENT_TYPES = new Set([\n  'memory',\n  'scratch',\n]);\n\nfunction normalizeDocumentType(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim().toLowerCase();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction resolveAnchorId(row: Record<string, unknown>): string | null {\n  const value = row.anchor_id ?? row.anchorId;\n  return typeof value === 'string' && value.trim().length > 0\n    ? value.trim()\n    : null;\n}\n\nfunction resolveFilePath(row: Record<string, unknown>): string | null {\n  const value = row.file_path ?? row.filePath;\n  return typeof value === 'string' && value.trim().length > 0\n    ? value\n    : null;\n}\n\nfunction resolveCanonicalSourceKind(row: Record<string, unknown>): CanonicalSourceKind | null {\n  const documentType = normalizeDocumentType(row.document_type ?? row.documentType);\n  const importanceTier = normalizeDocumentType(row.importance_tier ?? row.importanceTier);\n  const anchorId = resolveAnchorId(row);\n\n  if (importanceTier === 'constitutional' || documentType === 'constitutional') {\n    return 'constitutional';\n  }\n\n  if (anchorId === CONTINUITY_ANCHOR_ID || documentType === 'continuity') {\n    return 'continuity';\n  }\n\n  if (documentType && CANONICAL_SPEC_DOC_DOCUMENT_TYPES.has(documentType)) {\n    return 'spec_doc';\n  }\n\n  if (documentType && NON_CANONICAL_DOCUMENT_TYPES.has(documentType)) {\n    return null;\n  }\n\n  const filePath = resolveFilePath(row);\n  if (!filePath) {\n    return null;\n  }\n  const normalizedPath = normalizeSpecPath(filePath);\n  const basename = normalizedPath.split('/').filter(Boolean).pop() ?? '';\n\n  if (\n    basename.length > 0 &&\n    SPEC_DOCUMENT_FILENAMES.has(basename) &&\n    canClassifyAsSpecDocument(normalizedPath)\n  ) {\n    return anchorId === CONTINUITY_ANCHOR_ID ? 'continuity' : 'spec_doc';\n  }\n\n  return null;\n}\n\nfunction filterCanonicalSourceRows<T extends SessionAwareResult>(\n  results: T[],\n): { results: T[]; stats: CanonicalSourceStats } {\n  const stats: CanonicalSourceStats = {\n    retained: 0,\n    dropped: 0,\n    bySourceKind: {\n      spec_doc: 0,\n      continuity: 0,\n      constitutional: 0,","lineStart":1,"lineEnd":280,"totalLines":1788,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781764125150,"end":1781764125156}},"metadata":{"openai":{"itemId":"fc_09ce19760b694a7c016a33901cba4c8191a7f411e5a64b444f"}},"id":"prt_ed96af196001dGunnIkRQau75Q","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96ab68d001yXE4gNbuKK33KX"}}
{"type":"tool_use","timestamp":1781764125207,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_YbpIi6sZu8fWXWd7QacxZgMI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Confidence Scoring\n3: // ───────────────────────────────────────────────────────────────\n4: // Per-result calibrated confidence scoring\n5: //\n6: // PURPOSE: Combine margin, multi-channel agreement,\n7: // and anchor density into a single calibrated confidence score per\n8: // result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n9: //\n10: // FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n11: //\n12: // OUTPUT SHAPE (per result):\n13: // {\n14: //   \"confidence\": {\n15: //     \"label\": \"high\" | \"medium\" | \"low\",\n16: //     \"value\": 0.78,\n17: //     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n18: //   },\n19: //   \"requestQuality\": {\n20: //     \"label\": \"good\" | \"weak\" | \"gap\"\n21: //   }\n22: // }\n23: //\n24: // IMPORTANT: This module only models ranking confidence for retrieval ordering.\n25: // It is not freshness authority and it is not a substitute for StructuralTrust.\n26: import { statSync } from 'node:fs';\n27: import { resolveEffectiveScore, resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\n28: import {\n29:   isAbsoluteRelevanceCalibrationEnabled,\n30:   isConfidenceCalibrationEnabled,\n31:   getConfidenceCalibrationModelPath,\n32: } from './search-flags.js';\n33: import { applyCalibration, loadCalibrationModel, type CalibrationModel } from './confidence-calibration.js';\n34: \n35: declare const rankingConfidenceBrand: unique symbol;\n36: \n37: // -- Constants --\n38: \n39: const HIGH_THRESHOLD = 0.7;\n40: const LOW_THRESHOLD = 0.4;\n41: \n42: // Weights for each active confidence factor. The former reranker weight (0.20)\n43: // was removed with the LLM reranker; its term was already inert (always 0), so\n44: // rawValue stays capped at 0.80 exactly as before — behavior-neutral. The 0.20\n45: // is intentionally NOT redistributed (that would change confidence scores).\n46: const WEIGHT_MARGIN = 0.35;\n47: const WEIGHT_CHANNEL_AGREEMENT = 0.30;\n48: const WEIGHT_ANCHOR_DENSITY = 0.15;\n49: \n50: // Blend of the heuristic signal (margin/channel/anchor) and the absolute\n51: // relevance prior into the final per-result value. Relevance is intentionally\n52: // weighted higher than the heuristics so the band is monotonic in relevance: a\n53: // strong-but-isolated cosine hit (single channel, no anchors, tail margin) must\n54: // not be capped at \"medium\" purely because the heuristic signals are weak.\n55: // These two must sum to 1.0.\n56: const WEIGHT_HEURISTIC = 0.45;\n57: const WEIGHT_SCORE_PRIOR = 0.55;\n58: \n59: // Guard the sum-to-1.0 invariant at module load: if either weight is retuned\n60: // without adjusting the other, the rebalanced value would no longer be a convex\n61: // blend and could exceed 1 before clamping (silently distorting the band). Fail\n62: // loudly instead. Tolerance absorbs float representation error (0.45 + 0.55).\n63: if (Math.abs(WEIGHT_HEURISTIC + WEIGHT_SCORE_PRIOR - 1.0) > 1e-9) {\n64:   throw new Error(\n65:     `confidence-scoring: WEIGHT_HEURISTIC (${WEIGHT_HEURISTIC}) + WEIGHT_SCORE_PRIOR (${WEIGHT_SCORE_PRIOR}) must sum to 1.0`,\n66:   );\n67: }\n68: \n69: // Margin thresholds (gap between top score and next score, 0–1 scale)\n70: const LARGE_MARGIN_THRESHOLD = 0.15;\n71: const SMALL_MARGIN_THRESHOLD = 0.05;\n72: \n73: // Channel count thresholds\n74: const STRONG_CHANNEL_AGREEMENT_MIN = 2;\n75: \n76: // Request-quality aggregation: a top hit at or above this absolute relevance\n77: // stands on its own, so a weak tail cannot drag the verdict below \"good\".\n78: const TOP_DOMINANT_THRESHOLD = 0.8;\n79: \n80: // Cap the quality-ratio denominator at the head of the ranking. Pulling deeper\n81: // for recall appends weaker tail results; counting them would mechanically\n82: // depress the ratio and penalize a query for retrieving more candidates.\n83: const QUALITY_RATIO_HEAD = 5;\n84: \n85: // -- Types --\n86: \n87: /** Confidence label for a single result. */\n88: export type ConfidenceLabel = 'high' | 'medium' | 'low';\n89: \n90: /**\n91:  * Branded ranking score for retrieval ordering only.\n92:  * Consumers must not reuse this as parser provenance, evidence status,\n93:  * freshness authority, or any other StructuralTrust axis.\n94:  */\n95: export type RankingConfidenceValue = number & {\n96:   readonly [rankingConfidenceBrand]: 'RankingConfidenceValue';\n97: };\n98: \n99: /** Quality label at the request level (across all results). */\n100: export type RequestQualityLabel = 'good' | 'weak' | 'gap';\n101: \n102: /** Which factors drove the confidence score upward. */\n103: export type ConfidenceDriver =\n104:   | 'large_margin'\n105:   | 'multi_channel_agreement'\n106:   | 'anchor_density';\n107: \n108: /** Per-result confidence payload. */\n109: export interface RankingConfidenceContract {\n110:   label: ConfidenceLabel;\n111:   value: RankingConfidenceValue;\n112:   drivers: ConfidenceDriver[];\n113:   structuralTrust?: never;\n114:   parserProvenance?: never;\n115:   evidenceStatus?: never;\n116:   freshnessAuthority?: never;\n117: }\n118: \n119: export interface ResultConfidence {\n120:   confidence: RankingConfidenceContract;\n121: }\n122: \n123: /** Request-level quality assessment (one per search call). */\n124: export interface RequestQualityAssessment {\n125:   requestQuality: {\n126:     label: RequestQualityLabel;\n127:   };\n128: }\n129: \n130: /**\n131:  * Minimal result shape needed for confidence computation.\n132:  * Uses `Record<string, unknown>` to stay compatible with both\n133:  * `RawSearchResult` and `PipelineRow` without importing either.\n134:  */\n135: export interface ScoredResult extends Record<string, unknown> {\n136:   id: number;\n137:   /** Composite score (0–1). */\n138:   score?: number;\n139:   /** RRF fusion score (0–1). */\n140:   rrfScore?: number;\n141:   /** Intent-adjusted score (0–1). */\n142:   intentAdjustedScore?: number;\n143:   /** Raw cosine similarity (0–100 scale from sqlite-vec). */\n144:   similarity?: number;\n145:   /** Score origin metadata for distinguishing real reranks from fallbacks. */\n146:   scoringMethod?: string;\n147:   /** Anchor metadata array populated by Stage 2. */\n148:   anchorMetadata?: Array<Record<string, unknown>>;\n149:   /** Source channels that contributed this result. */\n150:   sources?: string[];\n151:   /** Single source channel string (legacy). */\n152:   source?: string;\n153:   /** Trace metadata containing channel attribution. */\n154:   traceMetadata?: Record<string, unknown>;\n155: }\n156: \n157: // -- Internal helpers --\n158: \n159: function resolveScore(result: ScoredResult): number {\n160:   return resolveEffectiveScore(result as PipelineRow);\n161: }\n162: \n163: /**\n164:  * Absolute relevance used for confidence calibration and request-quality — keeps\n165:  * ordering on the RRF/effective score while reading an absolute 0–1 signal for\n166:  * \"how good is this\", so the 0.7/0.4 thresholds mean what they say. Reverts to the\n167:  * effective score when SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION is disabled.\n168:  */\n169: function resolveCalibrationScore(result: ScoredResult): number {\n170:   return isAbsoluteRelevanceCalibrationEnabled()\n171:     ? resolveAbsoluteRelevance(result as PipelineRow)\n172:     : resolveEffectiveScore(result as PipelineRow);\n173: }\n174: \n175: // Lazily-loaded calibration model, memoized so the search hot path reads the\n176: // file at most once per (path, mtime) pair. The mtime is part of the cache key\n177: // so editing the model in place re-reads it; without it a path-stable file\n178: // rewritten on disk would serve the stale fitted curve indefinitely.\n179: // `undefined` = not yet looked up; `null` = looked up and absent/invalid\n180: // (degrade to identity).\n181: let cachedCalibrationModel: CalibrationModel | null | undefined;\n182: let cachedCalibrationModelPath: string | undefined;\n183: let cachedCalibrationModelMtimeMs: number | undefined;\n184: \n185: /** Best-effort mtime; `undefined` when the path is unreadable (treated as a miss). */\n186: function calibrationModelMtimeMs(path: string): number | undefined {\n187:   try {\n188:     return statSync(path).mtimeMs;\n189:   } catch {\n190:     return undefined;\n191:   }\n192: }\n193: \n194: function resolveCalibrationModel(): CalibrationModel | null {\n195:   const path = getConfidenceCalibrationModelPath();\n196:   if (!path) return null;\n197:   const mtimeMs = calibrationModelMtimeMs(path);\n198:   if (\n199:     cachedCalibrationModel !== undefined &&\n200:     cachedCalibrationModelPath === path &&\n201:     cachedCalibrationModelMtimeMs === mtimeMs\n202:   ) {\n203:     return cachedCalibrationModel;\n204:   }\n205:   cachedCalibrationModelPath = path;\n206:   cachedCalibrationModelMtimeMs = mtimeMs;\n207:   cachedCalibrationModel = loadCalibrationModel(path);\n208:   return cachedCalibrationModel;\n209: }\n210: \n211: /**\n212:  * Map a rebalanced confidence value through the empirical calibration model\n213:  * when enabled. Default OFF and a no-op when no model is configured, so the\n214:  * returned value is identical to the rebalance-only path until a validated\n215:  * model is wired in.\n216:  */\n217: function maybeCalibrate(value: number): number {\n218:   if (!isConfidenceCalibrationEnabled()) return value;\n219:   const model = resolveCalibrationModel();\n220:   if (!model) return value;\n221:   return applyCalibration(model, value);\n222: }\n223: \n224: /**\n225:  * Count the number of unique channels that retrieved this result.\n226:  * Inspects `sources`, `source`, and traceMetadata.attribution.\n227:  */\n228: function countChannels(result: ScoredResult): number {\n229:   const channels = new Set<string>();\n230: \n231:   if (Array.isArray(result.sources)) {\n232:     for (const s of result.sources) {\n233:       if (typeof s === 'string' && s.trim().length > 0) channels.add(s.trim());\n234:     }\n235:   }\n236: \n237:   if (typeof result.source === 'string' && result.source.trim().length > 0) {\n238:     channels.add(result.source.trim());\n239:   }\n240: \n241:   // Check traceMetadata.attribution for richer channel data\n242:   const numericId = typeof result.id === 'number' ? result.id : null;\n243:   const attribution = result.traceMetadata?.attribution;\n244:   if (attribution && typeof attribution === 'object' && numericId !== null) {\n245:     for (const [channel, memoryIds] of Object.entries(attribution as Record<string, unknown>)) {\n246:       if (!Array.isArray(memoryIds)) continue;\n247:       const matched = memoryIds.some((mid) => {\n248:         const n = typeof mid === 'number' ? mid : typeof mid === 'string' ? Number(mid) : NaN;\n249:         return Number.isFinite(n) && n === numericId;\n250:       });\n251:       if (matched && typeof channel === 'string' && channel.trim().length > 0) {\n252:         channels.add(channel.trim());\n253:       }\n254:     }\n255:   }\n256: \n257:   return channels.size;\n258: }\n259: \n260: /**\n\n(Showing lines 1-260 of 443. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Scoring\n// ───────────────────────────────────────────────────────────────\n// Per-result calibrated confidence scoring\n//\n// PURPOSE: Combine margin, multi-channel agreement,\n// and anchor density into a single calibrated confidence score per\n// result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n//\n// FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE (per result):\n// {\n//   \"confidence\": {\n//     \"label\": \"high\" | \"medium\" | \"low\",\n//     \"value\": 0.78,\n//     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n//   },\n//   \"requestQuality\": {\n//     \"label\": \"good\" | \"weak\" | \"gap\"","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Scoring\n// ───────────────────────────────────────────────────────────────\n// Per-result calibrated confidence scoring\n//\n// PURPOSE: Combine margin, multi-channel agreement,\n// and anchor density into a single calibrated confidence score per\n// result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n//\n// FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE (per result):\n// {\n//   \"confidence\": {\n//     \"label\": \"high\" | \"medium\" | \"low\",\n//     \"value\": 0.78,\n//     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n//   },\n//   \"requestQuality\": {\n//     \"label\": \"good\" | \"weak\" | \"gap\"\n//   }\n// }\n//\n// IMPORTANT: This module only models ranking confidence for retrieval ordering.\n// It is not freshness authority and it is not a substitute for StructuralTrust.\nimport { statSync } from 'node:fs';\nimport { resolveEffectiveScore, resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\nimport {\n  isAbsoluteRelevanceCalibrationEnabled,\n  isConfidenceCalibrationEnabled,\n  getConfidenceCalibrationModelPath,\n} from './search-flags.js';\nimport { applyCalibration, loadCalibrationModel, type CalibrationModel } from './confidence-calibration.js';\n\ndeclare const rankingConfidenceBrand: unique symbol;\n\n// -- Constants --\n\nconst HIGH_THRESHOLD = 0.7;\nconst LOW_THRESHOLD = 0.4;\n\n// Weights for each active confidence factor. The former reranker weight (0.20)\n// was removed with the LLM reranker; its term was already inert (always 0), so\n// rawValue stays capped at 0.80 exactly as before — behavior-neutral. The 0.20\n// is intentionally NOT redistributed (that would change confidence scores).\nconst WEIGHT_MARGIN = 0.35;\nconst WEIGHT_CHANNEL_AGREEMENT = 0.30;\nconst WEIGHT_ANCHOR_DENSITY = 0.15;\n\n// Blend of the heuristic signal (margin/channel/anchor) and the absolute\n// relevance prior into the final per-result value. Relevance is intentionally\n// weighted higher than the heuristics so the band is monotonic in relevance: a\n// strong-but-isolated cosine hit (single channel, no anchors, tail margin) must\n// not be capped at \"medium\" purely because the heuristic signals are weak.\n// These two must sum to 1.0.\nconst WEIGHT_HEURISTIC = 0.45;\nconst WEIGHT_SCORE_PRIOR = 0.55;\n\n// Guard the sum-to-1.0 invariant at module load: if either weight is retuned\n// without adjusting the other, the rebalanced value would no longer be a convex\n// blend and could exceed 1 before clamping (silently distorting the band). Fail\n// loudly instead. Tolerance absorbs float representation error (0.45 + 0.55).\nif (Math.abs(WEIGHT_HEURISTIC + WEIGHT_SCORE_PRIOR - 1.0) > 1e-9) {\n  throw new Error(\n    `confidence-scoring: WEIGHT_HEURISTIC (${WEIGHT_HEURISTIC}) + WEIGHT_SCORE_PRIOR (${WEIGHT_SCORE_PRIOR}) must sum to 1.0`,\n  );\n}\n\n// Margin thresholds (gap between top score and next score, 0–1 scale)\nconst LARGE_MARGIN_THRESHOLD = 0.15;\nconst SMALL_MARGIN_THRESHOLD = 0.05;\n\n// Channel count thresholds\nconst STRONG_CHANNEL_AGREEMENT_MIN = 2;\n\n// Request-quality aggregation: a top hit at or above this absolute relevance\n// stands on its own, so a weak tail cannot drag the verdict below \"good\".\nconst TOP_DOMINANT_THRESHOLD = 0.8;\n\n// Cap the quality-ratio denominator at the head of the ranking. Pulling deeper\n// for recall appends weaker tail results; counting them would mechanically\n// depress the ratio and penalize a query for retrieving more candidates.\nconst QUALITY_RATIO_HEAD = 5;\n\n// -- Types --\n\n/** Confidence label for a single result. */\nexport type ConfidenceLabel = 'high' | 'medium' | 'low';\n\n/**\n * Branded ranking score for retrieval ordering only.\n * Consumers must not reuse this as parser provenance, evidence status,\n * freshness authority, or any other StructuralTrust axis.\n */\nexport type RankingConfidenceValue = number & {\n  readonly [rankingConfidenceBrand]: 'RankingConfidenceValue';\n};\n\n/** Quality label at the request level (across all results). */\nexport type RequestQualityLabel = 'good' | 'weak' | 'gap';\n\n/** Which factors drove the confidence score upward. */\nexport type ConfidenceDriver =\n  | 'large_margin'\n  | 'multi_channel_agreement'\n  | 'anchor_density';\n\n/** Per-result confidence payload. */\nexport interface RankingConfidenceContract {\n  label: ConfidenceLabel;\n  value: RankingConfidenceValue;\n  drivers: ConfidenceDriver[];\n  structuralTrust?: never;\n  parserProvenance?: never;\n  evidenceStatus?: never;\n  freshnessAuthority?: never;\n}\n\nexport interface ResultConfidence {\n  confidence: RankingConfidenceContract;\n}\n\n/** Request-level quality assessment (one per search call). */\nexport interface RequestQualityAssessment {\n  requestQuality: {\n    label: RequestQualityLabel;\n  };\n}\n\n/**\n * Minimal result shape needed for confidence computation.\n * Uses `Record<string, unknown>` to stay compatible with both\n * `RawSearchResult` and `PipelineRow` without importing either.\n */\nexport interface ScoredResult extends Record<string, unknown> {\n  id: number;\n  /** Composite score (0–1). */\n  score?: number;\n  /** RRF fusion score (0–1). */\n  rrfScore?: number;\n  /** Intent-adjusted score (0–1). */\n  intentAdjustedScore?: number;\n  /** Raw cosine similarity (0–100 scale from sqlite-vec). */\n  similarity?: number;\n  /** Score origin metadata for distinguishing real reranks from fallbacks. */\n  scoringMethod?: string;\n  /** Anchor metadata array populated by Stage 2. */\n  anchorMetadata?: Array<Record<string, unknown>>;\n  /** Source channels that contributed this result. */\n  sources?: string[];\n  /** Single source channel string (legacy). */\n  source?: string;\n  /** Trace metadata containing channel attribution. */\n  traceMetadata?: Record<string, unknown>;\n}\n\n// -- Internal helpers --\n\nfunction resolveScore(result: ScoredResult): number {\n  return resolveEffectiveScore(result as PipelineRow);\n}\n\n/**\n * Absolute relevance used for confidence calibration and request-quality — keeps\n * ordering on the RRF/effective score while reading an absolute 0–1 signal for\n * \"how good is this\", so the 0.7/0.4 thresholds mean what they say. Reverts to the\n * effective score when SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION is disabled.\n */\nfunction resolveCalibrationScore(result: ScoredResult): number {\n  return isAbsoluteRelevanceCalibrationEnabled()\n    ? resolveAbsoluteRelevance(result as PipelineRow)\n    : resolveEffectiveScore(result as PipelineRow);\n}\n\n// Lazily-loaded calibration model, memoized so the search hot path reads the\n// file at most once per (path, mtime) pair. The mtime is part of the cache key\n// so editing the model in place re-reads it; without it a path-stable file\n// rewritten on disk would serve the stale fitted curve indefinitely.\n// `undefined` = not yet looked up; `null` = looked up and absent/invalid\n// (degrade to identity).\nlet cachedCalibrationModel: CalibrationModel | null | undefined;\nlet cachedCalibrationModelPath: string | undefined;\nlet cachedCalibrationModelMtimeMs: number | undefined;\n\n/** Best-effort mtime; `undefined` when the path is unreadable (treated as a miss). */\nfunction calibrationModelMtimeMs(path: string): number | undefined {\n  try {\n    return statSync(path).mtimeMs;\n  } catch {\n    return undefined;\n  }\n}\n\nfunction resolveCalibrationModel(): CalibrationModel | null {\n  const path = getConfidenceCalibrationModelPath();\n  if (!path) return null;\n  const mtimeMs = calibrationModelMtimeMs(path);\n  if (\n    cachedCalibrationModel !== undefined &&\n    cachedCalibrationModelPath === path &&\n    cachedCalibrationModelMtimeMs === mtimeMs\n  ) {\n    return cachedCalibrationModel;\n  }\n  cachedCalibrationModelPath = path;\n  cachedCalibrationModelMtimeMs = mtimeMs;\n  cachedCalibrationModel = loadCalibrationModel(path);\n  return cachedCalibrationModel;\n}\n\n/**\n * Map a rebalanced confidence value through the empirical calibration model\n * when enabled. Default OFF and a no-op when no model is configured, so the\n * returned value is identical to the rebalance-only path until a validated\n * model is wired in.\n */\nfunction maybeCalibrate(value: number): number {\n  if (!isConfidenceCalibrationEnabled()) return value;\n  const model = resolveCalibrationModel();\n  if (!model) return value;\n  return applyCalibration(model, value);\n}\n\n/**\n * Count the number of unique channels that retrieved this result.\n * Inspects `sources`, `source`, and traceMetadata.attribution.\n */\nfunction countChannels(result: ScoredResult): number {\n  const channels = new Set<string>();\n\n  if (Array.isArray(result.sources)) {\n    for (const s of result.sources) {\n      if (typeof s === 'string' && s.trim().length > 0) channels.add(s.trim());\n    }\n  }\n\n  if (typeof result.source === 'string' && result.source.trim().length > 0) {\n    channels.add(result.source.trim());\n  }\n\n  // Check traceMetadata.attribution for richer channel data\n  const numericId = typeof result.id === 'number' ? result.id : null;\n  const attribution = result.traceMetadata?.attribution;\n  if (attribution && typeof attribution === 'object' && numericId !== null) {\n    for (const [channel, memoryIds] of Object.entries(attribution as Record<string, unknown>)) {\n      if (!Array.isArray(memoryIds)) continue;\n      const matched = memoryIds.some((mid) => {\n        const n = typeof mid === 'number' ? mid : typeof mid === 'string' ? Number(mid) : NaN;\n        return Number.isFinite(n) && n === numericId;\n      });\n      if (matched && typeof channel === 'string' && channel.trim().length > 0) {\n        channels.add(channel.trim());\n      }\n    }\n  }\n\n  return channels.size;\n}\n\n/**","lineStart":1,"lineEnd":260,"totalLines":443,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","time":{"start":1781764125201,"end":1781764125205}},"metadata":{"openai":{"itemId":"fc_09ce19760b694a7c016a33901cba5881918615c5b4b5e478f1"}},"id":"prt_ed96af1eb001WCNI8us87My6cs","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96ab68d001yXE4gNbuKK33KX"}}
