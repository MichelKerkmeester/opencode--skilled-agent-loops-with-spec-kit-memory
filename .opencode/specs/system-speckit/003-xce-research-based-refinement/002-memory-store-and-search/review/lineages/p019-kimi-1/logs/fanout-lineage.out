{"type":"tool_use","timestamp":1781720002090,"sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","part":{"type":"tool","tool":"read","callID":"tool_9BHU8Es1Q6dVEpVhOoUBqLUX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","limit":25,"offset":555},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n555: }\n556: \n557: function nowMsFromOptions(options = {}) {\n558:   if (typeof options.nowMs === 'function') return options.nowMs();\n559:   if (typeof options.nowMs === 'number') return options.nowMs;\n560:   return Date.now();\n561: }\n562: \n563: function modelServerGiveUpStaleMs(options = {}) {\n564:   const giveUpCooldownMs = parsePositiveInteger(options.giveUpCooldownMs, getModelServerGiveUpCooldownMs(options.env || process.env));\n565:   const staleMs = parsePositiveInteger(options.staleMs, RESPAWN_LOCK_STALE_MS);\n566:   return Math.max(staleMs, giveUpCooldownMs);\n567: }\n568: \n569: function isModelServerGiveUpStale(parsed, options = {}) {\n570:   const liveness = options.liveness || processLiveness;\n571:   if (liveness(parsed?.pid) === 'dead') return true;\n572: \n573:   const writtenAtMs = parsed?.writtenAt ? Date.parse(parsed.writtenAt) : NaN;\n574:   if (!Number.isFinite(writtenAtMs)) return false;\n575:   return nowMsFromOptions(options) - writtenAtMs > modelServerGiveUpStaleMs(options);\n576: }\n577: \n578: function unlinkBestEffort(filePath, fsApi = fs) {\n579:   try {\n\n(Showing lines 555-579 of 1474. Use offset=580 to continue.)\n</content>","metadata":{"preview":"}\n\nfunction nowMsFromOptions(options = {}) {\n  if (typeof options.nowMs === 'function') return options.nowMs();\n  if (typeof options.nowMs === 'number') return options.nowMs;\n  return Date.now();\n}\n\nfunction modelServerGiveUpStaleMs(options = {}) {\n  const giveUpCooldownMs = parsePositiveInteger(options.giveUpCooldownMs, getModelServerGiveUpCooldownMs(options.env || process.env));\n  const staleMs = parsePositiveInteger(options.staleMs, RESPAWN_LOCK_STALE_MS);\n  return Math.max(staleMs, giveUpCooldownMs);\n}\n\nfunction isModelServerGiveUpStale(parsed, options = {}) {\n  const liveness = options.liveness || processLiveness;\n  if (liveness(parsed?.pid) === 'dead') return true;\n\n  const writtenAtMs = parsed?.writtenAt ? Date.parse(parsed.writtenAt) : NaN;\n  if (!Number.isFinite(writtenAtMs)) return false;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","text":"}\n\nfunction nowMsFromOptions(options = {}) {\n  if (typeof options.nowMs === 'function') return options.nowMs();\n  if (typeof options.nowMs === 'number') return options.nowMs;\n  return Date.now();\n}\n\nfunction modelServerGiveUpStaleMs(options = {}) {\n  const giveUpCooldownMs = parsePositiveInteger(options.giveUpCooldownMs, getModelServerGiveUpCooldownMs(options.env || process.env));\n  const staleMs = parsePositiveInteger(options.staleMs, RESPAWN_LOCK_STALE_MS);\n  return Math.max(staleMs, giveUpCooldownMs);\n}\n\nfunction isModelServerGiveUpStale(parsed, options = {}) {\n  const liveness = options.liveness || processLiveness;\n  if (liveness(parsed?.pid) === 'dead') return true;\n\n  const writtenAtMs = parsed?.writtenAt ? Date.parse(parsed.writtenAt) : NaN;\n  if (!Number.isFinite(writtenAtMs)) return false;\n  return nowMsFromOptions(options) - writtenAtMs > modelServerGiveUpStaleMs(options);\n}\n\nfunction unlinkBestEffort(filePath, fsApi = fs) {\n  try {","lineStart":555,"lineEnd":579,"totalLines":1474,"truncated":true}},"title":".opencode/bin/lib/model-server-supervision.cjs","time":{"start":1781720002086,"end":1781720002089}},"id":"prt_ed6c9abaf001twO7sLSZAdwY5U","sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","messageID":"ms