{"type":"step_start","timestamp":1781723076163,"sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","part":{"id":"prt_ed6f89641001Wqyf2457xS9PAj","messageID":"msg_ed6f88aaf001jHbwyflSdpcA8l","sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","snapshot":"d4862a97b4be7154c1d75f5d6c845fd7b5065a02","type":"step-start"}}
{"type":"tool_use","timestamp":1781723079452,"sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","part":{"type":"tool","tool":"bash","callID":"call_2cc86e3e758c405d86c70305","state":{"status":"completed","input":{"command":"mkdir -p \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/002-memory-store-and-search/review/lineages/p017c003-mimo/iterations\"","description":"Create artifact directory structure"},"output":"(no output)","metadata":{"output":"(no output)","exit":0,"description":"Create artifact directory structure","truncated":false},"title":"Create artifact directory structure","time":{"start":1781723079443,"end":1781723079452}},"id":"prt_ed6f8a2fc001II9SDU11Wa2wSG","sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","messageID":"msg_ed6f88aaf001jHbwyflSdpcA8l"}}
{"type":"tool_use","timestamp":1781723079937,"sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","part":{"type":"tool","tool":"read","callID":"call_35064973dbbf478d81456ee2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/query-classifier.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/query-classifier.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Query Classifier\n3: // ───────────────────────────────────────────────────────────────\n4: /* --- 1. TYPES & CONSTANTS --- */\n5: \n6: // Feature catalog: Query complexity router\n7: \n8: import {\n9:   buildComplexityQueryPlan,\n10:   type QueryPlan,\n11: } from '../query/query-plan.js';\n12: \n13: type QueryComplexityTier = 'simple' | 'moderate' | 'complex';\n14: \n15: interface ClassificationResult {\n16:   tier: QueryComplexityTier;\n17:   features: {\n18:     termCount: number;\n19:     charCount: number;\n20:     hasTriggerMatch: boolean;\n21:     stopWordRatio: number;\n22:   };\n23:   confidence: 'high' | 'medium' | 'low' | 'fallback';\n24:   queryPlan: QueryPlan;\n25: }\n26: \n27: /** Config-driven thresholds */\n28: const SIMPLE_TERM_THRESHOLD = 3;\n29: const COMPLEX_TERM_THRESHOLD = 8;\n30: \n31: /**\n32:  * Stop-word ratio at or above which a short, trigger-less query is treated as\n33:  * low-signal. Such queries carry too little lexical anchor for the cheap simple\n34:  * route — which suppresses extra channels and synonym/embedding expansion — to\n35:  * recall reliably, so they are escalated to the full pipeline. Set above the\n36:  * one-stop-word-in-three ratio of ordinary verb-noun queries (e.g. \"fix the\n37:  * bug\" = 0.333) so only genuinely vague queries escalate.\n38:  */\n39: const LOW_SIGNAL_STOPWORD_RATIO = 0.5;\n40: \n41: /** Common English stop words for semantic complexity heuristic */\n42: const STOP_WORDS: ReadonlySet<string> = new Set([\n43:   'the', 'a', 'an', 'is', 'are', 'was', 'were',\n44:   'in', 'on', 'at', 'to', 'for', 'of',\n45:   'and', 'or', 'but', 'not',\n46:   'with', 'this', 'that', 'it',\n47:   'from', 'by', 'as', 'be',\n48:   'has', 'had', 'have',\n49:   'do', 'does', 'did',\n50:   'will', 'would', 'can', 'could', 'should', 'may', 'might',\n51: ]);\n52: \n53: /* --- 2. FEATURE FLAG --- */\n54: \n55: /**\n56:  * Check if the complexity router feature flag is enabled.\n57:  * Default: TRUE (graduated). Set SPECKIT_COMPLEXITY_ROUTER=false to disable.\n58:  *\n59:  * @returns True when SPECKIT_COMPLEXITY_ROUTER is not explicitly disabled.\n60:  */\n61: function isComplexityRouterEnabled(): boolean {\n62:   const raw = process.env.SPECKIT_COMPLEXITY_ROUTER?.toLowerCase()?.trim();\n63:   return raw !== 'false';\n64: }\n65: \n66: /* --- 3. FEATURE EXTRACTION --- */\n67: \n68: /**\n69:  * Split query into terms by whitespace, filtering empty strings.\n70:  *\n71:  * @param query - Raw query string to tokenize.\n72:  * @returns Array of non-empty whitespace-delimited terms.\n73:  */\n74: function extractTerms(query: string): string[] {\n75:   return query.trim().split(/\\s+/).filter(t => t.length > 0);\n76: }\n77: \n78: /**\n79:  * Calculate the ratio of stop words in the query terms.\n80:  * Returns 0 for empty term lists.\n81:  *\n82:  * @param terms - Array of query terms to analyse.\n83:  * @returns Ratio in [0, 1] of stop words to total terms.\n84:  */\n85: function calculateStopWordRatio(terms: string[]): number {\n86:   if (terms.length === 0) return 0;\n87:   const stopCount = terms.filter(t => STOP_WORDS.has(t.toLowerCase())).length;\n88:   return stopCount / terms.length;\n89: }\n90: \n91: /**\n92:  * Check if the query exactly matches any known trigger phrase (case-insensitive).\n93:  *\n94:  * @param query          - Raw query string to test.\n95:  * @param triggerPhrases - Known trigger phrases to match against.\n96:  * @returns True when the query matches a trigger phrase exactly.\n97:  */\n98: function hasTriggerMatch(query: string, triggerPhrases: string[]): boolean {\n99:   if (triggerPhrases.length === 0) return false;\n100:   const normalized = query.trim().toLowerCase();\n101:   return triggerPhrases.some(tp => tp.trim().toLowerCase() === normalized);\n102: }\n103: \n104: /* --- 4. CLASSIFICATION --- */\n105: \n106: /**\n107:  * Determine confidence label based on how clearly the query fits its tier.\n108:  *\n109:  * @param tier          - Classified complexity tier.\n110:  * @param termCount     - Number of query terms.\n111:  * @param hasTrigger    - Whether a trigger phrase matched.\n112:  * @param stopWordRatio - Ratio of stop words in query.\n113:  * @returns Confidence label: 'high', 'medium', or 'low'.\n114:  */\n115: function determineConfidence(\n116:   tier: QueryComplexityTier,\n117:   termCount: number,\n118:   hasTrigger: boolean,\n119:   stopWordRatio: number,\n120: ): 'high' | 'medium' | 'low' {\n121:   if (tier === 'simple') {\n122:     // Trigger match is strongest simplicity signal — overrides term count\n123:     if (hasTrigger) return 'high';\n124:     if (termCount <= 2) return 'high';\n125:     return 'medium';\n126:   }\n127: \n128:   if (tier === 'complex') {\n129:     // High confidence: many terms and low stop-word ratio (content-rich)\n130:     if (termCount > 12) return 'high';\n131:     if (stopWordRatio < 0.3) return 'high';\n132:     return 'medium';\n133:   }\n134: \n135:   // Moderate tier: inherently less certain (between boundaries)\n136:   if (termCount === SIMPLE_TERM_THRESHOLD + 1 || termCount === COMPLEX_TERM_THRESHOLD) {\n137:     return 'low'; // Near boundary\n138:   }\n139:   return 'medium';\n140: }\n141: \n142: /**\n143:  * Detect a short query that lacks a confident retrieval anchor.\n144:  *\n145:  * A multi-term query within the simple term budget, with no trigger-phrase\n146:  * match and a high stop-word ratio, is generic: the cheap simple route would\n147:  * strip it of the extra channels and synonym/embedding expansion it most needs,\n148:  * so a real match reads as a weak result. Content-rich short queries (low\n149:  * stop-word ratio), trigger-anchored queries, and single tokens are excluded —\n150:  * they stay on the fast path.\n151:  *\n152:  * @param termCount     - Number of query terms.\n153:  * @param hasTrigger    - Whether a trigger phrase matched.\n154:  * @param stopWordRatio - Ratio of stop words in the query.\n155:  * @returns True when the query should escalate to the full pipeline.\n156:  */\n157: function isLowSignalShortQuery(\n158:   termCount: number,\n159:   hasTrigger: boolean,\n160:   stopWordRatio: number,\n161: ): boolean {\n162:   return termCount >= 2\n163:     && termCount <= SIMPLE_TERM_THRESHOLD\n164:     && !hasTrigger\n165:     && stopWordRatio >= LOW_SIGNAL_STOPWORD_RATIO;\n166: }\n167: \n168: /**\n169:  * Classify a query's complexity into one of three tiers: simple, moderate, or complex.\n170:  *\n171:  * Classification boundaries:\n172:  * - Simple: ≤3 terms OR trigger phrase match\n173:  * - Complex: >8 terms AND no trigger match\n174:  * - Moderate: everything else (interior)\n175:  *\n176:  * A simple-tier query with no trigger anchor and a high stop-word ratio is\n177:  * escalated to complex (full pipeline) with low confidence — see\n178:  * isLowSignalShortQuery — so generic short queries are not starved of recall.\n179:  *\n180:  * When the SPECKIT_COMPLEXITY_ROUTER feature flag is disabled (enabled by default,\n181:  * graduated), all queries classify as \"complex\" (safe fallback — full pipeline).\n182:  *\n183:  * On any error, returns \"complex\" (safe fallback per spec).\n184:  *\n185:  * @param query          - Raw user query string.\n186:  * @param triggerPhrases - Optional array of known trigger phrases.\n187:  * @returns ClassificationResult with tier, features, and confidence.\n188:  */\n189: function classifyQueryComplexity(\n190:   query: string,\n191:   triggerPhrases?: string[],\n192: ): ClassificationResult {\n193:   // Safe fallback for any unexpected state\n194:   const FALLBACK: ClassificationResult = {\n195:     tier: 'complex',\n196:     features: { termCount: 0, charCount: 0, hasTriggerMatch: false, stopWordRatio: 0 },\n197:     confidence: 'fallback',\n198:     queryPlan: buildComplexityQueryPlan({\n199:       complexity: 'complex',\n200:       confidence: 'fallback',\n201:       termCount: 0,\n202:       hasTriggerMatch: false,\n203:     }),\n204:   };\n205: \n206:   try {\n207:     // Feature flag gate: when disabled, always return complex\n208:     if (!isComplexityRouterEnabled()) {\n209:       return FALLBACK;\n210:     }\n211: \n212:     // Edge case: empty or whitespace-only queries → complex fallback\n213:     if (!query || typeof query !== 'string' || query.trim().length === 0) {\n214:       return FALLBACK;\n215:     }\n216: \n217:     const terms = extractTerms(query);\n218:     const termCount = terms.length;\n219:     const charCount = query.length;\n220:     const triggers = triggerPhrases ?? [];\n221:     const triggerMatch = hasTriggerMatch(query, triggers);\n222:     const stopWordRatio = calculateStopWordRatio(terms);\n223: \n224:     // Classification boundaries\n225:     let tier: QueryComplexityTier;\n226: \n227:     // TriggerMatch always forces simple tier regardless of term count\n228:     if (triggerMatch || termCount <= SIMPLE_TERM_THRESHOLD) {\n229:       tier = 'simple';\n230:     } else if (termCount > COMPLEX_TERM_THRESHOLD && !triggerMatch) {\n231:       tier = 'complex';\n232:     } else {\n233:       tier = 'moderate';\n234:     }\n235: \n236:     let confidence: 'high' | 'medium' | 'low' | 'fallback' =\n237:       determineConfidence(tier, termCount, triggerMatch, stopWordRatio);\n238: \n239:     // Generic-query deep routing: a low-signal short query is escalated off the\n240:     // channel-reduced simple route to the full pipeline, where the extra\n241:     // channels and synonym/embedding expansion give it a chance to recall.\n242:     // Confidence is marked 'low' so downstream recall-preserving paths (token\n243:     // budget, weak-result recovery) also engage. This adds no LLM calls — HyDE\n244:     // and reformulation gate separately on deep request mode.\n245:     if (tier === 'simple' && isLowSignalShortQuery(termCount, triggerMatch, stopWordRatio)) {\n246:       tier = 'complex';\n247:       confidence = 'low';\n248:     }\n249: \n250:     return {\n251:       tier,\n252:       features: {\n253:         termCount,\n254:         charCount,\n255:         hasTriggerMatch: triggerMatch,\n256:         // Round to 3 decimals to avoid floating-point noise in debug output\n257:         stopWordRatio: Math.round(stopWordRatio * 1000) / 1000,\n258:       },\n259:       confidence,\n260:       queryPlan: buildComplexityQueryPlan({\n261:         complexity: tier,\n262:         confidence,\n263:         termCount,\n264:         hasTriggerMatch: triggerMatch,\n265:       }),\n266:     };\n267:   } catch (_err: unknown) {\n268:     // Classification failure — return moderate default\n269:     return FALLBACK;\n270:   }\n271: }\n272: \n273: /* --- 5. EXPORTS --- */\n274: \n275: export {\n276:   // Types\n277:   type QueryComplexityTier,\n278:   type ClassificationResult,\n279: \n280:   // Constants\n281:   SIMPLE_TERM_THRESHOLD,\n282:   COMPLEX_TERM_THRESHOLD,\n283:   STOP_WORDS,\n284: \n285:   // Functions\n286:   classifyQueryComplexity,\n287:   isComplexityRouterEnabled,\n288: \n289:   // Internal helpers (exported for testing)\n290:   extractTerms,\n291:   calculateStopWordRatio,\n292:   hasTriggerMatch,\n293: };\n\n(End of file - total 293 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Query Classifier\n// ───────────────────────────────────────────────────────────────\n/* --- 1. TYPES & CONSTANTS --- */\n\n// Feature catalog: Query complexity router\n\nimport {\n  buildComplexityQueryPlan,\n  type QueryPlan,\n} from '../query/query-plan.js';\n\ntype QueryComplexityTier = 'simple' | 'moderate' | 'complex';\n\ninterface ClassificationResult {\n  tier: QueryComplexityTier;\n  features: {\n    termCount: number;\n    charCount: number;\n    hasTriggerMatch: boolean;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/query-classifier.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Query Classifier\n// ───────────────────────────────────────────────────────────────\n/* --- 1. TYPES & CONSTANTS --- */\n\n// Feature catalog: Query complexity router\n\nimport {\n  buildComplexityQueryPlan,\n  type QueryPlan,\n} from '../query/query-plan.js';\n\ntype QueryComplexityTier = 'simple' | 'moderate' | 'complex';\n\ninterface ClassificationResult {\n  tier: QueryComplexityTier;\n  features: {\n    termCount: number;\n    charCount: number;\n    hasTriggerMatch: boolean;\n    stopWordRatio: number;\n  };\n  confidence: 'high' | 'medium' | 'low' | 'fallback';\n  queryPlan: QueryPlan;\n}\n\n/** Config-driven thresholds */\nconst SIMPLE_TERM_THRESHOLD = 3;\nconst COMPLEX_TERM_THRESHOLD = 8;\n\n/**\n * Stop-word ratio at or above which a short, trigger-less query is treated as\n * low-signal. Such queries carry too little lexical anchor for the cheap simple\n * route — which suppresses extra channels and synonym/embedding expansion — to\n * recall reliably, so they are escalated to the full pipeline. Set above the\n * one-stop-word-in-three ratio of ordinary verb-noun queries (e.g. \"fix the\n * bug\" = 0.333) so only genuinely vague queries escalate.\n */\nconst LOW_SIGNAL_STOPWORD_RATIO = 0.5;\n\n/** Common English stop words for semantic complexity heuristic */\nconst STOP_WORDS: ReadonlySet<string> = new Set([\n  'the', 'a', 'an', 'is', 'are', 'was', 'were',\n  'in', 'on', 'at', 'to', 'for', 'of',\n  'and', 'or', 'but', 'not',\n  'with', 'this', 'that', 'it',\n  'from', 'by', 'as', 'be',\n  'has', 'had', 'have',\n  'do', 'does', 'did',\n  'will', 'would', 'can', 'could', 'should', 'may', 'might',\n]);\n\n/* --- 2. FEATURE FLAG --- */\n\n/**\n * Check if the complexity router feature flag is enabled.\n * Default: TRUE (graduated). Set SPECKIT_COMPLEXITY_ROUTER=false to disable.\n *\n * @returns True when SPECKIT_COMPLEXITY_ROUTER is not explicitly disabled.\n */\nfunction isComplexityRouterEnabled(): boolean {\n  const raw = process.env.SPECKIT_COMPLEXITY_ROUTER?.toLowerCase()?.trim();\n  return raw !== 'false';\n}\n\n/* --- 3. FEATURE EXTRACTION --- */\n\n/**\n * Split query into terms by whitespace, filtering empty strings.\n *\n * @param query - Raw query string to tokenize.\n * @returns Array of non-empty whitespace-delimited terms.\n */\nfunction extractTerms(query: string): string[] {\n  return query.trim().split(/\\s+/).filter(t => t.length > 0);\n}\n\n/**\n * Calculate the ratio of stop words in the query terms.\n * Returns 0 for empty term lists.\n *\n * @param terms - Array of query terms to analyse.\n * @returns Ratio in [0, 1] of stop words to total terms.\n */\nfunction calculateStopWordRatio(terms: string[]): number {\n  if (terms.length === 0) return 0;\n  const stopCount = terms.filter(t => STOP_WORDS.has(t.toLowerCase())).length;\n  return stopCount / terms.length;\n}\n\n/**\n * Check if the query exactly matches any known trigger phrase (case-insensitive).\n *\n * @param query          - Raw query string to test.\n * @param triggerPhrases - Known trigger phrases to match against.\n * @returns True when the query matches a trigger phrase exactly.\n */\nfunction hasTriggerMatch(query: string, triggerPhrases: string[]): boolean {\n  if (triggerPhrases.length === 0) return false;\n  const normalized = query.trim().toLowerCase();\n  return triggerPhrases.some(tp => tp.trim().toLowerCase() === normalized);\n}\n\n/* --- 4. CLASSIFICATION --- */\n\n/**\n * Determine confidence label based on how clearly the query fits its tier.\n *\n * @param tier          - Classified complexity tier.\n * @param termCount     - Number of query terms.\n * @param hasTrigger    - Whether a trigger phrase matched.\n * @param stopWordRatio - Ratio of stop words in query.\n * @returns Confidence label: 'high', 'medium', or 'low'.\n */\nfunction determineConfidence(\n  tier: QueryComplexityTier,\n  termCount: number,\n  hasTrigger: boolean,\n  stopWordRatio: number,\n): 'high' | 'medium' | 'low' {\n  if (tier === 'simple') {\n    // Trigger match is strongest simplicity signal — overrides term count\n    if (hasTrigger) return 'high';\n    if (termCount <= 2) return 'high';\n    return 'medium';\n  }\n\n  if (tier === 'complex') {\n    // High confidence: many terms and low stop-word ratio (content-rich)\n    if (termCount > 12) return 'high';\n    if (stopWordRatio < 0.3) return 'high';\n    return 'medium';\n  }\n\n  // Moderate tier: inherently less certain (between boundaries)\n  if (termCount === SIMPLE_TERM_THRESHOLD + 1 || termCount === COMPLEX_TERM_THRESHOLD) {\n    return 'low'; // Near boundary\n  }\n  return 'medium';\n}\n\n/**\n * Detect a short query that lacks a confident retrieval anchor.\n *\n * A multi-term query within the simple term budget, with no trigger-phrase\n * match and a high stop-word ratio, is generic: the cheap simple route would\n * strip it of the extra channels and synonym/embedding expansion it most needs,\n * so a real match reads as a weak result. Content-rich short queries (low\n * stop-word ratio), trigger-anchored queries, and single tokens are excluded —\n * they stay on the fast path.\n *\n * @param termCount     - Number of query terms.\n * @param hasTrigger    - Whether a trigger phrase matched.\n * @param stopWordRatio - Ratio of stop words in the query.\n * @returns True when the query should escalate to the full pipeline.\n */\nfunction isLowSignalShortQuery(\n  termCount: number,\n  hasTrigger: boolean,\n  stopWordRatio: number,\n): boolean {\n  return termCount >= 2\n    && termCount <= SIMPLE_TERM_THRESHOLD\n    && !hasTrigger\n    && stopWordRatio >= LOW_SIGNAL_STOPWORD_RATIO;\n}\n\n/**\n * Classify a query's complexity into one of three tiers: simple, moderate, or complex.\n *\n * Classification boundaries:\n * - Simple: ≤3 terms OR trigger phrase match\n * - Complex: >8 terms AND no trigger match\n * - Moderate: everything else (interior)\n *\n * A simple-tier query with no trigger anchor and a high stop-word ratio is\n * escalated to complex (full pipeline) with low confidence — see\n * isLowSignalShortQuery — so generic short queries are not starved of recall.\n *\n * When the SPECKIT_COMPLEXITY_ROUTER feature flag is disabled (enabled by default,\n * graduated), all queries classify as \"complex\" (safe fallback — full pipeline).\n *\n * On any error, returns \"complex\" (safe fallback per spec).\n *\n * @param query          - Raw user query string.\n * @param triggerPhrases - Optional array of known trigger phrases.\n * @returns ClassificationResult with tier, features, and confidence.\n */\nfunction classifyQueryComplexity(\n  query: string,\n  triggerPhrases?: string[],\n): ClassificationResult {\n  // Safe fallback for any unexpected state\n  const FALLBACK: ClassificationResult = {\n    tier: 'complex',\n    features: { termCount: 0, charCount: 0, hasTriggerMatch: false, stopWordRatio: 0 },\n    confidence: 'fallback',\n    queryPlan: buildComplexityQueryPlan({\n      complexity: 'complex',\n      confidence: 'fallback',\n      termCount: 0,\n      hasTriggerMatch: false,\n    }),\n  };\n\n  try {\n    // Feature flag gate: when disabled, always return complex\n    if (!isComplexityRouterEnabled()) {\n      return FALLBACK;\n    }\n\n    // Edge case: empty or whitespace-only queries → complex fallback\n    if (!query || typeof query !== 'string' || query.trim().length === 0) {\n      return FALLBACK;\n    }\n\n    const terms = extractTerms(query);\n    const termCount = terms.length;\n    const charCount = query.length;\n    const triggers = triggerPhrases ?? [];\n    const triggerMatch = hasTriggerMatch(query, triggers);\n    const stopWordRatio = calculateStopWordRatio(terms);\n\n    // Classification boundaries\n    let tier: QueryComplexityTier;\n\n    // TriggerMatch always forces simple tier regardless of term count\n    if (triggerMatch || termCount <= SIMPLE_TERM_THRESHOLD) {\n      tier = 'simple';\n    } else if (termCount > COMPLEX_TERM_THRESHOLD && !triggerMatch) {\n      tier = 'complex';\n    } else {\n      tier = 'moderate';\n    }\n\n    let confidence: 'high' | 'medium' | 'low' | 'fallback' =\n      determineConfidence(tier, termCount, triggerMatch, stopWordRatio);\n\n    // Generic-query deep routing: a low-signal short query is escalated off the\n    // channel-reduced simple route to the full pipeline, where the extra\n    // channels and synonym/embedding expansion give it a chance to recall.\n    // Confidence is marked 'low' so downstream recall-preserving paths (token\n    // budget, weak-result recovery) also engage. This adds no LLM calls — HyDE\n    // and reformulation gate separately on deep request mode.\n    if (tier === 'simple' && isLowSignalShortQuery(termCount, triggerMatch, stopWordRatio)) {\n      tier = 'complex';\n      confidence = 'low';\n    }\n\n    return {\n      tier,\n      features: {\n        termCount,\n        charCount,\n        hasTriggerMatch: triggerMatch,\n        // Round to 3 decimals to avoid floating-point noise in debug output\n        stopWordRatio: Math.round(stopWordRatio * 1000) / 1000,\n      },\n      confidence,\n      queryPlan: buildComplexityQueryPlan({\n        complexity: tier,\n        confidence,\n        termCount,\n        hasTriggerMatch: triggerMatch,\n      }),\n    };\n  } catch (_err: unknown) {\n    // Classification failure — return moderate default\n    return FALLBACK;\n  }\n}\n\n/* --- 5. EXPORTS --- */\n\nexport {\n  // Types\n  type QueryComplexityTier,\n  type ClassificationResult,\n\n  // Constants\n  SIMPLE_TERM_THRESHOLD,\n  COMPLEX_TERM_THRESHOLD,\n  STOP_WORDS,\n\n  // Functions\n  classifyQueryComplexity,\n  isComplexityRouterEnabled,\n\n  // Internal helpers (exported for testing)\n  extractTerms,\n  calculateStopWordRatio,\n  hasTriggerMatch,\n};","lineStart":1,"lineEnd":293,"totalLines":293,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/query-classifier.ts","time":{"start":1781723079928,"end":1781723079936}},"id":"prt_ed6f8a4f3001wwj4OzLcO5TGE4","sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","messageID":"msg_ed6f88aaf001jHbwyflSdpcA8l"}}
{"type":"tool_use","timestamp":1781723080438,"sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","part":{"type":"tool","tool":"read","callID":"call_cfc299c9d35e4698bf5f19f8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/query-expander.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/query-expander.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Query Expander\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Query expansion\n5: // Rule-based synonym expansion for mode=\"deep\" multi-query RAG.\n6: // No LLM calls — purely rule-based template substitution.\n7: \n8: // ───────────────────────────────────────────────────────────────\n9: // 1. CONSTANTS\n10: \n11: // ───────────────────────────────────────────────────────────────\n12: const MAX_VARIANTS = 3;\n13: \n14: /** Escape special regex characters in user input to prevent ReDoS. */\n15: function escapeRegExp(str: string): string {\n16:   return str.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n17: }\n18: \n19: /**\n20:  * Domain vocabulary map for server-side synonym expansion.\n21:  * No LLM calls — purely rule-based template substitution.\n22:  */\n23: export const DOMAIN_VOCABULARY_MAP: Record<string, string[]> = {\n24:   // Auth domain\n25:   login: ['authentication', 'sign-in'],\n26:   auth: ['authentication', 'authorization'],\n27:   password: ['credential', 'secret'],\n28:   token: ['jwt', 'session-key'],\n29:   // Error domain\n30:   error: ['exception', 'failure'],\n31:   bug: ['defect', 'issue'],\n32:   crash: ['fatal-error', 'unhandled-exception'],\n33:   fix: ['patch', 'resolve'],\n34:   // Architecture domain\n35:   api: ['endpoint', 'route'],\n36:   database: ['db', 'datastore'],\n37:   cache: ['memoize', 'store'],\n38:   deploy: ['release', 'ship'],\n39:   // Code domain\n40:   refactor: ['restructure', 'clean-up'],\n41:   test: ['spec', 'assertion'],\n42:   config: ['configuration', 'settings'],\n43:   // Memory system domain\n44:   memory: ['context', 'knowledge'],\n45:   spec: ['specification', 'requirement'],\n46:   embedding: ['vector', 'representation'],\n47:   tier: ['importance', 'priority'],\n48:   causal: ['relationship', 'dependency'],\n49:   checkpoint: ['snapshot', 'backup'],\n50:   indexing: ['ingestion', 'cataloging'],\n51:   search: ['retrieval', 'query'],\n52:   decision: ['adr', 'rationale'],\n53:   session: ['conversation', 'context-window'],\n54:   trigger: ['activation', 'match-phrase'],\n55:   fusion: ['merge', 'combine'],\n56:   semantic: ['embedding', 'vector'],\n57:   retrieval: ['search', 'recall'],\n58:   agent: ['subagent', 'assistant'],\n59:   skill: ['capability', 'workflow'],\n60:   council: ['deliberation', 'panel'],\n61: };\n62: \n63: // ───────────────────────────────────────────────────────────────\n64: // 2. CORE FUNCTION\n65: \n66: // ───────────────────────────────────────────────────────────────\n67: /**\n68:  * Expand a query into multiple search variants using synonym maps.\n69:  *\n70:  * - Original query is always included as the first variant.\n71:  * - Splits compound terms via word boundary matching.\n72:  * - Looks up synonyms from `DOMAIN_VOCABULARY_MAP` (case-insensitive).\n73:  * - Returns at most `MAX_VARIANTS` (3) strings.\n74:  *\n75:  * @param query - The input search query string.\n76:  * @returns Array of query variants, original first, max 3 total.\n77:  * @throws {TypeError} If called with a non-string value at runtime.\n78:  * @example\n79:  * ```ts\n80:  * expandQuery('auth error');\n81:  * // ['auth error', 'authentication error', 'auth exception']\n82:  * ```\n83:  */\n84: export function expandQuery(query: string): string[] {\n85:   const words = query.toLowerCase().match(/\\b\\w+\\b/g) || [];\n86:   const variants: Set<string> = new Set([query]);\n87: \n88:   for (const word of words) {\n89:     if (variants.size >= MAX_VARIANTS) break;\n90:     const synonyms = DOMAIN_VOCABULARY_MAP[word];\n91:     if (synonyms && synonyms.length > 0) {\n92:       // Keep one expansion per matched word to avoid over-expanding simple queries.\n93:       for (const synonym of synonyms) {\n94:         if (variants.size >= MAX_VARIANTS) break;\n95:         const expanded = query.replace(new RegExp(`\\\\b${escapeRegExp(word)}\\\\b`, 'i'), synonym);\n96:         const beforeSize = variants.size;\n97:         variants.add(expanded);\n98:         if (variants.size > beforeSize) {\n99:           break;\n100:         }\n101:       }\n102:     }\n103:   }\n104: \n105:   return Array.from(variants).slice(0, MAX_VARIANTS);\n106: }\n\n(End of file - total 106 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Query Expander\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Query expansion\n// Rule-based synonym expansion for mode=\"deep\" multi-query RAG.\n// No LLM calls — purely rule-based template substitution.\n\n// ───────────────────────────────────────────────────────────────\n// 1. CONSTANTS\n\n// ───────────────────────────────────────────────────────────────\nconst MAX_VARIANTS = 3;\n\n/** Escape special regex characters in user input to prevent ReDoS. */\nfunction escapeRegExp(str: string): string {\n  return str.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\n/**\n * Domain vocabulary map for server-side synonym expansion.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/query-expander.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Query Expander\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Query expansion\n// Rule-based synonym expansion for mode=\"deep\" multi-query RAG.\n// No LLM calls — purely rule-based template substitution.\n\n// ───────────────────────────────────────────────────────────────\n// 1. CONSTANTS\n\n// ───────────────────────────────────────────────────────────────\nconst MAX_VARIANTS = 3;\n\n/** Escape special regex characters in user input to prevent ReDoS. */\nfunction escapeRegExp(str: string): string {\n  return str.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\n/**\n * Domain vocabulary map for server-side synonym expansion.\n * No LLM calls — purely rule-based template substitution.\n */\nexport const DOMAIN_VOCABULARY_MAP: Record<string, string[]> = {\n  // Auth domain\n  login: ['authentication', 'sign-in'],\n  auth: ['authentication', 'authorization'],\n  password: ['credential', 'secret'],\n  token: ['jwt', 'session-key'],\n  // Error domain\n  error: ['exception', 'failure'],\n  bug: ['defect', 'issue'],\n  crash: ['fatal-error', 'unhandled-exception'],\n  fix: ['patch', 'resolve'],\n  // Architecture domain\n  api: ['endpoint', 'route'],\n  database: ['db', 'datastore'],\n  cache: ['memoize', 'store'],\n  deploy: ['release', 'ship'],\n  // Code domain\n  refactor: ['restructure', 'clean-up'],\n  test: ['spec', 'assertion'],\n  config: ['configuration', 'settings'],\n  // Memory system domain\n  memory: ['context', 'knowledge'],\n  spec: ['specification', 'requirement'],\n  embedding: ['vector', 'representation'],\n  tier: ['importance', 'priority'],\n  causal: ['relationship', 'dependency'],\n  checkpoint: ['snapshot', 'backup'],\n  indexing: ['ingestion', 'cataloging'],\n  search: ['retrieval', 'query'],\n  decision: ['adr', 'rationale'],\n  session: ['conversation', 'context-window'],\n  trigger: ['activation', 'match-phrase'],\n  fusion: ['merge', 'combine'],\n  semantic: ['embedding', 'vector'],\n  retrieval: ['search', 'recall'],\n  agent: ['subagent', 'assistant'],\n  skill: ['capability', 'workflow'],\n  council: ['deliberation', 'panel'],\n};\n\n// ───────────────────────────────────────────────────────────────\n// 2. CORE FUNCTION\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Expand a query into multiple search variants using synonym maps.\n *\n * - Original query is always included as the first variant.\n * - Splits compound terms via word boundary matching.\n * - Looks up synonyms from `DOMAIN_VOCABULARY_MAP` (case-insensitive).\n * - Returns at most `MAX_VARIANTS` (3) strings.\n *\n * @param query - The input search query string.\n * @returns Array of query variants, original first, max 3 total.\n * @throws {TypeError} If called with a non-string value at runtime.\n * @example\n * ```ts\n * expandQuery('auth error');\n * // ['auth error', 'authentication error', 'auth exception']\n * ```\n */\nexport function expandQuery(query: string): string[] {\n  const words = query.toLowerCase().match(/\\b\\w+\\b/g) || [];\n  const variants: Set<string> = new Set([query]);\n\n  for (const word of words) {\n    if (variants.size >= MAX_VARIANTS) break;\n    const synonyms = DOMAIN_VOCABULARY_MAP[word];\n    if (synonyms && synonyms.length > 0) {\n      // Keep one expansion per matched word to avoid over-expanding simple queries.\n      for (const synonym of synonyms) {\n        if (variants.size >= MAX_VARIANTS) break;\n        const expanded = query.replace(new RegExp(`\\\\b${escapeRegExp(word)}\\\\b`, 'i'), synonym);\n        const beforeSize = variants.size;\n        variants.add(expanded);\n        if (variants.size > beforeSize) {\n          break;\n        }\n      }\n    }\n  }\n\n  return Array.from(variants).slice(0, MAX_VARIANTS);\n}","lineStart":1,"lineEnd":106,"totalLines":106,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/query-expander.ts","time":{"start":1781723080432,"end":1781723080438}},"id":"prt_ed6f8a6ee001aXJ1yim1vK66Qm","sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","messageID":"msg_ed6f88aaf001jHbwyflSdpcA8l"}}
{"type":"tool_use","timestamp":1781723081273,"sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","part":{"type":"tool","tool":"read","callID":"call_1860204287374b678ec7575c","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Recovery Payload\n3: // ───────────────────────────────────────────────────────────────\n4: // Empty/Weak Result Recovery UX\n5: //\n6: // PURPOSE: Generate structured recovery payloads when search returns\n7: // no results, very low-confidence results, or only partial matches.\n8: // Provides the calling agent with actionable next steps.\n9: //\n10: // FEATURE FLAG: SPECKIT_EMPTY_RESULT_RECOVERY_V1 (default ON, graduated)\n11: //\n12: // OUTPUT SHAPE:\n13: // {\n14: //   \"status\": \"no_results\" | \"low_confidence\" | \"partial\",\n15: //   \"reason\": \"spec_filter_too_narrow\" | \"low_signal_query\" | \"knowledge_gap\",\n16: //   \"suggestedQueries\": [\"broader alternative 1\", \"rephrased alternative 2\"],\n17: //   \"recommendedAction\": \"retry_broader\" | \"switch_mode\" | \"save_memory\" | \"ask_user\" | \"ask_disambiguation\" | \"refuse_without_evidence\" | \"broaden_or_ask\"\n18: // }\n19: \n20: import { expandQuery } from './query-expander.js';\n21: \n22: // -- Types --\n23: \n24: /** The retrieval outcome state. */\n25: export type RecoveryStatus = 'no_results' | 'low_confidence' | 'partial';\n26: \n27: /** Root cause classification of the failure. */\n28: export type RecoveryReason = 'spec_filter_too_narrow' | 'low_signal_query' | 'knowledge_gap';\n29: \n30: /** Recommended next action for the calling agent. */\n31: export type RecoveryAction =\n32:   | 'retry_broader'\n33:   | 'switch_mode'\n34:   | 'save_memory'\n35:   | 'ask_user'\n36:   | 'ask_disambiguation'\n37:   | 'refuse_without_evidence'\n38:   | 'broaden_or_ask';\n39: \n40: /** Structured recovery payload attached to search responses. */\n41: export interface RecoveryPayload {\n42:   status: RecoveryStatus;\n43:   reason: RecoveryReason;\n44:   suggestedQueries: string[];\n45:   recommendedAction: RecoveryAction;\n46: }\n47: \n48: /** Input context used to build the recovery payload. */\n49: export interface RecoveryContext {\n50:   /** The original search query (may be null/empty if concepts were used). */\n51:   query: string | null;\n52:   /** Whether a specFolder filter was applied. */\n53:   hasSpecFolderFilter: boolean;\n54:   /** Whether upstream search logic detected an evidence gap for this result set. */\n55:   evidenceGap?: boolean;\n56:   /** How many results were returned (0 = no_results, 1–N = partial/low_confidence). */\n57:   resultCount: number;\n58:   /** Average confidence value across returned results (0–1). Only meaningful when resultCount > 0. */\n59:   avgConfidence?: number;\n60:   /** Low-confidence threshold — results below this trigger recovery. */\n61:   lowConfidenceThreshold?: number;\n62: }\n63: \n64: // -- Constants --\n65: \n66: const DEFAULT_LOW_CONFIDENCE_THRESHOLD = 0.4;\n67: \n68: // Minimum result count considered \"good enough\" — fewer than this triggers partial recovery.\n69: const PARTIAL_RESULT_MIN = 3;\n70: \n71: // -- Internal helpers --\n72: \n73: /**\n74:  * Classify retrieval status based on result count and confidence signals.\n75:  */\n76: function classifyStatus(ctx: RecoveryContext): RecoveryStatus {\n77:   const threshold = ctx.lowConfidenceThreshold ?? DEFAULT_LOW_CONFIDENCE_THRESHOLD;\n78: \n79:   if (ctx.resultCount === 0) return 'no_results';\n80:   if (ctx.evidenceGap) return 'partial';\n81:   if (\n82:     typeof ctx.avgConfidence === 'number' &&\n83:     Number.isFinite(ctx.avgConfidence) &&\n84:     ctx.avgConfidence < threshold\n85:   ) return 'low_confidence';\n86:   if (ctx.resultCount < PARTIAL_RESULT_MIN) return 'partial';\n87:   return 'low_confidence'; // fallback — should only be called when recovery is warranted\n88: }\n89: \n90: /**\n91:  * Classify root cause from context signals.\n92:  */\n93: function classifyReason(ctx: RecoveryContext, status: RecoveryStatus): RecoveryReason {\n94:   // If a narrow filter was applied and no results returned, that is most likely the cause\n95:   if (ctx.hasSpecFolderFilter && status === 'no_results') {\n96:     return 'spec_filter_too_narrow';\n97:   }\n98:   // Very short or generic queries (< 3 words) suggest low signal\n99:   const wordCount = ctx.query ? ctx.query.trim().split(/\\s+/).filter(Boolean).length : 0;\n100:   if (wordCount > 0 && wordCount <= 2) {\n101:     return 'low_signal_query';\n102:   }\n103:   // Default to knowledge_gap — the information may simply not be indexed\n104:   return 'knowledge_gap';\n105: }\n106: \n107: /**\n108:  * Generate suggested reformulations from the original query.\n109:  *\n110:  * Heuristics applied (in order):\n111:  * 1. Remove parenthetical or bracketed clauses (focus term extraction)\n112:  * 2. Keep only the first N words (shorten complex queries)\n113:  * 3. Strip trailing conjunctions / stop words\n114:  * 4. Suggest dropping the spec folder constraint when it was set\n115:  */\n116: function generateSuggestedQueries(ctx: RecoveryContext): string[] {\n117:   const suggestions: string[] = [];\n118:   const q = ctx.query?.trim() ?? '';\n119: \n120:   if (q.length === 0) {\n121:     suggestions.push('memory save context', 'recent decisions', 'project overview');\n122:     return suggestions.slice(0, 2);\n123:   }\n124: \n125:   // 1. Remove parentheticals/brackets — often over-specifying\n126:   const withoutParens = q.replace(/\\([^)]*\\)/g, '').replace(/\\[[^\\]]*\\]/g, '').replace(/\\s{2,}/g, ' ').trim();\n127:   if (withoutParens.length > 0 && withoutParens !== q) {\n128:     suggestions.push(withoutParens);\n129:   }\n130: \n131:   // 2. Shorten: keep first 3 words\n132:   const words = q.split(/\\s+/).filter(Boolean);\n133:   if (words.length > 4) {\n134:     suggestions.push(words.slice(0, 3).join(' '));\n135:   }\n136: \n137:   // 3. Remove trailing stop-words (and, or, the, in, for, with, to, of, a)\n138:   const stopWords = new Set(['and', 'or', 'the', 'in', 'for', 'with', 'to', 'of', 'a', 'an']);\n139:   const trimmedWords = [...words].reverse().reduce<string[]>((acc, word) => {\n140:     if (acc.length === 0 && stopWords.has(word.toLowerCase())) return acc;\n141:     return [word, ...acc];\n142:   }, []);\n143:   const stopTrimmed = trimmedWords.join(' ');\n144:   if (stopTrimmed.length > 0 && stopTrimmed !== q && !suggestions.includes(stopTrimmed)) {\n145:     suggestions.push(stopTrimmed);\n146:   }\n147: \n148:   // 4. If spec folder filter was active, suggest the same query without it\n149:   if (ctx.hasSpecFolderFilter && !suggestions.includes(q)) {\n150:     suggestions.push(q); // exact same query but without folder constraint\n151:   }\n152: \n153:   // 5. Synonym-expansion variants — turn a low-signal query into concrete\n154:   // broaden prompts. Reuses the deep-path expander so a weak result surfaces\n155:   // the same alternatives the recall pipeline would try, instead of an empty\n156:   // list. Best-effort: expansion never blocks recovery.\n157:   try {\n158:     for (const variant of expandQuery(q)) {\n159:       if (variant !== q && !suggestions.includes(variant)) {\n160:         suggestions.push(variant);\n161:       }\n162:     }\n163:   } catch {\n164:     // Expansion is advisory; fall back to heuristic suggestions on any failure.\n165:   }\n166: \n167:   // Deduplicate, remove empties, cap at 3\n168:   const unique = [...new Set(suggestions.filter((s) => s.length > 0))];\n169:   return unique.slice(0, 3);\n170: }\n171: \n172: /**\n173:  * Synthesize broad, safe suggestions when the normal heuristics cannot\n174:  * reformulate the query. These are intentionally generic: they keep only\n175:  * caller-supplied tokens and avoid inventing packet IDs or paths.\n176:  */\n177: function synthesizeBroadeningSuggestions(ctx: RecoveryContext): string[] {\n178:   const q = ctx.query?.trim() ?? '';\n179:   const rawTokens = q.split(/\\s+/).filter(Boolean);\n180:   const stopWords = new Set([\n181:     'a',\n182:     'an',\n183:     'and',\n184:     'for',\n185:     'from',\n186:     'in',\n187:     'of',\n188:     'on',\n189:     'or',\n190:     'the',\n191:     'to',\n192:     'with',\n193:   ]);\n194:   const tokens = rawTokens\n195:     .map((token) => token.replace(/^[^\\w-]+|[^\\w-]+$/g, '').toLowerCase())\n196:     .filter((token) => token.length > 0 && !stopWords.has(token));\n197: \n198:   if (tokens.length === 0) {\n199:     return ['recent memory context', 'related implementation notes'];\n200:   }\n201:   if (tokens.length === 1) {\n202:     return [`${tokens[0]} context`, `${tokens[0]} implementation`];\n203:   }\n204: \n205:   const firstPair = tokens.slice(0, 2).join(' ');\n206:   const firstTriple = tokens.slice(0, 3).join(' ');\n207:   const suggestions = [\n208:     firstPair,\n209:     firstTriple,\n210:     tokens.join(' '),\n211:   ].filter((suggestion) => suggestion.length > 0);\n212: \n213:   return [...new Set(suggestions)].slice(0, 2);\n214: }\n215: \n216: /**\n217:  * Map status + reason to a recommended next action.\n218:  */\n219: function recommendAction(status: RecoveryStatus, reason: RecoveryReason): RecoveryAction {\n220:   if (status === 'no_results') {\n221:     if (reason === 'spec_filter_too_narrow') return 'retry_broader';\n222:     if (reason === 'low_signal_query') return 'switch_mode';\n223:     return 'refuse_without_evidence';\n224:   }\n225:   if (status === 'low_confidence') {\n226:     if (reason === 'knowledge_gap') return 'ask_user';\n227:     if (reason === 'low_signal_query') return 'ask_disambiguation';\n228:     return 'switch_mode';\n229:   }\n230:   // partial\n231:   return 'broaden_or_ask';\n232: }\n233: \n234: // -- Graph-Expanded Fallback -----------------------------------\n235: \n236: import type Database from 'better-sqlite3';\n237: import { routeQueryConcepts } from './entity-linker.js';\n238: import { isGraphFallbackEnabled } from './search-flags.js';\n239: \n240: /**\n241:  * Build graph-expanded fallback query terms on zero/weak results.\n242:  *\n243:  * When the search produces no results or low-confidence results, this function\n244:  * queries the causal_edges table for nodes related to the matched concepts from\n245:  * concept routing, returning up to 5 expanded query terms derived from neighbor\n246:  * node titles.\n247:  *\n248:  * Feature-gated by SPECKIT_GRAPH_FALLBACK (default ON).\n249:  * Fail-open: returns empty array on any error.\n250:  *\n251:  * @param ctx - Recovery context with query and result state.\n252:  * @param db - SQLite database instance for graph lookups.\n253:  * @returns Array of up to 5 expanded query terms from graph neighbors.\n254:  */\n255: export function buildGraphExpandedFallback(\n256:   ctx: RecoveryContext,\n257:   db: Database.Database,\n258: ): string[] {\n259:   if (!isGraphFallbackEnabled()) return [];\n260: \n261:   const status = classifyStatus(ctx);\n262:   if (status !== 'no_results' && status !== 'low_confidence') return [];\n263: \n264:   try {\n265:     const routing = routeQueryConcepts(ctx.query ?? '', db);\n266:     if (!routing.graphActivated || routing.concepts.length === 0) return [];\n267: \n268:     // Find memory IDs matching the routed concepts via title keyword search,\n269:     // then walk causal_edges to find neighbors with distinct titles.\n270: \n271:     // Step 1: Find seed memory IDs whose titles contain matched concepts\n272:     const likeClauses = routing.concepts.map(() => 'LOWER(mi.title) LIKE ?').join(' OR ');\n273:     const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n274: \n275:     const seedRows = (db.prepare(`\n276:       SELECT mi.id FROM memory_index mi\n277:       WHERE (${likeClauses})\n278:       LIMIT 10\n279:     `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n280: \n281:     if (seedRows.length === 0) return [];\n282: \n283:     const seedIds = seedRows.map((r) => String(r.id));\n284:     const seedPlaceholdersSql = seedIds.map(() => '?').join(', ');\n285: \n286:     // Step 2: Walk 1-hop causal edges from seeds to find neighbor nodes\n287:     const neighborRows = (db.prepare(`\n288:       SELECT DISTINCT mi.title\n289:       FROM causal_edges ce\n290:       JOIN memory_index mi ON (\n291:         (ce.source_id IN (${seedPlaceholdersSql}) AND mi.id = CAST(ce.target_id AS INTEGER))\n292:         OR\n293:         (ce.target_id IN (${seedPlaceholdersSql}) AND mi.id = CAST(ce.source_id AS INTEGER))\n294:       )\n295:       WHERE mi.id NOT IN (${seedPlaceholdersSql})\n296:       LIMIT 10\n297:     `) as Database.Statement).all(\n298:       ...seedIds,\n299:       ...seedIds,\n300:       ...seedIds,\n301:     ) as Array<{ title: string }>;\n302: \n303:     if (neighborRows.length === 0) return [];\n304: \n305:     // Step 3: Extract short keyword phrases from neighbor titles\n306:     const terms: string[] = [];\n307:     const seen = new Set<string>();\n308: \n309:     for (const row of neighborRows) {\n310:       if (!row.title || terms.length >= 5) break;\n311:       // Take the first 3 words of the title as a search term\n312:       const words = row.title.trim().split(/\\s+/).slice(0, 3).join(' ').toLowerCase();\n313:       if (words.length > 0 && !seen.has(words)) {\n314:         seen.add(words);\n315:         terms.push(words);\n316:       }\n317:     }\n318: \n319:     return terms;\n320:   } catch (error: unknown) {\n321:     const message = error instanceof Error ? error.message : String(error);\n322:     console.warn(`[recovery-payload] buildGraphExpandedFallback failed (fail-open): ${message}`);\n323:     return [];\n324:   }\n325: }\n326: \n327: // -- Public API --\n328: \n329: /**\n330:  * Build a structured recovery payload for a failed or weak retrieval.\n331:  *\n332:  * Call this when:\n333:  *  - No results are returned (resultCount === 0)\n334:  *  - Results are returned but avgConfidence < threshold\n335:  *  - Fewer than PARTIAL_RESULT_MIN results (partial match)\n336:  *\n337:  * @param ctx - Retrieval outcome context\n338:  * @returns Structured recovery payload\n339:  */\n340: export function buildRecoveryPayload(ctx: RecoveryContext): RecoveryPayload {\n341:   const status = classifyStatus(ctx);\n342:   const reason = classifyReason(ctx, status);\n343:   const recommendedAction = recommendAction(status, reason);\n344:   const generatedSuggestions = generateSuggestedQueries(ctx);\n345:   const suggestedQueries = recommendedAction === 'ask_user' && generatedSuggestions.length === 0\n346:     ? synthesizeBroadeningSuggestions(ctx)\n347:     : generatedSuggestions;\n348: \n349:   return {\n350:     status,\n351:     reason,\n352:     suggestedQueries,\n353:     recommendedAction,\n354:   };\n355: }\n356: \n357: /**\n358:  * Determine whether a search result set warrants recovery.\n359:  *\n360:  * Returns true when:\n361:  *  - No results returned, OR\n362:  *  - Average confidence below threshold, OR\n363:  *  - Fewer than PARTIAL_RESULT_MIN results and avgConfidence is below mid-range\n364:  *\n365:  * @param ctx - Retrieval outcome context\n366:  */\n367: export function shouldTriggerRecovery(ctx: RecoveryContext): boolean {\n368:   if (ctx.resultCount === 0) return true;\n369:   if (ctx.evidenceGap) return true;\n370: \n371:   const threshold = ctx.lowConfidenceThreshold ?? DEFAULT_LOW_CONFIDENCE_THRESHOLD;\n372: \n373:   if (\n374:     typeof ctx.avgConfidence === 'number' &&\n375:     Number.isFinite(ctx.avgConfidence) &&\n376:     ctx.avgConfidence < threshold\n377:   ) return true;\n378: \n379:   if (ctx.resultCount < PARTIAL_RESULT_MIN) return true;\n380: \n381:   return false;\n382: }\n383: \n384: /**\n385:  * Check whether the empty-result recovery feature flag is enabled.\n386:  * Default: ON (graduated). Set SPECKIT_EMPTY_RESULT_RECOVERY_V1=false to disable.\n387:  */\n388: export { isEmptyResultRecoveryEnabled } from './search-flags.js';\n\n(End of file - total 388 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Recovery Payload\n// ───────────────────────────────────────────────────────────────\n// Empty/Weak Result Recovery UX\n//\n// PURPOSE: Generate structured recovery payloads when search returns\n// no results, very low-confidence results, or only partial matches.\n// Provides the calling agent with actionable next steps.\n//\n// FEATURE FLAG: SPECKIT_EMPTY_RESULT_RECOVERY_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE:\n// {\n//   \"status\": \"no_results\" | \"low_confidence\" | \"partial\",\n//   \"reason\": \"spec_filter_too_narrow\" | \"low_signal_query\" | \"knowledge_gap\",\n//   \"suggestedQueries\": [\"broader alternative 1\", \"rephrased alternative 2\"],\n//   \"recommendedAction\": \"retry_broader\" | \"switch_mode\" | \"save_memory\" | \"ask_user\" | \"ask_disambiguation\" | \"refuse_without_evidence\" | \"broaden_or_ask\"\n// }\n\nimport { expandQuery } from './query-expander.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Recovery Payload\n// ───────────────────────────────────────────────────────────────\n// Empty/Weak Result Recovery UX\n//\n// PURPOSE: Generate structured recovery payloads when search returns\n// no results, very low-confidence results, or only partial matches.\n// Provides the calling agent with actionable next steps.\n//\n// FEATURE FLAG: SPECKIT_EMPTY_RESULT_RECOVERY_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE:\n// {\n//   \"status\": \"no_results\" | \"low_confidence\" | \"partial\",\n//   \"reason\": \"spec_filter_too_narrow\" | \"low_signal_query\" | \"knowledge_gap\",\n//   \"suggestedQueries\": [\"broader alternative 1\", \"rephrased alternative 2\"],\n//   \"recommendedAction\": \"retry_broader\" | \"switch_mode\" | \"save_memory\" | \"ask_user\" | \"ask_disambiguation\" | \"refuse_without_evidence\" | \"broaden_or_ask\"\n// }\n\nimport { expandQuery } from './query-expander.js';\n\n// -- Types --\n\n/** The retrieval outcome state. */\nexport type RecoveryStatus = 'no_results' | 'low_confidence' | 'partial';\n\n/** Root cause classification of the failure. */\nexport type RecoveryReason = 'spec_filter_too_narrow' | 'low_signal_query' | 'knowledge_gap';\n\n/** Recommended next action for the calling agent. */\nexport type RecoveryAction =\n  | 'retry_broader'\n  | 'switch_mode'\n  | 'save_memory'\n  | 'ask_user'\n  | 'ask_disambiguation'\n  | 'refuse_without_evidence'\n  | 'broaden_or_ask';\n\n/** Structured recovery payload attached to search responses. */\nexport interface RecoveryPayload {\n  status: RecoveryStatus;\n  reason: RecoveryReason;\n  suggestedQueries: string[];\n  recommendedAction: RecoveryAction;\n}\n\n/** Input context used to build the recovery payload. */\nexport interface RecoveryContext {\n  /** The original search query (may be null/empty if concepts were used). */\n  query: string | null;\n  /** Whether a specFolder filter was applied. */\n  hasSpecFolderFilter: boolean;\n  /** Whether upstream search logic detected an evidence gap for this result set. */\n  evidenceGap?: boolean;\n  /** How many results were returned (0 = no_results, 1–N = partial/low_confidence). */\n  resultCount: number;\n  /** Average confidence value across returned results (0–1). Only meaningful when resultCount > 0. */\n  avgConfidence?: number;\n  /** Low-confidence threshold — results below this trigger recovery. */\n  lowConfidenceThreshold?: number;\n}\n\n// -- Constants --\n\nconst DEFAULT_LOW_CONFIDENCE_THRESHOLD = 0.4;\n\n// Minimum result count considered \"good enough\" — fewer than this triggers partial recovery.\nconst PARTIAL_RESULT_MIN = 3;\n\n// -- Internal helpers --\n\n/**\n * Classify retrieval status based on result count and confidence signals.\n */\nfunction classifyStatus(ctx: RecoveryContext): RecoveryStatus {\n  const threshold = ctx.lowConfidenceThreshold ?? DEFAULT_LOW_CONFIDENCE_THRESHOLD;\n\n  if (ctx.resultCount === 0) return 'no_results';\n  if (ctx.evidenceGap) return 'partial';\n  if (\n    typeof ctx.avgConfidence === 'number' &&\n    Number.isFinite(ctx.avgConfidence) &&\n    ctx.avgConfidence < threshold\n  ) return 'low_confidence';\n  if (ctx.resultCount < PARTIAL_RESULT_MIN) return 'partial';\n  return 'low_confidence'; // fallback — should only be called when recovery is warranted\n}\n\n/**\n * Classify root cause from context signals.\n */\nfunction classifyReason(ctx: RecoveryContext, status: RecoveryStatus): RecoveryReason {\n  // If a narrow filter was applied and no results returned, that is most likely the cause\n  if (ctx.hasSpecFolderFilter && status === 'no_results') {\n    return 'spec_filter_too_narrow';\n  }\n  // Very short or generic queries (< 3 words) suggest low signal\n  const wordCount = ctx.query ? ctx.query.trim().split(/\\s+/).filter(Boolean).length : 0;\n  if (wordCount > 0 && wordCount <= 2) {\n    return 'low_signal_query';\n  }\n  // Default to knowledge_gap — the information may simply not be indexed\n  return 'knowledge_gap';\n}\n\n/**\n * Generate suggested reformulations from the original query.\n *\n * Heuristics applied (in order):\n * 1. Remove parenthetical or bracketed clauses (focus term extraction)\n * 2. Keep only the first N words (shorten complex queries)\n * 3. Strip trailing conjunctions / stop words\n * 4. Suggest dropping the spec folder constraint when it was set\n */\nfunction generateSuggestedQueries(ctx: RecoveryContext): string[] {\n  const suggestions: string[] = [];\n  const q = ctx.query?.trim() ?? '';\n\n  if (q.length === 0) {\n    suggestions.push('memory save context', 'recent decisions', 'project overview');\n    return suggestions.slice(0, 2);\n  }\n\n  // 1. Remove parentheticals/brackets — often over-specifying\n  const withoutParens = q.replace(/\\([^)]*\\)/g, '').replace(/\\[[^\\]]*\\]/g, '').replace(/\\s{2,}/g, ' ').trim();\n  if (withoutParens.length > 0 && withoutParens !== q) {\n    suggestions.push(withoutParens);\n  }\n\n  // 2. Shorten: keep first 3 words\n  const words = q.split(/\\s+/).filter(Boolean);\n  if (words.length > 4) {\n    suggestions.push(words.slice(0, 3).join(' '));\n  }\n\n  // 3. Remove trailing stop-words (and, or, the, in, for, with, to, of, a)\n  const stopWords = new Set(['and', 'or', 'the', 'in', 'for', 'with', 'to', 'of', 'a', 'an']);\n  const trimmedWords = [...words].reverse().reduce<string[]>((acc, word) => {\n    if (acc.length === 0 && stopWords.has(word.toLowerCase())) return acc;\n    return [word, ...acc];\n  }, []);\n  const stopTrimmed = trimmedWords.join(' ');\n  if (stopTrimmed.length > 0 && stopTrimmed !== q && !suggestions.includes(stopTrimmed)) {\n    suggestions.push(stopTrimmed);\n  }\n\n  // 4. If spec folder filter was active, suggest the same query without it\n  if (ctx.hasSpecFolderFilter && !suggestions.includes(q)) {\n    suggestions.push(q); // exact same query but without folder constraint\n  }\n\n  // 5. Synonym-expansion variants — turn a low-signal query into concrete\n  // broaden prompts. Reuses the deep-path expander so a weak result surfaces\n  // the same alternatives the recall pipeline would try, instead of an empty\n  // list. Best-effort: expansion never blocks recovery.\n  try {\n    for (const variant of expandQuery(q)) {\n      if (variant !== q && !suggestions.includes(variant)) {\n        suggestions.push(variant);\n      }\n    }\n  } catch {\n    // Expansion is advisory; fall back to heuristic suggestions on any failure.\n  }\n\n  // Deduplicate, remove empties, cap at 3\n  const unique = [...new Set(suggestions.filter((s) => s.length > 0))];\n  return unique.slice(0, 3);\n}\n\n/**\n * Synthesize broad, safe suggestions when the normal heuristics cannot\n * reformulate the query. These are intentionally generic: they keep only\n * caller-supplied tokens and avoid inventing packet IDs or paths.\n */\nfunction synthesizeBroadeningSuggestions(ctx: RecoveryContext): string[] {\n  const q = ctx.query?.trim() ?? '';\n  const rawTokens = q.split(/\\s+/).filter(Boolean);\n  const stopWords = new Set([\n    'a',\n    'an',\n    'and',\n    'for',\n    'from',\n    'in',\n    'of',\n    'on',\n    'or',\n    'the',\n    'to',\n    'with',\n  ]);\n  const tokens = rawTokens\n    .map((token) => token.replace(/^[^\\w-]+|[^\\w-]+$/g, '').toLowerCase())\n    .filter((token) => token.length > 0 && !stopWords.has(token));\n\n  if (tokens.length === 0) {\n    return ['recent memory context', 'related implementation notes'];\n  }\n  if (tokens.length === 1) {\n    return [`${tokens[0]} context`, `${tokens[0]} implementation`];\n  }\n\n  const firstPair = tokens.slice(0, 2).join(' ');\n  const firstTriple = tokens.slice(0, 3).join(' ');\n  const suggestions = [\n    firstPair,\n    firstTriple,\n    tokens.join(' '),\n  ].filter((suggestion) => suggestion.length > 0);\n\n  return [...new Set(suggestions)].slice(0, 2);\n}\n\n/**\n * Map status + reason to a recommended next action.\n */\nfunction recommendAction(status: RecoveryStatus, reason: RecoveryReason): RecoveryAction {\n  if (status === 'no_results') {\n    if (reason === 'spec_filter_too_narrow') return 'retry_broader';\n    if (reason === 'low_signal_query') return 'switch_mode';\n    return 'refuse_without_evidence';\n  }\n  if (status === 'low_confidence') {\n    if (reason === 'knowledge_gap') return 'ask_user';\n    if (reason === 'low_signal_query') return 'ask_disambiguation';\n    return 'switch_mode';\n  }\n  // partial\n  return 'broaden_or_ask';\n}\n\n// -- Graph-Expanded Fallback -----------------------------------\n\nimport type Database from 'better-sqlite3';\nimport { routeQueryConcepts } from './entity-linker.js';\nimport { isGraphFallbackEnabled } from './search-flags.js';\n\n/**\n * Build graph-expanded fallback query terms on zero/weak results.\n *\n * When the search produces no results or low-confidence results, this function\n * queries the causal_edges table for nodes related to the matched concepts from\n * concept routing, returning up to 5 expanded query terms derived from neighbor\n * node titles.\n *\n * Feature-gated by SPECKIT_GRAPH_FALLBACK (default ON).\n * Fail-open: returns empty array on any error.\n *\n * @param ctx - Recovery context with query and result state.\n * @param db - SQLite database instance for graph lookups.\n * @returns Array of up to 5 expanded query terms from graph neighbors.\n */\nexport function buildGraphExpandedFallback(\n  ctx: RecoveryContext,\n  db: Database.Database,\n): string[] {\n  if (!isGraphFallbackEnabled()) return [];\n\n  const status = classifyStatus(ctx);\n  if (status !== 'no_results' && status !== 'low_confidence') return [];\n\n  try {\n    const routing = routeQueryConcepts(ctx.query ?? '', db);\n    if (!routing.graphActivated || routing.concepts.length === 0) return [];\n\n    // Find memory IDs matching the routed concepts via title keyword search,\n    // then walk causal_edges to find neighbors with distinct titles.\n\n    // Step 1: Find seed memory IDs whose titles contain matched concepts\n    const likeClauses = routing.concepts.map(() => 'LOWER(mi.title) LIKE ?').join(' OR ');\n    const likeParams = routing.concepts.map((c) => `%${c.toLowerCase()}%`);\n\n    const seedRows = (db.prepare(`\n      SELECT mi.id FROM memory_index mi\n      WHERE (${likeClauses})\n      LIMIT 10\n    `) as Database.Statement).all(...likeParams) as Array<{ id: number }>;\n\n    if (seedRows.length === 0) return [];\n\n    const seedIds = seedRows.map((r) => String(r.id));\n    const seedPlaceholdersSql = seedIds.map(() => '?').join(', ');\n\n    // Step 2: Walk 1-hop causal edges from seeds to find neighbor nodes\n    const neighborRows = (db.prepare(`\n      SELECT DISTINCT mi.title\n      FROM causal_edges ce\n      JOIN memory_index mi ON (\n        (ce.source_id IN (${seedPlaceholdersSql}) AND mi.id = CAST(ce.target_id AS INTEGER))\n        OR\n        (ce.target_id IN (${seedPlaceholdersSql}) AND mi.id = CAST(ce.source_id AS INTEGER))\n      )\n      WHERE mi.id NOT IN (${seedPlaceholdersSql})\n      LIMIT 10\n    `) as Database.Statement).all(\n      ...seedIds,\n      ...seedIds,\n      ...seedIds,\n    ) as Array<{ title: string }>;\n\n    if (neighborRows.length === 0) return [];\n\n    // Step 3: Extract short keyword phrases from neighbor titles\n    const terms: string[] = [];\n    const seen = new Set<string>();\n\n    for (const row of neighborRows) {\n      if (!row.title || terms.length >= 5) break;\n      // Take the first 3 words of the title as a search term\n      const words = row.title.trim().split(/\\s+/).slice(0, 3).join(' ').toLowerCase();\n      if (words.length > 0 && !seen.has(words)) {\n        seen.add(words);\n        terms.push(words);\n      }\n    }\n\n    return terms;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[recovery-payload] buildGraphExpandedFallback failed (fail-open): ${message}`);\n    return [];\n  }\n}\n\n// -- Public API --\n\n/**\n * Build a structured recovery payload for a failed or weak retrieval.\n *\n * Call this when:\n *  - No results are returned (resultCount === 0)\n *  - Results are returned but avgConfidence < threshold\n *  - Fewer than PARTIAL_RESULT_MIN results (partial match)\n *\n * @param ctx - Retrieval outcome context\n * @returns Structured recovery payload\n */\nexport function buildRecoveryPayload(ctx: RecoveryContext): RecoveryPayload {\n  const status = classifyStatus(ctx);\n  const reason = classifyReason(ctx, status);\n  const recommendedAction = recommendAction(status, reason);\n  const generatedSuggestions = generateSuggestedQueries(ctx);\n  const suggestedQueries = recommendedAction === 'ask_user' && generatedSuggestions.length === 0\n    ? synthesizeBroadeningSuggestions(ctx)\n    : generatedSuggestions;\n\n  return {\n    status,\n    reason,\n    suggestedQueries,\n    recommendedAction,\n  };\n}\n\n/**\n * Determine whether a search result set warrants recovery.\n *\n * Returns true when:\n *  - No results returned, OR\n *  - Average confidence below threshold, OR\n *  - Fewer than PARTIAL_RESULT_MIN results and avgConfidence is below mid-range\n *\n * @param ctx - Retrieval outcome context\n */\nexport function shouldTriggerRecovery(ctx: RecoveryContext): boolean {\n  if (ctx.resultCount === 0) return true;\n  if (ctx.evidenceGap) return true;\n\n  const threshold = ctx.lowConfidenceThreshold ?? DEFAULT_LOW_CONFIDENCE_THRESHOLD;\n\n  if (\n    typeof ctx.avgConfidence === 'number' &&\n    Number.isFinite(ctx.avgConfidence) &&\n    ctx.avgConfidence < threshold\n  ) return true;\n\n  if (ctx.resultCount < PARTIAL_RESULT_MIN) return true;\n\n  return false;\n}\n\n/**\n * Check whether the empty-result recovery feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_EMPTY_RESULT_RECOVERY_V1=false to disable.\n */\nexport { isEmptyResultRecoveryEnabled } from './search-flags.js';","lineStart":1,"lineEnd":388,"totalLines":388,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts","time":{"start":1781723081265,"end":1781723081272}},"id":"prt_ed6f8aa2d001MIH10dt3eboSK7","sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","messageID":"msg_ed6f88aaf001jHbwyflSdpcA8l"}}
{"type":"tool_use","timestamp":1781723081525,"sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","part":{"type":"tool","tool":"read","callID":"call_e078bbcfe259462e80bf4688","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/generic-query-deep-routing.vitest.ts"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/generic-query-deep-routing.vitest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // TEST — Generic-Query Deep Routing\n3: // ───────────────────────────────────────────────────────────────\n4: // Generic short queries read \"weak\" because the cheap simple route suppresses\n5: // the recall machinery they most need. These tests pin the escalation contract:\n6: //   1. A low/fallback-confidence short query escalates to the deep (complex)\n7: //      route — full channels + un-suppressed expansion.\n8: //   2. A confident short query stays on the cheap simple route (cost control).\n9: //   3. A weak result yields non-empty recovery.suggestedQueries.\n10: \n11: import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n12: import { classifyQueryComplexity } from '../lib/search/query-classifier';\n13: import { buildRecoveryPayload, type RecoveryContext } from '../lib/search/recovery-payload';\n14: \n15: const TRIGGER_PHRASES = ['save context', 'memory search'];\n16: \n17: function withRouter(fn: () => void): void {\n18:   const original = process.env.SPECKIT_COMPLEXITY_ROUTER;\n19:   process.env.SPECKIT_COMPLEXITY_ROUTER = 'true';\n20:   try {\n21:     fn();\n22:   } finally {\n23:     if (original === undefined) delete process.env.SPECKIT_COMPLEXITY_ROUTER;\n24:     else process.env.SPECKIT_COMPLEXITY_ROUTER = original;\n25:   }\n26: }\n27: \n28: function makeCtx(overrides: Partial<RecoveryContext> = {}): RecoveryContext {\n29:   return { query: null, hasSpecFolderFilter: false, resultCount: 0, ...overrides };\n30: }\n31: \n32: /* ───────────────────────────────────────────────────────────────\n33:    1. ESCALATION — low-signal short query → deep route\n34: ──────────────────────────────────────────────────────────────── */\n35: \n36: describe('Generic-query deep routing: escalation', () => {\n37:   it('escalates a high-stop-word short query to complex with low confidence', () => {\n38:     withRouter(() => {\n39:       // \"is it on\" — 3 terms, all stop words (ratio 1.0), no trigger anchor.\n40:       const result = classifyQueryComplexity('is it on');\n41:       expect(result.features.termCount).toBeLessThanOrEqual(3);\n42:       expect(result.features.stopWordRatio).toBeGreaterThanOrEqual(0.5);\n43:       expect(result.tier).toBe('complex');\n44:       expect(result.confidence).toBe('low');\n45:       // The escalated plan must reflect the full-pipeline complexity tier.\n46:       expect(result.queryPlan.complexity).toBe('complex');\n47:     });\n48:   });\n49: \n50:   it('escalation flips the low-signal flag the budget/recovery paths read', () => {\n51:     withRouter(() => {\n52:       // \"to do it\" — 3 terms, all stop words; escalated off the simple route.\n53:       const result = classifyQueryComplexity('to do it');\n54:       expect(result.features.termCount).toBe(3);\n55:       expect(result.tier).toBe('complex');\n56:       // Confidence in {low, fallback} is the contract hybrid-search keys\n57:       // lowSignalQuery off — escalated generic queries must satisfy it.\n58:       expect(['low', 'fallback']).toContain(result.confidence);\n59:     });\n60:   });\n61: });\n62: \n63: /* ───────────────────────────────────────────────────────────────\n64:    2. NON-ESCALATION — confident short queries stay cheap\n65: ──────────────────────────────────────────────────────────────── */\n66: \n67: describe('Generic-query deep routing: cost control', () => {\n68:   it('keeps a content-rich short query on the simple route', () => {\n69:     withRouter(() => {\n70:       const result = classifyQueryComplexity('semantic retrieval embedding');\n71:       expect(result.features.stopWordRatio).toBe(0);\n72:       expect(result.tier).toBe('simple');\n73:     });\n74:   });\n75: \n76:   it('keeps a one-stop-word short query (ratio below floor) on the simple route', () => {\n77:     withRouter(() => {\n78:       // \"fix the bug\" — 1 stop word of 3 (ratio 0.333) is below the 0.5 floor.\n79:       const result = classifyQueryComplexity('fix the bug');\n80:       expect(result.features.stopWordRatio).toBeCloseTo(0.333, 2);\n81:       expect(result.tier).toBe('simple');\n82:     });\n83:   });\n84: \n85:   it('keeps a trigger-anchored short query on the simple route', () => {\n86:     withRouter(() => {\n87:       const result = classifyQueryComplexity('memory search', TRIGGER_PHRASES);\n88:       expect(result.features.hasTriggerMatch).toBe(true);\n89:       expect(result.tier).toBe('simple');\n90:       expect(result.confidence).toBe('high');\n91:     });\n92:   });\n93: });\n94: \n95: /* ───────────────────────────────────────────────────────────────\n96:    3. RECOVERY — weak result yields actionable suggestions\n97: ──────────────────────────────────────────────────────────────── */\n98: \n99: describe('Generic-query deep routing: recovery suggestions', () => {\n100:   it('emits synonym-expansion suggestions for a weak generic short query', () => {\n101:     const payload = buildRecoveryPayload(makeCtx({\n102:       resultCount: 5,\n103:       avgConfidence: 0.2,\n104:       query: 'semantic search',\n105:     }));\n106:     expect(payload.status).toBe('low_confidence');\n107:     expect(payload.suggestedQueries.length).toBeGreaterThan(0);\n108:     // Variants come from the domain synonym map (semantic→embedding/vector,\n109:     // search→retrieval/query), so at least one must differ from the original.\n110:     expect(payload.suggestedQueries.some((s) => s !== 'semantic search')).toBe(true);\n111:     expect(\n112:       payload.suggestedQueries.some((s) => /embedding|vector|retrieval|query/.test(s)),\n113:     ).toBe(true);\n114:   });\n115: \n116:   it('fills suggestions for a single-word query that previously returned none', () => {\n117:     const payload = buildRecoveryPayload(makeCtx({ resultCount: 1, query: 'memory' }));\n118:     expect(payload.suggestedQueries.length).toBeGreaterThan(0);\n119:     expect(payload.suggestedQueries.every((s) => s.trim().length > 0)).toBe(true);\n120:   });\n121: \n122:   it('never exceeds the three-suggestion cap', () => {\n123:     const payload = buildRecoveryPayload(makeCtx({\n124:       resultCount: 0,\n125:       query: 'auth error fix deploy cache',\n126:     }));\n127:     expect(payload.suggestedQueries.length).toBeLessThanOrEqual(3);\n128:   });\n129: });\n\n(End of file - total 129 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// TEST — Generic-Query Deep Routing\n// ───────────────────────────────────────────────────────────────\n// Generic short queries read \"weak\" because the cheap simple route suppresses\n// the recall machinery they most need. These tests pin the escalation contract:\n//   1. A low/fallback-confidence short query escalates to the deep (complex)\n//      route — full channels + un-suppressed expansion.\n//   2. A confident short query stays on the cheap simple route (cost control).\n//   3. A weak result yields non-empty recovery.suggestedQueries.\n\nimport { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport { classifyQueryComplexity } from '../lib/search/query-classifier';\nimport { buildRecoveryPayload, type RecoveryContext } from '../lib/search/recovery-payload';\n\nconst TRIGGER_PHRASES = ['save context', 'memory search'];\n\nfunction withRouter(fn: () => void): void {\n  const original = process.env.SPECKIT_COMPLEXITY_ROUTER;\n  process.env.SPECKIT_COMPLEXITY_ROUTER = 'true';\n  try {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/generic-query-deep-routing.vitest.ts","text":"// ───────────────────────────────────────────────────────────────\n// TEST — Generic-Query Deep Routing\n// ───────────────────────────────────────────────────────────────\n// Generic short queries read \"weak\" because the cheap simple route suppresses\n// the recall machinery they most need. These tests pin the escalation contract:\n//   1. A low/fallback-confidence short query escalates to the deep (complex)\n//      route — full channels + un-suppressed expansion.\n//   2. A confident short query stays on the cheap simple route (cost control).\n//   3. A weak result yields non-empty recovery.suggestedQueries.\n\nimport { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport { classifyQueryComplexity } from '../lib/search/query-classifier';\nimport { buildRecoveryPayload, type RecoveryContext } from '../lib/search/recovery-payload';\n\nconst TRIGGER_PHRASES = ['save context', 'memory search'];\n\nfunction withRouter(fn: () => void): void {\n  const original = process.env.SPECKIT_COMPLEXITY_ROUTER;\n  process.env.SPECKIT_COMPLEXITY_ROUTER = 'true';\n  try {\n    fn();\n  } finally {\n    if (original === undefined) delete process.env.SPECKIT_COMPLEXITY_ROUTER;\n    else process.env.SPECKIT_COMPLEXITY_ROUTER = original;\n  }\n}\n\nfunction makeCtx(overrides: Partial<RecoveryContext> = {}): RecoveryContext {\n  return { query: null, hasSpecFolderFilter: false, resultCount: 0, ...overrides };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1. ESCALATION — low-signal short query → deep route\n──────────────────────────────────────────────────────────────── */\n\ndescribe('Generic-query deep routing: escalation', () => {\n  it('escalates a high-stop-word short query to complex with low confidence', () => {\n    withRouter(() => {\n      // \"is it on\" — 3 terms, all stop words (ratio 1.0), no trigger anchor.\n      const result = classifyQueryComplexity('is it on');\n      expect(result.features.termCount).toBeLessThanOrEqual(3);\n      expect(result.features.stopWordRatio).toBeGreaterThanOrEqual(0.5);\n      expect(result.tier).toBe('complex');\n      expect(result.confidence).toBe('low');\n      // The escalated plan must reflect the full-pipeline complexity tier.\n      expect(result.queryPlan.complexity).toBe('complex');\n    });\n  });\n\n  it('escalation flips the low-signal flag the budget/recovery paths read', () => {\n    withRouter(() => {\n      // \"to do it\" — 3 terms, all stop words; escalated off the simple route.\n      const result = classifyQueryComplexity('to do it');\n      expect(result.features.termCount).toBe(3);\n      expect(result.tier).toBe('complex');\n      // Confidence in {low, fallback} is the contract hybrid-search keys\n      // lowSignalQuery off — escalated generic queries must satisfy it.\n      expect(['low', 'fallback']).toContain(result.confidence);\n    });\n  });\n});\n\n/* ───────────────────────────────────────────────────────────────\n   2. NON-ESCALATION — confident short queries stay cheap\n──────────────────────────────────────────────────────────────── */\n\ndescribe('Generic-query deep routing: cost control', () => {\n  it('keeps a content-rich short query on the simple route', () => {\n    withRouter(() => {\n      const result = classifyQueryComplexity('semantic retrieval embedding');\n      expect(result.features.stopWordRatio).toBe(0);\n      expect(result.tier).toBe('simple');\n    });\n  });\n\n  it('keeps a one-stop-word short query (ratio below floor) on the simple route', () => {\n    withRouter(() => {\n      // \"fix the bug\" — 1 stop word of 3 (ratio 0.333) is below the 0.5 floor.\n      const result = classifyQueryComplexity('fix the bug');\n      expect(result.features.stopWordRatio).toBeCloseTo(0.333, 2);\n      expect(result.tier).toBe('simple');\n    });\n  });\n\n  it('keeps a trigger-anchored short query on the simple route', () => {\n    withRouter(() => {\n      const result = classifyQueryComplexity('memory search', TRIGGER_PHRASES);\n      expect(result.features.hasTriggerMatch).toBe(true);\n      expect(result.tier).toBe('simple');\n      expect(result.confidence).toBe('high');\n    });\n  });\n});\n\n/* ───────────────────────────────────────────────────────────────\n   3. RECOVERY — weak result yields actionable suggestions\n──────────────────────────────────────────────────────────────── */\n\ndescribe('Generic-query deep routing: recovery suggestions', () => {\n  it('emits synonym-expansion suggestions for a weak generic short query', () => {\n    const payload = buildRecoveryPayload(makeCtx({\n      resultCount: 5,\n      avgConfidence: 0.2,\n      query: 'semantic search',\n    }));\n    expect(payload.status).toBe('low_confidence');\n    expect(payload.suggestedQueries.length).toBeGreaterThan(0);\n    // Variants come from the domain synonym map (semantic→embedding/vector,\n    // search→retrieval/query), so at least one must differ from the original.\n    expect(payload.suggestedQueries.some((s) => s !== 'semantic search')).toBe(true);\n    expect(\n      payload.suggestedQueries.some((s) => /embedding|vector|retrieval|query/.test(s)),\n    ).toBe(true);\n  });\n\n  it('fills suggestions for a single-word query that previously returned none', () => {\n    const payload = buildRecoveryPayload(makeCtx({ resultCount: 1, query: 'memory' }));\n    expect(payload.suggestedQueries.length).toBeGreaterThan(0);\n    expect(payload.suggestedQueries.every((s) => s.trim().length > 0)).toBe(true);\n  });\n\n  it('never exceeds the three-suggestion cap', () => {\n    const payload = buildRecoveryPayload(makeCtx({\n      resultCount: 0,\n      query: 'auth error fix deploy cache',\n    }));\n    expect(payload.suggestedQueries.length).toBeLessThanOrEqual(3);\n  });\n});","lineStart":1,"lineEnd":129,"totalLines":129,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/generic-query-deep-routing.vitest.ts","time":{"start":1781723081514,"end":1781723081522}},"id":"prt_ed6f8ab250013MS6uff7f2Xv56","sessionID":"ses_12907dd91ffeHh8PTUPCnd7I0V","messageID":"msg_ed6f88aaf001jHbwyflSdpcA8l"}}
