{
  "version": "1.0",
  "description": "Packet-local matrix for Phase 003. Allows repo-wide reads, writes/edits only under the active packet, and read-only shell inspection commands. Resolution semantics: most-specific glob wins; first-in-array breaks equal-specificity ties.",
  "rules": [
    {
      "target_glob": "**",
      "operation_class": "read",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "Implementation needs read access across the repository for evidence gathering."
    },
    {
      "target_glob": ".opencode/specs/skilled-agent-orchestration/114-small-ai-model-optimization/003-permissions-matrix/**",
      "operation_class": "write",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 packet docs are the approved documentation write scope."
    },
    {
      "target_glob": ".opencode/specs/skilled-agent-orchestration/114-small-ai-model-optimization/003-permissions-matrix/**",
      "operation_class": "edit",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 packet docs are the approved documentation edit scope."
    },
    {
      "target_glob": ".opencode/skills/cli-opencode/assets/permissions-matrix*.json",
      "operation_class": "write",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 explicitly creates schema and example matrix assets."
    },
    {
      "target_glob": ".opencode/skills/cli-opencode/assets/permissions-matrix*.json",
      "operation_class": "edit",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 explicitly updates schema and example matrix assets."
    },
    {
      "target_glob": ".opencode/skills/cli-opencode/references/permissions-matrix.md",
      "operation_class": "write",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 explicitly creates the permissions matrix reference doc."
    },
    {
      "target_glob": ".opencode/skills/cli-opencode/references/permissions-matrix.md",
      "operation_class": "edit",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 explicitly edits the permissions matrix reference doc."
    },
    {
      "target_glob": ".opencode/skills/system-spec-kit/mcp_server/lib/deep-loop/permissions-gate.ts",
      "operation_class": "write",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 explicitly creates the runtime enforcer."
    },
    {
      "target_glob": ".opencode/skills/system-spec-kit/mcp_server/lib/deep-loop/permissions-gate.ts",
      "operation_class": "edit",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 explicitly edits the runtime enforcer."
    },
    {
      "target_glob": ".opencode/skills/system-spec-kit/mcp_server/tests/deep-loop/permissions-gate.vitest.ts",
      "operation_class": "write",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 explicitly creates unit tests for the runtime enforcer."
    },
    {
      "target_glob": ".opencode/skills/system-spec-kit/mcp_server/tests/deep-loop/permissions-gate.vitest.ts",
      "operation_class": "edit",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 explicitly edits unit tests for the runtime enforcer."
    },
    {
      "target_glob": ".opencode/skills/cli-opencode/SKILL.md",
      "operation_class": "edit",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 updates ONLY ALWAYS rule 13."
    },
    {
      "target_glob": ".opencode/skills/sk-small-model/references/pattern-index.md",
      "operation_class": "edit",
      "scope": "packet-local",
      "effect": "allow",
      "rationale": "Phase 003 marks the permissions-matrix pattern as shipped."
    },
    {
      "target_glob": "Exec(rg)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "rg is read-only search."
    },
    {
      "target_glob": "Exec(grep)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "grep is read-only search."
    },
    {
      "target_glob": "Exec(git)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "git status/show/diff/log support inspection."
    },
    {
      "target_glob": "Exec(ls)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "ls is read-only."
    },
    {
      "target_glob": "Exec(find)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "find is allowed for discovery; destructive find -delete remains denied by default."
    },
    {
      "target_glob": "Exec(cat)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "cat reads files."
    },
    {
      "target_glob": "Exec(head)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "head reads file prefixes."
    },
    {
      "target_glob": "Exec(tail)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "tail reads file suffixes."
    },
    {
      "target_glob": "Exec(wc)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "wc counts content."
    },
    {
      "target_glob": "Exec(awk)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "awk is allowed for read-only text processing."
    },
    {
      "target_glob": "Exec(sed -i*)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "sed in-place editing is a write operation hidden in Bash."
    },
    {
      "target_glob": "Exec(sed)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "allow",
      "rationale": "sed without -i is allowed for read-only inspection."
    },
    {
      "target_glob": "Exec(rm*)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "rm deletes files and is banned by the RM-8 packet-local guard."
    },
    {
      "target_glob": "Exec(mv)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "mv can move files out of the approved packet scope."
    },
    {
      "target_glob": "Exec(cp)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "cp can overwrite files outside the approved packet scope."
    },
    {
      "target_glob": "Exec(npm)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "npm can mutate dependencies or run scripts outside packet scope."
    },
    {
      "target_glob": "Exec(pnpm)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "pnpm can mutate dependencies or run scripts outside packet scope."
    },
    {
      "target_glob": "Exec(yarn)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "yarn can mutate dependencies or run scripts outside packet scope."
    },
    {
      "target_glob": "Exec(node)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "node can execute arbitrary mutation scripts."
    },
    {
      "target_glob": "Exec(python*)",
      "operation_class": "execute",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "python can execute arbitrary mutation scripts."
    },
    {
      "target_glob": "**",
      "operation_class": "write",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "Writes outside explicit Phase 003 paths are denied."
    },
    {
      "target_glob": "**",
      "operation_class": "edit",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "Edits outside explicit Phase 003 paths are denied."
    },
    {
      "target_glob": "**",
      "operation_class": "delete",
      "scope": "repo-wide",
      "effect": "deny",
      "rationale": "Packet-local work does not allow deletions."
    }
  ]
}
