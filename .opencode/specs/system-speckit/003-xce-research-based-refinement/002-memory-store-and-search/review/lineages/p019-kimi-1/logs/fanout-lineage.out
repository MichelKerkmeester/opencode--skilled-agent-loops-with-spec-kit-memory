nchronous tail phase (which\n1509:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1510:             maintenance.refresh();\n1511:             void setJobPhase(jobId, phase).catch(() => {});\n1512:           },\n1513:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1514:         });\n1515:         const scanData = extractEnvelopeData(response);\n1516:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1517:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1518:         if (wasCancelled) {\n1519:           // The run itself short-circuited on cancellation. A cancel that arrives\n1520:           // after the scan already finished does not retroactively cancel it.\n1521:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1522:         } else if (response.isError === true) {\n1523:           // An error envelope (not a thrown error) still means the scan failed.\n1524:           await appendJobError(jobId, '__scan__', scanData);\n1525:           await setJobState(jobId, 'failed');\n1526:         } else {\n1527:           await completeJob(jobId, { state: 'complete', result: scanData });\n1528:         }\n1529:       } catch (error: unknown) {\n1530:         try {\n1531:           await appendJobError(jobId, '__job__', error);\n1532:           await setJobState(jobId, 'failed');\n1533:         } catch (_secondaryError: unknown) {\n1534:           // Best-effort failure record; never surface a background unhandled rejection.\n1535:         }\n1536:       } finally {\n1537:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1538:         // Release this scan's hold; the marker stays present only while the\n1539:         // background-embedding queue still holds it.\n1540:         maintenance.end();\n1541:       }\n1542:     })();\n1543:   });\n1544: \n1545:   return createMCPSuccessResponse({\n1546:     tool: 'memory_index_scan',\n1547:     summary: `Queued background index scan ${jobId}`,\n1548:     data: { jobId, state: 'queued', background: true },\n1549:     hints: [\n1550:       'Use memory_index_scan_status with jobId to poll progress',\n1551:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1552:     ],\n1553:   });\n1554: }\n1555: \n1556: /* ───────────────────────────────────────────────────────────────\n1557:    9. EXPORTS\n1558: ──────────────────────────────────────────────────────────────── */\n1559: \n\n(Showing lines 1480-1559 of 1587. Use offset=1560 to continue.)\n</content>","metadata":{"preview":"      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */\n","lineStart":1480,"lineEnd":1559,"totalLines":1587,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781719927642,"end":1781719927654}},"id":"prt_ed6c88898001yC1B7b3BWpbhjZ","sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","messageID":"msg_ed6c85cad001BdbZifbEjcWsv2"}}
{"type":"tool_use","timestamp":1781719928588,"sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","part":{"type":"tool","tool":"read","callID":"tool_DcD4cFru0UAhTMtWyfXJ075X","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","offset":580,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n580:     fsApi.unlinkSync(filePath);\n581:   } catch {\n582:     // Best-effort stale-state cleanup.\n583:   }\n584: }\n585: \n586: function readModelServerGiveUpUntil(socketPath, options = {}) {\n587:   const fsApi = { ...fs, ...(options.fs || {}) };\n588:   const giveUpPath = modelServerGiveUpPath(socketPath, options);\n589:   try {\n590:     const parsed = JSON.parse(fsApi.readFileSync(giveUpPath, 'utf8'));\n591:     if (isModelServerGiveUpStale(parsed, options)) {\n592:       unlinkBestEffort(giveUpPath, fsApi);\n593:       return null;\n594:     }\n595:     return Number.isFinite(parsed?.giveUpUntil) && parsed.giveUpUntil > 0 ? parsed.giveUpUntil : null;\n596:   } catch {\n597:     return null;\n598:   }\n599: }\n600: \n601: // ── Maintenance-active marker ────────────────────────────────────────────────\n602: // A background index scan can legitimately keep the daemon's event loop busy for\n603: // stretches, so a competing launcher's deep liveness probe sees an unresponsive\n604: // socket and would reap+respawn the daemon mid-scan (killing the scan). The\n605: // daemon writes this marker beside its DB and refreshes it on a timer; the\n606: // launcher uses it to tell \"busy-by-design\" from \"wedged\": a fresh marker naming\n607: // the live daemon child means ADOPT, not reap. A genuinely wedged daemon cannot\n608: // fire its refresh timer, so the marker expires and normal reaping resumes.\n609: const MAINTENANCE_MARKER_FILE_NAME = '.maintenance-active.json';\n610: \n611: function maintenanceMarkerPath(dbDir) {\n612:   return path.join(dbDir, MAINTENANCE_MARKER_FILE_NAME);\n613: }\n614: \n615: function readMaintenanceMarker(dbDir, options = {}) {\n616:   const fsApi = { ...fs, ...(options.fs || {}) };\n617:   try {\n618:     const parsed = JSON.parse(fsApi.readFileSync(maintenanceMarkerPath(dbDir), 'utf8'));\n619:     if (Number.isInteger(parsed?.childPid) && parsed.childPid > 0 && Number.isFinite(parsed?.activeUntilMs)) {\n620:       return parsed;\n621:     }\n622:   } catch {\n623:     // Missing or corrupt marker => treat as no active maintenance.\n624:   }\n625:   return null;\n626: }\n627: \n628: // Pure adopt-vs-reap decision. Returns true only when a fresh marker names this\n629: // exact live child. Fail-safe toward reaping: a missing/expired marker, a\n630: // childPid mismatch, or a non-'alive' child all fall through to the normal reap\n631: // path so a stale marker can never pin a genuinely dead or wedged daemon.\n632: function shouldAdoptDespiteProbe(options = {}) {\n633:   const { marker, childPid, childLiveness } = options;\n634:   if (!marker) return false;\n635:   if (!Number.isInteger(childPid) || childPid <= 0) return false;\n636:   if (marker.childPid !== childPid) return false;\n637:   if (!(Number.isFinite(marker.activeUntilMs) && marker.activeUntilMs > nowMsFromOptions(options))) return false;\n638:   if (childLiveness !== 'alive') return false;\n639:   return true;\n640: }\n641: \n642: function isRespawnLockStale(raw, options = {}) {\n643:   const liveness = options.liveness || processLiveness;\n644:   const nowMs = typeof options.nowMs === 'number' ? options.nowMs : Date.now();\n645:   const staleMs = typeof options.staleMs === 'number' ? options.staleMs : RESPAWN_LOCK_STALE_MS;\n646:   let parsed;\n647:   try {\n648:     parsed = JSON.parse(raw);\n649:   } catch {\n650:     return true;\n651:   }\n652:   const pid = parsed && parsed.pid;\n653:   const hasPid = Number.isInteger(pid) && pid > 0;\n654:   if (hasPid && liveness(pid) === 'dead') return true;\n655:   // A live demand listener deliberately holds this lock across its whole bind + idle-listener\n656:   // window, which can exceed RESPAWN_LOCK_STALE_MS. Bound staleness to listener liveness: only let the\n657:   // wall-clock age expire the lock when the recorded owner is NOT confirmably alive (absent/invalid pid,\n658:   // or an EPERM-opaque pid we cannot prove is ours). If the owner pid is alive, it still owns the lock —\n659:   // never reclaim it from under a live owner on age alone.\n660:   if (hasPid && liveness(pid) === 'alive') return false;\n661:   const startedAtMs = parsed && parsed.startedAt ? Date.parse(parsed.startedAt) : NaN;\n662:   if (Number.isFinite(startedAtMs) && nowMs - startedAtMs > staleMs) return true;\n663:   return false;\n664: }\n665: \n666: function acquireRespawnLockFileAt(lockPath, label = 'respawn', options = {}) {\n667:   const logger = options.log || defaultLog;\n668:   const rel = options.rel || ((p) => p);\n669:   const fsApi = { ...fs, ...(options.fs || {}) };\n670:   const currentLockPath = path.join(ensureCanonicalDir(path.dirname(lockPath)), path.basename(lockPath));\n671:   const tryOpen = () => {\n672:     let fd = null;\n673:     try {\n674:       fd = fsApi.openSync(currentLockPath, 'wx', 0o600);\n675:       fsApi.writeFileSync(fd, `${JSON.stringify({ pid: process.pid, startedAt: new Date().toISOString() }, null, 2)}\\n`, 'utf8');\n676:       fsApi.fsyncSync(fd);\n677:       return { acquired: true, fd, path: currentLockPath };\n678:     } catch (error) {\n679:       if (typeof fd === 'number') {\n680:         try {\n681:           fsApi.closeSync(fd);\n682:         } catch {\n683:           // Close failure is secondary to the durable-write failure.\n684:         }\n685:         cleanupTmpFile(currentLockPath, fsApi);\n686:       }\n687:       if (isDurableWriteUnavailable(error)) {\n688:         logDurableWriteUnavailableOnce(logger, `${label} lock acquire`, currentLockPath, error, rel);\n689:         return { acquired: false, path: currentLockPath, reason: 'durable-write-unavailable' };\n690:       }\n691:       throw error;\n692:     }\n693:   };\n694:   try {\n695:     const opened = tryOpen();\n696:     if (!opened.acquired) return opened;\n697:     return opened;\n698:   } catch (error) {\n699:     if (error.code !== 'EEXIST') throw error;\n\n(Showing lines 580-699 of 1474. Use offset=700 to continue.)\n</content>","metadata":{"preview":"    fsApi.unlinkSync(filePath);\n  } catch {\n    // Best-effort stale-state cleanup.\n  }\n}\n\nfunction readModelServerGiveUpUntil(socketPath, options = {}) {\n  const fsApi = { ...fs, ...(options.fs || {}) };\n  const giveUpPath = modelServerGiveUpPath(socketPath, options);\n  try {\n    const parsed = JSON.parse(fsApi.readFileSync(giveUpPath, 'utf8'));\n    if (isModelServerGiveUpStale(parsed, options)) {\n      unlinkBestEffort(giveUpPath, fsApi);\n      return null;\n    }\n    return Number.isFinite(parsed?.giveUpUntil) && parsed.giveUpUntil > 0 ? parsed.giveUpUntil : null;\n  } catch {\n    return null;\n  }\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","text":"    fsApi.unlinkSync(filePath);\n  } catch {\n    // Best-effort stale-state cleanup.\n  }\n}\n\nfunction readModelServerGiveUpUntil(socketPath, options = {}) {\n  const fsApi = { ...fs, ...(options.fs || {}) };\n  const giveUpPath = modelServerGiveUpPath(socketPath, options);\n  try {\n    const parsed = JSON.parse(fsApi.readFileSync(giveUpPath, 'utf8'));\n    if (isModelServerGiveUpStale(parsed, options)) {\n      unlinkBestEffort(giveUpPath, fsApi);\n      return null;\n    }\n    return Number.isFinite(parsed?.giveUpUntil) && parsed.giveUpUntil > 0 ? parsed.giveUpUntil : null;\n  } catch {\n    return null;\n  }\n}\n\n// ── Maintenance-active marker ────────────────────────────────────────────────\n// A background index scan can legitimately keep the daemon's event loop busy for\n// stretches, so a competing launcher's deep liveness probe sees an unresponsive\n// socket and would reap+respawn the daemon mid-scan (killing the scan). The\n// daemon writes this marker beside its DB and refreshes it on a timer; the\n// launcher uses it to tell \"busy-by-design\" from \"wedged\": a fresh marker naming\n// the live daemon child means ADOPT, not reap. A genuinely wedged daemon cannot\n// fire its refresh timer, so the marker expires and normal reaping resumes.\nconst MAINTENANCE_MARKER_FILE_NAME = '.maintenance-active.json';\n\nfunction maintenanceMarkerPath(dbDir) {\n  return path.join(dbDir, MAINTENANCE_MARKER_FILE_NAME);\n}\n\nfunction readMaintenanceMarker(dbDir, options = {}) {\n  const fsApi = { ...fs, ...(options.fs || {}) };\n  try {\n    const parsed = JSON.parse(fsApi.readFileSync(maintenanceMarkerPath(dbDir), 'utf8'));\n    if (Number.isInteger(parsed?.childPid) && parsed.childPid > 0 && Number.isFinite(parsed?.activeUntilMs)) {\n      return parsed;\n    }\n  } catch {\n    // Missing or corrupt marker => treat as no active maintenance.\n  }\n  return null;\n}\n\n// Pure adopt-vs-reap decision. Returns true only when a fresh marker names this\n// exact live child. Fail-safe toward reaping: a missing/expired marker, a\n// childPid mismatch, or a non-'alive' child all fall through to the normal reap\n// path so a stale marker can never pin a genuinely dead or wedged daemon.\nfunction shouldAdoptDespiteProbe(options = {}) {\n  const { marker, childPid, childLiveness } = options;\n  if (!marker) return false;\n  if (!Number.isInteger(childPid) || childPid <= 0) return false;\n  if (marker.childPid !== childPid) return false;\n  if (!(Number.isFinite(marker.activeUntilMs) && marker.activeUntilMs > nowMsFromOptions(options))) return false;\n  if (childLiveness !== 'alive') return false;\n  return true;\n}\n\nfunction isRespawnLockStale(raw, options = {}) {\n  const liveness = options.liveness || processLiveness;\n  const nowMs = typeof options.nowMs === 'number' ? options.nowMs : Date.now();\n  const staleMs = typeof options.staleMs === 'number' ? options.staleMs : RESPAWN_LOCK_STALE_MS;\n  let parsed;\n  try {\n    parsed = JSON.parse(raw);\n  } catch {\n    return true;\n  }\n  const pid = parsed && parsed.pid;\n  const hasPid = Number.isInteger(pid) && pid > 0;\n  if (hasPid && liveness(pid) === 'dead') return true;\n  // A live demand listener deliberately holds this lock across its whole bind + idle-listener\n  // window, which can exceed RESPAWN_LOCK_STALE_MS. Bound staleness to listener liveness: only let the\n  // wall-clock age expire the lock when the recorded owner is NOT confirmably alive (absent/invalid pid,\n  // or an EPERM-opaque pid we cannot prove is ours). If the owner pid is alive, it still owns the lock —\n  // never reclaim it from under a live owner on age alone.\n  if (hasPid && liveness(pid) === 'alive') return false;\n  const startedAtMs = parsed && parsed.startedAt ? Date.parse(parsed.startedAt) : NaN;\n  if (Number.isFinite(startedAtMs) && nowMs - startedAtMs > staleMs) return true;\n  return false;\n}\n\nfunction acquireRespawnLockFileAt(lockPath, label = 'respawn', options = {}) {\n  const logger = options.log || defaultLog;\n  const rel = options.rel || ((p) => p);\n  const fsApi = { ...fs, ...(options.fs || {}) };\n  const currentLockPath = path.join(ensureCanonicalDir(path.dirname(lockPath)), path.basename(lockPath));\n  const tryOpen = () => {\n    let fd = null;\n    try {\n      fd = fsApi.openSync(currentLockPath, 'wx', 0o600);\n      fsApi.writeFileSync(fd, `${JSON.stringify({ pid: process.pid, startedAt: new Date().toISOString() }, null, 2)}\\n`, 'utf8');\n      fsApi.fsyncSync(fd);\n      return { acquired: true, fd, path: currentLockPath };\n    } catch (error) {\n      if (typeof fd === 'number') {\n        try {\n          fsApi.closeSync(fd);\n        } catch {\n          // Close failure is secondary to the durable-write failure.\n        }\n        cleanupTmpFile(currentLockPath, fsApi);\n      }\n      if (isDurableWriteUnavailable(error)) {\n        logDurableWriteUnavailableOnce(logger, `${label} lock acquire`, currentLockPath, error, rel);\n        return { acquired: false, path: currentLockPath, reason: 'durable-write-unavailable' };\n      }\n      throw error;\n    }\n  };\n  try {\n    const opened = tryOpen();\n    if (!opened.acquired) return opened;\n    return opened;\n  } catch (error) {\n    if (error.code !== 'EEXIST') throw error;","lineStart":580,"lineEnd":699,"totalLines":1474,"truncated":true}},"title":".opencode/bin/lib/model-server-supervision.cjs","time":{"start":1781719928577,"end":1781719928586}},"id":"prt_ed6c88b5e001bx4mm6yshIA2q8","sessionID":"ses_1293999f4ffexgD8bbCHsxB7WL","messageID":"msg_ed6c85cad001BdbZifbEjcWsv2"}}
