me(frame);\n616:       return;\n617:     }\n618:     forwardClientFrame(frame);\n619:   }\n620: \n621:   function handleBackendFrame(frame) {\n622:     lastBackendActivity = Date.now();\n623:     const parsed = parseFrame(frame);\n624:     if (pendingKeepaliveId !== null && isResponseFrame(parsed) && parsed.id === pendingKeepaliveId) {\n625:       pendingKeepaliveId = null;\n626:       if (keepaliveTimer !== null) {\n627:         clearTimeout(keepaliveTimer);\n628:         keepaliveTimer = null;\n629:       }\n630:       return;\n631:     }\n632:     const cachedInitializeId = tracker.getCachedInitializeId();\n633:     if (!tracker.hasObservedProtocolVersion()\n634:         && cachedInitializeId !== null\n635:         && isResponseFrame(parsed)\n636:         && parsed.id === cachedInitializeId) {\n637:       // Record the protocol version negotiated on the first initialize so an internal\n638:       // re-handshake to a swapped backend can fail closed on a version change rather\n639:       // than silently serve the client a protocol it never negotiated.\n640:       tracker.recordNegotiatedProtocolVersion(\n641:         parsed.result && typeof parsed.result === 'object' ? parsed.result.protocolVersion : undefined,\n642:       );\n643:     }\n644:     tracker.handleBackendFrame(frame);\n645:     enqueueOutputFrame(frame);\n646:     finishIfClientEndedAndIdle();\n647:   }\n648: \n649:   function replaySnapshot(snapshot) {\n650:     const cachedInitializeId = tracker.getCachedInitializeId();\n651:     for (const [id, entry] of snapshot) {\n652:       if (!tracker.pendingRequests.has(id)) continue;\n653:       // internalHandshake already re-sent (and consumed the reply for) the cached\n654:       // initialize on the fresh socket. Replaying it here too would deliver a second\n655:       // initialize to the backend, so the handshake path owns the initialize replay.\n656:       if (cachedInitializeId !== null && id === cachedInitializeId) continue;\n657:       if (entry