{"type":"text","timestamp":1781762655450,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"id":"prt_ed95482af001nB29xVn5dmks2D","messageID":"msg_ed95450c2001zQmWt1hLuMiS0E","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","type":"text","text":"Counterevidence shows the project explicitly documents “indexing runs before final rename,” and `memory-save.ts` indexes prepared in-memory content, so the ordering itself is intentional rather than a defect. I’m shifting to cancellation/cleanup and lifecycle paths for confirmed defects.","time":{"start":1781762654895,"end":1781762655447},"metadata":{"openai":{"itemId":"msg_0f557bc5edd26ece016a338a5ed9d8819187fe264ca6f6fd54","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781762655532,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"grep","callID":"call_vXtCzXtqwYPjXtB7hQe43K8U","state":{"status":"completed","input":{"pattern":"async function processPreparedMemory|function processPreparedMemory|const processPreparedMemory|file_mtime_ms|batchUpdateMtimes|getFileMetadata|indexMemoryFile\\(|parseMemoryFile\\(|readFileSync","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","include":"memory-save.ts"},"output":"Found 15 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:\n  Line 831:     content: fs.readFileSync(filePath, 'utf-8'),\n\n  Line 1115:     specContent = fs.readFileSync(specMdPath, 'utf8');\n\n  Line 1604:   const originalTargetContent = fs.readFileSync(targetDocPath, 'utf8');\n\n  Line 2148: async function processPreparedMemory(\n\n  Line 2262:       ? prepareParsedMemoryForIndexing(memoryParser.parseMemoryFile(filePath), database, {\n\n  Line 2833: async function indexMemoryFile(\n\n  Line 2850:   const parsed = parsedOverride || memoryParser.parseMemoryFile(filePath);\n\n  Line 2908:   return indexMemoryFile(filePath, {\n\n  Line 3373:     const parsedForDryRun = memoryParser.parseMemoryFile(validatedPath);\n\n  Line 3394:     parsedForPreflight = memoryParser.parseMemoryFile(validatedPath);\n\n  Line 3549:       const parsedForIdempotency = parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath);\n\n  Line 3658:       content: fs.readFileSync(validatedPath, 'utf8'),\n\n  Line 3668:         specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n\n  Line 3669:         title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n\n  Line 3689:     result = await indexMemoryFile(validatedPath, {\n","metadata":{"matches":15,"truncated":false},"title":"async function processPreparedMemory|function processPreparedMemory|const processPreparedMemory|file_mtime_ms|batchUpdateMtimes|getFileMetadata|indexMemoryFile\\(|parseMemoryFile\\(|readFileSync","time":{"start":1781762655517,"end":1781762655531}},"metadata":{"openai":{"itemId":"fc_0f557bc5edd26ece016a338a5f55948191904435d4a50f11ab"}},"id":"prt_ed95484d9001NQUEhTE67hqc4q","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed95450c2001zQmWt1hLuMiS0E"}}
{"type":"tool_use","timestamp":1781762655548,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_ZxTCzGdqAJdWhz8pPbiCVo4o","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Incremental Index\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Deferred lexical-only indexing\n5: // Mtime-based incremental indexing for fast re-indexing\n6: // Node stdlib\n7: import { createHash } from 'node:crypto';\n8: import * as fs from 'fs';\n9: import * as path from 'path';\n10: \n11: // External packages\n12: import type Database from 'better-sqlite3';\n13: \n14: // Internal modules\n15: import { getCanonicalPathKey } from '../utils/canonical-path.js';\n16: import { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\n17: import { canonicalFingerprint } from './canonical-fingerprint.js';\n18: import { createMemoStore } from './memo.js';\n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. CONSTANTS\n22: ----------------------------------------------------------------*/\n23: \n24: const MTIME_FAST_PATH_MS = 1000; // Skip if mtime within 1 second\n25: const DEFAULT_ORPHAN_SWEEP_LIMIT = 200;\n26: \n27: /* ───────────────────────────────────────────────────────────────\n28:    2. INTERFACES\n29: ----------------------------------------------------------------*/\n30: \n31: interface FileMetadata {\n32:   path: string;\n33:   mtime: number;\n34:   size: number;\n35:   exists: boolean;\n36: }\n37: \n38: interface StoredMetadata {\n39:   file_path: string;\n40:   canonical_file_path?: string | null;\n41:   file_mtime_ms: number | null;\n42:   content_hash: string | null;\n43:   embedding_status: string;\n44: }\n45: \n46: type IndexDecision = 'skip' | 'reindex' | 'new' | 'deleted' | 'modified' | 'unknown';\n47: \n48: interface CategorizedFiles {\n49:   toIndex: string[];\n50:   toUpdate: string[];\n51:   toSkip: string[];\n52:   toDelete: string[];\n53: }\n54: \n55: interface IndexedPathRow {\n56:   file_path: string;\n57:   canonical_file_path?: string | null;\n58: }\n59: \n60: interface IndexedRecordRow extends IndexedPathRow {\n61:   id: number;\n62: }\n63: \n64: interface OrphanSweepOptions {\n65:   limit?: number;\n66:   cursor?: number;\n67: }\n68: \n69: interface OrphanSweepResult {\n70:   swept: number;\n71:   nextCursor: number | null;\n72:   scannedRows: number;\n73:   orphanRecordIds: number[];\n74: }\n75: \n76: /* ───────────────────────────────────────────────────────────────\n77:    3. MODULE STATE\n78: ----------------------------------------------------------------*/\n79: \n80: let db: Database.Database | null = null;\n81: let canonicalPathColumnAvailable: boolean | null = null;\n82: let documentTypeColumnAvailable: boolean | null = null;\n83: \n84: function init(database: Database.Database): void {\n85:   db = database;\n86:   canonicalPathColumnAvailable = null;\n87:   documentTypeColumnAvailable = null;\n88: }\n89: \n90: function hasCanonicalPathColumn(): boolean {\n91:   if (!db) return false;\n92: \n93:   if (canonicalPathColumnAvailable !== null) {\n94:     return canonicalPathColumnAvailable;\n95:   }\n96: \n97:   try {\n98:     const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n99:     canonicalPathColumnAvailable = columns.some((column) => column.name === 'canonical_file_path');\n100:   } catch {\n101:     canonicalPathColumnAvailable = false;\n102:   }\n103: \n104:   return canonicalPathColumnAvailable;\n105: }\n106: \n107: function hasDocumentTypeColumn(): boolean {\n108:   if (!db) return false;\n109: \n110:   if (documentTypeColumnAvailable !== null) {\n111:     return documentTypeColumnAvailable;\n112:   }\n113: \n114:   try {\n115:     const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n116:     documentTypeColumnAvailable = columns.some((column) => column.name === 'document_type');\n117:   } catch {\n118:     documentTypeColumnAvailable = false;\n119:   }\n120: \n121:   return documentTypeColumnAvailable;\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    4. FILE METADATA\n126: ----------------------------------------------------------------*/\n127: \n128: function getFileMetadata(filePath: string): FileMetadata {\n129:   try {\n130:     const stats = fs.statSync(filePath);\n131:     return {\n132:       path: filePath,\n133:       mtime: stats.mtimeMs,\n134:       size: stats.size,\n135:       exists: true,\n136:     };\n137:   } catch {\n138:     return {\n139:       path: filePath,\n140:       mtime: 0,\n141:       size: 0,\n142:       exists: false,\n143:     };\n144:   }\n145: }\n146: \n147: function getStoredMetadata(filePath: string): StoredMetadata | null {\n148:   if (!db) return null;\n149: \n150:   try {\n151:     const canonicalPath = getCanonicalPathKey(filePath);\n152: \n153:     const row = hasCanonicalPathColumn()\n154:       ? (db.prepare(`\n155:           SELECT file_path, canonical_file_path, file_mtime_ms, content_hash, embedding_status\n156:           FROM memory_index\n157:           WHERE canonical_file_path = ? OR file_path = ?\n158:           ORDER BY CASE WHEN canonical_file_path = ? THEN 0 ELSE 1 END, id DESC\n159:           LIMIT 1\n160:         `) as Database.Statement).get(canonicalPath, filePath, canonicalPath) as StoredMetadata | undefined\n161:       : (db.prepare(`\n162:           SELECT file_path, file_mtime_ms, content_hash, embedding_status\n163:           FROM memory_index\n164:           WHERE file_path = ?\n165:         `) as Database.Statement).get(filePath) as StoredMetadata | undefined;\n166: \n167:     return row || null;\n168:   } catch (error: unknown) {\n169:     const msg = error instanceof Error ? error.message : String(error);\n170:     console.warn(`[incremental-index] getStoredMetadata error: ${msg}`);\n171:     return null;\n172:   }\n173: }\n174: \n175: function computeFileContentHash(filePath: string): string | null {\n176:   try {\n177:     const content = fs.readFileSync(filePath);\n178:     return createHash('sha256').update(content).digest('hex');\n179:   } catch {\n180:     return null;\n181:   }\n182: }\n183: \n184: /* ───────────────────────────────────────────────────────────────\n185:    5. DECISION LOGIC\n186: ----------------------------------------------------------------*/\n187: \n188: /**\n189:  * 6-path decision logic for whether a file needs re-indexing.\n190:  */\n191: function shouldReindex(filePath: string): IndexDecision {\n192:   const fileInfo = getFileMetadata(filePath);\n193: \n194:   // Path 1: File doesn't exist on disk\n195:   if (!fileInfo.exists) {\n196:     const stored = getStoredMetadata(filePath);\n197:     if (stored) return 'deleted';\n198:     return 'skip';\n199:   }\n200: \n201:   // Path 2: No stored metadata (new file)\n202:   const stored = getStoredMetadata(filePath);\n203:   if (!stored) return 'new';\n204: \n205:   // Path 3: No stored mtime (legacy entry, needs re-indexing)\n206:   if (stored.file_mtime_ms === null) return 'reindex';\n207: \n208:   // Path 4: Mtime unchanged (fast path - skip)\n209:   if (Math.abs(fileInfo.mtime - stored.file_mtime_ms) < MTIME_FAST_PATH_MS) {\n210:     // Still check if embedding status is pending\n211:     if (stored.embedding_status === 'pending' || stored.embedding_status === 'failed') {\n212:       return 'reindex';\n213:     }\n214: \n215:     if (stored.content_hash) {\n216:       const currentContentHash = computeFileContentHash(filePath);\n217:       if (currentContentHash && currentContentHash !== stored.content_hash) {\n218:         return 'modified';\n219:       }\n220:     }\n221: \n222:     return 'skip';\n223:   }\n224: \n225:   // Path 5: Mtime changed (file modified)\n226:   return 'modified';\n227: }\n228: \n229: /* ───────────────────────────────────────────────────────────────\n230:    6. MTIME MANAGEMENT\n231: ----------------------------------------------------------------*/\n232: \n233: function updateFileMtime(filePath: string, mtimeMs: number): boolean {\n234:   if (!db) return false;\n235: \n236:   try {\n237:     const canonicalPath = getCanonicalPathKey(filePath);\n238: \n239:     const result = hasCanonicalPathColumn()\n240:       ? (db.prepare(`\n241:           UPDATE memory_index\n242:           SET file_mtime_ms = ?\n243:           WHERE canonical_file_path = ? OR file_path = ?\n244:         `) as Database.Statement).run(mtimeMs, canonicalPath, filePath)\n245:       : (db.prepare(`\n246:           UPDATE memory_index\n247:           SET file_mtime_ms = ?\n248:           WHERE file_path = ?\n249:         `) as Database.Statement).run(mtimeMs, filePath);\n250: \n251:     return (result as { changes: number }).changes > 0;\n252:   } catch (error: unknown) {\n253:     const msg = error instanceof Error ? error.message : String(error);\n254:     console.warn(`[incremental-index] updateFileMtime error: ${msg}`);\n255:     return false;\n256:   }\n257: }\n258: \n259: function setIndexedMtime(filePath: string): boolean {\n260:   const fileInfo = getFileMetadata(filePath);\n261:   if (!fileInfo.exists) return false;\n262:   return updateFileMtime(filePath, fileInfo.mtime);\n263: }\n264: \n265: /* ───────────────────────────────────────────────────────────────\n266:    7. BATCH OPERATIONS\n267: ----------------------------------------------------------------*/\n268: \n269: function categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n270:   const result: CategorizedFiles = {\n271:     toIndex: [],\n272:     toUpdate: [],\n273:     toSkip: [],\n274:     toDelete: [],\n275:   };\n276: \n277:   for (const filePath of filePaths) {\n278:     const decision = shouldReindex(filePath);\n279: \n280:     switch (decision) {\n281:       case 'new':\n282:         result.toIndex.push(filePath);\n283:         break;\n284:       case 'modified':\n285:       case 'reindex':\n286:         result.toUpdate.push(filePath);\n287:         break;\n288:       case 'deleted':\n289:         result.toDelete.push(filePath);\n290:         break;\n291:       case 'skip':\n292:       default:\n293:         result.toSkip.push(filePath);\n294:         break;\n295:     }\n296:   }\n297: \n298:   // Include stale indexed paths that are no longer discovered on disk.\n299:   // Without this pass, removed files never enter toDelete during normal scans\n300:   // Because discovery only returns files that currently exist.\n301:   const staleIndexedPaths = listStaleIndexedPaths(filePaths);\n302:   if (staleIndexedPaths.length > 0) {\n303:     const seenDeleteKeys = new Set<string>(result.toDelete.map((filePath) => getCanonicalPathKey(filePath)));\n304:     for (const stalePath of staleIndexedPaths) {\n305:       const staleKey = getCanonicalPathKey(stalePath);\n306:       if (!seenDeleteKeys.has(staleKey)) {\n307:         result.toDelete.push(stalePath);\n308:         seenDeleteKeys.add(staleKey);\n309:       }\n310:     }\n311:   }\n312: \n313:   return result;\n314: }\n315: \n316: function listStaleIndexedPaths(scannedFilePaths: string[]): string[] {\n317:   if (!db) return [];\n318: \n319:   const scannedCanonicalPaths = new Set(scannedFilePaths.map((filePath) => getCanonicalPathKey(filePath)));\n320:   const stalePaths = new Set<string>();\n321: \n322:   try {\n323:     const rows = hasCanonicalPathColumn()\n324:       ? (db.prepare(`\n325:           SELECT DISTINCT file_path, canonical_file_path\n326:           FROM memory_index\n327:           WHERE file_path IS NOT NULL AND file_path != ''\n328:         `) as Database.Statement).all() as IndexedPathRow[]\n329:       : (db.prepare(`\n330:           SELECT DISTINCT file_path\n331:           FROM memory_index\n332:           WHERE file_path IS NOT NULL AND file_path != ''\n333:         `) as Database.Statement).all() as IndexedPathRow[];\n334: \n335:     for (const row of rows) {\n336:       if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n337:         continue;\n338:       }\n339: \n340:       const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n341:         ? row.canonical_file_path\n342:         : getCanonicalPathKey(row.file_path);\n343: \n344:       if (scannedCanonicalPaths.has(rowCanonicalPath)) {\n345:         continue;\n346:       }\n347: \n348:       const filePathExists = getFileMetadata(row.file_path).exists;\n349:       const canonicalPathExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n350:         ? getFileMetadata(row.canonical_file_path).exists\n351:         : false;\n352: \n353:       if (!filePathExists && !canonicalPathExists) {\n354:         stalePaths.add(row.file_path);\n355:       }\n356:     }\n357:   } catch (error: unknown) {\n358:     const msg = error instanceof Error ? error.message : String(error);\n359:     console.warn(`[incremental-index] listStaleIndexedPaths error: ${msg}`);\n360:   }\n361: \n362:   return Array.from(stalePaths);\n363: }\n364: \n365: function listIndexedRecordIdsForDeletedPaths(filePaths: string[]): number[] {\n366:   if (!db || filePaths.length === 0) return [];\n367: \n368:   const ids = new Set<number>();\n369:   const seenLookupKeys = new Set<string>();\n370: \n371:   try {\n372:     for (const filePath of filePaths) {\n373:       if (typeof filePath !== 'string' || filePath.length === 0) {\n374:         continue;\n375:       }\n376: \n377:       const canonicalPath = getCanonicalPathKey(filePath);\n378:       const lookupKey = `${canonicalPath}::${filePath}`;\n379:       if (seenLookupKeys.has(lookupKey)) {\n380:         continue;\n381:       }\n382:       seenLookupKeys.add(lookupKey);\n383: \n384:       const rows = hasCanonicalPathColumn()\n385:         ? (db.prepare(`\n386:             SELECT id, file_path, canonical_file_path\n387:             FROM memory_index\n388:             WHERE canonical_file_path = ? OR file_path = ?\n389:           `) as Database.Statement).all(canonicalPath, filePath) as IndexedRecordRow[]\n390:         : (db.prepare(`\n391:             SELECT id, file_path\n392:             FROM memory_index\n393:             WHERE file_path = ?\n394:           `) as Database.Statement).all(filePath) as IndexedRecordRow[];\n395: \n396:       for (const row of rows) {\n397:         if (!row || typeof row.id !== 'number') {\n398:           continue;\n399:         }\n400: \n401:         const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n402:           ? getFileMetadata(row.file_path).exists\n403:           : false;\n404:         const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n405:           ? getFileMetadata(row.canonical_file_path).exists\n406:           : false;\n407: \n408:         if (rowFileExists || rowCanonicalExists) {\n409:           continue;\n410:         }\n411: \n412:         ids.add(row.id);\n413:       }\n414:     }\n415:   } catch (error: unknown) {\n416:     const msg = error instanceof Error ? error.message : String(error);\n417:     console.warn(`[incremental-index] listIndexedRecordIdsForDeletedPaths error: ${msg}`);\n418:     return [];\n419:   }\n420: \n421:   return Array.from(ids).sort((a, b) => a - b);\n422: }\n423: \n424: function normalizeOrphanSweepLimit(limit?: number): number {\n425:   if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n426:     return DEFAULT_ORPHAN_SWEEP_LIMIT;\n427:   }\n428: \n429:   return Math.max(1, Math.floor(limit));\n430: }\n431: \n432: function indexedRecordIsAbsent(row: IndexedRecordRow): boolean {\n433:   const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n434:     ? getFileMetadata(row.file_path).exists\n435:     : false;\n436:   const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n437:     ? getFileMetadata(row.canonical_file_path).exists\n438:     : false;\n439: \n440:   return !rowFileExists && !rowCanonicalExists;\n441: }\n442: \n443: function sweepOrphanIndexRows(options: OrphanSweepOptions = {}): OrphanSweepResult {\n444:   if (!db) {\n445:     return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n446:   }\n447: \n448:   const limit = normalizeOrphanSweepLimit(options.limit);\n449:   const cursor = typeof options.cursor === 'number' && Number.isFinite(options.cursor) && options.cursor > 0\n450:     ? Math.floor(options.cursor)\n451:     : 0;\n452: \n453:   try {\n454:     const rows = hasCanonicalPathColumn()\n455:       ? (db.prepare(`\n456:           SELECT id, file_path, canonical_file_path\n457:           FROM memory_index\n458:           WHERE id > ?\n459:             AND file_path IS NOT NULL\n460:             AND file_path != ''\n461:           ORDER BY id ASC\n462:           LIMIT ?\n463:         `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[]\n464:       : (db.prepare(`\n465:           SELECT id, file_path\n466:           FROM memory_index\n467:           WHERE id > ?\n468:             AND file_path IS NOT NULL\n469:             AND file_path != ''\n470:           ORDER BY id ASC\n471:           LIMIT ?\n472:         `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[];\n473: \n474:     const orphanRecordIds: number[] = [];\n475:     for (const row of rows) {\n476:       if (!row || typeof row.id !== 'number') {\n477:         continue;\n478:       }\n479:       if (indexedRecordIsAbsent(row)) {\n480:         orphanRecordIds.push(row.id);\n481:       }\n482:     }\n483: \n484:     return {\n485:       swept: orphanRecordIds.length,\n486:       nextCursor: rows.length === limit ? rows[rows.length - 1]?.id ?? null : null,\n487:       scannedRows: rows.length,\n488:       orphanRecordIds,\n489:     };\n490:   } catch (error: unknown) {\n491:     const msg = error instanceof Error ? error.message : String(error);\n492:     console.warn(`[incremental-index] sweepOrphanIndexRows error: ${msg}`);\n493:     return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n494:   }\n495: }\n496: \n497: /* ───────────────────────────────────────────────────────────────\n498:    7b. MOVE RECONCILIATION\n499: ----------------------------------------------------------------*/\n500: \n501: interface MoveReconcileCandidate {\n502:   oldPath: string;\n503:   newPath: string;\n504:   rowId: number;\n505:   docType: string;\n506: }\n507: \n508: interface ReconcileMovesResult {\n509:   reconciled: MoveReconcileCandidate[];\n510:   filteredToDelete: string[];\n511:   filteredToIndex: string[];\n512: }\n513: \n514: interface IncrementalChunkFingerprint {\n515:   chunkId: string;\n516:   chunkFingerprint: string;\n517: }\n518: \n519: interface MemoizedPlanningInput {\n520:   componentPath: string;\n521:   canonicalInput: unknown;\n522:   codeHash: string;\n523:   chunks?: IncrementalChunkFingerprint[];\n524: }\n525: \n526: interface MemoizedPlanningOptions {\n527:   invalidateDependents?: boolean;\n528: }\n529: \n530: interface MemoizedPlanningResult {\n531:   memoHits: number;\n532:   memoMisses: number;\n533:   chunkHits: number;\n534:   chunkMisses: number;\n535:   dependencyInvalidated: number;\n536:   changedComponentPaths: string[];\n537:   unchangedComponentPaths: string[];\n538:   invalidatedComponentPaths: string[];\n539: }\n540: \n541: function reconcileMoves(\n542:   toDelete: string[],\n543:   toIndex: string[],\n544: ): ReconcileMovesResult {\n545:   if (!db || toDelete.length === 0 || toIndex.length === 0) {\n546:     return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n547:   }\n548: \n549:   // Build a map: packet_id → [{newPath, docType, newGrandparent}] from the toIndex files.\n550:   // Reads graph-metadata.json from the NEW location only — the old one may be gone after a move.\n551:   const newByPacketId = new Map<string, Array<{ newPath: string; docType: string; newGrandparent: string }>>();\n552:   for (const newPath of toIndex) {\n553:     try {\n554:       const newSpecFolder = path.dirname(newPath);\n555:       const graphMetaPath = path.join(newSpecFolder, 'graph-metadata.json');\n556:       if (!fs.existsSync(graphMetaPath)) continue;\n557:       const raw = fs.readFileSync(graphMetaPath, 'utf-8');\n558:       const meta = JSON.parse(raw) as { packet_id?: string };\n559:       const packetId = meta?.packet_id;\n560:       if (typeof packetId !== 'string' || packetId.length === 0) continue;\n561:       const docType = path.basename(newPath, path.extname(newPath));\n562:       const newGrandparent = path.dirname(newSpecFolder);\n563:       if (!newByPacketId.has(packetId)) newByPacketId.set(packetId, []);\n564:       newByPacketId.get(packetId)!.push({ newPath, docType, newGrandparent });\n565:     } catch {\n566:       // skip unreadable or non-JSON graph-metadata\n567:     }\n568:   }\n569: \n570:   if (newByPacketId.size === 0) {\n571:     return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n572:   }\n573: \n574:   const reconciledOldPaths = new Set<string>();\n575:   const reconciledNewPaths = new Set<string>();\n576:   const reconciled: MoveReconcileCandidate[] = [];\n577: \n578:   // Iterate from the NEW side: for each new path whose folder still carries a packet_id,\n579:   // find the corresponding old path in toDelete by matching grandparent directory + basename\n580:   // (a sibling folder rename within the same parent). The packet_id only gates which new\n581:   // paths are eligible — the actual old→new pairing is grandparent + basename plus the\n582:   // DB uniqueness guards below; it does NOT match the old row by its packet_id (the old\n583:   // graph-metadata.json may be gone, and memory_index has no packet_id column). To avoid\n584:   // repointing across mismatched document kinds, the stored document_type is cross-checked\n585:   // against the doc type derived from the new path before the in-place update.\n586:   const docTypeAvailable = hasDocumentTypeColumn();\n587:   const selectSql = docTypeAvailable\n588:     ? `SELECT id, document_type FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`\n589:     : `SELECT id FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`;\n590:   for (const [, newCandidates] of newByPacketId) {\n591:     for (const { newPath, docType, newGrandparent } of newCandidates) {\n592:       if (reconciledNewPaths.has(newPath)) continue;\n593: \n594:       const newBasename = path.basename(newPath);\n595: \n596:       // Find toDelete paths that are sibling renames: same grandparent dir, same basename.\n597:       // A sibling rename means only the immediate spec folder name changed (e.g. 012-old → 012-new).\n598:       const siblingDeleted = toDelete.filter(oldPath =>\n599:         !reconciledOldPaths.has(oldPath) &&\n600:         path.basename(oldPath) === newBasename &&\n601:         path.dirname(path.dirname(oldPath)) === newGrandparent\n602:       );\n603: \n604:       if (siblingDeleted.length !== 1) continue; // uniqueness required\n605: \n606:       const oldPath = siblingDeleted[0];\n607:       const canonicalOld = getCanonicalPathKey(oldPath);\n608: \n609:       // Verify in DB: exactly one live row for this old path (uniqueness guard).\n610:       const rows = db!.prepare(selectSql).all(oldPath, canonicalOld) as Array<{ id: number; document_type?: string | null }>;\n611:       if (rows.length !== 1) continue;\n612: \n613:       // Cross-verify document kind: the stored document_type must agree with the doc type\n614:       // derived from the new path. Skip rows whose stored type diverged from the new file\n615:       // (e.g. a generic 'memory' row that happens to share a basename), preventing a\n616:       // mismatched repoint. Tolerant when the column is absent (legacy/test schemas).\n617:       if (docTypeAvailable) {\n618:         const storedDocType = rows[0].document_type ?? null;\n619:         if (storedDocType !== null && storedDocType !== extractDocumentType(newPath)) continue;\n620:       }\n621: \n622:       const rowId = rows[0].id;\n623:       const newCanonical = getCanonicalPathKey(newPath);\n624:       const newSpecFolder = extractSpecFolder(newPath);\n625:       const newMtime = (() => {\n626:         try { return fs.statSync(newPath).mtimeMs; } catch { return null; }\n627:       })();\n628: \n629:       // Update the row's path in place (preserves embedding, id, history). A reconciled\n630:       // move is a folder rename, so spec_folder is repointed with the same canonicalization\n631:       // indexMemoryFile/migration 23 use — otherwise WHERE spec_folder=? grouping goes stale.\n632:       const updated = db!.prepare(`\n633:         UPDATE memory_index\n634:         SET file_path = ?,\n635:             canonical_file_path = ?,\n636:             spec_folder = ?,\n637:             file_mtime_ms = ?,\n638:             updated_at = datetime('now')\n639:         WHERE id = ?\n640:           AND embedding_status != 'failed'\n641:       `).run(newPath, newCanonical, newSpecFolder, newMtime, rowId);\n642: \n643:       if ((updated as { changes: number }).changes !== 1) continue;\n644: \n645:       reconciledOldPaths.add(oldPath);\n646:       reconciledNewPaths.add(newPath);\n647:       reconciled.push({ oldPath, newPath, rowId, docType });\n648:       console.error(`[incremental-index] Move reconciled: ${newBasename} ${oldPath} → ${newPath} (row ${rowId}, embedding preserved)`);\n649:     }\n650:   }\n651: \n652:   return {\n653:     reconciled,\n654:     filteredToDelete: toDelete.filter(p => !reconciledOldPaths.has(p)),\n655:     filteredToIndex: toIndex.filter(p => !reconciledNewPaths.has(p)),\n656:   };\n657: }\n658: \n659: function batchUpdateMtimes(filePaths: string[]): { updated: number; failed: number } {\n660:   if (!db) return { updated: 0, failed: filePaths.length };\n661: \n662:   let updated = 0;\n663:   let failed = 0;\n664: \n665:   const updateTx = db.transaction(() => {\n666:     for (const filePath of filePaths) {\n667:       if (setIndexedMtime(filePath)) {\n668:         updated++;\n669:       } else {\n670:         failed++;\n671:       }\n672:     }\n673:   });\n674: \n675:   try {\n676:     updateTx();\n677:   } catch (error: unknown) {\n678:     const msg = error instanceof Error ? error.message : String(error);\n679:     console.warn(`[incremental-index] batchUpdateMtimes error: ${msg}`);\n680:   }\n681: \n682:   return { updated, failed };\n683: }\n684: \n685: function countChunkFingerprintHits(database: Database.Database, input: MemoizedPlanningInput): { hits: number; misses: number } {\n686:   if (!input.chunks || input.chunks.length === 0) {\n687:     return { hits: 0, misses: 0 };\n688:   }\n689: \n690:   try {\n691:     const stmt = database.prepare(`\n692:       SELECT 1 AS hit\n693:       FROM memory_index\n694:       WHERE (canonical_file_path = ? OR file_path = ?)\n695:         AND chunk_id = ?\n696:         AND chunk_fingerprint = ?\n697:       LIMIT 1\n698:     `);\n699:     const canonicalPath = getCanonicalPathKey(input.componentPath);\n700:     let hits = 0;\n701:     let misses = 0;\n702:     for (const chunk of input.chunks) {\n703:       const row = stmt.get(canonicalPath, input.componentPath, chunk.chunkId, chunk.chunkFingerprint) as { hit?: number } | undefined;\n704:       if (row?.hit === 1) {\n705:         hits++;\n706:       } else {\n707:         misses++;\n708:       }\n709:     }\n710:     return { hits, misses };\n711:   } catch (error: unknown) {\n712:     const msg = error instanceof Error ? error.message : String(error);\n713:     console.warn(`[incremental-index] countChunkFingerprintHits error: ${msg}`);\n714:     return { hits: 0, misses: input.chunks.length };\n715:   }\n716: }\n717: \n718: function planMemoizedIndexing(\n719:   inputs: readonly MemoizedPlanningInput[],\n720:   options: MemoizedPlanningOptions = {},\n721:   database: Database.Database | null = db,\n722: ): MemoizedPlanningResult {\n723:   const result: MemoizedPlanningResult = {\n724:     memoHits: 0,\n725:     memoMisses: 0,\n726:     chunkHits: 0,\n727:     chunkMisses: 0,\n728:     dependencyInvalidated: 0,\n729:     changedComponentPaths: [],\n730:     unchangedComponentPaths: [],\n731:     invalidatedComponentPaths: [],\n732:   };\n733: \n734:   if (!database) {\n735:     result.changedComponentPaths = inputs.map((input) => input.componentPath);\n736:     result.memoMisses = inputs.length;\n737:     result.chunkMisses = inputs.reduce((count, input) => count + (input.chunks?.length ?? 0), 0);\n738:     return result;\n739:   }\n740: \n741:   const memoStore = createMemoStore(database);\n742:   const changedPaths: string[] = [];\n743:   for (const input of inputs) {\n744:     // An unfingerprintable input (e.g. a non-finite number) must not abort the\n745:     // whole batch plan — treat it as a memo miss for this one input so the\n746:     // remaining inputs are still planned.\n747:     let inputFingerprint: string | null = null;\n748:     try {\n749:       inputFingerprint = canonicalFingerprint(input.canonicalInput);\n750:     } catch (_error: unknown) {\n751:       inputFingerprint = null;\n752:     }\n753:     const memo = inputFingerprint === null\n754:       ? undefined\n755:       : memoStore.getMemoRecord(input.componentPath, inputFingerprint, input.codeHash);\n756:     if (memo) {\n757:       result.memoHits++;\n758:       result.unchangedComponentPaths.push(input.componentPath);\n759:     } else {\n760:       result.memoMisses++;\n761:       result.changedComponentPaths.push(input.componentPath);\n762:       changedPaths.push(input.componentPath);\n763:     }\n764: \n765:     const chunkCounts = countChunkFingerprintHits(database, input);\n766:     result.chunkHits += chunkCounts.hits;\n767:     result.chunkMisses += chunkCounts.misses;\n768:   }\n769: \n770:   if (options.invalidateDependents !== false && changedPaths.length > 0) {\n771:     const invalidation = memoStore.invalidateDependents(changedPaths);\n772:     result.invalidatedComponentPaths = invalidation.invalidatedPaths;\n773:     result.dependencyInvalidated = invalidation.invalidatedPaths.length;\n774:   }\n775: \n776:   return result;\n777: }\n778: \n779: /* ───────────────────────────────────────────────────────────────\n780:    8. EXPORTS\n781: ----------------------------------------------------------------*/\n782: \n783: export {\n784:   MTIME_FAST_PATH_MS,\n785: \n786:   init,\n787:   getFileMetadata,\n788:   getStoredMetadata,\n789:   shouldReindex,\n790:   updateFileMtime,\n791:   setIndexedMtime,\n792:   categorizeFilesForIndexing,\n793:   listStaleIndexedPaths,\n794:   listIndexedRecordIdsForDeletedPaths,\n795:   sweepOrphanIndexRows,\n796:   reconcileMoves,\n797:   batchUpdateMtimes,\n798:   planMemoizedIndexing,\n799: };\n800: \n801: /**\n802:  * Re-exports related public types.\n803:  */\n804: export type {\n805:   FileMetadata,\n806:   StoredMetadata,\n807:   IndexDecision,\n808:   CategorizedFiles,\n809:   OrphanSweepOptions,\n810:   OrphanSweepResult,\n811:   MoveReconcileCandidate,\n812:   ReconcileMovesResult,\n813:   IncrementalChunkFingerprint,\n814:   MemoizedPlanningInput,\n815:   MemoizedPlanningOptions,\n816:   MemoizedPlanningResult,\n817: };\n\n(End of file - total 817 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Incremental Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Deferred lexical-only indexing\n// Mtime-based incremental indexing for fast re-indexing\n// Node stdlib\nimport { createHash } from 'node:crypto';\nimport * as fs from 'fs';\nimport * as path from 'path';\n\n// External packages\nimport type Database from 'better-sqlite3';\n\n// Internal modules\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\nimport { canonicalFingerprint } from './canonical-fingerprint.js';\nimport { createMemoStore } from './memo.js';\n\n/* ───────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Incremental Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Deferred lexical-only indexing\n// Mtime-based incremental indexing for fast re-indexing\n// Node stdlib\nimport { createHash } from 'node:crypto';\nimport * as fs from 'fs';\nimport * as path from 'path';\n\n// External packages\nimport type Database from 'better-sqlite3';\n\n// Internal modules\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\nimport { canonicalFingerprint } from './canonical-fingerprint.js';\nimport { createMemoStore } from './memo.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst MTIME_FAST_PATH_MS = 1000; // Skip if mtime within 1 second\nconst DEFAULT_ORPHAN_SWEEP_LIMIT = 200;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface FileMetadata {\n  path: string;\n  mtime: number;\n  size: number;\n  exists: boolean;\n}\n\ninterface StoredMetadata {\n  file_path: string;\n  canonical_file_path?: string | null;\n  file_mtime_ms: number | null;\n  content_hash: string | null;\n  embedding_status: string;\n}\n\ntype IndexDecision = 'skip' | 'reindex' | 'new' | 'deleted' | 'modified' | 'unknown';\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface IndexedPathRow {\n  file_path: string;\n  canonical_file_path?: string | null;\n}\n\ninterface IndexedRecordRow extends IndexedPathRow {\n  id: number;\n}\n\ninterface OrphanSweepOptions {\n  limit?: number;\n  cursor?: number;\n}\n\ninterface OrphanSweepResult {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds: number[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet canonicalPathColumnAvailable: boolean | null = null;\nlet documentTypeColumnAvailable: boolean | null = null;\n\nfunction init(database: Database.Database): void {\n  db = database;\n  canonicalPathColumnAvailable = null;\n  documentTypeColumnAvailable = null;\n}\n\nfunction hasCanonicalPathColumn(): boolean {\n  if (!db) return false;\n\n  if (canonicalPathColumnAvailable !== null) {\n    return canonicalPathColumnAvailable;\n  }\n\n  try {\n    const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n    canonicalPathColumnAvailable = columns.some((column) => column.name === 'canonical_file_path');\n  } catch {\n    canonicalPathColumnAvailable = false;\n  }\n\n  return canonicalPathColumnAvailable;\n}\n\nfunction hasDocumentTypeColumn(): boolean {\n  if (!db) return false;\n\n  if (documentTypeColumnAvailable !== null) {\n    return documentTypeColumnAvailable;\n  }\n\n  try {\n    const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n    documentTypeColumnAvailable = columns.some((column) => column.name === 'document_type');\n  } catch {\n    documentTypeColumnAvailable = false;\n  }\n\n  return documentTypeColumnAvailable;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. FILE METADATA\n----------------------------------------------------------------*/\n\nfunction getFileMetadata(filePath: string): FileMetadata {\n  try {\n    const stats = fs.statSync(filePath);\n    return {\n      path: filePath,\n      mtime: stats.mtimeMs,\n      size: stats.size,\n      exists: true,\n    };\n  } catch {\n    return {\n      path: filePath,\n      mtime: 0,\n      size: 0,\n      exists: false,\n    };\n  }\n}\n\nfunction getStoredMetadata(filePath: string): StoredMetadata | null {\n  if (!db) return null;\n\n  try {\n    const canonicalPath = getCanonicalPathKey(filePath);\n\n    const row = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT file_path, canonical_file_path, file_mtime_ms, content_hash, embedding_status\n          FROM memory_index\n          WHERE canonical_file_path = ? OR file_path = ?\n          ORDER BY CASE WHEN canonical_file_path = ? THEN 0 ELSE 1 END, id DESC\n          LIMIT 1\n        `) as Database.Statement).get(canonicalPath, filePath, canonicalPath) as StoredMetadata | undefined\n      : (db.prepare(`\n          SELECT file_path, file_mtime_ms, content_hash, embedding_status\n          FROM memory_index\n          WHERE file_path = ?\n        `) as Database.Statement).get(filePath) as StoredMetadata | undefined;\n\n    return row || null;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] getStoredMetadata error: ${msg}`);\n    return null;\n  }\n}\n\nfunction computeFileContentHash(filePath: string): string | null {\n  try {\n    const content = fs.readFileSync(filePath);\n    return createHash('sha256').update(content).digest('hex');\n  } catch {\n    return null;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. DECISION LOGIC\n----------------------------------------------------------------*/\n\n/**\n * 6-path decision logic for whether a file needs re-indexing.\n */\nfunction shouldReindex(filePath: string): IndexDecision {\n  const fileInfo = getFileMetadata(filePath);\n\n  // Path 1: File doesn't exist on disk\n  if (!fileInfo.exists) {\n    const stored = getStoredMetadata(filePath);\n    if (stored) return 'deleted';\n    return 'skip';\n  }\n\n  // Path 2: No stored metadata (new file)\n  const stored = getStoredMetadata(filePath);\n  if (!stored) return 'new';\n\n  // Path 3: No stored mtime (legacy entry, needs re-indexing)\n  if (stored.file_mtime_ms === null) return 'reindex';\n\n  // Path 4: Mtime unchanged (fast path - skip)\n  if (Math.abs(fileInfo.mtime - stored.file_mtime_ms) < MTIME_FAST_PATH_MS) {\n    // Still check if embedding status is pending\n    if (stored.embedding_status === 'pending' || stored.embedding_status === 'failed') {\n      return 'reindex';\n    }\n\n    if (stored.content_hash) {\n      const currentContentHash = computeFileContentHash(filePath);\n      if (currentContentHash && currentContentHash !== stored.content_hash) {\n        return 'modified';\n      }\n    }\n\n    return 'skip';\n  }\n\n  // Path 5: Mtime changed (file modified)\n  return 'modified';\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. MTIME MANAGEMENT\n----------------------------------------------------------------*/\n\nfunction updateFileMtime(filePath: string, mtimeMs: number): boolean {\n  if (!db) return false;\n\n  try {\n    const canonicalPath = getCanonicalPathKey(filePath);\n\n    const result = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          UPDATE memory_index\n          SET file_mtime_ms = ?\n          WHERE canonical_file_path = ? OR file_path = ?\n        `) as Database.Statement).run(mtimeMs, canonicalPath, filePath)\n      : (db.prepare(`\n          UPDATE memory_index\n          SET file_mtime_ms = ?\n          WHERE file_path = ?\n        `) as Database.Statement).run(mtimeMs, filePath);\n\n    return (result as { changes: number }).changes > 0;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] updateFileMtime error: ${msg}`);\n    return false;\n  }\n}\n\nfunction setIndexedMtime(filePath: string): boolean {\n  const fileInfo = getFileMetadata(filePath);\n  if (!fileInfo.exists) return false;\n  return updateFileMtime(filePath, fileInfo.mtime);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. BATCH OPERATIONS\n----------------------------------------------------------------*/\n\nfunction categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n  const result: CategorizedFiles = {\n    toIndex: [],\n    toUpdate: [],\n    toSkip: [],\n    toDelete: [],\n  };\n\n  for (const filePath of filePaths) {\n    const decision = shouldReindex(filePath);\n\n    switch (decision) {\n      case 'new':\n        result.toIndex.push(filePath);\n        break;\n      case 'modified':\n      case 'reindex':\n        result.toUpdate.push(filePath);\n        break;\n      case 'deleted':\n        result.toDelete.push(filePath);\n        break;\n      case 'skip':\n      default:\n        result.toSkip.push(filePath);\n        break;\n    }\n  }\n\n  // Include stale indexed paths that are no longer discovered on disk.\n  // Without this pass, removed files never enter toDelete during normal scans\n  // Because discovery only returns files that currently exist.\n  const staleIndexedPaths = listStaleIndexedPaths(filePaths);\n  if (staleIndexedPaths.length > 0) {\n    const seenDeleteKeys = new Set<string>(result.toDelete.map((filePath) => getCanonicalPathKey(filePath)));\n    for (const stalePath of staleIndexedPaths) {\n      const staleKey = getCanonicalPathKey(stalePath);\n      if (!seenDeleteKeys.has(staleKey)) {\n        result.toDelete.push(stalePath);\n        seenDeleteKeys.add(staleKey);\n      }\n    }\n  }\n\n  return result;\n}\n\nfunction listStaleIndexedPaths(scannedFilePaths: string[]): string[] {\n  if (!db) return [];\n\n  const scannedCanonicalPaths = new Set(scannedFilePaths.map((filePath) => getCanonicalPathKey(filePath)));\n  const stalePaths = new Set<string>();\n\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT DISTINCT file_path, canonical_file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[]\n      : (db.prepare(`\n          SELECT DISTINCT file_path\n          FROM memory_index\n          WHERE file_path IS NOT NULL AND file_path != ''\n        `) as Database.Statement).all() as IndexedPathRow[];\n\n    for (const row of rows) {\n      if (!row || typeof row.file_path !== 'string' || row.file_path.length === 0) {\n        continue;\n      }\n\n      const rowCanonicalPath = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n        ? row.canonical_file_path\n        : getCanonicalPathKey(row.file_path);\n\n      if (scannedCanonicalPaths.has(rowCanonicalPath)) {\n        continue;\n      }\n\n      const filePathExists = getFileMetadata(row.file_path).exists;\n      const canonicalPathExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n        ? getFileMetadata(row.canonical_file_path).exists\n        : false;\n\n      if (!filePathExists && !canonicalPathExists) {\n        stalePaths.add(row.file_path);\n      }\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] listStaleIndexedPaths error: ${msg}`);\n  }\n\n  return Array.from(stalePaths);\n}\n\nfunction listIndexedRecordIdsForDeletedPaths(filePaths: string[]): number[] {\n  if (!db || filePaths.length === 0) return [];\n\n  const ids = new Set<number>();\n  const seenLookupKeys = new Set<string>();\n\n  try {\n    for (const filePath of filePaths) {\n      if (typeof filePath !== 'string' || filePath.length === 0) {\n        continue;\n      }\n\n      const canonicalPath = getCanonicalPathKey(filePath);\n      const lookupKey = `${canonicalPath}::${filePath}`;\n      if (seenLookupKeys.has(lookupKey)) {\n        continue;\n      }\n      seenLookupKeys.add(lookupKey);\n\n      const rows = hasCanonicalPathColumn()\n        ? (db.prepare(`\n            SELECT id, file_path, canonical_file_path\n            FROM memory_index\n            WHERE canonical_file_path = ? OR file_path = ?\n          `) as Database.Statement).all(canonicalPath, filePath) as IndexedRecordRow[]\n        : (db.prepare(`\n            SELECT id, file_path\n            FROM memory_index\n            WHERE file_path = ?\n          `) as Database.Statement).all(filePath) as IndexedRecordRow[];\n\n      for (const row of rows) {\n        if (!row || typeof row.id !== 'number') {\n          continue;\n        }\n\n        const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n          ? getFileMetadata(row.file_path).exists\n          : false;\n        const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n          ? getFileMetadata(row.canonical_file_path).exists\n          : false;\n\n        if (rowFileExists || rowCanonicalExists) {\n          continue;\n        }\n\n        ids.add(row.id);\n      }\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] listIndexedRecordIdsForDeletedPaths error: ${msg}`);\n    return [];\n  }\n\n  return Array.from(ids).sort((a, b) => a - b);\n}\n\nfunction normalizeOrphanSweepLimit(limit?: number): number {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return DEFAULT_ORPHAN_SWEEP_LIMIT;\n  }\n\n  return Math.max(1, Math.floor(limit));\n}\n\nfunction indexedRecordIsAbsent(row: IndexedRecordRow): boolean {\n  const rowFileExists = typeof row.file_path === 'string' && row.file_path.length > 0\n    ? getFileMetadata(row.file_path).exists\n    : false;\n  const rowCanonicalExists = typeof row.canonical_file_path === 'string' && row.canonical_file_path.length > 0\n    ? getFileMetadata(row.canonical_file_path).exists\n    : false;\n\n  return !rowFileExists && !rowCanonicalExists;\n}\n\nfunction sweepOrphanIndexRows(options: OrphanSweepOptions = {}): OrphanSweepResult {\n  if (!db) {\n    return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n  }\n\n  const limit = normalizeOrphanSweepLimit(options.limit);\n  const cursor = typeof options.cursor === 'number' && Number.isFinite(options.cursor) && options.cursor > 0\n    ? Math.floor(options.cursor)\n    : 0;\n\n  try {\n    const rows = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT id, file_path, canonical_file_path\n          FROM memory_index\n          WHERE id > ?\n            AND file_path IS NOT NULL\n            AND file_path != ''\n          ORDER BY id ASC\n          LIMIT ?\n        `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[]\n      : (db.prepare(`\n          SELECT id, file_path\n          FROM memory_index\n          WHERE id > ?\n            AND file_path IS NOT NULL\n            AND file_path != ''\n          ORDER BY id ASC\n          LIMIT ?\n        `) as Database.Statement).all(cursor, limit) as IndexedRecordRow[];\n\n    const orphanRecordIds: number[] = [];\n    for (const row of rows) {\n      if (!row || typeof row.id !== 'number') {\n        continue;\n      }\n      if (indexedRecordIsAbsent(row)) {\n        orphanRecordIds.push(row.id);\n      }\n    }\n\n    return {\n      swept: orphanRecordIds.length,\n      nextCursor: rows.length === limit ? rows[rows.length - 1]?.id ?? null : null,\n      scannedRows: rows.length,\n      orphanRecordIds,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] sweepOrphanIndexRows error: ${msg}`);\n    return { swept: 0, nextCursor: null, scannedRows: 0, orphanRecordIds: [] };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7b. MOVE RECONCILIATION\n----------------------------------------------------------------*/\n\ninterface MoveReconcileCandidate {\n  oldPath: string;\n  newPath: string;\n  rowId: number;\n  docType: string;\n}\n\ninterface ReconcileMovesResult {\n  reconciled: MoveReconcileCandidate[];\n  filteredToDelete: string[];\n  filteredToIndex: string[];\n}\n\ninterface IncrementalChunkFingerprint {\n  chunkId: string;\n  chunkFingerprint: string;\n}\n\ninterface MemoizedPlanningInput {\n  componentPath: string;\n  canonicalInput: unknown;\n  codeHash: string;\n  chunks?: IncrementalChunkFingerprint[];\n}\n\ninterface MemoizedPlanningOptions {\n  invalidateDependents?: boolean;\n}\n\ninterface MemoizedPlanningResult {\n  memoHits: number;\n  memoMisses: number;\n  chunkHits: number;\n  chunkMisses: number;\n  dependencyInvalidated: number;\n  changedComponentPaths: string[];\n  unchangedComponentPaths: string[];\n  invalidatedComponentPaths: string[];\n}\n\nfunction reconcileMoves(\n  toDelete: string[],\n  toIndex: string[],\n): ReconcileMovesResult {\n  if (!db || toDelete.length === 0 || toIndex.length === 0) {\n    return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n  }\n\n  // Build a map: packet_id → [{newPath, docType, newGrandparent}] from the toIndex files.\n  // Reads graph-metadata.json from the NEW location only — the old one may be gone after a move.\n  const newByPacketId = new Map<string, Array<{ newPath: string; docType: string; newGrandparent: string }>>();\n  for (const newPath of toIndex) {\n    try {\n      const newSpecFolder = path.dirname(newPath);\n      const graphMetaPath = path.join(newSpecFolder, 'graph-metadata.json');\n      if (!fs.existsSync(graphMetaPath)) continue;\n      const raw = fs.readFileSync(graphMetaPath, 'utf-8');\n      const meta = JSON.parse(raw) as { packet_id?: string };\n      const packetId = meta?.packet_id;\n      if (typeof packetId !== 'string' || packetId.length === 0) continue;\n      const docType = path.basename(newPath, path.extname(newPath));\n      const newGrandparent = path.dirname(newSpecFolder);\n      if (!newByPacketId.has(packetId)) newByPacketId.set(packetId, []);\n      newByPacketId.get(packetId)!.push({ newPath, docType, newGrandparent });\n    } catch {\n      // skip unreadable or non-JSON graph-metadata\n    }\n  }\n\n  if (newByPacketId.size === 0) {\n    return { reconciled: [], filteredToDelete: toDelete, filteredToIndex: toIndex };\n  }\n\n  const reconciledOldPaths = new Set<string>();\n  const reconciledNewPaths = new Set<string>();\n  const reconciled: MoveReconcileCandidate[] = [];\n\n  // Iterate from the NEW side: for each new path whose folder still carries a packet_id,\n  // find the corresponding old path in toDelete by matching grandparent directory + basename\n  // (a sibling folder rename within the same parent). The packet_id only gates which new\n  // paths are eligible — the actual old→new pairing is grandparent + basename plus the\n  // DB uniqueness guards below; it does NOT match the old row by its packet_id (the old\n  // graph-metadata.json may be gone, and memory_index has no packet_id column). To avoid\n  // repointing across mismatched document kinds, the stored document_type is cross-checked\n  // against the doc type derived from the new path before the in-place update.\n  const docTypeAvailable = hasDocumentTypeColumn();\n  const selectSql = docTypeAvailable\n    ? `SELECT id, document_type FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`\n    : `SELECT id FROM memory_index WHERE (file_path = ? OR canonical_file_path = ?) AND embedding_status != 'failed' LIMIT 2`;\n  for (const [, newCandidates] of newByPacketId) {\n    for (const { newPath, docType, newGrandparent } of newCandidates) {\n      if (reconciledNewPaths.has(newPath)) continue;\n\n      const newBasename = path.basename(newPath);\n\n      // Find toDelete paths that are sibling renames: same grandparent dir, same basename.\n      // A sibling rename means only the immediate spec folder name changed (e.g. 012-old → 012-new).\n      const siblingDeleted = toDelete.filter(oldPath =>\n        !reconciledOldPaths.has(oldPath) &&\n        path.basename(oldPath) === newBasename &&\n        path.dirname(path.dirname(oldPath)) === newGrandparent\n      );\n\n      if (siblingDeleted.length !== 1) continue; // uniqueness required\n\n      const oldPath = siblingDeleted[0];\n      const canonicalOld = getCanonicalPathKey(oldPath);\n\n      // Verify in DB: exactly one live row for this old path (uniqueness guard).\n      const rows = db!.prepare(selectSql).all(oldPath, canonicalOld) as Array<{ id: number; document_type?: string | null }>;\n      if (rows.length !== 1) continue;\n\n      // Cross-verify document kind: the stored document_type must agree with the doc type\n      // derived from the new path. Skip rows whose stored type diverged from the new file\n      // (e.g. a generic 'memory' row that happens to share a basename), preventing a\n      // mismatched repoint. Tolerant when the column is absent (legacy/test schemas).\n      if (docTypeAvailable) {\n        const storedDocType = rows[0].document_type ?? null;\n        if (storedDocType !== null && storedDocType !== extractDocumentType(newPath)) continue;\n      }\n\n      const rowId = rows[0].id;\n      const newCanonical = getCanonicalPathKey(newPath);\n      const newSpecFolder = extractSpecFolder(newPath);\n      const newMtime = (() => {\n        try { return fs.statSync(newPath).mtimeMs; } catch { return null; }\n      })();\n\n      // Update the row's path in place (preserves embedding, id, history). A reconciled\n      // move is a folder rename, so spec_folder is repointed with the same canonicalization\n      // indexMemoryFile/migration 23 use — otherwise WHERE spec_folder=? grouping goes stale.\n      const updated = db!.prepare(`\n        UPDATE memory_index\n        SET file_path = ?,\n            canonical_file_path = ?,\n            spec_folder = ?,\n            file_mtime_ms = ?,\n            updated_at = datetime('now')\n        WHERE id = ?\n          AND embedding_status != 'failed'\n      `).run(newPath, newCanonical, newSpecFolder, newMtime, rowId);\n\n      if ((updated as { changes: number }).changes !== 1) continue;\n\n      reconciledOldPaths.add(oldPath);\n      reconciledNewPaths.add(newPath);\n      reconciled.push({ oldPath, newPath, rowId, docType });\n      console.error(`[incremental-index] Move reconciled: ${newBasename} ${oldPath} → ${newPath} (row ${rowId}, embedding preserved)`);\n    }\n  }\n\n  return {\n    reconciled,\n    filteredToDelete: toDelete.filter(p => !reconciledOldPaths.has(p)),\n    filteredToIndex: toIndex.filter(p => !reconciledNewPaths.has(p)),\n  };\n}\n\nfunction batchUpdateMtimes(filePaths: string[]): { updated: number; failed: number } {\n  if (!db) return { updated: 0, failed: filePaths.length };\n\n  let updated = 0;\n  let failed = 0;\n\n  const updateTx = db.transaction(() => {\n    for (const filePath of filePaths) {\n      if (setIndexedMtime(filePath)) {\n        updated++;\n      } else {\n        failed++;\n      }\n    }\n  });\n\n  try {\n    updateTx();\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] batchUpdateMtimes error: ${msg}`);\n  }\n\n  return { updated, failed };\n}\n\nfunction countChunkFingerprintHits(database: Database.Database, input: MemoizedPlanningInput): { hits: number; misses: number } {\n  if (!input.chunks || input.chunks.length === 0) {\n    return { hits: 0, misses: 0 };\n  }\n\n  try {\n    const stmt = database.prepare(`\n      SELECT 1 AS hit\n      FROM memory_index\n      WHERE (canonical_file_path = ? OR file_path = ?)\n        AND chunk_id = ?\n        AND chunk_fingerprint = ?\n      LIMIT 1\n    `);\n    const canonicalPath = getCanonicalPathKey(input.componentPath);\n    let hits = 0;\n    let misses = 0;\n    for (const chunk of input.chunks) {\n      const row = stmt.get(canonicalPath, input.componentPath, chunk.chunkId, chunk.chunkFingerprint) as { hit?: number } | undefined;\n      if (row?.hit === 1) {\n        hits++;\n      } else {\n        misses++;\n      }\n    }\n    return { hits, misses };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] countChunkFingerprintHits error: ${msg}`);\n    return { hits: 0, misses: input.chunks.length };\n  }\n}\n\nfunction planMemoizedIndexing(\n  inputs: readonly MemoizedPlanningInput[],\n  options: MemoizedPlanningOptions = {},\n  database: Database.Database | null = db,\n): MemoizedPlanningResult {\n  const result: MemoizedPlanningResult = {\n    memoHits: 0,\n    memoMisses: 0,\n    chunkHits: 0,\n    chunkMisses: 0,\n    dependencyInvalidated: 0,\n    changedComponentPaths: [],\n    unchangedComponentPaths: [],\n    invalidatedComponentPaths: [],\n  };\n\n  if (!database) {\n    result.changedComponentPaths = inputs.map((input) => input.componentPath);\n    result.memoMisses = inputs.length;\n    result.chunkMisses = inputs.reduce((count, input) => count + (input.chunks?.length ?? 0), 0);\n    return result;\n  }\n\n  const memoStore = createMemoStore(database);\n  const changedPaths: string[] = [];\n  for (const input of inputs) {\n    // An unfingerprintable input (e.g. a non-finite number) must not abort the\n    // whole batch plan — treat it as a memo miss for this one input so the\n    // remaining inputs are still planned.\n    let inputFingerprint: string | null = null;\n    try {\n      inputFingerprint = canonicalFingerprint(input.canonicalInput);\n    } catch (_error: unknown) {\n      inputFingerprint = null;\n    }\n    const memo = inputFingerprint === null\n      ? undefined\n      : memoStore.getMemoRecord(input.componentPath, inputFingerprint, input.codeHash);\n    if (memo) {\n      result.memoHits++;\n      result.unchangedComponentPaths.push(input.componentPath);\n    } else {\n      result.memoMisses++;\n      result.changedComponentPaths.push(input.componentPath);\n      changedPaths.push(input.componentPath);\n    }\n\n    const chunkCounts = countChunkFingerprintHits(database, input);\n    result.chunkHits += chunkCounts.hits;\n    result.chunkMisses += chunkCounts.misses;\n  }\n\n  if (options.invalidateDependents !== false && changedPaths.length > 0) {\n    const invalidation = memoStore.invalidateDependents(changedPaths);\n    result.invalidatedComponentPaths = invalidation.invalidatedPaths;\n    result.dependencyInvalidated = invalidation.invalidatedPaths.length;\n  }\n\n  return result;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  MTIME_FAST_PATH_MS,\n\n  init,\n  getFileMetadata,\n  getStoredMetadata,\n  shouldReindex,\n  updateFileMtime,\n  setIndexedMtime,\n  categorizeFilesForIndexing,\n  listStaleIndexedPaths,\n  listIndexedRecordIdsForDeletedPaths,\n  sweepOrphanIndexRows,\n  reconcileMoves,\n  batchUpdateMtimes,\n  planMemoizedIndexing,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  FileMetadata,\n  StoredMetadata,\n  IndexDecision,\n  CategorizedFiles,\n  OrphanSweepOptions,\n  OrphanSweepResult,\n  MoveReconcileCandidate,\n  ReconcileMovesResult,\n  IncrementalChunkFingerprint,\n  MemoizedPlanningInput,\n  MemoizedPlanningOptions,\n  MemoizedPlanningResult,\n};","lineStart":1,"lineEnd":817,"totalLines":817,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","time":{"start":1781762655542,"end":1781762655546}},"metadata":{"openai":{"itemId":"fc_0f557bc5edd26ece016a338a5f55a481918a8c929a3af5a86c"}},"id":"prt_ed9548524001Msc4bDuw1pLXN6","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed95450c2001zQmWt1hLuMiS0E"}}
{"type":"tool_use","timestamp":1781762655578,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_QXXR2Dyfp5TZB9WEWz1TDxaD","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Job Queue\n3: // ───────────────────────────────────────────────────────────────\n4: // True sequential worker, meaningful state transitions,\n5: // Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n6: // Crash recovery with re-enqueue, and original-path progress tracking.\n7: \n8: /* ───────────────────────────────────────────────────────────────\n9:    1. IMPORTS\n10: ──────────────────────────────────────────────────────────────── */\n11: \n12: import path from 'node:path';\n13: import { requireDb, toErrorMessage } from '../../utils/index.js';\n14: import type { GovernanceDecision } from '../governance/scope-governance.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: // Feature catalog: Async ingestion job lifecycle\n18: \n19: /* ───────────────────────────────────────────────────────────────\n20:    2. TYPES\n21: ──────────────────────────────────────────────────────────────── */\n22: \n23: /**\n24:  * Defines the IngestJobState type.\n25:  */\n26: export type IngestJobState =\n27:   | 'queued'\n28:   | 'parsing'\n29:   | 'embedding'\n30:   | 'indexing'\n31:   | 'complete'\n32:   | 'failed'\n33:   | 'cancelled';\n34: \n35: /**\n36:  * Describes the IngestJobError shape.\n37:  */\n38: export interface IngestJobError {\n39:   filePath: string;\n40:   message: string;\n41:   timestamp: string;\n42: }\n43: \n44: /**\n45:  * Describes the IngestJob shape.\n46:  */\n47: export interface IngestJob {\n48:   id: string;\n49:   state: IngestJobState;\n50:   specFolder: string | null;\n51:   paths: string[];\n52:   filesTotal: number;\n53:   filesProcessed: number;\n54:   errors: IngestJobError[];\n55:   createdAt: string;\n56:   updatedAt: string;\n57:   // Validated governance decision captured at enqueue time so the worker\n58:   // re-indexes each path under the same provenance/retention/scope the\n59:   // synchronous save path applies. Null for ungoverned jobs (the default).\n60:   governance: GovernanceDecision | null;\n61: }\n62: \n63: export interface IngestJobForecast {\n64:   etaSeconds: number | null;\n65:   etaConfidence: number | null;\n66:   failureRisk: number | null;\n67:   riskSignals: string[];\n68:   caveat: string | null;\n69: }\n70: \n71: interface IngestJobRow {\n72:   id: string;\n73:   state: IngestJobState;\n74:   spec_folder: string | null;\n75:   paths_json: string;\n76:   files_total: number;\n77:   files_processed: number;\n78:   errors_json: string;\n79:   created_at: string;\n80:   updated_at: string;\n81:   governance_json?: string | null;\n82: }\n83: \n84: interface JobQueueConfig {\n85:   processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n86: }\n87: \n88: /* ───────────────────────────────────────────────────────────────\n89:    3. CONSTANTS\n90: ──────────────────────────────────────────────────────────────── */\n91: \n92: const ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\n93: const TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n94: \n95: const ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n96:   queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n97:   parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n98:   embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n99:   indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n100:   complete: new Set<IngestJobState>([]),\n101:   failed: new Set<IngestJobState>([]),\n102:   cancelled: new Set<IngestJobState>([]),\n103: };\n104: \n105: /* ───────────────────────────────────────────────────────────────\n106:    5. STATE MANAGEMENT\n107: ──────────────────────────────────────────────────────────────── */\n108: \n109: // True sequential queue — only one job processes at a time.\n110: const pendingQueue: string[] = [];\n111: let workerActive = false;\n112: // Drain fence. Once set, the worker stops draining and refuses to touch the\n113: // database. This prevents the worker from reopening a connection that shutdown\n114: // has already checkpointed and closed, which would otherwise re-dirty the WAL\n115: // and the unclean-shutdown marker at rest.\n116: let shuttingDown = false;\n117: let processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\n118: const MAX_STORED_ERRORS = 50;\n119: const MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n120: \n121: /* ───────────────────────────────────────────────────────────────\n122:    4. HELPERS\n123: ──────────────────────────────────────────────────────────────── */\n124: \n125: function toPublicPathLabel(filePath: string): string {\n126:   return filePath === '__job__' ? filePath : path.basename(filePath || '');\n127: }\n128: \n129: function sleep(ms: number): Promise<void> {\n130:   return new Promise((resolve) => setTimeout(resolve, ms));\n131: }\n132: \n133: function parsePositiveIntEnv(name: string, fallback: number): number {\n134:   const raw = process.env[name];\n135:   if (!raw) return fallback;\n136: \n137:   const parsed = Number.parseInt(raw, 10);\n138:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n139: }\n140: \n141: function parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n142:   if (!value) return fallback;\n143:   try {\n144:     const parsed = JSON.parse(value) as unknown;\n145:     return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n146:   } catch (_error: unknown) {\n147:     return fallback;\n148:   }\n149: }\n150: \n151: function parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n152:   if (!value) return null;\n153:   try {\n154:     const parsed = JSON.parse(value) as unknown;\n155:     if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n156:       return parsed as GovernanceDecision;\n157:     }\n158:     return null;\n159:   } catch (_error: unknown) {\n160:     return null;\n161:   }\n162: }\n163: \n164: function mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n165:   if (!row) return null;\n166:   return {\n167:     id: row.id,\n168:     state: row.state,\n169:     specFolder: row.spec_folder,\n170:     paths: parseJsonArray<string>(row.paths_json, []),\n171:     filesTotal: row.files_total,\n172:     filesProcessed: row.files_processed,\n173:     errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n174:     createdAt: row.created_at,\n175:     updatedAt: row.updated_at,\n176:     governance: parseGovernanceJson(row.governance_json),\n177:   };\n178: }\n179: \n180: function nowIso(): string {\n181:   return new Date().toISOString();\n182: }\n183: \n184: function isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n185:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n186: }\n187: \n188: // DB accessor for the worker path. While shutting down it refuses to acquire a\n189: // connection so the worker can never travel the requireDb -> getDb -> reopen\n190: // path after shutdown has closed the database. The throw is caught by the\n191: // worker's surrounding error handling and the drain unwinds cleanly.\n192: function acquireWorkerDb(): ReturnType<typeof requireDb> {\n193:   if (shuttingDown) {\n194:     throw new Error('Ingest worker is shutting down; database access refused');\n195:   }\n196:   return requireDb();\n197: }\n198: \n199: function ensureIngestJobsTable(): void {\n200:   const db = requireDb();\n201:   db.exec(`\n202:     CREATE TABLE IF NOT EXISTS ingest_jobs (\n203:       id TEXT PRIMARY KEY,\n204:       state TEXT,\n205:       spec_folder TEXT,\n206:       paths_json TEXT,\n207:       files_total INTEGER,\n208:       files_processed INTEGER,\n209:       errors_json TEXT,\n210:       created_at TEXT,\n211:       updated_at TEXT,\n212:       governance_json TEXT\n213:     )\n214:   `);\n215:   // Backward-compatible migration: add the nullable governance column to tables\n216:   // created before governed ingest existed. In-flight jobs simply carry a null\n217:   // governance and remain ungoverned, exactly as before.\n218:   const columns = db.prepare(`PRAGMA table_info(ingest_jobs)`).all() as Array<{ name: string }>;\n219:   if (!columns.some((column) => column.name === 'governance_json')) {\n220:     db.exec(`ALTER TABLE ingest_jobs ADD COLUMN governance_json TEXT`);\n221:   }\n222: }\n223: \n224: // Restart interrupted jobs from the beginning on process startup.\n225: // Indexing is idempotent, and replaying the original path list avoids\n226: // Mismatches when path accessibility changes between runs.\n227: function resetIncompleteJobsToQueued(): string[] {\n228:   const db = requireDb();\n229:   // Collect IDs of jobs that will be reset so we can re-enqueue them.\n230:   const rows = db.prepare(`\n231:     SELECT id FROM ingest_jobs\n232:     WHERE state NOT IN ('complete', 'failed', 'cancelled')\n233:   `).all() as Array<{ id: string }>;\n234: \n235:   if (rows.length === 0) return [];\n236: \n237:   withBusyRetrySync(() =>\n238:     db.prepare(`\n239:       UPDATE ingest_jobs\n240:       SET\n241:         state = 'queued',\n242:         files_processed = 0,\n243:         errors_json = '[]',\n244:         updated_at = ?\n245:       WHERE state NOT IN ('complete', 'failed', 'cancelled')\n246:     `).run(nowIso())\n247:   );\n248: \n249:   return rows.map((r) => r.id);\n250: }\n251: \n252: async function createIngestJob(args: {\n253:   id: string;\n254:   paths: string[];\n255:   specFolder?: string;\n256:   governance?: GovernanceDecision | null;\n257: }): Promise<IngestJob> {\n258:   const db = requireDb();\n259:   const timestamp = nowIso();\n260:   const normalizedPaths = args.paths.map((entry) => String(entry).trim()).filter((entry) => entry.length > 0);\n261: \n262:   if (normalizedPaths.length === 0) {\n263:     throw new Error('paths must include at least one file path');\n264:   }\n265: \n266:   const governance = args.governance ?? null;\n267:   const governanceJson = governance ? JSON.stringify(governance) : null;\n268: \n269:   await withBusyRetry(() =>\n270:     db.prepare(`\n271:       INSERT INTO ingest_jobs (\n272:         id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n273:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n274:     `).run(\n275:       args.id,\n276:       'queued',\n277:       args.specFolder ?? null,\n278:       JSON.stringify(normalizedPaths),\n279:       normalizedPaths.length,\n280:       0,\n281:       JSON.stringify([]),\n282:       timestamp,\n283:       timestamp,\n284:       governanceJson,\n285:     )\n286:   );\n287: \n288:   return {\n289:     id: args.id,\n290:     state: 'queued',\n291:     specFolder: args.specFolder ?? null,\n292:     paths: normalizedPaths,\n293:     filesTotal: normalizedPaths.length,\n294:     filesProcessed: 0,\n295:     errors: [],\n296:     createdAt: timestamp,\n297:     updatedAt: timestamp,\n298:     governance,\n299:   };\n300: }\n301: \n302: function getIngestJob(jobId: string): IngestJob | null {\n303:   const db = acquireWorkerDb();\n304:   const row = db.prepare(`\n305:     SELECT id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n306:     FROM ingest_jobs\n307:     WHERE id = ?\n308:   `).get(jobId) as IngestJobRow | undefined;\n309:   return mapRowToJob(row);\n310: }\n311: \n312: async function setIngestJobState(jobId: string, nextState: IngestJobState): Promise<IngestJob> {\n313:   const db = acquireWorkerDb();\n314:   const current = getIngestJob(jobId);\n315:   if (!current) {\n316:     throw new Error(`Ingest job not found: ${jobId}`);\n317:   }\n318: \n319:   if (current.state === nextState) {\n320:     return current;\n321:   }\n322: \n323:   if (!isTransitionAllowed(current.state, nextState)) {\n324:     throw new Error(`Invalid ingest job state transition: ${current.state} -> ${nextState}`);\n325:   }\n326: \n327:   const updatedAt = nowIso();\n328:   const result = await withBusyRetry(() =>\n329:     db.prepare(`\n330:       UPDATE ingest_jobs\n331:       SET state = ?, updated_at = ?\n332:       WHERE id = ? AND state = ?\n333:     `).run(nextState, updatedAt, jobId, current.state)\n334:   );\n335: \n336:   if ((result as { changes: number }).changes === 0) {\n337:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n338:   }\n339: \n340:   return {\n341:     ...current,\n342:     state: nextState,\n343:     updatedAt,\n344:   };\n345: }\n346: \n347: async function incrementProcessed(jobId: string): Promise<IngestJob> {\n348:   const db = acquireWorkerDb();\n349:   const updatedAt = nowIso();\n350:   await withBusyRetry(() =>\n351:     db.prepare(`\n352:       UPDATE ingest_jobs\n353:       SET files_processed = files_processed + 1, updated_at = ?\n354:       WHERE id = ?\n355:     `).run(updatedAt, jobId)\n356:   );\n357: \n358:   const updated = getIngestJob(jobId);\n359:   if (!updated) {\n360:     throw new Error(`Ingest job not found after progress update: ${jobId}`);\n361:   }\n362:   return updated;\n363: }\n364: \n365: async function appendIngestError(jobId: string, filePath: string, error: unknown): Promise<IngestJob> {\n366:   const db = acquireWorkerDb();\n367:   const current = getIngestJob(jobId);\n368:   if (!current) {\n369:     throw new Error(`Ingest job not found: ${jobId}`);\n370:   }\n371: \n372:   let errors = [\n373:     ...current.errors,\n374:     {\n375:       filePath: toPublicPathLabel(filePath),\n376:       message: toErrorMessage(error),\n377:       timestamp: nowIso(),\n378:     },\n379:   ];\n380: \n381:   if (errors.length > MAX_STORED_ERRORS) {\n382:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n383:     const trimmedCount = errors.length - tailLength;\n384:     const truncationNotice: IngestJobError = {\n385:       filePath: '__job__',\n386:       message: `error log truncated (${trimmedCount} older entries removed)`,\n387:       timestamp: nowIso(),\n388:     };\n389:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n390:     errors = [truncationNotice, ...truncatedTail];\n391:   }\n392: \n393:   const updatedAt = nowIso();\n394:   await withBusyRetry(() =>\n395:     db.prepare(`\n396:       UPDATE ingest_jobs\n397:       SET errors_json = ?, updated_at = ?\n398:       WHERE id = ?\n399:     `).run(JSON.stringify(errors), updatedAt, jobId)\n400:   );\n401: \n402:   return {\n403:     ...current,\n404:     errors,\n405:     updatedAt,\n406:   };\n407: }\n408: \n409: async function cancelIngestJob(jobId: string): Promise<IngestJob> {\n410:   const MAX_CANCEL_RETRIES = 3;\n411: \n412:   for (let attempt = 0; attempt < MAX_CANCEL_RETRIES; attempt += 1) {\n413:     const current = getIngestJob(jobId);\n414:     if (!current) {\n415:       throw new Error(`Ingest job not found: ${jobId}`);\n416:     }\n417:     if (TERMINAL_STATES.has(current.state)) {\n418:       return current;\n419:     }\n420: \n421:     try {\n422:       return await setIngestJobState(jobId, 'cancelled');\n423:     } catch (error: unknown) {\n424:       const message = toErrorMessage(error);\n425:       if (message.startsWith('State transition conflict:')) {\n426:         continue;\n427:       }\n428: \n429:       if (message.startsWith('Invalid ingest job state transition:')) {\n430:         const latest = getIngestJob(jobId);\n431:         if (latest && TERMINAL_STATES.has(latest.state)) {\n432:           return latest;\n433:         }\n434:         continue;\n435:       }\n436: \n437:       throw error;\n438:     }\n439:   }\n440: \n441:   const latest = getIngestJob(jobId);\n442:   if (!latest) {\n443:     throw new Error(`Ingest job not found: ${jobId}`);\n444:   }\n445:   if (TERMINAL_STATES.has(latest.state)) {\n446:     return latest;\n447:   }\n448: \n449:   return setIngestJobState(jobId, 'cancelled');\n450: }\n451: \n452: /**\n453:  * Provides the getIngestProgressPercent helper.\n454:  */\n455: export function getIngestProgressPercent(job: Pick<IngestJob, 'filesProcessed' | 'filesTotal'>): number {\n456:   if (job.filesTotal <= 0) return 0;\n457:   const raw = Math.round((job.filesProcessed / job.filesTotal) * 100);\n458:   return Math.max(0, Math.min(100, raw));\n459: }\n460: \n461: function parseIsoTimestamp(timestamp: string): number | null {\n462:   if (typeof timestamp !== 'string' || timestamp.trim().length === 0) {\n463:     return null;\n464:   }\n465: \n466:   const parsed = Date.parse(timestamp);\n467:   return Number.isFinite(parsed) ? parsed : null;\n468: }\n469: \n470: function clampUnitInterval(value: number): number {\n471:   if (!Number.isFinite(value)) return 0;\n472:   return Math.max(0, Math.min(1, value));\n473: }\n474: \n475: export function getIngestForecast(\n476:   job: Pick<IngestJob, 'state' | 'filesProcessed' | 'filesTotal' | 'errors' | 'createdAt' | 'updatedAt'>,\n477: ): IngestJobForecast {\n478:   const filesTotal = Math.max(0, job.filesTotal || 0);\n479:   const filesProcessed = Math.max(0, job.filesProcessed || 0);\n480:   const remaining = Math.max(0, filesTotal - filesProcessed);\n481:   const errorCount = Array.isArray(job.errors) ? job.errors.length : 0;\n482:   const errorRatio = filesTotal > 0 ? errorCount / filesTotal : 0;\n483:   const progressRatio = filesTotal > 0 ? filesProcessed / filesTotal : 0;\n484:   const riskSignals: string[] = [];\n485: \n486:   if (job.state === 'failed') {\n487:     return {\n488:       etaSeconds: 0,\n489:       etaConfidence: 1,\n490:       failureRisk: 1,\n491:       riskSignals: ['terminal_failed'],\n492:       caveat: null,\n493:     };\n494:   }\n495: \n496:   if (job.state === 'complete') {\n497:     return {\n498:       etaSeconds: 0,\n499:       etaConfidence: 1,\n500:       failureRisk: clampUnitInterval(errorRatio * 0.5),\n501:       riskSignals: errorCount > 0 ? ['completed_with_file_errors'] : [],\n502:       caveat: null,\n503:     };\n504:   }\n505: \n506:   if (job.state === 'cancelled') {\n507:     return {\n508:       etaSeconds: 0,\n509:       etaConfidence: 1,\n510:       failureRisk: 0,\n511:       riskSignals: ['terminal_cancelled'],\n512:       caveat: 'Forecast is advisory only because the job is no longer progressing.',\n513:     };\n514:   }\n515: \n516:   if (filesTotal <= 0) {\n517:     return {\n518:       etaSeconds: null,\n519:       etaConfidence: null,\n520:       failureRisk: null,\n521:       riskSignals,\n522:       caveat: 'Forecast unavailable because the queue has no file-count baseline yet.',\n523:     };\n524:   }\n525: \n526:   if (errorCount > 0) {\n527:     riskSignals.push('file_errors_seen');\n528:   }\n529:   if (job.state === 'queued') {\n530:     riskSignals.push('queued_not_started');\n531:   }\n532: \n533:   const createdAtMs = parseIsoTimestamp(job.createdAt);\n534:   const updatedAtMs = parseIsoTimestamp(job.updatedAt);\n535:   const elapsedSeconds = createdAtMs !== null && updatedAtMs !== null && updatedAtMs >= createdAtMs\n536:     ? Math.max(0, (updatedAtMs - createdAtMs) / 1000)\n537:     : 0;\n538: \n539:   let etaSeconds: number | null = null;\n540:   let etaConfidence: number | null = null;\n541:   let caveat: string | null = null;\n542: \n543:   if (filesProcessed <= 0 || elapsedSeconds < 1) {\n544:     caveat = 'Forecast is low-confidence until at least one file has been processed.';\n545:   } else {\n546:     const throughput = filesProcessed / elapsedSeconds;\n547:     if (throughput > 0) {\n548:       etaSeconds = Math.max(0, Math.round(remaining / throughput));\n549:       etaConfidence = clampUnitInterval(0.35 + (progressRatio * 0.45) - (errorRatio * 0.25));\n550:       if (etaConfidence < 0.4) {\n551:         caveat = 'Forecast is low-confidence because queue history is still sparse or noisy.';\n552:       }\n553:     } else {\n554:       caveat = 'Forecast unavailable because throughput could not be derived from queue history.';\n555:     }\n556:   }\n557: \n558:   if (progressRatio <= 0 && job.state !== 'queued') {\n559:     riskSignals.push('active_without_progress');\n560:   }\n561:   if (errorRatio >= 0.5 && errorCount > 0) {\n562:     riskSignals.push('high_error_ratio');\n563:   }\n564: \n565:   const stateRisk = job.state === 'indexing' ? 0.15 : (job.state === 'embedding' ? 0.1 : 0.05);\n566:   const failureRisk = clampUnitInterval((errorRatio * 0.7) + stateRisk + (progressRatio === 0 ? 0.05 : 0));\n567: \n568:   return {\n569:     etaSeconds,\n570:     etaConfidence,\n571:     failureRisk,\n572:     riskSignals,\n573:     caveat,\n574:   };\n575: }\n576: \n577: /* ───────────────────────────────────────────────────────────────\n578:    6. WORKER\n579: ──────────────────────────────────────────────────────────────── */\n580: \n581: // Real state machine — states now correspond to actual work phases.\n582: // Progress is tracked against the original submitted path list so terminal\n583: // Accounting stays stable even when some files are inaccessible.\n584: async function processQueuedJob(jobId: string): Promise<void> {\n585:   if (!processFileFn) {\n586:     throw new Error('Ingest queue not initialized: processFile handler is missing');\n587:   }\n588: \n589:   let job = getIngestJob(jobId);\n590:   if (!job || TERMINAL_STATES.has(job.state)) {\n591:     return;\n592:   }\n593: \n594:   // Step 1: Parsing — validate all paths exist and are readable.\n595:   job = await setIngestJobState(jobId, 'parsing');\n596:   if (TERMINAL_STATES.has(job.state)) return;\n597: \n598:   const { access } = await import('fs/promises');\n599: \n600:   // Step 2: Embedding — placeholder for batch embedding pre-processing.\n601:   // Transition is meaningful: it signals readiness for indexing after validation.\n602:   const latest1 = getIngestJob(jobId);\n603:   if (!latest1 || TERMINAL_STATES.has(latest1.state)) return;\n604:   job = await setIngestJobState(jobId, 'embedding');\n605:   if (TERMINAL_STATES.has(job.state)) return;\n606: \n607:   // Step 3: Indexing — process only validated paths (not original paths).\n608:   const latest2 = getIngestJob(jobId);\n609:   if (!latest2 || TERMINAL_STATES.has(latest2.state)) return;\n610:   job = await setIngestJobState(jobId, 'indexing');\n611: \n612:   // Resume from filesProcessed against the original submitted path order.\n613:   let currentIndex = job.filesProcessed;\n614:   // Track actual failure count independently of the truncated errors array.\n615:   // The errors array is capped at MAX_STORED_ERRORS, so using errors.length for\n616:   // Terminal state decisions would misclassify all-fail jobs with >50 files as \"complete\".\n617:   let failCount = 0;\n618: \n619:   while (currentIndex < job.paths.length) {\n620:     // Stop touching the DB the moment shutdown begins. The job stays in an\n621:     // active state and boot crash-recovery re-enqueues it on the next start.\n622:     if (shuttingDown) return;\n623:     const current = getIngestJob(jobId);\n624:     if (!current) return;\n625:     if (current.state === 'cancelled') return;\n626: \n627:     const nextPath = current.paths[currentIndex];\n628:     if (!nextPath) {\n629:       break;\n630:     }\n631: \n632:     // Continue on file error instead of aborting the entire job.\n633:     try {\n634:       await access(nextPath);\n635:       await processFileFn(nextPath, current.governance);\n636:     } catch (error: unknown) {\n637:       const normalizedError = error instanceof Error\n638:         && 'code' in error\n639:         && typeof error.code === 'string'\n640:         && error.code === 'ENOENT'\n641:         ? new Error('File not accessible')\n642:         : error;\n643:       await appendIngestError(jobId, nextPath, normalizedError);\n644:       failCount += 1;\n645:       console.warn(`[job-queue] File error (continuing): ${toPublicPathLabel(nextPath)} — ${toErrorMessage(normalizedError)}`);\n646:     }\n647: \n648:     job = await incrementProcessed(jobId);\n649:     currentIndex = job.filesProcessed;\n650:   }\n651: \n652:   // Determine terminal state: complete if no errors, failed if all files errored.\n653:   const done = getIngestJob(jobId);\n654:   if (!done) return;\n655:   if (done.state === 'cancelled') return;\n656: \n657:   if (failCount > 0 && failCount >= done.filesTotal) {\n658:     // All files failed — mark as failed.\n659:     await setIngestJobState(jobId, 'failed');\n660:   } else {\n661:     // Partial or full success — mark as complete (errors are preserved in record).\n662:     await setIngestJobState(jobId, 'complete');\n663:   }\n664: }\n665: \n666: // True sequential worker — processes one job at a time.\n667: // Multiple enqueueIngestJob calls add to pendingQueue; a single worker drains it.\n668: async function drainQueue(): Promise<void> {\n669:   if (workerActive) return;\n670:   workerActive = true;\n671: \n672:   try {\n673:     while (pendingQueue.length > 0) {\n674:       // Halt draining once shutdown begins so no new job opens the DB.\n675:       if (shuttingDown) break;\n676:       // PendingQueue.length > 0 in the loop condition guarantees shift() returns a job id\n677:       const jobId = pendingQueue.shift()!;\n678:       try {\n679:         await processQueuedJob(jobId);\n680:       } catch (error: unknown) {\n681:         try {\n682:           await appendIngestError(jobId, '__job__', error);\n683:           const current = getIngestJob(jobId);\n684:           if (current && ACTIVE_STATES.has(current.state)) {\n685:             await setIngestJobState(jobId, 'failed');\n686:           }\n687:         } catch (_error: unknown) {\n688:           // Non-fatal: queue guard to avoid unhandled rejection loops.\n689:         }\n690:       }\n691: \n692:       // Brief yield between jobs to avoid starving the event loop.\n693:       await sleep(10);\n694:     }\n695:   } finally {\n696:     workerActive = false;\n697:   }\n698: }\n699: \n700: function enqueueIngestJob(jobId: string): void {\n701:   // Never admit work or respawn the worker once shutdown has begun.\n702:   if (shuttingDown) {\n703:     return;\n704:   }\n705:   // Prevent duplicate enqueue of the same job.\n706:   if (pendingQueue.includes(jobId)) {\n707:     return;\n708:   }\n709: \n710:   pendingQueue.push(jobId);\n711:   while (pendingQueue.length > MAX_PENDING_INGEST_JOBS) {\n712:     const evictedJobId = pendingQueue.shift();\n713:     if (!evictedJobId) break;\n714:     void appendIngestError(\n715:       evictedJobId,\n716:       '__job__',\n717:       new Error(`Pending ingest queue exceeded cap ${MAX_PENDING_INGEST_JOBS}; oldest job aborted`),\n718:     )\n719:       .then(() => cancelIngestJob(evictedJobId))\n720:       .catch((error: unknown) => {\n721:         console.warn(`[job-queue] Failed to cancel overflow job ${evictedJobId}: ${toErrorMessage(error)}`);\n722:       });\n723:   }\n724: \n725:   // Start worker if not already running (fire-and-forget).\n726:   if (!workerActive) {\n727:     setImmediate(() => {\n728:       void drainQueue().catch((error: unknown) => {\n729:         console.error(`[job-queue] Worker error: ${toErrorMessage(error)}`);\n730:       });\n731:     });\n732:   }\n733: }\n734: \n735: /* ───────────────────────────────────────────────────────────────\n736:    7. INITIALIZATION\n737: ──────────────────────────────────────────────────────────────── */\n738: \n739: function initIngestJobQueue(config: JobQueueConfig): { resetCount: number } {\n740:   processFileFn = config.processFile;\n741:   ensureIngestJobsTable();\n742: \n743:   // Crash recovery: reset incomplete jobs to 'queued' AND re-enqueue them\n744:   // So they actually get processed by the worker.\n745:   const resetJobIds = resetIncompleteJobsToQueued();\n746:   for (const jobId of resetJobIds) {\n747:     enqueueIngestJob(jobId);\n748:   }\n749: \n750:   return { resetCount: resetJobIds.length };\n751: }\n752: \n753: // Default ceiling for how long stopWorker waits for the active drain to settle.\n754: // The worker yields between files and between jobs, so it observes the fence\n755: // quickly; the bound only guards against a wedged in-flight processFile call.\n756: const STOP_WORKER_DRAIN_DEADLINE_MS = 2_000;\n757: \n758: // Fence the ingest worker for shutdown: refuse new work, drop the pending\n759: // queue, and wait (bounded) for any in-flight drain to unwind before the\n760: // database is closed. Must run before closeDb() so the worker cannot reopen a\n761: // closed connection. Idempotent and safe to call when the worker is idle.\n762: async function stopWorker(options: { drainDeadlineMs?: number } = {}): Promise<void> {\n763:   shuttingDown = true;\n764:   pendingQueue.length = 0;\n765: \n766:   if (!workerActive) return;\n767: \n768:   const deadline = Date.now()\n769:     + (Number.isFinite(options.drainDeadlineMs) && (options.drainDeadlineMs as number) > 0\n770:       ? (options.drainDeadlineMs as number)\n771:       : STOP_WORKER_DRAIN_DEADLINE_MS);\n772: \n773:   while (workerActive && Date.now() < deadline) {\n774:     await sleep(10);\n775:   }\n776: }\n777: \n778: /* ───────────────────────────────────────────────────────────────\n779:    8. EXPORTS\n780: ──────────────────────────────────────────────────────────────── */\n781: \n782: export {\n783:   initIngestJobQueue,\n784:   stopWorker,\n785:   createIngestJob,\n786:   getIngestJob,\n787:   cancelIngestJob,\n788:   enqueueIngestJob,\n789:   resetIncompleteJobsToQueued,\n790:   MAX_PENDING_INGEST_JOBS,\n791: };\n\n(End of file - total 791 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Job Queue\n// ───────────────────────────────────────────────────────────────\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Job Queue\n// ───────────────────────────────────────────────────────────────\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Defines the IngestJobState type.\n */\nexport type IngestJobState =\n  | 'queued'\n  | 'parsing'\n  | 'embedding'\n  | 'indexing'\n  | 'complete'\n  | 'failed'\n  | 'cancelled';\n\n/**\n * Describes the IngestJobError shape.\n */\nexport interface IngestJobError {\n  filePath: string;\n  message: string;\n  timestamp: string;\n}\n\n/**\n * Describes the IngestJob shape.\n */\nexport interface IngestJob {\n  id: string;\n  state: IngestJobState;\n  specFolder: string | null;\n  paths: string[];\n  filesTotal: number;\n  filesProcessed: number;\n  errors: IngestJobError[];\n  createdAt: string;\n  updatedAt: string;\n  // Validated governance decision captured at enqueue time so the worker\n  // re-indexes each path under the same provenance/retention/scope the\n  // synchronous save path applies. Null for ungoverned jobs (the default).\n  governance: GovernanceDecision | null;\n}\n\nexport interface IngestJobForecast {\n  etaSeconds: number | null;\n  etaConfidence: number | null;\n  failureRisk: number | null;\n  riskSignals: string[];\n  caveat: string | null;\n}\n\ninterface IngestJobRow {\n  id: string;\n  state: IngestJobState;\n  spec_folder: string | null;\n  paths_json: string;\n  files_total: number;\n  files_processed: number;\n  errors_json: string;\n  created_at: string;\n  updated_at: string;\n  governance_json?: string | null;\n}\n\ninterface JobQueueConfig {\n  processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nconst ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\nconst TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n\nconst ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n  queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n  parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n  embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n  indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n  complete: new Set<IngestJobState>([]),\n  failed: new Set<IngestJobState>([]),\n  cancelled: new Set<IngestJobState>([]),\n};\n\n/* ───────────────────────────────────────────────────────────────\n   5. STATE MANAGEMENT\n──────────────────────────────────────────────────────────────── */\n\n// True sequential queue — only one job processes at a time.\nconst pendingQueue: string[] = [];\nlet workerActive = false;\n// Drain fence. Once set, the worker stops draining and refuses to touch the\n// database. This prevents the worker from reopening a connection that shutdown\n// has already checkpointed and closed, which would otherwise re-dirty the WAL\n// and the unclean-shutdown marker at rest.\nlet shuttingDown = false;\nlet processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\nconst MAX_STORED_ERRORS = 50;\nconst MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n  if (!value) return fallback;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n  if (!value) return null;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n      return parsed as GovernanceDecision;\n    }\n    return null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    state: row.state,\n    specFolder: row.spec_folder,\n    paths: parseJsonArray<string>(row.paths_json, []),\n    filesTotal: row.files_total,\n    filesProcessed: row.files_processed,\n    errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    governance: parseGovernanceJson(row.governance_json),\n  };\n}\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\n// DB accessor for the worker path. While shutting down it refuses to acquire a\n// connection so the worker can never travel the requireDb -> getDb -> reopen\n// path after shutdown has closed the database. The throw is caught by the\n// worker's surrounding error handling and the drain unwinds cleanly.\nfunction acquireWorkerDb(): ReturnType<typeof requireDb> {\n  if (shuttingDown) {\n    throw new Error('Ingest worker is shutting down; database access refused');\n  }\n  return requireDb();\n}\n\nfunction ensureIngestJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS ingest_jobs (\n      id TEXT PRIMARY KEY,\n      state TEXT,\n      spec_folder TEXT,\n      paths_json TEXT,\n      files_total INTEGER,\n      files_processed INTEGER,\n      errors_json TEXT,\n      created_at TEXT,\n      updated_at TEXT,\n      governance_json TEXT\n    )\n  `);\n  // Backward-compatible migration: add the nullable governance column to tables\n  // created before governed ingest existed. In-flight jobs simply carry a null\n  // governance and remain ungoverned, exactly as before.\n  const columns = db.prepare(`PRAGMA table_info(ingest_jobs)`).all() as Array<{ name: string }>;\n  if (!columns.some((column) => column.name === 'governance_json')) {\n    db.exec(`ALTER TABLE ingest_jobs ADD COLUMN governance_json TEXT`);\n  }\n}\n\n// Restart interrupted jobs from the beginning on process startup.\n// Indexing is idempotent, and replaying the original path list avoids\n// Mismatches when path accessibility changes between runs.\nfunction resetIncompleteJobsToQueued(): string[] {\n  const db = requireDb();\n  // Collect IDs of jobs that will be reset so we can re-enqueue them.\n  const rows = db.prepare(`\n    SELECT id FROM ingest_jobs\n    WHERE state NOT IN ('complete', 'failed', 'cancelled')\n  `).all() as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET\n        state = 'queued',\n        files_processed = 0,\n        errors_json = '[]',\n        updated_at = ?\n      WHERE state NOT IN ('complete', 'failed', 'cancelled')\n    `).run(nowIso())\n  );\n\n  return rows.map((r) => r.id);\n}\n\nasync function createIngestJob(args: {\n  id: string;\n  paths: string[];\n  specFolder?: string;\n  governance?: GovernanceDecision | null;\n}): Promise<IngestJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const normalizedPaths = args.paths.map((entry) => String(entry).trim()).filter((entry) => entry.length > 0);\n\n  if (normalizedPaths.length === 0) {\n    throw new Error('paths must include at least one file path');\n  }\n\n  const governance = args.governance ?? null;\n  const governanceJson = governance ? JSON.stringify(governance) : null;\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO ingest_jobs (\n        id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      'queued',\n      args.specFolder ?? null,\n      JSON.stringify(normalizedPaths),\n      normalizedPaths.length,\n      0,\n      JSON.stringify([]),\n      timestamp,\n      timestamp,\n      governanceJson,\n    )\n  );\n\n  return {\n    id: args.id,\n    state: 'queued',\n    specFolder: args.specFolder ?? null,\n    paths: normalizedPaths,\n    filesTotal: normalizedPaths.length,\n    filesProcessed: 0,\n    errors: [],\n    createdAt: timestamp,\n    updatedAt: timestamp,\n    governance,\n  };\n}\n\nfunction getIngestJob(jobId: string): IngestJob | null {\n  const db = acquireWorkerDb();\n  const row = db.prepare(`\n    SELECT id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n    FROM ingest_jobs\n    WHERE id = ?\n  `).get(jobId) as IngestJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nasync function setIngestJobState(jobId: string, nextState: IngestJobState): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const current = getIngestJob(jobId);\n  if (!current) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid ingest job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  return {\n    ...current,\n    state: nextState,\n    updatedAt,\n  };\n}\n\nasync function incrementProcessed(jobId: string): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET files_processed = files_processed + 1, updated_at = ?\n      WHERE id = ?\n    `).run(updatedAt, jobId)\n  );\n\n  const updated = getIngestJob(jobId);\n  if (!updated) {\n    throw new Error(`Ingest job not found after progress update: ${jobId}`);\n  }\n  return updated;\n}\n\nasync function appendIngestError(jobId: string, filePath: string, error: unknown): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const current = getIngestJob(jobId);\n  if (!current) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n\n  let errors = [\n    ...current.errors,\n    {\n      filePath: toPublicPathLabel(filePath),\n      message: toErrorMessage(error),\n      timestamp: nowIso(),\n    },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: IngestJobError = {\n      filePath: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET errors_json = ?, updated_at = ?\n      WHERE id = ?\n    `).run(JSON.stringify(errors), updatedAt, jobId)\n  );\n\n  return {\n    ...current,\n    errors,\n    updatedAt,\n  };\n}\n\nasync function cancelIngestJob(jobId: string): Promise<IngestJob> {\n  const MAX_CANCEL_RETRIES = 3;\n\n  for (let attempt = 0; attempt < MAX_CANCEL_RETRIES; attempt += 1) {\n    const current = getIngestJob(jobId);\n    if (!current) {\n      throw new Error(`Ingest job not found: ${jobId}`);\n    }\n    if (TERMINAL_STATES.has(current.state)) {\n      return current;\n    }\n\n    try {\n      return await setIngestJobState(jobId, 'cancelled');\n    } catch (error: unknown) {\n      const message = toErrorMessage(error);\n      if (message.startsWith('State transition conflict:')) {\n        continue;\n      }\n\n      if (message.startsWith('Invalid ingest job state transition:')) {\n        const latest = getIngestJob(jobId);\n        if (latest && TERMINAL_STATES.has(latest.state)) {\n          return latest;\n        }\n        continue;\n      }\n\n      throw error;\n    }\n  }\n\n  const latest = getIngestJob(jobId);\n  if (!latest) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n  if (TERMINAL_STATES.has(latest.state)) {\n    return latest;\n  }\n\n  return setIngestJobState(jobId, 'cancelled');\n}\n\n/**\n * Provides the getIngestProgressPercent helper.\n */\nexport function getIngestProgressPercent(job: Pick<IngestJob, 'filesProcessed' | 'filesTotal'>): number {\n  if (job.filesTotal <= 0) return 0;\n  const raw = Math.round((job.filesProcessed / job.filesTotal) * 100);\n  return Math.max(0, Math.min(100, raw));\n}\n\nfunction parseIsoTimestamp(timestamp: string): number | null {\n  if (typeof timestamp !== 'string' || timestamp.trim().length === 0) {\n    return null;\n  }\n\n  const parsed = Date.parse(timestamp);\n  return Number.isFinite(parsed) ? parsed : null;\n}\n\nfunction clampUnitInterval(value: number): number {\n  if (!Number.isFinite(value)) return 0;\n  return Math.max(0, Math.min(1, value));\n}\n\nexport function getIngestForecast(\n  job: Pick<IngestJob, 'state' | 'filesProcessed' | 'filesTotal' | 'errors' | 'createdAt' | 'updatedAt'>,\n): IngestJobForecast {\n  const filesTotal = Math.max(0, job.filesTotal || 0);\n  const filesProcessed = Math.max(0, job.filesProcessed || 0);\n  const remaining = Math.max(0, filesTotal - filesProcessed);\n  const errorCount = Array.isArray(job.errors) ? job.errors.length : 0;\n  const errorRatio = filesTotal > 0 ? errorCount / filesTotal : 0;\n  const progressRatio = filesTotal > 0 ? filesProcessed / filesTotal : 0;\n  const riskSignals: string[] = [];\n\n  if (job.state === 'failed') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: 1,\n      riskSignals: ['terminal_failed'],\n      caveat: null,\n    };\n  }\n\n  if (job.state === 'complete') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: clampUnitInterval(errorRatio * 0.5),\n      riskSignals: errorCount > 0 ? ['completed_with_file_errors'] : [],\n      caveat: null,\n    };\n  }\n\n  if (job.state === 'cancelled') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: 0,\n      riskSignals: ['terminal_cancelled'],\n      caveat: 'Forecast is advisory only because the job is no longer progressing.',\n    };\n  }\n\n  if (filesTotal <= 0) {\n    return {\n      etaSeconds: null,\n      etaConfidence: null,\n      failureRisk: null,\n      riskSignals,\n      caveat: 'Forecast unavailable because the queue has no file-count baseline yet.',\n    };\n  }\n\n  if (errorCount > 0) {\n    riskSignals.push('file_errors_seen');\n  }\n  if (job.state === 'queued') {\n    riskSignals.push('queued_not_started');\n  }\n\n  const createdAtMs = parseIsoTimestamp(job.createdAt);\n  const updatedAtMs = parseIsoTimestamp(job.updatedAt);\n  const elapsedSeconds = createdAtMs !== null && updatedAtMs !== null && updatedAtMs >= createdAtMs\n    ? Math.max(0, (updatedAtMs - createdAtMs) / 1000)\n    : 0;\n\n  let etaSeconds: number | null = null;\n  let etaConfidence: number | null = null;\n  let caveat: string | null = null;\n\n  if (filesProcessed <= 0 || elapsedSeconds < 1) {\n    caveat = 'Forecast is low-confidence until at least one file has been processed.';\n  } else {\n    const throughput = filesProcessed / elapsedSeconds;\n    if (throughput > 0) {\n      etaSeconds = Math.max(0, Math.round(remaining / throughput));\n      etaConfidence = clampUnitInterval(0.35 + (progressRatio * 0.45) - (errorRatio * 0.25));\n      if (etaConfidence < 0.4) {\n        caveat = 'Forecast is low-confidence because queue history is still sparse or noisy.';\n      }\n    } else {\n      caveat = 'Forecast unavailable because throughput could not be derived from queue history.';\n    }\n  }\n\n  if (progressRatio <= 0 && job.state !== 'queued') {\n    riskSignals.push('active_without_progress');\n  }\n  if (errorRatio >= 0.5 && errorCount > 0) {\n    riskSignals.push('high_error_ratio');\n  }\n\n  const stateRisk = job.state === 'indexing' ? 0.15 : (job.state === 'embedding' ? 0.1 : 0.05);\n  const failureRisk = clampUnitInterval((errorRatio * 0.7) + stateRisk + (progressRatio === 0 ? 0.05 : 0));\n\n  return {\n    etaSeconds,\n    etaConfidence,\n    failureRisk,\n    riskSignals,\n    caveat,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. WORKER\n──────────────────────────────────────────────────────────────── */\n\n// Real state machine — states now correspond to actual work phases.\n// Progress is tracked against the original submitted path list so terminal\n// Accounting stays stable even when some files are inaccessible.\nasync function processQueuedJob(jobId: string): Promise<void> {\n  if (!processFileFn) {\n    throw new Error('Ingest queue not initialized: processFile handler is missing');\n  }\n\n  let job = getIngestJob(jobId);\n  if (!job || TERMINAL_STATES.has(job.state)) {\n    return;\n  }\n\n  // Step 1: Parsing — validate all paths exist and are readable.\n  job = await setIngestJobState(jobId, 'parsing');\n  if (TERMINAL_STATES.has(job.state)) return;\n\n  const { access } = await import('fs/promises');\n\n  // Step 2: Embedding — placeholder for batch embedding pre-processing.\n  // Transition is meaningful: it signals readiness for indexing after validation.\n  const latest1 = getIngestJob(jobId);\n  if (!latest1 || TERMINAL_STATES.has(latest1.state)) return;\n  job = await setIngestJobState(jobId, 'embedding');\n  if (TERMINAL_STATES.has(job.state)) return;\n\n  // Step 3: Indexing — process only validated paths (not original paths).\n  const latest2 = getIngestJob(jobId);\n  if (!latest2 || TERMINAL_STATES.has(latest2.state)) return;\n  job = await setIngestJobState(jobId, 'indexing');\n\n  // Resume from filesProcessed against the original submitted path order.\n  let currentIndex = job.filesProcessed;\n  // Track actual failure count independently of the truncated errors array.\n  // The errors array is capped at MAX_STORED_ERRORS, so using errors.length for\n  // Terminal state decisions would misclassify all-fail jobs with >50 files as \"complete\".\n  let failCount = 0;\n\n  while (currentIndex < job.paths.length) {\n    // Stop touching the DB the moment shutdown begins. The job stays in an\n    // active state and boot crash-recovery re-enqueues it on the next start.\n    if (shuttingDown) return;\n    const current = getIngestJob(jobId);\n    if (!current) return;\n    if (current.state === 'cancelled') return;\n\n    const nextPath = current.paths[currentIndex];\n    if (!nextPath) {\n      break;\n    }\n\n    // Continue on file error instead of aborting the entire job.\n    try {\n      await access(nextPath);\n      await processFileFn(nextPath, current.governance);\n    } catch (error: unknown) {\n      const normalizedError = error instanceof Error\n        && 'code' in error\n        && typeof error.code === 'string'\n        && error.code === 'ENOENT'\n        ? new Error('File not accessible')\n        : error;\n      await appendIngestError(jobId, nextPath, normalizedError);\n      failCount += 1;\n      console.warn(`[job-queue] File error (continuing): ${toPublicPathLabel(nextPath)} — ${toErrorMessage(normalizedError)}`);\n    }\n\n    job = await incrementProcessed(jobId);\n    currentIndex = job.filesProcessed;\n  }\n\n  // Determine terminal state: complete if no errors, failed if all files errored.\n  const done = getIngestJob(jobId);\n  if (!done) return;\n  if (done.state === 'cancelled') return;\n\n  if (failCount > 0 && failCount >= done.filesTotal) {\n    // All files failed — mark as failed.\n    await setIngestJobState(jobId, 'failed');\n  } else {\n    // Partial or full success — mark as complete (errors are preserved in record).\n    await setIngestJobState(jobId, 'complete');\n  }\n}\n\n// True sequential worker — processes one job at a time.\n// Multiple enqueueIngestJob calls add to pendingQueue; a single worker drains it.\nasync function drainQueue(): Promise<void> {\n  if (workerActive) return;\n  workerActive = true;\n\n  try {\n    while (pendingQueue.length > 0) {\n      // Halt draining once shutdown begins so no new job opens the DB.\n      if (shuttingDown) break;\n      // PendingQueue.length > 0 in the loop condition guarantees shift() returns a job id\n      const jobId = pendingQueue.shift()!;\n      try {\n        await processQueuedJob(jobId);\n      } catch (error: unknown) {\n        try {\n          await appendIngestError(jobId, '__job__', error);\n          const current = getIngestJob(jobId);\n          if (current && ACTIVE_STATES.has(current.state)) {\n            await setIngestJobState(jobId, 'failed');\n          }\n        } catch (_error: unknown) {\n          // Non-fatal: queue guard to avoid unhandled rejection loops.\n        }\n      }\n\n      // Brief yield between jobs to avoid starving the event loop.\n      await sleep(10);\n    }\n  } finally {\n    workerActive = false;\n  }\n}\n\nfunction enqueueIngestJob(jobId: string): void {\n  // Never admit work or respawn the worker once shutdown has begun.\n  if (shuttingDown) {\n    return;\n  }\n  // Prevent duplicate enqueue of the same job.\n  if (pendingQueue.includes(jobId)) {\n    return;\n  }\n\n  pendingQueue.push(jobId);\n  while (pendingQueue.length > MAX_PENDING_INGEST_JOBS) {\n    const evictedJobId = pendingQueue.shift();\n    if (!evictedJobId) break;\n    void appendIngestError(\n      evictedJobId,\n      '__job__',\n      new Error(`Pending ingest queue exceeded cap ${MAX_PENDING_INGEST_JOBS}; oldest job aborted`),\n    )\n      .then(() => cancelIngestJob(evictedJobId))\n      .catch((error: unknown) => {\n        console.warn(`[job-queue] Failed to cancel overflow job ${evictedJobId}: ${toErrorMessage(error)}`);\n      });\n  }\n\n  // Start worker if not already running (fire-and-forget).\n  if (!workerActive) {\n    setImmediate(() => {\n      void drainQueue().catch((error: unknown) => {\n        console.error(`[job-queue] Worker error: ${toErrorMessage(error)}`);\n      });\n    });\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. INITIALIZATION\n──────────────────────────────────────────────────────────────── */\n\nfunction initIngestJobQueue(config: JobQueueConfig): { resetCount: number } {\n  processFileFn = config.processFile;\n  ensureIngestJobsTable();\n\n  // Crash recovery: reset incomplete jobs to 'queued' AND re-enqueue them\n  // So they actually get processed by the worker.\n  const resetJobIds = resetIncompleteJobsToQueued();\n  for (const jobId of resetJobIds) {\n    enqueueIngestJob(jobId);\n  }\n\n  return { resetCount: resetJobIds.length };\n}\n\n// Default ceiling for how long stopWorker waits for the active drain to settle.\n// The worker yields between files and between jobs, so it observes the fence\n// quickly; the bound only guards against a wedged in-flight processFile call.\nconst STOP_WORKER_DRAIN_DEADLINE_MS = 2_000;\n\n// Fence the ingest worker for shutdown: refuse new work, drop the pending\n// queue, and wait (bounded) for any in-flight drain to unwind before the\n// database is closed. Must run before closeDb() so the worker cannot reopen a\n// closed connection. Idempotent and safe to call when the worker is idle.\nasync function stopWorker(options: { drainDeadlineMs?: number } = {}): Promise<void> {\n  shuttingDown = true;\n  pendingQueue.length = 0;\n\n  if (!workerActive) return;\n\n  const deadline = Date.now()\n    + (Number.isFinite(options.drainDeadlineMs) && (options.drainDeadlineMs as number) > 0\n      ? (options.drainDeadlineMs as number)\n      : STOP_WORKER_DRAIN_DEADLINE_MS);\n\n  while (workerActive && Date.now() < deadline) {\n    await sleep(10);\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  initIngestJobQueue,\n  stopWorker,\n  createIngestJob,\n  getIngestJob,\n  cancelIngestJob,\n  enqueueIngestJob,\n  resetIncompleteJobsToQueued,\n  MAX_PENDING_INGEST_JOBS,\n};","lineStart":1,"lineEnd":791,"totalLines":791,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","time":{"start":1781762655573,"end":1781762655576}},"metadata":{"openai":{"itemId":"fc_0f557bc5edd26ece016a338a5f55ac8191921915bddfccd30d"}},"id":"prt_ed954853d001OuqvCtNf2aBISK","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed95450c2001zQmWt1hLuMiS0E"}}
{"type":"tool_use","timestamp":1781762655600,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_jxpNLkeOBvqlY2xVVeyJSWqs","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","offset":1,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memory Ingest Handlers\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    1. IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import fs from 'node:fs';\n10: import path from 'node:path';\n11: \n12: import { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\n13: import { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\n14: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n15: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n16: import {\n17:   createIngestJob,\n18:   enqueueIngestJob,\n19:   getIngestJob,\n20:   cancelIngestJob,\n21:   getIngestProgressPercent,\n22:   getIngestForecast,\n23:   type IngestJob,\n24: } from '../lib/ops/job-queue.js';\n25: import * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\n26: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n27: import { createJobId } from '../lib/ops/job-store.js';\n28: \n29: import type { MCPResponse } from './types.js';\n30: \n31: // Feature catalog: Async ingestion job lifecycle\n32: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n33: \n34: /* ───────────────────────────────────────────────────────────────\n35:    2. TYPES\n36: ──────────────────────────────────────────────────────────────── */\n37: \n38: interface MemoryIngestStartArgs {\n39:   paths: string[];\n40:   specFolder?: string;\n41:   tenantId?: string;\n42:   userId?: string;\n43:   agentId?: string;\n44:   sessionId?: string;\n45:   provenanceSource?: string;\n46:   provenanceActor?: string;\n47:   governedAt?: string;\n48:   retentionPolicy?: 'keep' | 'ephemeral';\n49:   deleteAfter?: string;\n50: }\n51: \n52: interface MemoryIngestStatusArgs {\n53:   jobId: string;\n54: }\n55: \n56: interface MemoryIngestCancelArgs {\n57:   jobId: string;\n58: }\n59: \n60: /* ───────────────────────────────────────────────────────────────\n61:    3. CONSTANTS\n62: ──────────────────────────────────────────────────────────────── */\n63: \n64: const MAX_PATH_LENGTH = 500;\n65: \n66: /* ───────────────────────────────────────────────────────────────\n67:    4. HELPERS\n68: ──────────────────────────────────────────────────────────────── */\n69: \n70: function hasTraversalSegment(inputPath: string): boolean {\n71:   return inputPath.split(/[\\\\/]+/).includes('..');\n72: }\n73: \n74: function toPublicPathLabel(filePath: string): string {\n75:   return filePath === '__job__' ? filePath : path.basename(filePath || '');\n76: }\n77: \n78: function mapJobForResponse(job: IngestJob): Record<string, unknown> {\n79:   let forecast: Record<string, unknown>;\n80:   try {\n81:     forecast = getIngestForecast(job) as unknown as Record<string, unknown>;\n82:   } catch (error: unknown) {\n83:     const message = error instanceof Error ? error.message : String(error);\n84:     forecast = {\n85:       etaSeconds: null,\n86:       etaConfidence: null,\n87:       failureRisk: null,\n88:       riskSignals: [],\n89:       caveat: `Forecast unavailable: ${message}`,\n90:     };\n91:   }\n92: \n93:   let telemetryPayload: Record<string, unknown> | undefined;\n94:   if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n95:     const telemetry = retrievalTelemetry.createTelemetry();\n96:     retrievalTelemetry.recordLifecycleForecastDiagnostics(telemetry, forecast, {\n97:       state: job.state,\n98:       progress: getIngestProgressPercent(job),\n99:       filesProcessed: job.filesProcessed,\n100:       filesTotal: job.filesTotal,\n101:     });\n102:     telemetryPayload = retrievalTelemetry.toJSON(telemetry);\n103:   }\n104: \n105:   return {\n106:     jobId: job.id,\n107:     state: job.state,\n108:     specFolder: job.specFolder,\n109:     paths: job.paths.map((entry) => toPublicPathLabel(entry)),\n110:     filesTotal: job.filesTotal,\n111:     filesProcessed: job.filesProcessed,\n112:     progress: getIngestProgressPercent(job),\n113:     errors: job.errors.map((entry) => ({\n114:       ...entry,\n115:       filePath: toPublicPathLabel(entry.filePath),\n116:     })),\n117:     createdAt: job.createdAt,\n118:     updatedAt: job.updatedAt,\n119:     forecast: forecast as unknown as Record<string, unknown>,\n120:     ...(telemetryPayload ? { _telemetry: telemetryPayload } : {}),\n121:   };\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    5. HANDLERS\n126: ──────────────────────────────────────────────────────────────── */\n127: \n128: /** Handle memory_ingest_start tool — begins batch ingestion of spec documents from disk.\n129:  * @param args - Ingest arguments (paths, scope, options)\n130:  * @returns MCP response with job ID and forecast\n131:  */\n132: async function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n133:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n134:   await checkDatabaseUpdated();\n135:   const governedIngest = requiresGovernedIngest(args);\n136:   const governanceDecision = validateGovernedIngest(args);\n137:   if (!governanceDecision.allowed) {\n138:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n139:   }\n140: \n141:   let paths = Array.isArray(args.paths)\n142:     ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n143:     : [];\n144: \n145:   if (paths.length === 0) {\n146:     throw new Error('paths must be a non-empty array of file paths');\n147:   }\n148: \n149:   if (paths.length > MAX_INGEST_PATHS) {\n150:     throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n151:   }\n152: \n153:   const overlengthPaths = paths\n154:     .filter((entry) => entry.length > MAX_PATH_LENGTH)\n155:     .map((entry) => ({\n156:       filePath: toPublicPathLabel(entry),\n157:       reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n158:     }));\n159:   const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n160:   if (withinLength.length !== paths.length) {\n161:     console.warn(\n162:       `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n163:     );\n164:   }\n165:   paths = withinLength;\n166: \n167:   if (paths.length === 0) {\n168:     throw new Error('paths must be a non-empty array of file paths');\n169:   }\n170: \n171:   const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n172:   const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n173:     ? path.resolve(process.cwd(), configuredMemoryRoot)\n174:     : path.resolve(path.dirname(DATABASE_PATH));\n175:   const allowedBasePaths = Array.from(\n176:     new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n177:   );\n178: \n179:   const normalizedPaths: string[] = [];\n180:   const invalidPaths: Array<{ input: string; reason: string }> = [];\n181: \n182:   for (const inputPath of paths) {\n183:     const trimmedPath = inputPath.trim();\n184: \n185:     if (hasTraversalSegment(trimmedPath)) {\n186:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n187:       continue;\n188:     }\n189: \n190:     const resolvedPath = path.resolve(trimmedPath);\n191: \n192:     const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n193:     if (hasTraversalAfterResolve) {\n194:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n195:       continue;\n196:     }\n197: \n198:     // Resolve symlinks so traversal checks apply to canonical targets.\n199:     let realPath: string;\n200:     try {\n201:       realPath = fs.realpathSync(resolvedPath);\n202:     } catch {\n203:       // Fall back to resolvedPath during pre-validation when target does not yet exist.\n204:       realPath = resolvedPath;\n205:     }\n206: \n207:     const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n208:       realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n209:     ));\n210:     if (!isWithinAllowedBase) {\n211:       invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n212:       continue;\n213:     }\n214: \n215:     normalizedPaths.push(realPath);\n216:   }\n217: \n218:   if (invalidPaths.length > 0) {\n219:     return createMCPErrorResponse({\n220:       tool: 'memory_ingest_start',\n221:       error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n222:       code: 'E_VALIDATION',\n223:       details: {\n224:         allowedBasePathCount: allowedBasePaths.length,\n225:         allowedPathPolicy: 'configured-memory-roots',\n226:         rejectedCount: invalidPaths.length,\n227:       },\n228:       recovery: {\n229:         hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n230:         actions: ['Use absolute paths rooted in the configured memory base path'],\n231:         severity: 'warning',\n232:       },\n233:     });\n234:   }\n235: \n236:   const deduplicatedPaths: string[] = [];\n237:   const seenPaths = new Set<string>();\n238:   let duplicatePathCount = 0;\n239: \n240:   for (const normalizedPath of normalizedPaths) {\n241:     if (seenPaths.has(normalizedPath)) {\n242:       duplicatePathCount++;\n243:       continue;\n244:     }\n245: \n246:     seenPaths.add(normalizedPath);\n247:     deduplicatedPaths.push(normalizedPath);\n248:   }\n249: \n250:   paths = deduplicatedPaths;\n251: \n252:   const jobId = createJobId();\n253:   const job = await createIngestJob({\n254:     id: jobId,\n255:     paths,\n256:     specFolder: args.specFolder,\n257:     governance: governedIngest ? governanceDecision : null,\n258:   });\n259: \n260:   enqueueIngestJob(job.id);\n261: \n262:   return createMCPSuccessResponse({\n263:     tool: 'memory_ingest_start',\n264:     summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n265:     data: {\n266:       jobId: job.id,\n267:       state: job.state,\n268:       filesTotal: job.filesTotal,\n269:       acceptedPathCount: paths.length,\n270:       rejectedPathCount: overlengthPaths.length,\n271:       ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n272:       ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n273:     },\n274:     hints: [\n275:       'Use memory_ingest_status with jobId to poll progress',\n276:       'Use memory_ingest_cancel with jobId to stop processing',\n277:       ...(duplicatePathCount > 0\n278:         ? ['Duplicate input paths were deduplicated before queueing']\n279:         : []),\n280:       ...(overlengthPaths.length > 0\n281:         ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n282:         : []),\n283:     ],\n284:   });\n285: }\n286: \n287: async function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {\n288:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_status');\n289:   await checkDatabaseUpdated();\n290: \n291:   if (!args.jobId || typeof args.jobId !== 'string') {\n292:     throw new Error('jobId is required and must be a string');\n293:   }\n294: \n295:   const job = getIngestJob(args.jobId);\n296:   if (!job) {\n297:     return createMCPErrorResponse({\n298:       tool: 'memory_ingest_status',\n299:       error: `Ingest job not found: ${args.jobId}`,\n300:       code: 'E404',\n301:       details: { jobId: args.jobId },\n302:       recovery: {\n303:         hint: 'Verify the jobId and retry.',\n304:         actions: ['Call memory_ingest_start to create a new ingest job'],\n305:         severity: 'warning',\n306:       },\n307:     });\n308:   }\n309: \n310:   return createMCPSuccessResponse({\n311:     tool: 'memory_ingest_status',\n312:     summary: `Ingest job ${job.id}: ${job.state} (${job.filesProcessed}/${job.filesTotal})`,\n313:     data: mapJobForResponse(job),\n314:   });\n315: }\n316: \n317: async function handleMemoryIngestCancel(args: MemoryIngestCancelArgs): Promise<MCPResponse> {\n318:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_cancel');\n319:   await checkDatabaseUpdated();\n320: \n321:   if (!args.jobId || typeof args.jobId !== 'string') {\n322:     throw new Error('jobId is required and must be a string');\n323:   }\n324: \n325:   const job = getIngestJob(args.jobId);\n326:   if (!job) {\n327:     return createMCPErrorResponse({\n328:       tool: 'memory_ingest_cancel',\n329:       error: `Ingest job not found: ${args.jobId}`,\n330:       code: 'E404',\n331:       details: { jobId: args.jobId },\n332:       recovery: {\n333:         hint: 'Verify the jobId and retry.',\n334:         actions: ['Call memory_ingest_status with a known jobId'],\n335:         severity: 'warning',\n336:       },\n337:     });\n338:   }\n339: \n340:   if (job.state === 'complete' || job.state === 'failed' || job.state === 'cancelled') {\n341:     return createMCPSuccessResponse({\n342:       tool: 'memory_ingest_cancel',\n343:       summary: `Ingest job ${job.id} is already terminal (${job.state})`,\n344:       data: mapJobForResponse(job),\n345:     });\n346:   }\n347: \n348:   const cancelled = await cancelIngestJob(args.jobId);\n349:   const summary = cancelled.state === 'cancelled'\n350:     ? `Cancelled ingest job ${cancelled.id}`\n351:     : `Ingest job ${cancelled.id} is already terminal (${cancelled.state})`;\n352: \n353:   return createMCPSuccessResponse({\n354:     tool: 'memory_ingest_cancel',\n355:     summary,\n356:     data: mapJobForResponse(cancelled),\n357:   });\n358: }\n359: \n360: /* ───────────────────────────────────────────────────────────────\n361:    6. EXPORTS\n362: ──────────────────────────────────────────────────────────────── */\n363: \n364: const handle_memory_ingest_start = handleMemoryIngestStart;\n365: const handle_memory_ingest_status = handleMemoryIngestStatus;\n366: const handle_memory_ingest_cancel = handleMemoryIngestCancel;\n367: \n368: export {\n369:   handleMemoryIngestStart,\n370:   handleMemoryIngestStatus,\n371:   handleMemoryIngestCancel,\n372:   handle_memory_ingest_start,\n373:   handle_memory_ingest_status,\n374:   handle_memory_ingest_cancel,\n375: };\n\n(End of file - total 375 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Ingest Handlers\n// ───────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\n\nimport { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\nimport { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  createIngestJob,\n  enqueueIngestJob,\n  getIngestJob,\n  cancelIngestJob,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Ingest Handlers\n// ───────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\n\nimport { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\nimport { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  createIngestJob,\n  enqueueIngestJob,\n  getIngestJob,\n  cancelIngestJob,\n  getIngestProgressPercent,\n  getIngestForecast,\n  type IngestJob,\n} from '../lib/ops/job-queue.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { createJobId } from '../lib/ops/job-store.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Async ingestion job lifecycle\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface MemoryIngestStartArgs {\n  paths: string[];\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\ninterface MemoryIngestStatusArgs {\n  jobId: string;\n}\n\ninterface MemoryIngestCancelArgs {\n  jobId: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nconst MAX_PATH_LENGTH = 500;\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction hasTraversalSegment(inputPath: string): boolean {\n  return inputPath.split(/[\\\\/]+/).includes('..');\n}\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction mapJobForResponse(job: IngestJob): Record<string, unknown> {\n  let forecast: Record<string, unknown>;\n  try {\n    forecast = getIngestForecast(job) as unknown as Record<string, unknown>;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    forecast = {\n      etaSeconds: null,\n      etaConfidence: null,\n      failureRisk: null,\n      riskSignals: [],\n      caveat: `Forecast unavailable: ${message}`,\n    };\n  }\n\n  let telemetryPayload: Record<string, unknown> | undefined;\n  if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n    const telemetry = retrievalTelemetry.createTelemetry();\n    retrievalTelemetry.recordLifecycleForecastDiagnostics(telemetry, forecast, {\n      state: job.state,\n      progress: getIngestProgressPercent(job),\n      filesProcessed: job.filesProcessed,\n      filesTotal: job.filesTotal,\n    });\n    telemetryPayload = retrievalTelemetry.toJSON(telemetry);\n  }\n\n  return {\n    jobId: job.id,\n    state: job.state,\n    specFolder: job.specFolder,\n    paths: job.paths.map((entry) => toPublicPathLabel(entry)),\n    filesTotal: job.filesTotal,\n    filesProcessed: job.filesProcessed,\n    progress: getIngestProgressPercent(job),\n    errors: job.errors.map((entry) => ({\n      ...entry,\n      filePath: toPublicPathLabel(entry.filePath),\n    })),\n    createdAt: job.createdAt,\n    updatedAt: job.updatedAt,\n    forecast: forecast as unknown as Record<string, unknown>,\n    ...(telemetryPayload ? { _telemetry: telemetryPayload } : {}),\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. HANDLERS\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_ingest_start tool — begins batch ingestion of spec documents from disk.\n * @param args - Ingest arguments (paths, scope, options)\n * @returns MCP response with job ID and forecast\n */\nasync function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n  await checkDatabaseUpdated();\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  let paths = Array.isArray(args.paths)\n    ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n    : [];\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  if (paths.length > MAX_INGEST_PATHS) {\n    throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n  }\n\n  const overlengthPaths = paths\n    .filter((entry) => entry.length > MAX_PATH_LENGTH)\n    .map((entry) => ({\n      filePath: toPublicPathLabel(entry),\n      reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n    }));\n  const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n  if (withinLength.length !== paths.length) {\n    console.warn(\n      `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n    );\n  }\n  paths = withinLength;\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n  const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n    ? path.resolve(process.cwd(), configuredMemoryRoot)\n    : path.resolve(path.dirname(DATABASE_PATH));\n  const allowedBasePaths = Array.from(\n    new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n  );\n\n  const normalizedPaths: string[] = [];\n  const invalidPaths: Array<{ input: string; reason: string }> = [];\n\n  for (const inputPath of paths) {\n    const trimmedPath = inputPath.trim();\n\n    if (hasTraversalSegment(trimmedPath)) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    const resolvedPath = path.resolve(trimmedPath);\n\n    const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n    if (hasTraversalAfterResolve) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    // Resolve symlinks so traversal checks apply to canonical targets.\n    let realPath: string;\n    try {\n      realPath = fs.realpathSync(resolvedPath);\n    } catch {\n      // Fall back to resolvedPath during pre-validation when target does not yet exist.\n      realPath = resolvedPath;\n    }\n\n    const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n      realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n    ));\n    if (!isWithinAllowedBase) {\n      invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n      continue;\n    }\n\n    normalizedPaths.push(realPath);\n  }\n\n  if (invalidPaths.length > 0) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_start',\n      error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n      code: 'E_VALIDATION',\n      details: {\n        allowedBasePathCount: allowedBasePaths.length,\n        allowedPathPolicy: 'configured-memory-roots',\n        rejectedCount: invalidPaths.length,\n      },\n      recovery: {\n        hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n        actions: ['Use absolute paths rooted in the configured memory base path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const deduplicatedPaths: string[] = [];\n  const seenPaths = new Set<string>();\n  let duplicatePathCount = 0;\n\n  for (const normalizedPath of normalizedPaths) {\n    if (seenPaths.has(normalizedPath)) {\n      duplicatePathCount++;\n      continue;\n    }\n\n    seenPaths.add(normalizedPath);\n    deduplicatedPaths.push(normalizedPath);\n  }\n\n  paths = deduplicatedPaths;\n\n  const jobId = createJobId();\n  const job = await createIngestJob({\n    id: jobId,\n    paths,\n    specFolder: args.specFolder,\n    governance: governedIngest ? governanceDecision : null,\n  });\n\n  enqueueIngestJob(job.id);\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_start',\n    summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n    data: {\n      jobId: job.id,\n      state: job.state,\n      filesTotal: job.filesTotal,\n      acceptedPathCount: paths.length,\n      rejectedPathCount: overlengthPaths.length,\n      ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n      ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n    },\n    hints: [\n      'Use memory_ingest_status with jobId to poll progress',\n      'Use memory_ingest_cancel with jobId to stop processing',\n      ...(duplicatePathCount > 0\n        ? ['Duplicate input paths were deduplicated before queueing']\n        : []),\n      ...(overlengthPaths.length > 0\n        ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n        : []),\n    ],\n  });\n}\n\nasync function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_status');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getIngestJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_status',\n      error: `Ingest job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_ingest_start to create a new ingest job'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_status',\n    summary: `Ingest job ${job.id}: ${job.state} (${job.filesProcessed}/${job.filesTotal})`,\n    data: mapJobForResponse(job),\n  });\n}\n\nasync function handleMemoryIngestCancel(args: MemoryIngestCancelArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_cancel');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getIngestJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_cancel',\n      error: `Ingest job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_ingest_status with a known jobId'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (job.state === 'complete' || job.state === 'failed' || job.state === 'cancelled') {\n    return createMCPSuccessResponse({\n      tool: 'memory_ingest_cancel',\n      summary: `Ingest job ${job.id} is already terminal (${job.state})`,\n      data: mapJobForResponse(job),\n    });\n  }\n\n  const cancelled = await cancelIngestJob(args.jobId);\n  const summary = cancelled.state === 'cancelled'\n    ? `Cancelled ingest job ${cancelled.id}`\n    : `Ingest job ${cancelled.id} is already terminal (${cancelled.state})`;\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_cancel',\n    summary,\n    data: mapJobForResponse(cancelled),\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nconst handle_memory_ingest_start = handleMemoryIngestStart;\nconst handle_memory_ingest_status = handleMemoryIngestStatus;\nconst handle_memory_ingest_cancel = handleMemoryIngestCancel;\n\nexport {\n  handleMemoryIngestStart,\n  handleMemoryIngestStatus,\n  handleMemoryIngestCancel,\n  handle_memory_ingest_start,\n  handle_memory_ingest_status,\n  handle_memory_ingest_cancel,\n};","lineStart":1,"lineEnd":375,"totalLines":375,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","time":{"start":1781762655596,"end":1781762655599}},"metadata":{"openai":{"itemId":"fc_0f557bc5edd26ece016a338a5f55b481918604e7adcd422c6d"}},"id":"prt_ed954855c001ZX1tDIJt3iHqah","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed95450c2001zQmWt1hLuMiS0E"}}
