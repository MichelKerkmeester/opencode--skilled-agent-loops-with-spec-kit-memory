t result = await harness.module.indexMemoryFile(filePath, { force: true, asyncEmbedding: false });\n\n  Line 3089:       const result = await harness.module.indexMemoryFile(filePath, { force: true, asyncEmbedding: false });\n\n  Line 3337:       const result = await harness.module.indexMemoryFile(filePath, { force: true, asyncEmbedding: false });\n\n  Line 3387:       const result = await harness.module.indexMemoryFile(filePath, { force: true, asyncEmbedding: false });\n\n  Line 3496:       const result = await harness.module.indexMemoryFile(filePath, { force: true, asyncEmbedding: false, plannerMode: 'full-auto' });\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/job-queue.vitest.ts:\n  Line 134:     mod.initIngestJobQueue({\n\n  Line 135:       processFile: async () => undefined,\n\n  Line 176:     mod.initIngestJobQueue({\n\n  Line 177:       processFile: async () => {\n\n  Line 208:     mod.initIngestJobQueue({\n\n  Line 209:       processFile: async () => undefined,\n\n  Line 269:     mod.initIngestJobQueue({\n\n  Line 270:       processFile: async () => undefined,\n\n  Line 308:     mod.initIngestJobQueue({\n\n  Line 309:       processFile: async (filePath: string) => {\n\n  Line 361:     mod.initIngestJobQueue({ processFile: async () => undefined });\n\n  Line 400:     mod.initIngestJobQueue({\n\n  Line 401:       processFile: async () => {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/context-server.vitest.ts:\n  Line 1109:       vi.doMock('../lib/ops/job-queue', () => ({ initIngestJobQueue: vi.fn(() => ({ resetCount: 0 })) }))\n\n  Line 1110:       vi.doMock('../lib/ops/job-queue.js', () => ({ initIngestJobQueue: vi.fn(() => ({ resetCount: 0 })) }))\n\n  Line 2579:       expect(sourceCode).toMatch(/processFile:\\s*async\\s*\\(filePath:\\s*string,\\s*governance\\)\\s*=>\\s*\\{[\\s\\S]*?await\\s+indexSingleFile\\(filePath,\\s*false[,)][\\s\\S]*?\\}/)\n","metadata":{"matches":66,"truncated":false},"title":"initIngestJobQueue|processFileFn|processFile:|indexMemoryFile\\(","time":{"start":1781764280983,"end":1781764281014}},"metadata":{"openai":{"itemId":"fc_0d768e0346ccaccc016a3390b83624819187eb5efad5a49b7f"}},"id":"prt_ed96d4fb30012HH2tar9z3ARH1","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96cfef5001DH3erQ96808yxK"}}
