xpectedResources = extractPaths(refBlock);\n134:   const expectedAssets = extractPaths(assetBlock);\n135: \n136:   // Negative activation: the skill should NOT route here (UNKNOWN surface,\n137:   // disambiguation expected, or advisor must pick another skill).\n138:   const lowerPass = (passCriteria || '').toLowerCase();\n139:   const negativeActivation = expectedSurface === 'UNKNOWN'\n140:     || /disambiguation|must not|asks? for clarification|top-1\\s*!=\\s*sk-code|routes? .* to sk-doc/.test(lowerPass)\n141:     || /\\bUNKNOWN\\b/.test(text.split('\\n').slice(0, 30).join('\\n'));\n142: \n143:   const classKind = classifyKind(id, category, expectedSurface, passCriteria);\n144: \n145:   return {\n146:     scenarioId: id,\n147:     category: category || null,\n148:     prompt: prompt || null,\n149:     classKind,\n150:     expectedSurface,\n151:     expectedSubLanguage: subLangM ? subLangM[1].toUpperCase() : null,\n152:     expectedIntent: null,\n153:     expectedResources,\n154:     expectedAssets,\n155:     passCriteria,\n156:     critical: !!critical,\n157:     negativeActivation,\n158:     source: { featureFile: path.relative(path.dirname(path.dirname(absPath)), absPath), shape: 'sk-code' },\n159:     parseWarnings: prompt ? [] : ['missing-exact-prompt'],\n160:   };\n161: }\n162: \n163: // Parse the root index table mapping id -> {category, featureFile, critical}.\n164: function parseRootIndex(rootText) {\n165:   const idx = [];\n166:   const secStart = rootText.search(/##\\s+\\d+\\.\\s+FEATURE CATALOG CROSS-REFERENCE INDEX/i);\n167:   const scope = secStart === -1 ? rootText : rootText.slice(secStart);\n168:   for (const line of scope.split('\\n')) {\n169:     // Row shape parsed below: | <category> | <AA-000> | `<feature-file>.md` | <Yes|No> |\n170:     const m = /^\\|\\s*([^|]+?)\\s*\\|\\s*([A-Z]{2}-\\d{3})\\s*\\|\\s*`?([^|`]+?\\.md)`?\\s*\\|\\s*(Yes|No)\\s*\\|/.exec(line);\n171:     if (m) {\n172:       idx.push({\n173:         categoryLabel: m[1].trim(),\n174:         scenarioId: m[2],\n175:         featureFile: m[3].trim(),\n176:         critical: /yes/i.test(m[4]),\n177:       });\n178:     }\n179:   }\n\n(Showing lines 110-179 of 271. Use offset=180 to continue.)\n</content>","metadata":{"preview":"  return map;\n}\n\nfunction parseFeatureFile(absPath, scenarioId, category, critical, rootEntry) {\n  const text = readFileSafe(absPath);\n  if (!text) return null;\n\n  const fmId = (/title:\\s*[\"']?([A-Z]{2}-\\d{3})/.exec(text) || [])[1];\n  const id = scenarioId || fmId;\n  if (!id) return null;\n\n  const prompt = parsePromptBlock(text) || (rootEntry && rootEntry.prompt) || null;\n  // Per-feature files vary: \"- Surface: `WEBFLOW`\" (SD/LS) vs \"**Expected surface**: `WEBFLOW`\" (CS).\n  const surfaceM = /(?:Expected\\s+)?Surface\\*{0,2}:\\s*`?([A-Za-z_]+)`?/i.exec(text);\n  const subLangM = /Sub-language:\\s*`?([A-Za-z]+)`?/i.exec(text);\n  const refBlock = sectionAfter(text, /\\*\\*Expected references loaded\\*\\*/i);\n  const assetBlock = sectionAfter(text, /\\*\\*Expected assets loaded\\*\\*/i);\n  const passM = /###?\\s*Pass\\/Fail Criteria\\s*([\\s\\S]*?)(?:\\n###?\\s|\\n##\\s|$)/i.exec(text);\n  const passCriteria = (passM ? passM[1].trim() : null) || (rootEntry && rootEntry.passCriteria) || null;\n","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/load-playbook-scenarios.cjs","time":{"start":1780372913324,"end":1780372913334}},"metadata":{"openai":{"itemId":"fc_0d043a952c0dcb44016a1e55b140048191b830dce36f9ad60a"}},"id":"prt_e867ebc9e0016eLVacnoStQ8cD","sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","messageID":"msg_e867e99f5001cs5nt7kwjsq0Fn"}}
