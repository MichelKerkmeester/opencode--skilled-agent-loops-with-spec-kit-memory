{
  "color": {
    "obsidian": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Obsidian — Deepest background, hero image overlay, footer canvas, shadow base — pure black creates cinematic depth behind atmospheric photography"
    },
    "onyx": {
      "$value": "#0f0d0d",
      "$type": "color",
      "$description": "Onyx — Primary page canvas (--bg), card surface, default button fill — the warm-tinted near-black that grounds the entire interface"
    },
    "charcoal": {
      "$value": "#171615",
      "$type": "color",
      "$description": "Charcoal — Raised surface, dark button background (--button-dark-bg), elevated cards — one step lighter than the canvas to signal depth without drawing attention"
    },
    "graphite": {
      "$value": "#262828",
      "$type": "color",
      "$description": "Graphite — Stepped feature panels, image containers, secondary surface layer — visible in side-by-side comparison modules"
    },
    "void": {
      "$value": "#050404",
      "$type": "color",
      "$description": "Void — Near-black used in box-shadow tints and image depth effects — effectively black but with a barely-warm undertone matching Onyx"
    },
    "paper": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Paper — Primary text, icons, light button text, filled button surface (--primary) — pure white on near-black achieves 19:1 contrast, the highest readable tier"
    },
    "ash": {
      "$value": "#878686",
      "$type": "color",
      "$description": "Ash — Secondary body text, descriptive copy, helper labels — sits at ~50% luminance, legible without competing with headlines"
    },
    "smoke": {
      "$value": "#6f6e6e",
      "$type": "color",
      "$description": "Smoke — Tertiary text, decorative fills, disabled states, muted metadata — low-contrast informational layer"
    },
    "fog": {
      "$value": "#939292",
      "$type": "color",
      "$description": "Fog — Mid-tone body text, inline labels, muted paragraph text — the readable middle gray for longer descriptions"
    },
    "ember-red": {
      "$value": "#fe2c02",
      "$type": "color",
      "$description": "Ember Red — Saturated accent for highlight cards and feature panels — the single chromatic punctuation in an otherwise monochrome system, evokes urgency and warmth without aggression"
    }
  },
  "font": {
    "gigasanstext": {
      "$value": "gigaSansText",
      "$type": "fontFamily",
      "$description": "Body text, buttons, navigation, links — the workhorse. Weight 400 for paragraphs, 500 for button labels and emphasis. 16px at 1.5 line-height is the readable default; 14px at 1.43 handles dense UI chrome."
    },
    "emiliodisplay": {
      "$value": "emilioDisplay",
      "$type": "fontFamily",
      "$description": "Display headlines — the signature voice. Ultra-light weight at 48-66px with tight -0.02em to -0.03em tracking creates a film-title-card feel. Most enterprise brands shout with 700-weight headlines; Giga whispers with 300, which is the entire personality in one choice."
    },
    "gigasansdisplay": {
      "$value": "gigaSansDisplay",
      "$type": "fontFamily",
      "$description": "Section subheadings, feature card titles, prominent UI labels — bridges the gap between whisper-thin display and body text. Weight 500 at 22px carries mid-importance statements."
    },
    "intertext": {
      "$value": "interText",
      "$type": "fontFamily",
      "$description": "Large numerical and functional headings — 44px with -0.03em tracking for stat callouts and mid-level headings. Acts as a contrast voice to the emilioDisplay serif displays."
    },
    "geistmono": {
      "$value": "geistMono",
      "$type": "fontFamily",
      "$description": "Micro-labels, badges, tags, version markers, uppercase metadata — always uppercase with +0.007em to +0.009em tracking. The 11-12px range with 2.0+ line-height creates spacious technical annotations."
    },
    "interdisplay": {
