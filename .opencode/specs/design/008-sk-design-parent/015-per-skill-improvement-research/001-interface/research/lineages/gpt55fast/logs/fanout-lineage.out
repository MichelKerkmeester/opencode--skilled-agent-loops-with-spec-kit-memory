16:         \"d2\": {\n417:           \"score\": 1,\n418:           \"proxy\": \"router-replay-recall\",\n419:           \"note\": \"Mode A proxy; live-mode replaces with observed-load Hit@k/Recall@k/MRR\"\n420:         },\n421:         \"d3\": {\n422:           \"score\": 0.16666666666666663,\n423:           \"routedCount\": 6,\n424:           \"wastedCount\": 5,\n425:           \"proxy\": \"router-overload\",\n426:           \"note\": \"Mode A proxy; live-mode replaces with calls/tokens-to-first-expected\"\n427:         },\n428:         \"assetRecall\": {\n429:           \"score\": null,\n430:           \"note\": \"no expected assets for this scenario\"\n431:         },\n432:         \"d1inter\": {\n433:           \"score\": null,\n434:           \"unscored\": \"no advisor probe (run with --advisor-mode=python)\"\n435:         },\n436:         \"d4\": {\n437:           \"score\": null,\n438:           \"unscored\": \"requires skill-on/off ablation (live mode)\"\n439:         },\n440:         \"modePrecision\": {\n441:           \"score\": null,\n442:           \"expectedMode\": null,\n443:           \"observedMode\": null,\n444:           \"advisory\": true,\n445:           \"unscored\": \"fixture carries no expected.mode\"\n446:         }\n447:       },\n448:       \"firstFailingStage\": null,\n449:       \"modeAScore\": 63,\n450:       \"applicable\": true,\n451:       \"classKind\": \"routing\",\n452:       \"expectedSurface\": null,\n453:       \"observedSurface\": \"UNKNOWN\",\n454:       \"surfaceMatch\": null,\n455:       \"traceMode\": \"live\",\n456:       \"liveEvidence\": {\n457:         \"eventCount\": 6,\n458:         \"activated\": false,\n459:         \"toolCalls\": [\n460:           \"read\"\n461:         ],\n462:         \"observedReads\": [],\n463:         \"statedRoutingParsed\": true,\n464:         \"responseHead\": \"```json\\n{\\n  \\\"surface\\\": \\\"UNKNOWN\\\",\\n  \\\"subLanguage\\\": \\\"none\\\",\\n  \\\"resources\\\": [\\n    \\\"refe