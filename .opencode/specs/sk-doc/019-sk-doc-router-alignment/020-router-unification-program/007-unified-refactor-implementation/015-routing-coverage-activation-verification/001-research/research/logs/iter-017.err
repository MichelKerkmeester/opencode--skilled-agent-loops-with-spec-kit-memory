    97	
    98	if __name__ == "__main__":
    99	    sys.exit(main(sys.argv[1:]))
   190	
   191	def _is_within(path: PurePosixPath, root: PurePosixPath) -> bool:
   192	    return path == root or root in path.parents
   193	
   194	
   195	def _is_tree_exempt(
   196	    path: PurePosixPath,
   197	    completed_spec_roots: set[PurePosixPath],
   198	) -> bool:
   199	    """Return whether a path belongs to an entirely exempt subtree."""
   200	    if any(_is_within(path, root) for root in CODEX_GENERATED_ROOTS):
   201	        return True
   202	    if any(_is_within(path, root) for root in completed_spec_roots):
   203	        return True
   204	
   205	    parts = set(path.parts)
   206	    return bool(
   207	        parts
   208	        & (
   209	            VENDORED_ROOT_NAMES
   210	            | GENERATED_ROOT_NAMES
   211	            | TEST_RUNNER_ROOT_NAMES
   212	            | FROZEN_ROOT_NAMES
   213	            | REPOSITORY_METADATA_ROOT_NAMES
   214	        )
   215	    )
   216	
   217	
   218	def _name_stem(name: str) -> str:
   219	    """Return the authored portion before the first extension."""
   220	    visible_name = name[1:] if name.startswith(".") else name
   221	    return visible_name.split(".", 1)[0]
   222	
   223	
   224	def _uses_snake_case(name: str) -> bool:
   225	    """Return whether a filesystem name uses underscore-separated words."""
   226	    resolved_root = canonical_root(name)
   227	    if resolved_root is not None:
   228	        return name != resolved_root
   229	    return bool(SNAKE_CASE.search(_name_stem(name)))
   230	
   231	
   232	def _is_python_package_dir(repo_root: Path, path: PurePosixPath) -> bool:
   233	    """Recognize regular and namespace-style Python package directories."""
   234	    physical_path = repo_root.joinpath(*path.parts)
   235	    if not physical_path.is_dir() or not path.name.isidentifier():
   236	        return False
   237	    try:
   238	        children = tuple(physical_path.iterdir())
   239	    except OSError:
   240	        return False
   241	    return any(child.name in {"__init__.py", "py.typed"} for child in children) or any(
   242	        child.is_file() and child.suffix == ".py" for child in children
   243	    )
   244	
   245	
   246	def _is_name_exempt(repo_root: Path, path: PurePosixPath, is_dir: bool) -> bool:
   247	    """Return whether the path's own basename has an exact-name exemption."""
   248	    name = path.name
   249	    if name in TOOL_MANDATED_NAMES or name in LOCKFILE_NAMES:
   250	        return True
   251	    if name.endswith(GENERATED_SUFFIXES):
   252	        return True
   253	    if not is_dir and name.endswith(".py"):
   254	        return True
   255	    if is_dir and _is_python_package_dir(repo_root, path):
   256	        return True
   257	    return False
   258	
   259	
   260	def _candidate_prefixes(path: PurePosixPath) -> Iterable[PurePosixPath]:
   261	    parts: list[str] = []
   262	    for part in path.parts:
   263	        parts.append(part)
   264	        yield PurePosixPath(*parts)
   265	
   266	
   267	def changed_since_offenders(repo_root: Path, ref: str) -> list[PurePosixPath]:
   268	    """Find newly introduced in-scope snake_case names since ``ref``."""
   269	    base_paths = _all_ref_paths(repo_root, ref)
   270	    completed_at_base = _completed_spec_roots(base_paths)
   271	    offenders: set[PurePosixPath] = set()
   272	
   273	    for changed_path in _changed_destinations(repo_root, ref):
   274	        for candidate in _candidate_prefixes(changed_path):
   275	            if candidate in base_paths or _is_tree_exempt(candidate, completed_at_base):
   276	                continue
   277	            physical_path = repo_root.joinpath(*candidate.parts)
   278	            is_dir = candidate != changed_path or physical_path.is_dir()
   279	            if _uses_snake_case(candidate.name) and not _is_name_exempt(
   280	                repo_root, candidate, is_dir
   281	            ):
   282	                offenders.add(candidate)
   283	
   284	    return sorted(offenders, key=lambda path: path.as_posix())
   285	
   286	
   287	def _current_completed_spec_roots(repo_root: Path) -> set[PurePosixPath]:
   288	    specs_root = repo_root / ".opencode" / "specs"
   289	    if not specs_root.is_dir():
   290	        return set()
   291	    roots = set()
   292	    for marker in specs_root.rglob("implementation-summary.md"):
   293	        roots.add(PurePosixPath(marker.parent.relative_to(repo_root).as_posix()))
   294	    return roots
   295	
   296	
   297	def all_offenders(repo_root: Path) -> list[PurePosixPath]:
   298	    """Find every current in-scope snake_case name in the repository tree."""
   299	    completed_spec_roots = _current_completed_spec_roots(repo_root)
   300	    offenders: set[PurePosixPath] = set()
   301	
   302	    for current_root, dir_names, file_names in os.walk(repo_root, topdown=True):
   303	        current = Path(current_root)
   304	        relative_current = current.relative_to(repo_root)
   305	        current_path = PurePosixPath(relative_current.as_posix())
   306	        if current_path != PurePosixPath(".") and _is_tree_exempt(
   307	            current_path, completed_spec_roots
   308	        ):
   309	            dir_names[:] = []
   310	            continue
   311	
   312	        retained_dirs = []
   313	        for name in sorted(dir_names):
   314	            path = current_path / name if current_path != PurePosixPath(".") else PurePosixPath(name)
   315	            if _is_tree_exempt(path, completed_spec_roots):
   316	                continue
   317	            retained_dirs.append(name)
   318	            if _uses_snake_case(name) and not _is_name_exempt(repo_root, path, True):
   319	                offenders.add(path)
   320	        dir_names[:] = retained_dirs
   321	
   322	        for name in sorted(file_names):
   323	            path = current_path / name if current_path != PurePosixPath(".") else PurePosixPath(name)
   324	            if _is_tree_exempt(path, completed_spec_roots):
   325	                continue
   326	            if _uses_snake_case(name) and not _is_name_exempt(repo_root, path, False):
   327	                offenders.add(path)
   328	
   329	    return sorted(offenders, key=lambda path: path.as_posix())
   330	
   331	
   332	def _print_result(offenders: Sequence[PurePosixPath], scope: str) -> int:
   333	    if not offenders:
   334	        print(f"PASS: no {scope} in-scope snake_case filesystem names found.")
   335	        return 0
   336	
   337	    print(f"FAIL: {len(offenders)} {scope} in-scope snake_case filesystem name(s) found:")
   338	    for offender in offenders:
   339	        print(f"  - {offender.as_posix()}")
   340	    return 1
   341	
   342	
   343	def parse_args(argv: Sequence[str]) -> argparse.Namespace:
   344	    parser = argparse.ArgumentParser(description=__doc__)
   345	    mode = parser.add_mutually_exclusive_group(required=True)
   346	    mode.add_argument("--changed-since", metavar="REF")
   347	    mode.add_argument("--all", action="store_true", dest="scan_all")
   348	    return parser.parse_args(argv)
   349	
   350	
   351	def main(argv: Sequence[str]) -> int:
   352	    args = parse_args(argv)
   353	    try:
   354	        repo_root = repository_root()
   355	        if args.scan_all:
   356	            return _print_result(all_offenders(repo_root), "current")
   357	        offenders = changed_since_offenders(repo_root, args.changed_since)
   358	        return _print_result(offenders, f"newly introduced since {args.changed_since}")
   359	    except GuardError as error:
   360	        print(f"ERROR: {error}", file=sys.stderr)
   361	        return 2
   362	
   363	
   364	if __name__ == "__main__":
   365	    sys.exit(main(sys.argv[1:]))

