        causalEdges.deleteEdgesForMemory(String(memory.id), {\n251:             reason: 'memory row mutation cleanup',\n252:             command: 'memory-crud-delete.handleMemoryDelete',\n253:             restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n254:           });\n255:         }\n256:       }\n257: \n258:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n259:       for (const deletedId of deletedIds) {\n260:         const snapshot = hashById.get(deletedId) ?? null;\n261:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n262:           mutationType: 'delete',\n263:           reason: 'memory_delete: bulk delete by spec folder',\n264:           priorHash: snapshot?.content_hash ?? null,\n265:           newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n266:           linkedMemoryIds: [deletedId],\n267:           decisionMeta: {\n268:             tool: 'memory_delete',\n269:             bulk: true,\n270:             specFolder,\n271:             checkpoint: checkpointName,\n272:             memoryId: deletedId,\n273:             filePath: snapshot?.file_path ?? null,\n274:           },\n275:           actor: 'mcp:memory_delete',\n276:         });\n277:         if (!ledgerRecorded) {\n278:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n279:         }\n280:       }\n281:     });\n282:     bulkDeleteTx();\n283:   }\n284: \n285:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n286:   if (deletedCount > 0) {\n287:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n288:     try {\n289:       postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n290:     } catch (hookError: unknown) {\n291:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n292:       postMutationHooks = {\n293:         latencyMs: 0, triggerCacheCleared: false,\n294:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n295:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n296:         errors: [msg],\n297:       };\n298:     }\n299:     postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n300:   }\n301: \n302:   const summary = deletedCount > 0\n303:     ? `Deleted ${deletedCount} memory(s)`\n304:     : 'No spec-doc records found to delete';\n305: \n306:   const hints: string[] = [];\n307:   if (checkpointName) {\n308:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n309:   }\n310:   if (deletedCount === 0) {\n311:     hints.push('Use memory_list() to find existing memories');\n312:   }\n313:   if (postMutationFeedback) {\n314:     hints.push(...postMutationFeedback.hints);\n315:   }\n316:   if (mutationLedgerWarning) {\n317:     hints.push(mutationLedgerWarning);\n318:   }\n319: \n320:   const data: Record<string, unknown> = { deleted: deletedCount };\n321:   if (checkpointName) {\n322:     data.checkpoint = checkpointName;\n323:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n324:   }\n325:   if (postMutationFeedback) {\n326:     data.postMutationHooks = postMutationFeedback.data;\n327:   }\n328:   if (mutationLedgerWarning) {\n329:     data.warning = mutationLedgerWarning;\n330:   }\n331: \n332:   return createMCPSuccessResponse({\n333:     tool: 'memory_delete',\n334:     summary,\n335:     data,\n336:     hints,\n337:   });\n338: }\n339: \n340: /* ───────────────────────────────────────────────────────────────\n341:    EXPORTS\n342: ──────────────────────────────────────────────────────────────── */\n343: \n344: export { handleMemoryDelete };\n\n(End of file - total 344 lines)\n</content>","metadata":{"preview":"        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id), {\n            reason: 'memory row mutation cleanup',\n            command: 'memory-crud-delete.handleMemoryDelete',\n            restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n          });\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: bulk delete by spec folder',\n          priorHash: snapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n          linkedMemoryIds: [deletedId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: true,\n            specFolder,\n            checkpoint: checkpointName,\n            memoryId: deletedId,\n            filePath: snapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    });\n    bulkDeleteTx();\n  }\n\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n  }\n\n  const summary = deletedCount > 0\n    ? `Deleted ${deletedCount} memory(s)`\n    : 'No spec-doc records found to delete';\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  }\n  if (deletedCount === 0) {\n    hints.push('Use memory_list() to find existing memories');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n\n  const data: Record<string, unknown> = { deleted: deletedCount };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (mutationLedgerWarning) {\n    data.warning = mutationLedgerWarning;\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport { handleMemoryDelete };","lineStart":221,"lineEnd":344,"totalLines":344,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781762036648,"end":1781762036657}},"metadata":{"openai":{"itemId":"fc_0b50bd46bc0ce1ad016a3387f45afc819199281d512b6c289c"}},"id":"prt_ed94b13a1001ppxYyb6uKq4TcU","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94aed360019KK8P6LBX130rw"}}
{"type":"tool_use","timestamp":1781762036659,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_qtYHxu3YDmm68u4FdSXhS0u4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","offset":1,"limit":280},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Checkpoints\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    1. LIB MODULE IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import * as checkpoints from '../lib/storage/checkpoints.js';\n10: import * as vectorIndex from '../lib/search/vector-index.js';\n11: import * as bm25Index from '../lib/search/bm25-index.js';\n12: import * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\n13: import * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\n14: import { executeAutoPromotion } from '../lib/search/auto-promotion.js';\n15: import { recordSelection } from '../lib/search/learned-feedback.js';\n16: import { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\n17: import { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\n18: import { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\n19: import { checkDatabaseUpdated } from '../core/index.js';\n20: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n21: import { requireDb, toErrorMessage } from '../utils/index.js';\n22: import * as sessionManager from '../lib/session/session-manager.js';\n23: \n24: // Standardized response structure\n25: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n26: \n27: // Shared handler types\n28: import type { MCPResponse } from './types.js';\n29: \n30: // Feature catalog: Checkpoint creation (checkpoint_create)\n31: // Feature catalog: Checkpoint listing (checkpoint_list)\n32: // Feature catalog: Checkpoint restore (checkpoint_restore)\n33: // Feature catalog: Checkpoint deletion (checkpoint_delete)\n34: // Feature catalog: Checkpoint delete confirmName safety\n35: \n36: \n37: /* ───────────────────────────────────────────────────────────────\n38:    2. TYPES\n39: ──────────────────────────────────────────────────────────────── */\n40: \n41: interface CheckpointCreateArgs {\n42:   name: string;\n43:   specFolder?: string;\n44:   tenantId?: string;\n45:   userId?: string;\n46:   agentId?: string;\n47:   includeEmbeddings?: boolean;\n48:   metadata?: Record<string, unknown>;\n49: }\n50: \n51: interface CheckpointListArgs {\n52:   specFolder?: string;\n53:   tenantId?: string;\n54:   userId?: string;\n55:   agentId?: string;\n56:   limit?: number;\n57: }\n58: \n59: interface CheckpointRestoreArgs {\n60:   name: string;\n61:   tenantId?: string;\n62:   userId?: string;\n63:   agentId?: string;\n64:   clearExisting?: boolean;\n65: }\n66: \n67: interface CheckpointDeleteArgs {\n68:   name: string;\n69:   tenantId?: string;\n70:   userId?: string;\n71:   agentId?: string;\n72:   confirmName: string;\n73: }\n74: \n75: interface CheckpointScopeArgs {\n76:   tenantId?: string;\n77:   userId?: string;\n78:   agentId?: string;\n79: }\n80: \n81: interface MemoryValidateArgs {\n82:   id: number | string;\n83:   wasUseful: boolean;\n84:   queryId?: string;\n85:   queryTerms?: string[];\n86:   resultRank?: number;\n87:   totalResultsShown?: number;\n88:   searchMode?: string;\n89:   intent?: string;\n90:   sessionId?: string;\n91:   notes?: string;\n92: }\n93: \n94: interface ValidationResult {\n95:   confidence: number;\n96:   validationCount: number;\n97:   positiveValidationCount: number;\n98:   promotionEligible: boolean;\n99: }\n100: \n101: function resolveValidationQueryText(\n102:   database: ReturnType<typeof requireDb>,\n103:   queryId?: string,\n104: ): string | null {\n105:   if (typeof queryId !== 'string') {\n106:     return null;\n107:   }\n108: \n109:   const normalizedQueryId = queryId.trim();\n110:   if (normalizedQueryId.length === 0) {\n111:     return null;\n112:   }\n113: \n114:   if (/\\s/.test(normalizedQueryId)) {\n115:     return normalizedQueryId;\n116:   }\n117: \n118:   const consumptionMatch = normalizedQueryId.match(/^(?:consumption:)?(\\d+)$/);\n119:   if (!consumptionMatch) {\n120:     return null;\n121:   }\n122: \n123:   const consumptionLogTable = database.prepare(`\n124:     SELECT 1\n125:     FROM sqlite_master\n126:     WHERE type = 'table'\n127:       AND name = 'consumption_log'\n128:     LIMIT 1\n129:   `).get();\n130:   if (!consumptionLogTable) {\n131:     return null;\n132:   }\n133: \n134:   // The clean consumption_log schema stores only a query fingerprint; raw\n135:   // query text exists solely on unmigrated legacy tables. Without the column\n136:   // there is nothing to resolve, and selecting it would throw.\n137:   const columns = database.prepare(`PRAGMA table_info(consumption_log)`).all() as Array<{ name: string }>;\n138:   if (!columns.some((column) => column.name === 'query_text')) {\n139:     return null;\n140:   }\n141: \n142:   const row = database.prepare(`\n143:     SELECT query_text\n144:     FROM consumption_log\n145:     WHERE id = ?\n146:       AND query_text IS NOT NULL\n147:       AND TRIM(query_text) != ''\n148:     LIMIT 1\n149:   `).get(Number.parseInt(consumptionMatch[1], 10)) as { query_text?: string } | undefined;\n150: \n151:   return typeof row?.query_text === 'string' && row.query_text.trim().length > 0\n152:     ? row.query_text\n153:     : null;\n154: }\n155: \n156: function parseMemoryId(rawId: number | string): number {\n157:   const numericId = typeof rawId === 'string'\n158:     ? Number.parseInt(rawId.trim(), 10)\n159:     : rawId;\n160: \n161:   if (\n162:     typeof numericId !== 'number' ||\n163:     !Number.isSafeInteger(numericId) ||\n164:     numericId <= 0 ||\n165:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n166:   ) {\n167:     throw new Error('id must be a positive integer');\n168:   }\n169: \n170:   return numericId;\n171: }\n172: \n173: function parseCheckpointMetadata(rawMetadata: unknown): Record<string, unknown> {\n174:   if (!rawMetadata) {\n175:     return {};\n176:   }\n177: \n178:   if (typeof rawMetadata === 'string') {\n179:     try {\n180:       const parsed = JSON.parse(rawMetadata);\n181:       return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n182:         ? parsed as Record<string, unknown>\n183:         : {};\n184:     } catch (_error: unknown) {\n185:       return {};\n186:     }\n187:   }\n188: \n189:   return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n190:     ? rawMetadata as Record<string, unknown>\n191:     : {};\n192: }\n193: \n194: function validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n195:   const validateValue = (\n196:     value: string | undefined,\n197:     field: keyof CheckpointScopeArgs,\n198:     options: { trim?: boolean } = {},\n199:   ): string | undefined => {\n200:     if (value === undefined) {\n201:       return undefined;\n202:     }\n203:     if (typeof value !== 'string') {\n204:       throw new Error(`${field} must be a string`);\n205:     }\n206:     return options.trim ? value.trim() : value;\n207:   };\n208: \n209:   const tenantId = validateValue(args.tenantId, 'tenantId', { trim: true });\n210:   const userId = validateValue(args.userId, 'userId');\n211:   const agentId = validateValue(args.agentId, 'agentId');\n212:   const hasActorScope = userId !== undefined || agentId !== undefined;\n213: \n214:   if (\n215:     hasActorScope\n216:     && tenantId !== undefined\n217:     && tenantId.trim().length === 0\n218:   ) {\n219:     throw new Error('tenantId must be a non-empty string when userId or agentId is provided');\n220:   }\n221: \n222:   return {\n223:     tenantId: tenantId && tenantId.length > 0 ? tenantId : undefined,\n224:     userId,\n225:     agentId,\n226:   };\n227: }\n228: \n229: function hasCheckpointScope(scope: CheckpointScopeArgs): boolean {\n230:   return (\n231:     scope.tenantId !== undefined\n232:     || scope.userId !== undefined\n233:     || scope.agentId !== undefined\n234:   );\n235: }\n236: \n237: function requiresCheckpointTenant(scope: CheckpointScopeArgs): boolean {\n238:   return scope.tenantId === undefined && (\n239:     scope.userId !== undefined\n240:     || scope.agentId !== undefined\n241:   );\n242: }\n243: \n244: function mergeCheckpointScopeMetadata(\n245:   metadata: Record<string, unknown> | undefined,\n246:   scope: CheckpointScopeArgs,\n247: ): Record<string, unknown> {\n248:   return {\n249:     ...(metadata ?? {}),\n250:     ...(scope.tenantId !== undefined ? { tenantId: scope.tenantId } : {}),\n251:     ...(scope.userId !== undefined ? { userId: scope.userId } : {}),\n252:     ...(scope.agentId !== undefined ? { agentId: scope.agentId } : {}),\n253:   };\n254: }\n255: \n256: function checkpointMatchesScope(rawMetadata: unknown, scope: CheckpointScopeArgs): boolean {\n257:   const metadata = parseCheckpointMetadata(rawMetadata);\n258:   const matchesScopeField = (field: keyof CheckpointScopeArgs): boolean => {\n259:     const expected = scope[field];\n260:     if (expected === undefined) {\n261:       return true;\n262:     }\n263:     const actual = metadata[field];\n264:     return actual === undefined || actual === expected;\n265:   };\n266: \n267:   return (\n268:     matchesScopeField('tenantId') &&\n269:     matchesScopeField('userId') &&\n270:     matchesScopeField('agentId')\n271:   );\n272: }\n273: \n274: function checkpointScopeDetails(scope: CheckpointScopeArgs): Record<string, string> {\n275:   const details: Record<string, string> = {};\n276:   if (scope.tenantId !== undefined) {\n277:     details.tenantId = scope.tenantId;\n278:   }\n279:   if (scope.userId !== undefined) {\n280:     details.userId = scope.userId;\n\n(Showing lines 1-280 of 918. Use offset=281 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\nimport { executeAutoPromotion } from '../lib/search/auto-promotion.js';\nimport { recordSelection } from '../lib/search/learned-feedback.js';\nimport { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\nimport { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\nimport { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   1. LIB MODULE IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as bm25Index from '../lib/search/bm25-index.js';\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport * as confidenceTracker from '../lib/scoring/confidence-tracker.js';\nimport { executeAutoPromotion } from '../lib/search/auto-promotion.js';\nimport { recordSelection } from '../lib/search/learned-feedback.js';\nimport { recordUserSelection } from '../lib/eval/ground-truth-feedback.js';\nimport { recordNegativeFeedbackEvent } from '../lib/scoring/negative-feedback.js';\nimport { recordAdaptiveSignal } from '../lib/cognitive/adaptive-ranking.js';\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { requireDb, toErrorMessage } from '../utils/index.js';\nimport * as sessionManager from '../lib/session/session-manager.js';\n\n// Standardized response structure\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n\n// Shared handler types\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint listing (checkpoint_list)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Feature catalog: Checkpoint deletion (checkpoint_delete)\n// Feature catalog: Checkpoint delete confirmName safety\n\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface CheckpointCreateArgs {\n  name: string;\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  includeEmbeddings?: boolean;\n  metadata?: Record<string, unknown>;\n}\n\ninterface CheckpointListArgs {\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  limit?: number;\n}\n\ninterface CheckpointRestoreArgs {\n  name: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  clearExisting?: boolean;\n}\n\ninterface CheckpointDeleteArgs {\n  name: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  confirmName: string;\n}\n\ninterface CheckpointScopeArgs {\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n}\n\ninterface MemoryValidateArgs {\n  id: number | string;\n  wasUseful: boolean;\n  queryId?: string;\n  queryTerms?: string[];\n  resultRank?: number;\n  totalResultsShown?: number;\n  searchMode?: string;\n  intent?: string;\n  sessionId?: string;\n  notes?: string;\n}\n\ninterface ValidationResult {\n  confidence: number;\n  validationCount: number;\n  positiveValidationCount: number;\n  promotionEligible: boolean;\n}\n\nfunction resolveValidationQueryText(\n  database: ReturnType<typeof requireDb>,\n  queryId?: string,\n): string | null {\n  if (typeof queryId !== 'string') {\n    return null;\n  }\n\n  const normalizedQueryId = queryId.trim();\n  if (normalizedQueryId.length === 0) {\n    return null;\n  }\n\n  if (/\\s/.test(normalizedQueryId)) {\n    return normalizedQueryId;\n  }\n\n  const consumptionMatch = normalizedQueryId.match(/^(?:consumption:)?(\\d+)$/);\n  if (!consumptionMatch) {\n    return null;\n  }\n\n  const consumptionLogTable = database.prepare(`\n    SELECT 1\n    FROM sqlite_master\n    WHERE type = 'table'\n      AND name = 'consumption_log'\n    LIMIT 1\n  `).get();\n  if (!consumptionLogTable) {\n    return null;\n  }\n\n  // The clean consumption_log schema stores only a query fingerprint; raw\n  // query text exists solely on unmigrated legacy tables. Without the column\n  // there is nothing to resolve, and selecting it would throw.\n  const columns = database.prepare(`PRAGMA table_info(consumption_log)`).all() as Array<{ name: string }>;\n  if (!columns.some((column) => column.name === 'query_text')) {\n    return null;\n  }\n\n  const row = database.prepare(`\n    SELECT query_text\n    FROM consumption_log\n    WHERE id = ?\n      AND query_text IS NOT NULL\n      AND TRIM(query_text) != ''\n    LIMIT 1\n  `).get(Number.parseInt(consumptionMatch[1], 10)) as { query_text?: string } | undefined;\n\n  return typeof row?.query_text === 'string' && row.query_text.trim().length > 0\n    ? row.query_text\n    : null;\n}\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('id must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction parseCheckpointMetadata(rawMetadata: unknown): Record<string, unknown> {\n  if (!rawMetadata) {\n    return {};\n  }\n\n  if (typeof rawMetadata === 'string') {\n    try {\n      const parsed = JSON.parse(rawMetadata);\n      return parsed && typeof parsed === 'object' && !Array.isArray(parsed)\n        ? parsed as Record<string, unknown>\n        : {};\n    } catch (_error: unknown) {\n      return {};\n    }\n  }\n\n  return typeof rawMetadata === 'object' && !Array.isArray(rawMetadata)\n    ? rawMetadata as Record<string, unknown>\n    : {};\n}\n\nfunction validateCheckpointScope(args: CheckpointScopeArgs): CheckpointScopeArgs {\n  const validateValue = (\n    value: string | undefined,\n    field: keyof CheckpointScopeArgs,\n    options: { trim?: boolean } = {},\n  ): string | undefined => {\n    if (value === undefined) {\n      return undefined;\n    }\n    if (typeof value !== 'string') {\n      throw new Error(`${field} must be a string`);\n    }\n    return options.trim ? value.trim() : value;\n  };\n\n  const tenantId = validateValue(args.tenantId, 'tenantId', { trim: true });\n  const userId = validateValue(args.userId, 'userId');\n  const agentId = validateValue(args.agentId, 'agentId');\n  const hasActorScope = userId !== undefined || agentId !== undefined;\n\n  if (\n    hasActorScope\n    && tenantId !== undefined\n    && tenantId.trim().length === 0\n  ) {\n    throw new Error('tenantId must be a non-empty string when userId or agentId is provided');\n  }\n\n  return {\n    tenantId: tenantId && tenantId.length > 0 ? tenantId : undefined,\n    userId,\n    agentId,\n  };\n}\n\nfunction hasCheckpointScope(scope: CheckpointScopeArgs): boolean {\n  return (\n    scope.tenantId !== undefined\n    || scope.userId !== undefined\n    || scope.agentId !== undefined\n  );\n}\n\nfunction requiresCheckpointTenant(scope: CheckpointScopeArgs): boolean {\n  return scope.tenantId === undefined && (\n    scope.userId !== undefined\n    || scope.agentId !== undefined\n  );\n}\n\nfunction mergeCheckpointScopeMetadata(\n  metadata: Record<string, unknown> | undefined,\n  scope: CheckpointScopeArgs,\n): Record<string, unknown> {\n  return {\n    ...(metadata ?? {}),\n    ...(scope.tenantId !== undefined ? { tenantId: scope.tenantId } : {}),\n    ...(scope.userId !== undefined ? { userId: scope.userId } : {}),\n    ...(scope.agentId !== undefined ? { agentId: scope.agentId } : {}),\n  };\n}\n\nfunction checkpointMatchesScope(rawMetadata: unknown, scope: CheckpointScopeArgs): boolean {\n  const metadata = parseCheckpointMetadata(rawMetadata);\n  const matchesScopeField = (field: keyof CheckpointScopeArgs): boolean => {\n    const expected = scope[field];\n    if (expected === undefined) {\n      return true;\n    }\n    const actual = metadata[field];\n    return actual === undefined || actual === expected;\n  };\n\n  return (\n    matchesScopeField('tenantId') &&\n    matchesScopeField('userId') &&\n    matchesScopeField('agentId')\n  );\n}\n\nfunction checkpointScopeDetails(scope: CheckpointScopeArgs): Record<string, string> {\n  const details: Record<string, string> = {};\n  if (scope.tenantId !== undefined) {\n    details.tenantId = scope.tenantId;\n  }\n  if (scope.userId !== undefined) {\n    details.userId = scope.userId;","lineStart":1,"lineEnd":280,"totalLines":918,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/checkpoints.ts","time":{"start":1781762036650,"end":1781762036658}},"metadata":{"openai":{"itemId":"fc_0b50bd46bc0ce1ad016a3387f45b048191848142e2bee79e4c"}},"id":"prt_ed94b13a9001WtkiDgY5qOqnY9","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94aed360019KK8P6LBX130rw"}}
