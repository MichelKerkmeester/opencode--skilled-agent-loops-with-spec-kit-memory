   231	function push(scores: Map<string, { score: number; evidence: string[] }>, skillId: string, amount: number, evidence: string): void {
   232	  const current = scores.get(skillId) ?? { score: 0, evidence: [] };
   233	  current.score += amount;
   234	  current.evidence.push(evidence);
   235	  scores.set(skillId, current);
   236	}
   237	
   238	export function scoreExplicitLane(prompt: string, projection: AdvisorProjection): LaneMatch[] {
   239	  const lower = prompt.toLowerCase();
   240	  const tokens = tokenize(prompt, true);
   241	  const scores = new Map<string, { score: number; evidence: string[] }>();
   242	
   243	  for (const [phrase, boosts] of Object.entries(PHRASE_BOOSTS)) {
   244	    if (!lower.includes(phrase)) continue;
   245	    for (const [skillId, amount] of boosts) {
   246	      push(scores, skillId, amount, `phrase:${phrase}`);
   247	    }
   248	  }
   249	
   250	  for (const token of tokens) {
   251	    for (const [skillId, amount] of TOKEN_BOOSTS[token] ?? []) {
   252	      push(scores, skillId, amount, `token:${token}`);
   253	    }
   254	  }
   255	
   256	  if (WRITE_VERBS.test(lower) && /\b(readme|docs|documentation|playbook|taxonomy|markdown|feature_catalog)\b/.test(lower)) {
   257	    push(scores, 'sk-doc', 0.7, 'write-doc-surface');
   258	  }
   259	  if (WRITE_VERBS.test(lower) && /\b(classifier|helper|fixture|json|jsonl|vitest|typescript|python|script|skill_advisor\.py|mcp\.json|commonjs)\b/.test(lower)) {
   260	    push(scores, 'sk-code', 0.7, 'write-system-code-surface');

