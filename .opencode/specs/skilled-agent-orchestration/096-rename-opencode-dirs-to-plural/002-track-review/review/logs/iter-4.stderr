exec
/bin/zsh -lc "node <<'NODE'
const fs=require('fs'), path=require('path');
const root=process.cwd(); const rel=p=>path.relative(root,p);
function files(d){let out=[]; if("'!fs.existsSync(d))return out; for(const e of fs.readdirSync(d,{withFileTypes:true})){const p=path.join(d,e.name); if(e.isDirectory()) out=out.concat(files(p)); else if(e.name.endsWith('"'.md')) out.push(p);} return out;}
function norm(s){return (s||'').trim().replace(/"'^`|`$/g,'"'').trim();}
function promptOf(txt){let m=txt.match(/"'^[-*]'"\\s+(?:RCAF\\s+)?Prompt:\\s*"'`([''^`]+)`/m); if(m) return m[1].trim(); m=txt.match(/''^Prompt:'"\\s*"'`?([''^`'"\\n]+)"'`?/m); return m?m[1].trim():'"'';}
function featureId(txt, file){let m=txt.match(/"'`([A-Z][A-Z0-9-]+-'"\\d{3})"'`/); if(m) return m[1]; m=txt.match(/''^feature_id:'"\\s*\"?(["'^"'"\\n]+)\"?/m); return m?m[1].trim():path.basename(file,'.md');}
