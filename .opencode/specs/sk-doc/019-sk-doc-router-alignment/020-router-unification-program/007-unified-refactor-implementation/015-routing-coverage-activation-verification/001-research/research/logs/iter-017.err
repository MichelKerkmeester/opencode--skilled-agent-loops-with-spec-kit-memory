   661	/**
   662	 * Parse a skill's manual_testing_playbook into normalized benchmark scenarios.
   663	 *
   664	 * @param {Object} [options] - Loader options.
   665	 * @param {string} [options.skillRoot] - Skill root dir (playbook resolved under it).
   666	 * @param {string} [options.playbookDir] - Explicit playbook dir override.
   667	 * @returns {{ scenarios: Array, shape: 'sk-code'|'sk-doc'|'none', warnings: string[] }}
   668	 */
   669	function loadPlaybookScenarios({ skillRoot, playbookDir } = {}) {
   670	  const dir = resolvePlaybookDir(skillRoot, playbookDir);
   671	  const warnings = [];
   672	  const rootPath = resolvePlaybookIndex(dir);
   673	  const rootText = rootPath ? readFileSafe(rootPath) : null;
   674	  const index = rootText ? parseRootIndex(rootText) : [];
   675	  const rootMap = rootText ? parseRootScenarioTables(rootText) : {};
   676	
   677	  if (index.length > 0) {
   678	    const scenarios = [];
   679	    for (const row of index) {
   680	      const abs = path.join(dir, row.featureFile);
   681	      const parsed = parseFeatureFile(abs, row.scenarioId, row.categoryLabel, row.critical, rootMap[row.scenarioId]);
   682	      if (parsed) {
   683	        if (parsed.parseWarnings.length) warnings.push(`${row.scenarioId}: ${parsed.parseWarnings.join(',')}`);
   684	        scenarios.push(parsed);
   685	      } else {
   686	        warnings.push(`${row.scenarioId}: feature file unreadable (${row.featureFile})`);
   687	      }
   688	    }
   689	    const byMode = loadManifestModeLeaves(skillRoot);
   690	    if (byMode) {
   691	      for (const sc of scenarios) {
   692	        const gold = deriveTypedGoldFromBodyGold(sc.expectedResources, byMode);
   693	        if (gold) {
   694	          sc.expected_leaf_resources = gold.pairs;
   695	          sc.expected = { ...(sc.expected || {}), workflowMode: gold.workflowMode };
   696	        }
   697	      }
   698	    }
   699	    return { scenarios, shape: 'sk-code', warnings };
   700	  }
   701	
   702	  // No root index table -> sk-doc YAML-frontmatter shape.
   703	  const scenarios = loadYamlFrontmatterScenarios(dir, warnings);
   704	  if (!scenarios.length) {
   705	    throw new PlaybookLoadError('EMPTY_PLAYBOOK', `no scenarios found under ${dir}`);
   706	  }
   707	  return { scenarios, shape: 'sk-doc', warnings };
   708	}
