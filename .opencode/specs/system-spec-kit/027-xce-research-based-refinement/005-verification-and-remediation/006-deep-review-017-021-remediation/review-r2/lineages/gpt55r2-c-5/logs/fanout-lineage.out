 === 'memory_search' || name === 'memory_context') && result && !result.isError && result.content?.[0]?.text) {\n\n  Line 1220:     if (result && !result.isError && result.content?.[0]?.text) {\n\n  Line 1245:     if (autoSurfacedContext && result && !result.isError) {\n\n  Line 1264:           if (sessionPrimeContext && !result.isError) {\n\n  Line 1267:           if (autoSurfacedContext && !result.isError) {\n\n  Line 1270:           if (dispatchGraphContext && !result.isError) {\n\n  Line 1271:             meta.graphContext = dispatchGraphContext;\n\n  Line 1698:   process.exit(exitCode);\n\n  Line 1798:       process.exit(EXIT_DB_LOCK_HELD);\n\n  Line 1854:     // Throw (not process.exit) so a bad first call fails THAT caller's tool request with a\n\n  Line 1857:     throw new Error(`memory runtime init failed (embedder): ${message}`);\n\n  Line 1897:           // Throw (not process.exit) so the shared daemon survives one bad first call. Tagged so\n\n  Line 1972:       throw new Error(dimValidation.warning ?? 'Embedding dimension mismatch between provider and database');\n\n  Line 1979:       throw new Error('Database not initialized after initializeDb(). Cannot start server.');\n\n  Line 2029:         throw new Error(`[context-server] Learned feedback migration/isolation failed: ${message}`);\n\n  Line 2112:       throw new Error(`[context-server] Extraction adapter startup failed: ${message}`);\n\n  Line 2340:   main().catch((err: unknown) => { console.error('[context-server] Fatal error:', err); process.exit(1); });\n","metadata":{"matches":35,"truncated":false},"title":"throw new Error|process\\.exit|return \\{.*error|isError|McpError|CallTool|dispatch|switch \\(name\\)|case 'memory_|case \"memory_","time":{"start":1781762615917,"end":1781762615930}},"metadata":{"openai":{"itemId":"fc_0049c9bd9ebe6922016a338a3788ec8191a4142e45ba7f9bd1"}},"id":"prt_ed953ea55001BnUX78vuo27FSF","sessionID":"ses_126ae8584ffeIHNv72WQpy5bXJ","messageID":"msg_ed9538b7f001685Qns0T6Z