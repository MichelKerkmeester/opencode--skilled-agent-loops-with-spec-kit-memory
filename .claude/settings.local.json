{
  "env": {
    "SPECKIT_ABLATION": "true",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "ENABLE_TOOL_SEARCH": "true",
    "MAX_THINKING_TOKENS": "999999"
  },
  "permissions": {
    "allow": [
      "mcp__sequential_thinking__sequentialthinking",
      "Bash(echo \"EXIT_CODE=$?\")",
      "Skill(update-config)",
