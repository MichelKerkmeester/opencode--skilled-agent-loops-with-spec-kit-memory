336-  const re = /(?:code-[a-z]+|references|assets|\.\.\/shared)\/[A-Za-z0-9_./-]+\.[a-z]{1,4}/g;
337-  let m;
338-  while ((m = re.exec(block)) !== null) {
339-    const p = m[0];
340-    if (!seen.has(p)) { seen.add(p); out.push(p); }
341-  }
342-  return out;
343-}
