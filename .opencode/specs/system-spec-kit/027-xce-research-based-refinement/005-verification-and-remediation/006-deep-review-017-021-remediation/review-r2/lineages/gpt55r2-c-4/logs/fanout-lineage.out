ionId: governanceDecision.normalized.sessionId,\n3388:   };\n3389:   let idempotencyKey: IdempotencyReceiptKey | null = null;\n3390: \n3391:   // PRE-FLIGHT VALIDATION\n3392:   let parsedForPreflight: ReturnType<typeof memoryParser.parseMemoryFile> | null = null;\n3393:   if (!skipPreflight) {\n3394:     parsedForPreflight = memoryParser.parseMemoryFile(validatedPath);\n3395: \n3396:     const preflightResult = preflight.runPreflight(\n3397:       {\n3398:         content: parsedForPreflight.content,\n3399:         file_path: validatedPath,\n3400:         spec_folder: parsedForPreflight.specFolder,\n3401:         database: database,\n3402:         find_similar: findSimilarMemories as Parameters<typeof preflight.runPreflight>[0]['find_similar'],\n3403:         tenantId: saveScope.tenantId ?? undefined,\n3404:         userId: saveScope.userId ?? undefined,\n3405:         agentId: saveScope.agentId ?? undefined,\n3406:       },\n3407:       {\n3408:         dry_run: dryRun,\n3409:         check_anchors: true,\n3410:         check_duplicates: !force,\n3411:         check_similar: false,\n3412:         check_tokens: true,\n3413:         check_size: true,\n3414:         strict_anchors: false,\n3415:       }\n3416:     );\n3417: \n3418:     if (dryRun) {\n3419:       let preparedDryRun: PreparedParsedMemory;\n3420:       try {\n3421:         preparedDryRun = prepareParsedMemoryForIndexing(parsedForPreflight, database, {\n3422:           emitEvalMetrics: false,\n3423:           qualityLoopMode: 'advisory',\n3424:         });\n3425:       } catch (error: unknown) {\n3426:         if (error instanceof VRuleUnavailableError) {\n3427:           return createMCPErrorResponse({\n3428:             tool: 'memory_save',\n3429:             error: error.message,\n3430:             code: 'E_RUNTIME',\n3431:             details: { requestId },\n3432:             recovery: {\n3433:               hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3434:               action