{"type":"text","timestamp":1781764140765,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"id":"prt_ed96b15bc0016zMKpD7ms7fvps","messageID":"msg_ed96afb7e001W3qLsQ87QsFGNb","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","type":"text","text":"No handler-dispatch issue strong enough to record yet. I’m checking the memory-save and index-scan file path boundary because this scope explicitly includes request validation and path handling.","time":{"start":1781764134332,"end":1781764140762},"metadata":{"openai":{"itemId":"msg_0d6ae382ff28249e016a3390264ed0819196fb86625bf2b1db","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781764140834,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_a9eQdaWZKxvG6hV0MwrgUmTF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":380,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n380: // best-effort, not load-bearing.\n381: const STRUCTURAL_METADATA_FILENAMES = new Set<string>(['graph-metadata.json']);\n382: \n383: function isStructuralMetadataFile(filePath: string): boolean {\n384:   return STRUCTURAL_METADATA_FILENAMES.has(path.basename(filePath));\n385: }\n386: \n387: function shouldBypassTemplateContract(\n388:   sourceClassification: PreparedParsedMemory['sourceClassification'],\n389:   sufficiencyResult: MemorySufficiencyResult,\n390:   templateContract: MemoryTemplateContractResult,\n391:   specDocHealth?: SpecDocHealthResult | null,\n392:   documentType?: string,\n393: ): boolean {\n394:   const isValidCanonicalSpecDoc = Boolean(\n395:     documentType\n396:       && CANONICAL_SPEC_DOCUMENT_TYPES.has(documentType)\n397:       && specDocHealth?.pass === true,\n398:   );\n399: \n400:   return sourceClassification === MANUAL_FALLBACK_SOURCE_CLASSIFICATION\n401:     && sufficiencyResult.pass\n402:     && !templateContract.valid\n403:     && (\n404:       isValidCanonicalSpecDoc\n405:       || (\n406:         sufficiencyResult.evidenceCounts.primary === 0\n407:         && sufficiencyResult.evidenceCounts.support >= 3\n408:         && sufficiencyResult.evidenceCounts.anchors >= 1\n409:       )\n410:     );\n411: }\n412: \n413: function buildQualityLoopMetadata(\n414:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n415:   database: ReturnType<typeof requireDb>,\n416: ): Record<string, unknown> {\n417:   return {\n418:     title: parsed.title ?? '',\n419:     triggerPhrases: parsed.triggerPhrases,\n420:     specFolder: parsed.specFolder,\n421:     contextType: parsed.contextType,\n422:     importanceTier: parsed.importanceTier,\n423:     causalLinks: parsed.causalLinks,\n424:     filePath: parsed.filePath,\n425:     lastModified: parsed.lastModified,\n426:     resolveReference: (reference: string) => resolveMemoryReference(database, reference) !== null,\n427:   };\n428: }\n429: \n430: function prepareParsedMemoryForIndexing(\n431:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n432:   database: ReturnType<typeof requireDb>,\n433:   options: {\n434:     emitEvalMetrics?: boolean;\n435:     qualityLoopMode?: 'advisory' | 'full-auto';\n436:   } = {},\n437: ): PreparedParsedMemory {\n438:   // Resolve to the canonical path before applying memory-index governance.\n439:   const canonicalFilePath = resolveCanonicalPath(path.resolve(parsed.filePath));\n440:   if (!shouldIndexForMemory(canonicalFilePath)) {\n441:     throw new Error(`Memory indexing excluded for path: ${parsed.filePath}`);\n442:   }\n443:   if (parsed.importanceTier === 'constitutional' && !isIndexableConstitutionalMemoryPath(canonicalFilePath)) {\n444:     console.warn('[memory-save] importance_tier=constitutional rejected for non-constitutional path; downgrading to important', {\n445:       file_path: parsed.filePath,\n446:     });\n447:     try {\n448:       recordTierDowngradeAudit(database, {\n449:         logicalKey: buildGovernanceLogicalKey(parsed.specFolder, canonicalFilePath, null),\n450:         requestedTier: 'constitutional',\n451:         nextTier: 'important',\n452:         source: 'memory_save',\n453:         filePath: parsed.filePath,\n454:         canonicalFilePath,\n455:       });\n456:     } catch (error: unknown) {\n457:       console.warn(\n458:         '[memory-save] governance_audit insert failed for tier downgrade:',\n459:         error instanceof Error ? error.message : String(error),\n460:       );\n461:     }\n462:     parsed.importanceTier = 'important';\n463:   }\n464: \n465:   const validation = memoryParser.validateParsedMemory(parsed);\n466:   if (validation.warnings && validation.warnings.length > 0) {\n467:     console.warn(`[memory] Warning for ${path.basename(parsed.filePath)}:`);\n468:     validation.warnings.forEach((warning: string) => console.warn(`[memory]   - ${warning}`));\n469:   }\n470: \n471:   // O2-5/O2-12: Run V-rule validation (previously only in workflow path)\n472:   const vRuleResult = validateMemoryQualityContent(parsed.content, { filePath: parsed.filePath });\n473:   if (isVRuleUnavailableResult(vRuleResult) && vRuleResult.status === 'error') {\n474:     throw new VRuleUnavailableError(vRuleResult.message);\n475:   }\n476:   if (vRuleResult && '_unavailable' in vRuleResult) {\n477:     validation.warnings.push('V-rule validator module unavailable — quality gate bypassed. Save proceeds without V-rule enforcement.');\n478:   }\n479:   if (vRuleResult && !isVRuleUnavailableResult(vRuleResult) && !vRuleResult.valid) {\n480:     const vRuleDisposition = determineValidationDisposition(\n481:       vRuleResult.failedRules,\n482:       parsed.memoryTypeSource || null,\n483:     );\n484:     if (vRuleDisposition && vRuleDisposition.disposition === 'abort_write') {\n485:       const failedRuleIds = vRuleDisposition.blockingRuleIds;\n486:       console.error(`[memory-save] V-rule hard block for ${path.basename(parsed.filePath)}: ${failedRuleIds.join(', ')}`);\n487:       // Return early with a rejected quality loop result so callers see the block\n488:       const rejectScore = { total: 0, breakdown: { triggers: 0, anchors: 0, budget: 0, coherence: 0 }, issues: [`V-rule hard block: ${failedRuleIds.join(', ')}`] };\n489:       return {\n490:         parsed,\n491:         validation,\n492:         qualityLoopResult: {\n493:           passed: false,\n494:           score: rejectScore,\n495:           attempts: 0,\n496:           fixes: [],\n497:           rejected: true,\n498:           rejectionReason: `V-rule hard block: ${failedRuleIds.join(', ')}`,\n499:         },\n500:         sufficiencyResult: {\n501:           pass: false,\n502:           rejectionCode: MEMORY_SUFFICIENCY_REJECTION_CODE,\n503:           score: 0,\n504:           reasons: [`V-rule hard block: ${failedRuleIds.join(', ')}`],\n505:           evidenceCounts: { primary: 0, support: 0, total: 0, semanticChars: 0, uniqueWords: 0, anchors: 0, triggerPhrases: 0 },\n506:         },\n507:         templateContract: { valid: true, violations: [], missingAnchors: [], unexpectedTemplateArtifacts: [] } as MemoryTemplateContractResult,\n508:         specDocHealth: null,\n509:         finalizedFileContent: null,\n510:         sourceClassification: 'template-generated',\n511:       };\n512:     }\n513:     if (vRuleDisposition && vRuleDisposition.disposition === 'write_skip_index') {\n514:       console.warn(`[memory-save] V-rule index block for ${path.basename(parsed.filePath)}: ${vRuleDisposition.indexBlockingRuleIds.join(', ')}`);\n515:       validation.warnings.push(`V-rule index block: ${vRuleDisposition.indexBlockingRuleIds.join(', ')}`);\n516:       // F07-002: Flag to skip indexing for write_skip_index disposition\n517:       const parsedWithIndexHints = parsed as ParsedMemoryWithIndexHints;\n518:       parsedWithIndexHints._skipIndex = true;\n519:       parsedWithIndexHints._vRuleIndexBlockIds = vRuleDisposition.indexBlockingRuleIds;\n520:     }\n521:   }\n522: \n523:   const qualityLoopResult = runQualityLoop(parsed.content, buildQualityLoopMetadata(parsed, database), {\n524:     emitEvalMetrics: options.emitEvalMetrics,\n525:     mode: options.qualityLoopMode ?? 'advisory',\n526:   });\n527:   parsed.qualityScore = qualityLoopResult.score.total;\n528:   parsed.qualityFlags = Array.from(new Set([\n529:     ...(parsed.qualityFlags ?? []),\n530:     ...qualityLoopResult.score.issues,\n531:   ]));\n532:   if (qualityLoopResult.fixedTriggerPhrases) {\n533:     parsed.triggerPhrases = qualityLoopResult.fixedTriggerPhrases;\n534:   }\n535:   const finalizedFileContent = qualityLoopResult.fixedContent\n536:     && qualityLoopResult.passed\n537:     ? qualityLoopResult.fixedContent\n538:     : null;\n539:   if (finalizedFileContent) {\n540:     parsed.content = finalizedFileContent;\n541:     parsed.contentHash = memoryParser.computeContentHash(parsed.content);\n542:   }\n543: \n544:   const sourceClassification = classifyMemorySaveSource(parsed.content);\n545:   if (sourceClassification === MANUAL_FALLBACK_SOURCE_CLASSIFICATION) {\n546:     const warning = 'Manual fallback save mode detected; standard generate-context template markers are missing.';\n547:     console.warn(`[memory-save] ${warning} ${path.basename(parsed.filePath)}`);\n548:     validation.warnings.push(warning);\n549:   }\n550: \n551:   const sufficiencyResult = evaluateMemorySufficiency(\n552:     {\n553:       ...buildParsedMemoryEvidenceSnapshot(parsed),\n554:       sourceClassification,\n555:     },\n556:   );\n557:   applyInsufficiencyMetadata(parsed, sufficiencyResult);\n558:   const templateContract = validateMemoryTemplateContract(parsed.content);\n559: \n560:   // Non-blocking spec doc health annotation\n561:   // Canonical saves land directly in the spec folder (e.g. .../NNN-name/decision-record.md),\n562:   // so the immediate parent is usually the spec folder itself.\n563:   let specDocHealth: SpecDocHealthResult | null = null;\n564:   if (parsed.specFolder && parsed.filePath) {\n565:     try {\n566:       const absFilePath = path.resolve(parsed.filePath);\n567:       const immediateParent = path.dirname(absFilePath);\n568:       const candidates = [immediateParent, path.dirname(immediateParent)];\n569:       for (const candidate of candidates) {\n570:         if (fs.existsSync(path.join(candidate, 'spec.md'))) {\n571:           specDocHealth = evaluateSpecDocHealth(candidate);\n572:           break;\n573:         }\n574:       }\n575:     } catch (error: unknown) {\n576:       const message = error instanceof Error ? error.message : String(error);\n577:       console.warn(\n578:         `[memory-save] spec-doc-health annotation skipped for ${path.basename(parsed.filePath)}: ${message}`\n579:       );\n580:     }\n581:   }\n582: \n583:   return {\n584:     parsed,\n585:     validation,\n586:     qualityLoopResult,\n587:     sufficiencyResult,\n588:     templateContract,\n589:     specDocHealth,\n590:     finalizedFileContent,\n591:     sourceClassification,\n592:   };\n593: }\n594: \n595: async function finalizeMemoryFileContent(\n596:   filePath: string,\n597:   content: string,\n598: ): Promise<void> {\n599:   const backupPath = `${filePath}.${randomUUID().slice(0, 8)}.bak`;\n600:   const tempPath = `${filePath}.${randomUUID().slice(0, 8)}.tmp`;\n601:   let backupCreated = false;\n602:   let tempCreated = false;\n603: \n604:   try {\n605:     try {\n606:       await fs.promises.copyFile(filePath, backupPath);\n607:       backupCreated = true;\n608:     } catch (backupErr: unknown) {\n609:       const errCode = typeof backupErr === 'object' && backupErr !== null && 'code' in backupErr\n610:         ? String((backupErr as NodeJS.ErrnoException).code)\n611:         : '';\n612:       if (errCode !== 'ENOENT') {\n613:         throw backupErr;\n614:       }\n615:     }\n616: \n617:     await fs.promises.writeFile(tempPath, content, 'utf-8');\n618:     tempCreated = true;\n619:     await fs.promises.rename(tempPath, filePath);\n620:     tempCreated = false;\n621:   } catch (writeErr: unknown) {\n622:     if (tempCreated) {\n623:       try {\n624:         await fs.promises.unlink(tempPath);\n625:       } catch {\n626:         // Best-effort cleanup only.\n627:       }\n628:     }\n629:     if (backupCreated) {\n630:       try {\n631:         await fs.promises.copyFile(backupPath, filePath);\n632:       } catch (restoreErr: unknown) {\n633:         console.warn(\n634:           '[memory-save] Auto-fix file restore failed after finalize error:',\n635:           restoreErr instanceof Error ? restoreErr.message : String(restoreErr),\n636:         );\n637:       }\n638:     }\n639:     throw writeErr;\n640:   } finally {\n641:     if (tempCreated) {\n642:       try {\n643:         await fs.promises.unlink(tempPath);\n644:       } catch {\n645:         // Best-effort cleanup only.\n646:       }\n647:     }\n648:     if (backupCreated) {\n649:       try {\n650:         await fs.promises.unlink(backupPath);\n651:       } catch {\n652:         // Best-effort cleanup only.\n653:       }\n654:     }\n655:   }\n656: }\n657: \n658: function appendResultWarning<T extends Record<string, unknown>>(result: T, warning: string | null): T {\n659:   if (!warning) {\n660:     return result;\n661:   }\n662: \n663:   const r = result as Record<string, unknown>;\n664:   const warnings = Array.isArray(r.warnings)\n665:     ? [...(r.warnings as string[])]\n666:     : [];\n667:   warnings.push(warning);\n668:   r.warnings = warnings;\n669:   return result;\n670: }\n671: \n672: class SaveTimeReconsolidationAbort extends Error {\n673:   readonly result: {\n674:     status: 'failed';\n675:     reason: ReconsolidationFailureReason;\n676:     warnings?: string[];\n677:     persistedState?: ReconsolidationOperationState;\n678:   };\n679: \n680:   constructor(result: SaveTimeReconsolidationAbort['result']) {\n681:     super(result.reason);\n682:     this.name = 'SaveTimeReconsolidationAbort';\n683:     this.result = result;\n684:   }\n685: }\n686: \n687: function buildSaveTimeReconsolidationFailureResult(args: {\n688:   parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n689:   validation: { warnings: string[] };\n690:   reconWarnings: string[];\n691:   failure: SaveTimeReconsolidationAbort['result'];\n692:   message?: string;\n693: }): IndexResult {\n694:   const warnings = [\n695:     ...args.validation.warnings,\n696:     ...args.reconWarnings,\n697:     ...(args.failure.warnings ?? []),\n698:   ];\n699: \n\n(Showing lines 380-699 of 4082. Use offset=700 to continue.)\n</content>","metadata":{"preview":"// best-effort, not load-bearing.\nconst STRUCTURAL_METADATA_FILENAMES = new Set<string>(['graph-metadata.json']);\n\nfunction isStructuralMetadataFile(filePath: string): boolean {\n  return STRUCTURAL_METADATA_FILENAMES.has(path.basename(filePath));\n}\n\nfunction shouldBypassTemplateContract(\n  sourceClassification: PreparedParsedMemory['sourceClassification'],\n  sufficiencyResult: MemorySufficiencyResult,\n  templateContract: MemoryTemplateContractResult,\n  specDocHealth?: SpecDocHealthResult | null,\n  documentType?: string,\n): boolean {\n  const isValidCanonicalSpecDoc = Boolean(\n    documentType\n      && CANONICAL_SPEC_DOCUMENT_TYPES.has(documentType)\n      && specDocHealth?.pass === true,\n  );\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"// best-effort, not load-bearing.\nconst STRUCTURAL_METADATA_FILENAMES = new Set<string>(['graph-metadata.json']);\n\nfunction isStructuralMetadataFile(filePath: string): boolean {\n  return STRUCTURAL_METADATA_FILENAMES.has(path.basename(filePath));\n}\n\nfunction shouldBypassTemplateContract(\n  sourceClassification: PreparedParsedMemory['sourceClassification'],\n  sufficiencyResult: MemorySufficiencyResult,\n  templateContract: MemoryTemplateContractResult,\n  specDocHealth?: SpecDocHealthResult | null,\n  documentType?: string,\n): boolean {\n  const isValidCanonicalSpecDoc = Boolean(\n    documentType\n      && CANONICAL_SPEC_DOCUMENT_TYPES.has(documentType)\n      && specDocHealth?.pass === true,\n  );\n\n  return sourceClassification === MANUAL_FALLBACK_SOURCE_CLASSIFICATION\n    && sufficiencyResult.pass\n    && !templateContract.valid\n    && (\n      isValidCanonicalSpecDoc\n      || (\n        sufficiencyResult.evidenceCounts.primary === 0\n        && sufficiencyResult.evidenceCounts.support >= 3\n        && sufficiencyResult.evidenceCounts.anchors >= 1\n      )\n    );\n}\n\nfunction buildQualityLoopMetadata(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  database: ReturnType<typeof requireDb>,\n): Record<string, unknown> {\n  return {\n    title: parsed.title ?? '',\n    triggerPhrases: parsed.triggerPhrases,\n    specFolder: parsed.specFolder,\n    contextType: parsed.contextType,\n    importanceTier: parsed.importanceTier,\n    causalLinks: parsed.causalLinks,\n    filePath: parsed.filePath,\n    lastModified: parsed.lastModified,\n    resolveReference: (reference: string) => resolveMemoryReference(database, reference) !== null,\n  };\n}\n\nfunction prepareParsedMemoryForIndexing(\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n  database: ReturnType<typeof requireDb>,\n  options: {\n    emitEvalMetrics?: boolean;\n    qualityLoopMode?: 'advisory' | 'full-auto';\n  } = {},\n): PreparedParsedMemory {\n  // Resolve to the canonical path before applying memory-index governance.\n  const canonicalFilePath = resolveCanonicalPath(path.resolve(parsed.filePath));\n  if (!shouldIndexForMemory(canonicalFilePath)) {\n    throw new Error(`Memory indexing excluded for path: ${parsed.filePath}`);\n  }\n  if (parsed.importanceTier === 'constitutional' && !isIndexableConstitutionalMemoryPath(canonicalFilePath)) {\n    console.warn('[memory-save] importance_tier=constitutional rejected for non-constitutional path; downgrading to important', {\n      file_path: parsed.filePath,\n    });\n    try {\n      recordTierDowngradeAudit(database, {\n        logicalKey: buildGovernanceLogicalKey(parsed.specFolder, canonicalFilePath, null),\n        requestedTier: 'constitutional',\n        nextTier: 'important',\n        source: 'memory_save',\n        filePath: parsed.filePath,\n        canonicalFilePath,\n      });\n    } catch (error: unknown) {\n      console.warn(\n        '[memory-save] governance_audit insert failed for tier downgrade:',\n        error instanceof Error ? error.message : String(error),\n      );\n    }\n    parsed.importanceTier = 'important';\n  }\n\n  const validation = memoryParser.validateParsedMemory(parsed);\n  if (validation.warnings && validation.warnings.length > 0) {\n    console.warn(`[memory] Warning for ${path.basename(parsed.filePath)}:`);\n    validation.warnings.forEach((warning: string) => console.warn(`[memory]   - ${warning}`));\n  }\n\n  // O2-5/O2-12: Run V-rule validation (previously only in workflow path)\n  const vRuleResult = validateMemoryQualityContent(parsed.content, { filePath: parsed.filePath });\n  if (isVRuleUnavailableResult(vRuleResult) && vRuleResult.status === 'error') {\n    throw new VRuleUnavailableError(vRuleResult.message);\n  }\n  if (vRuleResult && '_unavailable' in vRuleResult) {\n    validation.warnings.push('V-rule validator module unavailable — quality gate bypassed. Save proceeds without V-rule enforcement.');\n  }\n  if (vRuleResult && !isVRuleUnavailableResult(vRuleResult) && !vRuleResult.valid) {\n    const vRuleDisposition = determineValidationDisposition(\n      vRuleResult.failedRules,\n      parsed.memoryTypeSource || null,\n    );\n    if (vRuleDisposition && vRuleDisposition.disposition === 'abort_write') {\n      const failedRuleIds = vRuleDisposition.blockingRuleIds;\n      console.error(`[memory-save] V-rule hard block for ${path.basename(parsed.filePath)}: ${failedRuleIds.join(', ')}`);\n      // Return early with a rejected quality loop result so callers see the block\n      const rejectScore = { total: 0, breakdown: { triggers: 0, anchors: 0, budget: 0, coherence: 0 }, issues: [`V-rule hard block: ${failedRuleIds.join(', ')}`] };\n      return {\n        parsed,\n        validation,\n        qualityLoopResult: {\n          passed: false,\n          score: rejectScore,\n          attempts: 0,\n          fixes: [],\n          rejected: true,\n          rejectionReason: `V-rule hard block: ${failedRuleIds.join(', ')}`,\n        },\n        sufficiencyResult: {\n          pass: false,\n          rejectionCode: MEMORY_SUFFICIENCY_REJECTION_CODE,\n          score: 0,\n          reasons: [`V-rule hard block: ${failedRuleIds.join(', ')}`],\n          evidenceCounts: { primary: 0, support: 0, total: 0, semanticChars: 0, uniqueWords: 0, anchors: 0, triggerPhrases: 0 },\n        },\n        templateContract: { valid: true, violations: [], missingAnchors: [], unexpectedTemplateArtifacts: [] } as MemoryTemplateContractResult,\n        specDocHealth: null,\n        finalizedFileContent: null,\n        sourceClassification: 'template-generated',\n      };\n    }\n    if (vRuleDisposition && vRuleDisposition.disposition === 'write_skip_index') {\n      console.warn(`[memory-save] V-rule index block for ${path.basename(parsed.filePath)}: ${vRuleDisposition.indexBlockingRuleIds.join(', ')}`);\n      validation.warnings.push(`V-rule index block: ${vRuleDisposition.indexBlockingRuleIds.join(', ')}`);\n      // F07-002: Flag to skip indexing for write_skip_index disposition\n      const parsedWithIndexHints = parsed as ParsedMemoryWithIndexHints;\n      parsedWithIndexHints._skipIndex = true;\n      parsedWithIndexHints._vRuleIndexBlockIds = vRuleDisposition.indexBlockingRuleIds;\n    }\n  }\n\n  const qualityLoopResult = runQualityLoop(parsed.content, buildQualityLoopMetadata(parsed, database), {\n    emitEvalMetrics: options.emitEvalMetrics,\n    mode: options.qualityLoopMode ?? 'advisory',\n  });\n  parsed.qualityScore = qualityLoopResult.score.total;\n  parsed.qualityFlags = Array.from(new Set([\n    ...(parsed.qualityFlags ?? []),\n    ...qualityLoopResult.score.issues,\n  ]));\n  if (qualityLoopResult.fixedTriggerPhrases) {\n    parsed.triggerPhrases = qualityLoopResult.fixedTriggerPhrases;\n  }\n  const finalizedFileContent = qualityLoopResult.fixedContent\n    && qualityLoopResult.passed\n    ? qualityLoopResult.fixedContent\n    : null;\n  if (finalizedFileContent) {\n    parsed.content = finalizedFileContent;\n    parsed.contentHash = memoryParser.computeContentHash(parsed.content);\n  }\n\n  const sourceClassification = classifyMemorySaveSource(parsed.content);\n  if (sourceClassification === MANUAL_FALLBACK_SOURCE_CLASSIFICATION) {\n    const warning = 'Manual fallback save mode detected; standard generate-context template markers are missing.';\n    console.warn(`[memory-save] ${warning} ${path.basename(parsed.filePath)}`);\n    validation.warnings.push(warning);\n  }\n\n  const sufficiencyResult = evaluateMemorySufficiency(\n    {\n      ...buildParsedMemoryEvidenceSnapshot(parsed),\n      sourceClassification,\n    },\n  );\n  applyInsufficiencyMetadata(parsed, sufficiencyResult);\n  const templateContract = validateMemoryTemplateContract(parsed.content);\n\n  // Non-blocking spec doc health annotation\n  // Canonical saves land directly in the spec folder (e.g. .../NNN-name/decision-record.md),\n  // so the immediate parent is usually the spec folder itself.\n  let specDocHealth: SpecDocHealthResult | null = null;\n  if (parsed.specFolder && parsed.filePath) {\n    try {\n      const absFilePath = path.resolve(parsed.filePath);\n      const immediateParent = path.dirname(absFilePath);\n      const candidates = [immediateParent, path.dirname(immediateParent)];\n      for (const candidate of candidates) {\n        if (fs.existsSync(path.join(candidate, 'spec.md'))) {\n          specDocHealth = evaluateSpecDocHealth(candidate);\n          break;\n        }\n      }\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(\n        `[memory-save] spec-doc-health annotation skipped for ${path.basename(parsed.filePath)}: ${message}`\n      );\n    }\n  }\n\n  return {\n    parsed,\n    validation,\n    qualityLoopResult,\n    sufficiencyResult,\n    templateContract,\n    specDocHealth,\n    finalizedFileContent,\n    sourceClassification,\n  };\n}\n\nasync function finalizeMemoryFileContent(\n  filePath: string,\n  content: string,\n): Promise<void> {\n  const backupPath = `${filePath}.${randomUUID().slice(0, 8)}.bak`;\n  const tempPath = `${filePath}.${randomUUID().slice(0, 8)}.tmp`;\n  let backupCreated = false;\n  let tempCreated = false;\n\n  try {\n    try {\n      await fs.promises.copyFile(filePath, backupPath);\n      backupCreated = true;\n    } catch (backupErr: unknown) {\n      const errCode = typeof backupErr === 'object' && backupErr !== null && 'code' in backupErr\n        ? String((backupErr as NodeJS.ErrnoException).code)\n        : '';\n      if (errCode !== 'ENOENT') {\n        throw backupErr;\n      }\n    }\n\n    await fs.promises.writeFile(tempPath, content, 'utf-8');\n    tempCreated = true;\n    await fs.promises.rename(tempPath, filePath);\n    tempCreated = false;\n  } catch (writeErr: unknown) {\n    if (tempCreated) {\n      try {\n        await fs.promises.unlink(tempPath);\n      } catch {\n        // Best-effort cleanup only.\n      }\n    }\n    if (backupCreated) {\n      try {\n        await fs.promises.copyFile(backupPath, filePath);\n      } catch (restoreErr: unknown) {\n        console.warn(\n          '[memory-save] Auto-fix file restore failed after finalize error:',\n          restoreErr instanceof Error ? restoreErr.message : String(restoreErr),\n        );\n      }\n    }\n    throw writeErr;\n  } finally {\n    if (tempCreated) {\n      try {\n        await fs.promises.unlink(tempPath);\n      } catch {\n        // Best-effort cleanup only.\n      }\n    }\n    if (backupCreated) {\n      try {\n        await fs.promises.unlink(backupPath);\n      } catch {\n        // Best-effort cleanup only.\n      }\n    }\n  }\n}\n\nfunction appendResultWarning<T extends Record<string, unknown>>(result: T, warning: string | null): T {\n  if (!warning) {\n    return result;\n  }\n\n  const r = result as Record<string, unknown>;\n  const warnings = Array.isArray(r.warnings)\n    ? [...(r.warnings as string[])]\n    : [];\n  warnings.push(warning);\n  r.warnings = warnings;\n  return result;\n}\n\nclass SaveTimeReconsolidationAbort extends Error {\n  readonly result: {\n    status: 'failed';\n    reason: ReconsolidationFailureReason;\n    warnings?: string[];\n    persistedState?: ReconsolidationOperationState;\n  };\n\n  constructor(result: SaveTimeReconsolidationAbort['result']) {\n    super(result.reason);\n    this.name = 'SaveTimeReconsolidationAbort';\n    this.result = result;\n  }\n}\n\nfunction buildSaveTimeReconsolidationFailureResult(args: {\n  parsed: ReturnType<typeof memoryParser.parseMemoryFile>;\n  validation: { warnings: string[] };\n  reconWarnings: string[];\n  failure: SaveTimeReconsolidationAbort['result'];\n  message?: string;\n}): IndexResult {\n  const warnings = [\n    ...args.validation.warnings,\n    ...args.reconWarnings,\n    ...(args.failure.warnings ?? []),\n  ];\n","lineStart":380,"lineEnd":699,"totalLines":4082,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1781764140817,"end":1781764140828}},"metadata":{"openai":{"itemId":"fc_0d6ae382ff28249e016a33902cb6248191a0a6bc296b710f28"}},"id":"prt_ed96b2edc0010Adk74VwQnHYSQ","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed96afb7e001W3qLsQ87QsFGNb"}}
