.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:48:  node generate-context.js ${SESSION_SCOPED_SAVE_CONTEXT_EXAMPLE} specs/001-feature/
.opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js:49:  node generate-context.js ${SESSION_SCOPED_SAVE_CONTEXT_EXAMPLE} .opencode/specs/001-feature/
