{"type":"tool_use","timestamp":1781762552978,"sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","part":{"type":"tool","tool":"read","callID":"call_Uk4mSKAqAVD6HllO0uIHS8l8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Queries\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts — contains ALL query/search functions,\n6: // Content extraction, ranking, stats, cleanup, and integrity checks.\n7: \n8: import * as path from 'path';\n9: import * as fs from 'fs';\n10: import type Database from 'better-sqlite3';\n11: import { formatAgeString as format_age_string } from '../utils/format-helpers.js';\n12: import { createLogger } from '../utils/logger.js';\n13: import { recordHistory } from '../storage/history.js';\n14: import { isArchivedVectorInclusionEnabled } from './search-flags.js';\n15: import * as embeddingsProvider from '../providers/embeddings.js';\n16: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\n17: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n18: import { getEmbedderAdapter } from '../embedders/execution-router.js';\n19: import { getManifest } from '../embedders/registry.js';\n20: import {\n21:   computeContentHash,\n22:   getActiveEmbeddingProfileKey,\n23:   lookupEmbedding,\n24:   storeEmbedding,\n25: } from '../cache/embedding-cache.js';\n26: import {\n27:   get_error_message,\n28:   parse_trigger_phrases,\n29:   specFolderLikePattern,\n30:   to_embedding_buffer,\n31:   VectorIndexError,\n32:   VectorIndexErrorCode,\n33: } from './vector-index-types.js';\n34: import {\n35:   initialize_db,\n36:   get_embedding_dim,\n37:   get_constitutional_memories,\n38:   init_prepared_statements,\n39:   validate_file_path_local,\n40:   safe_read_file_async,\n41:   safe_parse_json,\n42:   search_weights,\n43:   sqlite_vec_available as get_sqlite_vec_available,\n44:   activeVectorSource as activeVectorSchema,\n45: } from './vector-index-store.js';\n46: import { delete_memory_from_database } from './vector-index-mutations.js';\n47: import type {\n48:   EmbeddingInput,\n49:   EnrichedSearchResult,\n50:   MemoryRow,\n51:   VectorSearchOptions,\n52: } from './vector-index-types.js';\n53: \n54: const logger = createLogger('VectorIndex');\n55: \n56: type RelatedMemoryLink = { id: number; similarity: number };\n57: type UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\n58: type CleanupOptions = {\n59:   maxAgeDays?: number;\n60:   maxAccessCount?: number;\n61:   maxConfidence?: number;\n62:   limit?: number;\n63: };\n64: type VectorSource = {\n65:   dim: number;\n66:   tableName: string;\n67:   idColumn: string;\n68:   embeddingColumn: string;\n69: };\n70: \n71: export interface KnnQueryShapeBenchmarkResult {\n72:   readonly corpusSize: number;\n73:   readonly iterations: number;\n74:   readonly scalarJoinAverageMs: number;\n75:   readonly matchAverageMs: number | null;\n76:   readonly matchSupported: boolean;\n77:   readonly matchImprovementPct: number | null;\n78:   readonly decision: 'adopt_match' | 'keep_scalar_join';\n79:   readonly reason: string;\n80: }\n81: \n82: const KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n83: \n84: function appendSpecFolderScope(\n85:   clauses: string[],\n86:   params: unknown[],\n87:   specFolder: string | null | undefined,\n88:   column = 'm.spec_folder',\n89: ): void {\n90:   if (!specFolder) return;\n91:   clauses.push(`(${column} = ? OR ${column} LIKE ? ESCAPE '\\\\')`);\n92:   params.push(specFolder, specFolderLikePattern(specFolder));\n93: }\n94: \n95: function tableExists(database: Database.Database, tableName: string): boolean {\n96:   const row = database.prepare(`\n97:     SELECT 1 AS found\n98:     FROM active_vec.sqlite_master\n99:     WHERE type = 'table' AND name = ?\n100:     LIMIT 1\n101:   `).get(tableName) as { found?: number } | undefined;\n102:   return row?.found === 1;\n103: }\n104: \n105: function getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n106:   const active = getActiveEmbedder(database);\n107:   const dimTableName = `vec_${active.dim}`;\n108:   if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n109:     return {\n110:       dim: active.dim,\n111:       tableName: activeVectorSchema(dimTableName),\n112:       idColumn: 'id',\n113:       embeddingColumn: 'vec',\n114:     };\n115:   }\n116: \n117:   return {\n118:     dim: get_embedding_dim(),\n119:     tableName: activeVectorSchema('vec_memories'),\n120:     idColumn: 'rowid',\n121:     embeddingColumn: 'embedding',\n122:   };\n123: }\n124: \n125: function elapsedMs(start: bigint): number {\n126:   return Number(process.hrtime.bigint() - start) / 1_000_000;\n127: }\n128: \n129: function average(values: number[]): number {\n130:   if (values.length === 0) return 0;\n131:   return values.reduce((sum, value) => sum + value, 0) / values.length;\n132: }\n133: \n134: export function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n135:   return result.matchSupported === true\n136:     && typeof result.matchImprovementPct === 'number'\n137:     && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n138: }\n139: \n140: export function benchmarkKnnQueryShapes(\n141:   query_embedding: EmbeddingInput,\n142:   options: { iterations?: number; limit?: number } = {},\n143:   database: Database.Database = initialize_db(),\n144: ): KnnQueryShapeBenchmarkResult {\n145:   const vectorSource = getActiveVectorSourceForQuery(database);\n146:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n147:     throw new VectorIndexError(\n148:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n149:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n150:     );\n151:   }\n152: \n153:   const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n154:   const limit = Math.max(1, Math.floor(options.limit ?? 20));\n155:   const queryBuffer = to_embedding_buffer(query_embedding);\n156:   const corpusSize = (database.prepare(`\n157:     SELECT COUNT(*) AS count\n158:     FROM memory_index m\n159:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n160:     WHERE m.embedding_status = 'success'\n161:   `).get() as { count: number }).count;\n162: \n163:   const scalarSql = `\n164:     SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n165:     FROM memory_index m\n166:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n167:     JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n168:     WHERE m.embedding_status = 'success'\n169:     ORDER BY distance ASC\n170:     LIMIT ?\n171:   `;\n172:   const scalarStmt = database.prepare(scalarSql);\n173:   scalarStmt.all(queryBuffer, limit);\n174:   const scalarRuns: number[] = [];\n175:   for (let i = 0; i < iterations; i += 1) {\n176:     const start = process.hrtime.bigint();\n177:     scalarStmt.all(queryBuffer, limit);\n178:     scalarRuns.push(elapsedMs(start));\n179:   }\n180: \n181:   const matchTable = activeVectorSchema('vec_memories');\n182:   const matchAvailable = tableExists(database, 'vec_memories');\n183:   let matchAverageMs: number | null = null;\n184:   let matchError: string | null = null;\n185: \n186:   if (matchAvailable) {\n187:     try {\n188:       const matchSql = `\n189:         WITH knn AS (\n190:           SELECT rowid, distance\n191:           FROM ${matchTable}\n192:           WHERE embedding MATCH ? AND k = ?\n193:         )\n194:         SELECT m.id, knn.distance\n195:         FROM knn\n196:         JOIN memory_index m ON m.id = knn.rowid\n197:         JOIN active_memory_projection p ON p.active_memory_id = m.id\n198:         WHERE m.embedding_status = 'success'\n199:         ORDER BY knn.distance ASC\n200:         LIMIT ?\n201:       `;\n202:       const matchStmt = database.prepare(matchSql);\n203:       matchStmt.all(queryBuffer, limit, limit);\n204:       const matchRuns: number[] = [];\n205:       for (let i = 0; i < iterations; i += 1) {\n206:         const start = process.hrtime.bigint();\n207:         matchStmt.all(queryBuffer, limit, limit);\n208:         matchRuns.push(elapsedMs(start));\n209:       }\n210:       matchAverageMs = average(matchRuns);\n211:     } catch (error: unknown) {\n212:       matchError = get_error_message(error);\n213:     }\n214:   }\n215: \n216:   const scalarJoinAverageMs = average(scalarRuns);\n217:   const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n218:     ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n219:     : null;\n220:   const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n221:     matchSupported: matchAverageMs !== null,\n222:     matchImprovementPct,\n223:   };\n224:   const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n225: \n226:   return {\n227:     corpusSize,\n228:     iterations,\n229:     scalarJoinAverageMs,\n230:     matchAverageMs,\n231:     matchSupported: matchAverageMs !== null,\n232:     matchImprovementPct,\n233:     decision,\n234:     reason: decision === 'adopt_match'\n235:       ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n236:       : matchError\n237:         ? `MATCH unavailable: ${matchError}`\n238:         : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n239:   };\n240: }\n241: \n242: /* ───────────────────────────────────────────────────────────────\n243:    SIMPLE QUERIES\n244: ----------------------------------------------------------------*/\n245: \n246: /**\n247:  * Gets one indexed memory by identifier.\n248:  * @param id - The memory identifier.\n249:  * @returns The matching memory row, if found.\n250:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n251:  * @example\n252:  * ```ts\n253:  * const memory = get_memory(42);\n254:  * ```\n255:  */\n256: export function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n257:   const stmts = init_prepared_statements(database);\n258:   const row = stmts.get_by_id.get(id);\n259: \n260:   if (row) {\n261:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n262:     row.isConstitutional = row.importance_tier === 'constitutional';\n263:   }\n264: \n265:   return row || null;\n266: }\n267: \n268: /**\n269:  * Gets indexed memories for a spec folder.\n270:  * @param spec_folder - The spec folder to query.\n271:  * @returns The memory rows for the folder.\n272:  */\n273: export function get_memories_by_folder(\n274:   spec_folder: string,\n275:   database: Database.Database = initialize_db(),\n276: ): MemoryRow[] {\n277:   const rows = database.prepare(`\n278:     SELECT m.*\n279:     FROM memory_index m\n280:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n281:     WHERE (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\n282:     ORDER BY m.created_at DESC\n283:   `).all(spec_folder, specFolderLikePattern(spec_folder)) as MemoryRow[];\n284: \n285:   return rows.map((row: MemoryRow) => {\n286:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n287:     row.isConstitutional = row.importance_tier === 'constitutional';\n288:     return row;\n289:   });\n290: }\n291: \n292: /**\n293:  * Gets the total number of indexed memories.\n294:  * @returns The total memory count.\n295:  */\n296: export function get_memory_count(database: Database.Database = initialize_db()): number {\n297:   const stmts = init_prepared_statements(database);\n298:   const result = stmts.count_all.get();\n299:   return result?.count ?? 0;\n300: }\n301: \n302: /**\n303:  * Gets memory counts grouped by embedding status.\n304:  * @returns The counts for each embedding status.\n305:  */\n306: export function get_status_counts(\n307:   database: Database.Database = initialize_db(),\n308: ): { pending: number; success: number; failed: number; retry: number; partial: number } {\n309:   const rows = database.prepare(`\n310:     SELECT m.embedding_status, COUNT(*) as count\n311:     FROM memory_index m\n312:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n313:     GROUP BY m.embedding_status\n314:   `).all();\n315: \n316:   // Include 'partial' status in counts.\n317:   const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n318:   for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n319:     if (row.embedding_status in counts) {\n320:       counts[row.embedding_status] = row.count;\n321:     }\n322:   }\n323: \n324:   return counts;\n325: }\n326: \n327: /**\n328:  * Gets summary counts for indexed memories.\n329:  * @returns The aggregate memory statistics.\n330:  */\n331: export function get_stats(\n332:   database: Database.Database = initialize_db(),\n333: ): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n334:   const counts = get_status_counts(database);\n335:   const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n336: \n337:   return {\n338:     total,\n339:     ...counts\n340:   };\n341: }\n342: \n343: /* ───────────────────────────────────────────────────────────────\n344:    VECTOR SEARCH\n345: ----------------------------------------------------------------*/\n346: \n347: /**\n348:  * Searches indexed memories by vector similarity.\n349:  * @param query_embedding - The query embedding to search with.\n350:  * @param options - Search options.\n351:  * @returns The matching memory rows.\n352:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n353:  * @example\n354:  * ```ts\n355:  * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n356:  * ```\n357:  */\n358: export function vector_search(\n359:   query_embedding: EmbeddingInput,\n360:   options: VectorSearchOptions = {},\n361:   database: Database.Database = initialize_db(),\n362: ): MemoryRow[] {\n363:   const sqlite_vec = get_sqlite_vec_available();\n364:   if (!sqlite_vec) {\n365:     console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n366:     return [];\n367:   }\n368: \n369:   const {\n370:     limit = 10,\n371:     specFolder = null,\n372:     minSimilarity = 0,\n373:     useDecay = true,\n374:     tier = null,\n375:     contextType = null,\n376:     includeConstitutional = true,\n377:     includeArchived = false\n378:   } = options;\n379: \n380:   const vectorSource = getActiveVectorSourceForQuery(database);\n381:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n382:     throw new VectorIndexError(\n383:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n384:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n385:     );\n386:   }\n387: \n388:   const query_buffer = to_embedding_buffer(query_embedding);\n389:   const max_distance = 2 * (1 - minSimilarity / 100);\n390: \n391:   // FSRS-preferred decay with half-life fallback\n392:   const decay_expr = useDecay\n393:     ? `CASE\n394:          WHEN m.is_pinned = 1 THEN m.importance_weight\n395:          WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n396:            m.importance_weight * POWER(\n397:              1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n398:              -0.5\n399:            )\n400:          ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n401:        END`\n402:     : 'm.importance_weight';\n403: \n404:   let constitutional_results: MemoryRow[] = [];\n405: \n406:   if (includeConstitutional && tier !== 'constitutional') {\n407:     constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n408:   }\n409: \n410:   const where_clauses = ['m.embedding_status = \\'success\\''];\n411:   const params: unknown[] = [query_buffer];\n412: \n413:   where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n414: \n415:   if (tier === 'deprecated') {\n416:     where_clauses.push('m.importance_tier = ?');\n417:     params.push('deprecated');\n418:   } else if (tier === 'constitutional') {\n419:     where_clauses.push('m.importance_tier = ?');\n420:     params.push('constitutional');\n421:   } else if (tier) {\n422:     where_clauses.push('m.importance_tier = ?');\n423:     params.push(tier);\n424:   } else if (isArchivedVectorInclusionEnabled()) {\n425:     // Cold/archived rows admitted to the projection (option A) must not be re-excluded\n426:     // here; still keep constitutional on its own injected path.\n427:     where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier != \\'constitutional\\')');\n428:   } else {\n429:     where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n430:   }\n431: \n432:   appendSpecFolderScope(where_clauses, params, specFolder);\n433: \n434:   if (contextType) {\n435:     where_clauses.push('m.context_type = ?');\n436:     params.push(contextType);\n437:   }\n438: \n439:   // If constitutional results already satisfy limit, return them directly.\n440:   if (constitutional_results.length >= limit) {\n441:     return constitutional_results.slice(0, limit);\n442:   }\n443:   const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n444:   params.push(max_distance, adjusted_limit);\n445: \n446:   const sql = `\n447:     SELECT sub.*,\n448:            ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n449:     FROM (\n450:       SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n451:              ${decay_expr} as effective_importance\n452:       FROM memory_index m\n453:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n454:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n455:       WHERE ${where_clauses.join(' AND ')}\n456:     ) sub\n457:     WHERE sub.distance <= ?\n458:     ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n459:     LIMIT ?\n460:   `;\n461: \n462:   const rows = database.prepare(sql).all(...params);\n463: \n464:   const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n465:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n466:     row.isConstitutional = row.importance_tier === 'constitutional';\n467:     return row;\n468:   });\n469: \n470:   return [...constitutional_results, ...regular_results];\n471: }\n472: \n473: /**\n474:  * Gets constitutional memories for prompt assembly.\n475:  * @param options - Retrieval options.\n476:  * @returns The constitutional memory rows.\n477:  */\n478: export function get_constitutional_memories_public(\n479:   options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n480:   database: Database.Database = initialize_db(),\n481: ): MemoryRow[] {\n482:   const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n483: \n484:   let results = get_constitutional_memories(database, specFolder, includeArchived);\n485: \n486:   const TOKENS_PER_MEMORY = 100;\n487:   const max_count = Math.floor(maxTokens / TOKENS_PER_MEMORY);\n488:   if (results.length > max_count) {\n489:     results = results.slice(0, max_count);\n490:   }\n491: \n492:   return results;\n493: }\n494: \n495: /**\n496:  * Searches indexed memories with multiple concept embeddings.\n497:  * @param concept_embeddings - The concept embeddings to search with.\n498:  * @param options - Search options.\n499:  * @returns The matching memory rows.\n500:  * @throws {VectorIndexError} When concept count or embedding dimensions are invalid, or when store initialization fails.\n501:  * @example\n502:  * ```ts\n503:  * const rows = multi_concept_search([embA, embB], { limit: 8, specFolder: 'specs/001-demo' });\n504:  * ```\n505:  */\n506: export function multi_concept_search(\n507:   concept_embeddings: EmbeddingInput[],\n508:   options: { limit?: number; specFolder?: string | null; minSimilarity?: number } = {}\n509: ): MemoryRow[] {\n510:   const sqlite_vec = get_sqlite_vec_available();\n511:   if (!sqlite_vec) {\n512:     console.warn('[vector-index] Multi-concept search unavailable - sqlite-vec not loaded');\n513:     return [];\n514:   }\n515: \n516:   const database = initialize_db();\n517: \n518:   const concepts = concept_embeddings;\n519:   if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n520:     throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n521:   }\n522: \n523:   const vectorSource = getActiveVectorSourceForQuery(database);\n524:   for (const emb of concepts) {\n525:     if (!emb || emb.length !== vectorSource.dim) {\n526:       throw new VectorIndexError(\n527:         `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n528:         VectorIndexErrorCode.QUERY_FAILED,\n529:       );\n530:     }\n531:   }\n532: \n533:   const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n534: \n535:   const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n536:   const max_distance = 2 * (1 - minSimilarity / 100);\n537: \n538:   const distance_expressions = concept_buffers.map((_, i) =>\n539:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n540:   ).join(', ');\n541: \n542:   const distance_filters = concept_buffers.map((_, _i) =>\n543:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n544:   ).join(' AND ');\n545: \n546:   const folder_filter = specFolder ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\" : '';\n547:   const similarity_select = concept_buffers.map((_, i) =>\n548:     `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n549:   ).join(', ');\n550: \n551:   const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n552: \n553:   const sql = `\n554:     SELECT\n555:       sub.*,\n556:       ${similarity_select},\n557:       (${avg_distance_expr}) / ${concepts.length} as avg_distance\n558:     FROM (\n559:       SELECT\n560:         m.*,\n561:         ${distance_expressions}\n562:       FROM memory_index m\n563:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n564:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n565:       WHERE m.embedding_status = 'success'\n566:         AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n567:         ${folder_filter}\n568:         AND ${distance_filters}\n569:     ) sub\n570:     ORDER BY avg_distance ASC\n571:     LIMIT ?\n572:   `;\n573: \n574:   const params = [\n575:     ...concept_buffers,\n576:     ...(specFolder ? [specFolder, specFolderLikePattern(specFolder)] : []),\n577:     ...concept_buffers.flatMap(b => [b, max_distance]),\n578:     limit\n579:   ];\n580: \n581:   const rows = database.prepare(sql).all(...params);\n582: \n583:   return (rows as MemoryRow[]).map((row: MemoryRow) => {\n584:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n585:     row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n586:     row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n587:     row.isConstitutional = row.importance_tier === 'constitutional';\n588:     return row;\n589:   });\n590: }\n591: \n592: /* ───────────────────────────────────────────────────────────────\n593:    CONTENT EXTRACTION HELPERS\n594: ----------------------------------------------------------------*/\n595: \n596: /**\n597:  * Extracts a display title from indexed content.\n598:  * @param content - The content to inspect.\n599:  * @param filename - The optional source filename.\n600:  * @returns The extracted title.\n601:  */\n602: export function extract_title(content: unknown, filename?: string): string {\n603:   if (!content || typeof content !== 'string') {\n604:     return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n605:   }\n606: \n607:   const h1_match = content.match(/^#\\s+(.+)$/m);\n608:   if (h1_match && h1_match[1]) {\n609:     return h1_match[1].trim();\n610:   }\n611: \n612:   const h2_match = content.match(/^##\\s+(.+)$/m);\n613:   if (h2_match && h2_match[1]) {\n614:     return h2_match[1].trim();\n615:   }\n616: \n617:   const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n618:   if (yaml_match && yaml_match[1]) {\n619:     return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n620:   }\n621: \n622:   const lines = content.split('\\n').filter(l => l.trim().length > 0);\n623:   if (lines.length > 0) {\n624:     const first_line = lines[0].trim();\n625:     return first_line.replace(/^#+\\s*/, '').substring(0, 100);\n626:   }\n627: \n628:   return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n629: }\n630: \n631: /**\n632:  * Extracts a preview snippet from indexed content.\n633:  * @param content - The content to inspect.\n634:  * @param max_length - The maximum snippet length.\n635:  * @returns The extracted snippet.\n636:  */\n637: export function extract_snippet(content: unknown, max_length = 200): string {\n638:   if (!content || typeof content !== 'string') {\n639:     return '';\n640:   }\n641: \n642:   const text = content.replace(/^---[\\s\\S]*?---\\n*/m, '');\n643:   const lines = text.split('\\n');\n644:   const snippet_lines: string[] = [];\n645: \n646:   for (const line of lines) {\n647:     const trimmed = line.trim();\n648: \n649:     if (!trimmed || /^#+\\s/.test(trimmed)) {\n650:       if (snippet_lines.length > 0) {\n651:         break;\n652:       }\n653:       continue;\n654:     }\n655: \n656:     if (/^[a-z_-]+:\\s/i.test(trimmed) && snippet_lines.length === 0) {\n657:       continue;\n658:     }\n659: \n660:     snippet_lines.push(trimmed);\n661: \n662:     const current_length = snippet_lines.join(' ').length;\n663:     if (current_length >= max_length) {\n664:       break;\n665:     }\n666:   }\n667: \n668:   let snippet = snippet_lines.join(' ');\n669: \n670:   if (snippet.length > max_length) {\n671:     snippet = snippet.substring(0, max_length);\n672:     const last_space = snippet.lastIndexOf(' ');\n673:     if (last_space > max_length * 0.7) {\n674:       snippet = snippet.substring(0, last_space);\n675:     }\n676:     snippet += '...';\n677:   }\n678: \n679:   return snippet;\n680: }\n681: \n682: /**\n683:  * Extracts tags from indexed content.\n684:  * @param content - The content to inspect.\n685:  * @returns The extracted tags.\n686:  */\n687: export function extract_tags(content: unknown): string[] {\n688:   if (!content || typeof content !== 'string') {\n689:     console.warn('[vector-index] extract_tags: invalid content type, expected string');\n690:     return [];\n691:   }\n692: \n693:   const tags = new Set<string>();\n694: \n695:   const yaml_tags_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\[([^\\]]+)\\]/m);\n696:   if (yaml_tags_match && yaml_tags_match[1]) {\n697:     yaml_tags_match[1].split(',').forEach(tag => {\n698:       const cleaned = tag.trim().replace(/^[\"']|[\"']$/g, '');\n699:       if (cleaned) tags.add(cleaned.toLowerCase());\n700:     });\n701:   }\n702: \n703:   const yaml_list_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/m);\n704:   if (yaml_list_match && yaml_list_match[1]) {\n705:     yaml_list_match[1].match(/-\\s*(.+)/g)?.forEach(match => {\n706:       const tag = match.replace(/^-\\s*/, '').trim().replace(/^[\"']|[\"']$/g, '');\n707:       if (tag) tags.add(tag.toLowerCase());\n708:     });\n709:   }\n710: \n711:   const hashtag_matches = content.match(/(?:^|\\s)#([a-zA-Z][a-zA-Z0-9_-]*)/g);\n712:   if (hashtag_matches) {\n713:     hashtag_matches.forEach(match => {\n714:       const tag = match.trim().replace(/^#/, '');\n715:       if (tag && !tag.match(/^[0-9]+$/)) {\n716:         tags.add(tag.toLowerCase());\n717:       }\n718:     });\n719:   }\n720: \n721:   return Array.from(tags);\n722: }\n723: \n724: /**\n725:  * Extracts a relevant date from indexed content or path.\n726:  * @param content - The content to inspect.\n727:  * @param file_path - The optional source file path.\n728:  * @returns The extracted date, if available.\n729:  */\n730: export function extract_date(content: unknown, file_path?: string): string | null {\n731:   if (content && typeof content === 'string') {\n732:     const date_match = content.match(/^---[\\s\\S]*?^date:\\s*(.+)$/m);\n733:     if (date_match && date_match[1]) {\n734:       const date_str = date_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n735:       try {\n736:         const parsed = new Date(date_str);\n737:         if (!isNaN(parsed.getTime())) {\n738:           return parsed.toISOString().split('T')[0];\n739:         }\n740:       } catch (_e: unknown) {\n741:         console.warn('[vector-index-queries] Date parsing failed', { error: _e instanceof Error ? _e.message : String(_e) });\n742:       }\n743:     }\n744:   }\n745: \n746:   if (file_path) {\n747:     const filename = path.basename(file_path);\n748: \n749:     const iso_match = filename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n750:     if (iso_match) {\n751:       return iso_match[1];\n752:     }\n753: \n754:     const ddmmyy_match = filename.match(/(\\d{2})-(\\d{2})-(\\d{2})/);\n755:     if (ddmmyy_match) {\n756:       const [, day, month, year] = ddmmyy_match;\n757:       const full_year = parseInt(year) > 50 ? `19${year}` : `20${year}`;\n758:       return `${full_year}-${month}-${day}`;\n759:     }\n760:   }\n761: \n762:   return null;\n763: }\n764: \n765: /* ───────────────────────────────────────────────────────────────\n766:    EMBEDDING GENERATION WRAPPER\n767: ----------------------------------------------------------------*/\n768: \n769: /**\n770:  * Generates an embedding for a search query.\n771:  * @param query - The search query.\n772:  * @returns A promise that resolves to the embedding, if generated.\n773:  */\n774: export async function generate_query_embedding(query: string): Promise<Float32Array | null> {\n775:   if (!query || typeof query !== 'string' || query.trim().length === 0) {\n776:     console.warn('[vector-index] Empty query provided for embedding');\n777:     return null;\n778:   }\n779: \n780:   try {\n781:     const database = initialize_db();\n782:     const active = getActiveEmbedder(database);\n783:     const trimmedQuery = query.trim();\n784:     const modelId = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n785:       ? active.name\n786:       : embeddingsProvider.getModelName();\n787:     const embeddingDim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n788:       ? active.dim\n789:       : embeddingsProvider.getEmbeddingDimension();\n790:     const profileKey = getActiveEmbeddingProfileKey(database, modelId, embeddingDim);\n791:     const contentHash = computeContentHash(trimmedQuery);\n792:     const cached = lookupEmbedding(database, contentHash, modelId, embeddingDim, {\n793:       profileKey,\n794:       inputKind: 'query',\n795:     });\n796:     if (cached) {\n797:       return new Float32Array(\n798:         cached.buffer,\n799:         cached.byteOffset,\n800:         Math.floor(cached.byteLength / Float32Array.BYTES_PER_ELEMENT),\n801:       );\n802:     }\n803: \n804:     const provider = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n805:       ? active.provider ?? getManifest(active.name)?.backend ?? 'ollama'\n806:       : getStartupEmbeddingProfile().provider;\n807:     const adapter = getEmbedderAdapter(provider, modelId, embeddingDim);\n808:     const activeAdapter = adapter as typeof adapter & {\n809:       embed: (\n810:         texts: ReadonlyArray<string>,\n811:         options?: { inputType?: 'query' | 'document' },\n812:       ) => Promise<Float32Array[]>;\n813:     };\n814:     const [activeEmbedding] = await activeAdapter.embed([trimmedQuery], { inputType: 'query' });\n815:     const embedding: Float32Array | null = activeEmbedding ?? null;\n816: \n817:     if (embedding) {\n818:       storeEmbedding(\n819:         database,\n820:         contentHash,\n821:         modelId,\n822:         Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n823:         embedding.length,\n824:         { profileKey, inputKind: 'query' },\n825:       );\n826:     }\n827: \n828:     return embedding;\n829:   } catch (error: unknown) {\n830:     console.warn(`[vector-index] Query embedding failed: ${get_error_message(error)}`);\n831:     return null;\n832:   }\n833: }\n834: \n835: /* ───────────────────────────────────────────────────────────────\n836:    KEYWORD SEARCH FALLBACK\n837: ----------------------------------------------------------------*/\n838: \n839: /**\n840:  * Searches indexed memories using keyword matching.\n841:  * @param query - The search query.\n842:  * @param options - Search options.\n843:  * @returns The matching memory rows.\n844:  */\n845: export function keyword_search(\n846:   query: string,\n847:   options: { limit?: number; specFolder?: string | null } = {},\n848:   database: Database.Database = initialize_db(),\n849: ): MemoryRow[] {\n850:   const { limit = 20, specFolder = null } = options;\n851: \n852:   if (!query || typeof query !== 'string') {\n853:     console.warn('[vector-index] keyword_search: invalid query, expected non-empty string');\n854:     return [];\n855:   }\n856: \n857:   const search_terms = query.toLowerCase().trim().split(/\\s+/).filter(t => t.length >= 2);\n858:   if (search_terms.length === 0) {\n859:     console.warn('[vector-index] keyword_search: no valid search terms after tokenization');\n860:     return [];\n861:   }\n862: \n863:   let where_clause = '1=1';\n864:   const params: unknown[] = [];\n865: \n866:   if (specFolder) {\n867:     where_clause += \" AND (spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')\";\n868:     params.push(specFolder, specFolderLikePattern(specFolder));\n869:   }\n870: \n871:   const sql = `\n872:     SELECT m.* FROM memory_index m\n873:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n874:     WHERE ${where_clause}\n875:     ORDER BY m.importance_weight DESC, m.created_at DESC\n876:   `;\n877: \n878:   const rows = database.prepare(sql).all(...params);\n879: \n880:   const scored = (rows as MemoryRow[]).map((row: MemoryRow) => {\n881:     let score = 0;\n882:     const searchable_text = [\n883:       row.title || '',\n884:       parse_trigger_phrases(row.trigger_phrases).join(' '),\n885:       row.spec_folder || '',\n886:       row.file_path || ''\n887:     ].join(' ').toLowerCase();\n888: \n889:     for (const term of search_terms) {\n890:       if (searchable_text.includes(term)) {\n891:         score += 1;\n892:         if ((row.title || '').toLowerCase().includes(term)) {\n893:           score += 2;\n894:         }\n895:         if (parse_trigger_phrases(row.trigger_phrases).join(' ').toLowerCase().includes(term)) {\n896:           score += 1.5;\n897:         }\n898:       }\n899:     }\n900: \n901:     score *= (0.5 + (row.importance_weight ?? 0));\n902:     return { ...row, keyword_score: score };\n903:   });\n904: \n905:   const filtered = scored\n906:     .filter((row: MemoryRow) => Number(row.keyword_score ?? 0) > 0)\n907:     .sort((a: MemoryRow, b: MemoryRow) => Number(b.keyword_score ?? 0) - Number(a.keyword_score ?? 0))\n908:     .slice(0, limit);\n909: \n910:   return filtered.map((row: MemoryRow) => {\n911:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n912:     row.isConstitutional = row.importance_tier === 'constitutional';\n913:     return row;\n914:   });\n915: }\n916: \n917: /* ───────────────────────────────────────────────────────────────\n918:    ENRICHED VECTOR SEARCH\n919: ----------------------------------------------------------------*/\n920: \n921: /**\n922:  * Runs enriched vector search for a text query.\n923:  * @param query - The search query.\n924:  * @param limit - The maximum number of results to return.\n925:  * @param options - Search options.\n926:  * @returns A promise that resolves to enriched search results.\n927:  * @throws {VectorIndexError} Propagates vector-store initialization failures from the underlying search pipeline.\n928:  * @example\n929:  * ```ts\n930:  * const results = await vector_search_enriched('sqlite vec mismatch', 10, { specFolder: 'specs/001-demo' });\n931:  * ```\n932:  */\n933: export async function vector_search_enriched(\n934:   query: string,\n935:   limit = 20,\n936:   options: { specFolder?: string | null; minSimilarity?: number } = {},\n937:   database: Database.Database = initialize_db(),\n938: ): Promise<EnrichedSearchResult[]> {\n939:   const start_time = Date.now();\n940:   const { specFolder = null, minSimilarity = 30 } = options;\n941: \n942:   const query_embedding = await generate_query_embedding(query);\n943: \n944:   let raw_results;\n945:   let search_method = 'vector';\n946: \n947:   const sqlite_vec = get_sqlite_vec_available();\n948:   if (query_embedding && sqlite_vec) {\n949:     raw_results = vector_search(query_embedding, {\n950:       limit,\n951:       specFolder,\n952:       minSimilarity\n953:     }, database);\n954:   } else {\n955:     console.warn('[vector-index] Falling back to keyword search');\n956:     search_method = 'keyword';\n957:     raw_results = keyword_search(query, { limit, specFolder }, database);\n958:   }\n959: \n960:   // HIGH-004 FIX: Read all files concurrently\n961:   const file_contents = await Promise.all(\n962:     raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n963:   );\n964: \n965:   const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n966:     const content = file_contents[i];\n967:     const title = row.title || extract_title(content, row.file_path);\n968:     const snippet = extract_snippet(content);\n969:     const tags = extract_tags(content);\n970:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n971: \n972:     const similarity = search_method === 'vector'\n973:       ? (row.similarity || 0)\n974:       : Math.min(100, (row.keyword_score || 0) * 20);\n975: \n976:     return {\n977:       rank: i + 1,\n978:       similarity: Math.round(similarity * 100) / 100,\n979:       title,\n980:       specFolder: row.spec_folder,\n981:       filePath: row.file_path,\n982:       date,\n983:       tags,\n984:       snippet,\n985:       id: row.id,\n986:       importanceWeight: row.importance_weight ?? 0.5,\n987:       searchMethod: search_method,\n988:       isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n989:     };\n990:   });\n991: \n992:   const elapsed = Date.now() - start_time;\n993:   if (elapsed > 500) {\n994:     console.warn(`[vector-index] Enriched search took ${elapsed}ms (target <500ms)`);\n995:   }\n996: \n997:   return enriched_results;\n998: }\n999: \n1000: /* ───────────────────────────────────────────────────────────────\n1001:    MULTI-CONCEPT ENRICHED SEARCH\n1002: ----------------------------------------------------------------*/\n1003: \n1004: /**\n1005:  * Runs enriched search across multiple concepts.\n1006:  * @param concepts - The concept queries or embeddings.\n1007:  * @param limit - The maximum number of results to return.\n1008:  * @param options - Search options.\n1009:  * @returns A promise that resolves to enriched search results.\n1010:  * @throws {VectorIndexError} When concept validation fails or the vector search pipeline cannot execute.\n1011:  * @example\n1012:  * ```ts\n1013:  * const results = await multi_concept_search_enriched(['sqlite', 'vector'], 10, { specFolder: 'specs/001-demo' });\n1014:  * ```\n1015:  */\n1016: export async function multi_concept_search_enriched(\n1017:   concepts: Array<string | EmbeddingInput>,\n1018:   limit = 20,\n1019:   options: { specFolder?: string | null; minSimilarity?: number } = {}\n1020: ): Promise<EnrichedSearchResult[]> {\n1021:   const start_time = Date.now();\n1022: \n1023:   if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n1024:     throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n1025:   }\n1026: \n1027:   const { specFolder = null, minSimilarity = 50 } = options;\n1028: \n1029:   const concept_embeddings: EmbeddingInput[] = [];\n1030:   for (const concept of concepts) {\n1031:     if (typeof concept === 'string') {\n1032:       const embedding = await generate_query_embedding(concept);\n1033:       if (!embedding) {\n1034:         console.warn(`[vector-index] Failed to embed concept: \"${concept}\"`);\n1035:         return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n1036:       }\n1037:       concept_embeddings.push(embedding);\n1038:     } else {\n1039:       concept_embeddings.push(concept);\n1040:     }\n1041:   }\n1042: \n1043:   const sqlite_vec = get_sqlite_vec_available();\n1044:   if (!sqlite_vec) {\n1045:     console.warn('[vector-index] Falling back to keyword multi-concept search');\n1046:     return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n1047:   }\n1048: \n1049:   const raw_results = multi_concept_search(concept_embeddings, { limit, specFolder, minSimilarity });\n1050: \n1051:   const file_contents = await Promise.all(\n1052:     raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n1053:   );\n1054: \n1055:   const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n1056:     const content = file_contents[i];\n1057:     const title = row.title || extract_title(content, row.file_path);\n1058:     const snippet = extract_snippet(content);\n1059:     const tags = extract_tags(content);\n1060:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n1061: \n1062:     return {\n1063:       rank: i + 1,\n1064:       avgSimilarity: Math.round((row.avg_similarity || 0) * 100) / 100,\n1065:       conceptSimilarities: (row.concept_similarities as number[] | undefined) || [],\n1066:       title,\n1067:       specFolder: row.spec_folder,\n1068:       filePath: row.file_path,\n1069:       date,\n1070:       tags,\n1071:       snippet,\n1072:       id: row.id,\n1073:       importanceWeight: row.importance_weight ?? 0.5,\n1074:       isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n1075:     };\n1076:   });\n1077: \n1078:   const elapsed = Date.now() - start_time;\n1079:   if (elapsed > 500) {\n1080:     console.warn(`[vector-index] Multi-concept search took ${elapsed}ms (target <500ms)`);\n1081:   }\n1082: \n1083:   return enriched_results;\n1084: }\n1085: \n1086: /**\n1087:  * Runs keyword search for multiple concepts.\n1088:  * @param concepts - The concept terms to search for.\n1089:  * @param limit - The maximum number of results to return.\n1090:  * @param options - Search options.\n1091:  * @returns A promise that resolves to enriched search results.\n1092:  */\n1093: export async function multi_concept_keyword_search(\n1094:   concepts: string[],\n1095:   limit = 20,\n1096:   options: { specFolder?: string | null } = {}\n1097: ): Promise<EnrichedSearchResult[]> {\n1098:   const { specFolder = null } = options;\n1099: \n1100:   if (!concepts.length) {\n1101:     console.warn('[vector-index] multi_concept_keyword_search: empty concepts array');\n1102:     return [];\n1103:   }\n1104: \n1105:   const concept_results = concepts.map((concept: string) =>\n1106:     keyword_search(concept, { limit: 100, specFolder })\n1107:   );\n1108: \n1109:   const id_counts = new Map<number, number>();\n1110:   const id_to_row = new Map<number, MemoryRow>();\n1111: \n1112:   for (const results of concept_results) {\n1113:     for (const row of results) {\n1114:       const count = id_counts.get(row.id) || 0;\n1115:       id_counts.set(row.id, count + 1);\n1116:       if (!id_to_row.has(row.id)) {\n1117:         id_to_row.set(row.id, row);\n1118:       }\n1119:     }\n1120:   }\n1121: \n1122:   const matching_ids: number[] = [];\n1123:   for (const [id, count] of id_counts) {\n1124:     if (count === concepts.length) {\n1125:       matching_ids.push(id);\n1126:     }\n1127:   }\n1128: \n1129:   const limited_ids = matching_ids.slice(0, limit);\n1130:   const rows = limited_ids.map(id => id_to_row.get(id)).filter((row): row is MemoryRow => Boolean(row));\n1131: \n1132:   const file_contents = await Promise.all(\n1133:     rows.map(row => safe_read_file_async(row.file_path))\n1134:   );\n1135: \n1136:   const enriched_results = rows.map((row, i) => {\n1137:     const content = file_contents[i];\n1138:     const title = row.title || extract_title(content, row.file_path);\n1139:     const snippet = extract_snippet(content);\n1140:     const tags = extract_tags(content);\n1141:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n1142: \n1143:     return {\n1144:       rank: i + 1,\n1145:       avgSimilarity: Math.min(100, (row.keyword_score || 1) * 15),\n1146:       conceptSimilarities: concepts.map(() => row.keyword_score || 1),\n1147:       title,\n1148:       specFolder: row.spec_folder,\n1149:       filePath: row.file_path,\n1150:       date,\n1151:       tags,\n1152:       snippet,\n1153:       id: row.id,\n1154:       importanceWeight: row.importance_weight ?? 0.5,\n1155:       searchMethod: 'keyword',\n1156:       isConstitutional: row.importance_tier === 'constitutional'\n1157:     };\n1158:   });\n1159: \n1160:   return enriched_results;\n1161: }\n1162: \n1163: /**\n1164:  * Parses quoted phrases from a search query.\n1165:  * @param query - The search query.\n1166:  * @returns The quoted search terms.\n1167:  */\n1168: export function parse_quoted_terms(query: string): string[] {\n1169:   if (!query || typeof query !== 'string') {\n1170:     console.warn('[vector-index] parse_quoted_terms: invalid query, expected non-empty string');\n1171:     return [];\n1172:   }\n1173: \n1174:   const quoted: string[] = [];\n1175:   const regex = /\"([^\"]+)\"/g;\n1176:   let match;\n1177: \n1178:   while ((match = regex.exec(query)) !== null) {\n1179:     if (match[1] && match[1].trim()) {\n1180:       quoted.push(match[1].trim());\n1181:     }\n1182:   }\n1183: \n1184:   return quoted;\n1185: }\n1186: \n1187: /* ───────────────────────────────────────────────────────────────\n1188:    SMART RANKING AND DIVERSITY\n1189: ----------------------------------------------------------------*/\n1190: \n1191: // Weights read from config instead of hardcoded\n1192: /**\n1193:  * Applies smart ranking weights to enriched results.\n1194:  * @param results - The results to rank.\n1195:  * @returns The ranked results.\n1196:  */\n1197: export function apply_smart_ranking(results: EnrichedSearchResult[]): EnrichedSearchResult[] {\n1198:   if (!results || results.length === 0) return results;\n1199: \n1200:   const recency_weight = search_weights.smartRanking?.recencyWeight || 0.3;\n1201:   const access_weight = search_weights.smartRanking?.accessWeight || 0.2;\n1202:   const relevance_weight = search_weights.smartRanking?.relevanceWeight || 0.5;\n1203: \n1204:   const now = Date.now();\n1205:   const week_ms = 7 * 24 * 60 * 60 * 1000;\n1206:   const month_ms = 30 * 24 * 60 * 60 * 1000;\n1207: \n1208:   return results.map((r: EnrichedSearchResult) => {\n1209:     const created_at = r.created_at ? new Date(r.created_at).getTime() : now;\n1210:     const age = now - created_at;\n1211:     let recency_factor;\n1212:     if (age < week_ms) {\n1213:       recency_factor = 1.0;\n1214:     } else if (age < month_ms) {\n1215:       recency_factor = 0.8;\n1216:     } else {\n1217:       recency_factor = 0.5;\n1218:     }\n1219: \n1220:     const usage_factor = Math.min(1.0, (r.access_count || 0) / 10);\n1221:     const similarity_factor = (r.similarity || 0) / 100;\n1222: \n1223:     r.smartScore = (similarity_factor * relevance_weight) + (recency_factor * recency_weight) + (usage_factor * access_weight);\n1224:     r.smartScore = Math.round(r.smartScore * 100) / 100;\n1225: \n1226:     return r;\n1227:   }).sort((a, b) => Number(b.smartScore ?? 0) - Number(a.smartScore ?? 0));\n1228: }\n1229: \n1230: // Apply diversity filtering using MMR (Maximal Marginal Relevance)\n1231: /**\n1232:  * Applies diversity reordering to enriched results.\n1233:  * @param results - The results to diversify.\n1234:  * @param diversity_factor - The diversity weight to apply.\n1235:  * @returns The diversified results.\n1236:  */\n1237: export function apply_diversity(results: EnrichedSearchResult[], diversity_factor = 0.3): EnrichedSearchResult[] {\n1238:   if (!results || results.length <= 3) return results;\n1239: \n1240:   const selected = [results[0]];\n1241:   const remaining = [...results.slice(1)];\n1242: \n1243:   while (selected.length < results.length && remaining.length > 0) {\n1244:     let best_idx = 0;\n1245:     let best_score = -Infinity;\n1246: \n1247:     for (let i = 0; i < remaining.length; i++) {\n1248:       const candidate = remaining[i];\n1249:       const relevance = candidate.smartScore || ((candidate.similarity ?? 0) / 100) || 0;\n1250: \n1251:       let max_similarity_to_selected = 0;\n1252:       for (const sel of selected) {\n1253:         if (sel.specFolder === candidate.specFolder || sel.spec_folder === candidate.spec_folder) {\n1254:           max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.8);\n1255:         }\n1256:         if (sel.date === candidate.date) {\n1257:           max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.5);\n1258:         }\n1259:       }\n1260: \n1261:       const mmr_score = relevance - (diversity_factor * max_similarity_to_selected);\n1262: \n1263:       if (mmr_score > best_score) {\n1264:         best_score = mmr_score;\n1265:         best_idx = i;\n1266:       }\n1267:     }\n1268: \n1269:     selected.push(remaining.splice(best_idx, 1)[0]);\n1270:   }\n1271: \n1272:   return selected;\n1273: }\n1274: \n1275: /* ───────────────────────────────────────────────────────────────\n1276:    RELATED MEMORIES AND USAGE TRACKING\n1277: ----------------------------------------------------------------*/\n1278: \n1279: /**\n1280:  * Gets memories related to a stored memory.\n1281:  * @param memory_id - The memory identifier.\n1282:  * @returns The related memory rows.\n1283:  */\n1284: export function get_related_memories(memory_id: number): MemoryRow[] {\n1285:   try {\n1286:     const database = initialize_db();\n1287: \n1288:     const memory = database.prepare(`\n1289:       SELECT related_memories FROM memory_index WHERE id = ?\n1290:     `).get(memory_id) as { related_memories?: string | null } | undefined;\n1291: \n1292:     if (!memory || !memory.related_memories) {\n1293:       return [];\n1294:     }\n1295: \n1296:     const related = safe_parse_json(memory.related_memories, []);\n1297: \n1298:     return (related as RelatedMemoryLink[]).map((rel: RelatedMemoryLink): MemoryRow | null => {\n1299:       const full_memory = get_memory(rel.id);\n1300:       if (full_memory) {\n1301:         return {\n1302:           ...full_memory,\n1303:           relationSimilarity: rel.similarity\n1304:         };\n1305:       }\n1306:       return null;\n1307:     }).filter((relatedMemory): relatedMemory is MemoryRow => Boolean(relatedMemory));\n1308:   } catch (error: unknown) {\n1309:     console.warn(`[vector-index] Failed to get related memories for ${memory_id}: ${get_error_message(error)}`);\n1310:     return [];\n1311:   }\n1312: }\n1313: \n1314: /**\n1315:  * Gets usage statistics for indexed memories.\n1316:  * @param options - Sorting and limit options.\n1317:  * @returns The usage statistics rows.\n1318:  */\n1319: export function get_usage_stats(options: UsageStatsOptions = {}): Array<{ id: number; title: string | null; spec_folder: string; file_path: string; access_count: number; last_accessed: number | null; confidence: number | null; created_at: string }> {\n1320:   const {\n1321:     sortBy = 'access_count',\n1322:     order = 'DESC',\n1323:     limit = 20\n1324:   } = options;\n1325: \n1326:   const valid_sort_fields = ['access_count', 'last_accessed', 'confidence'];\n1327:   const sort_field = valid_sort_fields.includes(sortBy) ? sortBy : 'access_count';\n1328:   const sort_order = order.toUpperCase() === 'ASC' ? 'ASC' : 'DESC';\n1329: \n1330:   const database = initialize_db();\n1331: \n1332:   const rows = database.prepare(`\n1333:     SELECT id, title, spec_folder, file_path, access_count,\n1334:            last_accessed, confidence, created_at\n1335:     FROM memory_index\n1336:     WHERE access_count > 0\n1337:     ORDER BY ${sort_field} ${sort_order}\n1338:     LIMIT ?\n1339:   `).all(limit) as Array<{\n1340:     id: number;\n1341:     title: string | null;\n1342:     spec_folder: string;\n1343:     file_path: string;\n1344:     access_count: number;\n1345:     last_accessed: number | null;\n1346:     confidence: number | null;\n1347:     created_at: string;\n1348:   }>;\n1349: \n1350:   return rows;\n1351: }\n1352: \n1353: /* ───────────────────────────────────────────────────────────────\n1354:    CLEANUP FUNCTIONS\n1355: ----------------------------------------------------------------*/\n1356: \n1357: /**\n1358:  * Finds memory records that are candidates for cleanup.\n1359:  * @param options - Cleanup thresholds and limits.\n1360:  * @returns The cleanup candidate details.\n1361:  */\n1362: export function find_cleanup_candidates(options: CleanupOptions = {}): Array<{ id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; reasons: string[] }> {\n1363:   const database = initialize_db();\n1364: \n1365:   const {\n1366:     maxAgeDays = 90,\n1367:     maxAccessCount = 2,\n1368:     maxConfidence = 0.4,\n1369:     limit = 50\n1370:   } = options;\n1371: \n1372:   const cutoff_date = new Date();\n1373:   cutoff_date.setDate(cutoff_date.getDate() - maxAgeDays);\n1374:   const cutoff_iso = cutoff_date.toISOString();\n1375: \n1376:   const sql = `\n1377:     SELECT\n1378:       id,\n1379:       spec_folder,\n1380:       file_path,\n1381:       title,\n1382:       created_at,\n1383:       last_accessed,\n1384:       access_count,\n1385:       confidence,\n1386:       importance_weight\n1387:     FROM memory_index\n1388:     WHERE\n1389:       created_at < ?\n1390:       OR access_count <= ?\n1391:       OR confidence <= ?\n1392:       OR (last_accessed IS NULL AND created_at < ?)\n1393:     ORDER BY\n1394:       last_accessed ASC NULLS FIRST,\n1395:       access_count ASC,\n1396:       confidence ASC\n1397:     LIMIT ?\n1398:   `;\n1399: \n1400:   let rows;\n1401:   try {\n1402:     rows = database.prepare(sql).all(\n1403:       cutoff_iso,\n1404:       maxAccessCount,\n1405:       maxConfidence,\n1406:       cutoff_iso,\n1407:       limit\n1408:     );\n1409:   } catch (e: unknown) {\n1410:     console.warn(`[vector-index] find_cleanup_candidates error: ${get_error_message(e)}`);\n1411:     return [];\n1412:   }\n1413: \n1414:   return (rows as MemoryRow[]).map((row: MemoryRow) => {\n1415:     const age_string = format_age_string(row.created_at ?? null);\n1416:     const last_access_string = format_age_string(\n1417:       typeof row.last_accessed === 'number' ? new Date(row.last_accessed).toISOString() : null\n1418:     );\n1419: \n1420:     const reasons: string[] = [];\n1421:     if (row.created_at && new Date(row.created_at) < cutoff_date) {\n1422:       reasons.push(`created ${age_string}`);\n1423:     }\n1424:     if ((row.access_count || 0) <= maxAccessCount) {\n1425:       const count = row.access_count || 0;\n1426:       reasons.push(`accessed ${count} time${count !== 1 ? 's' : ''}`);\n1427:     }\n1428:     if ((row.confidence || 0.5) <= maxConfidence) {\n1429:       reasons.push(`low importance (${Math.round((row.confidence || 0.5) * 100)}%)`);\n1430:     }\n1431: \n1432:     return {\n1433:       id: row.id,\n1434:       specFolder: row.spec_folder,\n1435:       filePath: row.file_path,\n1436:       title: row.title || 'Untitled',\n1437:       createdAt: row.created_at,\n1438:       lastAccessedAt: row.last_accessed,\n1439:       accessCount: row.access_count || 0,\n1440:       confidence: row.confidence || 0.5,\n1441:       ageString: age_string,\n1442:       lastAccessString: last_access_string,\n1443:       reasons\n1444:     };\n1445:   });\n1446: }\n1447: \n1448: /**\n1449:  * Builds a preview payload for a stored memory.\n1450:  * @param memory_id - The memory identifier.\n1451:  * @param max_lines - The maximum number of file lines to include.\n1452:  * @returns The memory preview, if found.\n1453:  */\n1454: export function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n1455:   const database = initialize_db();\n1456: \n1457:   let memory: MemoryRow | undefined;\n1458:   try {\n1459:     memory = database.prepare(`\n1460:       SELECT * FROM memory_index WHERE id = ?\n1461:     `).get(memory_id) as MemoryRow | undefined;\n1462:   } catch (e: unknown) {\n1463:     console.warn(`[vector-index] get_memory_preview query error: ${get_error_message(e)}`);\n1464:     return null;\n1465:   }\n1466: \n1467:   if (!memory) return null;\n1468: \n1469:   let content = '';\n1470:   try {\n1471:     // Validate DB-stored file paths before reading\n1472:     if (memory.file_path) {\n1473:       const valid_path = validate_file_path_local(memory.file_path);\n1474:       if (valid_path && fs.existsSync(valid_path)) {\n1475:         const full_content = fs.readFileSync(valid_path, 'utf-8');\n1476:         const lines = full_content.split('\\n');\n1477:         content = lines.slice(0, max_lines).join('\\n');\n1478:         if (lines.length > max_lines) {\n1479:           content += `\\n... (${lines.length - max_lines} more lines)`;\n1480:         }\n1481:       }\n1482:     }\n1483:   } catch (e: unknown) {\n1484:     console.warn('[vector-index] get_memory_preview file read warning', {\n\n(Output capped at 50 KB. Showing lines 1-1484. Use offset=1485 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Queries\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport { isArchivedVectorInclusionEnabled } from './search-flags.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Queries\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport { isArchivedVectorInclusionEnabled } from './search-flags.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport {\n  get_error_message,\n  parse_trigger_phrases,\n  specFolderLikePattern,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  initialize_db,\n  get_embedding_dim,\n  get_constitutional_memories,\n  init_prepared_statements,\n  validate_file_path_local,\n  safe_read_file_async,\n  safe_parse_json,\n  search_weights,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource as activeVectorSchema,\n} from './vector-index-store.js';\nimport { delete_memory_from_database } from './vector-index-mutations.js';\nimport type {\n  EmbeddingInput,\n  EnrichedSearchResult,\n  MemoryRow,\n  VectorSearchOptions,\n} from './vector-index-types.js';\n\nconst logger = createLogger('VectorIndex');\n\ntype RelatedMemoryLink = { id: number; similarity: number };\ntype UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\ntype CleanupOptions = {\n  maxAgeDays?: number;\n  maxAccessCount?: number;\n  maxConfidence?: number;\n  limit?: number;\n};\ntype VectorSource = {\n  dim: number;\n  tableName: string;\n  idColumn: string;\n  embeddingColumn: string;\n};\n\nexport interface KnnQueryShapeBenchmarkResult {\n  readonly corpusSize: number;\n  readonly iterations: number;\n  readonly scalarJoinAverageMs: number;\n  readonly matchAverageMs: number | null;\n  readonly matchSupported: boolean;\n  readonly matchImprovementPct: number | null;\n  readonly decision: 'adopt_match' | 'keep_scalar_join';\n  readonly reason: string;\n}\n\nconst KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n\nfunction appendSpecFolderScope(\n  clauses: string[],\n  params: unknown[],\n  specFolder: string | null | undefined,\n  column = 'm.spec_folder',\n): void {\n  if (!specFolder) return;\n  clauses.push(`(${column} = ? OR ${column} LIKE ? ESCAPE '\\\\')`);\n  params.push(specFolder, specFolderLikePattern(specFolder));\n}\n\nfunction tableExists(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS found\n    FROM active_vec.sqlite_master\n    WHERE type = 'table' AND name = ?\n    LIMIT 1\n  `).get(tableName) as { found?: number } | undefined;\n  return row?.found === 1;\n}\n\nfunction getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n  const active = getActiveEmbedder(database);\n  const dimTableName = `vec_${active.dim}`;\n  if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n    return {\n      dim: active.dim,\n      tableName: activeVectorSchema(dimTableName),\n      idColumn: 'id',\n      embeddingColumn: 'vec',\n    };\n  }\n\n  return {\n    dim: get_embedding_dim(),\n    tableName: activeVectorSchema('vec_memories'),\n    idColumn: 'rowid',\n    embeddingColumn: 'embedding',\n  };\n}\n\nfunction elapsedMs(start: bigint): number {\n  return Number(process.hrtime.bigint() - start) / 1_000_000;\n}\n\nfunction average(values: number[]): number {\n  if (values.length === 0) return 0;\n  return values.reduce((sum, value) => sum + value, 0) / values.length;\n}\n\nexport function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n  return result.matchSupported === true\n    && typeof result.matchImprovementPct === 'number'\n    && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n}\n\nexport function benchmarkKnnQueryShapes(\n  query_embedding: EmbeddingInput,\n  options: { iterations?: number; limit?: number } = {},\n  database: Database.Database = initialize_db(),\n): KnnQueryShapeBenchmarkResult {\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n  const limit = Math.max(1, Math.floor(options.limit ?? 20));\n  const queryBuffer = to_embedding_buffer(query_embedding);\n  const corpusSize = (database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE m.embedding_status = 'success'\n  `).get() as { count: number }).count;\n\n  const scalarSql = `\n    SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n    WHERE m.embedding_status = 'success'\n    ORDER BY distance ASC\n    LIMIT ?\n  `;\n  const scalarStmt = database.prepare(scalarSql);\n  scalarStmt.all(queryBuffer, limit);\n  const scalarRuns: number[] = [];\n  for (let i = 0; i < iterations; i += 1) {\n    const start = process.hrtime.bigint();\n    scalarStmt.all(queryBuffer, limit);\n    scalarRuns.push(elapsedMs(start));\n  }\n\n  const matchTable = activeVectorSchema('vec_memories');\n  const matchAvailable = tableExists(database, 'vec_memories');\n  let matchAverageMs: number | null = null;\n  let matchError: string | null = null;\n\n  if (matchAvailable) {\n    try {\n      const matchSql = `\n        WITH knn AS (\n          SELECT rowid, distance\n          FROM ${matchTable}\n          WHERE embedding MATCH ? AND k = ?\n        )\n        SELECT m.id, knn.distance\n        FROM knn\n        JOIN memory_index m ON m.id = knn.rowid\n        JOIN active_memory_projection p ON p.active_memory_id = m.id\n        WHERE m.embedding_status = 'success'\n        ORDER BY knn.distance ASC\n        LIMIT ?\n      `;\n      const matchStmt = database.prepare(matchSql);\n      matchStmt.all(queryBuffer, limit, limit);\n      const matchRuns: number[] = [];\n      for (let i = 0; i < iterations; i += 1) {\n        const start = process.hrtime.bigint();\n        matchStmt.all(queryBuffer, limit, limit);\n        matchRuns.push(elapsedMs(start));\n      }\n      matchAverageMs = average(matchRuns);\n    } catch (error: unknown) {\n      matchError = get_error_message(error);\n    }\n  }\n\n  const scalarJoinAverageMs = average(scalarRuns);\n  const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n    ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n    : null;\n  const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n  };\n  const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n\n  return {\n    corpusSize,\n    iterations,\n    scalarJoinAverageMs,\n    matchAverageMs,\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n    decision,\n    reason: decision === 'adopt_match'\n      ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n      : matchError\n        ? `MATCH unavailable: ${matchError}`\n        : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   SIMPLE QUERIES\n----------------------------------------------------------------*/\n\n/**\n * Gets one indexed memory by identifier.\n * @param id - The memory identifier.\n * @returns The matching memory row, if found.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const memory = get_memory(42);\n * ```\n */\nexport function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n  const stmts = init_prepared_statements(database);\n  const row = stmts.get_by_id.get(id);\n\n  if (row) {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n  }\n\n  return row || null;\n}\n\n/**\n * Gets indexed memories for a spec folder.\n * @param spec_folder - The spec folder to query.\n * @returns The memory rows for the folder.\n */\nexport function get_memories_by_folder(\n  spec_folder: string,\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const rows = database.prepare(`\n    SELECT m.*\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\n    ORDER BY m.created_at DESC\n  `).all(spec_folder, specFolderLikePattern(spec_folder)) as MemoryRow[];\n\n  return rows.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/**\n * Gets the total number of indexed memories.\n * @returns The total memory count.\n */\nexport function get_memory_count(database: Database.Database = initialize_db()): number {\n  const stmts = init_prepared_statements(database);\n  const result = stmts.count_all.get();\n  return result?.count ?? 0;\n}\n\n/**\n * Gets memory counts grouped by embedding status.\n * @returns The counts for each embedding status.\n */\nexport function get_status_counts(\n  database: Database.Database = initialize_db(),\n): { pending: number; success: number; failed: number; retry: number; partial: number } {\n  const rows = database.prepare(`\n    SELECT m.embedding_status, COUNT(*) as count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    GROUP BY m.embedding_status\n  `).all();\n\n  // Include 'partial' status in counts.\n  const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n  for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n    if (row.embedding_status in counts) {\n      counts[row.embedding_status] = row.count;\n    }\n  }\n\n  return counts;\n}\n\n/**\n * Gets summary counts for indexed memories.\n * @returns The aggregate memory statistics.\n */\nexport function get_stats(\n  database: Database.Database = initialize_db(),\n): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n  const counts = get_status_counts(database);\n  const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n\n  return {\n    total,\n    ...counts\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories by vector similarity.\n * @param query_embedding - The query embedding to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function vector_search(\n  query_embedding: EmbeddingInput,\n  options: VectorSearchOptions = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const {\n    limit = 10,\n    specFolder = null,\n    minSimilarity = 0,\n    useDecay = true,\n    tier = null,\n    contextType = null,\n    includeConstitutional = true,\n    includeArchived = false\n  } = options;\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const query_buffer = to_embedding_buffer(query_embedding);\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  // FSRS-preferred decay with half-life fallback\n  const decay_expr = useDecay\n    ? `CASE\n         WHEN m.is_pinned = 1 THEN m.importance_weight\n         WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n           m.importance_weight * POWER(\n             1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n             -0.5\n           )\n         ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n       END`\n    : 'm.importance_weight';\n\n  let constitutional_results: MemoryRow[] = [];\n\n  if (includeConstitutional && tier !== 'constitutional') {\n    constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n  }\n\n  const where_clauses = ['m.embedding_status = \\'success\\''];\n  const params: unknown[] = [query_buffer];\n\n  where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n\n  if (tier === 'deprecated') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('deprecated');\n  } else if (tier === 'constitutional') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('constitutional');\n  } else if (tier) {\n    where_clauses.push('m.importance_tier = ?');\n    params.push(tier);\n  } else if (isArchivedVectorInclusionEnabled()) {\n    // Cold/archived rows admitted to the projection (option A) must not be re-excluded\n    // here; still keep constitutional on its own injected path.\n    where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier != \\'constitutional\\')');\n  } else {\n    where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n  }\n\n  appendSpecFolderScope(where_clauses, params, specFolder);\n\n  if (contextType) {\n    where_clauses.push('m.context_type = ?');\n    params.push(contextType);\n  }\n\n  // If constitutional results already satisfy limit, return them directly.\n  if (constitutional_results.length >= limit) {\n    return constitutional_results.slice(0, limit);\n  }\n  const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n  params.push(max_distance, adjusted_limit);\n\n  const sql = `\n    SELECT sub.*,\n           ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n    FROM (\n      SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n             ${decay_expr} as effective_importance\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE ${where_clauses.join(' AND ')}\n    ) sub\n    WHERE sub.distance <= ?\n    ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n    LIMIT ?\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n\n  return [...constitutional_results, ...regular_results];\n}\n\n/**\n * Gets constitutional memories for prompt assembly.\n * @param options - Retrieval options.\n * @returns The constitutional memory rows.\n */\nexport function get_constitutional_memories_public(\n  options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n\n  let results = get_constitutional_memories(database, specFolder, includeArchived);\n\n  const TOKENS_PER_MEMORY = 100;\n  const max_count = Math.floor(maxTokens / TOKENS_PER_MEMORY);\n  if (results.length > max_count) {\n    results = results.slice(0, max_count);\n  }\n\n  return results;\n}\n\n/**\n * Searches indexed memories with multiple concept embeddings.\n * @param concept_embeddings - The concept embeddings to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} When concept count or embedding dimensions are invalid, or when store initialization fails.\n * @example\n * ```ts\n * const rows = multi_concept_search([embA, embB], { limit: 8, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function multi_concept_search(\n  concept_embeddings: EmbeddingInput[],\n  options: { limit?: number; specFolder?: string | null; minSimilarity?: number } = {}\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Multi-concept search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const database = initialize_db();\n\n  const concepts = concept_embeddings;\n  if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  for (const emb of concepts) {\n    if (!emb || emb.length !== vectorSource.dim) {\n      throw new VectorIndexError(\n        `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n        VectorIndexErrorCode.QUERY_FAILED,\n      );\n    }\n  }\n\n  const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  const distance_expressions = concept_buffers.map((_, i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n  ).join(', ');\n\n  const distance_filters = concept_buffers.map((_, _i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n  ).join(' AND ');\n\n  const folder_filter = specFolder ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\" : '';\n  const similarity_select = concept_buffers.map((_, i) =>\n    `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n  ).join(', ');\n\n  const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n\n  const sql = `\n    SELECT\n      sub.*,\n      ${similarity_select},\n      (${avg_distance_expr}) / ${concepts.length} as avg_distance\n    FROM (\n      SELECT\n        m.*,\n        ${distance_expressions}\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE m.embedding_status = 'success'\n        AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n        ${folder_filter}\n        AND ${distance_filters}\n    ) sub\n    ORDER BY avg_distance ASC\n    LIMIT ?\n  `;\n\n  const params = [\n    ...concept_buffers,\n    ...(specFolder ? [specFolder, specFolderLikePattern(specFolder)] : []),\n    ...concept_buffers.flatMap(b => [b, max_distance]),\n    limit\n  ];\n\n  const rows = database.prepare(sql).all(...params);\n\n  return (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n    row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   CONTENT EXTRACTION HELPERS\n----------------------------------------------------------------*/\n\n/**\n * Extracts a display title from indexed content.\n * @param content - The content to inspect.\n * @param filename - The optional source filename.\n * @returns The extracted title.\n */\nexport function extract_title(content: unknown, filename?: string): string {\n  if (!content || typeof content !== 'string') {\n    return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n  }\n\n  const h1_match = content.match(/^#\\s+(.+)$/m);\n  if (h1_match && h1_match[1]) {\n    return h1_match[1].trim();\n  }\n\n  const h2_match = content.match(/^##\\s+(.+)$/m);\n  if (h2_match && h2_match[1]) {\n    return h2_match[1].trim();\n  }\n\n  const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n  if (yaml_match && yaml_match[1]) {\n    return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n  }\n\n  const lines = content.split('\\n').filter(l => l.trim().length > 0);\n  if (lines.length > 0) {\n    const first_line = lines[0].trim();\n    return first_line.replace(/^#+\\s*/, '').substring(0, 100);\n  }\n\n  return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n}\n\n/**\n * Extracts a preview snippet from indexed content.\n * @param content - The content to inspect.\n * @param max_length - The maximum snippet length.\n * @returns The extracted snippet.\n */\nexport function extract_snippet(content: unknown, max_length = 200): string {\n  if (!content || typeof content !== 'string') {\n    return '';\n  }\n\n  const text = content.replace(/^---[\\s\\S]*?---\\n*/m, '');\n  const lines = text.split('\\n');\n  const snippet_lines: string[] = [];\n\n  for (const line of lines) {\n    const trimmed = line.trim();\n\n    if (!trimmed || /^#+\\s/.test(trimmed)) {\n      if (snippet_lines.length > 0) {\n        break;\n      }\n      continue;\n    }\n\n    if (/^[a-z_-]+:\\s/i.test(trimmed) && snippet_lines.length === 0) {\n      continue;\n    }\n\n    snippet_lines.push(trimmed);\n\n    const current_length = snippet_lines.join(' ').length;\n    if (current_length >= max_length) {\n      break;\n    }\n  }\n\n  let snippet = snippet_lines.join(' ');\n\n  if (snippet.length > max_length) {\n    snippet = snippet.substring(0, max_length);\n    const last_space = snippet.lastIndexOf(' ');\n    if (last_space > max_length * 0.7) {\n      snippet = snippet.substring(0, last_space);\n    }\n    snippet += '...';\n  }\n\n  return snippet;\n}\n\n/**\n * Extracts tags from indexed content.\n * @param content - The content to inspect.\n * @returns The extracted tags.\n */\nexport function extract_tags(content: unknown): string[] {\n  if (!content || typeof content !== 'string') {\n    console.warn('[vector-index] extract_tags: invalid content type, expected string');\n    return [];\n  }\n\n  const tags = new Set<string>();\n\n  const yaml_tags_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\[([^\\]]+)\\]/m);\n  if (yaml_tags_match && yaml_tags_match[1]) {\n    yaml_tags_match[1].split(',').forEach(tag => {\n      const cleaned = tag.trim().replace(/^[\"']|[\"']$/g, '');\n      if (cleaned) tags.add(cleaned.toLowerCase());\n    });\n  }\n\n  const yaml_list_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/m);\n  if (yaml_list_match && yaml_list_match[1]) {\n    yaml_list_match[1].match(/-\\s*(.+)/g)?.forEach(match => {\n      const tag = match.replace(/^-\\s*/, '').trim().replace(/^[\"']|[\"']$/g, '');\n      if (tag) tags.add(tag.toLowerCase());\n    });\n  }\n\n  const hashtag_matches = content.match(/(?:^|\\s)#([a-zA-Z][a-zA-Z0-9_-]*)/g);\n  if (hashtag_matches) {\n    hashtag_matches.forEach(match => {\n      const tag = match.trim().replace(/^#/, '');\n      if (tag && !tag.match(/^[0-9]+$/)) {\n        tags.add(tag.toLowerCase());\n      }\n    });\n  }\n\n  return Array.from(tags);\n}\n\n/**\n * Extracts a relevant date from indexed content or path.\n * @param content - The content to inspect.\n * @param file_path - The optional source file path.\n * @returns The extracted date, if available.\n */\nexport function extract_date(content: unknown, file_path?: string): string | null {\n  if (content && typeof content === 'string') {\n    const date_match = content.match(/^---[\\s\\S]*?^date:\\s*(.+)$/m);\n    if (date_match && date_match[1]) {\n      const date_str = date_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n      try {\n        const parsed = new Date(date_str);\n        if (!isNaN(parsed.getTime())) {\n          return parsed.toISOString().split('T')[0];\n        }\n      } catch (_e: unknown) {\n        console.warn('[vector-index-queries] Date parsing failed', { error: _e instanceof Error ? _e.message : String(_e) });\n      }\n    }\n  }\n\n  if (file_path) {\n    const filename = path.basename(file_path);\n\n    const iso_match = filename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n    if (iso_match) {\n      return iso_match[1];\n    }\n\n    const ddmmyy_match = filename.match(/(\\d{2})-(\\d{2})-(\\d{2})/);\n    if (ddmmyy_match) {\n      const [, day, month, year] = ddmmyy_match;\n      const full_year = parseInt(year) > 50 ? `19${year}` : `20${year}`;\n      return `${full_year}-${month}-${day}`;\n    }\n  }\n\n  return null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   EMBEDDING GENERATION WRAPPER\n----------------------------------------------------------------*/\n\n/**\n * Generates an embedding for a search query.\n * @param query - The search query.\n * @returns A promise that resolves to the embedding, if generated.\n */\nexport async function generate_query_embedding(query: string): Promise<Float32Array | null> {\n  if (!query || typeof query !== 'string' || query.trim().length === 0) {\n    console.warn('[vector-index] Empty query provided for embedding');\n    return null;\n  }\n\n  try {\n    const database = initialize_db();\n    const active = getActiveEmbedder(database);\n    const trimmedQuery = query.trim();\n    const modelId = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.name\n      : embeddingsProvider.getModelName();\n    const embeddingDim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.dim\n      : embeddingsProvider.getEmbeddingDimension();\n    const profileKey = getActiveEmbeddingProfileKey(database, modelId, embeddingDim);\n    const contentHash = computeContentHash(trimmedQuery);\n    const cached = lookupEmbedding(database, contentHash, modelId, embeddingDim, {\n      profileKey,\n      inputKind: 'query',\n    });\n    if (cached) {\n      return new Float32Array(\n        cached.buffer,\n        cached.byteOffset,\n        Math.floor(cached.byteLength / Float32Array.BYTES_PER_ELEMENT),\n      );\n    }\n\n    const provider = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.provider ?? getManifest(active.name)?.backend ?? 'ollama'\n      : getStartupEmbeddingProfile().provider;\n    const adapter = getEmbedderAdapter(provider, modelId, embeddingDim);\n    const activeAdapter = adapter as typeof adapter & {\n      embed: (\n        texts: ReadonlyArray<string>,\n        options?: { inputType?: 'query' | 'document' },\n      ) => Promise<Float32Array[]>;\n    };\n    const [activeEmbedding] = await activeAdapter.embed([trimmedQuery], { inputType: 'query' });\n    const embedding: Float32Array | null = activeEmbedding ?? null;\n\n    if (embedding) {\n      storeEmbedding(\n        database,\n        contentHash,\n        modelId,\n        Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n        embedding.length,\n        { profileKey, inputKind: 'query' },\n      );\n    }\n\n    return embedding;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Query embedding failed: ${get_error_message(error)}`);\n    return null;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   KEYWORD SEARCH FALLBACK\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories using keyword matching.\n * @param query - The search query.\n * @param options - Search options.\n * @returns The matching memory rows.\n */\nexport function keyword_search(\n  query: string,\n  options: { limit?: number; specFolder?: string | null } = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const { limit = 20, specFolder = null } = options;\n\n  if (!query || typeof query !== 'string') {\n    console.warn('[vector-index] keyword_search: invalid query, expected non-empty string');\n    return [];\n  }\n\n  const search_terms = query.toLowerCase().trim().split(/\\s+/).filter(t => t.length >= 2);\n  if (search_terms.length === 0) {\n    console.warn('[vector-index] keyword_search: no valid search terms after tokenization');\n    return [];\n  }\n\n  let where_clause = '1=1';\n  const params: unknown[] = [];\n\n  if (specFolder) {\n    where_clause += \" AND (spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')\";\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  const sql = `\n    SELECT m.* FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE ${where_clause}\n    ORDER BY m.importance_weight DESC, m.created_at DESC\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const scored = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    let score = 0;\n    const searchable_text = [\n      row.title || '',\n      parse_trigger_phrases(row.trigger_phrases).join(' '),\n      row.spec_folder || '',\n      row.file_path || ''\n    ].join(' ').toLowerCase();\n\n    for (const term of search_terms) {\n      if (searchable_text.includes(term)) {\n        score += 1;\n        if ((row.title || '').toLowerCase().includes(term)) {\n          score += 2;\n        }\n        if (parse_trigger_phrases(row.trigger_phrases).join(' ').toLowerCase().includes(term)) {\n          score += 1.5;\n        }\n      }\n    }\n\n    score *= (0.5 + (row.importance_weight ?? 0));\n    return { ...row, keyword_score: score };\n  });\n\n  const filtered = scored\n    .filter((row: MemoryRow) => Number(row.keyword_score ?? 0) > 0)\n    .sort((a: MemoryRow, b: MemoryRow) => Number(b.keyword_score ?? 0) - Number(a.keyword_score ?? 0))\n    .slice(0, limit);\n\n  return filtered.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   ENRICHED VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Runs enriched vector search for a text query.\n * @param query - The search query.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n * @throws {VectorIndexError} Propagates vector-store initialization failures from the underlying search pipeline.\n * @example\n * ```ts\n * const results = await vector_search_enriched('sqlite vec mismatch', 10, { specFolder: 'specs/001-demo' });\n * ```\n */\nexport async function vector_search_enriched(\n  query: string,\n  limit = 20,\n  options: { specFolder?: string | null; minSimilarity?: number } = {},\n  database: Database.Database = initialize_db(),\n): Promise<EnrichedSearchResult[]> {\n  const start_time = Date.now();\n  const { specFolder = null, minSimilarity = 30 } = options;\n\n  const query_embedding = await generate_query_embedding(query);\n\n  let raw_results;\n  let search_method = 'vector';\n\n  const sqlite_vec = get_sqlite_vec_available();\n  if (query_embedding && sqlite_vec) {\n    raw_results = vector_search(query_embedding, {\n      limit,\n      specFolder,\n      minSimilarity\n    }, database);\n  } else {\n    console.warn('[vector-index] Falling back to keyword search');\n    search_method = 'keyword';\n    raw_results = keyword_search(query, { limit, specFolder }, database);\n  }\n\n  // HIGH-004 FIX: Read all files concurrently\n  const file_contents = await Promise.all(\n    raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    const similarity = search_method === 'vector'\n      ? (row.similarity || 0)\n      : Math.min(100, (row.keyword_score || 0) * 20);\n\n    return {\n      rank: i + 1,\n      similarity: Math.round(similarity * 100) / 100,\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      searchMethod: search_method,\n      isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n    };\n  });\n\n  const elapsed = Date.now() - start_time;\n  if (elapsed > 500) {\n    console.warn(`[vector-index] Enriched search took ${elapsed}ms (target <500ms)`);\n  }\n\n  return enriched_results;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   MULTI-CONCEPT ENRICHED SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Runs enriched search across multiple concepts.\n * @param concepts - The concept queries or embeddings.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n * @throws {VectorIndexError} When concept validation fails or the vector search pipeline cannot execute.\n * @example\n * ```ts\n * const results = await multi_concept_search_enriched(['sqlite', 'vector'], 10, { specFolder: 'specs/001-demo' });\n * ```\n */\nexport async function multi_concept_search_enriched(\n  concepts: Array<string | EmbeddingInput>,\n  limit = 20,\n  options: { specFolder?: string | null; minSimilarity?: number } = {}\n): Promise<EnrichedSearchResult[]> {\n  const start_time = Date.now();\n\n  if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const { specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_embeddings: EmbeddingInput[] = [];\n  for (const concept of concepts) {\n    if (typeof concept === 'string') {\n      const embedding = await generate_query_embedding(concept);\n      if (!embedding) {\n        console.warn(`[vector-index] Failed to embed concept: \"${concept}\"`);\n        return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n      }\n      concept_embeddings.push(embedding);\n    } else {\n      concept_embeddings.push(concept);\n    }\n  }\n\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Falling back to keyword multi-concept search');\n    return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n  }\n\n  const raw_results = multi_concept_search(concept_embeddings, { limit, specFolder, minSimilarity });\n\n  const file_contents = await Promise.all(\n    raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    return {\n      rank: i + 1,\n      avgSimilarity: Math.round((row.avg_similarity || 0) * 100) / 100,\n      conceptSimilarities: (row.concept_similarities as number[] | undefined) || [],\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n    };\n  });\n\n  const elapsed = Date.now() - start_time;\n  if (elapsed > 500) {\n    console.warn(`[vector-index] Multi-concept search took ${elapsed}ms (target <500ms)`);\n  }\n\n  return enriched_results;\n}\n\n/**\n * Runs keyword search for multiple concepts.\n * @param concepts - The concept terms to search for.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n */\nexport async function multi_concept_keyword_search(\n  concepts: string[],\n  limit = 20,\n  options: { specFolder?: string | null } = {}\n): Promise<EnrichedSearchResult[]> {\n  const { specFolder = null } = options;\n\n  if (!concepts.length) {\n    console.warn('[vector-index] multi_concept_keyword_search: empty concepts array');\n    return [];\n  }\n\n  const concept_results = concepts.map((concept: string) =>\n    keyword_search(concept, { limit: 100, specFolder })\n  );\n\n  const id_counts = new Map<number, number>();\n  const id_to_row = new Map<number, MemoryRow>();\n\n  for (const results of concept_results) {\n    for (const row of results) {\n      const count = id_counts.get(row.id) || 0;\n      id_counts.set(row.id, count + 1);\n      if (!id_to_row.has(row.id)) {\n        id_to_row.set(row.id, row);\n      }\n    }\n  }\n\n  const matching_ids: number[] = [];\n  for (const [id, count] of id_counts) {\n    if (count === concepts.length) {\n      matching_ids.push(id);\n    }\n  }\n\n  const limited_ids = matching_ids.slice(0, limit);\n  const rows = limited_ids.map(id => id_to_row.get(id)).filter((row): row is MemoryRow => Boolean(row));\n\n  const file_contents = await Promise.all(\n    rows.map(row => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = rows.map((row, i) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    return {\n      rank: i + 1,\n      avgSimilarity: Math.min(100, (row.keyword_score || 1) * 15),\n      conceptSimilarities: concepts.map(() => row.keyword_score || 1),\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      searchMethod: 'keyword',\n      isConstitutional: row.importance_tier === 'constitutional'\n    };\n  });\n\n  return enriched_results;\n}\n\n/**\n * Parses quoted phrases from a search query.\n * @param query - The search query.\n * @returns The quoted search terms.\n */\nexport function parse_quoted_terms(query: string): string[] {\n  if (!query || typeof query !== 'string') {\n    console.warn('[vector-index] parse_quoted_terms: invalid query, expected non-empty string');\n    return [];\n  }\n\n  const quoted: string[] = [];\n  const regex = /\"([^\"]+)\"/g;\n  let match;\n\n  while ((match = regex.exec(query)) !== null) {\n    if (match[1] && match[1].trim()) {\n      quoted.push(match[1].trim());\n    }\n  }\n\n  return quoted;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   SMART RANKING AND DIVERSITY\n----------------------------------------------------------------*/\n\n// Weights read from config instead of hardcoded\n/**\n * Applies smart ranking weights to enriched results.\n * @param results - The results to rank.\n * @returns The ranked results.\n */\nexport function apply_smart_ranking(results: EnrichedSearchResult[]): EnrichedSearchResult[] {\n  if (!results || results.length === 0) return results;\n\n  const recency_weight = search_weights.smartRanking?.recencyWeight || 0.3;\n  const access_weight = search_weights.smartRanking?.accessWeight || 0.2;\n  const relevance_weight = search_weights.smartRanking?.relevanceWeight || 0.5;\n\n  const now = Date.now();\n  const week_ms = 7 * 24 * 60 * 60 * 1000;\n  const month_ms = 30 * 24 * 60 * 60 * 1000;\n\n  return results.map((r: EnrichedSearchResult) => {\n    const created_at = r.created_at ? new Date(r.created_at).getTime() : now;\n    const age = now - created_at;\n    let recency_factor;\n    if (age < week_ms) {\n      recency_factor = 1.0;\n    } else if (age < month_ms) {\n      recency_factor = 0.8;\n    } else {\n      recency_factor = 0.5;\n    }\n\n    const usage_factor = Math.min(1.0, (r.access_count || 0) / 10);\n    const similarity_factor = (r.similarity || 0) / 100;\n\n    r.smartScore = (similarity_factor * relevance_weight) + (recency_factor * recency_weight) + (usage_factor * access_weight);\n    r.smartScore = Math.round(r.smartScore * 100) / 100;\n\n    return r;\n  }).sort((a, b) => Number(b.smartScore ?? 0) - Number(a.smartScore ?? 0));\n}\n\n// Apply diversity filtering using MMR (Maximal Marginal Relevance)\n/**\n * Applies diversity reordering to enriched results.\n * @param results - The results to diversify.\n * @param diversity_factor - The diversity weight to apply.\n * @returns The diversified results.\n */\nexport function apply_diversity(results: EnrichedSearchResult[], diversity_factor = 0.3): EnrichedSearchResult[] {\n  if (!results || results.length <= 3) return results;\n\n  const selected = [results[0]];\n  const remaining = [...results.slice(1)];\n\n  while (selected.length < results.length && remaining.length > 0) {\n    let best_idx = 0;\n    let best_score = -Infinity;\n\n    for (let i = 0; i < remaining.length; i++) {\n      const candidate = remaining[i];\n      const relevance = candidate.smartScore || ((candidate.similarity ?? 0) / 100) || 0;\n\n      let max_similarity_to_selected = 0;\n      for (const sel of selected) {\n        if (sel.specFolder === candidate.specFolder || sel.spec_folder === candidate.spec_folder) {\n          max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.8);\n        }\n        if (sel.date === candidate.date) {\n          max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.5);\n        }\n      }\n\n      const mmr_score = relevance - (diversity_factor * max_similarity_to_selected);\n\n      if (mmr_score > best_score) {\n        best_score = mmr_score;\n        best_idx = i;\n      }\n    }\n\n    selected.push(remaining.splice(best_idx, 1)[0]);\n  }\n\n  return selected;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   RELATED MEMORIES AND USAGE TRACKING\n----------------------------------------------------------------*/\n\n/**\n * Gets memories related to a stored memory.\n * @param memory_id - The memory identifier.\n * @returns The related memory rows.\n */\nexport function get_related_memories(memory_id: number): MemoryRow[] {\n  try {\n    const database = initialize_db();\n\n    const memory = database.prepare(`\n      SELECT related_memories FROM memory_index WHERE id = ?\n    `).get(memory_id) as { related_memories?: string | null } | undefined;\n\n    if (!memory || !memory.related_memories) {\n      return [];\n    }\n\n    const related = safe_parse_json(memory.related_memories, []);\n\n    return (related as RelatedMemoryLink[]).map((rel: RelatedMemoryLink): MemoryRow | null => {\n      const full_memory = get_memory(rel.id);\n      if (full_memory) {\n        return {\n          ...full_memory,\n          relationSimilarity: rel.similarity\n        };\n      }\n      return null;\n    }).filter((relatedMemory): relatedMemory is MemoryRow => Boolean(relatedMemory));\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to get related memories for ${memory_id}: ${get_error_message(error)}`);\n    return [];\n  }\n}\n\n/**\n * Gets usage statistics for indexed memories.\n * @param options - Sorting and limit options.\n * @returns The usage statistics rows.\n */\nexport function get_usage_stats(options: UsageStatsOptions = {}): Array<{ id: number; title: string | null; spec_folder: string; file_path: string; access_count: number; last_accessed: number | null; confidence: number | null; created_at: string }> {\n  const {\n    sortBy = 'access_count',\n    order = 'DESC',\n    limit = 20\n  } = options;\n\n  const valid_sort_fields = ['access_count', 'last_accessed', 'confidence'];\n  const sort_field = valid_sort_fields.includes(sortBy) ? sortBy : 'access_count';\n  const sort_order = order.toUpperCase() === 'ASC' ? 'ASC' : 'DESC';\n\n  const database = initialize_db();\n\n  const rows = database.prepare(`\n    SELECT id, title, spec_folder, file_path, access_count,\n           last_accessed, confidence, created_at\n    FROM memory_index\n    WHERE access_count > 0\n    ORDER BY ${sort_field} ${sort_order}\n    LIMIT ?\n  `).all(limit) as Array<{\n    id: number;\n    title: string | null;\n    spec_folder: string;\n    file_path: string;\n    access_count: number;\n    last_accessed: number | null;\n    confidence: number | null;\n    created_at: string;\n  }>;\n\n  return rows;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   CLEANUP FUNCTIONS\n----------------------------------------------------------------*/\n\n/**\n * Finds memory records that are candidates for cleanup.\n * @param options - Cleanup thresholds and limits.\n * @returns The cleanup candidate details.\n */\nexport function find_cleanup_candidates(options: CleanupOptions = {}): Array<{ id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; reasons: string[] }> {\n  const database = initialize_db();\n\n  const {\n    maxAgeDays = 90,\n    maxAccessCount = 2,\n    maxConfidence = 0.4,\n    limit = 50\n  } = options;\n\n  const cutoff_date = new Date();\n  cutoff_date.setDate(cutoff_date.getDate() - maxAgeDays);\n  const cutoff_iso = cutoff_date.toISOString();\n\n  const sql = `\n    SELECT\n      id,\n      spec_folder,\n      file_path,\n      title,\n      created_at,\n      last_accessed,\n      access_count,\n      confidence,\n      importance_weight\n    FROM memory_index\n    WHERE\n      created_at < ?\n      OR access_count <= ?\n      OR confidence <= ?\n      OR (last_accessed IS NULL AND created_at < ?)\n    ORDER BY\n      last_accessed ASC NULLS FIRST,\n      access_count ASC,\n      confidence ASC\n    LIMIT ?\n  `;\n\n  let rows;\n  try {\n    rows = database.prepare(sql).all(\n      cutoff_iso,\n      maxAccessCount,\n      maxConfidence,\n      cutoff_iso,\n      limit\n    );\n  } catch (e: unknown) {\n    console.warn(`[vector-index] find_cleanup_candidates error: ${get_error_message(e)}`);\n    return [];\n  }\n\n  return (rows as MemoryRow[]).map((row: MemoryRow) => {\n    const age_string = format_age_string(row.created_at ?? null);\n    const last_access_string = format_age_string(\n      typeof row.last_accessed === 'number' ? new Date(row.last_accessed).toISOString() : null\n    );\n\n    const reasons: string[] = [];\n    if (row.created_at && new Date(row.created_at) < cutoff_date) {\n      reasons.push(`created ${age_string}`);\n    }\n    if ((row.access_count || 0) <= maxAccessCount) {\n      const count = row.access_count || 0;\n      reasons.push(`accessed ${count} time${count !== 1 ? 's' : ''}`);\n    }\n    if ((row.confidence || 0.5) <= maxConfidence) {\n      reasons.push(`low importance (${Math.round((row.confidence || 0.5) * 100)}%)`);\n    }\n\n    return {\n      id: row.id,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      title: row.title || 'Untitled',\n      createdAt: row.created_at,\n      lastAccessedAt: row.last_accessed,\n      accessCount: row.access_count || 0,\n      confidence: row.confidence || 0.5,\n      ageString: age_string,\n      lastAccessString: last_access_string,\n      reasons\n    };\n  });\n}\n\n/**\n * Builds a preview payload for a stored memory.\n * @param memory_id - The memory identifier.\n * @param max_lines - The maximum number of file lines to include.\n * @returns The memory preview, if found.\n */\nexport function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n  const database = initialize_db();\n\n  let memory: MemoryRow | undefined;\n  try {\n    memory = database.prepare(`\n      SELECT * FROM memory_index WHERE id = ?\n    `).get(memory_id) as MemoryRow | undefined;\n  } catch (e: unknown) {\n    console.warn(`[vector-index] get_memory_preview query error: ${get_error_message(e)}`);\n    return null;\n  }\n\n  if (!memory) return null;\n\n  let content = '';\n  try {\n    // Validate DB-stored file paths before reading\n    if (memory.file_path) {\n      const valid_path = validate_file_path_local(memory.file_path);\n      if (valid_path && fs.existsSync(valid_path)) {\n        const full_content = fs.readFileSync(valid_path, 'utf-8');\n        const lines = full_content.split('\\n');\n        content = lines.slice(0, max_lines).join('\\n');\n        if (lines.length > max_lines) {\n          content += `\\n... (${lines.length - max_lines} more lines)`;\n        }\n      }\n    }\n  } catch (e: unknown) {\n    console.warn('[vector-index] get_memory_preview file read warning', {","lineStart":1,"lineEnd":1484,"totalLines":1485,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781762552972,"end":1781762552976}},"metadata":{"openai":{"itemId":"fc_0ad6a33b31dfd68b016a3389f8c5c481918b1e56409448e3ed"}},"id":"prt_ed952f48b001n6xgYLmDZDfcSa","sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","messageID":"msg_ed952b9660016b4OyV917AJXcZ"}}
{"type":"tool_use","timestamp":1781762552998,"sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","part":{"type":"tool","tool":"read","callID":"call_5aTNNVpscHCPVzwbwrcbZM5j","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Hybrid Search\n3: // ───────────────────────────────────────────────────────────────\n4: // Combines vector, FTS, and BM25 search with fallback\n5: \n6: // 1. IMPORTS\n7: \n8: // Local\n9: import {\n10:   getIndex,\n11:   isBm25Enabled,\n12:   shouldUseSqliteLexicalEngine,\n13: } from './bm25-index.js';\n14: import { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\n15: import { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\n16: import { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\n17: import { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\n18: import { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\n19: import { fts5Bm25Search } from './sqlite-fts.js';\n20: import { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';\n21: import {\n22:   isMMREnabled,\n23:   isSearchFallbackEnabled,\n24:   isDocscoreAggregationEnabled,\n25:   isDegreeBoostEnabled,\n26:   isContextHeadersEnabled,\n27:   isArchivedRetrievalIncludedByDefault,\n28:   isCosineTopnReorderEnabled,\n29: } from './search-flags.js';\n30: import { resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\n31: import { computeDegreeScores } from './graph-search-fn.js';\n32: import type { GraphSearchFn } from './search-types.js';\n33: \n34: // Feature catalog: Hybrid search pipeline\n35: \n36: export type { GraphSearchFn } from './search-types.js';\n37: \n38: import { routeQuery } from './query-router.js';\n39: import { isComplexityRouterEnabled } from './query-classifier.js';\n40: import { enforceChannelRepresentation } from './channel-enforcement.js';\n41: import {\n42:   truncateByConfidence,\n43:   isConfidenceTruncationEnabled,\n44:   DEFAULT_MIN_RESULTS,\n45:   GAP_THRESHOLD_MULTIPLIER,\n46: } from './confidence-truncation.js';\n47: import {\n48:   getDynamicTokenBudget,\n49:   isDynamicTokenBudgetEnabled,\n50:   DEFAULT_TOKEN_BUDGET_CONFIG,\n51: } from './dynamic-token-budget.js';\n52: import {\n53:   buildProgressiveResponse,\n54:   DEFAULT_PAGE_SIZE,\n55: } from './progressive-disclosure.js';\n56: import type {\n57:   ProgressiveResponse,\n58:   DisclosureResult,\n59: } from './progressive-disclosure.js';\n60: import { resolveFusionIntentContract } from './search-utils.js';\n61: import { ensureDescriptionCache, getSpecsBasePaths } from './folder-discovery.js';\n62: import {\n63:   isFolderScoringEnabled,\n64:   lookupFolders,\n65:   computeFolderRelevanceScores,\n66:   enrichResultsWithFolderScores,\n67:   twoPhaseRetrieval,\n68: } from './folder-relevance.js';\n69: import { parse_trigger_phrases, specFolderLikePattern } from './vector-index-types.js';\n70: \n71: import { collapseAndReassembleChunkResults } from '../scoring/mpab-aggregation.js';\n72: \n73: // Type-only\n74: import type Database from 'better-sqlite3';\n75: import type { SpreadResult } from '../cognitive/co-activation.js';\n76: import type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\n77: import type { FusionResult } from '@spec-kit/shared/algorithms/rrf-fusion';\n78: import type { ChannelName } from './query-router.js';\n79: import type { EnforcementResult } from './channel-enforcement.js';\n80: import type { TruncationResult } from './confidence-truncation.js';\n81: \n82: // 2. INTERFACES\n83: \n84: type VectorSearchFn = (\n85:   embedding: Float32Array | number[],\n86:   options: Record<string, unknown>\n87: ) => Array<Record<string, unknown>>;\n88: \n89: interface HybridSearchOptions {\n90:   limit?: number;\n91:   specFolder?: string;\n92:   minSimilarity?: number;\n93:   useBm25?: boolean;\n94:   useFts?: boolean;\n95:   useVector?: boolean;\n96:   useGraph?: boolean;\n97:   includeArchived?: boolean;\n98:   includeContent?: boolean;\n99:   /**\n100:    * Evaluation-only mode.\n101:    * When true, preserve the requested top-K window by bypassing confidence\n102:    * truncation and token-budget truncation without changing live defaults.\n103:    */\n104:   evaluationMode?: boolean;\n105:   /** Classified query intent for adaptive fusion weight selection (e.g. 'understand', 'fix_bug'). */\n106:   intent?: string;\n107:   /** Optional trigger phrases for query-classifier trigger-match routing path. */\n108:   triggerPhrases?: string[];\n109:   /**\n110:    * Internal fallback override: when true, bypass complexity routing and\n111:    * enable all retrieval channels for this search call.\n112:    */\n113:   forceAllChannels?: boolean;\n114:   /**\n115:    * Internal raw-candidate mode used by the Stage 1 pipeline.\n116:    * When true, stop after channel collection and return pre-fusion candidates.\n117:    */\n118:   skipFusion?: boolean;\n119:   /**\n120:    * Internal pipeline handoff mode.\n121:    * When true, return immediately after adaptive/RRF fusion so Stage 2/3 can\n122:    * apply the remaining pipeline scoring and aggregation steps.\n123:    */\n124:   stopAfterFusion?: boolean;\n125: }\n126: \n127: interface HybridSearchResult {\n128:   id: number | string;\n129:   /**\n130:    * Normalized relevance score (0-1). Semantics depend on `source`:\n131:    * - `'vector'` — cosine similarity from sqlite-vec (normalized from 0-100 to 0-1)\n132:    * - `'bm25'` — BM25 term-frequency relevance (min-max normalized per source group)\n133:    * - `'fts'` — FTS5 rank score (absolute value, min-max normalized per source group)\n134:    * - `'graph'` — graph traversal relevance\n135:    *\n136:    * After hybrid merge, all source scores are min-max normalized to 0-1 within\n137:    * their source group to ensure fair cross-method comparison.\n138:    */\n139:   score: number;\n140:   source: string;\n141:   title?: string;\n142:   [key: string]: unknown;\n143: }\n144: \n145: type HardExclusionSource = 'archived-tier' | 'deprecated-tier';\n146: type HardExclusionClassification = 'intended' | 'silent-risk' | 'unclassified';\n147: \n148: interface HardExclusionPredicate {\n149:   id: string;\n150:   source: HardExclusionSource;\n151:   channel: string;\n152:   predicate: string;\n153:   defaultApplied: boolean;\n154:   classification: HardExclusionClassification;\n155: }\n156: \n157: const HARD_EXCLUSION_PREDICATES: readonly HardExclusionPredicate[] = Object.freeze([\n158:   {\n159:     id: 'includeArchived-default',\n160:     source: 'archived-tier',\n161:     channel: 'vector/fts',\n162:     predicate: 'includeArchived defaults to false',\n163:     defaultApplied: true,\n164:     classification: 'intended',\n165:   },\n166:   {\n167:     id: 'fts-deprecated-tier',\n168:     source: 'deprecated-tier',\n169:     channel: 'fts',\n170:     predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n171:     defaultApplied: true,\n172:     classification: 'silent-risk',\n173:   },\n174:   {\n175:     id: 'bm25-deprecated-tier',\n176:     source: 'deprecated-tier',\n177:     channel: 'bm25',\n178:     predicate: \"importance_tier != 'deprecated'\",\n179:     defaultApplied: true,\n180:     classification: 'silent-risk',\n181:   },\n182:   {\n183:     id: 'trigger-deprecated-tier',\n184:     source: 'deprecated-tier',\n185:     channel: 'trigger',\n186:     predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n187:     defaultApplied: true,\n188:     classification: 'silent-risk',\n189:   },\n190:   {\n191:     id: 'structural-deprecated-archived-tier',\n192:     source: 'deprecated-tier',\n193:     channel: 'structural',\n194:     predicate: \"importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived')\",\n195:     defaultApplied: true,\n196:     classification: 'silent-risk',\n197:   },\n198: ]);\n199: \n200: /** Return recall-path exclusion metadata without executing or changing search. */\n201: function getHardExclusionPredicates(): HardExclusionPredicate[] {\n202:   return HARD_EXCLUSION_PREDICATES.map((predicate) => ({ ...predicate }));\n203: }\n204: \n205: type Bm25MemoryMetadata = {\n206:   specFolder: string | null;\n207:   importanceTier: string | null;\n208: };\n209: \n210: /** Non-enumerable shadow metadata attached to result arrays via Object.defineProperty. */\n211: interface ShadowMetaArray {\n212:   _s4shadow?: unknown;\n213:   _s4attribution?: unknown;\n214:   _degradation?: unknown;\n215: }\n216: \n217: /** Normalize a fused RRF result to the HybridSearchResult contract. */\n218: function toHybridResult(result: FusionResult): HybridSearchResult {\n219:   const sourceCandidate = (result as { source?: unknown }).source;\n220:   const primarySource = result.sources[0] ?? 'hybrid';\n221:   const scoreCandidate = (result as { score?: unknown }).score;\n222: \n223:   return {\n224:     ...result,\n225:     id: result.id,\n226:     score: typeof scoreCandidate === 'number' ? scoreCandidate : result.rrfScore,\n227:     source: typeof sourceCandidate === 'string' ? sourceCandidate : primarySource,\n228:   };\n229: }\n230: \n231: // PIPELINE METADATA\n232: \n233: /**\n234:  * Optional metadata about pipeline stages attached to enhanced search results.\n235:  * Only populated when the corresponding feature flags are enabled.\n236:  */\n237: interface Sprint3PipelineMeta {\n238:   /** Query complexity routing result (SPECKIT_COMPLEXITY_ROUTER). */\n239:   routing?: {\n240:     tier: string;\n241:     channels: string[];\n242:     skippedChannels: string[];\n243:     featureFlagEnabled: boolean;\n244:     confidence: string;\n245:     features: Record<string, unknown>;\n246:   };\n247:   /** Channel enforcement result (SPECKIT_CHANNEL_MIN_REP). */\n248:   enforcement?: { applied: boolean; promotedCount: number; underRepresentedChannels: string[] };\n249:   /** Confidence truncation result (SPECKIT_CONFIDENCE_TRUNCATION). */\n250:   truncation?: {\n251:     truncated: boolean;\n252:     originalCount: number;\n253:     truncatedCount: number;\n254:     medianGap: number;\n255:     cutoffGap: number;\n256:     cutoffIndex: number;\n257:     thresholdMultiplier: number;\n258:     minResultsGuaranteed: number;\n259:     featureFlagEnabled: boolean;\n260:   };\n261:   /** Dynamic token budget result (SPECKIT_DYNAMIC_TOKEN_BUDGET). */\n262:   tokenBudget?: {\n263:     tier: string;\n264:     budget: number;\n265:     applied: boolean;\n266:     featureFlagEnabled: boolean;\n267:     configValues: Record<string, number>;\n268:     headerOverhead: number;\n269:     adjustedBudget: number;\n270:   };\n271: }\n272: \n273: // 4. PI-A2: DEGRADATION TYPES\n274: \n275: /** Fallback tier in the 3-tier degradation chain. */\n276: type FallbackTier = 1 | 2 | 3;\n277: \n278: /** Why degradation was triggered at a given tier. */\n279: interface DegradationTrigger {\n280:   reason: 'low_quality' | 'insufficient_results' | 'both';\n281:   topScore: number;\n282:   resultCount: number;\n283:   relativeGap?: number;\n284: }\n285: \n286: /** Record of a single degradation event during tiered fallback. */\n287: interface DegradationEvent {\n288:   tier: FallbackTier;\n289:   trigger: DegradationTrigger;\n290:   resultCountBefore: number;\n291:   resultCountAfter: number;\n292: }\n293: \n294: /**\n295:  * Absolute quality floor for degradation checks.\n296:  *\n297:  * Raw RRF scores are typically small decimals (often <0.05), so a\n298:  * high fixed threshold causes false degradations. Use a conservative floor and\n299:  * pair it with a relative-gap check to avoid score-scale coupling.\n300:  */\n301: const DEGRADATION_QUALITY_THRESHOLD = 0.02;\n302: \n303: /** Minimum relative separation between top-1 and top-2 scores. */\n304: const DEGRADATION_MIN_RELATIVE_GAP = 0.2;\n305: \n306: /** Minimum result count: must have >= this many results to stay at current tier. */\n307: const DEGRADATION_MIN_RESULTS = 3;\n308: \n309: // 5. MODULE STATE\n310: \n311: /** Default result limit when none is specified by the caller. */\n312: const DEFAULT_LIMIT = 20;\n313: /** Primary vector similarity floor for hybrid fallback passes (percentage units). */\n314: const PRIMARY_FALLBACK_MIN_SIMILARITY = 30;\n315: /** Secondary vector similarity floor for adaptive retry passes (percentage units). */\n316: const SECONDARY_FALLBACK_MIN_SIMILARITY = 17;\n317: /** Tier-2 vector similarity floor for quality-aware fallback (percentage units). */\n318: const TIERED_FALLBACK_MIN_SIMILARITY = 10;\n319: \n320: /** Minimum MMR candidates required for diversity reranking to be worthwhile. */\n321: const MMR_MIN_CANDIDATES = 2;\n322: \n323: /** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\n324: const MMR_DEFAULT_LAMBDA = 0.7;\n325: \n326: /** Number of top results used as seeds for co-activation spreading. */\n327: const SPREAD_ACTIVATION_TOP_N = 5;\n328: \n329: /** Maximum contextual tree header length prepended to content (including brackets). */\n330: const CONTEXT_HEADER_MAX_CHARS = 100;\n331: /** Header/content separator characters added during contextual tree injection. */\n332: const CONTEXT_HEADER_SEPARATOR_CHARS = 1;\n333: /** Reserved token overhead per contextual header, calibrated to max header length. */\n334: const CONTEXT_HEADER_TOKEN_OVERHEAD = Math.ceil(\n335:   (CONTEXT_HEADER_MAX_CHARS + CONTEXT_HEADER_SEPARATOR_CHARS) / 4\n336: );\n337: \n338: let db: Database.Database | null = null;\n339: let vectorSearchFn: VectorSearchFn | null = null;\n340: let graphSearchFn: GraphSearchFn | null = null;\n341: let enrichFusedResultsObserver: (() => void) | null = null;\n342: \n343: // 6. GRAPH CHANNEL METRICS\n344: \n345: interface GraphChannelMetrics {\n346:   totalQueries: number;\n347:   graphHits: number;\n348:   graphResultCount: number;\n349:   graphOnlyResults: number;\n350:   graphMultiSourceResults: number;\n351:   multiSourceResults: number;\n352:   degreeQueries: number;\n353:   degreeHits: number;\n354:   degreeResultCount: number;\n355: }\n356: \n357: const graphMetrics: GraphChannelMetrics = {\n358:   totalQueries: 0,\n359:   graphHits: 0,\n360:   graphResultCount: 0,\n361:   graphOnlyResults: 0,\n362:   graphMultiSourceResults: 0,\n363:   multiSourceResults: 0,\n364:   degreeQueries: 0,\n365:   degreeHits: 0,\n366:   degreeResultCount: 0,\n367: };\n368: \n369: /**\n370:  * Return current graph channel metrics for health check reporting.\n371:  * graphHitRate is computed as graphHits / totalQueries.\n372:  */\n373: function getGraphMetrics(): GraphChannelMetrics & { graphHitRate: number; degreeHitRate: number } {\n374:   return {\n375:     ...graphMetrics,\n376:     graphHitRate: graphMetrics.totalQueries > 0\n377:       ? graphMetrics.graphHits / graphMetrics.totalQueries\n378:       : 0,\n379:     degreeHitRate: graphMetrics.degreeQueries > 0\n380:       ? graphMetrics.degreeHits / graphMetrics.degreeQueries\n381:       : 0,\n382:   };\n383: }\n384: \n385: /** Reset all graph channel metrics counters to zero. */\n386: function resetGraphMetrics(): void {\n387:   graphMetrics.totalQueries = 0;\n388:   graphMetrics.graphHits = 0;\n389:   graphMetrics.graphResultCount = 0;\n390:   graphMetrics.graphOnlyResults = 0;\n391:   graphMetrics.graphMultiSourceResults = 0;\n392:   graphMetrics.multiSourceResults = 0;\n393:   graphMetrics.degreeQueries = 0;\n394:   graphMetrics.degreeHits = 0;\n395:   graphMetrics.degreeResultCount = 0;\n396: }\n397: \n398: // 7. INITIALIZATION\n399: \n400: /**\n401:  * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n402:  * @param database - The better-sqlite3 database instance for FTS and graph queries.\n403:  * @param vectorFn - Optional vector search function for semantic similarity.\n404:  * @param graphFn - Optional graph search function for causal/structural retrieval.\n405:  */\n406: function init(\n407:   database: Database.Database,\n408:   vectorFn: VectorSearchFn | null = null,\n409:   graphFn: GraphSearchFn | null = null\n410: ): void {\n411:   db = database;\n412:   vectorSearchFn = vectorFn;\n413:   graphSearchFn = graphFn;\n414: }\n415: \n416: // 8. BM25 SEARCH\n417: \n418: /**\n419:  * Search the BM25 index with optional spec folder filtering.\n420:  * @param query - The search query string.\n421:  * @param options - Optional limit and specFolder filter.\n422:  * @returns Array of BM25-scored results tagged with source 'bm25'.\n423:  */\n424: function bm25Search(\n425:   query: string,\n426:   options: { limit?: number; specFolder?: string } = {}\n427: ): HybridSearchResult[] {\n428:   if (!isBm25Enabled()) {\n429:     console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n430:     return [];\n431:   }\n432: \n433:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n434: \n435:   try {\n436:     if (shouldUseSqliteLexicalEngine(db)) {\n437:       return ftsSearch(query, {\n438:         limit,\n439:         specFolder,\n440:       }).map((result) => ({\n441:         ...result,\n442:         bm25_score: result.score,\n443:         source: 'bm25',\n444:         sources: Array.from(new Set([\n445:           ...(\n446:             Array.isArray((result as Record<string, unknown>).sources)\n447:               ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n448:               : []\n449:           ),\n450:           'fts',\n451:           'bm25',\n452:         ])),\n453:       }));\n454:     }\n455: \n456:     // Spec-folder scope can only be resolved from DB metadata; fail closed before\n457:     // searching when the DB is unavailable rather than over-fetching the whole\n458:     // corpus and then discarding it.\n459:     if (specFolder && !db) {\n460:       console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n461:       return [];\n462:     }\n463: \n464:     const index = getIndex();\n465:     const candidateLimit = (specFolder || db)\n466:       ? index.getStats().documentCount\n467:       : limit;\n468:     // Metadata filters run after in-memory scoring, so fetch the corpus-bounded\n469:     // candidate set whenever those filters can remove otherwise top-ranked hits.\n470:     const results = index.search(query, candidateLimit);\n471: \n472:     // BM25 document IDs are stringified\n473:     // Numeric memory IDs (e.g., \"42\"), not spec folder paths. The old filter compared\n474:     // R.id against specFolder which never matched. Use DB lookup to resolve spec_folder.\n475: \n476:     // Batch-resolve metadata for all result IDs (was N+1 individual queries)\n477:     // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n478:     // resolution returns [] rather than leaking unscoped BM25 candidates.\n479:     let memoryMetadataMap: Map<number, Bm25MemoryMetadata> | null = null;\n480:     if (results.length > 0) {\n481:       if (!db) {\n482:         if (specFolder) {\n483:           const error = new Error('Database unavailable for spec-folder scope lookup');\n484:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n485:           return [];\n486:         }\n487:       } else {\n488:         try {\n489:           const ids = results.map((r: { id: string }) => Number(r.id));\n490:           memoryMetadataMap = new Map();\n491:           // Resolve metadata in bounded batches. The candidate set can now be\n492:           // corpus-sized (over-fetch for scope/tier filtering), and a single\n493:           // IN (...) with one bind per id would exceed SQLite's parameter limit\n494:           // and throw — which the catch below turns into an empty result.\n495:           const METADATA_BATCH = 500;\n496:           for (let offset = 0; offset < ids.length; offset += METADATA_BATCH) {\n497:             const batch = ids.slice(offset, offset + METADATA_BATCH);\n498:             const placeholders = batch.map(() => '?').join(',');\n499:             const rows = db.prepare(\n500:               `SELECT id, spec_folder, importance_tier FROM memory_index WHERE id IN (${placeholders})`\n501:             ).all(...batch) as Array<{ id: number; spec_folder: string | null; importance_tier: string | null }>;\n502:             for (const row of rows) {\n503:               memoryMetadataMap.set(row.id, {\n504:                 specFolder: row.spec_folder,\n505:                 importanceTier: row.importance_tier,\n506:               });\n507:             }\n508:           }\n509:         } catch (error: unknown) {\n510:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n511:           return [];\n512:         }\n513:       }\n514: \n515:       // DEFENSE-IN-DEPTH: If specFolder was requested but metadata resolution\n516:       // is still null after the resolution block, something unexpected happened.\n517:       // Fail closed rather than falling through to unscoped results.\n518:       if (specFolder && !memoryMetadataMap) {\n519:         const error = new Error('memoryMetadataMap unexpectedly null after scope resolution');\n520:         console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n521:         return [];\n522:       }\n523:     }\n524: \n525:     const excludeCold = !isArchivedRetrievalIncludedByDefault();\n526:     return results\n527:       .filter((r: { id: string }) => {\n528:         const metadata = memoryMetadataMap?.get(Number(r.id));\n529:         // Cold/deprecated rows are included by default (FSRS ranks them lower);\n530:         // only drop them when archived retrieval is disabled.\n531:         if (excludeCold && metadata?.importanceTier === 'deprecated') return false;\n532:         if (!specFolder) return true;\n533:         if (!metadata) return false;\n534:         const folder = metadata.specFolder;\n535:         if (!folder) return false;\n536:         return folder === specFolder || folder.startsWith(specFolder + '/');\n537:       })\n538:       .slice(0, limit)\n539:       .map((r: { id: string; score: number }) => ({\n540:         ...r,\n541:         source: 'bm25',\n542:       }));\n543:   } catch (error: unknown) {\n544:     const msg = error instanceof Error ? error.message : String(error);\n545:     console.warn(`[hybrid-search] BM25 search failed: ${msg}`);\n546:     return [];\n547:   }\n548: }\n549: \n550: /**\n551:  * Check whether the BM25 index is populated and available for search.\n552:  * @returns True if the BM25 index exists and contains at least one document.\n553:  */\n554: function isBm25Available(): boolean {\n555:   if (!isBm25Enabled()) {\n556:     return false;\n557:   }\n558: \n559:   try {\n560:     const index = getIndex();\n561:     return index.getStats().documentCount > 0;\n562:   } catch (_err: unknown) {\n563:     // Swallow index-not-initialized errors; caller treats absence as unavailable\n564:     return false;\n565:   }\n566: }\n567: \n568: // 9. FTS SEARCH\n569: \n570: /**\n571:  * Check whether the FTS5 full-text search table exists in the database.\n572:  * @returns True if the memory_fts table exists in the connected database.\n573:  */\n574: function isFtsAvailable(): boolean {\n575:   if (!db) {\n576:     console.warn('[hybrid-search] db not initialized — isFtsAvailable returning false');\n577:     return false;\n578:   }\n579: \n580:   try {\n581:     const result = (db.prepare(`\n582:       SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'\n583:     `) as Database.Statement).get() as { name: string } | undefined;\n584:     return !!result;\n585:   } catch (_err: unknown) {\n586:     // Swallow DB errors; caller treats absence as unavailable\n587:     return false;\n588:   }\n589: }\n590: \n591: /**\n592:  * Run FTS5 full-text search with weighted BM25 scoring and optional spec folder filtering.\n593:  * @param query - The search query string.\n594:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n595:  * @returns Array of FTS-scored results tagged with source 'fts'.\n596:  */\n597: function ftsSearch(\n598:   query: string,\n599:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n600: ): HybridSearchResult[] {\n601:   if (!db || !isFtsAvailable()) {\n602:     console.warn('[hybrid-search] db not initialized or FTS unavailable — returning empty ftsSearch results');\n603:     return [];\n604:   }\n605: \n606:   const { limit = DEFAULT_LIMIT, specFolder, includeArchived = false } = options;\n607: \n608:   try {\n609:     // Delegate to weighted BM25 FTS5 search from sqlite-fts.ts\n610:     // Uses bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) for per-column weighting\n611:     // (title 10x, trigger_phrases 5x, file_path 2x, content 1x)\n612:     // Filters: deprecated-tier exclusion and spec-folder matching handled by fts5Bm25Search\n613:     const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n614: \n615:     return bm25Results.map(row => ({\n616:       ...row,\n617:       id: row.id as number,\n618:       score: row.fts_score || 0,\n619:       source: 'fts',\n620:     }));\n621:   } catch (error: unknown) {\n622:     const msg = error instanceof Error ? error.message : String(error);\n623:     console.warn(`[hybrid-search] FTS search failed: ${msg}`);\n624:     return [];\n625:   }\n626: }\n627: \n628: // 10. COMBINED LEXICAL SEARCH\n629: \n630: /**\n631:  * Merge FTS and BM25 search results, deduplicating by ID and preferring FTS scores.\n632:  * @param query - The search query string.\n633:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n634:  * @returns Deduplicated array of merged results sorted by score descending.\n635:  */\n636: function combinedLexicalSearch(\n637:   query: string,\n638:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n639: ): HybridSearchResult[] {\n640:   const ftsResults = ftsSearch(query, options);\n641:   const bm25Results = bm25Search(query, options);\n642: \n643:   // Merge by canonical ID, prefer FTS scores.\n644:   // CanonicalResultId() prevents duplicate rows when one channel emits\n645:   // Numeric IDs (42) and another emits string IDs (\"42\" or \"mem:42\").\n646:   const merged = new Map<string, HybridSearchResult>();\n647: \n648:   for (const r of ftsResults) {\n649:     merged.set(canonicalResultId(r.id), r);\n650:   }\n651: \n652:   for (const r of bm25Results) {\n653:     const canonicalId = canonicalResultId(r.id);\n654:     if (!merged.has(canonicalId)) {\n655:       merged.set(canonicalId, r);\n656:     }\n657:   }\n658: \n659:   return Array.from(merged.values())\n660:     .sort((a, b) => b.score - a.score)\n661:     .slice(0, options.limit || DEFAULT_LIMIT);\n662: }\n663: \n664: function normalizeTriggerText(value: string): string {\n665:   return value\n666:     .toLowerCase()\n667:     .replace(/[^a-z0-9]+/g, ' ')\n668:     .replace(/\\s+/g, ' ')\n669:     .trim();\n670: }\n671: \n672: function triggerQueryTokens(query: string): string[] {\n673:   return Array.from(new Set(\n674:     normalizeTriggerText(query)\n675:       .split(/\\s+/)\n676:       .filter((token) => token.length >= 2)\n677:   ));\n678: }\n679: \n680: function computeTriggerMatchScore(query: string, phrase: string): number {\n681:   const normalizedQuery = normalizeTriggerText(query);\n682:   const normalizedPhrase = normalizeTriggerText(phrase);\n683:   if (!normalizedQuery || !normalizedPhrase) return 0;\n684:   if (normalizedPhrase === normalizedQuery) return 1.0;\n685: \n686:   const queryTokens = triggerQueryTokens(normalizedQuery);\n687:   const phraseTokens = new Set(triggerQueryTokens(normalizedPhrase));\n688:   if (phraseTokens.size < 2) return 0;\n689:   if (normalizedPhrase.includes(normalizedQuery)) return 0.94;\n690:   if (normalizedQuery.includes(normalizedPhrase)) return 0.88;\n691:   if (queryTokens.length === 0) return 0;\n692:   const overlap = queryTokens.filter((token) => phraseTokens.has(token)).length;\n693:   const coverage = overlap / queryTokens.length;\n694:   return coverage >= 0.8 ? coverage * 0.75 : 0;\n695: }\n696: \n697: function timestampBoost(value: unknown): number {\n698:   if (typeof value !== 'string' || value.length === 0) return 0;\n699:   const parsed = Date.parse(value);\n700:   if (!Number.isFinite(parsed)) return 0;\n701:   const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n702:   return 1 / (1 + ageDays / 30);\n703: }\n704: \n705: function exactTriggerSearch(\n706:   query: string,\n707:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n708: ): HybridSearchResult[] {\n709:   if (!db) return [];\n710: \n711:   const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n712:   if (tokens.length === 0) return [];\n713: \n714:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n715:   const normalizedQuery = normalizeTriggerText(query);\n716:   const exactPhraseLike = `%${normalizedQuery}%`;\n717:   const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n718:   const conditions = [\n719:     `m.trigger_phrases IS NOT NULL`,\n720:     `m.trigger_phrases != ''`,\n721:     `m.trigger_phrases != '[]'`,\n722:     // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n723:     // them below hot memories); the hard exclusion only applies when archived\n724:     // retrieval is disabled.\n725:     ...(isArchivedRetrievalIncludedByDefault()\n726:       ? []\n727:       : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n728:     `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n729:     `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n730:   ];\n731:   const params: unknown[] = tokens.map((token) => `%${token}%`);\n732: \n733:   if (specFolder) {\n734:     conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n735:     params.push(specFolder, specFolderLikePattern(specFolder));\n736:   }\n737: \n738:   try {\n739:     const rows = db.prepare(`\n740:       SELECT m.*\n741:       FROM memory_index m\n742:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n743:       WHERE ${conditions.join(' AND ')}\n744:       ORDER BY\n745:         CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n746:         COALESCE(m.updated_at, m.created_at, '') DESC\n747:       LIMIT ${candidateLimit}\n748:     `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n749: \n750:     return rows\n751:       .map((row): HybridSearchResult | null => {\n752:         const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n753:         const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n754:         if (matchScore <= 0) return null;\n755: \n756:         const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n757:           ? Math.max(0, Math.min(1, row.importance_weight))\n758:           : 0.5;\n759:         const recency = timestampBoost(row.updated_at ?? row.created_at);\n760:         const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n761: \n762:         return {\n763:           ...row,\n764:           id: row.id as number,\n765:           score,\n766:           triggerScore: matchScore,\n767:           source: 'trigger',\n768:         };\n769:       })\n770:       .filter((row): row is HybridSearchResult => row !== null)\n771:       .sort((a, b) => {\n772:         const scoreDelta = b.score - a.score;\n773:         if (scoreDelta !== 0) return scoreDelta;\n774:         const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n775:         const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n776:         return bTime - aTime;\n777:       })\n778:       .slice(0, limit);\n779:   } catch (error: unknown) {\n780:     const msg = error instanceof Error ? error.message : String(error);\n781:     console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n782:     return [];\n783:   }\n784: }\n785: \n786: type RawChannelList = {\n787:   source: string;\n788:   results: Array<{ id: number | string; [key: string]: unknown }>;\n789: };\n790: \n791: function resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n792:   if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n793:     return result.score;\n794:   }\n795:   if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n796:     return result.similarity / 100;\n797:   }\n798:   return 0;\n799: }\n800: \n801: function getCandidateSources(result: HybridSearchResult): string[] {\n802:   const sourceList = (result as { sources?: unknown }).sources;\n803:   if (Array.isArray(sourceList)) {\n804:     return sourceList.filter((value): value is string => typeof value === 'string');\n805:   }\n806:   return typeof result.source === 'string' && result.source.length > 0\n807:     ? [result.source]\n808:     : [];\n809: }\n810: \n811: function getCandidateSourceScores(result: HybridSearchResult): Record<string, number> {\n812:   const sourceScores = (result as { sourceScores?: unknown }).sourceScores;\n813:   if (sourceScores && typeof sourceScores === 'object' && !Array.isArray(sourceScores)) {\n814:     const normalizedScores: Record<string, number> = {};\n815:     for (const [source, score] of Object.entries(sourceScores as Record<string, unknown>)) {\n816:       if (typeof score === 'number' && Number.isFinite(score)) {\n817:         normalizedScores[source] = score;\n818:       }\n819:     }\n820:     return normalizedScores;\n821:   }\n822: \n823:   const fallbackScores: Record<string, number> = {};\n824:   const resultScore = typeof result.score === 'number' && Number.isFinite(result.score)\n825:     ? result.score\n826:     : 0;\n827:   for (const source of getCandidateSources(result)) {\n828:     fallbackScores[source] = resultScore;\n829:   }\n830:   return fallbackScores;\n831: }\n832: \n833: function mergeRawCandidate(\n834:   existing: HybridSearchResult | undefined,\n835:   incoming: HybridSearchResult\n836: ): HybridSearchResult {\n837:   if (!existing) {\n838:     const sources = getCandidateSources(incoming);\n839:     const channelCount = sources.length;\n840:     return {\n841:       ...incoming,\n842:       sources,\n843:       channelCount,\n844:       sourceScores: getCandidateSourceScores(incoming),\n845:       channelAttribution: sources,\n846:     };\n847:   }\n848: \n849:   const existingScore = typeof existing.score === 'number' && Number.isFinite(existing.score)\n850:     ? existing.score\n851:     : 0;\n852:   const incomingScore = typeof incoming.score === 'number' && Number.isFinite(incoming.score)\n853:     ? incoming.score\n854:     : 0;\n855:   const primary = incomingScore > existingScore ? incoming : existing;\n856:   const secondary = primary === incoming ? existing : incoming;\n857:   const sources = Array.from(new Set([\n858:     ...getCandidateSources(existing),\n859:     ...getCandidateSources(incoming),\n860:   ]));\n861:   const channelCount = sources.length;\n862:   const crossChannelBonus = Math.min(0.06, 0.02 * Math.max(0, channelCount - 1));\n863:   const mergedScore = Math.max(0, Math.min(1, Math.max(existingScore, incomingScore) + crossChannelBonus));\n864: \n865:   return {\n866:     ...(secondary ?? {}),\n867:     ...primary,\n868:     score: mergedScore,\n869:     source: typeof primary.source === 'string' ? primary.source : (sources[0] ?? 'hybrid'),\n870:     sources,\n871:     channelCount,\n872:     sourceScores: {\n873:       ...getCandidateSourceScores(existing),\n874:       ...getCandidateSourceScores(incoming),\n875:     },\n876:     channelAttribution: sources,\n877:   };\n878: }\n879: \n880: function collectCandidatesFromLists(\n881:   lists: RawChannelList[],\n882:   limit?: number\n883: ): HybridSearchResult[] {\n884:   const deduped = new Map<string, HybridSearchResult>();\n885: \n886:   for (const list of lists) {\n887:     if (!Array.isArray(list.results) || list.results.length === 0) continue;\n888: \n889:     const scored = list.results.map((result) => {\n890:       const rawScore = resolveRawCandidateScore(result as { score?: unknown; similarity?: unknown });\n891:       return { result, rawScore };\n892:     });\n893: \n894:     let min = Infinity;\n895:     let max = -Infinity;\n896:     for (const { rawScore } of scored) {\n897:       if (rawScore < min) min = rawScore;\n898:       if (rawScore > max) max = rawScore;\n899:     }\n900:     const range = max - min;\n901: \n902:     for (const { result, rawScore } of scored) {\n903:       const normalizedScore = range > 0 ? (rawScore - min) / range : (rawScore > 0 ? 1.0 : 0);\n904:       const candidate: HybridSearchResult = {\n905:         ...result,\n906:         id: result.id,\n907:         source: list.source,\n908:         score: normalizedScore,\n909:         sources: [list.source],\n910:         sourceScores: { [list.source]: normalizedScore },\n911:         channelAttribution: [list.source],\n912:       };\n913:       const key = canonicalResultId(candidate.id);\n914:       deduped.set(key, mergeRawCandidate(deduped.get(key), candidate));\n915:     }\n916:   }\n917: \n918:   return applyResultLimit(\n919:     Array.from(deduped.values()).sort((a, b) => {\n920:       const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n921:       const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n922:       return bScore - aScore;\n923:     }),\n924:     limit\n925:   );\n926: }\n927: \n928: function mergeRawCandidateSets(\n929:   existing: HybridSearchResult[],\n930:   incoming: HybridSearchResult[],\n931:   limit?: number\n932: ): HybridSearchResult[] {\n933:   const merged = new Map<string, HybridSearchResult>();\n934: \n935:   for (const result of [...existing, ...incoming]) {\n936:     const key = canonicalResultId(result.id);\n937:     merged.set(key, mergeRawCandidate(merged.get(key), result));\n938:   }\n939: \n940:   return applyResultLimit(\n941:     Array.from(merged.values()).sort((a, b) => {\n942:       const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n943:       const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n944:       return bScore - aScore;\n945:     }),\n946:     limit\n947:   );\n948: }\n949: \n950: function getAllowedChannels(options: HybridSearchOptions): Set<ChannelName> {\n951:   const allowed = new Set<ChannelName>(['vector', 'fts', 'graph', 'degree']);\n952: \n953:   if (isBm25Enabled()) {\n954:     allowed.add('bm25');\n955:   }\n956: \n957:   if (options.useVector === false) allowed.delete('vector');\n958:   if (options.useBm25 === false) allowed.delete('bm25');\n959:   if (options.useFts === false) allowed.delete('fts');\n960:   if (options.useGraph === false) {\n961:     allowed.delete('graph');\n962:     allowed.delete('degree');\n963:   }\n964: \n965:   return allowed;\n966: }\n967: \n968: function applyAllowedChannelOverrides(\n969:   options: HybridSearchOptions,\n970:   allowedChannels: Set<ChannelName>,\n971:   overrides: Partial<HybridSearchOptions> = {}\n972: ): HybridSearchOptions {\n973:   return {\n974:     ...options,\n975:     ...overrides,\n976:     useVector: allowedChannels.has('vector'),\n977:     useBm25: allowedChannels.has('bm25'),\n978:     useFts: allowedChannels.has('fts'),\n979:     useGraph: allowedChannels.has('graph'),\n980:   };\n981: }\n982: \n983: type FallbackPlanKind = 'adaptive' | 'tiered';\n984: type FallbackStageName = 'primary' | 'retry';\n985: \n986: interface FallbackPlanStage {\n987:   stage: FallbackStageName;\n988:   options: HybridSearchOptions;\n989:   results: HybridSearchResult[];\n990:   execution: HybridFusionExecution | null;\n991:   trigger?: 'empty' | DegradationTrigger;\n992: }\n993: \n994: interface FallbackPlanExecution {\n995:   allowedChannels: Set<ChannelName>;\n996:   stages: FallbackPlanStage[];\n997: }\n998: \n999: interface HybridFusionExecution {\n1000:   evaluationMode: boolean;\n1001:   intent: string;\n1002:   lists: Array<{\n1003:     source: string;\n1004:     results: Array<{ id: number | string; [key: string]: unknown }>;\n1005:     weight?: number;\n1006:   }>;\n1007:   routeResult: ReturnType<typeof routeQuery>;\n1008:   budgetResult: ReturnType<typeof getDynamicTokenBudget>;\n1009:   s3meta: Sprint3PipelineMeta;\n1010:   fusedResults: HybridSearchResult[];\n1011:   vectorEmbeddingCache: Map<number, Float32Array>;\n1012: }\n1013: \n1014: function resolveAdaptiveDocumentType(\n1015:   lists: Array<{ results: Array<Record<string, unknown>> }>,\n1016: ): string | undefined {\n1017:   const counts = new Map<string, number>();\n1018:   for (const list of lists) {\n1019:     for (const result of list.results.slice(0, 3)) {\n1020:       const candidate = result.documentType ?? result.document_type;\n1021:       if (typeof candidate !== 'string' || candidate.length === 0) {\n1022:         continue;\n1023:       }\n1024:       counts.set(candidate, (counts.get(candidate) ?? 0) + 1);\n1025:     }\n1026:   }\n1027: \n1028:   let topType: string | undefined;\n1029:   let topCount = 0;\n1030:   for (const [documentType, count] of counts) {\n1031:     if (count > topCount) {\n1032:       topType = documentType;\n1033:       topCount = count;\n1034:     }\n1035:   }\n1036: \n1037:   return topType;\n1038: }\n1039: \n1040: function markFallbackRetry(results: HybridSearchResult[]): HybridSearchResult[] {\n1041:   for (const result of results) {\n1042:     (result as Record<string, unknown>).fallbackRetry = true;\n1043:   }\n1044: \n1045:   return results;\n1046: }\n1047: \n1048: function toEmbeddingBufferView(value: unknown): Float32Array | null {\n1049:   if (value instanceof Float32Array) {\n1050:     return value;\n1051:   }\n1052: \n1053:   if (Array.isArray(value)) {\n1054:     const asNumbers = value.every((entry) => typeof entry === 'number' && Number.isFinite(entry));\n1055:     return asNumbers ? new Float32Array(value) : null;\n1056:   }\n1057: \n1058:   if (Buffer.isBuffer(value)) {\n1059:     return new Float32Array(value.buffer, value.byteOffset, value.byteLength / 4);\n1060:   }\n1061: \n1062:   return null;\n1063: }\n1064: \n1065: async function executeFallbackPlan(\n1066:   query: string,\n1067:   embedding: Float32Array | number[] | null,\n1068:   options: HybridSearchOptions = {},\n1069:   planKind: FallbackPlanKind,\n1070:   overrides: Partial<HybridSearchOptions> = {}\n1071: ): Promise<FallbackPlanExecution> {\n1072:   const allowedChannels = getAllowedChannels(options);\n1073:   const stages: FallbackPlanStage[] = [];\n1074: \n1075:   const primaryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1076:     minSimilarity: options.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY,\n1077:     ...overrides,\n1078:   });\n1079:   const primaryExecution = await collectAndFuseHybridResults(query, embedding, primaryOptions);\n1080:   const primaryResults = primaryExecution\n1081:     ? applyResultLimit(primaryExecution.fusedResults, primaryOptions.limit)\n1082:     : await hybridSearch(query, embedding, primaryOptions);\n1083:   stages.push({\n1084:     stage: 'primary',\n1085:     options: primaryOptions,\n1086:     results: primaryResults,\n1087:     execution: primaryExecution,\n1088:   });\n1089: \n1090:   if (planKind === 'tiered') {\n1091:     const trigger = checkDegradation(primaryResults);\n1092:     if (!trigger) {\n1093:       return { allowedChannels, stages };\n1094:     }\n1095: \n1096:     const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1097:       ...overrides,\n1098:       minSimilarity: TIERED_FALLBACK_MIN_SIMILARITY,\n1099:       forceAllChannels: true,\n1100:     });\n1101:     const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n1102:     const retryResults = retryExecution\n1103:       ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n1104:       : await hybridSearch(query, embedding, retryOptions);\n1105:     stages.push({\n1106:       stage: 'retry',\n1107:       options: retryOptions,\n1108:       results: retryResults,\n1109:       execution: retryExecution,\n1110:       trigger,\n1111:     });\n1112:     return { allowedChannels, stages };\n1113:   }\n1114: \n1115:   const primaryMinSimilarity = primaryOptions.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY;\n1116:   if (primaryResults.length === 0 && primaryMinSimilarity >= SECONDARY_FALLBACK_MIN_SIMILARITY) {\n1117:     const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n1118:       ...overrides,\n1119:       minSimilarity: SECONDARY_FALLBACK_MIN_SIMILARITY,\n1120:     });\n1121:     const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n1122:     const retryResultsBase = retryExecution\n1123:       ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n1124:       : await hybridSearch(query, embedding, retryOptions);\n1125:     const retryResults = retryResultsBase.length > 0\n1126:       ? markFallbackRetry(retryResultsBase)\n1127:       : retryResultsBase;\n1128:     stages.push({\n1129:       stage: 'retry',\n1130:       options: retryOptions,\n1131:       results: retryResults,\n1132:       execution: retryExecution,\n1133:       trigger: 'empty',\n1134:     });\n1135:   }\n1136: \n1137:   return { allowedChannels, stages };\n1138: }\n1139: \n1140: // 11. HYBRID SEARCH\n1141: \n1142: /**\n1143:  * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n1144:  * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n1145:  * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n1146:  * Retained as internal fallback only.\n1147:  */\n1148: async function hybridSearch(\n1149:   query: string,\n1150:   embedding: Float32Array | number[] | null,\n1151:   options: HybridSearchOptions = {}\n1152: ): Promise<HybridSearchResult[]> {\n1153:   const {\n1154:     limit = DEFAULT_LIMIT,\n1155:     specFolder,\n1156:     minSimilarity = 0,\n1157:     useBm25 = isBm25Enabled(),\n1158:     useFts = true,\n1159:     useVector = true,\n1160:     useGraph = true,\n1161:     includeArchived = false,\n1162:   } = options;\n1163: \n1164:   const results: HybridSearchResult[] = [];\n1165: \n1166:   // Vector search\n1167:   if (useVector && embedding && vectorSearchFn) {\n1168:     try {\n1169:       const vectorResults = vectorSearchFn(embedding, {\n1170:         limit,\n1171:         specFolder,\n1172:         minSimilarity,\n1173:         includeConstitutional: false, // Handler manages constitutional separately\n1174:         includeArchived,\n1175:       });\n1176:       for (const r of vectorResults) {\n1177:         results.push({\n1178:           ...r,\n1179:           id: r.id as number,\n1180:           score: (r.similarity as number) || 0,\n1181:           source: 'vector',\n1182:         });\n1183:       }\n1184:     } catch (error: unknown) {\n1185:       const msg = error instanceof Error ? error.message : String(error);\n1186:       console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n1187:     }\n1188:   }\n1189: \n1190:   // FTS search\n1191:   if (useFts) {\n1192:     const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n1193:     results.push(...ftsResults);\n1194:   }\n1195: \n1196:   // BM25 search\n1197:   if (useBm25) {\n1198:     const bm25Results = bm25Search(query, { limit, specFolder });\n1199:     results.push(...bm25Results);\n1200:   }\n1201: \n1202:   // Graph search\n1203:   if (useGraph && graphSearchFn) {\n1204:     try {\n1205:       graphMetrics.totalQueries++;\n1206:       const graphResults = graphSearchFn(query, { limit, specFolder });\n1207:       for (const r of graphResults) {\n1208:         results.push({\n1209:           ...r,\n1210:           id: r.id as number | string,\n1211:           score: (r.score as number) || 0,\n1212:           source: 'graph',\n1213:         });\n1214:       }\n1215:       if (graphResults.length > 0) {\n1216:         graphMetrics.graphHits++;\n1217:         graphMetrics.graphResultCount += graphResults.length;\n1218:       }\n1219:     } catch (error: unknown) {\n1220:       const msg = error instanceof Error ? error.message : String(error);\n1221:       console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n1222:     }\n1223:   }\n1224: \n1225:   // Normalize scores per source before merging so one method's raw scale\n1226:   // Does not dominate others during final ranking.\n1227:   const bySource = new Map<string, HybridSearchResult[]>();\n1228:   for (const r of results) {\n1229:     const src = r.source || 'unknown';\n1230:     if (!bySource.has(src)) bySource.set(src, []);\n1231:     bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n1232:   }\n1233: \n1234:   const normalized: HybridSearchResult[] = [];\n1235:   for (const [, group] of bySource) {\n1236:     if (group.length === 0) continue;\n1237:     const scores = group.map(r => r.score);\n1238:     let min = Infinity;\n1239:     let max = -Infinity;\n1240:     for (const s of scores) {\n1241:       if (s < min) min = s;\n1242:       if (s > max) max = s;\n1243:     }\n1244:     const range = max - min;\n1245:     for (const r of group) {\n1246:       normalized.push({\n1247:         ...r,\n1248:         score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n1249:       });\n1250:     }\n1251:   }\n1252: \n1253:   // Deduplicate by ID (keep highest normalized score)\n1254:   // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n1255:   // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n1256:   // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n1257:   // Field and downstream consumers would need to be updated accordingly.\n1258:   const deduped = new Map<string, HybridSearchResult>();\n1259:   for (const r of normalized) {\n1260:     const canonicalId = canonicalResultId(r.id);\n1261:     const existing = deduped.get(canonicalId);\n1262:     if (!existing || r.score > existing.score) {\n1263:       deduped.set(canonicalId, r);\n1264:     }\n1265:   }\n1266: \n1267:   return Array.from(deduped.values())\n1268:     .sort((a, b) => b.score - a.score)\n1269:     .slice(0, limit);\n1270: }\n1271: \n1272: /**\n1273:  * Enhanced hybrid search with RRF fusion.\n1274:  * All search channels use synchronous better-sqlite3; sequential execution\n1275:  * is correct — Promise.all would add overhead without achieving parallelism.\n1276:  */\n1277: async function hybridSearchEnhanced(\n1278:   query: string,\n1279:   embedding: Float32Array | number[] | null,\n1280:   options: HybridSearchOptions = {}\n1281: ): Promise<HybridSearchResult[]> {\n1282:   const execution = await collectAndFuseHybridResults(query, embedding, options);\n1283:   if (execution) {\n1284:     if (options.stopAfterFusion) {\n1285:       return applyResultLimit(execution.fusedResults, options.limit);\n1286:     }\n1287: \n1288:     return enrichFusedResults(query, execution, options);\n1289:   }\n1290: \n1291:   return hybridSearch(query, embedding, options);\n1292: }\n1293: \n1294: async function collectAndFuseHybridResults(\n1295:   query: string,\n1296:   embedding: Float32Array | number[] | null,\n1297:   options: HybridSearchOptions = {}\n1298: ): Promise<HybridFusionExecution | null> {\n1299:   try {\n1300:     const evaluationMode = options.evaluationMode === true;\n1301:     const lists: HybridFusionExecution['lists'] = [];\n1302: \n1303:     // Pipeline metadata collector (populated by flag-gated stages)\n1304:     const s3meta: Sprint3PipelineMeta = {};\n1305: \n1306:     // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n1307:     // When enabled, classifies query complexity and restricts channels to a\n1308:     // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n1309:     const routeResult = routeQuery(query, options.triggerPhrases);\n1310:     const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n1311:     const activeChannels = options.forceAllChannels\n1312:       ? new Set<ChannelName>(allPossibleChannels)\n1313:       : new Set<ChannelName>(routeResult.channels);\n1314: \n1315:     // Respect explicit caller channel disables across both the primary route and\n1316:     // every fallback tier. useGraph=false also disables the dependent degree lane.\n1317:     const allowedChannels = getAllowedChannels(options);\n1318:     for (const channel of allPossibleChannels) {\n1319:       if (!allowedChannels.has(channel)) activeChannels.delete(channel);\n1320:     }\n1321: \n1322:     const skippedChannels = allPossibleChannels.filter(ch => !activeChannels.has(ch));\n1323: \n1324:     if (skippedChannels.length > 0) {\n1325:       s3meta.routing = {\n1326:         tier: routeResult.tier,\n1327:         channels: routeResult.channels,\n1328:         skippedChannels,\n1329:         featureFlagEnabled: isComplexityRouterEnabled(),\n1330:         confidence: routeResult.classification.confidence,\n1331:         features: routeResult.classification.features as Record<string, unknown>,\n1332:       };\n1333:     }\n1334: \n1335:     // -- Stage E: Dynamic Token Budget (SPECKIT_DYNAMIC_TOKEN_BUDGET) --\n1336:     // Compute tier-aware budget early so it's available for downstream truncation.\n1337:     // When disabled, getDynamicTokenBudget returns the default 4000 budget with applied=false.\n1338:     // Weak / low-confidence queries keep the full budget so recall is not trimmed away.\n1339:     const lowSignalQuery =\n1340:       routeResult.classification.confidence === 'low' ||\n1341:       routeResult.classification.confidence === 'fallback';\n1342:     const budgetResult = getDynamicTokenBudget(routeResult.tier, undefined, {\n1343:       lowSignal: lowSignalQuery,\n1344:     });\n1345:     if (budgetResult.applied && !evaluationMode) {\n1346:       s3meta.tokenBudget = {\n1347:         tier: budgetResult.tier,\n1348:         budget: budgetResult.budget,\n1349:         applied: budgetResult.applied,\n1350:         featureFlagEnabled: isDynamicTokenBudgetEnabled(),\n1351:         configValues: DEFAULT_TOKEN_BUDGET_CONFIG as unknown as Record<string, number>,\n1352:         // headerOverhead and adjustedBudget are patched in below after they are computed\n1353:         headerOverhead: 0,\n1354:         adjustedBudget: budgetResult.budget,\n1355:       };\n1356:     }\n1357: \n1358:     // Channel results collected independently, merged after all complete\n1359:     let semanticResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [];\n1360:     let ftsChannelResults: HybridSearchResult[] = [];\n1361:     let bm25ChannelResults: HybridSearchResult[] = [];\n1362:     let triggerChannelResults: HybridSearchResult[] = [];\n1363:     const vectorEmbeddingCache = new Map<number, Float32Array>();\n1364: \n1365:     // All channels use synchronous better-sqlite3; sequential execution\n1366:     // Is correct — Promise.all adds overhead without parallelism.\n1367: \n1368:     // Vector channel — gated by query-complexity routing\n1369:     if (activeChannels.has('vector') && embedding && vectorSearchFn) {\n1370:       try {\n1371:         const vectorResults = vectorSearchFn(embedding, {\n1372:           limit: options.limit || DEFAULT_LIMIT,\n1373:           specFolder: options.specFolder,\n1374:           minSimilarity: options.minSimilarity || 0,\n1375:           includeConstitutional: false,\n1376:           includeArchived: options.includeArchived || false,\n1377:           includeEmbeddings: true,\n1378:         });\n1379:         semanticResults = vectorResults.map((r: Record<string, unknown>): { id: number | string; source: string; [key: string]: unknown } => ({\n1380:           ...r,\n1381:           id: r.id as number | string,\n1382:           source: 'vector',\n1383:         }));\n1384:         for (const result of semanticResults) {\n1385:           if (typeof result.id !== 'number') continue;\n1386:           const embeddingCandidate = toEmbeddingBufferView(\n1387:             (result as Record<string, unknown>).embedding\n1388:             ?? (result as Record<string, unknown>).embeddingBuffer\n1389:           );\n1390:           if (embeddingCandidate) {\n1391:             vectorEmbeddingCache.set(result.id, embeddingCandidate);\n1392:           }\n1393:         }\n1394:         lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n1395:       } catch (_err: unknown) {\n1396:         // Non-critical — vector channel failure does not block pipeline\n1397:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1398:       }\n1399:     }\n1400: \n1401:     // FTS channel (internal error handling in ftsSearch) — gated by query-complexity routing\n1402:     if (activeChannels.has('fts')) {\n1403:       ftsChannelResults = ftsSearch(query, options);\n1404:       if (ftsChannelResults.length > 0) {\n1405:         // FTS weight reduced to 0.3 after ablation showed 0.8 was harmful,\n1406:         // flooding top-K with noisy lexical matches despite its exact-match value.\n1407:         lists.push({ source: 'fts', results: ftsChannelResults, weight: 0.3 });\n1408:       }\n1409:     }\n1410: \n1411:     // BM25 channel (internal error handling in bm25Search) — gated by query-complexity routing\n1412:     if (activeChannels.has('bm25')) {\n1413:       bm25ChannelResults = bm25Search(query, options);\n1414:       if (bm25ChannelResults.length > 0) {\n1415:         // BM25 weight 0.6 is lowest lexical channel — in-memory BM25 index\n1416:         // Has less precise scoring than SQLite FTS5 BM25; kept for coverage breadth.\n1417:         lists.push({ source: 'bm25', results: bm25ChannelResults, weight: 0.6 });\n1418:       }\n1419:     }\n1420: \n1421:     triggerChannelResults = exactTriggerSearch(query, options);\n1422:     if (triggerChannelResults.length > 0) {\n1423:       lists.push({ source: 'trigger', results: triggerChannelResults, weight: 1.4 });\n1424:     }\n1425: \n1426:     // Graph channel — gated by query-complexity routing\n1427:     const useGraph = (options.useGraph !== false) && activeChannels.has('graph');\n1428:     if (useGraph && graphSearchFn) {\n1429:       try {\n1430:         graphMetrics.totalQueries++; // counted only if channel executes\n1431:         const graphResults = graphSearchFn(query, {\n1432:           limit: options.limit || DEFAULT_LIMIT,\n1433:           specFolder: options.specFolder,\n1434:           intent: options.intent,\n1435:         });\n1436:         if (graphResults.length > 0) {\n1437:           graphMetrics.graphHits++;\n1438:           graphMetrics.graphResultCount += graphResults.length;\n1439:           lists.push({ source: 'graph', results: graphResults.map((r: Record<string, unknown>) => ({\n1440:             ...r,\n1441:             id: r.id as number | string,\n1442:           })), weight: 0.5 });\n1443:         }\n1444:       } catch (_err: unknown) {\n1445:         // Non-critical — graph channel failure does not block pipeline\n\n(Output capped at 50 KB. Showing lines 1-1445. Use offset=1446 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Hybrid Search\n// ───────────────────────────────────────────────────────────────\n// Combines vector, FTS, and BM25 search with fallback\n\n// 1. IMPORTS\n\n// Local\nimport {\n  getIndex,\n  isBm25Enabled,\n  shouldUseSqliteLexicalEngine,\n} from './bm25-index.js';\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\nimport { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\nimport { fts5Bm25Search } from './sqlite-fts.js';\nimport { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Hybrid Search\n// ───────────────────────────────────────────────────────────────\n// Combines vector, FTS, and BM25 search with fallback\n\n// 1. IMPORTS\n\n// Local\nimport {\n  getIndex,\n  isBm25Enabled,\n  shouldUseSqliteLexicalEngine,\n} from './bm25-index.js';\nimport { fuseResultsMulti } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport { adaptiveFuse, getAdaptiveWeights, isAdaptiveFusionEnabled } from '@spec-kit/shared/algorithms/adaptive-fusion';\nimport { CO_ACTIVATION_CONFIG, spreadActivation } from '../cognitive/co-activation.js';\nimport { applyMMR } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport { INTENT_LAMBDA_MAP, classifyIntent } from './intent-classifier.js';\nimport { fts5Bm25Search } from './sqlite-fts.js';\nimport { DEGREE_CHANNEL_WEIGHT } from './graph-search-fn.js';\nimport {\n  isMMREnabled,\n  isSearchFallbackEnabled,\n  isDocscoreAggregationEnabled,\n  isDegreeBoostEnabled,\n  isContextHeadersEnabled,\n  isArchivedRetrievalIncludedByDefault,\n  isCosineTopnReorderEnabled,\n} from './search-flags.js';\nimport { resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\nimport { computeDegreeScores } from './graph-search-fn.js';\nimport type { GraphSearchFn } from './search-types.js';\n\n// Feature catalog: Hybrid search pipeline\n\nexport type { GraphSearchFn } from './search-types.js';\n\nimport { routeQuery } from './query-router.js';\nimport { isComplexityRouterEnabled } from './query-classifier.js';\nimport { enforceChannelRepresentation } from './channel-enforcement.js';\nimport {\n  truncateByConfidence,\n  isConfidenceTruncationEnabled,\n  DEFAULT_MIN_RESULTS,\n  GAP_THRESHOLD_MULTIPLIER,\n} from './confidence-truncation.js';\nimport {\n  getDynamicTokenBudget,\n  isDynamicTokenBudgetEnabled,\n  DEFAULT_TOKEN_BUDGET_CONFIG,\n} from './dynamic-token-budget.js';\nimport {\n  buildProgressiveResponse,\n  DEFAULT_PAGE_SIZE,\n} from './progressive-disclosure.js';\nimport type {\n  ProgressiveResponse,\n  DisclosureResult,\n} from './progressive-disclosure.js';\nimport { resolveFusionIntentContract } from './search-utils.js';\nimport { ensureDescriptionCache, getSpecsBasePaths } from './folder-discovery.js';\nimport {\n  isFolderScoringEnabled,\n  lookupFolders,\n  computeFolderRelevanceScores,\n  enrichResultsWithFolderScores,\n  twoPhaseRetrieval,\n} from './folder-relevance.js';\nimport { parse_trigger_phrases, specFolderLikePattern } from './vector-index-types.js';\n\nimport { collapseAndReassembleChunkResults } from '../scoring/mpab-aggregation.js';\n\n// Type-only\nimport type Database from 'better-sqlite3';\nimport type { SpreadResult } from '../cognitive/co-activation.js';\nimport type { MMRCandidate } from '@spec-kit/shared/algorithms/mmr-reranker';\nimport type { FusionResult } from '@spec-kit/shared/algorithms/rrf-fusion';\nimport type { ChannelName } from './query-router.js';\nimport type { EnforcementResult } from './channel-enforcement.js';\nimport type { TruncationResult } from './confidence-truncation.js';\n\n// 2. INTERFACES\n\ntype VectorSearchFn = (\n  embedding: Float32Array | number[],\n  options: Record<string, unknown>\n) => Array<Record<string, unknown>>;\n\ninterface HybridSearchOptions {\n  limit?: number;\n  specFolder?: string;\n  minSimilarity?: number;\n  useBm25?: boolean;\n  useFts?: boolean;\n  useVector?: boolean;\n  useGraph?: boolean;\n  includeArchived?: boolean;\n  includeContent?: boolean;\n  /**\n   * Evaluation-only mode.\n   * When true, preserve the requested top-K window by bypassing confidence\n   * truncation and token-budget truncation without changing live defaults.\n   */\n  evaluationMode?: boolean;\n  /** Classified query intent for adaptive fusion weight selection (e.g. 'understand', 'fix_bug'). */\n  intent?: string;\n  /** Optional trigger phrases for query-classifier trigger-match routing path. */\n  triggerPhrases?: string[];\n  /**\n   * Internal fallback override: when true, bypass complexity routing and\n   * enable all retrieval channels for this search call.\n   */\n  forceAllChannels?: boolean;\n  /**\n   * Internal raw-candidate mode used by the Stage 1 pipeline.\n   * When true, stop after channel collection and return pre-fusion candidates.\n   */\n  skipFusion?: boolean;\n  /**\n   * Internal pipeline handoff mode.\n   * When true, return immediately after adaptive/RRF fusion so Stage 2/3 can\n   * apply the remaining pipeline scoring and aggregation steps.\n   */\n  stopAfterFusion?: boolean;\n}\n\ninterface HybridSearchResult {\n  id: number | string;\n  /**\n   * Normalized relevance score (0-1). Semantics depend on `source`:\n   * - `'vector'` — cosine similarity from sqlite-vec (normalized from 0-100 to 0-1)\n   * - `'bm25'` — BM25 term-frequency relevance (min-max normalized per source group)\n   * - `'fts'` — FTS5 rank score (absolute value, min-max normalized per source group)\n   * - `'graph'` — graph traversal relevance\n   *\n   * After hybrid merge, all source scores are min-max normalized to 0-1 within\n   * their source group to ensure fair cross-method comparison.\n   */\n  score: number;\n  source: string;\n  title?: string;\n  [key: string]: unknown;\n}\n\ntype HardExclusionSource = 'archived-tier' | 'deprecated-tier';\ntype HardExclusionClassification = 'intended' | 'silent-risk' | 'unclassified';\n\ninterface HardExclusionPredicate {\n  id: string;\n  source: HardExclusionSource;\n  channel: string;\n  predicate: string;\n  defaultApplied: boolean;\n  classification: HardExclusionClassification;\n}\n\nconst HARD_EXCLUSION_PREDICATES: readonly HardExclusionPredicate[] = Object.freeze([\n  {\n    id: 'includeArchived-default',\n    source: 'archived-tier',\n    channel: 'vector/fts',\n    predicate: 'includeArchived defaults to false',\n    defaultApplied: true,\n    classification: 'intended',\n  },\n  {\n    id: 'fts-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'fts',\n    predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'bm25-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'bm25',\n    predicate: \"importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'trigger-deprecated-tier',\n    source: 'deprecated-tier',\n    channel: 'trigger',\n    predicate: \"m.importance_tier IS NULL OR m.importance_tier != 'deprecated'\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n  {\n    id: 'structural-deprecated-archived-tier',\n    source: 'deprecated-tier',\n    channel: 'structural',\n    predicate: \"importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived')\",\n    defaultApplied: true,\n    classification: 'silent-risk',\n  },\n]);\n\n/** Return recall-path exclusion metadata without executing or changing search. */\nfunction getHardExclusionPredicates(): HardExclusionPredicate[] {\n  return HARD_EXCLUSION_PREDICATES.map((predicate) => ({ ...predicate }));\n}\n\ntype Bm25MemoryMetadata = {\n  specFolder: string | null;\n  importanceTier: string | null;\n};\n\n/** Non-enumerable shadow metadata attached to result arrays via Object.defineProperty. */\ninterface ShadowMetaArray {\n  _s4shadow?: unknown;\n  _s4attribution?: unknown;\n  _degradation?: unknown;\n}\n\n/** Normalize a fused RRF result to the HybridSearchResult contract. */\nfunction toHybridResult(result: FusionResult): HybridSearchResult {\n  const sourceCandidate = (result as { source?: unknown }).source;\n  const primarySource = result.sources[0] ?? 'hybrid';\n  const scoreCandidate = (result as { score?: unknown }).score;\n\n  return {\n    ...result,\n    id: result.id,\n    score: typeof scoreCandidate === 'number' ? scoreCandidate : result.rrfScore,\n    source: typeof sourceCandidate === 'string' ? sourceCandidate : primarySource,\n  };\n}\n\n// PIPELINE METADATA\n\n/**\n * Optional metadata about pipeline stages attached to enhanced search results.\n * Only populated when the corresponding feature flags are enabled.\n */\ninterface Sprint3PipelineMeta {\n  /** Query complexity routing result (SPECKIT_COMPLEXITY_ROUTER). */\n  routing?: {\n    tier: string;\n    channels: string[];\n    skippedChannels: string[];\n    featureFlagEnabled: boolean;\n    confidence: string;\n    features: Record<string, unknown>;\n  };\n  /** Channel enforcement result (SPECKIT_CHANNEL_MIN_REP). */\n  enforcement?: { applied: boolean; promotedCount: number; underRepresentedChannels: string[] };\n  /** Confidence truncation result (SPECKIT_CONFIDENCE_TRUNCATION). */\n  truncation?: {\n    truncated: boolean;\n    originalCount: number;\n    truncatedCount: number;\n    medianGap: number;\n    cutoffGap: number;\n    cutoffIndex: number;\n    thresholdMultiplier: number;\n    minResultsGuaranteed: number;\n    featureFlagEnabled: boolean;\n  };\n  /** Dynamic token budget result (SPECKIT_DYNAMIC_TOKEN_BUDGET). */\n  tokenBudget?: {\n    tier: string;\n    budget: number;\n    applied: boolean;\n    featureFlagEnabled: boolean;\n    configValues: Record<string, number>;\n    headerOverhead: number;\n    adjustedBudget: number;\n  };\n}\n\n// 4. PI-A2: DEGRADATION TYPES\n\n/** Fallback tier in the 3-tier degradation chain. */\ntype FallbackTier = 1 | 2 | 3;\n\n/** Why degradation was triggered at a given tier. */\ninterface DegradationTrigger {\n  reason: 'low_quality' | 'insufficient_results' | 'both';\n  topScore: number;\n  resultCount: number;\n  relativeGap?: number;\n}\n\n/** Record of a single degradation event during tiered fallback. */\ninterface DegradationEvent {\n  tier: FallbackTier;\n  trigger: DegradationTrigger;\n  resultCountBefore: number;\n  resultCountAfter: number;\n}\n\n/**\n * Absolute quality floor for degradation checks.\n *\n * Raw RRF scores are typically small decimals (often <0.05), so a\n * high fixed threshold causes false degradations. Use a conservative floor and\n * pair it with a relative-gap check to avoid score-scale coupling.\n */\nconst DEGRADATION_QUALITY_THRESHOLD = 0.02;\n\n/** Minimum relative separation between top-1 and top-2 scores. */\nconst DEGRADATION_MIN_RELATIVE_GAP = 0.2;\n\n/** Minimum result count: must have >= this many results to stay at current tier. */\nconst DEGRADATION_MIN_RESULTS = 3;\n\n// 5. MODULE STATE\n\n/** Default result limit when none is specified by the caller. */\nconst DEFAULT_LIMIT = 20;\n/** Primary vector similarity floor for hybrid fallback passes (percentage units). */\nconst PRIMARY_FALLBACK_MIN_SIMILARITY = 30;\n/** Secondary vector similarity floor for adaptive retry passes (percentage units). */\nconst SECONDARY_FALLBACK_MIN_SIMILARITY = 17;\n/** Tier-2 vector similarity floor for quality-aware fallback (percentage units). */\nconst TIERED_FALLBACK_MIN_SIMILARITY = 10;\n\n/** Minimum MMR candidates required for diversity reranking to be worthwhile. */\nconst MMR_MIN_CANDIDATES = 2;\n\n/** Fallback lambda (diversity vs relevance) when intent is not in INTENT_LAMBDA_MAP. */\nconst MMR_DEFAULT_LAMBDA = 0.7;\n\n/** Number of top results used as seeds for co-activation spreading. */\nconst SPREAD_ACTIVATION_TOP_N = 5;\n\n/** Maximum contextual tree header length prepended to content (including brackets). */\nconst CONTEXT_HEADER_MAX_CHARS = 100;\n/** Header/content separator characters added during contextual tree injection. */\nconst CONTEXT_HEADER_SEPARATOR_CHARS = 1;\n/** Reserved token overhead per contextual header, calibrated to max header length. */\nconst CONTEXT_HEADER_TOKEN_OVERHEAD = Math.ceil(\n  (CONTEXT_HEADER_MAX_CHARS + CONTEXT_HEADER_SEPARATOR_CHARS) / 4\n);\n\nlet db: Database.Database | null = null;\nlet vectorSearchFn: VectorSearchFn | null = null;\nlet graphSearchFn: GraphSearchFn | null = null;\nlet enrichFusedResultsObserver: (() => void) | null = null;\n\n// 6. GRAPH CHANNEL METRICS\n\ninterface GraphChannelMetrics {\n  totalQueries: number;\n  graphHits: number;\n  graphResultCount: number;\n  graphOnlyResults: number;\n  graphMultiSourceResults: number;\n  multiSourceResults: number;\n  degreeQueries: number;\n  degreeHits: number;\n  degreeResultCount: number;\n}\n\nconst graphMetrics: GraphChannelMetrics = {\n  totalQueries: 0,\n  graphHits: 0,\n  graphResultCount: 0,\n  graphOnlyResults: 0,\n  graphMultiSourceResults: 0,\n  multiSourceResults: 0,\n  degreeQueries: 0,\n  degreeHits: 0,\n  degreeResultCount: 0,\n};\n\n/**\n * Return current graph channel metrics for health check reporting.\n * graphHitRate is computed as graphHits / totalQueries.\n */\nfunction getGraphMetrics(): GraphChannelMetrics & { graphHitRate: number; degreeHitRate: number } {\n  return {\n    ...graphMetrics,\n    graphHitRate: graphMetrics.totalQueries > 0\n      ? graphMetrics.graphHits / graphMetrics.totalQueries\n      : 0,\n    degreeHitRate: graphMetrics.degreeQueries > 0\n      ? graphMetrics.degreeHits / graphMetrics.degreeQueries\n      : 0,\n  };\n}\n\n/** Reset all graph channel metrics counters to zero. */\nfunction resetGraphMetrics(): void {\n  graphMetrics.totalQueries = 0;\n  graphMetrics.graphHits = 0;\n  graphMetrics.graphResultCount = 0;\n  graphMetrics.graphOnlyResults = 0;\n  graphMetrics.graphMultiSourceResults = 0;\n  graphMetrics.multiSourceResults = 0;\n  graphMetrics.degreeQueries = 0;\n  graphMetrics.degreeHits = 0;\n  graphMetrics.degreeResultCount = 0;\n}\n\n// 7. INITIALIZATION\n\n/**\n * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n * @param database - The better-sqlite3 database instance for FTS and graph queries.\n * @param vectorFn - Optional vector search function for semantic similarity.\n * @param graphFn - Optional graph search function for causal/structural retrieval.\n */\nfunction init(\n  database: Database.Database,\n  vectorFn: VectorSearchFn | null = null,\n  graphFn: GraphSearchFn | null = null\n): void {\n  db = database;\n  vectorSearchFn = vectorFn;\n  graphSearchFn = graphFn;\n}\n\n// 8. BM25 SEARCH\n\n/**\n * Search the BM25 index with optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit and specFolder filter.\n * @returns Array of BM25-scored results tagged with source 'bm25'.\n */\nfunction bm25Search(\n  query: string,\n  options: { limit?: number; specFolder?: string } = {}\n): HybridSearchResult[] {\n  if (!isBm25Enabled()) {\n    console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n    return [];\n  }\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n\n  try {\n    if (shouldUseSqliteLexicalEngine(db)) {\n      return ftsSearch(query, {\n        limit,\n        specFolder,\n      }).map((result) => ({\n        ...result,\n        bm25_score: result.score,\n        source: 'bm25',\n        sources: Array.from(new Set([\n          ...(\n            Array.isArray((result as Record<string, unknown>).sources)\n              ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n              : []\n          ),\n          'fts',\n          'bm25',\n        ])),\n      }));\n    }\n\n    // Spec-folder scope can only be resolved from DB metadata; fail closed before\n    // searching when the DB is unavailable rather than over-fetching the whole\n    // corpus and then discarding it.\n    if (specFolder && !db) {\n      console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n      return [];\n    }\n\n    const index = getIndex();\n    const candidateLimit = (specFolder || db)\n      ? index.getStats().documentCount\n      : limit;\n    // Metadata filters run after in-memory scoring, so fetch the corpus-bounded\n    // candidate set whenever those filters can remove otherwise top-ranked hits.\n    const results = index.search(query, candidateLimit);\n\n    // BM25 document IDs are stringified\n    // Numeric memory IDs (e.g., \"42\"), not spec folder paths. The old filter compared\n    // R.id against specFolder which never matched. Use DB lookup to resolve spec_folder.\n\n    // Batch-resolve metadata for all result IDs (was N+1 individual queries)\n    // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n    // resolution returns [] rather than leaking unscoped BM25 candidates.\n    let memoryMetadataMap: Map<number, Bm25MemoryMetadata> | null = null;\n    if (results.length > 0) {\n      if (!db) {\n        if (specFolder) {\n          const error = new Error('Database unavailable for spec-folder scope lookup');\n          console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n          return [];\n        }\n      } else {\n        try {\n          const ids = results.map((r: { id: string }) => Number(r.id));\n          memoryMetadataMap = new Map();\n          // Resolve metadata in bounded batches. The candidate set can now be\n          // corpus-sized (over-fetch for scope/tier filtering), and a single\n          // IN (...) with one bind per id would exceed SQLite's parameter limit\n          // and throw — which the catch below turns into an empty result.\n          const METADATA_BATCH = 500;\n          for (let offset = 0; offset < ids.length; offset += METADATA_BATCH) {\n            const batch = ids.slice(offset, offset + METADATA_BATCH);\n            const placeholders = batch.map(() => '?').join(',');\n            const rows = db.prepare(\n              `SELECT id, spec_folder, importance_tier FROM memory_index WHERE id IN (${placeholders})`\n            ).all(...batch) as Array<{ id: number; spec_folder: string | null; importance_tier: string | null }>;\n            for (const row of rows) {\n              memoryMetadataMap.set(row.id, {\n                specFolder: row.spec_folder,\n                importanceTier: row.importance_tier,\n              });\n            }\n          }\n        } catch (error: unknown) {\n          console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n          return [];\n        }\n      }\n\n      // DEFENSE-IN-DEPTH: If specFolder was requested but metadata resolution\n      // is still null after the resolution block, something unexpected happened.\n      // Fail closed rather than falling through to unscoped results.\n      if (specFolder && !memoryMetadataMap) {\n        const error = new Error('memoryMetadataMap unexpectedly null after scope resolution');\n        console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n        return [];\n      }\n    }\n\n    const excludeCold = !isArchivedRetrievalIncludedByDefault();\n    return results\n      .filter((r: { id: string }) => {\n        const metadata = memoryMetadataMap?.get(Number(r.id));\n        // Cold/deprecated rows are included by default (FSRS ranks them lower);\n        // only drop them when archived retrieval is disabled.\n        if (excludeCold && metadata?.importanceTier === 'deprecated') return false;\n        if (!specFolder) return true;\n        if (!metadata) return false;\n        const folder = metadata.specFolder;\n        if (!folder) return false;\n        return folder === specFolder || folder.startsWith(specFolder + '/');\n      })\n      .slice(0, limit)\n      .map((r: { id: string; score: number }) => ({\n        ...r,\n        source: 'bm25',\n      }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] BM25 search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Check whether the BM25 index is populated and available for search.\n * @returns True if the BM25 index exists and contains at least one document.\n */\nfunction isBm25Available(): boolean {\n  if (!isBm25Enabled()) {\n    return false;\n  }\n\n  try {\n    const index = getIndex();\n    return index.getStats().documentCount > 0;\n  } catch (_err: unknown) {\n    // Swallow index-not-initialized errors; caller treats absence as unavailable\n    return false;\n  }\n}\n\n// 9. FTS SEARCH\n\n/**\n * Check whether the FTS5 full-text search table exists in the database.\n * @returns True if the memory_fts table exists in the connected database.\n */\nfunction isFtsAvailable(): boolean {\n  if (!db) {\n    console.warn('[hybrid-search] db not initialized — isFtsAvailable returning false');\n    return false;\n  }\n\n  try {\n    const result = (db.prepare(`\n      SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'\n    `) as Database.Statement).get() as { name: string } | undefined;\n    return !!result;\n  } catch (_err: unknown) {\n    // Swallow DB errors; caller treats absence as unavailable\n    return false;\n  }\n}\n\n/**\n * Run FTS5 full-text search with weighted BM25 scoring and optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Array of FTS-scored results tagged with source 'fts'.\n */\nfunction ftsSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db || !isFtsAvailable()) {\n    console.warn('[hybrid-search] db not initialized or FTS unavailable — returning empty ftsSearch results');\n    return [];\n  }\n\n  const { limit = DEFAULT_LIMIT, specFolder, includeArchived = false } = options;\n\n  try {\n    // Delegate to weighted BM25 FTS5 search from sqlite-fts.ts\n    // Uses bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) for per-column weighting\n    // (title 10x, trigger_phrases 5x, file_path 2x, content 1x)\n    // Filters: deprecated-tier exclusion and spec-folder matching handled by fts5Bm25Search\n    const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n\n    return bm25Results.map(row => ({\n      ...row,\n      id: row.id as number,\n      score: row.fts_score || 0,\n      source: 'fts',\n    }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] FTS search failed: ${msg}`);\n    return [];\n  }\n}\n\n// 10. COMBINED LEXICAL SEARCH\n\n/**\n * Merge FTS and BM25 search results, deduplicating by ID and preferring FTS scores.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Deduplicated array of merged results sorted by score descending.\n */\nfunction combinedLexicalSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  const ftsResults = ftsSearch(query, options);\n  const bm25Results = bm25Search(query, options);\n\n  // Merge by canonical ID, prefer FTS scores.\n  // CanonicalResultId() prevents duplicate rows when one channel emits\n  // Numeric IDs (42) and another emits string IDs (\"42\" or \"mem:42\").\n  const merged = new Map<string, HybridSearchResult>();\n\n  for (const r of ftsResults) {\n    merged.set(canonicalResultId(r.id), r);\n  }\n\n  for (const r of bm25Results) {\n    const canonicalId = canonicalResultId(r.id);\n    if (!merged.has(canonicalId)) {\n      merged.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(merged.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, options.limit || DEFAULT_LIMIT);\n}\n\nfunction normalizeTriggerText(value: string): string {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction triggerQueryTokens(query: string): string[] {\n  return Array.from(new Set(\n    normalizeTriggerText(query)\n      .split(/\\s+/)\n      .filter((token) => token.length >= 2)\n  ));\n}\n\nfunction computeTriggerMatchScore(query: string, phrase: string): number {\n  const normalizedQuery = normalizeTriggerText(query);\n  const normalizedPhrase = normalizeTriggerText(phrase);\n  if (!normalizedQuery || !normalizedPhrase) return 0;\n  if (normalizedPhrase === normalizedQuery) return 1.0;\n\n  const queryTokens = triggerQueryTokens(normalizedQuery);\n  const phraseTokens = new Set(triggerQueryTokens(normalizedPhrase));\n  if (phraseTokens.size < 2) return 0;\n  if (normalizedPhrase.includes(normalizedQuery)) return 0.94;\n  if (normalizedQuery.includes(normalizedPhrase)) return 0.88;\n  if (queryTokens.length === 0) return 0;\n  const overlap = queryTokens.filter((token) => phraseTokens.has(token)).length;\n  const coverage = overlap / queryTokens.length;\n  return coverage >= 0.8 ? coverage * 0.75 : 0;\n}\n\nfunction timestampBoost(value: unknown): number {\n  if (typeof value !== 'string' || value.length === 0) return 0;\n  const parsed = Date.parse(value);\n  if (!Number.isFinite(parsed)) return 0;\n  const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n  return 1 / (1 + ageDays / 30);\n}\n\nfunction exactTriggerSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db) return [];\n\n  const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n  if (tokens.length === 0) return [];\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n  const normalizedQuery = normalizeTriggerText(query);\n  const exactPhraseLike = `%${normalizedQuery}%`;\n  const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n  const conditions = [\n    `m.trigger_phrases IS NOT NULL`,\n    `m.trigger_phrases != ''`,\n    `m.trigger_phrases != '[]'`,\n    // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n    // them below hot memories); the hard exclusion only applies when archived\n    // retrieval is disabled.\n    ...(isArchivedRetrievalIncludedByDefault()\n      ? []\n      : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n    `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n    `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n  ];\n  const params: unknown[] = tokens.map((token) => `%${token}%`);\n\n  if (specFolder) {\n    conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  try {\n    const rows = db.prepare(`\n      SELECT m.*\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE ${conditions.join(' AND ')}\n      ORDER BY\n        CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n        COALESCE(m.updated_at, m.created_at, '') DESC\n      LIMIT ${candidateLimit}\n    `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n\n    return rows\n      .map((row): HybridSearchResult | null => {\n        const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n        const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n        if (matchScore <= 0) return null;\n\n        const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n          ? Math.max(0, Math.min(1, row.importance_weight))\n          : 0.5;\n        const recency = timestampBoost(row.updated_at ?? row.created_at);\n        const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n\n        return {\n          ...row,\n          id: row.id as number,\n          score,\n          triggerScore: matchScore,\n          source: 'trigger',\n        };\n      })\n      .filter((row): row is HybridSearchResult => row !== null)\n      .sort((a, b) => {\n        const scoreDelta = b.score - a.score;\n        if (scoreDelta !== 0) return scoreDelta;\n        const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n        const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n        return bTime - aTime;\n      })\n      .slice(0, limit);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n    return [];\n  }\n}\n\ntype RawChannelList = {\n  source: string;\n  results: Array<{ id: number | string; [key: string]: unknown }>;\n};\n\nfunction resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n  if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n    return result.score;\n  }\n  if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n    return result.similarity / 100;\n  }\n  return 0;\n}\n\nfunction getCandidateSources(result: HybridSearchResult): string[] {\n  const sourceList = (result as { sources?: unknown }).sources;\n  if (Array.isArray(sourceList)) {\n    return sourceList.filter((value): value is string => typeof value === 'string');\n  }\n  return typeof result.source === 'string' && result.source.length > 0\n    ? [result.source]\n    : [];\n}\n\nfunction getCandidateSourceScores(result: HybridSearchResult): Record<string, number> {\n  const sourceScores = (result as { sourceScores?: unknown }).sourceScores;\n  if (sourceScores && typeof sourceScores === 'object' && !Array.isArray(sourceScores)) {\n    const normalizedScores: Record<string, number> = {};\n    for (const [source, score] of Object.entries(sourceScores as Record<string, unknown>)) {\n      if (typeof score === 'number' && Number.isFinite(score)) {\n        normalizedScores[source] = score;\n      }\n    }\n    return normalizedScores;\n  }\n\n  const fallbackScores: Record<string, number> = {};\n  const resultScore = typeof result.score === 'number' && Number.isFinite(result.score)\n    ? result.score\n    : 0;\n  for (const source of getCandidateSources(result)) {\n    fallbackScores[source] = resultScore;\n  }\n  return fallbackScores;\n}\n\nfunction mergeRawCandidate(\n  existing: HybridSearchResult | undefined,\n  incoming: HybridSearchResult\n): HybridSearchResult {\n  if (!existing) {\n    const sources = getCandidateSources(incoming);\n    const channelCount = sources.length;\n    return {\n      ...incoming,\n      sources,\n      channelCount,\n      sourceScores: getCandidateSourceScores(incoming),\n      channelAttribution: sources,\n    };\n  }\n\n  const existingScore = typeof existing.score === 'number' && Number.isFinite(existing.score)\n    ? existing.score\n    : 0;\n  const incomingScore = typeof incoming.score === 'number' && Number.isFinite(incoming.score)\n    ? incoming.score\n    : 0;\n  const primary = incomingScore > existingScore ? incoming : existing;\n  const secondary = primary === incoming ? existing : incoming;\n  const sources = Array.from(new Set([\n    ...getCandidateSources(existing),\n    ...getCandidateSources(incoming),\n  ]));\n  const channelCount = sources.length;\n  const crossChannelBonus = Math.min(0.06, 0.02 * Math.max(0, channelCount - 1));\n  const mergedScore = Math.max(0, Math.min(1, Math.max(existingScore, incomingScore) + crossChannelBonus));\n\n  return {\n    ...(secondary ?? {}),\n    ...primary,\n    score: mergedScore,\n    source: typeof primary.source === 'string' ? primary.source : (sources[0] ?? 'hybrid'),\n    sources,\n    channelCount,\n    sourceScores: {\n      ...getCandidateSourceScores(existing),\n      ...getCandidateSourceScores(incoming),\n    },\n    channelAttribution: sources,\n  };\n}\n\nfunction collectCandidatesFromLists(\n  lists: RawChannelList[],\n  limit?: number\n): HybridSearchResult[] {\n  const deduped = new Map<string, HybridSearchResult>();\n\n  for (const list of lists) {\n    if (!Array.isArray(list.results) || list.results.length === 0) continue;\n\n    const scored = list.results.map((result) => {\n      const rawScore = resolveRawCandidateScore(result as { score?: unknown; similarity?: unknown });\n      return { result, rawScore };\n    });\n\n    let min = Infinity;\n    let max = -Infinity;\n    for (const { rawScore } of scored) {\n      if (rawScore < min) min = rawScore;\n      if (rawScore > max) max = rawScore;\n    }\n    const range = max - min;\n\n    for (const { result, rawScore } of scored) {\n      const normalizedScore = range > 0 ? (rawScore - min) / range : (rawScore > 0 ? 1.0 : 0);\n      const candidate: HybridSearchResult = {\n        ...result,\n        id: result.id,\n        source: list.source,\n        score: normalizedScore,\n        sources: [list.source],\n        sourceScores: { [list.source]: normalizedScore },\n        channelAttribution: [list.source],\n      };\n      const key = canonicalResultId(candidate.id);\n      deduped.set(key, mergeRawCandidate(deduped.get(key), candidate));\n    }\n  }\n\n  return applyResultLimit(\n    Array.from(deduped.values()).sort((a, b) => {\n      const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n      const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n      return bScore - aScore;\n    }),\n    limit\n  );\n}\n\nfunction mergeRawCandidateSets(\n  existing: HybridSearchResult[],\n  incoming: HybridSearchResult[],\n  limit?: number\n): HybridSearchResult[] {\n  const merged = new Map<string, HybridSearchResult>();\n\n  for (const result of [...existing, ...incoming]) {\n    const key = canonicalResultId(result.id);\n    merged.set(key, mergeRawCandidate(merged.get(key), result));\n  }\n\n  return applyResultLimit(\n    Array.from(merged.values()).sort((a, b) => {\n      const aScore = typeof a.score === 'number' && Number.isFinite(a.score) ? a.score : 0;\n      const bScore = typeof b.score === 'number' && Number.isFinite(b.score) ? b.score : 0;\n      return bScore - aScore;\n    }),\n    limit\n  );\n}\n\nfunction getAllowedChannels(options: HybridSearchOptions): Set<ChannelName> {\n  const allowed = new Set<ChannelName>(['vector', 'fts', 'graph', 'degree']);\n\n  if (isBm25Enabled()) {\n    allowed.add('bm25');\n  }\n\n  if (options.useVector === false) allowed.delete('vector');\n  if (options.useBm25 === false) allowed.delete('bm25');\n  if (options.useFts === false) allowed.delete('fts');\n  if (options.useGraph === false) {\n    allowed.delete('graph');\n    allowed.delete('degree');\n  }\n\n  return allowed;\n}\n\nfunction applyAllowedChannelOverrides(\n  options: HybridSearchOptions,\n  allowedChannels: Set<ChannelName>,\n  overrides: Partial<HybridSearchOptions> = {}\n): HybridSearchOptions {\n  return {\n    ...options,\n    ...overrides,\n    useVector: allowedChannels.has('vector'),\n    useBm25: allowedChannels.has('bm25'),\n    useFts: allowedChannels.has('fts'),\n    useGraph: allowedChannels.has('graph'),\n  };\n}\n\ntype FallbackPlanKind = 'adaptive' | 'tiered';\ntype FallbackStageName = 'primary' | 'retry';\n\ninterface FallbackPlanStage {\n  stage: FallbackStageName;\n  options: HybridSearchOptions;\n  results: HybridSearchResult[];\n  execution: HybridFusionExecution | null;\n  trigger?: 'empty' | DegradationTrigger;\n}\n\ninterface FallbackPlanExecution {\n  allowedChannels: Set<ChannelName>;\n  stages: FallbackPlanStage[];\n}\n\ninterface HybridFusionExecution {\n  evaluationMode: boolean;\n  intent: string;\n  lists: Array<{\n    source: string;\n    results: Array<{ id: number | string; [key: string]: unknown }>;\n    weight?: number;\n  }>;\n  routeResult: ReturnType<typeof routeQuery>;\n  budgetResult: ReturnType<typeof getDynamicTokenBudget>;\n  s3meta: Sprint3PipelineMeta;\n  fusedResults: HybridSearchResult[];\n  vectorEmbeddingCache: Map<number, Float32Array>;\n}\n\nfunction resolveAdaptiveDocumentType(\n  lists: Array<{ results: Array<Record<string, unknown>> }>,\n): string | undefined {\n  const counts = new Map<string, number>();\n  for (const list of lists) {\n    for (const result of list.results.slice(0, 3)) {\n      const candidate = result.documentType ?? result.document_type;\n      if (typeof candidate !== 'string' || candidate.length === 0) {\n        continue;\n      }\n      counts.set(candidate, (counts.get(candidate) ?? 0) + 1);\n    }\n  }\n\n  let topType: string | undefined;\n  let topCount = 0;\n  for (const [documentType, count] of counts) {\n    if (count > topCount) {\n      topType = documentType;\n      topCount = count;\n    }\n  }\n\n  return topType;\n}\n\nfunction markFallbackRetry(results: HybridSearchResult[]): HybridSearchResult[] {\n  for (const result of results) {\n    (result as Record<string, unknown>).fallbackRetry = true;\n  }\n\n  return results;\n}\n\nfunction toEmbeddingBufferView(value: unknown): Float32Array | null {\n  if (value instanceof Float32Array) {\n    return value;\n  }\n\n  if (Array.isArray(value)) {\n    const asNumbers = value.every((entry) => typeof entry === 'number' && Number.isFinite(entry));\n    return asNumbers ? new Float32Array(value) : null;\n  }\n\n  if (Buffer.isBuffer(value)) {\n    return new Float32Array(value.buffer, value.byteOffset, value.byteLength / 4);\n  }\n\n  return null;\n}\n\nasync function executeFallbackPlan(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {},\n  planKind: FallbackPlanKind,\n  overrides: Partial<HybridSearchOptions> = {}\n): Promise<FallbackPlanExecution> {\n  const allowedChannels = getAllowedChannels(options);\n  const stages: FallbackPlanStage[] = [];\n\n  const primaryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n    minSimilarity: options.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY,\n    ...overrides,\n  });\n  const primaryExecution = await collectAndFuseHybridResults(query, embedding, primaryOptions);\n  const primaryResults = primaryExecution\n    ? applyResultLimit(primaryExecution.fusedResults, primaryOptions.limit)\n    : await hybridSearch(query, embedding, primaryOptions);\n  stages.push({\n    stage: 'primary',\n    options: primaryOptions,\n    results: primaryResults,\n    execution: primaryExecution,\n  });\n\n  if (planKind === 'tiered') {\n    const trigger = checkDegradation(primaryResults);\n    if (!trigger) {\n      return { allowedChannels, stages };\n    }\n\n    const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n      ...overrides,\n      minSimilarity: TIERED_FALLBACK_MIN_SIMILARITY,\n      forceAllChannels: true,\n    });\n    const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n    const retryResults = retryExecution\n      ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n      : await hybridSearch(query, embedding, retryOptions);\n    stages.push({\n      stage: 'retry',\n      options: retryOptions,\n      results: retryResults,\n      execution: retryExecution,\n      trigger,\n    });\n    return { allowedChannels, stages };\n  }\n\n  const primaryMinSimilarity = primaryOptions.minSimilarity ?? PRIMARY_FALLBACK_MIN_SIMILARITY;\n  if (primaryResults.length === 0 && primaryMinSimilarity >= SECONDARY_FALLBACK_MIN_SIMILARITY) {\n    const retryOptions = applyAllowedChannelOverrides(options, allowedChannels, {\n      ...overrides,\n      minSimilarity: SECONDARY_FALLBACK_MIN_SIMILARITY,\n    });\n    const retryExecution = await collectAndFuseHybridResults(query, embedding, retryOptions);\n    const retryResultsBase = retryExecution\n      ? applyResultLimit(retryExecution.fusedResults, retryOptions.limit)\n      : await hybridSearch(query, embedding, retryOptions);\n    const retryResults = retryResultsBase.length > 0\n      ? markFallbackRetry(retryResultsBase)\n      : retryResultsBase;\n    stages.push({\n      stage: 'retry',\n      options: retryOptions,\n      results: retryResults,\n      execution: retryExecution,\n      trigger: 'empty',\n    });\n  }\n\n  return { allowedChannels, stages };\n}\n\n// 11. HYBRID SEARCH\n\n/**\n * Run multi-channel hybrid search combining vector, FTS, BM25, and graph results with per-source normalization.\n * Prefer hybridSearchEnhanced() or searchWithFallback() instead. This function uses naive per-source\n * min-max normalization which produces different orderings than the RRF pipeline in hybridSearchEnhanced().\n * Retained as internal fallback only.\n */\nasync function hybridSearch(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const {\n    limit = DEFAULT_LIMIT,\n    specFolder,\n    minSimilarity = 0,\n    useBm25 = isBm25Enabled(),\n    useFts = true,\n    useVector = true,\n    useGraph = true,\n    includeArchived = false,\n  } = options;\n\n  const results: HybridSearchResult[] = [];\n\n  // Vector search\n  if (useVector && embedding && vectorSearchFn) {\n    try {\n      const vectorResults = vectorSearchFn(embedding, {\n        limit,\n        specFolder,\n        minSimilarity,\n        includeConstitutional: false, // Handler manages constitutional separately\n        includeArchived,\n      });\n      for (const r of vectorResults) {\n        results.push({\n          ...r,\n          id: r.id as number,\n          score: (r.similarity as number) || 0,\n          source: 'vector',\n        });\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Vector search failed: ${msg}`);\n    }\n  }\n\n  // FTS search\n  if (useFts) {\n    const ftsResults = ftsSearch(query, { limit, specFolder, includeArchived });\n    results.push(...ftsResults);\n  }\n\n  // BM25 search\n  if (useBm25) {\n    const bm25Results = bm25Search(query, { limit, specFolder });\n    results.push(...bm25Results);\n  }\n\n  // Graph search\n  if (useGraph && graphSearchFn) {\n    try {\n      graphMetrics.totalQueries++;\n      const graphResults = graphSearchFn(query, { limit, specFolder });\n      for (const r of graphResults) {\n        results.push({\n          ...r,\n          id: r.id as number | string,\n          score: (r.score as number) || 0,\n          source: 'graph',\n        });\n      }\n      if (graphResults.length > 0) {\n        graphMetrics.graphHits++;\n        graphMetrics.graphResultCount += graphResults.length;\n      }\n    } catch (error: unknown) {\n      const msg = error instanceof Error ? error.message : String(error);\n      console.warn(`[hybrid-search] Graph search failed: ${msg}`);\n    }\n  }\n\n  // Normalize scores per source before merging so one method's raw scale\n  // Does not dominate others during final ranking.\n  const bySource = new Map<string, HybridSearchResult[]>();\n  for (const r of results) {\n    const src = r.source || 'unknown';\n    if (!bySource.has(src)) bySource.set(src, []);\n    bySource.get(src)!.push(r); // non-null safe: has() guard above guarantees entry exists\n  }\n\n  const normalized: HybridSearchResult[] = [];\n  for (const [, group] of bySource) {\n    if (group.length === 0) continue;\n    const scores = group.map(r => r.score);\n    let min = Infinity;\n    let max = -Infinity;\n    for (const s of scores) {\n      if (s < min) min = s;\n      if (s > max) max = s;\n    }\n    const range = max - min;\n    for (const r of group) {\n      normalized.push({\n        ...r,\n        score: range > 0 ? (r.score - min) / range : (r.score > 0 ? 1.0 : 0),\n      });\n    }\n  }\n\n  // Deduplicate by ID (keep highest normalized score)\n  // LIMITATION: When a result appears in multiple sources (e.g., vector + fts),\n  // Only the highest-scoring entry's `source` is preserved. Multi-source provenance\n  // Is lost here. To fix properly, HybridSearchResult would need a `sources: string[]`\n  // Field and downstream consumers would need to be updated accordingly.\n  const deduped = new Map<string, HybridSearchResult>();\n  for (const r of normalized) {\n    const canonicalId = canonicalResultId(r.id);\n    const existing = deduped.get(canonicalId);\n    if (!existing || r.score > existing.score) {\n      deduped.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(deduped.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, limit);\n}\n\n/**\n * Enhanced hybrid search with RRF fusion.\n * All search channels use synchronous better-sqlite3; sequential execution\n * is correct — Promise.all would add overhead without achieving parallelism.\n */\nasync function hybridSearchEnhanced(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const execution = await collectAndFuseHybridResults(query, embedding, options);\n  if (execution) {\n    if (options.stopAfterFusion) {\n      return applyResultLimit(execution.fusedResults, options.limit);\n    }\n\n    return enrichFusedResults(query, execution, options);\n  }\n\n  return hybridSearch(query, embedding, options);\n}\n\nasync function collectAndFuseHybridResults(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridFusionExecution | null> {\n  try {\n    const evaluationMode = options.evaluationMode === true;\n    const lists: HybridFusionExecution['lists'] = [];\n\n    // Pipeline metadata collector (populated by flag-gated stages)\n    const s3meta: Sprint3PipelineMeta = {};\n\n    // -- Stage A: Query Classification + Routing (SPECKIT_COMPLEXITY_ROUTER) --\n    // When enabled, classifies query complexity and restricts channels to a\n    // Subset (e.g., simple queries skip graph+degree). When disabled, all channels run.\n    const routeResult = routeQuery(query, options.triggerPhrases);\n    const allPossibleChannels: ChannelName[] = ['vector', 'fts', 'bm25', 'graph', 'degree'];\n    const activeChannels = options.forceAllChannels\n      ? new Set<ChannelName>(allPossibleChannels)\n      : new Set<ChannelName>(routeResult.channels);\n\n    // Respect explicit caller channel disables across both the primary route and\n    // every fallback tier. useGraph=false also disables the dependent degree lane.\n    const allowedChannels = getAllowedChannels(options);\n    for (const channel of allPossibleChannels) {\n      if (!allowedChannels.has(channel)) activeChannels.delete(channel);\n    }\n\n    const skippedChannels = allPossibleChannels.filter(ch => !activeChannels.has(ch));\n\n    if (skippedChannels.length > 0) {\n      s3meta.routing = {\n        tier: routeResult.tier,\n        channels: routeResult.channels,\n        skippedChannels,\n        featureFlagEnabled: isComplexityRouterEnabled(),\n        confidence: routeResult.classification.confidence,\n        features: routeResult.classification.features as Record<string, unknown>,\n      };\n    }\n\n    // -- Stage E: Dynamic Token Budget (SPECKIT_DYNAMIC_TOKEN_BUDGET) --\n    // Compute tier-aware budget early so it's available for downstream truncation.\n    // When disabled, getDynamicTokenBudget returns the default 4000 budget with applied=false.\n    // Weak / low-confidence queries keep the full budget so recall is not trimmed away.\n    const lowSignalQuery =\n      routeResult.classification.confidence === 'low' ||\n      routeResult.classification.confidence === 'fallback';\n    const budgetResult = getDynamicTokenBudget(routeResult.tier, undefined, {\n      lowSignal: lowSignalQuery,\n    });\n    if (budgetResult.applied && !evaluationMode) {\n      s3meta.tokenBudget = {\n        tier: budgetResult.tier,\n        budget: budgetResult.budget,\n        applied: budgetResult.applied,\n        featureFlagEnabled: isDynamicTokenBudgetEnabled(),\n        configValues: DEFAULT_TOKEN_BUDGET_CONFIG as unknown as Record<string, number>,\n        // headerOverhead and adjustedBudget are patched in below after they are computed\n        headerOverhead: 0,\n        adjustedBudget: budgetResult.budget,\n      };\n    }\n\n    // Channel results collected independently, merged after all complete\n    let semanticResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [];\n    let ftsChannelResults: HybridSearchResult[] = [];\n    let bm25ChannelResults: HybridSearchResult[] = [];\n    let triggerChannelResults: HybridSearchResult[] = [];\n    const vectorEmbeddingCache = new Map<number, Float32Array>();\n\n    // All channels use synchronous better-sqlite3; sequential execution\n    // Is correct — Promise.all adds overhead without parallelism.\n\n    // Vector channel — gated by query-complexity routing\n    if (activeChannels.has('vector') && embedding && vectorSearchFn) {\n      try {\n        const vectorResults = vectorSearchFn(embedding, {\n          limit: options.limit || DEFAULT_LIMIT,\n          specFolder: options.specFolder,\n          minSimilarity: options.minSimilarity || 0,\n          includeConstitutional: false,\n          includeArchived: options.includeArchived || false,\n          includeEmbeddings: true,\n        });\n        semanticResults = vectorResults.map((r: Record<string, unknown>): { id: number | string; source: string; [key: string]: unknown } => ({\n          ...r,\n          id: r.id as number | string,\n          source: 'vector',\n        }));\n        for (const result of semanticResults) {\n          if (typeof result.id !== 'number') continue;\n          const embeddingCandidate = toEmbeddingBufferView(\n            (result as Record<string, unknown>).embedding\n            ?? (result as Record<string, unknown>).embeddingBuffer\n          );\n          if (embeddingCandidate) {\n            vectorEmbeddingCache.set(result.id, embeddingCandidate);\n          }\n        }\n        lists.push({ source: 'vector', results: semanticResults, weight: 1.0 });\n      } catch (_err: unknown) {\n        // Non-critical — vector channel failure does not block pipeline\n        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // FTS channel (internal error handling in ftsSearch) — gated by query-complexity routing\n    if (activeChannels.has('fts')) {\n      ftsChannelResults = ftsSearch(query, options);\n      if (ftsChannelResults.length > 0) {\n        // FTS weight reduced to 0.3 after ablation showed 0.8 was harmful,\n        // flooding top-K with noisy lexical matches despite its exact-match value.\n        lists.push({ source: 'fts', results: ftsChannelResults, weight: 0.3 });\n      }\n    }\n\n    // BM25 channel (internal error handling in bm25Search) — gated by query-complexity routing\n    if (activeChannels.has('bm25')) {\n      bm25ChannelResults = bm25Search(query, options);\n      if (bm25ChannelResults.length > 0) {\n        // BM25 weight 0.6 is lowest lexical channel — in-memory BM25 index\n        // Has less precise scoring than SQLite FTS5 BM25; kept for coverage breadth.\n        lists.push({ source: 'bm25', results: bm25ChannelResults, weight: 0.6 });\n      }\n    }\n\n    triggerChannelResults = exactTriggerSearch(query, options);\n    if (triggerChannelResults.length > 0) {\n      lists.push({ source: 'trigger', results: triggerChannelResults, weight: 1.4 });\n    }\n\n    // Graph channel — gated by query-complexity routing\n    const useGraph = (options.useGraph !== false) && activeChannels.has('graph');\n    if (useGraph && graphSearchFn) {\n      try {\n        graphMetrics.totalQueries++; // counted only if channel executes\n        const graphResults = graphSearchFn(query, {\n          limit: options.limit || DEFAULT_LIMIT,\n          specFolder: options.specFolder,\n          intent: options.intent,\n        });\n        if (graphResults.length > 0) {\n          graphMetrics.graphHits++;\n          graphMetrics.graphResultCount += graphResults.length;\n          lists.push({ source: 'graph', results: graphResults.map((r: Record<string, unknown>) => ({\n            ...r,\n            id: r.id as number | string,\n          })), weight: 0.5 });\n        }\n      } catch (_err: unknown) {\n        // Non-critical — graph channel failure does not block pipeline","lineStart":1,"lineEnd":1445,"totalLines":1446,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781762552980,"end":1781762552989}},"metadata":{"openai":{"itemId":"fc_0ad6a33b31dfd68b016a3389f8c5cc8191b1475543b913d71e"}},"id":"prt_ed952f48d001eGKmzntthtlA7d","sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","messageID":"msg_ed952b9660016b4OyV917AJXcZ"}}
