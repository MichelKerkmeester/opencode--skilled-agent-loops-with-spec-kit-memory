     1	#!/usr/bin/env python3
     2	# ---------------------------------------------------------------------------
     3	# COMPONENT: Catalog / Playbook Root Name Resolver
     4	# ---------------------------------------------------------------------------
     5	"""Canonical-only resolver for the catalog and playbook root directories.
     6	
     7	Kebab-case is the sole canonical form. This module is the single place that recognizes
     8	the catalog and playbook roots, so no consumer reinterprets a root name on its own.
     9	
    10	It fails closed: a legacy underscore directory is no longer a recognized alias, so any
    11	path carrying one is rejected as unsupported rather than silently resolved. Path matching
    12	handles POSIX and Windows separators so a consumer gets the same answer on either platform.
    13	"""
    14	import re
    15	from pathlib import Path
    16	from typing import Iterable, Optional, Tuple
    17	
    18	# Canonical hyphen form only. The bounded migration window has closed: the legacy underscore
    19	# aliases are no longer accepted, and a path carrying one now fails closed as unsupported.
    20	CATALOG_ROOT_NAMES: Tuple[str, ...] = ('feature-catalog',)
    21	PLAYBOOK_ROOT_NAMES: Tuple[str, ...] = ('manual-testing-playbook',)
    22	ALL_ROOT_NAMES: Tuple[str, ...] = CATALOG_ROOT_NAMES + PLAYBOOK_ROOT_NAMES
    23	
    24	# Canonical hyphen forms only, for callers that emit rather than read.
    25	CANONICAL_ROOT_NAMES: Tuple[str, ...] = (CATALOG_ROOT_NAMES[0], PLAYBOOK_ROOT_NAMES[0])
    26	
    27	_CANONICAL = {
    28	    'feature-catalog': 'feature-catalog',
    29	    'manual-testing-playbook': 'manual-testing-playbook',
    30	}
    31	
    32	
    33	class RootCoexistenceError(Exception):
    34	    """A legacy underscore root directory is present and must be migrated, not resolved."""
    35	
    36	
    37	class UnsupportedRootError(Exception):
    38	    """A path contains a catalog/playbook-shaped root that is not supported."""
    39	
    40	
    41	def canonical_root(name: str) -> Optional[str]:
    42	    """Return the canonical hyphen root for either form, or None if not a root name."""
    43	    return _CANONICAL.get(name)
    44	
    45	
    46	def is_catalog_root(name: str) -> bool:
    47	    return name in CATALOG_ROOT_NAMES
    48	
    49	
    50	def is_playbook_root(name: str) -> bool:
    51	    return name in PLAYBOOK_ROOT_NAMES
    52	
    53	
    54	def is_root_name(name: str) -> bool:
    55	    return name in _CANONICAL
    56	
    57	
    58	def path_contains_root(path, roots: Iterable[str] = ALL_ROOT_NAMES) -> bool:
    59	    """True if any root name appears as a full path segment (POSIX or Windows)."""
    60	    lowered = str(path).lower()
    61	    return any(f'/{r}/' in lowered or f'\\{r}\\' in lowered for r in roots)
    62	
    63	
    64	def unsupported_root_names(path) -> Tuple[str, ...]:
    65	    """Return unsupported catalog/playbook-shaped path segments.
    66	
    67	    Near-miss names must not fall through into a generic document category.
    68	    Ordinary unrelated path segments remain outside this bounded contract.
    69	    """
    70	    segments = re.split(r'[/\\\\]+', str(path).lower())
    71	    candidates = []
    72	    for segment in segments:
    73	        if '.' in segment:
    74	            continue
    75	        if segment in _CANONICAL:
    76	            continue
    77	        normalized = segment.replace('-', '_')
    78	        if normalized.startswith('feature_catalog') or normalized.startswith('manual_testing_playbook'):
    79	            candidates.append(segment)
    80	    return tuple(dict.fromkeys(candidates))
    81	
    82	
    83	def assert_supported_root_path(path) -> None:
    84	    """Raise when a path contains an unsupported catalog/playbook root segment."""
    85	    unsupported = unsupported_root_names(path)
    86	    if unsupported:
    87	        raise UnsupportedRootError(
    88	            f"unsupported catalog/playbook root segment(s): {', '.join(unsupported)}"
    89	        )
    90	
    91	
    92	def find_unsupported_root_dirs(root: Path) -> Tuple[Path, ...]:
    93	    """Return unsupported catalog/playbook-shaped directories below ``root``."""
    94	    root = Path(root)
    95	    offenders = []
    96	    if not root.exists():
    97	        return ()
    98	    for candidate in root.rglob('*'):
    99	        if candidate.is_dir() and unsupported_root_names(candidate.name):
   100	            offenders.append(candidate)
   101	    return tuple(sorted(set(offenders)))
   102	
   103	
   104	def resolve_existing_root_dir(parent: Path, root_kind: str) -> Optional[Path]:
   105	    """Return the single existing canonical root dir under `parent` for 'catalog' or 'playbook'.
   106	
   107	    Fails closed (raises RootCoexistenceError) when a legacy underscore directory physically
   108	    exists, whether alone or beside the canonical form, because it must be migrated rather than
   109	    silently ignored. Returns None when no root of that kind exists.
   110	    """
   111	    if root_kind == 'catalog':
   112	        names = CATALOG_ROOT_NAMES
   113	        legacy = 'feature_catalog'
   114	    elif root_kind == 'playbook':
   115	        names = PLAYBOOK_ROOT_NAMES
   116	        legacy = 'manual_testing_playbook'
   117	    else:
   118	        raise ValueError(f"root_kind must be 'catalog' or 'playbook', got {root_kind!r}")
   119	    parent = Path(parent)
   120	    if (parent / legacy).is_dir():
   121	        raise RootCoexistenceError(
   122	            f"legacy underscore root {legacy!r} present under {parent}; "
   123	            "migrate it to the canonical hyphen form before continuing"
   124	        )
   125	    present = [parent / name for name in names if (parent / name).is_dir()]
   126	    return present[0] if present else None
     1	#!/usr/bin/env python3
     2	# ---------------------------------------------------------------------------
     3	# COMPONENT: Catalog Content Naming Guard
     4	# ---------------------------------------------------------------------------
     5	"""Enforce kebab-case for catalog and playbook content.
     6	
     7	Category folders and per-feature Markdown files must use kebab-case, matching the
     8	repo-wide filesystem-naming convention; an underscore in a content name is a
     9	violation. Root index files are outside the check because only content below a
    10	category folder is in scope. An underscore catalog/playbook ROOT is a hard error
    11	(the canonical roots are hyphenated) and is rejected before content is scanned.
    12	
    13	Usage:
    14	  check_no_hyphenated_catalog_content.py [ROOT]
    15	  check_no_hyphenated_catalog_content.py --json [ROOT]
    16	
    17	The historical --enforce-hyphen-target flag is accepted for backward
    18	compatibility but is now the default behavior.
    19	"""
    20	import json
    21	import sys
    22	from pathlib import Path
    23	
    24	
    25	sys.path.insert(0, str(Path(__file__).resolve().parent))
    26	from naming_root_resolver import ALL_ROOT_NAMES, find_unsupported_root_dirs  # type: ignore
    27	
    28	
    29	def find_underscored_content(root: Path):
    30	    """Return catalog/playbook content paths whose folder or Markdown name uses an underscore."""
    31	    offenders = []
    32	    for category_root in ALL_ROOT_NAMES:
    33	        for parent in root.rglob(category_root):
    34	            if not parent.is_dir():
    35	                continue
    36	            for category in parent.iterdir():
    37	                if not category.is_dir():
    38	                    continue
    39	                for candidate in [category, *category.rglob('*')]:
    40	                    if candidate.is_dir() and '_' in candidate.name:
    41	                        offenders.append(candidate)
    42	                    elif candidate.is_file() and candidate.suffix == '.md' and '_' in candidate.name:
    43	                        offenders.append(candidate)
    44	    return sorted(set(offenders))
    45	
    46	
    47	def main(argv) -> int:
    48	    # --enforce-hyphen-target is accepted but inert: enforcing kebab content is now the default.
    49	    flags = {'--json', '--enforce-hyphen-target'}
    50	    args = [argument for argument in argv if argument not in flags]
    51	    as_json = '--json' in argv
    52	    root = Path(args[0]) if args else Path('.opencode/skills')
    53	    if not root.exists():
    54	        print(f'ERROR: root not found: {root}', file=sys.stderr)
    55	        return 2
    56	
    57	    unsupported = find_unsupported_root_dirs(root)
    58	    if unsupported:
    59	        print(f'ERROR: unsupported catalog/playbook root: {unsupported[0]}', file=sys.stderr)
    60	        return 2
    61	
    62	    offenders = find_underscored_content(root)
    63	    paths = [str(path) for path in offenders]
    64	    if as_json:
    65	        print(json.dumps({'clean': not offenders, 'offenders': paths}, indent=2))
    66	    elif offenders:
    67	        print(f'FAIL: {len(offenders)} underscore catalog/playbook content path(s) found (use kebab-case):')
    68	        for offender in paths:
    69	            print(f'  - {offender}')
    70	    else:
    71	        print('PASS: catalog/playbook content is kebab-case.')
    72	    return 1 if offenders else 0
    73	
    74	
    75	if __name__ == '__main__':
    76	    sys.exit(main(sys.argv[1:]))
     1	#!/usr/bin/env python3
     2	# ---------------------------------------------------------------------------
     3	# COMPONENT: Authored Artifact Name Guard
     4	# ---------------------------------------------------------------------------
     5	"""Validate one authored artifact basename or slug as kebab-case.
     6	
     7	Usage:
     8	  check_authored_name_kebab.py <artifact-path-or-slug>
     9	  check_authored_name_kebab.py --directory <artifact-path-or-slug>
    10	
    11	The authored stem must match ``^[a-z0-9]+(?:-[a-z0-9]+)*$``. Repository-wide
    12	filesystem exemptions are delegated to ``check_no_new_snake_case.py`` so both
    13	guards apply the same boundary.
    14	"""
    15	
    16	import argparse
    17	import re
    18	import sys
    19	from pathlib import Path, PurePosixPath
    20	from typing import Sequence
    21	
    22	sys.path.insert(0, str(Path(__file__).resolve().parent))
    23	from check_no_new_snake_case import (  # type: ignore  # noqa: E402
    24	    GuardError,
    25	    _current_completed_spec_roots,
    26	    _is_name_exempt,
    27	    _is_tree_exempt,
    28	    _name_stem,
    29	    repository_root,
    30	)
    31	
    32	
    33	KEBAB_CASE = re.compile(r"^[a-z0-9]+(?:-[a-z0-9]+)*$")
    34	
    35	
    36	def _repository_relative_path(repo_root: Path, artifact: Path) -> PurePosixPath:
    37	    """Return a repository-relative path when possible, otherwise the supplied path."""
    38	    candidate = artifact if artifact.is_absolute() else Path.cwd() / artifact
    39	    try:
    40	        relative = candidate.resolve(strict=False).relative_to(repo_root)
    41	    except ValueError:
    42	        return PurePosixPath(artifact.as_posix())
    43	    return PurePosixPath(relative.as_posix())
    44	
    45	
    46	def validate_authored_name(repo_root: Path, artifact: Path, is_dir: bool) -> tuple[bool, bool]:
    47	    """Return ``(valid, exempt)`` for one authored artifact path or slug."""
    48	    relative_path = _repository_relative_path(repo_root, artifact)
    49	    completed_spec_roots = _current_completed_spec_roots(repo_root)
    50	    if _is_tree_exempt(relative_path, completed_spec_roots):
    51	        return True, True
    52	    if _is_name_exempt(repo_root, relative_path, is_dir):
    53	        return True, True
    54	    return bool(KEBAB_CASE.fullmatch(_name_stem(relative_path.name))), False
    55	
    56	
    57	def parse_args(argv: Sequence[str]) -> argparse.Namespace:
    58	    """Parse command-line arguments."""
    59	    parser = argparse.ArgumentParser(description=__doc__)
    60	    parser.add_argument("artifact", help="Artifact path, filename, or slug to validate")
    61	    parser.add_argument(
    62	        "--directory",
    63	        action="store_true",
    64	        help="Treat a not-yet-created artifact as a directory",
    65	    )
    66	    return parser.parse_args(argv)
    67	
    68	
    69	def main(argv: Sequence[str]) -> int:
    70	    """Validate one artifact name and print a stable pass/fail signal."""
    71	    args = parse_args(argv)
    72	    artifact = Path(args.artifact)
    73	    try:
    74	        repo_root = repository_root()
    75	        valid, exempt = validate_authored_name(
    76	            repo_root,
    77	            artifact,
    78	            args.directory or artifact.is_dir(),
    79	        )
    80	    except GuardError as error:
    81	        print(f"ERROR: {error}", file=sys.stderr)
    82	        return 2
    83	
    84	    if exempt:
    85	        print(f"PASS: authored artifact name is exempt: {args.artifact}")
    86	        return 0
    87	    if valid:
    88	        print(f"PASS: authored artifact name is kebab-case: {args.artifact}")
    89	        return 0
    90	
    91	    print(
    92	        "FAIL: authored artifact name must match "
    93	        f"{KEBAB_CASE.pattern}: {args.artifact}"
    94	    )
    95	    return 1
