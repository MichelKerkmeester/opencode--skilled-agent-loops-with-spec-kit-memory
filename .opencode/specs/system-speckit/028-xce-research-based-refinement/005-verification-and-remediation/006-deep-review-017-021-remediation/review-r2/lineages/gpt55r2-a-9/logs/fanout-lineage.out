{"type":"tool_use","timestamp":1781764189242,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_d3F3ucyna8jBIZKeTRzNSBg2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":400,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n400: /**\n401:  * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n402:  * @param database - The better-sqlite3 database instance for FTS and graph queries.\n403:  * @param vectorFn - Optional vector search function for semantic similarity.\n404:  * @param graphFn - Optional graph search function for causal/structural retrieval.\n405:  */\n406: function init(\n407:   database: Database.Database,\n408:   vectorFn: VectorSearchFn | null = null,\n409:   graphFn: GraphSearchFn | null = null\n410: ): void {\n411:   db = database;\n412:   vectorSearchFn = vectorFn;\n413:   graphSearchFn = graphFn;\n414: }\n415: \n416: // 8. BM25 SEARCH\n417: \n418: /**\n419:  * Search the BM25 index with optional spec folder filtering.\n420:  * @param query - The search query string.\n421:  * @param options - Optional limit and specFolder filter.\n422:  * @returns Array of BM25-scored results tagged with source 'bm25'.\n423:  */\n424: function bm25Search(\n425:   query: string,\n426:   options: { limit?: number; specFolder?: string } = {}\n427: ): HybridSearchResult[] {\n428:   if (!isBm25Enabled()) {\n429:     console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n430:     return [];\n431:   }\n432: \n433:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n434: \n435:   try {\n436:     if (shouldUseSqliteLexicalEngine(db)) {\n437:       return ftsSearch(query, {\n438:         limit,\n439:         specFolder,\n440:       }).map((result) => ({\n441:         ...result,\n442:         bm25_score: result.score,\n443:         source: 'bm25',\n444:         sources: Array.from(new Set([\n445:           ...(\n446:             Array.isArray((result as Record<string, unknown>).sources)\n447:               ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n448:               : []\n449:           ),\n450:           'fts',\n451:           'bm25',\n452:         ])),\n453:       }));\n454:     }\n455: \n456:     // Spec-folder scope can only be resolved from DB metadata; fail closed before\n457:     // searching when the DB is unavailable rather than over-fetching the whole\n458:     // corpus and then discarding it.\n459:     if (specFolder && !db) {\n460:       console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n461:       return [];\n462:     }\n463: \n464:     const index = getIndex();\n465:     const candidateLimit = (specFolder || db)\n466:       ? index.getStats().documentCount\n467:       : limit;\n468:     // Metadata filters run after in-memory scoring, so fetch the corpus-bounded\n469:     // candidate set whenever those filters can remove otherwise top-ranked hits.\n470:     const results = index.search(query, candidateLimit);\n471: \n472:     // BM25 document IDs are stringified\n473:     // Numeric memory IDs (e.g., \"42\"), not spec folder paths. The old filter compared\n474:     // R.id against specFolder which never matched. Use DB lookup to resolve spec_folder.\n475: \n476:     // Batch-resolve metadata for all result IDs (was N+1 individual queries)\n477:     // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n478:     // resolution returns [] rather than leaking unscoped BM25 candidates.\n479:     let memoryMetadataMap: Map<number, Bm25MemoryMetadata> | null = null;\n480:     if (results.length > 0) {\n481:       if (!db) {\n482:         if (specFolder) {\n483:           const error = new Error('Database unavailable for spec-folder scope lookup');\n484:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n485:           return [];\n486:         }\n487:       } else {\n488:         try {\n489:           const ids = results.map((r: { id: string }) => Number(r.id));\n490:           memoryMetadataMap = new Map();\n491:           // Resolve metadata in bounded batches. The candidate set can now be\n492:           // corpus-sized (over-fetch for scope/tier filtering), and a single\n493:           // IN (...) with one bind per id would exceed SQLite's parameter limit\n494:           // and throw — which the catch below turns into an empty result.\n495:           const METADATA_BATCH = 500;\n496:           for (let offset = 0; offset < ids.length; offset += METADATA_BATCH) {\n497:             const batch = ids.slice(offset, offset + METADATA_BATCH);\n498:             const placeholders = batch.map(() => '?').join(',');\n499:             const rows = db.prepare(\n500:               `SELECT id, spec_folder, importance_tier FROM memory_index WHERE id IN (${placeholders})`\n501:             ).all(...batch) as Array<{ id: number; spec_folder: string | null; importance_tier: string | null }>;\n502:             for (const row of rows) {\n503:               memoryMetadataMap.set(row.id, {\n504:                 specFolder: row.spec_folder,\n505:                 importanceTier: row.importance_tier,\n506:               });\n507:             }\n508:           }\n509:         } catch (error: unknown) {\n510:           console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n511:           return [];\n512:         }\n513:       }\n514: \n515:       // DEFENSE-IN-DEPTH: If specFolder was requested but metadata resolution\n516:       // is still null after the resolution block, something unexpected happened.\n517:       // Fail closed rather than falling through to unscoped results.\n518:       if (specFolder && !memoryMetadataMap) {\n519:         const error = new Error('memoryMetadataMap unexpectedly null after scope resolution');\n520:         console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n521:         return [];\n522:       }\n523:     }\n524: \n525:     const excludeCold = !isArchivedRetrievalIncludedByDefault();\n526:     return results\n527:       .filter((r: { id: string }) => {\n528:         const metadata = memoryMetadataMap?.get(Number(r.id));\n529:         // Cold/deprecated rows are included by default (FSRS ranks them lower);\n530:         // only drop them when archived retrieval is disabled.\n531:         if (excludeCold && metadata?.importanceTier === 'deprecated') return false;\n532:         if (!specFolder) return true;\n533:         if (!metadata) return false;\n534:         const folder = metadata.specFolder;\n535:         if (!folder) return false;\n536:         return folder === specFolder || folder.startsWith(specFolder + '/');\n537:       })\n538:       .slice(0, limit)\n539:       .map((r: { id: string; score: number }) => ({\n540:         ...r,\n541:         source: 'bm25',\n542:       }));\n543:   } catch (error: unknown) {\n544:     const msg = error instanceof Error ? error.message : String(error);\n545:     console.warn(`[hybrid-search] BM25 search failed: ${msg}`);\n546:     return [];\n547:   }\n548: }\n549: \n550: /**\n551:  * Check whether the BM25 index is populated and available for search.\n552:  * @returns True if the BM25 index exists and contains at least one document.\n553:  */\n554: function isBm25Available(): boolean {\n555:   if (!isBm25Enabled()) {\n556:     return false;\n557:   }\n558: \n559:   try {\n\n(Showing lines 400-559 of 2972. Use offset=560 to continue.)\n</content>","metadata":{"preview":"/**\n * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n * @param database - The better-sqlite3 database instance for FTS and graph queries.\n * @param vectorFn - Optional vector search function for semantic similarity.\n * @param graphFn - Optional graph search function for causal/structural retrieval.\n */\nfunction init(\n  database: Database.Database,\n  vectorFn: VectorSearchFn | null = null,\n  graphFn: GraphSearchFn | null = null\n): void {\n  db = database;\n  vectorSearchFn = vectorFn;\n  graphSearchFn = graphFn;\n}\n\n// 8. BM25 SEARCH\n\n/**\n * Search the BM25 index with optional spec folder filtering.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"/**\n * Initialize hybrid search with database, vector search, and optional graph search dependencies.\n * @param database - The better-sqlite3 database instance for FTS and graph queries.\n * @param vectorFn - Optional vector search function for semantic similarity.\n * @param graphFn - Optional graph search function for causal/structural retrieval.\n */\nfunction init(\n  database: Database.Database,\n  vectorFn: VectorSearchFn | null = null,\n  graphFn: GraphSearchFn | null = null\n): void {\n  db = database;\n  vectorSearchFn = vectorFn;\n  graphSearchFn = graphFn;\n}\n\n// 8. BM25 SEARCH\n\n/**\n * Search the BM25 index with optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit and specFolder filter.\n * @returns Array of BM25-scored results tagged with source 'bm25'.\n */\nfunction bm25Search(\n  query: string,\n  options: { limit?: number; specFolder?: string } = {}\n): HybridSearchResult[] {\n  if (!isBm25Enabled()) {\n    console.warn('[hybrid-search] BM25 not enabled — returning empty bm25Search results');\n    return [];\n  }\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n\n  try {\n    if (shouldUseSqliteLexicalEngine(db)) {\n      return ftsSearch(query, {\n        limit,\n        specFolder,\n      }).map((result) => ({\n        ...result,\n        bm25_score: result.score,\n        source: 'bm25',\n        sources: Array.from(new Set([\n          ...(\n            Array.isArray((result as Record<string, unknown>).sources)\n              ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n              : []\n          ),\n          'fts',\n          'bm25',\n        ])),\n      }));\n    }\n\n    // Spec-folder scope can only be resolved from DB metadata; fail closed before\n    // searching when the DB is unavailable rather than over-fetching the whole\n    // corpus and then discarding it.\n    if (specFolder && !db) {\n      console.warn('[BM25] Spec-folder scope requested without a database; returning empty scoped results');\n      return [];\n    }\n\n    const index = getIndex();\n    const candidateLimit = (specFolder || db)\n      ? index.getStats().documentCount\n      : limit;\n    // Metadata filters run after in-memory scoring, so fetch the corpus-bounded\n    // candidate set whenever those filters can remove otherwise top-ranked hits.\n    const results = index.search(query, candidateLimit);\n\n    // BM25 document IDs are stringified\n    // Numeric memory IDs (e.g., \"42\"), not spec folder paths. The old filter compared\n    // R.id against specFolder which never matched. Use DB lookup to resolve spec_folder.\n\n    // Batch-resolve metadata for all result IDs (was N+1 individual queries)\n    // SECURITY: Spec-folder scope MUST fail closed — any error in scope\n    // resolution returns [] rather than leaking unscoped BM25 candidates.\n    let memoryMetadataMap: Map<number, Bm25MemoryMetadata> | null = null;\n    if (results.length > 0) {\n      if (!db) {\n        if (specFolder) {\n          const error = new Error('Database unavailable for spec-folder scope lookup');\n          console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n          return [];\n        }\n      } else {\n        try {\n          const ids = results.map((r: { id: string }) => Number(r.id));\n          memoryMetadataMap = new Map();\n          // Resolve metadata in bounded batches. The candidate set can now be\n          // corpus-sized (over-fetch for scope/tier filtering), and a single\n          // IN (...) with one bind per id would exceed SQLite's parameter limit\n          // and throw — which the catch below turns into an empty result.\n          const METADATA_BATCH = 500;\n          for (let offset = 0; offset < ids.length; offset += METADATA_BATCH) {\n            const batch = ids.slice(offset, offset + METADATA_BATCH);\n            const placeholders = batch.map(() => '?').join(',');\n            const rows = db.prepare(\n              `SELECT id, spec_folder, importance_tier FROM memory_index WHERE id IN (${placeholders})`\n            ).all(...batch) as Array<{ id: number; spec_folder: string | null; importance_tier: string | null }>;\n            for (const row of rows) {\n              memoryMetadataMap.set(row.id, {\n                specFolder: row.spec_folder,\n                importanceTier: row.importance_tier,\n              });\n            }\n          }\n        } catch (error: unknown) {\n          console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n          return [];\n        }\n      }\n\n      // DEFENSE-IN-DEPTH: If specFolder was requested but metadata resolution\n      // is still null after the resolution block, something unexpected happened.\n      // Fail closed rather than falling through to unscoped results.\n      if (specFolder && !memoryMetadataMap) {\n        const error = new Error('memoryMetadataMap unexpectedly null after scope resolution');\n        console.warn('[BM25] Spec-folder scope lookup failed, returning empty scoped results:', error);\n        return [];\n      }\n    }\n\n    const excludeCold = !isArchivedRetrievalIncludedByDefault();\n    return results\n      .filter((r: { id: string }) => {\n        const metadata = memoryMetadataMap?.get(Number(r.id));\n        // Cold/deprecated rows are included by default (FSRS ranks them lower);\n        // only drop them when archived retrieval is disabled.\n        if (excludeCold && metadata?.importanceTier === 'deprecated') return false;\n        if (!specFolder) return true;\n        if (!metadata) return false;\n        const folder = metadata.specFolder;\n        if (!folder) return false;\n        return folder === specFolder || folder.startsWith(specFolder + '/');\n      })\n      .slice(0, limit)\n      .map((r: { id: string; score: number }) => ({\n        ...r,\n        source: 'bm25',\n      }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] BM25 search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Check whether the BM25 index is populated and available for search.\n * @returns True if the BM25 index exists and contains at least one document.\n */\nfunction isBm25Available(): boolean {\n  if (!isBm25Enabled()) {\n    return false;\n  }\n\n  try {","lineStart":400,"lineEnd":559,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781764189231,"end":1781764189241}},"metadata":{"openai":{"itemId":"fc_0a832f684a8a0901016a33905d15b48191971df9eb618f5d1f"}},"id":"prt_ed96bebfd001mAfAwtXROEEERz","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96bc7520017kcKyJ11jH1CKX"}}
