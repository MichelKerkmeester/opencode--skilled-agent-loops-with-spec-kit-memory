   599	function cliRecommendations(data, thresholds) {
   600	  return Array.isArray(data?.recommendations)
   601	    ? data.recommendations
   602	      .map((recommendation) => {
   603	        const skill = sanitizeLabel(recommendation?.skillId);
   604	        if (!skill) return null;
   605	        const confidence = Number.isFinite(recommendation?.confidence) ? recommendation.confidence : 0;
   606	        const uncertainty = Number.isFinite(recommendation?.uncertainty) ? recommendation.uncertainty : 1;
   607	        return {
   608	          skill,
   609	          kind: 'skill',
   610	          confidence,
   611	          uncertainty,
   612	          score: Number.isFinite(recommendation?.score) ? recommendation.score : confidence,
   613	          passes_threshold: confidence >= thresholds.confidenceThreshold
   614	            && uncertainty <= thresholds.uncertaintyThreshold,
   615	          reason: null,
   616	          ...(Array.isArray(recommendation?.ambiguousWith) ? { ambiguousWith: recommendation.ambiguousWith.map(sanitizeLabel).filter(Boolean) } : {}),
   617	        };
   618	      })
   619	      .filter((recommendation) => recommendation?.passes_threshold === true)
   620	    : [];
   621	}
