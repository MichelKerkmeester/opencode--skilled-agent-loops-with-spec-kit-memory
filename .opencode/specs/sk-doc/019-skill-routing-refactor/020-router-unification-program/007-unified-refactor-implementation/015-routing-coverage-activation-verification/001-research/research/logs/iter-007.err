     1	#!/usr/bin/env node
     2	// ╔══════════════════════════════════════════════════════════════════════════╗
     3	// ║ build-report.cjs — render report.md from report.json (anti-drift)        ║
     4	// ╚══════════════════════════════════════════════════════════════════════════╝
     5	'use strict';
     6	
     7	/**
     8	 * build-report.cjs — render report.md FROM report.json (anti-drift).
     9	 *
    10	 * The converged design requires a dual artifact: a machine report.json and a
    11	 * human report.md, with the markdown rendered from the JSON so they cannot drift.
    12	 * There is no pre-existing Lane B renderer to reuse (Lane B emits JSON only), so
    13	 * this renderer is Lane-C-specific. It is the ONLY writer of report.md — it
    14	 * accepts no score arguments, only the report object.
    15	 */
    16	
    17	// ─────────────────────────────────────────────────────────────────────────────
    18	// 1. IMPORTS/REQUIRES
    19	// ─────────────────────────────────────────────────────────────────────────────
    20	
    21	const fs = require('fs');
    22	
    23	// ─────────────────────────────────────────────────────────────────────────────
    24	// 2. HELPERS
    25	// ─────────────────────────────────────────────────────────────────────────────
    26	
    27	function dimLine(name, d) {
    28	  if (!d) return `| ${name} | — | — |`;
    29	  const score = d.score == null ? `_${d.status || 'unscored'}_` : `${d.score}/100`;
    30	  const gate = d.hardGate ? ' (hard gate)' : '';
    31	  return `| ${name}${gate} | ${d.points}pts | ${score} |`;
    32	}
    33	
    34	/**
    35	 * Fail-closed provenance guard. Scoped to the gated typed-pair taxonomy only:
    36	 * a plain report (no excluded rows, no row carrying an errorClass) never
    37	 * enters this check, so it can never trip for any pre-existing report shape.
    38	 * Once a report DOES carry gated rows, it must be able to say which skill
    39	 * root and manifest digest they were scored against, and every gated/excluded
    40	 * row must be individually identifiable — otherwise the report is rendered
    41	 * without knowing what it is claiming, which is worse than not rendering it.
    42	 *
    43	 * @param {Object} report - Candidate report object.
    44	 * @returns {string[]} Provenance problems; empty when the report is clean or ungated.
    45	 */
    46	function validateProvenance(report) {
    47	  const problems = [];
    48	  const excluded = Array.isArray(report && report.excludedRows) ? report.excludedRows : [];
    49	  const rows = Array.isArray(report && report.scenarioRows) ? report.scenarioRows : [];
    50	  const gatedRows = rows.filter((row) => row && row.errorClass != null);
    51	  if (excluded.length === 0 && gatedRows.length === 0) return problems;
    52	
    53	  if (!report || !report.targetSkill || !report.targetSkill.root) {
    54	    problems.push('missing provenance: targetSkill.root (skill root)');
    55	  }
    56	  if (!report.topologyDigest) {
    57	    problems.push('missing provenance: topologyDigest (manifest digest)');
    58	  }
    59	  for (const row of [...excluded, ...gatedRows]) {
    60	    if (!row.scenarioId) problems.push('missing provenance: a gated/excluded row has no scenarioId');
    61	  }
    62	  return problems;
    63	}
    64	
    65	// ─────────────────────────────────────────────────────────────────────────────
    66	// 3. CORE LOGIC
    67	// ─────────────────────────────────────────────────────────────────────────────
    68	
    69	/**
    70	 * Render the human-readable report.md from a machine report object.
    71	 * @param {Object} report - Parsed report.json object (scores, funnel, scenarios, etc.).
    72	 * @returns {string} Markdown document rendered deterministically from the report.
    73	 */
    74	function renderReport(report) {
    75	  const provenanceProblems = validateProvenance(report);
    76	  if (provenanceProblems.length) {
    77	    throw new Error(`build-report: fail-closed on missing provenance — ${provenanceProblems.join('; ')}`);
    78	  }
    79	  const r = report;
    80	  const lines = [];
    81	  lines.push(`# Skill Benchmark Report — ${r.targetSkill ? r.targetSkill.id : 'unknown'}`);
    82	  lines.push('');
    83	  lines.push(`> Rendered from report.json (do not hand-edit). Scoring: \`${r.scoringMethod}\` · trace mode: \`${r.traceMode}\`.`);
    84	  lines.push('');
    85	  lines.push(`**Verdict: ${r.verdict}**${r.aggregateScore != null ? ` · aggregate ${r.aggregateScore}/100` : ''}`);
    86	  if (r.gate && r.gate.gateFailed) lines.push(`\n⚠ **${r.gate.reason}** — verdict capped regardless of weighted score.`);
    87	  lines.push('');
    88	
    89	  if (r.coverage) {
    90	    const c = r.coverage;
    91	    lines.push('## Coverage');
    92	    lines.push('');
    93	    lines.push(`- Scored (text executors): **${c.scored}** · routed out to browser harness: **${c.routedOut}**`);
    94	    lines.push(`- By class — routing: ${c.routing} · advisor: ${c.advisor} · browser: ${c.browser}`);
    95	    if (c.holdout || c.negative) {
    96	      lines.push(`- By stage — holdout: ${c.holdout || 0} · negative (suppression): ${c.negative || 0}`);
    97	    }
    98	    lines.push('');
    99	  }
   100	
   101	  if (r.generalization) {
   102	    const g = r.generalization;
   103	    lines.push('## Generalization (fitted vs holdout)');
   104	    lines.push('');
   105	    if (!g.holdoutCount) {
   106	      lines.push(`- Fitted aggregate: **${g.fittedScore != null ? `${g.fittedScore}/100` : '—'}** · holdout: _none declared_ · negatives: ${g.negativeCount}`);
   107	    } else {
   108	      const gapSign = g.generalizationGap >= 0 ? '+' : '';
   109	      lines.push(`- Fitted (${g.fittedCount}): **${g.fittedScore}/100** · Holdout (${g.holdoutCount}): **${g.holdoutScore}/100** · Gap: **${gapSign}${g.generalizationGap}**`);
   110	      lines.push(`- Negatives (suppression): ${g.negativeCount}`);
   111	    }
   112	    lines.push(`- _${g.note}_`);
   113	    lines.push('');
   114	  }
   115	
   116	  lines.push('## Dimension scores');
   117	  lines.push('');
   118	  lines.push('| Dimension | Weight | Score |');
   119	  lines.push('| --------- | ------ | ----- |');
   120	  const d = r.dimensionScores || {};
   121	  lines.push(dimLine('D1 inter (advisor)', d.D1inter));
   122	  lines.push(dimLine('D1 intra (router)', d.D1intra));
   123	  lines.push(dimLine('D2 discovery', d.D2));
   124	  lines.push(dimLine('D3 efficiency', d.D3));
   125	  lines.push(dimLine('D4 usefulness', d.D4));
   126	  lines.push(dimLine('D5 connectivity', d.D5));
   127	  if (r.unscoredDimensions && r.unscoredDimensions.length) {
   128	    lines.push('');
   129	    lines.push(`_Unscored in this run (need live mode): ${r.unscoredDimensions.join(', ')}._`);
   130	  }
   131	  if (r.excludedDimensions && r.excludedDimensions.length) {
   132	    lines.push('');
   133	    const reasons = r.excludedDimensions.map((k) => {
   134	      const dim = (r.dimensionScores || {})[k] || {};
   135	      const owner = dim.delegatedMeasure && dim.delegatedMeasure.targetSkill;
   136	      return `${k} — ${dim.reason || 'excluded by design'}${owner ? ` (measured via ${owner})` : ''}`;
   137	    });
   138	    lines.push(`_Excluded by design (structurally N/A, not a gap): ${reasons.join('; ')}._`);
   139	  }
   140	  lines.push('');
   141	
   142	  if (r.advisorySignals) {
   143	    const a = r.advisorySignals;
   144	    const fmt = (s) => (s && typeof s.score === 'number' ? `${s.score}/100` : `_${(s && s.status) || 'unscored'}_`);
   145	    lines.push('### Advisory signals (NOT in the weighted aggregate)');
   146	    lines.push('');
   147	    if (a.D4_task_outcome) lines.push(`- **D4 task-outcome** — routine-task usefulness (skill-on vs off), separate from D4 hallucination: ${fmt(a.D4_task_outcome)}`);
   148	    if (a.assetRecall) lines.push(`- **Asset support recall** — deferred \`assets/*\` gold (router defers these on demand): ${fmt(a.assetRecall)}`);
   149	    lines.push('');
   150	  }
   151	
   152	  if (r.routeGold) {
   153	    const g = r.routeGold;
   154	    lines.push('## Route gold (hard lane)');
   155	    lines.push('');
   156	    lines.push(`- Gate: **${g.enabled ? 'ENFORCED' : 'not enforced'}** (flag \`${g.mode}\`) · rows scored: **${g.rows}** · matches: **${g.matches}** · violations: **${g.violations}** (gold parse failures: ${g.parseFailures})`);
   157	    if (g.failed) lines.push('- ⚠ **Route-gold violation(s) fail this run** — a route mismatch cannot remain a PASS while the gate is on.');
   158	    if (g.details && g.details.length) {
   159	      lines.push('');
   160	      lines.push('| Scenario | Intent | Resources | Expected | Observed |');
   161	      lines.push('| -------- | ------ | --------- | -------- | -------- |');
   162	      const cell = (v) => (Array.isArray(v) ? (v.length ? v.join('<br>') : '_empty set_') : (v == null ? '—' : String(v)));
   163	      for (const d of g.details) {
   164	        if (d.reason === 'gold-parse-failure') {
   165	          lines.push(`| ${d.scenarioId || '—'} | — | — | _gold parse failure_ | ${String(d.detail || '').replace(/\|/g, '\\|')} |`);
   166	          continue;
   167	        }
   168	        const expected = `intent: ${cell(d.expectedIntents)}<br>resources: ${cell(d.expectedResources)}`;
   169	        const observed = `intent: ${cell(d.observedIntents)}<br>resources: ${cell(d.observedResources)}`;
   170	        lines.push(`| ${d.scenarioId || '—'} | ${d.intentOk === false ? 'MISMATCH' : 'ok'} | ${d.resourceOk === false ? 'MISMATCH' : 'ok'} | ${expected.replace(/\|/g, '\\|')} | ${observed.replace(/\|/g, '\\|')} |`);
   171	      }
   172	    }
   173	    lines.push('');
   174	  }
   175	
   176	  lines.push('## Funnel');
   177	  lines.push('');
   178	  for (const [stage, count] of Object.entries(r.funnel || {})) {
   179	    lines.push(`- ${stage}: ${count}`);
   180	  }
   181	  if (r.headlineBottleneck) lines.push(`\n**Headline bottleneck: ${r.headlineBottleneck}**`);
   182	  lines.push('');
   183	
   184	  lines.push('## Ranked bottlenecks');
   185	  lines.push('');
   186	  const bn = r.bottlenecks || [];
   187	  if (!bn.length) lines.push('_None._');
   188	  else {
   189	    lines.push('| Severity | Class | Locus | Finding |');
   190	    lines.push('| -------- | ----- | ----- | ------- |');
   191	    for (const b of bn) {
   192	      lines.push(`| ${b.severity || '—'} | ${b.class || '—'} | ${b.locus || b.stage || '—'} | ${(b.detail || '').replace(/\|/g, '\\|')} |`);
   193	    }
   194	  }
   195	  lines.push('');
   196	
   197	  lines.push('## Scenarios');
   198	  lines.push('');
   199	  const rows = r.scenarioRows || [];
   200	  if (!rows.length) lines.push('_No scenarios._');
   201	  else {
   202	    lines.push('| Scenario | Class | Stage | Score | First failing stage |');
   203	    lines.push('| -------- | ----- | ----- | ----- | ------------------- |');
   204	    for (const s of rows) {
   205	      const score = s.routedOut ? '_routed-out_' : (typeof s.modeAScore === 'number' ? `${s.modeAScore}/100` : '—');
   206	      const failStage = s.routedOut ? (s.reason || 'browser harness') : (s.firstFailingStage || 'passed');
   207	      const benchStage = s.stage || 'routing';
   208	      lines.push(`| ${s.scenarioId} | ${s.classKind || s.tier || '—'} | ${benchStage} | ${score} | ${String(failStage).replace(/\|/g, '\\|')} |`);
   209	    }
   210	  }
   211	  lines.push('');
   212	
   213	  if (r.excludedRows && r.excludedRows.length) {
   214	    lines.push('## Excluded (fixture/oracle faults — not scored)');
   215	    lines.push('');
   216	    lines.push('_Excluded from every denominator above rather than counted as zero recall — a bad oracle, not a routing miss._');
   217	    lines.push('');
   218	    lines.push('| Scenario | Error class | Problems |');
   219	    lines.push('| -------- | ----------- | -------- |');
   220	    for (const e of r.excludedRows) {
   221	      lines.push(`| ${e.scenarioId || '—'} | ${e.errorClass || '—'} | ${(e.problems || []).join('; ').replace(/\|/g, '\\|')} |`);
   222	    }
   223	    lines.push('');
   224	  }
   225	
   226	  if (r.divergence && r.divergence.length) {
   227	    lines.push('## A↔B divergence (router vs live)');
   228	    lines.push('');
   229	    lines.push('| Scenario | Surface agree | Router-only refs | Live-only refs | Severity |');
   230	    lines.push('| -------- | ------------- | ---------------- | -------------- | -------- |');
   231	    for (const d of r.divergence) {
   232	      lines.push(`| ${d.scenarioId} | ${d.surfaceAgree == null ? '—' : d.surfaceAgree} | ${d.resourceDelta.onlyRouter.length} | ${d.resourceDelta.onlyLive.length} | ${d.severity} |`);
   233	    }
   234	    lines.push('');
   235	  }
   236	
   237	  if (r.lintFindings && r.lintFindings.length) {
   238	    lines.push('## Contamination findings (router mode — drift, not failures)');
   239	    lines.push('');
   240	    lines.push('_Playbook prompts intentionally carry trigger words; these are reported as drift signals, not scenario failures._');
   241	    for (const f of r.lintFindings) {
   242	      lines.push(`- ${f.scenarioId}: ${(f.leaks || []).slice(0, 6).join(', ')}`);
   243	    }
   244	    lines.push('');
   245	  }
   246	
   247	  lines.push('## Methodology / caveats');
   248	  lines.push('');
   249	  lines.push(`- ${r.runQuality ? r.runQuality.note : 'Mode A deterministic router-replay.'}`);
   250	  lines.push(`- Scenario count: ${r.runQuality ? r.runQuality.scenarioCount : (rows.length)}.`);
   251	  lines.push('');
   252	  return lines.join('\n');
   253	}
