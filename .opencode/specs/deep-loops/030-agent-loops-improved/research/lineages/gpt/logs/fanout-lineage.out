{"type":"tool_use","timestamp":1782890326896,"sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","part":{"type":"tool","tool":"read","callID":"call_qiWTxu3eLNTo7MF84f2QrZU5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","offset":254,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs</path>\n<type>file</type>\n<content>\n254: function markOrphanedLineages(ledgerPath, options = {}) {\n255:   const orphans = detectOrphanedLineages(readLedgerRecords(ledgerPath));\n256:   if (!orphans.length) {\n257:     return [];\n258:   }\n259:   const now = typeof options.now === 'function' ? options.now : () => new Date();\n260:   for (const orphan of orphans) {\n261:     appendStatusLedger(ledgerPath, {\n262:       event: 'orphan_requeued',\n263:       label: orphan.label,\n264:       index: orphan.index,\n265:       started_at_iso: orphan.started_at_iso,\n266:       at: normalizeTimestamp(now()),\n267:       status: 'requeued',\n268:     });\n269:   }\n270:   return orphans;\n271: }\n272: \n273: // ─────────────────────────────────────────────────────────────────────────────\n274: // 4. CORE LOGIC\n275: // ─────────────────────────────────────────────────────────────────────────────\n276: \n277: /**\n278:  * Run a single pool item through the worker and capture its result or error.\n279:  *\n280:  * Never throws: a worker rejection is captured as a `rejected` result so one\n281:  * failing lineage cannot sink the whole pool (mirrors council `settleSeat`).\n282:  *\n283:  * @param {Object} params - Settlement parameters.\n284:  * @param {*} params.item - The work item (e.g. a lineage descriptor).\n285:  * @param {number} params.index - Zero-based item index (preserves order).\n286:  * @param {Function} params.worker - Async worker: (item, { index, signal? }) => output.\n287:  * @param {Function} params.now - Callable returning a Date or ISO timestamp.\n288:  * @param {Function} [params.onEvent] - Optional callback for ledger events.\n289:  * @param {AbortSignal} [params.abortSignal] - Optional per-attempt abort signal.\n290:  * @param {number} [params.attempt] - One-based attempt number.\n291:  * @param {boolean} [params.emitSettledEvent] - False when the caller emits terminal events.\n292:  * @param {string} [params.startedAtIso] - Stable started timestamp for synthetic settlement.\n293:  * @param {number} [params.startedAtMs] - Stable started clock for duration accounting.\n294:  * @returns {Promise<Object>} Result with label, status, timing, output|error.\n295:  */\n296: async function settleItem({\n297:   item,\n298:   index,\n299:   worker,\n300:   now,\n301:   onEvent,\n302:   attempt: rawAttempt,\n303:   emitSettledEvent: shouldEmitSettledEvent,\n304:   abortSignal,\n305:   startedAtIso: rawStartedAtIso,\n306:   startedAtMs: rawStartedAtMs,\n307: }) {\n308:   const attempt = Number.isFinite(Number(rawAttempt)) ? Number(rawAttempt) : 1;\n309:   const emitSettledEvent = shouldEmitSettledEvent !== false;\n310:   const label = labelFor(item, index);\n311:   const startedAtIso = normalizeTimestamp(rawStartedAtIso ?? now());\n312:   const startedAtMs = Number.isFinite(Number(rawStartedAtMs)) ? Number(rawStartedAtMs) : Date.now();\n313: \n314:   if (typeof onEvent === 'function') {\n315:     onEvent({ event: 'started', label, index, attempt, at: startedAtIso });\n316:   }\n317: \n318:   try {\n319:     const workerContext = abortSignal ? { index, signal: abortSignal } : { index };\n320:     const output = await worker(item, workerContext);\n321:     const completedAtIso = normalizeTimestamp(now());\n322:     const durationMs = Math.max(0, Date.now() - startedAtMs);\n323:     if (emitSettledEvent && typeof onEvent === 'function') {\n324:       onEvent({ event: 'completed', label, index, attempt, at: completedAtIso, duration_ms: durationMs });\n325:     }\n326:     return {\n327:       label,\n328:       status: 'fulfilled',\n329:       attempt,\n330:       started_at_iso: startedAtIso,\n331:       completed_at_iso: completedAtIso,\n332:       duration_ms: durationMs,\n333:       output,\n334:     };\n335:   } catch (error) {\n336:     const completedAtIso = normalizeTimestamp(now());\n337:     const durationMs = Math.max(0, Date.now() - startedAtMs);\n338:     const normalizedError = normalizeError(error);\n339:     if (emitSettledEvent && typeof onEvent === 'function') {\n340:       onEvent({ event: 'failed', label, index, attempt, at: completedAtIso, duration_ms: durationMs, error: normalizedError });\n341:     }\n342:     return {\n343:       label,\n344:       status: 'rejected',\n345:       attempt,\n346:       started_at_iso: startedAtIso,\n347:       completed_at_iso: completedAtIso,\n348:       duration_ms: durationMs,\n349:       error: normalizedError,\n350:     };\n351:   }\n352: }\n353: \n354: /**\n355:  * Run items through a worker with at most `concurrency` in flight.\n356:  *\n357:  * This is the fan-out generalization of council `dispatchCouncilSeats`: same\n358:  * never-throws per-item settlement and ordered results, plus a concurrency cap\n359:  * so a large lineage set runs K-at-a-time (the proven `xargs -P K` shape).\n360:  *\n361:  * @param {Object} options - Pool configuration.\n362:  * @param {Array} options.items - Work items (each ideally has a `label`).\n363:  * @param {number} options.concurrency - Max items in flight (clamped to >= 1).\n364:  * @param {Function} options.worker - Async worker: (item, { index, signal? }) => output.\n365:  * @param {Function} [options.now] - Callable returning a Date/ISO timestamp.\n366:  * @param {Function} [options.onEvent] - Optional ledger-event callback.\n367:  * @param {string} [options.lagCeilingAction] - Optional `abort-requeue` action.\n368:  * @returns {Promise<Object>} { results: [...ordered], summary: { total,\n369:  *   succeeded, failed, all_failed } }.\n370:  * @throws {TypeError} If items is not an array or worker is not a function.\n371:  */\n372: function runCappedPool(options) {\n373:   if (!isRecord(options)) {\n374:     throw new TypeError('runCappedPool options must be an object');\n375:   }\n376:   const { items, worker } = options;\n377:   if (!Array.isArray(items)) {\n378:     throw new TypeError('items must be an array');\n379:   }\n380:   if (typeof worker !== 'function') {\n381:     throw new TypeError('worker must be a function');\n382:   }\n383: \n384:   const concurrency = normalizeConcurrency(options.concurrency);\n385:   const now = typeof options.now === 'function' ? options.now : () => new Date();\n386:   const onEvent = typeof options.onEvent === 'function' ? options.onEvent : undefined;\n387:   const maxRetries = normalizeMaxRetries(options.maxRetries);\n388:   const retryCounts = normalizeRetryCountMap(options.initialRetryCounts);\n389:   const results = new Array(items.length);\n390:   const queue = items.map((_item, index) => index);\n391:   const lagCeilingMs = normalizeNonNegativeDuration(options.lagCeilingMs ?? options.lag_ceiling_ms ?? options.lag_ceiling);\n392:   const lagCeilingAction = normalizeLagCeilingAction(options.lagCeilingAction ?? options.lag_ceiling_action);\n393:   const shouldAbortStalledLineages = lagCeilingAction === LAG_CEILING_ACTION_ABORT_REQUEUE;\n394:   if (shouldAbortStalledLineages && lagCeilingMs <= 0) {\n395:     throw new TypeError('lagCeilingAction \"abort-requeue\" requires lagCeilingMs > 0');\n396:   }\n397:   let lagCeilingTimer = null;\n398:   let lagCeilingExceeded = false;\n399:   let nextAttemptId = 1;\n400: \n401:   // STALL DETECTOR (not queue backpressure). The lag metric is the time since the pool\n402:   // last made progress — i.e. since the last item settled (or pool start if nothing has\n403:   // settled yet) — measured ONLY while work is still pending. On a healthy fan-out wider\n404:   // than its concurrency, items settle regularly, so each completion resets this clock and\n405:   // the gap stays small: normal second-wave backpressure does NOT trip the ceiling. The\n406:   // gap only grows past the ceiling when NOTHING settles while work waits — a genuinely\n407:   // stalled tail (a worker hung holding a slot). This deliberately replaces the prior\n408:   // time-since-queued-at-pool-start metric, which conflated normal backpressure with a\n409:   // stall and false-fired on every width>concurrency pool.\n410:   let lastProgressAtMs = Date.now();\n411:   const markProgress = () => {\n412:     lastProgressAtMs = Date.now();\n413:   };\n414: \n415:   const oldestPendingLagMs = () => {\n416:     // A stall is only meaningful while there is still queued work waiting for a slot.\n417:     if (lagCeilingMs <= 0 || queue.length === 0) return undefined;\n418:     return Date.now() - lastProgressAtMs;\n419:   };\n420: \n421:   const buildCurrentGauges = () => {\n422:     const settled = results.filter(Boolean).length;\n423:     const failed = results.filter((result) => result && result.status === 'rejected').length;\n424:     return buildPoolGauges({\n425:       total: items.length,\n426:       settled,\n427:       pending: queue.length,\n428:       failed,\n429:       oldestPendingLagMs: oldestPendingLagMs(),\n430:     });\n431:   };\n432: \n433:   return new Promise((resolve) => {\n434:     if (items.length === 0) {\n435:       resolve(buildPoolSummary(results));\n436:       return;\n437:     }\n438: \n439:     let active = 0;\n440:     let resolved = false;\n441:     const activeAttempts = new Map();\n442:     const clearLagCeilingTimer = () => {\n443:       if (lagCeilingTimer) {\n444:         clearTimeout(lagCeilingTimer);\n445:         lagCeilingTimer = null;\n446:       }\n447:     };\n448: \n449:     const emitLagCeilingWarning = (gauges = buildCurrentGauges()) => {\n450:       if (!onEvent || lagCeilingMs <= 0 || lagCeilingExceeded || queue.length === 0) return;\n451:       if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return;\n452:       lagCeilingExceeded = true;\n453:       onEvent({\n454:         event: 'lag_ceiling_exceeded',\n455:         at: normalizeTimestamp(now()),\n456:         severity: 'warning',\n457:         ...(lagCeilingAction ? { action: lagCeilingAction } : {}),\n458:         // The lag metric is time-since-last-progress while work is pending: a genuine\n459:         // stall signal, not queue backpressure. oldest_pending_lag_ms keeps its name for\n460:         // ledger shape compatibility but now carries the stall duration.\n461:         metric: 'time_since_last_completion',\n462:         lag_ceiling_ms: lagCeilingMs,\n463:         oldest_pending_lag_ms: gauges.oldest_pending_lag_ms,\n464:         gauges,\n465:       });\n466:     };\n467: \n468:     const scheduleLagCeilingCheck = () => {\n469:       clearLagCeilingTimer();\n470:       if (lagCeilingMs <= 0 || queue.length === 0) return;\n471:       if (!onEvent && !shouldAbortStalledLineages) return;\n472:       if (!shouldAbortStalledLineages && lagCeilingExceeded) return;\n473:       const lag = oldestPendingLagMs() ?? 0;\n474:       const delayMs = Math.max(0, lagCeilingMs - lag);\n475:       lagCeilingTimer = setTimeout(() => {\n476:         lagCeilingTimer = null;\n477:         handleLagCeilingExceeded();\n478:         if (!resolved) {\n479:           scheduleLagCeilingCheck();\n480:         }\n481:       }, delayMs);\n482:       lagCeilingTimer.unref?.();\n483:     };\n484: \n485:     const emitEvent = onEvent\n486:       ? (event) => {\n487:           onEvent({\n488:             ...event,\n489:             gauges: buildCurrentGauges(),\n490:           });\n491:           emitLagCeilingWarning();\n492:         }\n493:       : undefined;\n494: \n495:     const buildSyntheticAbortResult = (activeAttempt, gauges, error) => {\n496:       const lagMs = gauges.oldest_pending_lag_ms ?? lagCeilingMs;\n497:       const completedAtIso = normalizeTimestamp(now());\n498:       const durationMs = Math.max(0, Date.now() - activeAttempt.startedAtMs);\n499:       return {\n500:         label: activeAttempt.label,\n501:         status: 'rejected',\n502:         index: activeAttempt.index,\n503:         attempt: activeAttempt.attempt,\n504:         started_at_iso: activeAttempt.startedAtIso,\n505:         completed_at_iso: completedAtIso,\n506:         duration_ms: durationMs,\n507:         error: {\n508:           ...normalizeError(error),\n509:           aborted: true,\n510:           abort_reason: 'lag_ceiling_exceeded',\n511:         },\n512:       };\n513:     };\n\n(Showing lines 254-513 of 767. Use offset=514 to continue.)\n</content>","metadata":{"preview":"function markOrphanedLineages(ledgerPath, options = {}) {\n  const orphans = detectOrphanedLineages(readLedgerRecords(ledgerPath));\n  if (!orphans.length) {\n    return [];\n  }\n  const now = typeof options.now === 'function' ? options.now : () => new Date();\n  for (const orphan of orphans) {\n    appendStatusLedger(ledgerPath, {\n      event: 'orphan_requeued',\n      label: orphan.label,\n      index: orphan.index,\n      started_at_iso: orphan.started_at_iso,\n      at: normalizeTimestamp(now()),\n      status: 'requeued',\n    });\n  }\n  return orphans;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","text":"function markOrphanedLineages(ledgerPath, options = {}) {\n  const orphans = detectOrphanedLineages(readLedgerRecords(ledgerPath));\n  if (!orphans.length) {\n    return [];\n  }\n  const now = typeof options.now === 'function' ? options.now : () => new Date();\n  for (const orphan of orphans) {\n    appendStatusLedger(ledgerPath, {\n      event: 'orphan_requeued',\n      label: orphan.label,\n      index: orphan.index,\n      started_at_iso: orphan.started_at_iso,\n      at: normalizeTimestamp(now()),\n      status: 'requeued',\n    });\n  }\n  return orphans;\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Run a single pool item through the worker and capture its result or error.\n *\n * Never throws: a worker rejection is captured as a `rejected` result so one\n * failing lineage cannot sink the whole pool (mirrors council `settleSeat`).\n *\n * @param {Object} params - Settlement parameters.\n * @param {*} params.item - The work item (e.g. a lineage descriptor).\n * @param {number} params.index - Zero-based item index (preserves order).\n * @param {Function} params.worker - Async worker: (item, { index, signal? }) => output.\n * @param {Function} params.now - Callable returning a Date or ISO timestamp.\n * @param {Function} [params.onEvent] - Optional callback for ledger events.\n * @param {AbortSignal} [params.abortSignal] - Optional per-attempt abort signal.\n * @param {number} [params.attempt] - One-based attempt number.\n * @param {boolean} [params.emitSettledEvent] - False when the caller emits terminal events.\n * @param {string} [params.startedAtIso] - Stable started timestamp for synthetic settlement.\n * @param {number} [params.startedAtMs] - Stable started clock for duration accounting.\n * @returns {Promise<Object>} Result with label, status, timing, output|error.\n */\nasync function settleItem({\n  item,\n  index,\n  worker,\n  now,\n  onEvent,\n  attempt: rawAttempt,\n  emitSettledEvent: shouldEmitSettledEvent,\n  abortSignal,\n  startedAtIso: rawStartedAtIso,\n  startedAtMs: rawStartedAtMs,\n}) {\n  const attempt = Number.isFinite(Number(rawAttempt)) ? Number(rawAttempt) : 1;\n  const emitSettledEvent = shouldEmitSettledEvent !== false;\n  const label = labelFor(item, index);\n  const startedAtIso = normalizeTimestamp(rawStartedAtIso ?? now());\n  const startedAtMs = Number.isFinite(Number(rawStartedAtMs)) ? Number(rawStartedAtMs) : Date.now();\n\n  if (typeof onEvent === 'function') {\n    onEvent({ event: 'started', label, index, attempt, at: startedAtIso });\n  }\n\n  try {\n    const workerContext = abortSignal ? { index, signal: abortSignal } : { index };\n    const output = await worker(item, workerContext);\n    const completedAtIso = normalizeTimestamp(now());\n    const durationMs = Math.max(0, Date.now() - startedAtMs);\n    if (emitSettledEvent && typeof onEvent === 'function') {\n      onEvent({ event: 'completed', label, index, attempt, at: completedAtIso, duration_ms: durationMs });\n    }\n    return {\n      label,\n      status: 'fulfilled',\n      attempt,\n      started_at_iso: startedAtIso,\n      completed_at_iso: completedAtIso,\n      duration_ms: durationMs,\n      output,\n    };\n  } catch (error) {\n    const completedAtIso = normalizeTimestamp(now());\n    const durationMs = Math.max(0, Date.now() - startedAtMs);\n    const normalizedError = normalizeError(error);\n    if (emitSettledEvent && typeof onEvent === 'function') {\n      onEvent({ event: 'failed', label, index, attempt, at: completedAtIso, duration_ms: durationMs, error: normalizedError });\n    }\n    return {\n      label,\n      status: 'rejected',\n      attempt,\n      started_at_iso: startedAtIso,\n      completed_at_iso: completedAtIso,\n      duration_ms: durationMs,\n      error: normalizedError,\n    };\n  }\n}\n\n/**\n * Run items through a worker with at most `concurrency` in flight.\n *\n * This is the fan-out generalization of council `dispatchCouncilSeats`: same\n * never-throws per-item settlement and ordered results, plus a concurrency cap\n * so a large lineage set runs K-at-a-time (the proven `xargs -P K` shape).\n *\n * @param {Object} options - Pool configuration.\n * @param {Array} options.items - Work items (each ideally has a `label`).\n * @param {number} options.concurrency - Max items in flight (clamped to >= 1).\n * @param {Function} options.worker - Async worker: (item, { index, signal? }) => output.\n * @param {Function} [options.now] - Callable returning a Date/ISO timestamp.\n * @param {Function} [options.onEvent] - Optional ledger-event callback.\n * @param {string} [options.lagCeilingAction] - Optional `abort-requeue` action.\n * @returns {Promise<Object>} { results: [...ordered], summary: { total,\n *   succeeded, failed, all_failed } }.\n * @throws {TypeError} If items is not an array or worker is not a function.\n */\nfunction runCappedPool(options) {\n  if (!isRecord(options)) {\n    throw new TypeError('runCappedPool options must be an object');\n  }\n  const { items, worker } = options;\n  if (!Array.isArray(items)) {\n    throw new TypeError('items must be an array');\n  }\n  if (typeof worker !== 'function') {\n    throw new TypeError('worker must be a function');\n  }\n\n  const concurrency = normalizeConcurrency(options.concurrency);\n  const now = typeof options.now === 'function' ? options.now : () => new Date();\n  const onEvent = typeof options.onEvent === 'function' ? options.onEvent : undefined;\n  const maxRetries = normalizeMaxRetries(options.maxRetries);\n  const retryCounts = normalizeRetryCountMap(options.initialRetryCounts);\n  const results = new Array(items.length);\n  const queue = items.map((_item, index) => index);\n  const lagCeilingMs = normalizeNonNegativeDuration(options.lagCeilingMs ?? options.lag_ceiling_ms ?? options.lag_ceiling);\n  const lagCeilingAction = normalizeLagCeilingAction(options.lagCeilingAction ?? options.lag_ceiling_action);\n  const shouldAbortStalledLineages = lagCeilingAction === LAG_CEILING_ACTION_ABORT_REQUEUE;\n  if (shouldAbortStalledLineages && lagCeilingMs <= 0) {\n    throw new TypeError('lagCeilingAction \"abort-requeue\" requires lagCeilingMs > 0');\n  }\n  let lagCeilingTimer = null;\n  let lagCeilingExceeded = false;\n  let nextAttemptId = 1;\n\n  // STALL DETECTOR (not queue backpressure). The lag metric is the time since the pool\n  // last made progress — i.e. since the last item settled (or pool start if nothing has\n  // settled yet) — measured ONLY while work is still pending. On a healthy fan-out wider\n  // than its concurrency, items settle regularly, so each completion resets this clock and\n  // the gap stays small: normal second-wave backpressure does NOT trip the ceiling. The\n  // gap only grows past the ceiling when NOTHING settles while work waits — a genuinely\n  // stalled tail (a worker hung holding a slot). This deliberately replaces the prior\n  // time-since-queued-at-pool-start metric, which conflated normal backpressure with a\n  // stall and false-fired on every width>concurrency pool.\n  let lastProgressAtMs = Date.now();\n  const markProgress = () => {\n    lastProgressAtMs = Date.now();\n  };\n\n  const oldestPendingLagMs = () => {\n    // A stall is only meaningful while there is still queued work waiting for a slot.\n    if (lagCeilingMs <= 0 || queue.length === 0) return undefined;\n    return Date.now() - lastProgressAtMs;\n  };\n\n  const buildCurrentGauges = () => {\n    const settled = results.filter(Boolean).length;\n    const failed = results.filter((result) => result && result.status === 'rejected').length;\n    return buildPoolGauges({\n      total: items.length,\n      settled,\n      pending: queue.length,\n      failed,\n      oldestPendingLagMs: oldestPendingLagMs(),\n    });\n  };\n\n  return new Promise((resolve) => {\n    if (items.length === 0) {\n      resolve(buildPoolSummary(results));\n      return;\n    }\n\n    let active = 0;\n    let resolved = false;\n    const activeAttempts = new Map();\n    const clearLagCeilingTimer = () => {\n      if (lagCeilingTimer) {\n        clearTimeout(lagCeilingTimer);\n        lagCeilingTimer = null;\n      }\n    };\n\n    const emitLagCeilingWarning = (gauges = buildCurrentGauges()) => {\n      if (!onEvent || lagCeilingMs <= 0 || lagCeilingExceeded || queue.length === 0) return;\n      if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return;\n      lagCeilingExceeded = true;\n      onEvent({\n        event: 'lag_ceiling_exceeded',\n        at: normalizeTimestamp(now()),\n        severity: 'warning',\n        ...(lagCeilingAction ? { action: lagCeilingAction } : {}),\n        // The lag metric is time-since-last-progress while work is pending: a genuine\n        // stall signal, not queue backpressure. oldest_pending_lag_ms keeps its name for\n        // ledger shape compatibility but now carries the stall duration.\n        metric: 'time_since_last_completion',\n        lag_ceiling_ms: lagCeilingMs,\n        oldest_pending_lag_ms: gauges.oldest_pending_lag_ms,\n        gauges,\n      });\n    };\n\n    const scheduleLagCeilingCheck = () => {\n      clearLagCeilingTimer();\n      if (lagCeilingMs <= 0 || queue.length === 0) return;\n      if (!onEvent && !shouldAbortStalledLineages) return;\n      if (!shouldAbortStalledLineages && lagCeilingExceeded) return;\n      const lag = oldestPendingLagMs() ?? 0;\n      const delayMs = Math.max(0, lagCeilingMs - lag);\n      lagCeilingTimer = setTimeout(() => {\n        lagCeilingTimer = null;\n        handleLagCeilingExceeded();\n        if (!resolved) {\n          scheduleLagCeilingCheck();\n        }\n      }, delayMs);\n      lagCeilingTimer.unref?.();\n    };\n\n    const emitEvent = onEvent\n      ? (event) => {\n          onEvent({\n            ...event,\n            gauges: buildCurrentGauges(),\n          });\n          emitLagCeilingWarning();\n        }\n      : undefined;\n\n    const buildSyntheticAbortResult = (activeAttempt, gauges, error) => {\n      const lagMs = gauges.oldest_pending_lag_ms ?? lagCeilingMs;\n      const completedAtIso = normalizeTimestamp(now());\n      const durationMs = Math.max(0, Date.now() - activeAttempt.startedAtMs);\n      return {\n        label: activeAttempt.label,\n        status: 'rejected',\n        index: activeAttempt.index,\n        attempt: activeAttempt.attempt,\n        started_at_iso: activeAttempt.startedAtIso,\n        completed_at_iso: completedAtIso,\n        duration_ms: durationMs,\n        error: {\n          ...normalizeError(error),\n          aborted: true,\n          abort_reason: 'lag_ceiling_exceeded',\n        },\n      };\n    };","lineStart":254,"lineEnd":513,"totalLines":767,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","time":{"start":1782890326889,"end":1782890326894}},"metadata":{"openai":{"itemId":"fc_01aa19daa1438d1c016a44bf56cb4081918b8286a1b647a7ee"}},"id":"prt_f1c8b6b66001mZeQ9RIbId9b7J","sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","messageID":"msg_f1c8b2d81001ICqiBeckfmREOg"}}
{"type":"tool_use","timestamp":1782890326948,"sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","part":{"type":"tool","tool":"read","callID":"call_BAf6kcugPBF1Icce6rNa1RFG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","offset":514,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs</path>\n<type>file</type>\n<content>\n514: \n515:     const emitSettledResult = (result, isTerminal) => {\n516:       if (!emitEvent) return;\n517:       const baseEvent = {\n518:         event: result.status === 'fulfilled' ? 'completed' : 'failed',\n519:         label: result.label,\n520:         index: result.index,\n521:         attempt: result.attempt,\n522:         at: result.completed_at_iso,\n523:         duration_ms: result.duration_ms,\n524:         terminal: isTerminal,\n525:       };\n526:       if (result.status === 'rejected') {\n527:         emitEvent({ ...baseEvent, error: result.error });\n528:       } else {\n529:         emitEvent(baseEvent);\n530:       }\n531:     };\n532: \n533:     const handleSettledResult = (activeAttempt, result) => {\n534:       const { index, label, retryCount } = activeAttempt;\n535:       result.index = index;\n536:       if (result.status === 'fulfilled') {\n537:         result.retry_attempts = retryCount;\n538:         results[index] = result;\n539:         emitSettledResult(result, true);\n540:         return;\n541:       }\n542: \n543:       const canRetry = result.error.retryable === true && retryCount < maxRetries;\n544:       if (canRetry) {\n545:         const nextRetryCount = retryCount + 1;\n546:         retryCounts.set(label, nextRetryCount);\n547:         emitSettledResult(result, false);\n548:         queue.push(index);\n549:         if (emitEvent) {\n550:           emitEvent({\n551:             event: 'retry_scheduled',\n552:             label,\n553:             index,\n554:             at: normalizeTimestamp(now()),\n555:             retry_count: nextRetryCount,\n556:             next_attempt: nextRetryCount + 1,\n557:             max_retries: maxRetries,\n558:             failure_class: result.error.failure_class,\n559:             retry_verdict: result.error.retry_verdict,\n560:           });\n561:         }\n562:         return;\n563:       }\n564: \n565:       result.retry_attempts = retryCount;\n566:       result.retry_exhausted = result.error.retryable === true && retryCount >= maxRetries;\n567:       results[index] = result;\n568:       emitSettledResult(result, true);\n569:     };\n570: \n571:     const buildPoolErrorResult = (activeAttempt, error) => ({\n572:       label: activeAttempt.label,\n573:       status: 'rejected',\n574:       index: activeAttempt.index,\n575:       attempt: activeAttempt.attempt,\n576:       started_at_iso: activeAttempt.startedAtIso,\n577:       completed_at_iso: normalizeTimestamp(now()),\n578:       duration_ms: Math.max(0, Date.now() - activeAttempt.startedAtMs),\n579:       error: normalizeError({ name: 'PoolError', message: String(error) }),\n580:     });\n581: \n582:     const settleActiveAttempt = (activeAttempt, result) => {\n583:       if (activeAttempt.settled) {\n584:         return;\n585:       }\n586:       activeAttempt.settled = true;\n587:       activeAttempts.delete(activeAttempt.id);\n588:       handleSettledResult(activeAttempt, result);\n589:       active -= 1;\n590:       // Every settlement (success, failure, or retry re-queue) is forward progress:\n591:       // reset the stall clock so a healthy pool's steady completions keep the lag\n592:       // metric small and only a true stall (no settlement) lets it grow.\n593:       markProgress();\n594:       scheduleLagCeilingCheck();\n595:       pump();\n596:     };\n597: \n598:     const abortStalledAttempt = (gauges) => {\n599:       if (!shouldAbortStalledLineages || activeAttempts.size === 0 || queue.length === 0) return false;\n600:       if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return false;\n601:       const activeAttempt = activeAttempts.values().next().value;\n602:       if (!activeAttempt || activeAttempt.settled) return false;\n603: \n604:       const error = buildLagCeilingTimeoutError({\n605:         label: activeAttempt.label,\n606:         lagMs: gauges.oldest_pending_lag_ms ?? lagCeilingMs,\n607:         lagCeilingMs,\n608:       });\n609:       const result = buildSyntheticAbortResult(activeAttempt, gauges, error);\n610:       activeAttempt.abortController.abort(error);\n611:       if (onEvent) {\n612:         onEvent({\n613:           event: 'lag_ceiling_abort',\n614:           label: activeAttempt.label,\n615:           index: activeAttempt.index,\n616:           attempt: activeAttempt.attempt,\n617:           at: result.completed_at_iso,\n618:           action: lagCeilingAction,\n619:           lag_ceiling_ms: lagCeilingMs,\n620:           oldest_pending_lag_ms: gauges.oldest_pending_lag_ms,\n621:           gauges: buildCurrentGauges(),\n622:         });\n623:       }\n624:       settleActiveAttempt(activeAttempt, result);\n625:       return true;\n626:     };\n627: \n628:     const handleLagCeilingExceeded = () => {\n629:       if (lagCeilingMs <= 0 || queue.length === 0) return;\n630:       const gauges = buildCurrentGauges();\n631:       if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return;\n632:       emitLagCeilingWarning(gauges);\n633:       abortStalledAttempt(gauges);\n634:     };\n635: \n636:     const pump = () => {\n637:       if (resolved) {\n638:         return;\n639:       }\n640:       if (queue.length === 0 && active === 0) {\n641:         resolved = true;\n642:         clearLagCeilingTimer();\n643:         resolve(buildPoolSummary(results));\n644:         return;\n645:       }\n646:       while (active < concurrency && queue.length > 0) {\n647:         const index = queue.shift();\n648:         const label = labelFor(items[index], index);\n649:         const retryCount = retryCounts.get(label) || 0;\n650:         const attempt = retryCount + 1;\n651:         const startedAtIso = normalizeTimestamp(now());\n652:         const startedAtMs = Date.now();\n653:         const abortController = shouldAbortStalledLineages ? new AbortController() : null;\n654:         const activeAttempt = {\n655:           id: nextAttemptId,\n656:           index,\n657:           label,\n658:           retryCount,\n659:           attempt,\n660:           startedAtIso,\n661:           startedAtMs,\n662:           abortController,\n663:           settled: false,\n664:         };\n665:         nextAttemptId += 1;\n666:         activeAttempts.set(activeAttempt.id, activeAttempt);\n667:         active += 1;\n668:         settleItem({\n669:           item: items[index],\n670:           index,\n671:           worker,\n672:           now,\n673:           onEvent: emitEvent,\n674:           attempt,\n675:           emitSettledEvent: false,\n676:           abortSignal: abortController ? abortController.signal : undefined,\n677:           startedAtIso,\n678:           startedAtMs,\n679:         })\n680:           .then((result) => {\n681:             settleActiveAttempt(activeAttempt, result);\n682:           })\n683:           .catch((error) => {\n684:             // The item settler is meant to capture worker failures; this keeps\n685:             // an unexpected bug in the settler from wedging the whole pool.\n686:             settleActiveAttempt(activeAttempt, buildPoolErrorResult(activeAttempt, error));\n687:           });\n688:       }\n689:       scheduleLagCeilingCheck();\n690:     };\n691: \n692:     pump();\n693:   });\n694: }\n695: \n696: /**\n697:  * Build the ordered-results + summary envelope for a completed pool run.\n698:  *\n699:  * @param {Array<Object>} results - Per-item settlement results (ordered).\n700:  * @returns {Object} { results, summary: { total, succeeded, failed, all_failed } }.\n701:  */\n702: function buildPoolSummary(results) {\n703:   const total = results.length;\n704:   const succeeded = results.filter((result) => result && result.status === 'fulfilled').length;\n705:   const failed = total - succeeded;\n706:   const gauges = buildPoolGauges({ total, settled: total, pending: 0, failed });\n707:   const failureClasses = buildFailureClassRollup(results);\n708:   return {\n709:     results,\n710:     summary: {\n711:       total,\n712:       succeeded,\n713:       failed,\n714:       all_failed: total > 0 && failed === total,\n715:       gauges,\n716:       failure_classes: failureClasses,\n717:     },\n718:   };\n719: }\n720: \n721: // ─────────────────────────────────────────────────────────────────────────────\n722: // 5. STATUS LEDGER\n723: // ─────────────────────────────────────────────────────────────────────────────\n724: \n725: /**\n726:  * Append one JSONL event to the orchestration status ledger.\n727:  *\n728:  * Follows the `orchestration-status.log` ledger pattern: one line per lineage\n729:  * lifecycle event (started / completed / failed / salvaged / converged).\n730:  *\n731:  * @param {string} ledgerPath - Path to the JSONL ledger file.\n732:  * @param {Object} entry - A serializable event object.\n733:  */\n734: function appendStatusLedger(ledgerPath, entry) {\n735:   fs.mkdirSync(path.dirname(ledgerPath), { recursive: true });\n736:   fs.appendFileSync(ledgerPath, `${JSON.stringify(entry)}\\n`);\n737: }\n738: \n739: /**\n740:  * Write the orchestration summary JSON for a completed fan-out run.\n741:  *\n742:  * @param {string} summaryPath - Path to the summary JSON file.\n743:  * @param {Object} summary - Summary payload (e.g. the pool summary plus\n744:  *   salvage counts and per-lineage rollups).\n745:  */\n746: function writeOrchestrationSummary(summaryPath, summary) {\n747:   fs.mkdirSync(path.dirname(summaryPath), { recursive: true });\n748:   fs.writeFileSync(summaryPath, `${JSON.stringify(summary, null, 2)}\\n`);\n749: }\n750: \n751: // ─────────────────────────────────────────────────────────────────────────────\n752: // 6. EXPORTS\n753: // ─────────────────────────────────────────────────────────────────────────────\n754: \n755: module.exports = {\n756:   runCappedPool,\n757:   settleItem,\n758:   buildPoolSummary,\n759:   buildPoolGauges,\n760:   classifyLineageFailure,\n761:   detectOrphanedLineages,\n762:   createWavePlannerInterface,\n763:   markOrphanedLineages,\n764:   readRetryCountsFromLedger,\n765:   appendStatusLedger,\n766:   writeOrchestrationSummary,\n767: };\n\n(End of file - total 767 lines)\n</content>","metadata":{"preview":"\n    const emitSettledResult = (result, isTerminal) => {\n      if (!emitEvent) return;\n      const baseEvent = {\n        event: result.status === 'fulfilled' ? 'completed' : 'failed',\n        label: result.label,\n        index: result.index,\n        attempt: result.attempt,\n        at: result.completed_at_iso,\n        duration_ms: result.duration_ms,\n        terminal: isTerminal,\n      };\n      if (result.status === 'rejected') {\n        emitEvent({ ...baseEvent, error: result.error });\n      } else {\n        emitEvent(baseEvent);\n      }\n    };\n\n    const handleSettledResult = (activeAttempt, result) => {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","text":"\n    const emitSettledResult = (result, isTerminal) => {\n      if (!emitEvent) return;\n      const baseEvent = {\n        event: result.status === 'fulfilled' ? 'completed' : 'failed',\n        label: result.label,\n        index: result.index,\n        attempt: result.attempt,\n        at: result.completed_at_iso,\n        duration_ms: result.duration_ms,\n        terminal: isTerminal,\n      };\n      if (result.status === 'rejected') {\n        emitEvent({ ...baseEvent, error: result.error });\n      } else {\n        emitEvent(baseEvent);\n      }\n    };\n\n    const handleSettledResult = (activeAttempt, result) => {\n      const { index, label, retryCount } = activeAttempt;\n      result.index = index;\n      if (result.status === 'fulfilled') {\n        result.retry_attempts = retryCount;\n        results[index] = result;\n        emitSettledResult(result, true);\n        return;\n      }\n\n      const canRetry = result.error.retryable === true && retryCount < maxRetries;\n      if (canRetry) {\n        const nextRetryCount = retryCount + 1;\n        retryCounts.set(label, nextRetryCount);\n        emitSettledResult(result, false);\n        queue.push(index);\n        if (emitEvent) {\n          emitEvent({\n            event: 'retry_scheduled',\n            label,\n            index,\n            at: normalizeTimestamp(now()),\n            retry_count: nextRetryCount,\n            next_attempt: nextRetryCount + 1,\n            max_retries: maxRetries,\n            failure_class: result.error.failure_class,\n            retry_verdict: result.error.retry_verdict,\n          });\n        }\n        return;\n      }\n\n      result.retry_attempts = retryCount;\n      result.retry_exhausted = result.error.retryable === true && retryCount >= maxRetries;\n      results[index] = result;\n      emitSettledResult(result, true);\n    };\n\n    const buildPoolErrorResult = (activeAttempt, error) => ({\n      label: activeAttempt.label,\n      status: 'rejected',\n      index: activeAttempt.index,\n      attempt: activeAttempt.attempt,\n      started_at_iso: activeAttempt.startedAtIso,\n      completed_at_iso: normalizeTimestamp(now()),\n      duration_ms: Math.max(0, Date.now() - activeAttempt.startedAtMs),\n      error: normalizeError({ name: 'PoolError', message: String(error) }),\n    });\n\n    const settleActiveAttempt = (activeAttempt, result) => {\n      if (activeAttempt.settled) {\n        return;\n      }\n      activeAttempt.settled = true;\n      activeAttempts.delete(activeAttempt.id);\n      handleSettledResult(activeAttempt, result);\n      active -= 1;\n      // Every settlement (success, failure, or retry re-queue) is forward progress:\n      // reset the stall clock so a healthy pool's steady completions keep the lag\n      // metric small and only a true stall (no settlement) lets it grow.\n      markProgress();\n      scheduleLagCeilingCheck();\n      pump();\n    };\n\n    const abortStalledAttempt = (gauges) => {\n      if (!shouldAbortStalledLineages || activeAttempts.size === 0 || queue.length === 0) return false;\n      if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return false;\n      const activeAttempt = activeAttempts.values().next().value;\n      if (!activeAttempt || activeAttempt.settled) return false;\n\n      const error = buildLagCeilingTimeoutError({\n        label: activeAttempt.label,\n        lagMs: gauges.oldest_pending_lag_ms ?? lagCeilingMs,\n        lagCeilingMs,\n      });\n      const result = buildSyntheticAbortResult(activeAttempt, gauges, error);\n      activeAttempt.abortController.abort(error);\n      if (onEvent) {\n        onEvent({\n          event: 'lag_ceiling_abort',\n          label: activeAttempt.label,\n          index: activeAttempt.index,\n          attempt: activeAttempt.attempt,\n          at: result.completed_at_iso,\n          action: lagCeilingAction,\n          lag_ceiling_ms: lagCeilingMs,\n          oldest_pending_lag_ms: gauges.oldest_pending_lag_ms,\n          gauges: buildCurrentGauges(),\n        });\n      }\n      settleActiveAttempt(activeAttempt, result);\n      return true;\n    };\n\n    const handleLagCeilingExceeded = () => {\n      if (lagCeilingMs <= 0 || queue.length === 0) return;\n      const gauges = buildCurrentGauges();\n      if ((gauges.oldest_pending_lag_ms ?? 0) < lagCeilingMs) return;\n      emitLagCeilingWarning(gauges);\n      abortStalledAttempt(gauges);\n    };\n\n    const pump = () => {\n      if (resolved) {\n        return;\n      }\n      if (queue.length === 0 && active === 0) {\n        resolved = true;\n        clearLagCeilingTimer();\n        resolve(buildPoolSummary(results));\n        return;\n      }\n      while (active < concurrency && queue.length > 0) {\n        const index = queue.shift();\n        const label = labelFor(items[index], index);\n        const retryCount = retryCounts.get(label) || 0;\n        const attempt = retryCount + 1;\n        const startedAtIso = normalizeTimestamp(now());\n        const startedAtMs = Date.now();\n        const abortController = shouldAbortStalledLineages ? new AbortController() : null;\n        const activeAttempt = {\n          id: nextAttemptId,\n          index,\n          label,\n          retryCount,\n          attempt,\n          startedAtIso,\n          startedAtMs,\n          abortController,\n          settled: false,\n        };\n        nextAttemptId += 1;\n        activeAttempts.set(activeAttempt.id, activeAttempt);\n        active += 1;\n        settleItem({\n          item: items[index],\n          index,\n          worker,\n          now,\n          onEvent: emitEvent,\n          attempt,\n          emitSettledEvent: false,\n          abortSignal: abortController ? abortController.signal : undefined,\n          startedAtIso,\n          startedAtMs,\n        })\n          .then((result) => {\n            settleActiveAttempt(activeAttempt, result);\n          })\n          .catch((error) => {\n            // The item settler is meant to capture worker failures; this keeps\n            // an unexpected bug in the settler from wedging the whole pool.\n            settleActiveAttempt(activeAttempt, buildPoolErrorResult(activeAttempt, error));\n          });\n      }\n      scheduleLagCeilingCheck();\n    };\n\n    pump();\n  });\n}\n\n/**\n * Build the ordered-results + summary envelope for a completed pool run.\n *\n * @param {Array<Object>} results - Per-item settlement results (ordered).\n * @returns {Object} { results, summary: { total, succeeded, failed, all_failed } }.\n */\nfunction buildPoolSummary(results) {\n  const total = results.length;\n  const succeeded = results.filter((result) => result && result.status === 'fulfilled').length;\n  const failed = total - succeeded;\n  const gauges = buildPoolGauges({ total, settled: total, pending: 0, failed });\n  const failureClasses = buildFailureClassRollup(results);\n  return {\n    results,\n    summary: {\n      total,\n      succeeded,\n      failed,\n      all_failed: total > 0 && failed === total,\n      gauges,\n      failure_classes: failureClasses,\n    },\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. STATUS LEDGER\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Append one JSONL event to the orchestration status ledger.\n *\n * Follows the `orchestration-status.log` ledger pattern: one line per lineage\n * lifecycle event (started / completed / failed / salvaged / converged).\n *\n * @param {string} ledgerPath - Path to the JSONL ledger file.\n * @param {Object} entry - A serializable event object.\n */\nfunction appendStatusLedger(ledgerPath, entry) {\n  fs.mkdirSync(path.dirname(ledgerPath), { recursive: true });\n  fs.appendFileSync(ledgerPath, `${JSON.stringify(entry)}\\n`);\n}\n\n/**\n * Write the orchestration summary JSON for a completed fan-out run.\n *\n * @param {string} summaryPath - Path to the summary JSON file.\n * @param {Object} summary - Summary payload (e.g. the pool summary plus\n *   salvage counts and per-lineage rollups).\n */\nfunction writeOrchestrationSummary(summaryPath, summary) {\n  fs.mkdirSync(path.dirname(summaryPath), { recursive: true });\n  fs.writeFileSync(summaryPath, `${JSON.stringify(summary, null, 2)}\\n`);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. EXPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nmodule.exports = {\n  runCappedPool,\n  settleItem,\n  buildPoolSummary,\n  buildPoolGauges,\n  classifyLineageFailure,\n  detectOrphanedLineages,\n  createWavePlannerInterface,\n  markOrphanedLineages,\n  readRetryCountsFromLedger,\n  appendStatusLedger,\n  writeOrchestrationSummary,\n};","lineStart":514,"lineEnd":767,"totalLines":767,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","time":{"start":1782890326940,"end":1782890326947}},"metadata":{"openai":{"itemId":"fc_01aa19daa1438d1c016a44bf56cb5c8191a2d062770a0812df"}},"id":"prt_f1c8b6b87001opzKQbzmvdeQas","sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","messageID":"msg_f1c8b2d81001ICqiBeckfmREOg"}}
