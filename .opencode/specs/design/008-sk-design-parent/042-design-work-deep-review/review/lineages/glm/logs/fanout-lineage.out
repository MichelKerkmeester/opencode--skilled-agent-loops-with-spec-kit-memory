-design/design-foundations/scripts/fixtures/naming_doc/violating.md\n  artifact kind: token (frontmatter artifactKind)\n  token names: 3\n  required headings: COLOR RAMP, TYPE SCALE, SPACING SCALE, HAND OFF\nFAIL - line 12: --PrimaryColor - use lowercase kebab-case, not camelCase or uppercase\nFAIL - line 13: --color_primary - use hyphens, not underscores\nFAIL - line 14: --clr-primary - category must be one of the design-system token tiers\nFAIL - missing heading SPACING SCALE\n---VIOLATING_EXIT=0\n","exit":0,"truncated":false},"title":"python3 .opencode/skills/sk-design/design-foundations/scripts/naming_doc_check.py .opencode/skills/sk-design/design-foundations/scripts/fixtures/naming_doc/compliant.md 2>&1 | tail -5; echo \"---COMPLIANT_EXIT=$?\"; echo \"===\"; python3 .opencode/skills/sk-design/design-foundations/scripts/naming_doc_check.py .opencode/skills/sk-design/design-foundations/scripts/fixtures/naming_doc/violating.md 2>&1 | tail -10; echo \"---VIOLATING_EXIT=$?\"","time":{"start":1782750725058,"end":1782750725060}},"id":"prt_f14394371001b3iOf2hrOmc9Tg","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f14391491001mn7UYtyHfbWkOw"}}
