{"type":"tool_use","timestamp":1780925835300,"sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","part":{"type":"tool","tool":"read","callID":"call_hTJRDS7U7fMkmop8066yGXJJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/paths.ts","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/paths.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * paths.ts (openltm-core) — Path resolution without any host-specific defaults.\n3:  * Priority: LTM_DB_PATH env var > CLAUDE_PLUGIN_DATA env var > dev fallback.\n4:  * The CLAUDE_DIR constant is intentionally absent — adapters inject paths via LtmCoreConfig.\n5:  */\n6: import { join } from \"path\";\n7: \n8: export function getDbPath(): string {\n9:   if (process.env[\"LTM_DB_PATH\"]) return process.env[\"LTM_DB_PATH\"];\n10:   if (process.env[\"CLAUDE_PLUGIN_DATA\"]) return join(process.env[\"CLAUDE_PLUGIN_DATA\"], \"openltm.db\");\n11:   return join(import.meta.dir, \"..\", \"..\", \"..\", \"data\", \"openltm.db\");\n12: }\n13: \n14: export function getSchemaPath(): string {\n15:   return join(import.meta.dir, \"schema.sql\");\n16: }\n17: \n18: export function getMigrationsDir(): string {\n19:   // Resolves to project-root migrations/ during development inside the monorepo.\n20:   // Adapters should set LtmCoreConfig.migrationsDir when deploying standalone.\n21:   return join(import.meta.dir, \"..\", \"..\", \"..\", \"migrations\");\n22: }\n\n(End of file - total 22 lines)\n</content>","metadata":{"preview":"/**\n * paths.ts (openltm-core) — Path resolution without any host-specific defaults.\n * Priority: LTM_DB_PATH env var > CLAUDE_PLUGIN_DATA env var > dev fallback.\n * The CLAUDE_DIR constant is intentionally absent — adapters inject paths via LtmCoreConfig.\n */\nimport { join } from \"path\";\n\nexport function getDbPath(): string {\n  if (process.env[\"LTM_DB_PATH\"]) return process.env[\"LTM_DB_PATH\"];\n  if (process.env[\"CLAUDE_PLUGIN_DATA\"]) return join(process.env[\"CLAUDE_PLUGIN_DATA\"], \"openltm.db\");\n  return join(import.meta.dir, \"..\", \"..\", \"..\", \"data\", \"openltm.db\");\n}\n\nexport function getSchemaPath(): string {\n  return join(import.meta.dir, \"schema.sql\");\n}\n\nexport function getMigrationsDir(): string {\n  // Resolves to project-root migrations/ during development inside the monorepo.\n  // Adapters should set LtmCoreConfig.migrationsDir when deploying standalone.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/paths.ts","text":"/**\n * paths.ts (openltm-core) — Path resolution without any host-specific defaults.\n * Priority: LTM_DB_PATH env var > CLAUDE_PLUGIN_DATA env var > dev fallback.\n * The CLAUDE_DIR constant is intentionally absent — adapters inject paths via LtmCoreConfig.\n */\nimport { join } from \"path\";\n\nexport function getDbPath(): string {\n  if (process.env[\"LTM_DB_PATH\"]) return process.env[\"LTM_DB_PATH\"];\n  if (process.env[\"CLAUDE_PLUGIN_DATA\"]) return join(process.env[\"CLAUDE_PLUGIN_DATA\"], \"openltm.db\");\n  return join(import.meta.dir, \"..\", \"..\", \"..\", \"data\", \"openltm.db\");\n}\n\nexport function getSchemaPath(): string {\n  return join(import.meta.dir, \"schema.sql\");\n}\n\nexport function getMigrationsDir(): string {\n  // Resolves to project-root migrations/ during development inside the monorepo.\n  // Adapters should set LtmCoreConfig.migrationsDir when deploying standalone.\n  return join(import.meta.dir, \"..\", \"..\", \"..\", \"migrations\");\n}","lineStart":1,"lineEnd":22,"totalLines":22,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/paths.ts","time":{"start":1780925835291,"end":1780925835299}},"metadata":{"openai":{"itemId":"fc_0df03470a6a53fec016a26c584449881918d14ab52f21b2716"}},"id":"prt_ea773a31d001y3zrWedCcGJsi5","sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","messageID":"msg_ea7736a71001hXYN4Iya8DnbXF"}}
