the BM25 resolver is enabled', async () => {\n\n  Line 134:     const originalFlag = process.env[BM25_SYMBOL_RESOLVER_ENV];\n\n  Line 147:       delete process.env[BM25_SYMBOL_RESOLVER_ENV];\n\n  Line 154:       process.env[BM25_SYMBOL_RESOLVER_ENV] = '1';\n\n  Line 164:         delete process.env[BM25_SYMBOL_RESOLVER_ENV];\n\n  Line 166:         process.env[BM25_SYMBOL_RESOLVER_ENV] = originalFlag;\n\n  Line 172:     const originalFlag = process.env[BM25_SYMBOL_RESOLVER_ENV];\n\n  Line 174:       delete process.env[BM25_SYMBOL_RESOLVER_ENV];\n\n  Line 190:         delete process.env[BM25_SYMBOL_RESOLVER_ENV];\n\n  Line 192:         process.env[BM25_SYMBOL_RESOLVER_ENV] = originalFlag;\n\n  Line 197:   it('returns BM25 symbol suggestions only after exact subject matching misses and the flag is enabled', async () => {\n\n  Line 198:     const originalFlag = process.env[BM25_SYMBOL_RESOLVER_ENV];\n\n  Line 200:       process.env[BM25_SYMBOL_RESOLVER_ENV] = '1';\n\n  Line 225:           symbolResolution: {\n\n  Line 242:         delete process.env[BM25_SYMBOL_RESOLVER_ENV];\n\n  Line 244:         process.env[BM25_SYMBOL_RESOLVER_ENV] = originalFlag;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/tests/symbol-bm25-resolver.vitest.ts:\n  Line 2: // MODULE: Code Graph Symbol BM25 Resolver Tests\n\n  Line 8:   CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV,\n\n  Line 9:   isCodeGraphBm25SymbolResolverEnabled,\n\n  Line 10:   resolveSymbolBm25Candidates,\n\n  Line 11:   SYMBOL_BM25_FIELD_WEIGHTS,\n\n  Line 12:   SymbolPackedBm25Index,\n\n  Line 13:   type SymbolBm25Document,\n\n  Line 16: function symbol(overrides: Partial<SymbolBm25Document> & Pick<SymbolBm25Document, 'symbolId'>): SymbolBm25Document {\n\n  Line 29: describe('symbol BM25 resolver', () => {\n\n  Line 31:     expect(isCodeGraphBm25SymbolResolverEnabled({})).toBe(false);\n\n  Line 32:     expect(isCodeGraphBm25SymbolResolverEnabled({ [CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV]: 'fallback' })).toBe(true);\n\n  Line 33:     expect(isCodeGraphBm25SymbolResolverEnabled({ [CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV]: 'off' })).toBe(false);\n\n  Line 37:     const index = new SymbolPackedBm25Index([\n\n  Line 51:     const matches = resolveSymbolBm25Candidates('auth guard', [\n\n  Line 58:     expect(SYMBOL_BM25_FIELD_WEIGHTS.name).toBeGreaterThan(SYMBOL_BM25_FIELD_WEIGHTS.fqName);\n\n  Line 59:     expect(SYMBOL_BM25_FIELD_WEIGHTS.fqName).toBeGreaterThan(SYMBOL_BM25_FIELD_WEIGHTS.docstring);\n\n  Line 66:     const matches = resolveSymbolBm25Candidates('handleMemryContext', [\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/handlers/query.ts:\n  Line 29:   isCodeGraphBm25SymbolResolverEnabled,\n\n  Line 30:   resolveSymbolBm25Candidates,\n\n  Line 31:   type SymbolBm25Candidate,\n\n  Line 66: const SYMBOL_BM25_SUGGESTION_LIMIT = 5;\n\n  Line 146:   suggestions?: SymbolBm25Candidate[];\n\n  Line 377: function querySymbolBm25Suggestions(subject: string): SymbolBm25Candidate[] {\n\n  Line 378:   if (!isCodeGraphBm25SymbolResolverEnabled()) {\n\n  Line 382:   return resolveSymbolBm25Candidates(\n\n  Line 385:     { limit: SYMBOL_BM25_SUGGESTION_LIMIT },\n\n  Line 389: function buildUnresolvedSubjectError(subject: string, suggestions: SymbolBm25Candidate[]) {\n\n  Line 395:   if (suggestions.length === 0) {\n\n  Line 402:       symbolResolution: {\n\n  Line 406:         candidates: suggestions,\n\n  Line 484:   return { symbolId: null, suggestions: querySymbolBm25Suggestions(subject) };\n\n  Line 1647:         text: JSON.stringify(buildUnresolvedSubjectError(subject, resolvedSubject.suggestions ?? [])),\n","metadata":{"matches":91,"truncated":false},"title":"Bm25|BM25|symbolResolution|resolveSymbolBm25|CODE_GRAPH_BM25_SYMBOL_RESOLVER|suggestions","time":{"start":1781128840723,"end":1781128840739}},"metadata":{"openai":{"itemId":"fc_0a32ae643b178ac8016a29de88b0308191a9