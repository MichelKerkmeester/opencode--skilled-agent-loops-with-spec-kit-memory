   114	      observedIntents: projection.observedIntents,
   115	      observedResources: projection.observedResources.map((resource) => ({
   116	        intent: projection.observedIntents[0],
   117	        resource,
   118	      })),
   119	      receiptAttempts: [],
   120	      scenarioId: entry.id,
   121	      schemaVersion: 'V1',
   122	      targetQualifiedIds: evaluated.decision.action === 'route'
   123	        ? evaluated.decision.route.targets.map((target) => (
   124	          qualifiedDestinationId(target.destinationId)
   125	        ))
   126	        : [],
   127	      ...(evaluated.decision.action === 'route'
   128	        ? { selectionKind: evaluated.decision.route.selectionKind }
   129	        : {}),
   130	    };
   131	    row.projectionHash = computeProjectionHash('TypedRouteGoldV1', row);
   132	    return row;
   133	  });
   134	  return { cases: rows, schemaVersion: 'V1' };
   135	}
   136	
   137	function buildArtifacts() {
   138	  const { fixture, snapshot } = loadSnapshot();
   139	  const card = generatePolicyCard(snapshot);
   140	  const compiledDir = path.join(PHASE_ROOT, 'compiled');
   141	  const activationDir = path.join(PHASE_ROOT, 'activation');
   142	  const policyPath = path.join(compiledDir, 'policy.json');
   143	  const advisorPath = path.join(compiledDir, 'advisor-projection.json');
   144	  const cardPath = path.join(compiledDir, 'PolicyCardV1.md');
   145	  const typedGoldPath = path.join(compiledDir, 'route-gold.typed.json');
   146	  writeBytes(policyPath, artifactBytes(snapshot.policy));
   147	  writeBytes(advisorPath, artifactBytes(snapshot.advisorProjection));
   148	  writeBytes(cardPath, Buffer.from(card.markdown, 'utf8'));
   149	  writeBytes(typedGoldPath, artifactBytes(typedGold(snapshot, fixture)));
   150	
   151	  const priorPath = path.join(activationDir, 'manifest.prior.json');
   152	  const manifestPath = path.join(activationDir, 'manifest.json');
   153	  const candidatePath = path.join(activationDir, 'manifest.candidate.json');
   154	  const fencePath = path.join(activationDir, 'fence-state.json');
   155	  const priorBytes = fs.readFileSync(priorPath);
   156	  const candidate = {
   157	    schemaVersion: 'V1',
   158	    selectedPolicy: {
   159	      effectivePolicyHash: snapshot.policy.effectivePolicyHash,
   160	      generation: snapshot.policy.activationGeneration,
   161	    },
   162	    servingAuthority: 'legacy',
   163	    shadowOnly: true,
   164	  };
   165	  writeBytes(manifestPath, priorBytes);
   166	  writeBytes(candidatePath, artifactBytes(candidate));
   167	  writeBytes(fencePath, artifactBytes({ fencingEpoch: 0, schemaVersion: 'V1' }));
   168	
   169	  const artifactPaths = {
   170	    'PolicyCardV1.md': cardPath,
   171	    'advisor-projection.json': advisorPath,
   172	    'policy.json': policyPath,
   173	    'route-gold.typed.json': typedGoldPath,
   174	  };
   175	  const acceptance = {
   176	    candidateArtifacts: Object.fromEntries(Object.entries(artifactPaths).map(([name, filePath]) => (
   177	      [name, sha256(fs.readFileSync(filePath))]
   178	    ))),
   179	    candidatePolicy: candidate.selectedPolicy,
   180	    expectedCurrent: readJson(priorPath).selectedPolicy,
   181	    expectedFencingEpoch: 0,
   182	    hubId: snapshot.advisorProjection.hubId,
   183	    priorManifestHash: sha256(priorBytes),
   184	    schemaVersion: 'V1',
   185	    servingAuthority: 'legacy',
   186	    shadowOnly: true,
   187	    sourceHashes: snapshot.sourceHashes,
   188	  };
   189	  writeBytes(path.join(activationDir, 'acceptance.json'), artifactBytes(acceptance));
   190	  return {
   191	    artifacts: Object.keys(artifactPaths).length,
   192	    basePolicyHash: snapshot.policy.basePolicyHash,
   193	    effectivePolicyHash: snapshot.policy.effectivePolicyHash,
   194	    status: 'built',
   195	  };
   196	}
