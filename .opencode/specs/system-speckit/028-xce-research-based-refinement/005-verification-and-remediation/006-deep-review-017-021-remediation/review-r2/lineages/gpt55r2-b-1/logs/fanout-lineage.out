55:         updated: 0,\n856:         unchanged: 0,\n857:         failed: 0,\n858:         staleDeleted,\n859:         staleDeleteFailed,\n860:         orphanSwept: orphanSweepResult.swept,\n861:       },\n862:       staleCandidates: staleDeleted + staleDeleteFailed,\n863:     });\n864:     await releaseScanLease();\n865:     return createMCPSuccessResponse({\n866:       tool: 'memory_index_scan',\n867:       summary: 'No memory files found',\n868:       data: {\n869:         status: 'complete',\n870:         scanKey,\n871:         scanned: 0,\n872:         indexed: 0,\n873:         updated: 0,\n874:         unchanged: 0,\n875:         failed: 0,\n876:         staleDeleted,\n877:         staleDeleteFailed,\n878:         postInsertEnrichmentRepaired,\n879:         nearDuplicateRepaired,\n880:         triggerEmbeddingBackfill,\n881:         orphanSwept: orphanSweepResult.swept,\n882:         orphanSweepFailed: orphanSweepResult.failed,\n883:         orphanSweepScanned: orphanSweepResult.scannedRows,\n884:         orphanSweepNextCursor: orphanSweepResult.nextCursor,\n885:         checkpointRepair,\n886:         warnings: walkerWarnings,\n887:         capExceeded: walkerCapExceeded,\n888:       },\n889:       hints: [\n890:         ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n891:         ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n892:         ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n893:         ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n894:         ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n895:         ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n896:         ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n897:         ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n898:         ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n899:         ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n900:         'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n901:         'Constitutional files go in .opencode/skills/*/constitutional/'\n902:       ]\n903:     });\n904:   }\n905: \n906:   const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n907: \n908:   const results: ScanResults = {\n909:     scanned: files.length,\n910:     indexed: 0,\n911:     updated: 0,\n912:     unchanged: 0,\n913:     failed: 0,\n914:     deferred: 0,\n915:     skipped_mtime: 0,\n916:     mtimeUpdates: 0,\n917:     staleDeleted: 0,\n918:     staleDeleteFailed: 0,\n919:     postInsertEnrichmentRepaired: 0,\n920:     nearDuplicateRepaired: 0,\n921:     orphanSwept: 0,\n922:     orphanSweepFailed: 0,\n923:     orphanSweepScanned: 0,\n924:     orphanSweepNextCursor: null,\n925:     files: [],\n926:     constitutional: {\n927:       found: constitutionalFiles.length,\n928:       indexed: 0,\n929:       alreadyIndexed: 0\n930:     },\n931:     incremental: {\n932:       enabled: incremental && !force,\n933:       fast_path_skips: 0,\n934:       mtime_changed: 0,\n935:       metadataPromoter: {\n936:         processed: 0,\n937:         resolved: 0,\n938:         inserted: 0,\n939:         skippedManual: 0,\n940:         staleTombstoned: 0,\n941:         staleDeleted: 0,\n942:         warnings: 0,\n943:       }\n944:     },\n945:     dedup: {\n946:       inputTotal: mergedFiles.length,\n947:       uniqueTotal: files.length,\n948:       duplicatesSkipped: dedupDuplicatesSkipped,\n949:     },\n950:     aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n951:     divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n952:     checkpointRepair,\n953:     warnings: walkerWarnings,\n954:     capExceeded: walkerCapExceeded,\n955:   };\n956:   const scanAppliedActions: StatediffAction[] = [];\n957: \n958:   let filesToIndex: string[] = files;\n959:   let filesToDelete: string[] = [];\n960: \n961:   if (incremental && !force) {\n962:     const startCategorize = Date.now();\n963:     const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n964: \n965:     filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n966:     filesToDelete = categorized.toDelete;\n967: \n968:     results.unchanged = categorized.toSkip.length;\n969:     results.skipped_mtime = categorized.toSkip.length;\n970:     results.incremental.fast_path_skips = categorized.toSkip.length;\n971:     results.incremental.mtime_changed = categorized.toUpdate.length;\n972: \n973:     for (const unchangedPath of categorized.toSkip) {\n974:       if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n975:         results.constitutional.alreadyIndexed++;\n976:       }\n977:     }\n978: \n979:     const categorizeTime = Date.now() - startCategorize;\n980:     console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n981:     console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n982:   }\n983: \n984:   // Attempt move reconciliation before full delete+reindex cycle.\n985:   // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n986:   // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n987:   // stored-document_type cross-checks; the matched row is updated in place.\n988:   if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n989:     const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n990:     if (moveResult.reconciled.length > 0) {\n991:       results.moveReconciled = moveResult.reconciled.length;\n992:       filesToDelete = moveResult.filteredToDelete;\n993:       filesToIndex = moveResult.filteredToIndex;\n994:       console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n995:     }\n996:   }\n997: \n998:   const plannedScanActions = [\n999:     ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n1000:       target: 'memory_index',\n1001:       key: getCachedKey(filePath),\n1002:       sourceOperation: 'scan',\n1003:       metadata: { filePath },\n1004:     })),\n1005:     ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n1006:       target: 'memory_index',\n1007:       key: getCachedKey(filePath),\n1008:       sourceOperation: 'scan',\n1009:       metadata: { filePath },\n1010:     })),\n1011:   ];\n1012:   if (plannedScanActions.length > 0) {\n1013:     console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n1014:   }\n1015: \n1016:   // Track successfully indexed files for post-indexing mtime update.\n1017:   // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n1018:   // Failed files keep their old mtime so shouldReindex() returns 'modified'\n1019:   // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n1020:   // Before indexing would cause silent data loss — a failed file would be\n1021:   // Marked \"already indexed\" and permanently skipped.\n1022:   const successfullyIndexedFiles: string[] = [];\n1023:   const scanBatchSize = BATCH_SIZE;\n1024: \n1025:   ctx.onPhase?.('indexing');\n1026:   ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n1027: \n1028:   if (filesToIndex.length > 0) {\n1029:     let processedInScan = 0;\n1030:     const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n1031:       // Cancellation is checked between files (mirrors ingest). A cancelled file is\n1032:       // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n1033:       if (ctx.isCancelled?.()) {\n1034:         return { status: 'cancelled' } as IndexResult;\n1035:       }\n1036:       const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n1037:       // Constitutional markdown is policy text, not evidence-bearing memory.\n1038:       // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n1039:       // strict sufficiency gate would always reject it. Treat constitutional files like\n1040:       // spec docs and pass them through warn-only mode so they index against the same\n1041:       // pipeline without the document-evidence requirements.\n1042:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1043:       // During force reindex, use warn-only for all files — the goal is to index\n1044:       // everything that has valid frontmatter, not to enforce template contracts on\n1045:       // older files created before current templates were established.\n1046:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n1047:       const indexResult = await indexSingleFile(filePath, force, {\n1048:         ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n1049:         fromScan: true,\n1050:         asyncEmbedding: true,\n1051:         governance: governedIngest ? governanceDecision : undefined,\n1052:       });\n1053:       processedInScan += 1;\n1054:       ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n1055:       return indexResult;\n1056:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n1057: \n1058:     for (let i = 0; i < batchResults.length; i++) {\n1059:       const result = batchResults[i];\n1060:       const filePath = filesToIndex[i];\n1061:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1062: \n1063:       if (result.error) {\n1064:         results.failed++;\n1065:         results.files.push({\n1066:           file: path.basename(filePath),\n1067:           filePath,\n1068:           status: 'failed',\n1069:           error: result.error,\n1070:           errorDetail: result.errorDetail\n1071:         });\n1072:       } else if (isIndexResult(result)) {\n1073:         const isSuccessfulStatus =\n1074:           result.status === 'success' ||\n1075:           result.status === 'indexed' ||\n1076:           result.status === 'updated' ||\n1077:           result.status === 'unchanged' ||\n1078:           result.status === 'reinforced' ||\n1079:           result.status === 'duplicate' ||\n1080:           result.status === 'deferred';\n1081:         // A cancelled file was never indexed and was never going to be: counting it\n1082:         // as a failure would attribute an operator-requested stop to a file error.\n1083:         // It is neither success nor failure, so it falls through both tallies.\n1084:         if (!isSuccessfulStatus && result.status !== 'cancelled') {\n1085:           results.failed++;\n1086:         }\n1087: \n1088:         if (result.status === 'indexed') {\n1089:           results.indexed++;\n1090:           successfullyIndexedFiles.push(filePath);\n1091:           scanAppliedActions.push(createStatediffAction('insert', {\n1092:             target: 'memory_index',\n1093:             key: String(result.id ?? getCachedKey(filePath)),\n1094:             sourceOperation: 'scan',\n1095:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1096:           }));\n1097:         } else if (result.status === 'updated') {\n1098:           results.updated++;\n1099:           successfullyIndexedFiles.push(filePath);\n1100:           scanAppliedActions.push(createStatediffAction('upsert', {\n1101:             target: 'memory_index',\n1102:             key: String(result.id ?? getCachedKey(filePath)),\n1103:             sourceOperation: 'scan',\n1104:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1105:           }));\n1106:         } else if (result.status === 'unchanged') {\n1107:           results.unchanged++;\n1108:           successfullyIndexedFiles.push(filePath);\n1109:         } else if (result.status === 'reinforced') {\n1110:           results.updated++;\n1111:           successfullyIndexedFiles.push(filePath);\n1112:           scanAppliedActions.push(createStatediffAction('upsert', {\n1113:             target: 'memory_index',\n1114:             key: String(result.id ?? getCachedKey(filePath)),\n1115:             sourceOperation: 'scan',\n1116:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1117:           }));\n1118:         } else if (result.status === 'duplicate') {\n1119:           results.unchanged++;\n1120:           successfullyIndexedFiles.push(filePath);\n1121:         } else if (result.status === 'deferred') {\n1122:           results.indexed++;\n1123:           results.deferred++;\n1124:           successfullyIndexedFiles.push(filePath);\n1125:           scanAppliedActions.push(createStatediffAction('insert', {\n1126:             target: 'memory_index',\n1127:             key: String(result.id ?? getCachedKey(filePath)),\n1128:             sourceOperation: 'scan',\n1129:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1130:           }));\n1131:         }\n1132: \n1133:         if (isConstitutional) {\n1134:           if (result.status === 'indexed') {\n1135:             results.constitutional.indexed++;\n1136:           } else if (result.status === 'unchanged') {\n1137:             results.constitutional.alreadyIndexed++;\n1138:           }\n1139:         }\n1140: \n1141:         if (result.status !== 'unchanged') {\n1142:           const rejectionDetail = !isSuccessfulStatus\n1143:             ? {\n1144:                 ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n1145:                   ? { rejectionCode: result.rejectionCode }\n1146:                   : {}),\n1147:                 ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n1148:                   ? { rejectionReason: result.rejectionReason }\n1149:                   : (typeof result.message === 'string' && result.message.length > 0\n\n(Showing lines 820-1149 of 1598. Use offset=1150 to continue.)\n</content>","metadata":{"preview":"    const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n      runTriggerEmbeddingBackfill(requireDb(), {\n        isCancelled: () => ctx.isCancelled?.() ?? false,\n      }));\n\n    if (orphanSweepResult.swept > 0) {\n      runScanInvalidationHooks({\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        operation: 'orphan-sweep',\n      }, orphanSweepResult.actions);\n    }\n    if (postInsertEnrichmentRepaired > 0) {\n      runScanInvalidationHooks({\n        postInsertEnrichmentRepaired,\n        operation: 'post-insert-enrichment-repair',\n      }, [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: 'post-insert-enrichment-repair',\n        sourceOperation: 'scan',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"    const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n      runTriggerEmbeddingBackfill(requireDb(), {\n        isCancelled: () => ctx.isCancelled?.() ?? false,\n      }));\n\n    if (orphanSweepResult.swept > 0) {\n      runScanInvalidationHooks({\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        operation: 'orphan-sweep',\n      }, orphanSweepResult.actions);\n    }\n    if (postInsertEnrichmentRepaired > 0) {\n      runScanInvalidationHooks({\n        postInsertEnrichmentRepaired,\n        operation: 'post-insert-enrichment-repair',\n      }, [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: 'post-insert-enrichment-repair',\n        sourceOperation: 'scan',\n        metadata: { postInsertEnrichmentRepaired },\n      })]);\n    }\n    if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n      runScanInvalidationHooks({\n        triggerEmbeddingBackfill,\n        operation: 'trigger-embedding-backfill',\n      }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n    }\n\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'success',\n      counts: {\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        orphanSwept: orphanSweepResult.swept,\n      },\n      staleCandidates: staleDeleted + staleDeleteFailed,\n    });\n    await releaseScanLease();\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: 'No memory files found',\n      data: {\n        status: 'complete',\n        scanKey,\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        postInsertEnrichmentRepaired,\n        nearDuplicateRepaired,\n        triggerEmbeddingBackfill,\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        orphanSweepScanned: orphanSweepResult.scannedRows,\n        orphanSweepNextCursor: orphanSweepResult.nextCursor,\n        checkpointRepair,\n        warnings: walkerWarnings,\n        capExceeded: walkerCapExceeded,\n      },\n      hints: [\n        ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n        ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n        ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n        ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n        ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n        ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n        ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n        ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n        ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n        ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n        'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n        'Constitutional files go in .opencode/skills/*/constitutional/'\n      ]\n    });\n  }\n\n  const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n\n  const results: ScanResults = {\n    scanned: files.length,\n    indexed: 0,\n    updated: 0,\n    unchanged: 0,\n    failed: 0,\n    deferred: 0,\n    skipped_mtime: 0,\n    mtimeUpdates: 0,\n    staleDeleted: 0,\n    staleDeleteFailed: 0,\n    postInsertEnrichmentRepaired: 0,\n    nearDuplicateRepaired: 0,\n    orphanSwept: 0,\n    orphanSweepFailed: 0,\n    orphanSweepScanned: 0,\n    orphanSweepNextCursor: null,\n    files: [],\n    constitutional: {\n      found: constitutionalFiles.length,\n      indexed: 0,\n      alreadyIndexed: 0\n    },\n    incremental: {\n      enabled: incremental && !force,\n      fast_path_skips: 0,\n      mtime_changed: 0,\n      metadataPromoter: {\n        processed: 0,\n        resolved: 0,\n        inserted: 0,\n        skippedManual: 0,\n        staleTombstoned: 0,\n        staleDeleted: 0,\n        warnings: 0,\n      }\n    },\n    dedup: {\n      inputTotal: mergedFiles.length,\n      uniqueTotal: files.length,\n      duplicatesSkipped: dedupDuplicatesSkipped,\n    },\n    aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n    divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n    checkpointRepair,\n    warnings: walkerWarnings,\n    capExceeded: walkerCapExceeded,\n  };\n  const scanAppliedActions: StatediffAction[] = [];\n\n  let filesToIndex: string[] = files;\n  let filesToDelete: string[] = [];\n\n  if (incremental && !force) {\n    const startCategorize = Date.now();\n    const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n\n    filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n    filesToDelete = categorized.toDelete;\n\n    results.unchanged = categorized.toSkip.length;\n    results.skipped_mtime = categorized.toSkip.length;\n    results.incremental.fast_path_skips = categorized.toSkip.length;\n    results.incremental.mtime_changed = categorized.toUpdate.length;\n\n    for (const unchangedPath of categorized.toSkip) {\n      if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n        results.constitutional.alreadyIndexed++;\n      }\n    }\n\n    const categorizeTime = Date.now() - startCategorize;\n    console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n    console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n  }\n\n  // Attempt move reconciliation before full delete+reindex cycle.\n  // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n  // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n  // stored-document_type cross-checks; the matched row is updated in place.\n  if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n    const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n    if (moveResult.reconciled.length > 0) {\n      results.moveReconciled = moveResult.reconciled.length;\n      filesToDelete = moveResult.filteredToDelete;\n      filesToIndex = moveResult.filteredToIndex;\n      console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n    }\n  }\n\n  const plannedScanActions = [\n    ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n    ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss — a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;\n    const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n      // Cancellation is checked between files (mirrors ingest). A cancelled file is\n      // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n      if (ctx.isCancelled?.()) {\n        return { status: 'cancelled' } as IndexResult;\n      }\n      const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n      // Constitutional markdown is policy text, not evidence-bearing memory.\n      // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n      // strict sufficiency gate would always reject it. Treat constitutional files like\n      // spec docs and pass them through warn-only mode so they index against the same\n      // pipeline without the document-evidence requirements.\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n      // During force reindex, use warn-only for all files — the goal is to index\n      // everything that has valid frontmatter, not to enforce template contracts on\n      // older files created before current templates were established.\n      const useWarnOnly = force || isSpecDoc || isConstitutional;\n      const indexResult = await indexSingleFile(filePath, force, {\n        ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n        fromScan: true,\n        asyncEmbedding: true,\n        governance: governedIngest ? governanceDecision : undefined,\n      });\n      processedInScan += 1;\n      ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n      return indexResult;\n    }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n    for (let i = 0; i < batchResults.length; i++) {\n      const result = batchResults[i];\n      const filePath = filesToIndex[i];\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n\n      if (result.error) {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: result.error,\n          errorDetail: result.errorDetail\n        });\n      } else if (isIndexResult(result)) {\n        const isSuccessfulStatus =\n          result.status === 'success' ||\n          result.status === 'indexed' ||\n          result.status === 'updated' ||\n          result.status === 'unchanged' ||\n          result.status === 'reinforced' ||\n          result.status === 'duplicate' ||\n          result.status === 'deferred';\n        // A cancelled file was never indexed and was never going to be: counting it\n        // as a failure would attribute an operator-requested stop to a file error.\n        // It is neither success nor failure, so it falls through both tallies.\n        if (!isSuccessfulStatus && result.status !== 'cancelled') {\n          results.failed++;\n        }\n\n        if (result.status === 'indexed') {\n          results.indexed++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'updated') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'unchanged') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'reinforced') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'duplicate') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'deferred') {\n          results.indexed++;\n          results.deferred++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        }\n\n        if (isConstitutional) {\n          if (result.status === 'indexed') {\n            results.constitutional.indexed++;\n          } else if (result.status === 'unchanged') {\n            results.constitutional.alreadyIndexed++;\n          }\n        }\n\n        if (result.status !== 'unchanged') {\n          const rejectionDetail = !isSuccessfulStatus\n            ? {\n                ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n                  ? { rejectionCode: result.rejectionCode }\n                  : {}),\n                ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n                  ? { rejectionReason: result.rejectionReason }\n                  : (typeof result.message === 'string' && result.message.length > 0","lineStart":820,"lineEnd":1149,"totalLines":1598,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781761445836,"end":1781761445841}},"metadata":{"openai":{"itemId":"fc_0919e6e9e2ad4b66016a3385a5c9688191af83def6b613c679"}},"id":"prt_ed9420fad001Hs2uPS6bpGD8t9","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed941f11f001iscaBaC0WcppmN"}}
