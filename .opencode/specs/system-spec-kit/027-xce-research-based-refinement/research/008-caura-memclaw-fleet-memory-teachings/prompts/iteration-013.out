{"type":"tool_use","timestamp":1780728869222,"sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","part":{"type":"tool","tool":"read","callID":"call_grQKjQZwaaTzmWs8A0Myc32S","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/idempotency.py","offset":1,"limit":105},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/idempotency.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Idempotency inbox — CRUD for the (tenant_id, key) → response cache.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from datetime import datetime\n6: \n7: from fastapi import APIRouter, HTTPException, Response\n8: from pydantic import BaseModel\n9: \n10: from core_storage_api.schemas import IDEMPOTENCY_RESPONSE_FIELDS, orm_to_dict\n11: from core_storage_api.services.postgres_service import PostgresService\n12: \n13: router = APIRouter(prefix=\"/idempotency\", tags=[\"Idempotency\"])\n14: _svc = PostgresService()\n15: \n16: \n17: class IdempotencyClaimRequest(BaseModel):\n18:     tenant_id: str\n19:     idempotency_key: str\n20:     request_hash: str\n21:     expires_at: datetime\n22: \n23: \n24: class IdempotencyUpsertRequest(BaseModel):\n25:     tenant_id: str\n26:     idempotency_key: str\n27:     request_hash: str\n28:     response_body: dict\n29:     status_code: int\n30:     expires_at: datetime\n31: \n32: \n33: @router.get(\"\")\n34: async def get_idempotency(tenant_id: str, idempotency_key: str) -> dict:\n35:     row = await _svc.idempotency_get(\n36:         tenant_id=tenant_id,\n37:         idempotency_key=idempotency_key,\n38:     )\n39:     if row is None:\n40:         raise HTTPException(status_code=404, detail=\"idempotency record not found or expired\")\n41:     return orm_to_dict(row, IDEMPOTENCY_RESPONSE_FIELDS)\n42: \n43: \n44: @router.post(\"/claim\", status_code=201, responses={409: {\"description\": \"Already claimed\"}})\n45: async def claim_idempotency(body: IdempotencyClaimRequest, response: Response) -> dict:\n46:     \"\"\"Insert a pending claim for ``(tenant_id, idempotency_key)``.\n47: \n48:     Returns 201 with the claim row when the caller wins the race;\n49:     callers proceed with the underlying handler, then call POST ``\"\"``\n50:     (upsert) to record the response. Returns 409 when an existing row\n51:     already holds the key — callers poll GET ``\"\"`` until the previous\n52:     holder completes the response (``is_pending`` flips to False) or\n53:     the row's ``expires_at`` passes.\n54:     \"\"\"\n55:     row = await _svc.idempotency_claim(\n56:         tenant_id=body.tenant_id,\n57:         idempotency_key=body.idempotency_key,\n58:         request_hash=body.request_hash,\n59:         expires_at=body.expires_at,\n60:     )\n61:     if row is None:\n62:         existing = await _svc.idempotency_get(\n63:             tenant_id=body.tenant_id,\n64:             idempotency_key=body.idempotency_key,\n65:         )\n66:         response.status_code = 409\n67:         # The ``found`` field is the explicit signal callers use to tell\n68:         # \"real conflicting row\" from \"row vanished between conflict and\n69:         # SELECT\". Previously the client inferred this by checking for a\n70:         # ``tenant_id`` key in the body — a fragile coupling that would\n71:         # break the moment the error body grew a tenant_id field.\n72:         if existing is not None:\n73:             return {\"found\": True, **orm_to_dict(existing, IDEMPOTENCY_RESPONSE_FIELDS)}\n74:         return {\"found\": False, \"detail\": \"idempotency record not found or expired\"}\n75:     return orm_to_dict(row, IDEMPOTENCY_RESPONSE_FIELDS)\n76: \n77: \n78: @router.post(\"\")\n79: async def upsert_idempotency(body: IdempotencyUpsertRequest) -> dict:\n80:     # If a prior ``claim`` inserted a pending row, this UPDATEs it in\n81:     # place; otherwise it falls back to insert-or-existing semantics for\n82:     # legacy callers that skipped the claim step.\n83:     row = await _svc.idempotency_upsert(\n84:         tenant_id=body.tenant_id,\n85:         idempotency_key=body.idempotency_key,\n86:         request_hash=body.request_hash,\n87:         response_body=body.response_body,\n88:         status_code=body.status_code,\n89:         expires_at=body.expires_at,\n90:     )\n91:     return orm_to_dict(row, IDEMPOTENCY_RESPONSE_FIELDS)\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"\"\"\"Idempotency inbox — CRUD for the (tenant_id, key) → response cache.\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import datetime\n\nfrom fastapi import APIRouter, HTTPException, Response\nfrom pydantic import BaseModel\n\nfrom core_storage_api.schemas import IDEMPOTENCY_RESPONSE_FIELDS, orm_to_dict\nfrom core_storage_api.services.postgres_service import PostgresService\n\nrouter = APIRouter(prefix=\"/idempotency\", tags=[\"Idempotency\"])\n_svc = PostgresService()\n\n\nclass IdempotencyClaimRequest(BaseModel):\n    tenant_id: str\n    idempotency_key: str\n    request_hash: str","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/idempotency.py","text":"\"\"\"Idempotency inbox — CRUD for the (tenant_id, key) → response cache.\"\"\"\n\nfrom __future__ import annotations\n\nfrom datetime import datetime\n\nfrom fastapi import APIRouter, HTTPException, Response\nfrom pydantic import BaseModel\n\nfrom core_storage_api.schemas import IDEMPOTENCY_RESPONSE_FIELDS, orm_to_dict\nfrom core_storage_api.services.postgres_service import PostgresService\n\nrouter = APIRouter(prefix=\"/idempotency\", tags=[\"Idempotency\"])\n_svc = PostgresService()\n\n\nclass IdempotencyClaimRequest(BaseModel):\n    tenant_id: str\n    idempotency_key: str\n    request_hash: str\n    expires_at: datetime\n\n\nclass IdempotencyUpsertRequest(BaseModel):\n    tenant_id: str\n    idempotency_key: str\n    request_hash: str\n    response_body: dict\n    status_code: int\n    expires_at: datetime\n\n\n@router.get(\"\")\nasync def get_idempotency(tenant_id: str, idempotency_key: str) -> dict:\n    row = await _svc.idempotency_get(\n        tenant_id=tenant_id,\n        idempotency_key=idempotency_key,\n    )\n    if row is None:\n        raise HTTPException(status_code=404, detail=\"idempotency record not found or expired\")\n    return orm_to_dict(row, IDEMPOTENCY_RESPONSE_FIELDS)\n\n\n@router.post(\"/claim\", status_code=201, responses={409: {\"description\": \"Already claimed\"}})\nasync def claim_idempotency(body: IdempotencyClaimRequest, response: Response) -> dict:\n    \"\"\"Insert a pending claim for ``(tenant_id, idempotency_key)``.\n\n    Returns 201 with the claim row when the caller wins the race;\n    callers proceed with the underlying handler, then call POST ``\"\"``\n    (upsert) to record the response. Returns 409 when an existing row\n    already holds the key — callers poll GET ``\"\"`` until the previous\n    holder completes the response (``is_pending`` flips to False) or\n    the row's ``expires_at`` passes.\n    \"\"\"\n    row = await _svc.idempotency_claim(\n        tenant_id=body.tenant_id,\n        idempotency_key=body.idempotency_key,\n        request_hash=body.request_hash,\n        expires_at=body.expires_at,\n    )\n    if row is None:\n        existing = await _svc.idempotency_get(\n            tenant_id=body.tenant_id,\n            idempotency_key=body.idempotency_key,\n        )\n        response.status_code = 409\n        # The ``found`` field is the explicit signal callers use to tell\n        # \"real conflicting row\" from \"row vanished between conflict and\n        # SELECT\". Previously the client inferred this by checking for a\n        # ``tenant_id`` key in the body — a fragile coupling that would\n        # break the moment the error body grew a tenant_id field.\n        if existing is not None:\n            return {\"found\": True, **orm_to_dict(existing, IDEMPOTENCY_RESPONSE_FIELDS)}\n        return {\"found\": False, \"detail\": \"idempotency record not found or expired\"}\n    return orm_to_dict(row, IDEMPOTENCY_RESPONSE_FIELDS)\n\n\n@router.post(\"\")\nasync def upsert_idempotency(body: IdempotencyUpsertRequest) -> dict:\n    # If a prior ``claim`` inserted a pending row, this UPDATEs it in\n    # place; otherwise it falls back to insert-or-existing semantics for\n    # legacy callers that skipped the claim step.\n    row = await _svc.idempotency_upsert(\n        tenant_id=body.tenant_id,\n        idempotency_key=body.idempotency_key,\n        request_hash=body.request_hash,\n        response_body=body.response_body,\n        status_code=body.status_code,\n        expires_at=body.expires_at,\n    )\n    return orm_to_dict(row, IDEMPOTENCY_RESPONSE_FIELDS)","lineStart":1,"lineEnd":91,"totalLines":91,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-storage-api/src/core_storage_api/routers/idempotency.py","time":{"start":1780728869199,"end":1780728869221}},"metadata":{"openai":{"itemId":"fc_0ee34f8fc9ec7720016a23c42520f88191b381865aaa6ba2de"}},"id":"prt_e9bb6314b001RyauS1HQmajgFr","sessionID":"ses_1644b0d23ffeX4h16ioztT6XB0","messageID":"msg_e9bb60e3e001V72tehJ3TO5ZZL"}}
