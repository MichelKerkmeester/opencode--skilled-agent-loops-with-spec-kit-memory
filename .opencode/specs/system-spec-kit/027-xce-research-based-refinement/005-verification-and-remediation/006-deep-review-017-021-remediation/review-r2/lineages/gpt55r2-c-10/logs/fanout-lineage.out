{"type":"tool_use","timestamp":1781764328708,"sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","part":{"type":"tool","tool":"read","callID":"call_anBTkfujTWJLqqfPiAI5NkAy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/validators.ts","offset":1,"limit":200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/validators.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Validators\n3: // ───────────────────────────────────────────────────────────────\n4: import path from 'path';\n5: import os from 'os';\n6: \n7: // ───────────────────────────────────────────────────────────────\n8: // 1. TYPES\n9: \n10: // ───────────────────────────────────────────────────────────────\n11: /** Maximum allowed lengths for string inputs (SEC-003: CWE-400 mitigation) */\n12: export interface InputLimits {\n13:   query: number;\n14:   title: number;\n15:   specFolder: number;\n16:   contextType: number;\n17:   name: number;\n18:   prompt: number;\n19:   filePath: number;\n20: }\n21: \n22: /** Arguments object that can be validated for input lengths */\n23: export interface ValidatableArgs {\n24:   query?: string;\n25:   title?: string;\n26:   specFolder?: string;\n27:   contextType?: string;\n28:   name?: string;\n29:   prompt?: string;\n30:   filePath?: string;\n31:   [key: string]: unknown;\n32: }\n33: \n34: /** Shared file path validation function signature */\n35: export type SharedValidateFilePath = (filePath: string, allowedBasePaths: string[]) => string | null;\n36: \n37: // ───────────────────────────────────────────────────────────────\n38: // 2. CONFIGURATION CONSTANTS\n39: \n40: // ───────────────────────────────────────────────────────────────\n41: export const INPUT_LIMITS: Readonly<InputLimits> = {\n42:   query: 10000,\n43:   title: 500,\n44:   specFolder: 200,\n45:   contextType: 100,\n46:   name: 200,\n47:   prompt: 10000,\n48:   filePath: 500\n49: } as const;\n50: \n51: /** Maximum query length for search operations */\n52: export const MAX_QUERY_LENGTH: number = 10000;\n53: \n54: // ───────────────────────────────────────────────────────────────\n55: // 3. QUERY VALIDATION\n56: \n57: // ───────────────────────────────────────────────────────────────\n58: /**\n59:  * Validate and normalize a search query.\n60:  * Properly rejects empty, null, and invalid queries.\n61:  */\n62: export function validateQuery(query: unknown): string {\n63:   if (query === null || query === undefined) {\n64:     throw new Error('Query cannot be null or undefined');\n65:   }\n66:   if (typeof query !== 'string') {\n67:     throw new Error('Query must be a string');\n68:   }\n69:   const normalized = query.trim();\n70:   if (normalized.length === 0) {\n71:     throw new Error('Query cannot be empty or whitespace-only');\n72:   }\n73:   if (normalized.length > MAX_QUERY_LENGTH) {\n74:     throw new Error(`Query exceeds maximum length of ${MAX_QUERY_LENGTH} characters`);\n75:   }\n76:   return normalized;\n77: }\n78: \n79: // ───────────────────────────────────────────────────────────────\n80: // 4. INPUT LENGTH VALIDATION\n81: \n82: // ───────────────────────────────────────────────────────────────\n83: /**\n84:  * Validate input string lengths\n85:  * SEC-003: Input length enforcement for CWE-400 mitigation\n86:  */\n87: export function validateInputLengths(args: ValidatableArgs | null | undefined): void {\n88:   if (!args || typeof args !== 'object') return;\n89: \n90:   const checks: Array<[keyof InputLimits, number]> = [\n91:     ['query', INPUT_LIMITS.query],\n92:     ['title', INPUT_LIMITS.title],\n93:     ['specFolder', INPUT_LIMITS.specFolder],\n94:     ['contextType', INPUT_LIMITS.contextType],\n95:     ['name', INPUT_LIMITS.name],\n96:     ['prompt', INPUT_LIMITS.prompt],\n97:     ['filePath', INPUT_LIMITS.filePath]\n98:   ];\n99: \n100:   for (const [field, maxLength] of checks) {\n101:     const value = args[field];\n102:     if (value && typeof value === 'string' && value.length > maxLength) {\n103:       throw new Error(`Input '${field}' exceeds maximum length of ${maxLength} characters`);\n104:     }\n105:   }\n106: }\n107: \n108: // ───────────────────────────────────────────────────────────────\n109: // 5. FILE PATH VALIDATION\n110: \n111: // ───────────────────────────────────────────────────────────────\n112: /**\n113:  * Create a file path validator with specified allowed base paths\n114:  */\n115: export function createFilePathValidator(\n116:   allowedBasePaths: string[],\n117:   sharedValidateFilePath: SharedValidateFilePath\n118: ): (filePath: string) => string {\n119:   /**\n120:    * Validate file path against allowed directories\n121:    */\n122:   return function validateFilePathLocal(filePath: string): string {\n123:     const result = sharedValidateFilePath(filePath, allowedBasePaths);\n124:     if (result === null) {\n125:       throw new Error('Access denied: Path outside allowed directories');\n126:     }\n127:     // Additional check for .. patterns (not just null bytes which shared handles)\n128:     if (filePath.includes('..')) {\n129:       throw new Error('Access denied: Invalid path pattern');\n130:     }\n131:     return result;\n132:   };\n133: }\n134: \n135: /**\n136:  * Get default allowed base paths for file operations\n137:  */\n138: export function getDefaultAllowedPaths(defaultBasePath?: string): string[] {\n139:   const basePath = defaultBasePath || process.cwd();\n140:   return [\n141:     path.join(os.homedir(), '.claude'),\n142:     basePath,\n143:     process.cwd()\n144:   ]\n145:     .filter(Boolean)\n146:     .map(base => path.resolve(base));\n147: }\n148: \n149: /* ───────────────────────────────────────────────────────────────\n150:    6. (ESM exports above — no CommonJS module.exports needed)\n151:    ──────────────────────────────────────────────────────────────── */\n\n(End of file - total 151 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Validators\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport os from 'os';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/** Maximum allowed lengths for string inputs (SEC-003: CWE-400 mitigation) */\nexport interface InputLimits {\n  query: number;\n  title: number;\n  specFolder: number;\n  contextType: number;\n  name: number;\n  prompt: number;\n  filePath: number;\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/utils/validators.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Validators\n// ───────────────────────────────────────────────────────────────\nimport path from 'path';\nimport os from 'os';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/** Maximum allowed lengths for string inputs (SEC-003: CWE-400 mitigation) */\nexport interface InputLimits {\n  query: number;\n  title: number;\n  specFolder: number;\n  contextType: number;\n  name: number;\n  prompt: number;\n  filePath: number;\n}\n\n/** Arguments object that can be validated for input lengths */\nexport interface ValidatableArgs {\n  query?: string;\n  title?: string;\n  specFolder?: string;\n  contextType?: string;\n  name?: string;\n  prompt?: string;\n  filePath?: string;\n  [key: string]: unknown;\n}\n\n/** Shared file path validation function signature */\nexport type SharedValidateFilePath = (filePath: string, allowedBasePaths: string[]) => string | null;\n\n// ───────────────────────────────────────────────────────────────\n// 2. CONFIGURATION CONSTANTS\n\n// ───────────────────────────────────────────────────────────────\nexport const INPUT_LIMITS: Readonly<InputLimits> = {\n  query: 10000,\n  title: 500,\n  specFolder: 200,\n  contextType: 100,\n  name: 200,\n  prompt: 10000,\n  filePath: 500\n} as const;\n\n/** Maximum query length for search operations */\nexport const MAX_QUERY_LENGTH: number = 10000;\n\n// ───────────────────────────────────────────────────────────────\n// 3. QUERY VALIDATION\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Validate and normalize a search query.\n * Properly rejects empty, null, and invalid queries.\n */\nexport function validateQuery(query: unknown): string {\n  if (query === null || query === undefined) {\n    throw new Error('Query cannot be null or undefined');\n  }\n  if (typeof query !== 'string') {\n    throw new Error('Query must be a string');\n  }\n  const normalized = query.trim();\n  if (normalized.length === 0) {\n    throw new Error('Query cannot be empty or whitespace-only');\n  }\n  if (normalized.length > MAX_QUERY_LENGTH) {\n    throw new Error(`Query exceeds maximum length of ${MAX_QUERY_LENGTH} characters`);\n  }\n  return normalized;\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. INPUT LENGTH VALIDATION\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Validate input string lengths\n * SEC-003: Input length enforcement for CWE-400 mitigation\n */\nexport function validateInputLengths(args: ValidatableArgs | null | undefined): void {\n  if (!args || typeof args !== 'object') return;\n\n  const checks: Array<[keyof InputLimits, number]> = [\n    ['query', INPUT_LIMITS.query],\n    ['title', INPUT_LIMITS.title],\n    ['specFolder', INPUT_LIMITS.specFolder],\n    ['contextType', INPUT_LIMITS.contextType],\n    ['name', INPUT_LIMITS.name],\n    ['prompt', INPUT_LIMITS.prompt],\n    ['filePath', INPUT_LIMITS.filePath]\n  ];\n\n  for (const [field, maxLength] of checks) {\n    const value = args[field];\n    if (value && typeof value === 'string' && value.length > maxLength) {\n      throw new Error(`Input '${field}' exceeds maximum length of ${maxLength} characters`);\n    }\n  }\n}\n\n// ───────────────────────────────────────────────────────────────\n// 5. FILE PATH VALIDATION\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Create a file path validator with specified allowed base paths\n */\nexport function createFilePathValidator(\n  allowedBasePaths: string[],\n  sharedValidateFilePath: SharedValidateFilePath\n): (filePath: string) => string {\n  /**\n   * Validate file path against allowed directories\n   */\n  return function validateFilePathLocal(filePath: string): string {\n    const result = sharedValidateFilePath(filePath, allowedBasePaths);\n    if (result === null) {\n      throw new Error('Access denied: Path outside allowed directories');\n    }\n    // Additional check for .. patterns (not just null bytes which shared handles)\n    if (filePath.includes('..')) {\n      throw new Error('Access denied: Invalid path pattern');\n    }\n    return result;\n  };\n}\n\n/**\n * Get default allowed base paths for file operations\n */\nexport function getDefaultAllowedPaths(defaultBasePath?: string): string[] {\n  const basePath = defaultBasePath || process.cwd();\n  return [\n    path.join(os.homedir(), '.claude'),\n    basePath,\n    process.cwd()\n  ]\n    .filter(Boolean)\n    .map(base => path.resolve(base));\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. (ESM exports above — no CommonJS module.exports needed)\n   ──────────────────────────────────────────────────────────────── */","lineStart":1,"lineEnd":151,"totalLines":151,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/utils/validators.ts","time":{"start":1781764328697,"end":1781764328706}},"metadata":{"openai":{"itemId":"fc_04e8cfa8ed3f23a5016a3390e82c788191837aec9297140ec2"}},"id":"prt_ed96e0b46001huMG4N3pQsGccJ","sessionID":"ses_12697c8bdffeYX14kJoM4Gnbam","messageID":"msg_ed96df936001QkJWX8e5MS5pnx"}}
