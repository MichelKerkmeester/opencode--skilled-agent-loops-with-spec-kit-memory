    87	function parseArgs(argv) {
    88	  const args = {};
    89	  for (let index = 0; index < argv.length; index += 1) {
    90	    const entry = argv[index];
    91	    const match = /^--([a-z][a-z0-9-]*)(?:=(.*))?$/.exec(entry);
    92	    if (!match) continue;
    93	    const key = match[1];
    94	    if (match[2] !== undefined) {
    95	      // =-form: byte-identical to the original behavior (TST-1 identity).
    96	      args[key] = match[2];
    97	      continue;
    98	    }
    99	    // Bare --key: if the next token is a value (does not start with '--'),
   100	    // consume it as the space-form value; otherwise it stays a boolean flag.
   101	    // The Lane B command surface invokes loop-host with space-form
   102	    // (--profile {p} --scorer 5dim --grader noop), so these must bind to the
   103	    // following token rather than parse as booleans (F-P0-1).
   104	    const next = argv[index + 1];
   105	    if (next !== undefined && !next.startsWith('--')) {
   106	      args[key] = next;
   107	      index += 1;
   108	    } else {
   109	      args[key] = true;
   110	    }
   111	  }
   112	  return args;
