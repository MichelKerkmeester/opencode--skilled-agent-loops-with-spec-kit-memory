   167	function loadBridgeModule() {
   168	  try {
   169	    return require('./lib/launcher-ipc-bridge.cjs');
   170	  } catch (error) {
   171	    if (error.code !== 'MODULE_NOT_FOUND') throw error;
   172	    return {
   173	      getIpcSocketPath(_serviceName, options = {}) {
   174	        if (process.env.SPECKIT_IPC_SOCKET_DIR?.startsWith('tcp://')) {
   175	          return process.env.SPECKIT_IPC_SOCKET_DIR;
   176	        }
   177	        const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR
   178	          ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)
   179	          : path.resolve(options.dbDir ?? resolvedAdvisorDbDir());
   180	        return path.join(socketDir, 'daemon-ipc.sock');
   181	      },
   182	      async maybeBridgeLeaseHolder({ leaseResult, legacyReport }) {
   183	        if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' && legacyReport) {
   184	          legacyReport(leaseResult);
   185	          return { action: 'report', reason: 'bridge-disabled' };
   186	        }
   187	        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();
   188	        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';
   189	        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker} (no-bridge-socket)\n`);
   190	        return { action: 'report', reason: 'bridge-module-missing' };
   190	        return { action: 'report', reason: 'bridge-module-missing' };
   191	      },
   192	    };
   193	  }
   194	}
