Filters: deprecated-tier exclusion and spec-folder matching handled by fts5Bm25Search\n613:     const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n614: \n615:     return bm25Results.map(row => ({\n616:       ...row,\n617:       id: row.id as number,\n618:       score: row.fts_score || 0,\n619:       source: 'fts',\n620:     }));\n621:   } catch (error: unknown) {\n622:     const msg = error instanceof Error ? error.message : String(error);\n623:     console.warn(`[hybrid-search] FTS search failed: ${msg}`);\n624:     return [];\n625:   }\n626: }\n627: \n628: // 10. COMBINED LEXICAL SEARCH\n629: \n630: /**\n631:  * Merge FTS and BM25 search results, deduplicating by ID and preferring FTS scores.\n632:  * @param query - The search query string.\n633:  * @param options - Optional limit, specFolder filter, and includeArchived flag.\n634:  * @returns Deduplicated array of merged results sorted by score descending.\n635:  */\n636: function combinedLexicalSearch(\n637:   query: string,\n638:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n639: ): HybridSearchResult[] {\n640:   const ftsResults = ftsSearch(query, options);\n641:   const bm25Results = bm25Search(query, options);\n642: \n643:   // Merge by canonical ID, prefer FTS scores.\n644:   // CanonicalResultId() prevents duplicate rows when one channel emits\n645:   // Numeric IDs (42) and another emits string IDs (\"42\" or \"mem:42\").\n646:   const merged = new Map<string, HybridSearchResult>();\n647: \n648:   for (const r of ftsResults) {\n649:     merged.set(canonicalResultId(r.id), r);\n650:   }\n651: \n652:   for (const r of bm25Results) {\n653:     const canonicalId = canonicalResultId(r.id);\n654:     if (!merged.has(canonicalId)) {\n655:       merged.set(canonicalId, r);\n656:     }\n657:   }\n658: \n659:   return Array.from(merged.values())\n660:     .sort((a, b) => b.score - a.score)\n661:     .slice(0, options.limit || DEFAULT_LIMIT);\n662: }\n663: \n664: function normalizeTriggerText(value: string): string {\n665:   return value\n666:     .toLowerCase()\n667:     .replace(/[^a-z0-9]+/g, ' ')\n668:     .replace(/\\s+/g, ' ')\n669:     .trim();\n670: }\n671: \n672: function triggerQueryTokens(query: string): string[] {\n673:   return Array.from(new Set(\n674:     normalizeTriggerText(query)\n675:       .split(/\\s+/)\n676:       .filter((token) => token.length >= 2)\n677:   ));\n678: }\n679: \n680: function computeTriggerMatchScore(query: string, phrase: string): number {\n681:   const normalizedQuery = normalizeTriggerText(query);\n682:   const normalizedPhrase = normalizeTriggerText(phrase);\n683:   if (!normalizedQuery || !normalizedPhrase) return 0;\n684:   if (normalizedPhrase === normalizedQuery) return 1.0;\n685: \n686:   const queryTokens = triggerQueryTokens(normalizedQuery);\n687:   const phraseTokens = new Set(triggerQueryTokens(normalizedPhrase));\n688:   if (phraseTokens.size < 2) return 0;\n689:   if (normalizedPhrase.includes(normalizedQuery)) return 0.94;\n690:   if (normalizedQuery.includes(normalizedPhrase)) return 0.88;\n691:   if (queryTokens.length === 0) return 0;\n692:   const overlap = queryTokens.filter((token) => phraseTokens.has(token)).length;\n693:   const coverage = overlap / queryTokens.length;\n694:   return coverage >= 0.8 ? coverage * 0.75 : 0;\n695: }\n696: \n697: function timestampBoost(value: unknown): number {\n698:   if (typeof value !== 'string' || value.length === 0) return 0;\n699:   const parsed = Date.parse(value);\n700:   if (!Number.isFinite(parsed)) return 0;\n701:   const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n702:   return 1 / (1 + ageDays / 30);\n703: }\n704: \n705: function exactTriggerSearch(\n706:   query: string,\n707:   options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n708: ): HybridSearchResult[] {\n709:   if (!db) return [];\n710: \n711:   const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n712:   if (tokens.length === 0) return [];\n713: \n714:   const { limit = DEFAULT_LIMIT, specFolder } = options;\n715:   const normalizedQuery = normalizeTriggerText(query);\n716:   const exactPhraseLike = `%${normalizedQuery}%`;\n717:   const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n718:   const conditions = [\n719:     `m.trigger_phrases IS NOT NULL`,\n720:     `m.trigger_phrases != ''`,\n721:     `m.trigger_phrases != '[]'`,\n722:     // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n723:     // them below hot memories); the hard exclusion only applies when archived\n724:     // retrieval is disabled.\n725:     ...(isArchivedRetrievalIncludedByDefault()\n726:       ? []\n727:       : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n728:     `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n729:     `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n730:   ];\n731:   const params: unknown[] = tokens.map((token) => `%${token}%`);\n732: \n733:   if (specFolder) {\n734:     conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n735:     params.push(specFolder, specFolderLikePattern(specFolder));\n736:   }\n737: \n738:   try {\n739:     const rows = db.prepare(`\n740:       SELECT m.*\n741:       FROM memory_index m\n742:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n743:       WHERE ${conditions.join(' AND ')}\n744:       ORDER BY\n745:         CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n746:         COALESCE(m.updated_at, m.created_at, '') DESC\n747:       LIMIT ${candidateLimit}\n748:     `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n749: \n750:     return rows\n751:       .map((row): HybridSearchResult | null => {\n752:         const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n753:         const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n754:         if (matchScore <= 0) return null;\n755: \n756:         const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n757:           ? Math.max(0, Math.min(1, row.importance_weight))\n758:           : 0.5;\n759:         const recency = timestampBoost(row.updated_at ?? row.created_at);\n760:         const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n761: \n762:         return {\n763:           ...row,\n764:           id: row.id as number,\n765:           score,\n766:           triggerScore: matchScore,\n767:           source: 'trigger',\n768:         };\n769:       })\n770:       .filter((row): row is HybridSearchResult => row !== null)\n771:       .sort((a, b) => {\n772:         const scoreDelta = b.score - a.score;\n773:         if (scoreDelta !== 0) return scoreDelta;\n774:         const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n775:         const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n776:         return bTime - aTime;\n777:       })\n778:       .slice(0, limit);\n779:   } catch (error: unknown) {\n780:     const msg = error instanceof Error ? error.message : String(error);\n781:     console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n782:     return [];\n783:   }\n784: }\n785: \n786: type RawChannelList = {\n787:   source: string;\n788:   results: Array<{ id: number | string; [key: string]: unknown }>;\n789: };\n790: \n791: function resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n792:   if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n793:     return result.score;\n794:   }\n795:   if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n796:     return result.similarity / 100;\n797:   }\n798:   return 0;\n799: }\n\n(Showing lines 580-799 of 2972. Use offset=800 to continue.)\n</content>","metadata":{"preview":"  try {\n    const result = (db.prepare(`\n      SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'\n    `) as Database.Statement).get() as { name: string } | undefined;\n    return !!result;\n  } catch (_err: unknown) {\n    // Swallow DB errors; caller treats absence as unavailable\n    return false;\n  }\n}\n\n/**\n * Run FTS5 full-text search with weighted BM25 scoring and optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Array of FTS-scored results tagged with source 'fts'.\n */\nfunction ftsSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"  try {\n    const result = (db.prepare(`\n      SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'\n    `) as Database.Statement).get() as { name: string } | undefined;\n    return !!result;\n  } catch (_err: unknown) {\n    // Swallow DB errors; caller treats absence as unavailable\n    return false;\n  }\n}\n\n/**\n * Run FTS5 full-text search with weighted BM25 scoring and optional spec folder filtering.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Array of FTS-scored results tagged with source 'fts'.\n */\nfunction ftsSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db || !isFtsAvailable()) {\n    console.warn('[hybrid-search] db not initialized or FTS unavailable — returning empty ftsSearch results');\n    return [];\n  }\n\n  const { limit = DEFAULT_LIMIT, specFolder, includeArchived = false } = options;\n\n  try {\n    // Delegate to weighted BM25 FTS5 search from sqlite-fts.ts\n    // Uses bm25(memory_fts, 10.0, 5.0, 2.0, 1.0) for per-column weighting\n    // (title 10x, trigger_phrases 5x, file_path 2x, content 1x)\n    // Filters: deprecated-tier exclusion and spec-folder matching handled by fts5Bm25Search\n    const bm25Results = fts5Bm25Search(db, query, { limit, specFolder, includeArchived });\n\n    return bm25Results.map(row => ({\n      ...row,\n      id: row.id as number,\n      score: row.fts_score || 0,\n      source: 'fts',\n    }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] FTS search failed: ${msg}`);\n    return [];\n  }\n}\n\n// 10. COMBINED LEXICAL SEARCH\n\n/**\n * Merge FTS and BM25 search results, deduplicating by ID and preferring FTS scores.\n * @param query - The search query string.\n * @param options - Optional limit, specFolder filter, and includeArchived flag.\n * @returns Deduplicated array of merged results sorted by score descending.\n */\nfunction combinedLexicalSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  const ftsResults = ftsSearch(query, options);\n  const bm25Results = bm25Search(query, options);\n\n  // Merge by canonical ID, prefer FTS scores.\n  // CanonicalResultId() prevents duplicate rows when one channel emits\n  // Numeric IDs (42) and another emits string IDs (\"42\" or \"mem:42\").\n  const merged = new Map<string, HybridSearchResult>();\n\n  for (const r of ftsResults) {\n    merged.set(canonicalResultId(r.id), r);\n  }\n\n  for (const r of bm25Results) {\n    const canonicalId = canonicalResultId(r.id);\n    if (!merged.has(canonicalId)) {\n      merged.set(canonicalId, r);\n    }\n  }\n\n  return Array.from(merged.values())\n    .sort((a, b) => b.score - a.score)\n    .slice(0, options.limit || DEFAULT_LIMIT);\n}\n\nfunction normalizeTriggerText(value: string): string {\n  return value\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n}\n\nfunction triggerQueryTokens(query: string): string[] {\n  return Array.from(new Set(\n    normalizeTriggerText(query)\n      .split(/\\s+/)\n      .filter((token) => token.length >= 2)\n  ));\n}\n\nfunction computeTriggerMatchScore(query: string, phrase: string): number {\n  const normalizedQuery = normalizeTriggerText(query);\n  const normalizedPhrase = normalizeTriggerText(phrase);\n  if (!normalizedQuery || !normalizedPhrase) return 0;\n  if (normalizedPhrase === normalizedQuery) return 1.0;\n\n  const queryTokens = triggerQueryTokens(normalizedQuery);\n  const phraseTokens = new Set(triggerQueryTokens(normalizedPhrase));\n  if (phraseTokens.size < 2) return 0;\n  if (normalizedPhrase.includes(normalizedQuery)) return 0.94;\n  if (normalizedQuery.includes(normalizedPhrase)) return 0.88;\n  if (queryTokens.length === 0) return 0;\n  const overlap = queryTokens.filter((token) => phraseTokens.has(token)).length;\n  const coverage = overlap / queryTokens.length;\n  return coverage >= 0.8 ? coverage * 0.75 : 0;\n}\n\nfunction timestampBoost(value: unknown): number {\n  if (typeof value !== 'string' || value.length === 0) return 0;\n  const parsed = Date.parse(value);\n  if (!Number.isFinite(parsed)) return 0;\n  const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n  return 1 / (1 + ageDays / 30);\n}\n\nfunction exactTriggerSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db) return [];\n\n  const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n  if (tokens.length === 0) return [];\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n  const normalizedQuery = normalizeTriggerText(query);\n  const exactPhraseLike = `%${normalizedQuery}%`;\n  const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n  const conditions = [\n    `m.trigger_phrases IS NOT NULL`,\n    `m.trigger_phrases != ''`,\n    `m.trigger_phrases != '[]'`,\n    // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n    // them below hot memories); the hard exclusion only applies when archived\n    // retrieval is disabled.\n    ...(isArchivedRetrievalIncludedByDefault()\n      ? []\n      : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n    `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n    `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n  ];\n  const params: unknown[] = tokens.map((token) => `%${token}%`);\n\n  if (specFolder) {\n    conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  try {\n    const rows = db.prepare(`\n      SELECT m.*\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE ${conditions.join(' AND ')}\n      ORDER BY\n        CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n        COALESCE(m.updated_at, m.created_at, '') DESC\n      LIMIT ${candidateLimit}\n    `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n\n    return rows\n      .map((row): HybridSearchResult | null => {\n        const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n        const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n        if (matchScore <= 0) return null;\n\n        const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n          ? Math.max(0, Math.min(1, row.importance_weight))\n          : 0.5;\n        const recency = timestampBoost(row.updated_at ?? row.created_at);\n        const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n\n        return {\n          ...row,\n          id: row.id as number,\n          score,\n          triggerScore: matchScore,\n          source: 'trigger',\n        };\n      })\n      .filter((row): row is HybridSearchResult => row !== null)\n      .sort((a, b) => {\n        const scoreDelta = b.score - a.score;\n        if (scoreDelta !== 0) return scoreDelta;\n        const bTime = Date.parse(String(b.updated_at ?? b.created_at ?? '')) || 0;\n        const aTime = Date.parse(String(a.updated_at ?? a.created_at ?? '')) || 0;\n        return bTime - aTime;\n      })\n      .slice(0, limit);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Trigger phrase search failed: ${msg}`);\n    return [];\n  }\n}\n\ntype RawChannelList = {\n  source: string;\n  results: Array<{ id: number | string; [key: string]: unknown }>;\n};\n\nfunction resolveRawCandidateScore(result: { score?: unknown; similarity?: unknown }): number {\n  if (typeof result.score === 'number' && Number.isFinite(result.score)) {\n    return result.score;\n  }\n  if (typeof result.similarity === 'number' && Number.isFinite(result.similarity)) {\n    return result.similarity / 100;\n  }\n  return 0;\n}","lineStart":580,"lineEnd":799,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781764189253,"end":1781764189265}},"metadata":{"openai":{"itemId":"fc_0a832f684a8a0901016a33905d171c81918e7feb106c3267e4"}},"id":"prt_ed96bec3f001F5hRwJIXM1Vf2d","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96bc7520017kcKyJ11jH1CKX"}}
{"type":"tool_use","timestamp":1781764189267,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_3TmUmSrqKqHHfndeSmbiyoma","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":2080,"limit":250},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n2080:  * @returns Unfused candidate results from the first non-empty collection stage.\n2081:  */\n2082: async function collectRawCandidates(\n2083:   query: string,\n2084:   embedding: Float32Array | number[] | null,\n2085:   options: HybridSearchOptions = {}\n2086: ): Promise<HybridSearchResult[]> {\n2087:   const { allowedChannels, stages } = await executeFallbackPlan(\n2088:     query,\n2089:     embedding,\n2090:     options,\n2091:     isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n2092:     { stopAfterFusion: true }\n2093:   );\n2094: \n2095:   const primaryResults = stages[0]?.results ?? [];\n2096:   const retryResults = stages[1]?.results ?? [];\n2097: \n2098:   if (isSearchFallbackEnabled()) {\n2099:     const mergedResults = retryResults.length > 0\n2100:       ? mergeRawCandidateSets(primaryResults, retryResults, options.limit)\n2101:       : primaryResults;\n2102:     if (mergedResults.length > 0) return applyResultLimit(mergedResults, options.limit);\n2103:   } else {\n2104:     const stagedResults = retryResults.length > 0 ? retryResults : primaryResults;\n2105:     if (stagedResults.length > 0) return applyResultLimit(stagedResults, options.limit);\n2106:   }\n2107: \n2108:   if (allowedChannels.has('fts')) {\n2109:     const ftsFallback = collectCandidatesFromLists(\n2110:       [{ source: 'fts', results: ftsSearch(query, options) }],\n2111:       options.limit\n2112:     );\n2113:     if (ftsFallback.length > 0) return ftsFallback;\n2114:   }\n2115: \n2116:   if (allowedChannels.has('bm25')) {\n2117:     const bm25Fallback = collectCandidatesFromLists(\n2118:       [{ source: 'bm25', results: bm25Search(query, options) }],\n2119:       options.limit\n2120:     );\n2121:     if (bm25Fallback.length > 0) return bm25Fallback;\n2122:   }\n2123: \n2124:   console.warn('[hybrid-search] Raw candidate collection returned empty results');\n2125:   return [];\n2126: }\n2127: \n2128: /**\n2129:  * Search with automatic fallback chain.\n2130:  * When SPECKIT_SEARCH_FALLBACK=true: delegates to the 3-tier quality-aware\n2131:    * fallback (searchWithFallbackTiered). Otherwise: two-pass adaptive\n2132:  * fallback — primary at minSimilarity=30, retry at 17.\n2133:  *\n2134:  * @param query - The search query string.\n2135:  * @param embedding - Optional embedding vector for semantic search.\n2136:  * @param options - Hybrid search configuration options.\n2137:  * @returns Results from the first non-empty stage.\n2138:  */\n2139: async function searchWithFallback(\n2140:   query: string,\n2141:   embedding: Float32Array | number[] | null,\n2142:   options: HybridSearchOptions = {}\n2143: ): Promise<HybridSearchResult[]> {\n2144:   // PI-A2: Delegate to tiered fallback when flag is enabled\n2145:   if (isSearchFallbackEnabled()) {\n2146:     return searchWithFallbackTiered(query, embedding, options);\n2147:   }\n2148: \n2149:   // Primary 30 filters noise; fallback 17 widens recall for sparse corpora\n2150:   // Where no result exceeds the primary threshold — chosen empirically via eval.\n2151:   // Use hybridSearchEnhanced (with RRF fusion) instead of\n2152:   // The naive hybridSearch that merges raw scores\n2153:   const { allowedChannels, stages } = await executeFallbackPlan(\n2154:     query,\n2155:     embedding,\n2156:     options,\n2157:     'adaptive'\n2158:   );\n2159:   const primaryStage = stages[0];\n2160:   const retryStage = stages[1];\n2161:   const finalStage = retryStage?.results.length ? retryStage : primaryStage;\n2162:   if (finalStage?.results.length) {\n2163:     return finalStage.execution\n2164:       ? enrichFusedResults(query, finalStage.execution, finalStage.options, finalStage.results)\n2165:       : finalStage.results;\n2166:   }\n2167: \n2168:   // Fallback to FTS only\n2169:   if (allowedChannels.has('fts')) {\n2170:     const ftsResults = ftsSearch(query, options);\n2171:     if (ftsResults.length > 0) return ftsResults;\n2172:   }\n2173: \n2174:   // Fallback to BM25 only\n2175:   if (allowedChannels.has('bm25')) {\n2176:     const bm25Results = bm25Search(query, options);\n2177:     if (bm25Results.length > 0) return bm25Results;\n2178:   }\n2179: \n2180:   console.warn('[hybrid-search] All search methods returned empty results');\n2181:   return [];\n2182: }\n2183: \n2184: // 12. STRUCTURAL SEARCH (PI-A2 TIER 3)\n2185: \n2186: /**\n2187:  * PI-A2: Last-resort structural search against the memory_index table.\n2188:  * Retrieves memories ordered by importance tier and weight, without\n2189:  * requiring embeddings or text similarity. Pure SQL fallback.\n2190:  *\n2191:  * @param options - Search options (specFolder for filtering, limit for cap).\n2192:  * @returns Array of HybridSearchResult with source='structural'.\n2193:  */\n2194: function structuralSearch(\n2195:   options: Pick<HybridSearchOptions, 'specFolder' | 'limit'> = {}\n2196: ): HybridSearchResult[] {\n2197:   if (!db) {\n2198:     console.warn('[hybrid-search] db not initialized — returning empty structuralSearch results');\n2199:     return [];\n2200:   }\n2201: \n2202:   const limit = options.limit ?? DEFAULT_LIMIT;\n2203: \n2204:   try {\n2205:     // Build SQL with optional specFolder filter\n2206:     // Exclude archived rows unless explicitly requested\n2207:     const conditions = [\n2208:       `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n2209:     ];\n2210:     const params: unknown[] = [];\n2211: \n2212:     if (options.specFolder) {\n2213:       conditions.push(`(spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')`);\n2214:       params.push(options.specFolder, specFolderLikePattern(options.specFolder));\n2215:     }\n2216: \n2217:     const whereClause = conditions.join(' AND ');\n2218: \n2219:     const sql = `\n2220:       SELECT id, title, file_path, importance_tier, importance_weight, spec_folder\n2221:       FROM memory_index\n2222:       WHERE ${whereClause}\n2223:       ORDER BY\n2224:         CASE importance_tier\n2225:           WHEN 'constitutional' THEN 1\n2226:           WHEN 'critical' THEN 2\n2227:           WHEN 'important' THEN 3\n2228:           WHEN 'normal' THEN 4\n2229:           WHEN 'temporary' THEN 5\n2230:           ELSE 6\n2231:         END ASC,\n2232:         importance_weight DESC,\n2233:         created_at DESC\n2234:       LIMIT ?\n2235:     `;\n2236:     params.push(limit);\n2237: \n2238:     const stmt = db.prepare(sql);\n2239:     const rows = stmt.all(...params) as Array<Record<string, unknown>>;\n2240: \n2241:     return rows.map((row, index) => ({\n2242:       id: row.id as number,\n2243:       score: Math.max(0, 1.0 - index * 0.05),\n2244:       source: 'structural',\n2245:       title: (row.title as string) ?? undefined,\n2246:       file_path: row.file_path as string,\n2247:       importance_tier: row.importance_tier as string,\n2248:       spec_folder: row.spec_folder as string,\n2249:     }));\n2250:   } catch (error: unknown) {\n2251:     const msg = error instanceof Error ? error.message : String(error);\n2252:     console.warn(`[hybrid-search] Structural search failed: ${msg}`);\n2253:     return [];\n2254:   }\n2255: }\n2256: \n2257: /**\n2258:  * Normalize result IDs to a canonical key used for deduplication and source tracking.\n2259:  * Handles number-vs-string drift (`42` vs `\"42\"`) and legacy `mem:42` forms.\n2260:  */\n2261: function canonicalResultId(id: number | string): string {\n2262:   if (typeof id === 'number') {\n2263:     return String(id);\n2264:   }\n2265: \n2266:   const raw = String(id).trim();\n2267:   const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n2268:   if (memPrefixed) {\n2269:     return String(Number(memPrefixed[1]));\n2270:   }\n2271: \n2272:   if (/^\\d+$/.test(raw)) {\n2273:     return String(Number(raw));\n2274:   }\n2275: \n2276:   return raw;\n2277: }\n2278: \n2279: function truncateChars(input: string, maxChars: number): string {\n2280:   if (input.length <= maxChars) return input;\n2281:   if (maxChars <= 1) return input.slice(0, maxChars);\n2282:   return `${input.slice(0, maxChars - 1).trimEnd()}…`;\n2283: }\n2284: \n2285: function extractSpecSegments(filePath: string): { left: string; right: string; tailKey: string } | null {\n2286:   const normalized = filePath.replace(/\\\\/g, '/');\n2287:   const splitToken = '/specs/';\n2288:   const splitIdx = normalized.lastIndexOf(splitToken);\n2289:   if (splitIdx < 0) return null;\n2290: \n2291:   const relative = normalized.slice(splitIdx + splitToken.length).replace(/^\\/+/, '');\n2292:   const parts = relative.split('/').filter(Boolean);\n2293:   if (parts.length < 2) return null;\n2294: \n2295:   // Prefer spec-folder extraction up to /memory/ so we get [parent > child]\n2296:   // For canonical memory paths like:\n2297:   // .../specs/<parent>/<child>/memory/<file>.md\n2298:   const memoryIdx = parts.indexOf('memory');\n2299:   const scopeParts = memoryIdx >= 0 ? parts.slice(0, memoryIdx) : parts.slice(0, -1);\n2300:   const tailParts = scopeParts.slice(-2);\n2301:   if (tailParts.length < 2) return null;\n2302: \n2303:   return {\n2304:     left: tailParts[0],\n2305:     right: tailParts[1],\n2306:     tailKey: tailParts.join('/'),\n2307:   };\n2308: }\n2309: \n2310: // Memoize description map to avoid rebuilding on every search query.\n2311: // Cache invalidates after 60 seconds so folder renames are eventually picked up.\n2312: // Return stale cache immediately and refresh asynchronously to avoid\n2313: // blocking the search hot path with synchronous filesystem crawls.\n2314: let descMapCache: { map: Map<string, string>; timestamp: number } | null = null;\n2315: let descMapRefreshing = false;\n2316: const DESC_MAP_TTL_MS = 60_000;\n2317: \n2318: function rebuildDescriptionTailMap(): Map<string, string> {\n2319:   const descByTail = new Map<string, string>();\n2320:   const cache = ensureDescriptionCache(getSpecsBasePaths());\n2321:   if (!cache || !Array.isArray(cache.folders)) {\n2322:     return descByTail;\n2323:   }\n2324: \n2325:   for (const entry of cache.folders) {\n2326:     const specFolder = typeof entry.specFolder === 'string' ? entry.specFolder : '';\n2327:     const description = typeof entry.description === 'string' ? entry.description : '';\n2328:     if (!specFolder || !description) continue;\n2329:     const folderParts = specFolder.split('/').filter(Boolean);\n\n(Showing lines 2080-2329 of 2972. Use offset=2330 to continue.)\n</content>","metadata":{"preview":" * @returns Unfused candidate results from the first non-empty collection stage.\n */\nasync function collectRawCandidates(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n    { stopAfterFusion: true }\n  );\n\n  const primaryResults = stages[0]?.results ?? [];\n  const retryResults = stages[1]?.results ?? [];\n\n  if (isSearchFallbackEnabled()) {\n    const mergedResults = retryResults.length > 0","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":" * @returns Unfused candidate results from the first non-empty collection stage.\n */\nasync function collectRawCandidates(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n    { stopAfterFusion: true }\n  );\n\n  const primaryResults = stages[0]?.results ?? [];\n  const retryResults = stages[1]?.results ?? [];\n\n  if (isSearchFallbackEnabled()) {\n    const mergedResults = retryResults.length > 0\n      ? mergeRawCandidateSets(primaryResults, retryResults, options.limit)\n      : primaryResults;\n    if (mergedResults.length > 0) return applyResultLimit(mergedResults, options.limit);\n  } else {\n    const stagedResults = retryResults.length > 0 ? retryResults : primaryResults;\n    if (stagedResults.length > 0) return applyResultLimit(stagedResults, options.limit);\n  }\n\n  if (allowedChannels.has('fts')) {\n    const ftsFallback = collectCandidatesFromLists(\n      [{ source: 'fts', results: ftsSearch(query, options) }],\n      options.limit\n    );\n    if (ftsFallback.length > 0) return ftsFallback;\n  }\n\n  if (allowedChannels.has('bm25')) {\n    const bm25Fallback = collectCandidatesFromLists(\n      [{ source: 'bm25', results: bm25Search(query, options) }],\n      options.limit\n    );\n    if (bm25Fallback.length > 0) return bm25Fallback;\n  }\n\n  console.warn('[hybrid-search] Raw candidate collection returned empty results');\n  return [];\n}\n\n/**\n * Search with automatic fallback chain.\n * When SPECKIT_SEARCH_FALLBACK=true: delegates to the 3-tier quality-aware\n   * fallback (searchWithFallbackTiered). Otherwise: two-pass adaptive\n * fallback — primary at minSimilarity=30, retry at 17.\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Results from the first non-empty stage.\n */\nasync function searchWithFallback(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  // PI-A2: Delegate to tiered fallback when flag is enabled\n  if (isSearchFallbackEnabled()) {\n    return searchWithFallbackTiered(query, embedding, options);\n  }\n\n  // Primary 30 filters noise; fallback 17 widens recall for sparse corpora\n  // Where no result exceeds the primary threshold — chosen empirically via eval.\n  // Use hybridSearchEnhanced (with RRF fusion) instead of\n  // The naive hybridSearch that merges raw scores\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    'adaptive'\n  );\n  const primaryStage = stages[0];\n  const retryStage = stages[1];\n  const finalStage = retryStage?.results.length ? retryStage : primaryStage;\n  if (finalStage?.results.length) {\n    return finalStage.execution\n      ? enrichFusedResults(query, finalStage.execution, finalStage.options, finalStage.results)\n      : finalStage.results;\n  }\n\n  // Fallback to FTS only\n  if (allowedChannels.has('fts')) {\n    const ftsResults = ftsSearch(query, options);\n    if (ftsResults.length > 0) return ftsResults;\n  }\n\n  // Fallback to BM25 only\n  if (allowedChannels.has('bm25')) {\n    const bm25Results = bm25Search(query, options);\n    if (bm25Results.length > 0) return bm25Results;\n  }\n\n  console.warn('[hybrid-search] All search methods returned empty results');\n  return [];\n}\n\n// 12. STRUCTURAL SEARCH (PI-A2 TIER 3)\n\n/**\n * PI-A2: Last-resort structural search against the memory_index table.\n * Retrieves memories ordered by importance tier and weight, without\n * requiring embeddings or text similarity. Pure SQL fallback.\n *\n * @param options - Search options (specFolder for filtering, limit for cap).\n * @returns Array of HybridSearchResult with source='structural'.\n */\nfunction structuralSearch(\n  options: Pick<HybridSearchOptions, 'specFolder' | 'limit'> = {}\n): HybridSearchResult[] {\n  if (!db) {\n    console.warn('[hybrid-search] db not initialized — returning empty structuralSearch results');\n    return [];\n  }\n\n  const limit = options.limit ?? DEFAULT_LIMIT;\n\n  try {\n    // Build SQL with optional specFolder filter\n    // Exclude archived rows unless explicitly requested\n    const conditions = [\n      `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n    ];\n    const params: unknown[] = [];\n\n    if (options.specFolder) {\n      conditions.push(`(spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')`);\n      params.push(options.specFolder, specFolderLikePattern(options.specFolder));\n    }\n\n    const whereClause = conditions.join(' AND ');\n\n    const sql = `\n      SELECT id, title, file_path, importance_tier, importance_weight, spec_folder\n      FROM memory_index\n      WHERE ${whereClause}\n      ORDER BY\n        CASE importance_tier\n          WHEN 'constitutional' THEN 1\n          WHEN 'critical' THEN 2\n          WHEN 'important' THEN 3\n          WHEN 'normal' THEN 4\n          WHEN 'temporary' THEN 5\n          ELSE 6\n        END ASC,\n        importance_weight DESC,\n        created_at DESC\n      LIMIT ?\n    `;\n    params.push(limit);\n\n    const stmt = db.prepare(sql);\n    const rows = stmt.all(...params) as Array<Record<string, unknown>>;\n\n    return rows.map((row, index) => ({\n      id: row.id as number,\n      score: Math.max(0, 1.0 - index * 0.05),\n      source: 'structural',\n      title: (row.title as string) ?? undefined,\n      file_path: row.file_path as string,\n      importance_tier: row.importance_tier as string,\n      spec_folder: row.spec_folder as string,\n    }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Structural search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Normalize result IDs to a canonical key used for deduplication and source tracking.\n * Handles number-vs-string drift (`42` vs `\"42\"`) and legacy `mem:42` forms.\n */\nfunction canonicalResultId(id: number | string): string {\n  if (typeof id === 'number') {\n    return String(id);\n  }\n\n  const raw = String(id).trim();\n  const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n  if (memPrefixed) {\n    return String(Number(memPrefixed[1]));\n  }\n\n  if (/^\\d+$/.test(raw)) {\n    return String(Number(raw));\n  }\n\n  return raw;\n}\n\nfunction truncateChars(input: string, maxChars: number): string {\n  if (input.length <= maxChars) return input;\n  if (maxChars <= 1) return input.slice(0, maxChars);\n  return `${input.slice(0, maxChars - 1).trimEnd()}…`;\n}\n\nfunction extractSpecSegments(filePath: string): { left: string; right: string; tailKey: string } | null {\n  const normalized = filePath.replace(/\\\\/g, '/');\n  const splitToken = '/specs/';\n  const splitIdx = normalized.lastIndexOf(splitToken);\n  if (splitIdx < 0) return null;\n\n  const relative = normalized.slice(splitIdx + splitToken.length).replace(/^\\/+/, '');\n  const parts = relative.split('/').filter(Boolean);\n  if (parts.length < 2) return null;\n\n  // Prefer spec-folder extraction up to /memory/ so we get [parent > child]\n  // For canonical memory paths like:\n  // .../specs/<parent>/<child>/memory/<file>.md\n  const memoryIdx = parts.indexOf('memory');\n  const scopeParts = memoryIdx >= 0 ? parts.slice(0, memoryIdx) : parts.slice(0, -1);\n  const tailParts = scopeParts.slice(-2);\n  if (tailParts.length < 2) return null;\n\n  return {\n    left: tailParts[0],\n    right: tailParts[1],\n    tailKey: tailParts.join('/'),\n  };\n}\n\n// Memoize description map to avoid rebuilding on every search query.\n// Cache invalidates after 60 seconds so folder renames are eventually picked up.\n// Return stale cache immediately and refresh asynchronously to avoid\n// blocking the search hot path with synchronous filesystem crawls.\nlet descMapCache: { map: Map<string, string>; timestamp: number } | null = null;\nlet descMapRefreshing = false;\nconst DESC_MAP_TTL_MS = 60_000;\n\nfunction rebuildDescriptionTailMap(): Map<string, string> {\n  const descByTail = new Map<string, string>();\n  const cache = ensureDescriptionCache(getSpecsBasePaths());\n  if (!cache || !Array.isArray(cache.folders)) {\n    return descByTail;\n  }\n\n  for (const entry of cache.folders) {\n    const specFolder = typeof entry.specFolder === 'string' ? entry.specFolder : '';\n    const description = typeof entry.description === 'string' ? entry.description : '';\n    if (!specFolder || !description) continue;\n    const folderParts = specFolder.split('/').filter(Boolean);","lineStart":2080,"lineEnd":2329,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781764189259,"end":1781764189266}},"metadata":{"openai":{"itemId":"fc_0a832f684a8a0901016a33905d1728819193743025eea233ca"}},"id":"prt_ed96bec46001WBKHZal5K9EL6D","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96bc7520017kcKyJ11jH1CKX"}}
{"type":"tool_use","timestamp":1781764189357,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_gk4wGuj55ooMXpKA6MACldHX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":2400,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n2400:     if (!deduped.has(key)) {\n2401:       deduped.set(key, result);\n2402:     }\n2403:   }\n2404:   return Array.from(deduped.values());\n2405: }\n2406: \n2407: /** Apply caller limit after merges that can expand result count. */\n2408: function applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n2409:   if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n2410:     return results;\n2411:   }\n2412:   return results.slice(0, limit);\n2413: }\n2414: \n2415: /** Depth of the result head rebalanced by the cosine-primary reorder. */\n2416: const COSINE_TOPN_REORDER_DEPTH = 10;\n2417: \n2418: /**\n2419:  * Cosine-primary reorder of the result head.\n2420:  *\n2421:  * Reorders only the top-N by absolute cosine relevance (resolveAbsoluteRelevance),\n2422:  * as a STABLE sort so equal-relevance items keep their incoming fused (RRF) order.\n2423:  * RRF fusion remains the ranking baseline; only the head — where position 1 is now\n2424:  * decisive for downstream consumers — is rebalanced toward the strongest absolute\n2425:  * semantic signal. Vector hits carry a real cosine; lexical-only hits fall back to\n2426:  * the effective score, so a strong lexical hit is not unfairly zeroed out. Length\n2427:  * and membership are invariant — this only permutes the head.\n2428:  */\n2429: function reorderTopNByCosine(\n2430:   results: HybridSearchResult[],\n2431:   depth: number = COSINE_TOPN_REORDER_DEPTH\n2432: ): HybridSearchResult[] {\n2433:   const headCount = Math.min(depth, results.length);\n2434:   if (headCount <= 1) return results;\n2435: \n2436:   const head = results.slice(0, headCount);\n2437:   // Decorate with the original index so equal-relevance ties resolve to fused\n2438:   // order regardless of the engine's sort stability.\n2439:   const reordered = head\n2440:     .map((row, index) => ({ row, index, relevance: resolveAbsoluteRelevance(row as PipelineRow) }))\n2441:     .sort((a, b) => (b.relevance - a.relevance) || (a.index - b.index))\n2442:     .map((entry) => entry.row);\n2443: \n2444:   return [...reordered, ...results.slice(headCount)];\n2445: }\n2446: \n2447: /** Tier-3 structural results are capped at this fraction of the top existing score. */\n2448: const TIER3_CAP_RATIO = 0.5;\n2449: /** Per-rank score decay for Tier-3 results, as a fraction of the top existing score. */\n2450: const TIER3_DECAY_PER_RANK = 0.08;\n2451: \n2452: /**\n2453:  * Keep Tier 3 structural fallback scores below established Tier 1/2 confidence.\n2454:  * Prevents structural placeholders from outranking stronger semantic/lexical hits.\n2455:  */\n2456: function calibrateTier3Scores(\n2457:   existing: HybridSearchResult[],\n2458:   tier3: HybridSearchResult[]\n2459: ): HybridSearchResult[] {\n2460:   const topExisting = existing.reduce((max, row) => {\n2461:     if (typeof row.score !== 'number' || !Number.isFinite(row.score)) {\n2462:       return max;\n2463:     }\n2464:     return Math.max(max, row.score);\n2465:   }, 0);\n2466: \n2467:   if (topExisting <= 0) {\n2468:     return tier3;\n2469:   }\n2470: \n2471:   const topCap = topExisting * TIER3_CAP_RATIO;\n2472:   const decayPerRank = topExisting * TIER3_DECAY_PER_RANK;\n2473: \n2474:   return tier3.map((row, index) => {\n2475:     const calibrated = Math.max(0, topCap - (index * decayPerRank));\n2476:     return {\n2477:       ...row,\n2478:       score: Math.min(row.score, calibrated),\n2479:     };\n2480:   });\n2481: }\n2482: \n2483: // 13. TIERED FALLBACK (PI-A2)\n2484: \n2485: /**\n2486:  * Evaluate whether results meet quality thresholds.\n2487:  * Returns null if thresholds are met, or a DegradationTrigger if not.\n2488:  */\n2489: function checkDegradation(results: HybridSearchResult[]): DegradationTrigger | null {\n2490:   const scores = results\n2491:     .map(r => r.score)\n2492:     .filter((score): score is number => typeof score === 'number' && Number.isFinite(score))\n2493:     .sort((a, b) => b - a);\n2494: \n2495:   const topScore = scores[0] ?? 0;\n2496:   const secondScore = scores[1] ?? 0;\n2497:   const relativeGap = topScore > 0 ? (topScore - secondScore) / topScore : 0;\n2498:   const count = results.length;\n2499: \n2500:   const lowQuality =\n2501:     topScore < DEGRADATION_QUALITY_THRESHOLD\n2502:     && relativeGap < DEGRADATION_MIN_RELATIVE_GAP;\n2503:   const insufficientResults = count < DEGRADATION_MIN_RESULTS;\n2504: \n2505:   if (!lowQuality && !insufficientResults) return null;\n2506: \n2507:   return {\n2508:     reason: lowQuality && insufficientResults ? 'both'\n2509:       : lowQuality ? 'low_quality'\n2510:       : 'insufficient_results',\n2511:     topScore,\n2512:     resultCount: count,\n2513:     relativeGap,\n2514:   };\n2515: }\n2516: \n2517: /**\n2518:  * Merge two result arrays, deduplicating by id and keeping the higher score.\n2519:  */\n2520: function mergeResults(\n2521:   existing: HybridSearchResult[],\n2522:   incoming: HybridSearchResult[]\n2523: ): HybridSearchResult[] {\n2524:   const byId = new Map<string, HybridSearchResult>();\n2525: \n2526:   for (const r of existing) {\n2527:     byId.set(canonicalResultId(r.id), r);\n2528:   }\n2529:   for (const r of incoming) {\n2530:     const key = canonicalResultId(r.id);\n2531:     const prev = byId.get(key);\n2532:     if (!prev || r.score > prev.score) {\n2533:       byId.set(key, r);\n2534:     }\n2535:   }\n2536: \n2537:   return Array.from(byId.values()).sort((a, b) => b.score - a.score);\n2538: }\n2539: \n2540: /**\n2541:  * PI-A2: Quality-aware 3-tier search fallback chain.\n2542:  *\n2543:  * TIER 1: hybridSearchEnhanced at minSimilarity=30\n2544:  *   → Pass if quality signal is healthy AND count >= 3\n2545:  *\n2546:  * TIER 2: hybridSearchEnhanced at minSimilarity=10, all allowed channels forced\n2547:  *   → Merge with Tier 1, dedup by id\n2548:  *   → Pass if quality signal is healthy AND count >= 3\n2549:  *\n2550:  * TIER 3: structuralSearch (pure SQL last-resort)\n2551:  *   → Merge with Tier 1+2 results after score calibration\n2552:  *   → Return capped set\n2553:  *\n2554:  * @param query - The search query string.\n2555:  * @param embedding - Optional embedding vector for semantic search.\n2556:  * @param options - Hybrid search configuration options.\n2557:  * @returns Results with _degradation metadata attached as non-enumerable property.\n2558:  */\n2559: async function searchWithFallbackTiered(\n2560:   query: string,\n2561:   embedding: Float32Array | number[] | null,\n2562:   options: HybridSearchOptions = {}\n2563: ): Promise<HybridSearchResult[]> {\n2564:   const degradationEvents: DegradationEvent[] = [];\n2565:   const { stages } = await executeFallbackPlan(query, embedding, options, 'tiered');\n2566:   const tier1Stage = stages[0];\n2567:   const tier2Stage = stages[1];\n2568:   let results = tier1Stage?.results ?? [];\n2569:   let enrichmentExecution = tier1Stage?.execution ?? null;\n2570:   let enrichmentOptions = tier1Stage?.options ?? options;\n2571: \n2572:   const tier1Trigger = checkDegradation(results);\n2573:   if (tier1Trigger) {\n2574:     // TIER 2: Widen search — lower similarity, force all channels\n2575:     const tier1CountBefore = results.length;\n2576: \n2577:     console.error(`[hybrid-search] Tier 1→2 degradation: ${tier1Trigger.reason} (topScore=${tier1Trigger.topScore.toFixed(3)}, count=${tier1Trigger.resultCount})`);\n2578: \n2579:     const tier2Results = tier2Stage?.results ?? [];\n2580:     results = mergeResults(results, tier2Results);\n2581:     if (tier2Stage?.execution) {\n2582:       enrichmentExecution = tier2Stage.execution;\n2583:       enrichmentOptions = tier2Stage.options;\n2584:     }\n2585:     degradationEvents.push({\n2586:       tier: 1,\n2587:       trigger: tier1Trigger,\n2588:       resultCountBefore: tier1CountBefore,\n2589:       resultCountAfter: results.length,\n2590:     });\n2591: \n2592:     const tier2Trigger = checkDegradation(results);\n2593:     if (tier2Trigger) {\n2594:       // TIER 3: Structural search (pure SQL last-resort)\n2595:       const tier2CountBefore = results.length;\n2596: \n2597:       console.error(`[hybrid-search] Tier 2→3 degradation: ${tier2Trigger.reason} (topScore=${tier2Trigger.topScore.toFixed(3)}, count=${tier2Trigger.resultCount})`);\n2598: \n2599:       const tier3Results = structuralSearch({ specFolder: options.specFolder, limit: options.limit });\n2600:       const calibratedTier3 = calibrateTier3Scores(results, tier3Results);\n2601:       results = mergeResults(results, calibratedTier3);\n2602:       degradationEvents.push({\n2603:         tier: 2,\n2604:         trigger: tier2Trigger,\n2605:         resultCountBefore: tier2CountBefore,\n2606:         resultCountAfter: results.length,\n2607:       });\n2608:     }\n2609:   }\n2610: \n2611:   const finalResults = enrichmentExecution\n2612:     ? await enrichFusedResults(query, enrichmentExecution, enrichmentOptions, results)\n2613:     : applyResultLimit(results, options.limit);\n2614: \n2615:   Object.defineProperty(finalResults, '_degradation', {\n2616:     value: degradationEvents,\n2617:     enumerable: false,\n2618:     configurable: true,\n2619:   });\n2620: \n2621:   return finalResults;\n2622: }\n2623: \n2624: // 14. PRE-FLIGHT TOKEN BUDGET VALIDATION\n2625: \n2626: /** Default token budget — configurable via SPECKIT_TOKEN_BUDGET env var. */\n2627: const DEFAULT_TOKEN_BUDGET = 2000;\n2628: \n2629: /** Maximum characters for a summary fallback when a single result overflows the budget. */\n2630: const SUMMARY_MAX_CHARS = 400;\n2631: \n2632: /** Overflow log entry recording budget truncation events for eval infrastructure. */\n2633: interface OverflowLogEntry {\n2634:   queryId: string;\n2635:   candidateCount: number;\n2636:   totalTokens: number;\n2637:   budgetLimit: number;\n2638:   truncatedToCount: number;\n2639:   timestamp: string;\n\n(Showing lines 2400-2639 of 2972. Use offset=2640 to continue.)\n</content>","metadata":{"preview":"    if (!deduped.has(key)) {\n      deduped.set(key, result);\n    }\n  }\n  return Array.from(deduped.values());\n}\n\n/** Apply caller limit after merges that can expand result count. */\nfunction applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return results;\n  }\n  return results.slice(0, limit);\n}\n\n/** Depth of the result head rebalanced by the cosine-primary reorder. */\nconst COSINE_TOPN_REORDER_DEPTH = 10;\n\n/**\n * Cosine-primary reorder of the result head.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"    if (!deduped.has(key)) {\n      deduped.set(key, result);\n    }\n  }\n  return Array.from(deduped.values());\n}\n\n/** Apply caller limit after merges that can expand result count. */\nfunction applyResultLimit(results: HybridSearchResult[], limit?: number): HybridSearchResult[] {\n  if (typeof limit !== 'number' || !Number.isFinite(limit) || limit <= 0) {\n    return results;\n  }\n  return results.slice(0, limit);\n}\n\n/** Depth of the result head rebalanced by the cosine-primary reorder. */\nconst COSINE_TOPN_REORDER_DEPTH = 10;\n\n/**\n * Cosine-primary reorder of the result head.\n *\n * Reorders only the top-N by absolute cosine relevance (resolveAbsoluteRelevance),\n * as a STABLE sort so equal-relevance items keep their incoming fused (RRF) order.\n * RRF fusion remains the ranking baseline; only the head — where position 1 is now\n * decisive for downstream consumers — is rebalanced toward the strongest absolute\n * semantic signal. Vector hits carry a real cosine; lexical-only hits fall back to\n * the effective score, so a strong lexical hit is not unfairly zeroed out. Length\n * and membership are invariant — this only permutes the head.\n */\nfunction reorderTopNByCosine(\n  results: HybridSearchResult[],\n  depth: number = COSINE_TOPN_REORDER_DEPTH\n): HybridSearchResult[] {\n  const headCount = Math.min(depth, results.length);\n  if (headCount <= 1) return results;\n\n  const head = results.slice(0, headCount);\n  // Decorate with the original index so equal-relevance ties resolve to fused\n  // order regardless of the engine's sort stability.\n  const reordered = head\n    .map((row, index) => ({ row, index, relevance: resolveAbsoluteRelevance(row as PipelineRow) }))\n    .sort((a, b) => (b.relevance - a.relevance) || (a.index - b.index))\n    .map((entry) => entry.row);\n\n  return [...reordered, ...results.slice(headCount)];\n}\n\n/** Tier-3 structural results are capped at this fraction of the top existing score. */\nconst TIER3_CAP_RATIO = 0.5;\n/** Per-rank score decay for Tier-3 results, as a fraction of the top existing score. */\nconst TIER3_DECAY_PER_RANK = 0.08;\n\n/**\n * Keep Tier 3 structural fallback scores below established Tier 1/2 confidence.\n * Prevents structural placeholders from outranking stronger semantic/lexical hits.\n */\nfunction calibrateTier3Scores(\n  existing: HybridSearchResult[],\n  tier3: HybridSearchResult[]\n): HybridSearchResult[] {\n  const topExisting = existing.reduce((max, row) => {\n    if (typeof row.score !== 'number' || !Number.isFinite(row.score)) {\n      return max;\n    }\n    return Math.max(max, row.score);\n  }, 0);\n\n  if (topExisting <= 0) {\n    return tier3;\n  }\n\n  const topCap = topExisting * TIER3_CAP_RATIO;\n  const decayPerRank = topExisting * TIER3_DECAY_PER_RANK;\n\n  return tier3.map((row, index) => {\n    const calibrated = Math.max(0, topCap - (index * decayPerRank));\n    return {\n      ...row,\n      score: Math.min(row.score, calibrated),\n    };\n  });\n}\n\n// 13. TIERED FALLBACK (PI-A2)\n\n/**\n * Evaluate whether results meet quality thresholds.\n * Returns null if thresholds are met, or a DegradationTrigger if not.\n */\nfunction checkDegradation(results: HybridSearchResult[]): DegradationTrigger | null {\n  const scores = results\n    .map(r => r.score)\n    .filter((score): score is number => typeof score === 'number' && Number.isFinite(score))\n    .sort((a, b) => b - a);\n\n  const topScore = scores[0] ?? 0;\n  const secondScore = scores[1] ?? 0;\n  const relativeGap = topScore > 0 ? (topScore - secondScore) / topScore : 0;\n  const count = results.length;\n\n  const lowQuality =\n    topScore < DEGRADATION_QUALITY_THRESHOLD\n    && relativeGap < DEGRADATION_MIN_RELATIVE_GAP;\n  const insufficientResults = count < DEGRADATION_MIN_RESULTS;\n\n  if (!lowQuality && !insufficientResults) return null;\n\n  return {\n    reason: lowQuality && insufficientResults ? 'both'\n      : lowQuality ? 'low_quality'\n      : 'insufficient_results',\n    topScore,\n    resultCount: count,\n    relativeGap,\n  };\n}\n\n/**\n * Merge two result arrays, deduplicating by id and keeping the higher score.\n */\nfunction mergeResults(\n  existing: HybridSearchResult[],\n  incoming: HybridSearchResult[]\n): HybridSearchResult[] {\n  const byId = new Map<string, HybridSearchResult>();\n\n  for (const r of existing) {\n    byId.set(canonicalResultId(r.id), r);\n  }\n  for (const r of incoming) {\n    const key = canonicalResultId(r.id);\n    const prev = byId.get(key);\n    if (!prev || r.score > prev.score) {\n      byId.set(key, r);\n    }\n  }\n\n  return Array.from(byId.values()).sort((a, b) => b.score - a.score);\n}\n\n/**\n * PI-A2: Quality-aware 3-tier search fallback chain.\n *\n * TIER 1: hybridSearchEnhanced at minSimilarity=30\n *   → Pass if quality signal is healthy AND count >= 3\n *\n * TIER 2: hybridSearchEnhanced at minSimilarity=10, all allowed channels forced\n *   → Merge with Tier 1, dedup by id\n *   → Pass if quality signal is healthy AND count >= 3\n *\n * TIER 3: structuralSearch (pure SQL last-resort)\n *   → Merge with Tier 1+2 results after score calibration\n *   → Return capped set\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Results with _degradation metadata attached as non-enumerable property.\n */\nasync function searchWithFallbackTiered(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const degradationEvents: DegradationEvent[] = [];\n  const { stages } = await executeFallbackPlan(query, embedding, options, 'tiered');\n  const tier1Stage = stages[0];\n  const tier2Stage = stages[1];\n  let results = tier1Stage?.results ?? [];\n  let enrichmentExecution = tier1Stage?.execution ?? null;\n  let enrichmentOptions = tier1Stage?.options ?? options;\n\n  const tier1Trigger = checkDegradation(results);\n  if (tier1Trigger) {\n    // TIER 2: Widen search — lower similarity, force all channels\n    const tier1CountBefore = results.length;\n\n    console.error(`[hybrid-search] Tier 1→2 degradation: ${tier1Trigger.reason} (topScore=${tier1Trigger.topScore.toFixed(3)}, count=${tier1Trigger.resultCount})`);\n\n    const tier2Results = tier2Stage?.results ?? [];\n    results = mergeResults(results, tier2Results);\n    if (tier2Stage?.execution) {\n      enrichmentExecution = tier2Stage.execution;\n      enrichmentOptions = tier2Stage.options;\n    }\n    degradationEvents.push({\n      tier: 1,\n      trigger: tier1Trigger,\n      resultCountBefore: tier1CountBefore,\n      resultCountAfter: results.length,\n    });\n\n    const tier2Trigger = checkDegradation(results);\n    if (tier2Trigger) {\n      // TIER 3: Structural search (pure SQL last-resort)\n      const tier2CountBefore = results.length;\n\n      console.error(`[hybrid-search] Tier 2→3 degradation: ${tier2Trigger.reason} (topScore=${tier2Trigger.topScore.toFixed(3)}, count=${tier2Trigger.resultCount})`);\n\n      const tier3Results = structuralSearch({ specFolder: options.specFolder, limit: options.limit });\n      const calibratedTier3 = calibrateTier3Scores(results, tier3Results);\n      results = mergeResults(results, calibratedTier3);\n      degradationEvents.push({\n        tier: 2,\n        trigger: tier2Trigger,\n        resultCountBefore: tier2CountBefore,\n        resultCountAfter: results.length,\n      });\n    }\n  }\n\n  const finalResults = enrichmentExecution\n    ? await enrichFusedResults(query, enrichmentExecution, enrichmentOptions, results)\n    : applyResultLimit(results, options.limit);\n\n  Object.defineProperty(finalResults, '_degradation', {\n    value: degradationEvents,\n    enumerable: false,\n    configurable: true,\n  });\n\n  return finalResults;\n}\n\n// 14. PRE-FLIGHT TOKEN BUDGET VALIDATION\n\n/** Default token budget — configurable via SPECKIT_TOKEN_BUDGET env var. */\nconst DEFAULT_TOKEN_BUDGET = 2000;\n\n/** Maximum characters for a summary fallback when a single result overflows the budget. */\nconst SUMMARY_MAX_CHARS = 400;\n\n/** Overflow log entry recording budget truncation events for eval infrastructure. */\ninterface OverflowLogEntry {\n  queryId: string;\n  candidateCount: number;\n  totalTokens: number;\n  budgetLimit: number;\n  truncatedToCount: number;\n  timestamp: string;","lineStart":2400,"lineEnd":2639,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781764189351,"end":1781764189356}},"metadata":{"openai":{"itemId":"fc_0a832f684a8a0901016a33905d17308191bba15c4721d4dc8b"}},"id":"prt_ed96bec65001QPsE9hfLh9waL1","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96bc7520017kcKyJ11jH1CKX"}}
{"type":"tool_use","timestamp":1781764189366,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_8zNQh2n9VEVVSR4V6W9Mq7fh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Recovery Payload\n3: // ───────────────────────────────────────────────────────────────\n4: // Empty/Weak Result Recovery UX\n5: //\n6: // PURPOSE: Generate structured recovery payloads when search returns\n7: // no results, very low-confidence results, or only partial matches.\n8: // Provides the calling agent with actionable next steps.\n9: //\n10: // FEATURE FLAG: SPECKIT_EMPTY_RESULT_RECOVERY_V1 (default ON, graduated)\n11: //\n12: // OUTPUT SHAPE:\n13: // {\n14: //   \"status\": \"no_results\" | \"low_confidence\" | \"partial\",\n15: //   \"reason\": \"spec_filter_too_narrow\" | \"low_signal_query\" | \"knowledge_gap\",\n16: //   \"suggestedQueries\": [\"broader alternative 1\", \"rephrased alternative 2\"],\n17: //   \"recommendedAction\": \"retry_broader\" | \"switch_mode\" | \"save_memory\" | \"ask_user\" | \"ask_disambiguation\" | \"refuse_without_evidence\" | \"broaden_or_ask\"\n18: // }\n19: \n20: import { expandQuery } from './query-expander.js';\n21: \n22: // -- Types --\n23: \n24: /** The retrieval outcome state. */\n25: export type RecoveryStatus = 'no_results' | 'low_confidence' | 'partial';\n26: \n27: /** Root cause classification of the failure. */\n28: export type RecoveryReason = 'spec_filter_too_narrow' | 'low_signal_query' | 'knowledge_gap';\n29: \n30: /** Recommended next action for the calling agent. */\n31: export type RecoveryAction =\n32:   | 'retry_broader'\n33:   | 'switch_mode'\n34:   | 'save_memory'\n35:   | 'ask_user'\n36:   | 'ask_disambiguation'\n37:   | 'refuse_without_evidence'\n38:   | 'broaden_or_ask';\n39: \n40: /** Structured recovery payload attached to search responses. */\n41: export interface RecoveryPayload {\n42:   status: RecoveryStatus;\n43:   reason: RecoveryReason;\n44:   suggestedQueries: string[];\n45:   recommendedAction: RecoveryAction;\n46: }\n47: \n48: /** Input context used to build the recovery payload. */\n49: export interface RecoveryContext {\n50:   /** The original search query (may be null/empty if concepts were used). */\n51:   query: string | null;\n52:   /** Whether a specFolder filter was applied. */\n53:   hasSpecFolderFilter: boolean;\n54:   /** Whether upstream search logic detected an evidence gap for this result set. */\n55:   evidenceGap?: boolean;\n56:   /** How many results were returned (0 = no_results, 1–N = partial/low_confidence). */\n57:   resultCount: number;\n58:   /** Average confidence value across returned results (0–1). Only meaningful when resultCount > 0. */\n59:   avgConfidence?: number;\n60:   /** Low-confidence threshold — results below this trigger recovery. */\n61:   lowConfidenceThreshold?: number;\n62: }\n63: \n64: // -- Constants --\n65: \n66: const DEFAULT_LOW_CONFIDENCE_THRESHOLD = 0.4;\n67: \n68: // Minimum result count considered \"good enough\" — fewer than this triggers partial recovery.\n69: const PARTIAL_RESULT_MIN = 3;\n70: \n71: // -- Internal helpers --\n72: \n73: /**\n74:  * Classify retrieval status based on result count and confidence signals.\n75:  */\n76: function classifyStatus(ctx: RecoveryContext): RecoveryStatus {\n77:   const threshold = ctx.lowConfidenceThreshold ?? DEFAULT_LOW_CONFIDENCE_THRESHOLD;\n78: \n79:   if (ctx.resultCount === 0) return 'no_results';\n80:   if (ctx.evidenceGap) return 'partial';\n81:   if (\n82:     typeof ctx.avgConfidence === 'number' &&\n83:     Number.isFinite(ctx.avgConfidence) &&\n84:     ctx.avgConfidence < threshold\n85:   ) return 'low_confidence';\n86:   if (ctx.resultCount < PARTIAL_RESULT_MIN) return 'partial';\n87:   // Conservative fallback: results exist, are above the confidence threshold,\n88:   // and meet the count floor, yet recovery was still requested. The label\n89:   // intentionally repeats the `:81-85` value — `low_confidence` is the safest\n90:   // \"recovery warranted but no specific cause matched\" verdict, and the contract\n91:   // requires a valid RecoveryStatus here (callers branch on the literal, so a\n92:   // throw or new sentinel would be a behavior change, not a clarification).\n93:   return 'low_confidence';\n94: }\n95: \n96: /**\n97:  * Classify root cause from context signals.\n98:  */\n99: function classifyReason(ctx: RecoveryContext, status: RecoveryStatus): RecoveryReason {\n100:   // If a narrow filter was applied and no results returned, that is most likely the cause\n101:   if (ctx.hasSpecFolderFilter && status === 'no_results') {\n102:     return 'spec_filter_too_narrow';\n103:   }\n104:   // Very short or generic queries (< 3 words) suggest low signal\n105:   const wordCount = ctx.query ? ctx.query.trim().split(/\\s+/).filter(Boolean).length : 0;\n106:   if (wordCount > 0 && wordCount <= 2) {\n107:     return 'low_signal_query';\n108:   }\n109:   // Default to knowledge_gap — the information may simply not be indexed\n110:   return 'knowledge_gap';\n111: }\n112: \n113: /**\n114:  * Generate suggested reformulations from the original query.\n115:  *\n116:  * Heuristics applied (in order):\n117:  * 1. Remove parenthetical or bracketed clauses (focus term extraction)\n118:  * 2. Keep only the first N words (shorten complex queries)\n119:  * 3. Strip trailing conjunctions / stop words\n120:  * 4. Suggest dropping the spec folder constraint when it was set\n121:  */\n122: function generateSuggestedQueries(ctx: RecoveryContext): string[] {\n123:   const suggestions: string[] = [];\n124:   const q = ctx.query?.trim() ?? '';\n125: \n126:   if (q.length === 0) {\n127:     suggestions.push('memory save context', 'recent decisions', 'project overview');\n128:     return suggestions.slice(0, 2);\n129:   }\n130: \n131:   // 1. Remove parentheticals/brackets — often over-specifying\n132:   const withoutParens = q.replace(/\\([^)]*\\)/g, '').replace(/\\[[^\\]]*\\]/g, '').replace(/\\s{2,}/g, ' ').trim();\n133:   if (withoutParens.length > 0 && withoutParens !== q) {\n134:     suggestions.push(withoutParens);\n135:   }\n136: \n137:   // 2. Shorten: keep first 3 words\n138:   const words = q.split(/\\s+/).filter(Boolean);\n139:   if (words.length > 4) {\n140:     suggestions.push(words.slice(0, 3).join(' '));\n141:   }\n142: \n143:   // 3. Remove trailing stop-words (and, or, the, in, for, with, to, of, a)\n144:   const stopWords = new Set(['and', 'or', 'the', 'in', 'for', 'with', 'to', 'of', 'a', 'an']);\n145:   const trimmedWords = [...words].reverse().reduce<string[]>((acc, word) => {\n146:     if (acc.length === 0 && stopWords.has(word.toLowerCase())) return acc;\n147:     return [word, ...acc];\n148:   }, []);\n149:   const stopTrimmed = trimmedWords.join(' ');\n150:   if (stopTrimmed.length > 0 && stopTrimmed !== q && !suggestions.includes(stopTrimmed)) {\n151:     suggestions.push(stopTrimmed);\n152:   }\n153: \n154:   // 4. If spec folder filter was active, suggest the same query without it\n155:   if (ctx.hasSpecFolderFilter && !suggestions.includes(q)) {\n156:     suggestions.push(q); // exact same query but without folder constraint\n157:   }\n158: \n159:   // 5. Synonym-expansion variants — turn a low-signal query into concrete\n160:   // broaden prompts. Reuses the deep-path expander so a weak result surfaces\n161:   // the same alternatives the recall pipeline would try, instead of an empty\n162:   // list. Best-effort: expansion never blocks recovery.\n163:   try {\n164:     for (const variant of expandQuery(q)) {\n165:       if (variant !== q && !suggestions.includes(variant)) {\n166:         suggestions.push(variant);\n167:       }\n168:     }\n169:   } catch {\n170:     // Expansion is advisory; fall back to heuristic suggestions on any failure.\n171:   }\n172: \n173:   // Deduplicate, remove empties, cap at 3\n174:   const unique = [...new Set(suggestions.filter((s) => s.length > 0))];\n175:   return unique.slice(0, 3);\n176: }\n177: \n178: /**\n179:  * Synthesize broad, safe suggestions when the normal heuristics cannot\n180:  * reformulate the query. These are intentionally generic: they keep only\n181:  * caller-supplied tokens and avoid inventing packet IDs or paths.\n182:  */\n183: function synthesizeBroadeningSuggestions(ctx: RecoveryContext): string[] {\n184:   const q = ctx.query?.trim() ?? '';\n185:   const rawTokens = q.split(/\\s+/).filter(Boolean);\n186:   const stopWords = new Set([\n187:     'a',\n188:     'an',\n189:     'and',\n190:     'for',\n191:     'from',\n192:     'in',\n193:     'of',\n194:     'on',\n195:     'or',\n196:     'the',\n197:     'to',\n198:     'with',\n199:   ]);\n200:   const tokens = rawTokens\n201:     .map((token) => token.replace(/^[^\\w-]+|[^\\w-]+$/g, '').toLowerCase())\n202:     .filter((token) => token.length > 0 && !stopWords.has(token));\n203: \n204:   if (tokens.length === 0) {\n205:     return ['recent memory context', 'related implementation notes'];\n206:   }\n207:   if (tokens.length === 1) {\n208:     return [`${tokens[0]} context`, `${tokens[0]} implementation`];\n209:   }\n210: \n211:   const firstPair = tokens.slice(0, 2).join(' ');\n212:   const firstTriple = tokens.slice(0, 3).join(' ');\n213:   const suggestions = [\n214:     firstPair,\n215:     firstTriple,\n216:     tokens.join(' '),\n217:   ].filter((suggestion) => suggestion.length > 0);\n218: \n219:   return [...new Set(suggestions)].slice(0, 2);\n220: }\n\n(Showing lines 1-220 of 395. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Recovery Payload\n// ───────────────────────────────────────────────────────────────\n// Empty/Weak Result Recovery UX\n//\n// PURPOSE: Generate structured recovery payloads when search returns\n// no results, very low-confidence results, or only partial matches.\n// Provides the calling agent with actionable next steps.\n//\n// FEATURE FLAG: SPECKIT_EMPTY_RESULT_RECOVERY_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE:\n// {\n//   \"status\": \"no_results\" | \"low_confidence\" | \"partial\",\n//   \"reason\": \"spec_filter_too_narrow\" | \"low_signal_query\" | \"knowledge_gap\",\n//   \"suggestedQueries\": [\"broader alternative 1\", \"rephrased alternative 2\"],\n//   \"recommendedAction\": \"retry_broader\" | \"switch_mode\" | \"save_memory\" | \"ask_user\" | \"ask_disambiguation\" | \"refuse_without_evidence\" | \"broaden_or_ask\"\n// }\n\nimport { expandQuery } from './query-expander.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Recovery Payload\n// ───────────────────────────────────────────────────────────────\n// Empty/Weak Result Recovery UX\n//\n// PURPOSE: Generate structured recovery payloads when search returns\n// no results, very low-confidence results, or only partial matches.\n// Provides the calling agent with actionable next steps.\n//\n// FEATURE FLAG: SPECKIT_EMPTY_RESULT_RECOVERY_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE:\n// {\n//   \"status\": \"no_results\" | \"low_confidence\" | \"partial\",\n//   \"reason\": \"spec_filter_too_narrow\" | \"low_signal_query\" | \"knowledge_gap\",\n//   \"suggestedQueries\": [\"broader alternative 1\", \"rephrased alternative 2\"],\n//   \"recommendedAction\": \"retry_broader\" | \"switch_mode\" | \"save_memory\" | \"ask_user\" | \"ask_disambiguation\" | \"refuse_without_evidence\" | \"broaden_or_ask\"\n// }\n\nimport { expandQuery } from './query-expander.js';\n\n// -- Types --\n\n/** The retrieval outcome state. */\nexport type RecoveryStatus = 'no_results' | 'low_confidence' | 'partial';\n\n/** Root cause classification of the failure. */\nexport type RecoveryReason = 'spec_filter_too_narrow' | 'low_signal_query' | 'knowledge_gap';\n\n/** Recommended next action for the calling agent. */\nexport type RecoveryAction =\n  | 'retry_broader'\n  | 'switch_mode'\n  | 'save_memory'\n  | 'ask_user'\n  | 'ask_disambiguation'\n  | 'refuse_without_evidence'\n  | 'broaden_or_ask';\n\n/** Structured recovery payload attached to search responses. */\nexport interface RecoveryPayload {\n  status: RecoveryStatus;\n  reason: RecoveryReason;\n  suggestedQueries: string[];\n  recommendedAction: RecoveryAction;\n}\n\n/** Input context used to build the recovery payload. */\nexport interface RecoveryContext {\n  /** The original search query (may be null/empty if concepts were used). */\n  query: string | null;\n  /** Whether a specFolder filter was applied. */\n  hasSpecFolderFilter: boolean;\n  /** Whether upstream search logic detected an evidence gap for this result set. */\n  evidenceGap?: boolean;\n  /** How many results were returned (0 = no_results, 1–N = partial/low_confidence). */\n  resultCount: number;\n  /** Average confidence value across returned results (0–1). Only meaningful when resultCount > 0. */\n  avgConfidence?: number;\n  /** Low-confidence threshold — results below this trigger recovery. */\n  lowConfidenceThreshold?: number;\n}\n\n// -- Constants --\n\nconst DEFAULT_LOW_CONFIDENCE_THRESHOLD = 0.4;\n\n// Minimum result count considered \"good enough\" — fewer than this triggers partial recovery.\nconst PARTIAL_RESULT_MIN = 3;\n\n// -- Internal helpers --\n\n/**\n * Classify retrieval status based on result count and confidence signals.\n */\nfunction classifyStatus(ctx: RecoveryContext): RecoveryStatus {\n  const threshold = ctx.lowConfidenceThreshold ?? DEFAULT_LOW_CONFIDENCE_THRESHOLD;\n\n  if (ctx.resultCount === 0) return 'no_results';\n  if (ctx.evidenceGap) return 'partial';\n  if (\n    typeof ctx.avgConfidence === 'number' &&\n    Number.isFinite(ctx.avgConfidence) &&\n    ctx.avgConfidence < threshold\n  ) return 'low_confidence';\n  if (ctx.resultCount < PARTIAL_RESULT_MIN) return 'partial';\n  // Conservative fallback: results exist, are above the confidence threshold,\n  // and meet the count floor, yet recovery was still requested. The label\n  // intentionally repeats the `:81-85` value — `low_confidence` is the safest\n  // \"recovery warranted but no specific cause matched\" verdict, and the contract\n  // requires a valid RecoveryStatus here (callers branch on the literal, so a\n  // throw or new sentinel would be a behavior change, not a clarification).\n  return 'low_confidence';\n}\n\n/**\n * Classify root cause from context signals.\n */\nfunction classifyReason(ctx: RecoveryContext, status: RecoveryStatus): RecoveryReason {\n  // If a narrow filter was applied and no results returned, that is most likely the cause\n  if (ctx.hasSpecFolderFilter && status === 'no_results') {\n    return 'spec_filter_too_narrow';\n  }\n  // Very short or generic queries (< 3 words) suggest low signal\n  const wordCount = ctx.query ? ctx.query.trim().split(/\\s+/).filter(Boolean).length : 0;\n  if (wordCount > 0 && wordCount <= 2) {\n    return 'low_signal_query';\n  }\n  // Default to knowledge_gap — the information may simply not be indexed\n  return 'knowledge_gap';\n}\n\n/**\n * Generate suggested reformulations from the original query.\n *\n * Heuristics applied (in order):\n * 1. Remove parenthetical or bracketed clauses (focus term extraction)\n * 2. Keep only the first N words (shorten complex queries)\n * 3. Strip trailing conjunctions / stop words\n * 4. Suggest dropping the spec folder constraint when it was set\n */\nfunction generateSuggestedQueries(ctx: RecoveryContext): string[] {\n  const suggestions: string[] = [];\n  const q = ctx.query?.trim() ?? '';\n\n  if (q.length === 0) {\n    suggestions.push('memory save context', 'recent decisions', 'project overview');\n    return suggestions.slice(0, 2);\n  }\n\n  // 1. Remove parentheticals/brackets — often over-specifying\n  const withoutParens = q.replace(/\\([^)]*\\)/g, '').replace(/\\[[^\\]]*\\]/g, '').replace(/\\s{2,}/g, ' ').trim();\n  if (withoutParens.length > 0 && withoutParens !== q) {\n    suggestions.push(withoutParens);\n  }\n\n  // 2. Shorten: keep first 3 words\n  const words = q.split(/\\s+/).filter(Boolean);\n  if (words.length > 4) {\n    suggestions.push(words.slice(0, 3).join(' '));\n  }\n\n  // 3. Remove trailing stop-words (and, or, the, in, for, with, to, of, a)\n  const stopWords = new Set(['and', 'or', 'the', 'in', 'for', 'with', 'to', 'of', 'a', 'an']);\n  const trimmedWords = [...words].reverse().reduce<string[]>((acc, word) => {\n    if (acc.length === 0 && stopWords.has(word.toLowerCase())) return acc;\n    return [word, ...acc];\n  }, []);\n  const stopTrimmed = trimmedWords.join(' ');\n  if (stopTrimmed.length > 0 && stopTrimmed !== q && !suggestions.includes(stopTrimmed)) {\n    suggestions.push(stopTrimmed);\n  }\n\n  // 4. If spec folder filter was active, suggest the same query without it\n  if (ctx.hasSpecFolderFilter && !suggestions.includes(q)) {\n    suggestions.push(q); // exact same query but without folder constraint\n  }\n\n  // 5. Synonym-expansion variants — turn a low-signal query into concrete\n  // broaden prompts. Reuses the deep-path expander so a weak result surfaces\n  // the same alternatives the recall pipeline would try, instead of an empty\n  // list. Best-effort: expansion never blocks recovery.\n  try {\n    for (const variant of expandQuery(q)) {\n      if (variant !== q && !suggestions.includes(variant)) {\n        suggestions.push(variant);\n      }\n    }\n  } catch {\n    // Expansion is advisory; fall back to heuristic suggestions on any failure.\n  }\n\n  // Deduplicate, remove empties, cap at 3\n  const unique = [...new Set(suggestions.filter((s) => s.length > 0))];\n  return unique.slice(0, 3);\n}\n\n/**\n * Synthesize broad, safe suggestions when the normal heuristics cannot\n * reformulate the query. These are intentionally generic: they keep only\n * caller-supplied tokens and avoid inventing packet IDs or paths.\n */\nfunction synthesizeBroadeningSuggestions(ctx: RecoveryContext): string[] {\n  const q = ctx.query?.trim() ?? '';\n  const rawTokens = q.split(/\\s+/).filter(Boolean);\n  const stopWords = new Set([\n    'a',\n    'an',\n    'and',\n    'for',\n    'from',\n    'in',\n    'of',\n    'on',\n    'or',\n    'the',\n    'to',\n    'with',\n  ]);\n  const tokens = rawTokens\n    .map((token) => token.replace(/^[^\\w-]+|[^\\w-]+$/g, '').toLowerCase())\n    .filter((token) => token.length > 0 && !stopWords.has(token));\n\n  if (tokens.length === 0) {\n    return ['recent memory context', 'related implementation notes'];\n  }\n  if (tokens.length === 1) {\n    return [`${tokens[0]} context`, `${tokens[0]} implementation`];\n  }\n\n  const firstPair = tokens.slice(0, 2).join(' ');\n  const firstTriple = tokens.slice(0, 3).join(' ');\n  const suggestions = [\n    firstPair,\n    firstTriple,\n    tokens.join(' '),\n  ].filter((suggestion) => suggestion.length > 0);\n\n  return [...new Set(suggestions)].slice(0, 2);\n}","lineStart":1,"lineEnd":220,"totalLines":395,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/recovery-payload.ts","time":{"start":1781764189359,"end":1781764189365}},"metadata":{"openai":{"itemId":"fc_0a832f684a8a0901016a33905d17388191b2303004b504aaf6"}},"id":"prt_ed96beca8001Yu5JX1LSK5TWrD","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96bc7520017kcKyJ11jH1CKX"}}
