_TIMEOUT_MS,\n36:     teardownTimeout: TEARDOWN_TIMEOUT_MS,\n37:     alias: {\n38:       '@lib': path.resolve(import.meta.dirname, 'lib'),\n39:       '@spec-kit/shared': path.resolve(import.meta.dirname, '..', 'shared'),\n40:     },\n41:   },\n42: });\n\n(End of file - total 42 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vitest Config\n// ───────────────────────────────────────────────────────────────\n// ───────────────────────────────────────────────────────────────\n// 1. VITEST\n\n// ───────────────────────────────────────────────────────────────\nimport { defineConfig } from 'vitest/config';\nimport path from 'path';\n\nconst TEST_TIMEOUT_MS = 30_000; // 30s default, increase for CI if needed\nconst TEARDOWN_TIMEOUT_MS = 1_000;\nconst _INCLUDE_BENCHES = process.env.SPECKIT_RUN_BENCHES === 'true';\n\nexport default defineConfig({\n  root: path.resolve(import.meta.dirname, '..'),\n  test: {\n    include: [\n      'mcp_server/tests/**/*.{vitest,test}.ts',\n      '../deep-loop-runtime/tests/**/*.{vitest,test}.ts',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/vitest.config.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vitest Config\n// ───────────────────────────────────────────────────────────────\n// ───────────────────────────────────────────────────────────────\n// 1. VITEST\n\n// ───────────────────────────────────────────────────────────────\nimport { defineConfig } from 'vitest/config';\nimport path from 'path';\n\nconst TEST_TIMEOUT_MS = 30_000; // 30s default, increase for CI if needed\nconst TEARDOWN_TIMEOUT_MS = 1_000;\nconst _INCLUDE_BENCHES = process.env.SPECKIT_RUN_BENCHES === 'true';\n\nexport default defineConfig({\n  root: path.resolve(import.meta.dirname, '..'),\n  test: {\n    include: [\n      'mcp_server/tests/**/*.{vitest,test}.ts',\n      '../deep-loop-runtime/tests/**/*.{vitest,test}.ts',\n      'scripts/tests/**/*.{vitest,test}.ts',\n    ],\n    exclude: [\n      'mcp_server/tests/memory-save.vitest.ts',\n      'mcp_server/tests/archive/**',\n    ],\n    setupFiles: [\n      path.resolve(import.meta.dirname, 'tests', '_support', 'vitest-setup.ts'),\n    ],\n    // Several script suites mutate shared process-level state and temp project roots.\n    // Run files serially so the combined config remains deterministic.\n    fileParallelism: false,\n    globals: true,\n    environment: 'node',\n    testTimeout: TEST_TIMEOUT_MS,\n    teardownTimeout: TEARDOWN_TIMEOUT_MS,\n    alias: {\n      '@lib': path.resolve(import.meta.dirname, 'lib'),\n      '@spec-kit/shared': path.resolve(import.meta.dirname, '..', 'shared'),\n    },\n  },\n});","lineStart":1,"lineEnd":42,"totalLines":42,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/vitest.config.ts","time":{"start":1783486909995,"end":1783486910005}},"metadata":{"openai":{"itemId":"fc_06a76281af48175f016a4dd9bde9d48191bfa4551c224c060e"}},"id":"prt_f401a8e2a0016yhXujKtl9smfe","sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","messageID":"msg_f401a5a58001PMnNHAbH40r7pb"}}
