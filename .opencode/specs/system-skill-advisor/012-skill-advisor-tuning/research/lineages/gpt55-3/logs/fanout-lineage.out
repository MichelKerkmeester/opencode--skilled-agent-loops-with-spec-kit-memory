{"type":"tool_use","timestamp":1783437254823,"sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","part":{"type":"tool","tool":"read","callID":"call_a62DswEsYr1jq9nMNKsCK5F5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-improvement/scripts/skill-benchmark/parent-hub-vocab-sync.cjs","offset":361,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-improvement/scripts/skill-benchmark/parent-hub-vocab-sync.cjs</path>\n<type>file</type>\n<content>\n361:   }\n362: \n363:   const aliasCollisions = [];\n364:   const collisionKeys = new Set([...typedAliasKeys, ...registryAliasOwners.keys()]);\n365: \n366:   for (const key of collisionKeys) {\n367:     const modes = new Set();\n368:     const sources = new Set();\n369:     if (registryAliasOwners.has(key)) {\n370:       for (const mode of registryAliasOwners.get(key)) modes.add(mode);\n371:       sources.add('mode-registry');\n372:     }\n373:     const typed = projection.get(key);\n374:     if (typed) {\n375:       for (const mode of typed.modes) modes.add(mode);\n376:       sources.add('hub-router');\n377:     }\n378:     if (modes.size > 1) aliasCollisions.push(formatCollision(key, modes, sources));\n379:   }\n380: \n381:   const hubKeywordKeys = hubKeywords.map(normalizePhrase).filter(Boolean);\n382:   const untypedKeywords = hubKeywords.filter((keyword) => !projection.has(normalizePhrase(keyword)));\n383:   const untypedKeywordRate = hubKeywordKeys.length\n384:     ? untypedKeywords.length / hubKeywordKeys.length\n385:     : null;\n386: \n387:   const allSourceKeys = sourceKeys({ registryAliases, hubKeywords, triggerPhrases, intentSignalOwners });\n388:   const phantomTypedKeywords = [...typedKeywordRaw.entries()]\n389:     .filter(([key]) => {\n390:       const typed = projection.get(key);\n391:       if (typed && typed.classes.has('hub-identity')) return false;\n392:       return !allSourceKeys.has(key);\n393:     })\n394:     .map(([, raw]) => sortedValues(raw)[0])\n395:     .sort();\n396: \n397:   const coveredTriggerCount = triggerPhrases.filter((phrase) => {\n398:     const normalized = normalizePhrase(phrase);\n399:     return normalized && (projection.has(normalized) || registryAliasOwners.has(normalized));\n400:   }).length;\n401:   const triggerPhraseCoverage = triggerPhrases.length\n402:     ? coveredTriggerCount / triggerPhrases.length\n403:     : null;\n404: \n405:   for (const item of orphanAliases) {\n406:     findings.push(makeFinding(item, 'orphan-alias', `${item.mode} alias is not typed by the hub vocabulary`));\n407:   }\n408:   for (const item of aliasCollisions) {\n409:     findings.push(makeFinding(item, 'alias-collision', `phrase belongs to multiple modes: ${item.modes.join(', ')}`));\n410:   }\n411:   for (const item of ownershipDrift) {\n412:     findings.push(makeFinding(item, 'ownership-drift', `${item.mode} alias is typed as ${item.typedModes.join(', ')}`));\n413:   }\n414: \n415:   const driftDetected = orphanAliases.length > 0 || aliasCollisions.length > 0 || ownershipDrift.length > 0;\n416: \n417:   return {\n418:     familyPresent: true,\n419:     projectionParsed: true,\n420:     typedKeywordCount: projection.size,\n421:     score: scoreFromFindings(findings),\n422:     driftDetected,\n423:     verdict: driftDetected ? HARD_VERDICT : null,\n424:     findings,\n425:     orphanAliases,\n426:     aliasCollisions,\n427:     ownershipDrift,\n428:     untypedKeywords,\n429:     untypedKeywordRate,\n430:     phantomTypedKeywords,\n431:     triggerPhraseCoverage,\n432:   };\n433: }\n434: \n435: // ─────────────────────────────────────────────────────────────────────────────\n436: // 5. EXPORTS\n437: // ─────────────────────────────────────────────────────────────────────────────\n438: \n439: module.exports = {\n440:   checkVocabSync,\n441:   normalizePhrase,\n442:   ownerModeForClass,\n443: };\n444: \n445: if (require.main === module) {\n446:   const args = require('./_args.cjs').parse(process.argv.slice(2));\n447:   if (!args.skill) {\n448:     process.stderr.write('usage: parent-hub-vocab-sync.cjs --skill <skill-root>\\n');\n449:     process.exit(2);\n450:   }\n451: \n452:   try {\n453:     const result = checkVocabSync({ skillRoot: args.skill });\n454:     process.stdout.write(JSON.stringify(result, null, 2) + '\\n');\n455:     const structuralClasses = new Set([\n456:       'unparseable-input',\n457:       'invalid-input',\n458:       'missing-hub-router',\n459:       'missing-mode-registry',\n460:     ]);\n461:     if (result.findings.some((finding) => structuralClasses.has(finding.class))) {\n462:       process.exit(2);\n463:     }\n464:     process.exit(result.driftDetected ? 1 : 0);\n465:   } catch (err) {\n466:     process.stderr.write(`[parent-hub-vocab-sync] ${err.message}\\n`);\n467:     process.exit(2);\n468:   }\n469: }\n\n(End of file - total 469 lines)\n</content>","metadata":{"preview":"  }\n\n  const aliasCollisions = [];\n  const collisionKeys = new Set([...typedAliasKeys, ...registryAliasOwners.keys()]);\n\n  for (const key of collisionKeys) {\n    const modes = new Set();\n    const sources = new Set();\n    if (registryAliasOwners.has(key)) {\n      for (const mode of registryAliasOwners.get(key)) modes.add(mode);\n      sources.add('mode-registry');\n    }\n    const typed = projection.get(key);\n    if (typed) {\n      for (const mode of typed.modes) modes.add(mode);\n      sources.add('hub-router');\n    }\n    if (modes.size > 1) aliasCollisions.push(formatCollision(key, modes, sources));\n  }\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-improvement/scripts/skill-benchmark/parent-hub-vocab-sync.cjs","text":"  }\n\n  const aliasCollisions = [];\n  const collisionKeys = new Set([...typedAliasKeys, ...registryAliasOwners.keys()]);\n\n  for (const key of collisionKeys) {\n    const modes = new Set();\n    const sources = new Set();\n    if (registryAliasOwners.has(key)) {\n      for (const mode of registryAliasOwners.get(key)) modes.add(mode);\n      sources.add('mode-registry');\n    }\n    const typed = projection.get(key);\n    if (typed) {\n      for (const mode of typed.modes) modes.add(mode);\n      sources.add('hub-router');\n    }\n    if (modes.size > 1) aliasCollisions.push(formatCollision(key, modes, sources));\n  }\n\n  const hubKeywordKeys = hubKeywords.map(normalizePhrase).filter(Boolean);\n  const untypedKeywords = hubKeywords.filter((keyword) => !projection.has(normalizePhrase(keyword)));\n  const untypedKeywordRate = hubKeywordKeys.length\n    ? untypedKeywords.length / hubKeywordKeys.length\n    : null;\n\n  const allSourceKeys = sourceKeys({ registryAliases, hubKeywords, triggerPhrases, intentSignalOwners });\n  const phantomTypedKeywords = [...typedKeywordRaw.entries()]\n    .filter(([key]) => {\n      const typed = projection.get(key);\n      if (typed && typed.classes.has('hub-identity')) return false;\n      return !allSourceKeys.has(key);\n    })\n    .map(([, raw]) => sortedValues(raw)[0])\n    .sort();\n\n  const coveredTriggerCount = triggerPhrases.filter((phrase) => {\n    const normalized = normalizePhrase(phrase);\n    return normalized && (projection.has(normalized) || registryAliasOwners.has(normalized));\n  }).length;\n  const triggerPhraseCoverage = triggerPhrases.length\n    ? coveredTriggerCount / triggerPhrases.length\n    : null;\n\n  for (const item of orphanAliases) {\n    findings.push(makeFinding(item, 'orphan-alias', `${item.mode} alias is not typed by the hub vocabulary`));\n  }\n  for (const item of aliasCollisions) {\n    findings.push(makeFinding(item, 'alias-collision', `phrase belongs to multiple modes: ${item.modes.join(', ')}`));\n  }\n  for (const item of ownershipDrift) {\n    findings.push(makeFinding(item, 'ownership-drift', `${item.mode} alias is typed as ${item.typedModes.join(', ')}`));\n  }\n\n  const driftDetected = orphanAliases.length > 0 || aliasCollisions.length > 0 || ownershipDrift.length > 0;\n\n  return {\n    familyPresent: true,\n    projectionParsed: true,\n    typedKeywordCount: projection.size,\n    score: scoreFromFindings(findings),\n    driftDetected,\n    verdict: driftDetected ? HARD_VERDICT : null,\n    findings,\n    orphanAliases,\n    aliasCollisions,\n    ownershipDrift,\n    untypedKeywords,\n    untypedKeywordRate,\n    phantomTypedKeywords,\n    triggerPhraseCoverage,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. EXPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nmodule.exports = {\n  checkVocabSync,\n  normalizePhrase,\n  ownerModeForClass,\n};\n\nif (require.main === module) {\n  const args = require('./_args.cjs').parse(process.argv.slice(2));\n  if (!args.skill) {\n    process.stderr.write('usage: parent-hub-vocab-sync.cjs --skill <skill-root>\\n');\n    process.exit(2);\n  }\n\n  try {\n    const result = checkVocabSync({ skillRoot: args.skill });\n    process.stdout.write(JSON.stringify(result, null, 2) + '\\n');\n    const structuralClasses = new Set([\n      'unparseable-input',\n      'invalid-input',\n      'missing-hub-router',\n      'missing-mode-registry',\n    ]);\n    if (result.findings.some((finding) => structuralClasses.has(finding.class))) {\n      process.exit(2);\n    }\n    process.exit(result.driftDetected ? 1 : 0);\n  } catch (err) {\n    process.stderr.write(`[parent-hub-vocab-sync] ${err.message}\\n`);\n    process.exit(2);\n  }\n}","lineStart":361,"lineEnd":469,"totalLines":469,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-improvement/scripts/skill-benchmark/parent-hub-vocab-sync.cjs","time":{"start":1783437254818,"end":1783437254822}},"metadata":{"openai":{"itemId":"fc_02c613b22d0b2696016a4d17c6c2648191a78cb98460d69dc1"}},"id":"prt_f3d24e0a0001C2Njz2lFnWoFK1","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d24ba4000143vQbs8CaX3dyl"}}
