History(database);\n\n  return current_version;\n}\n\nexport function ensureLineageTables(database: Database.Database): void {\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS memory_lineage (\n      memory_id INTEGER PRIMARY KEY,\n      logical_key TEXT NOT NULL,\n      version_number INTEGER NOT NULL,\n      root_memory_id INTEGER NOT NULL,\n      predecessor_memory_id INTEGER,\n      superseded_by_memory_id INTEGER,","lineStart":1538,"lineEnd":1607,"totalLines":2784,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","time":{"start":1780925773291,"end":1780925773313}},"metadata":{"openai":{"itemId":"fc_01f118128bb1efd9016a26c54d3ac48191ad19a95848ff7456"}},"id":"prt_ea772b5e2001HwxhHECNH8KzUn","sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","messageID":"msg_ea7729304001Wo1pAL1I6w2EVe"}}
{"type":"tool_use","timestamp":1780925773372,"sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","part":{"type":"tool","tool":"read","callID":"call_cmfZakMhPcHtL2v0yTbzwUqf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","offset":2550,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts</path>\n<type>file</type>\n<content>\n2550:  * @param options - Schema creation options.\n2551:  * @returns Nothing.\n2552:  */\n2553: export function create_schema(\n2554:   database: Database.Database,\n2555:   options: { sqlite_vec_available: boolean; get_embedding_dim: () => number }\n2556: ): void {\n2557:   const { sqlite_vec_available, get_embedding_dim } = options;\n2558: \n2559:   const table_exists = database.prepare(`\n2560:     SELECT name FROM sqlite_master\n2561:     WHERE type='table' AND name='memory_index'\n2562:   `).get();\n2563: \n2564:   if (table_exists) {\n2565:     migrate_confidence_columns(database);\n2566:     migrate_constitutional_tier(database);\n2567:     ensure_canonical_file_path_support(database);\n2568:     create_common_indexes(database);\n2569:     ensureCompanionTables(database);\n2570:     ensureLineageTables(database);\n2571:     ensureGovernanceTables(database);\n2572:     const compatibility = validate_backward_compatibility(database);\n2573:     if (!compatibility.compatible) {\n2574:       logger.warn(\n2575:         'Existing schema is not fully backward-compatible after bootstrap',\n2576:         compatibility as unknown as Record<string, unknown>\n2577:       );\n2578:     }\n2579:     // the rollout — embedding cache table must exist before any\n2580:     // Save/index operation so lookupEmbedding() can skip redundant provider calls.\n2581:     ensureEmbeddingCacheSchema(database);\n2582:     return;\n2583:   }\n2584: \n2585:   // Create memory_index table (metadata only)\n2586:   database.exec(`\n2587:     CREATE TABLE memory_index (\n2588:       id INTEGER PRIMARY KEY,\n2589:       spec_folder TEXT NOT NULL,\n2590:       file_path TEXT NOT NULL,\n2591:       canonical_file_path TEXT,\n2592:       anchor_id TEXT,\n2593:       title TEXT,\n2594:       trigger_phrases TEXT,\n2595:       importance_weight REAL DEFAULT 0.5,\n2596:       created_at TEXT NOT NULL,\n2597:       updated_at TEXT NOT NULL,\n2598:       embedding_model TEXT,\n2599:       embedding_generated_at TEXT,\n2600:       embedding_status TEXT DEFAULT 'pending' CHECK(embedding_status IN ('pending', 'success', 'failed', 'retry', 'partial')),\n2601:       retry_count INTEGER DEFAULT 0,\n2602:       last_retry_at TEXT,\n2603:       failure_reason TEXT,\n2604:       base_importance REAL DEFAULT 0.5,\n2605:       decay_half_life_days REAL DEFAULT 90.0,\n2606:       is_pinned INTEGER DEFAULT 0,\n2607:       access_count INTEGER DEFAULT 0,\n2608:       last_accessed INTEGER DEFAULT 0,\n2609:       importance_tier TEXT DEFAULT 'normal' CHECK(importance_tier IN ('constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated')),\n2610:       tenant_id TEXT,\n2611:       user_id TEXT,\n2612:       agent_id TEXT,\n2613:       session_id TEXT,\n2614:       context_type TEXT DEFAULT 'general' CHECK(context_type IN ('research', 'implementation', 'planning', 'general')),\n2615:       channel TEXT DEFAULT 'default',\n2616:       content_hash TEXT,\n2617:       provenance_source TEXT,\n2618:       provenance_actor TEXT,\n2619:       governed_at TEXT,\n2620:       retention_policy TEXT DEFAULT 'keep',\n2621:       delete_after TEXT,\n2622:       governance_metadata TEXT,\n2623:       expires_at DATETIME,\n2624:       confidence REAL DEFAULT 0.5,\n2625:       validation_count INTEGER DEFAULT 0,\n2626:       -- FSRS (Free Spaced Repetition Scheduler) columns for cognitive memory\n2627:       stability REAL DEFAULT 1.0,\n2628:       difficulty REAL DEFAULT 5.0,\n2629:       last_review TEXT,\n2630:       review_count INTEGER DEFAULT 0,\n2631:       file_mtime_ms INTEGER,\n2632:       -- DEPRECATED post-026.018 cleanup: archived-tier removed. Column kept to\n2633:       -- DEPRECATED schema stability: new rows always have is_archived = 0 and\n2634:       -- query paths must not branch on this column.\n2635:       is_archived INTEGER DEFAULT 0, -- DEPRECATED schema stability\n2636:       document_type TEXT DEFAULT 'memory',\n2637:       spec_level INTEGER,\n2638:       content_text TEXT,\n2639:       quality_score REAL DEFAULT 0,\n2640:       quality_flags TEXT,\n2641:       parent_id INTEGER REFERENCES memory_index(id) ON DELETE CASCADE,\n2642:       chunk_index INTEGER,\n2643:       chunk_label TEXT,\n2644:       encoding_intent TEXT DEFAULT 'document',\n2645:       learned_triggers TEXT DEFAULT '[]',\n2646:       interference_score REAL DEFAULT 0,\n2647:       post_insert_enrichment_status TEXT NOT NULL DEFAULT 'complete',\n2648:       post_insert_enrichment_state TEXT,\n2649:       post_insert_enrichment_completed_at TEXT,\n2650:       post_insert_enrichment_version INTEGER\n2651:     )\n2652:   `);\n2653: \n2654:   // Create vec_memories virtual table (only if sqlite-vec is available)\n2655:   if (sqlite_vec_available) {\n2656:     const embedding_dim = get_embedding_dim();\n2657:     database.exec(`\n2658:       CREATE VIRTUAL TABLE vec_memories USING vec0(\n2659:         embedding FLOAT[${embedding_dim}]\n2660:       )\n2661:     `);\n2662:     database.exec(`\n2663:       CREATE TABLE IF NOT EXISTS vec_metadata (\n2664:         key TEXT PRIMARY KEY,\n2665:         value TEXT NOT NULL,\n2666:         created_at TEXT DEFAULT (datetime('now'))\n2667:       )\n2668:     `);\n2669:     database.prepare(`\n2670:       INSERT OR REPLACE INTO vec_metadata (key, value) VALUES ('embedding_dim', ?)\n2671:     `).run(String(embedding_dim));\n2672:     logger.info(`Created vec_memories table with dimension ${embedding_dim}`);\n2673:   }\n2674: \n2675:   // Create FTS5 virtual table (includes content_text for full-text search)\n2676:   database.exec(`\n2677:     CREATE VIRTUAL TABLE IF NOT EXISTS memory_fts USING fts5(\n2678:       title, trigger_phrases, file_path, content_text,\n2679:       content='memory_index', content_rowid='id'\n2680:     )\n2681:   `);\n2682: \n2683:   // Create FTS5 sync triggers (includes content_text)\n2684:   database.exec(`\n2685:     CREATE TRIGGER IF NOT EXISTS memory_fts_insert AFTER INSERT ON memory_index BEGIN\n2686:       INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n2687:       VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n2688:     END\n2689:   `);\n2690: \n2691:   database.exec(`\n2692:     CREATE TRIGGER IF NOT EXISTS memory_fts_update AFTER UPDATE ON memory_index BEGIN\n2693:       INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n2694:       VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n2695:       INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n2696:       VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n2697:     END\n2698:   `);\n2699: \n2700:   database.exec(`\n2701:     CREATE TRIGGER IF NOT EXISTS memory_fts_delete AFTER DELETE ON memory_index BEGIN\n2702:       INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n2703:       VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n2704:     END\n2705:   `);\n2706: \n2707:   // Create companion tables\n2708:   ensureCompanionTables(database);\n2709:   ensureLineageTables(database);\n2710:   ensureGovernanceTables(database);\n2711: \n2712:   // the rollout — create embedding_cache table\n2713:   ensureEmbeddingCacheSchema(database);\n2714: \n2715:   // Create memory_index-specific indexes (not IF NOT EXISTS because this is a fresh DB)\n2716:   database.exec(`\n2717:     CREATE INDEX idx_spec_folder ON memory_index(spec_folder);\n2718:     CREATE INDEX idx_created_at ON memory_index(created_at);\n2719:     CREATE INDEX idx_importance ON memory_index(importance_weight DESC);\n2720:     CREATE INDEX idx_embedding_status ON memory_index(embedding_status);\n2721:     CREATE INDEX idx_retry_eligible ON memory_index(embedding_status, retry_count, last_retry_at)\n2722:   `);\n2723: \n2724:   database.exec(`\n2725:     CREATE INDEX IF NOT EXISTS idx_importance_tier ON memory_index(importance_tier);\n2726:     CREATE INDEX IF NOT EXISTS idx_access_importance ON memory_index(access_count DESC, importance_weight DESC);\n2727:     CREATE INDEX IF NOT EXISTS idx_memories_scope ON memory_index(spec_folder, session_id, context_type);\n2728:     CREATE INDEX IF NOT EXISTS idx_memories_governed_scope ON memory_index(tenant_id, user_id, agent_id, session_id);\n2729:     CREATE INDEX IF NOT EXISTS idx_channel ON memory_index(channel);\n\n(Showing lines 2550-2729 of 2784. Use offset=2730 to continue.)\n</content>","metadata":{"preview":" * @param options - Schema creation options.\n * @returns Nothing.\n */\nexport function create_schema(\n  database: Database.Database,\n  options: { sqlite_vec_available: boolean; get_embedding_dim: () => number }\n): void {\n  const { sqlite_vec_available, get_embedding_dim } = options;\n\n  const table_exists = database.prepare(`\n    SELECT name FROM sqlite_master\n    WHERE type='table' AND name='memory_index'\n  `).get();\n\n  if (table_exists) {\n    migrate_confidence_columns(database);\n    migrate_constitutional_tier(database);\n    ensure_canonical_file_path_support(database);\n    create_common_indexes(database);\n    ensureCompanionTables(database);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","text":" * @param options - Schema creation options.\n * @returns Nothing.\n */\nexport function create_schema(\n  database: Database.Database,\n  options: { sqlite_vec_available: boolean; get_embedding_dim: () => number }\n): void {\n  const { sqlite_vec_available, get_embedding_dim } = options;\n\n  const table_exists = database.prepare(`\n    SELECT name FROM sqlite_master\n    WHERE type='table' AND name='memory_index'\n  `).get();\n\n  if (table_exists) {\n    migrate_confidence_columns(database);\n    migrate_constitutional_tier(database);\n    ensure_canonical_file_path_support(database);\n    create_common_indexes(database);\n    ensureCompanionTables(database);\n    ensureLineageTables(database);\n    ensureGovernanceTables(database);\n    const compatibility = validate_backward_compatibility(database);\n    if (!compatibility.compatible) {\n      logger.warn(\n        'Existing schema is not fully backward-compatible after bootstrap',\n        compatibility as unknown as Record<string, unknown>\n      );\n    }\n    // the rollout — embedding cache table must exist before any\n    // Save/index operation so lookupEmbedding() can skip redundant provider calls.\n    ensureEmbeddingCacheSchema(database);\n    return;\n  }\n\n  // Create memory_index table (metadata only)\n  database.exec(`\n    CREATE TABLE memory_index (\n      id INTEGER PRIMARY KEY,\n      spec_folder TEXT NOT NULL,\n      file_path TEXT NOT NULL,\n      canonical_file_path TEXT,\n      anchor_id TEXT,\n      title TEXT,\n      trigger_phrases TEXT,\n      importance_weight REAL DEFAULT 0.5,\n      created_at TEXT NOT NULL,\n      updated_at TEXT NOT NULL,\n      embedding_model TEXT,\n      embedding_generated_at TEXT,\n      embedding_status TEXT DEFAULT 'pending' CHECK(embedding_status IN ('pending', 'success', 'failed', 'retry', 'partial')),\n      retry_count INTEGER DEFAULT 0,\n      last_retry_at TEXT,\n      failure_reason TEXT,\n      base_importance REAL DEFAULT 0.5,\n      decay_half_life_days REAL DEFAULT 90.0,\n      is_pinned INTEGER DEFAULT 0,\n      access_count INTEGER DEFAULT 0,\n      last_accessed INTEGER DEFAULT 0,\n      importance_tier TEXT DEFAULT 'normal' CHECK(importance_tier IN ('constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated')),\n      tenant_id TEXT,\n      user_id TEXT,\n      agent_id TEXT,\n      session_id TEXT,\n      context_type TEXT DEFAULT 'general' CHECK(context_type IN ('research', 'implementation', 'planning', 'general')),\n      channel TEXT DEFAULT 'default',\n      content_hash TEXT,\n      provenance_source TEXT,\n      provenance_actor TEXT,\n      governed_at TEXT,\n      retention_policy TEXT DEFAULT 'keep',\n      delete_after TEXT,\n      governance_metadata TEXT,\n      expires_at DATETIME,\n      confidence REAL DEFAULT 0.5,\n      validation_count INTEGER DEFAULT 0,\n      -- FSRS (Free Spaced Repetition Scheduler) columns for cognitive memory\n      stability REAL DEFAULT 1.0,\n      difficulty REAL DEFAULT 5.0,\n      last_review TEXT,\n      review_count INTEGER DEFAULT 0,\n      file_mtime_ms INTEGER,\n      -- DEPRECATED post-026.018 cleanup: archived-tier removed. Column kept to\n      -- DEPRECATED schema stability: new rows always have is_archived = 0 and\n      -- query paths must not branch on this column.\n      is_archived INTEGER DEFAULT 0, -- DEPRECATED schema stability\n      document_type TEXT DEFAULT 'memory',\n      spec_level INTEGER,\n      content_text TEXT,\n      quality_score REAL DEFAULT 0,\n      quality_flags TEXT,\n      parent_id INTEGER REFERENCES memory_index(id) ON DELETE CASCADE,\n      chunk_index INTEGER,\n      chunk_label TEXT,\n      encoding_intent TEXT DEFAULT 'document',\n      learned_triggers TEXT DEFAULT '[]',\n      interference_score REAL DEFAULT 0,\n      post_insert_enrichment_status TEXT NOT NULL DEFAULT 'complete',\n      post_insert_enrichment_state TEXT,\n      post_insert_enrichment_completed_at TEXT,\n      post_insert_enrichment_version INTEGER\n    )\n  `);\n\n  // Create vec_memories virtual table (only if sqlite-vec is available)\n  if (sqlite_vec_available) {\n    const embedding_dim = get_embedding_dim();\n    database.exec(`\n      CREATE VIRTUAL TABLE vec_memories USING vec0(\n        embedding FLOAT[${embedding_dim}]\n      )\n    `);\n    database.exec(`\n      CREATE TABLE IF NOT EXISTS vec_metadata (\n        key TEXT PRIMARY KEY,\n        value TEXT NOT NULL,\n        created_at TEXT DEFAULT (datetime('now'))\n      )\n    `);\n    database.prepare(`\n      INSERT OR REPLACE INTO vec_metadata (key, value) VALUES ('embedding_dim', ?)\n    `).run(String(embedding_dim));\n    logger.info(`Created vec_memories table with dimension ${embedding_dim}`);\n  }\n\n  // Create FTS5 virtual table (includes content_text for full-text search)\n  database.exec(`\n    CREATE VIRTUAL TABLE IF NOT EXISTS memory_fts USING fts5(\n      title, trigger_phrases, file_path, content_text,\n      content='memory_index', content_rowid='id'\n    )\n  `);\n\n  // Create FTS5 sync triggers (includes content_text)\n  database.exec(`\n    CREATE TRIGGER IF NOT EXISTS memory_fts_insert AFTER INSERT ON memory_index BEGIN\n      INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n      VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n    END\n  `);\n\n  database.exec(`\n    CREATE TRIGGER IF NOT EXISTS memory_fts_update AFTER UPDATE ON memory_index BEGIN\n      INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n      VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n      INSERT INTO memory_fts(rowid, title, trigger_phrases, file_path, content_text)\n      VALUES (new.id, new.title, new.trigger_phrases, new.file_path, new.content_text);\n    END\n  `);\n\n  database.exec(`\n    CREATE TRIGGER IF NOT EXISTS memory_fts_delete AFTER DELETE ON memory_index BEGIN\n      INSERT INTO memory_fts(memory_fts, rowid, title, trigger_phrases, file_path, content_text)\n      VALUES ('delete', old.id, old.title, old.trigger_phrases, old.file_path, old.content_text);\n    END\n  `);\n\n  // Create companion tables\n  ensureCompanionTables(database);\n  ensureLineageTables(database);\n  ensureGovernanceTables(database);\n\n  // the rollout — create embedding_cache table\n  ensureEmbeddingCacheSchema(database);\n\n  // Create memory_index-specific indexes (not IF NOT EXISTS because this is a fresh DB)\n  database.exec(`\n    CREATE INDEX idx_spec_folder ON memory_index(spec_folder);\n    CREATE INDEX idx_created_at ON memory_index(created_at);\n    CREATE INDEX idx_importance ON memory_index(importance_weight DESC);\n    CREATE INDEX idx_embedding_status ON memory_index(embedding_status);\n    CREATE INDEX idx_retry_eligible ON memory_index(embedding_status, retry_count, last_retry_at)\n  `);\n\n  database.exec(`\n    CREATE INDEX IF NOT EXISTS idx_importance_tier ON memory_index(importance_tier);\n    CREATE INDEX IF NOT EXISTS idx_access_importance ON memory_index(access_count DESC, importance_weight DESC);\n    CREATE INDEX IF NOT EXISTS idx_memories_scope ON memory_index(spec_folder, session_id, context_type);\n    CREATE INDEX IF NOT EXISTS idx_memories_governed_scope ON memory_index(tenant_id, user_id, agent_id, session_id);\n    CREATE INDEX IF NOT EXISTS idx_channel ON memory_index(channel);","lineStart":2550,"lineEnd":2729,"totalLines":2784,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts","time":{"start":1780925773364,"end":1780925773370}},"metadata":{"openai":{"itemId":"fc_01f118128bb1efd9016a26c54d3ae48191bceca29fb97681a9"}},"id":"prt_ea772b5ed001nhRHs2rEVilncA","sessionID":"ses_158903c2cffe2nrTzl0pYixxzr","messageID":"msg_ea7729304001Wo1pAL1I6w2EVe"}}
