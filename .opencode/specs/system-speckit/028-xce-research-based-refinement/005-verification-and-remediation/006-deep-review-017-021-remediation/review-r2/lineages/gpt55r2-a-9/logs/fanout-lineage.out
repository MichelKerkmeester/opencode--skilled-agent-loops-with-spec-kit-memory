{"type":"tool_use","timestamp":1781764333635,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_jgAadlV1Ty2QC4xPbk4JElVY","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/rrf-fusion.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/rrf-fusion.ts</path>\n<type>file</type>\n<content>\n1: // ---------------------------------------------------------------\n2: // MODULE: RRF Fusion\n3: // ---------------------------------------------------------------\n4: // Reciprocal Rank Fusion for combining search results\n5: // P3-11: TypeScript source (previously orphaned .js only)\n6: \n7: /* --- 1. CONSTANTS --- */\n8: \n9: // Feature catalog: Hybrid search pipeline\n10: // Feature catalog: RRF K-value sensitivity analysis\n11: \n12: const SOURCE_TYPES = {\n13:   VECTOR: 'vector',\n14:   FTS: 'fts',\n15:   BM25: 'bm25',\n16:   GRAPH: 'graph',\n17:   DEGREE: 'degree',\n18:   KEYWORD: 'keyword',\n19: } as const;\n20: \n21: /**\n22:  * Default RRF smoothing constant used in the reciprocal rank term `1 / (k + rank)`.\n23:  *\n24:  * Origin: Cormack, Clarke, and Buettcher (SIGIR 2009), where Reciprocal Rank\n25:  * Fusion is introduced with `k = 60` as a robust default for rank aggregation.\n26:  * This implementation defaults to `k = 40` for the current ~1000-memory corpus.\n27:  *\n28:  * Behavior:\n29:  * - Lower `k` increases sensitivity to early ranks (top results dominate more).\n30:  * - Higher `k` flattens rank-position impact (more conservative, less top-heavy).\n31:  *\n32:  * Valid range:\n33:  * - Explicit `k` values must be finite and non-negative.\n34:  * - Runtime override `SPECKIT_RRF_K` is accepted only when parseable as a\n35:  *   finite positive number (`> 0`).\n36:  */\n37: // k=40 optimized for ~1000-memory corpus.\n38: const DEFAULT_K = 40;\n39: const CONVERGENCE_BONUS = 0.10;\n40: // AI-WHY: Graph channel gets 1.5x boost when no explicit weight is supplied because\n41: // graph edges encode curated human decisions (causal links) that are high-signal.\n42: const GRAPH_WEIGHT_BOOST = 1.5;\n43: \n44: /**\n45:  * Default beta scaling factor for calibrated overlap bonus (REQ-D1-001).\n46:  * Controls the magnitude of the query-aware overlap bonus relative to\n47:  * the mean normalized top score. Lower values produce smaller bonuses.\n48:  */\n49: const CALIBRATED_OVERLAP_BETA = 0.15;\n50: \n51: /**\n52:  * Maximum overlap bonus when calibrated overlap is enabled (REQ-D1-001).\n53:  * Clamped to prevent a single overlap bonus from dominating RRF scores.\n54:  */\n55: const CALIBRATED_OVERLAP_MAX = 0.06;\n56: \n57: /** Minimum character length for a query term to be considered for term matching. */\n58: const MIN_QUERY_TERM_LENGTH = 2;\n59: \n60: /* --- 2. INTERFACES --- */\n61: \n62: /** A single item from a ranked retrieval list, identified by its unique ID. */\n63: interface RrfItem {\n64:   id: number | string;\n65:   [key: string]: unknown;\n66: }\n67: \n68: /** Result of RRF fusion: an RrfItem augmented with fused score, source tracking, and convergence bonus. */\n69: interface FusionResult extends RrfItem {\n70:   /**\n71:    * Reciprocal Rank Fusion score. Combines rankings from multiple retrieval\n72:    * methods using the formula `1/(k + rank)`. Higher values indicate the\n73:    * result was ranked highly by more methods. Includes convergence bonus\n74:    * when a result appears in multiple ranked lists.\n75:    */\n76:   rrfScore: number;\n77:   sources: string[];\n78:   sourceScores: Record<string, number>;\n79:   convergenceBonus: number;\n80: }\n81: \n82: /** A ranked result list from a single retrieval source (e.g., vector, BM25, graph). */\n83: interface RankedList {\n84:   source: string;\n85:   results: RrfItem[];\n86:   weight?: number;\n87: }\n88: \n89: /** Configuration options for multi-list RRF fusion. */\n90: interface FuseMultiOptions {\n91:   k?: number;\n92:   convergenceBonus?: number;\n93:   graphWeightBoost?: number;\n94:   /**\n95:    * Beta scaling factor for calibrated overlap bonus (REQ-D1-001).\n96:    * Only used when SPECKIT_CALIBRATED_OVERLAP_BONUS is enabled.\n97:    * Default: 0.15\n98:    */\n99:   calibratedOverlapBeta?: number;\n100: }\n101: \n102: /** Configuration options for advanced score fusion with term matching. */\n103: interface FuseAdvancedOptions {\n104:   termMatchBonus?: number;\n105: }\n106: \n107: /** A search function descriptor: source label, async retrieval function, and optional weight. */\n108: interface SearchFunction {\n109:   source: string;\n110:   fn: () => Promise<RrfItem[]>;\n111:   weight?: number;\n112: }\n113: \n114: /** Canonical key for cross-channel deduplication (`42`, `\"42\"`, `\"mem:42\"` -> `\"42\"`). */\n115: function canonicalRrfId(id: number | string): string {\n116:   if (typeof id === 'number') {\n117:     return String(id);\n118:   }\n119: \n120:   const raw = String(id).trim();\n121:   const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n122:   if (memPrefixed) {\n123:     return String(Number(memPrefixed[1]));\n124:   }\n125: \n126:   if (/^\\d+$/.test(raw)) {\n127:     return String(Number(raw));\n128:   }\n129: \n130:   return raw;\n131: }\n132: \n133: /**\n134:  * Resolve the effective RRF `k` with explicit-zero support and shared validation semantics.\n135:  *\n136:  * Runtime override:\n137:  * - If `SPECKIT_RRF_K` is set and parses to a finite positive number, that value\n138:  *   is used as the fallback in place of `DEFAULT_K`.\n139:  * - Invalid/non-positive env values are ignored.\n140:  *\n141:  * Precedence:\n142:  * 1) caller-provided `rawK` (when finite and non-negative)\n143:  * 2) `SPECKIT_RRF_K` (when valid)\n144:  * 3) `DEFAULT_K`\n145:  *\n146:  * @param rawK - Optional caller-provided RRF smoothing constant.\n147:  * @returns Effective `k` used for fusion scoring.\n148:  * @throws Error if `rawK` is negative.\n149:  */\n150: function resolveRrfK(rawK: number | undefined): number {\n151:   const envKRaw = process.env.SPECKIT_RRF_K;\n152:   const envKParsed = envKRaw === undefined ? Number.NaN : Number(envKRaw);\n153:   const fallbackK = Number.isFinite(envKParsed) && envKParsed > 0 ? envKParsed : DEFAULT_K;\n154: \n155:   if (rawK === undefined) {\n156:     return fallbackK;\n157:   }\n158: \n159:   if (rawK < 0) {\n160:     throw new Error('RRF k parameter must be non-negative');\n161:   }\n162: \n163:   return Number.isFinite(rawK) ? rawK : fallbackK;\n164: }\n165: \n166: /* --- 3. FEATURE FLAG HELPERS --- */\n167: \n168: /**\n169:  * Check if calibrated overlap bonus is enabled (REQ-D1-001).\n170:  * Default: ON (graduated). Set SPECKIT_CALIBRATED_OVERLAP_BONUS=false to disable.\n171:  * When OFF, the flat CONVERGENCE_BONUS is used.\n172:  * When ON, a query-aware scaled overlap bonus is computed.\n173:  */\n174: function isCalibratedOverlapBonusEnabled(): boolean {\n175:   const val = process.env.SPECKIT_CALIBRATED_OVERLAP_BONUS?.toLowerCase().trim();\n176:   return val !== 'false' && val !== '0';\n177: }\n178: \n179: /**\n180:  * Clamp a value to [min, max].\n181:  */\n182: function clamp(value: number, min: number, max: number): number {\n183:   return Math.max(min, Math.min(max, value));\n184: }\n185: \n186: /* --- 4. CORE FUNCTIONS --- */\n187: \n188: /**\n189:  * Fuse two ranked result lists using Reciprocal Rank Fusion.\n190:  * @param listA - First ranked result list.\n191:  * @param listB - Second ranked result list.\n192:  * @param k - RRF smoothing constant (default 40).\n193:  * @param sourceA - Source label for listA (default 'vector').\n194:  * @param sourceB - Source label for listB (default 'fts').\n195:  * @returns Fused results sorted by descending RRF score.\n196:  */\n197: function fuseResults(\n198:   listA: RrfItem[],\n199:   listB: RrfItem[],\n200:   k: number = DEFAULT_K,\n201:   sourceA: string = SOURCE_TYPES.VECTOR,\n202:   sourceB: string = SOURCE_TYPES.FTS,\n203: ): FusionResult[] {\n204:   const effectiveK = Number.isFinite(k) && k >= 0 ? k : resolveRrfK(undefined);\n205:   const scoreMap = new Map<string, FusionResult>();\n206: \n207:   // Process list A\n208:   for (let i = 0; i < listA.length; i++) {\n209:     const item = listA[i];\n210:     const rrfScore = 1 / (effectiveK + i + 1);\n211:     const key = canonicalRrfId(item.id);\n212:     const existing = scoreMap.get(key);\n213:     if (existing) {\n214:       existing.rrfScore += rrfScore;\n215:       existing.sourceScores[sourceA] = rrfScore;\n216:       existing.sources.push(sourceA);\n217:     } else {\n218:       scoreMap.set(key, {\n219:         ...item,\n220:         rrfScore,\n221:         sources: [sourceA],\n222:         sourceScores: { [sourceA]: rrfScore },\n223:         convergenceBonus: 0,\n224:       });\n225:     }\n226:   }\n227: \n228:   // Process list B\n229:   for (let i = 0; i < listB.length; i++) {\n230:     const item = listB[i];\n231:     const rrfScore = 1 / (effectiveK + i + 1);\n232:     const key = canonicalRrfId(item.id);\n233:     const existing = scoreMap.get(key);\n234:     if (existing) {\n235:       existing.rrfScore += rrfScore;\n236:       existing.sourceScores[sourceB] = rrfScore;\n237:       existing.sources.push(sourceB);\n238:       // AI: Fix F16 — apply convergence bonus only once per ID.\n239:       if (existing.convergenceBonus === 0) {\n240:         existing.convergenceBonus = CONVERGENCE_BONUS;\n\n(Showing lines 1-240 of 656. Use offset=241 to continue.)\n</content>","metadata":{"preview":"// ---------------------------------------------------------------\n// MODULE: RRF Fusion\n// ---------------------------------------------------------------\n// Reciprocal Rank Fusion for combining search results\n// P3-11: TypeScript source (previously orphaned .js only)\n\n/* --- 1. CONSTANTS --- */\n\n// Feature catalog: Hybrid search pipeline\n// Feature catalog: RRF K-value sensitivity analysis\n\nconst SOURCE_TYPES = {\n  VECTOR: 'vector',\n  FTS: 'fts',\n  BM25: 'bm25',\n  GRAPH: 'graph',\n  DEGREE: 'degree',\n  KEYWORD: 'keyword',\n} as const;\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/rrf-fusion.ts","text":"// ---------------------------------------------------------------\n// MODULE: RRF Fusion\n// ---------------------------------------------------------------\n// Reciprocal Rank Fusion for combining search results\n// P3-11: TypeScript source (previously orphaned .js only)\n\n/* --- 1. CONSTANTS --- */\n\n// Feature catalog: Hybrid search pipeline\n// Feature catalog: RRF K-value sensitivity analysis\n\nconst SOURCE_TYPES = {\n  VECTOR: 'vector',\n  FTS: 'fts',\n  BM25: 'bm25',\n  GRAPH: 'graph',\n  DEGREE: 'degree',\n  KEYWORD: 'keyword',\n} as const;\n\n/**\n * Default RRF smoothing constant used in the reciprocal rank term `1 / (k + rank)`.\n *\n * Origin: Cormack, Clarke, and Buettcher (SIGIR 2009), where Reciprocal Rank\n * Fusion is introduced with `k = 60` as a robust default for rank aggregation.\n * This implementation defaults to `k = 40` for the current ~1000-memory corpus.\n *\n * Behavior:\n * - Lower `k` increases sensitivity to early ranks (top results dominate more).\n * - Higher `k` flattens rank-position impact (more conservative, less top-heavy).\n *\n * Valid range:\n * - Explicit `k` values must be finite and non-negative.\n * - Runtime override `SPECKIT_RRF_K` is accepted only when parseable as a\n *   finite positive number (`> 0`).\n */\n// k=40 optimized for ~1000-memory corpus.\nconst DEFAULT_K = 40;\nconst CONVERGENCE_BONUS = 0.10;\n// AI-WHY: Graph channel gets 1.5x boost when no explicit weight is supplied because\n// graph edges encode curated human decisions (causal links) that are high-signal.\nconst GRAPH_WEIGHT_BOOST = 1.5;\n\n/**\n * Default beta scaling factor for calibrated overlap bonus (REQ-D1-001).\n * Controls the magnitude of the query-aware overlap bonus relative to\n * the mean normalized top score. Lower values produce smaller bonuses.\n */\nconst CALIBRATED_OVERLAP_BETA = 0.15;\n\n/**\n * Maximum overlap bonus when calibrated overlap is enabled (REQ-D1-001).\n * Clamped to prevent a single overlap bonus from dominating RRF scores.\n */\nconst CALIBRATED_OVERLAP_MAX = 0.06;\n\n/** Minimum character length for a query term to be considered for term matching. */\nconst MIN_QUERY_TERM_LENGTH = 2;\n\n/* --- 2. INTERFACES --- */\n\n/** A single item from a ranked retrieval list, identified by its unique ID. */\ninterface RrfItem {\n  id: number | string;\n  [key: string]: unknown;\n}\n\n/** Result of RRF fusion: an RrfItem augmented with fused score, source tracking, and convergence bonus. */\ninterface FusionResult extends RrfItem {\n  /**\n   * Reciprocal Rank Fusion score. Combines rankings from multiple retrieval\n   * methods using the formula `1/(k + rank)`. Higher values indicate the\n   * result was ranked highly by more methods. Includes convergence bonus\n   * when a result appears in multiple ranked lists.\n   */\n  rrfScore: number;\n  sources: string[];\n  sourceScores: Record<string, number>;\n  convergenceBonus: number;\n}\n\n/** A ranked result list from a single retrieval source (e.g., vector, BM25, graph). */\ninterface RankedList {\n  source: string;\n  results: RrfItem[];\n  weight?: number;\n}\n\n/** Configuration options for multi-list RRF fusion. */\ninterface FuseMultiOptions {\n  k?: number;\n  convergenceBonus?: number;\n  graphWeightBoost?: number;\n  /**\n   * Beta scaling factor for calibrated overlap bonus (REQ-D1-001).\n   * Only used when SPECKIT_CALIBRATED_OVERLAP_BONUS is enabled.\n   * Default: 0.15\n   */\n  calibratedOverlapBeta?: number;\n}\n\n/** Configuration options for advanced score fusion with term matching. */\ninterface FuseAdvancedOptions {\n  termMatchBonus?: number;\n}\n\n/** A search function descriptor: source label, async retrieval function, and optional weight. */\ninterface SearchFunction {\n  source: string;\n  fn: () => Promise<RrfItem[]>;\n  weight?: number;\n}\n\n/** Canonical key for cross-channel deduplication (`42`, `\"42\"`, `\"mem:42\"` -> `\"42\"`). */\nfunction canonicalRrfId(id: number | string): string {\n  if (typeof id === 'number') {\n    return String(id);\n  }\n\n  const raw = String(id).trim();\n  const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n  if (memPrefixed) {\n    return String(Number(memPrefixed[1]));\n  }\n\n  if (/^\\d+$/.test(raw)) {\n    return String(Number(raw));\n  }\n\n  return raw;\n}\n\n/**\n * Resolve the effective RRF `k` with explicit-zero support and shared validation semantics.\n *\n * Runtime override:\n * - If `SPECKIT_RRF_K` is set and parses to a finite positive number, that value\n *   is used as the fallback in place of `DEFAULT_K`.\n * - Invalid/non-positive env values are ignored.\n *\n * Precedence:\n * 1) caller-provided `rawK` (when finite and non-negative)\n * 2) `SPECKIT_RRF_K` (when valid)\n * 3) `DEFAULT_K`\n *\n * @param rawK - Optional caller-provided RRF smoothing constant.\n * @returns Effective `k` used for fusion scoring.\n * @throws Error if `rawK` is negative.\n */\nfunction resolveRrfK(rawK: number | undefined): number {\n  const envKRaw = process.env.SPECKIT_RRF_K;\n  const envKParsed = envKRaw === undefined ? Number.NaN : Number(envKRaw);\n  const fallbackK = Number.isFinite(envKParsed) && envKParsed > 0 ? envKParsed : DEFAULT_K;\n\n  if (rawK === undefined) {\n    return fallbackK;\n  }\n\n  if (rawK < 0) {\n    throw new Error('RRF k parameter must be non-negative');\n  }\n\n  return Number.isFinite(rawK) ? rawK : fallbackK;\n}\n\n/* --- 3. FEATURE FLAG HELPERS --- */\n\n/**\n * Check if calibrated overlap bonus is enabled (REQ-D1-001).\n * Default: ON (graduated). Set SPECKIT_CALIBRATED_OVERLAP_BONUS=false to disable.\n * When OFF, the flat CONVERGENCE_BONUS is used.\n * When ON, a query-aware scaled overlap bonus is computed.\n */\nfunction isCalibratedOverlapBonusEnabled(): boolean {\n  const val = process.env.SPECKIT_CALIBRATED_OVERLAP_BONUS?.toLowerCase().trim();\n  return val !== 'false' && val !== '0';\n}\n\n/**\n * Clamp a value to [min, max].\n */\nfunction clamp(value: number, min: number, max: number): number {\n  return Math.max(min, Math.min(max, value));\n}\n\n/* --- 4. CORE FUNCTIONS --- */\n\n/**\n * Fuse two ranked result lists using Reciprocal Rank Fusion.\n * @param listA - First ranked result list.\n * @param listB - Second ranked result list.\n * @param k - RRF smoothing constant (default 40).\n * @param sourceA - Source label for listA (default 'vector').\n * @param sourceB - Source label for listB (default 'fts').\n * @returns Fused results sorted by descending RRF score.\n */\nfunction fuseResults(\n  listA: RrfItem[],\n  listB: RrfItem[],\n  k: number = DEFAULT_K,\n  sourceA: string = SOURCE_TYPES.VECTOR,\n  sourceB: string = SOURCE_TYPES.FTS,\n): FusionResult[] {\n  const effectiveK = Number.isFinite(k) && k >= 0 ? k : resolveRrfK(undefined);\n  const scoreMap = new Map<string, FusionResult>();\n\n  // Process list A\n  for (let i = 0; i < listA.length; i++) {\n    const item = listA[i];\n    const rrfScore = 1 / (effectiveK + i + 1);\n    const key = canonicalRrfId(item.id);\n    const existing = scoreMap.get(key);\n    if (existing) {\n      existing.rrfScore += rrfScore;\n      existing.sourceScores[sourceA] = rrfScore;\n      existing.sources.push(sourceA);\n    } else {\n      scoreMap.set(key, {\n        ...item,\n        rrfScore,\n        sources: [sourceA],\n        sourceScores: { [sourceA]: rrfScore },\n        convergenceBonus: 0,\n      });\n    }\n  }\n\n  // Process list B\n  for (let i = 0; i < listB.length; i++) {\n    const item = listB[i];\n    const rrfScore = 1 / (effectiveK + i + 1);\n    const key = canonicalRrfId(item.id);\n    const existing = scoreMap.get(key);\n    if (existing) {\n      existing.rrfScore += rrfScore;\n      existing.sourceScores[sourceB] = rrfScore;\n      existing.sources.push(sourceB);\n      // AI: Fix F16 — apply convergence bonus only once per ID.\n      if (existing.convergenceBonus === 0) {\n        existing.convergenceBonus = CONVERGENCE_BONUS;","lineStart":1,"lineEnd":240,"totalLines":656,"truncated":true}},"title":".opencode/skills/system-spec-kit/shared/algorithms/rrf-fusion.ts","time":{"start":1781764333618,"end":1781764333633}},"metadata":{"openai":{"itemId":"fc_031d3c8d18dc078a016a3390ec50408191892762465670b322"}},"id":"prt_ed96e1b38001oIdk600fkHCrGY","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96e1094001BKieGXBm9yicYs"}}
{"type":"step_finish","timestamp":1781764333961,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"id":"prt_ed96e2187001juFg3LmBCBJjhC","reason":"tool-calls","snapshot":"7ce7037dc69c91003d7f4649c29147af1e1c141b","messageID":"msg_ed96e1094001BKieGXBm9yicYs","sessionID":"ses_126974374fferlHj5CU2Guj68V","type":"step-finish","tokens":{"total":207201,"input":293,"output":60,"reasoning":0,"cache":{"write":0,"read":206848}},"cost":0}}
{"type":"step_start","timestamp":1781764336435,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"id":"prt_ed96e2b30001Ie8vOuePBul3ns","messageID":"msg_ed96e22a3001luiEILTq9I0Hc3","sessionID":"ses_126974374fferlHj5CU2Guj68V","snapshot":"7ce7037dc69c91003d7f4649c29147af1e1c141b","type":"step-start"}}
{"type":"tool_use","timestamp":1781764338971,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_xuwIgQIWH3AlHxBkitK2aYat","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/rrf-fusion.ts","offset":320,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/algorithms/rrf-fusion.ts</path>\n<type>file</type>\n<content>\n320:           rrfScore,\n321:           sources: [list.source],\n322:           sourceScores: { [list.source]: rrfScore },\n323:           convergenceBonus: 0,\n324:         });\n325:       }\n326:       // Track raw score for calibrated overlap computation\n327:       let srcMap = rawScoresBySource.get(key);\n328:       if (!srcMap) {\n329:         srcMap = new Map<string, number>();\n330:         rawScoresBySource.set(key, srcMap);\n331:       }\n332:       // Accumulate score per source (in case same source appears twice)\n333:       srcMap.set(list.source, (srcMap.get(list.source) ?? 0) + rrfScore);\n334:     }\n335:   }\n336: \n337:   // Compute max raw score across all candidates (for normalization in calibrated overlap)\n338:   // AI-WHY: We normalize per-candidate scores against the global max so the bonus\n339:   // is proportional to the candidate's strength relative to the pool.\n340:   let globalMaxRawScore = 0;\n341:   for (const result of scoreMap.values()) {\n342:     if (result.rrfScore > globalMaxRawScore) globalMaxRawScore = result.rrfScore;\n343:   }\n344: \n345:   const totalChannels = activeChannelCount;\n346:   const calibratedMode = isCalibratedOverlapBonusEnabled();\n347: \n348:   // Apply convergence bonus for multi-source matches\n349:   for (const [id, result] of scoreMap) {\n350:     // AI-WHY: Deduplicate sources before counting — a source can appear multiple\n351:     // times when the same channel contributes via different code paths.\n352:     const uniqueSources = new Set(result.sources);\n353:     const uniqueSourceCount = uniqueSources.size;\n354:     if (uniqueSourceCount >= 2) {\n355:       if (calibratedMode) {\n356:         // REQ-D1-001: Calibrated overlap bonus — query-aware, bounded to [0, 0.06]\n357:         // channelsHit = number of unique channels this candidate appeared in\n358:         // overlapRatio = fraction of possible additional channels that hit (0 when 1 channel, 1 when all channels)\n359:         const channelsHit = uniqueSourceCount;\n360:         const overlapRatio = (channelsHit - 1) / Math.max(1, totalChannels - 1);\n361: \n362:         // meanTopNormScore: mean normalized raw score across channels that hit this candidate\n363:         const srcScores = rawScoresBySource.get(id);\n364:         let meanNorm = 0;\n365:         if (srcScores && globalMaxRawScore > 0) {\n366:           let sumNorm = 0;\n367:           let count = 0;\n368:           for (const [src, rawScore] of srcScores) {\n369:             if (uniqueSources.has(src)) {\n370:               sumNorm += rawScore / globalMaxRawScore;\n371:               count++;\n372:             }\n373:           }\n374:           meanNorm = count > 0 ? sumNorm / count : 0;\n375:         }\n376: \n377:         const overlapScore = beta * overlapRatio * meanNorm;\n378:         const bonus = clamp(overlapScore, 0, CALIBRATED_OVERLAP_MAX);\n379:         result.convergenceBonus = bonus;\n380:         result.rrfScore += bonus;\n381:       } else {\n382:         // Default flat convergence bonus (backwards compatible)\n383:         const bonus = convergenceBonus * (uniqueSourceCount - 1);\n384:         result.convergenceBonus = bonus;\n385:         result.rrfScore += bonus;\n386:       }\n387:     }\n388:   }\n389: \n390:   const results = Array.from(scoreMap.values())\n391:     .sort((a, b) => b.rrfScore - a.rrfScore);\n392: \n393:   // Normalize RRF scores to [0,1] when enabled\n394:   if (isScoreNormalizationEnabled()) {\n395:     normalizeRrfScores(results);\n396:   }\n397: \n398:   return results;\n399: }\n400: \n401: /**\n402:  * Advanced score fusion with original term match counting.\n403:  * @param results - Pre-fused results to augment with term-match bonuses.\n404:  * @param query - Original query string for term extraction.\n405:  * @param options - Optional termMatchBonus multiplier (default 0.05 per match).\n406:  * @returns Augmented results with termMatches count, re-sorted by adjusted RRF score.\n407:  */\n408: function fuseScoresAdvanced(\n409:   results: FusionResult[],\n410:   query: string,\n411:   options: FuseAdvancedOptions = {}\n412: ): Array<FusionResult & { termMatches: number }> {\n413:   const termMatchBonus = options.termMatchBonus ?? 0.05;\n414:   const queryTerms = query.toLowerCase().split(/\\s+/).filter(t => t.length >= MIN_QUERY_TERM_LENGTH);\n415: \n416:   return results.map(r => {\n417:     const termMatches = countOriginalTermMatches(r, queryTerms);\n418:     const bonus = termMatches * termMatchBonus;\n419:     return {\n420:       ...r,\n421:       rrfScore: r.rrfScore + bonus,\n422:       termMatches,\n423:     };\n424:   }).sort((a, b) => b.rrfScore - a.rrfScore);\n425: }\n426: \n427: /**\n428:  * Count how many query terms match in the result's text fields.\n429:  * @param result - A search result record with title, trigger_phrases, and file_path fields.\n430:  * @param queryTerms - Lowercased query terms to match against.\n431:  * @returns Number of query terms found in the result's searchable text.\n432:  */\n433: function countOriginalTermMatches(\n434:   result: Record<string, unknown>,\n435:   queryTerms: string[]\n436: ): number {\n437:   const searchableText = [\n438:     (result.title as string) || '',\n439:     (result.trigger_phrases as string) || '',\n440:     (result.file_path as string) || '',\n441:   ].join(' ').toLowerCase();\n442: \n443:   let matches = 0;\n444:   for (const term of queryTerms) {\n445:     if (searchableText.includes(term)) {\n446:       matches++;\n447:     }\n448:   }\n449:   return matches;\n450: }\n451: \n452: /**\n453:  * Unified search that combines vector, FTS, and BM25 results via RRF.\n454:  * @param searchFunctions - Array of search descriptors with source label, async function, and optional weight.\n455:  * @param options - Fusion configuration (k, convergence bonus, graph weight boost).\n456:  * @returns Fused results from all successful search channels.\n457:  */\n458: async function unifiedSearch(\n459:   searchFunctions: SearchFunction[],\n460:   options: FuseMultiOptions = {}\n461: ): Promise<FusionResult[]> {\n462:   const lists: RankedList[] = await Promise.all(\n463:     searchFunctions.map(async (sf) => {\n464:       try {\n465:         const results = await sf.fn();\n466:         return { source: sf.source, results, weight: sf.weight };\n467:       } catch (error: unknown) {\n468:         const msg = error instanceof Error ? error.message : String(error);\n469:         console.warn(`[rrf-fusion] ${sf.source} search failed: ${msg}`);\n470:         return { source: sf.source, results: [], weight: sf.weight };\n471:       }\n472:     })\n473:   );\n474:   return fuseResultsMulti(lists, options);\n475: }\n476: \n477: /**\n478:  * C138-P3: Cross-Variant RRF Fusion for multi-query RAG.\n479:  *\n480:  * Accepts multi-dimensional arrays (one RankedList[] per query variant),\n481:  * groups identical memory IDs across variants, and applies a +0.10\n482:  * cross-variant convergence bonus when the same ID appears in results\n483:  * from different query variants.\n484:  *\n485:  * @param variantLists - Array of variant result sets, each containing\n486:  *                       multiple RankedLists (e.g., vector + fts per variant)\n487:  * @param options - Standard fusion options\n488:  * @returns Fused results with cross-variant convergence bonuses\n489:  */\n490: function fuseResultsCrossVariant(\n491:   varian