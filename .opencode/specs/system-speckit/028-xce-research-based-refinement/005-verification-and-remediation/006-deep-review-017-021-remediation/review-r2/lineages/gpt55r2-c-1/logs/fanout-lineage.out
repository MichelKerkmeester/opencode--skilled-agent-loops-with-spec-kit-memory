{"type":"tool_use","timestamp":1781761501756,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_5n7pfb1avd2MLoGhVJhOj6mH","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","offset":1,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ COMPONENT: Model Server Supervision                                      ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n5: // ╚══════════════════════════════════════════════════════════════════════════╝\n6: \n7: 'use strict';\n8: \n9: const fs = require('fs');\n10: const http = require('http');\n11: const path = require('path');\n12: const { spawn, spawnSync } = require('child_process');\n13: \n14: const defaultRoot = path.resolve(__dirname, '..', '..', '..');\n15: const defaultOpencodeDir = path.join(defaultRoot, '.opencode');\n16: const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n17: \n18: const SHUTDOWN_DEADLINE_MS = 5000;\n19: const RESPAWN_REAP_GRACE_MS = 7000;\n20: const RESPAWN_LOCK_STALE_MS = 60000;\n21: const DEFAULT_WATCHDOG_GRACE_MS = 7000;\n22: const DEFAULT_WATCHDOG_INTERVAL_MS = 15000;\n23: const DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES = 3;\n24: const DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS = 30000;\n25: const DEFAULT_CRASH_LOOP_MAX_DEATHS = 3;\n26: const DEFAULT_CRASH_LOOP_WINDOW_MS = 60000;\n27: const DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS = 250;\n28: const DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS = 5000;\n29: const HF_MODEL_SERVER_SOCKET_FILE_NAME = 'hf-embed.sock';\n30: const HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME = 'hf-embed-respawn.lock';\n31: const HF_MODEL_SERVER_PID_FILE_NAME = 'hf-embed.pid';\n32: const HF_MODEL_SERVER_GIVEUP_FILE_NAME = 'hf-embed-giveup.json';\n33: const MODEL_SERVER_DEMAND_STATUS = 503;\n34: const DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS = 60000;\n35: const DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\n36: const durableWriteWarnings = new Set();\n37: \n38: function defaultLog(message) {\n39:   process.stderr.write(`[model-server-supervision] ${message}\\n`);\n40: }\n41: \n42: function parsePositiveInteger(value, fallback) {\n43:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n44:   const parsed = Number.parseInt(String(value).trim(), 10);\n45:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n46: }\n47: \n48: function isPermissionError(error) {\n49:   const code = error && typeof error === 'object' ? error.code : undefined;\n50:   if (code === 'EPERM' || code === 'EACCES') return true;\n51:   const message = error instanceof Error ? error.message : String(error ?? '');\n52:   return /operation not permitted|permission denied/i.test(message);\n53: }\n54: \n55: function isDurableWriteUnavailable(error) {\n56:   const code = error && typeof error === 'object' ? error.code : undefined;\n57:   return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n58: }\n59: \n60: function logDurableWriteUnavailableOnce(logger, operation, targetPath, error, rel = (p) => p) {\n61:   const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n62:   const key = `${operation}:${targetPath}:${code}`;\n63:   if (durableWriteWarnings.has(key)) return;\n64:   durableWriteWarnings.add(key);\n65:   const detail = error instanceof Error ? error.message : String(error ?? code);\n66:   logger(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n67: }\n68: \n69: function cleanupTmpFile(tmpPath, fsApi = fs) {\n70:   try {\n71:     fsApi.unlinkSync(tmpPath);\n72:   } catch (error) {\n73:     if (error.code !== 'ENOENT') {\n74:       // Best-effort cleanup only; the original durable-write failure is more useful.\n75:     }\n76:   }\n77: }\n78: \n79: function parseProcessRows(input) {\n80:   if (Array.isArray(input)) {\n81:     return input\n82:       .map((row) => ({\n83:         pid: Number(row.pid),\n84:         ppid: Number(row.ppid),\n85:         rss: Number(row.rss),\n86:       }))\n87:       .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n88:   }\n89: \n90:   return String(input ?? '')\n91:     .split(/\\r?\\n/)\n92:     .map((line) => line.trim())\n93:     .filter(Boolean)\n94:     .map((line) => {\n95:       const [pid, ppid, rss] = line.split(/\\s+/).map((value) => Number.parseInt(value, 10));\n96:       return { pid, ppid, rss };\n97:     })\n98:     .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n99: }\n100: \n101: function defaultProcessRowsRunner() {\n102:   const result = spawnSync('ps', ['-eo', 'pid=,ppid=,rss='], {\n103:     encoding: 'utf8',\n104:     stdio: ['ignore', 'pipe', 'pipe'],\n105:   });\n106:   if (result.error) throw result.error;\n107:   if (result.status !== 0) {\n108:     const error = new Error(result.stderr || `ps exited ${result.status}`);\n109:     error.code = result.status === 1 && /operation not permitted|permission denied/i.test(result.stderr || '') ? 'EPERM' : 'PS_FAILED';\n110:     throw error;\n111:   }\n112:   return result.stdout;\n113: }\n114: \n115: function resolveProcessTreeRows(childPid, runner = defaultProcessRowsRunner) {\n116:   if (!Number.isInteger(childPid) || childPid <= 0) return null;\n117: \n118:   let rows;\n119:   try {\n120:     rows = parseProcessRows(runner());\n121:   } catch (error) {\n122:     if (isPermissionError(error)) return null;\n123:     throw error;\n124:   }\n125: \n126:   const byPid = new Map();\n127:   const childrenByPpid = new Map();\n128:   for (const row of rows) {\n129:     byPid.set(row.pid, row);\n130:     const children = childrenByPpid.get(row.ppid) || [];\n131:     children.push(row);\n132:     childrenByPpid.set(row.ppid, children);\n133:   }\n134:   if (!byPid.has(childPid)) return null;\n135: \n136:   const subtree = [];\n137:   const stack = [childPid];\n138:   const seen = new Set();\n139:   while (stack.length > 0) {\n140:     const pid = stack.pop();\n141:     if (seen.has(pid)) continue;\n142:     seen.add(pid);\n143:     const row = byPid.get(pid);\n144:     if (row) subtree.push(row);\n145:     for (const child of childrenByPpid.get(pid) || []) {\n146:       stack.push(child.pid);\n147:     }\n148:   }\n149: \n150:   return subtree;\n151: }\n152: \n153: function sampleProcessTreeRssMb(childPid, runner = defaultProcessRowsRunner) {\n154:   const rows = resolveProcessTreeRows(childPid, runner);\n155:   if (!rows) return null;\n156:   const rssKb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0);\n157:   return rssKb / 1024;\n158: }\n159: \n160: function normalizeWatchdogGraceMs(rawGraceMs, warn = defaultLog, envName = 'SPECKIT_LAUNCHER_RSS_GRACE_MS') {\n161:   const parsed = parsePositiveInteger(rawGraceMs, DEFAULT_WATCHDOG_GRACE_MS);\n162:   if (parsed > SHUTDOWN_DEADLINE_MS) return parsed;\n163:   warn(`${envName}=${JSON.stringify(rawGraceMs)} is <= ${SHUTDOWN_DEADLINE_MS}; using ${DEFAULT_WATCHDOG_GRACE_MS}ms`);\n164:   return DEFAULT_WATCHDOG_GRACE_MS;\n165: }\n166: \n167: function getWatchdogConfig(env = process.env, warn = defaultLog, options = {}) {\n168:   const envNames = {\n169:     maxRssMb: options.maxRssMbEnv || 'SPECKIT_CONTEXT_SERVER_MAX_RSS_MB',\n170:     selfExit: options.selfExitEnv || 'SPECKIT_LAUNCHER_RSS_SELF_EXIT',\n171:     intervalMs: options.intervalMsEnv || 'SPECKIT_LAUNCHER_RSS_WATCHDOG_INTERVAL_MS',\n172:     consecutiveBreaches: options.consecutiveBreachesEnv || 'SPECKIT_LAUNCHER_RSS_CONSECUTIVE_BREACHES',\n173:     graceMs: options.graceMsEnv || 'SPECKIT_LAUNCHER_RSS_GRACE_MS',\n174:   };\n175:   const rawMaxRssMb = env[envNames.maxRssMb];\n176:   const maxRssMb = rawMaxRssMb === undefined || rawMaxRssMb === null || String(rawMaxRssMb).trim() === ''\n177:     ? null\n178:     : Number.parseFloat(String(rawMaxRssMb).trim());\n179:   const enabled = Number.isFinite(maxRssMb) && maxRssMb > 0 && env[envNames.selfExit] === '1';\n180:   return {\n181:     enabled,\n182:     maxRssMb,\n183:     intervalMs: parsePositiveInteger(env[envNames.intervalMs], DEFAULT_WATCHDOG_INTERVAL_MS),\n184:     consecutiveBreaches: parsePositiveInteger(env[envNames.consecutiveBreaches], DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES),\n185:     graceMs: normalizeWatchdogGraceMs(env[envNames.graceMs], warn, envNames.graceMs),\n186:     maxRssMbEnv: envNames.maxRssMb,\n187:     selfExitEnv: envNames.selfExit,\n188:   };\n189: }\n190: \n191: function getModelServerWatchdogConfig(env = process.env, warn = defaultLog) {\n192:   return getWatchdogConfig(env, warn, {\n193:     maxRssMbEnv: 'SPECKIT_HF_MODEL_SERVER_MAX_RSS_MB',\n194:     selfExitEnv: 'SPECKIT_HF_MODEL_SERVER_RSS_SELF_EXIT',\n195:   });\n196: }\n197: \n198: function getModelServerIdleConfig(env = process.env) {\n199:   const rawIdleMin = env.SPECKIT_HF_MODEL_SERVER_IDLE_TIMEOUT_MIN;\n200:   const idleMin = rawIdleMin === undefined || rawIdleMin === null || String(rawIdleMin).trim() === ''\n201:     ? 0\n202:     : Number.parseFloat(String(rawIdleMin).trim());\n203:   const enabled = Number.isFinite(idleMin) && idleMin > 0;\n204:   return {\n205:     enabled,\n206:     timeoutMs: enabled ? idleMin * 60000 : 0,\n207:   };\n208: }\n209: \n210: function computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs) {\n211:   const exponent = Math.max(0, deathsInWindow - 1);\n212:   return Math.min(maxBackoffMs, initialBackoffMs * (2 ** exponent));\n213: }\n214: \n215: function createCrashLoopGuard(options = {}) {\n216:   const maxDeaths = parsePositiveInteger(options.maxDeaths, DEFAULT_CRASH_LOOP_MAX_DEATHS);\n217:   const windowMs = parsePositiveInteger(options.windowMs, DEFAULT_CRASH_LOOP_WINDOW_MS);\n218:   const initialBackoffMs = parsePositiveInteger(options.initialBackoffMs, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS);\n219:   const maxBackoffMs = parsePositiveInteger(options.maxBackoffMs, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS);\n220:   const nowMs = typeof options.now === 'function' ? options.now : () => Date.now();\n221:   const deaths = [];\n222: \n223:   return {\n224:     recordDeath() {\n225:       const current = nowMs();\n226:       deaths.push(current);\n227:       while (deaths.length > 0 && current - deaths[0] > windowMs) deaths.shift();\n228:       const deathsInWindow = deaths.length;\n229:       return {\n230:         deathsInWindow,\n231:         giveUp: deathsInWindow >= maxDeaths,\n232:         backoffMs: computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs),\n233:       };\n234:     },\n235:   };\n236: }\n237: \n238: function getCrashLoopConfig(env = process.env) {\n239:   return {\n240:     maxDeaths: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_DEATHS, DEFAULT_CRASH_LOOP_MAX_DEATHS),\n241:     windowMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_WINDOW_MS, DEFAULT_CRASH_LOOP_WINDOW_MS),\n242:     initialBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_INITIAL_BACKOFF_MS, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS),\n243:     maxBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_BACKOFF_MS, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS),\n244:   };\n245: }\n246: \n247: function getModelServerGiveUpCooldownMs(env = process.env) {\n248:   return parsePositiveInteger(env.SPECKIT_HF_MODEL_SERVER_GIVEUP_COOLDOWN_MS, DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS);\n249: }\n250: \n251: function superviseChildExit(event, actions) {\n252:   if (event.intentional) {\n253:     actions.clearLease();\n254:     actions.exit(event.code ?? 0);\n255:     return { action: 'intentional-exit' };\n256:   }\n257: \n258:   const decision = actions.crashLoopGuard.recordDeath();\n259:   if (decision.giveUp) {\n260:     actions.clearLease();\n261:     actions.reapProcessGroup(event.childPid);\n262:     if (event.signal) {\n263:       actions.mirrorSignal(event.signal);\n264:     } else {\n265:       actions.exit(event.code ?? 1);\n266:     }\n267:     return { action: 'give-up', deathsInWindow: decision.deathsInWindow };\n268:   }\n269: \n270:   actions.scheduleRelaunch(decision.backoffMs);\n271:   return { action: 'relaunch', deathsInWindow: decision.deathsInWindow, backoffMs: decision.backoffMs };\n272: }\n273: \n274: function processLiveness(pid) {\n275:   if (!Number.isInteger(pid) || pid <= 0) return 'dead';\n276:   try {\n277:     process.kill(pid, 0);\n278:     return 'alive';\n279:   } catch (error) {\n280:     if (error.code === 'ESRCH') return 'dead';\n281:     if (error.code === 'EPERM') return 'unknown-eperm';\n282:     return 'alive';\n283:   }\n284: }\n285: \n286: async function waitForPidExit(pid, timeoutMs) {\n287:   const deadline = Date.now() + timeoutMs;\n288:   while (Date.now() <= deadline) {\n289:     if (processLiveness(pid) === 'dead') return true;\n290:     await sleep(100);\n291:   }\n292:   return processLiveness(pid) === 'dead';\n293: }\n294: \n295: function signalProcess(pid, signal) {\n296:   try {\n297:     process.kill(pid, signal);\n298:     return true;\n299:   } catch (error) {\n300:     if (error.code === 'ESRCH' || error.code === 'EPERM') return false;\n301:     throw error;\n302:   }\n303: }\n304: \n305: function isChildRunning(child) {\n306:   return child && child.exitCode === null && child.signalCode === null;\n307: }\n308: \n309: function shouldSkipLaunch(child) {\n310:   return Boolean(child && isChildRunning(child));\n311: }\n312: \n313: // A scheduled daemon relaunch must be ABORTED when its backoff fires under a dying owner.\n314: // The MCP host spawns the launcher directly, so a parent pid that no longer matches the value\n315: // captured at startup (or has reparented to the init/subreaper pid 1) means the owning session\n316: // disposed; respawning then would only flap the daemon under a runtime that is going away and\n317: // drop every bridged transport. Crash-recovery and RSS-recycle fire with the owner alive and a\n318: // matching ppid, so this stays a no-op for them.\n319: function shouldAbortRelaunchOnFire({ shuttingDown, currentPpid, initialPpid } = {}) {\n320:   return Boolean(shuttingDown) || currentPpid !== initialPpid || currentPpid === 1;\n321: }\n322: \n323: function refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner, options = {}) {\n324:   const snapshot = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n325:   const rows = resolveProcessTreeRows(childPid, runner);\n326:   if (rows === null) return snapshot;\n327:   const pids = rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1);\n328:   if (options.snapshot && typeof options.snapshot.set === 'function') {\n329:     options.snapshot.set(pids);\n330:   }\n331:   return pids;\n332: }\n333: \n334: function reapProcessTreeGroups(childPid, options = {}) {\n335:   const runner = options.runner || defaultProcessRowsRunner;\n336:   const signal = options.signal || signalProcess;\n337:   const snapshotPids = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n338: \n339:   const liveRows = resolveProcessTreeRows(childPid, runner);\n340:   const liveDescendants = liveRows ? liveRows.map((row) => row.pid).filter((pid) => pid !== childPid) : [];\n341: \n342:   const candidates = [...new Set([...liveDescendants, ...snapshotPids])].filter(\n343:     (pid) => Number.isInteger(pid) && pid > 1 && pid !== childPid && pid !== process.pid && signal(pid, 0),\n344:   );\n345:   if (candidates.length === 0) return;\n346: \n347:   for (const pid of candidates) {\n348:     if (process.platform !== 'win32') signal(-pid, 'SIGTERM');\n349:     signal(pid, 'SIGTERM');\n350:   }\n351:   setTimeout(() => {\n352:     for (const pid of candidates) {\n353:       if (process.platform !== 'win32') signal(-pid, 'SIGKILL');\n354:       signal(pid, 'SIGKILL');\n355:     }\n356:   }, 1000).unref();\n357: }\n358: \n359: function startRssWatchdog(childPid, options = {}) {\n360:   let fallbackTimer = null;\n\n(Showing lines 1-360 of 1474. Use offset=361 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: Model Server Supervision                                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\n\nconst defaultRoot = path.resolve(__dirname, '..', '..', '..');\nconst defaultOpencodeDir = path.join(defaultRoot, '.opencode');\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nconst SHUTDOWN_DEADLINE_MS = 5000;\nconst RESPAWN_REAP_GRACE_MS = 7000;\nconst RESPAWN_LOCK_STALE_MS = 60000;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: Model Server Supervision                                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Shared hf-model-server launcher supervision for OpenCode MCPs   ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst fs = require('fs');\nconst http = require('http');\nconst path = require('path');\nconst { spawn, spawnSync } = require('child_process');\n\nconst defaultRoot = path.resolve(__dirname, '..', '..', '..');\nconst defaultOpencodeDir = path.join(defaultRoot, '.opencode');\nconst sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n\nconst SHUTDOWN_DEADLINE_MS = 5000;\nconst RESPAWN_REAP_GRACE_MS = 7000;\nconst RESPAWN_LOCK_STALE_MS = 60000;\nconst DEFAULT_WATCHDOG_GRACE_MS = 7000;\nconst DEFAULT_WATCHDOG_INTERVAL_MS = 15000;\nconst DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES = 3;\nconst DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS = 30000;\nconst DEFAULT_CRASH_LOOP_MAX_DEATHS = 3;\nconst DEFAULT_CRASH_LOOP_WINDOW_MS = 60000;\nconst DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS = 250;\nconst DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS = 5000;\nconst HF_MODEL_SERVER_SOCKET_FILE_NAME = 'hf-embed.sock';\nconst HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME = 'hf-embed-respawn.lock';\nconst HF_MODEL_SERVER_PID_FILE_NAME = 'hf-embed.pid';\nconst HF_MODEL_SERVER_GIVEUP_FILE_NAME = 'hf-embed-giveup.json';\nconst MODEL_SERVER_DEMAND_STATUS = 503;\nconst DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS = 60000;\nconst DURABLE_WRITE_UNAVAILABLE_CODES = new Set(['ENOSPC', 'EDQUOT', 'EROFS']);\nconst durableWriteWarnings = new Set();\n\nfunction defaultLog(message) {\n  process.stderr.write(`[model-server-supervision] ${message}\\n`);\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isPermissionError(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  if (code === 'EPERM' || code === 'EACCES') return true;\n  const message = error instanceof Error ? error.message : String(error ?? '');\n  return /operation not permitted|permission denied/i.test(message);\n}\n\nfunction isDurableWriteUnavailable(error) {\n  const code = error && typeof error === 'object' ? error.code : undefined;\n  return DURABLE_WRITE_UNAVAILABLE_CODES.has(code);\n}\n\nfunction logDurableWriteUnavailableOnce(logger, operation, targetPath, error, rel = (p) => p) {\n  const code = error && typeof error === 'object' ? error.code : 'UNKNOWN';\n  const key = `${operation}:${targetPath}:${code}`;\n  if (durableWriteWarnings.has(key)) return;\n  durableWriteWarnings.add(key);\n  const detail = error instanceof Error ? error.message : String(error ?? code);\n  logger(`${operation} skipped for ${rel(targetPath)}: ${code} ${detail}`);\n}\n\nfunction cleanupTmpFile(tmpPath, fsApi = fs) {\n  try {\n    fsApi.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction parseProcessRows(input) {\n  if (Array.isArray(input)) {\n    return input\n      .map((row) => ({\n        pid: Number(row.pid),\n        ppid: Number(row.ppid),\n        rss: Number(row.rss),\n      }))\n      .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n  }\n\n  return String(input ?? '')\n    .split(/\\r?\\n/)\n    .map((line) => line.trim())\n    .filter(Boolean)\n    .map((line) => {\n      const [pid, ppid, rss] = line.split(/\\s+/).map((value) => Number.parseInt(value, 10));\n      return { pid, ppid, rss };\n    })\n    .filter((row) => Number.isFinite(row.pid) && Number.isFinite(row.ppid) && Number.isFinite(row.rss));\n}\n\nfunction defaultProcessRowsRunner() {\n  const result = spawnSync('ps', ['-eo', 'pid=,ppid=,rss='], {\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n  if (result.error) throw result.error;\n  if (result.status !== 0) {\n    const error = new Error(result.stderr || `ps exited ${result.status}`);\n    error.code = result.status === 1 && /operation not permitted|permission denied/i.test(result.stderr || '') ? 'EPERM' : 'PS_FAILED';\n    throw error;\n  }\n  return result.stdout;\n}\n\nfunction resolveProcessTreeRows(childPid, runner = defaultProcessRowsRunner) {\n  if (!Number.isInteger(childPid) || childPid <= 0) return null;\n\n  let rows;\n  try {\n    rows = parseProcessRows(runner());\n  } catch (error) {\n    if (isPermissionError(error)) return null;\n    throw error;\n  }\n\n  const byPid = new Map();\n  const childrenByPpid = new Map();\n  for (const row of rows) {\n    byPid.set(row.pid, row);\n    const children = childrenByPpid.get(row.ppid) || [];\n    children.push(row);\n    childrenByPpid.set(row.ppid, children);\n  }\n  if (!byPid.has(childPid)) return null;\n\n  const subtree = [];\n  const stack = [childPid];\n  const seen = new Set();\n  while (stack.length > 0) {\n    const pid = stack.pop();\n    if (seen.has(pid)) continue;\n    seen.add(pid);\n    const row = byPid.get(pid);\n    if (row) subtree.push(row);\n    for (const child of childrenByPpid.get(pid) || []) {\n      stack.push(child.pid);\n    }\n  }\n\n  return subtree;\n}\n\nfunction sampleProcessTreeRssMb(childPid, runner = defaultProcessRowsRunner) {\n  const rows = resolveProcessTreeRows(childPid, runner);\n  if (!rows) return null;\n  const rssKb = rows.reduce((sum, row) => sum + Math.max(0, row.rss), 0);\n  return rssKb / 1024;\n}\n\nfunction normalizeWatchdogGraceMs(rawGraceMs, warn = defaultLog, envName = 'SPECKIT_LAUNCHER_RSS_GRACE_MS') {\n  const parsed = parsePositiveInteger(rawGraceMs, DEFAULT_WATCHDOG_GRACE_MS);\n  if (parsed > SHUTDOWN_DEADLINE_MS) return parsed;\n  warn(`${envName}=${JSON.stringify(rawGraceMs)} is <= ${SHUTDOWN_DEADLINE_MS}; using ${DEFAULT_WATCHDOG_GRACE_MS}ms`);\n  return DEFAULT_WATCHDOG_GRACE_MS;\n}\n\nfunction getWatchdogConfig(env = process.env, warn = defaultLog, options = {}) {\n  const envNames = {\n    maxRssMb: options.maxRssMbEnv || 'SPECKIT_CONTEXT_SERVER_MAX_RSS_MB',\n    selfExit: options.selfExitEnv || 'SPECKIT_LAUNCHER_RSS_SELF_EXIT',\n    intervalMs: options.intervalMsEnv || 'SPECKIT_LAUNCHER_RSS_WATCHDOG_INTERVAL_MS',\n    consecutiveBreaches: options.consecutiveBreachesEnv || 'SPECKIT_LAUNCHER_RSS_CONSECUTIVE_BREACHES',\n    graceMs: options.graceMsEnv || 'SPECKIT_LAUNCHER_RSS_GRACE_MS',\n  };\n  const rawMaxRssMb = env[envNames.maxRssMb];\n  const maxRssMb = rawMaxRssMb === undefined || rawMaxRssMb === null || String(rawMaxRssMb).trim() === ''\n    ? null\n    : Number.parseFloat(String(rawMaxRssMb).trim());\n  const enabled = Number.isFinite(maxRssMb) && maxRssMb > 0 && env[envNames.selfExit] === '1';\n  return {\n    enabled,\n    maxRssMb,\n    intervalMs: parsePositiveInteger(env[envNames.intervalMs], DEFAULT_WATCHDOG_INTERVAL_MS),\n    consecutiveBreaches: parsePositiveInteger(env[envNames.consecutiveBreaches], DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES),\n    graceMs: normalizeWatchdogGraceMs(env[envNames.graceMs], warn, envNames.graceMs),\n    maxRssMbEnv: envNames.maxRssMb,\n    selfExitEnv: envNames.selfExit,\n  };\n}\n\nfunction getModelServerWatchdogConfig(env = process.env, warn = defaultLog) {\n  return getWatchdogConfig(env, warn, {\n    maxRssMbEnv: 'SPECKIT_HF_MODEL_SERVER_MAX_RSS_MB',\n    selfExitEnv: 'SPECKIT_HF_MODEL_SERVER_RSS_SELF_EXIT',\n  });\n}\n\nfunction getModelServerIdleConfig(env = process.env) {\n  const rawIdleMin = env.SPECKIT_HF_MODEL_SERVER_IDLE_TIMEOUT_MIN;\n  const idleMin = rawIdleMin === undefined || rawIdleMin === null || String(rawIdleMin).trim() === ''\n    ? 0\n    : Number.parseFloat(String(rawIdleMin).trim());\n  const enabled = Number.isFinite(idleMin) && idleMin > 0;\n  return {\n    enabled,\n    timeoutMs: enabled ? idleMin * 60000 : 0,\n  };\n}\n\nfunction computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs) {\n  const exponent = Math.max(0, deathsInWindow - 1);\n  return Math.min(maxBackoffMs, initialBackoffMs * (2 ** exponent));\n}\n\nfunction createCrashLoopGuard(options = {}) {\n  const maxDeaths = parsePositiveInteger(options.maxDeaths, DEFAULT_CRASH_LOOP_MAX_DEATHS);\n  const windowMs = parsePositiveInteger(options.windowMs, DEFAULT_CRASH_LOOP_WINDOW_MS);\n  const initialBackoffMs = parsePositiveInteger(options.initialBackoffMs, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS);\n  const maxBackoffMs = parsePositiveInteger(options.maxBackoffMs, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS);\n  const nowMs = typeof options.now === 'function' ? options.now : () => Date.now();\n  const deaths = [];\n\n  return {\n    recordDeath() {\n      const current = nowMs();\n      deaths.push(current);\n      while (deaths.length > 0 && current - deaths[0] > windowMs) deaths.shift();\n      const deathsInWindow = deaths.length;\n      return {\n        deathsInWindow,\n        giveUp: deathsInWindow >= maxDeaths,\n        backoffMs: computeBackoffMs(deathsInWindow, initialBackoffMs, maxBackoffMs),\n      };\n    },\n  };\n}\n\nfunction getCrashLoopConfig(env = process.env) {\n  return {\n    maxDeaths: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_DEATHS, DEFAULT_CRASH_LOOP_MAX_DEATHS),\n    windowMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_WINDOW_MS, DEFAULT_CRASH_LOOP_WINDOW_MS),\n    initialBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_INITIAL_BACKOFF_MS, DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS),\n    maxBackoffMs: parsePositiveInteger(env.SPECKIT_LAUNCHER_CRASH_LOOP_MAX_BACKOFF_MS, DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS),\n  };\n}\n\nfunction getModelServerGiveUpCooldownMs(env = process.env) {\n  return parsePositiveInteger(env.SPECKIT_HF_MODEL_SERVER_GIVEUP_COOLDOWN_MS, DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS);\n}\n\nfunction superviseChildExit(event, actions) {\n  if (event.intentional) {\n    actions.clearLease();\n    actions.exit(event.code ?? 0);\n    return { action: 'intentional-exit' };\n  }\n\n  const decision = actions.crashLoopGuard.recordDeath();\n  if (decision.giveUp) {\n    actions.clearLease();\n    actions.reapProcessGroup(event.childPid);\n    if (event.signal) {\n      actions.mirrorSignal(event.signal);\n    } else {\n      actions.exit(event.code ?? 1);\n    }\n    return { action: 'give-up', deathsInWindow: decision.deathsInWindow };\n  }\n\n  actions.scheduleRelaunch(decision.backoffMs);\n  return { action: 'relaunch', deathsInWindow: decision.deathsInWindow, backoffMs: decision.backoffMs };\n}\n\nfunction processLiveness(pid) {\n  if (!Number.isInteger(pid) || pid <= 0) return 'dead';\n  try {\n    process.kill(pid, 0);\n    return 'alive';\n  } catch (error) {\n    if (error.code === 'ESRCH') return 'dead';\n    if (error.code === 'EPERM') return 'unknown-eperm';\n    return 'alive';\n  }\n}\n\nasync function waitForPidExit(pid, timeoutMs) {\n  const deadline = Date.now() + timeoutMs;\n  while (Date.now() <= deadline) {\n    if (processLiveness(pid) === 'dead') return true;\n    await sleep(100);\n  }\n  return processLiveness(pid) === 'dead';\n}\n\nfunction signalProcess(pid, signal) {\n  try {\n    process.kill(pid, signal);\n    return true;\n  } catch (error) {\n    if (error.code === 'ESRCH' || error.code === 'EPERM') return false;\n    throw error;\n  }\n}\n\nfunction isChildRunning(child) {\n  return child && child.exitCode === null && child.signalCode === null;\n}\n\nfunction shouldSkipLaunch(child) {\n  return Boolean(child && isChildRunning(child));\n}\n\n// A scheduled daemon relaunch must be ABORTED when its backoff fires under a dying owner.\n// The MCP host spawns the launcher directly, so a parent pid that no longer matches the value\n// captured at startup (or has reparented to the init/subreaper pid 1) means the owning session\n// disposed; respawning then would only flap the daemon under a runtime that is going away and\n// drop every bridged transport. Crash-recovery and RSS-recycle fire with the owner alive and a\n// matching ppid, so this stays a no-op for them.\nfunction shouldAbortRelaunchOnFire({ shuttingDown, currentPpid, initialPpid } = {}) {\n  return Boolean(shuttingDown) || currentPpid !== initialPpid || currentPpid === 1;\n}\n\nfunction refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner, options = {}) {\n  const snapshot = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n  const rows = resolveProcessTreeRows(childPid, runner);\n  if (rows === null) return snapshot;\n  const pids = rows.map((row) => row.pid).filter((pid) => pid !== childPid && pid > 1);\n  if (options.snapshot && typeof options.snapshot.set === 'function') {\n    options.snapshot.set(pids);\n  }\n  return pids;\n}\n\nfunction reapProcessTreeGroups(childPid, options = {}) {\n  const runner = options.runner || defaultProcessRowsRunner;\n  const signal = options.signal || signalProcess;\n  const snapshotPids = Array.isArray(options.snapshotPids) ? options.snapshotPids : [];\n\n  const liveRows = resolveProcessTreeRows(childPid, runner);\n  const liveDescendants = liveRows ? liveRows.map((row) => row.pid).filter((pid) => pid !== childPid) : [];\n\n  const candidates = [...new Set([...liveDescendants, ...snapshotPids])].filter(\n    (pid) => Number.isInteger(pid) && pid > 1 && pid !== childPid && pid !== process.pid && signal(pid, 0),\n  );\n  if (candidates.length === 0) return;\n\n  for (const pid of candidates) {\n    if (process.platform !== 'win32') signal(-pid, 'SIGTERM');\n    signal(pid, 'SIGTERM');\n  }\n  setTimeout(() => {\n    for (const pid of candidates) {\n      if (process.platform !== 'win32') signal(-pid, 'SIGKILL');\n      signal(pid, 'SIGKILL');\n    }\n  }, 1000).unref();\n}\n\nfunction startRssWatchdog(childPid, options = {}) {\n  let fallbackTimer = null;","lineStart":1,"lineEnd":360,"totalLines":1474,"truncated":true}},"title":".opencode/bin/lib/model-server-supervision.cjs","time":{"start":1781761501752,"end":1781761501755}},"metadata":{"openai":{"itemId":"fc_00ff612f68860895016a3385ddac388191880c533d622a5a27"}},"id":"prt_ed942ea0d001ciNcxe24LTg27M","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed942b79b001rlj0G50T58wap8"}}
{"type":"tool_use","timestamp":1781761501783,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_fJWJGGL5n4IiiG1QyvUA9AU6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":240,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n240:   // Code-graph MCP tools route through standalone mk-code-index\n241: ]);\n242: \n243: const MEMORY_RUNTIME_TOOL_NAMES = new Set<string>([\n244:   'memory_context',\n245:   'memory_search',\n246:   'memory_quick_search',\n247:   'memory_match_triggers',\n248:   'memory_save',\n249:   'memory_list',\n250:   'memory_stats',\n251:   'memory_delete',\n252:   'memory_update',\n253:   'memory_validate',\n254:   'memory_bulk_delete',\n255:   'memory_retention_sweep',\n256:   'memory_embedding_reconcile',\n257:   'memory_index_scan',\n258:   'memory_index_scan_status',\n259:   'memory_index_scan_cancel',\n260:   'memory_ingest_start',\n261:   'memory_ingest_status',\n262:   'memory_ingest_cancel',\n263:   'checkpoint_create',\n264:   'checkpoint_list',\n265:   'checkpoint_restore',\n266:   'checkpoint_delete',\n267:   'embedder_list',\n268:   'embedder_set',\n269:   'embedder_status',\n270:   'task_preflight',\n271:   'task_postflight',\n272:   'memory_get_learning_history',\n273:   'eval_run_ablation',\n274:   'eval_reporting_dashboard',\n275:   'memory_drift_why',\n276:   'memory_causal_link',\n277:   'memory_causal_stats',\n278:   'memory_causal_unlink',\n279: ]);\n280: \n281: interface GraphContextNeighborSummary {\n282:   filePath: string;\n283:   relationTypes: string[];\n284:   symbols: Array<{\n285:     name: string;\n286:     kind: string;\n287:     line: number;\n288:     direction: 'incoming' | 'outgoing';\n289:     relation: string;\n290:   }>;\n291: }\n292: \n293: interface GraphContextFileSummary {\n294:   filePath: string;\n295:   outline: Array<{\n296:     name: string;\n297:     kind: string;\n298:     line: number;\n299:   }>;\n300:   neighbors: GraphContextNeighborSummary[];\n301: }\n302: \n303: interface DispatchGraphContextMeta {\n304:   status: 'ok' | 'timeout' | 'unavailable';\n305:   source: 'tool-dispatch';\n306:   fileCount: number;\n307:   filePaths: string[];\n308:   latencyMs: number;\n309:   files?: GraphContextFileSummary[];\n310:   error?: string;\n311: }\n312: \n313: export interface StructuralRoutingNudge {\n314:   advisory: true;\n315:   readiness: 'ready';\n316:   preferredTool: 'mcp__mk_code_index__code_graph_query';\n317:   secondaryTool: 'mcp__mk_code_index__code_graph_context';\n318:   message: string;\n319:   preservesAuthority: 'session_bootstrap';\n320:   surface: 'response-hints' | 'session-bootstrap' | 'memory-context';\n321: }\n322: \n323: const STRUCTURAL_MISFIRE_PATTERNS = [\n324:   /\\b(?:who|what)\\s+calls?\\b/i,\n325:   /\\bcallers?\\s+of\\b/i,\n326:   /\\b(?:who|what)\\s+imports?\\b/i,\n327:   /\\bimports?\\s+of\\b/i,\n328:   /\\b(?:show|list)\\s+(?:the\\s+)?outline\\b/i,\n329:   /\\boutline\\s+of\\b/i,\n330:   /\\bdependenc(?:y|ies)\\b/i,\n331:   /\\bdependents?\\b/i,\n332:   /\\bwhat\\s+extends\\b/i,\n333: ];\n334: \n335: const NON_STRUCTURAL_SUPPRESS_PATTERNS = [\n336:   /\\bfind code\\b/i,\n337:   /\\bimplementation of\\b/i,\n338:   /\\bsimilar code\\b/i,\n339:   /\\bexplain\\b/i,\n340:   /\\bpurpose of\\b/i,\n341: ];\n342: \n343: function isMutationStatus(status: string | undefined): boolean {\n344:   return status === 'indexed' || status === 'updated' || status === 'reinforced' || status === 'deferred';\n345: }\n346: \n347: let generatedCallIdCounter = 0;\n348: const FALLBACK_SESSION_TRACKING_ID = `stdio-session-${process.pid}`;\n349: // `getDetectedRuntime` was previously exported from this module\n350: // but had zero live consumers (only its own definition + the generated\n351: // `dist/context-server.d.ts` declaration). The variable still drives the\n352: // startup banner inside main(), so it stays as a module-private. Removing\n353: // the dead export keeps the public surface honest and unblocks future\n354: // refactors that touch the runtime detection path.\n355: let detectedRuntime: RuntimeInfo | null = null;\n356: let bootFtsIntegrityHealth: BootFtsIntegrityHealth = 'unknown';\n357: \n358: type CheckpointRepairSource = 'boot' | 'startup-scan';\n359: \n360: function getUncleanShutdownMarkerPath(): string {\n361:   // Derive the marker dir from the ACTUAL opened DB path (vectorIndex.getDbPath()) — the same path the\n362:   // marker writer in vector-index-store uses — not the independently-derived DATABASE_PATH. Under a\n363:   // MEMORY_DB_PATH whose dirname differs from the resolved DB dir, DATABASE_PATH would point the boot check\n364:   // at the wrong dir and silently disable corruption detection. Falls back to\n365:   // DATABASE_PATH if the DB is not open yet (the boot check only runs post-connect, so getDbPath is set).\n366:   const dbPath = vectorIndex.getDbPath() || DATABASE_PATH;\n367:   return path.join(path.dirname(dbPath), UNCLEAN_SHUTDOWN_MARKER);\n368: }\n369: \n370: function getBootFtsIntegrityHealth(): BootFtsIntegrityHealth {\n371:   return bootFtsIntegrityHealth;\n372: }\n373: \n374: function runBootFtsIntegrityCheck(): void {\n375:   const db = vectorIndex.getDb();\n376:   try {\n377:     db.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('integrity-check')\").run();\n378:     bootFtsIntegrityHealth = 'ok';\n379:     return;\n380:   } catch (error: unknown) {\n381:     const message = error instanceof Error ? error.message : String(error);\n382:     // The FTS5 shadow is fully derivable from memory_index, so rebuilding it is\n383:     // non-destructive. An unclean shutdown can leave the shadow malformed while the\n384:     // source rows are intact; rebuild and re-verify before falling back to detect-only.\n385:     // Opt out with SPECKIT_BOOT_FTS_AUTOHEAL=0.\n386:     if (process.env.SPECKIT_BOOT_FTS_AUTOHEAL !== '0') {\n387:       try {\n388:         console.error('[context-server] FTS5 shadow integrity-check failed; attempting boot auto-rebuild...');\n389:         db.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('rebuild')\").run();\n390:         db.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('integrity-check')\").run();\n391:         bootFtsIntegrityHealth = 'repaired';\n392:         console.error('[context-server] FTS5 shadow rebuilt and re-verified OK at boot.');\n393:         return;\n394:       } catch (rebuildError: unknown) {\n395:         const rebuildMessage = rebuildError instanceof Error ? rebuildError.message : String(rebuildError);\n396:         bootFtsIntegrityHealth = 'corrupt';\n397:         console.error([\n398:           '[context-server] ===== FTS5 SHADOW INDEX CORRUPTION DETECTED =====',\n399:           '[context-server] Boot marker indicates the previous mk-spec-memory shutdown was unclean.',\n400:           `[context-server] FTS5 integrity-check failed: ${message}`,\n401:           `[context-server] Boot auto-rebuild FAILED: ${rebuildMessage}`,\n402:           '[context-server] DETECT-ONLY fallback: no further recovery attempted; manual repair required.',\n403:           `[context-server] Runbook: ${FTS_CORRUPTION_RUNBOOK}`,\n404:           '[context-server] =================================================',\n405:         ].join('\\n'));\n406:         return;\n407:       }\n408:     }\n409:     bootFtsIntegrityHealth = 'corrupt';\n410:     console.error([\n411:       '[context-server] ===== FTS5 SHADOW INDEX CORRUPTION DETECTED =====',\n412:       '[context-server] Boot marker indicates the previous mk-spec-memory shutdown was unclean.',\n413:       `[context-server] FTS5 integrity-check failed: ${message}`,\n414:       '[context-server] DETECT-ONLY: auto-heal disabled (SPECKIT_BOOT_FTS_AUTOHEAL=0); no rebuild attempted.',\n415:       `[context-server] Runbook: ${FTS_CORRUPTION_RUNBOOK}`,\n416:       '[context-server] =================================================',\n417:     ].join('\\n'));\n418:   }\n419: }\n420: \n421: function scheduleBootFtsIntegrityCheck(): void {\n422:   if (!fs.existsSync(getUncleanShutdownMarkerPath())) {\n423:     bootFtsIntegrityHealth = 'skipped';\n424:     return;\n425:   }\n426: \n427:   registerTimeout(() => runBootFtsIntegrityCheck(), 0, { unref: true });\n428: }\n429: \n430: function runCheckpointNeedsRebuildRepair(\n431:   database: Database.Database,\n432:   source: CheckpointRepairSource,\n433: ): checkpointsLib.NeedsRebuildRepairResult | null {\n434:   try {\n435:     const result = checkpointsLib.repairNeedsRebuildSentinel(database, {\n436:       source,\n437:       actor: `mcp:${source.replace(/-/g, '_')}`,\n438:     });\n439:     if (!result.sentinelPresent) {\n440:       return result;\n441:     }\n442: \n443:     const completed = result.summary?.completed.length ?? 0;\n444:     const failed = result.summary?.failed.length ?? 0;\n445:     const skipped = result.summary?.skipped.length ?? 0;\n446:     if (result.cleared) {\n447:       console.error(`[context-server] Checkpoint derived rebuild repair (${source}) completed: completed=${completed}, failed=0, skipped=0`);\n448:     } else {\n449:       console.warn(\n450:         `[context-server] Checkpoint derived rebuild repair (${source}) incomplete; sentinel retained: completed=${completed}, failed=${failed}, skipped=${skipped}${result.error ? `, error=${result.error}` : ''}`,\n451:       );\n452:     }\n453:     return result;\n454:   } catch (error: unknown) {\n455:     const message = error instanceof Error ? error.message : String(error);\n456:     console.warn(`[context-server] Checkpoint derived rebuild repair (${source}) failed (non-fatal): ${message}`);\n457:     return null;\n458:   }\n459: }\n460: \n461: export function maybeStructuralNudge(\n462:   task: string,\n463:   options: {\n464:     graphReady: boolean;\n465:     activationScaffoldReady: boolean;\n466:     surface?: StructuralRoutingNudge['surface'];\n467:   },\n468: ): StructuralRoutingNudge | null {\n469:   const normalizedTask = task.trim();\n470:   if (!normalizedTask) {\n471:     return null;\n472:   }\n473: \n474:   if (!options.graphReady || !options.activationScaffoldReady) {\n475:     return null;\n476:   }\n477: \n478:   if (NON_STRUCTURAL_SUPPRESS_PATTERNS.some((pattern) => pattern.test(normalizedTask))) {\n479:     return null;\n480:   }\n481: \n482:   if (!STRUCTURAL_MISFIRE_PATTERNS.some((pattern) => pattern.test(normalizedTask))) {\n483:     return null;\n484:   }\n485: \n486:   return {\n487:     advisory: true,\n488:     readiness: 'ready',\n489:     preferredTool: 'mcp__mk_code_index__code_graph_query',\n490:     secondaryTool: 'mcp__mk_code_index__code_graph_context',\n491:     message: 'Advisory only: this looks like a structural question. Prefer `mcp__mk_code_index__code_graph_query` before Grep or Glob for callers, imports, outline, and dependency lookups.',\n492:     preservesAuthority: 'session_bootstrap',\n493:     surface: options.surface ?? 'response-hints',\n494:   };\n495: }\n496: \n497: function injectStructuralRoutingNudge(\n498:   envelope: Record<string, unknown>,\n499:   nudge: StructuralRoutingNudge,\n500: ): void {\n501:   const hints = Array.isArray(envelope.hints)\n502:     ? envelope.hints.filter((hint): hint is string => typeof hint === 'string')\n503:     : [];\n504:   envelope.hints = hints;\n505:   if (!hints.includes(nudge.message)) {\n506:     hints.push(nudge.message);\n507:   }\n508: \n509:   const meta = typeof envelope.meta === 'object' && envelope.meta !== null && !Array.isArray(envelope.meta)\n510:     ? envelope.meta as Record<string, unknown>\n511:     : {};\n512:   meta.structuralRoutingNudge = nudge;\n513:   envelope.meta = meta;\n514: }\n515: \n516: function resolveToolCallId(request: { id?: unknown }): string {\n517:   const requestId = request.id;\n518:   if (typeof requestId === 'string' || typeof requestId === 'number') {\n519:     return String(requestId);\n520:   }\n521:   generatedCallIdCounter += 1;\n522:   return `generated-${generatedCallIdCounter}`;\n523: }\n524: \n525: function resolveSessionTrackingId(\n526:   args: Record<string, unknown>,\n527:   extra: unknown,\n528: ): string | undefined {\n529:   const transportSessionId = typeof (extra as { sessionId?: unknown } | null)?.sessionId === 'string'\n530:     ? ((extra as { sessionId?: string }).sessionId ?? null)\n531:     : null;\n532:   const explicitSessionId = typeof args.sessionId === 'string'\n533:     ? args.sessionId\n534:     : typeof args.session_id === 'string'\n535:       ? args.session_id\n536:       : null;\n537:   const codexThreadId = typeof process.env.CODEX_THREAD_ID === 'string'\n538:     && process.env.CODEX_THREAD_ID.trim().length > 0\n539:     ? process.env.CODEX_THREAD_ID.trim()\n540:     : null;\n541: \n542:   return explicitSessionId ?? transportSessionId ?? codexThreadId ?? FALLBACK_SESSION_TRACKING_ID;\n543: }\n544: \n545: // Sticky session for follow_on_tool_use correlation.\n546: // Stores the last resolved session ID so non-search tools (e.g. memory_stats)\n547: // that lack an explicit sessionId param can still correlate with a prior search.\n548: // Safe for stdio (single client). TTL in query-flow-tracker bounds staleness.\n549: let lastKnownSessionId: string | null = null;\n550: \n551: function runAfterToolCallbacks(tool: string, callId: string, result: unknown): void {\n552:   if (afterToolCallbacks.length === 0) {\n553:     return;\n554:   }\n555: \n556:   queueMicrotask(() => {\n557:     for (const callback of afterToolCallbacks) {\n558:       void callback(tool, callId, result).catch((error: unknown) => {\n559:         const message = error instanceof Error ? error.message : String(error);\n560:         console.error(`[context-server] afterTool callback failed for '${tool}' (${callId}): ${message}`);\n561:       });\n562:     }\n563:   });\n564: }\n565: \n566: function isRecord(value: unknown): value is Record<string, unknown> {\n567:   return typeof value === 'object' && value !== null && !Array.isArray(value);\n568: }\n569: \n570: function resolveCallerPid(metadata: Record<string, unknown>): number | undefined {\n571:   return typeof metadata.pid === 'number' && Number.isFinite(metadata.pid)\n572:     ? metadata.pid\n573:     : undefined;\n574: }\n575: \n576: function resolveTrustedCaller(metadata: Record<string, unknown>): boolean {\n577:   if (metadata.trusted === false || metadata.callerAuthority === 'untrusted') {\n578:     return false;\n579:   }\n580:   // Local stdio MCP runs inside the same user-owned process boundary. Treat it\n581:   // as trusted unless the transport metadata explicitly opts out.\n582:   return metadata.trusted === true || metadata.callerAuthority === 'trusted' || metadata.transport === undefined;\n583: }\n584: \n585: function buildCallerContext(extra: unknown): MCPCallerContext {\n586:   const metadata = isRecord(extra) ? { ...extra } : {};\n587:   return {\n588:     // Under stdio, the MCP SDK never gives us a real transport session ID and\n589:     // leaves the field empty (@modelcontextprotocol/sdk/dist/esm/shared/protocol.js:280-316).\n590:     // That makes stdio session binding advisory-only, not vulnerable: the server\n591:     // and caller share a single-UID subprocess boundary. HTTP/WS transports still\n592:     // carry validated server-generated session IDs that the auth guard enforces.\n593:     sessionId: typeof metadata.sessionId === 'string' ? metadata.sessionId : null,\n594:     transport: 'stdio',\n595:     connectedAt: transportConnectedAt ?? new Date().toISOString(),\n596:     callerPid: resolveCallerPid(metadata),\n597:     trusted: resolveTrustedCaller(metadata),\n598:     metadata,\n599:   };\n\n(Showing lines 240-599 of 2341. Use offset=600 to continue.)\n</content>","metadata":{"preview":"  // Code-graph MCP tools route through standalone mk-code-index\n]);\n\nconst MEMORY_RUNTIME_TOOL_NAMES = new Set<string>([\n  'memory_context',\n  'memory_search',\n  'memory_quick_search',\n  'memory_match_triggers',\n  'memory_save',\n  'memory_list',\n  'memory_stats',\n  'memory_delete',\n  'memory_update',\n  'memory_validate',\n  'memory_bulk_delete',\n  'memory_retention_sweep',\n  'memory_embedding_reconcile',\n  'memory_index_scan',\n  'memory_index_scan_status',\n  'memory_index_scan_cancel',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"  // Code-graph MCP tools route through standalone mk-code-index\n]);\n\nconst MEMORY_RUNTIME_TOOL_NAMES = new Set<string>([\n  'memory_context',\n  'memory_search',\n  'memory_quick_search',\n  'memory_match_triggers',\n  'memory_save',\n  'memory_list',\n  'memory_stats',\n  'memory_delete',\n  'memory_update',\n  'memory_validate',\n  'memory_bulk_delete',\n  'memory_retention_sweep',\n  'memory_embedding_reconcile',\n  'memory_index_scan',\n  'memory_index_scan_status',\n  'memory_index_scan_cancel',\n  'memory_ingest_start',\n  'memory_ingest_status',\n  'memory_ingest_cancel',\n  'checkpoint_create',\n  'checkpoint_list',\n  'checkpoint_restore',\n  'checkpoint_delete',\n  'embedder_list',\n  'embedder_set',\n  'embedder_status',\n  'task_preflight',\n  'task_postflight',\n  'memory_get_learning_history',\n  'eval_run_ablation',\n  'eval_reporting_dashboard',\n  'memory_drift_why',\n  'memory_causal_link',\n  'memory_causal_stats',\n  'memory_causal_unlink',\n]);\n\ninterface GraphContextNeighborSummary {\n  filePath: string;\n  relationTypes: string[];\n  symbols: Array<{\n    name: string;\n    kind: string;\n    line: number;\n    direction: 'incoming' | 'outgoing';\n    relation: string;\n  }>;\n}\n\ninterface GraphContextFileSummary {\n  filePath: string;\n  outline: Array<{\n    name: string;\n    kind: string;\n    line: number;\n  }>;\n  neighbors: GraphContextNeighborSummary[];\n}\n\ninterface DispatchGraphContextMeta {\n  status: 'ok' | 'timeout' | 'unavailable';\n  source: 'tool-dispatch';\n  fileCount: number;\n  filePaths: string[];\n  latencyMs: number;\n  files?: GraphContextFileSummary[];\n  error?: string;\n}\n\nexport interface StructuralRoutingNudge {\n  advisory: true;\n  readiness: 'ready';\n  preferredTool: 'mcp__mk_code_index__code_graph_query';\n  secondaryTool: 'mcp__mk_code_index__code_graph_context';\n  message: string;\n  preservesAuthority: 'session_bootstrap';\n  surface: 'response-hints' | 'session-bootstrap' | 'memory-context';\n}\n\nconst STRUCTURAL_MISFIRE_PATTERNS = [\n  /\\b(?:who|what)\\s+calls?\\b/i,\n  /\\bcallers?\\s+of\\b/i,\n  /\\b(?:who|what)\\s+imports?\\b/i,\n  /\\bimports?\\s+of\\b/i,\n  /\\b(?:show|list)\\s+(?:the\\s+)?outline\\b/i,\n  /\\boutline\\s+of\\b/i,\n  /\\bdependenc(?:y|ies)\\b/i,\n  /\\bdependents?\\b/i,\n  /\\bwhat\\s+extends\\b/i,\n];\n\nconst NON_STRUCTURAL_SUPPRESS_PATTERNS = [\n  /\\bfind code\\b/i,\n  /\\bimplementation of\\b/i,\n  /\\bsimilar code\\b/i,\n  /\\bexplain\\b/i,\n  /\\bpurpose of\\b/i,\n];\n\nfunction isMutationStatus(status: string | undefined): boolean {\n  return status === 'indexed' || status === 'updated' || status === 'reinforced' || status === 'deferred';\n}\n\nlet generatedCallIdCounter = 0;\nconst FALLBACK_SESSION_TRACKING_ID = `stdio-session-${process.pid}`;\n// `getDetectedRuntime` was previously exported from this module\n// but had zero live consumers (only its own definition + the generated\n// `dist/context-server.d.ts` declaration). The variable still drives the\n// startup banner inside main(), so it stays as a module-private. Removing\n// the dead export keeps the public surface honest and unblocks future\n// refactors that touch the runtime detection path.\nlet detectedRuntime: RuntimeInfo | null = null;\nlet bootFtsIntegrityHealth: BootFtsIntegrityHealth = 'unknown';\n\ntype CheckpointRepairSource = 'boot' | 'startup-scan';\n\nfunction getUncleanShutdownMarkerPath(): string {\n  // Derive the marker dir from the ACTUAL opened DB path (vectorIndex.getDbPath()) — the same path the\n  // marker writer in vector-index-store uses — not the independently-derived DATABASE_PATH. Under a\n  // MEMORY_DB_PATH whose dirname differs from the resolved DB dir, DATABASE_PATH would point the boot check\n  // at the wrong dir and silently disable corruption detection. Falls back to\n  // DATABASE_PATH if the DB is not open yet (the boot check only runs post-connect, so getDbPath is set).\n  const dbPath = vectorIndex.getDbPath() || DATABASE_PATH;\n  return path.join(path.dirname(dbPath), UNCLEAN_SHUTDOWN_MARKER);\n}\n\nfunction getBootFtsIntegrityHealth(): BootFtsIntegrityHealth {\n  return bootFtsIntegrityHealth;\n}\n\nfunction runBootFtsIntegrityCheck(): void {\n  const db = vectorIndex.getDb();\n  try {\n    db.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('integrity-check')\").run();\n    bootFtsIntegrityHealth = 'ok';\n    return;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    // The FTS5 shadow is fully derivable from memory_index, so rebuilding it is\n    // non-destructive. An unclean shutdown can leave the shadow malformed while the\n    // source rows are intact; rebuild and re-verify before falling back to detect-only.\n    // Opt out with SPECKIT_BOOT_FTS_AUTOHEAL=0.\n    if (process.env.SPECKIT_BOOT_FTS_AUTOHEAL !== '0') {\n      try {\n        console.error('[context-server] FTS5 shadow integrity-check failed; attempting boot auto-rebuild...');\n        db.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('rebuild')\").run();\n        db.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('integrity-check')\").run();\n        bootFtsIntegrityHealth = 'repaired';\n        console.error('[context-server] FTS5 shadow rebuilt and re-verified OK at boot.');\n        return;\n      } catch (rebuildError: unknown) {\n        const rebuildMessage = rebuildError instanceof Error ? rebuildError.message : String(rebuildError);\n        bootFtsIntegrityHealth = 'corrupt';\n        console.error([\n          '[context-server] ===== FTS5 SHADOW INDEX CORRUPTION DETECTED =====',\n          '[context-server] Boot marker indicates the previous mk-spec-memory shutdown was unclean.',\n          `[context-server] FTS5 integrity-check failed: ${message}`,\n          `[context-server] Boot auto-rebuild FAILED: ${rebuildMessage}`,\n          '[context-server] DETECT-ONLY fallback: no further recovery attempted; manual repair required.',\n          `[context-server] Runbook: ${FTS_CORRUPTION_RUNBOOK}`,\n          '[context-server] =================================================',\n        ].join('\\n'));\n        return;\n      }\n    }\n    bootFtsIntegrityHealth = 'corrupt';\n    console.error([\n      '[context-server] ===== FTS5 SHADOW INDEX CORRUPTION DETECTED =====',\n      '[context-server] Boot marker indicates the previous mk-spec-memory shutdown was unclean.',\n      `[context-server] FTS5 integrity-check failed: ${message}`,\n      '[context-server] DETECT-ONLY: auto-heal disabled (SPECKIT_BOOT_FTS_AUTOHEAL=0); no rebuild attempted.',\n      `[context-server] Runbook: ${FTS_CORRUPTION_RUNBOOK}`,\n      '[context-server] =================================================',\n    ].join('\\n'));\n  }\n}\n\nfunction scheduleBootFtsIntegrityCheck(): void {\n  if (!fs.existsSync(getUncleanShutdownMarkerPath())) {\n    bootFtsIntegrityHealth = 'skipped';\n    return;\n  }\n\n  registerTimeout(() => runBootFtsIntegrityCheck(), 0, { unref: true });\n}\n\nfunction runCheckpointNeedsRebuildRepair(\n  database: Database.Database,\n  source: CheckpointRepairSource,\n): checkpointsLib.NeedsRebuildRepairResult | null {\n  try {\n    const result = checkpointsLib.repairNeedsRebuildSentinel(database, {\n      source,\n      actor: `mcp:${source.replace(/-/g, '_')}`,\n    });\n    if (!result.sentinelPresent) {\n      return result;\n    }\n\n    const completed = result.summary?.completed.length ?? 0;\n    const failed = result.summary?.failed.length ?? 0;\n    const skipped = result.summary?.skipped.length ?? 0;\n    if (result.cleared) {\n      console.error(`[context-server] Checkpoint derived rebuild repair (${source}) completed: completed=${completed}, failed=0, skipped=0`);\n    } else {\n      console.warn(\n        `[context-server] Checkpoint derived rebuild repair (${source}) incomplete; sentinel retained: completed=${completed}, failed=${failed}, skipped=${skipped}${result.error ? `, error=${result.error}` : ''}`,\n      );\n    }\n    return result;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[context-server] Checkpoint derived rebuild repair (${source}) failed (non-fatal): ${message}`);\n    return null;\n  }\n}\n\nexport function maybeStructuralNudge(\n  task: string,\n  options: {\n    graphReady: boolean;\n    activationScaffoldReady: boolean;\n    surface?: StructuralRoutingNudge['surface'];\n  },\n): StructuralRoutingNudge | null {\n  const normalizedTask = task.trim();\n  if (!normalizedTask) {\n    return null;\n  }\n\n  if (!options.graphReady || !options.activationScaffoldReady) {\n    return null;\n  }\n\n  if (NON_STRUCTURAL_SUPPRESS_PATTERNS.some((pattern) => pattern.test(normalizedTask))) {\n    return null;\n  }\n\n  if (!STRUCTURAL_MISFIRE_PATTERNS.some((pattern) => pattern.test(normalizedTask))) {\n    return null;\n  }\n\n  return {\n    advisory: true,\n    readiness: 'ready',\n    preferredTool: 'mcp__mk_code_index__code_graph_query',\n    secondaryTool: 'mcp__mk_code_index__code_graph_context',\n    message: 'Advisory only: this looks like a structural question. Prefer `mcp__mk_code_index__code_graph_query` before Grep or Glob for callers, imports, outline, and dependency lookups.',\n    preservesAuthority: 'session_bootstrap',\n    surface: options.surface ?? 'response-hints',\n  };\n}\n\nfunction injectStructuralRoutingNudge(\n  envelope: Record<string, unknown>,\n  nudge: StructuralRoutingNudge,\n): void {\n  const hints = Array.isArray(envelope.hints)\n    ? envelope.hints.filter((hint): hint is string => typeof hint === 'string')\n    : [];\n  envelope.hints = hints;\n  if (!hints.includes(nudge.message)) {\n    hints.push(nudge.message);\n  }\n\n  const meta = typeof envelope.meta === 'object' && envelope.meta !== null && !Array.isArray(envelope.meta)\n    ? envelope.meta as Record<string, unknown>\n    : {};\n  meta.structuralRoutingNudge = nudge;\n  envelope.meta = meta;\n}\n\nfunction resolveToolCallId(request: { id?: unknown }): string {\n  const requestId = request.id;\n  if (typeof requestId === 'string' || typeof requestId === 'number') {\n    return String(requestId);\n  }\n  generatedCallIdCounter += 1;\n  return `generated-${generatedCallIdCounter}`;\n}\n\nfunction resolveSessionTrackingId(\n  args: Record<string, unknown>,\n  extra: unknown,\n): string | undefined {\n  const transportSessionId = typeof (extra as { sessionId?: unknown } | null)?.sessionId === 'string'\n    ? ((extra as { sessionId?: string }).sessionId ?? null)\n    : null;\n  const explicitSessionId = typeof args.sessionId === 'string'\n    ? args.sessionId\n    : typeof args.session_id === 'string'\n      ? args.session_id\n      : null;\n  const codexThreadId = typeof process.env.CODEX_THREAD_ID === 'string'\n    && process.env.CODEX_THREAD_ID.trim().length > 0\n    ? process.env.CODEX_THREAD_ID.trim()\n    : null;\n\n  return explicitSessionId ?? transportSessionId ?? codexThreadId ?? FALLBACK_SESSION_TRACKING_ID;\n}\n\n// Sticky session for follow_on_tool_use correlation.\n// Stores the last resolved session ID so non-search tools (e.g. memory_stats)\n// that lack an explicit sessionId param can still correlate with a prior search.\n// Safe for stdio (single client). TTL in query-flow-tracker bounds staleness.\nlet lastKnownSessionId: string | null = null;\n\nfunction runAfterToolCallbacks(tool: string, callId: string, result: unknown): void {\n  if (afterToolCallbacks.length === 0) {\n    return;\n  }\n\n  queueMicrotask(() => {\n    for (const callback of afterToolCallbacks) {\n      void callback(tool, callId, result).catch((error: unknown) => {\n        const message = error instanceof Error ? error.message : String(error);\n        console.error(`[context-server] afterTool callback failed for '${tool}' (${callId}): ${message}`);\n      });\n    }\n  });\n}\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === 'object' && value !== null && !Array.isArray(value);\n}\n\nfunction resolveCallerPid(metadata: Record<string, unknown>): number | undefined {\n  return typeof metadata.pid === 'number' && Number.isFinite(metadata.pid)\n    ? metadata.pid\n    : undefined;\n}\n\nfunction resolveTrustedCaller(metadata: Record<string, unknown>): boolean {\n  if (metadata.trusted === false || metadata.callerAuthority === 'untrusted') {\n    return false;\n  }\n  // Local stdio MCP runs inside the same user-owned process boundary. Treat it\n  // as trusted unless the transport metadata explicitly opts out.\n  return metadata.trusted === true || metadata.callerAuthority === 'trusted' || metadata.transport === undefined;\n}\n\nfunction buildCallerContext(extra: unknown): MCPCallerContext {\n  const metadata = isRecord(extra) ? { ...extra } : {};\n  return {\n    // Under stdio, the MCP SDK never gives us a real transport session ID and\n    // leaves the field empty (@modelcontextprotocol/sdk/dist/esm/shared/protocol.js:280-316).\n    // That makes stdio session binding advisory-only, not vulnerable: the server\n    // and caller share a single-UID subprocess boundary. HTTP/WS transports still\n    // carry validated server-generated session IDs that the auth guard enforces.\n    sessionId: typeof metadata.sessionId === 'string' ? metadata.sessionId : null,\n    transport: 'stdio',\n    connectedAt: transportConnectedAt ?? new Date().toISOString(),\n    callerPid: resolveCallerPid(metadata),\n    trusted: resolveTrustedCaller(metadata),\n    metadata,\n  };","lineStart":240,"lineEnd":599,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781761501777,"end":1781761501781}},"metadata":{"openai":{"itemId":"fc_00ff612f68860895016a3385ddac4481919a87d0dd91d26005"}},"id":"prt_ed942ea49001L0VX1MfPXcxMwE","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed942b79b001rlj0G50T58wap8"}}
{"type":"tool_use","timestamp":1781761501804,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_2UmFUVW2bkDKwlvBFROXZJXo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":1000,"limit":460},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n1000:   afterToolCallbacks.push(fn);\n1001: }\n1002: \n1003: async function invalidateReinitializedDbCaches(): Promise<void> {\n1004:   const invalidatedEntries = toolCache.clear();\n1005: \n1006:   try {\n1007:     const triggerMatcher = await import('./lib/parsing/trigger-matcher.js');\n1008:     if (typeof triggerMatcher.clearCache === 'function') {\n1009:       triggerMatcher.clearCache();\n1010:     }\n1011:   } catch (error: unknown) {\n1012:     const message = error instanceof Error ? error.message : String(error);\n1013:     console.error(`[context-server] Failed to clear trigger cache after DB reinit: ${message}`);\n1014:   }\n1015: \n1016:   if (invalidatedEntries > 0) {\n1017:     console.error(`[context-server] Cleared ${invalidatedEntries} tool-cache entries after DB reinitialization`);\n1018:   }\n1019: }\n1020: \n1021: /* ───────────────────────────────────────────────────────────────\n1022:    3. SERVER INITIALIZATION\n1023: ──────────────────────────────────────────────────────────────── */\n1024: \n1025: function createContextMcpServer(): Server {\n1026:   return new Server(\n1027:     { name: 'mk-spec-memory', version: '1.8.0' },\n1028:     { capabilities: { tools: {} } },\n1029:   );\n1030: }\n1031: \n1032: const server = createContextMcpServer();\n1033: const serverWithInstructions = server as unknown as { setInstructions?: (instructions: string) => void };\n1034: const KNOWN_TOOL_NAMES = new Set(TOOL_DEFINITIONS.map((tool) => tool.name));\n1035: \n1036: /* ───────────────────────────────────────────────────────────────\n1037:    TOOL DEFINITIONS\n1038: ──────────────────────────────────────────────────────────────── */\n1039: \n1040: function registerContextServerHandlers(targetServer: Server): void {\n1041:   targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n1042:     tools: TOOL_DEFINITIONS\n1043:   }));\n1044: \n1045: /* ───────────────────────────────────────────────────────────────\n1046:    TOOL DISPATCH\n1047: ──────────────────────────────────────────────────────────────── */\n1048: \n1049: // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1050:   targetServer.setRequestHandler(CallToolRequestSchema, async (request, _extra: unknown): Promise<any> => {\n1051:   const requestParams = request.params as { name: string; arguments?: Record<string, unknown> };\n1052:   const { name } = requestParams;\n1053:   const args: Record<string, unknown> = requestParams.arguments ?? {};\n1054:   const callId = resolveToolCallId(request as { id?: unknown });\n1055:   const sessionTrackingId = resolveSessionTrackingId(args, _extra);\n1056:   const callerContext = buildCallerContext(_extra);\n1057:   if (sessionTrackingId) lastKnownSessionId = sessionTrackingId;\n1058: \n1059:   try {\n1060:     // SEC-003: Validate input lengths before processing (CWE-400 mitigation)\n1061:     validateInputLengths(args);\n1062:     // Validate at the server boundary before metrics, session priming, and\n1063:     // auto-surface logic can observe malformed raw tool arguments.\n1064:     const validatedArgs: Record<string, unknown> = KNOWN_TOOL_NAMES.has(name)\n1065:       ? validateToolArgs(name, args) as Record<string, unknown>\n1066:       : args;\n1067: \n1068:     // Track last tool call timestamp for all tools except session_health.\n1069:     if (name !== 'session_health') {\n1070:       recordToolCall(sessionTrackingId);\n1071: \n1072:       // Record metric event for context quality tracking\n1073:       recordMetricEvent({ kind: 'tool_call', toolName: name });\n1074:     }\n1075:     // Classify specific tool calls for finer-grained metrics\n1076:     if (name === 'memory_context' && validatedArgs.mode === 'resume') {\n1077:       recordMetricEvent({ kind: 'memory_recovery' });\n1078:     }\n1079:     // Code-graph MCP metrics now originate from standalone mk-code-index\n1080:     if (typeof validatedArgs.specFolder === 'string' && validatedArgs.specFolder) {\n1081:       recordMetricEvent({ kind: 'spec_folder_change', specFolder: validatedArgs.specFolder as string });\n1082:     }\n1083: \n1084:     const memoryRuntimeRequired = MEMORY_RUNTIME_TOOL_NAMES.has(name);\n1085:     if (memoryRuntimeRequired) {\n1086:       await ensureMemoryRuntimeInitialized(`handler:${name}`);\n1087:     }\n1088: \n1089:     const dbReinitialized = memoryRuntimeRequired\n1090:       ? await checkDatabaseUpdated()\n1091:       : false;\n1092:     if (dbReinitialized) {\n1093:       await invalidateReinitializedDbCaches();\n1094:     }\n1095: \n1096:     let sessionPrimeContext: AutoSurfaceResult | null = null;\n1097:     const memoryRuntimeAvailable = memoryRuntimeRequired || isMemoryRuntimeInitialized();\n1098:     if (memoryRuntimeAvailable) {\n1099:       try {\n1100:         sessionPrimeContext = await primeSessionIfNeeded(\n1101:           name,\n1102:           validatedArgs,\n1103:           sessionTrackingId,\n1104:         );\n1105:       } catch (primeErr: unknown) {\n1106:         const msg = primeErr instanceof Error ? primeErr.message : String(primeErr);\n1107:         console.error(`[context-server] Session priming failed (non-fatal): ${msg}`);\n1108:       }\n1109:     }\n1110: \n1111:     // Auto-surface memories before dispatch (after validation)\n1112:     let autoSurfacedContext: AutoSurfaceResult | null = null;\n1113:     const isCompactionLifecycleCall =\n1114:       name === 'memory_context' && validatedArgs.mode === 'resume';\n1115: \n1116:     const autoSurfaceStart = Date.now();\n1117:     if (MEMORY_AWARE_TOOLS.has(name) && memoryRuntimeAvailable) {\n1118:       const contextHint: string | null = extractContextHint(validatedArgs);\n1119:       if (contextHint) {\n1120:         try {\n1121:           if (isCompactionLifecycleCall) {\n1122:             autoSurfacedContext = await autoSurfaceAtCompaction(contextHint);\n1123:           } else {\n1124:             autoSurfacedContext = await autoSurfaceMemories(contextHint);\n1125:           }\n1126:         } catch (surfaceErr: unknown) {\n1127:           const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n1128:           console.error(`[context-server] Auto-surface failed (non-fatal): ${msg}`);\n1129:         }\n1130:       }\n1131:     } else if (memoryRuntimeAvailable) {\n1132:       try {\n1133:         autoSurfacedContext = await autoSurfaceAtToolDispatch(name, validatedArgs);\n1134:       } catch (surfaceErr: unknown) {\n1135:         const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n1136:         console.error(`[context-server] Tool-dispatch auto-surface failed (non-fatal): ${msg}`);\n1137:       }\n1138:     }\n1139:     const autoSurfaceLatencyMs = Date.now() - autoSurfaceStart;\n1140:     if (autoSurfaceLatencyMs > 250) {\n1141:       console.warn(`[context-server] Auto-surface precheck exceeded p95 target: ${autoSurfaceLatencyMs}ms`);\n1142:     }\n1143: \n1144:     // Dispatch to tool modules\n1145:     const result = await runWithCallerContext(\n1146:       callerContext,\n1147:       async () => dispatchTool(name, validatedArgs, callerContext),\n1148:     ) as ToolCallResponse | null;\n1149:     if (!result) {\n1150:       throw new Error(`Unknown tool: ${name}`);\n1151:     }\n1152: \n1153:     let dispatchGraphContext: DispatchGraphContextMeta | null = null;\n1154:     if (!result.isError) {\n1155:       dispatchGraphContext = await resolveDispatchGraphContext(name, validatedArgs);\n1156:     }\n1157: \n1158:     runAfterToolCallbacks(name, callId, structuredClone(result));\n1159: \n1160:     // Log follow_on_tool_use when a non-search tool is called after a recent search\n1161:     // Shadow-only: no ranking side effects. Fail-safe, never throws.\n1162:     if (isMemoryRuntimeInitialized() && name !== 'memory_search' && name !== 'memory_context' && name !== 'session_health') {\n1163:       try {\n1164:         const { logFollowOnToolUse } = await import('./lib/feedback/query-flow-tracker.js');\n1165:         const { requireDb } = await import('./utils/index.js');\n1166:         const db = (() => { try { return requireDb(); } catch { return null; } })();\n1167:         const followOnSessionId = sessionTrackingId ?? lastKnownSessionId;\n1168:         if (db && followOnSessionId) {\n1169:           logFollowOnToolUse(db, followOnSessionId);\n1170:         }\n1171:       } catch { /* follow_on_tool_use logging must never break dispatch */ }\n1172:     }\n1173: \n1174:     // Code-search redirect hint for memory tools\n1175:     if ((name === 'memory_search' || name === 'memory_context') && result && !result.isError && result.content?.[0]?.text) {\n1176:       const queryStr = typeof args.query === 'string' ? args.query : typeof args.input === 'string' ? args.input : '';\n1177:       const codeSearchPattern = /\\b(find code|implementation of|function that|where is|how does .+ work|class that|method for)\\b/i;\n1178:       if (queryStr && codeSearchPattern.test(queryStr)) {\n1179:         try {\n1180:           const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n1181:           if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n1182:             const existingHints = Array.isArray(envelope.hints) ? envelope.hints as string[] : [];\n1183:             existingHints.push('Tip: For code search queries, use mcp__mk_code_index__code_graph_query for structural lookups and Grep for exact text or token searches.');\n1184:             envelope.hints = existingHints;\n1185:             result.content[0].text = JSON.stringify(envelope, null, 2);\n1186:           }\n1187:         } catch {\n1188:           // Response is not JSON envelope — skip hint injection\n1189:         }\n1190:       }\n1191: \n1192:       if (queryStr) {\n1193:         try {\n1194:           const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n1195:           if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n1196:             const meta = typeof envelope.meta === 'object' && envelope.meta !== null && !Array.isArray(envelope.meta)\n1197:               ? envelope.meta as Record<string, unknown>\n1198:               : {};\n1199:             const snapshot = getSessionSnapshot();\n1200:             const nudge = meta.structuralRoutingNudge\n1201:               ? null\n1202:               : maybeStructuralNudge(queryStr, {\n1203:                 graphReady: snapshot.graphFreshness === 'fresh',\n1204:                 activationScaffoldReady: snapshot.primed,\n1205:                 surface: 'response-hints',\n1206:               });\n1207:             if (nudge) {\n1208:               injectStructuralRoutingNudge(envelope, nudge);\n1209:               result.content[0].text = JSON.stringify(envelope, null, 2);\n1210:             }\n1211:           }\n1212:         } catch {\n1213:           // Response is not JSON envelope — skip structural nudge injection\n1214:         }\n1215:       }\n1216:     }\n1217: \n1218:     // Passive context enrichment pipeline — adds code graph symbols\n1219:     // near mentioned file paths and session continuity warnings.\n1220:     if (result && !result.isError && result.content?.[0]?.text) {\n1221:       try {\n1222:         const { runPassiveEnrichment } = await import('./lib/enrichment/passive-enrichment.js');\n1223:         const enrichment = await runPassiveEnrichment(result.content[0].text);\n1224:         if (!enrichment.skipped && enrichment.hints.length > 0) {\n1225:           try {\n1226:             const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n1227:             if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n1228:               const existingHints = Array.isArray(envelope.hints) ? envelope.hints as string[] : [];\n1229:               envelope.hints = [...existingHints, ...enrichment.hints];\n1230:               result.content[0].text = JSON.stringify(envelope, null, 2);\n1231:             }\n1232:           } catch {\n1233:             // Response is not JSON envelope — skip enrichment injection\n1234:           }\n1235:         }\n1236:       } catch (enrichErr: unknown) {\n1237:         // Passive enrichment is strictly non-fatal\n1238:         const msg = enrichErr instanceof Error ? enrichErr.message : String(enrichErr);\n1239:         console.warn(`[context-server] Passive enrichment failed (non-fatal): ${msg}`);\n1240:       }\n1241:     }\n1242: \n1243:     // Inject auto-surface hints before token-budget enforcement so\n1244:     // The final envelope metadata reflects the fully decorated response.\n1245:     if (autoSurfacedContext && result && !result.isError) {\n1246:       appendAutoSurfaceHints(result, autoSurfacedContext);\n1247:     }\n1248: \n1249:     // Token Budget Hybrid: Inject tokenBudget into response metadata\n1250:     // Enforce per-layer token budgets with actual truncation\n1251:     if (result && result.content && result.content[0]?.text) {\n1252:       try {\n1253:         const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n1254:         if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n1255:           const metaValue = envelope.meta;\n1256:           const meta = isRecord(metaValue)\n1257:             ? metaValue as Record<string, unknown>\n1258:             : {};\n1259:           const dataValue = envelope.data;\n1260:           const data = isRecord(dataValue)\n1261:             ? dataValue as Record<string, unknown>\n1262:             : null;\n1263:           envelope.meta = meta;\n1264:           if (sessionPrimeContext && !result.isError) {\n1265:             injectSessionPrimeHints(envelope, meta, sessionPrimeContext);\n1266:           }\n1267:           if (autoSurfacedContext && !result.isError) {\n1268:             meta.autoSurfacedContext = autoSurfacedContext;\n1269:           }\n1270:           if (dispatchGraphContext && !result.isError) {\n1271:             meta.graphContext = dispatchGraphContext;\n1272:           }\n1273:           const budget = getTokenBudget(name);\n1274:           meta.tokenBudget = budget;\n1275:           syncEnvelopeTokenCount(envelope);\n1276: \n1277:           if (typeof meta.tokenCount === 'number' && meta.tokenCount > budget) {\n1278:             console.error(`[token-budget] ${name} response (${meta.tokenCount} tokens) exceeds budget (${budget})`);\n1279: \n1280:             // First-call session priming rides along in meta and can dwarf a\n1281:             // small tool's own payload. Slim it BEFORE touching the tool's\n1282:             // results: the tool's answer is the caller's data, the priming\n1283:             // payload is recoverable via memory_search/memory_context.\n1284:             if (isRecord(meta.sessionPriming)) {\n1285:               const priming = meta.sessionPriming as Record<string, unknown>;\n1286:               const alreadyTrimmed = priming.trimmed === true;\n1287:               if (!alreadyTrimmed) {\n1288:                 const constitutionalCount = Array.isArray(priming.constitutional)\n1289:                   ? priming.constitutional.length\n1290:                   : 0;\n1291:                 meta.sessionPriming = {\n1292:                   trimmed: true,\n1293:                   constitutionalCount,\n1294:                   ...(isRecord(priming.primePackage) ? { primePackage: priming.primePackage } : {}),\n1295:                 };\n1296:                 syncEnvelopeTokenCount(envelope);\n1297:                 if (Array.isArray(envelope.hints)) {\n1298:                   envelope.hints.push(`Session priming trimmed to fit the ${budget} token budget; full constitutional content remains retrievable via memory_search`);\n1299:                 }\n1300:                 meta.sessionPrimingTrimmed = true;\n1301:               }\n1302:             }\n1303: \n1304:             // Attempt to truncate results array to fit within budget — only\n1305:             // when still over after the priming slim above, because the loop\n1306:             // below pops a result before it re-measures.\n1307:             const stillOverBudget = typeof meta.tokenCount === 'number' && meta.tokenCount > budget;\n1308:             const innerResults = data?.results;\n1309:             if (stillOverBudget && Array.isArray(innerResults) && innerResults.length > 1) {\n1310:               const originalCount = innerResults.length;\n1311:               // Results are typically sorted by score (highest first)\n1312:               // Remove from end (lowest-scored) until within budget\n1313:               while (innerResults.length > 1) {\n1314:                 innerResults.pop();\n1315:                 // Recalculate token count from the full envelope\n1316:                 // (not just results) so trace metadata is included in the budget.\n1317:                 syncEnvelopeTokenCount(envelope);\n1318:                 if (typeof meta.tokenCount === 'number' && meta.tokenCount <= budget) break;\n1319:               }\n1320:               if (data && data.count !== undefined) {\n1321:                 data.count = innerResults.length;\n1322:               }\n1323:               // Recompute constitutionalCount from the results that survived truncation\n1324:               // so consumers reading data.constitutionalCount or envelope.summary see\n1325:               // counts that agree with data.results.length.\n1326:               if (data) {\n1327:                 const survivingConstitutionalCount = innerResults.filter(\n1328:                   (r: unknown) => r !== null && typeof r === 'object' && (r as Record<string, unknown>).isConstitutional === true\n1329:                 ).length;\n1330:                 data.constitutionalCount = survivingConstitutionalCount;\n1331:                 if (typeof envelope.summary === 'string') {\n1332:                   envelope.summary = survivingConstitutionalCount > 0\n1333:                     ? `Found ${innerResults.length} memories (${survivingConstitutionalCount} constitutional)`\n1334:                     : `Found ${innerResults.length} memories`;\n1335:                 }\n1336:               }\n1337:               if (Array.isArray(envelope.hints)) {\n1338:                 envelope.hints.push(`Token budget enforced: truncated ${originalCount} → ${innerResults.length} results to fit ${budget} token budget`);\n1339:               }\n1340:               meta.tokenBudgetTruncated = true;\n1341:               meta.originalResultCount = originalCount;\n1342:               meta.returnedResultCount = innerResults.length;\n1343:             } else if (stillOverBudget) {\n1344:               // No truncatable results array — add warning hint only\n1345:               if (Array.isArray(envelope.hints)) {\n1346:                 envelope.hints.push(`Response exceeds token budget (${meta.tokenCount}/${budget})`);\n1347:               }\n1348:             }\n1349:           }\n1350:           result.content[0].text = serializeEnvelopeWithTokenCount(envelope);\n1351:         }\n1352:       } catch (_parseErr: unknown) {\n1353:         // Non-JSON response, skip token budget injection\n1354:       }\n1355:     }\n1356: \n1357:     return result;\n1358:   } catch (error: unknown) {\n1359:     // Include recovery hints in all error responses\n1360:     const err = error instanceof Error ? error : new Error(String(error));\n1361:     try {\n1362:       const errorResponse = buildErrorResponse(name, err, args);\n1363:       // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1364:       return wrapForMCP(errorResponse as any, true);\n1365:     } catch (wrapError: unknown) {\n1366:       const fallbackError = wrapError instanceof Error ? wrapError.message : String(wrapError);\n1367:       console.error(`[context-server] Failed to build MCP error envelope for '${name}': ${fallbackError}`);\n1368:       const fallbackCode = getDefaultErrorCodeForTool(name);\n1369:       return createMCPErrorResponse({\n1370:         tool: name,\n1371:         error: 'Request failed.',\n1372:         code: fallbackCode,\n1373:         recovery: getRecoveryHint(name, fallbackCode),\n1374:       });\n1375:     }\n1376:   }\n1377:   });\n1378: }\n1379: \n1380: registerContextServerHandlers(server);\n1381: \n1382: /* ───────────────────────────────────────────────────────────────\n1383:    6. STARTUP SCAN & PENDING FILE RECOVERY\n1384: ──────────────────────────────────────────────────────────────── */\n1385: \n1386: let startupScanInProgress = false;\n1387: // Tracked (not fire-and-forget) so fatalShutdown can await the scan to a safe stopping point before\n1388: // closeDb — a resuming scan writes through the DB and would otherwise reopen a closed connection.\n1389: let startupScanPromise: Promise<void> | null = null;\n1390: \n1391: function getStartupWorkspaceRoots(basePath: string): string[] {\n1392:   const configuredMemoryRoot = process.env.MEMORY_BASE_PATH?.trim();\n1393:   const derivedMemoryRoot = configuredMemoryRoot ? path.resolve(process.cwd(), configuredMemoryRoot) : null;\n1394:   return Array.from(new Set(\n1395:     [basePath, derivedMemoryRoot, ...ALLOWED_BASE_PATHS]\n1396:       .filter((root): root is string => typeof root === 'string' && root.trim().length > 0)\n1397:       .map((root) => path.resolve(root))\n1398:   ));\n1399: }\n1400: \n1401: function getPendingRecoveryLocations(basePath: string): string[] {\n1402:   const scanLocations: string[] = [];\n1403:   for (const root of getStartupWorkspaceRoots(basePath)) {\n1404:     scanLocations.push(path.join(root, 'specs'));\n1405:     scanLocations.push(path.join(root, '.opencode', 'specs'));\n1406:     const skillDir = path.join(root, '.opencode', 'skills');\n1407:     try {\n1408:       if (!fs.existsSync(skillDir)) continue;\n1409:       for (const entry of fs.readdirSync(skillDir, { withFileTypes: true })) {\n1410:         if (!entry.isDirectory() || entry.name.startsWith('.')) continue;\n1411:         const constDir = path.join(skillDir, entry.name, 'constitutional');\n1412:         if (fs.existsSync(constDir)) scanLocations.push(constDir);\n1413:       }\n1414:     } catch (_error: unknown) {\n1415:       // Non-fatal: constitutional directory discovery failed\n1416:     }\n1417:   }\n1418:   return Array.from(new Set(scanLocations.filter((location) => fs.existsSync(location))));\n1419: }\n1420: \n1421: /**\n1422:  * Recover pending memory files on MCP startup.\n1423:  * Pending files processed by recovery job on next startup.\n1424:  *\n1425:  * Scans for files with _pending suffix (created when index failed after file write)\n1426:  * and attempts to index them.\n1427:  */\n1428: async function recoverPendingFiles(basePath: string): Promise<PendingRecoveryResult> {\n1429:   console.error('[context-server] Checking for pending memory files...');\n1430: \n1431:   try {\n1432:     // Restrict scan to known memory file locations to prevent OOM when scanning large workspaces.\n1433:     // Share the same allowed-root expansion that startup indexing uses.\n1434:     const existingScanLocations = getPendingRecoveryLocations(basePath);\n1435: \n1436:     // P1 FIX: Wire isCommittedInDb callback so stale pending files are detected at startup.\n1437:     // VectorIndex.getDb() is an initializing accessor — always returns a valid DB after initializeDb().\n1438:     const database = vectorIndex.getDb();\n1439:     const isCommittedInDb = (originalPath: string): boolean => {\n1440:       const row = (database.prepare('SELECT 1 FROM memory_index WHERE file_path = ?') as import('better-sqlite3').Statement).get(originalPath);\n1441:       return !!row;\n1442:     };\n1443: \n1444:     const rawResults = existingScanLocations.flatMap((location) =>\n1445:       transactionManager.recoverAllPendingFiles(location, isCommittedInDb)\n1446:     );\n1447: \n1448:     // Aggregate per-file results into a summary\n1449:     const found = rawResults.length;\n1450:     const recovered = rawResults.filter(r => r.recovered).length;\n1451:     const failed = found - recovered;\n1452: \n1453:     const recoveryResult: PendingRecoveryResult = {\n1454:       found,\n1455:       processed: found,\n1456:       recovered,\n1457:       failed,\n1458:       results: rawResults,\n1459:     };\n\n(Showing lines 1000-1459 of 2341. Use offset=1460 to continue.)\n</content>","metadata":{"preview":"  afterToolCallbacks.push(fn);\n}\n\nasync function invalidateReinitializedDbCaches(): Promise<void> {\n  const invalidatedEntries = toolCache.clear();\n\n  try {\n    const triggerMatcher = await import('./lib/parsing/trigger-matcher.js');\n    if (typeof triggerMatcher.clearCache === 'function') {\n      triggerMatcher.clearCache();\n    }\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] Failed to clear trigger cache after DB reinit: ${message}`);\n  }\n\n  if (invalidatedEntries > 0) {\n    console.error(`[context-server] Cleared ${invalidatedEntries} tool-cache entries after DB reinitialization`);\n  }\n}","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"  afterToolCallbacks.push(fn);\n}\n\nasync function invalidateReinitializedDbCaches(): Promise<void> {\n  const invalidatedEntries = toolCache.clear();\n\n  try {\n    const triggerMatcher = await import('./lib/parsing/trigger-matcher.js');\n    if (typeof triggerMatcher.clearCache === 'function') {\n      triggerMatcher.clearCache();\n    }\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] Failed to clear trigger cache after DB reinit: ${message}`);\n  }\n\n  if (invalidatedEntries > 0) {\n    console.error(`[context-server] Cleared ${invalidatedEntries} tool-cache entries after DB reinitialization`);\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. SERVER INITIALIZATION\n──────────────────────────────────────────────────────────────── */\n\nfunction createContextMcpServer(): Server {\n  return new Server(\n    { name: 'mk-spec-memory', version: '1.8.0' },\n    { capabilities: { tools: {} } },\n  );\n}\n\nconst server = createContextMcpServer();\nconst serverWithInstructions = server as unknown as { setInstructions?: (instructions: string) => void };\nconst KNOWN_TOOL_NAMES = new Set(TOOL_DEFINITIONS.map((tool) => tool.name));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nfunction registerContextServerHandlers(targetServer: Server): void {\n  targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n    tools: TOOL_DEFINITIONS\n  }));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DISPATCH\n──────────────────────────────────────────────────────────────── */\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\n  targetServer.setRequestHandler(CallToolRequestSchema, async (request, _extra: unknown): Promise<any> => {\n  const requestParams = request.params as { name: string; arguments?: Record<string, unknown> };\n  const { name } = requestParams;\n  const args: Record<string, unknown> = requestParams.arguments ?? {};\n  const callId = resolveToolCallId(request as { id?: unknown });\n  const sessionTrackingId = resolveSessionTrackingId(args, _extra);\n  const callerContext = buildCallerContext(_extra);\n  if (sessionTrackingId) lastKnownSessionId = sessionTrackingId;\n\n  try {\n    // SEC-003: Validate input lengths before processing (CWE-400 mitigation)\n    validateInputLengths(args);\n    // Validate at the server boundary before metrics, session priming, and\n    // auto-surface logic can observe malformed raw tool arguments.\n    const validatedArgs: Record<string, unknown> = KNOWN_TOOL_NAMES.has(name)\n      ? validateToolArgs(name, args) as Record<string, unknown>\n      : args;\n\n    // Track last tool call timestamp for all tools except session_health.\n    if (name !== 'session_health') {\n      recordToolCall(sessionTrackingId);\n\n      // Record metric event for context quality tracking\n      recordMetricEvent({ kind: 'tool_call', toolName: name });\n    }\n    // Classify specific tool calls for finer-grained metrics\n    if (name === 'memory_context' && validatedArgs.mode === 'resume') {\n      recordMetricEvent({ kind: 'memory_recovery' });\n    }\n    // Code-graph MCP metrics now originate from standalone mk-code-index\n    if (typeof validatedArgs.specFolder === 'string' && validatedArgs.specFolder) {\n      recordMetricEvent({ kind: 'spec_folder_change', specFolder: validatedArgs.specFolder as string });\n    }\n\n    const memoryRuntimeRequired = MEMORY_RUNTIME_TOOL_NAMES.has(name);\n    if (memoryRuntimeRequired) {\n      await ensureMemoryRuntimeInitialized(`handler:${name}`);\n    }\n\n    const dbReinitialized = memoryRuntimeRequired\n      ? await checkDatabaseUpdated()\n      : false;\n    if (dbReinitialized) {\n      await invalidateReinitializedDbCaches();\n    }\n\n    let sessionPrimeContext: AutoSurfaceResult | null = null;\n    const memoryRuntimeAvailable = memoryRuntimeRequired || isMemoryRuntimeInitialized();\n    if (memoryRuntimeAvailable) {\n      try {\n        sessionPrimeContext = await primeSessionIfNeeded(\n          name,\n          validatedArgs,\n          sessionTrackingId,\n        );\n      } catch (primeErr: unknown) {\n        const msg = primeErr instanceof Error ? primeErr.message : String(primeErr);\n        console.error(`[context-server] Session priming failed (non-fatal): ${msg}`);\n      }\n    }\n\n    // Auto-surface memories before dispatch (after validation)\n    let autoSurfacedContext: AutoSurfaceResult | null = null;\n    const isCompactionLifecycleCall =\n      name === 'memory_context' && validatedArgs.mode === 'resume';\n\n    const autoSurfaceStart = Date.now();\n    if (MEMORY_AWARE_TOOLS.has(name) && memoryRuntimeAvailable) {\n      const contextHint: string | null = extractContextHint(validatedArgs);\n      if (contextHint) {\n        try {\n          if (isCompactionLifecycleCall) {\n            autoSurfacedContext = await autoSurfaceAtCompaction(contextHint);\n          } else {\n            autoSurfacedContext = await autoSurfaceMemories(contextHint);\n          }\n        } catch (surfaceErr: unknown) {\n          const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n          console.error(`[context-server] Auto-surface failed (non-fatal): ${msg}`);\n        }\n      }\n    } else if (memoryRuntimeAvailable) {\n      try {\n        autoSurfacedContext = await autoSurfaceAtToolDispatch(name, validatedArgs);\n      } catch (surfaceErr: unknown) {\n        const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n        console.error(`[context-server] Tool-dispatch auto-surface failed (non-fatal): ${msg}`);\n      }\n    }\n    const autoSurfaceLatencyMs = Date.now() - autoSurfaceStart;\n    if (autoSurfaceLatencyMs > 250) {\n      console.warn(`[context-server] Auto-surface precheck exceeded p95 target: ${autoSurfaceLatencyMs}ms`);\n    }\n\n    // Dispatch to tool modules\n    const result = await runWithCallerContext(\n      callerContext,\n      async () => dispatchTool(name, validatedArgs, callerContext),\n    ) as ToolCallResponse | null;\n    if (!result) {\n      throw new Error(`Unknown tool: ${name}`);\n    }\n\n    let dispatchGraphContext: DispatchGraphContextMeta | null = null;\n    if (!result.isError) {\n      dispatchGraphContext = await resolveDispatchGraphContext(name, validatedArgs);\n    }\n\n    runAfterToolCallbacks(name, callId, structuredClone(result));\n\n    // Log follow_on_tool_use when a non-search tool is called after a recent search\n    // Shadow-only: no ranking side effects. Fail-safe, never throws.\n    if (isMemoryRuntimeInitialized() && name !== 'memory_search' && name !== 'memory_context' && name !== 'session_health') {\n      try {\n        const { logFollowOnToolUse } = await import('./lib/feedback/query-flow-tracker.js');\n        const { requireDb } = await import('./utils/index.js');\n        const db = (() => { try { return requireDb(); } catch { return null; } })();\n        const followOnSessionId = sessionTrackingId ?? lastKnownSessionId;\n        if (db && followOnSessionId) {\n          logFollowOnToolUse(db, followOnSessionId);\n        }\n      } catch { /* follow_on_tool_use logging must never break dispatch */ }\n    }\n\n    // Code-search redirect hint for memory tools\n    if ((name === 'memory_search' || name === 'memory_context') && result && !result.isError && result.content?.[0]?.text) {\n      const queryStr = typeof args.query === 'string' ? args.query : typeof args.input === 'string' ? args.input : '';\n      const codeSearchPattern = /\\b(find code|implementation of|function that|where is|how does .+ work|class that|method for)\\b/i;\n      if (queryStr && codeSearchPattern.test(queryStr)) {\n        try {\n          const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n          if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n            const existingHints = Array.isArray(envelope.hints) ? envelope.hints as string[] : [];\n            existingHints.push('Tip: For code search queries, use mcp__mk_code_index__code_graph_query for structural lookups and Grep for exact text or token searches.');\n            envelope.hints = existingHints;\n            result.content[0].text = JSON.stringify(envelope, null, 2);\n          }\n        } catch {\n          // Response is not JSON envelope — skip hint injection\n        }\n      }\n\n      if (queryStr) {\n        try {\n          const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n          if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n            const meta = typeof envelope.meta === 'object' && envelope.meta !== null && !Array.isArray(envelope.meta)\n              ? envelope.meta as Record<string, unknown>\n              : {};\n            const snapshot = getSessionSnapshot();\n            const nudge = meta.structuralRoutingNudge\n              ? null\n              : maybeStructuralNudge(queryStr, {\n                graphReady: snapshot.graphFreshness === 'fresh',\n                activationScaffoldReady: snapshot.primed,\n                surface: 'response-hints',\n              });\n            if (nudge) {\n              injectStructuralRoutingNudge(envelope, nudge);\n              result.content[0].text = JSON.stringify(envelope, null, 2);\n            }\n          }\n        } catch {\n          // Response is not JSON envelope — skip structural nudge injection\n        }\n      }\n    }\n\n    // Passive context enrichment pipeline — adds code graph symbols\n    // near mentioned file paths and session continuity warnings.\n    if (result && !result.isError && result.content?.[0]?.text) {\n      try {\n        const { runPassiveEnrichment } = await import('./lib/enrichment/passive-enrichment.js');\n        const enrichment = await runPassiveEnrichment(result.content[0].text);\n        if (!enrichment.skipped && enrichment.hints.length > 0) {\n          try {\n            const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n            if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n              const existingHints = Array.isArray(envelope.hints) ? envelope.hints as string[] : [];\n              envelope.hints = [...existingHints, ...enrichment.hints];\n              result.content[0].text = JSON.stringify(envelope, null, 2);\n            }\n          } catch {\n            // Response is not JSON envelope — skip enrichment injection\n          }\n        }\n      } catch (enrichErr: unknown) {\n        // Passive enrichment is strictly non-fatal\n        const msg = enrichErr instanceof Error ? enrichErr.message : String(enrichErr);\n        console.warn(`[context-server] Passive enrichment failed (non-fatal): ${msg}`);\n      }\n    }\n\n    // Inject auto-surface hints before token-budget enforcement so\n    // The final envelope metadata reflects the fully decorated response.\n    if (autoSurfacedContext && result && !result.isError) {\n      appendAutoSurfaceHints(result, autoSurfacedContext);\n    }\n\n    // Token Budget Hybrid: Inject tokenBudget into response metadata\n    // Enforce per-layer token budgets with actual truncation\n    if (result && result.content && result.content[0]?.text) {\n      try {\n        const envelope = JSON.parse(result.content[0].text) as Record<string, unknown>;\n        if (envelope && typeof envelope === 'object' && !Array.isArray(envelope)) {\n          const metaValue = envelope.meta;\n          const meta = isRecord(metaValue)\n            ? metaValue as Record<string, unknown>\n            : {};\n          const dataValue = envelope.data;\n          const data = isRecord(dataValue)\n            ? dataValue as Record<string, unknown>\n            : null;\n          envelope.meta = meta;\n          if (sessionPrimeContext && !result.isError) {\n            injectSessionPrimeHints(envelope, meta, sessionPrimeContext);\n          }\n          if (autoSurfacedContext && !result.isError) {\n            meta.autoSurfacedContext = autoSurfacedContext;\n          }\n          if (dispatchGraphContext && !result.isError) {\n            meta.graphContext = dispatchGraphContext;\n          }\n          const budget = getTokenBudget(name);\n          meta.tokenBudget = budget;\n          syncEnvelopeTokenCount(envelope);\n\n          if (typeof meta.tokenCount === 'number' && meta.tokenCount > budget) {\n            console.error(`[token-budget] ${name} response (${meta.tokenCount} tokens) exceeds budget (${budget})`);\n\n            // First-call session priming rides along in meta and can dwarf a\n            // small tool's own payload. Slim it BEFORE touching the tool's\n            // results: the tool's answer is the caller's data, the priming\n            // payload is recoverable via memory_search/memory_context.\n            if (isRecord(meta.sessionPriming)) {\n              const priming = meta.sessionPriming as Record<string, unknown>;\n              const alreadyTrimmed = priming.trimmed === true;\n              if (!alreadyTrimmed) {\n                const constitutionalCount = Array.isArray(priming.constitutional)\n                  ? priming.constitutional.length\n                  : 0;\n                meta.sessionPriming = {\n                  trimmed: true,\n                  constitutionalCount,\n                  ...(isRecord(priming.primePackage) ? { primePackage: priming.primePackage } : {}),\n                };\n                syncEnvelopeTokenCount(envelope);\n                if (Array.isArray(envelope.hints)) {\n                  envelope.hints.push(`Session priming trimmed to fit the ${budget} token budget; full constitutional content remains retrievable via memory_search`);\n                }\n                meta.sessionPrimingTrimmed = true;\n              }\n            }\n\n            // Attempt to truncate results array to fit within budget — only\n            // when still over after the priming slim above, because the loop\n            // below pops a result before it re-measures.\n            const stillOverBudget = typeof meta.tokenCount === 'number' && meta.tokenCount > budget;\n            const innerResults = data?.results;\n            if (stillOverBudget && Array.isArray(innerResults) && innerResults.length > 1) {\n              const originalCount = innerResults.length;\n              // Results are typically sorted by score (highest first)\n              // Remove from end (lowest-scored) until within budget\n              while (innerResults.length > 1) {\n                innerResults.pop();\n                // Recalculate token count from the full envelope\n                // (not just results) so trace metadata is included in the budget.\n                syncEnvelopeTokenCount(envelope);\n                if (typeof meta.tokenCount === 'number' && meta.tokenCount <= budget) break;\n              }\n              if (data && data.count !== undefined) {\n                data.count = innerResults.length;\n              }\n              // Recompute constitutionalCount from the results that survived truncation\n              // so consumers reading data.constitutionalCount or envelope.summary see\n              // counts that agree with data.results.length.\n              if (data) {\n                const survivingConstitutionalCount = innerResults.filter(\n                  (r: unknown) => r !== null && typeof r === 'object' && (r as Record<string, unknown>).isConstitutional === true\n                ).length;\n                data.constitutionalCount = survivingConstitutionalCount;\n                if (typeof envelope.summary === 'string') {\n                  envelope.summary = survivingConstitutionalCount > 0\n                    ? `Found ${innerResults.length} memories (${survivingConstitutionalCount} constitutional)`\n                    : `Found ${innerResults.length} memories`;\n                }\n              }\n              if (Array.isArray(envelope.hints)) {\n                envelope.hints.push(`Token budget enforced: truncated ${originalCount} → ${innerResults.length} results to fit ${budget} token budget`);\n              }\n              meta.tokenBudgetTruncated = true;\n              meta.originalResultCount = originalCount;\n              meta.returnedResultCount = innerResults.length;\n            } else if (stillOverBudget) {\n              // No truncatable results array — add warning hint only\n              if (Array.isArray(envelope.hints)) {\n                envelope.hints.push(`Response exceeds token budget (${meta.tokenCount}/${budget})`);\n              }\n            }\n          }\n          result.content[0].text = serializeEnvelopeWithTokenCount(envelope);\n        }\n      } catch (_parseErr: unknown) {\n        // Non-JSON response, skip token budget injection\n      }\n    }\n\n    return result;\n  } catch (error: unknown) {\n    // Include recovery hints in all error responses\n    const err = error instanceof Error ? error : new Error(String(error));\n    try {\n      const errorResponse = buildErrorResponse(name, err, args);\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return wrapForMCP(errorResponse as any, true);\n    } catch (wrapError: unknown) {\n      const fallbackError = wrapError instanceof Error ? wrapError.message : String(wrapError);\n      console.error(`[context-server] Failed to build MCP error envelope for '${name}': ${fallbackError}`);\n      const fallbackCode = getDefaultErrorCodeForTool(name);\n      return createMCPErrorResponse({\n        tool: name,\n        error: 'Request failed.',\n        code: fallbackCode,\n        recovery: getRecoveryHint(name, fallbackCode),\n      });\n    }\n  }\n  });\n}\n\nregisterContextServerHandlers(server);\n\n/* ───────────────────────────────────────────────────────────────\n   6. STARTUP SCAN & PENDING FILE RECOVERY\n──────────────────────────────────────────────────────────────── */\n\nlet startupScanInProgress = false;\n// Tracked (not fire-and-forget) so fatalShutdown can await the scan to a safe stopping point before\n// closeDb — a resuming scan writes through the DB and would otherwise reopen a closed connection.\nlet startupScanPromise: Promise<void> | null = null;\n\nfunction getStartupWorkspaceRoots(basePath: string): string[] {\n  const configuredMemoryRoot = process.env.MEMORY_BASE_PATH?.trim();\n  const derivedMemoryRoot = configuredMemoryRoot ? path.resolve(process.cwd(), configuredMemoryRoot) : null;\n  return Array.from(new Set(\n    [basePath, derivedMemoryRoot, ...ALLOWED_BASE_PATHS]\n      .filter((root): root is string => typeof root === 'string' && root.trim().length > 0)\n      .map((root) => path.resolve(root))\n  ));\n}\n\nfunction getPendingRecoveryLocations(basePath: string): string[] {\n  const scanLocations: string[] = [];\n  for (const root of getStartupWorkspaceRoots(basePath)) {\n    scanLocations.push(path.join(root, 'specs'));\n    scanLocations.push(path.join(root, '.opencode', 'specs'));\n    const skillDir = path.join(root, '.opencode', 'skills');\n    try {\n      if (!fs.existsSync(skillDir)) continue;\n      for (const entry of fs.readdirSync(skillDir, { withFileTypes: true })) {\n        if (!entry.isDirectory() || entry.name.startsWith('.')) continue;\n        const constDir = path.join(skillDir, entry.name, 'constitutional');\n        if (fs.existsSync(constDir)) scanLocations.push(constDir);\n      }\n    } catch (_error: unknown) {\n      // Non-fatal: constitutional directory discovery failed\n    }\n  }\n  return Array.from(new Set(scanLocations.filter((location) => fs.existsSync(location))));\n}\n\n/**\n * Recover pending memory files on MCP startup.\n * Pending files processed by recovery job on next startup.\n *\n * Scans for files with _pending suffix (created when index failed after file write)\n * and attempts to index them.\n */\nasync function recoverPendingFiles(basePath: string): Promise<PendingRecoveryResult> {\n  console.error('[context-server] Checking for pending memory files...');\n\n  try {\n    // Restrict scan to known memory file locations to prevent OOM when scanning large workspaces.\n    // Share the same allowed-root expansion that startup indexing uses.\n    const existingScanLocations = getPendingRecoveryLocations(basePath);\n\n    // P1 FIX: Wire isCommittedInDb callback so stale pending files are detected at startup.\n    // VectorIndex.getDb() is an initializing accessor — always returns a valid DB after initializeDb().\n    const database = vectorIndex.getDb();\n    const isCommittedInDb = (originalPath: string): boolean => {\n      const row = (database.prepare('SELECT 1 FROM memory_index WHERE file_path = ?') as import('better-sqlite3').Statement).get(originalPath);\n      return !!row;\n    };\n\n    const rawResults = existingScanLocations.flatMap((location) =>\n      transactionManager.recoverAllPendingFiles(location, isCommittedInDb)\n    );\n\n    // Aggregate per-file results into a summary\n    const found = rawResults.length;\n    const recovered = rawResults.filter(r => r.recovered).length;\n    const failed = found - recovered;\n\n    const recoveryResult: PendingRecoveryResult = {\n      found,\n      processed: found,\n      recovered,\n      failed,\n      results: rawResults,\n    };","lineStart":1000,"lineEnd":1459,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781761501796,"end":1781761501801}},"metadata":{"openai":{"itemId":"fc_00ff612f68860895016a3385ddac4c8191b13bca495f02a7e3"}},"id":"prt_ed942ea51001Wlra74dOuped9P","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed942b79b001rlj0G50T58wap8"}}
{"type":"tool_use","timestamp":1781761501808,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_QGYe4JaMAlAkBDD3ZssjhOhr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":1600,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n1600: const EXIT_DB_LOCK_HELD = 86;\n1601: \n1602: export const __testables = {\n1603:   runCleanupStep,\n1604:   runAsyncCleanupStep,\n1605:   main: () => main(),\n1606:   getBootFtsIntegrityHealth,\n1607:   runCheckpointNeedsRebuildRepair,\n1608:   normalizeGraphFilePath,\n1609:   extractFilePathsFromToolArgs,\n1610: };\n1611: \n1612: async function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n1613:   if (shuttingDown) return;\n1614:   shuttingDown = true;\n1615:   console.error(`[context-server] ${reason}`);\n1616: \n1617:   runCleanupStep('sessionManager', () => sessionManager.shutdown());\n1618:   runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n1619:   // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n1620:   // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n1621:   // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n1622:   runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n1623:   runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n1624:   runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n1625:   runCleanupStep('accessTracker', () => accessTracker.reset());\n1626:   runCleanupStep('toolCache', () => toolCache.shutdown());\n1627:   runCleanupStep('launcherIdleMonitor', () => {\n1628:     if (launcherIdleMonitor) {\n1629:       launcherIdleMonitor.stop();\n1630:       launcherIdleMonitor = null;\n1631:     }\n1632:   });\n1633: \n1634:   let deadlineTimer: NodeJS.Timeout | undefined;\n1635:   const cleanup = (async () => {\n1636:     // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n1637:     // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n1638:     // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n1639:     await runAsyncCleanupStep('startupScan', async () => {\n1640:       if (startupScanPromise) await startupScanPromise;\n1641:     });\n1642:     // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n1643:     // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n1644:     // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n1645:     // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n1646:     // at rest and defeating the durability guarantee. closeDb() is\n1647:     // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n1648:     // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n1649:     // small even if a pathologically slow drain starves this step.\n1650:     await runAsyncCleanupStep('fileWatcher', async () => {\n1651:       if (fileWatcher) {\n1652:         await fileWatcher.close();\n1653:         fileWatcher = null;\n1654:       }\n1655:     });\n1656:     // Fence the ingest worker before closeDb for the same reason as the file\n1657:     // watcher above: the worker writes through the DB and would otherwise reopen\n1658:     // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n1659:     await runAsyncCleanupStep('ingestWorker', async () => {\n1660:       await stopIngestWorker();\n1661:     });\n1662:     runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n1663:     // Close MCP transport on shutdown\n1664:     runCleanupStep('transport', () => {\n1665:       if (transport) {\n1666:         transport.close();\n1667:         transport = null;\n1668:         transportConnectedAt = null;\n1669:       }\n1670:     });\n1671:     await runAsyncCleanupStep('ipcBridge', async () => {\n1672:       if (ipcBridge) {\n1673:         await ipcBridge.close();\n1674:         ipcBridge = null;\n1675:       }\n1676:     });\n1677:     await runAsyncCleanupStep('shutdownHooks', async () => {\n1678:       await runShutdownHooks();\n1679:     });\n1680:     runCleanupStep('registeredTimers', () => clearAllTimers());\n1681:   })();\n1682: \n1683:   const timedOut = await Promise.race([\n1684:     cleanup.then(() => false),\n1685:     new Promise<boolean>((resolve) => {\n1686:       deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n1687:     }),\n1688:   ]);\n1689: \n1690:   if (deadlineTimer) {\n1691:     clearRegisteredTimer(deadlineTimer);\n1692:   }\n1693: \n1694:   if (timedOut) {\n1695:     console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n1696:   }\n1697: \n1698:   process.exit(exitCode);\n1699: }\n1700: \n1701: /** Remove indexed rows for watcher delete and rename events. */\n1702: async function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n1703:   const database = vectorIndex.getDb();\n1704:   if (!database) {\n1705:     return;\n1706:   }\n1707: \n1708:   const canonicalPath = getCanonicalPathKey(filePath);\n1709:   let rows: Array<{ id: number; spec_folder: string | null }> = [];\n1710: \n1711:   try {\n1712:     rows = database.prepare(`\n1713:       SELECT id, spec_folder\n1714:       FROM memory_index\n1715:       WHERE canonical_file_path = ? OR file_path = ?\n1716:       ORDER BY id ASC\n1717:     `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n1718:   } catch (_error: unknown) {\n1719:     rows = database.prepare(`\n1720:       SELECT id, spec_folder\n1721:       FROM memory_index\n1722:       WHERE file_path = ?\n1723:       ORDER BY id ASC\n1724:     `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n1725:   }\n1726: \n1727:   let deletedCount = 0;\n1728:   for (const row of rows) {\n1729:     if (typeof row.id === 'number') {\n1730:       if (vectorIndex.deleteMemory(row.id)) {\n1731:         deletedCount += 1;\n1732:         // Record DELETE history only after confirmed deletion.\n1733:         try {\n1734:           recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n1735:         } catch (_histErr: unknown) {\n1736:           // History recording is best-effort in file-watcher path\n1737:         }\n1738:       }\n1739:     }\n1740:   }\n1741: \n1742:   if (deletedCount > 0) {\n1743:     try {\n1744:       runPostMutationHooks('delete', { filePath, deletedCount });\n1745:     } catch (_error: unknown) {\n1746:       // Non-throwing by design: file-watcher path must not crash the server.\n1747:     }\n1748:   }\n1749: }\n1750: \n1751: process.on('SIGTERM', () => {\n1752:   void fatalShutdown('Received SIGTERM, shutting down...', 0);\n1753: });\n1754: process.on('SIGINT', () => {\n1755:   void fatalShutdown('Received SIGINT, shutting down...', 0);\n1756: });\n1757: process.on('SIGHUP', () => {\n1758:   void fatalShutdown('Received SIGHUP, shutting down...', 0);\n1759: });\n1760: process.on('SIGQUIT', () => {\n1761:   void fatalShutdown('Received SIGQUIT, shutting down...', 0);\n1762: });\n1763: \n1764: process.on('uncaughtException', (err: Error) => {\n1765:   void fatalShutdown(`Uncaught exception: ${err.stack ?? err.message}`, 1);\n1766: });\n1767: \n1768: process.on('unhandledRejection', (reason: unknown, promise: Promise<unknown>) => {\n1769:   void fatalShutdown(\n1770:     `Unhandled rejection at: ${String(promise)} reason: ${reason instanceof Error ? reason.stack ?? reason.message : String(reason)}`,\n1771:     1,\n1772:   );\n1773: });\n1774: \n1775: /* ───────────────────────────────────────────────────────────────\n1776:    8. MAIN\n1777: ──────────────────────────────────────────────────────────────── */\n1778: \n1779: async function main(): Promise<void> {\n1780:   // Node version mismatch detection (non-blocking)\n1781:   detectNodeVersionMismatch();\n1782:   detectedRuntime = detectRuntime();\n1783:   console.error(\n1784:     `[context-server] Detected runtime: ${detectedRuntime.runtime} (hookPolicy=${detectedRuntime.hookPolicy})`,\n1785:   );\n1786: \n1787:   validateConfiguredEmbeddingsProvider();\n1788: \n1789:   // Refuse to boot as a second writer BEFORE anything else initializes. The\n1790:   // kernel-held sidecar lock survives every crash mode; a losing cold-spawn\n1791:   // must exit before it can touch the database, and the launcher converts\n1792:   // this exit code into a bridge to the live owner.\n1793:   try {\n1794:     acquireDbInstanceLock(vectorIndex.getDbPath() || DATABASE_PATH);\n1795:   } catch (error: unknown) {\n1796:     if (error instanceof VectorIndexError && error.code === VectorIndexErrorCode.DB_LOCK_HELD) {\n1797:       console.error(`[context-server] ${error.message}`);\n1798:       process.exit(EXIT_DB_LOCK_HELD);\n1799:     }\n1800:     throw error;\n1801:   }\n1802: \n1803:   registerInitTasks(async () => {\n1804:     console.error('[context-server] Initializing database...');\n1805:     let startupDb: Database.Database;\n1806:     try {\n1807:       startupDb = vectorIndex.initializeDb();\n1808:     } catch (error: unknown) {\n1809:       if (error instanceof VectorIndexError && error.code === VectorIndexErrorCode.DB_LOCK_HELD) {\n1810:         // Fail this caller's request with a structured error, then exit with\n1811:         // the lock-held code so the launcher bridges to the live owner\n1812:         // instead of relaunching a doomed second writer.\n1813:         setImmediate(() => { void fatalShutdown(error.message, EXIT_DB_LOCK_HELD); });\n1814:       }\n1815:       throw error;\n1816:     }\n1817:     console.error('[context-server] Database initialized');\n1818:     console.error('[context-server] Database path: ' + DATABASE_PATH);\n1819: \n1820:     // Idempotency receipts are replay caches. This is the ONLY sweep: it runs\n1821:     // once at boot, so the TTL is enforced across daemon restarts only. A warm\n1822:     // daemon running longer than the receipt TTL never re-sweeps, so rows past\n1823:     // TTL persist and the table grows until the next restart. That unbounded\n1824:     // growth is the accepted tradeoff (receipts are small and stale replays are\n1825:     // already gated by the active-row identity recheck at lookup time); if a\n1826:     // long-lived daemon needs mid-run expiry, add a bounded periodic/on-write\n1827:     // sweep here. Best-effort: a sweep failure never blocks boot.\n1828:     try {\n1829:       const prunedReceipts = pruneExpiredIdempotencyReceipts(startupDb);\n1830:       if (prunedReceipts > 0) {\n1831:         console.error(`[context-server] Pruned ${prunedReceipts} expired idempotency receipt(s)`);\n1832:       }\n1833:     } catch (_: unknown) { /* best-effort */ }\n1834: \n1835:     // Opt-in (SPECKIT_INCLUDE_ARCHIVED_VECTOR, default off): admit archived/cold rows\n1836:     // whose logical key has no active winner into the vector projection so the semantic\n1837:     // lane can reach them. Self-gated and idempotent; best-effort never blocks boot.\n1838:     try {\n1839:       const cold = backfillColdOrphanProjection(startupDb);\n1840:       if (cold.admitted > 0) {\n1841:         console.error(`[context-server] Admitted ${cold.admitted} archived/cold row(s) into the vector projection`);\n1842:       }\n1843:     } catch (_: unknown) { /* best-effort */ }\n1844: \n1845:   try {\n1846:     const active = await ensureActiveEmbedder(startupDb, { timeoutMs: API_KEY_VALIDATION_TIMEOUT_MS });\n1847:     vectorIndex.attachActiveVectorShardForActiveProfile(startupDb);\n1848:     console.error(\n1849:       `[context-server] Active embedder: ${active.name} (${active.dim}d${active.provider ? `, ${active.provider}` : ''})`,\n1850:     );\n1851:   } catch (error: unknown) {\n1852:     const message = error instanceof Error ? error.message : String(error);\n1853:     console.error(`[context-server] FATAL: ${message}`);\n1854:     // Throw (not process.exit) so a bad first call fails THAT caller's tool request with a\n1855:     // structured error while the shared daemon stays alive. The init guard resets and retries\n1856:     // on the next memory-runtime call, so a transient embedder failure self-heals.\n1857:     throw new Error(`memory runtime init failed (embedder): ${message}`);\n1858:   }\n1859: \n1860:   // Pre-Flight API Key Validation\n1861:   // Validates API key at startup to fail fast with actionable error messages\n1862:   // Skip validation if SPECKIT_SKIP_API_VALIDATION=true (for testing/CI)\n1863:   let startupEmbeddingConfig: Awaited<ReturnType<typeof resolveStartupEmbeddingConfig>> | null = null;\n1864:   if (process.env.SPECKIT_SKIP_API_VALIDATION !== 'true') {\n1865:     console.error('[context-server] Validating embedding API key...');\n1866:     try {\n1867:       startupEmbeddingConfig = await resolveStartupEmbeddingConfig({ timeout: API_KEY_VALIDATION_TIMEOUT_MS });\n1868:       const validation: ApiKeyValidation = startupEmbeddingConfig.validation;\n1869: \n1870:       if (!validation.valid) {\n1871:         if (validation.networkError) {\n1872:           // Transient network failure — warn and continue, validation will occur on first use\n1873:           console.warn('[context-server] ===== API KEY VALIDATION SKIPPED (network error) =====');\n1874:           console.warn(`[context-server] Provider: ${validation.provider}`);\n1875:           console.warn(`[context-server] Error: ${validation.error}`);\n1876:           if (validation.actions) {\n1877:             console.warn('[context-server] Recovery Actions:');\n1878:             validation.actions.forEach((action: string, i: number) => {\n1879:               console.warn(`[context-server]   ${i + 1}. ${action}`);\n1880:             });\n1881:           }\n1882:           console.warn('[context-server] Continuing startup — validation will occur on first use');\n1883:         } else {\n1884:           console.error('[context-server] ===== API KEY VALIDATION FAILED =====');\n1885:           console.error(`[context-server] Provider: ${validation.provider}`);\n1886:           console.error(`[context-server] Error: ${validation.error}`);\n1887:           console.error(`[context-server] Error Code: ${validation.errorCode || 'E050'}`);\n1888:           if (validation.actions) {\n1889:             console.error('[context-server] Recovery Actions:');\n1890:             validation.actions.forEach((action: string, i: number) => {\n1891:               console.error(`[context-server]   ${i + 1}. ${action}`);\n1892:             });\n1893:           }\n1894:           console.error('[context-server] =====================================');\n1895:           console.error('[context-server] FATAL: Cannot start MCP server with invalid API key');\n1896:           console.error('[context-server] Set SPECKIT_SKIP_API_VALIDATION=true to bypass (not recommended)');\n1897:           // Throw (not process.exit) so the shared daemon survives one bad first call. Tagged so\n1898:           // the enclosing transient-error catch RE-THROWS it (rather than swallowing it into the\n1899:           // \"continue\" path), letting the init guard surface it as a structured tool error + retry.\n1900:           throw Object.assign(\n1901:             new Error(`embedding API key validation failed: ${validation.error ?? validation.errorCode ?? 'invalid key'}`),\n1902:             { speckitInitHardFail: true },\n1903:           );\n1904:         }\n1905:       }\n1906: \n1907:       if (validation.warning) {\n1908:         console.warn(`[context-server] API key warning: ${validation.warning}`);\n1909:       }\n1910: \n1911:       if (validation.valid) {\n1912:         console.error(`[context-server] API key validated (provider: ${validation.provider})`);\n1913:       }\n1914:     } catch (validationError: unknown) {\n1915:       // A tagged hard-fail (invalid API key) must propagate to the init guard so the daemon does\n1916:       // not silently start with a known-bad key; only genuine transient validation errors fall\n1917:       // through to \"continue, validate on first use\".\n1918:       if (validationError && typeof validationError === 'object'\n1919:           && (validationError as { speckitInitHardFail?: boolean }).speckitInitHardFail) {\n1920:         throw validationError;\n1921:       }\n1922:       const message = validationError instanceof Error ? validationError.message : String(validationError);\n1923:       console.error(`[context-server] API key validation error: ${message}`);\n1924:       console.error('[context-server] Continuing startup - validation will occur on first use');\n1925:     }\n1926:   } else {\n1927:     console.warn('[context-server] API key validation skipped (SPECKIT_SKIP_API_VALIDATION=true)');\n1928:   }\n1929: \n1930:   if (!process.env.EMBEDDING_DIM) {\n1931:     process.env.EMBEDDING_DIM = String(\n1932:       startupEmbeddingConfig?.dimension ?? getStartupEmbeddingDimension(),\n1933:     );\n1934:   }\n1935: \n1936:   // Initialize db-state module with dependencies\n1937:   // P4-12/P4-19 FIX: Pass sessionManager and incrementalIndex so db-state can\n1938:   // Refresh their DB handles during reinitializeDatabase(), preventing stale refs.\n1939:   initDbState({\n1940:     vectorIndex,\n1941:     checkpoints: checkpointsLib,\n1942:     accessTracker,\n1943:     hybridSearch,\n1944:     sessionManager,\n1945:     incrementalIndex,\n1946:     dbConsumers: [\n1947:       sessionBoost,\n1948:       causalBoost,\n1949:       historyStore,\n1950:       workingMemory,\n1951:       attentionDecay,\n1952:       coActivation,\n1953:     ],\n1954:   });\n1955: \n1956:   console.error('[context-server] Lazy loading enabled - embedding model will initialize on first use');\n1957:   console.error('[context-server] SPECKIT_EAGER_WARMUP and SPECKIT_LAZY_LOADING are deprecated compatibility flags');\n1958: \n1959:   // Integrity check and module initialization\n1960:   try {\n1961:     const report = vectorIndex.verifyIntegrity();\n1962:     console.error(`[context-server] Integrity check: ${report.totalMemories}/${report.totalMemories + report.missingVectors} valid entries`);\n1963:     if (report.orphanedVectors > 0) console.error(`[context-server] WARNING: ${report.orphanedVectors} orphaned entries detected`);\n1964: \n1965:     // Validate embedding dimension matches database\n1966:     const dimValidation = vectorIndex.validateEmbeddingDimension();\n1967:     if (!dimValidation.valid) {\n1968:       console.error(`[context-server] ===== EMBEDDING DIMENSION MISMATCH =====`);\n1969:       console.error(`[context-server] ${dimValidation.warning}`);\n1970:       console.error(`[context-server] =========================================`);\n1971:       console.error('[context-server] FATAL: Refusing to start with mismatched embedding dimensions');\n1972:       throw new Error(dimValidation.warning ?? 'Embedding dimension mismatch between provider and database');\n1973:     } else if (dimValidation.stored) {\n1974:       console.error(`[context-server] Embedding dimension validated: ${dimValidation.stored}`);\n1975:     }\n1976: \n1977:     const database = vectorIndex.getDb();\n1978:     if (!database) {\n1979:       throw new Error('Database not initialized after initializeDb(). Cannot start server.');\n1980:     }\n1981: \n1982:     try {\n1983:       initScoringObservability(database);\n1984:       console.error('[context-server] Scoring observability initialized');\n1985:     } catch (scoringObsErr: unknown) {\n1986:       const message = scoringObsErr instanceof Error ? scoringObsErr.message : String(scoringObsErr);\n1987:       console.warn('[context-server] Scoring observability init failed (non-fatal):', message);\n1988:     }\n1989: \n1990:     const installGraphRefresh = (refreshDb: Database.Database): void => {\n1991:       registerGlobalRefreshFn(() => {\n1992:         const dirtyNodeIds = Array.from(getDirtyNodes().nodeIds);\n1993:         if (dirtyNodeIds.length === 0) {\n1994:           return;\n1995:         }\n1996: \n1997:         const updatedEdges = recomputeLocal(refreshDb, dirtyNodeIds);\n1998:         clearDirtyNodes();\n1999:         console.error(\n2000:           '[context-server] Scheduled graph refresh applied: dirty_nodes=%d, updated_edges=%d',\n2001:           dirtyNodeIds.length,\n2002:           updatedEdges,\n2003:         );\n2004:       });\n2005:     };\n2006: \n2007:     registerDatabaseRebindListener((nextDatabase) => {\n2008:       const reboundDatabase = nextDatabase as Database.Database;\n2009:       rebindScoringObservability(reboundDatabase);\n2010:       rebindExtractionAdapter(reboundDatabase);\n2011: \n2012:       cancelScheduledRefresh();\n2013:       installGraphRefresh(reboundDatabase);\n2014:       if (getDirtyNodes().nodeIds.size > 0) {\n2015:         scheduleGlobalRefresh();\n2016:       }\n2017: \n2018:       shadowEvaluationRuntime.stopShadowEvaluationScheduler();\n2019:       shadowEvaluationRuntime.startShadowEvaluationScheduler(reboundDatabase);\n2020:     });\n2021: \n2022:     if (isLearnedFeedbackEnabled()) {\n2023:       try {\n2024:         const migrated = migrateLearnedTriggers(database);\n2025:         const isolated = verifyFts5Isolation(database);\n2026:         console.error(`[context-server] Learned triggers ready (migrated=${migrated}, fts5Isolated=${isolated})`);\n2027:       } catch (learnedErr: unknown) {\n2028:         const message = learnedErr instanceof Error ? learnedErr.message : String(learnedErr);\n2029:         throw new Error(`[context-server] Learned feedback migration/isolation failed: ${message}`);\n2030:       }\n2031:     }\n2032: \n2033:     // Check SQLite version meets minimum requirement (3.35.0+)\n2034:     checkSqliteVersion(database);\n2035: \n2036:     // Verify WAL mode is active for operational concurrency guarantees.\n2037:     const walRow = database.prepare('PRAGMA journal_mode').get() as { journal_mode?: string } | undefined;\n2038:     const journalMode = String(walRow?.journal_mode ?? '').toLowerCase();\n2039:     if (journalMode !== 'wal') {\n2040:       database.pragma('journal_mode = WAL');\n2041:       console.warn('[context-server] journal_mode was not WAL; forcing WAL mode');\n2042:     }\n2043: \n2044:     const memoryCountRow = database.prepare('SELECT COUNT(*) as cnt FROM memory_index').get() as { cnt?: number } | undefined;\n2045:     const memoryCount = Number(memoryCountRow?.cnt ?? 0);\n2046:     let projectionCount = 0;\n2047:     let projectionTableExists = true;\n2048: \n2049:     try {\n2050:       const projectionCountRow = database.prepare('SELECT COUNT(*) as cnt FROM active_memory_projection').get() as { cnt?: number } | undefined;\n2051:       projectionCount = Number(projectionCountRow?.cnt ?? 0);\n2052:     } catch {\n2053:       projectionTableExists = false;\n2054:     }\n2055: \n2056:     console.error('[context-server] Startup health: memory_index=%d, active_memory_projection=%d', memoryCount, projectionCount);\n2057: \n2058:     if (memoryCount > 0 && (!projectionTableExists || projectionCount === 0)) {\n2059:       const result = runLineageBackfill(database);\n2060:       console.error('[context-server] Auto-backfill triggered: %d rows seeded into active_memory_projection', result.seeded);\n2061:     }\n2062: \n2063:     if (memoryCount === 0 && projectionCount === 0) {\n2064:       console.error('[context-server] WARNING: Database has 0 memories — search will return no results until memories are saved');\n2065:     }\n2066: \n2067:     const graphSearchFn = isGraphUnifiedEnabled()\n2068:       ? createUnifiedGraphSearchFn(database)\n2069:       : null;\n2070: \n2071:     checkpointsLib.init(database);\n2072:     accessTracker.init(database);\n2073:     hybridSearch.init(database, vectorIndex.vectorSearch, graphSearchFn);\n2074: \n2075:     // Keep db-state reinitialization wiring aligned with startup search wiring.\n2076:     initDbState({ graphSearchFn });\n2077:     sessionBoost.init(database);\n2078:     causalBoost.init(database);\n2079:     installGraphRefresh(database);\n2080:     console.error('[context-server] Checkpoints, access tracker, hybrid search, session boost, and causal boost initialized');\n2081:     runCheckpointNeedsRebuildRepair(database, 'boot');\n2082: \n2083:     // P3-04/014: Warm in-memory BM25 only when the selected lexical engine needs it.\n2084:     if (bm25Index.shouldWarmInMemoryBm25(database)) {\n2085:       try {\n2086:         const bm25 = bm25Index.getIndex();\n2087:         const count = bm25.rebuildFromDatabase(database);\n2088:         console.error(`[context-server] BM25 index rebuilt from database: ${count} documents`);\n2089:       } catch (bm25Err: unknown) {\n2090:         const message = bm25Err instanceof Error ? bm25Err.message : String(bm25Err);\n2091:         console.warn('[context-server] BM25 index rebuild failed:', message);\n2092:       }\n2093:     }\n2094: \n2095:     // Cognitive memory modules\n2096:     try {\n2097:       workingMemory.init(database);\n2098:       attentionDecay.init(database);\n2099:       coActivation.init(database);\n\n(Showing lines 1600-2099 of 2341. Use offset=2100 to continue.)\n</content>","metadata":{"preview":"const EXIT_DB_LOCK_HELD = 86;\n\nexport const __testables = {\n  runCleanupStep,\n  runAsyncCleanupStep,\n  main: () => main(),\n  getBootFtsIntegrityHealth,\n  runCheckpointNeedsRebuildRepair,\n  normalizeGraphFilePath,\n  extractFilePathsFromToolArgs,\n};\n\nasync function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n  if (shuttingDown) return;\n  shuttingDown = true;\n  console.error(`[context-server] ${reason}`);\n\n  runCleanupStep('sessionManager', () => sessionManager.shutdown());\n  runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n  // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"const EXIT_DB_LOCK_HELD = 86;\n\nexport const __testables = {\n  runCleanupStep,\n  runAsyncCleanupStep,\n  main: () => main(),\n  getBootFtsIntegrityHealth,\n  runCheckpointNeedsRebuildRepair,\n  normalizeGraphFilePath,\n  extractFilePathsFromToolArgs,\n};\n\nasync function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n  if (shuttingDown) return;\n  shuttingDown = true;\n  console.error(`[context-server] ${reason}`);\n\n  runCleanupStep('sessionManager', () => sessionManager.shutdown());\n  runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n  // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n  // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n  // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n  runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n  runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n  runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n  runCleanupStep('accessTracker', () => accessTracker.reset());\n  runCleanupStep('toolCache', () => toolCache.shutdown());\n  runCleanupStep('launcherIdleMonitor', () => {\n    if (launcherIdleMonitor) {\n      launcherIdleMonitor.stop();\n      launcherIdleMonitor = null;\n    }\n  });\n\n  let deadlineTimer: NodeJS.Timeout | undefined;\n  const cleanup = (async () => {\n    // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n    // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n    // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n    await runAsyncCleanupStep('startupScan', async () => {\n      if (startupScanPromise) await startupScanPromise;\n    });\n    // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n    // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n    // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n    // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n    // at rest and defeating the durability guarantee. closeDb() is\n    // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n    // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n    // small even if a pathologically slow drain starves this step.\n    await runAsyncCleanupStep('fileWatcher', async () => {\n      if (fileWatcher) {\n        await fileWatcher.close();\n        fileWatcher = null;\n      }\n    });\n    // Fence the ingest worker before closeDb for the same reason as the file\n    // watcher above: the worker writes through the DB and would otherwise reopen\n    // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n    await runAsyncCleanupStep('ingestWorker', async () => {\n      await stopIngestWorker();\n    });\n    runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n    // Close MCP transport on shutdown\n    runCleanupStep('transport', () => {\n      if (transport) {\n        transport.close();\n        transport = null;\n        transportConnectedAt = null;\n      }\n    });\n    await runAsyncCleanupStep('ipcBridge', async () => {\n      if (ipcBridge) {\n        await ipcBridge.close();\n        ipcBridge = null;\n      }\n    });\n    await runAsyncCleanupStep('shutdownHooks', async () => {\n      await runShutdownHooks();\n    });\n    runCleanupStep('registeredTimers', () => clearAllTimers());\n  })();\n\n  const timedOut = await Promise.race([\n    cleanup.then(() => false),\n    new Promise<boolean>((resolve) => {\n      deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n    }),\n  ]);\n\n  if (deadlineTimer) {\n    clearRegisteredTimer(deadlineTimer);\n  }\n\n  if (timedOut) {\n    console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n  }\n\n  process.exit(exitCode);\n}\n\n/** Remove indexed rows for watcher delete and rename events. */\nasync function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return;\n  }\n\n  const canonicalPath = getCanonicalPathKey(filePath);\n  let rows: Array<{ id: number; spec_folder: string | null }> = [];\n\n  try {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE canonical_file_path = ? OR file_path = ?\n      ORDER BY id ASC\n    `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n  } catch (_error: unknown) {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE file_path = ?\n      ORDER BY id ASC\n    `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n  }\n\n  let deletedCount = 0;\n  for (const row of rows) {\n    if (typeof row.id === 'number') {\n      if (vectorIndex.deleteMemory(row.id)) {\n        deletedCount += 1;\n        // Record DELETE history only after confirmed deletion.\n        try {\n          recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n        } catch (_histErr: unknown) {\n          // History recording is best-effort in file-watcher path\n        }\n      }\n    }\n  }\n\n  if (deletedCount > 0) {\n    try {\n      runPostMutationHooks('delete', { filePath, deletedCount });\n    } catch (_error: unknown) {\n      // Non-throwing by design: file-watcher path must not crash the server.\n    }\n  }\n}\n\nprocess.on('SIGTERM', () => {\n  void fatalShutdown('Received SIGTERM, shutting down...', 0);\n});\nprocess.on('SIGINT', () => {\n  void fatalShutdown('Received SIGINT, shutting down...', 0);\n});\nprocess.on('SIGHUP', () => {\n  void fatalShutdown('Received SIGHUP, shutting down...', 0);\n});\nprocess.on('SIGQUIT', () => {\n  void fatalShutdown('Received SIGQUIT, shutting down...', 0);\n});\n\nprocess.on('uncaughtException', (err: Error) => {\n  void fatalShutdown(`Uncaught exception: ${err.stack ?? err.message}`, 1);\n});\n\nprocess.on('unhandledRejection', (reason: unknown, promise: Promise<unknown>) => {\n  void fatalShutdown(\n    `Unhandled rejection at: ${String(promise)} reason: ${reason instanceof Error ? reason.stack ?? reason.message : String(reason)}`,\n    1,\n  );\n});\n\n/* ───────────────────────────────────────────────────────────────\n   8. MAIN\n──────────────────────────────────────────────────────────────── */\n\nasync function main(): Promise<void> {\n  // Node version mismatch detection (non-blocking)\n  detectNodeVersionMismatch();\n  detectedRuntime = detectRuntime();\n  console.error(\n    `[context-server] Detected runtime: ${detectedRuntime.runtime} (hookPolicy=${detectedRuntime.hookPolicy})`,\n  );\n\n  validateConfiguredEmbeddingsProvider();\n\n  // Refuse to boot as a second writer BEFORE anything else initializes. The\n  // kernel-held sidecar lock survives every crash mode; a losing cold-spawn\n  // must exit before it can touch the database, and the launcher converts\n  // this exit code into a bridge to the live owner.\n  try {\n    acquireDbInstanceLock(vectorIndex.getDbPath() || DATABASE_PATH);\n  } catch (error: unknown) {\n    if (error instanceof VectorIndexError && error.code === VectorIndexErrorCode.DB_LOCK_HELD) {\n      console.error(`[context-server] ${error.message}`);\n      process.exit(EXIT_DB_LOCK_HELD);\n    }\n    throw error;\n  }\n\n  registerInitTasks(async () => {\n    console.error('[context-server] Initializing database...');\n    let startupDb: Database.Database;\n    try {\n      startupDb = vectorIndex.initializeDb();\n    } catch (error: unknown) {\n      if (error instanceof VectorIndexError && error.code === VectorIndexErrorCode.DB_LOCK_HELD) {\n        // Fail this caller's request with a structured error, then exit with\n        // the lock-held code so the launcher bridges to the live owner\n        // instead of relaunching a doomed second writer.\n        setImmediate(() => { void fatalShutdown(error.message, EXIT_DB_LOCK_HELD); });\n      }\n      throw error;\n    }\n    console.error('[context-server] Database initialized');\n    console.error('[context-server] Database path: ' + DATABASE_PATH);\n\n    // Idempotency receipts are replay caches. This is the ONLY sweep: it runs\n    // once at boot, so the TTL is enforced across daemon restarts only. A warm\n    // daemon running longer than the receipt TTL never re-sweeps, so rows past\n    // TTL persist and the table grows until the next restart. That unbounded\n    // growth is the accepted tradeoff (receipts are small and stale replays are\n    // already gated by the active-row identity recheck at lookup time); if a\n    // long-lived daemon needs mid-run expiry, add a bounded periodic/on-write\n    // sweep here. Best-effort: a sweep failure never blocks boot.\n    try {\n      const prunedReceipts = pruneExpiredIdempotencyReceipts(startupDb);\n      if (prunedReceipts > 0) {\n        console.error(`[context-server] Pruned ${prunedReceipts} expired idempotency receipt(s)`);\n      }\n    } catch (_: unknown) { /* best-effort */ }\n\n    // Opt-in (SPECKIT_INCLUDE_ARCHIVED_VECTOR, default off): admit archived/cold rows\n    // whose logical key has no active winner into the vector projection so the semantic\n    // lane can reach them. Self-gated and idempotent; best-effort never blocks boot.\n    try {\n      const cold = backfillColdOrphanProjection(startupDb);\n      if (cold.admitted > 0) {\n        console.error(`[context-server] Admitted ${cold.admitted} archived/cold row(s) into the vector projection`);\n      }\n    } catch (_: unknown) { /* best-effort */ }\n\n  try {\n    const active = await ensureActiveEmbedder(startupDb, { timeoutMs: API_KEY_VALIDATION_TIMEOUT_MS });\n    vectorIndex.attachActiveVectorShardForActiveProfile(startupDb);\n    console.error(\n      `[context-server] Active embedder: ${active.name} (${active.dim}d${active.provider ? `, ${active.provider}` : ''})`,\n    );\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] FATAL: ${message}`);\n    // Throw (not process.exit) so a bad first call fails THAT caller's tool request with a\n    // structured error while the shared daemon stays alive. The init guard resets and retries\n    // on the next memory-runtime call, so a transient embedder failure self-heals.\n    throw new Error(`memory runtime init failed (embedder): ${message}`);\n  }\n\n  // Pre-Flight API Key Validation\n  // Validates API key at startup to fail fast with actionable error messages\n  // Skip validation if SPECKIT_SKIP_API_VALIDATION=true (for testing/CI)\n  let startupEmbeddingConfig: Awaited<ReturnType<typeof resolveStartupEmbeddingConfig>> | null = null;\n  if (process.env.SPECKIT_SKIP_API_VALIDATION !== 'true') {\n    console.error('[context-server] Validating embedding API key...');\n    try {\n      startupEmbeddingConfig = await resolveStartupEmbeddingConfig({ timeout: API_KEY_VALIDATION_TIMEOUT_MS });\n      const validation: ApiKeyValidation = startupEmbeddingConfig.validation;\n\n      if (!validation.valid) {\n        if (validation.networkError) {\n          // Transient network failure — warn and continue, validation will occur on first use\n          console.warn('[context-server] ===== API KEY VALIDATION SKIPPED (network error) =====');\n          console.warn(`[context-server] Provider: ${validation.provider}`);\n          console.warn(`[context-server] Error: ${validation.error}`);\n          if (validation.actions) {\n            console.warn('[context-server] Recovery Actions:');\n            validation.actions.forEach((action: string, i: number) => {\n              console.warn(`[context-server]   ${i + 1}. ${action}`);\n            });\n          }\n          console.warn('[context-server] Continuing startup — validation will occur on first use');\n        } else {\n          console.error('[context-server] ===== API KEY VALIDATION FAILED =====');\n          console.error(`[context-server] Provider: ${validation.provider}`);\n          console.error(`[context-server] Error: ${validation.error}`);\n          console.error(`[context-server] Error Code: ${validation.errorCode || 'E050'}`);\n          if (validation.actions) {\n            console.error('[context-server] Recovery Actions:');\n            validation.actions.forEach((action: string, i: number) => {\n              console.error(`[context-server]   ${i + 1}. ${action}`);\n            });\n          }\n          console.error('[context-server] =====================================');\n          console.error('[context-server] FATAL: Cannot start MCP server with invalid API key');\n          console.error('[context-server] Set SPECKIT_SKIP_API_VALIDATION=true to bypass (not recommended)');\n          // Throw (not process.exit) so the shared daemon survives one bad first call. Tagged so\n          // the enclosing transient-error catch RE-THROWS it (rather than swallowing it into the\n          // \"continue\" path), letting the init guard surface it as a structured tool error + retry.\n          throw Object.assign(\n            new Error(`embedding API key validation failed: ${validation.error ?? validation.errorCode ?? 'invalid key'}`),\n            { speckitInitHardFail: true },\n          );\n        }\n      }\n\n      if (validation.warning) {\n        console.warn(`[context-server] API key warning: ${validation.warning}`);\n      }\n\n      if (validation.valid) {\n        console.error(`[context-server] API key validated (provider: ${validation.provider})`);\n      }\n    } catch (validationError: unknown) {\n      // A tagged hard-fail (invalid API key) must propagate to the init guard so the daemon does\n      // not silently start with a known-bad key; only genuine transient validation errors fall\n      // through to \"continue, validate on first use\".\n      if (validationError && typeof validationError === 'object'\n          && (validationError as { speckitInitHardFail?: boolean }).speckitInitHardFail) {\n        throw validationError;\n      }\n      const message = validationError instanceof Error ? validationError.message : String(validationError);\n      console.error(`[context-server] API key validation error: ${message}`);\n      console.error('[context-server] Continuing startup - validation will occur on first use');\n    }\n  } else {\n    console.warn('[context-server] API key validation skipped (SPECKIT_SKIP_API_VALIDATION=true)');\n  }\n\n  if (!process.env.EMBEDDING_DIM) {\n    process.env.EMBEDDING_DIM = String(\n      startupEmbeddingConfig?.dimension ?? getStartupEmbeddingDimension(),\n    );\n  }\n\n  // Initialize db-state module with dependencies\n  // P4-12/P4-19 FIX: Pass sessionManager and incrementalIndex so db-state can\n  // Refresh their DB handles during reinitializeDatabase(), preventing stale refs.\n  initDbState({\n    vectorIndex,\n    checkpoints: checkpointsLib,\n    accessTracker,\n    hybridSearch,\n    sessionManager,\n    incrementalIndex,\n    dbConsumers: [\n      sessionBoost,\n      causalBoost,\n      historyStore,\n      workingMemory,\n      attentionDecay,\n      coActivation,\n    ],\n  });\n\n  console.error('[context-server] Lazy loading enabled - embedding model will initialize on first use');\n  console.error('[context-server] SPECKIT_EAGER_WARMUP and SPECKIT_LAZY_LOADING are deprecated compatibility flags');\n\n  // Integrity check and module initialization\n  try {\n    const report = vectorIndex.verifyIntegrity();\n    console.error(`[context-server] Integrity check: ${report.totalMemories}/${report.totalMemories + report.missingVectors} valid entries`);\n    if (report.orphanedVectors > 0) console.error(`[context-server] WARNING: ${report.orphanedVectors} orphaned entries detected`);\n\n    // Validate embedding dimension matches database\n    const dimValidation = vectorIndex.validateEmbeddingDimension();\n    if (!dimValidation.valid) {\n      console.error(`[context-server] ===== EMBEDDING DIMENSION MISMATCH =====`);\n      console.error(`[context-server] ${dimValidation.warning}`);\n      console.error(`[context-server] =========================================`);\n      console.error('[context-server] FATAL: Refusing to start with mismatched embedding dimensions');\n      throw new Error(dimValidation.warning ?? 'Embedding dimension mismatch between provider and database');\n    } else if (dimValidation.stored) {\n      console.error(`[context-server] Embedding dimension validated: ${dimValidation.stored}`);\n    }\n\n    const database = vectorIndex.getDb();\n    if (!database) {\n      throw new Error('Database not initialized after initializeDb(). Cannot start server.');\n    }\n\n    try {\n      initScoringObservability(database);\n      console.error('[context-server] Scoring observability initialized');\n    } catch (scoringObsErr: unknown) {\n      const message = scoringObsErr instanceof Error ? scoringObsErr.message : String(scoringObsErr);\n      console.warn('[context-server] Scoring observability init failed (non-fatal):', message);\n    }\n\n    const installGraphRefresh = (refreshDb: Database.Database): void => {\n      registerGlobalRefreshFn(() => {\n        const dirtyNodeIds = Array.from(getDirtyNodes().nodeIds);\n        if (dirtyNodeIds.length === 0) {\n          return;\n        }\n\n        const updatedEdges = recomputeLocal(refreshDb, dirtyNodeIds);\n        clearDirtyNodes();\n        console.error(\n          '[context-server] Scheduled graph refresh applied: dirty_nodes=%d, updated_edges=%d',\n          dirtyNodeIds.length,\n          updatedEdges,\n        );\n      });\n    };\n\n    registerDatabaseRebindListener((nextDatabase) => {\n      const reboundDatabase = nextDatabase as Database.Database;\n      rebindScoringObservability(reboundDatabase);\n      rebindExtractionAdapter(reboundDatabase);\n\n      cancelScheduledRefresh();\n      installGraphRefresh(reboundDatabase);\n      if (getDirtyNodes().nodeIds.size > 0) {\n        scheduleGlobalRefresh();\n      }\n\n      shadowEvaluationRuntime.stopShadowEvaluationScheduler();\n      shadowEvaluationRuntime.startShadowEvaluationScheduler(reboundDatabase);\n    });\n\n    if (isLearnedFeedbackEnabled()) {\n      try {\n        const migrated = migrateLearnedTriggers(database);\n        const isolated = verifyFts5Isolation(database);\n        console.error(`[context-server] Learned triggers ready (migrated=${migrated}, fts5Isolated=${isolated})`);\n      } catch (learnedErr: unknown) {\n        const message = learnedErr instanceof Error ? learnedErr.message : String(learnedErr);\n        throw new Error(`[context-server] Learned feedback migration/isolation failed: ${message}`);\n      }\n    }\n\n    // Check SQLite version meets minimum requirement (3.35.0+)\n    checkSqliteVersion(database);\n\n    // Verify WAL mode is active for operational concurrency guarantees.\n    const walRow = database.prepare('PRAGMA journal_mode').get() as { journal_mode?: string } | undefined;\n    const journalMode = String(walRow?.journal_mode ?? '').toLowerCase();\n    if (journalMode !== 'wal') {\n      database.pragma('journal_mode = WAL');\n      console.warn('[context-server] journal_mode was not WAL; forcing WAL mode');\n    }\n\n    const memoryCountRow = database.prepare('SELECT COUNT(*) as cnt FROM memory_index').get() as { cnt?: number } | undefined;\n    const memoryCount = Number(memoryCountRow?.cnt ?? 0);\n    let projectionCount = 0;\n    let projectionTableExists = true;\n\n    try {\n      const projectionCountRow = database.prepare('SELECT COUNT(*) as cnt FROM active_memory_projection').get() as { cnt?: number } | undefined;\n      projectionCount = Number(projectionCountRow?.cnt ?? 0);\n    } catch {\n      projectionTableExists = false;\n    }\n\n    console.error('[context-server] Startup health: memory_index=%d, active_memory_projection=%d', memoryCount, projectionCount);\n\n    if (memoryCount > 0 && (!projectionTableExists || projectionCount === 0)) {\n      const result = runLineageBackfill(database);\n      console.error('[context-server] Auto-backfill triggered: %d rows seeded into active_memory_projection', result.seeded);\n    }\n\n    if (memoryCount === 0 && projectionCount === 0) {\n      console.error('[context-server] WARNING: Database has 0 memories — search will return no results until memories are saved');\n    }\n\n    const graphSearchFn = isGraphUnifiedEnabled()\n      ? createUnifiedGraphSearchFn(database)\n      : null;\n\n    checkpointsLib.init(database);\n    accessTracker.init(database);\n    hybridSearch.init(database, vectorIndex.vectorSearch, graphSearchFn);\n\n    // Keep db-state reinitialization wiring aligned with startup search wiring.\n    initDbState({ graphSearchFn });\n    sessionBoost.init(database);\n    causalBoost.init(database);\n    installGraphRefresh(database);\n    console.error('[context-server] Checkpoints, access tracker, hybrid search, session boost, and causal boost initialized');\n    runCheckpointNeedsRebuildRepair(database, 'boot');\n\n    // P3-04/014: Warm in-memory BM25 only when the selected lexical engine needs it.\n    if (bm25Index.shouldWarmInMemoryBm25(database)) {\n      try {\n        const bm25 = bm25Index.getIndex();\n        const count = bm25.rebuildFromDatabase(database);\n        console.error(`[context-server] BM25 index rebuilt from database: ${count} documents`);\n      } catch (bm25Err: unknown) {\n        const message = bm25Err instanceof Error ? bm25Err.message : String(bm25Err);\n        console.warn('[context-server] BM25 index rebuild failed:', message);\n      }\n    }\n\n    // Cognitive memory modules\n    try {\n      workingMemory.init(database);\n      attentionDecay.init(database);\n      coActivation.init(database);","lineStart":1600,"lineEnd":2099,"totalLines":2341,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781761501802,"end":1781761501807}},"metadata":{"openai":{"itemId":"fc_00ff612f68860895016a3385ddac5481919344a3525804e3a1"}},"id":"prt_ed942ea65001WKZGdZjLEfH4yO","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed942b79b001rlj0G50T58wap8"}}
{"type":"tool_use","timestamp":1781761501820,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_RhEIwftFjQg1kikANqLHfx0i","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":260,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n260: }\n261: \n262: function loadBridgeModule() {\n263:   try {\n264:     return require('./lib/launcher-ipc-bridge.cjs');\n265:   } catch (error) {\n266:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n267:     return {\n268:       async maybeBridgeLeaseHolder({ leaseResult }) {\n269:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n270:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n271:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n272:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n273:         return { action: 'report', reason: 'bridge-module-missing' };\n274:       },\n275:     };\n276:   }\n277: }\n278: \n279: function resolveSessionProxySocketPath() {\n280:   const { getIpcSocketPath } = loadBridgeModule();\n281:   return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n282: }\n283: \n284: // Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n285: // the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n286: // like the lease holder does — instead of the raw bridge that severs on recycle. Each\n287: // secondary launcher process gets its own proxy instance (its own pendingRequests and\n288: // cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n289: // JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n290: // unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\n291: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n292:   const createProxy = options.createProxy ?? createSessionProxy;\n293:   const sessionProxy = createProxy({\n294:     socketPath,\n295:     stdin: options.stdin ?? process.stdin,\n296:     stdout: options.stdout ?? process.stdout,\n297:     log,\n298:   });\n299:   return sessionProxy.start();\n300: }\n301: \n302: function refreshPaths() {\n303:   skillsDir = path.join(opencodeDir, 'skills');\n304:   legacySkillDir = path.join(opencodeDir, 'skill');\n305:   kitDir = path.join(skillsDir, 'system-spec-kit');\n306:   dbDir = path.join(kitDir, 'mcp_server', 'database');\n307:   lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n308:   stateFile = path.join(dbDir, PID_FILE_NAME);\n309:   canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n310: }\n311: \n312: function exists(p) {\n313:   return fs.existsSync(p);\n314: }\n315: \n316: function writeState(payload) {\n317:   fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n318:   fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n319: }\n320: \n321: function resolvedDbDir() {\n322:   return canonicalizePath(dbDir);\n323: }\n324: \n325: // Resolve the dir the daemon writes its maintenance marker into. Must mirror the\n326: // daemon's DATABASE_DIR precedence (SPEC_KIT_DB_DIR / SPECKIT_DB_DIR override,\n327: // resolved against cwd, else the default DB dir) so both sides agree on the path\n328: // even under a test fake-root that sets SPEC_KIT_DB_DIR.\n329: function maintenanceMarkerDir() {\n330:   const override = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n331:   if (override) return canonicalizePath(path.resolve(process.cwd(), override));\n332:   return resolvedDbDir();\n333: }\n334: \n335: function leasePath() {\n336:   return path.join(resolvedDbDir(), PID_FILE_NAME);\n337: }\n338: \n339: function ownerLeasePath() {\n340:   return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n341: }\n342: \n343: function legacyLeasePaths() {\n344:   return [\n345:     path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n346:   ].map(canonicalizePath);\n347: }\n348: \n349: function readLeaseFile(filePath = leasePath()) {\n350:   try {\n351:     const raw = fs.readFileSync(filePath, 'utf8');\n352:     const parsed = JSON.parse(raw);\n353:     if (typeof parsed.pid === 'number') return parsed;\n354:   } catch {\n355:     // Missing or corrupt lease files are treated as no active lease.\n356:   }\n357:   return null;\n358: }\n359: \n360: function readOwnerLeaseFile(filePath = ownerLeasePath()) {\n361:   try {\n362:     const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n363:     if (\n364:       Number.isInteger(parsed.ownerPid) &&\n365:       Number.isInteger(parsed.ppid) &&\n366:       typeof parsed.executablePath === 'string' &&\n367:       typeof parsed.startedAtIso === 'string' &&\n368:       typeof parsed.lastHeartbeatIso === 'string' &&\n369:       Number.isInteger(parsed.ttlMs) &&\n370:       typeof parsed.canonicalDbDir === 'string'\n371:     ) {\n372:       return parsed;\n373:     }\n374:   } catch {\n375:     // Missing or corrupt owner leases are treated as no active owner.\n376:   }\n377:   return null;\n378: }\n379: \n380: function writeOwnerLeaseFile(lease) {\n381:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n382:   const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n383:   // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n384:   // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n385:   // after power loss and break ownership detection.\n386:   let fd;\n387:   try {\n388:     fd = fs.openSync(tmp, 'wx', 0o600);\n389:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n390:     fs.fsyncSync(fd);\n391:   } finally {\n392:     if (typeof fd === 'number') fs.closeSync(fd);\n393:   }\n394:   fs.renameSync(tmp, currentLeasePath);\n395: }\n396: \n397: function writeOwnerLeaseFileExclusive(lease) {\n398:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n399:   let fd;\n400:   try {\n401:     fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n402:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n403:     fs.fsyncSync(fd);\n404:     return true;\n405:   } catch (error) {\n406:     if (error.code === 'EEXIST') return false;\n407:     throw error;\n408:   } finally {\n409:     if (typeof fd === 'number') fs.closeSync(fd);\n410:   }\n411: }\n412: \n413: function buildOwnerLease(ownerPid = process.pid) {\n414:   return {\n415:     ownerPid,\n416:     ppid: process.ppid,\n417:     executablePath: process.execPath,\n418:     startedAtIso: new Date().toISOString(),\n419:     lastHeartbeatIso: new Date().toISOString(),\n420:     ttlMs: 60000,\n421:     canonicalDbDir: resolvedDbDir(),\n422:   };\n423: }\n424: \n425: function readParentPid(pid) {\n426:   if (!Number.isInteger(pid) || pid <= 0) return null;\n427:   if (process.platform === 'linux') {\n428:     try {\n429:       const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n430:       const match = status.match(/^PPid:\\s+(\\d+)$/m);\n431:       return match ? Number.parseInt(match[1], 10) : null;\n432:     } catch {\n433:       return null;\n434:     }\n435:   }\n436:   const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n437:     encoding: 'utf8',\n438:     stdio: ['ignore', 'pipe', 'ignore'],\n439:   });\n440:   if (result.status !== 0 || !result.stdout) return null;\n441:   const parsed = Number.parseInt(result.stdout.trim(), 10);\n442:   return Number.isInteger(parsed) ? parsed : null;\n443: }\n444: \n445: function classifyOwnerLease(lease) {\n446:   const liveness = processLiveness(lease.ownerPid);\n447:   if (liveness === 'dead') return 'stale-pid';\n448:   if (liveness === 'unknown-eperm') return 'unknown-eperm';\n449: \n450:   const actualPpid = readParentPid(lease.ownerPid);\n451:   if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n452:     return 'ppid-1-orphan';\n453:   }\n454: \n455:   const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n456:   const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n457:   if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n458:     return 'stale-heartbeat-reclaim';\n459:   }\n460: \n461:   return 'live-owner';\n462: }\n463: \n464: function acquireOwnerLeaseFile() {\n465:   const currentOwnerLeasePath = ownerLeasePath();\n466:   const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n467: \n468:   if (existing) {\n469:     const classification = classifyOwnerLease(existing);\n470:     if (classification === 'live-owner' || classification === 'unknown-eperm') {\n471:       return { acquired: false, holder: existing, classification };\n472:     }\n473:     log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n474:   }\n475: \n476:   const lease = buildOwnerLease(process.pid);\n477:   // Reclaim a stale lease by removing it first, then claim exclusively (O_EXCL).\n478:   // This collapses the fresh-acquire and stale-reclaim paths into a single CAS so\n479:   // only one racer can win: the loser's exclusive create hits EEXIST and returns\n480:   // acquired:false instead of last-writer-wins overwriting the winner's lease.\n481:   if (existing) {\n482:     try {\n483:       fs.unlinkSync(currentOwnerLeasePath);\n484:     } catch (error) {\n485:       if (error.code !== 'ENOENT') throw error;\n486:     }\n487:   }\n488:   if (!writeOwnerLeaseFileExclusive(lease)) {\n489:     const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n490:     return {\n491:       acquired: false,\n492:       holder: holder || lease,\n493:       classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n494:     };\n495:   }\n496:   ownerLeasePid = process.pid;\n497:   return { acquired: true, lease, reclaimed: existing };\n498: }\n499: \n500: function refreshOwnerLeaseFile(ownerPid, patch = {}) {\n501:   const lease = readOwnerLeaseFile();\n502:   if (!lease || lease.ownerPid !== ownerPid) return false;\n503:   const nextOwnerPid = patch.ownerPid ?? ownerPid;\n504:   writeOwnerLeaseFile({\n505:     ...lease,\n506:     ...patch,\n507:     lastHeartbeatIso: new Date().toISOString(),\n508:   });\n509:   const reread = readOwnerLeaseFile();\n510:   if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n511:   ownerLeasePid = nextOwnerPid;\n512:   return true;\n513: }\n514: \n515: function clearOwnerLeaseHeartbeat() {\n516:   if (ownerLeaseHeartbeatTimer) {\n517:     clearInterval(ownerLeaseHeartbeatTimer);\n518:     ownerLeaseHeartbeatTimer = null;\n519:   }\n520: }\n521: \n522: function startOwnerLeaseHeartbeat(ownerPid = process.pid) {\n523:   clearOwnerLeaseHeartbeat();\n524:   const lease = readOwnerLeaseFile();\n525:   const ttlMs = Number.isFinite(lease?.ttlMs) && lease.ttlMs > 0 ? lease.ttlMs : 60000;\n526:   const intervalMs = Math.max(1000, Math.floor(ttlMs / 2));\n527:   ownerLeaseHeartbeatTimer = setInterval(() => {\n528:     if (refreshOwnerLeaseFile(ownerPid)) return;\n529:     log('owner lease heartbeat refresh failed; shutting down launcher to preserve single ownership');\n530:     clearOwnerLeaseHeartbeat();\n531:     void shutdownLauncherForSignal('SIGTERM').catch((error) => {\n532:       log(error.stack || error.message);\n533:       clearAllLeaseFiles();\n534:       process.exit(128);\n535:     });\n536:   }, intervalMs);\n537:   ownerLeaseHeartbeatTimer.unref?.();\n538: }\n539: \n540: function ownsOwnerLeaseFile(ownerPid = process.pid) {\n541:   const lease = readOwnerLeaseFile();\n542:   return lease?.ownerPid === ownerPid;\n543: }\n544: \n545: function clearOwnerLeaseFile() {\n546:   if (!Number.isInteger(ownerLeasePid)) return;\n547:   try {\n548:     const lease = readOwnerLeaseFile();\n549:     if (lease && lease.ownerPid === ownerLeasePid\n550:         && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n551:       fs.unlinkSync(ownerLeasePath());\n552:     }\n553:   } catch {\n554:     // Idempotent cleanup.\n555:   } finally {\n556:     clearOwnerLeaseHeartbeat();\n557:     ownerLeasePid = null;\n558:   }\n559: }\n560: \n561: function clearOwnerLeaseFileIfOwner(ownerPid) {\n562:   try {\n563:     const lease = readOwnerLeaseFile();\n564:     if (lease && lease.ownerPid === ownerPid\n565:         && readOwnerLeaseFile()?.ownerPid === ownerPid) {\n566:       fs.unlinkSync(ownerLeasePath());\n567:     }\n568:   } catch {\n569:     // Idempotent cleanup.\n570:   }\n571: }\n572: \n573: function leaseHeldFromFile(filePath, legacyPath = null) {\n574:   const lease = readLeaseFile(filePath);\n575:   if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath, socketPath: null };\n576:   const startedAt = lease.startedAt ?? new Date(0).toISOString();\n577:   // Surface the owner-recorded socket path so the bridge can prefer it over recomputing one that\n578:   // may diverge under a different SPECKIT_IPC_SOCKET_DIR. Null when the lease predates this field.\n579:   const socketPath = typeof lease.socketPath === 'string' && lease.socketPath.length > 0 ? lease.socketPath : null;\n580:   try {\n581:     process.kill(lease.pid, 0);\n582:     return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n583:   } catch (error) {\n584:     if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath, socketPath };\n585:     // Mirror skill-advisor parity — EPERM means the process exists but we lack permission (e.g. sandbox); treat as live lease.\n586:     if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n587:     throw error;\n588:   }\n589: }\n590: \n591: function isLeaseHeld() {\n592:   const primary = leaseHeldFromFile(leasePath());\n593:   if (primary.held) return primary;\n594: \n595:   for (const legacyPath of legacyLeasePaths()) {\n596:     if (legacyPath === leasePath()) continue;\n597:     const legacy = leaseHeldFromFile(legacyPath, legacyPath);\n598:     if (legacy.held || legacy.staleReclaimable) return legacy;\n599:   }\n600: \n601:   return primary;\n602: }\n603: \n604: function writeLeaseHeldDiagnostic(leaseResult, suffix = '') {\n605:   const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n606:   const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n607:   process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n608: }\n609: \n610: function writeLeaseHeldJsonRpcError(leaseResult, reason) {\n611:   process.stdout.write(`${JSON.stringify({\n612:     jsonrpc: '2.0',\n613:     id: null,\n614:     error: {\n615:       code: -32001,\n616:       message: `mk-spec-memory: lease held by pid ${leaseResult.ownerPid} but session bridge unavailable (${reason}); reconnect`,\n617:       data: { retryable: true },\n618:     },\n619:   })}\\n`);\n620: }\n621: \n622: function bridgeReadiness(leaseResult) {\n623:   if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n624:     return { ready: false, reason: 'bridge-disabled' };\n625:   }\n626:   const storedSocketPath = leaseResult.socketPath;\n627:   if (\n628:     typeof storedSocketPath === 'string' &&\n629:     storedSocketPath.length > 0 &&\n630:     (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n631:   ) {\n632:     return { ready: true, socketPath: storedSocketPath };\n633:   }\n634:   const { getIpcSocketPath } = loadBridgeModule();\n635:   if (typeof getIpcSocketPath !== 'function') {\n636:     return { ready: false, reason: 'bridge-module-missing' };\n637:   }\n638:   const socketPath = getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n639:   if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n640:     return { ready: false, reason: 'no-bridge-socket' };\n641:   }\n642:   return { ready: true, socketPath };\n643: }\n644: \n645: function leaseResultForOwnerLease(ownerLease) {\n646:   const pidLeaseResult = isLeaseHeld();\n647:   if (pidLeaseResult.held && pidLeaseResult.ownerPid === ownerLease.ownerPid) {\n648:     return pidLeaseResult;\n649:   }\n650:   return {\n651:     held: true,\n652:     ownerPid: ownerLease.ownerPid,\n653:     staleReclaimable: false,\n654:     startedAt: ownerLease.startedAtIso,\n655:     legacyPath: null,\n656:     socketPath: null,\n657:   };\n658: }\n659: \n660: function respawnLockPath() {\n661:   return path.join(resolvedDbDir(), '.mk-spec-memory-respawn.lock');\n662: }\n663: \n664: function modelServerRespawnLockPath(socketPath = resolveModelServerSocketPath()) {\n665:   return mss.modelServerRespawnLockPath(socketPath, { dbDir: resolvedDbDir });\n666: }\n667: \n668: function acquireRespawnLockFileAt(lockPath, label = 'respawn') {\n669:   return acquireSharedRespawnLockFileAt(lockPath, label, { log, rel });\n670: }\n671: \n672: function acquireRespawnLockFile() {\n673:   return acquireRespawnLockFileAt(respawnLockPath(), 'respawn');\n674: }\n675: \n676: function acquireModelServerRespawnLockFile(socketPath = resolveModelServerSocketPath()) {\n677:   return mss.acquireModelServerRespawnLockFile(socketPath, { dbDir: resolvedDbDir, log, rel });\n678: }\n679: \n\n(Showing lines 260-679 of 1882. Use offset=680 to continue.)\n</content>","metadata":{"preview":"}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\nfunction resolveSessionProxySocketPath() {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\nfunction resolveSessionProxySocketPath() {\n  const { getIpcSocketPath } = loadBridgeModule();\n  return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n}\n\n// Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n// the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n// like the lease holder does — instead of the raw bridge that severs on recycle. Each\n// secondary launcher process gets its own proxy instance (its own pendingRequests and\n// cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n// JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n// unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\nfunction bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n  const createProxy = options.createProxy ?? createSessionProxy;\n  const sessionProxy = createProxy({\n    socketPath,\n    stdin: options.stdin ?? process.stdin,\n    stdout: options.stdout ?? process.stdout,\n    log,\n  });\n  return sessionProxy.start();\n}\n\nfunction refreshPaths() {\n  skillsDir = path.join(opencodeDir, 'skills');\n  legacySkillDir = path.join(opencodeDir, 'skill');\n  kitDir = path.join(skillsDir, 'system-spec-kit');\n  dbDir = path.join(kitDir, 'mcp_server', 'database');\n  lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n  stateFile = path.join(dbDir, PID_FILE_NAME);\n  canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n}\n\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  return canonicalizePath(dbDir);\n}\n\n// Resolve the dir the daemon writes its maintenance marker into. Must mirror the\n// daemon's DATABASE_DIR precedence (SPEC_KIT_DB_DIR / SPECKIT_DB_DIR override,\n// resolved against cwd, else the default DB dir) so both sides agree on the path\n// even under a test fake-root that sets SPEC_KIT_DB_DIR.\nfunction maintenanceMarkerDir() {\n  const override = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n  if (override) return canonicalizePath(path.resolve(process.cwd(), override));\n  return resolvedDbDir();\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n}\n\nfunction legacyLeasePaths() {\n  return [\n    path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n  ].map(canonicalizePath);\n}\n\nfunction readLeaseFile(filePath = leasePath()) {\n  try {\n    const raw = fs.readFileSync(filePath, 'utf8');\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.pid === 'number') return parsed;\n  } catch {\n    // Missing or corrupt lease files are treated as no active lease.\n  }\n  return null;\n}\n\nfunction readOwnerLeaseFile(filePath = ownerLeasePath()) {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n    if (\n      Number.isInteger(parsed.ownerPid) &&\n      Number.isInteger(parsed.ppid) &&\n      typeof parsed.executablePath === 'string' &&\n      typeof parsed.startedAtIso === 'string' &&\n      typeof parsed.lastHeartbeatIso === 'string' &&\n      Number.isInteger(parsed.ttlMs) &&\n      typeof parsed.canonicalDbDir === 'string'\n    ) {\n      return parsed;\n    }\n  } catch {\n    // Missing or corrupt owner leases are treated as no active owner.\n  }\n  return null;\n}\n\nfunction writeOwnerLeaseFile(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n  // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n  // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n  // after power loss and break ownership detection.\n  let fd;\n  try {\n    fd = fs.openSync(tmp, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n  fs.renameSync(tmp, currentLeasePath);\n}\n\nfunction writeOwnerLeaseFileExclusive(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  let fd;\n  try {\n    fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n    return true;\n  } catch (error) {\n    if (error.code === 'EEXIST') return false;\n    throw error;\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n}\n\nfunction buildOwnerLease(ownerPid = process.pid) {\n  return {\n    ownerPid,\n    ppid: process.ppid,\n    executablePath: process.execPath,\n    startedAtIso: new Date().toISOString(),\n    lastHeartbeatIso: new Date().toISOString(),\n    ttlMs: 60000,\n    canonicalDbDir: resolvedDbDir(),\n  };\n}\n\nfunction readParentPid(pid) {\n  if (!Number.isInteger(pid) || pid <= 0) return null;\n  if (process.platform === 'linux') {\n    try {\n      const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n      const match = status.match(/^PPid:\\s+(\\d+)$/m);\n      return match ? Number.parseInt(match[1], 10) : null;\n    } catch {\n      return null;\n    }\n  }\n  const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'ignore'],\n  });\n  if (result.status !== 0 || !result.stdout) return null;\n  const parsed = Number.parseInt(result.stdout.trim(), 10);\n  return Number.isInteger(parsed) ? parsed : null;\n}\n\nfunction classifyOwnerLease(lease) {\n  const liveness = processLiveness(lease.ownerPid);\n  if (liveness === 'dead') return 'stale-pid';\n  if (liveness === 'unknown-eperm') return 'unknown-eperm';\n\n  const actualPpid = readParentPid(lease.ownerPid);\n  if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n    return 'ppid-1-orphan';\n  }\n\n  const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n  const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n  if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n    return 'stale-heartbeat-reclaim';\n  }\n\n  return 'live-owner';\n}\n\nfunction acquireOwnerLeaseFile() {\n  const currentOwnerLeasePath = ownerLeasePath();\n  const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n\n  if (existing) {\n    const classification = classifyOwnerLease(existing);\n    if (classification === 'live-owner' || classification === 'unknown-eperm') {\n      return { acquired: false, holder: existing, classification };\n    }\n    log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n  }\n\n  const lease = buildOwnerLease(process.pid);\n  // Reclaim a stale lease by removing it first, then claim exclusively (O_EXCL).\n  // This collapses the fresh-acquire and stale-reclaim paths into a single CAS so\n  // only one racer can win: the loser's exclusive create hits EEXIST and returns\n  // acquired:false instead of last-writer-wins overwriting the winner's lease.\n  if (existing) {\n    try {\n      fs.unlinkSync(currentOwnerLeasePath);\n    } catch (error) {\n      if (error.code !== 'ENOENT') throw error;\n    }\n  }\n  if (!writeOwnerLeaseFileExclusive(lease)) {\n    const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n    return {\n      acquired: false,\n      holder: holder || lease,\n      classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n    };\n  }\n  ownerLeasePid = process.pid;\n  return { acquired: true, lease, reclaimed: existing };\n}\n\nfunction refreshOwnerLeaseFile(ownerPid, patch = {}) {\n  const lease = readOwnerLeaseFile();\n  if (!lease || lease.ownerPid !== ownerPid) return false;\n  const nextOwnerPid = patch.ownerPid ?? ownerPid;\n  writeOwnerLeaseFile({\n    ...lease,\n    ...patch,\n    lastHeartbeatIso: new Date().toISOString(),\n  });\n  const reread = readOwnerLeaseFile();\n  if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n  ownerLeasePid = nextOwnerPid;\n  return true;\n}\n\nfunction clearOwnerLeaseHeartbeat() {\n  if (ownerLeaseHeartbeatTimer) {\n    clearInterval(ownerLeaseHeartbeatTimer);\n    ownerLeaseHeartbeatTimer = null;\n  }\n}\n\nfunction startOwnerLeaseHeartbeat(ownerPid = process.pid) {\n  clearOwnerLeaseHeartbeat();\n  const lease = readOwnerLeaseFile();\n  const ttlMs = Number.isFinite(lease?.ttlMs) && lease.ttlMs > 0 ? lease.ttlMs : 60000;\n  const intervalMs = Math.max(1000, Math.floor(ttlMs / 2));\n  ownerLeaseHeartbeatTimer = setInterval(() => {\n    if (refreshOwnerLeaseFile(ownerPid)) return;\n    log('owner lease heartbeat refresh failed; shutting down launcher to preserve single ownership');\n    clearOwnerLeaseHeartbeat();\n    void shutdownLauncherForSignal('SIGTERM').catch((error) => {\n      log(error.stack || error.message);\n      clearAllLeaseFiles();\n      process.exit(128);\n    });\n  }, intervalMs);\n  ownerLeaseHeartbeatTimer.unref?.();\n}\n\nfunction ownsOwnerLeaseFile(ownerPid = process.pid) {\n  const lease = readOwnerLeaseFile();\n  return lease?.ownerPid === ownerPid;\n}\n\nfunction clearOwnerLeaseFile() {\n  if (!Number.isInteger(ownerLeasePid)) return;\n  try {\n    const lease = readOwnerLeaseFile();\n    if (lease && lease.ownerPid === ownerLeasePid\n        && readOwnerLeaseFile()?.ownerPid === ownerLeasePid) {\n      fs.unlinkSync(ownerLeasePath());\n    }\n  } catch {\n    // Idempotent cleanup.\n  } finally {\n    clearOwnerLeaseHeartbeat();\n    ownerLeasePid = null;\n  }\n}\n\nfunction clearOwnerLeaseFileIfOwner(ownerPid) {\n  try {\n    const lease = readOwnerLeaseFile();\n    if (lease && lease.ownerPid === ownerPid\n        && readOwnerLeaseFile()?.ownerPid === ownerPid) {\n      fs.unlinkSync(ownerLeasePath());\n    }\n  } catch {\n    // Idempotent cleanup.\n  }\n}\n\nfunction leaseHeldFromFile(filePath, legacyPath = null) {\n  const lease = readLeaseFile(filePath);\n  if (!lease) return { held: false, ownerPid: null, staleReclaimable: false, startedAt: null, legacyPath, socketPath: null };\n  const startedAt = lease.startedAt ?? new Date(0).toISOString();\n  // Surface the owner-recorded socket path so the bridge can prefer it over recomputing one that\n  // may diverge under a different SPECKIT_IPC_SOCKET_DIR. Null when the lease predates this field.\n  const socketPath = typeof lease.socketPath === 'string' && lease.socketPath.length > 0 ? lease.socketPath : null;\n  try {\n    process.kill(lease.pid, 0);\n    return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n  } catch (error) {\n    if (error.code === 'ESRCH') return { held: false, ownerPid: lease.pid, staleReclaimable: true, startedAt, legacyPath, socketPath };\n    // Mirror skill-advisor parity — EPERM means the process exists but we lack permission (e.g. sandbox); treat as live lease.\n    if (error.code === 'EPERM') return { held: true, ownerPid: lease.pid, staleReclaimable: false, startedAt, legacyPath, socketPath };\n    throw error;\n  }\n}\n\nfunction isLeaseHeld() {\n  const primary = leaseHeldFromFile(leasePath());\n  if (primary.held) return primary;\n\n  for (const legacyPath of legacyLeasePaths()) {\n    if (legacyPath === leasePath()) continue;\n    const legacy = leaseHeldFromFile(legacyPath, legacyPath);\n    if (legacy.held || legacy.staleReclaimable) return legacy;\n  }\n\n  return primary;\n}\n\nfunction writeLeaseHeldDiagnostic(leaseResult, suffix = '') {\n  const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n  const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n  process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n}\n\nfunction writeLeaseHeldJsonRpcError(leaseResult, reason) {\n  process.stdout.write(`${JSON.stringify({\n    jsonrpc: '2.0',\n    id: null,\n    error: {\n      code: -32001,\n      message: `mk-spec-memory: lease held by pid ${leaseResult.ownerPid} but session bridge unavailable (${reason}); reconnect`,\n      data: { retryable: true },\n    },\n  })}\\n`);\n}\n\nfunction bridgeReadiness(leaseResult) {\n  if (process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1') {\n    return { ready: false, reason: 'bridge-disabled' };\n  }\n  const storedSocketPath = leaseResult.socketPath;\n  if (\n    typeof storedSocketPath === 'string' &&\n    storedSocketPath.length > 0 &&\n    (storedSocketPath.startsWith('tcp://') || fs.existsSync(storedSocketPath))\n  ) {\n    return { ready: true, socketPath: storedSocketPath };\n  }\n  const { getIpcSocketPath } = loadBridgeModule();\n  if (typeof getIpcSocketPath !== 'function') {\n    return { ready: false, reason: 'bridge-module-missing' };\n  }\n  const socketPath = getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n  if (!socketPath.startsWith('tcp://') && !fs.existsSync(socketPath)) {\n    return { ready: false, reason: 'no-bridge-socket' };\n  }\n  return { ready: true, socketPath };\n}\n\nfunction leaseResultForOwnerLease(ownerLease) {\n  const pidLeaseResult = isLeaseHeld();\n  if (pidLeaseResult.held && pidLeaseResult.ownerPid === ownerLease.ownerPid) {\n    return pidLeaseResult;\n  }\n  return {\n    held: true,\n    ownerPid: ownerLease.ownerPid,\n    staleReclaimable: false,\n    startedAt: ownerLease.startedAtIso,\n    legacyPath: null,\n    socketPath: null,\n  };\n}\n\nfunction respawnLockPath() {\n  return path.join(resolvedDbDir(), '.mk-spec-memory-respawn.lock');\n}\n\nfunction modelServerRespawnLockPath(socketPath = resolveModelServerSocketPath()) {\n  return mss.modelServerRespawnLockPath(socketPath, { dbDir: resolvedDbDir });\n}\n\nfunction acquireRespawnLockFileAt(lockPath, label = 'respawn') {\n  return acquireSharedRespawnLockFileAt(lockPath, label, { log, rel });\n}\n\nfunction acquireRespawnLockFile() {\n  return acquireRespawnLockFileAt(respawnLockPath(), 'respawn');\n}\n\nfunction acquireModelServerRespawnLockFile(socketPath = resolveModelServerSocketPath()) {\n  return mss.acquireModelServerRespawnLockFile(socketPath, { dbDir: resolvedDbDir, log, rel });\n}\n","lineStart":260,"lineEnd":679,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781761501812,"end":1781761501818}},"metadata":{"openai":{"itemId":"fc_00ff612f68860895016a3385ddac5c819189ee92644d05d261"}},"id":"prt_ed942ea6b001bz3iBnFJ1rdDLV","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed942b79b001rlj0G50T58wap8"}}
{"type":"tool_use","timestamp":1781761501820,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_2crVLXxdxHiP1zKcOokNyLrE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":680,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n680: const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n681: \n682: // The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n683: // successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n684: // child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n685: // DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n686: // guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.\n687: function uncleanShutdownMarkerPath() {\n688:   // Mirror the daemon's full path precedence, not just MEMORY_DB_PATH:\n689:   // the daemon resolves its database dir from SPEC_KIT_DB_DIR /\n690:   // SPECKIT_DB_DIR before falling back to the packaged default, and the\n691:   // marker lives beside whatever database it actually opened. Checking the\n692:   // static dir under a dir override silently forfeits clean-close detection.\n693:   const fileOverride = process.env.MEMORY_DB_PATH?.trim();\n694:   if (fileOverride) {\n695:     return path.join(path.dirname(fileOverride), UNCLEAN_SHUTDOWN_MARKER);\n696:   }\n697:   const dirOverride = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n698:   const dir = dirOverride ? path.resolve(root, dirOverride) : resolvedDbDir();\n699:   return path.join(dir, UNCLEAN_SHUTDOWN_MARKER);\n700: }\n701: \n702: function uncleanMarkerPresent() {\n703:   try {\n704:     return fs.existsSync(uncleanShutdownMarkerPath());\n705:   } catch {\n706:     return false;\n707:   }\n708: }\n709: \n710: // A reap is a verified clean DB handoff only when the child exited on SIGTERM (not SIGKILL) AND the\n711: // clean-shutdown marker is gone (close_db ran its checkpoint + close). Anything else means the\n712: // replacement daemon will open a possibly-dirty shadow and must rebuild it at boot.\n713: function cleanCloseAfterReap({ killed, markerPresent }) {\n714:   return !killed && !markerPresent;\n715: }\n716: \n717: async function reapLeaseChildBeforeRespawn(childPid) {\n718:   const liveness = processLiveness(childPid);\n719:   if (liveness === 'unknown-eperm') {\n720:     return { allowed: false, reason: 'child-liveness-unknown-eperm' };\n721:   }\n722:   if (liveness === 'dead') {\n723:     return {\n724:       allowed: true,\n725:       reaped: false,\n726:       cleanClose: cleanCloseAfterReap({ killed: false, markerPresent: uncleanMarkerPresent() }),\n727:       reason: 'child-already-dead',\n728:     };\n729:   }\n730: \n731:   log(`reaping recorded context-server child pid ${childPid} before respawn`);\n732:   signalProcess(childPid, 'SIGTERM');\n733:   reapProcessTreeGroups(childPid, { signal: signalProcess });\n734:   const exitedAfterTerm = await waitForPidExit(childPid, RESPAWN_REAP_GRACE_MS);\n735:   let killed = false;\n736:   if (!exitedAfterTerm) {\n737:     log(`context-server child pid ${childPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n738:     signalProcess(childPid, 'SIGKILL');\n739:     const exitedAfterKill = await waitForPidExit(childPid, 1000);\n740:     killed = true;\n741:     if (!exitedAfterKill) {\n742:       // The child outlived SIGKILL within the grace window (uninterruptible state, or a pid we can\n743:       // no longer confirm). Refuse to hand the database to a replacement while the recorded writer\n744:       // may still be alive, so a caller never spawns a second writer onto the same WAL.\n745:       log(`context-server child pid ${childPid} did not exit after SIGKILL within grace; refusing respawn`);\n746:       return { allowed: false, reason: 'child-kill-unconfirmed' };\n747:     }\n748:   }\n749: \n750:   // Clean-close barrier: verify the child closed the DB cleanly (marker removed) before handing the\n751:   // DB to a replacement daemon. If it did not (graceful close timed out, or we had to SIGKILL), log\n752:   // it so the corruption window is visible — the replacement daemon's boot FTS auto-heal rebuilds the\n753:   // shadow. We never block respawn on this: a missing daemon is worse than a self-healing one.\n754:   const markerPresent = uncleanMarkerPresent();\n755:   const cleanClose = cleanCloseAfterReap({ killed, markerPresent });\n756:   if (!cleanClose) {\n757:     log(`reaped context-server child pid ${childPid} WITHOUT a verified clean DB close (killed=${killed}, uncleanMarkerPresent=${markerPresent}); the replacement daemon will rebuild the FTS shadow at boot`);\n758:   }\n759:   return { allowed: true, reaped: true, cleanClose, reason: 'child-reaped' };\n760: }\n761: \n762: async function reapOwnerBeforeRespawn(ownerPid) {\n763:   const liveness = processLiveness(ownerPid);\n764:   if (liveness === 'unknown-eperm') {\n765:     return { allowed: false, reason: 'owner-liveness-unknown-eperm' };\n766:   }\n767:   if (liveness === 'dead') {\n768:     return { allowed: true, reason: 'owner-already-dead' };\n769:   }\n770: \n771:   // A socket probe cannot distinguish a genuinely-dead daemon from one that merely\n772:   // refused the connection at its client cap (both look \"closed before reply\"). Before\n773:   // killing a process that is still ALIVE, require the owner lease to be heartbeat-stale\n774:   // too: a daemon that has refreshed its lease within its TTL is serving clients, not\n775:   // dead, and must never be reaped on a socket-probe-only verdict regardless of cap.\n776:   const currentOwner = readOwnerLeaseFile();\n777:   if (currentOwner?.ownerPid === ownerPid && classifyOwnerLease(currentOwner) === 'live-owner') {\n778:     log(`spec-memory owner pid ${ownerPid} is heartbeat-fresh (live-owner); refusing socket-probe reap (likely cap-refusal, not death)`);\n779:     return { allowed: false, reason: 'owner-heartbeat-fresh' };\n780:   }\n781: \n782:   log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n783:   signalProcess(ownerPid, 'SIGTERM');\n784:   const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n785:   if (!exitedAfterTerm) {\n786:     log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n787:     signalProcess(ownerPid, 'SIGKILL');\n788:     await waitForPidExit(ownerPid, 1000);\n789:   }\n790:   return { allowed: true, reason: 'owner-reaped' };\n791: }\n792: \n793: async function respawnAfterDeadSocket(leaseResult, decision) {\n794:   if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n795:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n796:     return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n797:   }\n798: \n799:   const ownerPid = leaseResult.ownerPid;\n800:   if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n801:     log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n802:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n803:     return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };\n804:   }\n805: \n806:   const lease = readLeaseFile(leaseResult.legacyPath || leasePath());\n807:   const childPid = lease?.childPid;\n808:   if (!Number.isInteger(childPid) || childPid <= 0) {\n809:     log('confirmed-dead socket but lease has no childPid; child-pid gate keeps respawn inert');\n810:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-child-pid)');\n811:     return { action: 'report', reason: 'missing-child-pid', socketPath: decision.socketPath };\n812:   }\n813: \n814:   // A daemon mid-maintenance (e.g. a background index scan) legitimately fails the\n815:   // deep liveness probe because its event loop is busy, not dead. If it holds a\n816:   // fresh marker naming this exact live child, refuse the respawn and leave it\n817:   // running. The marker lapses if the daemon is genuinely wedged (it can no longer\n818:   // refresh it), so a real death still respawns once the marker expires. Checked\n819:   // before the respawn lock and any reap so a bail unwinds nothing.\n820:   const deadSocketMarker = readMaintenanceMarker(maintenanceMarkerDir());\n821:   if (shouldAdoptDespiteProbe({ marker: deadSocketMarker, childPid, childLiveness: processLiveness(childPid) })) {\n822:     log(`confirmed-dead socket but child pid ${childPid} holds a fresh maintenance marker (activeUntil ${new Date(deadSocketMarker.activeUntilMs).toISOString()}); refusing respawn (busy, not dead)`);\n823:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-maintenance-active)');\n824:     return { action: 'report', reason: 'maintenance-active', socketPath: decision.socketPath };\n825:   }\n826: \n827:   let bootstrapLockHeld = false;\n828:   let respawnLock = null;\n829:   try {\n830:     bootstrapLockHeld = await acquireBootstrapLock({ requireLock: true });\n831:     respawnLock = acquireRespawnLockFile();\n832:     if (!respawnLock.acquired) {\n833:       log(`dead-socket respawn skipped; another launcher owns ${rel(respawnLock.path)}`);\n834:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n835:       return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n836:     }\n837: \n838:     const currentOwner = readOwnerLeaseFile();\n839:     if (currentOwner?.ownerPid !== ownerPid) {\n840:       log('dead-socket respawn skipped; spec-memory owner lease changed while waiting for respawn lock');\n841:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n842:       return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n843:     }\n844: \n845:     const currentLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n846:     if (currentLease?.pid !== leaseResult.ownerPid || currentLease?.childPid !== childPid) {\n847:       log('dead-socket respawn skipped; lease changed while waiting for respawn lock');\n848:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n849:       return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n850:     }\n851: \n852:     const ownerReapResult = await reapOwnerBeforeRespawn(ownerPid);\n853:     if (!ownerReapResult.allowed) {\n854:       log(`dead-socket respawn skipped; ${ownerReapResult.reason} for ownerPid=${ownerPid}`);\n855:       writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${ownerReapResult.reason})`);\n856:       return { action: 'report', reason: ownerReapResult.reason, socketPath: decision.socketPath };\n857:     }\n858: \n859:     clearOwnerLeaseFileIfOwner(ownerPid);\n860:     const ownerLease = buildOwnerLease(process.pid);\n861:     if (!writeOwnerLeaseFileExclusive(ownerLease)) {\n862:       const holder = readOwnerLeaseFile();\n863:       log(`dead-socket respawn skipped; another launcher owns spec-memory owner lease pid=${holder?.ownerPid ?? 'unknown'}`);\n864:       writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n865:       return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n866:     }\n867:     ownerLeasePid = process.pid;\n868: \n869:     const reapResult = await reapLeaseChildBeforeRespawn(childPid);\n870:     if (!reapResult.allowed) {\n871:       log(`dead-socket respawn skipped; ${reapResult.reason} for childPid=${childPid}`);\n872:       writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${reapResult.reason})`);\n873:       return { action: 'report', reason: reapResult.reason, socketPath: decision.socketPath };\n874:     }\n875: \n876:     buildIfNeeded([]);\n877:     leaseStartedAt = new Date().toISOString();\n878:     writeLeaseFile();\n879:     launchServer();\n880:     return { action: 'respawn', reason: 'spawned', socketPath: decision.socketPath };\n881:   } finally {\n882:     releaseRespawnLockFile(respawnLock);\n883:     if (bootstrapLockHeld) {\n884:       fs.rmSync(lockDir, { recursive: true, force: true });\n885:     }\n886:   }\n887: }\n888: \n889: async function bridgeOrReportLeaseHeld(leaseResult) {\n890:   const readiness = bridgeReadiness(leaseResult);\n891:   if (!readiness.ready) {\n892:     writeLeaseHeldJsonRpcError(leaseResult, readiness.reason);\n893:     return { action: 'report', reason: readiness.reason };\n894:   }\n895:   const { maybeBridgeLeaseHolder } = loadBridgeModule();\n896:   const decision = await maybeBridgeLeaseHolder({\n897:     serviceName: 'mk-spec-memory',\n898:     leaseResult,\n899:     loggerPrefix: 'mk-spec-memory-launcher',\n900:     dbDir: resolvedDbDir(),\n901:     bridge: bridgeStdioThroughSessionProxy,\n902:   });\n903:   if (decision && decision.action === 'respawn') {\n904:     return await respawnAfterDeadSocket(leaseResult, decision);\n905:   }\n906:   return decision;\n907: }\n908: \n909: async function bridgeOrReportLeaseHeldAndExit(leaseResult) {\n910:   const decision = await bridgeOrReportLeaseHeld(leaseResult);\n911:   if (!decision || decision.action === 'report') {\n912:     clearOwnerLeaseFile();\n913:     process.exit(0);\n914:   }\n915:   return decision;\n916: }\n917: \n918: function resolveModelServerSocketPath(env = process.env, options = {}) {\n919:   return mss.resolveModelServerSocketPath(env, {\n920:     ...options,\n921:     dbDir: options.dbDir || resolvedDbDir,\n922:   });\n923: }\n924: \n925: function getContextServerPid() {\n926:   return isChildRunning(childProcess) ? childProcess.pid : null;\n927: }\n928: \n929: // Pure lease-payload builder (exported for tests). `childPid`, `modelServerPid`, and `socketPath`\n930: // are ADDITIVE fields; existing readers consume only pid/startedAt/ownerPid and ignore the extras.\n931: // `socketPath` records the IPC path this owner actually listens on so a secondary launcher prefers\n932: // it over recomputing one that can diverge under a different SPECKIT_IPC_SOCKET_DIR.\n933: function buildLeaseObject(childPid = null, startedAt = leaseStartedAt, modelServerPid = null, socketPath = null) {\n934:   return buildSharedLeaseObject(childPid, startedAt || new Date().toISOString(), modelServerPid, socketPath);\n935: }\n936: \n937: function writeLeaseFile(childPid = getContextServerPid(), modelServerPid = hfControl.getPid()) {\n938:   if (!leaseStartedAt) leaseStartedAt = new Date().toISOString();\n939:   const payload = buildLeaseObject(childPid, leaseStartedAt, modelServerPid, resolveSessionProxySocketPath());\n940:   return writeAtomicJsonFile(leasePath(), payload, 'lease write');\n941: }\n942: \n943: function sharedModelServerPidPath(socketPath = resolveModelServerSocketPath()) {\n944:   const pidDir = socketPath.startsWith('tcp://') ? resolvedDbDir() : path.dirname(socketPath);\n945:   return path.join(pidDir, HF_MODEL_SERVER_PID_FILE_NAME);\n946: }\n947: \n948: function writeSharedModelServerPid(pid) {\n949:   const socketPath = resolveModelServerSocketPath();\n950:   const pidPath = sharedModelServerPidPath(socketPath);\n951:   if (!Number.isInteger(pid) || pid <= 0) {\n952:     try {\n953:       fs.unlinkSync(pidPath);\n954:     } catch (error) {\n955:       if (error.code === 'ENOENT') return true;\n956:       if (isDurableWriteUnavailable(error)) {\n957:         logDurableWriteUnavailableOnce('shared model-server pid clear', pidPath, error);\n958:         return false;\n959:       }\n960:       throw error;\n961:     }\n962:     return true;\n963:   }\n964: \n965:   return writeAtomicJsonFile(pidPath, {\n966:     pid,\n967:     startedAt: new Date().toISOString(),\n968:     ownerLauncher: 'mk-spec-memory',\n969:     socketPath,\n970:   }, 'shared model-server pid write');\n971: }\n972: \n973: function readSharedModelServerPid() {\n974:   const pidPath = sharedModelServerPidPath();\n975:   try {\n976:     const parsed = JSON.parse(fs.readFileSync(pidPath, 'utf8'));\n977:     if (Number.isInteger(parsed.pid) && parsed.pid > 0) return parsed.pid;\n978:   } catch (error) {\n979:     if (error.code !== 'ENOENT') {\n980:       // Corrupt pid files are treated like absent pid files; the respawn lock still serializes recovery.\n981:     }\n982:   }\n983: \n984:   const lease = readLeaseFile();\n985:   return Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0 ? lease.modelServerPid : null;\n986: }\n987: \n988: const hfControl = mss.createModelServerControl({\n989:   log,\n990:   env: process.env,\n991:   rootDir: root,\n992:   opencodeDir,\n993:   dbDir: resolvedDbDir,\n994:   getLauncherShutdownInProgress: () => launcherShutdownInProgress,\n995:   onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n996:   bridge: loadBridgeModule(),\n997:   writeModelServerPid: (pid) => writeSharedModelServerPid(pid),\n998:   readModelServerPid: () => readSharedModelServerPid(),\n999:   writeLease: () => writeLeaseFile(),\n1000: });\n1001: \n1002: function clearLeaseFile() {\n1003:   try {\n1004:     const lease = readLeaseFile();\n1005:     if (launcherShutdownInProgress && Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0) {\n1006:       try {\n1007:         hfControl.reapProcessTree(lease.modelServerPid);\n1008:       } catch {\n1009:         // Lease cleanup must remain best-effort even if a final process-tree read fails.\n1010:       }\n1011:     }\n1012:     if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n1013:   } catch {\n1014:     // Idempotent cleanup.\n1015:   }\n1016: }\n1017: \n1018: function clearAllLeaseFiles() {\n1019:   clearLeaseFile();\n1020:   clearOwnerLeaseFile();\n1021: }\n1022: \n1023: function isInside(parent, child) {\n1024:   const relative = path.relative(parent, child);\n1025:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n1026: }\n1027: \n1028: function enforceStandaloneCodeGraphDb(actions) {\n1029:   const current = process.env.SPECKIT_CODE_GRAPH_DB_DIR;\n1030:   const resolvedCurrent = current ? path.resolve(current) : null;\n1031:   const resolvedCanonical = path.resolve(canonicalCodeGraphDbDir);\n1032:   const specKitRoot = path.resolve(kitDir);\n1033: \n1034:   if (!resolvedCurrent || isInside(specKitRoot, resolvedCurrent)) {\n1035:     process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n1036:     actions.push(\n1037:       `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n1038:     );\n1039:   }\n1040: }\n1041: \n1042: function run(command, args, options = {}) {\n1043:   const result = spawnSync(command, args, {\n1044:     cwd: options.cwd || root,\n1045:     env: process.env,\n1046:     encoding: 'utf8',\n1047:     stdio: ['ignore', 'pipe', 'pipe'],\n1048:   });\n1049: \n1050:   if (result.stdout) {\n1051:     process.stderr.write(result.stdout);\n1052:   }\n1053:   if (result.stderr) {\n1054:     process.stderr.write(result.stderr);\n1055:   }\n1056:   if (result.error) {\n1057:     throw result.error;\n1058:   }\n1059:   if (result.status !== 0) {\n1060:     throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n1061:   }\n1062: }\n1063: \n1064: function ensureLayout(actions) {\n1065:   if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n1066:     fs.renameSync(legacySkillDir, skillsDir);\n1067:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n1068:     actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n1069:     refreshPaths();\n1070:     return;\n1071:   }\n1072: \n1073:   if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n1074:     const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n1075:     fs.renameSync(legacySkillDir, backup);\n1076:     fs.symlinkSync('skills', legacySkillDir, 'dir');\n1077:     actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n1078:     refreshPaths();\n1079:     return;\n1080:   }\n1081: \n1082:   // Compatibility symlink `.opencode/skill -> skills` removed; a prior cleanup cleaned\n1083:   // up consumers of the singular path, so the bridge no longer needs to be\n1084:   // recreated on every MCP startup. Migration paths above (rename / move-aside)\n1085:   // still create the symlink when an actual legacy singular dir is present.\n1086: }\n1087: \n1088: function requiredArtifacts() {\n1089:   return [\n1090:     path.join(kitDir, 'mcp_server', 'dist', 'context-server.js'),\n1091:     path.join(kitDir, 'scripts', 'dist', 'graph', 'backfill-graph-metadata.js'),\n1092:     path.join(kitDir, 'scripts', 'dist', 'spec-folder', 'generate-description.js'),\n1093:   ];\n1094: }\n1095: \n1096: function artifactsReady() {\n1097:   return requiredArtifacts().every(exists);\n1098: }\n1099: \n1100: function buildIfNeeded(actions) {\n1101:   if (artifactsReady()) {\n1102:     return;\n1103:   }\n1104: \n1105:   if (!exists(kitDir)) {\n1106:     throw new Error(`system-spec-kit not found at ${rel(kitDir)}`);\n1107:   }\n1108: \n1109:   actions.push('installed dependencies and built @spec-kit/mcp-server plus @spec-kit/scripts');\n1110:   const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n1111:   run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n1112:   run('npm', ['run', 'build', '--workspace=@spec-kit/mcp-server'], { cwd: kitDir });\n1113:   run('npm', ['run', 'build', '--workspace=@spec-kit/scripts'], { cwd: kitDir });\n1114: \n1115:   const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n1116:   if (missing.length > 0) {\n1117:     throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n1118:   }\n1119: }\n1120: \n1121: function getContextServerNodeArgs() {\n1122:   const nodeArgs = [];\n1123:   const rawOldSpaceMb = process.env.SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB;\n1124:   if (rawOldSpaceMb === undefined || rawOldSpaceMb === null || String(rawOldSpaceMb).trim() === '') {\n1125:     return nodeArgs;\n1126:   }\n1127: \n1128:   const parsedOldSpaceMb = Number.parseInt(String(rawOldSpaceMb).trim(), 10);\n1129:   if (!Number.isFinite(parsedOldSpaceMb) || parsedOldSpaceMb <= 0) {\n1130:     log(`ignoring invalid SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB=${JSON.stringify(rawOldSpaceMb)}`);\n1131:     return nodeArgs;\n1132:   }\n1133: \n1134:   nodeArgs.push(`--max-old-space-size=${parsedOldSpaceMb}`);\n1135:   log(`applying context-server V8 old-space cap: ${parsedOldSpaceMb} MB`);\n1136:   return nodeArgs;\n1137: }\n1138: \n1139: function waitForChildExit(child, timeoutMs) {\n1140:   if (!isChildRunning(child)) return Promise.resolve(true);\n1141:   return new Promise((resolve) => {\n1142:     let settled = false;\n1143:     const finish = (exited) => {\n1144:       if (settled) return;\n1145:       settled = true;\n1146:       clearTimeout(timer);\n1147:       child.off('exit', onExit);\n1148:       resolve(exited);\n1149:     };\n1150:     const onExit = () => finish(true);\n1151:     const timer = setTimeout(() => finish(false), timeoutMs);\n1152:     timer.unref?.();\n1153:     child.once('exit', onExit);\n1154:   });\n1155: }\n1156: \n1157: // Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n1158: // the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n1159: // snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\n1160: function refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n1161:   return mss.refreshDescendantSnapshot(childPid, runner, {\n1162:     snapshotPids: lastKnownDescendantPids,\n1163:     snapshot: {\n1164:       set: (pids) => {\n1165:         lastKnownDescendantPids = pids;\n1166:       },\n1167:     },\n1168:   });\n1169: }\n1170: \n1171: // Reap an orphaned sidecar on crash-loop give-up. The dominant RSS risk lives in a\n1172: // forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n1173: // anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n1174: // still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n1175: // (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n1176: // bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\n1177: function reapProcessTreeGroups(childPid, options = {}) {\n1178:   return mss.reapProcessTreeGroups(childPid, {\n1179:     ...options,\n1180:     snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n1181:     signal: options.signal || signalProcess,\n1182:   });\n1183: }\n1184: \n1185: // Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n1186: // reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n1187: // closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\n1188: async function recycleDaemonInPlace(graceMs, deps = {}) {\n1189:   const ctx = {\n1190:     getContextChild: deps.getContextChild ?? (() => childProcess),\n1191:     hfControl: deps.hfControl ?? hfControl,\n1192:     isChildRunning: deps.isChildRunning ?? isChildRunning,\n1193:     waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n1194:     clearLease: deps.clearLease ?? clearLeaseFile,\n1195:     clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n1196:     isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n1197:     setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n1198:     log: deps.log ?? log,\n1199:   };\n\n(Showing lines 680-1199 of 1882. Use offset=1200 to continue.)\n</content>","metadata":{"preview":"const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n\n// The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n// successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n// child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n// DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n// guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.\nfunction uncleanShutdownMarkerPath() {\n  // Mirror the daemon's full path precedence, not just MEMORY_DB_PATH:\n  // the daemon resolves its database dir from SPEC_KIT_DB_DIR /\n  // SPECKIT_DB_DIR before falling back to the packaged default, and the\n  // marker lives beside whatever database it actually opened. Checking the\n  // static dir under a dir override silently forfeits clean-close detection.\n  const fileOverride = process.env.MEMORY_DB_PATH?.trim();\n  if (fileOverride) {\n    return path.join(path.dirname(fileOverride), UNCLEAN_SHUTDOWN_MARKER);\n  }\n  const dirOverride = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n  const dir = dirOverride ? path.resolve(root, dirOverride) : resolvedDbDir();\n  return path.join(dir, UNCLEAN_SHUTDOWN_MARKER);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n\n// The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n// successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n// child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n// DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n// guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.\nfunction uncleanShutdownMarkerPath() {\n  // Mirror the daemon's full path precedence, not just MEMORY_DB_PATH:\n  // the daemon resolves its database dir from SPEC_KIT_DB_DIR /\n  // SPECKIT_DB_DIR before falling back to the packaged default, and the\n  // marker lives beside whatever database it actually opened. Checking the\n  // static dir under a dir override silently forfeits clean-close detection.\n  const fileOverride = process.env.MEMORY_DB_PATH?.trim();\n  if (fileOverride) {\n    return path.join(path.dirname(fileOverride), UNCLEAN_SHUTDOWN_MARKER);\n  }\n  const dirOverride = process.env.SPEC_KIT_DB_DIR?.trim() || process.env.SPECKIT_DB_DIR?.trim();\n  const dir = dirOverride ? path.resolve(root, dirOverride) : resolvedDbDir();\n  return path.join(dir, UNCLEAN_SHUTDOWN_MARKER);\n}\n\nfunction uncleanMarkerPresent() {\n  try {\n    return fs.existsSync(uncleanShutdownMarkerPath());\n  } catch {\n    return false;\n  }\n}\n\n// A reap is a verified clean DB handoff only when the child exited on SIGTERM (not SIGKILL) AND the\n// clean-shutdown marker is gone (close_db ran its checkpoint + close). Anything else means the\n// replacement daemon will open a possibly-dirty shadow and must rebuild it at boot.\nfunction cleanCloseAfterReap({ killed, markerPresent }) {\n  return !killed && !markerPresent;\n}\n\nasync function reapLeaseChildBeforeRespawn(childPid) {\n  const liveness = processLiveness(childPid);\n  if (liveness === 'unknown-eperm') {\n    return { allowed: false, reason: 'child-liveness-unknown-eperm' };\n  }\n  if (liveness === 'dead') {\n    return {\n      allowed: true,\n      reaped: false,\n      cleanClose: cleanCloseAfterReap({ killed: false, markerPresent: uncleanMarkerPresent() }),\n      reason: 'child-already-dead',\n    };\n  }\n\n  log(`reaping recorded context-server child pid ${childPid} before respawn`);\n  signalProcess(childPid, 'SIGTERM');\n  reapProcessTreeGroups(childPid, { signal: signalProcess });\n  const exitedAfterTerm = await waitForPidExit(childPid, RESPAWN_REAP_GRACE_MS);\n  let killed = false;\n  if (!exitedAfterTerm) {\n    log(`context-server child pid ${childPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n    signalProcess(childPid, 'SIGKILL');\n    const exitedAfterKill = await waitForPidExit(childPid, 1000);\n    killed = true;\n    if (!exitedAfterKill) {\n      // The child outlived SIGKILL within the grace window (uninterruptible state, or a pid we can\n      // no longer confirm). Refuse to hand the database to a replacement while the recorded writer\n      // may still be alive, so a caller never spawns a second writer onto the same WAL.\n      log(`context-server child pid ${childPid} did not exit after SIGKILL within grace; refusing respawn`);\n      return { allowed: false, reason: 'child-kill-unconfirmed' };\n    }\n  }\n\n  // Clean-close barrier: verify the child closed the DB cleanly (marker removed) before handing the\n  // DB to a replacement daemon. If it did not (graceful close timed out, or we had to SIGKILL), log\n  // it so the corruption window is visible — the replacement daemon's boot FTS auto-heal rebuilds the\n  // shadow. We never block respawn on this: a missing daemon is worse than a self-healing one.\n  const markerPresent = uncleanMarkerPresent();\n  const cleanClose = cleanCloseAfterReap({ killed, markerPresent });\n  if (!cleanClose) {\n    log(`reaped context-server child pid ${childPid} WITHOUT a verified clean DB close (killed=${killed}, uncleanMarkerPresent=${markerPresent}); the replacement daemon will rebuild the FTS shadow at boot`);\n  }\n  return { allowed: true, reaped: true, cleanClose, reason: 'child-reaped' };\n}\n\nasync function reapOwnerBeforeRespawn(ownerPid) {\n  const liveness = processLiveness(ownerPid);\n  if (liveness === 'unknown-eperm') {\n    return { allowed: false, reason: 'owner-liveness-unknown-eperm' };\n  }\n  if (liveness === 'dead') {\n    return { allowed: true, reason: 'owner-already-dead' };\n  }\n\n  // A socket probe cannot distinguish a genuinely-dead daemon from one that merely\n  // refused the connection at its client cap (both look \"closed before reply\"). Before\n  // killing a process that is still ALIVE, require the owner lease to be heartbeat-stale\n  // too: a daemon that has refreshed its lease within its TTL is serving clients, not\n  // dead, and must never be reaped on a socket-probe-only verdict regardless of cap.\n  const currentOwner = readOwnerLeaseFile();\n  if (currentOwner?.ownerPid === ownerPid && classifyOwnerLease(currentOwner) === 'live-owner') {\n    log(`spec-memory owner pid ${ownerPid} is heartbeat-fresh (live-owner); refusing socket-probe reap (likely cap-refusal, not death)`);\n    return { allowed: false, reason: 'owner-heartbeat-fresh' };\n  }\n\n  log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n  signalProcess(ownerPid, 'SIGTERM');\n  const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n  if (!exitedAfterTerm) {\n    log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n    signalProcess(ownerPid, 'SIGKILL');\n    await waitForPidExit(ownerPid, 1000);\n  }\n  return { allowed: true, reason: 'owner-reaped' };\n}\n\nasync function respawnAfterDeadSocket(leaseResult, decision) {\n  if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n    return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n  }\n\n  const ownerPid = leaseResult.ownerPid;\n  if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n    log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n    return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };\n  }\n\n  const lease = readLeaseFile(leaseResult.legacyPath || leasePath());\n  const childPid = lease?.childPid;\n  if (!Number.isInteger(childPid) || childPid <= 0) {\n    log('confirmed-dead socket but lease has no childPid; child-pid gate keeps respawn inert');\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-child-pid)');\n    return { action: 'report', reason: 'missing-child-pid', socketPath: decision.socketPath };\n  }\n\n  // A daemon mid-maintenance (e.g. a background index scan) legitimately fails the\n  // deep liveness probe because its event loop is busy, not dead. If it holds a\n  // fresh marker naming this exact live child, refuse the respawn and leave it\n  // running. The marker lapses if the daemon is genuinely wedged (it can no longer\n  // refresh it), so a real death still respawns once the marker expires. Checked\n  // before the respawn lock and any reap so a bail unwinds nothing.\n  const deadSocketMarker = readMaintenanceMarker(maintenanceMarkerDir());\n  if (shouldAdoptDespiteProbe({ marker: deadSocketMarker, childPid, childLiveness: processLiveness(childPid) })) {\n    log(`confirmed-dead socket but child pid ${childPid} holds a fresh maintenance marker (activeUntil ${new Date(deadSocketMarker.activeUntilMs).toISOString()}); refusing respawn (busy, not dead)`);\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-maintenance-active)');\n    return { action: 'report', reason: 'maintenance-active', socketPath: decision.socketPath };\n  }\n\n  let bootstrapLockHeld = false;\n  let respawnLock = null;\n  try {\n    bootstrapLockHeld = await acquireBootstrapLock({ requireLock: true });\n    respawnLock = acquireRespawnLockFile();\n    if (!respawnLock.acquired) {\n      log(`dead-socket respawn skipped; another launcher owns ${rel(respawnLock.path)}`);\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n      return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n    }\n\n    const currentOwner = readOwnerLeaseFile();\n    if (currentOwner?.ownerPid !== ownerPid) {\n      log('dead-socket respawn skipped; spec-memory owner lease changed while waiting for respawn lock');\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n      return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n    }\n\n    const currentLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n    if (currentLease?.pid !== leaseResult.ownerPid || currentLease?.childPid !== childPid) {\n      log('dead-socket respawn skipped; lease changed while waiting for respawn lock');\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-superseded)');\n      return { action: 'report', reason: 'respawn-superseded', socketPath: decision.socketPath };\n    }\n\n    const ownerReapResult = await reapOwnerBeforeRespawn(ownerPid);\n    if (!ownerReapResult.allowed) {\n      log(`dead-socket respawn skipped; ${ownerReapResult.reason} for ownerPid=${ownerPid}`);\n      writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${ownerReapResult.reason})`);\n      return { action: 'report', reason: ownerReapResult.reason, socketPath: decision.socketPath };\n    }\n\n    clearOwnerLeaseFileIfOwner(ownerPid);\n    const ownerLease = buildOwnerLease(process.pid);\n    if (!writeOwnerLeaseFileExclusive(ownerLease)) {\n      const holder = readOwnerLeaseFile();\n      log(`dead-socket respawn skipped; another launcher owns spec-memory owner lease pid=${holder?.ownerPid ?? 'unknown'}`);\n      writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-owned)');\n      return { action: 'report', reason: 'respawn-lock-held', socketPath: decision.socketPath };\n    }\n    ownerLeasePid = process.pid;\n\n    const reapResult = await reapLeaseChildBeforeRespawn(childPid);\n    if (!reapResult.allowed) {\n      log(`dead-socket respawn skipped; ${reapResult.reason} for childPid=${childPid}`);\n      writeLeaseHeldDiagnostic(leaseResult, ` (dead-socket-${reapResult.reason})`);\n      return { action: 'report', reason: reapResult.reason, socketPath: decision.socketPath };\n    }\n\n    buildIfNeeded([]);\n    leaseStartedAt = new Date().toISOString();\n    writeLeaseFile();\n    launchServer();\n    return { action: 'respawn', reason: 'spawned', socketPath: decision.socketPath };\n  } finally {\n    releaseRespawnLockFile(respawnLock);\n    if (bootstrapLockHeld) {\n      fs.rmSync(lockDir, { recursive: true, force: true });\n    }\n  }\n}\n\nasync function bridgeOrReportLeaseHeld(leaseResult) {\n  const readiness = bridgeReadiness(leaseResult);\n  if (!readiness.ready) {\n    writeLeaseHeldJsonRpcError(leaseResult, readiness.reason);\n    return { action: 'report', reason: readiness.reason };\n  }\n  const { maybeBridgeLeaseHolder } = loadBridgeModule();\n  const decision = await maybeBridgeLeaseHolder({\n    serviceName: 'mk-spec-memory',\n    leaseResult,\n    loggerPrefix: 'mk-spec-memory-launcher',\n    dbDir: resolvedDbDir(),\n    bridge: bridgeStdioThroughSessionProxy,\n  });\n  if (decision && decision.action === 'respawn') {\n    return await respawnAfterDeadSocket(leaseResult, decision);\n  }\n  return decision;\n}\n\nasync function bridgeOrReportLeaseHeldAndExit(leaseResult) {\n  const decision = await bridgeOrReportLeaseHeld(leaseResult);\n  if (!decision || decision.action === 'report') {\n    clearOwnerLeaseFile();\n    process.exit(0);\n  }\n  return decision;\n}\n\nfunction resolveModelServerSocketPath(env = process.env, options = {}) {\n  return mss.resolveModelServerSocketPath(env, {\n    ...options,\n    dbDir: options.dbDir || resolvedDbDir,\n  });\n}\n\nfunction getContextServerPid() {\n  return isChildRunning(childProcess) ? childProcess.pid : null;\n}\n\n// Pure lease-payload builder (exported for tests). `childPid`, `modelServerPid`, and `socketPath`\n// are ADDITIVE fields; existing readers consume only pid/startedAt/ownerPid and ignore the extras.\n// `socketPath` records the IPC path this owner actually listens on so a secondary launcher prefers\n// it over recomputing one that can diverge under a different SPECKIT_IPC_SOCKET_DIR.\nfunction buildLeaseObject(childPid = null, startedAt = leaseStartedAt, modelServerPid = null, socketPath = null) {\n  return buildSharedLeaseObject(childPid, startedAt || new Date().toISOString(), modelServerPid, socketPath);\n}\n\nfunction writeLeaseFile(childPid = getContextServerPid(), modelServerPid = hfControl.getPid()) {\n  if (!leaseStartedAt) leaseStartedAt = new Date().toISOString();\n  const payload = buildLeaseObject(childPid, leaseStartedAt, modelServerPid, resolveSessionProxySocketPath());\n  return writeAtomicJsonFile(leasePath(), payload, 'lease write');\n}\n\nfunction sharedModelServerPidPath(socketPath = resolveModelServerSocketPath()) {\n  const pidDir = socketPath.startsWith('tcp://') ? resolvedDbDir() : path.dirname(socketPath);\n  return path.join(pidDir, HF_MODEL_SERVER_PID_FILE_NAME);\n}\n\nfunction writeSharedModelServerPid(pid) {\n  const socketPath = resolveModelServerSocketPath();\n  const pidPath = sharedModelServerPidPath(socketPath);\n  if (!Number.isInteger(pid) || pid <= 0) {\n    try {\n      fs.unlinkSync(pidPath);\n    } catch (error) {\n      if (error.code === 'ENOENT') return true;\n      if (isDurableWriteUnavailable(error)) {\n        logDurableWriteUnavailableOnce('shared model-server pid clear', pidPath, error);\n        return false;\n      }\n      throw error;\n    }\n    return true;\n  }\n\n  return writeAtomicJsonFile(pidPath, {\n    pid,\n    startedAt: new Date().toISOString(),\n    ownerLauncher: 'mk-spec-memory',\n    socketPath,\n  }, 'shared model-server pid write');\n}\n\nfunction readSharedModelServerPid() {\n  const pidPath = sharedModelServerPidPath();\n  try {\n    const parsed = JSON.parse(fs.readFileSync(pidPath, 'utf8'));\n    if (Number.isInteger(parsed.pid) && parsed.pid > 0) return parsed.pid;\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Corrupt pid files are treated like absent pid files; the respawn lock still serializes recovery.\n    }\n  }\n\n  const lease = readLeaseFile();\n  return Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0 ? lease.modelServerPid : null;\n}\n\nconst hfControl = mss.createModelServerControl({\n  log,\n  env: process.env,\n  rootDir: root,\n  opencodeDir,\n  dbDir: resolvedDbDir,\n  getLauncherShutdownInProgress: () => launcherShutdownInProgress,\n  onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n  bridge: loadBridgeModule(),\n  writeModelServerPid: (pid) => writeSharedModelServerPid(pid),\n  readModelServerPid: () => readSharedModelServerPid(),\n  writeLease: () => writeLeaseFile(),\n});\n\nfunction clearLeaseFile() {\n  try {\n    const lease = readLeaseFile();\n    if (launcherShutdownInProgress && Number.isInteger(lease?.modelServerPid) && lease.modelServerPid > 0) {\n      try {\n        hfControl.reapProcessTree(lease.modelServerPid);\n      } catch {\n        // Lease cleanup must remain best-effort even if a final process-tree read fails.\n      }\n    }\n    if (lease && lease.pid === process.pid) fs.unlinkSync(leasePath());\n  } catch {\n    // Idempotent cleanup.\n  }\n}\n\nfunction clearAllLeaseFiles() {\n  clearLeaseFile();\n  clearOwnerLeaseFile();\n}\n\nfunction isInside(parent, child) {\n  const relative = path.relative(parent, child);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction enforceStandaloneCodeGraphDb(actions) {\n  const current = process.env.SPECKIT_CODE_GRAPH_DB_DIR;\n  const resolvedCurrent = current ? path.resolve(current) : null;\n  const resolvedCanonical = path.resolve(canonicalCodeGraphDbDir);\n  const specKitRoot = path.resolve(kitDir);\n\n  if (!resolvedCurrent || isInside(specKitRoot, resolvedCurrent)) {\n    process.env.SPECKIT_CODE_GRAPH_DB_DIR = resolvedCanonical;\n    actions.push(\n      `set SPECKIT_CODE_GRAPH_DB_DIR=${rel(resolvedCanonical)} for standalone system-code-graph storage`\n    );\n  }\n}\n\nfunction run(command, args, options = {}) {\n  const result = spawnSync(command, args, {\n    cwd: options.cwd || root,\n    env: process.env,\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'pipe'],\n  });\n\n  if (result.stdout) {\n    process.stderr.write(result.stdout);\n  }\n  if (result.stderr) {\n    process.stderr.write(result.stderr);\n  }\n  if (result.error) {\n    throw result.error;\n  }\n  if (result.status !== 0) {\n    throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);\n  }\n}\n\nfunction ensureLayout(actions) {\n  if (!exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    fs.renameSync(legacySkillDir, skillsDir);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push('promoted .opencode/skill to .opencode/skills and created compatibility symlink');\n    refreshPaths();\n    return;\n  }\n\n  if (exists(skillsDir) && exists(legacySkillDir) && !fs.lstatSync(legacySkillDir).isSymbolicLink()) {\n    const backup = path.join(opencodeDir, `skill_legacy_backup_${new Date().toISOString().replace(/[-:]/g, '').replace(/\\..+/, 'Z')}`);\n    fs.renameSync(legacySkillDir, backup);\n    fs.symlinkSync('skills', legacySkillDir, 'dir');\n    actions.push(`moved legacy .opencode/skill to ${rel(backup)} and created compatibility symlink`);\n    refreshPaths();\n    return;\n  }\n\n  // Compatibility symlink `.opencode/skill -> skills` removed; a prior cleanup cleaned\n  // up consumers of the singular path, so the bridge no longer needs to be\n  // recreated on every MCP startup. Migration paths above (rename / move-aside)\n  // still create the symlink when an actual legacy singular dir is present.\n}\n\nfunction requiredArtifacts() {\n  return [\n    path.join(kitDir, 'mcp_server', 'dist', 'context-server.js'),\n    path.join(kitDir, 'scripts', 'dist', 'graph', 'backfill-graph-metadata.js'),\n    path.join(kitDir, 'scripts', 'dist', 'spec-folder', 'generate-description.js'),\n  ];\n}\n\nfunction artifactsReady() {\n  return requiredArtifacts().every(exists);\n}\n\nfunction buildIfNeeded(actions) {\n  if (artifactsReady()) {\n    return;\n  }\n\n  if (!exists(kitDir)) {\n    throw new Error(`system-spec-kit not found at ${rel(kitDir)}`);\n  }\n\n  actions.push('installed dependencies and built @spec-kit/mcp-server plus @spec-kit/scripts');\n  const installCommand = exists(path.join(kitDir, 'package-lock.json')) ? 'ci' : 'install';\n  run('npm', [installCommand, '--no-audit', '--no-fund', '--silent'], { cwd: kitDir });\n  run('npm', ['run', 'build', '--workspace=@spec-kit/mcp-server'], { cwd: kitDir });\n  run('npm', ['run', 'build', '--workspace=@spec-kit/scripts'], { cwd: kitDir });\n\n  const missing = requiredArtifacts().filter((artifact) => !exists(artifact));\n  if (missing.length > 0) {\n    throw new Error(`bootstrap finished but artifacts are still missing: ${missing.map(rel).join(', ')}`);\n  }\n}\n\nfunction getContextServerNodeArgs() {\n  const nodeArgs = [];\n  const rawOldSpaceMb = process.env.SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB;\n  if (rawOldSpaceMb === undefined || rawOldSpaceMb === null || String(rawOldSpaceMb).trim() === '') {\n    return nodeArgs;\n  }\n\n  const parsedOldSpaceMb = Number.parseInt(String(rawOldSpaceMb).trim(), 10);\n  if (!Number.isFinite(parsedOldSpaceMb) || parsedOldSpaceMb <= 0) {\n    log(`ignoring invalid SPECKIT_CONTEXT_SERVER_MAX_OLD_SPACE_MB=${JSON.stringify(rawOldSpaceMb)}`);\n    return nodeArgs;\n  }\n\n  nodeArgs.push(`--max-old-space-size=${parsedOldSpaceMb}`);\n  log(`applying context-server V8 old-space cap: ${parsedOldSpaceMb} MB`);\n  return nodeArgs;\n}\n\nfunction waitForChildExit(child, timeoutMs) {\n  if (!isChildRunning(child)) return Promise.resolve(true);\n  return new Promise((resolve) => {\n    let settled = false;\n    const finish = (exited) => {\n      if (settled) return;\n      settled = true;\n      clearTimeout(timer);\n      child.off('exit', onExit);\n      resolve(exited);\n    };\n    const onExit = () => finish(true);\n    const timer = setTimeout(() => finish(false), timeoutMs);\n    timer.unref?.();\n    child.once('exit', onExit);\n  });\n}\n\n// Refresh the before-death descendant snapshot from a live process-tree walk. Called periodically by\n// the monitor while the child is alive. On an unknown/permission-denied read (null), the previous\n// snapshot is KEPT (a transient ps failure must not erase the only handle on an orphan-able sidecar).\nfunction refreshDescendantSnapshot(childPid, runner = defaultProcessRowsRunner) {\n  return mss.refreshDescendantSnapshot(childPid, runner, {\n    snapshotPids: lastKnownDescendantPids,\n    snapshot: {\n      set: (pids) => {\n        lastKnownDescendantPids = pids;\n      },\n    },\n  });\n}\n\n// Reap an orphaned sidecar on crash-loop give-up. The dominant RSS risk lives in a\n// forked-detached sidecar GRANDCHILD; on hard daemon death it re-parents to pid 1, so a fresh walk\n// anchored on the (now-dead, ps-absent) childPid finds nothing. We therefore reap the UNION of any\n// still-live childPid subtree (the not-yet-reparented case) and the before-death snapshot\n// (`lastKnownDescendantPids`), filtered to currently-alive, signalable pids. The signal-0 alive gate\n// bounds (but cannot fully eliminate) pid-reuse risk; the snapshot is at most one monitor tick old.\nfunction reapProcessTreeGroups(childPid, options = {}) {\n  return mss.reapProcessTreeGroups(childPid, {\n    ...options,\n    snapshotPids: options.snapshotPids ?? lastKnownDescendantPids,\n    signal: options.signal || signalProcess,\n  });\n}\n\n// Dependency seam mirrors the launcher's other supervision helpers (startRssWatchdog,\n// reapProcessTreeGroups): production callers pass only graceMs, so deps default to the live\n// closures and runtime behavior is unchanged; tests inject fakes to assert lease handling.\nasync function recycleDaemonInPlace(graceMs, deps = {}) {\n  const ctx = {\n    getContextChild: deps.getContextChild ?? (() => childProcess),\n    hfControl: deps.hfControl ?? hfControl,\n    isChildRunning: deps.isChildRunning ?? isChildRunning,\n    waitForChildExit: deps.waitForChildExit ?? waitForChildExit,\n    clearLease: deps.clearLease ?? clearLeaseFile,\n    clearWatchdog: deps.clearWatchdog ?? (() => { if (rssWatchdogTimer) clearInterval(rssWatchdogTimer); }),\n    isRecycleInProgress: deps.isRecycleInProgress ?? (() => rssBreachSelfExitInProgress),\n    setRecycleInProgress: deps.setRecycleInProgress ?? ((value) => { rssBreachSelfExitInProgress = value; }),\n    log: deps.log ?? log,\n  };","lineStart":680,"lineEnd":1199,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781761501814,"end":1781761501819}},"metadata":{"openai":{"itemId":"fc_00ff612f68860895016a3385ddac608191baa64c540ed6af13"}},"id":"prt_ed942ea75001X2W367k9VQfB2c","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed942b79b001rlj0G50T58wap8"}}
{"type":"tool_use","timestamp":1781761501824,"sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","part":{"type":"tool","tool":"read","callID":"call_7aWieuYSJkCV9yyLwWaVXvny","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1200,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1200:   if (ctx.isRecycleInProgress()) return;\n1201:   ctx.setRecycleInProgress(true);\n1202:   ctx.clearWatchdog();\n1203:   ctx.hfControl.clearTimers();\n1204:   await ctx.hfControl.stopDemandListener();\n1205:   const modelServerChild = ctx.hfControl.getChild();\n1206:   if (ctx.isChildRunning(modelServerChild)) {\n1207:     ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n1208:     modelServerChild.kill('SIGTERM');\n1209:     ctx.hfControl.reapProcessTree(modelServerChild.pid);\n1210:     const modelExitedAfterTerm = await ctx.waitForChildExit(modelServerChild, graceMs);\n1211:     if (!modelExitedAfterTerm && ctx.isChildRunning(modelServerChild)) {\n1212:       ctx.log(`hf-model-server pid ${modelServerChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n1213:       modelServerChild.kill('SIGKILL');\n1214:       await ctx.waitForChildExit(modelServerChild, 1000);\n1215:     }\n1216:   }\n1217:   const contextChild = ctx.getContextChild();\n1218:   if (!ctx.isChildRunning(contextChild)) {\n1219:     ctx.clearLease();\n1220:     ctx.setRecycleInProgress(false);\n1221:     return;\n1222:   }\n1223: \n1224:   ctx.log(`RSS ceiling sustained; sending SIGTERM to context-server pid ${contextChild.pid} before daemon recycle`);\n1225:   contextChild.kill('SIGTERM');\n1226:   const exitedAfterTerm = await ctx.waitForChildExit(contextChild, graceMs);\n1227:   if (!exitedAfterTerm && ctx.isChildRunning(contextChild)) {\n1228:     ctx.log(`context-server pid ${contextChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n1229:     contextChild.kill('SIGKILL');\n1230:     await ctx.waitForChildExit(contextChild, 1000);\n1231:   }\n1232:   // Keep the lease held across an in-place recycle. The launcher process stays alive and the\n1233:   // lease is keyed on its (still-live) pid, so the replacement daemon is respawned by the child\n1234:   // exit handler's scheduleRelaunch backoff. Clearing the lease here would open a window — until\n1235:   // relaunch rewrites childPid — where a concurrent launcher reads no lease and passes the\n1236:   // single-writer gate, producing a competing daemon. Relaunch (writeLeaseFile) rewrites childPid.\n1237: }\n1238: \n1239: function startRssWatchdog(childPid, options = {}) {\n1240:   return mss.startRssWatchdog(childPid, {\n1241:     ...options,\n1242:     timerState: options.timerState || {\n1243:       get: () => rssWatchdogTimer,\n1244:       set: (timer) => {\n1245:         rssWatchdogTimer = timer;\n1246:       },\n1247:     },\n1248:     snapshot: options.snapshot || {\n1249:       set: (pids) => {\n1250:         lastKnownDescendantPids = pids;\n1251:       },\n1252:     },\n1253:     log: options.log || log,\n1254:     onBreach: options.onBreach || ((breachConfig) => recycleDaemonInPlace(breachConfig.graceMs)),\n1255:   });\n1256: }\n1257: \n1258: // Launcher-local factory that pre-seeds the launcher-aware defaults (writeLease/shouldExitLauncher/\n1259: // onRssBreach) the shared lib intentionally leaves as generic no-ops. Keeps the launcher's exported\n1260: // createModelServerSupervisor + launchModelServer(options) seam byte-equivalent to pre-extraction HEAD.\n1261: // Explicit caller options still win via the trailing spread for targeted writeLease injection.\n1262: function createModelServerSupervisor(options = {}) {\n1263:   return baseCreateModelServerSupervisor({\n1264:     writeLease: () => writeLeaseFile(),\n1265:     shouldExitLauncher: () => launcherShutdownInProgress,\n1266:     onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n1267:     ...options,\n1268:   });\n1269: }\n1270: \n1271: function launchModelServer(options = null) {\n1272:   if (options && typeof options === 'object') {\n1273:     return createModelServerSupervisor(options).launch();\n1274:   }\n1275:   return hfControl.launch();\n1276: }\n1277: \n1278: function startModelServerDemandListener(options = {}) {\n1279:   return hfControl.startDemandListener(options);\n1280: }\n1281: \n1282: function stopModelServerDemandListener() {\n1283:   return hfControl.stopDemandListener();\n1284: }\n1285: \n1286: const BOOTSTRAP_LOCK_OWNER_FILE = 'owner.pid';\n1287: \n1288: // Returns the pid recorded inside the lock dir, or null when no readable pid\n1289: // stamp exists (legacy lock dirs, or a holder that died before stamping).\n1290: function readBootstrapLockOwnerPid() {\n1291:   try {\n1292:     const raw = fs.readFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), 'utf8').trim();\n1293:     const pid = Number.parseInt(raw, 10);\n1294:     return Number.isInteger(pid) && pid > 0 ? pid : null;\n1295:   } catch {\n1296:     return null;\n1297:   }\n1298: }\n1299: \n1300: // Reclaim a stale bootstrap lockdir. A lock is reclaimable as soon as its\n1301: // recorded holder is provably dead; the mtime TTL is only a fallback for lock\n1302: // dirs with no readable pid stamp (legacy dirs) or a holder whose liveness\n1303: // cannot be determined. Without the dead-holder check, a holder killed less than\n1304: // BOOTSTRAP_LOCK_STALE_MS ago wedges every requireLock respawn for the full wait\n1305: // deadline (the TTL exceeds the deadline by design for a slow-but-live build).\n1306: function removeStaleBootstrapLock(staleMs = BOOTSTRAP_LOCK_STALE_MS) {\n1307:   let ageMs;\n1308:   try {\n1309:     ageMs = Date.now() - fs.statSync(lockDir).mtimeMs;\n1310:   } catch (error) {\n1311:     if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;\n1312:     throw error;\n1313:   }\n1314:   const ownerPid = readBootstrapLockOwnerPid();\n1315:   const ownerDead = ownerPid !== null && processLiveness(ownerPid) === 'dead';\n1316:   if (!ownerDead && ageMs <= staleMs) {\n1317:     return false;\n1318:   }\n1319:   // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n1320:   // racer wins the rename; a successor that mkdir'd a fresh lockDir after our stat\n1321:   // creates a new inode that our rename/rmSync cannot touch, so we never delete a\n1322:   // live successor lock. A losing racer's rename throws ENOENT and falls through to\n1323:   // the outer retry.\n1324:   const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n1325:   try {\n1326:     fs.renameSync(lockDir, staleClaim);\n1327:     fs.rmSync(staleClaim, { recursive: true, force: true });\n1328:     const reason = ownerDead ? `dead holder pid=${ownerPid}` : `mtime ${Math.round(ageMs / 1000)}s old`;\n1329:     log(`reclaiming stale bootstrap lock ${rel(lockDir)} (${reason})`);\n1330:     return true;\n1331:   } catch (error) {\n1332:     if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;\n1333:     throw error;\n1334:   }\n1335: }\n1336: \n1337: async function acquireBootstrapLock(options = {}) {\n1338:   const requireLock = options.requireLock === true;\n1339:   fs.mkdirSync(dbDir, { recursive: true });\n1340:   const deadline = Date.now() + (options.timeoutMs ?? 120000);\n1341:   const staleMs = options.staleMs ?? BOOTSTRAP_LOCK_STALE_MS;\n1342:   const retrySleepMs = options.retrySleepMs ?? 1000;\n1343:   while (true) {\n1344:     try {\n1345:       fs.mkdirSync(lockDir);\n1346:       // Stamp the holder pid so a later launcher can reclaim this lock the\n1347:       // instant we die, instead of waiting out the mtime TTL. Best-effort: a\n1348:       // failed stamp degrades to the TTL path, never blocks acquisition.\n1349:       try {\n1350:         fs.writeFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), String(process.pid), { mode: 0o600 });\n1351:       } catch { /* TTL fallback covers an unstamped lock */ }\n1352:       return true;\n1353:     } catch (error) {\n1354:       if (error.code !== 'EEXIST') {\n1355:         throw error;\n1356:       }\n1357:       if (removeStaleBootstrapLock(staleMs)) {\n1358:         continue;\n1359:       }\n1360:       if (artifactsReady() && !requireLock) {\n1361:         return false;\n1362:       }\n1363:       if (Date.now() > deadline) {\n1364:         throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n1365:       }\n1366:       await sleep(retrySleepMs);\n1367:     }\n1368:   }\n1369: }\n1370: \n1371: function launchServer() {\n1372:   if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n1373:     log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n1374:     return false;\n1375:   }\n1376:   if (shouldSkipLaunch(childProcess)) {\n1377:     log('launchServer skipped: a context-server child is already running in this launcher process');\n1378:     return false;\n1379:   }\n1380:   if (!crashLoopGuard) crashLoopGuard = createCrashLoopGuard(getCrashLoopConfig());\n1381:   if (supervisorRelaunchTimer) {\n1382:     clearTimeout(supervisorRelaunchTimer);\n1383:     supervisorRelaunchTimer = null;\n1384:   }\n1385:   const server = path.join(kitDir, 'mcp_server', 'dist', 'context-server.js');\n1386:   const nodeArgs = getContextServerNodeArgs();\n1387:   const reelectionEnabled = daemonReelectionEnabled();\n1388:   const spawnIo = contextServerSpawnIo(reelectionEnabled);\n1389:   childProcess = spawn(process.execPath, [...nodeArgs, server], {\n1390:     cwd: root,\n1391:     env: {\n1392:       ...process.env,\n1393:       SPECKIT_BACKEND_ONLY: '1',\n1394:     },\n1395:     stdio: spawnIo.stdio,\n1396:     detached: spawnIo.detached,\n1397:   });\n1398:   // Re-election only: let the launcher exit without keeping the detached daemon tethered to it.\n1399:   if (reelectionEnabled) childProcess.unref();\n1400:   const childPid = childProcess.pid;\n1401:   const refreshed = refreshOwnerLeaseFile(process.pid);\n1402:   if (!refreshed) {\n1403:     log('owner lease refresh failed after child spawn; launcher pid remains the recorded owner');\n1404:   }\n1405:   startOwnerLeaseHeartbeat(process.pid);\n1406:   writeLeaseFile(childPid);\n1407:   startRssWatchdog(childPid);\n1408: \n1409:   childProcess.on('exit', (code, signal) => {\n1410:     if (launcherShutdownInProgress) {\n1411:       return;\n1412:     }\n1413:     if (code === EXIT_DB_LOCK_HELD) {\n1414:       void handleDbLockHeldChildExit();\n1415:       return;\n1416:     }\n1417:     const result = superviseChildExit(\n1418:       { code, signal, childPid, intentional: false },\n1419:       {\n1420:         crashLoopGuard,\n1421:         clearLease: clearAllLeaseFiles,\n1422:         reapProcessGroup: reapProcessTreeGroups,\n1423:         mirrorSignal: (exitSignal) => process.kill(process.pid, exitSignal),\n1424:         exit: (exitCode) => process.exit(exitCode),\n1425:         scheduleRelaunch: (backoffMs) => {\n1426:           log(`context-server child exited code=${code ?? 'null'} signal=${signal ?? 'null'}; relaunching in ${backoffMs}ms`);\n1427:           supervisorRelaunchTimer = setTimeout(() => {\n1428:             // Owner-disposal race guard: by the time the backoff fires, re-check that this\n1429:             // launcher is still live AND its owning runtime is still present. Respawning the\n1430:             // daemon under a disposing session is what produced the SIGTERM/relaunch flap that\n1431:             // dropped every bridged session's transport. Crash-recovery and RSS-recycle are\n1432:             // unaffected — both run with the owning runtime alive and no shutdown in progress.\n1433:             if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) {\n1434:               log('relaunch aborted: launcher shutting down or owning runtime gone; releasing lease and exiting');\n1435:               clearAllLeaseFiles();\n1436:               process.exit(0);\n1437:               return;\n1438:             }\n1439:             launchServer();\n1440:           }, backoffMs);\n1441:           supervisorRelaunchTimer.unref?.();\n1442:         },\n1443:       },\n1444:     );\n1445:     if (result.action === 'give-up') {\n1446:       log(`context-server crash loop detected after ${result.deathsInWindow} deaths; clearing lease and mirroring child exit`);\n1447:     }\n1448:   });\n1449: \n1450:   childProcess.on('error', (error) => {\n1451:     log(error.stack || error.message);\n1452:     process.exit(1);\n1453:   });\n1454:   if (rssBreachSelfExitInProgress) {\n1455:     rssBreachSelfExitInProgress = false;\n1456:   }\n1457:   return true;\n1458: }\n1459: \n1460: // Pure decision for the exit-86 flow (exported for tests). A lease whose\n1461: // owner is THIS launcher is NOT a bridge target: in supervised mode the\n1462: // pid-lease records the launcher's own pid, so after its child exits 86 the\n1463: // lease still reads \"held by a live owner\" — us. Bridging would deep-probe\n1464: // our own dead socket and route into a self-reap. Only a DIFFERENT live\n1465: // owner is bridgeable; a self-held lease means a non-daemon process (e.g. a\n1466: // standalone save mid-run) owns the database lock, so retry in place.\n1467: function decideDbLockHeldAction({ leaseHeld, leaseOwnerPid, selfPid, attempt, maxRetries }) {\n1468:   if (attempt > maxRetries + 2) return { action: 'report', reason: 'db-lock-held-persistent' };\n1469:   if (leaseHeld && leaseOwnerPid !== selfPid) return { action: 'bridge' };\n1470:   if (attempt <= maxRetries) return { action: 'retry', backoffMs: 2000 * 2 ** (attempt - 1) };\n1471:   return { action: 'report', reason: 'db-lock-held' };\n1472: }\n1473: \n1474: // The daemon refused to become a second writer on a database another live\n1475: // process holds. Prefer bridging to that owner; when the holder is not a\n1476: // bridgeable daemon (e.g. a maintenance script mid-run), retry the launch a\n1477: // few times so a short-lived holder can finish, then report and exit clean.\n1478: async function handleDbLockHeldChildExit() {\n1479:   dbLockHeldRetries += 1;\n1480:   const leaseResult = isLeaseHeld();\n1481:   const decision = decideDbLockHeldAction({\n1482:     leaseHeld: leaseResult.held,\n1483:     leaseOwnerPid: leaseResult.ownerPid,\n1484:     selfPid: process.pid,\n1485:     attempt: dbLockHeldRetries,\n1486:     maxRetries: DB_LOCK_HELD_MAX_RETRIES,\n1487:   });\n1488:   if (decision.action === 'bridge') {\n1489:     log(`context-server exited: database single-writer lock held; bridging to live owner pid=${leaseResult.ownerPid}`);\n1490:     await bridgeOrReportLeaseHeldAndExit(leaseResult);\n1491:     return;\n1492:   }\n1493:   if (decision.action === 'retry') {\n1494:     log(`database single-writer lock held by a non-bridgeable holder; retrying launch in ${decision.backoffMs}ms (attempt ${dbLockHeldRetries}/${DB_LOCK_HELD_MAX_RETRIES})`);\n1495:     if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n1496:     supervisorRelaunchTimer = setTimeout(() => {\n1497:       // Abort if the owning runtime vanished (shutdown in progress, or the launcher\n1498:       // was reparented to init without a SIGTERM) — same guard as the primary\n1499:       // backoff-relaunch path, so neither relaunches a daemon under a disposed session.\n1500:       if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) return;\n1501:       launchServer();\n1502:     }, decision.backoffMs);\n1503:     if (supervisorRelaunchTimer.unref) supervisorRelaunchTimer.unref();\n1504:     return;\n1505:   }\n1506:   log('database single-writer lock still held after launch retries; reporting and exiting');\n1507:   writeLeaseHeldJsonRpcError(\n1508:     { ownerPid: leaseResult.ownerPid ?? 'unknown', startedAt: leaseResult.startedAt ?? new Date().toISOString() },\n1509:     decision.reason,\n1510:   );\n1511:   clearAllLeaseFiles();\n1512:   process.exit(0);\n1513: }\n1514: \n1515: async function shutdownLauncherForSignal(signal) {\n1516:   if (launcherShutdownInProgress) return;\n1517:   launcherShutdownInProgress = true;\n1518:   if (rssWatchdogTimer) clearInterval(rssWatchdogTimer);\n1519:   if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n1520:   clearOwnerLeaseHeartbeat();\n1521:   hfControl.clearTimers();\n1522:   await hfControl.stopDemandListener();\n1523: \n1524:   // Re-election release path (on by default): release the detached context-server for a live secondary to adopt\n1525:   // instead of killing it. Reap only the non-adoptable model-server, KEEP the daemon lease (its socket\n1526:   // stays findable for adoption), drop only OWNERSHIP, and exit without killing the daemon. When the\n1527:   // flag is off this branch is skipped and the original kill path below runs unchanged.\n1528:   if (shouldReleaseDaemonForReelection({ enabled: daemonReelectionEnabled(), hasLiveDaemon: isChildRunning(childProcess) })) {\n1529:     const releasedModelServer = hfControl.getChild();\n1530:     if (isChildRunning(releasedModelServer)) {\n1531:       hfControl.reapProcessTree(releasedModelServer.pid);\n1532:       releasedModelServer.kill(signal);\n1533:       // Escalate to SIGKILL if the non-adoptable model-server does not exit within the grace window,\n1534:       // so the release path does not leave a wedged sidecar behind on its way out.\n1535:       const exited = await waitForChildExit(releasedModelServer, RESPAWN_REAP_GRACE_MS);\n1536:       if (!exited && isChildRunning(releasedModelServer)) {\n1537:         releasedModelServer.kill('SIGKILL');\n1538:       }\n1539:     }\n1540:     log('daemon re-election: releasing context-server for adoption (not killing); dropping ownership lease only');\n1541:     // The process 'exit' handler clears BOTH leases; detach it first so the daemon lease (its socket\n1542:     // path) survives for a secondary to adopt. Ownership is still dropped explicitly below.\n1543:     process.removeListener('exit', clearAllLeaseFiles);\n1544:     clearOwnerLeaseFile();\n1545:     process.exit(0);\n1546:     return;\n1547:   }\n1548: \n1549:   const children = [];\n1550:   if (isChildRunning(childProcess)) {\n1551:     children.push({ child: childProcess, label: 'context-server' });\n1552:   }\n1553:   const modelServerChild = hfControl.getChild();\n1554:   if (isChildRunning(modelServerChild)) {\n1555:     children.push({ child: modelServerChild, label: 'hf-model-server' });\n1556:   }\n1557: \n1558:   if (children.length === 0) {\n1559:     clearAllLeaseFiles();\n1560:     process.exit(128);\n1561:     return;\n1562:   }\n1563: \n1564:   for (const { child, label } of children) {\n1565:     if (label === 'hf-model-server') {\n1566:       hfControl.reapProcessTree(child.pid);\n1567:     }\n1568:     child.kill(signal);\n1569:   }\n1570: \n1571:   const exited = await Promise.race([\n1572:     Promise.all(children.map(({ child }) => waitForChildExit(child, RESPAWN_REAP_GRACE_MS))).then((results) => results.every(Boolean)),\n1573:     sleep(RESPAWN_REAP_GRACE_MS).then(() => false),\n1574:   ]);\n1575:   if (!exited) {\n1576:     for (const { child } of children) {\n1577:       if (isChildRunning(child)) child.kill('SIGKILL');\n1578:     }\n1579:   }\n1580:   clearAllLeaseFiles();\n1581:   process.exit(128);\n1582: }\n1583: \n1584: function installSignalHandlers() {\n1585:   for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n1586:     process.on(signal, () => {\n1587:       void shutdownLauncherForSignal(signal).catch((error) => {\n1588:         log(error.stack || error.message);\n1589:         clearAllLeaseFiles();\n1590:         process.exit(128);\n1591:       });\n1592:     });\n1593:   }\n1594:   process.on('uncaughtException', (err) => {\n1595:     try {\n1596:       clearAllLeaseFiles();\n1597:     } catch {\n1598:       // Preserve default uncaughtException crash behavior.\n1599:     }\n1600:     throw err;\n1601:   });\n1602: }\n1603: \n1604: async function main() {\n1605:   loadProjectEnvFiles();\n1606:   const started = now();\n1607:   const actions = [];\n1608:   let lockHeld = false;\n1609:   let staleRespawnLock = null;\n1610: \n1611:   try {\n1612:     installSignalHandlers();\n1613:     // Lease cleanup runs unconditionally regardless of child termination path.\n1614:     process.on('exit', clearAllLeaseFiles);\n1615:     refreshPaths();\n1616: \n1617:     const strictSingleWriter = !isStrictModeDisabled(process.env.MK_SPEC_MEMORY_STRICT_SINGLE_WRITER);\n1618:     ownerLeaseRequired = strictSingleWriter;\n1619:     if (strictSingleWriter) {\n1620:       const legacyLeaseResult = isLeaseHeld();\n1621:       if (legacyLeaseResult.held && legacyLeaseResult.legacyPath && !legacyLeaseResult.staleReclaimable) {\n1622:         await bridgeOrReportLeaseHeldAndExit(legacyLeaseResult);\n1623:         return;\n1624:       }\n1625:     }\n1626: \n1627:     ensureLayout(actions);\n1628:     refreshPaths();\n1629:     enforceStandaloneCodeGraphDb(actions);\n1630: \n1631:     if (strictSingleWriter) {\n1632:       const ownerLeaseResult = acquireOwnerLeaseFile();\n1633:       if (!ownerLeaseResult.acquired) {\n1634:         log(`liveOwnerDetected: ownerPid=${ownerLeaseResult.holder.ownerPid} classification=${ownerLeaseResult.classification}`);\n1635:         await bridgeOrReportLeaseHeldAndExit(leaseResultForOwnerLease(ownerLeaseResult.holder));\n1636:         return;\n1637:       }\n1638: \n1639:       const leaseResult = isLeaseHeld();\n1640:       if (leaseResult.held && !leaseResult.staleReclaimable) {\n1641:         clearOwnerLeaseFile();\n1642:         await bridgeOrReportLeaseHeldAndExit(leaseResult);\n1643:         return;\n1644:       }\n1645:       if (leaseResult.staleReclaimable) {\n1646:         log(`staleReclaimed: true${leaseResult.legacyPath ? ' (legacy path)' : ''}`);\n1647:         // A re-election daemon released by a disposing owner (or orphaned by a crashed owner) stays\n1648:         // alive under this stale lease, which records the live daemon as childPid. ADOPT it: if the\n1649:         // daemon is still alive and its recorded socket is bridgeable, bridge to the live socket\n1650:         // instead of reaping and respawning. This reuses the warm daemon and never tears down a\n1651:         // daemon a live secondary may still be bridged to. The reap+respawn path below runs only\n1652:         // when the daemon is genuinely gone.\n1653:         const staleLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n1654:         const orphanChildPid = staleLease?.childPid;\n1655:         if (Number.isInteger(orphanChildPid) && orphanChildPid > 0 && processLiveness(orphanChildPid) !== 'dead') {\n1656:           const adoptResult = { ...leaseResult, socketPath: staleLease.socketPath || leaseResult.socketPath };\n1657:           const readiness = bridgeReadiness(adoptResult);\n1658:           if (readiness.ready) {\n1659:             // A live pid that still owns its socket can be WEDGED: its event loop is starved, so the\n1660:             // kernel accepts the connection into the listen backlog but the daemon never services a\n1661:             // request. bridgeReadiness only proves the socket file exists — adopting on that alone\n1662:             // bridges every client into a dead end, and the launcher can never recover because the pid\n1663:             // stays alive forever and is never reaped. Require a real JSON-RPC reply (the same deep\n1664:             // probe the dead-socket decision uses, with its tuned timeout + retry that tolerates a\n1665:             // busy-but-responsive daemon) before adopting. A non-responsive daemon falls through to the\n1666:             // reap+respawn block below, which tears it down and spawns a fresh one under the lock.\n1667:             const { probeLeaseHolderWithRetries } = loadBridgeModule();\n1668:             let probe;\n1669:             try {\n1670:               probe = await probeLeaseHolderWithRetries(readiness.socketPath, {\n1671:                 onRetry: (attempt, total, result) => log(`stale-reclaim adopt probe ${attempt}/${total} not alive (${result.reason}); retrying`),\n1672:               });\n1673:             } catch (error) {\n1674:               // The probe resolves to a status even on socket failure; a thrown error means the probe\n1675:               // infrastructure itself failed. Treat that as not-alive so control falls through to\n1676:               // reap+respawn, rather than letting the exception abort startup and strand the daemon.\n1677:               probe = { status: 'dead', reason: `probe-threw: ${error instanceof Error ? error.message : String(error)}` };\n1678:             }\n1679:             if (probe.status === 'alive') {\n1680:               log(`stale-reclaim adopting live daemon pid ${orphanChildPid} via bridge instead of reaping`);\n1681:               clearOwnerLeaseFile();\n1682:               await bridgeOrReportLeaseHeldAndExit(adoptResult);\n1683:               return;\n1684:             }\n1685:             // The probe can fail because the daemon is busy-by-design (a background\n1686:             // index scan starves its event loop), not wedged. A fresh maintenance\n1687:             // marker naming this live child means adopt rather than reap+respawn.\n1688:             const adoptMarker = readMaintenanceMarker(maintenanceMarkerDir());\n1689:             if (shouldAdoptDespiteProbe({ marker: adoptMarker, childPid: orphanChildPid, childLiveness: processLiveness(orphanChildPid) })) {\n1690:               log(`stale-reclaim adopting busy daemon pid ${orphanChildPid} via bridge: probe failed (${probe.reason}) but a fresh maintenance marker is active (until ${new Date(adoptMarker.activeUntilMs).toISOString()})`);\n1691:               clearOwnerLeaseFile();\n1692:               await bridgeOrReportLeaseHeldAndExit(adoptResult);\n1693:               return;\n1694:             }\n1695:             log(`stale-reclaim NOT adopting pid ${orphanChildPid}: liveness probe failed (${probe.reason}); reaping and respawning instead`);\n1696:           }\n1697:         }\n1698:         // Daemon is dead, unbridgeable, or alive but failing its liveness probe. Reclaiming an existing STALE owner lease is a\n1699:         // non-exclusive write (the owner-lease O_EXCL above only covers the no-prior-lease case), so\n1700:         // two fresh launchers racing a crashed owner could both reach the reap and spawn. Take the\n1701:         // exclusive respawn lock to serialize it, the same lock the dead-socket respawn path uses;\n1702:         // the loser bails and reconnects.\n1703:         staleRespawnLock = acquireRespawnLockFile();\n1704:         if (!staleRespawnLock.acquired) {\n1705:           log('stale-reclaim deferred: another launcher holds the respawn lock; reporting lease held');\n1706:           clearOwnerLeaseFile();\n1707:           writeLeaseHeldJsonRpcError(leaseResult, 'respawn-lock-held');\n1708:           process.exit(0);\n1709:         }\n1710:         if (Number.isInteger(orphanChildPid) && orphanChildPid > 0) {\n1711:           // Re-validate under the respawn lock. The liveness probe above can take seconds, during which\n1712:           // a racing launcher may have reaped this same orphan and spawned a fresh daemon (recording a\n1713:           // new childPid) before we acquired the lock. Reaping now would tear down that replacement and\n1714:           // risk a second writer, so if the recorded lease no longer names the orphan we snapshotted,\n1715:           // defer and reconnect. Mirrors the dead-socket respawn path's post-lock lease re-read.\n1716:           const recheckLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n1717:           if (recheckLease && recheckLease.childPid !== orphanChildPid) {\n1718:             log('stale-reclaim deferred: lease childPid changed after acquiring respawn lock (replacement already present); reporting lease held');\n1719:             releaseRespawnLockFile(staleRespawnLock);\n\n(Showing lines 1200-1719 of 1882. Use offset=1720 to continue.)\n</content>","metadata":{"preview":"  if (ctx.isRecycleInProgress()) return;\n  ctx.setRecycleInProgress(true);\n  ctx.clearWatchdog();\n  ctx.hfControl.clearTimers();\n  await ctx.hfControl.stopDemandListener();\n  const modelServerChild = ctx.hfControl.getChild();\n  if (ctx.isChildRunning(modelServerChild)) {\n    ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n    modelServerChild.kill('SIGTERM');\n    ctx.hfControl.reapProcessTree(modelServerChild.pid);\n    const modelExitedAfterTerm = await ctx.waitForChildExit(modelServerChild, graceMs);\n    if (!modelExitedAfterTerm && ctx.isChildRunning(modelServerChild)) {\n      ctx.log(`hf-model-server pid ${modelServerChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n      modelServerChild.kill('SIGKILL');\n      await ctx.waitForChildExit(modelServerChild, 1000);\n    }\n  }\n  const contextChild = ctx.getContextChild();\n  if (!ctx.isChildRunning(contextChild)) {\n    ctx.clearLease();","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"  if (ctx.isRecycleInProgress()) return;\n  ctx.setRecycleInProgress(true);\n  ctx.clearWatchdog();\n  ctx.hfControl.clearTimers();\n  await ctx.hfControl.stopDemandListener();\n  const modelServerChild = ctx.hfControl.getChild();\n  if (ctx.isChildRunning(modelServerChild)) {\n    ctx.log(`RSS ceiling sustained; sending SIGTERM to hf-model-server pid ${modelServerChild.pid} before daemon recycle`);\n    modelServerChild.kill('SIGTERM');\n    ctx.hfControl.reapProcessTree(modelServerChild.pid);\n    const modelExitedAfterTerm = await ctx.waitForChildExit(modelServerChild, graceMs);\n    if (!modelExitedAfterTerm && ctx.isChildRunning(modelServerChild)) {\n      ctx.log(`hf-model-server pid ${modelServerChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n      modelServerChild.kill('SIGKILL');\n      await ctx.waitForChildExit(modelServerChild, 1000);\n    }\n  }\n  const contextChild = ctx.getContextChild();\n  if (!ctx.isChildRunning(contextChild)) {\n    ctx.clearLease();\n    ctx.setRecycleInProgress(false);\n    return;\n  }\n\n  ctx.log(`RSS ceiling sustained; sending SIGTERM to context-server pid ${contextChild.pid} before daemon recycle`);\n  contextChild.kill('SIGTERM');\n  const exitedAfterTerm = await ctx.waitForChildExit(contextChild, graceMs);\n  if (!exitedAfterTerm && ctx.isChildRunning(contextChild)) {\n    ctx.log(`context-server pid ${contextChild.pid} exceeded ${graceMs}ms grace; sending SIGKILL before daemon recycle`);\n    contextChild.kill('SIGKILL');\n    await ctx.waitForChildExit(contextChild, 1000);\n  }\n  // Keep the lease held across an in-place recycle. The launcher process stays alive and the\n  // lease is keyed on its (still-live) pid, so the replacement daemon is respawned by the child\n  // exit handler's scheduleRelaunch backoff. Clearing the lease here would open a window — until\n  // relaunch rewrites childPid — where a concurrent launcher reads no lease and passes the\n  // single-writer gate, producing a competing daemon. Relaunch (writeLeaseFile) rewrites childPid.\n}\n\nfunction startRssWatchdog(childPid, options = {}) {\n  return mss.startRssWatchdog(childPid, {\n    ...options,\n    timerState: options.timerState || {\n      get: () => rssWatchdogTimer,\n      set: (timer) => {\n        rssWatchdogTimer = timer;\n      },\n    },\n    snapshot: options.snapshot || {\n      set: (pids) => {\n        lastKnownDescendantPids = pids;\n      },\n    },\n    log: options.log || log,\n    onBreach: options.onBreach || ((breachConfig) => recycleDaemonInPlace(breachConfig.graceMs)),\n  });\n}\n\n// Launcher-local factory that pre-seeds the launcher-aware defaults (writeLease/shouldExitLauncher/\n// onRssBreach) the shared lib intentionally leaves as generic no-ops. Keeps the launcher's exported\n// createModelServerSupervisor + launchModelServer(options) seam byte-equivalent to pre-extraction HEAD.\n// Explicit caller options still win via the trailing spread for targeted writeLease injection.\nfunction createModelServerSupervisor(options = {}) {\n  return baseCreateModelServerSupervisor({\n    writeLease: () => writeLeaseFile(),\n    shouldExitLauncher: () => launcherShutdownInProgress,\n    onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n    ...options,\n  });\n}\n\nfunction launchModelServer(options = null) {\n  if (options && typeof options === 'object') {\n    return createModelServerSupervisor(options).launch();\n  }\n  return hfControl.launch();\n}\n\nfunction startModelServerDemandListener(options = {}) {\n  return hfControl.startDemandListener(options);\n}\n\nfunction stopModelServerDemandListener() {\n  return hfControl.stopDemandListener();\n}\n\nconst BOOTSTRAP_LOCK_OWNER_FILE = 'owner.pid';\n\n// Returns the pid recorded inside the lock dir, or null when no readable pid\n// stamp exists (legacy lock dirs, or a holder that died before stamping).\nfunction readBootstrapLockOwnerPid() {\n  try {\n    const raw = fs.readFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), 'utf8').trim();\n    const pid = Number.parseInt(raw, 10);\n    return Number.isInteger(pid) && pid > 0 ? pid : null;\n  } catch {\n    return null;\n  }\n}\n\n// Reclaim a stale bootstrap lockdir. A lock is reclaimable as soon as its\n// recorded holder is provably dead; the mtime TTL is only a fallback for lock\n// dirs with no readable pid stamp (legacy dirs) or a holder whose liveness\n// cannot be determined. Without the dead-holder check, a holder killed less than\n// BOOTSTRAP_LOCK_STALE_MS ago wedges every requireLock respawn for the full wait\n// deadline (the TTL exceeds the deadline by design for a slow-but-live build).\nfunction removeStaleBootstrapLock(staleMs = BOOTSTRAP_LOCK_STALE_MS) {\n  let ageMs;\n  try {\n    ageMs = Date.now() - fs.statSync(lockDir).mtimeMs;\n  } catch (error) {\n    if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;\n    throw error;\n  }\n  const ownerPid = readBootstrapLockOwnerPid();\n  const ownerDead = ownerPid !== null && processLiveness(ownerPid) === 'dead';\n  if (!ownerDead && ageMs <= staleMs) {\n    return false;\n  }\n  // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n  // racer wins the rename; a successor that mkdir'd a fresh lockDir after our stat\n  // creates a new inode that our rename/rmSync cannot touch, so we never delete a\n  // live successor lock. A losing racer's rename throws ENOENT and falls through to\n  // the outer retry.\n  const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n  try {\n    fs.renameSync(lockDir, staleClaim);\n    fs.rmSync(staleClaim, { recursive: true, force: true });\n    const reason = ownerDead ? `dead holder pid=${ownerPid}` : `mtime ${Math.round(ageMs / 1000)}s old`;\n    log(`reclaiming stale bootstrap lock ${rel(lockDir)} (${reason})`);\n    return true;\n  } catch (error) {\n    if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;\n    throw error;\n  }\n}\n\nasync function acquireBootstrapLock(options = {}) {\n  const requireLock = options.requireLock === true;\n  fs.mkdirSync(dbDir, { recursive: true });\n  const deadline = Date.now() + (options.timeoutMs ?? 120000);\n  const staleMs = options.staleMs ?? BOOTSTRAP_LOCK_STALE_MS;\n  const retrySleepMs = options.retrySleepMs ?? 1000;\n  while (true) {\n    try {\n      fs.mkdirSync(lockDir);\n      // Stamp the holder pid so a later launcher can reclaim this lock the\n      // instant we die, instead of waiting out the mtime TTL. Best-effort: a\n      // failed stamp degrades to the TTL path, never blocks acquisition.\n      try {\n        fs.writeFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), String(process.pid), { mode: 0o600 });\n      } catch { /* TTL fallback covers an unstamped lock */ }\n      return true;\n    } catch (error) {\n      if (error.code !== 'EEXIST') {\n        throw error;\n      }\n      if (removeStaleBootstrapLock(staleMs)) {\n        continue;\n      }\n      if (artifactsReady() && !requireLock) {\n        return false;\n      }\n      if (Date.now() > deadline) {\n        throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n      }\n      await sleep(retrySleepMs);\n    }\n  }\n}\n\nfunction launchServer() {\n  if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n    log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n    return false;\n  }\n  if (shouldSkipLaunch(childProcess)) {\n    log('launchServer skipped: a context-server child is already running in this launcher process');\n    return false;\n  }\n  if (!crashLoopGuard) crashLoopGuard = createCrashLoopGuard(getCrashLoopConfig());\n  if (supervisorRelaunchTimer) {\n    clearTimeout(supervisorRelaunchTimer);\n    supervisorRelaunchTimer = null;\n  }\n  const server = path.join(kitDir, 'mcp_server', 'dist', 'context-server.js');\n  const nodeArgs = getContextServerNodeArgs();\n  const reelectionEnabled = daemonReelectionEnabled();\n  const spawnIo = contextServerSpawnIo(reelectionEnabled);\n  childProcess = spawn(process.execPath, [...nodeArgs, server], {\n    cwd: root,\n    env: {\n      ...process.env,\n      SPECKIT_BACKEND_ONLY: '1',\n    },\n    stdio: spawnIo.stdio,\n    detached: spawnIo.detached,\n  });\n  // Re-election only: let the launcher exit without keeping the detached daemon tethered to it.\n  if (reelectionEnabled) childProcess.unref();\n  const childPid = childProcess.pid;\n  const refreshed = refreshOwnerLeaseFile(process.pid);\n  if (!refreshed) {\n    log('owner lease refresh failed after child spawn; launcher pid remains the recorded owner');\n  }\n  startOwnerLeaseHeartbeat(process.pid);\n  writeLeaseFile(childPid);\n  startRssWatchdog(childPid);\n\n  childProcess.on('exit', (code, signal) => {\n    if (launcherShutdownInProgress) {\n      return;\n    }\n    if (code === EXIT_DB_LOCK_HELD) {\n      void handleDbLockHeldChildExit();\n      return;\n    }\n    const result = superviseChildExit(\n      { code, signal, childPid, intentional: false },\n      {\n        crashLoopGuard,\n        clearLease: clearAllLeaseFiles,\n        reapProcessGroup: reapProcessTreeGroups,\n        mirrorSignal: (exitSignal) => process.kill(process.pid, exitSignal),\n        exit: (exitCode) => process.exit(exitCode),\n        scheduleRelaunch: (backoffMs) => {\n          log(`context-server child exited code=${code ?? 'null'} signal=${signal ?? 'null'}; relaunching in ${backoffMs}ms`);\n          supervisorRelaunchTimer = setTimeout(() => {\n            // Owner-disposal race guard: by the time the backoff fires, re-check that this\n            // launcher is still live AND its owning runtime is still present. Respawning the\n            // daemon under a disposing session is what produced the SIGTERM/relaunch flap that\n            // dropped every bridged session's transport. Crash-recovery and RSS-recycle are\n            // unaffected — both run with the owning runtime alive and no shutdown in progress.\n            if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) {\n              log('relaunch aborted: launcher shutting down or owning runtime gone; releasing lease and exiting');\n              clearAllLeaseFiles();\n              process.exit(0);\n              return;\n            }\n            launchServer();\n          }, backoffMs);\n          supervisorRelaunchTimer.unref?.();\n        },\n      },\n    );\n    if (result.action === 'give-up') {\n      log(`context-server crash loop detected after ${result.deathsInWindow} deaths; clearing lease and mirroring child exit`);\n    }\n  });\n\n  childProcess.on('error', (error) => {\n    log(error.stack || error.message);\n    process.exit(1);\n  });\n  if (rssBreachSelfExitInProgress) {\n    rssBreachSelfExitInProgress = false;\n  }\n  return true;\n}\n\n// Pure decision for the exit-86 flow (exported for tests). A lease whose\n// owner is THIS launcher is NOT a bridge target: in supervised mode the\n// pid-lease records the launcher's own pid, so after its child exits 86 the\n// lease still reads \"held by a live owner\" — us. Bridging would deep-probe\n// our own dead socket and route into a self-reap. Only a DIFFERENT live\n// owner is bridgeable; a self-held lease means a non-daemon process (e.g. a\n// standalone save mid-run) owns the database lock, so retry in place.\nfunction decideDbLockHeldAction({ leaseHeld, leaseOwnerPid, selfPid, attempt, maxRetries }) {\n  if (attempt > maxRetries + 2) return { action: 'report', reason: 'db-lock-held-persistent' };\n  if (leaseHeld && leaseOwnerPid !== selfPid) return { action: 'bridge' };\n  if (attempt <= maxRetries) return { action: 'retry', backoffMs: 2000 * 2 ** (attempt - 1) };\n  return { action: 'report', reason: 'db-lock-held' };\n}\n\n// The daemon refused to become a second writer on a database another live\n// process holds. Prefer bridging to that owner; when the holder is not a\n// bridgeable daemon (e.g. a maintenance script mid-run), retry the launch a\n// few times so a short-lived holder can finish, then report and exit clean.\nasync function handleDbLockHeldChildExit() {\n  dbLockHeldRetries += 1;\n  const leaseResult = isLeaseHeld();\n  const decision = decideDbLockHeldAction({\n    leaseHeld: leaseResult.held,\n    leaseOwnerPid: leaseResult.ownerPid,\n    selfPid: process.pid,\n    attempt: dbLockHeldRetries,\n    maxRetries: DB_LOCK_HELD_MAX_RETRIES,\n  });\n  if (decision.action === 'bridge') {\n    log(`context-server exited: database single-writer lock held; bridging to live owner pid=${leaseResult.ownerPid}`);\n    await bridgeOrReportLeaseHeldAndExit(leaseResult);\n    return;\n  }\n  if (decision.action === 'retry') {\n    log(`database single-writer lock held by a non-bridgeable holder; retrying launch in ${decision.backoffMs}ms (attempt ${dbLockHeldRetries}/${DB_LOCK_HELD_MAX_RETRIES})`);\n    if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n    supervisorRelaunchTimer = setTimeout(() => {\n      // Abort if the owning runtime vanished (shutdown in progress, or the launcher\n      // was reparented to init without a SIGTERM) — same guard as the primary\n      // backoff-relaunch path, so neither relaunches a daemon under a disposed session.\n      if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) return;\n      launchServer();\n    }, decision.backoffMs);\n    if (supervisorRelaunchTimer.unref) supervisorRelaunchTimer.unref();\n    return;\n  }\n  log('database single-writer lock still held after launch retries; reporting and exiting');\n  writeLeaseHeldJsonRpcError(\n    { ownerPid: leaseResult.ownerPid ?? 'unknown', startedAt: leaseResult.startedAt ?? new Date().toISOString() },\n    decision.reason,\n  );\n  clearAllLeaseFiles();\n  process.exit(0);\n}\n\nasync function shutdownLauncherForSignal(signal) {\n  if (launcherShutdownInProgress) return;\n  launcherShutdownInProgress = true;\n  if (rssWatchdogTimer) clearInterval(rssWatchdogTimer);\n  if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n  clearOwnerLeaseHeartbeat();\n  hfControl.clearTimers();\n  await hfControl.stopDemandListener();\n\n  // Re-election release path (on by default): release the detached context-server for a live secondary to adopt\n  // instead of killing it. Reap only the non-adoptable model-server, KEEP the daemon lease (its socket\n  // stays findable for adoption), drop only OWNERSHIP, and exit without killing the daemon. When the\n  // flag is off this branch is skipped and the original kill path below runs unchanged.\n  if (shouldReleaseDaemonForReelection({ enabled: daemonReelectionEnabled(), hasLiveDaemon: isChildRunning(childProcess) })) {\n    const releasedModelServer = hfControl.getChild();\n    if (isChildRunning(releasedModelServer)) {\n      hfControl.reapProcessTree(releasedModelServer.pid);\n      releasedModelServer.kill(signal);\n      // Escalate to SIGKILL if the non-adoptable model-server does not exit within the grace window,\n      // so the release path does not leave a wedged sidecar behind on its way out.\n      const exited = await waitForChildExit(releasedModelServer, RESPAWN_REAP_GRACE_MS);\n      if (!exited && isChildRunning(releasedModelServer)) {\n        releasedModelServer.kill('SIGKILL');\n      }\n    }\n    log('daemon re-election: releasing context-server for adoption (not killing); dropping ownership lease only');\n    // The process 'exit' handler clears BOTH leases; detach it first so the daemon lease (its socket\n    // path) survives for a secondary to adopt. Ownership is still dropped explicitly below.\n    process.removeListener('exit', clearAllLeaseFiles);\n    clearOwnerLeaseFile();\n    process.exit(0);\n    return;\n  }\n\n  const children = [];\n  if (isChildRunning(childProcess)) {\n    children.push({ child: childProcess, label: 'context-server' });\n  }\n  const modelServerChild = hfControl.getChild();\n  if (isChildRunning(modelServerChild)) {\n    children.push({ child: modelServerChild, label: 'hf-model-server' });\n  }\n\n  if (children.length === 0) {\n    clearAllLeaseFiles();\n    process.exit(128);\n    return;\n  }\n\n  for (const { child, label } of children) {\n    if (label === 'hf-model-server') {\n      hfControl.reapProcessTree(child.pid);\n    }\n    child.kill(signal);\n  }\n\n  const exited = await Promise.race([\n    Promise.all(children.map(({ child }) => waitForChildExit(child, RESPAWN_REAP_GRACE_MS))).then((results) => results.every(Boolean)),\n    sleep(RESPAWN_REAP_GRACE_MS).then(() => false),\n  ]);\n  if (!exited) {\n    for (const { child } of children) {\n      if (isChildRunning(child)) child.kill('SIGKILL');\n    }\n  }\n  clearAllLeaseFiles();\n  process.exit(128);\n}\n\nfunction installSignalHandlers() {\n  for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n    process.on(signal, () => {\n      void shutdownLauncherForSignal(signal).catch((error) => {\n        log(error.stack || error.message);\n        clearAllLeaseFiles();\n        process.exit(128);\n      });\n    });\n  }\n  process.on('uncaughtException', (err) => {\n    try {\n      clearAllLeaseFiles();\n    } catch {\n      // Preserve default uncaughtException crash behavior.\n    }\n    throw err;\n  });\n}\n\nasync function main() {\n  loadProjectEnvFiles();\n  const started = now();\n  const actions = [];\n  let lockHeld = false;\n  let staleRespawnLock = null;\n\n  try {\n    installSignalHandlers();\n    // Lease cleanup runs unconditionally regardless of child termination path.\n    process.on('exit', clearAllLeaseFiles);\n    refreshPaths();\n\n    const strictSingleWriter = !isStrictModeDisabled(process.env.MK_SPEC_MEMORY_STRICT_SINGLE_WRITER);\n    ownerLeaseRequired = strictSingleWriter;\n    if (strictSingleWriter) {\n      const legacyLeaseResult = isLeaseHeld();\n      if (legacyLeaseResult.held && legacyLeaseResult.legacyPath && !legacyLeaseResult.staleReclaimable) {\n        await bridgeOrReportLeaseHeldAndExit(legacyLeaseResult);\n        return;\n      }\n    }\n\n    ensureLayout(actions);\n    refreshPaths();\n    enforceStandaloneCodeGraphDb(actions);\n\n    if (strictSingleWriter) {\n      const ownerLeaseResult = acquireOwnerLeaseFile();\n      if (!ownerLeaseResult.acquired) {\n        log(`liveOwnerDetected: ownerPid=${ownerLeaseResult.holder.ownerPid} classification=${ownerLeaseResult.classification}`);\n        await bridgeOrReportLeaseHeldAndExit(leaseResultForOwnerLease(ownerLeaseResult.holder));\n        return;\n      }\n\n      const leaseResult = isLeaseHeld();\n      if (leaseResult.held && !leaseResult.staleReclaimable) {\n        clearOwnerLeaseFile();\n        await bridgeOrReportLeaseHeldAndExit(leaseResult);\n        return;\n      }\n      if (leaseResult.staleReclaimable) {\n        log(`staleReclaimed: true${leaseResult.legacyPath ? ' (legacy path)' : ''}`);\n        // A re-election daemon released by a disposing owner (or orphaned by a crashed owner) stays\n        // alive under this stale lease, which records the live daemon as childPid. ADOPT it: if the\n        // daemon is still alive and its recorded socket is bridgeable, bridge to the live socket\n        // instead of reaping and respawning. This reuses the warm daemon and never tears down a\n        // daemon a live secondary may still be bridged to. The reap+respawn path below runs only\n        // when the daemon is genuinely gone.\n        const staleLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n        const orphanChildPid = staleLease?.childPid;\n        if (Number.isInteger(orphanChildPid) && orphanChildPid > 0 && processLiveness(orphanChildPid) !== 'dead') {\n          const adoptResult = { ...leaseResult, socketPath: staleLease.socketPath || leaseResult.socketPath };\n          const readiness = bridgeReadiness(adoptResult);\n          if (readiness.ready) {\n            // A live pid that still owns its socket can be WEDGED: its event loop is starved, so the\n            // kernel accepts the connection into the listen backlog but the daemon never services a\n            // request. bridgeReadiness only proves the socket file exists — adopting on that alone\n            // bridges every client into a dead end, and the launcher can never recover because the pid\n            // stays alive forever and is never reaped. Require a real JSON-RPC reply (the same deep\n            // probe the dead-socket decision uses, with its tuned timeout + retry that tolerates a\n            // busy-but-responsive daemon) before adopting. A non-responsive daemon falls through to the\n            // reap+respawn block below, which tears it down and spawns a fresh one under the lock.\n            const { probeLeaseHolderWithRetries } = loadBridgeModule();\n            let probe;\n            try {\n              probe = await probeLeaseHolderWithRetries(readiness.socketPath, {\n                onRetry: (attempt, total, result) => log(`stale-reclaim adopt probe ${attempt}/${total} not alive (${result.reason}); retrying`),\n              });\n            } catch (error) {\n              // The probe resolves to a status even on socket failure; a thrown error means the probe\n              // infrastructure itself failed. Treat that as not-alive so control falls through to\n              // reap+respawn, rather than letting the exception abort startup and strand the daemon.\n              probe = { status: 'dead', reason: `probe-threw: ${error instanceof Error ? error.message : String(error)}` };\n            }\n            if (probe.status === 'alive') {\n              log(`stale-reclaim adopting live daemon pid ${orphanChildPid} via bridge instead of reaping`);\n              clearOwnerLeaseFile();\n              await bridgeOrReportLeaseHeldAndExit(adoptResult);\n              return;\n            }\n            // The probe can fail because the daemon is busy-by-design (a background\n            // index scan starves its event loop), not wedged. A fresh maintenance\n            // marker naming this live child means adopt rather than reap+respawn.\n            const adoptMarker = readMaintenanceMarker(maintenanceMarkerDir());\n            if (shouldAdoptDespiteProbe({ marker: adoptMarker, childPid: orphanChildPid, childLiveness: processLiveness(orphanChildPid) })) {\n              log(`stale-reclaim adopting busy daemon pid ${orphanChildPid} via bridge: probe failed (${probe.reason}) but a fresh maintenance marker is active (until ${new Date(adoptMarker.activeUntilMs).toISOString()})`);\n              clearOwnerLeaseFile();\n              await bridgeOrReportLeaseHeldAndExit(adoptResult);\n              return;\n            }\n            log(`stale-reclaim NOT adopting pid ${orphanChildPid}: liveness probe failed (${probe.reason}); reaping and respawning instead`);\n          }\n        }\n        // Daemon is dead, unbridgeable, or alive but failing its liveness probe. Reclaiming an existing STALE owner lease is a\n        // non-exclusive write (the owner-lease O_EXCL above only covers the no-prior-lease case), so\n        // two fresh launchers racing a crashed owner could both reach the reap and spawn. Take the\n        // exclusive respawn lock to serialize it, the same lock the dead-socket respawn path uses;\n        // the loser bails and reconnects.\n        staleRespawnLock = acquireRespawnLockFile();\n        if (!staleRespawnLock.acquired) {\n          log('stale-reclaim deferred: another launcher holds the respawn lock; reporting lease held');\n          clearOwnerLeaseFile();\n          writeLeaseHeldJsonRpcError(leaseResult, 'respawn-lock-held');\n          process.exit(0);\n        }\n        if (Number.isInteger(orphanChildPid) && orphanChildPid > 0) {\n          // Re-validate under the respawn lock. The liveness probe above can take seconds, during which\n          // a racing launcher may have reaped this same orphan and spawned a fresh daemon (recording a\n          // new childPid) before we acquired the lock. Reaping now would tear down that replacement and\n          // risk a second writer, so if the recorded lease no longer names the orphan we snapshotted,\n          // defer and reconnect. Mirrors the dead-socket respawn path's post-lock lease re-read.\n          const recheckLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n          if (recheckLease && recheckLease.childPid !== orphanChildPid) {\n            log('stale-reclaim deferred: lease childPid changed after acquiring respawn lock (replacement already present); reporting lease held');\n            releaseRespawnLockFile(staleRespawnLock);","lineStart":1200,"lineEnd":1719,"totalLines":1882,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781761501821,"end":1781761501823}},"metadata":{"openai":{"itemId":"fc_00ff612f68860895016a3385ddac6881918328267b19706e4f"}},"id":"prt_ed942ea77001kWKiUadyU1OIRE","sessionID":"ses_126bf2c73ffeZ1nadU7aA32XcF","messageID":"msg_ed942b79b001rlj0G50T58wap8"}}
