   272	      step_scope_discovery:
   273	        action: "Resolve review target to a concrete file list based on target type"
   274	        resolve:
   275	          spec-folder: |
   276	            1. Read spec.md, plan.md, tasks.md, checklist.md, implementation-summary.md
   277	            2. Discover implementation files referenced in spec artifacts
   278	            3. Discover test files associated with implementation
   279	            4. Set scope = all discovered files
   280	          skill: |
   281	            1. Read SKILL.md from .opencode/skills/{skill_name}/
   282	            2. Discover references/, assets/, scripts/ contents
   283	            3. Find agent definitions referencing this skill across runtimes
   284	            4. Find command entry points referencing this skill
   285	            5. Set scope = all discovered files
   286	          agent: |
   287	            1. Find agent definition across all runtimes (.claude/agents/, .opencode/agents/, .codex/agents/, .agents/, .gemini/agents/)
   288	            2. Compare agent definitions for consistency
   289	            3. Set scope = all discovered agent files
   290	          track: |
   291	            1. List all child spec folders under specs/{track}/ or .opencode/specs/{track}/
   292	            2. For each: read spec.md + checklist.md
   293	            3. Set scope = all child spec artifacts
   294	          files: |
   295	            1. Expand glob patterns from review_target
   296	            2. Validate all files exist
   297	            3. Discover immediate cross-references (imports, links)
   298	            4. Set scope = expanded file list + cross-references
   299	        outputs:
