 `Usage: compiled-route-sync.cjs [--verify|--check|--help]\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/tests/compiled-route-manifest.test.cjs:\n  Line 20: const sync = require('../compiled-route-sync.cjs');\n\n  Line 31: const SYNC_PATH = path.join(REPO_ROOT, '.opencode', 'bin', 'compiled-route-sync.cjs');\n\n  Line 104:       env: { ...process.env, SPECKIT_COMPILED_ROUTING: '1' },\n\n  Line 144:     delete process.env.SPECKIT_COMPILED_ROUTING;\n\n  Line 356:     delete process.env.SPECKIT_COMPILED_ROUTING;\n\n  Line 411:     assert.match(verify.stdout, /all 7 hubs resolve; 0 reads under \\.opencode\\/specs/);\n\n  Line 488:     delete process.env.SPECKIT_COMPILED_ROUTING;\n\n  Line 489:     assert.equal(resolver.DEFAULT_ON_HUBS.size, 7);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs:\n  Line 7: //   1. the runtime flag permits it — SPECKIT_COMPILED_ROUTING=1 forces compiled,\n\n  Line 26: const FLAG = 'SPECKIT_COMPILED_ROUTING';\n\n  Line 27: const DEBUG_FLAG = 'SPECKIT_COMPILED_ROUTING_DEBUG';\n\n  Line 32: // resolves to compiled for every eligible hub. SPECKIT_COMPILED_ROUTING=0\n\n  Line 34: const DEFAULT_ON_HUBS = new Set([\n\n  Line 70:   if (mode === 'default') return DEFAULT_ON_HUBS.has(hubId);\n\n  Line 131:   DEFAULT_ON_HUBS,\n","metadata":{"matches":25,"truncated":false},"title":"compiled-route-sync|0 reads under|SPECKIT_COMPILED_ROUTING|DEFAULT_ON_HUBS","time":{"start":1784692812555,"end":1784692812573}},"metadata":{"openai":{"itemId":"fc_02747d6796337114016a60404c6b74819193c7a421e5e6eeac"}},"id":"prt_f87fb2b090014yMX5hfVKCvkoE","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87facd60001VdxwAH5hklaJqq"}}
{"type":"tool_use","timestamp":1784692812578,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_la2dWXqSIHRlBVz3ujkBXZzq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/compiled-routing-parity.cjs","offset":1,"limit":210},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/compiled-routing-parity.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ╔══════════════════════════════════════════════════════════════════════════╗\n3: // ║ compiled-routing-parity — Lane C compiled-vs-legacy parity (non-frozen)  ║\n4: // ╚══════════════════════════════════════════════════════════════════════════╝\n5: 'use strict';\n6: \n7: /**\n8:  * compiled-routing-parity.cjs — prove the compiled routing decision matches the\n9:  * legacy decision on a scenario, WITHOUT re-implementing any scoring judgment.\n10:  *\n11:  * This is a non-frozen sibling of the frozen scorer trio. It never edits those\n12:  * files; it only re-hashes them (as a precondition), translates the compiled\n13:  * decision into the legacy evaluator's vocabulary, and delegates the verdict to\n14:  * the frozen `evaluateRouteGold` unchanged. Three guards keep the comparison\n15:  * honest:\n16:  *\n17:  *   1. Vacuous-parity guard. The runtime flag alone is insufficient — the\n18:  *      resolver serves compiled ONLY when the hub's activation manifest also\n19:  *      reads `servingAuthority: compiled`. A lane that trusted the flag would\n20:  *      read a legacy fallback as a false \"parity\" pass, so this reads the hub's\n21:  *      manifest directly and hard-fails `vacuous` on anything but `compiled`.\n22:  *   2. Shape bridge. Compiled emits qualified destination ids; the frozen\n23:  *      evaluator reads legacy `observedResources`. The two vocabularies are\n24:  *      incompatible without translation, so every target is resolved through the\n25:  *      shared `qualifiedIdToLeaf` boundary before the frozen evaluator runs. A\n26:  *      target that resolves to no manifest mode fails closed, never a silent skip.\n27:  *      A resolved leaf is packet-qualified to match legacy's own hub-relative\n28:  *      convention, then projected down to legacy's own observed granularity for\n29:  *      the gold comparison -- a leaf-manifest declares a whole mode's possible\n30:  *      leaves, legacy's replay selects a task-scoped subset of them, and an\n31:  *      unconditional hub-level resource belongs to no packet's declaration at\n32:  *      all -- so a compiled target's declared breadth is never mistaken for\n33:  *      task-scoped precision, and a genuine compiled declaration gap still\n34:  *      fails closed.\n35:  *   3. Frozen-scorer pin. The three shared scorer files are re-hashed against\n36:  *      pinned digests before any comparison; drift aborts before evidence is\n37:  *      written, so a scorer edited out from under a run never produces a report.\n38:  *\n39:  * The parity status is one of match / drift / vacuous / n/a / resolver-missing;\n40:  * only `match` counts as a pass and `n/a` is informational (a hub that is\n41:  * route-gold enforced but not in the compiled serving closure). The run-level\n42:  * verdict sub-state that these statuses roll up into lives in the orchestrator,\n43:  * never here and never in the frozen scorer.\n44:  *\n45:  * Pure: given its inputs plus the on-disk manifest and compiled artifacts, it\n46:  * makes no network call and no clock-dependent branch. Every external seam\n47:  * (hub eligibility, manifest read, compiled decision, manifest mode index) is an\n48:  * injectable dependency with a production default, so the whole status space is\n49:  * exercisable from fixtures without a live fleet.\n50:  */\n51: \n52: // ─────────────────────────────────────────────────────────────────────────────\n53: // 1. IMPORTS\n54: // ─────────────────────────────────────────────────────────────────────────────\n55: \n56: const fs = require('fs');\n57: const path = require('path');\n58: const crypto = require('crypto');\n59: const { spawnSync } = require('child_process');\n60: \n61: // The shared identity contract owns the single conversion boundary from a\n62: // compiled qualified id to the manifest mode that declares its leaves. Consumed,\n63: // never redefined, so this harness and the drift guards agree byte for byte.\n64: const { qualifiedIdToLeaf } = require(\n65:   path.join(__dirname, '..', '..', '..', '..', 'sk-doc', 'create-skill', 'scripts', 'lib', 'leaf-resource-contract.cjs'),\n66: );\n67: \n68: // The frozen evaluator is the sole authority for legacy route-gold scoring. It\n69: // is called, never re-implemented: this harness only feeds it a translated\n70: // observed decision and compares its verdicts.\n71: const { evaluateRouteGold } = require('./score-skill-benchmark.cjs');\n72: \n73: // ─────────────────────────────────────────────────────────────────────────────\n74: // 2. CONSTANTS\n75: // ─────────────────────────────────────────────────────────────────────────────\n76: \n77: // The promoted runtime closure — what actually serves. The vacuous-parity guard\n78: // and the compiled engine both read here, never the spec tree, so the harness\n79: // reflects the routing the fleet would really perform.\n80: const SKILLS_ROOT = path.resolve(__dirname, '..', '..', '..', '..');\n81: const RUNTIME_ROOT = path.resolve(__dirname, '..', '..', '..', '..', '..', 'bin', 'lib', 'compiled-routing');\n82: const ACTIVATION_ROOT = path.join(RUNTIME_ROOT, '010-live-activation', 'activation');\n83: const SERVING_CLOSURE_MANIFEST = path.join(RUNTIME_ROOT, 'serving-closure.manifest.json');\n84: const PROMOTED_ENGINE = path.join(RUNTIME_ROOT, '011-runtime-engine', 'lib', 'compiled-route.cjs');\n85: const PROMOTED_RESOLVER = path.join(RUNTIME_ROOT, '011-runtime-engine', 'lib', 'resolve.cjs');\n86: const PUBLIC_FRONT_DOOR = path.resolve(RUNTIME_ROOT, '..', '..', 'compiled-route.cjs');\n87: const STATUS_PROBE = path.resolve(RUNTIME_ROOT, '..', '..', 'compiled-route-status.cjs');\n88: \n89: // Pinned digests of the frozen scorer trio. Re-hashed before every parity run;\n90: // any drift aborts before a report is written, so the parity baseline can never\n91: // be scored against a scorer that changed mid-flight. These are the same digests\n92: // the activation driver refuses to run without.\n93: const PINNED_FROZEN_SCORER_DIGESTS = Object.freeze({\n94:   'router-replay.cjs': 'd5e13daf3e99469c079e8037c988b31db4d27dfcf5045789d70dceb48de8af47',\n95:   'score-skill-benchmark.cjs': 'd5a9cc72ec7cfcfb6484f0998f78e7ec16160ecdfee9e3c63f3215c72bf8780c',\n96:   'load-playbook-scenarios.cjs': '5029f22df920418eb0f87859a7146b83656619943a9fe6f010d6d06e96cdd029',\n97: });\n98: \n99: // Per-scenario parity status. Only `match` is a pass; `n/a` is informational\n100: // (route-gold enforced but the hub is outside the compiled serving closure);\n101: // every other value blocks once it rolls up.\n102: const PARITY_STATUS = Object.freeze({\n103:   MATCH: 'match',\n104:   DRIFT: 'drift',\n105:   VACUOUS: 'vacuous',\n106:   NA: 'n/a',\n107:   RESOLVER_MISSING: 'resolver-missing',\n108: });\n109: \n110: // Run-level verdict sub-state the orchestrator inspects before deciding the\n111: // outer verdict. Kept distinct so drift and a structurally broken compiled path\n112: // never collapse into one opaque BLOCKED.\n113: const COMPILED_SUBVERDICT = Object.freeze({\n114:   SERVING: 'compiled-serving',\n115:   DRIFTED: 'legacy-fallback-drifted',\n116:   BROKEN: 'broken-compiled-path',\n117:   NA: 'n/a',\n118: });\n119: \n120: // The single blocking drift-gate owner. Every other consumer of this\n121: // classification (for example a registry-drift CI workflow) reports it and\n122: // never independently blocks, so two gates can never disagree or both abstain.\n123: const DRIFT_GATE_OWNER = 'lane-c-compiled-parity';\n124: const DRIFT_GATE_REPORT_ONLY_CONSUMERS = Object.freeze(['routing-registry-drift-ci']);\n125: \n126: // Outer verdicts a compiled block is allowed to raise. A compiled drift or\n127: // broken path takes over only a non-blocked verdict; an existing structural,\n128: // registry, or route-gold block outranks it and stays, so those distinct causes\n129: // never collapse into one another.\n130: const COMPILED_OVERRIDABLE_VERDICTS = Object.freeze(new Set(['PASS', 'CONDITIONAL', 'FAIL', 'NO-SCENARIOS']));\n131: \n132: // ─────────────────────────────────────────────────────────────────────────────\n133: // 3. HELPERS\n134: // ─────────────────────────────────────────────────────────────────────────────\n135: \n136: let eligibleHubsCache = null;\n137: \n138: /**\n139:  * The set of hubs in the compiled serving closure — the only hubs where a\n140:  * missing compiled parity is a real gap rather than structurally `n/a`. Read\n141:  * from the promoted closure manifest, cached, with the promoted runtime's\n142:  * exported hub map as the only fallback. No benchmark-local allowlist exists.\n143:  *\n144:  * @param {string} [manifestPath] - Serving-closure manifest path (override for tests).\n145:  * @returns {Set<string>} Hub ids eligible for compiled parity.\n146:  */\n147: function loadEligibleHubs(manifestPath = SERVING_CLOSURE_MANIFEST) {\n148:   if (manifestPath === SERVING_CLOSURE_MANIFEST && eligibleHubsCache) return eligibleHubsCache;\n149:   let hubs = [];\n150:   try {\n151:     const parsed = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));\n152:     if (Array.isArray(parsed.hubs) && parsed.hubs.length) hubs = parsed.hubs;\n153:   } catch {\n154:     try {\n155:       const runtime = require(PROMOTED_ENGINE);\n156:       hubs = runtime && runtime.HUB_CHILD ? Object.keys(runtime.HUB_CHILD) : [];\n157:     } catch {\n158:       hubs = [];\n159:     }\n160:   }\n161:   const set = new Set(hubs);\n162:   if (manifestPath === SERVING_CLOSURE_MANIFEST) eligibleHubsCache = set;\n163:   return set;\n164: }\n165: \n166: /**\n167:  * Read a hub's live serving authority straight from its activation manifest.\n168:  * Returns 'compiled', 'legacy', or null when the manifest is missing/unreadable\n169:  * (which the guard treats as vacuous, never a pass).\n170:  *\n171:  * @param {string} hubId - Hub id.\n172:  * @param {string} [activationRoot] - Activation root (override for tests).\n173:  * @returns {string|null} Serving authority, or null when unreadable.\n174:  */\n175: function runJsonChild(scriptPath, args, envOverrides = {}) {\n176:   const parentFlag = process.env.SPECKIT_COMPILED_ROUTING;\n177:   const result = spawnSync(\n178:     process.execPath,\n179:     [scriptPath, ...args],\n180:     {\n181:       env: { ...process.env, ...envOverrides },\n182:       encoding: 'utf8',\n183:       shell: false,\n184:     },\n185:   );\n186:   if (process.env.SPECKIT_COMPILED_ROUTING !== parentFlag) {\n187:     throw new Error('compiled child mutated the parent routing flag');\n188:   }\n189:   if (result.error) throw result.error;\n190:   if (result.status !== 0) {\n191:     throw new Error(result.stderr.trim() || `child exited ${result.status}`);\n192:   }\n193:   try {\n194:     return JSON.parse(result.stdout);\n195:   } catch {\n196:     throw new Error(`invalid JSON from ${path.basename(scriptPath)}`);\n197:   }\n198: }\n199: \n200: /**\n201:  * Produce the compiled routing decision for a hub + prompt through the promoted\n202:  * runtime engine. A load or route throw is surfaced (not swallowed) so the\n203:  * caller can classify it as a broken compiled path rather than a false pass.\n204:  *\n205:  * @param {string} hubId - Hub id.\n206:  * @param {string} taskText - Scenario prompt.\n207:  * @returns {Object} Normalized compiled decision ({ action, targets, ... }).\n208:  */\n209: function defaultCompiledDecision(hubId, taskText) {\n210:   return runJsonChild(\n\n(Showing lines 1-210 of 842. Use offset=211 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ compiled-routing-parity — Lane C compiled-vs-legacy parity (non-frozen)  ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n/**\n * compiled-routing-parity.cjs — prove the compiled routing decision matches the\n * legacy decision on a scenario, WITHOUT re-implementing any scoring judgment.\n *\n * This is a non-frozen sibling of the frozen scorer trio. It never edits those\n * files; it only re-hashes them (as a precondition), translates the compiled\n * decision into the legacy evaluator's vocabulary, and delegates the verdict to\n * the frozen `evaluateRouteGold` unchanged. Three guards keep the comparison\n * honest:\n *\n *   1. Vacuous-parity guard. The runtime flag alone is insufficient — the\n *      resolver serves compiled ONLY when the hub's activation manifest also\n *      reads `servingAuthority: compiled`. A lane that trusted the flag would\n *      read a legacy fallback as a false \"parity\" pass, so this reads the hub's","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/compiled-routing-parity.cjs","text":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ compiled-routing-parity — Lane C compiled-vs-legacy parity (non-frozen)  ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\n/**\n * compiled-routing-parity.cjs — prove the compiled routing decision matches the\n * legacy decision on a scenario, WITHOUT re-implementing any scoring judgment.\n *\n * This is a non-frozen sibling of the frozen scorer trio. It never edits those\n * files; it only re-hashes them (as a precondition), translates the compiled\n * decision into the legacy evaluator's vocabulary, and delegates the verdict to\n * the frozen `evaluateRouteGold` unchanged. Three guards keep the comparison\n * honest:\n *\n *   1. Vacuous-parity guard. The runtime flag alone is insufficient — the\n *      resolver serves compiled ONLY when the hub's activation manifest also\n *      reads `servingAuthority: compiled`. A lane that trusted the flag would\n *      read a legacy fallback as a false \"parity\" pass, so this reads the hub's\n *      manifest directly and hard-fails `vacuous` on anything but `compiled`.\n *   2. Shape bridge. Compiled emits qualified destination ids; the frozen\n *      evaluator reads legacy `observedResources`. The two vocabularies are\n *      incompatible without translation, so every target is resolved through the\n *      shared `qualifiedIdToLeaf` boundary before the frozen evaluator runs. A\n *      target that resolves to no manifest mode fails closed, never a silent skip.\n *      A resolved leaf is packet-qualified to match legacy's own hub-relative\n *      convention, then projected down to legacy's own observed granularity for\n *      the gold comparison -- a leaf-manifest declares a whole mode's possible\n *      leaves, legacy's replay selects a task-scoped subset of them, and an\n *      unconditional hub-level resource belongs to no packet's declaration at\n *      all -- so a compiled target's declared breadth is never mistaken for\n *      task-scoped precision, and a genuine compiled declaration gap still\n *      fails closed.\n *   3. Frozen-scorer pin. The three shared scorer files are re-hashed against\n *      pinned digests before any comparison; drift aborts before evidence is\n *      written, so a scorer edited out from under a run never produces a report.\n *\n * The parity status is one of match / drift / vacuous / n/a / resolver-missing;\n * only `match` counts as a pass and `n/a` is informational (a hub that is\n * route-gold enforced but not in the compiled serving closure). The run-level\n * verdict sub-state that these statuses roll up into lives in the orchestrator,\n * never here and never in the frozen scorer.\n *\n * Pure: given its inputs plus the on-disk manifest and compiled artifacts, it\n * makes no network call and no clock-dependent branch. Every external seam\n * (hub eligibility, manifest read, compiled decision, manifest mode index) is an\n * injectable dependency with a production default, so the whole status space is\n * exercisable from fixtures without a live fleet.\n */\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('fs');\nconst path = require('path');\nconst crypto = require('crypto');\nconst { spawnSync } = require('child_process');\n\n// The shared identity contract owns the single conversion boundary from a\n// compiled qualified id to the manifest mode that declares its leaves. Consumed,\n// never redefined, so this harness and the drift guards agree byte for byte.\nconst { qualifiedIdToLeaf } = require(\n  path.join(__dirname, '..', '..', '..', '..', 'sk-doc', 'create-skill', 'scripts', 'lib', 'leaf-resource-contract.cjs'),\n);\n\n// The frozen evaluator is the sole authority for legacy route-gold scoring. It\n// is called, never re-implemented: this harness only feeds it a translated\n// observed decision and compares its verdicts.\nconst { evaluateRouteGold } = require('./score-skill-benchmark.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\n// The promoted runtime closure — what actually serves. The vacuous-parity guard\n// and the compiled engine both read here, never the spec tree, so the harness\n// reflects the routing the fleet would really perform.\nconst SKILLS_ROOT = path.resolve(__dirname, '..', '..', '..', '..');\nconst RUNTIME_ROOT = path.resolve(__dirname, '..', '..', '..', '..', '..', 'bin', 'lib', 'compiled-routing');\nconst ACTIVATION_ROOT = path.join(RUNTIME_ROOT, '010-live-activation', 'activation');\nconst SERVING_CLOSURE_MANIFEST = path.join(RUNTIME_ROOT, 'serving-closure.manifest.json');\nconst PROMOTED_ENGINE = path.join(RUNTIME_ROOT, '011-runtime-engine', 'lib', 'compiled-route.cjs');\nconst PROMOTED_RESOLVER = path.join(RUNTIME_ROOT, '011-runtime-engine', 'lib', 'resolve.cjs');\nconst PUBLIC_FRONT_DOOR = path.resolve(RUNTIME_ROOT, '..', '..', 'compiled-route.cjs');\nconst STATUS_PROBE = path.resolve(RUNTIME_ROOT, '..', '..', 'compiled-route-status.cjs');\n\n// Pinned digests of the frozen scorer trio. Re-hashed before every parity run;\n// any drift aborts before a report is written, so the parity baseline can never\n// be scored against a scorer that changed mid-flight. These are the same digests\n// the activation driver refuses to run without.\nconst PINNED_FROZEN_SCORER_DIGESTS = Object.freeze({\n  'router-replay.cjs': 'd5e13daf3e99469c079e8037c988b31db4d27dfcf5045789d70dceb48de8af47',\n  'score-skill-benchmark.cjs': 'd5a9cc72ec7cfcfb6484f0998f78e7ec16160ecdfee9e3c63f3215c72bf8780c',\n  'load-playbook-scenarios.cjs': '5029f22df920418eb0f87859a7146b83656619943a9fe6f010d6d06e96cdd029',\n});\n\n// Per-scenario parity status. Only `match` is a pass; `n/a` is informational\n// (route-gold enforced but the hub is outside the compiled serving closure);\n// every other value blocks once it rolls up.\nconst PARITY_STATUS = Object.freeze({\n  MATCH: 'match',\n  DRIFT: 'drift',\n  VACUOUS: 'vacuous',\n  NA: 'n/a',\n  RESOLVER_MISSING: 'resolver-missing',\n});\n\n// Run-level verdict sub-state the orchestrator inspects before deciding the\n// outer verdict. Kept distinct so drift and a structurally broken compiled path\n// never collapse into one opaque BLOCKED.\nconst COMPILED_SUBVERDICT = Object.freeze({\n  SERVING: 'compiled-serving',\n  DRIFTED: 'legacy-fallback-drifted',\n  BROKEN: 'broken-compiled-path',\n  NA: 'n/a',\n});\n\n// The single blocking drift-gate owner. Every other consumer of this\n// classification (for example a registry-drift CI workflow) reports it and\n// never independently blocks, so two gates can never disagree or both abstain.\nconst DRIFT_GATE_OWNER = 'lane-c-compiled-parity';\nconst DRIFT_GATE_REPORT_ONLY_CONSUMERS = Object.freeze(['routing-registry-drift-ci']);\n\n// Outer verdicts a compiled block is allowed to raise. A compiled drift or\n// broken path takes over only a non-blocked verdict; an existing structural,\n// registry, or route-gold block outranks it and stays, so those distinct causes\n// never collapse into one another.\nconst COMPILED_OVERRIDABLE_VERDICTS = Object.freeze(new Set(['PASS', 'CONDITIONAL', 'FAIL', 'NO-SCENARIOS']));\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nlet eligibleHubsCache = null;\n\n/**\n * The set of hubs in the compiled serving closure — the only hubs where a\n * missing compiled parity is a real gap rather than structurally `n/a`. Read\n * from the promoted closure manifest, cached, with the promoted runtime's\n * exported hub map as the only fallback. No benchmark-local allowlist exists.\n *\n * @param {string} [manifestPath] - Serving-closure manifest path (override for tests).\n * @returns {Set<string>} Hub ids eligible for compiled parity.\n */\nfunction loadEligibleHubs(manifestPath = SERVING_CLOSURE_MANIFEST) {\n  if (manifestPath === SERVING_CLOSURE_MANIFEST && eligibleHubsCache) return eligibleHubsCache;\n  let hubs = [];\n  try {\n    const parsed = JSON.parse(fs.readFileSync(manifestPath, 'utf8'));\n    if (Array.isArray(parsed.hubs) && parsed.hubs.length) hubs = parsed.hubs;\n  } catch {\n    try {\n      const runtime = require(PROMOTED_ENGINE);\n      hubs = runtime && runtime.HUB_CHILD ? Object.keys(runtime.HUB_CHILD) : [];\n    } catch {\n      hubs = [];\n    }\n  }\n  const set = new Set(hubs);\n  if (manifestPath === SERVING_CLOSURE_MANIFEST) eligibleHubsCache = set;\n  return set;\n}\n\n/**\n * Read a hub's live serving authority straight from its activation manifest.\n * Returns 'compiled', 'legacy', or null when the manifest is missing/unreadable\n * (which the guard treats as vacuous, never a pass).\n *\n * @param {string} hubId - Hub id.\n * @param {string} [activationRoot] - Activation root (override for tests).\n * @returns {string|null} Serving authority, or null when unreadable.\n */\nfunction runJsonChild(scriptPath, args, envOverrides = {}) {\n  const parentFlag = process.env.SPECKIT_COMPILED_ROUTING;\n  const result = spawnSync(\n    process.execPath,\n    [scriptPath, ...args],\n    {\n      env: { ...process.env, ...envOverrides },\n      encoding: 'utf8',\n      shell: false,\n    },\n  );\n  if (process.env.SPECKIT_COMPILED_ROUTING !== parentFlag) {\n    throw new Error('compiled child mutated the parent routing flag');\n  }\n  if (result.error) throw result.error;\n  if (result.status !== 0) {\n    throw new Error(result.stderr.trim() || `child exited ${result.status}`);\n  }\n  try {\n    return JSON.parse(result.stdout);\n  } catch {\n    throw new Error(`invalid JSON from ${path.basename(scriptPath)}`);\n  }\n}\n\n/**\n * Produce the compiled routing decision for a hub + prompt through the promoted\n * runtime engine. A load or route throw is surfaced (not swallowed) so the\n * caller can classify it as a broken compiled path rather than a false pass.\n *\n * @param {string} hubId - Hub id.\n * @param {string} taskText - Scenario prompt.\n * @returns {Object} Normalized compiled decision ({ action, targets, ... }).\n */\nfunction defaultCompiledDecision(hubId, taskText) {\n  return runJsonChild(","lineStart":1,"lineEnd":210,"totalLines":842,"truncated":true}},"title":".opencode/skills/system-deep-loop/deep-improvement/scripts/skill-benchmark/compiled-routing-parity.cjs","time":{"start":1784692812550,"end":1784692812575}},"metadata":{"openai":{"itemId":"fc_02747d6796337114016a60404c6b688191819fbb25b2bec1bf"}},"id":"prt_f87fb2afd0013j3Qt7WGcPkqZp","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f87facd60001VdxwAH5hklaJqq"}}
