   163	        wait_for_completion: true
   164	
   165	  # ═══════════════════════════════════════════════════════════════
   166	  # PHASE 1: INITIALIZATION
   167	  # ═══════════════════════════════════════════════════════════════
   168	  phase_init:
   169	    purpose: Create all state files for the research session
   170	    steps:
   171	
   172	      step_preflight_contract:
   173	        action: "Validate required setup bindings and executable workflow contract before any file writes"
   174	        verify:
   175	          - required_values_present: [research_topic, spec_folder, max_iterations, convergence_threshold]
   176	          - spec_folder_is_within: "specs/ or .opencode/specs/ (canonicalize alias roots before validation)"
   177	          - unresolved_placeholders: "FAIL if any user-facing template references placeholders not produced by earlier steps"
   178	          - tool_contract: "FAIL if executable steps reference tools outside the command allowlist"
   179	        on_fail: "Halt with STATUS=FAIL and report the missing binding or unsupported contract reference"
   180	
   181	      step_create_directories:
   182	        action: "Create spec folder and research packet directories if they don't exist"
   183	        command: "mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}"
   184	
   185	      step_resolve_canonical_names:
   186	        action: "Resolve canonical research packet artifact names before classification"
   187	        inspect_legacy:
   188	          - "{state_paths.packet_dir}/config.json"
   189	          - "{state_paths.packet_dir}/state.jsonl"
   190	          - "{state_paths.packet_dir}/strategy.md"
   191	          - "{state_paths.packet_dir}/dashboard.md"
   192	          - "{state_paths.packet_dir}/.pause"
   193	        migration_policy: "dual-read / single-write for 4 weeks"
   194	        on_legacy_read:
   195	          append_jsonl: '{"type":"event","event":"migration","legacyPath":"{legacy_path}","canonicalPath":"{canonical_path}","timestamp":"{ISO_8601_NOW}"}'
   196	
   197	      step_acquire_lock:
   198	        action: "Acquire the advisory lock defined by the spec_check_protocol before session classification"
   199	        command: "Open {state_paths.lock_file} with exclusive non-blocking advisory locking semantics; if locked, stop and present recovery choices."
   200	        note: "macOS/BSD locking here is advisory. Stale-lock override is confirm-only or explicit recovery-only."
   201	
   202	      step_classify_session:
   203	        action: "Classify the session before writing files"
   204	        inspect:
   205	          - "{state_paths.config}"
   206	          - "{state_paths.state_log}"
   207	          - "{state_paths.strategy}"
   208	        classify:
   209	          fresh: "None of the three state artifacts exist"
   210	          resume: "Config, JSONL, and strategy all exist and agree on topic/spec folder"
   211	          completed-session: "Resume artifacts exist and config.status == 'complete'"
   212	          invalid-state: "Any partial, missing, or contradictory combination"
   213	        outputs:
   214	          - session_state: "fresh | resume | completed-session | invalid-state"
   215	        on_resume:
   216	          show_dashboard: "{state_paths.dashboard}"
   217	          ask: "Existing research session is consistent. Resume where it left off, or restart (archive the current research packet under the root-level research_archive/ tree and start a fresh session)?"
   218	          options: [resume, restart, cancel]
   219	          on_resume_choice:
   220	            set:
   221	              lineage_mode: "resume"
   222	              parent_session_id: "{session_id}"
   223	            append_jsonl: '{"type":"event","event":"resumed","mode":"research","sessionId":"{session_id}","parentSessionId":"{session_id}","lineageMode":"resume","continuedFromRun":{iteration_count},"archivedPath":null,"timestamp":"{ISO_8601_NOW}","generation":{generation}}'
   224	            skip_to: gate_init_approval
   225	          on_restart_choice:
   226	            command: "if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi"
   227	            set:
   228	              lineage_mode: "restart"
   229	              parent_session_id: "{prior_session_id}"
   230	              generation: "{prior_generation + 1}"
   231	            append_jsonl: '{"type":"event","event":"restarted","mode":"research","sessionId":"{session_id}","parentSessionId":"{prior_session_id}","lineageMode":"restart","generation":{generation},"archivedPath":"{state_paths.archive_root}/{timestamp_slug}","timestamp":"{ISO_8601_NOW}"}'
   232	            skip_to: step_create_config
   233	          on_cancel_choice:
   234	            halt: true
   235	            message: "Research session preserved. Manually archive or edit research/ before re-running."
   236	          note: "fork and completed-continue branches are deferred. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are runtime-supported in this release. See deep-research/references/protocol/loop_protocol.md `Session Lifecycle` for the canonical one-session model."
   237	        on_completed_session:
   238	          log: "Prior session already completed. Do not route directly to synthesis; archive the completed research/ tree or start a fresh packet instead."
   239	          halt: true
   240	          message: "Completed deep-research packet detected. Archive or replace the existing research/ tree before starting a new session."
   241	        on_invalid_state:
   242	          halt: true
   243	          message: "Existing deep-research state is incomplete or contradictory. Repair or archive the invalid research packet before continuing."
   244	        on_fresh:
   245	          action: "Proceed with a new session"
   246	
   247	      step_create_config:
   248	        action: "Create deep-research-config.json from template"
   249	        template: .opencode/skills/deep-research/assets/deep_research_config.json
   250	        populate:
   251	          topic: "{research_topic}"
   252	          maxIterations: "{max_iterations}"
   253	          # Semantic: newInfoRatio with negative-knowledge emphasis. See SKILL.md §"Convergence Threshold Semantics".
   254	          convergenceThreshold: "{convergence_threshold}"
   255	          stuckThreshold: 3
   256	          maxDurationMinutes: 120
   257	          specFolder: "{spec_folder}"
   258	          resource_map_present: "{resource_map_present}"
   259	          resource_map.emit: true
   260	          createdAt: "{ISO_8601_NOW}"
   261	          status: "initialized"
   262	          executionMode: "confirm"
   263	          lineage.sessionId: "{AUTO_SESSION_ID}"
   264	          lineage.parentSessionId: null
   265	          lineage.lineageMode: "new"
   266	          lineage.generation: 1
   267	          lineage.continuedFromRun: null
   268	        output: "{state_paths.config}"
   269	
   270	      step_create_state_log:
   271	        action: "Initialize JSONL state log with config record"
   272	        content: '{"type":"config","topic":"{research_topic}","maxIterations":{max_iterations},"convergenceThreshold":{convergence_threshold},"resource_map_present":{resource_map_present},"resource_map":{"emit":true},"createdAt":"{ISO_8601_NOW}","specFolder":"{spec_folder}"}'
   273	        output: "{state_paths.state_log}"
   274	
   275	      step_create_strategy:
   276	        action: "Create strategy file from template with initial questions"
   277	        template: .opencode/skills/deep-research/assets/deep_research_strategy.md
   278	        populate:
   279	          topic: "{research_topic}"
   280	          key_questions: "Derive 3-5 key questions from the research topic"
   281	          known_context: "None"
   282	          known_context_summary: "None"
   283	          max_iterations: "{max_iterations}"
   284	          convergence_threshold: "{convergence_threshold}"
   285	        output: "{state_paths.strategy}"
   286	
   287	      step_create_registry:
   288	        action: "Initialize reducer-owned findings registry"
   289	        content: '{"openQuestions":[],"resolvedQuestions":[],"keyFindings":[],"ruledOutDirections":[],"metrics":{"iterationsCompleted":0,"openQuestions":0,"resolvedQuestions":0,"keyFindings":0,"convergenceScore":0,"coverageBySources":{}}}'
   290	        output: "{state_paths.registry}"
   291	
   292	      step_enrich_strategy_context:
   293	        action: "Ensure Known Context is written only after strategy.md exists"
   294	        condition: "prior_context_found"
   295	        edit: "{state_paths.strategy}"
   296	        note: "Append or replace the Known Context section with prior_context_summary and retained detail from prior_context"
   297	
   298	      step_detect_spec_present:
   299	        action: "Classify late-INIT spec.md state after the durable research packet exists"
   300	        inspect:

