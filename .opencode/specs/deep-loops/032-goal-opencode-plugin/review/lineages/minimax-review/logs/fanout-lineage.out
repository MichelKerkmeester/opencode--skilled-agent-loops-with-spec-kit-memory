t fn({ helpers, pluginModule, stateDir });\n32:   } finally {\n33:     restoreEnv('MK_GOAL_AUTONOMY', originalAutonomy);\n34:     restoreEnv('MK_GOAL_DEBUG', originalDebug);\n35:     await rm(stateDir, { recursive: true, force: true });\n36:   }\n37: }\n38: \n39: async function readGoalEventEntries(stateDir) {\n40:   try {\n\n(Showing lines 1-40 of 654. Use offset=41 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-goal Continuation Tests                                  ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Verify default-off autonomy gates and continuation caps.       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\nconst assert = require('node:assert/strict');\nconst { test } = require('node:test');\nconst { chmod, mkdir, mkdtemp, readFile, rm, utimes, writeFile } = require('node:fs/promises');\nconst { tmpdir } = require('node:os');\nconst { dirname, join } = require('node:path');\nconst { pathToFileURL } = require('node:url');\nconst { readContinuationEntries, restoreEnv } = require('./helpers/continuation-log.cjs');\n\nconst testDir = dirname(__filename);\nconst pluginUrl = pathToFileURL(join(testDir, '..', 'mk-goal.js')).href;\n\nasync function loadPluginModule() {\n  return import(pluginUrl);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/plugins/tests/mk-goal-continuation.test.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ COMPONENT: mk-goal Continuation Tests                                  ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ PURPOSE: Verify default-off autonomy gates and continuation caps.       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n'use strict';\n\nconst assert = require('node:assert/strict');\nconst { test } = require('node:test');\nconst { chmod, mkdir, mkdtemp, readFile, rm, utimes, writeFile } = require('node:fs/promises');\nconst { tmpdir } = require('node:os');\nconst { dirname, join } = require('node:path');\nconst { pathToFileURL } = require('node:url');\nconst { readContinuationEntries, restoreEnv } = require('./helpers/continuation-log.cjs');\n\nconst testDir = dirname(__filename);\nconst pluginUrl = pathToFileURL(join(testDir, '..', 'mk-goal.js')).href;\n\nasync function loadPluginModule() {\n  return import(pluginUrl);\n}\n\nasync function withState(fn) {\n  const pluginModule = await loadPluginModule();\n  const helpers = pluginModule.default.__test;\n  const stateDir = await mkdtemp(join(tmpdir(), 'mk-goal-continuation-'));\n  const originalAutonomy = process.env.MK_GOAL_AUTONOMY;\n  const originalDebug = process.env.MK_GOAL_DEBUG;\n\n  try {\n    return await fn({ helpers, pluginModule, stateDir });\n  } finally {\n    restoreEnv('MK_GOAL_AUTONOMY', originalAutonomy);\n    restoreEnv('MK_GOAL_DEBUG', originalDebug);\n    await rm(stateDir, { recursive: true, force: true });\n  }\n}\n\nasync function readGoalEventEntries(stateDir) {\n  try {","lineStart":1,"lineEnd":40,"totalLines":654,"truncated":true}},"title":".opencode/plugins/tests/mk-goal-continuation.test.cjs","time":{"start":1783147634142,"end":1783147634147}},"id":"prt_f2be19b89001ZOQocPwwoIjqXu","sessionID":"ses_0d42abedcffewM196xEPACWSgW","messageID":"msg_f2be18050001t0OH40fb5VfLRx"}}
