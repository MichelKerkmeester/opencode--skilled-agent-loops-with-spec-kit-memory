   \"sessionPriming\": {\n      \"constitutional\": [],\n      \"triggered\": [],\n      \"codeGraphStatus\": {\n        \"status\": \"error\",\n        \"error\": \"Code graph readiness marker unavailable\"\n      },\n      \"sessionPrimed\": true,\n      \"primedTool\": \"memory_match_triggers\",\n      \"primePackage\": {\n        \"specFolder\": \"sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/002-naming-manifests\",\n        \"currentTask\": \"Execute detached deep-research workflow for naming manifest remediation in spec folder 002-naming-manifests, using lineage artifact directory research/lineages/sol-high-fast, session fanout-sol-high-f\",\n        \"codeGraphStatus\": \"empty\",\n        \"recommendedCalls\": [\n          \"code_graph_scan\"\n        ],\n        \"structuralContext\": {\n          \"status\": \"missing\",\n          \"summary\": \"No structural context available — code graph is empty or unavailable\",\n          \"recommendedAction\": \"Call session_bootstrap first. Then run code_graph_scan if structural context is needed.\",\n          \"sourceSurface\": \"auto-prime\",\n          \"provenance\": {\n            \"producer\": \"session_snapshot\",\n            \"sourceSurface\": \"auto-prime\",\n            \"trustState\": \"absent\",\n            \"generatedAt\": \"2026-07-21T07:39:14.327Z\",\n            \"lastUpdated\": null,\n            \"sourceRefs\": [\n              \"code-graph-db\",\n              \"session-snapshot\"\n            ]\n          }\n        },\n        \"routingRules\": {\n          \"graphRetrieval\": \"For broad topic questions, use memory_search with retrievalLevel: \\\"global\\\" for community-level results. For specific memories, use \\\"local\\\" (default). Use \\\"auto\\\" for automatic fallback.\",\n          \"communitySearch\": \"When primary search returns weak results, community search fallback activates automatically (SPECKIT_COMMUNITY_SEARCH_FALLBACK). Graph provenance is visible in graphEvidence field.\",\n          \"toolRouting\": \"SEARCH ROUTING: exact text/regex → Grep\"\n        }\n      },\n      \"surfaced_at\": \"2026-07-21T07:39:14.327Z\",\n      \"latencyMs\": 1\n    },\n    \"autoSurfacedContext\": {\n      \"constitutional\": [],\n      \"triggered\": [\n        {\n          \"memory_id\": 3877,\n          \"spec_folder\": \"system-deep-loop/z_archive/006-deep-skill-evolution/005-deep-research/006-hygiene-fix-pack\",\n          \"title\": \"Feature Specification: Deep Research Hygiene and Negative Knowledge Dedup\",\n          \"matched_phrases\": [\n            \"deep-research\"\n          ]\n        },\n        {\n          \"memory_id\": 3873,\n          \"spec_folder\": \"system-deep-loop/z_archive/006-deep-skill-evolution/005-deep-research/005-uncovered-questions\",\n          \"title\": \"Feature Specification: Deep Research Uncovered Questions Tracking\",\n          \"matched_phrases\": [\n            \"deep-research\"\n          ]\n        },\n        {\n          \"memory_id\": 2701,\n          \"spec_folder\": \"system-code-graph/z_archive/012-query-routing-integration\",\n          \"title\": \"Feature Specification: Query-Routing [system-code-graph/z_archive/012-query-routing-integration/spec]\",\n          \"matched_phrases\": [\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 2696,\n          \"spec_folder\": \"system-code-graph/z_archive/011-code-graph-auto-trigger\",\n          \"title\": \"Phase 019: Code Graph Auto-Trigger [system-code-graph/z_archive/011-code-graph-auto-trigger/spec]\",\n          \"matched_phrases\": [\n            \"spec\"\n          ]\n        },\n        {\n          \"memory_id\": 2691,\n          \"spec_folder\": \"system-code-graph/z_archive/010-tree-sitter-classifier-fixes\",\n          \"title\": \"Phase 017: Tree-Sitter & Query-Intent [system-code-graph/z_archive/010-tree-sitter-classifier-fixes/spec]\",\n          \"matched_phrases\": [\n            \"spec\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-07-21T07:39:16.214Z\",\n      \"latencyMs\": 1887\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1784619551670,"end":1784619557029}},"metadata":{"openai":{"itemId":"fc_07108520c832069c016a5f221d8d3c8191bd9b856a47cf423d"}},"id":"prt_f839d4382001I9cd0vwrf6HFof","sessionID":"ses_07c62e1e5ffemFsnADH4fVqMT5","messageID":"msg_f839d2093001Pkp7PLj5aLnRB8"}}
