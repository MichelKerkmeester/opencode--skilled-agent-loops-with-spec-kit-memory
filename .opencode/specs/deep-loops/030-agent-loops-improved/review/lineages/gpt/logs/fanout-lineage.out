ills/system-spec-kit/scripts/spec/validate.sh:1021\",\"evidence\":\"Phase 011 handoff requires all 7 children complete, but validate.sh's node recursive path iterates only direct children of the provided folder. The recorded packet-030 validation evidence says 12/12 folders, which covers the root plus 11 direct phases, not 011's 7 grandchildren.\",\"finding_class\":\"verification-gap\",\"content_hash\":\"sha256:gpt-f002-root-recursive-misses-nested-children\",\"disposition\":\"active\"}],\"newFindingsRatio\":0.5,\"timestamp\":\"2026-07-02T12:02:00.000Z\",\"durationMs\":60000,\"sessionId\":\"fanout-gpt-1782998103426-5a2g5w\",\"generation\":1,\"lineageMode\":\"new\"}\n+{\"type\":\"iteration\",\"iteration\":3,\"run\":3,\"mode\":\"review\",\"status\":\"complete\",\"focus\":\"correctness - validate.sh node-path strict validators\",\"dimensions\":[\"correctness\"],\"filesReviewed\":[\".opencode/skills/system-spec-kit/scripts/spec/validate.sh:1194\",\".opencode/skills/system-spec-kit/mcp_server/lib/validation/orchestrator.ts:268\",\".opencode/skills/system-spec-kit/scripts/lib/validator-registry.json:312\"],\"findingsCount\":1,\"findingsSummary\":{\"P0\":0,\"P1\":1,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":1,\"P2\":0},\"findingDetails\":[{\"id\":\"GPT-F003\",\"severity\":\"P1\",\"category\":\"validation\",\"title\":\"Default Node validation path still skips strict-only evidence and continuity lint rules\",\"file\":\".opencode/skills/system-spec-kit/scripts/spec/validate.sh:1194\",\"evidence\":\"When SPECKIT_COMPLETION_FRESHNESS is off, validate.sh invokes run_node_orchestrator, which exits after the Node report. The orchestrator bridge filters strict_only registry entries, so CONTINUITY_FRESHNESS and EVIDENCE_MARKER_LINT never run in that default Node path even under --strict.\",\"finding_class\":\"validation-coverage-gap\",\"content_hash\":\"sha256:gpt-f003-node-path-skips-strict-only-rules\",\"disposition\":\"active\"}],\"newFindingsRatio\":0.333333,\"timestamp\":\"2026