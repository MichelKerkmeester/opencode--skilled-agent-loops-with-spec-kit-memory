vent === 'retry_scheduled')).toHaveLength(2);\n\n  Line 621:     expect(result.results[0]).toMatchObject({ status: 'rejected', retry_attempts: 5, retry_exhausted: true });\n\n  Line 622:     expect(events.filter((event) => event.event === 'retry_scheduled')).toEqual([]);\n\n  Line 625:   it('counts retry attempts from retry_scheduled ledger rows', () => {\n\n  Line 628:     appendStatusLedger(ledger, { event: 'retry_scheduled', label: 'a' });\n\n  Line 629:     appendStatusLedger(ledger, { event: 'retry_scheduled', label: 'a' });\n\n  Line 630:     appendStatusLedger(ledger, { event: 'retry_scheduled', label: 'b' });\n","metadata":{"matches":18,"truncated":false},"title":"fanout-pool|runFanoutPool|executeReplica|retry_scheduled|retry_exhausted","time":{"start":1783487332854,"end":1783487332870}},"metadata":{"openai":{"itemId":"fc_07cfe05cfbb4e1aa016a4ddb64b8808191b61a37308b6c5abc"}},"id":"prt_f402101f2001OMnFN7xV6Uv4dk","sessionID":"ses_0bfeb66ceffe83jWKFM65pCjvi","messageID":"msg_f4020dfcc001Zv5tEs3FwnzGp3"}}
