{"type":"tool_use","timestamp":1784619836570,"sessionID":"ses_07c62e1e5ffemFsnADH4fVqMT5","part":{"type":"tool","tool":"read","callID":"call_nTiNvn2vpfDMITnG8T3h3hnq","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts","offset":600,"limit":590},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts</path>\n<type>file</type>\n<content>\n600:   };\n601:   const record = buildReceiptRecord('completion', ctx.dispatchId, facts, ctx.key);\n602:   tryWriteReceipt(input.stateLogPath, input.executor, input.iteration, 'completion', ctx.completionPath, record);\n603: }\n604: \n605: // ───── EXPORTS ─────\n606: \n607: /**\n608:  * Detect whether the same executor kind already appears in the dispatch stack.\n609:  *\n610:  * @param stack - The SPECKIT_CLI_DISPATCH_STACK env value.\n611:  * @param kind - The executor kind to check.\n612:  * @returns True if the kind is already present in the stack.\n613:  */\n614: export function detectSameKindFromStack(stack: string | undefined, kind: ExecutorKind): boolean {\n615:   if (kind === 'native') {\n616:     return false;\n617:   }\n618: \n619:   return splitDispatchStack(stack).includes(kind);\n620: }\n621: \n622: /**\n623:  * Detect whether an executor binary appears in the process ancestry.\n624:  *\n625:  * Reads Linux /proc ancestor cmdlines to find the executor binary.\n626:  *\n627:  * @param kind - The executor kind to check.\n628:  * @param ancestryCmdlines - Pre-computed ancestor command lines (optional).\n629:  * @returns True if the executor binary is found in the ancestry.\n630:  */\n631: export function detectFromAncestry(kind: ExecutorKind, ancestryCmdlines: string[] = readLinuxAncestorCmdlines()): boolean {\n632:   const binary = EXECUTOR_BINARY_BY_KIND[kind];\n633:   if (!binary) {\n634:     return false;\n635:   }\n636: \n637:   return ancestryCmdlines.some((commandLine) => commandLineContainsBinary(commandLine, binary));\n638: }\n639: \n640: /**\n641:  * Detect whether a runtime session environment variable is set for an executor.\n642:  *\n643:  * @param kind - The executor kind to check.\n644:  * @param env - Environment variable map (defaults to process.env).\n645:  * @returns True if the session environment variable is set.\n646:  */\n647: export function detectFromRuntimeEnv(\n648:   kind: ExecutorKind,\n649:   env: Record<string, string | undefined> = process.env,\n650: ): boolean {\n651:   const sessionEnvName = EXECUTOR_SESSION_ENV_BY_KIND[kind];\n652:   if (!sessionEnvName) {\n653:     return false;\n654:   }\n655: \n656:   return typeof env[sessionEnvName] === 'string' && env[sessionEnvName]?.trim() !== '';\n657: }\n658: \n659: /**\n660:  * Detect whether a dispatch lockfile exists in executor state directories.\n661:  *\n662:  * @param kind - The executor kind to check.\n663:  * @param statePaths - State directory paths to scan (defaults to auto-detected).\n664:  * @returns True if a lockfile is found.\n665:  */\n666: export function detectFromLockfile(kind: ExecutorKind, statePaths: string[] = getDefaultStatePaths(kind, process.env)): boolean {\n667:   if (kind === 'native') {\n668:     return false;\n669:   }\n670: \n671:   const names = candidateLockfileNames(kind);\n672:   for (const statePath of statePaths) {\n673:     const directories = [statePath, join(statePath, 'locks')];\n674:     for (const directory of directories) {\n675:       if (!pathIsReadableDirectory(directory)) {\n676:         continue;\n677:       }\n678:       const entries = new Set(readdirSync(directory));\n679:       if (names.some((name) => entries.has(name))) {\n680:         return true;\n681:       }\n682:     }\n683:   }\n684: \n685:   return false;\n686: }\n687: \n688: /**\n689:  * Validate that an executor dispatch is allowed.\n690:  *\n691:  * Checks stack, ancestry, runtime env, and lockfile layers for recursion\n692:  * guard violations per the deep-loop dispatch contract.\n693:  *\n694:  * @param config - Executor configuration.\n695:  * @param context - Optional environment, ancestry, and state path context.\n696:  * @returns Dispatch result indicating whether dispatch is allowed.\n697:  */\n698: export function validateExecutorDispatchAllowed(\n699:   config: ExecutorConfig,\n700:   context: ExecutorDispatchGuardContext = {},\n701: ): ExecutorDispatchAllowedResult {\n702:   const kind = getExecutorKind(config);\n703:   if (kind === 'native') {\n704:     return { allowed: true };\n705:   }\n706: \n707:   const env = context.env ?? process.env;\n708:   const stack = env[CLI_DISPATCH_STACK_ENV];\n709:   if (detectSameKindFromStack(stack, kind)) {\n710:     return {\n711:       allowed: false,\n712:       layer: 'stack',\n713:       reason: recursionReasonForLayer('stack'),\n714:       detail: `${kind} already appears in ${CLI_DISPATCH_STACK_ENV}`,\n715:     };\n716:   }\n717: \n718:   if (detectFromAncestry(kind, context.ancestryCmdlines)) {\n719:     return {\n720:       allowed: false,\n721:       layer: 'ancestry',\n722:       reason: recursionReasonForLayer('ancestry'),\n723:       detail: `${kind} executor binary appears in process ancestry`,\n724:     };\n725:   }\n726: \n727:   if (detectFromRuntimeEnv(kind, env)) {\n728:     const envName = EXECUTOR_SESSION_ENV_BY_KIND[kind] ?? 'runtime session env';\n729:     return {\n730:       allowed: false,\n731:       layer: 'env',\n732:       reason: recursionReasonForLayer('env'),\n733:       detail: `${envName} is set for ${kind}`,\n734:     };\n735:   }\n736: \n737:   const statePaths = context.statePaths ?? getDefaultStatePaths(kind, env);\n738:   if (detectFromLockfile(kind, statePaths)) {\n739:     return {\n740:       allowed: false,\n741:       layer: 'lockfile',\n742:       reason: recursionReasonForLayer('lockfile'),\n743:       detail: `${kind} dispatch lockfile exists in runtime state path`,\n744:     };\n745:   }\n746: \n747:   return { allowed: true };\n748: }\n749: \n750: /**\n751:  * Build the environment for a dispatched executor.\n752:  *\n753:  * Filters the parent environment to only include allowed keys per executor kind\n754:  * and appends the current kind to the dispatch stack.\n755:  *\n756:  * @param config - Executor configuration.\n757:  * @param parentEnv - Parent environment (defaults to process.env).\n758:  * @returns Filtered environment with dispatch stack updated.\n759:  */\n760: export function buildExecutorDispatchEnv(\n761:   config: ExecutorConfig,\n762:   parentEnv: Record<string, string | undefined> = process.env,\n763: ): Record<string, string | undefined> {\n764:   const kind = getExecutorKind(config);\n765:   if (kind === 'native') {\n766:     return { ...parentEnv };\n767:   }\n768: \n769:   const nextEnv: Record<string, string | undefined> = {};\n770:   for (const [key, value] of Object.entries(parentEnv)) {\n771:     if (value !== undefined && isAllowedExecutorEnvKey(key, kind)) {\n772:       nextEnv[key] = value;\n773:     }\n774:   }\n775:   nextEnv[CLI_DISPATCH_STACK_ENV] = [...splitDispatchStack(parentEnv[CLI_DISPATCH_STACK_ENV]), kind].join(':');\n776:   return nextEnv;\n777: }\n778: \n779: /**\n780:  * Build an executor audit record for provenance logging.\n781:  *\n782:  * @param executor - Executor configuration.\n783:  * @returns Audit record with kind, model, reasoning effort, and service tier.\n784:  */\n785: export function buildExecutorAuditRecord(executor: ExecutorConfig, lineageId?: string): Record<string, unknown> {\n786:   return {\n787:     kind: getExecutorKind(executor),\n788:     model: executor.model,\n789:     reasoningEffort: executor.reasoningEffort,\n790:     serviceTier: executor.serviceTier,\n791:     ...(lineageId !== undefined ? { lineageId } : {}),\n792:   };\n793: }\n794: \n795: /**\n796:  * Write the first executor provenance record for an iteration.\n797:  *\n798:  * Updates the iteration start record in the JSONL state log with executor\n799:  * audit data, or creates a new iteration_start record if none exists.\n800:  *\n801:  * @param stateLogPath - Path to the JSONL state log.\n802:  * @param executor - Executor configuration.\n803:  * @param iteration - Current iteration number.\n804:  */\n805: export function writeFirstRecordExecutor(stateLogPath: string, executor: ExecutorConfig, iteration: number): void {\n806:   if (getExecutorKind(executor) === 'native') {\n807:     return;\n808:   }\n809: \n810:   const { lines, hasTrailingNewline } = readJsonlFileAfterTailRepair(stateLogPath);\n811:   const recordIndex = findLatestIterationRecordIndex(lines, iteration);\n812: \n813:   if (recordIndex !== -1) {\n814:     const parsedRecord = JSON.parse(lines[recordIndex]);\n815:     if (!isObjectRecord(parsedRecord)) {\n816:       throw new Error(`Iteration ${iteration} JSONL record is not an object`);\n817:     }\n818: \n819:     if (isObjectRecord(parsedRecord.executor)) {\n820:       return;\n821:     }\n822: \n823:     lines[recordIndex] = JSON.stringify({\n824:       ...parsedRecord,\n825:       executor: buildExecutorAuditRecord(executor),\n826:     });\n827:     rewriteJsonlFile(stateLogPath, lines, hasTrailingNewline);\n828:     return;\n829:   }\n830: \n831:   appendJsonlRecordSafe(stateLogPath, {\n832:     type: 'iteration_start',\n833:     iteration,\n834:     executor: buildExecutorAuditRecord(executor),\n835:     timestamp: new Date().toISOString(),\n836:   });\n837: }\n838: \n839: /**\n840:  * Emit a dispatch failure event to the JSONL state log.\n841:  *\n842:  * @param stateLogPath - Path to the JSONL state log.\n843:  * @param executor - Executor configuration.\n844:  * @param reason - Dispatch failure reason.\n845:  * @param iteration - Current iteration number.\n846:  * @param detail - Optional failure detail string.\n847:  */\n848: export function emitDispatchFailure(\n849:   stateLogPath: string,\n850:   executor: ExecutorConfig,\n851:   reason: DispatchFailureReason,\n852:   iteration: number,\n853:   detail?: string,\n854: ): void {\n855:   const executorAudit = getExecutorKind(executor) === 'native'\n856:     ? undefined\n857:     : buildExecutorAuditRecord(executor);\n858:   const lastIterationEvent = findLatestIterationEvent(readJsonlFileAfterTailRepair(stateLogPath).lines, iteration);\n859:   if (\n860:     lastIterationEvent?.event === 'dispatch_failure'\n861:     && lastIterationEvent.reason === reason\n862:     && lastIterationEvent.detail === (detail || undefined)\n863:     && JSON.stringify(lastIterationEvent.executor) === JSON.stringify(executorAudit)\n864:   ) {\n865:     return;\n866:   }\n867: \n868:   appendJsonlRecordSafe(stateLogPath, {\n869:     type: 'event',\n870:     event: 'dispatch_failure',\n871:     ...(executorAudit ? { executor: executorAudit } : {}),\n872:     reason,\n873:     iteration,\n874:     ...(detail ? { detail } : {}),\n875:     timestamp: new Date().toISOString(),\n876:   });\n877: }\n878: \n879: /**\n880:  * Run a non-native executor command synchronously and log dispatch failures.\n881:  *\n882:  * Detects timeout, crash, and non-zero exit conditions and translates\n883:  * them into typed dispatch_failure JSONL events.\n884:  *\n885:  * @param input - Command input with executor config and state log path.\n886:  * @returns Always returns 0 (failures are logged, not thrown).\n887:  */\n888: export function runAuditedExecutorCommand(input: RunAuditedExecutorCommandInput): number {\n889:   const dispatchAllowed = validateExecutorDispatchAllowed(input.executor, input.guardContext);\n890:   if (!dispatchAllowed.allowed) {\n891:     emitDispatchFailure(input.stateLogPath, input.executor, dispatchAllowed.reason, input.iteration, dispatchAllowed.detail);\n892:     return 0;\n893:   }\n894: \n895:   // Pre-dispatch INTENT receipt (engine-signed, no child id yet). Null when the\n896:   // caller did not opt into receipts.\n897:   const receiptCtx = beginReceipt(input);\n898: \n899:   const timeoutMs = Number.isFinite(input.timeoutSeconds)\n900:     ? Math.max(1000, Math.trunc(input.timeoutSeconds * 1000) - 1000)\n901:     : 1000;\n902:   const result = spawnSync(input.command, input.args, {\n903:     cwd: input.cwd,\n904:     encoding: 'utf8',\n905:     timeout: timeoutMs,\n906:     env: buildExecutorDispatchEnv(input.executor, input.guardContext?.env ?? process.env),\n907:     maxBuffer: 10 * 1024 * 1024,\n908:     ...(typeof input.input === 'string' ? { input: input.input } : {}),\n909:   });\n910: \n911:   if (typeof result.stdout === 'string' && result.stdout.length > 0) {\n912:     process.stdout.write(result.stdout);\n913:   }\n914:   if (typeof result.stderr === 'string' && result.stderr.length > 0) {\n915:     process.stderr.write(result.stderr);\n916:   }\n917: \n918:   // Post-dispatch COMPLETION countersign: bind the INTENT to the child facts the\n919:   // wrapper observed (pid / exit / signal). Written before failure classification\n920:   // so it always reflects the real outcome, even when the dispatch crashed.\n921:   if (receiptCtx) {\n922:     completeReceipt(input, receiptCtx, {\n923:       childPid: typeof result.pid === 'number' ? result.pid : null,\n924:       exitStatus: typeof result.status === 'number' ? result.status : null,\n925:       signal: typeof result.signal === 'string' ? result.signal : null,\n926:       sessionId: null,\n927:     });\n928:   }\n929: \n930:   if (result.error) {\n931:     const isTimeoutError =\n932:       result.error.name === 'TimeoutError' ||\n933:       (typeof result.error === 'object' &&\n934:         result.error !== null &&\n935:         'code' in result.error &&\n936:         result.error.code === 'ETIMEDOUT');\n937:     emitDispatchFailure(\n938:       input.stateLogPath,\n939:       input.executor,\n940:       isTimeoutError ? 'timeout' : 'crash',\n941:       input.iteration,\n942:       result.error.message,\n943:     );\n944:     return 0;\n945:   }\n946: \n947:   if (typeof result.status === 'number' && result.status !== 0) {\n948:     emitDispatchFailure(\n949:       input.stateLogPath,\n950:       input.executor,\n951:       'crash',\n952:       input.iteration,\n953:       `executor exited with status ${result.status}`,\n954:     );\n955:     return 0;\n956:   }\n957: \n958:   if (typeof result.signal === 'string' && result.signal.length > 0) {\n959:     emitDispatchFailure(\n960:       input.stateLogPath,\n961:       input.executor,\n962:       'crash',\n963:       input.iteration,\n964:       `executor terminated by signal ${result.signal}`,\n965:     );\n966:     return 0;\n967:   }\n968: \n969:   // Provenance must not lie: a clean exit can fail loud when the model the CLI\n970:   // actually ran differs from the one the caller requested. DISABLED BY DEFAULT —\n971:   // current CLIs (the live opencode build) omit the model on a successful stream,\n972:   // so extractActualModel returns null and the check would never fire usefully.\n973:   // It is opt-in via SPECKIT_PROVENANCE_CHECK=1, ready to activate once a build\n974:   // surfaces the model on stdout. It fails safe regardless: an unknown actual\n975:   // model is skipped, never a false loud failure.\n976:   if (process.env.SPECKIT_PROVENANCE_CHECK === '1') {\n977:     const requestedModel = input.executor.model;\n978:     const actualModel = extractActualModel(typeof result.stdout === 'string' ? result.stdout : '', getExecutorKind(input.executor));\n979:     if (\n980:       actualModel !== null &&\n981:       typeof requestedModel === 'string' &&\n982:       requestedModel.trim() !== '' &&\n983:       normalizeModelId(actualModel) !== normalizeModelId(requestedModel)\n984:     ) {\n985:       emitDispatchFailure(\n986:         input.stateLogPath,\n987:         input.executor,\n988:         'model_mismatch',\n989:         input.iteration,\n990:         `requested model ${requestedModel} but executor ran ${actualModel}`,\n991:       );\n992:       return 0;\n993:     }\n994:   }\n995: \n996:   return 0;\n997: }\n998: \n999: /**\n1000:  * Run a non-native executor command asynchronously with signal escalation.\n1001:  *\n1002:  * Uses spawn + detached process group for graceful timeout handling with\n1003:  * SIGTERM escalation to SIGKILL after the grace period.\n1004:  *\n1005:  * @param input - Command input with executor config and state log path.\n1006:  * @returns Promise resolving to 0 after process completes.\n1007:  */\n1008: export async function runAuditedExecutorCommandAsync(input: RunAuditedExecutorCommandInput): Promise<number> {\n1009:   const dispatchAllowed = validateExecutorDispatchAllowed(input.executor, input.guardContext);\n1010:   if (!dispatchAllowed.allowed) {\n1011:     emitDispatchFailure(input.stateLogPath, input.executor, dispatchAllowed.reason, input.iteration, dispatchAllowed.detail);\n1012:     return 0;\n1013:   }\n1014: \n1015:   // Pre-dispatch INTENT receipt (engine-signed, no child id yet).\n1016:   const receiptCtx = beginReceipt(input);\n1017: \n1018:   const timeoutMs = Number.isFinite(input.timeoutSeconds)\n1019:     ? Math.max(1, Math.trunc(input.timeoutSeconds * 1000))\n1020:     : 1000;\n1021:   const graceMs = Number.isFinite(input.timeoutGraceMs)\n1022:     ? Math.max(1, Math.trunc(input.timeoutGraceMs ?? 250))\n1023:     : 250;\n1024: \n1025:   await new Promise<void>((resolve) => {\n1026:     let timedOut = false;\n1027:     let settled = false;\n1028:     let completionWritten = false;\n1029:     let graceTimer: NodeJS.Timeout | undefined;\n1030:     const child = spawn(input.command, input.args, {\n1031:       cwd: input.cwd,\n1032:       detached: process.platform !== 'win32',\n1033:       env: buildExecutorDispatchEnv(input.executor, input.guardContext?.env ?? process.env),\n1034:       stdio: ['pipe', 'pipe', 'pipe'],\n1035:     });\n1036:     // Capture the real child pid before any handler runs; on spawn failure it may\n1037:     // be undefined, in which case the COMPLETION records a null pid (no child).\n1038:     const childPid = typeof child.pid === 'number' ? child.pid : null;\n1039: \n1040:     const writeCompletionOnce = (status: number | null, signal: NodeJS.Signals | null): void => {\n1041:       if (completionWritten || !receiptCtx) {\n1042:         return;\n1043:       }\n1044:       completionWritten = true;\n1045:       completeReceipt(input, receiptCtx, {\n1046:         childPid,\n1047:         exitStatus: status,\n1048:         signal,\n1049:         sessionId: null,\n1050:       });\n1051:     };\n1052: \n1053:     const timeoutTimer = setTimeout(() => {\n1054:       timedOut = true;\n1055:       killProcessGroup(child.pid, 'SIGTERM');\n1056:       graceTimer = setTimeout(() => {\n1057:         killProcessGroup(child.pid, 'SIGKILL');\n1058:       }, graceMs);\n1059:     }, timeoutMs);\n1060: \n1061:     if (typeof input.input === 'string') {\n1062:       child.stdin.write(input.input);\n1063:     }\n1064:     child.stdin.end();\n1065: \n1066:     child.stdout.on('data', (chunk: Buffer) => {\n1067:       process.stdout.write(chunk);\n1068:     });\n1069:     child.stderr.on('data', (chunk: Buffer) => {\n1070:       process.stderr.write(chunk);\n1071:     });\n1072: \n1073:     child.on('error', (error: Error) => {\n1074:       if (settled) {\n1075:         return;\n1076:       }\n1077:       settled = true;\n1078:       clearTimeout(timeoutTimer);\n1079:       if (graceTimer) clearTimeout(graceTimer);\n1080:       // Spawn failed before a child existed; countersign with null facts.\n1081:       writeCompletionOnce(null, null);\n1082:       emitDispatchFailure(input.stateLogPath, input.executor, 'crash', input.iteration, error.message);\n1083:       resolve();\n1084:     });\n1085: \n1086:     child.on('close', (status: number | null, signal: NodeJS.Signals | null) => {\n1087:       if (settled) {\n1088:         return;\n1089:       }\n1090:       settled = true;\n1091:       clearTimeout(timeoutTimer);\n1092:       if (graceTimer) clearTimeout(graceTimer);\n1093: \n1094:       // Bind INTENT to the observed child exit facts before failure classification.\n1095:       writeCompletionOnce(status, signal);\n1096: \n1097:       if (timedOut) {\n1098:         emitDispatchFailure(\n1099:           input.stateLogPath,\n1100:           input.executor,\n1101:           'timeout',\n1102:           input.iteration,\n1103:           `executor timed out after ${timeoutMs}ms`,\n1104:         );\n1105:         resolve();\n1106:         return;\n1107:       }\n1108: \n1109:       if (typeof status === 'number' && status !== 0) {\n1110:         emitDispatchFailure(\n1111:           input.stateLogPath,\n1112:           input.executor,\n1113:           'crash',\n1114:           input.iteration,\n1115:           `executor exited with status ${status}`,\n1116:         );\n1117:         resolve();\n1118:         return;\n1119:       }\n1120: \n1121:       if (typeof signal === 'string' && signal.length > 0) {\n1122:         emitDispatchFailure(\n1123:           input.stateLogPath,\n1124:           input.executor,\n1125:           'crash',\n1126:           input.iteration,\n1127:           `executor terminated by signal ${signal}`,\n1128:         );\n1129:       }\n1130: \n1131:       resolve();\n1132:     });\n1133:   });\n1134: \n1135:   return 0;\n1136: }\n1137: \n1138: /**\n1139:  * Append executor audit information to the last JSONL record in the state log.\n1140:  *\n1141:  * @param stateLogPath - Path to the JSONL state log.\n1142:  * @param executor - Executor configuration.\n1143:  * @throws If the state log is empty or the last record is not an object.\n1144:  */\n1145: export function appendExecutorAuditToLastRecord(stateLogPath: string, executor: ExecutorConfig): void {\n1146:   if (getExecutorKind(executor) === 'native') {\n1147:     return;\n1148:   }\n1149: \n1150:   const { lines, hasTrailingNewline } = readJsonlFile(stateLogPath);\n1151:   const lastLineIndex = findLastNonEmptyLineIndex(lines);\n1152: \n1153:   if (lastLineIndex === -1) {\n1154:     throw new Error('State log does not contain any JSONL records');\n1155:   }\n1156: \n1157:   const parsedRecord = JSON.parse(lines[lastLineIndex]);\n1158:   if (parsedRecord === null || Array.isArray(parsedRecord) || typeof parsedRecord !== 'object') {\n1159:     throw new Error('Last JSONL record is not an object');\n1160:   }\n1161: \n1162:   const mergedRecord: Record<string, unknown> = {\n1163:     ...parsedRecord,\n1164:     executor: buildExecutorAuditRecord(executor),\n1165:   };\n1166: \n1167:   lines[lastLineIndex] = JSON.stringify(mergedRecord);\n1168:   rewriteJsonlFile(stateLogPath, lines, hasTrailingNewline);\n1169: }\n\n(End of file - total 1169 lines)\n</content>","metadata":{"preview":"  };\n  const record = buildReceiptRecord('completion', ctx.dispatchId, facts, ctx.key);\n  tryWriteReceipt(input.stateLogPath, input.executor, input.iteration, 'completion', ctx.completionPath, record);\n}\n\n// ───── EXPORTS ─────\n\n/**\n * Detect whether the same executor kind already appears in the dispatch stack.\n *\n * @param stack - The SPECKIT_CLI_DISPATCH_STACK env value.\n * @param kind - The executor kind to check.\n * @returns True if the kind is already present in the stack.\n */\nexport function detectSameKindFromStack(stack: string | undefined, kind: ExecutorKind): boolean {\n  if (kind === 'native') {\n    return false;\n  }\n\n  return splitDispatchStack(stack).includes(kind);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts","text":"  };\n  const record = buildReceiptRecord('completion', ctx.dispatchId, facts, ctx.key);\n  tryWriteReceipt(input.stateLogPath, input.executor, input.iteration, 'completion', ctx.completionPath, record);\n}\n\n// ───── EXPORTS ─────\n\n/**\n * Detect whether the same executor kind already appears in the dispatch stack.\n *\n * @param stack - The SPECKIT_CLI_DISPATCH_STACK env value.\n * @param kind - The executor kind to check.\n * @returns True if the kind is already present in the stack.\n */\nexport function detectSameKindFromStack(stack: string | undefined, kind: ExecutorKind): boolean {\n  if (kind === 'native') {\n    return false;\n  }\n\n  return splitDispatchStack(stack).includes(kind);\n}\n\n/**\n * Detect whether an executor binary appears in the process ancestry.\n *\n * Reads Linux /proc ancestor cmdlines to find the executor binary.\n *\n * @param kind - The executor kind to check.\n * @param ancestryCmdlines - Pre-computed ancestor command lines (optional).\n * @returns True if the executor binary is found in the ancestry.\n */\nexport function detectFromAncestry(kind: ExecutorKind, ancestryCmdlines: string[] = readLinuxAncestorCmdlines()): boolean {\n  const binary = EXECUTOR_BINARY_BY_KIND[kind];\n  if (!binary) {\n    return false;\n  }\n\n  return ancestryCmdlines.some((commandLine) => commandLineContainsBinary(commandLine, binary));\n}\n\n/**\n * Detect whether a runtime session environment variable is set for an executor.\n *\n * @param kind - The executor kind to check.\n * @param env - Environment variable map (defaults to process.env).\n * @returns True if the session environment variable is set.\n */\nexport function detectFromRuntimeEnv(\n  kind: ExecutorKind,\n  env: Record<string, string | undefined> = process.env,\n): boolean {\n  const sessionEnvName = EXECUTOR_SESSION_ENV_BY_KIND[kind];\n  if (!sessionEnvName) {\n    return false;\n  }\n\n  return typeof env[sessionEnvName] === 'string' && env[sessionEnvName]?.trim() !== '';\n}\n\n/**\n * Detect whether a dispatch lockfile exists in executor state directories.\n *\n * @param kind - The executor kind to check.\n * @param statePaths - State directory paths to scan (defaults to auto-detected).\n * @returns True if a lockfile is found.\n */\nexport function detectFromLockfile(kind: ExecutorKind, statePaths: string[] = getDefaultStatePaths(kind, process.env)): boolean {\n  if (kind === 'native') {\n    return false;\n  }\n\n  const names = candidateLockfileNames(kind);\n  for (const statePath of statePaths) {\n    const directories = [statePath, join(statePath, 'locks')];\n    for (const directory of directories) {\n      if (!pathIsReadableDirectory(directory)) {\n        continue;\n      }\n      const entries = new Set(readdirSync(directory));\n      if (names.some((name) => entries.has(name))) {\n        return true;\n      }\n    }\n  }\n\n  return false;\n}\n\n/**\n * Validate that an executor dispatch is allowed.\n *\n * Checks stack, ancestry, runtime env, and lockfile layers for recursion\n * guard violations per the deep-loop dispatch contract.\n *\n * @param config - Executor configuration.\n * @param context - Optional environment, ancestry, and state path context.\n * @returns Dispatch result indicating whether dispatch is allowed.\n */\nexport function validateExecutorDispatchAllowed(\n  config: ExecutorConfig,\n  context: ExecutorDispatchGuardContext = {},\n): ExecutorDispatchAllowedResult {\n  const kind = getExecutorKind(config);\n  if (kind === 'native') {\n    return { allowed: true };\n  }\n\n  const env = context.env ?? process.env;\n  const stack = env[CLI_DISPATCH_STACK_ENV];\n  if (detectSameKindFromStack(stack, kind)) {\n    return {\n      allowed: false,\n      layer: 'stack',\n      reason: recursionReasonForLayer('stack'),\n      detail: `${kind} already appears in ${CLI_DISPATCH_STACK_ENV}`,\n    };\n  }\n\n  if (detectFromAncestry(kind, context.ancestryCmdlines)) {\n    return {\n      allowed: false,\n      layer: 'ancestry',\n      reason: recursionReasonForLayer('ancestry'),\n      detail: `${kind} executor binary appears in process ancestry`,\n    };\n  }\n\n  if (detectFromRuntimeEnv(kind, env)) {\n    const envName = EXECUTOR_SESSION_ENV_BY_KIND[kind] ?? 'runtime session env';\n    return {\n      allowed: false,\n      layer: 'env',\n      reason: recursionReasonForLayer('env'),\n      detail: `${envName} is set for ${kind}`,\n    };\n  }\n\n  const statePaths = context.statePaths ?? getDefaultStatePaths(kind, env);\n  if (detectFromLockfile(kind, statePaths)) {\n    return {\n      allowed: false,\n      layer: 'lockfile',\n      reason: recursionReasonForLayer('lockfile'),\n      detail: `${kind} dispatch lockfile exists in runtime state path`,\n    };\n  }\n\n  return { allowed: true };\n}\n\n/**\n * Build the environment for a dispatched executor.\n *\n * Filters the parent environment to only include allowed keys per executor kind\n * and appends the current kind to the dispatch stack.\n *\n * @param config - Executor configuration.\n * @param parentEnv - Parent environment (defaults to process.env).\n * @returns Filtered environment with dispatch stack updated.\n */\nexport function buildExecutorDispatchEnv(\n  config: ExecutorConfig,\n  parentEnv: Record<string, string | undefined> = process.env,\n): Record<string, string | undefined> {\n  const kind = getExecutorKind(config);\n  if (kind === 'native') {\n    return { ...parentEnv };\n  }\n\n  const nextEnv: Record<string, string | undefined> = {};\n  for (const [key, value] of Object.entries(parentEnv)) {\n    if (value !== undefined && isAllowedExecutorEnvKey(key, kind)) {\n      nextEnv[key] = value;\n    }\n  }\n  nextEnv[CLI_DISPATCH_STACK_ENV] = [...splitDispatchStack(parentEnv[CLI_DISPATCH_STACK_ENV]), kind].join(':');\n  return nextEnv;\n}\n\n/**\n * Build an executor audit record for provenance logging.\n *\n * @param executor - Executor configuration.\n * @returns Audit record with kind, model, reasoning effort, and service tier.\n */\nexport function buildExecutorAuditRecord(executor: ExecutorConfig, lineageId?: string): Record<string, unknown> {\n  return {\n    kind: getExecutorKind(executor),\n    model: executor.model,\n    reasoningEffort: executor.reasoningEffort,\n    serviceTier: executor.serviceTier,\n    ...(lineageId !== undefined ? { lineageId } : {}),\n  };\n}\n\n/**\n * Write the first executor provenance record for an iteration.\n *\n * Updates the iteration start record in the JSONL state log with executor\n * audit data, or creates a new iteration_start record if none exists.\n *\n * @param stateLogPath - Path to the JSONL state log.\n * @param executor - Executor configuration.\n * @param iteration - Current iteration number.\n */\nexport function writeFirstRecordExecutor(stateLogPath: string, executor: ExecutorConfig, iteration: number): void {\n  if (getExecutorKind(executor) === 'native') {\n    return;\n  }\n\n  const { lines, hasTrailingNewline } = readJsonlFileAfterTailRepair(stateLogPath);\n  const recordIndex = findLatestIterationRecordIndex(lines, iteration);\n\n  if (recordIndex !== -1) {\n    const parsedRecord = JSON.parse(lines[recordIndex]);\n    if (!isObjectRecord(parsedRecord)) {\n      throw new Error(`Iteration ${iteration} JSONL record is not an object`);\n    }\n\n    if (isObjectRecord(parsedRecord.executor)) {\n      return;\n    }\n\n    lines[recordIndex] = JSON.stringify({\n      ...parsedRecord,\n      executor: buildExecutorAuditRecord(executor),\n    });\n    rewriteJsonlFile(stateLogPath, lines, hasTrailingNewline);\n    return;\n  }\n\n  appendJsonlRecordSafe(stateLogPath, {\n    type: 'iteration_start',\n    iteration,\n    executor: buildExecutorAuditRecord(executor),\n    timestamp: new Date().toISOString(),\n  });\n}\n\n/**\n * Emit a dispatch failure event to the JSONL state log.\n *\n * @param stateLogPath - Path to the JSONL state log.\n * @param executor - Executor configuration.\n * @param reason - Dispatch failure reason.\n * @param iteration - Current iteration number.\n * @param detail - Optional failure detail string.\n */\nexport function emitDispatchFailure(\n  stateLogPath: string,\n  executor: ExecutorConfig,\n  reason: DispatchFailureReason,\n  iteration: number,\n  detail?: string,\n): void {\n  const executorAudit = getExecutorKind(executor) === 'native'\n    ? undefined\n    : buildExecutorAuditRecord(executor);\n  const lastIterationEvent = findLatestIterationEvent(readJsonlFileAfterTailRepair(stateLogPath).lines, iteration);\n  if (\n    lastIterationEvent?.event === 'dispatch_failure'\n    && lastIterationEvent.reason === reason\n    && lastIterationEvent.detail === (detail || undefined)\n    && JSON.stringify(lastIterationEvent.executor) === JSON.stringify(executorAudit)\n  ) {\n    return;\n  }\n\n  appendJsonlRecordSafe(stateLogPath, {\n    type: 'event',\n    event: 'dispatch_failure',\n    ...(executorAudit ? { executor: executorAudit } : {}),\n    reason,\n    iteration,\n    ...(detail ? { detail } : {}),\n    timestamp: new Date().toISOString(),\n  });\n}\n\n/**\n * Run a non-native executor command synchronously and log dispatch failures.\n *\n * Detects timeout, crash, and non-zero exit conditions and translates\n * them into typed dispatch_failure JSONL events.\n *\n * @param input - Command input with executor config and state log path.\n * @returns Always returns 0 (failures are logged, not thrown).\n */\nexport function runAuditedExecutorCommand(input: RunAuditedExecutorCommandInput): number {\n  const dispatchAllowed = validateExecutorDispatchAllowed(input.executor, input.guardContext);\n  if (!dispatchAllowed.allowed) {\n    emitDispatchFailure(input.stateLogPath, input.executor, dispatchAllowed.reason, input.iteration, dispatchAllowed.detail);\n    return 0;\n  }\n\n  // Pre-dispatch INTENT receipt (engine-signed, no child id yet). Null when the\n  // caller did not opt into receipts.\n  const receiptCtx = beginReceipt(input);\n\n  const timeoutMs = Number.isFinite(input.timeoutSeconds)\n    ? Math.max(1000, Math.trunc(input.timeoutSeconds * 1000) - 1000)\n    : 1000;\n  const result = spawnSync(input.command, input.args, {\n    cwd: input.cwd,\n    encoding: 'utf8',\n    timeout: timeoutMs,\n    env: buildExecutorDispatchEnv(input.executor, input.guardContext?.env ?? process.env),\n    maxBuffer: 10 * 1024 * 1024,\n    ...(typeof input.input === 'string' ? { input: input.input } : {}),\n  });\n\n  if (typeof result.stdout === 'string' && result.stdout.length > 0) {\n    process.stdout.write(result.stdout);\n  }\n  if (typeof result.stderr === 'string' && result.stderr.length > 0) {\n    process.stderr.write(result.stderr);\n  }\n\n  // Post-dispatch COMPLETION countersign: bind the INTENT to the child facts the\n  // wrapper observed (pid / exit / signal). Written before failure classification\n  // so it always reflects the real outcome, even when the dispatch crashed.\n  if (receiptCtx) {\n    completeReceipt(input, receiptCtx, {\n      childPid: typeof result.pid === 'number' ? result.pid : null,\n      exitStatus: typeof result.status === 'number' ? result.status : null,\n      signal: typeof result.signal === 'string' ? result.signal : null,\n      sessionId: null,\n    });\n  }\n\n  if (result.error) {\n    const isTimeoutError =\n      result.error.name === 'TimeoutError' ||\n      (typeof result.error === 'object' &&\n        result.error !== null &&\n        'code' in result.error &&\n        result.error.code === 'ETIMEDOUT');\n    emitDispatchFailure(\n      input.stateLogPath,\n      input.executor,\n      isTimeoutError ? 'timeout' : 'crash',\n      input.iteration,\n      result.error.message,\n    );\n    return 0;\n  }\n\n  if (typeof result.status === 'number' && result.status !== 0) {\n    emitDispatchFailure(\n      input.stateLogPath,\n      input.executor,\n      'crash',\n      input.iteration,\n      `executor exited with status ${result.status}`,\n    );\n    return 0;\n  }\n\n  if (typeof result.signal === 'string' && result.signal.length > 0) {\n    emitDispatchFailure(\n      input.stateLogPath,\n      input.executor,\n      'crash',\n      input.iteration,\n      `executor terminated by signal ${result.signal}`,\n    );\n    return 0;\n  }\n\n  // Provenance must not lie: a clean exit can fail loud when the model the CLI\n  // actually ran differs from the one the caller requested. DISABLED BY DEFAULT —\n  // current CLIs (the live opencode build) omit the model on a successful stream,\n  // so extractActualModel returns null and the check would never fire usefully.\n  // It is opt-in via SPECKIT_PROVENANCE_CHECK=1, ready to activate once a build\n  // surfaces the model on stdout. It fails safe regardless: an unknown actual\n  // model is skipped, never a false loud failure.\n  if (process.env.SPECKIT_PROVENANCE_CHECK === '1') {\n    const requestedModel = input.executor.model;\n    const actualModel = extractActualModel(typeof result.stdout === 'string' ? result.stdout : '', getExecutorKind(input.executor));\n    if (\n      actualModel !== null &&\n      typeof requestedModel === 'string' &&\n      requestedModel.trim() !== '' &&\n      normalizeModelId(actualModel) !== normalizeModelId(requestedModel)\n    ) {\n      emitDispatchFailure(\n        input.stateLogPath,\n        input.executor,\n        'model_mismatch',\n        input.iteration,\n        `requested model ${requestedModel} but executor ran ${actualModel}`,\n      );\n      return 0;\n    }\n  }\n\n  return 0;\n}\n\n/**\n * Run a non-native executor command asynchronously with signal escalation.\n *\n * Uses spawn + detached process group for graceful timeout handling with\n * SIGTERM escalation to SIGKILL after the grace period.\n *\n * @param input - Command input with executor config and state log path.\n * @returns Promise resolving to 0 after process completes.\n */\nexport async function runAuditedExecutorCommandAsync(input: RunAuditedExecutorCommandInput): Promise<number> {\n  const dispatchAllowed = validateExecutorDispatchAllowed(input.executor, input.guardContext);\n  if (!dispatchAllowed.allowed) {\n    emitDispatchFailure(input.stateLogPath, input.executor, dispatchAllowed.reason, input.iteration, dispatchAllowed.detail);\n    return 0;\n  }\n\n  // Pre-dispatch INTENT receipt (engine-signed, no child id yet).\n  const receiptCtx = beginReceipt(input);\n\n  const timeoutMs = Number.isFinite(input.timeoutSeconds)\n    ? Math.max(1, Math.trunc(input.timeoutSeconds * 1000))\n    : 1000;\n  const graceMs = Number.isFinite(input.timeoutGraceMs)\n    ? Math.max(1, Math.trunc(input.timeoutGraceMs ?? 250))\n    : 250;\n\n  await new Promise<void>((resolve) => {\n    let timedOut = false;\n    let settled = false;\n    let completionWritten = false;\n    let graceTimer: NodeJS.Timeout | undefined;\n    const child = spawn(input.command, input.args, {\n      cwd: input.cwd,\n      detached: process.platform !== 'win32',\n      env: buildExecutorDispatchEnv(input.executor, input.guardContext?.env ?? process.env),\n      stdio: ['pipe', 'pipe', 'pipe'],\n    });\n    // Capture the real child pid before any handler runs; on spawn failure it may\n    // be undefined, in which case the COMPLETION records a null pid (no child).\n    const childPid = typeof child.pid === 'number' ? child.pid : null;\n\n    const writeCompletionOnce = (status: number | null, signal: NodeJS.Signals | null): void => {\n      if (completionWritten || !receiptCtx) {\n        return;\n      }\n      completionWritten = true;\n      completeReceipt(input, receiptCtx, {\n        childPid,\n        exitStatus: status,\n        signal,\n        sessionId: null,\n      });\n    };\n\n    const timeoutTimer = setTimeout(() => {\n      timedOut = true;\n      killProcessGroup(child.pid, 'SIGTERM');\n      graceTimer = setTimeout(() => {\n        killProcessGroup(child.pid, 'SIGKILL');\n      }, graceMs);\n    }, timeoutMs);\n\n    if (typeof input.input === 'string') {\n      child.stdin.write(input.input);\n    }\n    child.stdin.end();\n\n    child.stdout.on('data', (chunk: Buffer) => {\n      process.stdout.write(chunk);\n    });\n    child.stderr.on('data', (chunk: Buffer) => {\n      process.stderr.write(chunk);\n    });\n\n    child.on('error', (error: Error) => {\n      if (settled) {\n        return;\n      }\n      settled = true;\n      clearTimeout(timeoutTimer);\n      if (graceTimer) clearTimeout(graceTimer);\n      // Spawn failed before a child existed; countersign with null facts.\n      writeCompletionOnce(null, null);\n      emitDispatchFailure(input.stateLogPath, input.executor, 'crash', input.iteration, error.message);\n      resolve();\n    });\n\n    child.on('close', (status: number | null, signal: NodeJS.Signals | null) => {\n      if (settled) {\n        return;\n      }\n      settled = true;\n      clearTimeout(timeoutTimer);\n      if (graceTimer) clearTimeout(graceTimer);\n\n      // Bind INTENT to the observed child exit facts before failure classification.\n      writeCompletionOnce(status, signal);\n\n      if (timedOut) {\n        emitDispatchFailure(\n          input.stateLogPath,\n          input.executor,\n          'timeout',\n          input.iteration,\n          `executor timed out after ${timeoutMs}ms`,\n        );\n        resolve();\n        return;\n      }\n\n      if (typeof status === 'number' && status !== 0) {\n        emitDispatchFailure(\n          input.stateLogPath,\n          input.executor,\n          'crash',\n          input.iteration,\n          `executor exited with status ${status}`,\n        );\n        resolve();\n        return;\n      }\n\n      if (typeof signal === 'string' && signal.length > 0) {\n        emitDispatchFailure(\n          input.stateLogPath,\n          input.executor,\n          'crash',\n          input.iteration,\n          `executor terminated by signal ${signal}`,\n        );\n      }\n\n      resolve();\n    });\n  });\n\n  return 0;\n}\n\n/**\n * Append executor audit information to the last JSONL record in the state log.\n *\n * @param stateLogPath - Path to the JSONL state log.\n * @param executor - Executor configuration.\n * @throws If the state log is empty or the last record is not an object.\n */\nexport function appendExecutorAuditToLastRecord(stateLogPath: string, executor: ExecutorConfig): void {\n  if (getExecutorKind(executor) === 'native') {\n    return;\n  }\n\n  const { lines, hasTrailingNewline } = readJsonlFile(stateLogPath);\n  const lastLineIndex = findLastNonEmptyLineIndex(lines);\n\n  if (lastLineIndex === -1) {\n    throw new Error('State log does not contain any JSONL records');\n  }\n\n  const parsedRecord = JSON.parse(lines[lastLineIndex]);\n  if (parsedRecord === null || Array.isArray(parsedRecord) || typeof parsedRecord !== 'object') {\n    throw new Error('Last JSONL record is not an object');\n  }\n\n  const mergedRecord: Record<string, unknown> = {\n    ...parsedRecord,\n    executor: buildExecutorAuditRecord(executor),\n  };\n\n  lines[lastLineIndex] = JSON.stringify(mergedRecord);\n  rewriteJsonlFile(stateLogPath, lines, hasTrailingNewline);\n}","lineStart":600,"lineEnd":1169,"totalLines":1169,"truncated":false}},"title":".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts","time":{"start":1784619836563,"end":1784619836569}},"metadata":{"openai":{"itemId":"fc_0afa9bb5a441cfe8016a5f233b68cc8191aa4750adf288bd0c"}},"id":"prt_f83a1a031001ZPnZkoOYHgRz0n","sessionID":"ses_07c62e1e5ffemFsnADH4fVqMT5","messageID":"msg_f83a1916e001IdXw9RjcDFmkvU"}}
