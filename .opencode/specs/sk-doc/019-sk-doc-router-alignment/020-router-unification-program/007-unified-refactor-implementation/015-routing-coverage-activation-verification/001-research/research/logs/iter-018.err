     1	#!/usr/bin/env node
     2	// ╔══════════════════════════════════════════════════════════════════════════╗
     3	// ║ live-executor — Mode B live executor (cli-opencode)                      ║
     4	// ╚══════════════════════════════════════════════════════════════════════════╝
     5	'use strict';
     6	
     7	/**
     8	 * live-executor.cjs — Mode B live executor (cli-opencode).
     9	 *
    10	 * Runs a playbook routing/advisor scenario through a real `opencode run` and
    11	 * reads back what actually happened, normalized into the observed-result shape
    12	 * the scorer consumes. Validated against the live event schema (see the Phase 0
    13	 * spike): NDJSON events of shape { type, timestamp, sessionID, part }, where
    14	 *   - tool_use:  part.tool (e.g. "skill","read","glob","grep","bash"),
    15	 *                part.state.input, part.state.output
    16	 *   - text:      part.text  (the model's final answer)
    17	 *
    18	 * KEY observability fact: opencode emits no startup "resources loaded" manifest.
    19	 * So we run scenarios as routing-ANALYSIS prompts — the model STATES its routing
    20	 * in a fenced JSON block, which we grade against gold. tool_use events
    21	 * corroborate (a `skill` call with input.name === skillId is hard activation
    22	 * evidence; read/glob/grep on the skill's tree is observed discovery).
    23	 *
    24	 * Self-contained dispatch (does not reuse dispatch-model.cjs): MiniMax models
    25	 * reject `--agent`, which that helper hardcodes, and we need `--format json`.
    26	 * Model + binary come from env so no machine-specific id is baked in.
    27	 */
    28	
    29	// ─────────────────────────────────────────────────────────────────────────────
    30	// 1. IMPORTS/REQUIRES
    31	// ─────────────────────────────────────────────────────────────────────────────
    32	
    33	const fs = require('fs');
    34	const path = require('path');
    35	const { spawnSync } = require('child_process');
    36	
    37	// ─────────────────────────────────────────────────────────────────────────────
    38	// 2. CONSTANTS
    39	// ─────────────────────────────────────────────────────────────────────────────
    40	
    41	const DEFAULT_MODEL = process.env.SKILL_BENCH_OPENCODE_MODEL || 'deepseek/deepseek-v4-pro';
    42	const DEFAULT_VARIANT = process.env.SKILL_BENCH_OPENCODE_VARIANT || 'high';
    43	const OPENCODE_BIN = process.env.OPENCODE_BIN || 'opencode';
    44	const DISPATCH_TIMEOUT_MS = Number(process.env.SKILL_BENCH_DISPATCH_TIMEOUT_MS || 360000);
    45	const GRADED_RESPONSE_MAX_CHARS = 8000;
    46	
    47	// ─────────────────────────────────────────────────────────────────────────────
    48	// 3. CORE LOGIC
    49	// ─────────────────────────────────────────────────────────────────────────────
    50	
    51	/**
    52	 * Wrap the scenario prompt as a routing-ANALYSIS task with a strict output
    53	 * contract. CS-* scenarios are already analysis-shaped; SD/LS/RD/SA get the
    54	 * reframe. Route-gold cases add a declaration line before the fenced json block
    55	 * the parser can read.
    56	 *
    57	 * @param {Object} scenario - Scenario being dispatched.
    58	 * @returns {string} The routing-analysis dispatch prompt.
    59	 */
    60	function buildLiveDispatchPrompt(scenario, skillId) {
    61	  const base = scenario.prompt || '';
