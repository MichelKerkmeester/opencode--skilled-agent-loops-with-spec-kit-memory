   285	  if (result.stdout) {
   286	    process.stderr.write(result.stdout);
   287	  }
   288	  if (result.stderr) {
   289	    process.stderr.write(result.stderr);
   290	  }
   291	  if (result.error) {
   292	    throw result.error;
   293	  }
   294	  if (result.status !== 0) {
   295	    throw new Error(`${command} ${args.join(' ')} exited ${result.status}`);
   296	  }
   297	}
