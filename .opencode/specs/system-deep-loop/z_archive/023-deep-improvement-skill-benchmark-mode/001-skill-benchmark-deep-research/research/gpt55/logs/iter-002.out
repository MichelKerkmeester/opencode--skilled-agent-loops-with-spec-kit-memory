.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/014-two-lane-deep-review/review/iterations/iteration-5.md:1:[{"id":"correctness-5-1","severity":"P1","dimension":"correctness","title":"5dim scoring ignores forbidden patterns","file":".opencode/skills/deep-agent-improvement/scripts/model-benchmark/run-benchmark.cjs","line":220,"evidence":"The pattern scorer checks fixture.forbiddenPatterns, but the 5dim path passes only acceptance, requiredHeadings, and requiredPatterns into scorerModule.score; fixture.forbiddenPatterns are omitted entirely.","fix":"Carry forbiddenPatterns into scoreFixture5dim and fail/add failureModes when any forbidden pattern matches, or extend score-model-variant to consume and enforce forbiddenPatterns."},{"id":"correctness-5-2","severity":"P1","dimension":"correctness","title":"Unknown grader silently degrades to mock","file":".opencode/skills/deep-agent-improvement/scripts/model-benchmark/run-benchmark.cjs","line":328,"evidence":"graderKind is assigned directly from args.grader with no enum validation, while the documented contract only allows noop|mock|llm; downstream non-noop/non-llm grader values take the mock path.","fix":"Validate args.grader against new Set(['noop','mock','llm']) before scoring; fail fast or warn and explicitly default, and persist the resolved grader in the report/state record."},{"id":"correctness-5-3","severity":"P1","dimension":"correctness","title":"Plateau stop can fire on partial dimension data","file":".opencode/skills/deep-agent-improvement/scripts/shared/reduce-state.cjs","line":777,"evidence":"dimsWithEnoughData filters to only dimensions with enough samples, then line 783 stops when all of that subset plateaued; one populated dimension can therefore report 'all dimensions plateaued' while the other dimensions have no data.","fix":"Require every expected scored dimension to have plateauWindow samples before the all-dimensions plateau stop, or rename and gate this as a configured partial-dimension plateau rule."},{"id":"correctness-5-4","severity":"P1","dimension":"correctness","title":"Interactive Lane B promotion condition is unreachable","file":".opencode/commands/deep/assets/deep_start-model-benchmark-loop_confirm.yaml","line":202,"evidence":"The promotion step condition checks benchmark_recommendation == 'candidate-better', but run-benchmark emits recommendations as 'benchmark-pass' or 'benchmark-fail'.","fix":"Change the condition to the benchmark enum, e.g. benchmark_recommendation == 'benchmark-pass', and keep any candidate/target evidence gates separate."}]
