tion = expectedSurface === 'UNKNOWN'\n140:     || /disambiguation|must not|asks? for clarification|top-1\\s*!=\\s*sk-code|routes? .* to sk-doc/.test(lowerPass)\n141:     || /\\bUNKNOWN\\b/.test(text.split('\\n').slice(0, 30).join('\\n'));\n142: \n143:   const classKind = classifyKind(id, category, expectedSurface, passCriteria);\n144: \n145:   return {\n146:     scenarioId: id,\n147:     category: category || null,\n148:     prompt: prompt || null,\n149:     classKind,\n150:     expectedSurface,\n151:     expectedSubLanguage: subLangM ? subLangM[1].toUpperCase() : null,\n152:     expectedIntent: null,\n153:     expectedResources,\n154:     expectedAssets,\n155:     passCriteria,\n156:     critical: !!critical,\n157:     negativeActivation,\n158:     source: { featureFile: path.relative(path.dirname(path.dirname(absPath)), absPath), shape: 'sk-code' },\n159:     parseWarnings: prompt ? [] : ['missing-exact-prompt'],\n160:   };\n161: }\n162: \n163: // Parse the root index table mapping id -> {category, featureFile, critical}.\n164: function parseRootIndex(rootText) {\n165:   const idx = [];\n166:   const secStart = rootText.search(/##\\s+\\d+\\.\\s+FEATURE CATALOG CROSS-REFERENCE INDEX/i);\n167:   const scope = secStart === -1 ? rootText : rootText.slice(secStart);\n168:   for (const line of scope.split('\\n')) {\n169:     // Row shape parsed below: | <category> | <AA-000> | `<feature-file>.md` | <Yes|No> |\n170:     const m = /^\\|\\s*([^|]+?)\\s*\\|\\s*([A-Z]{2}-\\d{3})\\s*\\|\\s*`?([^|`]+?\\.md)`?\\s*\\|\\s*(Yes|No)\\s*\\|/.exec(line);\n171:     if (m) {\n172:       idx.push({\n173:         categoryLabel: m[1].trim(),\n174:         scenarioId: m[2],\n175:         featureFile: m[3].trim(),\n176:         critical: /yes/i.test(m[4]),\n177:       });\n178:     }\n179:   }\n180:   return idx;\n181: }\n182: \n183: // sk-doc shape: walk per-scenario files, read YAML frontmatter gold.\n184: function loadYamlFrontmatterScenarios(playbookDir) {\n185:   const out = [];\n186:   const stack = [playbookDir];\n187:   while (stack.length) {\n188:     const cur = stack.pop();\n189:     let entries;\n190:     try { entries = fs.readdirSync(cur, { withFileTypes: true }); } catch { continue; }\n191:     for (const e of entries) {\n192:       const full = path.join(cur, e.name);\n193:       if (e.isDirectory()) { stack.push(full); continue; }\n194:       if (!e.isFile() || !/^\\d{3}-.*\\.md$/.test(e.name)) continue;\n195:       const text = readFileSafe(full);\n196:       if (!text) continue;\n197:       const fm = /^---\\n([\\s\\S]*?)\\n---/.exec(text);\n198:       if (!fm) continue;\n199:       const block = fm[1];\n200:       const idM = /(?:^|\\n)id:\\s*[\"']?([A-Za-z0-9-]+)/.exec(block);\n201:       const intentM = /expected_intent:\\s*[\"']?([A-Za-z_]+)/.exec(block);\n202:       const resM = /expected_resources:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/.exec(block);\n203:       const resources = resM ? extractPaths(resM[1]) : [];\n204:       const category = path.basename(cur);\n205:       const prompt = parsePromptBlock(text);\n206:       const id = idM ? idM[1] : e.name.replace(/\\.md$/, '');\n207:       out.push({\n208:         scenarioId: id,\n209:         category,\n210:         prompt: prompt || null,\n211:         classKind: classifyKind(id, category, null, intentM ? intentM[1] : ''),\n212:         expectedSurface: null,\n213:         expectedSubLanguage: null,\n214:         expectedIntent: intentM ? intentM[1] : null,\n215:         expectedResources: resources,\n216:         expectedAssets: [],\n217:         passCriteria: null,\n218:         critical: false,\n219:         negativeActivation: false,\n\n(Showing lines 120-219 of 271. Use offset=220 to continue.)\n</content>","metadata":{"preview":"\n  const prompt = parsePromptBlock(text) || (rootEntry && rootEntry.prompt) || null;\n  // Per-feature files vary: \"- Surface: `WEBFLOW`\" (SD/LS) vs \"**Expected surface**: `WEBFLOW`\" (CS).\n  const surfaceM = /(?:Expected\\s+)?Surface\\*{0,2}:\\s*`