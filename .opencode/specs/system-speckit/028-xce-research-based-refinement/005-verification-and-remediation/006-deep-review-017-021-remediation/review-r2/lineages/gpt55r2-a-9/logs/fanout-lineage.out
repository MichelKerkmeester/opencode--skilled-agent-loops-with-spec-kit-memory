{"type":"tool_use","timestamp":1781764178866,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_lXOUtUbVek5YFOroBTEC1drg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","offset":1,"limit":210},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Orchestrator\n3: // ───────────────────────────────────────────────────────────────\n4: // 4-stage pipeline execution with per-stage error handling and timeouts.\n5: //\n6: // Each stage is wrapped in try/catch with withTimeout().\n7: // Stage 1 is mandatory (throws on failure — no candidates = no results).\n8: // Stages 2-4 fall back to previous stage output with degraded metadata.\n9: // Timing is recorded for latency observability.\n10: //\n11: // I/O CONTRACT:\n12: // Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n13: // Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n14: // Key invariants:\n15: //     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n16: //     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n17: //     - Stage metadata for all four stages is included for observability\n18: //     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n19: // Side effects:\n20: //     - Delegates to each stage; see individual stage modules for their side effects\n21: \n22: import type {\n23:   PipelineConfig,\n24:   PipelineResult,\n25:   Stage1Output,\n26:   Stage2Output,\n27:   Stage3Output,\n28:   Stage4Output,\n29:   Stage4ReadonlyRow,\n30:   SignalStatus,\n31: } from './types.js';\n32: \n33: import { executeStage1 } from './stage1-candidate-gen.js';\n34: import { executeStage2 } from './stage2-fusion.js';\n35: import { executeStage3 } from './stage3-rerank.js';\n36: import { executeStage4 } from './stage4-filter.js';\n37: import { MemoryError, withTimeout } from '../../errors/core.js';\n38: \n39: // Feature catalog: 4-stage pipeline architecture\n40: // Feature catalog: 4-stage pipeline refactor\n41: \n42: \n43: /** Per-stage timeout in milliseconds. */\n44: const STAGE_TIMEOUT_MS = 10_000;\n45: \n46: /**\n47:  * Execute the 4-stage retrieval pipeline with per-stage error handling.\n48:  *\n49:  * Stage 1: Candidate Generation — MANDATORY (throws on failure)\n50:  * Stage 2: Fusion + Signal Integration — falls back to unsorted candidates\n51:  * Stage 3: Rerank + Aggregate — falls back to unranked scored results\n52:  * Stage 4: Filter + Annotate — falls back to unfiltered results\n53:  *\n54:  * @param config Pipeline configuration derived from search args\n55:  * @returns Pipeline result with stage metadata and timing\n56:  */\n57: export async function executePipeline(config: PipelineConfig): Promise<PipelineResult> {\n58:   const timing: Record<string, number> = {};\n59:   const pipelineStart = Date.now();\n60:   let degraded = false;\n61: \n62:   // -- Stage 1: Candidate Generation (MANDATORY — no fallback possible) --\n63:   let stage1Result: Stage1Output;\n64:   try {\n65:     const t0 = Date.now();\n66:     stage1Result = await withTimeout(\n67:       executeStage1({ config }),\n68:       STAGE_TIMEOUT_MS,\n69:       'Stage 1: Candidate Generation',\n70:     );\n71:     timing.stage1 = Date.now() - t0;\n72:   } catch (err) {\n73:     throw new MemoryError(\n74:       'PIPELINE_STAGE1_FAILED',\n75:       `Candidate generation failed: ${err instanceof Error ? err.message : String(err)}`,\n76:       { cause: err instanceof Error ? err.message : String(err) },\n77:     );\n78:   }\n79: \n80:   // -- Stage 2: Fusion + Signal Integration (falls back to unsorted candidates) --\n81:   let stage2Result: Stage2Output;\n82:   try {\n83:     const t0 = Date.now();\n84:     stage2Result = await withTimeout(\n85:       executeStage2({\n86:         candidates: stage1Result.candidates,\n87:         config,\n88:         stage1Metadata: stage1Result.metadata,\n89:       }),\n90:       STAGE_TIMEOUT_MS,\n91:       'Stage 2: Fusion',\n92:     );\n93:     timing.stage2 = Date.now() - t0;\n94:   } catch (err) {\n95:     const msg = err instanceof Error ? err.message : String(err);\n96:     console.warn(`[pipeline] Stage 2 failed, returning unscored candidates: ${msg}`);\n97:     degraded = true;\n98:     stage2Result = {\n99:       scored: stage1Result.candidates,\n100:       metadata: {\n101:         sessionBoostApplied: 'failed' as SignalStatus,\n102:         causalBoostApplied: 'failed' as SignalStatus,\n103:         intentWeightsApplied: 'failed' as SignalStatus,\n104:         artifactRoutingApplied: 'failed' as SignalStatus,\n105:         feedbackSignalsApplied: 'failed' as SignalStatus,\n106:         qualityFiltered: 0,\n107:         durationMs: 0,\n108:       },\n109:     };\n110:     timing.stage2 = 0;\n111:   }\n112: \n113:   // -- Stage 3: Rerank + Aggregate (falls back to unranked scored results) --\n114:   let stage3Result: Stage3Output;\n115:   try {\n116:     const t0 = Date.now();\n117:     stage3Result = await withTimeout(\n118:       executeStage3({\n119:         scored: stage2Result.scored,\n120:         config,\n121:       }),\n122:       STAGE_TIMEOUT_MS,\n123:       'Stage 3: Rerank',\n124:     );\n125:     timing.stage3 = Date.now() - t0;\n126:   } catch (err) {\n127:     const msg = err instanceof Error ? err.message : String(err);\n128:     console.warn(`[pipeline] Stage 3 failed, returning unranked results: ${msg}`);\n129:     degraded = true;\n130:     stage3Result = {\n131:       reranked: stage2Result.scored,\n132:       metadata: {\n133:         rerankApplied: false,\n134:         chunkReassemblyStats: {\n135:           collapsedChunkHits: 0,\n136:           chunkParents: 0,\n137:           reassembled: 0,\n138:           fallback: 0,\n139:         },\n140:         durationMs: 0,\n141:       },\n142:     };\n143:     timing.stage3 = 0;\n144:   }\n145: \n146:   // -- Stage 4: Filter + Annotate (falls back to unfiltered results) --\n147:   let stage4Result: Stage4Output;\n148:   try {\n149:     const t0 = Date.now();\n150:     stage4Result = await withTimeout(\n151:       executeStage4({\n152:         results: stage3Result.reranked as Stage4ReadonlyRow[],\n153:         config,\n154:         stage1Metadata: { constitutionalInjected: stage1Result.metadata.constitutionalInjected },\n155:       }),\n156:       STAGE_TIMEOUT_MS,\n157:       'Stage 4: Filter',\n158:     );\n159:     timing.stage4 = Date.now() - t0;\n160:   } catch (err) {\n161:     const msg = err instanceof Error ? err.message : String(err);\n162:     console.warn(`[pipeline] Stage 4 failed, returning unfiltered results: ${msg}`);\n163:     degraded = true;\n164:     stage4Result = {\n165:       final: stage3Result.reranked as Stage4ReadonlyRow[],\n166:       metadata: {\n167:         stateFiltered: 0,\n168:         constitutionalInjected: stage1Result.metadata.constitutionalInjected,\n169:         evidenceGapDetected: false,\n170:         durationMs: 0,\n171:       },\n172:       annotations: {\n173:         stateStats: {},\n174:         featureFlags: {},\n175:       },\n176:     };\n177:     timing.stage4 = 0;\n178:   }\n179: \n180:   timing.total = Date.now() - pipelineStart;\n181: \n182:   return {\n183:     results: stage4Result.final,\n184:     metadata: {\n185:       stage1: stage1Result.metadata,\n186:       stage2: stage2Result.metadata,\n187:       stage3: stage3Result.metadata,\n188:       stage4: stage4Result.metadata,\n189:       timing,\n190:       degraded: degraded || undefined,\n191:     },\n192:     annotations: stage4Result.annotations,\n193:     trace: config.trace,\n194:   };\n195: }\n\n(End of file - total 195 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Orchestrator\n// ───────────────────────────────────────────────────────────────\n// 4-stage pipeline execution with per-stage error handling and timeouts.\n//\n// Each stage is wrapped in try/catch with withTimeout().\n// Stage 1 is mandatory (throws on failure — no candidates = no results).\n// Stages 2-4 fall back to previous stage output with degraded metadata.\n// Timing is recorded for latency observability.\n//\n// I/O CONTRACT:\n// Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n// Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n// Key invariants:\n//     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n//     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n//     - Stage metadata for all four stages is included for observability\n//     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n// Side effects:\n//     - Delegates to each stage; see individual stage modules for their side effects","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Orchestrator\n// ───────────────────────────────────────────────────────────────\n// 4-stage pipeline execution with per-stage error handling and timeouts.\n//\n// Each stage is wrapped in try/catch with withTimeout().\n// Stage 1 is mandatory (throws on failure — no candidates = no results).\n// Stages 2-4 fall back to previous stage output with degraded metadata.\n// Timing is recorded for latency observability.\n//\n// I/O CONTRACT:\n// Input:  PipelineConfig (query, embedding, limits, flags, intent, session)\n// Output: PipelineResult { results: Stage4ReadonlyRow[], metadata, annotations, trace }\n// Key invariants:\n//     - results are scored by Stage 2, reranked by Stage 3, filtered by Stage 4\n//     - Score fields are frozen after Stage 3; Stage 4 output scores == Stage 3 output scores\n//     - Stage metadata for all four stages is included for observability\n//     - When a stage degrades, metadata.degraded = true and timing tracks each stage\n// Side effects:\n//     - Delegates to each stage; see individual stage modules for their side effects\n\nimport type {\n  PipelineConfig,\n  PipelineResult,\n  Stage1Output,\n  Stage2Output,\n  Stage3Output,\n  Stage4Output,\n  Stage4ReadonlyRow,\n  SignalStatus,\n} from './types.js';\n\nimport { executeStage1 } from './stage1-candidate-gen.js';\nimport { executeStage2 } from './stage2-fusion.js';\nimport { executeStage3 } from './stage3-rerank.js';\nimport { executeStage4 } from './stage4-filter.js';\nimport { MemoryError, withTimeout } from '../../errors/core.js';\n\n// Feature catalog: 4-stage pipeline architecture\n// Feature catalog: 4-stage pipeline refactor\n\n\n/** Per-stage timeout in milliseconds. */\nconst STAGE_TIMEOUT_MS = 10_000;\n\n/**\n * Execute the 4-stage retrieval pipeline with per-stage error handling.\n *\n * Stage 1: Candidate Generation — MANDATORY (throws on failure)\n * Stage 2: Fusion + Signal Integration — falls back to unsorted candidates\n * Stage 3: Rerank + Aggregate — falls back to unranked scored results\n * Stage 4: Filter + Annotate — falls back to unfiltered results\n *\n * @param config Pipeline configuration derived from search args\n * @returns Pipeline result with stage metadata and timing\n */\nexport async function executePipeline(config: PipelineConfig): Promise<PipelineResult> {\n  const timing: Record<string, number> = {};\n  const pipelineStart = Date.now();\n  let degraded = false;\n\n  // -- Stage 1: Candidate Generation (MANDATORY — no fallback possible) --\n  let stage1Result: Stage1Output;\n  try {\n    const t0 = Date.now();\n    stage1Result = await withTimeout(\n      executeStage1({ config }),\n      STAGE_TIMEOUT_MS,\n      'Stage 1: Candidate Generation',\n    );\n    timing.stage1 = Date.now() - t0;\n  } catch (err) {\n    throw new MemoryError(\n      'PIPELINE_STAGE1_FAILED',\n      `Candidate generation failed: ${err instanceof Error ? err.message : String(err)}`,\n      { cause: err instanceof Error ? err.message : String(err) },\n    );\n  }\n\n  // -- Stage 2: Fusion + Signal Integration (falls back to unsorted candidates) --\n  let stage2Result: Stage2Output;\n  try {\n    const t0 = Date.now();\n    stage2Result = await withTimeout(\n      executeStage2({\n        candidates: stage1Result.candidates,\n        config,\n        stage1Metadata: stage1Result.metadata,\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 2: Fusion',\n    );\n    timing.stage2 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 2 failed, returning unscored candidates: ${msg}`);\n    degraded = true;\n    stage2Result = {\n      scored: stage1Result.candidates,\n      metadata: {\n        sessionBoostApplied: 'failed' as SignalStatus,\n        causalBoostApplied: 'failed' as SignalStatus,\n        intentWeightsApplied: 'failed' as SignalStatus,\n        artifactRoutingApplied: 'failed' as SignalStatus,\n        feedbackSignalsApplied: 'failed' as SignalStatus,\n        qualityFiltered: 0,\n        durationMs: 0,\n      },\n    };\n    timing.stage2 = 0;\n  }\n\n  // -- Stage 3: Rerank + Aggregate (falls back to unranked scored results) --\n  let stage3Result: Stage3Output;\n  try {\n    const t0 = Date.now();\n    stage3Result = await withTimeout(\n      executeStage3({\n        scored: stage2Result.scored,\n        config,\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 3: Rerank',\n    );\n    timing.stage3 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 3 failed, returning unranked results: ${msg}`);\n    degraded = true;\n    stage3Result = {\n      reranked: stage2Result.scored,\n      metadata: {\n        rerankApplied: false,\n        chunkReassemblyStats: {\n          collapsedChunkHits: 0,\n          chunkParents: 0,\n          reassembled: 0,\n          fallback: 0,\n        },\n        durationMs: 0,\n      },\n    };\n    timing.stage3 = 0;\n  }\n\n  // -- Stage 4: Filter + Annotate (falls back to unfiltered results) --\n  let stage4Result: Stage4Output;\n  try {\n    const t0 = Date.now();\n    stage4Result = await withTimeout(\n      executeStage4({\n        results: stage3Result.reranked as Stage4ReadonlyRow[],\n        config,\n        stage1Metadata: { constitutionalInjected: stage1Result.metadata.constitutionalInjected },\n      }),\n      STAGE_TIMEOUT_MS,\n      'Stage 4: Filter',\n    );\n    timing.stage4 = Date.now() - t0;\n  } catch (err) {\n    const msg = err instanceof Error ? err.message : String(err);\n    console.warn(`[pipeline] Stage 4 failed, returning unfiltered results: ${msg}`);\n    degraded = true;\n    stage4Result = {\n      final: stage3Result.reranked as Stage4ReadonlyRow[],\n      metadata: {\n        stateFiltered: 0,\n        constitutionalInjected: stage1Result.metadata.constitutionalInjected,\n        evidenceGapDetected: false,\n        durationMs: 0,\n      },\n      annotations: {\n        stateStats: {},\n        featureFlags: {},\n      },\n    };\n    timing.stage4 = 0;\n  }\n\n  timing.total = Date.now() - pipelineStart;\n\n  return {\n    results: stage4Result.final,\n    metadata: {\n      stage1: stage1Result.metadata,\n      stage2: stage2Result.metadata,\n      stage3: stage3Result.metadata,\n      stage4: stage4Result.metadata,\n      timing,\n      degraded: degraded || undefined,\n    },\n    annotations: stage4Result.annotations,\n    trace: config.trace,\n  };\n}","lineStart":1,"lineEnd":195,"totalLines":195,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/orchestrator.ts","time":{"start":1781764178862,"end":1781764178865}},"metadata":{"openai":{"itemId":"fc_0eeadce08442b1f3016a339052bc408191ac366f16ba5fd782"}},"id":"prt_ed96bc377001OMFo5VpiVKxLtu","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96ba22a001l3Sutsu44FZqq8"}}
{"type":"tool_use","timestamp":1781764178899,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_04OSNjZZWoOWDIM1EtYMT4cc","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","offset":130,"limit":90},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts</path>\n<type>file</type>\n<content>\n130:   // Annotation fields (Stage 4 may add these)\n131:   channelAttribution?: string[];\n132:   evidenceGap?: { gapDetected: boolean; warning?: string };\n133: }\n134: \n135: // -- Pipeline Configuration --\n136: \n137: /**\n138:  * Normalized configuration consumed by the four-stage retrieval pipeline.\n139:  */\n140: export interface PipelineConfig {\n141:   query: string;\n142:   queryEmbedding?: Float32Array;\n143:   concepts?: string[];\n144:   searchType: 'hybrid' | 'vector' | 'multi-concept';\n145:   mode?: string;\n146: \n147:   // Limits and filtering\n148:   limit: number;\n149:   specFolder?: string;\n150:   tenantId?: string;\n151:   userId?: string;\n152:   agentId?: string;\n153:   tier?: string;\n154:   contextType?: string;\n155:   includeArchived: boolean;\n156:   includeConstitutional: boolean;\n157:   includeContent: boolean;\n158:   anchors?: string[];\n159:   qualityThreshold?: number;\n160: \n161:   // Scoring configuration\n162:   minState: string;\n163:   applyStateLimits: boolean;\n164:   useDecay: boolean;\n165:   rerank: boolean;\n166:   applyLengthPenalty: boolean;\n167: \n168:   // Session and boost\n169:   sessionId?: string;\n170:   enableDedup: boolean;\n171:   enableSessionBoost: boolean;\n172:   enableCausalBoost: boolean;\n173:   trackAccess: boolean;\n174: \n175:   // Intent\n176:   detectedIntent: string | null;\n177:   adaptiveFusionIntent?: string | null;\n178:   intentConfidence: number;\n179:   intentWeights: IntentWeightsConfig | null;\n180: \n181:   // Routing\n182:   artifactRouting?: ArtifactRoutingConfig;\n183:   queryPlan?: QueryPlan;\n184: \n185:   // Trace\n186:   trace?: RetrievalTrace;\n187: }\n188: \n189: /**\n190:  * Intent-aware weighting factors applied during fusion.\n191:  */\n192: export interface IntentWeightsConfig {\n193:   similarity: number;\n194:   importance: number;\n195:   recency: number;\n196: }\n197: \n198: /**\n199:  * Artifact-class routing decision passed into the pipeline.\n200:  */\n201: export interface ArtifactRoutingConfig {\n202:   detectedClass: string;\n203:   confidence: number;\n204:   strategy: {\n205:     maxResults: number;\n206:     [key: string]: unknown;\n207:   };\n208: }\n209: \n210: // -- Stage Interfaces --\n211: \n212: /**\n213:  * Stage 1: Candidate Generation\n214:  * Executes search channels (FTS5, semantic, trigger, graph, co-activation)\n215:  * and collects raw results. No scoring modifications.\n216:  */\n217: export interface Stage1Input {\n218:   config: PipelineConfig;\n219: }\n\n(Showing lines 130-219 of 464. Use offset=220 to continue.)\n</content>","metadata":{"preview":"  // Annotation fields (Stage 4 may add these)\n  channelAttribution?: string[];\n  evidenceGap?: { gapDetected: boolean; warning?: string };\n}\n\n// -- Pipeline Configuration --\n\n/**\n * Normalized configuration consumed by the four-stage retrieval pipeline.\n */\nexport interface PipelineConfig {\n  query: string;\n  queryEmbedding?: Float32Array;\n  concepts?: string[];\n  searchType: 'hybrid' | 'vector' | 'multi-concept';\n  mode?: string;\n\n  // Limits and filtering\n  limit: number;\n  specFolder?: string;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","text":"  // Annotation fields (Stage 4 may add these)\n  channelAttribution?: string[];\n  evidenceGap?: { gapDetected: boolean; warning?: string };\n}\n\n// -- Pipeline Configuration --\n\n/**\n * Normalized configuration consumed by the four-stage retrieval pipeline.\n */\nexport interface PipelineConfig {\n  query: string;\n  queryEmbedding?: Float32Array;\n  concepts?: string[];\n  searchType: 'hybrid' | 'vector' | 'multi-concept';\n  mode?: string;\n\n  // Limits and filtering\n  limit: number;\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  tier?: string;\n  contextType?: string;\n  includeArchived: boolean;\n  includeConstitutional: boolean;\n  includeContent: boolean;\n  anchors?: string[];\n  qualityThreshold?: number;\n\n  // Scoring configuration\n  minState: string;\n  applyStateLimits: boolean;\n  useDecay: boolean;\n  rerank: boolean;\n  applyLengthPenalty: boolean;\n\n  // Session and boost\n  sessionId?: string;\n  enableDedup: boolean;\n  enableSessionBoost: boolean;\n  enableCausalBoost: boolean;\n  trackAccess: boolean;\n\n  // Intent\n  detectedIntent: string | null;\n  adaptiveFusionIntent?: string | null;\n  intentConfidence: number;\n  intentWeights: IntentWeightsConfig | null;\n\n  // Routing\n  artifactRouting?: ArtifactRoutingConfig;\n  queryPlan?: QueryPlan;\n\n  // Trace\n  trace?: RetrievalTrace;\n}\n\n/**\n * Intent-aware weighting factors applied during fusion.\n */\nexport interface IntentWeightsConfig {\n  similarity: number;\n  importance: number;\n  recency: number;\n}\n\n/**\n * Artifact-class routing decision passed into the pipeline.\n */\nexport interface ArtifactRoutingConfig {\n  detectedClass: string;\n  confidence: number;\n  strategy: {\n    maxResults: number;\n    [key: string]: unknown;\n  };\n}\n\n// -- Stage Interfaces --\n\n/**\n * Stage 1: Candidate Generation\n * Executes search channels (FTS5, semantic, trigger, graph, co-activation)\n * and collects raw results. No scoring modifications.\n */\nexport interface Stage1Input {\n  config: PipelineConfig;\n}","lineStart":130,"lineEnd":219,"totalLines":464,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/types.ts","time":{"start":1781764178895,"end":1781764178897}},"metadata":{"openai":{"itemId":"fc_0eeadce08442b1f3016a339052bc548191ba0e843be4061696"}},"id":"prt_ed96bc3c30011EwBcVltpkejB2","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96ba22a001l3Sutsu44FZqq8"}}
{"type":"tool_use","timestamp":1781764178922,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_q1jmLOXW31gdMFS5cT5lVa5A","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","offset":960,"limit":470},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts</path>\n<type>file</type>\n<content>\n960:  * the architectural documentation (see types.ts Stage2 comment block).\n961:  *\n962:  * Signal application order (13 steps):\n963:  *   1.  Session boost      (hybrid only — working memory attention)\n964:  *   1a. Recency fusion     (all types — time-decay bonus)\n965:  *   2.  Causal boost       (hybrid only — graph-traversal amplification)\n966:  *   2a. Co-activation      (spreading activation from top-N seeds)\n967:  *   2b. Community boost    (N2c — inject co-members)\n968:  *   2c. Graph signals      (N2a+N2b — momentum + depth)\n969:  *   3.  Testing effect     (all types, when trackAccess = true)\n970:  *   4.  Intent weights     (non-hybrid only — G2 prevention)\n971:  *   5.  Artifact routing   (all types, when routing confidence > 0)\n972:  *   6.  Feedback signals   (all types — learned triggers + negative feedback)\n973:  *   7.  Artifact limiting  (trim to strategy.maxResults if routing active)\n974:  *   8.  Anchor metadata    (annotation — no score mutation)\n975:  *   9.  Validation metadata (spec quality signals + quality scoring)\n976:  *\n977:  * @param input - Stage 2 input containing candidates and pipeline config\n978:  * @returns Stage 2 output with scored results and per-signal metadata\n979:  */\n980: export async function executeStage2(input: Stage2Input): Promise<Stage2Output> {\n981:   const { candidates, config } = input;\n982:   const start = Date.now();\n983: \n984:   const metadata: Stage2Output['metadata'] & { communityBoostApplied?: boolean; graphSignalsApplied?: boolean } = {\n985:     sessionBoostApplied: 'off',\n986:     causalBoostApplied: 'off',\n987:     intentWeightsApplied: 'off',\n988:     artifactRoutingApplied: 'off',\n989:     feedbackSignalsApplied: 'off',\n990:     graphContribution: {\n991:       killSwitchActive: !isGraphUnifiedEnabled(),\n992:       causalBoosted: 0,\n993:       coActivationBoosted: 0,\n994:       communityInjected: 0,\n995:       graphSignalsBoosted: 0,\n996:       totalGraphInjected: 0,\n997:       rolloutState: resolveGraphWalkRolloutState(),\n998:     },\n999:     qualityFiltered: 0,\n1000:     durationMs: 0,\n1001:   };\n1002: \n1003:   // FIX #3: Deep clone candidates so in-place mutations (e.g., syncScoreAliasesInPlace)\n1004:   // cannot corrupt the original Stage 1 output. A shallow copy ([...candidates]) shares\n1005:   // the same row objects, creating a race condition if the orchestrator's timeout fallback\n1006:   // uses the original Stage 1 candidates array.\n1007:   let results: PipelineRow[] = candidates.map(row => ({ ...row }));\n1008:   const isHybrid = config.searchType === 'hybrid';\n1009: \n1010:   // -- 1. Session boost --\n1011:   // Only for hybrid search type — session attention signals are most meaningful\n1012:   // When the full hybrid result set is available for ordering.\n1013:   if (isHybrid && config.enableSessionBoost && config.sessionId) {\n1014:     try {\n1015:       const { results: boosted, metadata: sbMeta } = sessionBoost.applySessionBoost(\n1016:         results,\n1017:         config.sessionId\n1018:       );\n1019:       results = boosted as PipelineRow[];\n1020:       // FIX #4: Sync aliases immediately after session boost score mutations\n1021:       // so rrfScore/intentAdjustedScore are not stale for subsequent steps.\n1022:       syncScoreAliasesInPlace(results);\n1023:       metadata.sessionBoostApplied = sbMeta.applied ? 'applied' : 'enabled';\n1024:     } catch (err: unknown) {\n1025:       const message = err instanceof Error ? err.message : String(err);\n1026:       console.warn(`[stage2-fusion] session boost failed: ${message}`);\n1027:       metadata.sessionBoostApplied = 'failed';\n1028:     }\n1029:   }\n1030: \n1031:   // -- 1a. Recency fusion --\n1032:   // Applies a time-decay bonus to each candidate based on its created_at timestamp.\n1033:   // Uses computeRecencyScore (already imported but previously unused in hybrid path).\n1034:   // Bonus is capped at RECENCY_FUSION_CAP and clamped to keep score in [0, 1].\n1035:   try {\n1036:     let recencyBoostedCount = 0;\n1037:     const fusionIntent = resolveFusionIntentContract({\n1038:       detectedIntent: config.detectedIntent,\n1039:       adaptiveFusionIntent: config.adaptiveFusionIntent,\n1040:       query: config.query,\n1041:     });\n1042:     const adaptiveRecencyEnabled = Boolean(fusionIntent) && isAdaptiveFusionEnabled();\n1043:     results = results.map((row) => {\n1044:       const recencyTimestamp = (row.created_at as string | undefined) ?? '';\n1045:       const importanceTier = (row.importance_tier as string | undefined) ?? 'normal';\n1046:       if (!recencyTimestamp) return row;\n1047: \n1048:       const recencyScore = computeRecencyScore(recencyTimestamp, importanceTier);\n1049:       const recencyWeight = adaptiveRecencyEnabled && fusionIntent\n1050:         ? getAdaptiveWeights(fusionIntent, resolveRowDocumentType(row)).recencyWeight\n1051:         : RECENCY_FUSION_WEIGHT;\n1052:       const bonus = Math.min(RECENCY_FUSION_CAP, recencyScore * recencyWeight);\n1053:       if (bonus <= 0) return row;\n1054: \n1055:       const baseScore = resolveBaseScore(row);\n1056:       const boostedScore = Math.min(1.0, baseScore + bonus);\n1057:       if (boostedScore === baseScore) return row;\n1058: \n1059:       recencyBoostedCount++;\n1060:       return withSyncedScoreAliases(row, boostedScore);\n1061:     });\n1062:     if (recencyBoostedCount > 0) {\n1063:       syncScoreAliasesInPlace(results);\n1064:       (metadata as Record<string, unknown>).recencyFusionApplied = true;\n1065:       (metadata as Record<string, unknown>).recencyFusionBoosted = recencyBoostedCount;\n1066:     }\n1067:   } catch (err: unknown) {\n1068:     const message = err instanceof Error ? err.message : String(err);\n1069:     console.warn(`[stage2-fusion] recency fusion failed: ${message}`);\n1070:   }\n1071: \n1072:   // -- 2. Causal boost --\n1073:   // Only for hybrid search type — causal graph traversal is seeded from the\n1074:   // Top results after session boost has re-ordered them.\n1075:   if (isHybrid && config.enableCausalBoost && isGraphUnifiedEnabled()) {\n1076:     try {\n1077:       const beforeScores = new Map(results.map((row) => [row.id, resolveBaseScore(row)]));\n1078:       const { results: boosted, metadata: cbMeta } = causalBoost.applyCausalBoost(results);\n1079:       results = (boosted as PipelineRow[]).map((row) => {\n1080:         const previous = beforeScores.get(row.id) ?? resolveBaseScore(row);\n1081:         const next = resolveBaseScore(row);\n1082:         return next !== previous\n1083:           ? withGraphContribution(row, 'causalDelta', next - previous, 'causal', row.injectedByCausalBoost === true)\n1084:           : row;\n1085:       });\n1086:       // FIX #4: Sync aliases immediately after causal boost score mutations.\n1087:       syncScoreAliasesInPlace(results);\n1088:       metadata.causalBoostApplied = cbMeta.applied ? 'applied' : 'enabled';\n1089:     } catch (err: unknown) {\n1090:       const message = err instanceof Error ? err.message : String(err);\n1091:       console.warn(`[stage2-fusion] causal boost failed: ${message}`);\n1092:       metadata.causalBoostApplied = 'failed';\n1093:     }\n1094:   }\n1095: \n1096:   // -- 2a. Co-activation spreading --\n1097:   // Gated behind SPECKIT_COACTIVATION flag. Takes the top-N results as seeds,\n1098:   // Performs spreading activation traversal, and boosts scores of results that\n1099:   // Appear in the co-activation graph. Matches V1 hybrid-search behavior.\n1100:   if (isCoActivationEnabled() && isGraphUnifiedEnabled()) {\n1101:     try {\n1102:       const topIds = results\n1103:         .slice(0, SPREAD_ACTIVATION_TOP_N)\n1104:         .map(r => r.id)\n1105:         .filter((id): id is number => typeof id === 'number');\n1106: \n1107:       if (topIds.length > 0) {\n1108:         const spreadResults: SpreadResult[] = spreadActivation(topIds);\n1109:         if (spreadResults.length > 0) {\n1110:           const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n1111:           const relatedCounts = getRelatedMemoryCounts([...new Set(spreadResults.map((result) => result.id))]);\n1112:           results = results.map((row) => {\n1113:             const boost = spreadMap.get(row.id);\n1114:             if (boost !== undefined) {\n1115:               const baseScore = resolveBaseScore(row);\n1116:               // fan-effect divisor: dampen hub nodes proportionally to their\n1117:               // fan-out degree so no single hub dominates the top-N results.\n1118:               // Uses the same sqrt scaling as co-activation.ts boostScore().\n1119:               const relatedCount = typeof row.id === 'number' ? (relatedCounts.get(row.id) ?? 0) : 0;\n1120:               const fanDivisor = Math.sqrt(Math.max(1, relatedCount));\n1121:               const updated = withSyncedScoreAliases(row, baseScore + (boost * resolveCoActivationBoostFactor()) / fanDivisor);\n1122:               return withGraphContribution(updated, 'coActivationDelta', resolveBaseScore(updated) - baseScore, 'co-activation');\n1123:             }\n1124:             return row;\n1125:           });\n1126:           // Re-sort after co-activation boost to ensure boosted results\n1127:           // Are promoted to their correct position in the ranking\n1128:           results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n1129:           (metadata as Record<string, unknown>).coActivationApplied = true;\n1130:         }\n1131:       }\n1132:     } catch (err: unknown) {\n1133:       // Non-critical enrichment — co-activation failure does not affect core ranking\n1134:       const message = err instanceof Error ? err.message : String(err);\n1135:       console.warn(`[stage2-fusion] co-activation spreading failed: ${message}`);\n1136:     }\n1137:   }\n1138: \n1139:   // -- 2b. Community co-retrieval (N2c) --\n1140:   // Inject community co-members into result set before graph signals\n1141:   // So injected rows also receive momentum/depth adjustments.\n1142:   if (isCommunityDetectionEnabled() && isGraphUnifiedEnabled()) {\n1143:     const beforeCommunityIds = new Set(results.map((row) => row.id));\n1144:     try {\n1145:       const db = requireDb();\n1146:       const boosted = applyCommunityBoost(results, db);\n1147:       if (boosted.length > results.length) {\n1148:         results = (boosted as PipelineRow[]).map((row) => beforeCommunityIds.has(row.id)\n1149:           ? row\n1150:           : withGraphContribution(row, 'communityDelta', 0, 'community', true));\n1151:         (metadata as Record<string, unknown>).communityBoostApplied = true;\n1152:       }\n1153:     } catch (err: unknown) {\n1154:       const message = err instanceof Error ? err.message : String(err);\n1155:       console.warn(`[stage2-fusion] community boost failed: ${message}`);\n1156:     }\n1157: \n1158:     const injectedIds = results\n1159:       .filter((row) => !beforeCommunityIds.has(row.id) && typeof row.id === 'number')\n1160:       .map((row) => row.id);\n1161:     if (injectedIds.length > 0) {\n1162:       try {\n1163:         const db = requireDb();\n1164:         const placeholders = injectedIds.map(() => '?').join(',');\n1165:         const stateRows = db.prepare(\n1166:           `SELECT id, memory_state FROM memory_index WHERE id IN (${placeholders})`\n1167:         ).all(...injectedIds) as Array<{ id: number; memory_state?: string }>;\n1168:         const stateMap = new Map(stateRows.map((row) => [row.id, row.memory_state]));\n1169:         const injectedIdSet = new Set(injectedIds);\n1170:         for (const row of results) {\n1171:           const rowId = typeof row.id === 'number' ? row.id : null;\n1172:           if (rowId === null || !injectedIdSet.has(rowId)) {\n1173:             continue;\n1174:           }\n1175:           const hydratedState = stateMap.get(rowId);\n1176:           if (typeof hydratedState === 'string') {\n1177:             row.memoryState = hydratedState;\n1178:           }\n1179:         }\n1180:       } catch (err: unknown) {\n1181:         console.warn('[stage2] Community state hydration failed:', err instanceof Error ? err.message : err);\n1182:       }\n1183:     }\n1184:   }\n1185: \n1186:   // -- 2c. Graph signals (N2a + N2b) --\n1187:   // Additive score adjustments for graph momentum and causal depth.\n1188:   if (isGraphSignalsEnabled() && isGraphUnifiedEnabled()) {\n1189:     try {\n1190:       const db = requireDb();\n1191:       const beforeScores = new Map(results.map((row) => [row.id, resolveBaseScore(row)]));\n1192:       const signaled = applyGraphSignals(results, db, {\n1193:         rolloutState: resolveGraphWalkRolloutState(),\n1194:       });\n1195:       results = (signaled as PipelineRow[]).map((row) => {\n1196:         const previous = beforeScores.get(row.id) ?? resolveBaseScore(row);\n1197:         const next = resolveBaseScore(row);\n1198:         return next !== previous\n1199:           ? withGraphContribution(row, 'graphSignalDelta', next - previous, 'graph-signals')\n1200:           : row;\n1201:       });\n1202:       // FIX #4: Sync aliases immediately after graph signal score mutations.\n1203:       syncScoreAliasesInPlace(results);\n1204:       if (isGraphCalibrationProfileEnabled()) {\n1205:         results = applyGraphCalibrationProfileToResults(results);\n1206:         syncScoreAliasesInPlace(results);\n1207:       }\n1208:       (metadata as Record<string, unknown>).graphSignalsApplied = true;\n1209:     } catch (err: unknown) {\n1210:       const message = err instanceof Error ? err.message : String(err);\n1211:       console.warn(`[stage2-fusion] graph signals failed: ${message}`);\n1212:     }\n1213:   }\n1214: \n1215:   // -- 2d. Usage-weighted ranking --\n1216:   if (isUsageRankingEnabled()) {\n1217:     try {\n1218:       const db = requireDb();\n1219:       results = applyUsageRankingBoost(db, results);\n1220:     } catch (err: unknown) {\n1221:       const message = err instanceof Error ? err.message : String(err);\n1222:       console.warn(`[stage2-fusion] usage ranking skipped (db unavailable): ${message}`);\n1223:     }\n1224:   }\n1225: \n1226:   // -- 2e. Graph evidence provenance --\n1227:   // Populate graphEvidence on results that received graph-based boosts.\n1228:   // Gated behind SPECKIT_RESULT_PROVENANCE. Fail-open.\n1229:   try {\n1230:     results = populateGraphEvidence(results);\n1231:   } catch (err: unknown) {\n1232:     const message = err instanceof Error ? err.message : String(err);\n1233:     console.warn(`[stage2-fusion] graph evidence provenance failed: ${message}`);\n1234:   }\n1235: \n1236:   // -- 3. Testing effect (FSRS write-back) --\n1237:   // Only when explicitly opted in via trackAccess.\n1238:   // Write-back is fire-and-forget; errors per-row are swallowed inside\n1239:   // ApplyTestingEffect so they never abort the pipeline.\n1240:   if (config.trackAccess) {\n1241:     try {\n1242:       const db = requireDb();\n1243:       applyTestingEffect(db, results);\n1244:       recordAdaptiveAccessSignals(db, results, config.query);\n1245:     } catch (err: unknown) {\n1246:       const message = err instanceof Error ? err.message : String(err);\n1247:       console.warn(`[stage2-fusion] testing effect skipped (db unavailable): ${message}`);\n1248:     }\n1249:   }\n1250: \n1251:   // -- 4. Intent weights --\n1252:   // G2 PREVENTION: Only apply for non-hybrid search types.\n1253:   // Hybrid search (RRF / RSF) incorporates intent weighting during fusion —\n1254:   // Applying it again here would double-count, causing the G2 bug.\n1255:   if (!isHybrid && config.intentWeights) {\n1256:     try {\n1257:       const weighted = applyIntentWeightsToResults(results, config.intentWeights);\n1258:       results = weighted.map((result) =>\n1259:         typeof result.intentAdjustedScore === 'number'\n1260:           ? withSyncedScoreAliases(result, result.intentAdjustedScore)\n1261:           : result\n1262:       );\n1263:       metadata.intentWeightsApplied = 'applied';\n1264:     } catch (err: unknown) {\n1265:       const message = err instanceof Error ? err.message : String(err);\n1266:       console.warn(`[stage2-fusion] intent weights failed: ${message}`);\n1267:       metadata.intentWeightsApplied = 'failed';\n1268:     }\n1269:   }\n1270: \n1271:   // -- 5. Artifact routing weights --\n1272:   if (config.artifactRouting && config.artifactRouting.confidence > 0) {\n1273:     try {\n1274:       const routed = applyArtifactRouting(results, config.artifactRouting);\n1275:       results = routed;\n1276:       metadata.artifactRoutingApplied = 'applied';\n1277:     } catch (err: unknown) {\n1278:       const message = err instanceof Error ? err.message : String(err);\n1279:       console.warn(`[stage2-fusion] artifact routing failed: ${message}`);\n1280:       metadata.artifactRoutingApplied = 'failed';\n1281:     }\n1282:   }\n1283: \n1284:   // -- 6. Feedback signals --\n1285:   try {\n1286:     const withFeedback = applyFeedbackSignals(results, config.query);\n1287:     // Detect if any score actually changed\n1288:     const changed = withFeedback.some((r, i) => r !== results[i]);\n1289:     if (changed) {\n1290:       results = withFeedback;\n1291:       metadata.feedbackSignalsApplied = 'applied';\n1292:     }\n1293:   } catch (err: unknown) {\n1294:     const message = err instanceof Error ? err.message : String(err);\n1295:     console.warn(`[stage2-fusion] feedback signals failed: ${message}`);\n1296:     metadata.feedbackSignalsApplied = 'failed';\n1297:   }\n1298: \n1299:   // -- 6a. Learned Stage 2 shadow scoring --\n1300:   // Runs the learned linear ranker in parallel with the manual combiner.\n1301:   // Shadow-only — scores are logged for comparison but never affect live ranking.\n1302:   // Gated behind SPECKIT_LEARNED_STAGE2_COMBINER (default ON, graduated).\n1303:   // When SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT is set in (0, 0.05],\n1304:   // a small guarded blend `(1-w)*manual + w*learned` is applied to the live\n1305:   // score. Default 0 preserves shadow-only behavior. The blend weight is\n1306:   // clamped at the source by resolveLearnedBlendWeight().\n1307:   if (isLearnedStage2CombinerEnabled()) {\n1308:     try {\n1309:       const learnedShadowModel = await loadPersistedLearnedStage2Model();\n1310:       // Weight resolved once per pipeline run; flag-gated and\n1311:       // clamped. Zero means shadow-only (today's behavior).\n1312:       const learnedBlendWeight = resolveLearnedBlendWeight();\n1313:       for (let rowIndex = 0; rowIndex < results.length; rowIndex++) {\n1314:         const row = results[rowIndex];\n1315:         const features = extractFeatureVector({\n1316:           rrfScore: row.rrfScore,\n1317:           overlapScore: typeof row.overlapScore === 'number' ? row.overlapScore : undefined,\n1318:           graphScore: (() => {\n1319:             const gc = row.graphContribution as Record<string, unknown> | undefined;\n1320:             const delta = typeof gc?.totalDelta === 'number' ? gc.totalDelta : 0;\n1321:             return Math.max(0, Math.min(1, delta + 0.5));\n1322:           })(),\n1323:           sessionScore: typeof row.sessionScore === 'number' ? row.sessionScore : undefined,\n1324:           causalScore: typeof row.causalScore === 'number' ? row.causalScore : undefined,\n1325:           feedbackScore: typeof row.feedbackScore === 'number' ? row.feedbackScore : undefined,\n1326:           validationScore: (() => {\n1327:             const vm = row.validationMetadata as Record<string, unknown> | undefined;\n1328:             return typeof vm?.qualityScore === 'number' ? vm.qualityScore : undefined;\n1329:           })(),\n1330:           artifactScore: typeof row.artifactBoostApplied === 'number'\n1331:             ? Math.min(1, row.artifactBoostApplied / 2)\n1332:             : undefined,\n1333:         });\n1334:         const shadow = shadowScore(learnedShadowModel, features, resolveBaseScore(row), true);\n1335:         if (shadow) {\n1336:           console.warn(\n1337:             `[stage2-fusion] shadow-learned id=${row.id} manual=${shadow.manualScore.toFixed(4)} learned=${shadow.learnedScore.toFixed(4)} delta=${shadow.delta.toFixed(4)}`\n1338:           );\n1339:           // Apply the small guarded blend when weight > 0 AND a\n1340:           // shadow result is available (model loaded successfully). Mutate\n1341:           // the row through withSyncedScoreAliases so all score aliases stay\n1342:           // aligned. When weight is 0 (default) or model failed to load, this\n1343:           // branch is skipped and behavior is identical to pre-fix.\n1344:           if (learnedBlendWeight > 0) {\n1345:             const blendedScore = (1 - learnedBlendWeight) * shadow.manualScore\n1346:               + learnedBlendWeight * shadow.learnedScore;\n1347:             results[rowIndex] = withSyncedScoreAliases(row, blendedScore);\n1348:           }\n1349:         }\n1350:       }\n1351:     } catch (err: unknown) {\n1352:       const message = err instanceof Error ? err.message : String(err);\n1353:       console.warn(`[stage2-fusion] learned stage2 shadow scoring failed: ${message}`);\n1354:     }\n1355:   }\n1356: \n1357:   // -- 6a. Retrieval rescue + 7. Artifact-based result limiting --\n1358:   // The routing strategy may specify a maxResults count stricter than the\n1359:   // Overall pipeline limit. Apply it here so Stage 3 reranks a pre-trimmed set.\n1360:   syncScoreAliasesInPlace(results);\n1361:   if (isRetrievalRescueEnabled()) {\n1362:     try {\n1363:       let rescueDb: Database.Database | null = null;\n1364:       try {\n1365:         rescueDb = requireDb();\n1366:       } catch {\n1367:         rescueDb = null;\n1368:       }\n1369:       results = applyRetrievalRescueLayer(config.query, results, {\n1370:         db: rescueDb,\n1371:         artifactClass: config.artifactRouting?.strategy?.artifactClass as string | undefined\n1372:           ?? config.artifactRouting?.detectedClass,\n1373:       });\n1374:       logger.debug('retrieval rescue layer completed', {\n1375:         event: 'stage2_retrieval_rescue_success',\n1376:         resultCount: results.length,\n1377:         hasDb: rescueDb !== null,\n1378:         artifactClass: config.artifactRouting?.strategy?.artifactClass\n1379:           ?? config.artifactRouting?.detectedClass\n1380:           ?? null,\n1381:       });\n1382:     } catch (err: unknown) {\n1383:       const message = err instanceof Error ? err.message : String(err);\n1384:       console.warn(`[stage2-fusion] retrieval rescue layer failed: ${message}`);\n1385:     }\n1386:   }\n1387:   results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n1388:   if (\n1389:     config.artifactRouting &&\n1390:     config.artifactRouting.confidence > 0 &&\n1391:     typeof config.artifactRouting.strategy?.maxResults === 'number' &&\n1392:     config.artifactRouting.strategy.maxResults > 0 &&\n1393:     results.length > config.artifactRouting.strategy.maxResults\n1394:   ) {\n1395:     results = results.slice(0, config.artifactRouting.strategy.maxResults);\n1396:   }\n1397: \n1398:   // -- Steps 8-9: Enrichment (extracted to stage2b-enrichment.ts) --\n1399:   // Pure annotation: anchor metadata + validation metadata.\n1400:   // Validation signal SCORING (applyValidationSignalScoring) stays here\n1401:   // because it's a scoring step, not a pure enrichment.\n1402:   results = executeStage2bEnrichment(results);\n1403:   try {\n1404:     results = applyValidationSignalScoring(results);\n1405:   } catch (err: unknown) {\n1406:     const message = err instanceof Error ? err.message : String(err);\n1407:     console.warn(`[stage2-fusion] validation signal scoring failed: ${message}`);\n1408:   }\n1409: \n1410:   // Keep all score aliases aligned after late-stage score mutations.\n1411:   syncScoreAliasesInPlace(results);\n1412:   if (metadata.graphContribution) {\n1413:     metadata.graphContribution.causalBoosted = countGraphContribution(results, 'causalDelta');\n1414:     metadata.graphContribution.coActivationBoosted = countGraphContribution(results, 'coActivationDelta');\n1415:     metadata.graphContribution.communityInjected = countGraphContribution(results, 'communityDelta');\n1416:     metadata.graphContribution.graphSignalsBoosted = countGraphContribution(results, 'graphSignalDelta');\n1417:     metadata.graphContribution.totalGraphInjected = countGraphInjected(results);\n1418: \n1419:     // P2 fix: Diagnostic when graph is activated but contributes nothing\n1420:     if (\n1421:       !metadata.graphContribution.killSwitchActive &&\n1422:       metadata.graphContribution.rolloutState === 'bounded_runtime' &&\n1423:       metadata.graphContribution.causalBoosted === 0 &&\n1424:       metadata.graphContribution.coActivationBoosted === 0 &&\n1425:       metadata.graphContribution.communityInjected === 0 &&\n1426:       metadata.graphContribution.graphSignalsBoosted === 0 &&\n1427:       results.length > 0\n1428:     ) {\n1429:       console.warn(\n\n(Showing lines 960-1429 of 1486. Use offset=1430 to continue.)\n</content>","metadata":{"preview":" * the architectural documentation (see types.ts Stage2 comment block).\n *\n * Signal application order (13 steps):\n *   1.  Session boost      (hybrid only — working memory attention)\n *   1a. Recency fusion     (all types — time-decay bonus)\n *   2.  Causal boost       (hybrid only — graph-traversal amplification)\n *   2a. Co-activation      (spreading activation from top-N seeds)\n *   2b. Community boost    (N2c — inject co-members)\n *   2c. Graph signals      (N2a+N2b — momentum + depth)\n *   3.  Testing effect     (all types, when trackAccess = true)\n *   4.  Intent weights     (non-hybrid only — G2 prevention)\n *   5.  Artifact routing   (all types, when routing confidence > 0)\n *   6.  Feedback signals   (all types — learned triggers + negative feedback)\n *   7.  Artifact limiting  (trim to strategy.maxResults if routing active)\n *   8.  Anchor metadata    (annotation — no score mutation)\n *   9.  Validation metadata (spec quality signals + quality scoring)\n *\n * @param input - Stage 2 input containing candidates and pipeline config\n * @returns Stage 2 output with scored results and per-signal metadata\n */","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","text":" * the architectural documentation (see types.ts Stage2 comment block).\n *\n * Signal application order (13 steps):\n *   1.  Session boost      (hybrid only — working memory attention)\n *   1a. Recency fusion     (all types — time-decay bonus)\n *   2.  Causal boost       (hybrid only — graph-traversal amplification)\n *   2a. Co-activation      (spreading activation from top-N seeds)\n *   2b. Community boost    (N2c — inject co-members)\n *   2c. Graph signals      (N2a+N2b — momentum + depth)\n *   3.  Testing effect     (all types, when trackAccess = true)\n *   4.  Intent weights     (non-hybrid only — G2 prevention)\n *   5.  Artifact routing   (all types, when routing confidence > 0)\n *   6.  Feedback signals   (all types — learned triggers + negative feedback)\n *   7.  Artifact limiting  (trim to strategy.maxResults if routing active)\n *   8.  Anchor metadata    (annotation — no score mutation)\n *   9.  Validation metadata (spec quality signals + quality scoring)\n *\n * @param input - Stage 2 input containing candidates and pipeline config\n * @returns Stage 2 output with scored results and per-signal metadata\n */\nexport async function executeStage2(input: Stage2Input): Promise<Stage2Output> {\n  const { candidates, config } = input;\n  const start = Date.now();\n\n  const metadata: Stage2Output['metadata'] & { communityBoostApplied?: boolean; graphSignalsApplied?: boolean } = {\n    sessionBoostApplied: 'off',\n    causalBoostApplied: 'off',\n    intentWeightsApplied: 'off',\n    artifactRoutingApplied: 'off',\n    feedbackSignalsApplied: 'off',\n    graphContribution: {\n      killSwitchActive: !isGraphUnifiedEnabled(),\n      causalBoosted: 0,\n      coActivationBoosted: 0,\n      communityInjected: 0,\n      graphSignalsBoosted: 0,\n      totalGraphInjected: 0,\n      rolloutState: resolveGraphWalkRolloutState(),\n    },\n    qualityFiltered: 0,\n    durationMs: 0,\n  };\n\n  // FIX #3: Deep clone candidates so in-place mutations (e.g., syncScoreAliasesInPlace)\n  // cannot corrupt the original Stage 1 output. A shallow copy ([...candidates]) shares\n  // the same row objects, creating a race condition if the orchestrator's timeout fallback\n  // uses the original Stage 1 candidates array.\n  let results: PipelineRow[] = candidates.map(row => ({ ...row }));\n  const isHybrid = config.searchType === 'hybrid';\n\n  // -- 1. Session boost --\n  // Only for hybrid search type — session attention signals are most meaningful\n  // When the full hybrid result set is available for ordering.\n  if (isHybrid && config.enableSessionBoost && config.sessionId) {\n    try {\n      const { results: boosted, metadata: sbMeta } = sessionBoost.applySessionBoost(\n        results,\n        config.sessionId\n      );\n      results = boosted as PipelineRow[];\n      // FIX #4: Sync aliases immediately after session boost score mutations\n      // so rrfScore/intentAdjustedScore are not stale for subsequent steps.\n      syncScoreAliasesInPlace(results);\n      metadata.sessionBoostApplied = sbMeta.applied ? 'applied' : 'enabled';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] session boost failed: ${message}`);\n      metadata.sessionBoostApplied = 'failed';\n    }\n  }\n\n  // -- 1a. Recency fusion --\n  // Applies a time-decay bonus to each candidate based on its created_at timestamp.\n  // Uses computeRecencyScore (already imported but previously unused in hybrid path).\n  // Bonus is capped at RECENCY_FUSION_CAP and clamped to keep score in [0, 1].\n  try {\n    let recencyBoostedCount = 0;\n    const fusionIntent = resolveFusionIntentContract({\n      detectedIntent: config.detectedIntent,\n      adaptiveFusionIntent: config.adaptiveFusionIntent,\n      query: config.query,\n    });\n    const adaptiveRecencyEnabled = Boolean(fusionIntent) && isAdaptiveFusionEnabled();\n    results = results.map((row) => {\n      const recencyTimestamp = (row.created_at as string | undefined) ?? '';\n      const importanceTier = (row.importance_tier as string | undefined) ?? 'normal';\n      if (!recencyTimestamp) return row;\n\n      const recencyScore = computeRecencyScore(recencyTimestamp, importanceTier);\n      const recencyWeight = adaptiveRecencyEnabled && fusionIntent\n        ? getAdaptiveWeights(fusionIntent, resolveRowDocumentType(row)).recencyWeight\n        : RECENCY_FUSION_WEIGHT;\n      const bonus = Math.min(RECENCY_FUSION_CAP, recencyScore * recencyWeight);\n      if (bonus <= 0) return row;\n\n      const baseScore = resolveBaseScore(row);\n      const boostedScore = Math.min(1.0, baseScore + bonus);\n      if (boostedScore === baseScore) return row;\n\n      recencyBoostedCount++;\n      return withSyncedScoreAliases(row, boostedScore);\n    });\n    if (recencyBoostedCount > 0) {\n      syncScoreAliasesInPlace(results);\n      (metadata as Record<string, unknown>).recencyFusionApplied = true;\n      (metadata as Record<string, unknown>).recencyFusionBoosted = recencyBoostedCount;\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] recency fusion failed: ${message}`);\n  }\n\n  // -- 2. Causal boost --\n  // Only for hybrid search type — causal graph traversal is seeded from the\n  // Top results after session boost has re-ordered them.\n  if (isHybrid && config.enableCausalBoost && isGraphUnifiedEnabled()) {\n    try {\n      const beforeScores = new Map(results.map((row) => [row.id, resolveBaseScore(row)]));\n      const { results: boosted, metadata: cbMeta } = causalBoost.applyCausalBoost(results);\n      results = (boosted as PipelineRow[]).map((row) => {\n        const previous = beforeScores.get(row.id) ?? resolveBaseScore(row);\n        const next = resolveBaseScore(row);\n        return next !== previous\n          ? withGraphContribution(row, 'causalDelta', next - previous, 'causal', row.injectedByCausalBoost === true)\n          : row;\n      });\n      // FIX #4: Sync aliases immediately after causal boost score mutations.\n      syncScoreAliasesInPlace(results);\n      metadata.causalBoostApplied = cbMeta.applied ? 'applied' : 'enabled';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] causal boost failed: ${message}`);\n      metadata.causalBoostApplied = 'failed';\n    }\n  }\n\n  // -- 2a. Co-activation spreading --\n  // Gated behind SPECKIT_COACTIVATION flag. Takes the top-N results as seeds,\n  // Performs spreading activation traversal, and boosts scores of results that\n  // Appear in the co-activation graph. Matches V1 hybrid-search behavior.\n  if (isCoActivationEnabled() && isGraphUnifiedEnabled()) {\n    try {\n      const topIds = results\n        .slice(0, SPREAD_ACTIVATION_TOP_N)\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (topIds.length > 0) {\n        const spreadResults: SpreadResult[] = spreadActivation(topIds);\n        if (spreadResults.length > 0) {\n          const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n          const relatedCounts = getRelatedMemoryCounts([...new Set(spreadResults.map((result) => result.id))]);\n          results = results.map((row) => {\n            const boost = spreadMap.get(row.id);\n            if (boost !== undefined) {\n              const baseScore = resolveBaseScore(row);\n              // fan-effect divisor: dampen hub nodes proportionally to their\n              // fan-out degree so no single hub dominates the top-N results.\n              // Uses the same sqrt scaling as co-activation.ts boostScore().\n              const relatedCount = typeof row.id === 'number' ? (relatedCounts.get(row.id) ?? 0) : 0;\n              const fanDivisor = Math.sqrt(Math.max(1, relatedCount));\n              const updated = withSyncedScoreAliases(row, baseScore + (boost * resolveCoActivationBoostFactor()) / fanDivisor);\n              return withGraphContribution(updated, 'coActivationDelta', resolveBaseScore(updated) - baseScore, 'co-activation');\n            }\n            return row;\n          });\n          // Re-sort after co-activation boost to ensure boosted results\n          // Are promoted to their correct position in the ranking\n          results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n          (metadata as Record<string, unknown>).coActivationApplied = true;\n        }\n      }\n    } catch (err: unknown) {\n      // Non-critical enrichment — co-activation failure does not affect core ranking\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] co-activation spreading failed: ${message}`);\n    }\n  }\n\n  // -- 2b. Community co-retrieval (N2c) --\n  // Inject community co-members into result set before graph signals\n  // So injected rows also receive momentum/depth adjustments.\n  if (isCommunityDetectionEnabled() && isGraphUnifiedEnabled()) {\n    const beforeCommunityIds = new Set(results.map((row) => row.id));\n    try {\n      const db = requireDb();\n      const boosted = applyCommunityBoost(results, db);\n      if (boosted.length > results.length) {\n        results = (boosted as PipelineRow[]).map((row) => beforeCommunityIds.has(row.id)\n          ? row\n          : withGraphContribution(row, 'communityDelta', 0, 'community', true));\n        (metadata as Record<string, unknown>).communityBoostApplied = true;\n      }\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] community boost failed: ${message}`);\n    }\n\n    const injectedIds = results\n      .filter((row) => !beforeCommunityIds.has(row.id) && typeof row.id === 'number')\n      .map((row) => row.id);\n    if (injectedIds.length > 0) {\n      try {\n        const db = requireDb();\n        const placeholders = injectedIds.map(() => '?').join(',');\n        const stateRows = db.prepare(\n          `SELECT id, memory_state FROM memory_index WHERE id IN (${placeholders})`\n        ).all(...injectedIds) as Array<{ id: number; memory_state?: string }>;\n        const stateMap = new Map(stateRows.map((row) => [row.id, row.memory_state]));\n        const injectedIdSet = new Set(injectedIds);\n        for (const row of results) {\n          const rowId = typeof row.id === 'number' ? row.id : null;\n          if (rowId === null || !injectedIdSet.has(rowId)) {\n            continue;\n          }\n          const hydratedState = stateMap.get(rowId);\n          if (typeof hydratedState === 'string') {\n            row.memoryState = hydratedState;\n          }\n        }\n      } catch (err: unknown) {\n        console.warn('[stage2] Community state hydration failed:', err instanceof Error ? err.message : err);\n      }\n    }\n  }\n\n  // -- 2c. Graph signals (N2a + N2b) --\n  // Additive score adjustments for graph momentum and causal depth.\n  if (isGraphSignalsEnabled() && isGraphUnifiedEnabled()) {\n    try {\n      const db = requireDb();\n      const beforeScores = new Map(results.map((row) => [row.id, resolveBaseScore(row)]));\n      const signaled = applyGraphSignals(results, db, {\n        rolloutState: resolveGraphWalkRolloutState(),\n      });\n      results = (signaled as PipelineRow[]).map((row) => {\n        const previous = beforeScores.get(row.id) ?? resolveBaseScore(row);\n        const next = resolveBaseScore(row);\n        return next !== previous\n          ? withGraphContribution(row, 'graphSignalDelta', next - previous, 'graph-signals')\n          : row;\n      });\n      // FIX #4: Sync aliases immediately after graph signal score mutations.\n      syncScoreAliasesInPlace(results);\n      if (isGraphCalibrationProfileEnabled()) {\n        results = applyGraphCalibrationProfileToResults(results);\n        syncScoreAliasesInPlace(results);\n      }\n      (metadata as Record<string, unknown>).graphSignalsApplied = true;\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] graph signals failed: ${message}`);\n    }\n  }\n\n  // -- 2d. Usage-weighted ranking --\n  if (isUsageRankingEnabled()) {\n    try {\n      const db = requireDb();\n      results = applyUsageRankingBoost(db, results);\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] usage ranking skipped (db unavailable): ${message}`);\n    }\n  }\n\n  // -- 2e. Graph evidence provenance --\n  // Populate graphEvidence on results that received graph-based boosts.\n  // Gated behind SPECKIT_RESULT_PROVENANCE. Fail-open.\n  try {\n    results = populateGraphEvidence(results);\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] graph evidence provenance failed: ${message}`);\n  }\n\n  // -- 3. Testing effect (FSRS write-back) --\n  // Only when explicitly opted in via trackAccess.\n  // Write-back is fire-and-forget; errors per-row are swallowed inside\n  // ApplyTestingEffect so they never abort the pipeline.\n  if (config.trackAccess) {\n    try {\n      const db = requireDb();\n      applyTestingEffect(db, results);\n      recordAdaptiveAccessSignals(db, results, config.query);\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] testing effect skipped (db unavailable): ${message}`);\n    }\n  }\n\n  // -- 4. Intent weights --\n  // G2 PREVENTION: Only apply for non-hybrid search types.\n  // Hybrid search (RRF / RSF) incorporates intent weighting during fusion —\n  // Applying it again here would double-count, causing the G2 bug.\n  if (!isHybrid && config.intentWeights) {\n    try {\n      const weighted = applyIntentWeightsToResults(results, config.intentWeights);\n      results = weighted.map((result) =>\n        typeof result.intentAdjustedScore === 'number'\n          ? withSyncedScoreAliases(result, result.intentAdjustedScore)\n          : result\n      );\n      metadata.intentWeightsApplied = 'applied';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] intent weights failed: ${message}`);\n      metadata.intentWeightsApplied = 'failed';\n    }\n  }\n\n  // -- 5. Artifact routing weights --\n  if (config.artifactRouting && config.artifactRouting.confidence > 0) {\n    try {\n      const routed = applyArtifactRouting(results, config.artifactRouting);\n      results = routed;\n      metadata.artifactRoutingApplied = 'applied';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] artifact routing failed: ${message}`);\n      metadata.artifactRoutingApplied = 'failed';\n    }\n  }\n\n  // -- 6. Feedback signals --\n  try {\n    const withFeedback = applyFeedbackSignals(results, config.query);\n    // Detect if any score actually changed\n    const changed = withFeedback.some((r, i) => r !== results[i]);\n    if (changed) {\n      results = withFeedback;\n      metadata.feedbackSignalsApplied = 'applied';\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] feedback signals failed: ${message}`);\n    metadata.feedbackSignalsApplied = 'failed';\n  }\n\n  // -- 6a. Learned Stage 2 shadow scoring --\n  // Runs the learned linear ranker in parallel with the manual combiner.\n  // Shadow-only — scores are logged for comparison but never affect live ranking.\n  // Gated behind SPECKIT_LEARNED_STAGE2_COMBINER (default ON, graduated).\n  // When SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT is set in (0, 0.05],\n  // a small guarded blend `(1-w)*manual + w*learned` is applied to the live\n  // score. Default 0 preserves shadow-only behavior. The blend weight is\n  // clamped at the source by resolveLearnedBlendWeight().\n  if (isLearnedStage2CombinerEnabled()) {\n    try {\n      const learnedShadowModel = await loadPersistedLearnedStage2Model();\n      // Weight resolved once per pipeline run; flag-gated and\n      // clamped. Zero means shadow-only (today's behavior).\n      const learnedBlendWeight = resolveLearnedBlendWeight();\n      for (let rowIndex = 0; rowIndex < results.length; rowIndex++) {\n        const row = results[rowIndex];\n        const features = extractFeatureVector({\n          rrfScore: row.rrfScore,\n          overlapScore: typeof row.overlapScore === 'number' ? row.overlapScore : undefined,\n          graphScore: (() => {\n            const gc = row.graphContribution as Record<string, unknown> | undefined;\n            const delta = typeof gc?.totalDelta === 'number' ? gc.totalDelta : 0;\n            return Math.max(0, Math.min(1, delta + 0.5));\n          })(),\n          sessionScore: typeof row.sessionScore === 'number' ? row.sessionScore : undefined,\n          causalScore: typeof row.causalScore === 'number' ? row.causalScore : undefined,\n          feedbackScore: typeof row.feedbackScore === 'number' ? row.feedbackScore : undefined,\n          validationScore: (() => {\n            const vm = row.validationMetadata as Record<string, unknown> | undefined;\n            return typeof vm?.qualityScore === 'number' ? vm.qualityScore : undefined;\n          })(),\n          artifactScore: typeof row.artifactBoostApplied === 'number'\n            ? Math.min(1, row.artifactBoostApplied / 2)\n            : undefined,\n        });\n        const shadow = shadowScore(learnedShadowModel, features, resolveBaseScore(row), true);\n        if (shadow) {\n          console.warn(\n            `[stage2-fusion] shadow-learned id=${row.id} manual=${shadow.manualScore.toFixed(4)} learned=${shadow.learnedScore.toFixed(4)} delta=${shadow.delta.toFixed(4)}`\n          );\n          // Apply the small guarded blend when weight > 0 AND a\n          // shadow result is available (model loaded successfully). Mutate\n          // the row through withSyncedScoreAliases so all score aliases stay\n          // aligned. When weight is 0 (default) or model failed to load, this\n          // branch is skipped and behavior is identical to pre-fix.\n          if (learnedBlendWeight > 0) {\n            const blendedScore = (1 - learnedBlendWeight) * shadow.manualScore\n              + learnedBlendWeight * shadow.learnedScore;\n            results[rowIndex] = withSyncedScoreAliases(row, blendedScore);\n          }\n        }\n      }\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] learned stage2 shadow scoring failed: ${message}`);\n    }\n  }\n\n  // -- 6a. Retrieval rescue + 7. Artifact-based result limiting --\n  // The routing strategy may specify a maxResults count stricter than the\n  // Overall pipeline limit. Apply it here so Stage 3 reranks a pre-trimmed set.\n  syncScoreAliasesInPlace(results);\n  if (isRetrievalRescueEnabled()) {\n    try {\n      let rescueDb: Database.Database | null = null;\n      try {\n        rescueDb = requireDb();\n      } catch {\n        rescueDb = null;\n      }\n      results = applyRetrievalRescueLayer(config.query, results, {\n        db: rescueDb,\n        artifactClass: config.artifactRouting?.strategy?.artifactClass as string | undefined\n          ?? config.artifactRouting?.detectedClass,\n      });\n      logger.debug('retrieval rescue layer completed', {\n        event: 'stage2_retrieval_rescue_success',\n        resultCount: results.length,\n        hasDb: rescueDb !== null,\n        artifactClass: config.artifactRouting?.strategy?.artifactClass\n          ?? config.artifactRouting?.detectedClass\n          ?? null,\n      });\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] retrieval rescue layer failed: ${message}`);\n    }\n  }\n  results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n  if (\n    config.artifactRouting &&\n    config.artifactRouting.confidence > 0 &&\n    typeof config.artifactRouting.strategy?.maxResults === 'number' &&\n    config.artifactRouting.strategy.maxResults > 0 &&\n    results.length > config.artifactRouting.strategy.maxResults\n  ) {\n    results = results.slice(0, config.artifactRouting.strategy.maxResults);\n  }\n\n  // -- Steps 8-9: Enrichment (extracted to stage2b-enrichment.ts) --\n  // Pure annotation: anchor metadata + validation metadata.\n  // Validation signal SCORING (applyValidationSignalScoring) stays here\n  // because it's a scoring step, not a pure enrichment.\n  results = executeStage2bEnrichment(results);\n  try {\n    results = applyValidationSignalScoring(results);\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] validation signal scoring failed: ${message}`);\n  }\n\n  // Keep all score aliases aligned after late-stage score mutations.\n  syncScoreAliasesInPlace(results);\n  if (metadata.graphContribution) {\n    metadata.graphContribution.causalBoosted = countGraphContribution(results, 'causalDelta');\n    metadata.graphContribution.coActivationBoosted = countGraphContribution(results, 'coActivationDelta');\n    metadata.graphContribution.communityInjected = countGraphContribution(results, 'communityDelta');\n    metadata.graphContribution.graphSignalsBoosted = countGraphContribution(results, 'graphSignalDelta');\n    metadata.graphContribution.totalGraphInjected = countGraphInjected(results);\n\n    // P2 fix: Diagnostic when graph is activated but contributes nothing\n    if (\n      !metadata.graphContribution.killSwitchActive &&\n      metadata.graphContribution.rolloutState === 'bounded_runtime' &&\n      metadata.graphContribution.causalBoosted === 0 &&\n      metadata.graphContribution.coActivationBoosted === 0 &&\n      metadata.graphContribution.communityInjected === 0 &&\n      metadata.graphContribution.graphSignalsBoosted === 0 &&\n      results.length > 0\n    ) {\n      console.warn(","lineStart":960,"lineEnd":1429,"totalLines":1486,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","time":{"start":1781764178918,"end":1781764178921}},"metadata":{"openai":{"itemId":"fc_0eeadce08442b1f3016a339052bc608191bdef6622e83c22d5"}},"id":"prt_ed96bc3d2001TEHb0KmMOcwwoS","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96ba22a001l3Sutsu44FZqq8"}}
{"type":"tool_use","timestamp":1781764179040,"sessionID":"ses_126974374fferlHj5CU2Guj68V","part":{"type":"tool","tool":"read","callID":"call_1MiomDfuBsWrXyT6mvE8zyX5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","offset":80,"limit":170},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts</path>\n<type>file</type>\n<content>\n80:   chunks: PipelineRow[];\n81:   /** The chunk with the highest similarity/score — the representative row. */\n82:   bestChunk: PipelineRow;\n83:   /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n84:   parentScore: number;\n85: }\n86: \n87: type RerankProvider = 'fallback-sort' | 'none';\n88: \n89: // -- Stage 3 Entry Point ----------------------------------------\n90: \n91: /**\n92:  * Execute Stage 3: Rerank + Aggregate.\n93:  *\n94:  * Applies MMR diversity reranking (when enabled) and then collapses\n95:  * chunked memory hits into their parent documents (MPAB). Stage 3\n96:  * reduces near-duplicate chunks before parent reassembly aggregates\n97:  * the result set.\n98:  *\n99:  * @param input - Stage 3 input containing scored results from Stage 2\n100:  *   and the shared pipeline configuration.\n101:  * @returns Stage 3 output with reranked, aggregated results and metadata.\n102:  */\n103: export async function executeStage3(input: Stage3Input): Promise<Stage3Output> {\n104:   const stageStart = Date.now();\n105:   const { scored, config } = input;\n106: \n107:   let results = scored;\n108: \n109:   // -- Step 1: (removed) model-based cross-encoder reranking -----\n110:   // The cross-encoder / local-GGUF reranking layer was removed: it had no\n111:   // configured provider after the sidecar deprecation (isCrossEncoderEnabled()\n112:   // was hard-off), so it was an inactive no-op. Stage 3 now performs only\n113:   // algorithmic MMR diversity (Step 2) and MPAB chunk-collapse (Step 3).\n114:   // These constants preserve the unchanged metadata/envelope shape.\n115:   const rerankApplied = false;\n116:   const rerankProvider: RerankProvider = 'none';\n117: \n118:   // -- Step 2: MMR diversity pruning ----------------------------\n119:   // Gated behind SPECKIT_MMR feature flag. Retrieves embeddings from\n120:   // Vec_memories and applies Maximal Marginal Relevance to diversify\n121:   // The result set, matching the V1 hybrid-search behavior.\n122:   if (isMMREnabled() && results.length >= MMR_MIN_CANDIDATES) {\n123:     try {\n124:       const db = requireDb() as Database.Database;\n125:       const numericIds = results\n126:         .map(r => r.id)\n127:         .filter((id): id is number => typeof id === 'number');\n128: \n129:       if (numericIds.length >= MMR_MIN_CANDIDATES) {\n130:         const placeholders = numericIds.map(() => '?').join(', ');\n131:         const embRows = (db.prepare(\n132:           `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n133:         ) as Database.Statement).all(...numericIds) as Array<{ rowid: number; embedding: Buffer }>;\n134: \n135:         const embeddingMap = new Map<number, Float32Array>();\n136:         for (const row of embRows) {\n137:           if (Buffer.isBuffer(row.embedding)) {\n138:             embeddingMap.set(\n139:               row.rowid,\n140:               new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n141:             );\n142:           }\n143:         }\n144: \n145:         const mmrCandidates: MMRCandidate[] = [];\n146:         for (const r of results) {\n147:           const emb = embeddingMap.get(r.id);\n148:           if (emb) {\n149:             mmrCandidates.push({\n150:               id: r.id,\n151:               // Use effectiveScore() for consistent fallback chain\n152:               score: floorScore(effectiveScore(r)),\n153:               embedding: emb,\n154:             });\n155:           }\n156:         }\n157: \n158:         if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n159:           const originalPositionMap = new Map<number | string, number>();\n160:           results.forEach((row, index) => originalPositionMap.set(row.id, index));\n161:           const intent = config.adaptiveFusionIntent ?? config.detectedIntent ?? '';\n162:           const mmrLambda = (INTENT_LAMBDA_MAP as Record<string, number>)[intent] ?? MMR_DEFAULT_LAMBDA;\n163:           const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit: config.limit });\n164: \n165:           // FIX #5: MMR can only diversify rows that have embeddings. Non-embedded\n166:           // rows (lexical-only hits, graph injections) must be preserved and merged\n167:           // back in their original relative order instead of being silently dropped.\n168:           const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n169:           const nonEmbeddedRows = results.filter(r => !embeddedIdSet.has(r.id));\n170: \n171:           // Rebuild PipelineRow[] from diversified candidates, preserving all original fields\n172:           const rowMap = new Map<number | string, PipelineRow>();\n173:           for (const r of results) rowMap.set(r.id, r);\n174: \n175:           const diversifiedRows = diversified.map((candidate): PipelineRow => {\n176:             const existing = rowMap.get(candidate.id);\n177:             if (existing) return existing;\n178:             return { id: candidate.id as number, score: candidate.score };\n179:           });\n180: \n181:           const positioned: Array<{ row: PipelineRow; pos: number }> = [];\n182:           diversifiedRows.forEach((row, index) => positioned.push({ row, pos: index }));\n183:           nonEmbeddedRows.forEach((row) => {\n184:             const originalPosition = originalPositionMap.get(row.id) ?? results.length;\n185:             positioned.push({ row, pos: originalPosition });\n186:           });\n187: \n188:           positioned.sort((left, right) => left.pos - right.pos);\n189:           results = positioned.map(({ row }) => row);\n190:         }\n191:       }\n192:     } catch (mmrErr: unknown) {\n193:       // Non-critical — MMR failure does not block pipeline\n194:       console.warn(`[stage3-rerank] MMR diversity pruning failed: ${toErrorMessage(mmrErr)}`);\n195:     }\n196:   }\n197: \n198:   // -- Step 3: MPAB chunk collapse + parent reassembly -----------\n199:   //\n200:   // MPAB must remain AFTER RRF (Stage 2 constraint). This step runs\n201:   // Here in Stage 3 — never move it upstream.\n202:   const mpabStart = Date.now();\n203:   const beforeMpab = results.length;\n204: \n205:   const { results: aggregated, stats: chunkStats } =\n206:     await collapseAndReassembleChunkResults(results);\n207: \n208:   results = aggregated;\n209: \n210:   if (config.trace) {\n211:     addTraceEntry(\n212:       config.trace,\n213:       'final-rank',\n214:       beforeMpab,\n215:       results.length,\n216:       Date.now() - mpabStart,\n217:       {\n218:         collapsedChunkHits: chunkStats.collapsedChunkHits,\n219:         chunkParents: chunkStats.chunkParents,\n220:         reassembled: chunkStats.reassembled,\n221:         fallback: chunkStats.fallback,\n222:       }\n223:     );\n224:   }\n225: \n226:   const metadata = {\n227:     rerankApplied,\n228:     rerankProvider,\n229:     chunkReassemblyStats: chunkStats,\n230:     durationMs: Date.now() - stageStart,\n231:   };\n232: \n233:   return {\n234:     reranked: results,\n235:     metadata,\n236:   };\n237: }\n238: \n239: // -- Internal: MPAB Chunk Collapse + Parent Reassembly ---------\n240: \n241: /**\n242:  * Collapse chunk-level hits and reassemble parent memory documents.\n243:  *\n244:  * MPAB (Multi-Part Aggregation + Backfill) algorithm:\n245:  *   1. Separate rows into chunks (has `parent_id`) and non-chunks.\n246:  *   2. Group chunks by `parent_id`.\n247:  *   3. For each group, elect the best chunk (highest score).\n248:  *   4. Attempt to load the full parent content from the database.\n249:  *   5. If the DB query succeeds, emit a reassembled parent row.\n\n(Showing lines 80-249 of 502. Use offset=250 to continue.)\n</content>","metadata":{"preview":"  chunks: PipelineRow[];\n  /** The chunk with the highest similarity/score — the representative row. */\n  bestChunk: PipelineRow;\n  /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n  parentScore: number;\n}\n\ntype RerankProvider = 'fallback-sort' | 'none';\n\n// -- Stage 3 Entry Point ----------------------------------------\n\n/**\n * Execute Stage 3: Rerank + Aggregate.\n *\n * Applies MMR diversity reranking (when enabled) and then collapses\n * chunked memory hits into their parent documents (MPAB). Stage 3\n * reduces near-duplicate chunks before parent reassembly aggregates\n * the result set.\n *\n * @param input - Stage 3 input containing scored results from Stage 2","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","text":"  chunks: PipelineRow[];\n  /** The chunk with the highest similarity/score — the representative row. */\n  bestChunk: PipelineRow;\n  /** Parent-level score derived from all chunk scores with a best-chunk floor. */\n  parentScore: number;\n}\n\ntype RerankProvider = 'fallback-sort' | 'none';\n\n// -- Stage 3 Entry Point ----------------------------------------\n\n/**\n * Execute Stage 3: Rerank + Aggregate.\n *\n * Applies MMR diversity reranking (when enabled) and then collapses\n * chunked memory hits into their parent documents (MPAB). Stage 3\n * reduces near-duplicate chunks before parent reassembly aggregates\n * the result set.\n *\n * @param input - Stage 3 input containing scored results from Stage 2\n *   and the shared pipeline configuration.\n * @returns Stage 3 output with reranked, aggregated results and metadata.\n */\nexport async function executeStage3(input: Stage3Input): Promise<Stage3Output> {\n  const stageStart = Date.now();\n  const { scored, config } = input;\n\n  let results = scored;\n\n  // -- Step 1: (removed) model-based cross-encoder reranking -----\n  // The cross-encoder / local-GGUF reranking layer was removed: it had no\n  // configured provider after the sidecar deprecation (isCrossEncoderEnabled()\n  // was hard-off), so it was an inactive no-op. Stage 3 now performs only\n  // algorithmic MMR diversity (Step 2) and MPAB chunk-collapse (Step 3).\n  // These constants preserve the unchanged metadata/envelope shape.\n  const rerankApplied = false;\n  const rerankProvider: RerankProvider = 'none';\n\n  // -- Step 2: MMR diversity pruning ----------------------------\n  // Gated behind SPECKIT_MMR feature flag. Retrieves embeddings from\n  // Vec_memories and applies Maximal Marginal Relevance to diversify\n  // The result set, matching the V1 hybrid-search behavior.\n  if (isMMREnabled() && results.length >= MMR_MIN_CANDIDATES) {\n    try {\n      const db = requireDb() as Database.Database;\n      const numericIds = results\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length >= MMR_MIN_CANDIDATES) {\n        const placeholders = numericIds.map(() => '?').join(', ');\n        const embRows = (db.prepare(\n          `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n        ) as Database.Statement).all(...numericIds) as Array<{ rowid: number; embedding: Buffer }>;\n\n        const embeddingMap = new Map<number, Float32Array>();\n        for (const row of embRows) {\n          if (Buffer.isBuffer(row.embedding)) {\n            embeddingMap.set(\n              row.rowid,\n              new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n            );\n          }\n        }\n\n        const mmrCandidates: MMRCandidate[] = [];\n        for (const r of results) {\n          const emb = embeddingMap.get(r.id);\n          if (emb) {\n            mmrCandidates.push({\n              id: r.id,\n              // Use effectiveScore() for consistent fallback chain\n              score: floorScore(effectiveScore(r)),\n              embedding: emb,\n            });\n          }\n        }\n\n        if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n          const originalPositionMap = new Map<number | string, number>();\n          results.forEach((row, index) => originalPositionMap.set(row.id, index));\n          const intent = config.adaptiveFusionIntent ?? config.detectedIntent ?? '';\n          const mmrLambda = (INTENT_LAMBDA_MAP as Record<string, number>)[intent] ?? MMR_DEFAULT_LAMBDA;\n          const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit: config.limit });\n\n          // FIX #5: MMR can only diversify rows that have embeddings. Non-embedded\n          // rows (lexical-only hits, graph injections) must be preserved and merged\n          // back in their original relative order instead of being silently dropped.\n          const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n          const nonEmbeddedRows = results.filter(r => !embeddedIdSet.has(r.id));\n\n          // Rebuild PipelineRow[] from diversified candidates, preserving all original fields\n          const rowMap = new Map<number | string, PipelineRow>();\n          for (const r of results) rowMap.set(r.id, r);\n\n          const diversifiedRows = diversified.map((candidate): PipelineRow => {\n            const existing = rowMap.get(candidate.id);\n            if (existing) return existing;\n            return { id: candidate.id as number, score: candidate.score };\n          });\n\n          const positioned: Array<{ row: PipelineRow; pos: number }> = [];\n          diversifiedRows.forEach((row, index) => positioned.push({ row, pos: index }));\n          nonEmbeddedRows.forEach((row) => {\n            const originalPosition = originalPositionMap.get(row.id) ?? results.length;\n            positioned.push({ row, pos: originalPosition });\n          });\n\n          positioned.sort((left, right) => left.pos - right.pos);\n          results = positioned.map(({ row }) => row);\n        }\n      }\n    } catch (mmrErr: unknown) {\n      // Non-critical — MMR failure does not block pipeline\n      console.warn(`[stage3-rerank] MMR diversity pruning failed: ${toErrorMessage(mmrErr)}`);\n    }\n  }\n\n  // -- Step 3: MPAB chunk collapse + parent reassembly -----------\n  //\n  // MPAB must remain AFTER RRF (Stage 2 constraint). This step runs\n  // Here in Stage 3 — never move it upstream.\n  const mpabStart = Date.now();\n  const beforeMpab = results.length;\n\n  const { results: aggregated, stats: chunkStats } =\n    await collapseAndReassembleChunkResults(results);\n\n  results = aggregated;\n\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'final-rank',\n      beforeMpab,\n      results.length,\n      Date.now() - mpabStart,\n      {\n        collapsedChunkHits: chunkStats.collapsedChunkHits,\n        chunkParents: chunkStats.chunkParents,\n        reassembled: chunkStats.reassembled,\n        fallback: chunkStats.fallback,\n      }\n    );\n  }\n\n  const metadata = {\n    rerankApplied,\n    rerankProvider,\n    chunkReassemblyStats: chunkStats,\n    durationMs: Date.now() - stageStart,\n  };\n\n  return {\n    reranked: results,\n    metadata,\n  };\n}\n\n// -- Internal: MPAB Chunk Collapse + Parent Reassembly ---------\n\n/**\n * Collapse chunk-level hits and reassemble parent memory documents.\n *\n * MPAB (Multi-Part Aggregation + Backfill) algorithm:\n *   1. Separate rows into chunks (has `parent_id`) and non-chunks.\n *   2. Group chunks by `parent_id`.\n *   3. For each group, elect the best chunk (highest score).\n *   4. Attempt to load the full parent content from the database.\n *   5. If the DB query succeeds, emit a reassembled parent row.","lineStart":80,"lineEnd":249,"totalLines":502,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage3-rerank.ts","time":{"start":1781764179033,"end":1781764179039}},"metadata":{"openai":{"itemId":"fc_0eeadce08442b1f3016a339052bc688191b2045c3596654342"}},"id":"prt_ed96bc40d001fU9Yi9noJjnhdy","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96ba22a001l3Sutsu44FZqq8"}}
