ller per file path for cancellation of stale reindex\n\n  Line 360:   const activeAbortControllers = new Map<string, AbortController>();\n\n  Line 428:     // Abort any in-flight reindex for this same file before scheduling new one\n\n  Line 430:       const prev = activeAbortControllers.get(filePath);\n\n  Line 439:       const controller = new AbortController();\n\n  Line 440:       activeAbortControllers.set(filePath, controller);\n\n  Line 455:         activeAbortControllers.set(resolvedPath, controller);\n\n  Line 508:           await withBusyRetry(async () => {\n\n  Line 510:           }, { shouldAbort: () => isClosing, waker: retryWaker });\n\n  Line 519:           releaseReindexSlot();\n\n  Line 522:         if (activeAbortControllers.get(filePath) === controller) {\n\n  Line 523:           activeAbortControllers.delete(filePath);\n\n  Line 526:         if (resolvedPath && activeAbortControllers.get(resolvedPath) === controller) {\n\n  Line 527:           activeAbortControllers.delete(resolvedPath);\n\n  Line 552:       await withBusyRetry(async () => {\n\n  Line 554:       }, { shouldAbort: () => isClosing, waker: retryWaker });\n\n  Line 589:     // non-cancellable retry timer expires.\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/sqlite-busy-retry.ts:\n  Line 20: export async function withBusyRetry<T>(operation: () => T): Promise<T> {\n\n  Line 24: export function withBusyRetrySync<T>(operation: () => T): T {\n","metadata":{"matches":92,"truncated":false},"title":"cancel|cancelled|isCancelled|Abort|lease|setImmediate|setInterval|withBusyRetry|transaction\\(|\\.immediate\\(|BEGIN|COMMIT|ROLLBACK|delete_after|deleted_at","time":{"start":1781762722874,"end":1781762722889}},"metadata":{"openai":{"itemId":"fc_0ce2b4075cb63118016a338aa27340819198415dd9d75841d2"}},"id":"prt_ed9558b56001HxKcOcFzH544Fq","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed9555043001Wt513dlJB1q8