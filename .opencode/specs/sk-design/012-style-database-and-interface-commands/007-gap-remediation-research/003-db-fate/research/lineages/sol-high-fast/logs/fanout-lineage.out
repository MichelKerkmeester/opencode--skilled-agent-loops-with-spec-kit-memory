oolsUsed\":[\"Read\",\"Grep\"],\"sourcesQueried\":[\"styles/_engine/style-library.mjs\",\"design-interface/corpus/relational-exemplar.mjs\",\"design-motion/corpus/motion-evidence.mjs\",\"design-audit/corpus/comparison-lane.mjs\",\"design-foundations/corpus/relationship-blueprint.mjs\"],\"timestamp\":\"2026-07-21T08:38:00Z\",\"durationMs\":155000,\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1,\"executor\":{\"kind\":\"cli-opencode\",\"model\":\"openai/gpt-5.6-sol-fast\"},\"graphEvents\":[]}\n{\"type\":\"event\",\"event\":\"dashboard_generated\",\"iteration\":1,\"timestamp\":\"2026-07-21T08:38:01Z\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-state.jsonl","text":"{\"type\":\"config\",\"topic\":\"Decide whether to wire the dormant styles SQLite database into the default retrieval path or formally shelve it in favor of the flat-file engine\",\"maxIterations\":5,\"minIterations\":3,\"convergenceThreshold\":0.05,\"antiConvergence\":{\"convergenceMode\":\"default\",\"stopPolicy\":\"max-iterations\",\"divergent\":{}},\"resource_map_present\":false,\"resource_map\":{\"emit\":true},\"createdAt\":\"2026-07-21T08:35:03Z\",\"specFolder\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate\",\"artifactDir\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1,\"nextRunAt\":null,\"remainingDelayMs\":null}\n{\"type\":\"event\",\"event\":\"spec_check_result\",\"folder_state\":\"spec-present\",\"normalized_topic\":\"decide whether to wire the dormant styles sqlite database into the default retrieval path or formally shelve it in favor of the flat-file engine\",\"specPath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/spec.md\",\"lockPath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/.deep-research.lock\",\"timestamp\":\"2026-07-21T08:35:19Z\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1}\n{\"type\":\"event\",\"event\":\"spec_synthesis_deferred\",\"reason\":\"detached-lineage scope permits writes only inside the lineage artifact directory\",\"timestamp\":\"2026-07-21T08:35:19Z\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1}\n{\"type\":\"iteration\",\"iteration\":1,\"mode\":\"research\",\"target_agent\":\"deep-research\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=research target_agent=deep-research\",\"run\":1,\"status\":\"complete\",\"focus\":\"Actual design-mode consumer contract and runtime path\",\"findingsCount\":5,\"newInfoRatio\":1.0,\"noveltyJustification\":\"First iteration established five new contract-level findings from the actual consumers.\",\"keyQuestions\":[\"What contract and workload do the four design-mode corpus consumers require?\"],\"answeredQuestions\":[\"What contract and workload do the four design-mode corpus consumers require?\"],\"ruledOut\":[\"Consumer modules require a database-specific API\",\"SQLite would become the authoritative content store\",\"Consumer rewrites are required for backend selection\"],\"focusTrack\":\"architecture\",\"edgeCase\":\"ambiguous-input\",\"toolsUsed\":[\"Read\",\"Grep\"],\"sourcesQueried\":[\"styles/_engine/style-library.mjs\",\"design-interface/corpus/relational-exemplar.mjs\",\"design-motion/corpus/motion-evidence.mjs\",\"design-audit/corpus/comparison-lane.mjs\",\"design-foundations/corpus/relationship-blueprint.mjs\"],\"timestamp\":\"2026-07-21T08:38:00Z\",\"durationMs\":155000,\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1,\"executor\":{\"kind\":\"cli-opencode\",\"model\":\"openai/gpt-5.6-sol-fast\"},\"graphEvents\":[]}\n{\"type\":\"event\",\"event\":\"dashboard_generated\",\"iteration\":1,\"timestamp\":\"2026-07-21T08:38:01Z\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1}","lineStart":1,"lineEnd":5,"totalLines":5,"truncated":false}},"title":".opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-state.jsonl","time":{"start":1784623168546,"end":1784623168550}},"metadata":{"openai":{"itemId":"fc_02bf757ba310bf3e016a5f30403a94819192b69841634cf45a"}},"id":"prt_f83d47bfb001Fz4iK5cJAtJd6J","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV"}}
{"type":"tool_use","timestamp":1784623168626,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"read","callID":"call_QVQDVkWq3gV19gsaKGadMbyw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-strategy.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-strategy.md</path>\n<type>file</type>\n<content>\n1: # Deep Research Strategy: Styles SQLite Database Fate\n2: \n3: ## 1. Research Topic\n4: \n5: Decide whether to fully wire and populate the dormant styles SQLite database as the default retrieval path or formally shelve it and retain the flat-file engine as the single source.\n6: \n7: ## 2. Non-Goals\n8: \n9: - Do not implement, remove, rename, or relocate styles code or data.\n10: - Do not modify the parent spec packet or any path outside this detached lineage.\n11: - Do not decide the separate interface-command rewrite or styles-directory naming questions.\n12: - Do not treat code existence or passing unit tests alone as proof of production need.\n13: \n14: ## 3. Stop Conditions\n15: \n16: - Complete exactly five iterations because `stopPolicy=max-iterations`.\n17: - Produce an evidence-backed recommendation, decision framework, keep-path wiring plan, and shelf-path deprecation plan.\n18: - Ground the recommendation in the four design-mode corpus consumers and current operational evidence.\n19: \n20: <!-- ANCHOR:key-questions -->\n21: ## 4. Key Questions (Remaining)\n22: \n23: - [x] What contract and workload do design-interface, design-motion, design-audit, and design-foundations actually require from the styles library?\n24: - [ ] How complete is the persistent implementation, and what exact work remains to make it the default and populate a real database?\n25: - [ ] What measurable benefits justify SQLite at the present corpus size, and what recurring operational costs would default persistence introduce?\n26: - [ ] Which decision criteria and thresholds should govern keep versus shelve?\n27: - [ ] What are the safe wiring and deprecation plans, including rollback and preservation of useful evidence assets?\n28: <!-- /ANCHOR:key-questions -->\n29: \n30: <!-- ANCHOR:answered-questions -->\n31: ## 5. Answered Questions\n32: \n33: - The four consumers require a bounded, generation-safe `runQuery`/`runHydrate` facade and degrade safely when retrieval is unavailable; none requires SQLite specifically. (iteration 1)\n34: <!-- /ANCHOR:answered-questions -->\n35: \n36: <!-- MACHINE-OWNED: START -->\n37: <!-- ANCHOR:what-worked -->\n38: ## 6. What Worked\n39: \n40: - Consumer-to-facade tracing: showed that backend choice is isolated below all four corpus modules. (iteration 1)\n41: <!-- /ANCHOR:what-worked -->\n42: \n43: <!-- ANCHOR:what-failed -->\n44: ## 7. What Failed\n45: \n46: - Initial wildcard include search: returned no files because the path/include shape was too broad; replaced with an exact call-site search. (iteration 1)\n47: <!-- /ANCHOR:what-failed -->\n48: \n49: <!-- ANCHOR:exhausted-approaches -->\n50: ## 8. Exhausted Approaches\n51: \n52: - Database-specific consumer rewrites: ruled out because all consumers already call the adapter-backed facade. (iteration 1)\n53: - SQLite as authoritative content storage: ruled out because hydration remains flat-file artifact access. (iteration 1)\n54: <!-- /ANCHOR:exhausted-approaches -->\n55: \n56: <!-- ANCHOR:ruled-out-directions -->\n57: ## 9. Ruled-Out Directions\n58: \n59: None yet.\n60: <!-- /ANCHOR:ruled-out-directions -->\n61: \n62: <!-- ANCHOR:carried-forward-open-questions -->\n63: ## 10. Carried-Forward Open Questions\n64: \n65: None yet.\n66: <!-- /ANCHOR:carried-forward-open-questions -->\n67: \n68: <!-- ANCHOR:next-focus -->\n69: ## 11. Next Focus\n70: \n71: Assess persistent-backend completeness and enumerate the exact wiring/build work required for a real default database.\n72: <!-- /ANCHOR:next-focus -->\n73: <!-- MACHINE-OWNED: END -->\n74: \n75: ## 12. Known Context\n76: \n77: - The gap analysis reports 1,290 style folders, no SQLite file, a `legacy` default, and four corpus modules routed through `_engine/style-library.mjs`. [SOURCE: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-89]\n78: - The database foundation packet reports 69 passing tests for generation manifests, telemetry, differential oracle, fixtures, and judgments, but identifies live-corpus telemetry and human relevance labels as unresolved. [SOURCE: .opencode/specs/sk-design/015-styles-database-evolution/001-foundation/implementation-summary.md:50-57] [SOURCE: .opencode/specs/sk-design/015-styles-database-evolution/001-foundation/implementation-summary.md:117-123]\n79: - `resource-map.md` is not present in the target spec folder; skipping the input coverage gate.\n80: \n81: ## 13. Research Boundaries\n82: \n83: - Maximum iterations: 5\n84: - Stop policy: max-iterations\n85: - Convergence threshold: 0.05, telemetry only before iteration 5\n86: - Allowed write root: this detached `sol-high-fast` lineage only\n87: - Per-iteration write set: one prompt, one narrative, one delta, one state-log append, then workflow-owned reducer projections\n\n(End of file - total 87 lines)\n</content>","metadata":{"preview":"# Deep Research Strategy: Styles SQLite Database Fate\n\n## 1. Research Topic\n\nDecide whether to fully wire and populate the dormant styles SQLite database as the default retrieval path or formally shelve it and retain the flat-file engine as the single source.\n\n## 2. Non-Goals\n\n- Do not implement, remove, rename, or relocate styles code or data.\n- Do not modify the parent spec packet or any path outside this detached lineage.\n- Do not decide the separate interface-command rewrite or styles-directory naming questions.\n- Do not treat code existence or passing unit tests alone as proof of production need.\n\n## 3. Stop Conditions\n\n- Complete exactly five iterations because `stopPolicy=max-iterations`.\n- Produce an evidence-backed recommendation, decision framework, keep-path wiring plan, and shelf-path deprecation plan.\n- Ground the recommendation in the four design-mode corpus consumers and current operational evidence.\n\n<!-- ANCHOR:key-questions -->","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-strategy.md","text":"# Deep Research Strategy: Styles SQLite Database Fate\n\n## 1. Research Topic\n\nDecide whether to fully wire and populate the dormant styles SQLite database as the default retrieval path or formally shelve it and retain the flat-file engine as the single source.\n\n## 2. Non-Goals\n\n- Do not implement, remove, rename, or relocate styles code or data.\n- Do not modify the parent spec packet or any path outside this detached lineage.\n- Do not decide the separate interface-command rewrite or styles-directory naming questions.\n- Do not treat code existence or passing unit tests alone as proof of production need.\n\n## 3. Stop Conditions\n\n- Complete exactly five iterations because `stopPolicy=max-iterations`.\n- Produce an evidence-backed recommendation, decision framework, keep-path wiring plan, and shelf-path deprecation plan.\n- Ground the recommendation in the four design-mode corpus consumers and current operational evidence.\n\n<!-- ANCHOR:key-questions -->\n## 4. Key Questions (Remaining)\n\n- [x] What contract and workload do design-interface, design-motion, design-audit, and design-foundations actually require from the styles library?\n- [ ] How complete is the persistent implementation, and what exact work remains to make it the default and populate a real database?\n- [ ] What measurable benefits justify SQLite at the present corpus size, and what recurring operational costs would default persistence introduce?\n- [ ] Which decision criteria and thresholds should govern keep versus shelve?\n- [ ] What are the safe wiring and deprecation plans, including rollback and preservation of useful evidence assets?\n<!-- /ANCHOR:key-questions -->\n\n<!-- ANCHOR:answered-questions -->\n## 5. Answered Questions\n\n- The four consumers require a bounded, generation-safe `runQuery`/`runHydrate` facade and degrade safely when retrieval is unavailable; none requires SQLite specifically. (iteration 1)\n<!-- /ANCHOR:answered-questions -->\n\n<!-- MACHINE-OWNED: START -->\n<!-- ANCHOR:what-worked -->\n## 6. What Worked\n\n- Consumer-to-facade tracing: showed that backend choice is isolated below all four corpus modules. (iteration 1)\n<!-- /ANCHOR:what-worked -->\n\n<!-- ANCHOR:what-failed -->\n## 7. What Failed\n\n- Initial wildcard include search: returned no files because the path/include shape was too broad; replaced with an exact call-site search. (iteration 1)\n<!-- /ANCHOR:what-failed -->\n\n<!-- ANCHOR:exhausted-approaches -->\n## 8. Exhausted Approaches\n\n- Database-specific consumer rewrites: ruled out because all consumers already call the adapter-backed facade. (iteration 1)\n- SQLite as authoritative content storage: ruled out because hydration remains flat-file artifact access. (iteration 1)\n<!-- /ANCHOR:exhausted-approaches -->\n\n<!-- ANCHOR:ruled-out-directions -->\n## 9. Ruled-Out Directions\n\nNone yet.\n<!-- /ANCHOR:ruled-out-directions -->\n\n<!-- ANCHOR:carried-forward-open-questions -->\n## 10. Carried-Forward Open Questions\n\nNone yet.\n<!-- /ANCHOR:carried-forward-open-questions -->\n\n<!-- ANCHOR:next-focus -->\n## 11. Next Focus\n\nAssess persistent-backend completeness and enumerate the exact wiring/build work required for a real default database.\n<!-- /ANCHOR:next-focus -->\n<!-- MACHINE-OWNED: END -->\n\n## 12. Known Context\n\n- The gap analysis reports 1,290 style folders, no SQLite file, a `legacy` default, and four corpus modules routed through `_engine/style-library.mjs`. [SOURCE: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-89]\n- The database foundation packet reports 69 passing tests for generation manifests, telemetry, differential oracle, fixtures, and judgments, but identifies live-corpus telemetry and human relevance labels as unresolved. [SOURCE: .opencode/specs/sk-design/015-styles-database-evolution/001-foundation/implementation-summary.md:50-57] [SOURCE: .opencode/specs/sk-design/015-styles-database-evolution/001-foundation/implementation-summary.md:117-123]\n- `resource-map.md` is not present in the target spec folder; skipping the input coverage gate.\n\n## 13. Research Boundaries\n\n- Maximum iterations: 5\n- Stop policy: max-iterations\n- Convergence threshold: 0.05, telemetry only before iteration 5\n- Allowed write root: this detached `sol-high-fast` lineage only\n- Per-iteration write set: one prompt, one narrative, one delta, one state-log append, then workflow-owned reducer projections","lineStart":1,"lineEnd":87,"totalLines":87,"truncated":false}},"title":".opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-strategy.md","time":{"start":1784623168620,"end":1784623168625}},"metadata":{"openai":{"itemId":"fc_02bf757ba310bf3e016a5f30403aa08191b8d59ef93710d98d"}},"id":"prt_f83d47c4d001sYyv4x6mCVeH6N","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV"}}
{"type":"tool_use","timestamp":1784623168714,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"read","callID":"call_200Tx5drSfA9AetqjkcTMmsJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs","offset":1,"limit":390},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Style Database Migration Adapter                                         ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import { createHash } from 'node:crypto';\n6: import { readFile, realpath } from 'node:fs/promises';\n7: import path from 'node:path';\n8: \n9: import { queryPersistentStyles, retrievalInternals } from '../_db/retrieval.mjs';\n10: import {\n11:   DEFAULT_STYLE_DATABASE_PATH,\n12:   openPublishedStyleDatabase,\n13: } from '../_db/schema.mjs';\n14: import { modeIncludes } from './hydrate.mjs';\n15: \n16: export const STYLE_DATABASE_MODES = Object.freeze(['legacy', 'shadow', 'persistent']);\n17: \n18: export { DEFAULT_STYLE_DATABASE_PATH };\n19: const DEFAULT_HYDRATION_BYTES = 16 * 1024;\n20: const MAX_HYDRATION_BYTES = 128 * 1024;\n21: const EXACT_REUSE_LICENSES = new Set(['allowed', 'licensed', 'public-domain']);\n22: const HYDRATION_REQUEST_KEYS = new Set([\n23:   'id',\n24:   'generationHash',\n25:   'cardGenerationHash',\n26:   'mode',\n27:   'includes',\n28:   'maxBytes',\n29:   'usage',\n30: ]);\n31: \n32: function digest(buffer) {\n33:   return `sha256:${createHash('sha256').update(buffer).digest('hex')}`;\n34: }\n35: \n36: function isContained(rootPath, candidatePath) {\n37:   const relative = path.relative(rootPath, candidatePath);\n38:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n39: }\n40: \n41: function sliceUtf8(buffer, maxBytes) {\n42:   if (buffer.byteLength <= maxBytes) return buffer.toString('utf8');\n43:   let high = Math.min(buffer.byteLength, maxBytes);\n44:   while (high > 0) {\n45:     const text = buffer.subarray(0, high).toString('utf8');\n46:     if (Buffer.byteLength(text, 'utf8') <= maxBytes) return text;\n47:     high -= 1;\n48:   }\n49:   return '';\n50: }\n51: \n52: function persistentOptions(options) {\n53:   return {\n54:     ...(options.database ? { database: options.database } : {}),\n55:     databasePath: options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n56:   };\n57: }\n58: \n59: function deepFreeze(value, seen = new Set()) {\n60:   if (value === null || typeof value !== 'object' || seen.has(value)) return value;\n61:   seen.add(value);\n62:   for (const child of Object.values(value)) deepFreeze(child, seen);\n63:   return Object.freeze(value);\n64: }\n65: \n66: function snapshotHydrationRequest(request) {\n67:   if (!request || typeof request !== 'object' || Array.isArray(request)) return false;\n68:   const prototype = Object.getPrototypeOf(request);\n69:   if (prototype !== Object.prototype && prototype !== null) return null;\n70:   const keys = Reflect.ownKeys(request);\n71:   if (keys.some((key) => typeof key !== 'string' || !HYDRATION_REQUEST_KEYS.has(key))) {\n72:     return null;\n73:   }\n74:   if (keys.some((key) => {\n75:     const descriptor = Object.getOwnPropertyDescriptor(request, key);\n76:     return descriptor?.enumerable !== true\n77:       || !Object.hasOwn(descriptor, 'value')\n78:       || Object.hasOwn(descriptor, 'get')\n79:       || Object.hasOwn(descriptor, 'set');\n80:   })) return null;\n81:   const isValid = typeof request.id === 'string'\n82:     && request.id.length > 0\n83:     && typeof request.mode === 'string'\n84:     && (request.generationHash === undefined || typeof request.generationHash === 'string')\n85:     && (request.cardGenerationHash === undefined\n86:       || typeof request.cardGenerationHash === 'string')\n87:     && (request.includes === undefined || (\n88:       Array.isArray(request.includes)\n89:       && request.includes.every((item) => typeof item === 'string')\n90:     ))\n91:     && (request.maxBytes === undefined\n92:       || (Number.isInteger(request.maxBytes) && request.maxBytes > 0))\n93:     && (request.usage === undefined || ['reference', 'exact-reuse'].includes(request.usage));\n94:   return isValid ? deepFreeze(structuredClone(request)) : null;\n95: }\n96: \n97: /**\n98:  * Resolve the explicit migration mode while keeping the legacy engine default.\n99:  *\n100:  * @param {Object} [options] - Adapter controls.\n101:  * @returns {'legacy'|'shadow'|'persistent'} Selected backend.\n102:  */\n103: export function resolveStyleDatabaseMode(options = {}) {\n104:   const mode = options.styleDatabaseMode ?? process.env.SK_DESIGN_STYLE_DB_MODE ?? 'legacy';\n105:   if (!STYLE_DATABASE_MODES.includes(mode)) {\n106:     const error = new Error(`Unknown style database mode: ${mode}`);\n107:     error.code = 'invalid-database-mode';\n108:     throw error;\n109:   }\n110:   return mode;\n111: }\n112: \n113: function compareQueryResults(legacy, persistent) {\n114:   const projectCard = (card) => ({\n115:     id: card.id,\n116:     title: card.title,\n117:     thesis: card.thesis,\n118:     capabilities: card.capabilities,\n119:     availableSections: card.availableSections,\n120:     tokenAxes: card.tokenAxes,\n121:     provenance: card.provenance,\n122:     estimatedHydrationBytes: card.estimatedHydrationBytes,\n123:     warnings: card.warnings,\n124:     scoreFields: Object.keys(card.score ?? {}).sort(),\n125:   });\n126:   const legacyCards = legacy.cards?.map(projectCard) ?? [];\n127:   const persistentCards = persistent.cards?.map(projectCard) ?? [];\n128:   const eligibilityMatches = JSON.stringify(legacy.eligibility) === JSON.stringify(\n129:     persistent.eligibility,\n130:   );\n131:   const cardsMatch = JSON.stringify(legacyCards) === JSON.stringify(persistentCards);\n132:   return {\n133:     ok: legacy.ok === persistent.ok && eligibilityMatches && cardsMatch,\n134:     eligibilityMatches,\n135:     cardsMatch,\n136:     legacyCards,\n137:     persistentCards,\n138:     persistentGenerationHash: persistent.generationHash,\n139:     persistentRankingMode: persistent.rankingMode,\n140:     toleratedDifferences: ['generationHash', 'contentHash', 'scoreValues', 'rankingMode'],\n141:   };\n142: }\n143: \n144: /**\n145:  * Route query traffic without allowing normal persistent reads to walk the corpus.\n146:  *\n147:  * @param {Object} request - Existing retrieval request.\n148:  * @param {Object} options - Adapter and database controls.\n149:  * @param {Function} runLegacy - Unchanged flat-file implementation.\n150:  * @returns {Promise<Object>} Existing response shape with optional shadow evidence.\n151:  */\n152: export async function dispatchStyleQuery(request, options, runLegacy) {\n153:   const mode = resolveStyleDatabaseMode(options);\n154:   if (mode === 'legacy') return runLegacy(request, options);\n155:   if (mode === 'persistent') return queryPersistentStyles(request, persistentOptions(options));\n156:   const legacy = await runLegacy(request, options);\n157:   try {\n158:     const persistent = queryPersistentStyles(request, persistentOptions(options));\n159:     return { ...legacy, shadow: compareQueryResults(legacy, persistent) };\n160:   } catch (error) {\n161:     return {\n162:       ...legacy,\n163:       shadow: { ok: false, error: error.code ?? 'internal-error', message: error.message },\n164:     };\n165:   }\n166: }\n167: \n168: /**\n169:  * Hydrate DB-selected artifacts from authoritative flat files under all legacy guards.\n170:  *\n171:  * @param {Object} request - Existing hydration request.\n172:  * @param {Object} options - Corpus and database paths.\n173:  * @returns {Promise<Object>} Existing hydration success or refusal shape.\n174:  */\n175: export async function hydratePersistentStyle(request, options = {}) {\n176:   const requestSnapshot = snapshotHydrationRequest(request);\n177:   if (!requestSnapshot) {\n178:     return { ok: false, error: 'invalid-input' };\n179:   }\n180:   request = requestSnapshot;\n181:   const allowedIncludes = modeIncludes(request.mode);\n182:   if (allowedIncludes.length === 0) return { ok: false, error: 'invalid-mode' };\n183:   const database = options.database ?? openPublishedStyleDatabase(\n184:     options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n185:   );\n186:   const ownsDatabase = !options.database;\n187:   database.exec('BEGIN');\n188:   try {\n189:     let generation;\n190:     try {\n191:       generation = retrievalInternals.validateGeneration(database);\n192:     } catch {\n193:       database.exec('ROLLBACK');\n194:       return { ok: false, error: 'manifest-stale' };\n195:     }\n196:     const requestedGeneration = request.generationHash ?? request.cardGenerationHash;\n197:     if (requestedGeneration !== generation.generation_hash) {\n198:       database.exec('ROLLBACK');\n199:       return { ok: false, error: 'generation-mismatch' };\n200:     }\n201:     const style = database.prepare(`\n202:       SELECT s.style_rowid, s.style_id, s.slug, p.license_status, p.rights_known\n203:       FROM styles s JOIN style_provenance p ON p.style_rowid = s.style_rowid\n204:       WHERE s.style_id = ? AND s.lifecycle_state = 'active'\n205:     `).get(request.id);\n206:     if (!style) {\n207:       database.exec('ROLLBACK');\n208:       return { ok: false, error: 'unavailable' };\n209:     }\n210:     if (request.usage === 'exact-reuse' && (\n211:       Number(style.rights_known) !== 1 || !EXACT_REUSE_LICENSES.has(style.license_status)\n212:     )) {\n213:       database.exec('ROLLBACK');\n214:       return { ok: false, error: 'rights-restricted' };\n215:     }\n216:     const requestedIncludes = Array.isArray(request.includes) && request.includes.length > 0\n217:       ? request.includes.filter((name) => allowedIncludes.includes(name))\n218:       : allowedIncludes;\n219:     const artifacts = database.prepare(`\n220:       SELECT relative_path, byte_length, sha256 FROM style_artifacts\n221:       WHERE style_rowid = ? ORDER BY relative_path ASC\n222:     `).all(style.style_rowid).filter((artifact) => requestedIncludes.some((name) => (\n223:       artifact.relative_path.endsWith(`/${name}`)\n224:     )));\n225:     if (artifacts.length === 0) {\n226:       database.exec('ROLLBACK');\n227:       return { ok: false, error: 'unavailable' };\n228:     }\n229:     const corpusRoot = options.corpusRoot;\n230:     if (!corpusRoot) {\n231:       database.exec('ROLLBACK');\n232:       return { ok: false, error: 'invalid-input' };\n233:     }\n234:     const corpusRealPath = await realpath(corpusRoot);\n235:     const styleRealPath = await realpath(path.join(corpusRoot, style.slug));\n236:     if (!isContained(corpusRealPath, styleRealPath)) {\n237:       database.exec('ROLLBACK');\n238:       return { ok: false, error: 'path-escape' };\n239:     }\n240:     const maxBytes = Math.min(\n241:       MAX_HYDRATION_BYTES,\n242:       Math.max(1, request.maxBytes ?? DEFAULT_HYDRATION_BYTES),\n243:     );\n244:     const loaded = [];\n245:     let totalBytes = 0;\n246:     for (const artifact of artifacts) {\n247:       const candidatePath = path.resolve(corpusRoot, artifact.relative_path);\n248:       const artifactRealPath = await realpath(candidatePath);\n249:       if (!isContained(corpusRealPath, artifactRealPath)\n250:         || !isContained(styleRealPath, artifactRealPath)) {\n251:         database.exec('ROLLBACK');\n252:         return { ok: false, error: 'path-escape' };\n253:       }\n254:       const buffer = await readFile(artifactRealPath);\n255:       if (digest(buffer) !== artifact.sha256) {\n256:         database.exec('ROLLBACK');\n257:         return { ok: false, error: 'unavailable' };\n258:       }\n259:       const remainingBytes = maxBytes - totalBytes;\n260:       if (remainingBytes <= 0) break;\n261:       const content = sliceUtf8(buffer, remainingBytes);\n262:       const outputBytes = Buffer.byteLength(content, 'utf8');\n263:       loaded.push({\n264:         path: artifact.relative_path,\n265:         sha256: artifact.sha256,\n266:         bytes: outputBytes,\n267:         truncated: outputBytes < buffer.byteLength,\n268:         content,\n269:       });\n270:       totalBytes += outputBytes;\n271:     }\n272:     database.exec('COMMIT');\n273:     return {\n274:       ok: true,\n275:       id: style.style_id,\n276:       generationHash: generation.generation_hash,\n277:       mode: request.mode,\n278:       totalBytes,\n279:       artifacts: loaded,\n280:     };\n281:   } catch (error) {\n282:     try {\n283:       database.exec('ROLLBACK');\n284:     } catch {\n285:       // The refusal below remains stable even when SQLite already ended the snapshot.\n286:     }\n287:     if (['ENOENT', 'ENOTDIR'].includes(error.code)) return { ok: false, error: 'unavailable' };\n288:     throw error;\n289:   } finally {\n290:     if (ownsDatabase) database.close();\n291:   }\n292: }\n293: \n294: function compareHydrationResults(legacy, persistent) {\n295:   if (!legacy.ok || !persistent.ok) {\n296:     return {\n297:       ok: legacy.ok === persistent.ok && legacy.error === persistent.error,\n298:       legacyError: legacy.error ?? null,\n299:       persistentError: persistent.error ?? null,\n300:     };\n301:   }\n302:   const legacyProjection = {\n303:     id: legacy.id,\n304:     mode: legacy.mode,\n305:     totalBytes: legacy.totalBytes,\n306:     artifacts: legacy.artifacts,\n307:   };\n308:   const persistentProjection = {\n309:     id: persistent.id,\n310:     mode: persistent.mode,\n311:     totalBytes: persistent.totalBytes,\n312:     artifacts: persistent.artifacts,\n313:   };\n314:   return {\n315:     ok: JSON.stringify(legacyProjection) === JSON.stringify(persistentProjection),\n316:     legacyProjection,\n317:     persistentProjection,\n318:     persistentGenerationHash: persistent.generationHash ?? null,\n319:     toleratedDifferences: ['generationHash'],\n320:   };\n321: }\n322: \n323: /**\n324:  * Route hydration through legacy, shadow, or persistent behavior.\n325:  *\n326:  * @param {Object} request - Existing hydration request.\n327:  * @param {Object} options - Adapter controls.\n328:  * @param {Function} runLegacy - Unchanged flat-file implementation.\n329:  * @returns {Promise<Object>} Existing response shape with optional shadow evidence.\n330:  */\n331: export async function dispatchStyleHydrate(request, options, runLegacy) {\n332:   const mode = resolveStyleDatabaseMode(options);\n333:   if (mode === 'legacy') return runLegacy(request, options);\n334:   if (mode === 'persistent') return hydratePersistentStyle(request, options);\n335:   const legacy = await runLegacy(request, options);\n336:   try {\n337:     const database = options.database ?? openPublishedStyleDatabase(\n338:       options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n339:     );\n340:     const ownsDatabase = !options.database;\n341:     const currentGeneration = database.prepare(`\n342:       SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n343:     `).get()?.generation_hash;\n344:     if (ownsDatabase) database.close();\n345:     const persistent = await hydratePersistentStyle({\n346:       ...request,\n347:       generationHash: currentGeneration,\n348:       cardGenerationHash: undefined,\n349:     }, options);\n350:     return { ...legacy, shadow: compareHydrationResults(legacy, persistent) };\n351:   } catch (error) {\n352:     return {\n353:       ...legacy,\n354:       shadow: { ok: false, error: error.code ?? 'internal-error', message: error.message },\n355:     };\n356:   }\n357: }\n\n(End of file - total 357 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Style Database Migration Adapter                                         ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { createHash } from 'node:crypto';\nimport { readFile, realpath } from 'node:fs/promises';\nimport path from 'node:path';\n\nimport { queryPersistentStyles, retrievalInternals } from '../_db/retrieval.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,\n  openPublishedStyleDatabase,\n} from '../_db/schema.mjs';\nimport { modeIncludes } from './hydrate.mjs';\n\nexport const STYLE_DATABASE_MODES = Object.freeze(['legacy', 'shadow', 'persistent']);\n\nexport { DEFAULT_STYLE_DATABASE_PATH };\nconst DEFAULT_HYDRATION_BYTES = 16 * 1024;\nconst MAX_HYDRATION_BYTES = 128 * 1024;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Style Database Migration Adapter                                         ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { createHash } from 'node:crypto';\nimport { readFile, realpath } from 'node:fs/promises';\nimport path from 'node:path';\n\nimport { queryPersistentStyles, retrievalInternals } from '../_db/retrieval.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,\n  openPublishedStyleDatabase,\n} from '../_db/schema.mjs';\nimport { modeIncludes } from './hydrate.mjs';\n\nexport const STYLE_DATABASE_MODES = Object.freeze(['legacy', 'shadow', 'persistent']);\n\nexport { DEFAULT_STYLE_DATABASE_PATH };\nconst DEFAULT_HYDRATION_BYTES = 16 * 1024;\nconst MAX_HYDRATION_BYTES = 128 * 1024;\nconst EXACT_REUSE_LICENSES = new Set(['allowed', 'licensed', 'public-domain']);\nconst HYDRATION_REQUEST_KEYS = new Set([\n  'id',\n  'generationHash',\n  'cardGenerationHash',\n  'mode',\n  'includes',\n  'maxBytes',\n  'usage',\n]);\n\nfunction digest(buffer) {\n  return `sha256:${createHash('sha256').update(buffer).digest('hex')}`;\n}\n\nfunction isContained(rootPath, candidatePath) {\n  const relative = path.relative(rootPath, candidatePath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction sliceUtf8(buffer, maxBytes) {\n  if (buffer.byteLength <= maxBytes) return buffer.toString('utf8');\n  let high = Math.min(buffer.byteLength, maxBytes);\n  while (high > 0) {\n    const text = buffer.subarray(0, high).toString('utf8');\n    if (Buffer.byteLength(text, 'utf8') <= maxBytes) return text;\n    high -= 1;\n  }\n  return '';\n}\n\nfunction persistentOptions(options) {\n  return {\n    ...(options.database ? { database: options.database } : {}),\n    databasePath: options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n  };\n}\n\nfunction deepFreeze(value, seen = new Set()) {\n  if (value === null || typeof value !== 'object' || seen.has(value)) return value;\n  seen.add(value);\n  for (const child of Object.values(value)) deepFreeze(child, seen);\n  return Object.freeze(value);\n}\n\nfunction snapshotHydrationRequest(request) {\n  if (!request || typeof request !== 'object' || Array.isArray(request)) return false;\n  const prototype = Object.getPrototypeOf(request);\n  if (prototype !== Object.prototype && prototype !== null) return null;\n  const keys = Reflect.ownKeys(request);\n  if (keys.some((key) => typeof key !== 'string' || !HYDRATION_REQUEST_KEYS.has(key))) {\n    return null;\n  }\n  if (keys.some((key) => {\n    const descriptor = Object.getOwnPropertyDescriptor(request, key);\n    return descriptor?.enumerable !== true\n      || !Object.hasOwn(descriptor, 'value')\n      || Object.hasOwn(descriptor, 'get')\n      || Object.hasOwn(descriptor, 'set');\n  })) return null;\n  const isValid = typeof request.id === 'string'\n    && request.id.length > 0\n    && typeof request.mode === 'string'\n    && (request.generationHash === undefined || typeof request.generationHash === 'string')\n    && (request.cardGenerationHash === undefined\n      || typeof request.cardGenerationHash === 'string')\n    && (request.includes === undefined || (\n      Array.isArray(request.includes)\n      && request.includes.every((item) => typeof item === 'string')\n    ))\n    && (request.maxBytes === undefined\n      || (Number.isInteger(request.maxBytes) && request.maxBytes > 0))\n    && (request.usage === undefined || ['reference', 'exact-reuse'].includes(request.usage));\n  return isValid ? deepFreeze(structuredClone(request)) : null;\n}\n\n/**\n * Resolve the explicit migration mode while keeping the legacy engine default.\n *\n * @param {Object} [options] - Adapter controls.\n * @returns {'legacy'|'shadow'|'persistent'} Selected backend.\n */\nexport function resolveStyleDatabaseMode(options = {}) {\n  const mode = options.styleDatabaseMode ?? process.env.SK_DESIGN_STYLE_DB_MODE ?? 'legacy';\n  if (!STYLE_DATABASE_MODES.includes(mode)) {\n    const error = new Error(`Unknown style database mode: ${mode}`);\n    error.code = 'invalid-database-mode';\n    throw error;\n  }\n  return mode;\n}\n\nfunction compareQueryResults(legacy, persistent) {\n  const projectCard = (card) => ({\n    id: card.id,\n    title: card.title,\n    thesis: card.thesis,\n    capabilities: card.capabilities,\n    availableSections: card.availableSections,\n    tokenAxes: card.tokenAxes,\n    provenance: card.provenance,\n    estimatedHydrationBytes: card.estimatedHydrationBytes,\n    warnings: card.warnings,\n    scoreFields: Object.keys(card.score ?? {}).sort(),\n  });\n  const legacyCards = legacy.cards?.map(projectCard) ?? [];\n  const persistentCards = persistent.cards?.map(projectCard) ?? [];\n  const eligibilityMatches = JSON.stringify(legacy.eligibility) === JSON.stringify(\n    persistent.eligibility,\n  );\n  const cardsMatch = JSON.stringify(legacyCards) === JSON.stringify(persistentCards);\n  return {\n    ok: legacy.ok === persistent.ok && eligibilityMatches && cardsMatch,\n    eligibilityMatches,\n    cardsMatch,\n    legacyCards,\n    persistentCards,\n    persistentGenerationHash: persistent.generationHash,\n    persistentRankingMode: persistent.rankingMode,\n    toleratedDifferences: ['generationHash', 'contentHash', 'scoreValues', 'rankingMode'],\n  };\n}\n\n/**\n * Route query traffic without allowing normal persistent reads to walk the corpus.\n *\n * @param {Object} request - Existing retrieval request.\n * @param {Object} options - Adapter and database controls.\n * @param {Function} runLegacy - Unchanged flat-file implementation.\n * @returns {Promise<Object>} Existing response shape with optional shadow evidence.\n */\nexport async function dispatchStyleQuery(request, options, runLegacy) {\n  const mode = resolveStyleDatabaseMode(options);\n  if (mode === 'legacy') return runLegacy(request, options);\n  if (mode === 'persistent') return queryPersistentStyles(request, persistentOptions(options));\n  const legacy = await runLegacy(request, options);\n  try {\n    const persistent = queryPersistentStyles(request, persistentOptions(options));\n    return { ...legacy, shadow: compareQueryResults(legacy, persistent) };\n  } catch (error) {\n    return {\n      ...legacy,\n      shadow: { ok: false, error: error.code ?? 'internal-error', message: error.message },\n    };\n  }\n}\n\n/**\n * Hydrate DB-selected artifacts from authoritative flat files under all legacy guards.\n *\n * @param {Object} request - Existing hydration request.\n * @param {Object} options - Corpus and database paths.\n * @returns {Promise<Object>} Existing hydration success or refusal shape.\n */\nexport async function hydratePersistentStyle(request, options = {}) {\n  const requestSnapshot = snapshotHydrationRequest(request);\n  if (!requestSnapshot) {\n    return { ok: false, error: 'invalid-input' };\n  }\n  request = requestSnapshot;\n  const allowedIncludes = modeIncludes(request.mode);\n  if (allowedIncludes.length === 0) return { ok: false, error: 'invalid-mode' };\n  const database = options.database ?? openPublishedStyleDatabase(\n    options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n  );\n  const ownsDatabase = !options.database;\n  database.exec('BEGIN');\n  try {\n    let generation;\n    try {\n      generation = retrievalInternals.validateGeneration(database);\n    } catch {\n      database.exec('ROLLBACK');\n      return { ok: false, error: 'manifest-stale' };\n    }\n    const requestedGeneration = request.generationHash ?? request.cardGenerationHash;\n    if (requestedGeneration !== generation.generation_hash) {\n      database.exec('ROLLBACK');\n      return { ok: false, error: 'generation-mismatch' };\n    }\n    const style = database.prepare(`\n      SELECT s.style_rowid, s.style_id, s.slug, p.license_status, p.rights_known\n      FROM styles s JOIN style_provenance p ON p.style_rowid = s.style_rowid\n      WHERE s.style_id = ? AND s.lifecycle_state = 'active'\n    `).get(request.id);\n    if (!style) {\n      database.exec('ROLLBACK');\n      return { ok: false, error: 'unavailable' };\n    }\n    if (request.usage === 'exact-reuse' && (\n      Number(style.rights_known) !== 1 || !EXACT_REUSE_LICENSES.has(style.license_status)\n    )) {\n      database.exec('ROLLBACK');\n      return { ok: false, error: 'rights-restricted' };\n    }\n    const requestedIncludes = Array.isArray(request.includes) && request.includes.length > 0\n      ? request.includes.filter((name) => allowedIncludes.includes(name))\n      : allowedIncludes;\n    const artifacts = database.prepare(`\n      SELECT relative_path, byte_length, sha256 FROM style_artifacts\n      WHERE style_rowid = ? ORDER BY relative_path ASC\n    `).all(style.style_rowid).filter((artifact) => requestedIncludes.some((name) => (\n      artifact.relative_path.endsWith(`/${name}`)\n    )));\n    if (artifacts.length === 0) {\n      database.exec('ROLLBACK');\n      return { ok: false, error: 'unavailable' };\n    }\n    const corpusRoot = options.corpusRoot;\n    if (!corpusRoot) {\n      database.exec('ROLLBACK');\n      return { ok: false, error: 'invalid-input' };\n    }\n    const corpusRealPath = await realpath(corpusRoot);\n    const styleRealPath = await realpath(path.join(corpusRoot, style.slug));\n    if (!isContained(corpusRealPath, styleRealPath)) {\n      database.exec('ROLLBACK');\n      return { ok: false, error: 'path-escape' };\n    }\n    const maxBytes = Math.min(\n      MAX_HYDRATION_BYTES,\n      Math.max(1, request.maxBytes ?? DEFAULT_HYDRATION_BYTES),\n    );\n    const loaded = [];\n    let totalBytes = 0;\n    for (const artifact of artifacts) {\n      const candidatePath = path.resolve(corpusRoot, artifact.relative_path);\n      const artifactRealPath = await realpath(candidatePath);\n      if (!isContained(corpusRealPath, artifactRealPath)\n        || !isContained(styleRealPath, artifactRealPath)) {\n        database.exec('ROLLBACK');\n        return { ok: false, error: 'path-escape' };\n      }\n      const buffer = await readFile(artifactRealPath);\n      if (digest(buffer) !== artifact.sha256) {\n        database.exec('ROLLBACK');\n        return { ok: false, error: 'unavailable' };\n      }\n      const remainingBytes = maxBytes - totalBytes;\n      if (remainingBytes <= 0) break;\n      const content = sliceUtf8(buffer, remainingBytes);\n      const outputBytes = Buffer.byteLength(content, 'utf8');\n      loaded.push({\n        path: artifact.relative_path,\n        sha256: artifact.sha256,\n        bytes: outputBytes,\n        truncated: outputBytes < buffer.byteLength,\n        content,\n      });\n      totalBytes += outputBytes;\n    }\n    database.exec('COMMIT');\n    return {\n      ok: true,\n      id: style.style_id,\n      generationHash: generation.generation_hash,\n      mode: request.mode,\n      totalBytes,\n      artifacts: loaded,\n    };\n  } catch (error) {\n    try {\n      database.exec('ROLLBACK');\n    } catch {\n      // The refusal below remains stable even when SQLite already ended the snapshot.\n    }\n    if (['ENOENT', 'ENOTDIR'].includes(error.code)) return { ok: false, error: 'unavailable' };\n    throw error;\n  } finally {\n    if (ownsDatabase) database.close();\n  }\n}\n\nfunction compareHydrationResults(legacy, persistent) {\n  if (!legacy.ok || !persistent.ok) {\n    return {\n      ok: legacy.ok === persistent.ok && legacy.error === persistent.error,\n      legacyError: legacy.error ?? null,\n      persistentError: persistent.error ?? null,\n    };\n  }\n  const legacyProjection = {\n    id: legacy.id,\n    mode: legacy.mode,\n    totalBytes: legacy.totalBytes,\n    artifacts: legacy.artifacts,\n  };\n  const persistentProjection = {\n    id: persistent.id,\n    mode: persistent.mode,\n    totalBytes: persistent.totalBytes,\n    artifacts: persistent.artifacts,\n  };\n  return {\n    ok: JSON.stringify(legacyProjection) === JSON.stringify(persistentProjection),\n    legacyProjection,\n    persistentProjection,\n    persistentGenerationHash: persistent.generationHash ?? null,\n    toleratedDifferences: ['generationHash'],\n  };\n}\n\n/**\n * Route hydration through legacy, shadow, or persistent behavior.\n *\n * @param {Object} request - Existing hydration request.\n * @param {Object} options - Adapter controls.\n * @param {Function} runLegacy - Unchanged flat-file implementation.\n * @returns {Promise<Object>} Existing response shape with optional shadow evidence.\n */\nexport async function dispatchStyleHydrate(request, options, runLegacy) {\n  const mode = resolveStyleDatabaseMode(options);\n  if (mode === 'legacy') return runLegacy(request, options);\n  if (mode === 'persistent') return hydratePersistentStyle(request, options);\n  const legacy = await runLegacy(request, options);\n  try {\n    const database = options.database ?? openPublishedStyleDatabase(\n      options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH,\n    );\n    const ownsDatabase = !options.database;\n    const currentGeneration = database.prepare(`\n      SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n    `).get()?.generation_hash;\n    if (ownsDatabase) database.close();\n    const persistent = await hydratePersistentStyle({\n      ...request,\n      generationHash: currentGeneration,\n      cardGenerationHash: undefined,\n    }, options);\n    return { ...legacy, shadow: compareHydrationResults(legacy, persistent) };\n  } catch (error) {\n    return {\n      ...legacy,\n      shadow: { ok: false, error: error.code ?? 'internal-error', message: error.message },\n    };\n  }\n}","lineStart":1,"lineEnd":357,"totalLines":357,"truncated":false}},"title":".opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs","time":{"start":1784623168703,"end":1784623168713}},"metadata":{"openai":{"itemId":"fc_02bf757ba310bf3e016a5f30403aa881918bbb65a920e8a477"}},"id":"prt_f83d47c84001iqj84lrQRLnkr9","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV"}}
{"type":"tool_use","timestamp":1784623168830,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"read","callID":"call_FiWUZBJuOFKdWHFrLrMBSpz6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/README.md","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/README.md</path>\n<type>file</type>\n<content>\n1: # Style Database\n2: \n3: The style database is a rebuildable SQLite projection of the flat style bundles in the parent\n4: directory. The flat files remain authoritative. Normal persistent reads never walk the corpus.\n5: \n6: ## Generation Model\n7: \n8: `styles.style_id` is the stable UUID identity; `style_rowid` is an internal join key for FTS,\n9: vectors, and normalized children. A successful index run writes source rows, vector jobs, an\n10: immutable `corpus_generations` record, and the singleton `current_corpus_generation` pointer in\n11: one `BEGIN IMMEDIATE` transaction. The on-disk publish pointer (`.current.json`) is a versioned\n12: generation manifest that content-addresses one or more immutable artifacts (`generation-manifest.mjs`);\n13: legacy single-file pointers still resolve. Readers realpath-check the selected file against the\n14: generation directory, bind the pointer's generation hash to the opened database, then validate that\n15: the schema version, active count, and aggregate hash agree. Any mismatch fails closed.\n16: \n17: Artifact freshness uses `style-all-artifacts-v2`: the stable style UUID, sorted artifact roles, and\n18: raw bytes are encoded as unsigned 64-bit length frames before SHA-256. The mutable slug locator is\n19: excluded. Mtime, ctime, and size are retained as hints,\n20: not correctness authorities. Normal incremental runs hash only metadata candidates; maintenance\n21: can set `verifyAll: true` to force canonical re-verification of every bundle. Crawl-record hashes\n22: independently invalidate provenance fallback data. The semantic retrieval hash is separate: it covers stable JSON for\n23: identity, title, thesis, theme, industry, sorted capabilities/facets/token axes/sections, and a\n24: normalized `DESIGN.md`. CSS or source-only changes therefore publish corpus freshness without\n25: invalidating an unchanged semantic embedding.\n26: \n27: ## Indexer Lifecycle\n28: \n29: `indexStyleCorpus()` requires `corpusWalkMode: 'migration'` or `'rollback'` and runs:\n30: \n31: `DISCOVER -> VERIFY -> PARSE_VALIDATE -> COMMIT -> VECTOR_DRAIN -> PUBLISH`\n32: \n33: Discovery is side-effect free. Every changed bundle is fully read, hash-verified, parsed, and\n34: validated before the write lock. The transaction replaces all normalized children, lets FTS5\n35: external-content triggers synchronize, supersedes stale vector jobs, and advances success markers\n36: only with the generation pointer. A thrown error rolls the transaction back. A disappeared style\n37: is quarantined on one scan and tombstoned only after a separate confirming scan (or an explicit\n38: `confirmMissing` maintenance run).\n39: \n40: `buildStyleDatabase()` is the callable full-build entry point. It is never invoked by query or\n41: hydrate. A full build validates and checkpoints a uniquely named immutable generation file, syncs\n42: the file and directory, then atomically replaces a synced `.current.json` pointer. Existing readers\n43: remain bound to the prior generation file; `rollbackStyleDatabase()` durably reverses the pointer.\n44: Vector jobs are keyed by style row, retrieval hash, and profile. `drainVectorQueue()`\n45: uses a content-addressed cache, checks current identity again before publication, and records\n46: bounded failures without blocking FTS or structured retrieval. Each drain also reclaims at most\n47: its batch limit of stale `running` claims after a five-minute lease timeout. A reclaimed claim is\n48: returned to `pending` without consuming a retry. `rebuildVectorProjection()`\n49: invalidates one profile, advances its projection revision, and requeues every active style.\n50: \n51: The current schema version is 2. Opening a version-1 database transactionally adds the crawl-record\n52: freshness marker and creates vector projection revisions before advancing `PRAGMA user_version`.\n53: \n54: ## Retrieval\n55: \n56: `queryPersistentStyles()` applies required facets, exclusions, known provenance, and exact-reuse\n57: rights before any ranking lane receives candidates. Structured, persistent FTS5, and vector lanes\n58: produce independent top-k ranks. `style-rrf-v1` combines only ranks using weighted reciprocal rank\n59: fusion and reports each channel's rank and contribution. It never adds raw BM25, cosine, and\n60: structured scores.\n61: \n62: The degradation ladder is channel-local: `hybrid`, `structured+fts`, `structured+vector`, then\n63: `structured-only`. Cursors bind the corpus generation, request fingerprint, fusion profile,\n64: candidate K, vector projection revision, and final `(fusedScore, id)` key.\n65: Caller-supplied `generationHash` pins are enforced against the opened generation rather than\n66: silently served from current. Query vectors must be arrays of 1-16,384 finite numbers and serialize\n67: to at most 256 KiB; validation occurs before request fingerprinting or database access.\n68: \n69: ## Operator Commands\n70: \n71: `operator.mjs` is the supported persistent maintenance entry point. It emits JSON and exits nonzero\n72: on invalid input or a failed operation:\n73: \n74: ```bash\n75: node .opencode/skills/sk-design/styles/_db/operator.mjs status --database /path/style.sqlite\n76: node .opencode/skills/sk-design/styles/_db/operator.mjs build --corpus /path/styles --database /path/style.sqlite\n77: node .opencode/skills/sk-design/styles/_db/operator.mjs cutover --database /path/style.sqlite --generation /path/retained.sqlite\n78: node .opencode/skills/sk-design/styles/_db/operator.mjs rollback --database /path/style.sqlite\n79: node .opencode/skills/sk-design/styles/_db/operator.mjs repair --database /path/style.sqlite --profile style-default-v1\n80: ```\n81: \n82: `status` reports the published generation, rollback candidate, retained files, and vector-job\n83: counts. `build` stages, validates, and publishes a complete generation. `cutover` points readers at\n84: an explicitly retained generation; `rollback` selects the newest retained non-current generation\n85: unless `--generation` is supplied. `repair` invalidates and requeues one vector profile. After each\n86: build, cutover, or rollback, pruning keeps the current generation and, when available, one rollback\n87: generation; older generation files and SQLite sidecars are removed.\n88: \n89: ## Measurement & Contract Foundation\n90: \n91: The `_db/` tree carries a measurement and parity plane so later work can prove a claim, detect a\n92: regression, and roll back safely. Every piece serializes identity through one shared canonicalizer\n93: (`canonical.mjs`: stable-key JSON plus length-framed SHA-256), so a byte reference can never drift\n94: from what production emits.\n95: \n96: - **Generation manifest** (`generation-manifest.mjs`) — a versioned pointer that content-addresses\n97:   a generation's artifacts (the SQLite projection today, plus optional screenshot features, model\n98:   profiles, and index). Publishing is one atomic pointer flip with fsync durability, so a reader\n99:   sees the whole prior manifest or the whole new one. `pruneManifestGenerations` drops a generation\n100:   as a unit; an artifact shared with a retained manifest is never removed. Digest verification is\n101:   opt-in (`verifyDigests`) so the query hot path is not re-hashed on every open. Currently the real\n102:   build publishes only the `sqlite` artifact; the multi-artifact machinery is proven by the manifest\n103:   test suite and activates as later phases produce the additional artifacts.\n104: \n105: - **Stage telemetry** (`stage-telemetry.mjs`) — a residency-honest recorder threaded (off by\n106:   default) through the indexer lifecycle and the query lanes. Every stage is tagged `native` (work\n107:   inside the node:sqlite / FTS5 boundary) or `js-resident` (JS heap and event-loop work: fs\n108:   orchestration, JSON decode, cosine, sort, RRF, card assembly). There is no blended bucket — an\n109:   unattributed record cannot be created — so native and JS-resident latency sum to the total. The\n110:   vector lane splits its native row fetch from JS-resident `JSON.parse` + cosine + sort. Telemetry\n111:   is a pure side channel: with it on or off, the retrieval DTO is byte-identical.\n112: \n113: - **Differential oracle** (`oracle/differential-oracle.mjs`, `oracle/query-set.mjs`,\n114:   `oracle/golden/`) — freezes the current retrieval/index output for a fixed query matrix as\n115:   canonical golden bytes, then replays byte-for-byte. A deliberate ordering, tie-break, or field\n116:   perturbation fails replay; a missing golden is reported rather than silently passing. No\n117:   TypeScript toolchain is introduced — the oracle ships as pinned JS/ESM golden bytes. Regenerate\n118:   the golden only via `freezeOracle` when an intended output change lands.\n119: \n120: - **Replay fixtures** (`oracle/replay-fixtures.mjs`) — deterministic 1x/10x/100x corpora\n121:   (`REPLAY_SCALES`, base 13 → 13/130/1,300; the 100x scale approximates the real ~1,290-bundle\n122:   corpus and is tunable). Every byte is a pure function of an index-derived seed, so regenerating a\n123:   scale yields identical bytes and the oracle reproduces identical query output. Per-scale corpus\n124:   and oracle hashes are frozen in `oracle/golden/scales.json`.\n125: \n126: - **Relevance judgments** (`oracle/relevance-judgments.mjs`,\n127:   `oracle/relevance-judgments.seed.json`) — a versioned, honestly-labeled seed. `authored-similar`\n128:   rows trace to a style's own `designSystem.similar[]` authorship resolved against the corpus;\n129:   `silver-heuristic` rows are retrieval-derived weak positives where a candidate agrees across at\n130:   least two lanes. Every row carries its `label_source` and provenance. **No row is human gold**,\n131:   and the seed header flags that human relevance labeling is still required for a true judged qrels\n132:   set.\n133: \n134: ## Adapter Modes\n135: \n136: `styles/_engine/style-library.mjs` preserves `runQuery`, `runHydrate`, CLI output, card fields, and\n137: refusal codes behind these modes:\n138: \n139: | Mode | Behavior |\n140: |---|---|\n141: | `legacy` | Default. Runs the unchanged manifest and flat-file engine. |\n142: | `shadow` | Returns the legacy result and attaches bounded persistent parity evidence. Corpus walking is explicit because this is a migration mode. |\n143: | `persistent` | Reads only the published database for selection; hydration reads only selected, DB-hash-verified authoritative artifacts. |\n144: \n145: Select a mode with `options.styleDatabaseMode`, CLI `--backend`, or\n146: `SK_DESIGN_STYLE_DB_MODE`. The default is always `legacy`. Supply `options.databasePath`, CLI\n147: `--database`, or use `_db/style-library.sqlite`.\n\n(End of file - total 147 lines)\n</content>","metadata":{"preview":"# Style Database\n\nThe style database is a rebuildable SQLite projection of the flat style bundles in the parent\ndirectory. The flat files remain authoritative. Normal persistent reads never walk the corpus.\n\n## Generation Model\n\n`styles.style_id` is the stable UUID identity; `style_rowid` is an internal join key for FTS,\nvectors, and normalized children. A successful index run writes source rows, vector jobs, an\nimmutable `corpus_generations` record, and the singleton `current_corpus_generation` pointer in\none `BEGIN IMMEDIATE` transaction. The on-disk publish pointer (`.current.json`) is a versioned\ngeneration manifest that content-addresses one or more immutable artifacts (`generation-manifest.mjs`);\nlegacy single-file pointers still resolve. Readers realpath-check the selected file against the\ngeneration directory, bind the pointer's generation hash to the opened database, then validate that\nthe schema version, active count, and aggregate hash agree. Any mismatch fails closed.\n\nArtifact freshness uses `style-all-artifacts-v2`: the stable style UUID, sorted artifact roles, and\nraw bytes are encoded as unsigned 64-bit length frames before SHA-256. The mutable slug locator is\nexcluded. Mtime, ctime, and size are retained as hints,\nnot correctness authorities. Normal incremental runs hash only metadata candidates; maintenance","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/README.md","text":"# Style Database\n\nThe style database is a rebuildable SQLite projection of the flat style bundles in the parent\ndirectory. The flat files remain authoritative. Normal persistent reads never walk the corpus.\n\n## Generation Model\n\n`styles.style_id` is the stable UUID identity; `style_rowid` is an internal join key for FTS,\nvectors, and normalized children. A successful index run writes source rows, vector jobs, an\nimmutable `corpus_generations` record, and the singleton `current_corpus_generation` pointer in\none `BEGIN IMMEDIATE` transaction. The on-disk publish pointer (`.current.json`) is a versioned\ngeneration manifest that content-addresses one or more immutable artifacts (`generation-manifest.mjs`);\nlegacy single-file pointers still resolve. Readers realpath-check the selected file against the\ngeneration directory, bind the pointer's generation hash to the opened database, then validate that\nthe schema version, active count, and aggregate hash agree. Any mismatch fails closed.\n\nArtifact freshness uses `style-all-artifacts-v2`: the stable style UUID, sorted artifact roles, and\nraw bytes are encoded as unsigned 64-bit length frames before SHA-256. The mutable slug locator is\nexcluded. Mtime, ctime, and size are retained as hints,\nnot correctness authorities. Normal incremental runs hash only metadata candidates; maintenance\ncan set `verifyAll: true` to force canonical re-verification of every bundle. Crawl-record hashes\nindependently invalidate provenance fallback data. The semantic retrieval hash is separate: it covers stable JSON for\nidentity, title, thesis, theme, industry, sorted capabilities/facets/token axes/sections, and a\nnormalized `DESIGN.md`. CSS or source-only changes therefore publish corpus freshness without\ninvalidating an unchanged semantic embedding.\n\n## Indexer Lifecycle\n\n`indexStyleCorpus()` requires `corpusWalkMode: 'migration'` or `'rollback'` and runs:\n\n`DISCOVER -> VERIFY -> PARSE_VALIDATE -> COMMIT -> VECTOR_DRAIN -> PUBLISH`\n\nDiscovery is side-effect free. Every changed bundle is fully read, hash-verified, parsed, and\nvalidated before the write lock. The transaction replaces all normalized children, lets FTS5\nexternal-content triggers synchronize, supersedes stale vector jobs, and advances success markers\nonly with the generation pointer. A thrown error rolls the transaction back. A disappeared style\nis quarantined on one scan and tombstoned only after a separate confirming scan (or an explicit\n`confirmMissing` maintenance run).\n\n`buildStyleDatabase()` is the callable full-build entry point. It is never invoked by query or\nhydrate. A full build validates and checkpoints a uniquely named immutable generation file, syncs\nthe file and directory, then atomically replaces a synced `.current.json` pointer. Existing readers\nremain bound to the prior generation file; `rollbackStyleDatabase()` durably reverses the pointer.\nVector jobs are keyed by style row, retrieval hash, and profile. `drainVectorQueue()`\nuses a content-addressed cache, checks current identity again before publication, and records\nbounded failures without blocking FTS or structured retrieval. Each drain also reclaims at most\nits batch limit of stale `running` claims after a five-minute lease timeout. A reclaimed claim is\nreturned to `pending` without consuming a retry. `rebuildVectorProjection()`\ninvalidates one profile, advances its projection revision, and requeues every active style.\n\nThe current schema version is 2. Opening a version-1 database transactionally adds the crawl-record\nfreshness marker and creates vector projection revisions before advancing `PRAGMA user_version`.\n\n## Retrieval\n\n`queryPersistentStyles()` applies required facets, exclusions, known provenance, and exact-reuse\nrights before any ranking lane receives candidates. Structured, persistent FTS5, and vector lanes\nproduce independent top-k ranks. `style-rrf-v1` combines only ranks using weighted reciprocal rank\nfusion and reports each channel's rank and contribution. It never adds raw BM25, cosine, and\nstructured scores.\n\nThe degradation ladder is channel-local: `hybrid`, `structured+fts`, `structured+vector`, then\n`structured-only`. Cursors bind the corpus generation, request fingerprint, fusion profile,\ncandidate K, vector projection revision, and final `(fusedScore, id)` key.\nCaller-supplied `generationHash` pins are enforced against the opened generation rather than\nsilently served from current. Query vectors must be arrays of 1-16,384 finite numbers and serialize\nto at most 256 KiB; validation occurs before request fingerprinting or database access.\n\n## Operator Commands\n\n`operator.mjs` is the supported persistent maintenance entry point. It emits JSON and exits nonzero\non invalid input or a failed operation:\n\n```bash\nnode .opencode/skills/sk-design/styles/_db/operator.mjs status --database /path/style.sqlite\nnode .opencode/skills/sk-design/styles/_db/operator.mjs build --corpus /path/styles --database /path/style.sqlite\nnode .opencode/skills/sk-design/styles/_db/operator.mjs cutover --database /path/style.sqlite --generation /path/retained.sqlite\nnode .opencode/skills/sk-design/styles/_db/operator.mjs rollback --database /path/style.sqlite\nnode .opencode/skills/sk-design/styles/_db/operator.mjs repair --database /path/style.sqlite --profile style-default-v1\n```\n\n`status` reports the published generation, rollback candidate, retained files, and vector-job\ncounts. `build` stages, validates, and publishes a complete generation. `cutover` points readers at\nan explicitly retained generation; `rollback` selects the newest retained non-current generation\nunless `--generation` is supplied. `repair` invalidates and requeues one vector profile. After each\nbuild, cutover, or rollback, pruning keeps the current generation and, when available, one rollback\ngeneration; older generation files and SQLite sidecars are removed.\n\n## Measurement & Contract Foundation\n\nThe `_db/` tree carries a measurement and parity plane so later work can prove a claim, detect a\nregression, and roll back safely. Every piece serializes identity through one shared canonicalizer\n(`canonical.mjs`: stable-key JSON plus length-framed SHA-256), so a byte reference can never drift\nfrom what production emits.\n\n- **Generation manifest** (`generation-manifest.mjs`) — a versioned pointer that content-addresses\n  a generation's artifacts (the SQLite projection today, plus optional screenshot features, model\n  profiles, and index). Publishing is one atomic pointer flip with fsync durability, so a reader\n  sees the whole prior manifest or the whole new one. `pruneManifestGenerations` drops a generation\n  as a unit; an artifact shared with a retained manifest is never removed. Digest verification is\n  opt-in (`verifyDigests`) so the query hot path is not re-hashed on every open. Currently the real\n  build publishes only the `sqlite` artifact; the multi-artifact machinery is proven by the manifest\n  test suite and activates as later phases produce the additional artifacts.\n\n- **Stage telemetry** (`stage-telemetry.mjs`) — a residency-honest recorder threaded (off by\n  default) through the indexer lifecycle and the query lanes. Every stage is tagged `native` (work\n  inside the node:sqlite / FTS5 boundary) or `js-resident` (JS heap and event-loop work: fs\n  orchestration, JSON decode, cosine, sort, RRF, card assembly). There is no blended bucket — an\n  unattributed record cannot be created — so native and JS-resident latency sum to the total. The\n  vector lane splits its native row fetch from JS-resident `JSON.parse` + cosine + sort. Telemetry\n  is a pure side channel: with it on or off, the retrieval DTO is byte-identical.\n\n- **Differential oracle** (`oracle/differential-oracle.mjs`, `oracle/query-set.mjs`,\n  `oracle/golden/`) — freezes the current retrieval/index output for a fixed query matrix as\n  canonical golden bytes, then replays byte-for-byte. A deliberate ordering, tie-break, or field\n  perturbation fails replay; a missing golden is reported rather than silently passing. No\n  TypeScript toolchain is introduced — the oracle ships as pinned JS/ESM golden bytes. Regenerate\n  the golden only via `freezeOracle` when an intended output change lands.\n\n- **Replay fixtures** (`oracle/replay-fixtures.mjs`) — deterministic 1x/10x/100x corpora\n  (`REPLAY_SCALES`, base 13 → 13/130/1,300; the 100x scale approximates the real ~1,290-bundle\n  corpus and is tunable). Every byte is a pure function of an index-derived seed, so regenerating a\n  scale yields identical bytes and the oracle reproduces identical query output. Per-scale corpus\n  and oracle hashes are frozen in `oracle/golden/scales.json`.\n\n- **Relevance judgments** (`oracle/relevance-judgments.mjs`,\n  `oracle/relevance-judgments.seed.json`) — a versioned, honestly-labeled seed. `authored-similar`\n  rows trace to a style's own `designSystem.similar[]` authorship resolved against the corpus;\n  `silver-heuristic` rows are retrieval-derived weak positives where a candidate agrees across at\n  least two lanes. Every row carries its `label_source` and provenance. **No row is human gold**,\n  and the seed header flags that human relevance labeling is still required for a true judged qrels\n  set.\n\n## Adapter Modes\n\n`styles/_engine/style-library.mjs` preserves `runQuery`, `runHydrate`, CLI output, card fields, and\nrefusal codes behind these modes:\n\n| Mode | Behavior |\n|---|---|\n| `legacy` | Default. Runs the unchanged manifest and flat-file engine. |\n| `shadow` | Returns the legacy result and attaches bounded persistent parity evidence. Corpus walking is explicit because this is a migration mode. |\n| `persistent` | Reads only the published database for selection; hydration reads only selected, DB-hash-verified authoritative artifacts. |\n\nSelect a mode with `options.styleDatabaseMode`, CLI `--backend`, or\n`SK_DESIGN_STYLE_DB_MODE`. The default is always `legacy`. Supply `options.databasePath`, CLI\n`--database`, or use `_db/style-library.sqlite`.","lineStart":1,"lineEnd":147,"totalLines":147,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/README.md","time":{"start":1784623168823,"end":1784623168828}},"metadata":{"openai":{"itemId":"fc_02bf757ba310bf3e016a5f30403ab08191b8a275d8db15d56a"}},"id":"prt_f83d47d07001qeEVlWJ7TDoJmA","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV"}}
{"type":"tool_use","timestamp":1784623168888,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"read","callID":"call_pJY5FPn0WJJcDHhl24kxGeru","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/indexer.mjs","offset":1,"limit":480},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/indexer.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Incremental Style Database Indexer                                       ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import {\n6:   lstat,\n7:   open,\n8:   readFile,\n9:   readdir,\n10:   realpath,\n11:   rename,\n12:   rm,\n13:   stat,\n14: } from 'node:fs/promises';\n15: import path from 'node:path';\n16: \n17: import {\n18:   compareRawStrings,\n19:   digest,\n20:   lengthFrame,\n21:   stableJson,\n22: } from './canonical.mjs';\n23: import {\n24:   buildManifest,\n25:   hashArtifactFile,\n26:   writeManifestPointer,\n27: } from './generation-manifest.mjs';\n28: import {\n29:   RESIDENCY,\n30: } from './stage-telemetry.mjs';\n31: import {\n32:   DEFAULT_STYLE_DATABASE_PATH,\n33:   STYLE_DB_SCHEMA_VERSION,\n34:   STYLE_DATABASE_POINTER_SUFFIX,\n35:   openStyleDatabase,\n36: } from './schema.mjs';\n37: \n38: export const INDEXER_LIFECYCLE = Object.freeze([\n39:   'DISCOVER',\n40:   'VERIFY',\n41:   'PARSE_VALIDATE',\n42:   'COMMIT',\n43:   'VECTOR_DRAIN',\n44:   'PUBLISH',\n45: ]);\n46: export const DEFAULT_EMBEDDING_PROFILE = 'style-default-v1';\n47: \n48: const AGGREGATE_HASH_VERSION = 'style-all-artifacts-v2';\n49: const RETRIEVAL_HASH_VERSION = 'style-retrieval-document-v1';\n50: const GENERATION_HASH_VERSION = 'style-corpus-generation-v2';\n51: const LICENSE_ALLOWLIST = new Set(['allowed', 'licensed', 'public-domain']);\n52: const RESTRICTED_LICENSE_PATTERN = /\\b(unlicensed trial|license[- ]restricted)\\b/i;\n53: const WARM_SURFACE_PATTERN = /\\b(warm|cream|beige|bone|ivory|linen|sand|tan)\\b/i;\n54: const MOTION_PATTERN = /\\b(motion|animation|animated|transition|kinetic|scroll)\\b/i;\n55: const SERIF_PATTERN = /(^|[^a-z])serif([^a-z]|$)/i;\n56: const SANS_SERIF_PATTERN = /sans[- ]serif/i;\n57: \n58: function nowIso() {\n59:   return new Date().toISOString();\n60: }\n61: \n62: function normalizeTerm(value) {\n63:   return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n64: }\n65: \n66: function normalizeMarkdown(value) {\n67:   return String(value ?? '').normalize('NFC').replace(/\\r\\n?/g, '\\n')\n68:     .split('\\n').map((line) => line.trimEnd()).join('\\n').trimEnd();\n69: }\n70: \n71: function artifactRole(fileName) {\n72:   if (fileName.endsWith('-canonical.json')) return 'canonical';\n73:   if (fileName === 'design-tokens.json') return 'tokens';\n74:   if (fileName === 'DESIGN.md') return 'design';\n75:   if (fileName === 'source.md') return 'source';\n76:   if (fileName === 'css-variables.css') return 'css-variables';\n77:   if (fileName === 'tailwind-v4.css') return 'tailwind';\n78:   return null;\n79: }\n80: \n81: function isContained(rootPath, candidatePath) {\n82:   const relative = path.relative(rootPath, candidatePath);\n83:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n84: }\n85: \n86: function parseJson(artifact, label) {\n87:   if (!artifact) return {};\n88:   try {\n89:     return JSON.parse(artifact.buffer.toString('utf8'));\n90:   } catch (error) {\n91:     const invalid = new Error(`Invalid ${label} JSON: ${artifact.relativePath}`, { cause: error });\n92:     invalid.code = 'invalid-artifact';\n93:     throw invalid;\n94:   }\n95: }\n96: \n97: function countTokenLeaves(value) {\n98:   if (!value || typeof value !== 'object') return 0;\n99:   if (Object.hasOwn(value, '$value')) return 1;\n100:   return Object.values(value).reduce((sum, child) => sum + countTokenLeaves(child), 0);\n101: }\n102: \n103: function deriveTokenAxes(tokens, designSystem) {\n104:   const counts = new Map();\n105:   for (const [axis, value] of Object.entries(tokens ?? {})) {\n106:     const count = countTokenLeaves(value);\n107:     if (count > 0) counts.set(axis, count);\n108:   }\n109:   const fallbackCounts = {\n110:     color: Array.isArray(designSystem.colors) ? designSystem.colors.length : 0,\n111:     spacing: designSystem.spacing ? Object.keys(designSystem.spacing).length : 0,\n112:     typography: Array.isArray(designSystem.typography) ? designSystem.typography.length : 0,\n113:   };\n114:   for (const [axis, count] of Object.entries(fallbackCounts)) {\n115:     if (count > 0 && !counts.has(axis)) counts.set(axis, count);\n116:   }\n117:   return [...counts].map(([axis, count]) => ({ axis, count }))\n118:     .sort((left, right) => compareRawStrings(left.axis, right.axis));\n119: }\n120: \n121: function deriveSections(designMarkdown) {\n122:   const sections = [];\n123:   for (const [index, line] of designMarkdown.split('\\n').entries()) {\n124:     const match = /^##\\s+(.+?)\\s*$/.exec(line);\n125:     if (match) sections.push({ name: match[1], line: index + 1 });\n126:   }\n127:   return sections;\n128: }\n129: \n130: function deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus) {\n131:   const values = new Set();\n132:   if (tokenAxes.length > 0) values.add('tokens');\n133:   if ((designSystem.components?.length ?? 0) > 0) values.add('components');\n134:   if (designSystem.layout) values.add('layout');\n135:   if (designSystem.imagery) values.add('imagery');\n136:   if (designSystem.spacing) values.add('spacing');\n137:   if ((designSystem.dos?.length ?? 0) + (designSystem.donts?.length ?? 0) > 0) {\n138:     values.add('constraints');\n139:   }\n140:   if (provenanceStatus === 'known') values.add('provenance');\n141:   if (sections.some((section) => MOTION_PATTERN.test(section.name))) values.add('motion');\n142:   return [...values].sort(compareRawStrings);\n143: }\n144: \n145: function deriveFacets(style, designSystem, capabilities, tokenAxes, searchableText, licenseStatus) {\n146:   const values = new Set(capabilities);\n147:   for (const { axis } of tokenAxes) values.add(axis);\n148:   if (designSystem.theme) values.add(normalizeTerm(designSystem.theme));\n149:   if (designSystem.industry) values.add(normalizeTerm(designSystem.industry));\n150:   if (SERIF_PATTERN.test(searchableText) && !SANS_SERIF_PATTERN.test(searchableText)) {\n151:     values.add('serif-role');\n152:   }\n153:   if (WARM_SURFACE_PATTERN.test(searchableText)) values.add('warm-surface');\n154:   if (MOTION_PATTERN.test(searchableText)) values.add('motion');\n155:   if (licenseStatus === 'restricted') values.add('license-restricted');\n156:   values.add(normalizeTerm(style.slug));\n157:   return [...values].filter(Boolean).sort(compareRawStrings);\n158: }\n159: \n160: function excerpt(value, maxLength = 240) {\n161:   const normalized = String(value ?? '').replace(/\\s+/g, ' ').trim();\n162:   if (normalized.length <= maxLength) return normalized;\n163:   return `${normalized.slice(0, maxLength - 1).trimEnd()}…`;\n164: }\n165: \n166: function computeAggregateHash(styleId, artifacts) {\n167:   const parts = [\n168:     ...lengthFrame(AGGREGATE_HASH_VERSION),\n169:     ...lengthFrame(styleId),\n170:   ];\n171:   for (const artifact of artifacts.slice()\n172:     .sort((left, right) => compareRawStrings(left.role, right.role))) {\n173:     parts.push(...lengthFrame(artifact.role), ...lengthFrame(artifact.buffer));\n174:   }\n175:   return digest(parts);\n176: }\n177: \n178: function computeHintHash(artifacts) {\n179:   return digest([\n180:     'style-artifact-hints-v1\\0',\n181:     ...artifacts.map((artifact) => (\n182:       `${artifact.relativePath}\\0${artifact.byteLength}\\0${artifact.mtimeNs}\\0${artifact.ctimeNs}\\n`\n183:     )),\n184:   ]);\n185: }\n186: \n187: function computeCrawlRecordHash(crawlRecord) {\n188:   return digest([\n189:     'style-crawl-record-v1\\0',\n190:     stableJson(crawlRecord ?? null),\n191:   ]);\n192: }\n193: \n194: function computeGenerationHash(crawlManifestHash, styles, inactiveStates = []) {\n195:   const parts = [\n196:     ...lengthFrame(GENERATION_HASH_VERSION),\n197:     ...lengthFrame(STYLE_DB_SCHEMA_VERSION),\n198:     ...lengthFrame(crawlManifestHash),\n199:   ];\n200:   for (const style of styles.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n201:     parts.push(...lengthFrame(style.id), ...lengthFrame(style.aggregateHash));\n202:   }\n203:   for (const style of inactiveStates.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n204:     parts.push(...lengthFrame(style.id), ...lengthFrame(style.state));\n205:   }\n206:   return digest(parts);\n207: }\n208: \n209: async function readVerifiedArtifacts(corpusRoot, corpusRealPath, slug) {\n210:   const styleRoot = path.join(corpusRoot, slug);\n211:   const entries = (await readdir(styleRoot, { withFileTypes: true }))\n212:     .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n213:     .sort((left, right) => compareRawStrings(left.name, right.name));\n214:   const artifacts = [];\n215:   for (const entry of entries) {\n216:     const role = artifactRole(entry.name);\n217:     if (!role) {\n218:       const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n219:       error.code = 'invalid-artifact';\n220:       throw error;\n221:     }\n222:     const candidatePath = path.join(styleRoot, entry.name);\n223:     const linkInfo = await lstat(candidatePath, { bigint: true });\n224:     if (!linkInfo.isFile() && !linkInfo.isSymbolicLink()) continue;\n225:     const artifactRealPath = await realpath(candidatePath);\n226:     if (!isContained(corpusRealPath, artifactRealPath)) {\n227:       const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n228:       error.code = 'path-escape';\n229:       throw error;\n230:     }\n231:     const before = await stat(artifactRealPath, { bigint: true });\n232:     const buffer = await readFile(artifactRealPath);\n233:     const after = await stat(artifactRealPath, { bigint: true });\n234:     if (before.size !== after.size || before.mtimeNs !== after.mtimeNs || before.ctimeNs !== after.ctimeNs) {\n235:       const error = new Error(`Corpus changed while reading ${slug}/${entry.name}.`);\n236:       error.code = 'corpus-changing';\n237:       throw error;\n238:     }\n239:     artifacts.push({\n240:       role,\n241:       relativePath: `${slug}/${entry.name}`,\n242:       byteLength: buffer.byteLength,\n243:       sha256: digest([buffer]),\n244:       mtimeNs: String(after.mtimeNs),\n245:       ctimeNs: String(after.ctimeNs),\n246:       buffer,\n247:     });\n248:   }\n249:   if (!artifacts.some((artifact) => artifact.role === 'canonical')\n250:     || !artifacts.some((artifact) => artifact.role === 'design')) {\n251:     const error = new Error(`Style ${slug} lacks its canonical JSON or DESIGN.md artifact.`);\n252:     error.code = 'invalid-artifact';\n253:     throw error;\n254:   }\n255:   return artifacts;\n256: }\n257: \n258: async function readArtifactHints(corpusRoot, corpusRealPath, slug) {\n259:   const styleRoot = path.join(corpusRoot, slug);\n260:   const entries = (await readdir(styleRoot, { withFileTypes: true }))\n261:     .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n262:     .sort((left, right) => compareRawStrings(left.name, right.name));\n263:   const artifacts = [];\n264:   for (const entry of entries) {\n265:     const role = artifactRole(entry.name);\n266:     if (!role) {\n267:       const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n268:       error.code = 'invalid-artifact';\n269:       throw error;\n270:     }\n271:     const candidatePath = path.join(styleRoot, entry.name);\n272:     const artifactRealPath = await realpath(candidatePath);\n273:     if (!isContained(corpusRealPath, artifactRealPath)) {\n274:       const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n275:       error.code = 'path-escape';\n276:       throw error;\n277:     }\n278:     const fileInfo = await stat(artifactRealPath, { bigint: true });\n279:     artifacts.push({\n280:       role,\n281:       relativePath: `${slug}/${entry.name}`,\n282:       byteLength: Number(fileInfo.size),\n283:       mtimeNs: String(fileInfo.mtimeNs),\n284:       ctimeNs: String(fileInfo.ctimeNs),\n285:     });\n286:   }\n287:   return artifacts;\n288: }\n289: \n290: function parseStyle(slug, crawlRecord, artifacts) {\n291:   const canonical = parseJson(artifacts.find((artifact) => artifact.role === 'canonical'), 'canonical');\n292:   const tokens = parseJson(artifacts.find((artifact) => artifact.role === 'tokens'), 'token');\n293:   const designMarkdown = normalizeMarkdown(\n294:     artifacts.find((artifact) => artifact.role === 'design')?.buffer.toString('utf8'),\n295:   );\n296:   const designSystem = canonical.designSystem ?? {};\n297:   const id = canonical.uuid ?? crawlRecord?.uuid;\n298:   if (typeof id !== 'string' || id.length === 0) {\n299:     const error = new Error(`Style ${slug} has no stable UUID.`);\n300:     error.code = 'invalid-artifact';\n301:     throw error;\n302:   }\n303:   const title = excerpt(canonical.name ?? slug, 120);\n304:   const thesis = excerpt(canonical.northStar ?? designSystem.northStar ?? designSystem.description);\n305:   const theme = designSystem.theme == null ? null : String(designSystem.theme);\n306:   const industry = designSystem.industry == null ? null : String(designSystem.industry);\n307:   const sections = deriveSections(designMarkdown);\n308:   const tokenAxes = deriveTokenAxes(tokens, designSystem);\n309:   const provenanceStatus = canonical.source && canonical.uuid && canonical.meta?.url\n310:     ? 'known'\n311:     : 'missing';\n312:   const searchableText = [\n313:     title,\n314:     thesis,\n315:     designSystem.description,\n316:     theme,\n317:     industry,\n318:     designSystem.layout,\n319:     designSystem.imagery,\n320:     ...(Array.isArray(designSystem.typography)\n321:       ? designSystem.typography.map((entry) => `${entry.family ?? ''} ${entry.role ?? ''}`)\n322:       : []),\n323:     designMarkdown.slice(0, 65_536),\n324:   ].join(' ');\n325:   const licenseStatus = RESTRICTED_LICENSE_PATTERN.test(searchableText)\n326:     ? 'restricted'\n327:     : String(canonical.license?.status ?? 'unknown');\n328:   const rightsKnown = LICENSE_ALLOWLIST.has(licenseStatus) || licenseStatus === 'restricted';\n329:   const capabilities = deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus);\n330:   const facets = deriveFacets(\n331:     { slug },\n332:     designSystem,\n333:     capabilities,\n334:     tokenAxes,\n335:     searchableText,\n336:     licenseStatus,\n337:   );\n338:   const retrievalDocument = {\n339:     id,\n340:     title,\n341:     thesis,\n342:     theme,\n343:     industry,\n344:     capabilities,\n345:     facets,\n346:     tokenAxes,\n347:     sections: sections.map((section) => section.name),\n348:     designMarkdown,\n349:   };\n350:   const retrievalJson = stableJson(retrievalDocument);\n351:   const retrievalHash = digest([\n352:     ...lengthFrame(RETRIEVAL_HASH_VERSION),\n353:     ...lengthFrame(retrievalJson),\n354:   ]);\n355:   const aggregateHash = computeAggregateHash(id, artifacts);\n356:   return {\n357:     id,\n358:     slug,\n359:     crawlStatus: crawlRecord?.status ?? 'unknown',\n360:     title,\n361:     thesis,\n362:     theme,\n363:     industry,\n364:     aggregateHash,\n365:     artifactHintHash: computeHintHash(artifacts),\n366:     crawlRecordHash: computeCrawlRecordHash(crawlRecord),\n367:     retrievalHash,\n368:     artifacts,\n369:     tokenAxes,\n370:     sections,\n371:     capabilities,\n372:     facets,\n373:     provenance: {\n374:       status: provenanceStatus,\n375:       sourceUrl: canonical.source ?? crawlRecord?.url ?? null,\n376:       originalUrl: canonical.meta?.url ?? null,\n377:       screenshotUrl: canonical.screenshot?.url ?? null,\n378:       uuid: canonical.uuid ?? crawlRecord?.uuid ?? null,\n379:       capturedAt: canonical.capturedAt ?? crawlRecord?.capturedAt ?? null,\n380:       licenseStatus,\n381:       rightsKnown,\n382:       evidenceScope: ['reference', 'rationale'],\n383:     },\n384:     relationships: (Array.isArray(designSystem.similar) ? designSystem.similar : [])\n385:       .map((relationship, ordinal) => ({\n386:         ordinal,\n387:         rawTargetLabel: String(relationship.business ?? relationship.name ?? '').trim(),\n388:         rationale: String(relationship.why ?? relationship.rationale ?? '').trim(),\n389:       })).filter((relationship) => relationship.rawTargetLabel),\n390:     retrievalDocument: {\n391:       title,\n392:       thesis,\n393:       theme: theme ?? '',\n394:       industry: industry ?? '',\n395:       terms: [...new Set([...facets, ...capabilities, ...tokenAxes.map(({ axis }) => axis)])]\n396:         .sort(compareRawStrings).join(' '),\n397:       body: designMarkdown,\n398:       documentJson: retrievalJson,\n399:       retrievalHash,\n400:     },\n401:   };\n402: }\n403: \n404: function replaceStyleChildren(database, styleRowid, style, timestamp) {\n405:   for (const table of [\n406:     'style_provenance',\n407:     'style_artifacts',\n408:     'style_terms',\n409:     'style_token_axes',\n410:     'style_sections',\n411:     'retrieval_documents',\n412:     'style_relationships',\n413:   ]) {\n414:     const key = table === 'style_relationships' ? 'source_style_rowid' : 'style_rowid';\n415:     database.prepare(`DELETE FROM ${table} WHERE ${key} = ?`).run(styleRowid);\n416:   }\n417:   database.prepare(`\n418:     INSERT INTO style_provenance(\n419:       style_rowid, status, source_url, original_url, screenshot_url, source_uuid,\n420:       captured_at, license_status, rights_known, evidence_scope_json\n421:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n422:   `).run(\n423:     styleRowid,\n424:     style.provenance.status,\n425:     style.provenance.sourceUrl,\n426:     style.provenance.originalUrl,\n427:     style.provenance.screenshotUrl,\n428:     style.provenance.uuid,\n429:     style.provenance.capturedAt,\n430:     style.provenance.licenseStatus,\n431:     style.provenance.rightsKnown ? 1 : 0,\n432:     JSON.stringify(style.provenance.evidenceScope),\n433:   );\n434:   const insertArtifact = database.prepare(`\n435:     INSERT INTO style_artifacts(\n436:       style_rowid, role, relative_path, byte_length, sha256, mtime_ns, ctime_ns\n437:     ) VALUES (?, ?, ?, ?, ?, ?, ?)\n438:   `);\n439:   for (const artifact of style.artifacts) {\n440:     insertArtifact.run(\n441:       styleRowid,\n442:       artifact.role,\n443:       artifact.relativePath,\n444:       artifact.byteLength,\n445:       artifact.sha256,\n446:       artifact.mtimeNs,\n447:       artifact.ctimeNs,\n448:     );\n449:   }\n450:   const insertTerm = database.prepare(\n451:     'INSERT INTO style_terms(style_rowid, term_type, term) VALUES (?, ?, ?)',\n452:   );\n453:   for (const term of style.facets) insertTerm.run(styleRowid, 'facet', term);\n454:   for (const term of style.capabilities) insertTerm.run(styleRowid, 'capability', term);\n455:   const insertAxis = database.prepare(\n456:     'INSERT INTO style_token_axes(style_rowid, axis, token_count) VALUES (?, ?, ?)',\n457:   );\n458:   for (const axis of style.tokenAxes) insertAxis.run(styleRowid, axis.axis, axis.count);\n459:   const insertSection = database.prepare(`\n460:     INSERT INTO style_sections(style_rowid, ordinal, name, line_number) VALUES (?, ?, ?, ?)\n461:   `);\n462:   for (const [ordinal, section] of style.sections.entries()) {\n463:     insertSection.run(styleRowid, ordinal, section.name, section.line);\n464:   }\n465:   const document = style.retrievalDocument;\n466:   database.prepare(`\n467:     INSERT INTO retrieval_documents(\n468:       style_rowid, title, thesis, theme, industry, terms, body, document_json, retrieval_hash\n469:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n470:   `).run(\n471:     styleRowid,\n472:     document.title,\n473:     document.thesis,\n474:     document.theme,\n475:     document.industry,\n476:     document.terms,\n477:     document.body,\n478:     document.documentJson,\n479:     document.retrievalHash,\n480:   );\n\n(Showing lines 1-480 of 1187. Use offset=481 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Incremental Style Database Indexer                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport {\n  lstat,\n  open,\n  readFile,\n  readdir,\n  realpath,\n  rename,\n  rm,\n  stat,\n} from 'node:fs/promises';\nimport path from 'node:path';\n\nimport {\n  compareRawStrings,\n  digest,\n  lengthFrame,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/indexer.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Incremental Style Database Indexer                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport {\n  lstat,\n  open,\n  readFile,\n  readdir,\n  realpath,\n  rename,\n  rm,\n  stat,\n} from 'node:fs/promises';\nimport path from 'node:path';\n\nimport {\n  compareRawStrings,\n  digest,\n  lengthFrame,\n  stableJson,\n} from './canonical.mjs';\nimport {\n  buildManifest,\n  hashArtifactFile,\n  writeManifestPointer,\n} from './generation-manifest.mjs';\nimport {\n  RESIDENCY,\n} from './stage-telemetry.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,\n  STYLE_DB_SCHEMA_VERSION,\n  STYLE_DATABASE_POINTER_SUFFIX,\n  openStyleDatabase,\n} from './schema.mjs';\n\nexport const INDEXER_LIFECYCLE = Object.freeze([\n  'DISCOVER',\n  'VERIFY',\n  'PARSE_VALIDATE',\n  'COMMIT',\n  'VECTOR_DRAIN',\n  'PUBLISH',\n]);\nexport const DEFAULT_EMBEDDING_PROFILE = 'style-default-v1';\n\nconst AGGREGATE_HASH_VERSION = 'style-all-artifacts-v2';\nconst RETRIEVAL_HASH_VERSION = 'style-retrieval-document-v1';\nconst GENERATION_HASH_VERSION = 'style-corpus-generation-v2';\nconst LICENSE_ALLOWLIST = new Set(['allowed', 'licensed', 'public-domain']);\nconst RESTRICTED_LICENSE_PATTERN = /\\b(unlicensed trial|license[- ]restricted)\\b/i;\nconst WARM_SURFACE_PATTERN = /\\b(warm|cream|beige|bone|ivory|linen|sand|tan)\\b/i;\nconst MOTION_PATTERN = /\\b(motion|animation|animated|transition|kinetic|scroll)\\b/i;\nconst SERIF_PATTERN = /(^|[^a-z])serif([^a-z]|$)/i;\nconst SANS_SERIF_PATTERN = /sans[- ]serif/i;\n\nfunction nowIso() {\n  return new Date().toISOString();\n}\n\nfunction normalizeTerm(value) {\n  return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n}\n\nfunction normalizeMarkdown(value) {\n  return String(value ?? '').normalize('NFC').replace(/\\r\\n?/g, '\\n')\n    .split('\\n').map((line) => line.trimEnd()).join('\\n').trimEnd();\n}\n\nfunction artifactRole(fileName) {\n  if (fileName.endsWith('-canonical.json')) return 'canonical';\n  if (fileName === 'design-tokens.json') return 'tokens';\n  if (fileName === 'DESIGN.md') return 'design';\n  if (fileName === 'source.md') return 'source';\n  if (fileName === 'css-variables.css') return 'css-variables';\n  if (fileName === 'tailwind-v4.css') return 'tailwind';\n  return null;\n}\n\nfunction isContained(rootPath, candidatePath) {\n  const relative = path.relative(rootPath, candidatePath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction parseJson(artifact, label) {\n  if (!artifact) return {};\n  try {\n    return JSON.parse(artifact.buffer.toString('utf8'));\n  } catch (error) {\n    const invalid = new Error(`Invalid ${label} JSON: ${artifact.relativePath}`, { cause: error });\n    invalid.code = 'invalid-artifact';\n    throw invalid;\n  }\n}\n\nfunction countTokenLeaves(value) {\n  if (!value || typeof value !== 'object') return 0;\n  if (Object.hasOwn(value, '$value')) return 1;\n  return Object.values(value).reduce((sum, child) => sum + countTokenLeaves(child), 0);\n}\n\nfunction deriveTokenAxes(tokens, designSystem) {\n  const counts = new Map();\n  for (const [axis, value] of Object.entries(tokens ?? {})) {\n    const count = countTokenLeaves(value);\n    if (count > 0) counts.set(axis, count);\n  }\n  const fallbackCounts = {\n    color: Array.isArray(designSystem.colors) ? designSystem.colors.length : 0,\n    spacing: designSystem.spacing ? Object.keys(designSystem.spacing).length : 0,\n    typography: Array.isArray(designSystem.typography) ? designSystem.typography.length : 0,\n  };\n  for (const [axis, count] of Object.entries(fallbackCounts)) {\n    if (count > 0 && !counts.has(axis)) counts.set(axis, count);\n  }\n  return [...counts].map(([axis, count]) => ({ axis, count }))\n    .sort((left, right) => compareRawStrings(left.axis, right.axis));\n}\n\nfunction deriveSections(designMarkdown) {\n  const sections = [];\n  for (const [index, line] of designMarkdown.split('\\n').entries()) {\n    const match = /^##\\s+(.+?)\\s*$/.exec(line);\n    if (match) sections.push({ name: match[1], line: index + 1 });\n  }\n  return sections;\n}\n\nfunction deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus) {\n  const values = new Set();\n  if (tokenAxes.length > 0) values.add('tokens');\n  if ((designSystem.components?.length ?? 0) > 0) values.add('components');\n  if (designSystem.layout) values.add('layout');\n  if (designSystem.imagery) values.add('imagery');\n  if (designSystem.spacing) values.add('spacing');\n  if ((designSystem.dos?.length ?? 0) + (designSystem.donts?.length ?? 0) > 0) {\n    values.add('constraints');\n  }\n  if (provenanceStatus === 'known') values.add('provenance');\n  if (sections.some((section) => MOTION_PATTERN.test(section.name))) values.add('motion');\n  return [...values].sort(compareRawStrings);\n}\n\nfunction deriveFacets(style, designSystem, capabilities, tokenAxes, searchableText, licenseStatus) {\n  const values = new Set(capabilities);\n  for (const { axis } of tokenAxes) values.add(axis);\n  if (designSystem.theme) values.add(normalizeTerm(designSystem.theme));\n  if (designSystem.industry) values.add(normalizeTerm(designSystem.industry));\n  if (SERIF_PATTERN.test(searchableText) && !SANS_SERIF_PATTERN.test(searchableText)) {\n    values.add('serif-role');\n  }\n  if (WARM_SURFACE_PATTERN.test(searchableText)) values.add('warm-surface');\n  if (MOTION_PATTERN.test(searchableText)) values.add('motion');\n  if (licenseStatus === 'restricted') values.add('license-restricted');\n  values.add(normalizeTerm(style.slug));\n  return [...values].filter(Boolean).sort(compareRawStrings);\n}\n\nfunction excerpt(value, maxLength = 240) {\n  const normalized = String(value ?? '').replace(/\\s+/g, ' ').trim();\n  if (normalized.length <= maxLength) return normalized;\n  return `${normalized.slice(0, maxLength - 1).trimEnd()}…`;\n}\n\nfunction computeAggregateHash(styleId, artifacts) {\n  const parts = [\n    ...lengthFrame(AGGREGATE_HASH_VERSION),\n    ...lengthFrame(styleId),\n  ];\n  for (const artifact of artifacts.slice()\n    .sort((left, right) => compareRawStrings(left.role, right.role))) {\n    parts.push(...lengthFrame(artifact.role), ...lengthFrame(artifact.buffer));\n  }\n  return digest(parts);\n}\n\nfunction computeHintHash(artifacts) {\n  return digest([\n    'style-artifact-hints-v1\\0',\n    ...artifacts.map((artifact) => (\n      `${artifact.relativePath}\\0${artifact.byteLength}\\0${artifact.mtimeNs}\\0${artifact.ctimeNs}\\n`\n    )),\n  ]);\n}\n\nfunction computeCrawlRecordHash(crawlRecord) {\n  return digest([\n    'style-crawl-record-v1\\0',\n    stableJson(crawlRecord ?? null),\n  ]);\n}\n\nfunction computeGenerationHash(crawlManifestHash, styles, inactiveStates = []) {\n  const parts = [\n    ...lengthFrame(GENERATION_HASH_VERSION),\n    ...lengthFrame(STYLE_DB_SCHEMA_VERSION),\n    ...lengthFrame(crawlManifestHash),\n  ];\n  for (const style of styles.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n    parts.push(...lengthFrame(style.id), ...lengthFrame(style.aggregateHash));\n  }\n  for (const style of inactiveStates.slice().sort((left, right) => compareRawStrings(left.id, right.id))) {\n    parts.push(...lengthFrame(style.id), ...lengthFrame(style.state));\n  }\n  return digest(parts);\n}\n\nasync function readVerifiedArtifacts(corpusRoot, corpusRealPath, slug) {\n  const styleRoot = path.join(corpusRoot, slug);\n  const entries = (await readdir(styleRoot, { withFileTypes: true }))\n    .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n    .sort((left, right) => compareRawStrings(left.name, right.name));\n  const artifacts = [];\n  for (const entry of entries) {\n    const role = artifactRole(entry.name);\n    if (!role) {\n      const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n      error.code = 'invalid-artifact';\n      throw error;\n    }\n    const candidatePath = path.join(styleRoot, entry.name);\n    const linkInfo = await lstat(candidatePath, { bigint: true });\n    if (!linkInfo.isFile() && !linkInfo.isSymbolicLink()) continue;\n    const artifactRealPath = await realpath(candidatePath);\n    if (!isContained(corpusRealPath, artifactRealPath)) {\n      const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n      error.code = 'path-escape';\n      throw error;\n    }\n    const before = await stat(artifactRealPath, { bigint: true });\n    const buffer = await readFile(artifactRealPath);\n    const after = await stat(artifactRealPath, { bigint: true });\n    if (before.size !== after.size || before.mtimeNs !== after.mtimeNs || before.ctimeNs !== after.ctimeNs) {\n      const error = new Error(`Corpus changed while reading ${slug}/${entry.name}.`);\n      error.code = 'corpus-changing';\n      throw error;\n    }\n    artifacts.push({\n      role,\n      relativePath: `${slug}/${entry.name}`,\n      byteLength: buffer.byteLength,\n      sha256: digest([buffer]),\n      mtimeNs: String(after.mtimeNs),\n      ctimeNs: String(after.ctimeNs),\n      buffer,\n    });\n  }\n  if (!artifacts.some((artifact) => artifact.role === 'canonical')\n    || !artifacts.some((artifact) => artifact.role === 'design')) {\n    const error = new Error(`Style ${slug} lacks its canonical JSON or DESIGN.md artifact.`);\n    error.code = 'invalid-artifact';\n    throw error;\n  }\n  return artifacts;\n}\n\nasync function readArtifactHints(corpusRoot, corpusRealPath, slug) {\n  const styleRoot = path.join(corpusRoot, slug);\n  const entries = (await readdir(styleRoot, { withFileTypes: true }))\n    .filter((entry) => entry.isFile() || entry.isSymbolicLink())\n    .sort((left, right) => compareRawStrings(left.name, right.name));\n  const artifacts = [];\n  for (const entry of entries) {\n    const role = artifactRole(entry.name);\n    if (!role) {\n      const error = new Error(`Style ${slug} contains an unsupported artifact: ${entry.name}`);\n      error.code = 'invalid-artifact';\n      throw error;\n    }\n    const candidatePath = path.join(styleRoot, entry.name);\n    const artifactRealPath = await realpath(candidatePath);\n    if (!isContained(corpusRealPath, artifactRealPath)) {\n      const error = new Error(`Artifact escapes the corpus root: ${slug}/${entry.name}`);\n      error.code = 'path-escape';\n      throw error;\n    }\n    const fileInfo = await stat(artifactRealPath, { bigint: true });\n    artifacts.push({\n      role,\n      relativePath: `${slug}/${entry.name}`,\n      byteLength: Number(fileInfo.size),\n      mtimeNs: String(fileInfo.mtimeNs),\n      ctimeNs: String(fileInfo.ctimeNs),\n    });\n  }\n  return artifacts;\n}\n\nfunction parseStyle(slug, crawlRecord, artifacts) {\n  const canonical = parseJson(artifacts.find((artifact) => artifact.role === 'canonical'), 'canonical');\n  const tokens = parseJson(artifacts.find((artifact) => artifact.role === 'tokens'), 'token');\n  const designMarkdown = normalizeMarkdown(\n    artifacts.find((artifact) => artifact.role === 'design')?.buffer.toString('utf8'),\n  );\n  const designSystem = canonical.designSystem ?? {};\n  const id = canonical.uuid ?? crawlRecord?.uuid;\n  if (typeof id !== 'string' || id.length === 0) {\n    const error = new Error(`Style ${slug} has no stable UUID.`);\n    error.code = 'invalid-artifact';\n    throw error;\n  }\n  const title = excerpt(canonical.name ?? slug, 120);\n  const thesis = excerpt(canonical.northStar ?? designSystem.northStar ?? designSystem.description);\n  const theme = designSystem.theme == null ? null : String(designSystem.theme);\n  const industry = designSystem.industry == null ? null : String(designSystem.industry);\n  const sections = deriveSections(designMarkdown);\n  const tokenAxes = deriveTokenAxes(tokens, designSystem);\n  const provenanceStatus = canonical.source && canonical.uuid && canonical.meta?.url\n    ? 'known'\n    : 'missing';\n  const searchableText = [\n    title,\n    thesis,\n    designSystem.description,\n    theme,\n    industry,\n    designSystem.layout,\n    designSystem.imagery,\n    ...(Array.isArray(designSystem.typography)\n      ? designSystem.typography.map((entry) => `${entry.family ?? ''} ${entry.role ?? ''}`)\n      : []),\n    designMarkdown.slice(0, 65_536),\n  ].join(' ');\n  const licenseStatus = RESTRICTED_LICENSE_PATTERN.test(searchableText)\n    ? 'restricted'\n    : String(canonical.license?.status ?? 'unknown');\n  const rightsKnown = LICENSE_ALLOWLIST.has(licenseStatus) || licenseStatus === 'restricted';\n  const capabilities = deriveCapabilities(designSystem, tokenAxes, sections, provenanceStatus);\n  const facets = deriveFacets(\n    { slug },\n    designSystem,\n    capabilities,\n    tokenAxes,\n    searchableText,\n    licenseStatus,\n  );\n  const retrievalDocument = {\n    id,\n    title,\n    thesis,\n    theme,\n    industry,\n    capabilities,\n    facets,\n    tokenAxes,\n    sections: sections.map((section) => section.name),\n    designMarkdown,\n  };\n  const retrievalJson = stableJson(retrievalDocument);\n  const retrievalHash = digest([\n    ...lengthFrame(RETRIEVAL_HASH_VERSION),\n    ...lengthFrame(retrievalJson),\n  ]);\n  const aggregateHash = computeAggregateHash(id, artifacts);\n  return {\n    id,\n    slug,\n    crawlStatus: crawlRecord?.status ?? 'unknown',\n    title,\n    thesis,\n    theme,\n    industry,\n    aggregateHash,\n    artifactHintHash: computeHintHash(artifacts),\n    crawlRecordHash: computeCrawlRecordHash(crawlRecord),\n    retrievalHash,\n    artifacts,\n    tokenAxes,\n    sections,\n    capabilities,\n    facets,\n    provenance: {\n      status: provenanceStatus,\n      sourceUrl: canonical.source ?? crawlRecord?.url ?? null,\n      originalUrl: canonical.meta?.url ?? null,\n      screenshotUrl: canonical.screenshot?.url ?? null,\n      uuid: canonical.uuid ?? crawlRecord?.uuid ?? null,\n      capturedAt: canonical.capturedAt ?? crawlRecord?.capturedAt ?? null,\n      licenseStatus,\n      rightsKnown,\n      evidenceScope: ['reference', 'rationale'],\n    },\n    relationships: (Array.isArray(designSystem.similar) ? designSystem.similar : [])\n      .map((relationship, ordinal) => ({\n        ordinal,\n        rawTargetLabel: String(relationship.business ?? relationship.name ?? '').trim(),\n        rationale: String(relationship.why ?? relationship.rationale ?? '').trim(),\n      })).filter((relationship) => relationship.rawTargetLabel),\n    retrievalDocument: {\n      title,\n      thesis,\n      theme: theme ?? '',\n      industry: industry ?? '',\n      terms: [...new Set([...facets, ...capabilities, ...tokenAxes.map(({ axis }) => axis)])]\n        .sort(compareRawStrings).join(' '),\n      body: designMarkdown,\n      documentJson: retrievalJson,\n      retrievalHash,\n    },\n  };\n}\n\nfunction replaceStyleChildren(database, styleRowid, style, timestamp) {\n  for (const table of [\n    'style_provenance',\n    'style_artifacts',\n    'style_terms',\n    'style_token_axes',\n    'style_sections',\n    'retrieval_documents',\n    'style_relationships',\n  ]) {\n    const key = table === 'style_relationships' ? 'source_style_rowid' : 'style_rowid';\n    database.prepare(`DELETE FROM ${table} WHERE ${key} = ?`).run(styleRowid);\n  }\n  database.prepare(`\n    INSERT INTO style_provenance(\n      style_rowid, status, source_url, original_url, screenshot_url, source_uuid,\n      captured_at, license_status, rights_known, evidence_scope_json\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    styleRowid,\n    style.provenance.status,\n    style.provenance.sourceUrl,\n    style.provenance.originalUrl,\n    style.provenance.screenshotUrl,\n    style.provenance.uuid,\n    style.provenance.capturedAt,\n    style.provenance.licenseStatus,\n    style.provenance.rightsKnown ? 1 : 0,\n    JSON.stringify(style.provenance.evidenceScope),\n  );\n  const insertArtifact = database.prepare(`\n    INSERT INTO style_artifacts(\n      style_rowid, role, relative_path, byte_length, sha256, mtime_ns, ctime_ns\n    ) VALUES (?, ?, ?, ?, ?, ?, ?)\n  `);\n  for (const artifact of style.artifacts) {\n    insertArtifact.run(\n      styleRowid,\n      artifact.role,\n      artifact.relativePath,\n      artifact.byteLength,\n      artifact.sha256,\n      artifact.mtimeNs,\n      artifact.ctimeNs,\n    );\n  }\n  const insertTerm = database.prepare(\n    'INSERT INTO style_terms(style_rowid, term_type, term) VALUES (?, ?, ?)',\n  );\n  for (const term of style.facets) insertTerm.run(styleRowid, 'facet', term);\n  for (const term of style.capabilities) insertTerm.run(styleRowid, 'capability', term);\n  const insertAxis = database.prepare(\n    'INSERT INTO style_token_axes(style_rowid, axis, token_count) VALUES (?, ?, ?)',\n  );\n  for (const axis of style.tokenAxes) insertAxis.run(styleRowid, axis.axis, axis.count);\n  const insertSection = database.prepare(`\n    INSERT INTO style_sections(style_rowid, ordinal, name, line_number) VALUES (?, ?, ?, ?)\n  `);\n  for (const [ordinal, section] of style.sections.entries()) {\n    insertSection.run(styleRowid, ordinal, section.name, section.line);\n  }\n  const document = style.retrievalDocument;\n  database.prepare(`\n    INSERT INTO retrieval_documents(\n      style_rowid, title, thesis, theme, industry, terms, body, document_json, retrieval_hash\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    styleRowid,\n    document.title,\n    document.thesis,\n    document.theme,\n    document.industry,\n    document.terms,\n    document.body,\n    document.documentJson,\n    document.retrievalHash,\n  );","lineStart":1,"lineEnd":480,"totalLines":1187,"truncated":true}},"title":".opencode/skills/sk-design/styles/_db/indexer.mjs","time":{"start":1784623168865,"end":1784623168882}},"metadata":{"openai":{"itemId":"fc_02bf757ba310bf3e016a5f30403ab88191bca43f955e3bd97d"}},"id":"prt_f83d47d420015giVwMWApSWRCL","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV"}}
{"type":"tool_use","timestamp":1784623168911,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"read","callID":"call_1TIeII54v5oxinQwuCXBaoey","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/schema.mjs","offset":1,"limit":390},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/schema.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Persistent Style Database Schema                                         ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import { DatabaseSync } from 'node:sqlite';\n6: import path from 'node:path';\n7: import { fileURLToPath } from 'node:url';\n8: \n9: import { resolvePublishedTarget } from './generation-manifest.mjs';\n10: \n11: export const STYLE_DB_SCHEMA_VERSION = 2;\n12: export const DEFAULT_STYLE_DATABASE_PATH = path.join(\n13:   path.dirname(fileURLToPath(import.meta.url)),\n14:   'style-library.sqlite',\n15: );\n16: export const STYLE_DATABASE_POINTER_SUFFIX = '.current.json';\n17: \n18: // The published pointer is a versioned multi-artifact manifest; legacy\n19: // single-file pointers still resolve. Manifest ownership lives in\n20: // generation-manifest.mjs so publish and resolve share one shape contract.\n21: function resolvePublishedDatabaseTarget(databasePath) {\n22:   return resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX);\n23: }\n24: \n25: /**\n26:  * Resolve the immutable generation selected by an atomic pointer file.\n27:  *\n28:  * @param {string} [databasePath] - Logical database path.\n29:  * @returns {string} Published generation path, or the direct path for legacy databases.\n30:  */\n31: export function resolvePublishedDatabasePath(databasePath = DEFAULT_STYLE_DATABASE_PATH) {\n32:   return resolvePublishedDatabaseTarget(databasePath).databasePath;\n33: }\n34: \n35: const SCHEMA_SQL = `\n36:   CREATE TABLE IF NOT EXISTS style_db_metadata (\n37:     key TEXT PRIMARY KEY,\n38:     value TEXT NOT NULL\n39:   ) STRICT;\n40: \n41:   CREATE TABLE IF NOT EXISTS styles (\n42:     style_rowid INTEGER PRIMARY KEY,\n43:     style_id TEXT NOT NULL UNIQUE,\n44:     slug TEXT NOT NULL UNIQUE,\n45:     lifecycle_state TEXT NOT NULL DEFAULT 'active'\n46:       CHECK (lifecycle_state IN ('active', 'quarantined', 'tombstoned')),\n47:     crawl_status TEXT NOT NULL,\n48:     title TEXT NOT NULL,\n49:     thesis TEXT NOT NULL,\n50:     theme TEXT,\n51:     industry TEXT,\n52:     aggregate_hash TEXT NOT NULL,\n53:     retrieval_hash TEXT NOT NULL,\n54:     quarantine_at TEXT,\n55:     tombstoned_at TEXT,\n56:     created_at TEXT NOT NULL,\n57:     updated_at TEXT NOT NULL,\n58:     CHECK (\n59:       (lifecycle_state = 'active' AND quarantine_at IS NULL AND tombstoned_at IS NULL)\n60:       OR (lifecycle_state = 'quarantined' AND quarantine_at IS NOT NULL AND tombstoned_at IS NULL)\n61:       OR (lifecycle_state = 'tombstoned' AND quarantine_at IS NOT NULL AND tombstoned_at IS NOT NULL)\n62:     )\n63:   ) STRICT;\n64: \n65:   CREATE TABLE IF NOT EXISTS style_provenance (\n66:     style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n67:     status TEXT NOT NULL CHECK (status IN ('known', 'missing')),\n68:     source_url TEXT,\n69:     original_url TEXT,\n70:     screenshot_url TEXT,\n71:     source_uuid TEXT,\n72:     captured_at TEXT,\n73:     license_status TEXT NOT NULL,\n74:     rights_known INTEGER NOT NULL CHECK (rights_known IN (0, 1)),\n75:     evidence_scope_json TEXT NOT NULL\n76:   ) STRICT;\n77: \n78:   CREATE TABLE IF NOT EXISTS style_artifacts (\n79:     artifact_id INTEGER PRIMARY KEY,\n80:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n81:     role TEXT NOT NULL CHECK (role IN (\n82:       'canonical', 'tokens', 'design', 'source', 'css-variables', 'tailwind'\n83:     )),\n84:     relative_path TEXT NOT NULL,\n85:     byte_length INTEGER NOT NULL CHECK (byte_length >= 0),\n86:     sha256 TEXT NOT NULL,\n87:     mtime_ns TEXT NOT NULL,\n88:     ctime_ns TEXT NOT NULL,\n89:     UNIQUE (style_rowid, role),\n90:     UNIQUE (style_rowid, relative_path)\n91:   ) STRICT;\n92: \n93:   CREATE TABLE IF NOT EXISTS style_terms (\n94:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n95:     term_type TEXT NOT NULL CHECK (term_type IN ('facet', 'capability')),\n96:     term TEXT NOT NULL,\n97:     PRIMARY KEY (style_rowid, term_type, term)\n98:   ) WITHOUT ROWID, STRICT;\n99: \n100:   CREATE TABLE IF NOT EXISTS style_token_axes (\n101:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n102:     axis TEXT NOT NULL,\n103:     token_count INTEGER NOT NULL CHECK (token_count >= 0),\n104:     PRIMARY KEY (style_rowid, axis)\n105:   ) WITHOUT ROWID, STRICT;\n106: \n107:   CREATE TABLE IF NOT EXISTS style_sections (\n108:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n109:     ordinal INTEGER NOT NULL CHECK (ordinal >= 0),\n110:     name TEXT NOT NULL,\n111:     line_number INTEGER NOT NULL CHECK (line_number > 0),\n112:     PRIMARY KEY (style_rowid, ordinal)\n113:   ) WITHOUT ROWID, STRICT;\n114: \n115:   CREATE TABLE IF NOT EXISTS retrieval_documents (\n116:     style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n117:     title TEXT NOT NULL,\n118:     thesis TEXT NOT NULL,\n119:     theme TEXT NOT NULL,\n120:     industry TEXT NOT NULL,\n121:     terms TEXT NOT NULL,\n122:     body TEXT NOT NULL,\n123:     document_json TEXT NOT NULL,\n124:     retrieval_hash TEXT NOT NULL\n125:   ) STRICT;\n126: \n127:   CREATE VIRTUAL TABLE IF NOT EXISTS style_fts USING fts5(\n128:     title, thesis, theme, industry, terms, body,\n129:     content='retrieval_documents', content_rowid='style_rowid'\n130:   );\n131: \n132:   CREATE TRIGGER IF NOT EXISTS style_fts_insert\n133:   AFTER INSERT ON retrieval_documents BEGIN\n134:     INSERT INTO style_fts(rowid, title, thesis, theme, industry, terms, body)\n135:     VALUES (new.style_rowid, new.title, new.thesis, new.theme, new.industry,\n136:       new.terms, new.body);\n137:   END;\n138: \n139:   CREATE TRIGGER IF NOT EXISTS style_fts_update\n140:   AFTER UPDATE ON retrieval_documents BEGIN\n141:     INSERT INTO style_fts(style_fts, rowid, title, thesis, theme, industry, terms, body)\n142:     VALUES ('delete', old.style_rowid, old.title, old.thesis, old.theme,\n143:       old.industry, old.terms, old.body);\n144:     INSERT INTO style_fts(rowid, title, thesis, theme, industry, terms, body)\n145:     VALUES (new.style_rowid, new.title, new.thesis, new.theme, new.industry,\n146:       new.terms, new.body);\n147:   END;\n148: \n149:   CREATE TRIGGER IF NOT EXISTS style_fts_delete\n150:   AFTER DELETE ON retrieval_documents BEGIN\n151:     INSERT INTO style_fts(style_fts, rowid, title, thesis, theme, industry, terms, body)\n152:     VALUES ('delete', old.style_rowid, old.title, old.thesis, old.theme,\n153:       old.industry, old.terms, old.body);\n154:   END;\n155: \n156:   CREATE TABLE IF NOT EXISTS embedding_profiles (\n157:     profile_id TEXT PRIMARY KEY,\n158:     provider TEXT NOT NULL,\n159:     model TEXT NOT NULL,\n160:     dimensions INTEGER CHECK (dimensions IS NULL OR dimensions > 0),\n161:     config_hash TEXT NOT NULL,\n162:     created_at TEXT NOT NULL\n163:   ) STRICT;\n164: \n165:   CREATE TABLE IF NOT EXISTS embedding_cache (\n166:     retrieval_hash TEXT NOT NULL,\n167:     profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n168:     dimensions INTEGER NOT NULL CHECK (dimensions > 0),\n169:     vector_json TEXT NOT NULL,\n170:     created_at TEXT NOT NULL,\n171:     PRIMARY KEY (retrieval_hash, profile_id)\n172:   ) WITHOUT ROWID, STRICT;\n173: \n174:   CREATE TABLE IF NOT EXISTS style_vector_jobs (\n175:     job_id INTEGER PRIMARY KEY,\n176:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n177:     retrieval_hash TEXT NOT NULL,\n178:     profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n179:     status TEXT NOT NULL DEFAULT 'pending'\n180:       CHECK (status IN ('pending', 'running', 'completed', 'failed', 'superseded')),\n181:     attempts INTEGER NOT NULL DEFAULT 0 CHECK (attempts >= 0),\n182:     next_attempt_at TEXT,\n183:     last_error TEXT,\n184:     created_at TEXT NOT NULL,\n185:     updated_at TEXT NOT NULL,\n186:     UNIQUE (style_rowid, retrieval_hash, profile_id)\n187:   ) STRICT;\n188: \n189:   CREATE TABLE IF NOT EXISTS style_vectors (\n190:     style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n191:     retrieval_hash TEXT NOT NULL,\n192:     profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n193:     dimensions INTEGER NOT NULL CHECK (dimensions > 0),\n194:     vector_json TEXT NOT NULL,\n195:     created_at TEXT NOT NULL,\n196:     PRIMARY KEY (style_rowid, profile_id)\n197:   ) WITHOUT ROWID, STRICT;\n198: \n199:   CREATE TABLE IF NOT EXISTS style_relationships (\n200:     relationship_id INTEGER PRIMARY KEY,\n201:     source_style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n202:     ordinal INTEGER NOT NULL CHECK (ordinal >= 0),\n203:     raw_target_label TEXT NOT NULL,\n204:     target_style_rowid INTEGER REFERENCES styles(style_rowid) ON DELETE SET NULL,\n205:     rationale TEXT NOT NULL,\n206:     resolution_state TEXT NOT NULL\n207:       CHECK (resolution_state IN ('resolved', 'ambiguous', 'unresolved')),\n208:     confidence REAL NOT NULL CHECK (confidence >= 0 AND confidence <= 1),\n209:     UNIQUE (source_style_rowid, ordinal)\n210:   ) STRICT;\n211: \n212:   CREATE TABLE IF NOT EXISTS style_index_state (\n213:     style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n214:     artifact_hint_hash TEXT NOT NULL,\n215:     crawl_record_hash TEXT NOT NULL,\n216:     aggregate_hash TEXT NOT NULL,\n217:     last_success_generation TEXT NOT NULL,\n218:     last_success_at TEXT NOT NULL,\n219:     missing_observations INTEGER NOT NULL DEFAULT 0 CHECK (missing_observations >= 0)\n220:   ) STRICT;\n221: \n222:   CREATE TABLE IF NOT EXISTS corpus_generations (\n223:     generation_hash TEXT PRIMARY KEY,\n224:     parent_generation_hash TEXT REFERENCES corpus_generations(generation_hash),\n225:     crawl_manifest_hash TEXT NOT NULL,\n226:     aggregate_corpus_hash TEXT NOT NULL,\n227:     schema_version INTEGER NOT NULL,\n228:     active_style_count INTEGER NOT NULL CHECK (active_style_count >= 0),\n229:     quarantined_style_count INTEGER NOT NULL CHECK (quarantined_style_count >= 0),\n230:     tombstoned_style_count INTEGER NOT NULL CHECK (tombstoned_style_count >= 0),\n231:     created_at TEXT NOT NULL\n232:   ) STRICT;\n233: \n234:   CREATE TABLE IF NOT EXISTS current_corpus_generation (\n235:     singleton INTEGER PRIMARY KEY CHECK (singleton = 1),\n236:     generation_hash TEXT NOT NULL REFERENCES corpus_generations(generation_hash),\n237:     published_at TEXT NOT NULL\n238:   ) STRICT;\n239: \n240:   CREATE TABLE IF NOT EXISTS vector_projection_revisions (\n241:     profile_id TEXT PRIMARY KEY REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n242:     revision INTEGER NOT NULL DEFAULT 0 CHECK (revision >= 0),\n243:     updated_at TEXT NOT NULL\n244:   ) STRICT;\n245: \n246:   CREATE TRIGGER IF NOT EXISTS corpus_generations_immutable_update\n247:   BEFORE UPDATE ON corpus_generations BEGIN\n248:     SELECT RAISE(ABORT, 'corpus generations are immutable');\n249:   END;\n250: \n251:   CREATE TRIGGER IF NOT EXISTS corpus_generations_immutable_delete\n252:   BEFORE DELETE ON corpus_generations BEGIN\n253:     SELECT RAISE(ABORT, 'corpus generations are immutable');\n254:   END;\n255: \n256:   CREATE INDEX IF NOT EXISTS idx_styles_active_theme\n257:     ON styles(theme, style_id) WHERE lifecycle_state = 'active';\n258:   CREATE INDEX IF NOT EXISTS idx_styles_lifecycle ON styles(lifecycle_state, style_id);\n259:   CREATE INDEX IF NOT EXISTS idx_style_terms_lookup ON style_terms(term_type, term, style_rowid);\n260:   CREATE INDEX IF NOT EXISTS idx_style_axes_lookup ON style_token_axes(axis, style_rowid);\n261:   CREATE INDEX IF NOT EXISTS idx_style_artifacts_path ON style_artifacts(relative_path);\n262:   CREATE INDEX IF NOT EXISTS idx_style_vectors_profile ON style_vectors(profile_id, style_rowid);\n263:   CREATE INDEX IF NOT EXISTS idx_vector_jobs_drain\n264:     ON style_vector_jobs(status, next_attempt_at, job_id);\n265:   CREATE INDEX IF NOT EXISTS idx_relationships_source\n266:     ON style_relationships(source_style_rowid, resolution_state);\n267:   CREATE INDEX IF NOT EXISTS idx_relationships_target\n268:     ON style_relationships(target_style_rowid) WHERE target_style_rowid IS NOT NULL;\n269: `;\n270: \n271: /**\n272:  * Create or validate the current style database schema.\n273:  *\n274:  * @param {DatabaseSync} database - Open SQLite connection.\n275:  * @returns {DatabaseSync} The configured connection.\n276:  */\n277: export function createSchema(database) {\n278:   if (!(database instanceof DatabaseSync)) {\n279:     throw new TypeError('database must be a node:sqlite DatabaseSync instance.');\n280:   }\n281:   database.exec('PRAGMA foreign_keys = ON; PRAGMA busy_timeout = 5000;');\n282:   const currentVersion = Number(database.prepare('PRAGMA user_version').get().user_version);\n283:   if (currentVersion > STYLE_DB_SCHEMA_VERSION) {\n284:     throw new Error(`Style database schema ${currentVersion} is newer than supported version ${STYLE_DB_SCHEMA_VERSION}.`);\n285:   }\n286:   if (currentVersion === 1) {\n287:     const indexStateColumns = database.prepare(`\n288:       PRAGMA table_info(style_index_state)\n289:     `).all().map((column) => column.name);\n290:     if (!indexStateColumns.includes('crawl_record_hash')) {\n291:       database.exec('BEGIN IMMEDIATE');\n292:       try {\n293:         database.exec(`\n294:           ALTER TABLE style_index_state\n295:           ADD COLUMN crawl_record_hash TEXT NOT NULL DEFAULT 'legacy-unverified'\n296:         `);\n297:         database.exec('COMMIT');\n298:       } catch (error) {\n299:         database.exec('ROLLBACK');\n300:         throw error;\n301:       }\n302:     }\n303:   }\n304:   database.exec(SCHEMA_SQL);\n305:   const requiredIndexStateColumns = new Set([\n306:     'style_rowid',\n307:     'artifact_hint_hash',\n308:     'crawl_record_hash',\n309:     'aggregate_hash',\n310:     'last_success_generation',\n311:     'last_success_at',\n312:     'missing_observations',\n313:   ]);\n314:   const actualIndexStateColumns = new Set(database.prepare(`\n315:     PRAGMA table_info(style_index_state)\n316:   `).all().map((column) => column.name));\n317:   if ([...requiredIndexStateColumns].some((column) => !actualIndexStateColumns.has(column))) {\n318:     throw new Error('Style database index-state schema is incomplete after migration.');\n319:   }\n320:   database.prepare(`\n321:     INSERT INTO style_db_metadata(key, value) VALUES ('schema_version', ?)\n322:     ON CONFLICT(key) DO UPDATE SET value = excluded.value\n323:   `).run(String(STYLE_DB_SCHEMA_VERSION));\n324:   database.exec(`PRAGMA user_version = ${STYLE_DB_SCHEMA_VERSION};`);\n325:   return database;\n326: }\n327: \n328: /**\n329:  * Open a local style database with its versioned schema initialized.\n330:  *\n331:  * @param {string} [databasePath=':memory:'] - SQLite file path or in-memory marker.\n332:  * @returns {DatabaseSync} Ready database connection.\n333:  */\n334: export function openStyleDatabase(databasePath = ':memory:') {\n335:   const database = new DatabaseSync(databasePath);\n336:   if (databasePath !== ':memory:') database.exec('PRAGMA journal_mode = WAL;');\n337:   return createSchema(database);\n338: }\n339: \n340: /**\n341:  * Open the published generation and bind its internal identity to the pointer.\n342:  *\n343:  * @param {string} [databasePath] - Logical database path.\n344:  * @returns {DatabaseSync} Generation-bound database connection.\n345:  */\n346: export function openPublishedStyleDatabase(databasePath = DEFAULT_STYLE_DATABASE_PATH) {\n347:   const target = resolvePublishedDatabaseTarget(databasePath);\n348:   const database = openStyleDatabase(target.databasePath);\n349:   if (target.generationHash === null) return database;\n350:   const openedGeneration = database.prepare(`\n351:     SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n352:   `).get()?.generation_hash;\n353:   if (openedGeneration !== target.generationHash) {\n354:     database.close();\n355:     const error = new Error('Published database generation does not match its pointer.');\n356:     error.code = 'generation-pointer-mismatch';\n357:     throw error;\n358:   }\n359:   return database;\n360: }\n\n(End of file - total 360 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Schema                                         ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { DatabaseSync } from 'node:sqlite';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { resolvePublishedTarget } from './generation-manifest.mjs';\n\nexport const STYLE_DB_SCHEMA_VERSION = 2;\nexport const DEFAULT_STYLE_DATABASE_PATH = path.join(\n  path.dirname(fileURLToPath(import.meta.url)),\n  'style-library.sqlite',\n);\nexport const STYLE_DATABASE_POINTER_SUFFIX = '.current.json';\n\n// The published pointer is a versioned multi-artifact manifest; legacy\n// single-file pointers still resolve. Manifest ownership lives in\n// generation-manifest.mjs so publish and resolve share one shape contract.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/schema.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Schema                                         ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { DatabaseSync } from 'node:sqlite';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { resolvePublishedTarget } from './generation-manifest.mjs';\n\nexport const STYLE_DB_SCHEMA_VERSION = 2;\nexport const DEFAULT_STYLE_DATABASE_PATH = path.join(\n  path.dirname(fileURLToPath(import.meta.url)),\n  'style-library.sqlite',\n);\nexport const STYLE_DATABASE_POINTER_SUFFIX = '.current.json';\n\n// The published pointer is a versioned multi-artifact manifest; legacy\n// single-file pointers still resolve. Manifest ownership lives in\n// generation-manifest.mjs so publish and resolve share one shape contract.\nfunction resolvePublishedDatabaseTarget(databasePath) {\n  return resolvePublishedTarget(databasePath, STYLE_DATABASE_POINTER_SUFFIX);\n}\n\n/**\n * Resolve the immutable generation selected by an atomic pointer file.\n *\n * @param {string} [databasePath] - Logical database path.\n * @returns {string} Published generation path, or the direct path for legacy databases.\n */\nexport function resolvePublishedDatabasePath(databasePath = DEFAULT_STYLE_DATABASE_PATH) {\n  return resolvePublishedDatabaseTarget(databasePath).databasePath;\n}\n\nconst SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS style_db_metadata (\n    key TEXT PRIMARY KEY,\n    value TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS styles (\n    style_rowid INTEGER PRIMARY KEY,\n    style_id TEXT NOT NULL UNIQUE,\n    slug TEXT NOT NULL UNIQUE,\n    lifecycle_state TEXT NOT NULL DEFAULT 'active'\n      CHECK (lifecycle_state IN ('active', 'quarantined', 'tombstoned')),\n    crawl_status TEXT NOT NULL,\n    title TEXT NOT NULL,\n    thesis TEXT NOT NULL,\n    theme TEXT,\n    industry TEXT,\n    aggregate_hash TEXT NOT NULL,\n    retrieval_hash TEXT NOT NULL,\n    quarantine_at TEXT,\n    tombstoned_at TEXT,\n    created_at TEXT NOT NULL,\n    updated_at TEXT NOT NULL,\n    CHECK (\n      (lifecycle_state = 'active' AND quarantine_at IS NULL AND tombstoned_at IS NULL)\n      OR (lifecycle_state = 'quarantined' AND quarantine_at IS NOT NULL AND tombstoned_at IS NULL)\n      OR (lifecycle_state = 'tombstoned' AND quarantine_at IS NOT NULL AND tombstoned_at IS NOT NULL)\n    )\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_provenance (\n    style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    status TEXT NOT NULL CHECK (status IN ('known', 'missing')),\n    source_url TEXT,\n    original_url TEXT,\n    screenshot_url TEXT,\n    source_uuid TEXT,\n    captured_at TEXT,\n    license_status TEXT NOT NULL,\n    rights_known INTEGER NOT NULL CHECK (rights_known IN (0, 1)),\n    evidence_scope_json TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_artifacts (\n    artifact_id INTEGER PRIMARY KEY,\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    role TEXT NOT NULL CHECK (role IN (\n      'canonical', 'tokens', 'design', 'source', 'css-variables', 'tailwind'\n    )),\n    relative_path TEXT NOT NULL,\n    byte_length INTEGER NOT NULL CHECK (byte_length >= 0),\n    sha256 TEXT NOT NULL,\n    mtime_ns TEXT NOT NULL,\n    ctime_ns TEXT NOT NULL,\n    UNIQUE (style_rowid, role),\n    UNIQUE (style_rowid, relative_path)\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_terms (\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    term_type TEXT NOT NULL CHECK (term_type IN ('facet', 'capability')),\n    term TEXT NOT NULL,\n    PRIMARY KEY (style_rowid, term_type, term)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_token_axes (\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    axis TEXT NOT NULL,\n    token_count INTEGER NOT NULL CHECK (token_count >= 0),\n    PRIMARY KEY (style_rowid, axis)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_sections (\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    ordinal INTEGER NOT NULL CHECK (ordinal >= 0),\n    name TEXT NOT NULL,\n    line_number INTEGER NOT NULL CHECK (line_number > 0),\n    PRIMARY KEY (style_rowid, ordinal)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS retrieval_documents (\n    style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    title TEXT NOT NULL,\n    thesis TEXT NOT NULL,\n    theme TEXT NOT NULL,\n    industry TEXT NOT NULL,\n    terms TEXT NOT NULL,\n    body TEXT NOT NULL,\n    document_json TEXT NOT NULL,\n    retrieval_hash TEXT NOT NULL\n  ) STRICT;\n\n  CREATE VIRTUAL TABLE IF NOT EXISTS style_fts USING fts5(\n    title, thesis, theme, industry, terms, body,\n    content='retrieval_documents', content_rowid='style_rowid'\n  );\n\n  CREATE TRIGGER IF NOT EXISTS style_fts_insert\n  AFTER INSERT ON retrieval_documents BEGIN\n    INSERT INTO style_fts(rowid, title, thesis, theme, industry, terms, body)\n    VALUES (new.style_rowid, new.title, new.thesis, new.theme, new.industry,\n      new.terms, new.body);\n  END;\n\n  CREATE TRIGGER IF NOT EXISTS style_fts_update\n  AFTER UPDATE ON retrieval_documents BEGIN\n    INSERT INTO style_fts(style_fts, rowid, title, thesis, theme, industry, terms, body)\n    VALUES ('delete', old.style_rowid, old.title, old.thesis, old.theme,\n      old.industry, old.terms, old.body);\n    INSERT INTO style_fts(rowid, title, thesis, theme, industry, terms, body)\n    VALUES (new.style_rowid, new.title, new.thesis, new.theme, new.industry,\n      new.terms, new.body);\n  END;\n\n  CREATE TRIGGER IF NOT EXISTS style_fts_delete\n  AFTER DELETE ON retrieval_documents BEGIN\n    INSERT INTO style_fts(style_fts, rowid, title, thesis, theme, industry, terms, body)\n    VALUES ('delete', old.style_rowid, old.title, old.thesis, old.theme,\n      old.industry, old.terms, old.body);\n  END;\n\n  CREATE TABLE IF NOT EXISTS embedding_profiles (\n    profile_id TEXT PRIMARY KEY,\n    provider TEXT NOT NULL,\n    model TEXT NOT NULL,\n    dimensions INTEGER CHECK (dimensions IS NULL OR dimensions > 0),\n    config_hash TEXT NOT NULL,\n    created_at TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS embedding_cache (\n    retrieval_hash TEXT NOT NULL,\n    profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n    dimensions INTEGER NOT NULL CHECK (dimensions > 0),\n    vector_json TEXT NOT NULL,\n    created_at TEXT NOT NULL,\n    PRIMARY KEY (retrieval_hash, profile_id)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_vector_jobs (\n    job_id INTEGER PRIMARY KEY,\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    retrieval_hash TEXT NOT NULL,\n    profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n    status TEXT NOT NULL DEFAULT 'pending'\n      CHECK (status IN ('pending', 'running', 'completed', 'failed', 'superseded')),\n    attempts INTEGER NOT NULL DEFAULT 0 CHECK (attempts >= 0),\n    next_attempt_at TEXT,\n    last_error TEXT,\n    created_at TEXT NOT NULL,\n    updated_at TEXT NOT NULL,\n    UNIQUE (style_rowid, retrieval_hash, profile_id)\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_vectors (\n    style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    retrieval_hash TEXT NOT NULL,\n    profile_id TEXT NOT NULL REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n    dimensions INTEGER NOT NULL CHECK (dimensions > 0),\n    vector_json TEXT NOT NULL,\n    created_at TEXT NOT NULL,\n    PRIMARY KEY (style_rowid, profile_id)\n  ) WITHOUT ROWID, STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_relationships (\n    relationship_id INTEGER PRIMARY KEY,\n    source_style_rowid INTEGER NOT NULL REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    ordinal INTEGER NOT NULL CHECK (ordinal >= 0),\n    raw_target_label TEXT NOT NULL,\n    target_style_rowid INTEGER REFERENCES styles(style_rowid) ON DELETE SET NULL,\n    rationale TEXT NOT NULL,\n    resolution_state TEXT NOT NULL\n      CHECK (resolution_state IN ('resolved', 'ambiguous', 'unresolved')),\n    confidence REAL NOT NULL CHECK (confidence >= 0 AND confidence <= 1),\n    UNIQUE (source_style_rowid, ordinal)\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS style_index_state (\n    style_rowid INTEGER PRIMARY KEY REFERENCES styles(style_rowid) ON DELETE CASCADE,\n    artifact_hint_hash TEXT NOT NULL,\n    crawl_record_hash TEXT NOT NULL,\n    aggregate_hash TEXT NOT NULL,\n    last_success_generation TEXT NOT NULL,\n    last_success_at TEXT NOT NULL,\n    missing_observations INTEGER NOT NULL DEFAULT 0 CHECK (missing_observations >= 0)\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS corpus_generations (\n    generation_hash TEXT PRIMARY KEY,\n    parent_generation_hash TEXT REFERENCES corpus_generations(generation_hash),\n    crawl_manifest_hash TEXT NOT NULL,\n    aggregate_corpus_hash TEXT NOT NULL,\n    schema_version INTEGER NOT NULL,\n    active_style_count INTEGER NOT NULL CHECK (active_style_count >= 0),\n    quarantined_style_count INTEGER NOT NULL CHECK (quarantined_style_count >= 0),\n    tombstoned_style_count INTEGER NOT NULL CHECK (tombstoned_style_count >= 0),\n    created_at TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS current_corpus_generation (\n    singleton INTEGER PRIMARY KEY CHECK (singleton = 1),\n    generation_hash TEXT NOT NULL REFERENCES corpus_generations(generation_hash),\n    published_at TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TABLE IF NOT EXISTS vector_projection_revisions (\n    profile_id TEXT PRIMARY KEY REFERENCES embedding_profiles(profile_id) ON DELETE CASCADE,\n    revision INTEGER NOT NULL DEFAULT 0 CHECK (revision >= 0),\n    updated_at TEXT NOT NULL\n  ) STRICT;\n\n  CREATE TRIGGER IF NOT EXISTS corpus_generations_immutable_update\n  BEFORE UPDATE ON corpus_generations BEGIN\n    SELECT RAISE(ABORT, 'corpus generations are immutable');\n  END;\n\n  CREATE TRIGGER IF NOT EXISTS corpus_generations_immutable_delete\n  BEFORE DELETE ON corpus_generations BEGIN\n    SELECT RAISE(ABORT, 'corpus generations are immutable');\n  END;\n\n  CREATE INDEX IF NOT EXISTS idx_styles_active_theme\n    ON styles(theme, style_id) WHERE lifecycle_state = 'active';\n  CREATE INDEX IF NOT EXISTS idx_styles_lifecycle ON styles(lifecycle_state, style_id);\n  CREATE INDEX IF NOT EXISTS idx_style_terms_lookup ON style_terms(term_type, term, style_rowid);\n  CREATE INDEX IF NOT EXISTS idx_style_axes_lookup ON style_token_axes(axis, style_rowid);\n  CREATE INDEX IF NOT EXISTS idx_style_artifacts_path ON style_artifacts(relative_path);\n  CREATE INDEX IF NOT EXISTS idx_style_vectors_profile ON style_vectors(profile_id, style_rowid);\n  CREATE INDEX IF NOT EXISTS idx_vector_jobs_drain\n    ON style_vector_jobs(status, next_attempt_at, job_id);\n  CREATE INDEX IF NOT EXISTS idx_relationships_source\n    ON style_relationships(source_style_rowid, resolution_state);\n  CREATE INDEX IF NOT EXISTS idx_relationships_target\n    ON style_relationships(target_style_rowid) WHERE target_style_rowid IS NOT NULL;\n`;\n\n/**\n * Create or validate the current style database schema.\n *\n * @param {DatabaseSync} database - Open SQLite connection.\n * @returns {DatabaseSync} The configured connection.\n */\nexport function createSchema(database) {\n  if (!(database instanceof DatabaseSync)) {\n    throw new TypeError('database must be a node:sqlite DatabaseSync instance.');\n  }\n  database.exec('PRAGMA foreign_keys = ON; PRAGMA busy_timeout = 5000;');\n  const currentVersion = Number(database.prepare('PRAGMA user_version').get().user_version);\n  if (currentVersion > STYLE_DB_SCHEMA_VERSION) {\n    throw new Error(`Style database schema ${currentVersion} is newer than supported version ${STYLE_DB_SCHEMA_VERSION}.`);\n  }\n  if (currentVersion === 1) {\n    const indexStateColumns = database.prepare(`\n      PRAGMA table_info(style_index_state)\n    `).all().map((column) => column.name);\n    if (!indexStateColumns.includes('crawl_record_hash')) {\n      database.exec('BEGIN IMMEDIATE');\n      try {\n        database.exec(`\n          ALTER TABLE style_index_state\n          ADD COLUMN crawl_record_hash TEXT NOT NULL DEFAULT 'legacy-unverified'\n        `);\n        database.exec('COMMIT');\n      } catch (error) {\n        database.exec('ROLLBACK');\n        throw error;\n      }\n    }\n  }\n  database.exec(SCHEMA_SQL);\n  const requiredIndexStateColumns = new Set([\n    'style_rowid',\n    'artifact_hint_hash',\n    'crawl_record_hash',\n    'aggregate_hash',\n    'last_success_generation',\n    'last_success_at',\n    'missing_observations',\n  ]);\n  const actualIndexStateColumns = new Set(database.prepare(`\n    PRAGMA table_info(style_index_state)\n  `).all().map((column) => column.name));\n  if ([...requiredIndexStateColumns].some((column) => !actualIndexStateColumns.has(column))) {\n    throw new Error('Style database index-state schema is incomplete after migration.');\n  }\n  database.prepare(`\n    INSERT INTO style_db_metadata(key, value) VALUES ('schema_version', ?)\n    ON CONFLICT(key) DO UPDATE SET value = excluded.value\n  `).run(String(STYLE_DB_SCHEMA_VERSION));\n  database.exec(`PRAGMA user_version = ${STYLE_DB_SCHEMA_VERSION};`);\n  return database;\n}\n\n/**\n * Open a local style database with its versioned schema initialized.\n *\n * @param {string} [databasePath=':memory:'] - SQLite file path or in-memory marker.\n * @returns {DatabaseSync} Ready database connection.\n */\nexport function openStyleDatabase(databasePath = ':memory:') {\n  const database = new DatabaseSync(databasePath);\n  if (databasePath !== ':memory:') database.exec('PRAGMA journal_mode = WAL;');\n  return createSchema(database);\n}\n\n/**\n * Open the published generation and bind its internal identity to the pointer.\n *\n * @param {string} [databasePath] - Logical database path.\n * @returns {DatabaseSync} Generation-bound database connection.\n */\nexport function openPublishedStyleDatabase(databasePath = DEFAULT_STYLE_DATABASE_PATH) {\n  const target = resolvePublishedDatabaseTarget(databasePath);\n  const database = openStyleDatabase(target.databasePath);\n  if (target.generationHash === null) return database;\n  const openedGeneration = database.prepare(`\n    SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n  `).get()?.generation_hash;\n  if (openedGeneration !== target.generationHash) {\n    database.close();\n    const error = new Error('Published database generation does not match its pointer.');\n    error.code = 'generation-pointer-mismatch';\n    throw error;\n  }\n  return database;\n}","lineStart":1,"lineEnd":360,"totalLines":360,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/schema.mjs","time":{"start":1784623168890,"end":1784623168907}},"metadata":{"openai":{"itemId":"fc_02bf757ba310bf3e016a5f30403abc8191a0a53c4e30850d5e"}},"id":"prt_f83d47d65001BFvXVMGqIrUU2A","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV"}}
{"type":"tool_use","timestamp":1784623168982,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"read","callID":"call_PMGUvskKAn3Hp5cJ7qBWce94","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/retrieval.mjs","offset":1,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/retrieval.mjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Generation-Bound Persistent Style Retrieval                             ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: import { assembleCandidateCards } from '../_engine/cards.mjs';\n6: import { compareRawStrings, digest, stableJson } from './canonical.mjs';\n7: import { RESIDENCY } from './stage-telemetry.mjs';\n8: import {\n9:   STYLE_DB_SCHEMA_VERSION,\n10:   openPublishedStyleDatabase,\n11: } from './schema.mjs';\n12: \n13: export const FUSION_PROFILE = Object.freeze({\n14:   id: 'style-rrf-v1',\n15:   k: 60,\n16:   weights: Object.freeze({ structured: 1, fts: 1, vector: 1 }),\n17: });\n18: \n19: const MAX_QUERY_LENGTH = 1_000;\n20: const MAX_QUERY_TERMS = 12;\n21: const MAX_QUERY_VECTOR_DIMENSIONS = 16_384;\n22: const MAX_QUERY_VECTOR_BYTES = 256 * 1_024;\n23: const MAX_CANDIDATE_K = 200;\n24: const DEFAULT_CANDIDATE_K = 50;\n25: const EXACT_REUSE_LICENSES = new Set(['allowed', 'licensed', 'public-domain']);\n26: \n27: function normalizeFacet(value) {\n28:   return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n29: }\n30: \n31: function queryTerms(text) {\n32:   if (typeof text !== 'string' || text.length > MAX_QUERY_LENGTH) {\n33:     const error = new Error(`Query text must be a string of at most ${MAX_QUERY_LENGTH} characters.`);\n34:     error.code = 'invalid-query';\n35:     throw error;\n36:   }\n37:   return [...new Set(text.toLowerCase().match(/[\\p{L}\\p{N}][\\p{L}\\p{N}-]*/gu) ?? [])]\n38:     .slice(0, MAX_QUERY_TERMS).map((term) => term.slice(0, 64));\n39: }\n40: \n41: function placeholders(count) {\n42:   return Array.from({ length: count }, () => '?').join(', ');\n43: }\n44: \n45: function encodeOpaque(value) {\n46:   return Buffer.from(JSON.stringify(value), 'utf8').toString('base64url');\n47: }\n48: \n49: function decodeOpaque(value, code) {\n50:   try {\n51:     return JSON.parse(Buffer.from(value, 'base64url').toString('utf8'));\n52:   } catch (cause) {\n53:     const error = new Error(`Invalid ${code}.`, { cause });\n54:     error.code = code;\n55:     throw error;\n56:   }\n57: }\n58: \n59: function retrievalError(code, message) {\n60:   const error = new Error(message);\n61:   error.code = code;\n62:   return error;\n63: }\n64: \n65: function validateQueryVector(queryVector) {\n66:   if (queryVector === undefined || queryVector === null) return null;\n67:   if (!Array.isArray(queryVector)\n68:     || queryVector.length === 0\n69:     || queryVector.length > MAX_QUERY_VECTOR_DIMENSIONS\n70:     || queryVector.some((value) => typeof value !== 'number' || !Number.isFinite(value))) {\n71:     throw retrievalError(\n72:       'invalid-query-vector',\n73:       `queryVector must contain 1-${MAX_QUERY_VECTOR_DIMENSIONS} finite numbers.`,\n74:     );\n75:   }\n76:   if (Buffer.byteLength(JSON.stringify(queryVector), 'utf8') > MAX_QUERY_VECTOR_BYTES) {\n77:     throw retrievalError(\n78:       'invalid-query-vector',\n79:       `queryVector must serialize to at most ${MAX_QUERY_VECTOR_BYTES} bytes.`,\n80:     );\n81:   }\n82:   return queryVector;\n83: }\n84: \n85: function requestFingerprint(request, candidateK, profile) {\n86:   return digest(stableJson({\n87:     text: request.text ?? '',\n88:     requiredFacets: (request.requiredFacets ?? []).map(normalizeFacet).sort(compareRawStrings),\n89:     exclusions: (request.exclusions ?? []).map(normalizeFacet).sort(compareRawStrings),\n90:     axes: (request.axes ?? []).map(normalizeFacet).sort(compareRawStrings),\n91:     needs: (request.needs ?? []).map(normalizeFacet).sort(compareRawStrings),\n92:     usage: request.usage ?? null,\n93:     exactReuse: request.exactReuse === true,\n94:     generationHash: request.generationHash ?? null,\n95:     queryVector: request.queryVector ?? null,\n96:     vectorProfile: request.vectorProfile ?? null,\n97:     disableFts: request.disableFts === true,\n98:     disableVector: request.disableVector === true,\n99:     candidateK,\n100:     fusionProfile: profile,\n101:   }));\n102: }\n103: \n104: function loadEligibility(database, request, telemetry) {\n105:   const loadSpan = telemetry?.span('eligibility.load', RESIDENCY.NATIVE);\n106:   const rows = database.prepare(`\n107:     SELECT s.style_rowid, s.style_id, s.slug, s.title, s.thesis, s.theme,\n108:       s.industry, s.aggregate_hash, s.retrieval_hash, p.status AS provenance_status,\n109:       p.source_url, p.original_url, p.screenshot_url, p.source_uuid, p.captured_at,\n110:       p.license_status, p.rights_known, p.evidence_scope_json\n111:     FROM styles s\n112:     JOIN style_provenance p ON p.style_rowid = s.style_rowid\n113:     WHERE s.lifecycle_state = 'active'\n114:     ORDER BY s.style_id ASC\n115:   `).all();\n116:   loadSpan?.end(rows.length);\n117:   if (rows.length === 0) {\n118:     return { eligible: [], rejectedCount: 0, activeCount: 0 };\n119:   }\n120:   const ids = rows.map((row) => row.style_rowid);\n121:   const bindings = placeholders(ids.length);\n122:   const facetsLoadSpan = telemetry?.span('eligibility.facets.load', RESIDENCY.NATIVE);\n123:   const termRows = database.prepare(`\n124:     SELECT style_rowid, term FROM style_terms WHERE style_rowid IN (${bindings})\n125:   `).all(...ids);\n126:   const axisRows = database.prepare(`\n127:     SELECT style_rowid, axis FROM style_token_axes WHERE style_rowid IN (${bindings})\n128:   `).all(...ids);\n129:   const sectionRows = database.prepare(`\n130:     SELECT style_rowid, name FROM style_sections WHERE style_rowid IN (${bindings})\n131:   `).all(...ids);\n132:   facetsLoadSpan?.end(termRows.length + axisRows.length + sectionRows.length);\n133:   const facetsAssembleSpan = telemetry?.span('eligibility.facets.assemble', RESIDENCY.JS_RESIDENT);\n134:   const facetsById = new Map(ids.map((id) => [Number(id), new Set()]));\n135:   for (const term of termRows) {\n136:     facetsById.get(Number(term.style_rowid)).add(normalizeFacet(term.term));\n137:   }\n138:   for (const axis of axisRows) {\n139:     facetsById.get(Number(axis.style_rowid)).add(normalizeFacet(axis.axis));\n140:   }\n141:   for (const section of sectionRows) {\n142:     facetsById.get(Number(section.style_rowid)).add(normalizeFacet(section.name));\n143:   }\n144:   facetsAssembleSpan?.end(rows.length);\n145:   const filterSpan = telemetry?.span('eligibility.filter', RESIDENCY.JS_RESIDENT);\n146:   const required = (request.requiredFacets ?? []).map(normalizeFacet).filter(Boolean);\n147:   const excluded = (request.exclusions ?? []).map(normalizeFacet).filter(Boolean);\n148:   const exactReuse = request.usage === 'exact-reuse' || request.exactReuse === true;\n149:   const eligible = rows.filter((row) => {\n150:     const facets = facetsById.get(Number(row.style_rowid));\n151:     if (row.theme) facets.add(normalizeFacet(row.theme));\n152:     if (row.license_status === 'restricted') facets.add('license-restricted');\n153:     return required.every((facet) => facets.has(facet))\n154:       && excluded.every((facet) => !facets.has(facet))\n155:       && row.provenance_status === 'known'\n156:       && (!exactReuse || (\n157:         Number(row.rights_known) === 1 && EXACT_REUSE_LICENSES.has(row.license_status)\n158:       ));\n159:   }).map((row) => ({\n160:     ...row,\n161:     facets: facetsById.get(Number(row.style_rowid)),\n162:     matchedRequiredFacets: required,\n163:   }));\n164:   filterSpan?.end(eligible.length);\n165:   return { eligible, rejectedCount: rows.length - eligible.length, activeCount: rows.length };\n166: }\n167: \n168: function structuredLane(database, eligible, request, candidateK, telemetry) {\n169:   const axes = new Set((request.axes ?? []).map(normalizeFacet));\n170:   const needs = new Set((request.needs ?? []).map(normalizeFacet));\n171:   const ids = eligible.map((row) => row.style_rowid);\n172:   if (ids.length === 0) return [];\n173:   const loadSpan = telemetry?.span('lane.structured.load', RESIDENCY.NATIVE);\n174:   const axisRows = database.prepare(`\n175:     SELECT style_rowid, axis FROM style_token_axes\n176:     WHERE style_rowid IN (${placeholders(ids.length)})\n177:   `).all(...ids);\n178:   const capabilities = database.prepare(`\n179:     SELECT style_rowid, term FROM style_terms\n180:     WHERE term_type = 'capability' AND style_rowid IN (${placeholders(ids.length)})\n181:   `).all(...ids);\n182:   loadSpan?.end(axisRows.length + capabilities.length);\n183:   const rankSpan = telemetry?.span('lane.structured.rank', RESIDENCY.JS_RESIDENT);\n184:   const axisById = new Map(ids.map((id) => [Number(id), new Set()]));\n185:   const capabilitiesById = new Map(ids.map((id) => [Number(id), new Set()]));\n186:   for (const row of axisRows) axisById.get(Number(row.style_rowid)).add(normalizeFacet(row.axis));\n187:   for (const row of capabilities) {\n188:     capabilitiesById.get(Number(row.style_rowid)).add(normalizeFacet(row.term));\n189:   }\n190:   const ranked = eligible.map((row) => ({\n191:     id: row.style_id,\n192:     rawScore: row.matchedRequiredFacets.length * 10\n193:       + [...axes].filter((axis) => axisById.get(Number(row.style_rowid)).has(axis)).length * 2\n194:       + [...needs].filter((need) => capabilitiesById.get(Number(row.style_rowid)).has(need)).length,\n195:   })).sort((left, right) => right.rawScore - left.rawScore\n196:     || compareRawStrings(left.id, right.id)).slice(0, candidateK);\n197:   rankSpan?.end(ranked.length);\n198:   return ranked;\n199: }\n200: \n201: function ftsLane(database, eligible, request, candidateK, telemetry) {\n202:   const terms = queryTerms(request.text ?? '');\n203:   if (terms.length === 0) return [];\n204:   const ids = eligible.map((row) => row.style_rowid);\n205:   if (ids.length === 0) return [];\n206:   const expression = terms.map((term) => `\"${term.replaceAll('\"', '\"\"')}\"`).join(' OR ');\n207:   const span = telemetry?.span('lane.fts', RESIDENCY.NATIVE);\n208:   const ranked = database.prepare(`\n209:     SELECT s.style_id AS id, bm25(style_fts, 5.0, 3.0, 2.0, 2.0, 1.0, 1.0) AS raw_score\n210:     FROM style_fts\n211:     JOIN styles s ON s.style_rowid = style_fts.rowid\n212:     WHERE style_fts MATCH ? AND s.style_rowid IN (${placeholders(ids.length)})\n213:     ORDER BY raw_score ASC, s.style_id ASC LIMIT ?\n214:   `).all(expression, ...ids, candidateK).map((row) => ({\n215:     id: row.id,\n216:     rawScore: Number(row.raw_score),\n217:   }));\n218:   span?.end(ranked.length);\n219:   return ranked;\n220: }\n221: \n222: function cosine(left, right) {\n223:   if (left.length !== right.length || left.length === 0) return null;\n224:   let dot = 0;\n225:   let leftNorm = 0;\n226:   let rightNorm = 0;\n227:   for (let index = 0; index < left.length; index += 1) {\n228:     dot += left[index] * right[index];\n229:     leftNorm += left[index] ** 2;\n230:     rightNorm += right[index] ** 2;\n231:   }\n232:   if (leftNorm === 0 || rightNorm === 0) return null;\n233:   return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n234: }\n235: \n236: function vectorLane(database, eligible, request, candidateK, telemetry) {\n237:   if (!Array.isArray(request.queryVector) || !request.vectorProfile) return [];\n238:   const queryVector = request.queryVector;\n239:   const ids = eligible.map((row) => row.style_rowid);\n240:   if (ids.length === 0) return [];\n241:   const fetchSpan = telemetry?.span('lane.vector.fetch', RESIDENCY.NATIVE);\n242:   const rows = database.prepare(`\n243:     SELECT s.style_id AS id, v.vector_json\n244:     FROM style_vectors v\n245:     JOIN styles s ON s.style_rowid = v.style_rowid\n246:       AND s.retrieval_hash = v.retrieval_hash\n247:       AND s.lifecycle_state = 'active'\n248:     WHERE v.profile_id = ? AND v.style_rowid IN (${placeholders(ids.length)})\n249:   `).all(request.vectorProfile, ...ids);\n250:   fetchSpan?.end(rows.length);\n251:   const computeSpan = telemetry?.span('lane.vector.cosine', RESIDENCY.JS_RESIDENT);\n252:   const ranked = rows.map((row) => ({\n253:     id: row.id,\n254:     rawScore: cosine(queryVector, JSON.parse(row.vector_json)),\n255:   })).filter((row) => row.rawScore !== null)\n256:     .sort((left, right) => right.rawScore - left.rawScore\n257:       || compareRawStrings(left.id, right.id)).slice(0, candidateK);\n258:   computeSpan?.end(ranked.length);\n259:   return ranked;\n260: }\n261: \n262: /**\n263:  * Fuse ranked channels with a versioned weighted reciprocal-rank formula.\n264:  *\n265:  * @param {Object<string,Object[]>} lanes - Ordered candidate lists by channel.\n266:  * @param {Object} [profile=FUSION_PROFILE] - RRF k and channel weights.\n267:  * @returns {Object[]} Deterministically fused candidates with attribution.\n268:  */\n269: export function weightedRrf(lanes, profile = FUSION_PROFILE) {\n270:   const fused = new Map();\n271:   for (const [channel, results] of Object.entries(lanes)) {\n272:     const weight = Number(profile.weights[channel] ?? 0);\n273:     if (!Number.isFinite(weight) || weight <= 0) continue;\n274:     for (const [index, result] of results.entries()) {\n275:       const rank = index + 1;\n276:       const contribution = weight / (profile.k + rank);\n277:       const existing = fused.get(result.id) ?? {\n278:         id: result.id,\n279:         fusedScore: 0,\n280:         sourceRanks: {},\n281:         channelContributions: {},\n282:         rawScores: {},\n283:       };\n284:       existing.fusedScore += contribution;\n285:       existing.sourceRanks[channel] = rank;\n286:       existing.channelContributions[channel] = contribution;\n287:       existing.rawScores[channel] = result.rawScore;\n288:       fused.set(result.id, existing);\n289:     }\n290:   }\n291:   return [...fused.values()].sort((left, right) => (\n292:     right.fusedScore - left.fusedScore || compareRawStrings(left.id, right.id)\n293:   ));\n294: }\n295: \n296: function validateGeneration(database, telemetry) {\n297:   const readSpan = telemetry?.span('generation.read', RESIDENCY.NATIVE);\n298:   const generation = database.prepare(`\n299:     SELECT g.* FROM current_corpus_generation p\n300:     JOIN corpus_generations g ON g.generation_hash = p.generation_hash\n301:     WHERE p.singleton = 1\n302:   `).get();\n303:   if (!generation || Number(generation.schema_version) !== STYLE_DB_SCHEMA_VERSION) {\n304:     throw retrievalError('generation-unavailable', 'No valid published style generation exists.');\n305:   }\n306:   const activeRows = database.prepare(`\n307:     SELECT style_id, aggregate_hash FROM styles\n308:     WHERE lifecycle_state = 'active' ORDER BY style_id ASC\n309:   `).all();\n310:   readSpan?.end(activeRows.length);\n311:   const verifySpan = telemetry?.span('generation.verify', RESIDENCY.JS_RESIDENT);\n312:   const aggregateHash = digest(\n313:     `style-corpus-aggregate-v1\\0${activeRows.map((row) => (\n314:       `${row.style_id}\\0${row.aggregate_hash}\\n`\n315:     )).join('')}`,\n316:   );\n317:   if (activeRows.length !== Number(generation.active_style_count)\n318:     || aggregateHash !== generation.aggregate_corpus_hash) {\n319:     throw retrievalError('generation-invalid', 'Published generation does not match indexed style state.');\n320:   }\n321:   verifySpan?.end(activeRows.length);\n322:   return generation;\n323: }\n324: \n325: function loadCardStyle(database, row) {\n326:   const axes = database.prepare(`\n327:     SELECT axis, token_count FROM style_token_axes\n328:     WHERE style_rowid = ? ORDER BY axis ASC\n329:   `).all(row.style_rowid).map((axis) => ({ axis: axis.axis, count: Number(axis.token_count) }));\n330:   const capabilities = database.prepare(`\n331:     SELECT term FROM style_terms WHERE style_rowid = ? AND term_type = 'capability'\n332:     ORDER BY term ASC\n333:   `).all(row.style_rowid).map((term) => term.term);\n334:   const sections = database.prepare(`\n335:     SELECT name FROM style_sections WHERE style_rowid = ? ORDER BY ordinal ASC\n336:   `).all(row.style_rowid).map((section) => section.name);\n337:   const estimatedHydrationBytes = Number(database.prepare(`\n338:     SELECT COALESCE(SUM(byte_length), 0) AS bytes FROM style_artifacts\n339:     WHERE style_rowid = ? AND role IN ('design', 'source', 'tokens')\n340:   `).get(row.style_rowid).bytes);\n341:   return {\n342:     id: row.style_id,\n343:     title: row.title,\n344:     thesis: row.thesis,\n345:     contentHash: row.aggregate_hash,\n346:     capabilities,\n347:     availableSections: sections,\n348:     tokenAxes: axes,\n349:     provenance: {\n350:       status: row.provenance_status,\n351:       sourceUrl: row.source_url,\n352:       originalUrl: row.original_url,\n353:       screenshotUrl: row.screenshot_url,\n354:       uuid: row.source_uuid,\n355:       capturedAt: row.captured_at,\n356:       licenseStatus: row.license_status,\n357:       rightsKnown: Number(row.rights_known) === 1,\n358:       evidenceScope: JSON.parse(row.evidence_scope_json),\n359:     },\n360:     estimatedHydrationBytes,\n361:   };\n362: }\n363: \n364: /**\n365:  * Query one immutable generation snapshot without walking the source corpus.\n366:  *\n367:  * @param {Object} request - Eligibility, ranking, and paging request.\n368:  * @param {Object} options - Database connection or path.\n369:  * @returns {Object} Generation-stamped cards, cursor, and channel evidence.\n370:  */\n371: export function queryPersistentStyles(request = {}, options = {}) {\n372:   validateQueryVector(request.queryVector);\n373:   const database = options.database ?? openPublishedStyleDatabase(options.databasePath);\n374:   const ownsDatabase = !options.database;\n375:   const telemetry = options.telemetry;\n376:   const candidateK = Math.max(1, Math.min(MAX_CANDIDATE_K, request.candidateK ?? DEFAULT_CANDIDATE_K));\n377:   const fingerprintSpan = telemetry?.span('request.fingerprint', RESIDENCY.JS_RESIDENT);\n378:   const fingerprint = requestFingerprint(request, candidateK, FUSION_PROFILE);\n379:   fingerprintSpan?.end(1);\n380:   const beginSpan = telemetry?.span('transaction.begin', RESIDENCY.NATIVE);\n381:   database.exec('BEGIN');\n382:   beginSpan?.end(1);\n383:   try {\n384:     const generation = validateGeneration(database, telemetry);\n385:     if (request.generationHash !== undefined\n386:       && request.generationHash !== generation.generation_hash) {\n387:       throw retrievalError(\n388:         'generation-mismatch',\n389:         'Requested generation is not the published generation.',\n390:       );\n391:     }\n392:     const vectorRevisionSpan = telemetry?.span('generation.vector-revision', RESIDENCY.NATIVE);\n393:     const vectorRevision = request.vectorProfile ? Number(database.prepare(`\n394:       SELECT revision FROM vector_projection_revisions WHERE profile_id = ?\n395:     `).get(request.vectorProfile)?.revision ?? 0) : 0;\n396:     vectorRevisionSpan?.end(request.vectorProfile ? 1 : 0);\n397:     let cursor = null;\n398:     if (request.cursor) {\n399:       cursor = decodeOpaque(request.cursor, 'invalid-cursor');\n400:       if (cursor.generationHash !== generation.generation_hash) {\n401:         throw retrievalError('generation-mismatch', 'Cursor belongs to another generation.');\n402:       }\n403:       if (cursor.queryFingerprint !== fingerprint\n404:         || cursor.fusionProfile !== FUSION_PROFILE.id\n405:         || cursor.candidateK !== candidateK\n406:         || cursor.vectorRevision !== vectorRevision) {\n407:         throw retrievalError('invalid-cursor', 'Cursor does not match this retrieval request.');\n408:       }\n409:     }\n410:     const eligibility = loadEligibility(database, request, telemetry);\n411:     const channelHealth = {\n412:       structured: { state: 'healthy' },\n413:       fts: { state: request.disableFts === true ? 'disabled' : 'healthy' },\n414:       vector: { state: request.disableVector === true ? 'disabled' : 'healthy' },\n415:     };\n416:     const lanes = {\n417:       structured: structuredLane(database, eligibility.eligible, request, candidateK, telemetry),\n418:     };\n419:     if (!request.disableFts) {\n420:       try {\n421:         lanes.fts = ftsLane(database, eligibility.eligible, request, candidateK, telemetry);\n422:       } catch (error) {\n423:         if (error.code === 'invalid-query') throw error;\n424:         channelHealth.fts = { state: 'failed', reason: String(error.message ?? error) };\n425:       }\n426:     }\n427:     if (!request.disableVector) {\n428:       try {\n429:         lanes.vector = vectorLane(database, eligibility.eligible, request, candidateK, telemetry);\n430:       } catch (error) {\n431:         if (error.code === 'invalid-query-vector') throw error;\n432:         channelHealth.vector = { state: 'failed', reason: String(error.message ?? error) };\n433:       }\n434:     }\n435:     const hasFts = Array.isArray(lanes.fts) && lanes.fts.length > 0;\n436:     const hasVector = Array.isArray(lanes.vector) && lanes.vector.length > 0;\n437:     const rankingMode = hasFts && hasVector\n438:       ? 'hybrid'\n439:       : hasFts\n440:         ? 'structured+fts'\n441:         : hasVector\n442:           ? 'structured+vector'\n443:           : 'structured-only';\n444:     const fusionSpan = telemetry?.span('fusion.rrf', RESIDENCY.JS_RESIDENT);\n445:     let fused = weightedRrf(lanes);\n446:     if (cursor) {\n447:       fused = fused.filter((entry) => entry.fusedScore < cursor.lastScore\n448:         || (entry.fusedScore === cursor.lastScore\n449:           && compareRawStrings(entry.id, cursor.lastId) > 0));\n450:     }\n451:     fusionSpan?.end(fused.length);\n452:     const limit = Math.max(0, Math.min(5, Number.isInteger(request.limit) ? request.limit : 5));\n453:     const page = fused.slice(0, limit);\n454:     const rowById = new Map(eligibility.eligible.map((row) => [row.style_id, row]));\n455:     const hydrateSpan = telemetry?.span('cards.hydrate', RESIDENCY.NATIVE);\n456:     const ranked = page.map((entry) => ({\n457:       style: loadCardStyle(database, rowById.get(entry.id)),\n458:       score: {\n459:         deterministic: Number(entry.rawScores.structured ?? 0),\n460:         lexical: Number(entry.channelContributions.fts ?? 0),\n461:         total: Number(entry.fusedScore.toFixed(12)),\n462:       },\n463:     }));\n464:     hydrateSpan?.end(ranked.length);\n465:     const assembleSpan = telemetry?.span('cards.assemble', RESIDENCY.JS_RESIDENT);\n466:     const cards = assembleCandidateCards(ranked, generation.generation_hash, request);\n467:     assembleSpan?.end(cards.length);\n468:     const encodeSpan = telemetry?.span('cards.attribution.encode', RESIDENCY.JS_RESIDENT);\n469:     const attributions = Object.fromEntries(page.map((entry) => [entry.id, {\n470:       sourceRanks: entry.sourceRanks,\n471:       channelContributions: entry.channelContributions,\n472:       rawScores: entry.rawScores,\n473:       hydrationToken: encodeOpaque({\n474:         generationHash: generation.generation_hash,\n475:         id: entry.id,\n476:         contentHash: rowById.get(entry.id).aggregate_hash,\n477:       }),\n478:     }]));\n479:     const last = page.at(-1);\n480:     const nextCursor = last && fused.length > page.length ? encodeOpaque({\n481:       generationHash: generation.generation_hash,\n482:       queryFingerprint: fingerprint,\n483:       fusionProfile: FUSION_PROFILE.id,\n484:       candidateK,\n485:       vectorRevision,\n486:       lastScore: last.fusedScore,\n487:       lastId: last.id,\n488:     }) : null;\n489:     encodeSpan?.end(page.length);\n490:     const commitSpan = telemetry?.span('transaction.commit', RESIDENCY.NATIVE);\n491:     database.exec('COMMIT');\n492:     commitSpan?.end(1);\n493:     return {\n494:       ok: true,\n495:       generationHash: generation.generation_hash,\n496:       degraded: rankingMode !== 'hybrid',\n497:       rankingMode,\n498:       queryFingerprint: fingerprint,\n499:       fusionProfile: FUSION_PROFILE.id,\n500:       candidateK,\n501:       vectorRevision,\n502:       channelHealth,\n503:       eligibility: {\n504:         eligibleCount: eligibility.eligible.length,\n505:         rejectedCount: eligibility.rejectedCount,\n506:       },\n507:       cards,\n508:       attributions,\n509:       nextCursor,\n510:     };\n511:   } catch (error) {\n512:     database.exec('ROLLBACK');\n513:     throw error;\n514:   } finally {\n515:     if (ownsDatabase) database.close();\n516:   }\n517: }\n518: \n519: export const retrievalInternals = Object.freeze({\n520:   decodeOpaque,\n\n(Showing lines 1-520 of 524. Use offset=521 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Generation-Bound Persistent Style Retrieval                             ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { assembleCandidateCards } from '../_engine/cards.mjs';\nimport { compareRawStrings, digest, stableJson } from './canonical.mjs';\nimport { RESIDENCY } from './stage-telemetry.mjs';\nimport {\n  STYLE_DB_SCHEMA_VERSION,\n  openPublishedStyleDatabase,\n} from './schema.mjs';\n\nexport const FUSION_PROFILE = Object.freeze({\n  id: 'style-rrf-v1',\n  k: 60,\n  weights: Object.freeze({ structured: 1, fts: 1, vector: 1 }),\n});\n\nconst MAX_QUERY_LENGTH = 1_000;\nconst MAX_QUERY_TERMS = 12;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/retrieval.mjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Generation-Bound Persistent Style Retrieval                             ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { assembleCandidateCards } from '../_engine/cards.mjs';\nimport { compareRawStrings, digest, stableJson } from './canonical.mjs';\nimport { RESIDENCY } from './stage-telemetry.mjs';\nimport {\n  STYLE_DB_SCHEMA_VERSION,\n  openPublishedStyleDatabase,\n} from './schema.mjs';\n\nexport const FUSION_PROFILE = Object.freeze({\n  id: 'style-rrf-v1',\n  k: 60,\n  weights: Object.freeze({ structured: 1, fts: 1, vector: 1 }),\n});\n\nconst MAX_QUERY_LENGTH = 1_000;\nconst MAX_QUERY_TERMS = 12;\nconst MAX_QUERY_VECTOR_DIMENSIONS = 16_384;\nconst MAX_QUERY_VECTOR_BYTES = 256 * 1_024;\nconst MAX_CANDIDATE_K = 200;\nconst DEFAULT_CANDIDATE_K = 50;\nconst EXACT_REUSE_LICENSES = new Set(['allowed', 'licensed', 'public-domain']);\n\nfunction normalizeFacet(value) {\n  return String(value ?? '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '-');\n}\n\nfunction queryTerms(text) {\n  if (typeof text !== 'string' || text.length > MAX_QUERY_LENGTH) {\n    const error = new Error(`Query text must be a string of at most ${MAX_QUERY_LENGTH} characters.`);\n    error.code = 'invalid-query';\n    throw error;\n  }\n  return [...new Set(text.toLowerCase().match(/[\\p{L}\\p{N}][\\p{L}\\p{N}-]*/gu) ?? [])]\n    .slice(0, MAX_QUERY_TERMS).map((term) => term.slice(0, 64));\n}\n\nfunction placeholders(count) {\n  return Array.from({ length: count }, () => '?').join(', ');\n}\n\nfunction encodeOpaque(value) {\n  return Buffer.from(JSON.stringify(value), 'utf8').toString('base64url');\n}\n\nfunction decodeOpaque(value, code) {\n  try {\n    return JSON.parse(Buffer.from(value, 'base64url').toString('utf8'));\n  } catch (cause) {\n    const error = new Error(`Invalid ${code}.`, { cause });\n    error.code = code;\n    throw error;\n  }\n}\n\nfunction retrievalError(code, message) {\n  const error = new Error(message);\n  error.code = code;\n  return error;\n}\n\nfunction validateQueryVector(queryVector) {\n  if (queryVector === undefined || queryVector === null) return null;\n  if (!Array.isArray(queryVector)\n    || queryVector.length === 0\n    || queryVector.length > MAX_QUERY_VECTOR_DIMENSIONS\n    || queryVector.some((value) => typeof value !== 'number' || !Number.isFinite(value))) {\n    throw retrievalError(\n      'invalid-query-vector',\n      `queryVector must contain 1-${MAX_QUERY_VECTOR_DIMENSIONS} finite numbers.`,\n    );\n  }\n  if (Buffer.byteLength(JSON.stringify(queryVector), 'utf8') > MAX_QUERY_VECTOR_BYTES) {\n    throw retrievalError(\n      'invalid-query-vector',\n      `queryVector must serialize to at most ${MAX_QUERY_VECTOR_BYTES} bytes.`,\n    );\n  }\n  return queryVector;\n}\n\nfunction requestFingerprint(request, candidateK, profile) {\n  return digest(stableJson({\n    text: request.text ?? '',\n    requiredFacets: (request.requiredFacets ?? []).map(normalizeFacet).sort(compareRawStrings),\n    exclusions: (request.exclusions ?? []).map(normalizeFacet).sort(compareRawStrings),\n    axes: (request.axes ?? []).map(normalizeFacet).sort(compareRawStrings),\n    needs: (request.needs ?? []).map(normalizeFacet).sort(compareRawStrings),\n    usage: request.usage ?? null,\n    exactReuse: request.exactReuse === true,\n    generationHash: request.generationHash ?? null,\n    queryVector: request.queryVector ?? null,\n    vectorProfile: request.vectorProfile ?? null,\n    disableFts: request.disableFts === true,\n    disableVector: request.disableVector === true,\n    candidateK,\n    fusionProfile: profile,\n  }));\n}\n\nfunction loadEligibility(database, request, telemetry) {\n  const loadSpan = telemetry?.span('eligibility.load', RESIDENCY.NATIVE);\n  const rows = database.prepare(`\n    SELECT s.style_rowid, s.style_id, s.slug, s.title, s.thesis, s.theme,\n      s.industry, s.aggregate_hash, s.retrieval_hash, p.status AS provenance_status,\n      p.source_url, p.original_url, p.screenshot_url, p.source_uuid, p.captured_at,\n      p.license_status, p.rights_known, p.evidence_scope_json\n    FROM styles s\n    JOIN style_provenance p ON p.style_rowid = s.style_rowid\n    WHERE s.lifecycle_state = 'active'\n    ORDER BY s.style_id ASC\n  `).all();\n  loadSpan?.end(rows.length);\n  if (rows.length === 0) {\n    return { eligible: [], rejectedCount: 0, activeCount: 0 };\n  }\n  const ids = rows.map((row) => row.style_rowid);\n  const bindings = placeholders(ids.length);\n  const facetsLoadSpan = telemetry?.span('eligibility.facets.load', RESIDENCY.NATIVE);\n  const termRows = database.prepare(`\n    SELECT style_rowid, term FROM style_terms WHERE style_rowid IN (${bindings})\n  `).all(...ids);\n  const axisRows = database.prepare(`\n    SELECT style_rowid, axis FROM style_token_axes WHERE style_rowid IN (${bindings})\n  `).all(...ids);\n  const sectionRows = database.prepare(`\n    SELECT style_rowid, name FROM style_sections WHERE style_rowid IN (${bindings})\n  `).all(...ids);\n  facetsLoadSpan?.end(termRows.length + axisRows.length + sectionRows.length);\n  const facetsAssembleSpan = telemetry?.span('eligibility.facets.assemble', RESIDENCY.JS_RESIDENT);\n  const facetsById = new Map(ids.map((id) => [Number(id), new Set()]));\n  for (const term of termRows) {\n    facetsById.get(Number(term.style_rowid)).add(normalizeFacet(term.term));\n  }\n  for (const axis of axisRows) {\n    facetsById.get(Number(axis.style_rowid)).add(normalizeFacet(axis.axis));\n  }\n  for (const section of sectionRows) {\n    facetsById.get(Number(section.style_rowid)).add(normalizeFacet(section.name));\n  }\n  facetsAssembleSpan?.end(rows.length);\n  const filterSpan = telemetry?.span('eligibility.filter', RESIDENCY.JS_RESIDENT);\n  const required = (request.requiredFacets ?? []).map(normalizeFacet).filter(Boolean);\n  const excluded = (request.exclusions ?? []).map(normalizeFacet).filter(Boolean);\n  const exactReuse = request.usage === 'exact-reuse' || request.exactReuse === true;\n  const eligible = rows.filter((row) => {\n    const facets = facetsById.get(Number(row.style_rowid));\n    if (row.theme) facets.add(normalizeFacet(row.theme));\n    if (row.license_status === 'restricted') facets.add('license-restricted');\n    return required.every((facet) => facets.has(facet))\n      && excluded.every((facet) => !facets.has(facet))\n      && row.provenance_status === 'known'\n      && (!exactReuse || (\n        Number(row.rights_known) === 1 && EXACT_REUSE_LICENSES.has(row.license_status)\n      ));\n  }).map((row) => ({\n    ...row,\n    facets: facetsById.get(Number(row.style_rowid)),\n    matchedRequiredFacets: required,\n  }));\n  filterSpan?.end(eligible.length);\n  return { eligible, rejectedCount: rows.length - eligible.length, activeCount: rows.length };\n}\n\nfunction structuredLane(database, eligible, request, candidateK, telemetry) {\n  const axes = new Set((request.axes ?? []).map(normalizeFacet));\n  const needs = new Set((request.needs ?? []).map(normalizeFacet));\n  const ids = eligible.map((row) => row.style_rowid);\n  if (ids.length === 0) return [];\n  const loadSpan = telemetry?.span('lane.structured.load', RESIDENCY.NATIVE);\n  const axisRows = database.prepare(`\n    SELECT style_rowid, axis FROM style_token_axes\n    WHERE style_rowid IN (${placeholders(ids.length)})\n  `).all(...ids);\n  const capabilities = database.prepare(`\n    SELECT style_rowid, term FROM style_terms\n    WHERE term_type = 'capability' AND style_rowid IN (${placeholders(ids.length)})\n  `).all(...ids);\n  loadSpan?.end(axisRows.length + capabilities.length);\n  const rankSpan = telemetry?.span('lane.structured.rank', RESIDENCY.JS_RESIDENT);\n  const axisById = new Map(ids.map((id) => [Number(id), new Set()]));\n  const capabilitiesById = new Map(ids.map((id) => [Number(id), new Set()]));\n  for (const row of axisRows) axisById.get(Number(row.style_rowid)).add(normalizeFacet(row.axis));\n  for (const row of capabilities) {\n    capabilitiesById.get(Number(row.style_rowid)).add(normalizeFacet(row.term));\n  }\n  const ranked = eligible.map((row) => ({\n    id: row.style_id,\n    rawScore: row.matchedRequiredFacets.length * 10\n      + [...axes].filter((axis) => axisById.get(Number(row.style_rowid)).has(axis)).length * 2\n      + [...needs].filter((need) => capabilitiesById.get(Number(row.style_rowid)).has(need)).length,\n  })).sort((left, right) => right.rawScore - left.rawScore\n    || compareRawStrings(left.id, right.id)).slice(0, candidateK);\n  rankSpan?.end(ranked.length);\n  return ranked;\n}\n\nfunction ftsLane(database, eligible, request, candidateK, telemetry) {\n  const terms = queryTerms(request.text ?? '');\n  if (terms.length === 0) return [];\n  const ids = eligible.map((row) => row.style_rowid);\n  if (ids.length === 0) return [];\n  const expression = terms.map((term) => `\"${term.replaceAll('\"', '\"\"')}\"`).join(' OR ');\n  const span = telemetry?.span('lane.fts', RESIDENCY.NATIVE);\n  const ranked = database.prepare(`\n    SELECT s.style_id AS id, bm25(style_fts, 5.0, 3.0, 2.0, 2.0, 1.0, 1.0) AS raw_score\n    FROM style_fts\n    JOIN styles s ON s.style_rowid = style_fts.rowid\n    WHERE style_fts MATCH ? AND s.style_rowid IN (${placeholders(ids.length)})\n    ORDER BY raw_score ASC, s.style_id ASC LIMIT ?\n  `).all(expression, ...ids, candidateK).map((row) => ({\n    id: row.id,\n    rawScore: Number(row.raw_score),\n  }));\n  span?.end(ranked.length);\n  return ranked;\n}\n\nfunction cosine(left, right) {\n  if (left.length !== right.length || left.length === 0) return null;\n  let dot = 0;\n  let leftNorm = 0;\n  let rightNorm = 0;\n  for (let index = 0; index < left.length; index += 1) {\n    dot += left[index] * right[index];\n    leftNorm += left[index] ** 2;\n    rightNorm += right[index] ** 2;\n  }\n  if (leftNorm === 0 || rightNorm === 0) return null;\n  return dot / (Math.sqrt(leftNorm) * Math.sqrt(rightNorm));\n}\n\nfunction vectorLane(database, eligible, request, candidateK, telemetry) {\n  if (!Array.isArray(request.queryVector) || !request.vectorProfile) return [];\n  const queryVector = request.queryVector;\n  const ids = eligible.map((row) => row.style_rowid);\n  if (ids.length === 0) return [];\n  const fetchSpan = telemetry?.span('lane.vector.fetch', RESIDENCY.NATIVE);\n  const rows = database.prepare(`\n    SELECT s.style_id AS id, v.vector_json\n    FROM style_vectors v\n    JOIN styles s ON s.style_rowid = v.style_rowid\n      AND s.retrieval_hash = v.retrieval_hash\n      AND s.lifecycle_state = 'active'\n    WHERE v.profile_id = ? AND v.style_rowid IN (${placeholders(ids.length)})\n  `).all(request.vectorProfile, ...ids);\n  fetchSpan?.end(rows.length);\n  const computeSpan = telemetry?.span('lane.vector.cosine', RESIDENCY.JS_RESIDENT);\n  const ranked = rows.map((row) => ({\n    id: row.id,\n    rawScore: cosine(queryVector, JSON.parse(row.vector_json)),\n  })).filter((row) => row.rawScore !== null)\n    .sort((left, right) => right.rawScore - left.rawScore\n      || compareRawStrings(left.id, right.id)).slice(0, candidateK);\n  computeSpan?.end(ranked.length);\n  return ranked;\n}\n\n/**\n * Fuse ranked channels with a versioned weighted reciprocal-rank formula.\n *\n * @param {Object<string,Object[]>} lanes - Ordered candidate lists by channel.\n * @param {Object} [profile=FUSION_PROFILE] - RRF k and channel weights.\n * @returns {Object[]} Deterministically fused candidates with attribution.\n */\nexport function weightedRrf(lanes, profile = FUSION_PROFILE) {\n  const fused = new Map();\n  for (const [channel, results] of Object.entries(lanes)) {\n    const weight = Number(profile.weights[channel] ?? 0);\n    if (!Number.isFinite(weight) || weight <= 0) continue;\n    for (const [index, result] of results.entries()) {\n      const rank = index + 1;\n      const contribution = weight / (profile.k + rank);\n      const existing = fused.get(result.id) ?? {\n        id: result.id,\n        fusedScore: 0,\n        sourceRanks: {},\n        channelContributions: {},\n        rawScores: {},\n      };\n      existing.fusedScore += contribution;\n      existing.sourceRanks[channel] = rank;\n      existing.channelContributions[channel] = contribution;\n      existing.rawScores[channel] = result.rawScore;\n      fused.set(result.id, existing);\n    }\n  }\n  return [...fused.values()].sort((left, right) => (\n    right.fusedScore - left.fusedScore || compareRawStrings(left.id, right.id)\n  ));\n}\n\nfunction validateGeneration(database, telemetry) {\n  const readSpan = telemetry?.span('generation.read', RESIDENCY.NATIVE);\n  const generation = database.prepare(`\n    SELECT g.* FROM current_corpus_generation p\n    JOIN corpus_generations g ON g.generation_hash = p.generation_hash\n    WHERE p.singleton = 1\n  `).get();\n  if (!generation || Number(generation.schema_version) !== STYLE_DB_SCHEMA_VERSION) {\n    throw retrievalError('generation-unavailable', 'No valid published style generation exists.');\n  }\n  const activeRows = database.prepare(`\n    SELECT style_id, aggregate_hash FROM styles\n    WHERE lifecycle_state = 'active' ORDER BY style_id ASC\n  `).all();\n  readSpan?.end(activeRows.length);\n  const verifySpan = telemetry?.span('generation.verify', RESIDENCY.JS_RESIDENT);\n  const aggregateHash = digest(\n    `style-corpus-aggregate-v1\\0${activeRows.map((row) => (\n      `${row.style_id}\\0${row.aggregate_hash}\\n`\n    )).join('')}`,\n  );\n  if (activeRows.length !== Number(generation.active_style_count)\n    || aggregateHash !== generation.aggregate_corpus_hash) {\n    throw retrievalError('generation-invalid', 'Published generation does not match indexed style state.');\n  }\n  verifySpan?.end(activeRows.length);\n  return generation;\n}\n\nfunction loadCardStyle(database, row) {\n  const axes = database.prepare(`\n    SELECT axis, token_count FROM style_token_axes\n    WHERE style_rowid = ? ORDER BY axis ASC\n  `).all(row.style_rowid).map((axis) => ({ axis: axis.axis, count: Number(axis.token_count) }));\n  const capabilities = database.prepare(`\n    SELECT term FROM style_terms WHERE style_rowid = ? AND term_type = 'capability'\n    ORDER BY term ASC\n  `).all(row.style_rowid).map((term) => term.term);\n  const sections = database.prepare(`\n    SELECT name FROM style_sections WHERE style_rowid = ? ORDER BY ordinal ASC\n  `).all(row.style_rowid).map((section) => section.name);\n  const estimatedHydrationBytes = Number(database.prepare(`\n    SELECT COALESCE(SUM(byte_length), 0) AS bytes FROM style_artifacts\n    WHERE style_rowid = ? AND role IN ('design', 'source', 'tokens')\n  `).get(row.style_rowid).bytes);\n  return {\n    id: row.style_id,\n    title: row.title,\n    thesis: row.thesis,\n    contentHash: row.aggregate_hash,\n    capabilities,\n    availableSections: sections,\n    tokenAxes: axes,\n    provenance: {\n      status: row.provenance_status,\n      sourceUrl: row.source_url,\n      originalUrl: row.original_url,\n      screenshotUrl: row.screenshot_url,\n      uuid: row.source_uuid,\n      capturedAt: row.captured_at,\n      licenseStatus: row.license_status,\n      rightsKnown: Number(row.rights_known) === 1,\n      evidenceScope: JSON.parse(row.evidence_scope_json),\n    },\n    estimatedHydrationBytes,\n  };\n}\n\n/**\n * Query one immutable generation snapshot without walking the source corpus.\n *\n * @param {Object} request - Eligibility, ranking, and paging request.\n * @param {Object} options - Database connection or path.\n * @returns {Object} Generation-stamped cards, cursor, and channel evidence.\n */\nexport function queryPersistentStyles(request = {}, options = {}) {\n  validateQueryVector(request.queryVector);\n  const database = options.database ?? openPublishedStyleDatabase(options.databasePath);\n  const ownsDatabase = !options.database;\n  const telemetry = options.telemetry;\n  const candidateK = Math.max(1, Math.min(MAX_CANDIDATE_K, request.candidateK ?? DEFAULT_CANDIDATE_K));\n  const fingerprintSpan = telemetry?.span('request.fingerprint', RESIDENCY.JS_RESIDENT);\n  const fingerprint = requestFingerprint(request, candidateK, FUSION_PROFILE);\n  fingerprintSpan?.end(1);\n  const beginSpan = telemetry?.span('transaction.begin', RESIDENCY.NATIVE);\n  database.exec('BEGIN');\n  beginSpan?.end(1);\n  try {\n    const generation = validateGeneration(database, telemetry);\n    if (request.generationHash !== undefined\n      && request.generationHash !== generation.generation_hash) {\n      throw retrievalError(\n        'generation-mismatch',\n        'Requested generation is not the published generation.',\n      );\n    }\n    const vectorRevisionSpan = telemetry?.span('generation.vector-revision', RESIDENCY.NATIVE);\n    const vectorRevision = request.vectorProfile ? Number(database.prepare(`\n      SELECT revision FROM vector_projection_revisions WHERE profile_id = ?\n    `).get(request.vectorProfile)?.revision ?? 0) : 0;\n    vectorRevisionSpan?.end(request.vectorProfile ? 1 : 0);\n    let cursor = null;\n    if (request.cursor) {\n      cursor = decodeOpaque(request.cursor, 'invalid-cursor');\n      if (cursor.generationHash !== generation.generation_hash) {\n        throw retrievalError('generation-mismatch', 'Cursor belongs to another generation.');\n      }\n      if (cursor.queryFingerprint !== fingerprint\n        || cursor.fusionProfile !== FUSION_PROFILE.id\n        || cursor.candidateK !== candidateK\n        || cursor.vectorRevision !== vectorRevision) {\n        throw retrievalError('invalid-cursor', 'Cursor does not match this retrieval request.');\n      }\n    }\n    const eligibility = loadEligibility(database, request, telemetry);\n    const channelHealth = {\n      structured: { state: 'healthy' },\n      fts: { state: request.disableFts === true ? 'disabled' : 'healthy' },\n      vector: { state: request.disableVector === true ? 'disabled' : 'healthy' },\n    };\n    const lanes = {\n      structured: structuredLane(database, eligibility.eligible, request, candidateK, telemetry),\n    };\n    if (!request.disableFts) {\n      try {\n        lanes.fts = ftsLane(database, eligibility.eligible, request, candidateK, telemetry);\n      } catch (error) {\n        if (error.code === 'invalid-query') throw error;\n        channelHealth.fts = { state: 'failed', reason: String(error.message ?? error) };\n      }\n    }\n    if (!request.disableVector) {\n      try {\n        lanes.vector = vectorLane(database, eligibility.eligible, request, candidateK, telemetry);\n      } catch (error) {\n        if (error.code === 'invalid-query-vector') throw error;\n        channelHealth.vector = { state: 'failed', reason: String(error.message ?? error) };\n      }\n    }\n    const hasFts = Array.isArray(lanes.fts) && lanes.fts.length > 0;\n    const hasVector = Array.isArray(lanes.vector) && lanes.vector.length > 0;\n    const rankingMode = hasFts && hasVector\n      ? 'hybrid'\n      : hasFts\n        ? 'structured+fts'\n        : hasVector\n          ? 'structured+vector'\n          : 'structured-only';\n    const fusionSpan = telemetry?.span('fusion.rrf', RESIDENCY.JS_RESIDENT);\n    let fused = weightedRrf(lanes);\n    if (cursor) {\n      fused = fused.filter((entry) => entry.fusedScore < cursor.lastScore\n        || (entry.fusedScore === cursor.lastScore\n          && compareRawStrings(entry.id, cursor.lastId) > 0));\n    }\n    fusionSpan?.end(fused.length);\n    const limit = Math.max(0, Math.min(5, Number.isInteger(request.limit) ? request.limit : 5));\n    const page = fused.slice(0, limit);\n    const rowById = new Map(eligibility.eligible.map((row) => [row.style_id, row]));\n    const hydrateSpan = telemetry?.span('cards.hydrate', RESIDENCY.NATIVE);\n    const ranked = page.map((entry) => ({\n      style: loadCardStyle(database, rowById.get(entry.id)),\n      score: {\n        deterministic: Number(entry.rawScores.structured ?? 0),\n        lexical: Number(entry.channelContributions.fts ?? 0),\n        total: Number(entry.fusedScore.toFixed(12)),\n      },\n    }));\n    hydrateSpan?.end(ranked.length);\n    const assembleSpan = telemetry?.span('cards.assemble', RESIDENCY.JS_RESIDENT);\n    const cards = assembleCandidateCards(ranked, generation.generation_hash, request);\n    assembleSpan?.end(cards.length);\n    const encodeSpan = telemetry?.span('cards.attribution.encode', RESIDENCY.JS_RESIDENT);\n    const attributions = Object.fromEntries(page.map((entry) => [entry.id, {\n      sourceRanks: entry.sourceRanks,\n      channelContributions: entry.channelContributions,\n      rawScores: entry.rawScores,\n      hydrationToken: encodeOpaque({\n        generationHash: generation.generation_hash,\n        id: entry.id,\n        contentHash: rowById.get(entry.id).aggregate_hash,\n      }),\n    }]));\n    const last = page.at(-1);\n    const nextCursor = last && fused.length > page.length ? encodeOpaque({\n      generationHash: generation.generation_hash,\n      queryFingerprint: fingerprint,\n      fusionProfile: FUSION_PROFILE.id,\n      candidateK,\n      vectorRevision,\n      lastScore: last.fusedScore,\n      lastId: last.id,\n    }) : null;\n    encodeSpan?.end(page.length);\n    const commitSpan = telemetry?.span('transaction.commit', RESIDENCY.NATIVE);\n    database.exec('COMMIT');\n    commitSpan?.end(1);\n    return {\n      ok: true,\n      generationHash: generation.generation_hash,\n      degraded: rankingMode !== 'hybrid',\n      rankingMode,\n      queryFingerprint: fingerprint,\n      fusionProfile: FUSION_PROFILE.id,\n      candidateK,\n      vectorRevision,\n      channelHealth,\n      eligibility: {\n        eligibleCount: eligibility.eligible.length,\n        rejectedCount: eligibility.rejectedCount,\n      },\n      cards,\n      attributions,\n      nextCursor,\n    };\n  } catch (error) {\n    database.exec('ROLLBACK');\n    throw error;\n  } finally {\n    if (ownsDatabase) database.close();\n  }\n}\n\nexport const retrievalInternals = Object.freeze({\n  decodeOpaque,","lineStart":1,"lineEnd":520,"totalLines":524,"truncated":true}},"title":".opencode/skills/sk-design/styles/_db/retrieval.mjs","time":{"start":1784623168964,"end":1784623168980}},"metadata":{"openai":{"itemId":"fc_02bf757ba310bf3e016a5f30403ac08191bf1e8f2b5f6688bb"}},"id":"prt_f83d47d84001dqM6Ndx9lYeoc9","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV"}}
{"type":"tool_use","timestamp":1784623169022,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"read","callID":"call_i9QdX9buLOjR3agQVG9X7lal","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/operator.mjs","offset":1,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/operator.mjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ╔══════════════════════════════════════════════════════════════════════════╗\n3: // ║ Persistent Style Database Operator                                       ║\n4: // ╚══════════════════════════════════════════════════════════════════════════╝\n5: \n6: import { existsSync } from 'node:fs';\n7: import { readdir, rm, stat } from 'node:fs/promises';\n8: import path from 'node:path';\n9: import { pathToFileURL } from 'node:url';\n10: \n11: import {\n12:   buildStyleDatabase,\n13:   rollbackStyleDatabase,\n14: } from './indexer.mjs';\n15: import {\n16:   manifestArtifactFiles,\n17:   readManifest,\n18: } from './generation-manifest.mjs';\n19: import {\n20:   DEFAULT_STYLE_DATABASE_PATH,\n21:   STYLE_DATABASE_POINTER_SUFFIX,\n22:   openPublishedStyleDatabase,\n23:   resolvePublishedDatabasePath,\n24: } from './schema.mjs';\n25: import { rebuildVectorProjection } from './vectors.mjs';\n26: \n27: /**\n28:  * Read the published manifest's artifact roles and absolute file paths.\n29:  *\n30:  * @param {string} databasePath - Logical database path.\n31:  * @returns {Promise<{roles:string[], paths:string[]}>} Current-manifest artifacts.\n32:  */\n33: async function currentManifestArtifacts(databasePath) {\n34:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n35:   if (!existsSync(pointerPath)) return { roles: [], paths: [] };\n36:   try {\n37:     const manifest = await readManifest(pointerPath);\n38:     const directory = path.dirname(databasePath);\n39:     return {\n40:       roles: Object.keys(manifest.artifacts).sort(),\n41:       paths: manifestArtifactFiles({ artifacts: manifest.artifacts })\n42:         .map((file) => path.resolve(path.join(directory, file))),\n43:     };\n44:   } catch {\n45:     return { roles: [], paths: [] };\n46:   }\n47: }\n48: \n49: function optionValue(argumentsList, name) {\n50:   const index = argumentsList.indexOf(name);\n51:   return index === -1 ? null : argumentsList[index + 1] ?? null;\n52: }\n53: \n54: function writeJson(value, stream = process.stdout) {\n55:   stream.write(`${JSON.stringify(value, null, 2)}\\n`);\n56: }\n57: \n58: async function listGenerationPaths(databasePath) {\n59:   const directory = path.dirname(databasePath);\n60:   const prefix = `${path.basename(databasePath)}.sha256-`;\n61:   const entries = await readdir(directory, { withFileTypes: true });\n62:   const generations = [];\n63:   for (const entry of entries) {\n64:     if (!entry.isFile() || !entry.name.startsWith(prefix) || !entry.name.endsWith('.sqlite')) {\n65:       continue;\n66:     }\n67:     const generationPath = path.join(directory, entry.name);\n68:     const info = await stat(generationPath);\n69:     generations.push({ path: generationPath, modifiedAt: info.mtimeMs });\n70:   }\n71:   return generations.sort((left, right) => right.modifiedAt - left.modifiedAt\n72:     || left.path.localeCompare(right.path));\n73: }\n74: \n75: /**\n76:  * Report the published generation, rollback candidate, queues, and retained files.\n77:  *\n78:  * @param {Object} [options] - Logical database path.\n79:  * @returns {Promise<Object>} Persistent database status.\n80:  */\n81: export async function getStyleDatabaseStatus(options = {}) {\n82:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n83:   const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n84:   const generations = await listGenerationPaths(databasePath);\n85:   if (!existsSync(pointerPath)) {\n86:     return {\n87:       ok: true,\n88:       databasePath,\n89:       published: false,\n90:       currentGenerationPath: null,\n91:       rollbackGenerationPath: generations[0]?.path ?? null,\n92:       retainedGenerationPaths: generations.map((entry) => entry.path),\n93:       vectorJobs: {},\n94:     };\n95:   }\n96:   const currentGenerationPath = resolvePublishedDatabasePath(databasePath);\n97:   const manifestArtifacts = await currentManifestArtifacts(databasePath);\n98:   const database = openPublishedStyleDatabase(databasePath);\n99:   try {\n100:     const generationHash = database.prepare(`\n101:       SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n102:     `).get()?.generation_hash ?? null;\n103:     const vectorJobs = Object.fromEntries(database.prepare(`\n104:       SELECT status, COUNT(*) AS count FROM style_vector_jobs GROUP BY status ORDER BY status\n105:     `).all().map((row) => [row.status, Number(row.count)]));\n106:     return {\n107:       ok: true,\n108:       databasePath,\n109:       published: true,\n110:       generationHash,\n111:       currentGenerationPath,\n112:       manifestArtifacts: manifestArtifacts.roles,\n113:       rollbackGenerationPath: generations\n114:         .find((entry) => entry.path !== currentGenerationPath)?.path ?? null,\n115:       retainedGenerationPaths: generations.map((entry) => entry.path),\n116:       vectorJobs,\n117:     };\n118:   } finally {\n119:     database.close();\n120:   }\n121: }\n122: \n123: /**\n124:  * Remove generation files except the published file and one rollback target.\n125:  *\n126:  * @param {Object} options - Logical path and explicit retention set.\n127:  * @returns {Promise<Object>} Kept and removed generation paths.\n128:  */\n129: export async function pruneStyleDatabaseGenerations(options) {\n130:   const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n131:   const currentGenerationPath = options?.currentGenerationPath\n132:     ?? resolvePublishedDatabasePath(databasePath);\n133:   const rollbackGenerationPath = options?.rollbackGenerationPath ?? null;\n134:   const keep = new Set([currentGenerationPath, rollbackGenerationPath]\n135:     .filter(Boolean).map((value) => path.resolve(value)));\n136:   // Protect every artifact the published manifest references, so a generation is\n137:   // retained as a whole unit once it spans more than the SQLite file.\n138:   for (const artifactPath of (await currentManifestArtifacts(databasePath)).paths) {\n139:     keep.add(artifactPath);\n140:   }\n141:   const generations = await listGenerationPaths(databasePath);\n142:   const removed = [];\n143:   for (const generation of generations) {\n144:     if (keep.has(path.resolve(generation.path))) continue;\n145:     await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n146:       rm(`${generation.path}${suffix}`, { force: true })\n147:     )));\n148:     removed.push(generation.path);\n149:   }\n150:   return {\n151:     kept: generations.map((entry) => entry.path)\n152:       .filter((generationPath) => keep.has(path.resolve(generationPath))),\n153:     removed,\n154:   };\n155: }\n156: \n157: async function buildAndRetain(options) {\n158:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n159:   const before = await getStyleDatabaseStatus({ databasePath });\n160:   const result = await buildStyleDatabase({ ...options, databasePath });\n161:   const retention = await pruneStyleDatabaseGenerations({\n162:     databasePath,\n163:     currentGenerationPath: result.generationDatabasePath,\n164:     rollbackGenerationPath: before.currentGenerationPath,\n165:   });\n166:   return { ...result, action: 'build', retention };\n167: }\n168: \n169: async function switchGeneration(action, options) {\n170:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n171:   const before = await getStyleDatabaseStatus({ databasePath });\n172:   const generationDatabasePath = options.generationDatabasePath\n173:     ?? before.rollbackGenerationPath;\n174:   if (!generationDatabasePath) {\n175:     const error = new Error('No retained rollback generation is available.');\n176:     error.code = 'rollback-generation-unavailable';\n177:     throw error;\n178:   }\n179:   const result = await rollbackStyleDatabase({ databasePath, generationDatabasePath });\n180:   const retention = await pruneStyleDatabaseGenerations({\n181:     databasePath,\n182:     currentGenerationPath: generationDatabasePath,\n183:     rollbackGenerationPath: before.currentGenerationPath,\n184:   });\n185:   return { ...result, action, retention };\n186: }\n187: \n188: async function repairVectors(options) {\n189:   if (!options.profileId) {\n190:     const error = new Error('Vector repair requires an embedding profile.');\n191:     error.code = 'invalid-arguments';\n192:     throw error;\n193:   }\n194:   const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n195:   const database = openPublishedStyleDatabase(databasePath);\n196:   try {\n197:     return {\n198:       ok: true,\n199:       action: 'repair',\n200:       ...rebuildVectorProjection(database, options.profileId),\n201:     };\n202:   } finally {\n203:     database.close();\n204:   }\n205: }\n206: \n207: /**\n208:  * Dispatch the persistent style database operator command surface.\n209:  *\n210:  * @param {string[]} argumentsList - Command and flags.\n211:  * @returns {Promise<Object>} Structured operator result.\n212:  */\n213: export async function runStyleDatabaseOperator(argumentsList = process.argv.slice(2)) {\n214:   const [command, ...commandArguments] = argumentsList;\n215:   const databasePath = optionValue(commandArguments, '--database')\n216:     ?? DEFAULT_STYLE_DATABASE_PATH;\n217:   if (command === 'status') return getStyleDatabaseStatus({ databasePath });\n218:   if (command === 'build') {\n219:     const corpusRoot = optionValue(commandArguments, '--corpus');\n220:     if (!corpusRoot) {\n221:       const error = new Error('Build requires --corpus.');\n222:       error.code = 'invalid-arguments';\n223:       throw error;\n224:     }\n225:     return buildAndRetain({ corpusRoot, databasePath, corpusWalkMode: 'migration' });\n226:   }\n227:   if (command === 'cutover') {\n228:     const generationDatabasePath = optionValue(commandArguments, '--generation');\n229:     if (!generationDatabasePath) {\n230:       const error = new Error('Cutover requires --generation.');\n231:       error.code = 'invalid-arguments';\n232:       throw error;\n233:     }\n234:     return switchGeneration('cutover', { databasePath, generationDatabasePath });\n235:   }\n236:   if (command === 'rollback') {\n237:     return switchGeneration('rollback', {\n238:       databasePath,\n239:       generationDatabasePath: optionValue(commandArguments, '--generation'),\n240:     });\n241:   }\n242:   if (command === 'repair') {\n243:     return repairVectors({\n244:       databasePath,\n245:       profileId: optionValue(commandArguments, '--profile'),\n246:     });\n247:   }\n248:   const error = new Error(\n249:     'Usage: operator.mjs <status|build|cutover|rollback|repair> [options]',\n250:   );\n251:   error.code = 'invalid-arguments';\n252:   throw error;\n253: }\n254: \n255: const isDirectExecution = process.argv[1]\n256:   && import.meta.url === pathToFileURL(path.resolve(process.argv[1])).href;\n257: if (isDirectExecution) {\n258:   try {\n259:     writeJson(await runStyleDatabaseOperator());\n260:   } catch (error) {\n261:     writeJson({\n262:       ok: false,\n263:       error: error.code ?? 'internal-error',\n264:       message: error.message,\n265:     }, process.stderr);\n266:     process.exitCode = 1;\n267:   }\n268: }\n\n(End of file - total 268 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Operator                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { existsSync } from 'node:fs';\nimport { readdir, rm, stat } from 'node:fs/promises';\nimport path from 'node:path';\nimport { pathToFileURL } from 'node:url';\n\nimport {\n  buildStyleDatabase,\n  rollbackStyleDatabase,\n} from './indexer.mjs';\nimport {\n  manifestArtifactFiles,\n  readManifest,\n} from './generation-manifest.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/styles/_db/operator.mjs","text":"#!/usr/bin/env node\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Persistent Style Database Operator                                       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\nimport { existsSync } from 'node:fs';\nimport { readdir, rm, stat } from 'node:fs/promises';\nimport path from 'node:path';\nimport { pathToFileURL } from 'node:url';\n\nimport {\n  buildStyleDatabase,\n  rollbackStyleDatabase,\n} from './indexer.mjs';\nimport {\n  manifestArtifactFiles,\n  readManifest,\n} from './generation-manifest.mjs';\nimport {\n  DEFAULT_STYLE_DATABASE_PATH,\n  STYLE_DATABASE_POINTER_SUFFIX,\n  openPublishedStyleDatabase,\n  resolvePublishedDatabasePath,\n} from './schema.mjs';\nimport { rebuildVectorProjection } from './vectors.mjs';\n\n/**\n * Read the published manifest's artifact roles and absolute file paths.\n *\n * @param {string} databasePath - Logical database path.\n * @returns {Promise<{roles:string[], paths:string[]}>} Current-manifest artifacts.\n */\nasync function currentManifestArtifacts(databasePath) {\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  if (!existsSync(pointerPath)) return { roles: [], paths: [] };\n  try {\n    const manifest = await readManifest(pointerPath);\n    const directory = path.dirname(databasePath);\n    return {\n      roles: Object.keys(manifest.artifacts).sort(),\n      paths: manifestArtifactFiles({ artifacts: manifest.artifacts })\n        .map((file) => path.resolve(path.join(directory, file))),\n    };\n  } catch {\n    return { roles: [], paths: [] };\n  }\n}\n\nfunction optionValue(argumentsList, name) {\n  const index = argumentsList.indexOf(name);\n  return index === -1 ? null : argumentsList[index + 1] ?? null;\n}\n\nfunction writeJson(value, stream = process.stdout) {\n  stream.write(`${JSON.stringify(value, null, 2)}\\n`);\n}\n\nasync function listGenerationPaths(databasePath) {\n  const directory = path.dirname(databasePath);\n  const prefix = `${path.basename(databasePath)}.sha256-`;\n  const entries = await readdir(directory, { withFileTypes: true });\n  const generations = [];\n  for (const entry of entries) {\n    if (!entry.isFile() || !entry.name.startsWith(prefix) || !entry.name.endsWith('.sqlite')) {\n      continue;\n    }\n    const generationPath = path.join(directory, entry.name);\n    const info = await stat(generationPath);\n    generations.push({ path: generationPath, modifiedAt: info.mtimeMs });\n  }\n  return generations.sort((left, right) => right.modifiedAt - left.modifiedAt\n    || left.path.localeCompare(right.path));\n}\n\n/**\n * Report the published generation, rollback candidate, queues, and retained files.\n *\n * @param {Object} [options] - Logical database path.\n * @returns {Promise<Object>} Persistent database status.\n */\nexport async function getStyleDatabaseStatus(options = {}) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const pointerPath = `${databasePath}${STYLE_DATABASE_POINTER_SUFFIX}`;\n  const generations = await listGenerationPaths(databasePath);\n  if (!existsSync(pointerPath)) {\n    return {\n      ok: true,\n      databasePath,\n      published: false,\n      currentGenerationPath: null,\n      rollbackGenerationPath: generations[0]?.path ?? null,\n      retainedGenerationPaths: generations.map((entry) => entry.path),\n      vectorJobs: {},\n    };\n  }\n  const currentGenerationPath = resolvePublishedDatabasePath(databasePath);\n  const manifestArtifacts = await currentManifestArtifacts(databasePath);\n  const database = openPublishedStyleDatabase(databasePath);\n  try {\n    const generationHash = database.prepare(`\n      SELECT generation_hash FROM current_corpus_generation WHERE singleton = 1\n    `).get()?.generation_hash ?? null;\n    const vectorJobs = Object.fromEntries(database.prepare(`\n      SELECT status, COUNT(*) AS count FROM style_vector_jobs GROUP BY status ORDER BY status\n    `).all().map((row) => [row.status, Number(row.count)]));\n    return {\n      ok: true,\n      databasePath,\n      published: true,\n      generationHash,\n      currentGenerationPath,\n      manifestArtifacts: manifestArtifacts.roles,\n      rollbackGenerationPath: generations\n        .find((entry) => entry.path !== currentGenerationPath)?.path ?? null,\n      retainedGenerationPaths: generations.map((entry) => entry.path),\n      vectorJobs,\n    };\n  } finally {\n    database.close();\n  }\n}\n\n/**\n * Remove generation files except the published file and one rollback target.\n *\n * @param {Object} options - Logical path and explicit retention set.\n * @returns {Promise<Object>} Kept and removed generation paths.\n */\nexport async function pruneStyleDatabaseGenerations(options) {\n  const databasePath = options?.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const currentGenerationPath = options?.currentGenerationPath\n    ?? resolvePublishedDatabasePath(databasePath);\n  const rollbackGenerationPath = options?.rollbackGenerationPath ?? null;\n  const keep = new Set([currentGenerationPath, rollbackGenerationPath]\n    .filter(Boolean).map((value) => path.resolve(value)));\n  // Protect every artifact the published manifest references, so a generation is\n  // retained as a whole unit once it spans more than the SQLite file.\n  for (const artifactPath of (await currentManifestArtifacts(databasePath)).paths) {\n    keep.add(artifactPath);\n  }\n  const generations = await listGenerationPaths(databasePath);\n  const removed = [];\n  for (const generation of generations) {\n    if (keep.has(path.resolve(generation.path))) continue;\n    await Promise.all(['', '-wal', '-shm'].map((suffix) => (\n      rm(`${generation.path}${suffix}`, { force: true })\n    )));\n    removed.push(generation.path);\n  }\n  return {\n    kept: generations.map((entry) => entry.path)\n      .filter((generationPath) => keep.has(path.resolve(generationPath))),\n    removed,\n  };\n}\n\nasync function buildAndRetain(options) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const before = await getStyleDatabaseStatus({ databasePath });\n  const result = await buildStyleDatabase({ ...options, databasePath });\n  const retention = await pruneStyleDatabaseGenerations({\n    databasePath,\n    currentGenerationPath: result.generationDatabasePath,\n    rollbackGenerationPath: before.currentGenerationPath,\n  });\n  return { ...result, action: 'build', retention };\n}\n\nasync function switchGeneration(action, options) {\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const before = await getStyleDatabaseStatus({ databasePath });\n  const generationDatabasePath = options.generationDatabasePath\n    ?? before.rollbackGenerationPath;\n  if (!generationDatabasePath) {\n    const error = new Error('No retained rollback generation is available.');\n    error.code = 'rollback-generation-unavailable';\n    throw error;\n  }\n  const result = await rollbackStyleDatabase({ databasePath, generationDatabasePath });\n  const retention = await pruneStyleDatabaseGenerations({\n    databasePath,\n    currentGenerationPath: generationDatabasePath,\n    rollbackGenerationPath: before.currentGenerationPath,\n  });\n  return { ...result, action, retention };\n}\n\nasync function repairVectors(options) {\n  if (!options.profileId) {\n    const error = new Error('Vector repair requires an embedding profile.');\n    error.code = 'invalid-arguments';\n    throw error;\n  }\n  const databasePath = options.databasePath ?? DEFAULT_STYLE_DATABASE_PATH;\n  const database = openPublishedStyleDatabase(databasePath);\n  try {\n    return {\n      ok: true,\n      action: 'repair',\n      ...rebuildVectorProjection(database, options.profileId),\n    };\n  } finally {\n    database.close();\n  }\n}\n\n/**\n * Dispatch the persistent style database operator command surface.\n *\n * @param {string[]} argumentsList - Command and flags.\n * @returns {Promise<Object>} Structured operator result.\n */\nexport async function runStyleDatabaseOperator(argumentsList = process.argv.slice(2)) {\n  const [command, ...commandArguments] = argumentsList;\n  const databasePath = optionValue(commandArguments, '--database')\n    ?? DEFAULT_STYLE_DATABASE_PATH;\n  if (command === 'status') return getStyleDatabaseStatus({ databasePath });\n  if (command === 'build') {\n    const corpusRoot = optionValue(commandArguments, '--corpus');\n    if (!corpusRoot) {\n      const error = new Error('Build requires --corpus.');\n      error.code = 'invalid-arguments';\n      throw error;\n    }\n    return buildAndRetain({ corpusRoot, databasePath, corpusWalkMode: 'migration' });\n  }\n  if (command === 'cutover') {\n    const generationDatabasePath = optionValue(commandArguments, '--generation');\n    if (!generationDatabasePath) {\n      const error = new Error('Cutover requires --generation.');\n      error.code = 'invalid-arguments';\n      throw error;\n    }\n    return switchGeneration('cutover', { databasePath, generationDatabasePath });\n  }\n  if (command === 'rollback') {\n    return switchGeneration('rollback', {\n      databasePath,\n      generationDatabasePath: optionValue(commandArguments, '--generation'),\n    });\n  }\n  if (command === 'repair') {\n    return repairVectors({\n      databasePath,\n      profileId: optionValue(commandArguments, '--profile'),\n    });\n  }\n  const error = new Error(\n    'Usage: operator.mjs <status|build|cutover|rollback|repair> [options]',\n  );\n  error.code = 'invalid-arguments';\n  throw error;\n}\n\nconst isDirectExecution = process.argv[1]\n  && import.meta.url === pathToFileURL(path.resolve(process.argv[1])).href;\nif (isDirectExecution) {\n  try {\n    writeJson(await runStyleDatabaseOperator());\n  } catch (error) {\n    writeJson({\n      ok: false,\n      error: error.code ?? 'internal-error',\n      message: error.message,\n    }, process.stderr);\n    process.exitCode = 1;\n  }\n}","lineStart":1,"lineEnd":268,"totalLines":268,"truncated":false}},"title":".opencode/skills/sk-design/styles/_db/operator.mjs","time":{"start":1784623169009,"end":1784623169019}},"metadata":{"openai":{"itemId":"fc_02bf757ba310bf3e016a5f30403ac88191aa03a69d8efea7a3"}},"id":"prt_f83d47dc6001ll7ar27FQ7sPXb","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV"}}
{"type":"step_finish","timestamp":1784623169569,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"id":"prt_f83d4801e001Lx5D6qFXS6aM13","reason":"tool-calls","snapshot":"726155bb8adfce6ee82c9966f8ba75f8ee839083","messageID":"msg_f83d42bac001rqWi8pnYAVRuIV","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","type":"step-finish","tokens":{"total":179898,"input":5459,"output":672,"reasoning":199,"cache":{"write":0,"read":173568}},"cost":0}}
{"type":"step_start","timestamp":1784623172484,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"id":"prt_f83d48b8000190EGO19XCW3ieE","messageID":"msg_f83d481d4001iwS0TDeLQQRx12","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","snapshot":"726155bb8adfce6ee82c9966f8ba75f8ee839083","type":"step-start"}}
{"type":"tool_use","timestamp":1784623258610,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"apply_patch","callID":"call_3S1pg7yZJKSBnpwC2wHtV4Yj","state":{"status":"completed","input":{"patchText":"*** Begin Patch\n*** Add File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/prompts/iteration-002.md\n+DEEP-RESEARCH ITERATION 2\n+\n+STATE SUMMARY: Iteration 2 of 5; 1/5 questions answered; last ratio 1.00; stop policy is max-iterations.\n+\n+Focus Area: Persistent-backend completeness and exact missing wiring/build work.\n+Constraints: Read state first; preserve the consumer facade; write only this lineage; no implementation.\n+Route: mode=research; target_agent=deep-research; execution=single_iteration; state_source=externalized_files.\n*** Add File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/iterations/iteration-002.md\n+# Iteration 2: Persistent Backend Readiness and Missing Wiring\n+\n+## Focus\n+\n+Assess whether the database is merely a sketch or a deployable projection, then enumerate what still separates it from a safe default.\n+\n+## Findings\n+\n+1. The persistent implementation is technically substantial, not a stub: schema v2 contains normalized style/provenance/artifact/facet/section tables, external-content FTS5, embeddings/jobs/vectors, relationships, immutable corpus generations, and indexes. [SOURCE: .opencode/skills/sk-design/styles/_db/schema.mjs:35-269]\n+2. Publication and rollback are implemented around immutable generation files plus an atomic `.current.json` manifest pointer. The operator supports `status`, `build`, `cutover`, `rollback`, and vector `repair`, retaining current plus one rollback generation. [SOURCE: .opencode/skills/sk-design/styles/_db/README.md:6-49] [SOURCE: .opencode/skills/sk-design/styles/_db/operator.mjs:75-185] [SOURCE: .opencode/skills/sk-design/styles/_db/operator.mjs:207-247]\n+3. Query semantics exceed today's consumer needs: structured, FTS5, and optional vector lanes feed deterministic weighted RRF, generation-bound cursors, attribution, and channel-local degradation. Consumers currently ask for at most five reference cards and do not supply evidence that vector search or pagination is required. [SOURCE: .opencode/skills/sk-design/styles/_db/retrieval.mjs:13-25] [SOURCE: .opencode/skills/sk-design/styles/_db/retrieval.mjs:168-294] [SOURCE: .opencode/skills/sk-design/styles/_db/retrieval.mjs:364-510] [INFERENCE: iteration 1 consumer evidence]\n+4. The code deliberately avoids implicit construction: `buildStyleDatabase()` is never invoked by query or hydrate, and the operator requires an explicit corpus path. Therefore changing the mode default alone would fail on a clean checkout because neither the default SQLite artifact nor its pointer exists. [SOURCE: .opencode/skills/sk-design/styles/_db/README.md:40-43] [SOURCE: .opencode/skills/sk-design/styles/_db/operator.mjs:213-226] [SOURCE: .opencode/skills/sk-design/styles/_db/schema.mjs:11-23]\n+5. A production cutover needs more than one successful build: it needs a refresh owner tied to corpus extraction/update, artifact distribution or deterministic local bootstrap, status/repair observability, and a failure policy. No such default-path lifecycle is visible in the facade or operator; reads fail closed rather than auto-building, which is correct for integrity but leaves operations unowned. [SOURCE: .opencode/skills/sk-design/styles/_db/README.md:27-49] [SOURCE: .opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs:144-166]\n+6. Shadow mode is a useful migration gate but its parity comparison intentionally tolerates generation hashes, content hashes, score values, and ranking mode. It checks projected cards and eligibility, not strict rank/score equivalence; default cutover should additionally use the differential oracle and live-corpus relevance/latency evidence. [SOURCE: .opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs:113-141] [SOURCE: .opencode/skills/sk-design/styles/_db/README.md:89-131]\n+\n+## Ruled Out\n+\n+- Calling the database \"unfinished\": the storage, publication, query, hydration, telemetry, and operator machinery is implemented and tested.\n+- Flipping `legacy` to `persistent` as the entire wiring plan: it would point clean checkouts at a missing publication pointer.\n+\n+## Dead Ends\n+\n+- Treating feature richness as proof of default-path value. The vector/cursor/relationship machinery is capability supply; observed consumer demand remains separate.\n+\n+## Edge Cases\n+\n+- Ambiguous input: \"build and populate\" could commit a generated DB or bootstrap locally. Both remain viable, but either requires an explicit freshness/distribution owner.\n+- Contradictory evidence: the implementation is deployable in isolation while the product integration is incomplete. This is not a code-quality contradiction; it is an ownership gap.\n+- Missing dependencies: no production workload trace or committed DB artifact.\n+- Partial success: readiness is established statically, not through a live full-corpus build in this write-restricted research lineage.\n+\n+## Sources Consulted\n+\n+- `.opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs:1-357`\n+- `.opencode/skills/sk-design/styles/_db/README.md:1-147`\n+- `.opencode/skills/sk-design/styles/_db/indexer.mjs:1-480`\n+- `.opencode/skills/sk-design/styles/_db/schema.mjs:1-360`\n+- `.opencode/skills/sk-design/styles/_db/retrieval.mjs:1-520`\n+- `.opencode/skills/sk-design/styles/_db/operator.mjs:1-268`\n+\n+## Assessment\n+\n+- New information ratio: 0.85\n+- Novelty justification: Five findings are new and one refines the consumer-demand result from iteration 1.\n+- Questions addressed: persistent implementation completeness and exact default-path gap.\n+- Questions answered: the implementation is mature, but no build/distribution/refresh owner or cutover evidence makes it a real default.\n+- Confidence: high on static readiness; medium on operational effort until a full-corpus build and workload trace are measured.\n+\n+## Reflection\n+\n+- What worked and why: separating implementation completeness from integration completeness resolved the apparent \"built but unused\" paradox.\n+- What did not work and why: reading only the first indexer segment did not expose the full build function, but the operator and README independently establish its lifecycle and invocation contract.\n+- What I would do differently: quantify current benefits and recurring costs before treating the missing lifecycle as work worth funding.\n+\n+## Recommended Next Focus\n+\n+Measure the economic case from available evidence: corpus size, legacy query work, existing benchmark claims, DB build/repair burden, and missing relevance/workload validation.\n*** Add File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deltas/iter-002.jsonl\n+{\"type\":\"iteration\",\"iteration\":2,\"mode\":\"research\",\"target_agent\":\"deep-research\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=research target_agent=deep-research\",\"run\":2,\"status\":\"complete\",\"focus\":\"Persistent backend readiness and missing default-path wiring\",\"findingsCount\":6,\"newInfoRatio\":0.85,\"noveltyJustification\":\"Five findings are new and one refines the consumer-demand result from iteration 1.\",\"keyQuestions\":[\"How complete is the persistent implementation and what remains to make it default?\"],\"answeredQuestions\":[\"How complete is the persistent implementation and what remains to make it default?\"],\"ruledOut\":[\"The persistent database is only a stub\",\"Changing the adapter default is a complete cutover plan\",\"Implemented capabilities alone prove default-path value\"],\"focusTrack\":\"architecture\",\"edgeCase\":\"missing-dependency\",\"toolsUsed\":[\"Read\"],\"sourcesQueried\":[\"styles/_engine/persistent-adapter.mjs\",\"styles/_db/README.md\",\"styles/_db/indexer.mjs\",\"styles/_db/schema.mjs\",\"styles/_db/retrieval.mjs\",\"styles/_db/operator.mjs\"],\"timestamp\":\"2026-07-21T08:41:30Z\",\"durationMs\":208000,\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1,\"executor\":{\"kind\":\"cli-opencode\",\"model\":\"openai/gpt-5.6-sol-fast\"},\"graphEvents\":[]}\n+{\"type\":\"finding\",\"id\":\"f-db-mature\",\"iteration\":2,\"summary\":\"The persistent projection, publication, retrieval, hydration, telemetry, and operator machinery is technically mature.\"}\n+{\"type\":\"finding\",\"id\":\"f-lifecycle-unowned\",\"iteration\":2,\"summary\":\"No default build, distribution, refresh, or repair owner exists.\"}\n+{\"type\":\"finding\",\"id\":\"f-shadow-bounded\",\"iteration\":2,\"summary\":\"Shadow parity is intentionally bounded and not sufficient alone for default cutover.\"}\n*** Update File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-state.jsonl\n@@\n {\"type\":\"event\",\"event\":\"dashboard_generated\",\"iteration\":1,\"timestamp\":\"2026-07-21T08:38:01Z\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1}\n+{\"type\":\"iteration\",\"iteration\":2,\"mode\":\"research\",\"target_agent\":\"deep-research\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=research target_agent=deep-research\",\"run\":2,\"status\":\"complete\",\"focus\":\"Persistent backend readiness and missing default-path wiring\",\"findingsCount\":6,\"newInfoRatio\":0.85,\"noveltyJustification\":\"Five findings are new and one refines the consumer-demand result from iteration 1.\",\"keyQuestions\":[\"How complete is the persistent implementation and what remains to make it default?\"],\"answeredQuestions\":[\"How complete is the persistent implementation and what remains to make it default?\"],\"ruledOut\":[\"The persistent database is only a stub\",\"Changing the adapter default is a complete cutover plan\",\"Implemented capabilities alone prove default-path value\"],\"focusTrack\":\"architecture\",\"edgeCase\":\"missing-dependency\",\"toolsUsed\":[\"Read\"],\"sourcesQueried\":[\"styles/_engine/persistent-adapter.mjs\",\"styles/_db/README.md\",\"styles/_db/indexer.mjs\",\"styles/_db/schema.mjs\",\"styles/_db/retrieval.mjs\",\"styles/_db/operator.mjs\"],\"timestamp\":\"2026-07-21T08:41:30Z\",\"durationMs\":208000,\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1,\"executor\":{\"kind\":\"cli-opencode\",\"model\":\"openai/gpt-5.6-sol-fast\"},\"graphEvents\":[]}\n+{\"type\":\"event\",\"event\":\"dashboard_generated\",\"iteration\":2,\"timestamp\":\"2026-07-21T08:41:31Z\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1}\n*** Update File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-strategy.md\n@@\n-- [ ] How complete is the persistent implementation, and what exact work remains to make it the default and populate a real database?\n+- [x] How complete is the persistent implementation, and what exact work remains to make it the default and populate a real database?\n@@\n - The four consumers require a bounded, generation-safe `runQuery`/`runHydrate` facade and degrade safely when retrieval is unavailable; none requires SQLite specifically. (iteration 1)\n+- The persistent implementation is mature, but a real default requires a published initial generation plus explicit build/distribution/refresh/repair ownership and live cutover evidence. (iteration 2)\n@@\n - Consumer-to-facade tracing: showed that backend choice is isolated below all four corpus modules. (iteration 1)\n+- Implementation-versus-integration separation: distinguished mature database code from the absent operational lifecycle. (iteration 2)\n@@\n - Initial wildcard include search: returned no files because the path/include shape was too broad; replaced with an exact call-site search. (iteration 1)\n+- First-segment indexer read: did not reach the build function, so operator and README evidence were used to triangulate the published lifecycle. (iteration 2)\n@@\n - SQLite as authoritative content storage: ruled out because hydration remains flat-file artifact access. (iteration 1)\n+- Default flip without build/distribution: ruled out because clean checkouts have no pointer or generation file. (iteration 2)\n+- Capability inventory as business justification: ruled out because consumer demand and measured value are separate. (iteration 2)\n@@\n-Assess persistent-backend completeness and enumerate the exact wiring/build work required for a real default database.\n+Quantify benefits and recurring costs at the current corpus scale, including the limits of existing benchmark and relevance evidence.\n*** Update File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/findings-registry.json\n@@\n-    {\"id\":\"q-readiness\",\"text\":\"How complete is the persistent implementation and what remains to make it default?\",\"status\":\"open\"},\n@@\n-    {\"id\":\"q-consumers\",\"text\":\"What contract and workload do the four design-mode corpus consumers require?\",\"status\":\"resolved\",\"resolvedAtIteration\":1,\"answer\":\"A bounded generation-safe query/hydration facade; no consumer requires SQLite specifically.\"}\n+    {\"id\":\"q-consumers\",\"text\":\"What contract and workload do the four design-mode corpus consumers require?\",\"status\":\"resolved\",\"resolvedAtIteration\":1,\"answer\":\"A bounded generation-safe query/hydration facade; no consumer requires SQLite specifically.\"},\n+    {\"id\":\"q-readiness\",\"text\":\"How complete is the persistent implementation and what remains to make it default?\",\"status\":\"resolved\",\"resolvedAtIteration\":2,\"answer\":\"Technically mature, but missing a published artifact and an owned build/distribution/refresh/repair lifecycle plus live cutover evidence.\"}\n@@\n-    {\"id\":\"f-legacy-freshness-cost\",\"iteration\":1,\"summary\":\"Legacy queries rebuild and compare the live corpus manifest on every call.\",\"sources\":[\"style-library.mjs:123-159\"]}\n+    {\"id\":\"f-legacy-freshness-cost\",\"iteration\":1,\"summary\":\"Legacy queries rebuild and compare the live corpus manifest on every call.\",\"sources\":[\"style-library.mjs:123-159\"]},\n+    {\"id\":\"f-db-mature\",\"iteration\":2,\"summary\":\"The persistent projection and operator machinery are technically mature.\",\"sources\":[\"schema.mjs:35-269\",\"retrieval.mjs:364-510\",\"operator.mjs:75-247\"]},\n+    {\"id\":\"f-lifecycle-unowned\",\"iteration\":2,\"summary\":\"No default build, distribution, refresh, or repair owner exists.\",\"sources\":[\"README.md:40-49\",\"operator.mjs:213-226\"]},\n+    {\"id\":\"f-shadow-bounded\",\"iteration\":2,\"summary\":\"Shadow parity tolerates ranking and identity differences and is not a sufficient cutover gate alone.\",\"sources\":[\"persistent-adapter.mjs:113-141\"]}\n@@\n-    {\"approach\":\"Move authoritative content into SQLite\",\"reason\":\"Consumer hydration semantics rely on bounded flat artifacts.\",\"iterations\":[1]}\n+    {\"approach\":\"Move authoritative content into SQLite\",\"reason\":\"Consumer hydration semantics rely on bounded flat artifacts.\",\"iterations\":[1]},\n+    {\"approach\":\"Flip the adapter default without publishing and owning the database lifecycle\",\"reason\":\"Clean checkouts have no generation pointer and reads correctly fail closed.\",\"iterations\":[2]},\n+    {\"approach\":\"Use feature richness as proof of value\",\"reason\":\"Implemented supply does not establish observed consumer demand.\",\"iterations\":[2]}\n@@\n-    \"iterationsCompleted\": 1,\n-    \"openQuestions\": 4,\n-    \"resolvedQuestions\": 1,\n-    \"keyFindings\": 3,\n+    \"iterationsCompleted\": 2,\n+    \"openQuestions\": 3,\n+    \"resolvedQuestions\": 2,\n+    \"keyFindings\": 6,\n@@\n-    \"coverageBySources\": {\"code\":5,\"spec\":0,\"tests\":0}\n+    \"coverageBySources\": {\"code\":11,\"spec\":0,\"tests\":0}\n*** Update File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-dashboard.md\n@@\n | 1 | Consumer contract and runtime path | 1.00 | 5 | complete |\n+| 2 | Persistent readiness and missing wiring | 0.85 | 6 | complete |\n@@\n-- 1/5 answered; 4 remaining.\n-- Answered: consumer contract and workload.\n+- 2/5 answered; 3 remaining.\n+- Answered: consumer contract; persistent readiness and missing wiring.\n@@\n-- Ratios: 1.00\n+- Ratios: 1.00 -> 0.85 (descending, still high novelty)\n@@\n - SQLite as authoritative content storage.\n+- Default flip without a publication lifecycle.\n+- Feature richness as proof of value.\n@@\n-Persistent-backend completeness and missing wiring/build work.\n+Economic case at current scale and limits of benchmark/relevance evidence.\n*** Update File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/research.md\n@@\n The decision should preserve the existing storage-neutral consumer facade. The four design modes require bounded generation-safe selection and flat-file hydration, not SQLite itself. [SOURCE: iteration-001.md]\n+\n+The database is a mature rebuildable projection, but not a complete product integration. Safe defaulting requires an initial publication, a corpus-refresh owner, artifact/bootstrap policy, monitoring and repair, and stronger live cutover gates. [SOURCE: iteration-002.md]\n@@\n - Legacy retrieval rebuilds and compares the live manifest on each query, creating the clearest potential benefit for a persistent index.\n+- Persistent retrieval supplies FTS5, vectors, RRF, cursors, attribution, immutable generations, rollback, telemetry, and an operator surface.\n+- Query/hydrate never auto-build; clean checkouts have no published generation.\n+- Shadow mode is a migration aid, not a complete relevance or strict ranking proof.\n*** Update File: .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/orchestration-status.log\n@@\n {\"event\":\"progress\",\"label\":\"sol-high-fast\",\"at\":\"2026-07-21T08:38:01Z\",\"duration_ms\":162000,\"loop_type\":\"research\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1,\"run\":1,\"status\":\"complete\",\"gauges\":{\"iterations\":1,\"elapsed_ms\":162000,\"score\":1.0}}\n+{\"event\":\"progress\",\"label\":\"sol-high-fast\",\"at\":\"2026-07-21T08:41:31Z\",\"duration_ms\":372000,\"loop_type\":\"research\",\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1,\"run\":2,\"status\":\"complete\",\"gauges\":{\"iterations\":2,\"elapsed_ms\":372000,\"score\":0.85}}\n*** End Patch"},"output":"Success. Updated the following files:\nA .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/prompts/iteration-002.md\nA .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/iterations/iteration-002.md\nA .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deltas/iter-002.jsonl\nM .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-state.jsonl\nM .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-strategy.md\nM .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/findings-registry.json\nM .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deep-research-dashboard.md\nM .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/research.md\nM .opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/orchestration-status.log","metadata":{"diff":"Index: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/prompts/iteration-002.md\n===================================================================\n--- /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/prompts/iteration-002.md\n+++ /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/prompts/iteration-002.md\n@@ -0,0 +1,7 @@\n+DEEP-RESEARCH ITERATION 2\n+\n+STATE SUMMARY: Iteration 2 of 5; 1/5 questions answered; last ratio 1.00; stop policy is max-iterations.\n+\n+Focus Area: Persistent-backend completeness and exact missing wiring/build work.\n+Constraints: Read state first; preserve the consumer facade; write only this lineage; no implementation.\n+Route: mode=research; target_agent=deep-research; execution=single_iteration; state_source=externalized_files.\n\nIndex: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/iterations/iteration-002.md\n===================================================================\n--- /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/iterations/iteration-002.md\n+++ /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/iterations/iteration-002.md\n@@ -0,0 +1,57 @@\n+# Iteration 2: Persistent Backend Readiness and Missing Wiring\n+\n+## Focus\n+\n+Assess whether the database is merely a sketch or a deployable projection, then enumerate what still separates it from a safe default.\n+\n+## Findings\n+\n+1. The persistent implementation is technically substantial, not a stub: schema v2 contains normalized style/provenance/artifact/facet/section tables, external-content FTS5, embeddings/jobs/vectors, relationships, immutable corpus generations, and indexes. [SOURCE: .opencode/skills/sk-design/styles/_db/schema.mjs:35-269]\n+2. Publication and rollback are implemented around immutable generation files plus an atomic `.current.json` manifest pointer. The operator supports `status`, `build`, `cutover`, `rollback`, and vector `repair`, retaining current plus one rollback generation. [SOURCE: .opencode/skills/sk-design/styles/_db/README.md:6-49] [SOURCE: .opencode/skills/sk-design/styles/_db/operator.mjs:75-185] [SOURCE: .opencode/skills/sk-design/styles/_db/operator.mjs:207-247]\n+3. Query semantics exceed today's consumer needs: structured, FTS5, and optional vector lanes feed deterministic weighted RRF, generation-bound cursors, attribution, and channel-local degradation. Consumers currently ask for at most five reference cards and do not supply evidence that vector search or pagination is required. [SOURCE: .opencode/skills/sk-design/styles/_db/retrieval.mjs:13-25] [SOURCE: .opencode/skills/sk-design/styles/_db/retrieval.mjs:168-294] [SOURCE: .opencode/skills/sk-design/styles/_db/retrieval.mjs:364-510] [INFERENCE: iteration 1 consumer evidence]\n+4. The code deliberately avoids implicit construction: `buildStyleDatabase()` is never invoked by query or hydrate, and the operator requires an explicit corpus path. Therefore changing the mode default alone would fail on a clean checkout because neither the default SQLite artifact nor its pointer exists. [SOURCE: .opencode/skills/sk-design/styles/_db/README.md:40-43] [SOURCE: .opencode/skills/sk-design/styles/_db/operator.mjs:213-226] [SOURCE: .opencode/skills/sk-design/styles/_db/schema.mjs:11-23]\n+5. A production cutover needs more than one successful build: it needs a refresh owner tied to corpus extraction/update, artifact distribution or deterministic local bootstrap, status/repair observability, and a failure policy. No such default-path lifecycle is visible in the facade or operator; reads fail closed rather than auto-building, which is correct for integrity but leaves operations unowned. [SOURCE: .opencode/skills/sk-design/styles/_db/README.md:27-49] [SOURCE: .opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs:144-166]\n+6. Shadow mode is a useful migration gate but its parity comparison intentionally tolerates generation hashes, content hashes, score values, and ranking mode. It checks projected cards and eligibility, not strict rank/score equivalence; default cutover should additionally use the differential oracle and live-corpus relevance/latency evidence. [SOURCE: .opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs:113-141] [SOURCE: .opencode/skills/sk-design/styles/_db/README.md:89-131]\n+\n+## Ruled Out\n+\n+- Calling the database \"unfinished\": the storage, publication, query, hydration, telemetry, and operator machinery is implemented and tested.\n+- Flipping `legacy` to `persistent` as the entire wiring plan: it would point clean checkouts at a missing publication pointer.\n+\n+## Dead Ends\n+\n+- Treating feature richness as proof of default-path value. The vector/cursor/relationship machinery is capability supply; observed consumer demand remains separate.\n+\n+## Edge Cases\n+\n+- Ambiguous input: \"build and populate\" could commit a generated DB or bootstrap locally. Both remain viable, but either requires an explicit freshness/distribution owner.\n+- Contradictory evidence: the implementation is deployable in isolation while the product integration is incomplete. This is not a code-quality contradiction; it is an ownership gap.\n+- Missing dependencies: no production workload trace or committed DB artifact.\n+- Partial success: readiness is established statically, not through a live full-corpus build in this write-restricted research lineage.\n+\n+## Sources Consulted\n+\n+- `.opencode/skills/sk-design/styles/_engine/persistent-adapter.mjs:1-357`\n+- `.opencode/skills/sk-design/styles/_db/README.md:1-147`\n+- `.opencode/skills/sk-design/styles/_db/indexer.mjs:1-480`\n+- `.opencode/skills/sk-design/styles/_db/schema.mjs:1-360`\n+- `.opencode/skills/sk-design/styles/_db/retrieval.mjs:1-520`\n+- `.opencode/skills/sk-design/styles/_db/operator.mjs:1-268`\n+\n+## Assessment\n+\n+- New information ratio: 0.85\n+- Novelty justification: Five findings are new and one refines the consumer-demand result from iteration 1.\n+- Questions addressed: persistent implementation completeness and exact default-path gap.\n+- Questions answered: the implementation is mature, but no build/distribution/refresh owner or cutover evidence makes it a real default.\n+- Confidence: high on static readiness; medium on operational effort until a full-corpus build and workload trace are measured.\n+\n+## Reflection\n+\n+- What worked and why: separating implementation completeness from integration completeness resolved the apparent \"built but unused\" paradox.\n+- What did not work and why: reading only the first indexer segment did not expose the full build function, but the operator and README independently establish its lifecycle and invocation contract.\n+- What I would do differently: quantify current benefits and recurring costs before treating the missing lifecycle as work worth funding.\n+\n+## Recommended Next Focus\n+\n+Measure the economic case from available evidence: corpus size, legacy query work, existing benchmark claims, DB build/repair burden, and missing relevance/workload validation.\n\nIndex: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deltas/iter-002.jsonl\n===================================================================\n--- /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deltas/iter-002.jsonl\n+++ /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/003-db-fate/research/lineages/sol-high-fast/deltas/iter-002.jsonl\n@@ -0,0 +1,4 @@\n+{\"type\":\"iteration\",\"iteration\":2,\"mode\":\"research\",\"target_agent\":\"deep-research\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=research target_agent=deep-research\",\"run\":2,\"status\":\"complete\",\"focus\":\"Persistent backend readiness and missing default-path wiring\",\"findingsCount\":6,\"newInfoRatio\":0.85,\"noveltyJustification\":\"Five findings are new and one refines the consumer-demand result from iteration 1.\",\"keyQuestions\":[\"How complete is the persistent implementation and what remains to make it default?\"],\"answeredQuestions\":[\"How complete is the persistent implementation and what remains to make it default?\"],\"ruledOut\":[\"The persistent database is only a stub\",\"Changing the adapter default is a complete cutover plan\",\"Implemented capabilities alone prove default-path value\"],\"focusTrack\":\"architecture\",\"edgeCase\":\"missing-dependency\",\"toolsUsed\":[\"Read\"],\"sourcesQueried\":[\"styles/_engine/persistent-adapter.mjs\",\"styles/_db/README.md\",\"styles/_db/indexer.mjs\",\"styles/_db/schema.mjs\",\"styles/_db/retrieval.mjs\",\"styles/_db/operator.mjs\"],\"timestamp\":\"2026-07-21T08:41:30Z\",\"durationMs\":208000,\"sessionId\":\"fanout-sol-high-fast-1784622756165-kgdopz\",\"generation\":1,\"executor\":{\"kind\":\"cli-opencode\",\"model\":\"openai/gpt-5.6-sol-fast\"},\"graphEvents\":[]}\n+{\"type\":\"finding\",\"id\":\"f-db-mature\",\"iteration\":2,\"summary\":\"The persistent projection, publication, retrieval, hydration, telemetry, and operator machinery is technically mature.\"}\n+{\"type\":\"finding\",\"id\":\"f-lifecycle-unowned\",\"iteration\":2,\"summary\":\"No default build, distribution, refresh, or repair owner exists.\"}\n+{\"type\":\"finding\",\"id\":\"f-shadow-bounded\",\"iteration\":2,\"summary\":\"Shadow parity is intentionally bounded and not sufficient alone for default cutover.\"}\n\nIndex: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Publi