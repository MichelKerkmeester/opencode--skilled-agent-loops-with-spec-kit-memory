lows, so\n\n  Line 2781:     the contract is {skill: deep-loop-workflows, mode: <workflowMode>} plus\n\n  Line 2785:     (deep-loop-workflows, research) WITHOUT flattening the mode distinction.\n\n  Line 2795:         \"skill\": MERGED_DEEP_SKILL_ID,\n\n  Line 2829:         recommendation.get(\"skill\") == MERGED_DEEP_SKILL_ID\n\n  Line 2836:         # (deep-loop-workflows) carries the winning mode; legacy mode-level ids\n\n  Line 2839:         if skill == MERGED_DEEP_SKILL_ID:\n\n  Line 3698:         return _find(MERGED_DEEP_SKILL_ID) or _find(legacy_id)\n\n  Line 4272:                         help='Dump the hardcoded deep-loop-workflows routing projection maps as JSON (consumed by the registry drift-guard test).')\n","metadata":{"matches":24,"truncated":false},"title":"deep-loop-workflows|deep-loop-runtime|MERGED_DEEP_SKILL_ID|MODE_REGISTRY_PATH","time":{"start":1783487354545,"end":1783487354556}},"metadata":{"openai":{"itemId":"fc_06bd639e67fc5e50016a4ddb7a791c81919ea3575edc8a2188"}},"id":"prt_f4021568d001cmhiZ7jEswOx7h","sessionID":"ses_0bfeb66cbffe4XyuwEMaxiBvG7","messageID":"msg_f40212e02001P33Du5qYL6fPgo"}}
