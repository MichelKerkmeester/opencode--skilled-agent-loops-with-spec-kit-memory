\n}\n\n// --- Settings helpers (used by janitor + server routes) ---\n\nexport interface SettingRow {\n  key: string;\n  value: string;\n  updated_at: string;\n}\n\nexport function getSetting(key: string): string | null {\n  const db = getDb();\n  const row = db\n    .query<SettingRow, [string]>(\"SELECT value FROM settings WHERE key=?\")\n    .get(key);\n  return row?.value ?? null;\n}","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/shared-db.ts","text":"    }\n  }\n  throw lastError;\n}\n\n// --- Settings helpers (used by janitor + server routes) ---\n\nexport interface SettingRow {\n  key: string;\n  value: string;\n  updated_at: string;\n}\n\nexport function getSetting(key: string): string | null {\n  const db = getDb();\n  const row = db\n    .query<SettingRow, [string]>(\"SELECT value FROM settings WHERE key=?\")\n    .get(key);\n  return row?.value ?? null;\n}\n\nexport function setSetting(key: string, value: string): Promise<void> {\n  const db = getDb();\n  return writeQueue.enqueue(() => {\n    db.run(\n      `INSERT INTO settings (key, value, updated_at) VALUES (?, ?, datetime('now'))\n       ON CONFLICT(key) DO UPDATE SET value=excluded.value, updated_at=excluded.updated_at`,\n      [key, value],\n    );\n  }, db);\n}\n\nexport function getAllSettings(): Record<string, string> {\n  const db = getDb();\n  const rows = db\n    .query<SettingRow, []>(\"SELECT key, value FROM settings\")\n    .all();\n  return Object.fromEntries(rows.map((r) => [r.key, r.value]));\n}","lineStart":120,"lineEnd":158,"totalLines":158,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/packages/openltm-core/src/shared-db.ts","time":{"start":1780928563664,"end":1780928563672}},"metadata":{"openai":{"itemId":"fc_0af50de8b9242f54016a26d0337c8881