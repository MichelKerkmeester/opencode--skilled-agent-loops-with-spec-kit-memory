   311	3. Format with toFixed(1) and append unit.
   312	</pre-plan>
   313	
   314	\`\`\`ts
   315	export function formatBytes(n: number): string {
   316	  const units = ['B','KB','MB','GB'];
   317	  if (n === 0) return '0 B';
   318	  let i = 0; let v = n;
   319	  while (v >= 1024 && i < units.length - 1) { v /= 1024; i++; }
   320	  return v.toFixed(1) + ' ' + units[i];
   321	}
   322	\`\`\`
   323	
