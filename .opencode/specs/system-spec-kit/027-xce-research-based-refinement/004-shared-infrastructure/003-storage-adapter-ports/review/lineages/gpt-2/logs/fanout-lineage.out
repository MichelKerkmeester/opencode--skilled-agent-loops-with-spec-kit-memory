{"type":"text","timestamp":1781144200869,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"id":"prt_eb4778f58001SP986HdkV41tAt","messageID":"msg_eb4778162001F2alOO06lz0MYE","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","type":"text","text":"The port interfaces and adapters exist. I’m checking the routed call sites and contract tests for behavioral drift or unsupported completion claims.","time":{"start":1781144194904,"end":1781144200867},"metadata":{"openai":{"itemId":"msg_02d0ac507d0d4065016a2a1a82e6a88191b0b614f081414828","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781144201052,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_qnXwbWbTMy1Q7X3Yfh8sj5VS","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","offset":1,"limit":340},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Memo Storage\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import type Database from 'better-sqlite3';\n6: import { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n7: \n8: export interface MemoRecordInput {\n9:   componentPath: string;\n10:   inputFingerprint: string;\n11:   codeHash: string;\n12:   outputBlob: string;\n13:   computedAt?: string;\n14: }\n15: \n16: export interface MemoRecord extends MemoRecordInput {\n17:   computedAt: string;\n18: }\n19: \n20: export interface DependencyEdgeInput {\n21:   parentPath: string;\n22:   childPath: string;\n23:   kind: string;\n24: }\n25: \n26: export interface DependencyEdge extends DependencyEdgeInput {\n27:   createdAt: string;\n28: }\n29: \n30: export interface InvalidationResult {\n31:   invalidatedPaths: string[];\n32:   deletedMemoRecords: number;\n33: }\n34: \n35: function assertPath(value: string, label: string): void {\n36:   if (typeof value !== 'string' || value.trim().length === 0) {\n37:     throw new Error(`${label} must be a non-empty string`);\n38:   }\n39: }\n40: \n41: export function ensureMemoStorageSchema(database: Database.Database): void {\n42:   database.exec(`\n43:     CREATE TABLE IF NOT EXISTS memoization_records (\n44:       component_path TEXT NOT NULL,\n45:       input_fingerprint TEXT NOT NULL,\n46:       code_hash TEXT NOT NULL,\n47:       output_blob TEXT NOT NULL,\n48:       computed_at TEXT NOT NULL DEFAULT (datetime('now')),\n49:       PRIMARY KEY (component_path, input_fingerprint, code_hash)\n50:     );\n51: \n52:     CREATE TABLE IF NOT EXISTS dependency_edges (\n53:       parent_path TEXT NOT NULL,\n54:       child_path TEXT NOT NULL,\n55:       kind TEXT NOT NULL,\n56:       created_at TEXT NOT NULL DEFAULT (datetime('now')),\n57:       PRIMARY KEY (parent_path, child_path, kind),\n58:       CHECK(parent_path != child_path)\n59:     );\n60: \n61:     CREATE INDEX IF NOT EXISTS idx_memoization_records_component\n62:       ON memoization_records(component_path);\n63:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_parent\n64:       ON dependency_edges(parent_path);\n65:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_child\n66:       ON dependency_edges(child_path);\n67:     CREATE INDEX IF NOT EXISTS idx_dependency_edges_kind\n68:       ON dependency_edges(kind);\n69:   `);\n70: }\n71: \n72: function mapMemoRow(row: {\n73:   component_path: string;\n74:   input_fingerprint: string;\n75:   code_hash: string;\n76:   output_blob: string;\n77:   computed_at: string;\n78: }): MemoRecord {\n79:   return {\n80:     componentPath: row.component_path,\n81:     inputFingerprint: row.input_fingerprint,\n82:     codeHash: row.code_hash,\n83:     outputBlob: row.output_blob,\n84:     computedAt: row.computed_at,\n85:   };\n86: }\n87: \n88: function mapEdgeRow(row: {\n89:   parent_path: string;\n90:   child_path: string;\n91:   kind: string;\n92:   created_at: string;\n93: }): DependencyEdge {\n94:   return {\n95:     parentPath: row.parent_path,\n96:     childPath: row.child_path,\n97:     kind: row.kind,\n98:     createdAt: row.created_at,\n99:   };\n100: }\n101: \n102: export class MemoStore {\n103:   private dependencyEdgeCount: number;\n104:   private readonly graphTraversal: GraphTraversal;\n105: \n106:   constructor(\n107:     private readonly database: Database.Database,\n108:     graphTraversal: GraphTraversal = new BetterSqliteGraphTraversal(database),\n109:   ) {\n110:     ensureMemoStorageSchema(database);\n111:     this.graphTraversal = graphTraversal;\n112:     this.dependencyEdgeCount = this.countDependencyEdges();\n113:   }\n114: \n115:   private countDependencyEdges(): number {\n116:     const row = this.database.prepare(`\n117:       SELECT COUNT(*) AS edge_count\n118:       FROM dependency_edges\n119:     `).get() as { edge_count: number } | undefined;\n120:     return row?.edge_count ?? 0;\n121:   }\n122: \n123:   private insertDependencyEdge(edge: DependencyEdgeInput): void {\n124:     const result = this.database.prepare(`\n125:       INSERT OR IGNORE INTO dependency_edges (parent_path, child_path, kind)\n126:       VALUES (?, ?, ?)\n127:     `).run(edge.parentPath, edge.childPath, edge.kind) as { changes: number };\n128:     if (result.changes > 0) {\n129:       this.dependencyEdgeCount += result.changes;\n130:     }\n131:   }\n132: \n133:   getMemoRecord(componentPath: string, inputFingerprint: string, codeHash: string): MemoRecord | null {\n134:     const row = this.database.prepare(`\n135:       SELECT component_path, input_fingerprint, code_hash, output_blob, computed_at\n136:       FROM memoization_records\n137:       WHERE component_path = ?\n138:         AND input_fingerprint = ?\n139:         AND code_hash = ?\n140:       LIMIT 1\n141:     `).get(componentPath, inputFingerprint, codeHash) as Parameters<typeof mapMemoRow>[0] | undefined;\n142: \n143:     return row ? mapMemoRow(row) : null;\n144:   }\n145: \n146:   upsertMemoRecord(record: MemoRecordInput): void {\n147:     assertPath(record.componentPath, 'componentPath');\n148:     assertPath(record.inputFingerprint, 'inputFingerprint');\n149:     assertPath(record.codeHash, 'codeHash');\n150:     this.database.prepare(`\n151:       INSERT INTO memoization_records (\n152:         component_path,\n153:         input_fingerprint,\n154:         code_hash,\n155:         output_blob,\n156:         computed_at\n157:       ) VALUES (?, ?, ?, ?, COALESCE(?, datetime('now')))\n158:       ON CONFLICT(component_path, input_fingerprint, code_hash) DO UPDATE SET\n159:         output_blob = excluded.output_blob,\n160:         computed_at = excluded.computed_at\n161:     `).run(\n162:       record.componentPath,\n163:       record.inputFingerprint,\n164:       record.codeHash,\n165:       record.outputBlob,\n166:       record.computedAt ?? null,\n167:     );\n168:   }\n169: \n170:   deleteMemoRecords(componentPaths: readonly string[]): number {\n171:     const paths = Array.from(new Set(componentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n172:     if (paths.length === 0) {\n173:       return 0;\n174:     }\n175: \n176:     const placeholders = paths.map(() => '?').join(', ');\n177:     const result = this.database.prepare(`\n178:       DELETE FROM memoization_records\n179:       WHERE component_path IN (${placeholders})\n180:     `).run(...paths) as { changes: number };\n181:     return result.changes;\n182:   }\n183: \n184:   listDependencyEdges(parentPath?: string): DependencyEdge[] {\n185:     const rows = parentPath\n186:       ? this.database.prepare(`\n187:           SELECT parent_path, child_path, kind, created_at\n188:           FROM dependency_edges\n189:           WHERE parent_path = ?\n190:           ORDER BY parent_path, child_path, kind\n191:         `).all(parentPath) as Parameters<typeof mapEdgeRow>[0][]\n192:       : this.database.prepare(`\n193:           SELECT parent_path, child_path, kind, created_at\n194:           FROM dependency_edges\n195:           ORDER BY parent_path, child_path, kind\n196:         `).all() as Parameters<typeof mapEdgeRow>[0][];\n197: \n198:     return rows.map(mapEdgeRow);\n199:   }\n200: \n201:   addDependencyEdge(edge: DependencyEdgeInput): void {\n202:     assertPath(edge.parentPath, 'parentPath');\n203:     assertPath(edge.childPath, 'childPath');\n204:     assertPath(edge.kind, 'kind');\n205:     if (edge.parentPath === edge.childPath) {\n206:       throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n207:     }\n208:     if (this.dependencyEdgeCount > 0 && this.wouldCreateCycle(edge.parentPath, edge.childPath)) {\n209:       throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n210:     }\n211: \n212:     this.insertDependencyEdge(edge);\n213:   }\n214: \n215:   collectDependents(parentPaths: readonly string[]): string[] {\n216:     const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n217:     if (roots.length === 0 || this.dependencyEdgeCount === 0) {\n218:       return [];\n219:     }\n220: \n221:     return this.graphTraversal.collectDependencyReachability(roots).sort();\n222:   }\n223: \n224:   invalidateDependents(parentPaths: readonly string[], includeSources = false): InvalidationResult {\n225:     const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n226:     const invalidatedPaths = this.collectDependents(roots);\n227:     const deleteTargets = includeSources ? Array.from(new Set([...roots, ...invalidatedPaths])) : invalidatedPaths;\n228:     const deletedMemoRecords = this.deleteMemoRecords(deleteTargets);\n229:     return { invalidatedPaths, deletedMemoRecords };\n230:   }\n231: \n232:   private wouldCreateCycle(parentPath: string, childPath: string): boolean {\n233:     if (parentPath === childPath) {\n234:       return true;\n235:     }\n236: \n237:     return this.collectDependents([childPath]).includes(parentPath);\n238:   }\n239: }\n240: \n241: export function createMemoStore(\n242:   database: Database.Database,\n243:   graphTraversal?: GraphTraversal,\n244: ): MemoStore {\n245:   return new MemoStore(database, graphTraversal);\n246: }\n\n(End of file - total 246 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memo Storage\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n\nexport interface MemoRecordInput {\n  componentPath: string;\n  inputFingerprint: string;\n  codeHash: string;\n  outputBlob: string;\n  computedAt?: string;\n}\n\nexport interface MemoRecord extends MemoRecordInput {\n  computedAt: string;\n}\n\nexport interface DependencyEdgeInput {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memo Storage\n// ───────────────────────────────────────────────────────────────\n\nimport type Database from 'better-sqlite3';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from './ports/index.js';\n\nexport interface MemoRecordInput {\n  componentPath: string;\n  inputFingerprint: string;\n  codeHash: string;\n  outputBlob: string;\n  computedAt?: string;\n}\n\nexport interface MemoRecord extends MemoRecordInput {\n  computedAt: string;\n}\n\nexport interface DependencyEdgeInput {\n  parentPath: string;\n  childPath: string;\n  kind: string;\n}\n\nexport interface DependencyEdge extends DependencyEdgeInput {\n  createdAt: string;\n}\n\nexport interface InvalidationResult {\n  invalidatedPaths: string[];\n  deletedMemoRecords: number;\n}\n\nfunction assertPath(value: string, label: string): void {\n  if (typeof value !== 'string' || value.trim().length === 0) {\n    throw new Error(`${label} must be a non-empty string`);\n  }\n}\n\nexport function ensureMemoStorageSchema(database: Database.Database): void {\n  database.exec(`\n    CREATE TABLE IF NOT EXISTS memoization_records (\n      component_path TEXT NOT NULL,\n      input_fingerprint TEXT NOT NULL,\n      code_hash TEXT NOT NULL,\n      output_blob TEXT NOT NULL,\n      computed_at TEXT NOT NULL DEFAULT (datetime('now')),\n      PRIMARY KEY (component_path, input_fingerprint, code_hash)\n    );\n\n    CREATE TABLE IF NOT EXISTS dependency_edges (\n      parent_path TEXT NOT NULL,\n      child_path TEXT NOT NULL,\n      kind TEXT NOT NULL,\n      created_at TEXT NOT NULL DEFAULT (datetime('now')),\n      PRIMARY KEY (parent_path, child_path, kind),\n      CHECK(parent_path != child_path)\n    );\n\n    CREATE INDEX IF NOT EXISTS idx_memoization_records_component\n      ON memoization_records(component_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_parent\n      ON dependency_edges(parent_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_child\n      ON dependency_edges(child_path);\n    CREATE INDEX IF NOT EXISTS idx_dependency_edges_kind\n      ON dependency_edges(kind);\n  `);\n}\n\nfunction mapMemoRow(row: {\n  component_path: string;\n  input_fingerprint: string;\n  code_hash: string;\n  output_blob: string;\n  computed_at: string;\n}): MemoRecord {\n  return {\n    componentPath: row.component_path,\n    inputFingerprint: row.input_fingerprint,\n    codeHash: row.code_hash,\n    outputBlob: row.output_blob,\n    computedAt: row.computed_at,\n  };\n}\n\nfunction mapEdgeRow(row: {\n  parent_path: string;\n  child_path: string;\n  kind: string;\n  created_at: string;\n}): DependencyEdge {\n  return {\n    parentPath: row.parent_path,\n    childPath: row.child_path,\n    kind: row.kind,\n    createdAt: row.created_at,\n  };\n}\n\nexport class MemoStore {\n  private dependencyEdgeCount: number;\n  private readonly graphTraversal: GraphTraversal;\n\n  constructor(\n    private readonly database: Database.Database,\n    graphTraversal: GraphTraversal = new BetterSqliteGraphTraversal(database),\n  ) {\n    ensureMemoStorageSchema(database);\n    this.graphTraversal = graphTraversal;\n    this.dependencyEdgeCount = this.countDependencyEdges();\n  }\n\n  private countDependencyEdges(): number {\n    const row = this.database.prepare(`\n      SELECT COUNT(*) AS edge_count\n      FROM dependency_edges\n    `).get() as { edge_count: number } | undefined;\n    return row?.edge_count ?? 0;\n  }\n\n  private insertDependencyEdge(edge: DependencyEdgeInput): void {\n    const result = this.database.prepare(`\n      INSERT OR IGNORE INTO dependency_edges (parent_path, child_path, kind)\n      VALUES (?, ?, ?)\n    `).run(edge.parentPath, edge.childPath, edge.kind) as { changes: number };\n    if (result.changes > 0) {\n      this.dependencyEdgeCount += result.changes;\n    }\n  }\n\n  getMemoRecord(componentPath: string, inputFingerprint: string, codeHash: string): MemoRecord | null {\n    const row = this.database.prepare(`\n      SELECT component_path, input_fingerprint, code_hash, output_blob, computed_at\n      FROM memoization_records\n      WHERE component_path = ?\n        AND input_fingerprint = ?\n        AND code_hash = ?\n      LIMIT 1\n    `).get(componentPath, inputFingerprint, codeHash) as Parameters<typeof mapMemoRow>[0] | undefined;\n\n    return row ? mapMemoRow(row) : null;\n  }\n\n  upsertMemoRecord(record: MemoRecordInput): void {\n    assertPath(record.componentPath, 'componentPath');\n    assertPath(record.inputFingerprint, 'inputFingerprint');\n    assertPath(record.codeHash, 'codeHash');\n    this.database.prepare(`\n      INSERT INTO memoization_records (\n        component_path,\n        input_fingerprint,\n        code_hash,\n        output_blob,\n        computed_at\n      ) VALUES (?, ?, ?, ?, COALESCE(?, datetime('now')))\n      ON CONFLICT(component_path, input_fingerprint, code_hash) DO UPDATE SET\n        output_blob = excluded.output_blob,\n        computed_at = excluded.computed_at\n    `).run(\n      record.componentPath,\n      record.inputFingerprint,\n      record.codeHash,\n      record.outputBlob,\n      record.computedAt ?? null,\n    );\n  }\n\n  deleteMemoRecords(componentPaths: readonly string[]): number {\n    const paths = Array.from(new Set(componentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    if (paths.length === 0) {\n      return 0;\n    }\n\n    const placeholders = paths.map(() => '?').join(', ');\n    const result = this.database.prepare(`\n      DELETE FROM memoization_records\n      WHERE component_path IN (${placeholders})\n    `).run(...paths) as { changes: number };\n    return result.changes;\n  }\n\n  listDependencyEdges(parentPath?: string): DependencyEdge[] {\n    const rows = parentPath\n      ? this.database.prepare(`\n          SELECT parent_path, child_path, kind, created_at\n          FROM dependency_edges\n          WHERE parent_path = ?\n          ORDER BY parent_path, child_path, kind\n        `).all(parentPath) as Parameters<typeof mapEdgeRow>[0][]\n      : this.database.prepare(`\n          SELECT parent_path, child_path, kind, created_at\n          FROM dependency_edges\n          ORDER BY parent_path, child_path, kind\n        `).all() as Parameters<typeof mapEdgeRow>[0][];\n\n    return rows.map(mapEdgeRow);\n  }\n\n  addDependencyEdge(edge: DependencyEdgeInput): void {\n    assertPath(edge.parentPath, 'parentPath');\n    assertPath(edge.childPath, 'childPath');\n    assertPath(edge.kind, 'kind');\n    if (edge.parentPath === edge.childPath) {\n      throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n    }\n    if (this.dependencyEdgeCount > 0 && this.wouldCreateCycle(edge.parentPath, edge.childPath)) {\n      throw new Error(`Dependency edge would create a cycle: ${edge.parentPath} -> ${edge.childPath}`);\n    }\n\n    this.insertDependencyEdge(edge);\n  }\n\n  collectDependents(parentPaths: readonly string[]): string[] {\n    const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    if (roots.length === 0 || this.dependencyEdgeCount === 0) {\n      return [];\n    }\n\n    return this.graphTraversal.collectDependencyReachability(roots).sort();\n  }\n\n  invalidateDependents(parentPaths: readonly string[], includeSources = false): InvalidationResult {\n    const roots = Array.from(new Set(parentPaths.filter((value) => typeof value === 'string' && value.length > 0)));\n    const invalidatedPaths = this.collectDependents(roots);\n    const deleteTargets = includeSources ? Array.from(new Set([...roots, ...invalidatedPaths])) : invalidatedPaths;\n    const deletedMemoRecords = this.deleteMemoRecords(deleteTargets);\n    return { invalidatedPaths, deletedMemoRecords };\n  }\n\n  private wouldCreateCycle(parentPath: string, childPath: string): boolean {\n    if (parentPath === childPath) {\n      return true;\n    }\n\n    return this.collectDependents([childPath]).includes(parentPath);\n  }\n}\n\nexport function createMemoStore(\n  database: Database.Database,\n  graphTraversal?: GraphTraversal,\n): MemoStore {\n  return new MemoStore(database, graphTraversal);\n}","lineStart":1,"lineEnd":246,"totalLines":246,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/memo.ts","time":{"start":1781144201042,"end":1781144201051}},"metadata":{"openai":{"itemId":"fc_02d0ac507d0d4065016a2a1a88c750819189c47f73d49ab633"}},"id":"prt_eb477a6e0001fJ2oZrkL2IGRAg","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb4778162001F2alOO06lz0MYE"}}
{"type":"tool_use","timestamp":1781144201178,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_pMyZsVyhthOXsey14p6RK4nE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Causal Boost\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Causal neighbor boost and injection\n5: // Graph-traversal score boosting via causal edge relationships.\n6: // Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n7: // For results related to top seed results via weighted CTE.\n8: //\n9: // Sparse-First + Intent-Aware Traversal:\n10: // - Sparse-first policy — density < 0.5 disables community\n11: //   detection and constrains traversal to typed 1-hop expansion only.\n12: // - Intent-aware edge traversal — maps classified query intents\n13: //   to edge-type priority orderings; computes traversal score as:\n14: //   score = seedScore * edgePrior * hopDecay * freshness\n15: // Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\n16: import { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\n17: import { routeQueryConcepts } from './entity-linker.js';\n18: import { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n19: \n20: import type Database from 'better-sqlite3';\n21: \n22: /** Maximum graph traversal depth. Beyond 2 hops, signal degrades and queries become expensive. */\n23: const MAX_HOPS = 2;\n24: /** Per-hop boost cap. 0.05 keeps causal nudge subtle relative to semantic scores (~0.5–1.0). */\n25: const MAX_BOOST_PER_HOP = 0.05;\n26: /** Combined causal + session boost ceiling to prevent runaway amplification. */\n27: const MAX_COMBINED_BOOST = 0.20;\n28: /** Top fraction of result set used as graph walk seed nodes. */\n29: const SEED_FRACTION = 0.25;\n30: /** Absolute cap on seed nodes regardless of result set size. */\n31: const MAX_SEED_RESULTS = 5;\n32: \n33: // ───────────────────────────────────────────────────────────────\n34: // SPARSE-FIRST POLICY CONSTANTS\n35: // ───────────────────────────────────────────────────────────────\n36: /** Graph density threshold below which community detection is disabled\n37:  * and traversal is constrained to typed 1-hop expansion only.\n38:  * Density = edgeCount / totalMemories (see edge-density.ts). */\n39: const SPARSE_DENSITY_THRESHOLD = 0.5;\n40: \n41: /** Traversal depth used in sparse mode (1-hop typed expansion). */\n42: const SPARSE_MAX_HOPS = 1;\n43: \n44: /** Default traversal depth for typed traversal helper policies. */\n45: const DEFAULT_TYPED_TRAVERSAL_DEPTH = SPARSE_MAX_HOPS;\n46: \n47: // ───────────────────────────────────────────────────────────────\n48: // INTENT-AWARE EDGE TRAVERSAL\n49: // ───────────────────────────────────────────────────────────────\n50: /** Per-hop decay factor applied to traversal score. 1-hop = 1.0, 2-hop = 0.5. */\n51: const HOP_DECAY_BASE = 1.0;\n52: \n53: /**\n54:  * Intent-to-edge-type priority ordering.\n55:  * Maps each query intent to an ordered list of edge relation types.\n56:  * Earlier entries in the list receive higher edge prior scores.\n57:  *\n58:  * Scores are normalized: first-listed relation = 1.0, second = 0.75, remaining = 0.5.\n59:  */\n60: const INTENT_EDGE_PRIORITY: Record<string, string[]> = {\n61:   fix_bug:        ['CORRECTION', 'DEPENDS_ON', 'supersedes', 'caused'],\n62:   add_feature:    ['EXTENDS', 'DEPENDS_ON', 'enabled', 'derived_from'],\n63:   find_decision:  ['PREFERENCE', 'CORRECTION', 'supersedes', 'contradicts'],\n64:   // Defaults for other intents — use existing relation-weight ordering\n65:   understand:     ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n66:   find_spec:      ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n67:   refactor:       ['caused', 'derived_from', 'enabled', 'supports', 'supersedes', 'contradicts'],\n68:   security_audit: ['caused', 'contradicts', 'supersedes', 'enabled', 'supports', 'derived_from'],\n69: };\n70: \n71: /** Fallback priority list when intent is unrecognized. */\n72: const DEFAULT_EDGE_PRIORITY = ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'];\n73: \n74: /** Edge prior score tiers: 1st priority = 1.0, 2nd = 0.75, remaining = 0.5. */\n75: const EDGE_PRIOR_TIERS = [1.0, 0.75, 0.5];\n76: const DEFAULT_EDGE_PRIOR = 1.0;\n77: const FRESHNESS_DECAY_WINDOW_MS = 30 * 24 * 60 * 60 * 1000;\n78: \n79: /**\n80:  * Relation-type weight multipliers for causal edge traversal.\n81:  * Applied during CTE accumulation so stronger relation types (supersedes)\n82:  * amplify the boost while weaker ones (contradicts) attenuate it.\n83:  *\n84:  * These multipliers serve a DIFFERENT purpose from RELATION_WEIGHTS in\n85:  * causal-edges.ts. causal-edges weights are applied during chain traversal\n86:  * scoring (getCausalChain), while these are applied during the causal-boost\n87:  * CTE walk (getNeighborBoosts) for search result amplification. The value\n88:  * ranges overlap but are tuned independently for their respective contexts:\n89:  *   - causal-edges: traversal strength propagation (range 0.8–1.5)\n90:  *   - causal-boost: search result boost amplitude (range 0.8–1.5)\n91:  */\n92: const RELATION_WEIGHT_MULTIPLIERS: Record<string, number> = {\n93:   supersedes: 1.5,\n94:   contradicts: 0.8,\n95:   caused: 1.0,\n96:   enabled: 1.0,\n97:   derived_from: 1.0,\n98:   supports: 1.0,\n99: };\n100: \n101: interface RankedSearchResult extends Record<string, unknown> {\n102:   id: number;\n103:   score?: number;\n104:   rrfScore?: number;\n105:   intentAdjustedScore?: number;\n106:   attentionScore?: number;\n107:   similarity?: number;\n108:   sessionBoost?: number;\n109:   baseScore?: number;\n110:   causalBoost?: number;\n111:   injectedByCausalBoost?: boolean;\n112: }\n113: \n114: interface CausalBoostMetadata {\n115:   enabled: boolean;\n116:   applied: boolean;\n117:   boostedCount: number;\n118:   injectedCount: number;\n119:   maxBoostApplied: number;\n120:   traversalDepth: number;\n121:   /** True when sparse-first policy was active (density < threshold) */\n122:   sparseModeActive?: boolean;\n123:   /** Intent used for edge traversal scoring (if typed traversal enabled) */\n124:   intentUsed?: string;\n125: }\n126: \n127: /** Options for applyCausalBoost — extended with sparse-first parameters. */\n128: interface CausalBoostOptions {\n129:   /** Graph density (edgeCount / totalMemories). Used for sparse-first gate. */\n130:   graphDensity?: number;\n131:   /** Classified query intent. Used for intent-aware edge priority mapping. */\n132:   intent?: string;\n133:   /** Freshness factor [0,1] applied to traversal scoring. Defaults to 1.0. */\n134:   freshness?: number;\n135: }\n136: \n137: interface NeighborBoost {\n138:   boost: number;\n139:   hopCount: number;\n140: }\n141: \n142: let db: Database.Database | null = null;\n143: let graphTraversal: GraphTraversal | null = null;\n144: \n145: /**\n146:  * Check whether the causal boost feature flag is enabled.\n147:  * Default: ON (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n148:  * When enabled, causal graph traversal amplifies scores for results\n149:  * connected to top-ranked results via causal edges.\n150:  *\n151:  * Delegates to the canonical flag check in search-flags.ts.\n152:  */\n153: function isEnabled(): boolean {\n154:   return isCausalBoostEnabled();\n155: }\n156: \n157: /**\n158:  * Check whether the typed traversal feature flag is enabled.\n159:  * Default: ON (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n160:  * Activates sparse-first + intent-aware traversal.\n161:  */\n162: function isTypedTraversalEnabled(): boolean {\n163:   return _isTypedTraversalEnabled();\n164: }\n165: \n166: /** Store the database reference used by causal edge traversal queries. */\n167: function init(database: Database.Database): void {\n168:   db = database;\n169:   graphTraversal = new BetterSqliteGraphTraversal(database);\n170: }\n171: \n172: // ───────────────────────────────────────────────────────────────\n173: // SPARSE-FIRST POLICY\n174: // ───────────────────────────────────────────────────────────────\n175: \n176: /**\n177:  * Determine whether sparse mode should be active for this traversal pass.\n178:  * Sparse mode is active when:\n179:  *   - SPECKIT_TYPED_TRAVERSAL is enabled, AND\n180:  *   - graphDensity is a finite number below SPARSE_DENSITY_THRESHOLD (0.5)\n181:  *\n182:  * When sparse mode is active:\n183:  *   - Community detection is suppressed (caller must respect this)\n184:  *   - Traversal is constrained to SPARSE_MAX_HOPS (1)\n185:  */\n186: function isSparseMode(graphDensity: number | undefined): boolean {\n187:   if (!isTypedTraversalEnabled()) return false;\n188:   if (typeof graphDensity !== 'number' || !Number.isFinite(graphDensity)) return false;\n189:   return graphDensity < SPARSE_DENSITY_THRESHOLD;\n190: }\n191: \n192: interface SparseFirstTraversalPolicy {\n193:   sparseModeActive: boolean;\n194:   communityDetectionEnabled: boolean;\n195: }\n196: \n197: /**\n198:  * Resolve the sparse-first policy gate for callers that need a simple\n199:  * community-detection decision without running the full boost pipeline.\n200:  */\n201: function resolveSparseFirstTraversalPolicy(graphDensity: number | undefined): SparseFirstTraversalPolicy {\n202:   const sparseModeActive = isSparseMode(graphDensity);\n203:   return {\n204:     sparseModeActive,\n205:     communityDetectionEnabled: !sparseModeActive,\n206:   };\n207: }\n208: \n209: /**\n210:  * Resolve traversal depth for typed traversal helper callers.\n211:  * Typed traversal defaults to 1-hop and stays within the supported range.\n212:  * When the flag is off, preserve the legacy MAX_HOPS behavior.\n213:  */\n214: function resolveTraversalDepth(depth: number = DEFAULT_TYPED_TRAVERSAL_DEPTH): number {\n215:   if (!isTypedTraversalEnabled()) {\n216:     return MAX_HOPS;\n217:   }\n218: \n219:   if (!Number.isFinite(depth)) {\n220:     return DEFAULT_TYPED_TRAVERSAL_DEPTH;\n221:   }\n222: \n223:   return Math.max(DEFAULT_TYPED_TRAVERSAL_DEPTH, Math.min(MAX_HOPS, Math.trunc(depth)));\n224: }\n225: \n226: // ───────────────────────────────────────────────────────────────\n227: // INTENT-AWARE EDGE TRAVERSAL HELPERS\n228: // ───────────────────────────────────────────────────────────────\n229: \n230: /**\n231:  * Compute the edge prior score for a given relation type and intent.\n232:  * Returns a normalized score in [0.5, 1.0] based on priority position.\n233:  *\n234:  * Canonical relation names from causal-boost are lower-cased (e.g. 'supersedes').\n235:  * Intent priority lists may include upper-case semantic labels (e.g. 'CORRECTION').\n236:  * Matching is case-insensitive against both the label and any alias.\n237:  *\n238:  * Alias map: CORRECTION → supersedes | contradicts\n239:  *            DEPENDS_ON → caused | enabled | derived_from\n240:  *            EXTENDS    → enabled | derived_from\n241:  *            PREFERENCE → supports\n242:  */\n243: const EDGE_LABEL_ALIASES: Record<string, string[]> = {\n244:   CORRECTION:  ['supersedes', 'contradicts'],\n245:   DEPENDS_ON:  ['caused', 'enabled', 'derived_from'],\n246:   EXTENDS:     ['enabled', 'derived_from'],\n247:   PREFERENCE:  ['supports'],\n248: };\n249: \n250: function resolveEdgePrior(relation: string, intent: string): number {\n251:   if (!isTypedTraversalEnabled()) return 1.0;\n252: \n253:   const priority = INTENT_EDGE_PRIORITY[intent] ?? DEFAULT_EDGE_PRIORITY;\n254:   const relLower = relation.toLowerCase();\n255: \n256:   for (let i = 0; i < priority.length; i++) {\n257:     const entry = priority[i];\n258:     if (!entry) continue;\n259:     // Exact match (case-insensitive)\n260:     if (entry.toLowerCase() === relLower) {\n\n(Showing lines 1-260 of 773. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Boost\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal neighbor boost and injection\n// Graph-traversal score boosting via causal edge relationships.\n// Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n// For results related to top seed results via weighted CTE.\n//\n// Sparse-First + Intent-Aware Traversal:\n// - Sparse-first policy — density < 0.5 disables community\n//   detection and constrains traversal to typed 1-hop expansion only.\n// - Intent-aware edge traversal — maps classified query intents\n//   to edge-type priority orderings; computes traversal score as:\n//   score = seedScore * edgePrior * hopDecay * freshness\n// Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\nimport { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\nimport { routeQueryConcepts } from './entity-linker.js';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n\nimport type Database from 'better-sqlite3';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Boost\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal neighbor boost and injection\n// Graph-traversal score boosting via causal edge relationships.\n// Walks the causal_edges graph up to MAX_HOPS, amplifying scores\n// For results related to top seed results via weighted CTE.\n//\n// Sparse-First + Intent-Aware Traversal:\n// - Sparse-first policy — density < 0.5 disables community\n//   detection and constrains traversal to typed 1-hop expansion only.\n// - Intent-aware edge traversal — maps classified query intents\n//   to edge-type priority orderings; computes traversal score as:\n//   score = seedScore * edgePrior * hopDecay * freshness\n// Both requirements are gated behind SPECKIT_TYPED_TRAVERSAL (default ON, graduated).\nimport { isCausalBoostEnabled, isTypedTraversalEnabled as _isTypedTraversalEnabled, isGraphContextInjectionEnabled } from './search-flags.js';\nimport { routeQueryConcepts } from './entity-linker.js';\nimport { BetterSqliteGraphTraversal, type GraphTraversal } from '../storage/ports/index.js';\n\nimport type Database from 'better-sqlite3';\n\n/** Maximum graph traversal depth. Beyond 2 hops, signal degrades and queries become expensive. */\nconst MAX_HOPS = 2;\n/** Per-hop boost cap. 0.05 keeps causal nudge subtle relative to semantic scores (~0.5–1.0). */\nconst MAX_BOOST_PER_HOP = 0.05;\n/** Combined causal + session boost ceiling to prevent runaway amplification. */\nconst MAX_COMBINED_BOOST = 0.20;\n/** Top fraction of result set used as graph walk seed nodes. */\nconst SEED_FRACTION = 0.25;\n/** Absolute cap on seed nodes regardless of result set size. */\nconst MAX_SEED_RESULTS = 5;\n\n// ───────────────────────────────────────────────────────────────\n// SPARSE-FIRST POLICY CONSTANTS\n// ───────────────────────────────────────────────────────────────\n/** Graph density threshold below which community detection is disabled\n * and traversal is constrained to typed 1-hop expansion only.\n * Density = edgeCount / totalMemories (see edge-density.ts). */\nconst SPARSE_DENSITY_THRESHOLD = 0.5;\n\n/** Traversal depth used in sparse mode (1-hop typed expansion). */\nconst SPARSE_MAX_HOPS = 1;\n\n/** Default traversal depth for typed traversal helper policies. */\nconst DEFAULT_TYPED_TRAVERSAL_DEPTH = SPARSE_MAX_HOPS;\n\n// ───────────────────────────────────────────────────────────────\n// INTENT-AWARE EDGE TRAVERSAL\n// ───────────────────────────────────────────────────────────────\n/** Per-hop decay factor applied to traversal score. 1-hop = 1.0, 2-hop = 0.5. */\nconst HOP_DECAY_BASE = 1.0;\n\n/**\n * Intent-to-edge-type priority ordering.\n * Maps each query intent to an ordered list of edge relation types.\n * Earlier entries in the list receive higher edge prior scores.\n *\n * Scores are normalized: first-listed relation = 1.0, second = 0.75, remaining = 0.5.\n */\nconst INTENT_EDGE_PRIORITY: Record<string, string[]> = {\n  fix_bug:        ['CORRECTION', 'DEPENDS_ON', 'supersedes', 'caused'],\n  add_feature:    ['EXTENDS', 'DEPENDS_ON', 'enabled', 'derived_from'],\n  find_decision:  ['PREFERENCE', 'CORRECTION', 'supersedes', 'contradicts'],\n  // Defaults for other intents — use existing relation-weight ordering\n  understand:     ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n  find_spec:      ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'],\n  refactor:       ['caused', 'derived_from', 'enabled', 'supports', 'supersedes', 'contradicts'],\n  security_audit: ['caused', 'contradicts', 'supersedes', 'enabled', 'supports', 'derived_from'],\n};\n\n/** Fallback priority list when intent is unrecognized. */\nconst DEFAULT_EDGE_PRIORITY = ['caused', 'enabled', 'derived_from', 'supports', 'supersedes', 'contradicts'];\n\n/** Edge prior score tiers: 1st priority = 1.0, 2nd = 0.75, remaining = 0.5. */\nconst EDGE_PRIOR_TIERS = [1.0, 0.75, 0.5];\nconst DEFAULT_EDGE_PRIOR = 1.0;\nconst FRESHNESS_DECAY_WINDOW_MS = 30 * 24 * 60 * 60 * 1000;\n\n/**\n * Relation-type weight multipliers for causal edge traversal.\n * Applied during CTE accumulation so stronger relation types (supersedes)\n * amplify the boost while weaker ones (contradicts) attenuate it.\n *\n * These multipliers serve a DIFFERENT purpose from RELATION_WEIGHTS in\n * causal-edges.ts. causal-edges weights are applied during chain traversal\n * scoring (getCausalChain), while these are applied during the causal-boost\n * CTE walk (getNeighborBoosts) for search result amplification. The value\n * ranges overlap but are tuned independently for their respective contexts:\n *   - causal-edges: traversal strength propagation (range 0.8–1.5)\n *   - causal-boost: search result boost amplitude (range 0.8–1.5)\n */\nconst RELATION_WEIGHT_MULTIPLIERS: Record<string, number> = {\n  supersedes: 1.5,\n  contradicts: 0.8,\n  caused: 1.0,\n  enabled: 1.0,\n  derived_from: 1.0,\n  supports: 1.0,\n};\n\ninterface RankedSearchResult extends Record<string, unknown> {\n  id: number;\n  score?: number;\n  rrfScore?: number;\n  intentAdjustedScore?: number;\n  attentionScore?: number;\n  similarity?: number;\n  sessionBoost?: number;\n  baseScore?: number;\n  causalBoost?: number;\n  injectedByCausalBoost?: boolean;\n}\n\ninterface CausalBoostMetadata {\n  enabled: boolean;\n  applied: boolean;\n  boostedCount: number;\n  injectedCount: number;\n  maxBoostApplied: number;\n  traversalDepth: number;\n  /** True when sparse-first policy was active (density < threshold) */\n  sparseModeActive?: boolean;\n  /** Intent used for edge traversal scoring (if typed traversal enabled) */\n  intentUsed?: string;\n}\n\n/** Options for applyCausalBoost — extended with sparse-first parameters. */\ninterface CausalBoostOptions {\n  /** Graph density (edgeCount / totalMemories). Used for sparse-first gate. */\n  graphDensity?: number;\n  /** Classified query intent. Used for intent-aware edge priority mapping. */\n  intent?: string;\n  /** Freshness factor [0,1] applied to traversal scoring. Defaults to 1.0. */\n  freshness?: number;\n}\n\ninterface NeighborBoost {\n  boost: number;\n  hopCount: number;\n}\n\nlet db: Database.Database | null = null;\nlet graphTraversal: GraphTraversal | null = null;\n\n/**\n * Check whether the causal boost feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_CAUSAL_BOOST=false to disable.\n * When enabled, causal graph traversal amplifies scores for results\n * connected to top-ranked results via causal edges.\n *\n * Delegates to the canonical flag check in search-flags.ts.\n */\nfunction isEnabled(): boolean {\n  return isCausalBoostEnabled();\n}\n\n/**\n * Check whether the typed traversal feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_TYPED_TRAVERSAL=false to disable.\n * Activates sparse-first + intent-aware traversal.\n */\nfunction isTypedTraversalEnabled(): boolean {\n  return _isTypedTraversalEnabled();\n}\n\n/** Store the database reference used by causal edge traversal queries. */\nfunction init(database: Database.Database): void {\n  db = database;\n  graphTraversal = new BetterSqliteGraphTraversal(database);\n}\n\n// ───────────────────────────────────────────────────────────────\n// SPARSE-FIRST POLICY\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Determine whether sparse mode should be active for this traversal pass.\n * Sparse mode is active when:\n *   - SPECKIT_TYPED_TRAVERSAL is enabled, AND\n *   - graphDensity is a finite number below SPARSE_DENSITY_THRESHOLD (0.5)\n *\n * When sparse mode is active:\n *   - Community detection is suppressed (caller must respect this)\n *   - Traversal is constrained to SPARSE_MAX_HOPS (1)\n */\nfunction isSparseMode(graphDensity: number | undefined): boolean {\n  if (!isTypedTraversalEnabled()) return false;\n  if (typeof graphDensity !== 'number' || !Number.isFinite(graphDensity)) return false;\n  return graphDensity < SPARSE_DENSITY_THRESHOLD;\n}\n\ninterface SparseFirstTraversalPolicy {\n  sparseModeActive: boolean;\n  communityDetectionEnabled: boolean;\n}\n\n/**\n * Resolve the sparse-first policy gate for callers that need a simple\n * community-detection decision without running the full boost pipeline.\n */\nfunction resolveSparseFirstTraversalPolicy(graphDensity: number | undefined): SparseFirstTraversalPolicy {\n  const sparseModeActive = isSparseMode(graphDensity);\n  return {\n    sparseModeActive,\n    communityDetectionEnabled: !sparseModeActive,\n  };\n}\n\n/**\n * Resolve traversal depth for typed traversal helper callers.\n * Typed traversal defaults to 1-hop and stays within the supported range.\n * When the flag is off, preserve the legacy MAX_HOPS behavior.\n */\nfunction resolveTraversalDepth(depth: number = DEFAULT_TYPED_TRAVERSAL_DEPTH): number {\n  if (!isTypedTraversalEnabled()) {\n    return MAX_HOPS;\n  }\n\n  if (!Number.isFinite(depth)) {\n    return DEFAULT_TYPED_TRAVERSAL_DEPTH;\n  }\n\n  return Math.max(DEFAULT_TYPED_TRAVERSAL_DEPTH, Math.min(MAX_HOPS, Math.trunc(depth)));\n}\n\n// ───────────────────────────────────────────────────────────────\n// INTENT-AWARE EDGE TRAVERSAL HELPERS\n// ───────────────────────────────────────────────────────────────\n\n/**\n * Compute the edge prior score for a given relation type and intent.\n * Returns a normalized score in [0.5, 1.0] based on priority position.\n *\n * Canonical relation names from causal-boost are lower-cased (e.g. 'supersedes').\n * Intent priority lists may include upper-case semantic labels (e.g. 'CORRECTION').\n * Matching is case-insensitive against both the label and any alias.\n *\n * Alias map: CORRECTION → supersedes | contradicts\n *            DEPENDS_ON → caused | enabled | derived_from\n *            EXTENDS    → enabled | derived_from\n *            PREFERENCE → supports\n */\nconst EDGE_LABEL_ALIASES: Record<string, string[]> = {\n  CORRECTION:  ['supersedes', 'contradicts'],\n  DEPENDS_ON:  ['caused', 'enabled', 'derived_from'],\n  EXTENDS:     ['enabled', 'derived_from'],\n  PREFERENCE:  ['supports'],\n};\n\nfunction resolveEdgePrior(relation: string, intent: string): number {\n  if (!isTypedTraversalEnabled()) return 1.0;\n\n  const priority = INTENT_EDGE_PRIORITY[intent] ?? DEFAULT_EDGE_PRIORITY;\n  const relLower = relation.toLowerCase();\n\n  for (let i = 0; i < priority.length; i++) {\n    const entry = priority[i];\n    if (!entry) continue;\n    // Exact match (case-insensitive)\n    if (entry.toLowerCase() === relLower) {","lineStart":1,"lineEnd":260,"totalLines":773,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/causal-boost.ts","time":{"start":1781144201166,"end":1781144201176}},"metadata":{"openai":{"itemId":"fc_02d0ac507d0d4065016a2a1a88c7608191991105797215f54f"}},"id":"prt_eb477a79a001XwzwYJ7RvwAp7n","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb4778162001F2alOO06lz0MYE"}}
{"type":"tool_use","timestamp":1781144201218,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_yoWVOBxsfEeSLCUCfqpkg64S","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","offset":320,"limit":285},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n320:       reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n321:       prior_hash: null,\n322:       new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n323:       linked_memory_ids: deletedIds.slice(0, 50),\n324:       decision_meta: {\n325:         tool: 'memory_retention_sweep',\n326:         reason: 'retention_expired',\n327:         totalDeleted: deletedIds.length,\n328:         originalDeleteAfter: candidates\n329:           .filter((candidate) => deletedIds.includes(candidate.id))\n330:           .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n331:       },\n332:       actor: 'mcp:memory_retention_sweep',\n333:     });\n334:     return true;\n335:   } catch (error: unknown) {\n336:     const message = error instanceof Error ? error.message : String(error);\n337:     console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n338:     return false;\n339:   }\n340: }\n341: \n342: function runPostDeleteMaintenance(database: Database.Database): void {\n343:   try {\n344:     database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n345:   } catch (error: unknown) {\n346:     const message = error instanceof Error ? error.message : String(error);\n347:     console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n348:   }\n349: \n350:   const maintenance = new BetterSqliteMaintenance(database, {\n351:     onMaintenanceError: reportRetentionMaintenanceError,\n352:   });\n353:   maintenance.vacuum();\n354:   maintenance.checkpoint({ mode: 'truncate' });\n355: }\n356: \n357: function reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n358:   const message = error instanceof Error ? error.message : String(error);\n359:   if (operation === 'auto_vacuum') {\n360:     console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n361:   } else if (operation === 'incremental_vacuum') {\n362:     console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n363:   } else if (operation === 'wal_checkpoint') {\n364:     console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n365:   }\n366: }\n367: \n368: /**\n369:  * Sweep expired governed memory rows.\n370:  *\n371:  * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n372:  * to enforce the ISO timestamps persisted by governed ingest.\n373:  */\n374: export function runMemoryRetentionSweep(\n375:   database: Database.Database,\n376:   args: MemoryRetentionSweepArgs = {},\n377: ): MemoryRetentionSweepResult {\n378:   const startTime = Date.now();\n379:   const dryRun = args.dryRun === true;\n380:   const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n381: \n382:   if (!hasTable(database, 'memory_index')) {\n383:     return {\n384:       swept: 0,\n385:       retained: 0,\n386:       protectedCount: 0,\n387:       dryRun,\n388:       durationMs: Date.now() - startTime,\n389:       candidates: [],\n390:       deletedIds: [],\n391:       protectedIds: [],\n392:       ledgerRecorded: null,\n393:       tombstoneState: {\n394:         usesPurgeablePartition: false,\n395:         usingPurgeableIndex: false,\n396:         candidateCount: 0,\n397:         deletedCount: 0,\n398:       },\n399:       edgeState: {\n400:         causalEdgesTablePresent: false,\n401:         candidateEdgeCount: 0,\n402:       },\n403:     };\n404:   }\n405: \n406:   const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n407:   const initialEdgeState = buildEdgeState(database, candidates);\n408:   const feedbackRetention = isFeedbackRetentionLearningEnabled()\n409:     ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n410:     : null;\n411: \n412:   if (dryRun || candidates.length === 0) {\n413:     const totalRows = countRows(database);\n414:     const dryRunProtectedIds = candidates\n415:       .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n416:       .map((candidate) => candidate.id);\n417:     return {\n418:       swept: 0,\n419:       retained: totalRows,\n420:       protectedCount: dryRunProtectedIds.length,\n421:       dryRun,\n422:       durationMs: Date.now() - startTime,\n423:       candidates,\n424:       deletedIds: [],\n425:       protectedIds: dryRunProtectedIds,\n426:       ledgerRecorded: null,\n427:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n428:       edgeState: initialEdgeState,\n429:       ...(feedbackRetention ? { feedbackRetention } : {}),\n430:     };\n431:   }\n432: \n433:   if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n434:     const auditTx = database.transaction(() => {\n435:       feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n436:         database,\n437:         candidates,\n438:         feedbackRetention,\n439:         false,\n440:       );\n441:     });\n442:     auditTx();\n443: \n444:     return {\n445:       swept: 0,\n446:       retained: countRows(database),\n447:       protectedCount: feedbackRetention.protectedIds.length,\n448:       dryRun,\n449:       durationMs: Date.now() - startTime,\n450:       candidates,\n451:       deletedIds: [],\n452:       protectedIds: feedbackRetention.protectedIds,\n453:       extendedIds: [],\n454:       ledgerRecorded: null,\n455:       tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n456:       edgeState: initialEdgeState,\n457:       feedbackRetention,\n458:     };\n459:   }\n460: \n461:   initHistory(database);\n462: \n463:   const deletedIds: number[] = [];\n464:   const protectedIds: number[] = [];\n465:   const extendedIds: number[] = [];\n466:   let ledgerRecorded: boolean | null = null;\n467: \n468:   const sweepTx = database.transaction(() => {\n469:     for (const candidate of candidates) {\n470:       // TOCTOU guard: skip rows un-expired by another writer since selection.\n471:       if (!isStillExpired(database, candidate.id, useSoftDeleteTombstones)) {\n472:         continue;\n473:       }\n474:       if (feedbackRetention) {\n475:         const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n476:         if (!decision) {\n477:           continue;\n478:         }\n479: \n480:         if (decision.decision === 'protect') {\n481:           database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n482:           protectedIds.push(candidate.id);\n483:           recordFeedbackRetentionAudit(database, candidate, decision, {\n484:             mode: feedbackRetention.mode,\n485:             applied: true,\n486:             activeGatePassed: feedbackRetention.activeGatePassed,\n487:           });\n488:           feedbackRetention.auditCount += 1;\n489:           continue;\n490:         }\n491: \n492:         if (decision.decision === 'extend') {\n493:           database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n494:             decision.nextDeleteAfter,\n495:             candidate.id,\n496:           );\n497:           extendedIds.push(candidate.id);\n498:           recordFeedbackRetentionAudit(database, candidate, decision, {\n499:             mode: feedbackRetention.mode,\n500:             applied: true,\n501:             activeGatePassed: feedbackRetention.activeGatePassed,\n502:           });\n503:           feedbackRetention.auditCount += 1;\n504:           continue;\n505:         }\n506: \n507:         recordFeedbackRetentionAudit(database, candidate, decision, {\n508:           mode: feedbackRetention.mode,\n509:           applied: true,\n510:           activeGatePassed: feedbackRetention.activeGatePassed,\n511:         });\n512:         feedbackRetention.auditCount += 1;\n513:       }\n514:       // Tier basement: protected rows are never deleted on TTL expiry alone.\n515:       // Audited as decision='deny' (the delete was denied) with a protection reason.\n516:       if (isProtectedFromRetentionDelete(candidate)) {\n517:         protectedIds.push(candidate.id);\n518:         recordGovernanceAudit(database, {\n519:           action: 'retention_sweep',\n520:           decision: 'deny',\n521:           memoryId: candidate.id,\n522:           logicalKey: candidate.filePath,\n523:           tenantId: candidate.tenantId ?? undefined,\n524:           userId: candidate.userId ?? undefined,\n525:           agentId: candidate.agentId ?? undefined,\n526:           sessionId: candidate.sessionId ?? undefined,\n527:           reason: 'retention_tier_protected',\n528:           metadata: {\n529:             originalDeleteAfter: candidate.deleteAfter,\n530:             importanceTier: candidate.importanceTier,\n531:             isPinned: candidate.isPinned,\n532:             specFolder: candidate.specFolder,\n533:             filePath: candidate.filePath,\n534:           },\n535:         });\n536:         continue;\n537:       }\n538:       const deleted = vectorIndex.deleteMemory(candidate.id, database);\n539:       if (!deleted) {\n540:         continue;\n541:       }\n542: \n543:       deletedIds.push(candidate.id);\n544: \n545:       recordHistory(\n546:         candidate.id,\n547:         'DELETE',\n548:         {\n549:           reason: 'retention_expired',\n550:           deleteAfter: candidate.deleteAfter,\n551:           filePath: candidate.filePath,\n552:         },\n553:         null,\n554:         'mcp:memory_retention_sweep',\n555:         candidate.specFolder,\n556:       );\n557: \n558:       recordGovernanceAudit(database, {\n559:         action: 'retention_sweep',\n560:         decision: 'delete',\n561:         memoryId: candidate.id,\n562:         logicalKey: candidate.filePath,\n563:         tenantId: candidate.tenantId ?? undefined,\n564:         userId: candidate.userId ?? undefined,\n565:         agentId: candidate.agentId ?? undefined,\n566:         sessionId: candidate.sessionId ?? undefined,\n567:         reason: 'retention_expired',\n568:         metadata: {\n569:           originalDeleteAfter: candidate.deleteAfter,\n570:           delete_after: candidate.deleteAfter,\n571:           specFolder: candidate.specFolder,\n572:           filePath: candidate.filePath,\n573:         },\n574:       });\n575:     }\n576: \n577:     if (deletedIds.length > 0) {\n578:       ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n579:     }\n580:   });\n581: \n582:   sweepTx();\n583:   if (deletedIds.length > 0) {\n584:     runPostDeleteMaintenance(database);\n585:   }\n586:   if (feedbackRetention) {\n587:     feedbackRetention.extendedIds = extendedIds;\n588:     feedbackRetention.protectedIds = protectedIds;\n589:     feedbackRetention.deletedIds = deletedIds;\n590:   }\n591: \n592:   return {\n593:     swept: deletedIds.length,\n594:     retained: countRows(database),\n595:     protectedCount: protectedIds.length,\n596:     dryRun,\n597:     durationMs: Date.now() - startTime,\n598:     candidates,\n599:     deletedIds,\n600:     protectedIds,\n601:     ledgerRecorded,\n602:     tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n603:     edgeState: initialEdgeState,\n604:     ...(feedbackRetention ? { extendedIds } : {}),\n\n(Showing lines 320-604 of 607. Use offset=605 to continue.)\n</content>","metadata":{"preview":"      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","text":"      reason: `memory_retention_sweep: retention_expired ${deletedIds.length} memory row(s)`,\n      prior_hash: null,\n      new_hash: mutationLedger.computeHash(`retention-sweep:${deletedIds.join(',')}:${Date.now()}`),\n      linked_memory_ids: deletedIds.slice(0, 50),\n      decision_meta: {\n        tool: 'memory_retention_sweep',\n        reason: 'retention_expired',\n        totalDeleted: deletedIds.length,\n        originalDeleteAfter: candidates\n          .filter((candidate) => deletedIds.includes(candidate.id))\n          .map((candidate) => ({ id: candidate.id, deleteAfter: candidate.deleteAfter })),\n      },\n      actor: 'mcp:memory_retention_sweep',\n    });\n    return true;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] mutation ledger append failed: ${message}`);\n    return false;\n  }\n}\n\nfunction runPostDeleteMaintenance(database: Database.Database): void {\n  try {\n    database.prepare(\"INSERT INTO memory_fts(memory_fts) VALUES('optimize')\").run();\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[memory-retention-sweep] FTS optimize skipped: ${message}`);\n  }\n\n  const maintenance = new BetterSqliteMaintenance(database, {\n    onMaintenanceError: reportRetentionMaintenanceError,\n  });\n  maintenance.vacuum();\n  maintenance.checkpoint({ mode: 'truncate' });\n}\n\nfunction reportRetentionMaintenanceError(operation: MaintenanceOperation, error: unknown): void {\n  const message = error instanceof Error ? error.message : String(error);\n  if (operation === 'auto_vacuum') {\n    console.warn(`[memory-retention-sweep] auto_vacuum check skipped: ${message}`);\n  } else if (operation === 'incremental_vacuum') {\n    console.warn(`[memory-retention-sweep] incremental vacuum skipped: ${message}`);\n  } else if (operation === 'wal_checkpoint') {\n    console.warn(`[memory-retention-sweep] WAL checkpoint skipped: ${message}`);\n  }\n}\n\n/**\n * Sweep expired governed memory rows.\n *\n * Rows are selected by normalized `datetime(delete_after) < datetime('now')`\n * to enforce the ISO timestamps persisted by governed ingest.\n */\nexport function runMemoryRetentionSweep(\n  database: Database.Database,\n  args: MemoryRetentionSweepArgs = {},\n): MemoryRetentionSweepResult {\n  const startTime = Date.now();\n  const dryRun = args.dryRun === true;\n  const useSoftDeleteTombstones = isSoftDeleteTombstonesEnabled();\n\n  if (!hasTable(database, 'memory_index')) {\n    return {\n      swept: 0,\n      retained: 0,\n      protectedCount: 0,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates: [],\n      deletedIds: [],\n      protectedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: {\n        usesPurgeablePartition: false,\n        usingPurgeableIndex: false,\n        candidateCount: 0,\n        deletedCount: 0,\n      },\n      edgeState: {\n        causalEdgesTablePresent: false,\n        candidateEdgeCount: 0,\n      },\n    };\n  }\n\n  const candidates = selectExpiredRows(database, useSoftDeleteTombstones);\n  const initialEdgeState = buildEdgeState(database, candidates);\n  const feedbackRetention = isFeedbackRetentionLearningEnabled()\n    ? buildFeedbackRetentionReport(database, candidates, dryRun, args.feedbackRetention)\n    : null;\n\n  if (dryRun || candidates.length === 0) {\n    const totalRows = countRows(database);\n    const dryRunProtectedIds = candidates\n      .filter((candidate) => isProtectedFromRetentionDelete(candidate))\n      .map((candidate) => candidate.id);\n    return {\n      swept: 0,\n      retained: totalRows,\n      protectedCount: dryRunProtectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: dryRunProtectedIds,\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      ...(feedbackRetention ? { feedbackRetention } : {}),\n    };\n  }\n\n  if (feedbackRetention && (feedbackRetention.mode === 'shadow' || feedbackRetention.activeBlocked)) {\n    const auditTx = database.transaction(() => {\n      feedbackRetention.auditCount = recordFeedbackRetentionAudits(\n        database,\n        candidates,\n        feedbackRetention,\n        false,\n      );\n    });\n    auditTx();\n\n    return {\n      swept: 0,\n      retained: countRows(database),\n      protectedCount: feedbackRetention.protectedIds.length,\n      dryRun,\n      durationMs: Date.now() - startTime,\n      candidates,\n      deletedIds: [],\n      protectedIds: feedbackRetention.protectedIds,\n      extendedIds: [],\n      ledgerRecorded: null,\n      tombstoneState: buildTombstoneState(database, candidates.length, 0, useSoftDeleteTombstones),\n      edgeState: initialEdgeState,\n      feedbackRetention,\n    };\n  }\n\n  initHistory(database);\n\n  const deletedIds: number[] = [];\n  const protectedIds: number[] = [];\n  const extendedIds: number[] = [];\n  let ledgerRecorded: boolean | null = null;\n\n  const sweepTx = database.transaction(() => {\n    for (const candidate of candidates) {\n      // TOCTOU guard: skip rows un-expired by another writer since selection.\n      if (!isStillExpired(database, candidate.id, useSoftDeleteTombstones)) {\n        continue;\n      }\n      if (feedbackRetention) {\n        const decision = feedbackRetention.decisions.find((entry) => entry.memoryId === candidate.id);\n        if (!decision) {\n          continue;\n        }\n\n        if (decision.decision === 'protect') {\n          database.prepare('UPDATE memory_index SET delete_after = NULL WHERE id = ?').run(candidate.id);\n          protectedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, candidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n\n        if (decision.decision === 'extend') {\n          database.prepare('UPDATE memory_index SET delete_after = ? WHERE id = ?').run(\n            decision.nextDeleteAfter,\n            candidate.id,\n          );\n          extendedIds.push(candidate.id);\n          recordFeedbackRetentionAudit(database, candidate, decision, {\n            mode: feedbackRetention.mode,\n            applied: true,\n            activeGatePassed: feedbackRetention.activeGatePassed,\n          });\n          feedbackRetention.auditCount += 1;\n          continue;\n        }\n\n        recordFeedbackRetentionAudit(database, candidate, decision, {\n          mode: feedbackRetention.mode,\n          applied: true,\n          activeGatePassed: feedbackRetention.activeGatePassed,\n        });\n        feedbackRetention.auditCount += 1;\n      }\n      // Tier basement: protected rows are never deleted on TTL expiry alone.\n      // Audited as decision='deny' (the delete was denied) with a protection reason.\n      if (isProtectedFromRetentionDelete(candidate)) {\n        protectedIds.push(candidate.id);\n        recordGovernanceAudit(database, {\n          action: 'retention_sweep',\n          decision: 'deny',\n          memoryId: candidate.id,\n          logicalKey: candidate.filePath,\n          tenantId: candidate.tenantId ?? undefined,\n          userId: candidate.userId ?? undefined,\n          agentId: candidate.agentId ?? undefined,\n          sessionId: candidate.sessionId ?? undefined,\n          reason: 'retention_tier_protected',\n          metadata: {\n            originalDeleteAfter: candidate.deleteAfter,\n            importanceTier: candidate.importanceTier,\n            isPinned: candidate.isPinned,\n            specFolder: candidate.specFolder,\n            filePath: candidate.filePath,\n          },\n        });\n        continue;\n      }\n      const deleted = vectorIndex.deleteMemory(candidate.id, database);\n      if (!deleted) {\n        continue;\n      }\n\n      deletedIds.push(candidate.id);\n\n      recordHistory(\n        candidate.id,\n        'DELETE',\n        {\n          reason: 'retention_expired',\n          deleteAfter: candidate.deleteAfter,\n          filePath: candidate.filePath,\n        },\n        null,\n        'mcp:memory_retention_sweep',\n        candidate.specFolder,\n      );\n\n      recordGovernanceAudit(database, {\n        action: 'retention_sweep',\n        decision: 'delete',\n        memoryId: candidate.id,\n        logicalKey: candidate.filePath,\n        tenantId: candidate.tenantId ?? undefined,\n        userId: candidate.userId ?? undefined,\n        agentId: candidate.agentId ?? undefined,\n        sessionId: candidate.sessionId ?? undefined,\n        reason: 'retention_expired',\n        metadata: {\n          originalDeleteAfter: candidate.deleteAfter,\n          delete_after: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        },\n      });\n    }\n\n    if (deletedIds.length > 0) {\n      ledgerRecorded = appendRetentionLedger(database, deletedIds, candidates);\n    }\n  });\n\n  sweepTx();\n  if (deletedIds.length > 0) {\n    runPostDeleteMaintenance(database);\n  }\n  if (feedbackRetention) {\n    feedbackRetention.extendedIds = extendedIds;\n    feedbackRetention.protectedIds = protectedIds;\n    feedbackRetention.deletedIds = deletedIds;\n  }\n\n  return {\n    swept: deletedIds.length,\n    retained: countRows(database),\n    protectedCount: protectedIds.length,\n    dryRun,\n    durationMs: Date.now() - startTime,\n    candidates,\n    deletedIds,\n    protectedIds,\n    ledgerRecorded,\n    tombstoneState: buildTombstoneState(database, candidates.length, deletedIds.length, useSoftDeleteTombstones),\n    edgeState: initialEdgeState,\n    ...(feedbackRetention ? { extendedIds } : {}),","lineStart":320,"lineEnd":604,"totalLines":607,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts","time":{"start":1781144201212,"end":1781144201217}},"metadata":{"openai":{"itemId":"fc_02d0ac507d0d4065016a2a1a88c76881918099d1b0a33fcc69"}},"id":"prt_eb477a7d5001GVALqHwlZphHb9","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb4778162001F2alOO06lz0MYE"}}
{"type":"tool_use","timestamp":1781144201313,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_ZYfqLNdjspIdq8ZBfM6G6yEI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Checkpoints\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Checkpoint creation (checkpoint_create)\n5: // Feature catalog: Checkpoint restore (checkpoint_restore)\n6: // Gzip-compressed database checkpoints with embedding preservation\n7: // Node stdlib\n8: import * as fs from 'fs';\n9: import * as path from 'path';\n10: import * as zlib from 'zlib';\n11: \n12: // External packages\n13: import type Database from 'better-sqlite3';\n14: import { z } from 'zod';\n15: \n16: // Internal utils\n17: import { toErrorMessage } from '../../utils/db-helpers.js';\n18: import { rebuildAutoEntities } from '../extraction/entity-extractor.js';\n19: import {\n20:   buildGovernanceLogicalKey,\n21:   createScopeFilterPredicate,\n22:   GOVERNANCE_AUDIT_ACTIONS,\n23:   hasScopeConstraints,\n24:   normalizeScopeContext,\n25:   recordGovernanceAudit,\n26:   recordTierDowngradeAudit,\n27:   type ScopeContext,\n28:   type GovernanceAuditEntry,\n29:   type TierDowngradeAuditParams,\n30: } from '../governance/scope-governance.js';\n31: import { detectCommunities, storeCommunityAssignments } from '../graph/community-detection.js';\n32: import { generateCommunitySummaries } from '../graph/community-summaries.js';\n33: import { storeCommunities } from '../graph/community-storage.js';\n34: import { snapshotDegrees } from '../graph/graph-signals.js';\n35: import { runLineageBackfill } from './lineage-state.js';\n36: import { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../utils/index-scope.js';\n37: import { reopenActiveDatabase } from '../search/vector-index-store.js';\n38: import { SCHEMA_VERSION } from '../search/vector-index-schema.js';\n39: import { sweepCausalEdges } from '../causal/sweep.js';\n40: import { BetterSqliteContentionPolicy } from './ports/contention-policy.js';\n41: \n42: function batchedInQuery<T>(db: Database.Database, sql: string, ids: (number | string)[], batchSize = 500): T[] {\n43:   const results: T[] = [];\n44:   for (let i = 0; i < ids.length; i += batchSize) {\n45:     const batch = ids.slice(i, i + batchSize);\n46:     const placeholders = batch.map(() => '?').join(', ');\n47:     const batchSql = sql.replace('__PLACEHOLDERS__', placeholders);\n48:     results.push(...(db.prepare(batchSql).all(...batch) as T[]));\n49:   }\n50:   return results;\n51: }\n52: \n53: function dedupeRowsById<T extends Record<string, unknown>>(rows: T[]): T[] {\n54:   const results: T[] = [];\n55:   const seenIds = new Set<number | string>();\n56: \n57:   for (const row of rows) {\n58:     const id = row.id;\n59:     if (typeof id === 'number' || typeof id === 'string') {\n60:       if (seenIds.has(id)) {\n61:         continue;\n62:       }\n63:       seenIds.add(id);\n64:     }\n65:     results.push(row);\n66:   }\n67: \n68:   return results;\n69: }\n70: \n71: function getSnapshotColumnsFromRows(rows: Array<Record<string, unknown>>): string[] {\n72:   const columns = new Set<string>();\n73: \n74:   for (const row of rows) {\n75:     for (const key of Object.keys(row ?? {})) {\n76:       if (typeof key === 'string' && key.length > 0) {\n77:         columns.add(key);\n78:       }\n79:     }\n80:   }\n81: \n82:   return Array.from(columns);\n83: }\n84: \n85: function flushGovernanceAudits(\n86:   database: Database.Database,\n87:   entries: GovernanceAuditEntry[],\n88: ): void {\n89:   for (const entry of entries) {\n90:     try {\n91:       recordGovernanceAudit(database, entry);\n92:     } catch (error: unknown) {\n93:       console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n94:     }\n95:   }\n96: }\n97: \n98: function flushTierDowngradeAudits(\n99:   database: Database.Database,\n100:   entries: TierDowngradeAuditParams[],\n101: ): void {\n102:   for (const entry of entries) {\n103:     try {\n104:       recordTierDowngradeAudit(database, entry);\n105:     } catch (error: unknown) {\n106:       console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n107:     }\n108:   }\n109: }\n110: \n111: /* ───────────────────────────────────────────────────────────────\n112:    1. CONSTANTS\n113: ----------------------------------------------------------------*/\n114: \n115: const MAX_CHECKPOINTS = 10;\n116: const CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\n117: const CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\n118: const CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\n119: const RESTORE_JOURNAL_NAME = '.restore-journal.json';\n120: const NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\n121: const checkpointContention = new BetterSqliteContentionPolicy({ retryable: isCheckpointBusyError });\n122: \n123: const CHECKPOINT_MANIFEST = Object.freeze({\n124:   snapshot: [\n125:     'memory_index',\n126:     'vec_memories',\n127:     'vec_metadata',\n128:     'working_memory',\n129:     'causal_edges',\n130:     'weight_history',\n131:     'memory_history',\n132:     'mutation_ledger',\n133:     'memory_conflicts',\n134:     'memory_corrections',\n135:     'adaptive_signal_events',\n136:     'negative_feedback_events',\n137:     'learned_feedback_audit',\n138:     'session_learning',\n139:     'governance_audit',\n140:     'session_state',\n141:     'session_sent_memories',\n142:     'memory_summaries',\n143:   ],\n144:   rebuild: [\n145:     'memory_lineage',\n146:     'active_memory_projection',\n147:     'memory_entities',\n148:     'entity_catalog',\n149:     'degree_snapshots',\n150:     'community_assignments',\n151:     'graph_communities',\n152:     'community_summaries',\n153:     'memory_fts',\n154:   ],\n155:   skip: [\n156:     'checkpoints',\n157:     'schema_version',\n158:     'embedding_cache',\n159:     'adaptive_shadow_runs',\n160:   ],\n161: });\n162: \n163: const CHECKPOINT_RESTORE_ORDER = [\n164:   'memory_index',\n165:   'vec_memories',\n166:   'vec_metadata',\n167:   'working_memory',\n168:   'causal_edges',\n169:   'weight_history',\n170:   'memory_history',\n171:   'mutation_ledger',\n172:   'memory_conflicts',\n173:   'memory_corrections',\n174:   'adaptive_signal_events',\n175:   'negative_feedback_events',\n176:   'learned_feedback_audit',\n177:   'session_learning',\n178:   'governance_audit',\n179:   'session_state',\n180:   'session_sent_memories',\n181:   'memory_summaries',\n182: ] as const;\n183: \n184: const CHECKPOINT_CLEAR_ORDER = [...CHECKPOINT_RESTORE_ORDER].reverse();\n185: \n186: const MUTATION_LEDGER_TRIGGER_SQL = `\n187:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n188:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n189:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n190:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n191: `;\n192: \n193: /* ───────────────────────────────────────────────────────────────\n194:    2. INTERFACES\n195: ----------------------------------------------------------------*/\n196: \n197: interface CheckpointEntry {\n198:   id: number;\n199:   name: string;\n200:   created_at: string;\n201:   spec_folder: string | null;\n202:   git_branch: string | null;\n203:   memory_snapshot: Buffer | null;\n204:   file_snapshot: Buffer | null;\n205:   snapshot_format?: string | null;\n206:   snapshot_path?: string | null;\n207:   metadata: string | null;\n208: }\n209: \n210: interface CheckpointInfo {\n211:   id: number;\n212:   name: string;\n213:   createdAt: string;\n214:   specFolder: string | null;\n215:   gitBranch: string | null;\n216:   snapshotSize: number;\n217:   metadata: Record<string, unknown>;\n218:   [key: string]: unknown;\n219: }\n220: \n221: interface CreateCheckpointOptions {\n222:   name?: string;\n223:   specFolder?: string | null;\n224:   includeEmbeddings?: boolean;\n225:   metadata?: Record<string, unknown>;\n226:   scope?: ScopeContext;\n227: }\n228: \n229: type CheckpointCreateErrorCode =\n230:   | 'CHECKPOINT_CREATE_SQLITE_BUSY'\n231:   | 'CHECKPOINT_CREATE_SQLITE_LOCKED'\n232:   | 'CHECKPOINT_CREATE_DUPLICATE_NAME'\n233:   | 'CHECKPOINT_CREATE_INVALID_NAME'\n234:   | 'CHECKPOINT_CREATE_PERMISSION_DENIED'\n235:   | 'CHECKPOINT_CREATE_FAILED';\n236: \n237: type CheckpointRestoreErrorCode =\n238:   | 'CHECKPOINT_RESTORE_MANIFEST_INVALID'\n239:   | 'CHECKPOINT_RESTORE_DOWNGRADE_UNSAFE'\n240:   | 'CHECKPOINT_RESTORE_EMBEDDER_MISMATCH'\n241:   | 'CHECKPOINT_RESTORE_FILE_MISSING'\n242:   | 'CHECKPOINT_RESTORE_PATH_UNRESOLVED'\n243:   | 'CHECKPOINT_RESTORE_JOURNAL_FAILED'\n244:   | 'CHECKPOINT_RESTORE_SWAP_FAILED';\n245: \n246: class CheckpointCreateError extends Error {\n247:   public readonly code: CheckpointCreateErrorCode;\n248:   public readonly originalCode: string | null;\n249:   public readonly details: Record<string, unknown>;\n250: \n251:   constructor(\n252:     code: CheckpointCreateErrorCode,\n253:     message: string,\n254:     details: Record<string, unknown> = {},\n255:     cause?: unknown,\n256:   ) {\n257:     super(message, { cause });\n258:     Object.setPrototypeOf(this, CheckpointCreateError.prototype);\n259:     this.name = 'CheckpointCreateError';\n260:     this.code = code;\n\n(Showing lines 1-260 of 3319. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Gzip-compressed database checkpoints with embedding preservation\n// Node stdlib\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport * as zlib from 'zlib';\n\n// External packages\nimport type Database from 'better-sqlite3';\nimport { z } from 'zod';\n\n// Internal utils\nimport { toErrorMessage } from '../../utils/db-helpers.js';\nimport { rebuildAutoEntities } from '../extraction/entity-extractor.js';\nimport {\n  buildGovernanceLogicalKey,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Checkpoints\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Checkpoint creation (checkpoint_create)\n// Feature catalog: Checkpoint restore (checkpoint_restore)\n// Gzip-compressed database checkpoints with embedding preservation\n// Node stdlib\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport * as zlib from 'zlib';\n\n// External packages\nimport type Database from 'better-sqlite3';\nimport { z } from 'zod';\n\n// Internal utils\nimport { toErrorMessage } from '../../utils/db-helpers.js';\nimport { rebuildAutoEntities } from '../extraction/entity-extractor.js';\nimport {\n  buildGovernanceLogicalKey,\n  createScopeFilterPredicate,\n  GOVERNANCE_AUDIT_ACTIONS,\n  hasScopeConstraints,\n  normalizeScopeContext,\n  recordGovernanceAudit,\n  recordTierDowngradeAudit,\n  type ScopeContext,\n  type GovernanceAuditEntry,\n  type TierDowngradeAuditParams,\n} from '../governance/scope-governance.js';\nimport { detectCommunities, storeCommunityAssignments } from '../graph/community-detection.js';\nimport { generateCommunitySummaries } from '../graph/community-summaries.js';\nimport { storeCommunities } from '../graph/community-storage.js';\nimport { snapshotDegrees } from '../graph/graph-signals.js';\nimport { runLineageBackfill } from './lineage-state.js';\nimport { isIndexableConstitutionalMemoryPath, shouldIndexForMemory } from '../utils/index-scope.js';\nimport { reopenActiveDatabase } from '../search/vector-index-store.js';\nimport { SCHEMA_VERSION } from '../search/vector-index-schema.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { BetterSqliteContentionPolicy } from './ports/contention-policy.js';\n\nfunction batchedInQuery<T>(db: Database.Database, sql: string, ids: (number | string)[], batchSize = 500): T[] {\n  const results: T[] = [];\n  for (let i = 0; i < ids.length; i += batchSize) {\n    const batch = ids.slice(i, i + batchSize);\n    const placeholders = batch.map(() => '?').join(', ');\n    const batchSql = sql.replace('__PLACEHOLDERS__', placeholders);\n    results.push(...(db.prepare(batchSql).all(...batch) as T[]));\n  }\n  return results;\n}\n\nfunction dedupeRowsById<T extends Record<string, unknown>>(rows: T[]): T[] {\n  const results: T[] = [];\n  const seenIds = new Set<number | string>();\n\n  for (const row of rows) {\n    const id = row.id;\n    if (typeof id === 'number' || typeof id === 'string') {\n      if (seenIds.has(id)) {\n        continue;\n      }\n      seenIds.add(id);\n    }\n    results.push(row);\n  }\n\n  return results;\n}\n\nfunction getSnapshotColumnsFromRows(rows: Array<Record<string, unknown>>): string[] {\n  const columns = new Set<string>();\n\n  for (const row of rows) {\n    for (const key of Object.keys(row ?? {})) {\n      if (typeof key === 'string' && key.length > 0) {\n        columns.add(key);\n      }\n    }\n  }\n\n  return Array.from(columns);\n}\n\nfunction flushGovernanceAudits(\n  database: Database.Database,\n  entries: GovernanceAuditEntry[],\n): void {\n  for (const entry of entries) {\n    try {\n      recordGovernanceAudit(database, entry);\n    } catch (error: unknown) {\n      console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n    }\n  }\n}\n\nfunction flushTierDowngradeAudits(\n  database: Database.Database,\n  entries: TierDowngradeAuditParams[],\n): void {\n  for (const entry of entries) {\n    try {\n      recordTierDowngradeAudit(database, entry);\n    } catch (error: unknown) {\n      console.warn(`[checkpoints] governance_audit insert failed: ${toErrorMessage(error)}`);\n    }\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst MAX_CHECKPOINTS = 10;\nconst CHECKPOINT_CREATE_MAX_ATTEMPTS = 3;\nconst CHECKPOINT_CREATE_RETRY_MIN_DELAY_MS = 50;\nconst CHECKPOINT_CREATE_RETRY_MAX_DELAY_MS = 200;\nconst RESTORE_JOURNAL_NAME = '.restore-journal.json';\nconst NEEDS_REBUILD_SENTINEL_NAME = '.needs-rebuild';\nconst checkpointContention = new BetterSqliteContentionPolicy({ retryable: isCheckpointBusyError });\n\nconst CHECKPOINT_MANIFEST = Object.freeze({\n  snapshot: [\n    'memory_index',\n    'vec_memories',\n    'vec_metadata',\n    'working_memory',\n    'causal_edges',\n    'weight_history',\n    'memory_history',\n    'mutation_ledger',\n    'memory_conflicts',\n    'memory_corrections',\n    'adaptive_signal_events',\n    'negative_feedback_events',\n    'learned_feedback_audit',\n    'session_learning',\n    'governance_audit',\n    'session_state',\n    'session_sent_memories',\n    'memory_summaries',\n  ],\n  rebuild: [\n    'memory_lineage',\n    'active_memory_projection',\n    'memory_entities',\n    'entity_catalog',\n    'degree_snapshots',\n    'community_assignments',\n    'graph_communities',\n    'community_summaries',\n    'memory_fts',\n  ],\n  skip: [\n    'checkpoints',\n    'schema_version',\n    'embedding_cache',\n    'adaptive_shadow_runs',\n  ],\n});\n\nconst CHECKPOINT_RESTORE_ORDER = [\n  'memory_index',\n  'vec_memories',\n  'vec_metadata',\n  'working_memory',\n  'causal_edges',\n  'weight_history',\n  'memory_history',\n  'mutation_ledger',\n  'memory_conflicts',\n  'memory_corrections',\n  'adaptive_signal_events',\n  'negative_feedback_events',\n  'learned_feedback_audit',\n  'session_learning',\n  'governance_audit',\n  'session_state',\n  'session_sent_memories',\n  'memory_summaries',\n] as const;\n\nconst CHECKPOINT_CLEAR_ORDER = [...CHECKPOINT_RESTORE_ORDER].reverse();\n\nconst MUTATION_LEDGER_TRIGGER_SQL = `\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface CheckpointEntry {\n  id: number;\n  name: string;\n  created_at: string;\n  spec_folder: string | null;\n  git_branch: string | null;\n  memory_snapshot: Buffer | null;\n  file_snapshot: Buffer | null;\n  snapshot_format?: string | null;\n  snapshot_path?: string | null;\n  metadata: string | null;\n}\n\ninterface CheckpointInfo {\n  id: number;\n  name: string;\n  createdAt: string;\n  specFolder: string | null;\n  gitBranch: string | null;\n  snapshotSize: number;\n  metadata: Record<string, unknown>;\n  [key: string]: unknown;\n}\n\ninterface CreateCheckpointOptions {\n  name?: string;\n  specFolder?: string | null;\n  includeEmbeddings?: boolean;\n  metadata?: Record<string, unknown>;\n  scope?: ScopeContext;\n}\n\ntype CheckpointCreateErrorCode =\n  | 'CHECKPOINT_CREATE_SQLITE_BUSY'\n  | 'CHECKPOINT_CREATE_SQLITE_LOCKED'\n  | 'CHECKPOINT_CREATE_DUPLICATE_NAME'\n  | 'CHECKPOINT_CREATE_INVALID_NAME'\n  | 'CHECKPOINT_CREATE_PERMISSION_DENIED'\n  | 'CHECKPOINT_CREATE_FAILED';\n\ntype CheckpointRestoreErrorCode =\n  | 'CHECKPOINT_RESTORE_MANIFEST_INVALID'\n  | 'CHECKPOINT_RESTORE_DOWNGRADE_UNSAFE'\n  | 'CHECKPOINT_RESTORE_EMBEDDER_MISMATCH'\n  | 'CHECKPOINT_RESTORE_FILE_MISSING'\n  | 'CHECKPOINT_RESTORE_PATH_UNRESOLVED'\n  | 'CHECKPOINT_RESTORE_JOURNAL_FAILED'\n  | 'CHECKPOINT_RESTORE_SWAP_FAILED';\n\nclass CheckpointCreateError extends Error {\n  public readonly code: CheckpointCreateErrorCode;\n  public readonly originalCode: string | null;\n  public readonly details: Record<string, unknown>;\n\n  constructor(\n    code: CheckpointCreateErrorCode,\n    message: string,\n    details: Record<string, unknown> = {},\n    cause?: unknown,\n  ) {\n    super(message, { cause });\n    Object.setPrototypeOf(this, CheckpointCreateError.prototype);\n    this.name = 'CheckpointCreateError';\n    this.code = code;","lineStart":1,"lineEnd":260,"totalLines":3319,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/checkpoints.ts","time":{"start":1781144201305,"end":1781144201312}},"metadata":{"openai":{"itemId":"fc_02d0ac507d0d4065016a2a1a88c7708191bc41b5ad039028aa"}},"id":"prt_eb477a7fe001Y5YUSV8Oqurans","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb4778162001F2alOO06lz0MYE"}}
{"type":"tool_use","timestamp":1781144201383,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_unJK0xR5cdGnM2Vgn8gyQZMP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","offset":1,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // TEST: STORAGE PORT CONTRACTS\n3: // -------------------------------------------------------------------\n4: \n5: import * as fs from 'fs';\n6: import * as os from 'os';\n7: import * as path from 'path';\n8: \n9: import Database from 'better-sqlite3';\n10: import { describe, expect, it } from 'vitest';\n11: \n12: import {\n13:   BetterSqliteContentionPolicy,\n14:   BetterSqliteGraphTraversal,\n15:   BetterSqliteMaintenance,\n16:   BetterSqliteVectorStore,\n17:   PackedBm25LexicalSearch,\n18:   type ContentionPolicy,\n19:   type GraphTraversal,\n20:   type LexicalSearch,\n21:   type Maintenance,\n22:   type VectorMetadata,\n23:   type VectorStore,\n24: } from '../lib/storage/ports';\n25: import {\n26:   FakeContentionPolicy,\n27:   FakeGraphTraversal,\n28:   FakeLexicalSearch,\n29:   FakeMaintenance,\n30:   FakeVectorStore,\n31: } from './fakes/storage-ports';\n32: \n33: interface ContractSubject<TPort> {\n34:   readonly port: TPort;\n35:   readonly cleanup: () => void;\n36: }\n37: \n38: interface EnvSnapshot {\n39:   readonly EMBEDDING_DIM: string | undefined;\n40:   readonly MEMORY_ALLOWED_PATHS: string | undefined;\n41: }\n42: \n43: type VectorFixtureMetadata = VectorMetadata & {\n44:   readonly spec_folder: string;\n45:   readonly file_path: string;\n46:   readonly title: string;\n47: };\n48: \n49: function snapshotEnv(): EnvSnapshot {\n50:   return {\n51:     EMBEDDING_DIM: process.env.EMBEDDING_DIM,\n52:     MEMORY_ALLOWED_PATHS: process.env.MEMORY_ALLOWED_PATHS,\n53:   };\n54: }\n55: \n56: function restoreEnv(snapshot: EnvSnapshot): void {\n57:   if (snapshot.EMBEDDING_DIM === undefined) {\n58:     delete process.env.EMBEDDING_DIM;\n59:   } else {\n60:     process.env.EMBEDDING_DIM = snapshot.EMBEDDING_DIM;\n61:   }\n62:   if (snapshot.MEMORY_ALLOWED_PATHS === undefined) {\n63:     delete process.env.MEMORY_ALLOWED_PATHS;\n64:   } else {\n65:     process.env.MEMORY_ALLOWED_PATHS = snapshot.MEMORY_ALLOWED_PATHS;\n66:   }\n67: }\n68: \n69: function createGraphFixtureDb(): Database.Database {\n70:   const database = new Database(':memory:');\n71:   database.exec(`\n72:     CREATE TABLE causal_edges (\n73:       source_id TEXT NOT NULL,\n74:       target_id TEXT NOT NULL,\n75:       relation TEXT NOT NULL,\n76:       strength REAL\n77:     );\n78:     CREATE TABLE dependency_edges (\n79:       parent_path TEXT NOT NULL,\n80:       child_path TEXT NOT NULL\n81:     );\n82:   `);\n83: \n84:   const insertCausal = database.prepare(`\n85:     INSERT INTO causal_edges (source_id, target_id, relation, strength)\n86:     VALUES (?, ?, ?, ?)\n87:   `);\n88:   insertCausal.run('1', '2', 'supports', 0.5);\n89:   insertCausal.run('2', '3', 'enabled', 0.25);\n90: \n91:   const insertDependency = database.prepare(`\n92:     INSERT INTO dependency_edges (parent_path, child_path)\n93:     VALUES (?, ?)\n94:   `);\n95:   insertDependency.run('root', 'child');\n96:   insertDependency.run('child', 'grandchild');\n97: \n98:   return database;\n99: }\n100: \n101: function createFakeGraphTraversal(): FakeGraphTraversal {\n102:   return new FakeGraphTraversal({\n103:     causalEdges: [\n104:       { sourceId: 1, targetId: 2, relation: 'supports', strength: 0.5 },\n105:       { sourceId: 2, targetId: 3, relation: 'enabled', strength: 0.25 },\n106:     ],\n107:     dependencyEdges: [\n108:       { parentPath: 'root', childPath: 'child' },\n109:       { parentPath: 'child', childPath: 'grandchild' },\n110:     ],\n111:   });\n112: }\n113: \n114: function createBetterSqliteVectorSubject(): ContractSubject<VectorStore<VectorFixtureMetadata>> {\n115:   const env = snapshotEnv();\n116:   const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-store-port-'));\n117:   process.env.EMBEDDING_DIM = '4';\n118:   process.env.MEMORY_ALLOWED_PATHS = tempDir;\n119:   const store = new BetterSqliteVectorStore({ dbPath: path.join(tempDir, 'context-index.sqlite') });\n120:   return {\n121:     port: store,\n122:     cleanup: () => {\n123:       void store.close();\n124:       restoreEnv(env);\n125:       fs.rmSync(tempDir, { recursive: true, force: true });\n126:     },\n127:   };\n128: }\n129: \n130: function createBetterSqliteMaintenanceSubject(): ContractSubject<Maintenance> {\n131:   const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintenance-port-'));\n132:   const database = new Database(path.join(tempDir, 'maintenance.sqlite'));\n133:   database.pragma('auto_vacuum = INCREMENTAL');\n134:   database.exec('VACUUM');\n135:   database.pragma('journal_mode = WAL');\n136:   database.exec(`\n137:     CREATE TABLE records (id INTEGER PRIMARY KEY, value TEXT NOT NULL);\n138:     INSERT INTO records (value) VALUES ('kept'), ('deleted');\n139:     DELETE FROM records WHERE value = 'deleted';\n140:   `);\n141: \n142:   return {\n143:     port: new BetterSqliteMaintenance(database),\n144:     cleanup: () => {\n145:       database.close();\n146:       fs.rmSync(tempDir, { recursive: true, force: true });\n147:     },\n148:   };\n149: }\n150: \n151: function createBetterSqliteContentionSubject(): ContractSubject<ContentionPolicy> & { database: Database.Database } {\n152:   const database = new Database(':memory:');\n153:   database.exec('CREATE TABLE writes (id INTEGER PRIMARY KEY, value TEXT NOT NULL)');\n154:   return {\n155:     database,\n156:     port: new BetterSqliteContentionPolicy({\n157:       database,\n158:       sleep: async () => undefined,\n159:       sleepSync: () => undefined,\n160:     }),\n161:     cleanup: () => database.close(),\n162:   };\n163: }\n164: \n165: function runGraphTraversalContract(\n166:   label: string,\n167:   createSubject: () => ContractSubject<GraphTraversal>,\n168: ): void {\n169:   describe(label, () => {\n170:     it('collects weighted causal neighbors with hop and score aggregation', () => {\n171:       const subject = createSubject();\n172:       try {\n173:         const results = subject.port.collectCausalWeightedNeighbors(\n174:           [1],\n175:           2,\n176:           { supports: 2, enabled: 4 },\n177:         );\n178: \n179:         expect(results.get(2)).toEqual({ nodeId: 2, minHop: 1, maxWalkScore: 1 });\n180:         expect(results.get(3)).toEqual({ nodeId: 3, minHop: 2, maxWalkScore: 1 });\n181:         expect(results.has(1)).toBe(false);\n182:       } finally {\n183:         subject.cleanup();\n184:       }\n185:     });\n186: \n187:     it('collects dependency children through directed reachability', () => {\n188:       const subject = createSubject();\n189:       try {\n190:         expect(subject.port.collectDependencyReachability(['root'])).toEqual(['child', 'grandchild']);\n191:       } finally {\n192:         subject.cleanup();\n193:       }\n194:     });\n195: \n196:     it('exposes generic directed reachability for caller-supplied readers', () => {\n197:       const subject = createSubject();\n198:       try {\n199:         const reached = subject.port.collectDirectedReachability({\n200:           roots: ['a'],\n201:           readEdges: (nodeIds) => nodeIds.includes('a')\n202:             ? [{ from: 'a', to: 'b' }, { from: 'a', to: 'c' }]\n203:             : [],\n204:         });\n205: \n206:         expect(reached).toEqual(['b', 'c']);\n207:       } finally {\n208:         subject.cleanup();\n209:       }\n210:     });\n211:   });\n212: }\n213: \n214: function runLexicalSearchContract(\n215:   label: string,\n216:   createSubject: () => ContractSubject<LexicalSearch>,\n217: ): void {\n218:   describe(label, () => {\n219:     it('indexes fielded documents and returns ranked query matches', () => {\n220:       const subject = createSubject();\n221:       try {\n222:         subject.port.addDocumentFields('auth', {\n223:           title: 'Auth guard',\n224:           trigger_phrases: ['authentication', 'login'],\n225:           content_generic: 'auth/module.md',\n226:           body: 'Guarded login access for memory search',\n227:         });\n228:         subject.port.addDocumentFields('cache', {\n229:           title: 'Cache invalidation',\n230:           trigger_phrases: ['cache'],\n231:           content_generic: 'cache/module.md',\n232:           body: 'Background cache refresh notes',\n233:         });\n234: \n235:         const results = subject.port.search('auth guard', { limit: 1 });\n236: \n237:         expect(results).toHaveLength(1);\n238:         expect(results[0]?.id).toBe('auth');\n239:         expect(results[0]?.score).toBeGreaterThan(0);\n240:       } finally {\n241:         subject.cleanup();\n242:       }\n243:     });\n244: \n245:     it('removes and clears indexed documents', () => {\n246:       const subject = createSubject();\n247:       try {\n248:         subject.port.addDocument('one', 'memory search document');\n249:         subject.port.addDocument('two', 'cache refresh document');\n250: \n251:         expect(subject.port.getStats().documentCount).toBe(2);\n252:         expect(subject.port.removeDocument('one')).toBe(true);\n253:         expect(subject.port.search('memory', { limit: 5 })).toEqual([]);\n254: \n255:         subject.port.clear();\n256:         expect(subject.port.getStats()).toEqual({\n257:           documentCount: 0,\n258:           termCount: 0,\n259:           avgDocLength: 0,\n260:         });\n261:       } finally {\n262:         subject.cleanup();\n263:       }\n264:     });\n265:   });\n266: }\n267: \n268: function runVectorStoreContract(\n269:   label: string,\n270:   createSubject: () => ContractSubject<VectorStore<VectorFixtureMetadata>>,\n271: ): void {\n272:   describe(label, () => {\n273:     it('stores vectors and returns ranked matches through the port', async () => {\n274:       const subject = createSubject();\n275:       try {\n276:         await subject.port.upsert({\n277:           id: 'left',\n278:           embedding: [1, 0, 0, 0],\n279:           metadata: {\n280:             spec_folder: 'specs/vector-port',\n281:             file_path: 'left.md',\n282:             title: 'Left vector',\n283:           },\n284:         });\n285:         await subject.port.upsert({\n286:           id: 'right',\n287:           embedding: [0, 1, 0, 0],\n288:           metadata: {\n289:             spec_folder: 'specs/vector-port',\n290:             file_path: 'right.md',\n291:             title: 'Right vector',\n292:           },\n293:         });\n294: \n295:         const results = await subject.port.search([1, 0, 0, 0], { limit: 2, minScore: 0 });\n296: \n297:         expect(results).toHaveLength(2);\n298:         expect(results[0]?.metadata.title).toBe('Left vector');\n299:         expect(results[0]?.score).toBeGreaterThanOrEqual(results[1]?.score ?? 0);\n300: \n301:         const stored = await subject.port.get(String(results[0]?.id));\n302:         expect(stored?.metadata.title).toBe('Left vector');\n303:         expect(await subject.port.delete(String(results[0]?.id))).toBe(true);\n304:         expect(await subject.port.get(String(results[0]?.id))).toBeNull();\n305:       } finally {\n306:         subject.cleanup();\n307:       }\n308:     });\n309: \n310:     it('clears stored vector records', async () => {\n311:       const subject = createSubject();\n312:       try {\n313:         await subject.port.upsert({\n314:           id: 'clear-me',\n315:           embedding: [1, 0, 0, 0],\n316:           metadata: {\n317:             spec_folder: 'specs/vector-port',\n318:             file_path: 'clear.md',\n319:             title: 'Clear vector',\n320:           },\n321:         });\n322: \n323:         await subject.port.clear();\n324: \n325:         expect(await subject.port.search([1, 0, 0, 0], { limit: 5, minScore: 0 })).toEqual([]);\n326:       } finally {\n327:         subject.cleanup();\n328:       }\n329:     });\n330:   });\n331: }\n332: \n333: function runMaintenanceContract(\n334:   label: string,\n335:   createSubject: () => ContractSubject<Maintenance>,\n336: ): void {\n337:   describe(label, () => {\n338:     it('reports storage integrity through the port', () => {\n339:       const subject = createSubject();\n340:       try {\n341:         expect(subject.port.integrityCheck().ok).toBe(true);\n342:       } finally {\n343:         subject.cleanup();\n344:       }\n345:     });\n346: \n347:     it('runs vacuum and checkpoint maintenance through the port', () => {\n348:       const subject = createSubject();\n349:       try {\n350:         expect(subject.port.vacuum().ok).toBe(true);\n351:         expect(subject.port.checkpoint({ mode: 'truncate' }).ok).toBe(true);\n352:       } finally {\n353:         subject.cleanup();\n354:       }\n355:     });\n356:   });\n357: }\n358: \n359: function runContentionPolicyContract(\n360:   label: string,\n361:   createSubject: () => ContractSubject<ContentionPolicy>,\n362: ): void {\n363:   describe(label, () => {\n364:     it('retries transient failures through the port', async () => {\n365:       const subject = createSubject();\n366:       try {\n367:         let attempts = 0;\n368: \n369:         const result = await subject.port.withRetry(() => {\n370:           attempts += 1;\n371:           if (attempts === 1) {\n372:             const error = new Error('SQLITE_BUSY: database is locked');\n373:             (error as unknown as { code: string }).code = 'SQLITE_BUSY';\n374:             throw error;\n375:           }\n376:           return 'ok';\n377:         }, { attempts: 2 });\n378: \n379:         expect(result).toBe('ok');\n380:         expect(attempts).toBe(2);\n381:       } finally {\n382:         subject.cleanup();\n383:       }\n384:     });\n385: \n386:     it('runs exclusive write sections through the port', async () => {\n387:       const subject = createSubject();\n388:       try {\n389:         const result = await subject.port.withWriteLock(() => 'locked', { sync: true });\n390: \n391:         expect(result).toBe('locked');\n392:       } finally {\n393:         subject.cleanup();\n394:       }\n395:     });\n396:   });\n397: }\n398: \n399: runGraphTraversalContract('BetterSqliteGraphTraversal contract', () => {\n400:   const database = createGraphFixtureDb();\n401:   return {\n402:     port: new BetterSqliteGraphTraversal(database),\n403:     cleanup: () => database.close(),\n404:   };\n405: });\n406: \n407: runGraphTraversalContract('FakeGraphTraversal contract', () => ({\n408:   port: createFakeGraphTraversal(),\n409:   cleanup: () => {},\n410: }));\n411: \n412: runLexicalSearchContract('PackedBm25LexicalSearch contract', () => ({\n413:   port: new PackedBm25LexicalSearch(),\n414:   cleanup: () => {},\n415: }));\n416: \n417: runLexicalSearchContract('FakeLexicalSearch contract', () => ({\n418:   port: new FakeLexicalSearch(),\n419:   cleanup: () => {},\n420: }));\n421: \n422: runVectorStoreContract('BetterSqliteVectorStore contract', createBetterSqliteVectorSubject);\n423: \n424: runVectorStoreContract('FakeVectorStore contract', () => ({\n425:   port: new FakeVectorStore<VectorFixtureMetadata>(),\n426:   cleanup: () => {},\n427: }));\n428: \n429: runMaintenanceContract('BetterSqliteMaintenance contract', createBetterSqliteMaintenanceSubject);\n430: \n431: runMaintenanceContract('FakeMaintenance contract', () => ({\n432:   port: new FakeMaintenance({ ok: true, message: 'healthy' }),\n433:   cleanup: () => {},\n434: }));\n435: \n436: runContentionPolicyContract('BetterSqliteContentionPolicy contract', createBetterSqliteContentionSubject);\n437: \n438: runContentionPolicyContract('FakeContentionPolicy contract', () => ({\n439:   port: new FakeContentionPolicy(),\n440:   cleanup: () => {},\n441: }));\n442: \n443: describe('BetterSqliteContentionPolicy', () => {\n444:   it('applies better-sqlite busy_timeout pragmas through the port', () => {\n445:     const subject = createBetterSqliteContentionSubject();\n446:     try {\n447:       subject.port.setBusyTimeout(subject.database, 1234);\n448: \n449:       expect(subject.database.pragma('busy_timeout', { simple: true })).toBe(1234);\n450:     } finally {\n451:       subject.cleanup();\n452:     }\n453:   });\n454: });\n455: \n456: describe('storage port fakes', () => {\n457:   it('FakeVectorStore stores vectors and returns cosine-ranked matches', () => {\n458:     const store = new FakeVectorStore<{ readonly type: string }>();\n459:     store.upsert({ id: 'left', embedding: [1, 0], metadata: { type: 'axis' } });\n460:     store.upsert({ id: 'right', embedding: [0, 1], metadata: { type: 'axis' } });\n461: \n462:     const results = store.search([1, 0], { limit: 2, minScore: 0 });\n463: \n464:     expect(results.map((result) => result.id)).toEqual(['left', 'right']);\n465:     expect(store.get('left')?.metadata.type).toBe('axis');\n466:     expect(store.delete('left')).toBe(true);\n467:     expect(store.get('left')).toBeNull();\n468:   });\n469: \n470:   it('FakeMaintenance records calls and returns configured results', () => {\n471:     const maintenance = new FakeMaintenance({ ok: true, message: 'healthy' });\n472: \n473:     expect(maintenance.integrityCheck()).toEqual({ ok: true, message: 'healthy' });\n474:     expect(maintenance.vacuum()).toEqual({ ok: true, message: 'healthy' });\n475:     expect(maintenance.checkpoint({ mode: 'truncate' })).toEqual({ ok: true, message: 'healthy' });\n476:     expect(maintenance.calls).toEqual(['integrityCheck', 'vacuum', 'checkpoint:truncate']);\n477:   });\n478: \n479:   it('FakeContentionPolicy retries transient failures', async () => {\n480:     const policy = new FakeContentionPolicy();\n481:     let attempts = 0;\n482: \n483:     const result = await policy.withRetry(() => {\n484:       attempts += 1;\n485:       if (attempts === 1) {\n486:         const error = new Error('SQLITE_BUSY: database is locked');\n487:         (error as unknown as { code: string }).code = 'SQLITE_BUSY';\n488:         throw error;\n489:       }\n490:       return 'ok';\n491:     }, { attempts: 2 });\n492: \n493:     expect(result).toBe('ok');\n494:     expect(attempts).toBe(2);\n495:     await expect(policy.withWriteLock(() => 'locked')).resolves.toBe('locked');\n496:     const database = new Database(':memory:');\n497:     policy.setBusyTimeout(database, 250);\n498:     database.close();\n499:     expect(policy.busyTimeouts).toEqual([250]);\n500:   });\n501: });\n\n(End of file - total 501 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// TEST: STORAGE PORT CONTRACTS\n// -------------------------------------------------------------------\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';\nimport { describe, expect, it } from 'vitest';\n\nimport {\n  BetterSqliteContentionPolicy,\n  BetterSqliteGraphTraversal,\n  BetterSqliteMaintenance,\n  BetterSqliteVectorStore,\n  PackedBm25LexicalSearch,\n  type ContentionPolicy,\n  type GraphTraversal,\n  type LexicalSearch,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","text":"// -------------------------------------------------------------------\n// TEST: STORAGE PORT CONTRACTS\n// -------------------------------------------------------------------\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';\nimport { describe, expect, it } from 'vitest';\n\nimport {\n  BetterSqliteContentionPolicy,\n  BetterSqliteGraphTraversal,\n  BetterSqliteMaintenance,\n  BetterSqliteVectorStore,\n  PackedBm25LexicalSearch,\n  type ContentionPolicy,\n  type GraphTraversal,\n  type LexicalSearch,\n  type Maintenance,\n  type VectorMetadata,\n  type VectorStore,\n} from '../lib/storage/ports';\nimport {\n  FakeContentionPolicy,\n  FakeGraphTraversal,\n  FakeLexicalSearch,\n  FakeMaintenance,\n  FakeVectorStore,\n} from './fakes/storage-ports';\n\ninterface ContractSubject<TPort> {\n  readonly port: TPort;\n  readonly cleanup: () => void;\n}\n\ninterface EnvSnapshot {\n  readonly EMBEDDING_DIM: string | undefined;\n  readonly MEMORY_ALLOWED_PATHS: string | undefined;\n}\n\ntype VectorFixtureMetadata = VectorMetadata & {\n  readonly spec_folder: string;\n  readonly file_path: string;\n  readonly title: string;\n};\n\nfunction snapshotEnv(): EnvSnapshot {\n  return {\n    EMBEDDING_DIM: process.env.EMBEDDING_DIM,\n    MEMORY_ALLOWED_PATHS: process.env.MEMORY_ALLOWED_PATHS,\n  };\n}\n\nfunction restoreEnv(snapshot: EnvSnapshot): void {\n  if (snapshot.EMBEDDING_DIM === undefined) {\n    delete process.env.EMBEDDING_DIM;\n  } else {\n    process.env.EMBEDDING_DIM = snapshot.EMBEDDING_DIM;\n  }\n  if (snapshot.MEMORY_ALLOWED_PATHS === undefined) {\n    delete process.env.MEMORY_ALLOWED_PATHS;\n  } else {\n    process.env.MEMORY_ALLOWED_PATHS = snapshot.MEMORY_ALLOWED_PATHS;\n  }\n}\n\nfunction createGraphFixtureDb(): Database.Database {\n  const database = new Database(':memory:');\n  database.exec(`\n    CREATE TABLE causal_edges (\n      source_id TEXT NOT NULL,\n      target_id TEXT NOT NULL,\n      relation TEXT NOT NULL,\n      strength REAL\n    );\n    CREATE TABLE dependency_edges (\n      parent_path TEXT NOT NULL,\n      child_path TEXT NOT NULL\n    );\n  `);\n\n  const insertCausal = database.prepare(`\n    INSERT INTO causal_edges (source_id, target_id, relation, strength)\n    VALUES (?, ?, ?, ?)\n  `);\n  insertCausal.run('1', '2', 'supports', 0.5);\n  insertCausal.run('2', '3', 'enabled', 0.25);\n\n  const insertDependency = database.prepare(`\n    INSERT INTO dependency_edges (parent_path, child_path)\n    VALUES (?, ?)\n  `);\n  insertDependency.run('root', 'child');\n  insertDependency.run('child', 'grandchild');\n\n  return database;\n}\n\nfunction createFakeGraphTraversal(): FakeGraphTraversal {\n  return new FakeGraphTraversal({\n    causalEdges: [\n      { sourceId: 1, targetId: 2, relation: 'supports', strength: 0.5 },\n      { sourceId: 2, targetId: 3, relation: 'enabled', strength: 0.25 },\n    ],\n    dependencyEdges: [\n      { parentPath: 'root', childPath: 'child' },\n      { parentPath: 'child', childPath: 'grandchild' },\n    ],\n  });\n}\n\nfunction createBetterSqliteVectorSubject(): ContractSubject<VectorStore<VectorFixtureMetadata>> {\n  const env = snapshotEnv();\n  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-store-port-'));\n  process.env.EMBEDDING_DIM = '4';\n  process.env.MEMORY_ALLOWED_PATHS = tempDir;\n  const store = new BetterSqliteVectorStore({ dbPath: path.join(tempDir, 'context-index.sqlite') });\n  return {\n    port: store,\n    cleanup: () => {\n      void store.close();\n      restoreEnv(env);\n      fs.rmSync(tempDir, { recursive: true, force: true });\n    },\n  };\n}\n\nfunction createBetterSqliteMaintenanceSubject(): ContractSubject<Maintenance> {\n  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintenance-port-'));\n  const database = new Database(path.join(tempDir, 'maintenance.sqlite'));\n  database.pragma('auto_vacuum = INCREMENTAL');\n  database.exec('VACUUM');\n  database.pragma('journal_mode = WAL');\n  database.exec(`\n    CREATE TABLE records (id INTEGER PRIMARY KEY, value TEXT NOT NULL);\n    INSERT INTO records (value) VALUES ('kept'), ('deleted');\n    DELETE FROM records WHERE value = 'deleted';\n  `);\n\n  return {\n    port: new BetterSqliteMaintenance(database),\n    cleanup: () => {\n      database.close();\n      fs.rmSync(tempDir, { recursive: true, force: true });\n    },\n  };\n}\n\nfunction createBetterSqliteContentionSubject(): ContractSubject<ContentionPolicy> & { database: Database.Database } {\n  const database = new Database(':memory:');\n  database.exec('CREATE TABLE writes (id INTEGER PRIMARY KEY, value TEXT NOT NULL)');\n  return {\n    database,\n    port: new BetterSqliteContentionPolicy({\n      database,\n      sleep: async () => undefined,\n      sleepSync: () => undefined,\n    }),\n    cleanup: () => database.close(),\n  };\n}\n\nfunction runGraphTraversalContract(\n  label: string,\n  createSubject: () => ContractSubject<GraphTraversal>,\n): void {\n  describe(label, () => {\n    it('collects weighted causal neighbors with hop and score aggregation', () => {\n      const subject = createSubject();\n      try {\n        const results = subject.port.collectCausalWeightedNeighbors(\n          [1],\n          2,\n          { supports: 2, enabled: 4 },\n        );\n\n        expect(results.get(2)).toEqual({ nodeId: 2, minHop: 1, maxWalkScore: 1 });\n        expect(results.get(3)).toEqual({ nodeId: 3, minHop: 2, maxWalkScore: 1 });\n        expect(results.has(1)).toBe(false);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('collects dependency children through directed reachability', () => {\n      const subject = createSubject();\n      try {\n        expect(subject.port.collectDependencyReachability(['root'])).toEqual(['child', 'grandchild']);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('exposes generic directed reachability for caller-supplied readers', () => {\n      const subject = createSubject();\n      try {\n        const reached = subject.port.collectDirectedReachability({\n          roots: ['a'],\n          readEdges: (nodeIds) => nodeIds.includes('a')\n            ? [{ from: 'a', to: 'b' }, { from: 'a', to: 'c' }]\n            : [],\n        });\n\n        expect(reached).toEqual(['b', 'c']);\n      } finally {\n        subject.cleanup();\n      }\n    });\n  });\n}\n\nfunction runLexicalSearchContract(\n  label: string,\n  createSubject: () => ContractSubject<LexicalSearch>,\n): void {\n  describe(label, () => {\n    it('indexes fielded documents and returns ranked query matches', () => {\n      const subject = createSubject();\n      try {\n        subject.port.addDocumentFields('auth', {\n          title: 'Auth guard',\n          trigger_phrases: ['authentication', 'login'],\n          content_generic: 'auth/module.md',\n          body: 'Guarded login access for memory search',\n        });\n        subject.port.addDocumentFields('cache', {\n          title: 'Cache invalidation',\n          trigger_phrases: ['cache'],\n          content_generic: 'cache/module.md',\n          body: 'Background cache refresh notes',\n        });\n\n        const results = subject.port.search('auth guard', { limit: 1 });\n\n        expect(results).toHaveLength(1);\n        expect(results[0]?.id).toBe('auth');\n        expect(results[0]?.score).toBeGreaterThan(0);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('removes and clears indexed documents', () => {\n      const subject = createSubject();\n      try {\n        subject.port.addDocument('one', 'memory search document');\n        subject.port.addDocument('two', 'cache refresh document');\n\n        expect(subject.port.getStats().documentCount).toBe(2);\n        expect(subject.port.removeDocument('one')).toBe(true);\n        expect(subject.port.search('memory', { limit: 5 })).toEqual([]);\n\n        subject.port.clear();\n        expect(subject.port.getStats()).toEqual({\n          documentCount: 0,\n          termCount: 0,\n          avgDocLength: 0,\n        });\n      } finally {\n        subject.cleanup();\n      }\n    });\n  });\n}\n\nfunction runVectorStoreContract(\n  label: string,\n  createSubject: () => ContractSubject<VectorStore<VectorFixtureMetadata>>,\n): void {\n  describe(label, () => {\n    it('stores vectors and returns ranked matches through the port', async () => {\n      const subject = createSubject();\n      try {\n        await subject.port.upsert({\n          id: 'left',\n          embedding: [1, 0, 0, 0],\n          metadata: {\n            spec_folder: 'specs/vector-port',\n            file_path: 'left.md',\n            title: 'Left vector',\n          },\n        });\n        await subject.port.upsert({\n          id: 'right',\n          embedding: [0, 1, 0, 0],\n          metadata: {\n            spec_folder: 'specs/vector-port',\n            file_path: 'right.md',\n            title: 'Right vector',\n          },\n        });\n\n        const results = await subject.port.search([1, 0, 0, 0], { limit: 2, minScore: 0 });\n\n        expect(results).toHaveLength(2);\n        expect(results[0]?.metadata.title).toBe('Left vector');\n        expect(results[0]?.score).toBeGreaterThanOrEqual(results[1]?.score ?? 0);\n\n        const stored = await subject.port.get(String(results[0]?.id));\n        expect(stored?.metadata.title).toBe('Left vector');\n        expect(await subject.port.delete(String(results[0]?.id))).toBe(true);\n        expect(await subject.port.get(String(results[0]?.id))).toBeNull();\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('clears stored vector records', async () => {\n      const subject = createSubject();\n      try {\n        await subject.port.upsert({\n          id: 'clear-me',\n          embedding: [1, 0, 0, 0],\n          metadata: {\n            spec_folder: 'specs/vector-port',\n            file_path: 'clear.md',\n            title: 'Clear vector',\n          },\n        });\n\n        await subject.port.clear();\n\n        expect(await subject.port.search([1, 0, 0, 0], { limit: 5, minScore: 0 })).toEqual([]);\n      } finally {\n        subject.cleanup();\n      }\n    });\n  });\n}\n\nfunction runMaintenanceContract(\n  label: string,\n  createSubject: () => ContractSubject<Maintenance>,\n): void {\n  describe(label, () => {\n    it('reports storage integrity through the port', () => {\n      const subject = createSubject();\n      try {\n        expect(subject.port.integrityCheck().ok).toBe(true);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('runs vacuum and checkpoint maintenance through the port', () => {\n      const subject = createSubject();\n      try {\n        expect(subject.port.vacuum().ok).toBe(true);\n        expect(subject.port.checkpoint({ mode: 'truncate' }).ok).toBe(true);\n      } finally {\n        subject.cleanup();\n      }\n    });\n  });\n}\n\nfunction runContentionPolicyContract(\n  label: string,\n  createSubject: () => ContractSubject<ContentionPolicy>,\n): void {\n  describe(label, () => {\n    it('retries transient failures through the port', async () => {\n      const subject = createSubject();\n      try {\n        let attempts = 0;\n\n        const result = await subject.port.withRetry(() => {\n          attempts += 1;\n          if (attempts === 1) {\n            const error = new Error('SQLITE_BUSY: database is locked');\n            (error as unknown as { code: string }).code = 'SQLITE_BUSY';\n            throw error;\n          }\n          return 'ok';\n        }, { attempts: 2 });\n\n        expect(result).toBe('ok');\n        expect(attempts).toBe(2);\n      } finally {\n        subject.cleanup();\n      }\n    });\n\n    it('runs exclusive write sections through the port', async () => {\n      const subject = createSubject();\n      try {\n        const result = await subject.port.withWriteLock(() => 'locked', { sync: true });\n\n        expect(result).toBe('locked');\n      } finally {\n        subject.cleanup();\n      }\n    });\n  });\n}\n\nrunGraphTraversalContract('BetterSqliteGraphTraversal contract', () => {\n  const database = createGraphFixtureDb();\n  return {\n    port: new BetterSqliteGraphTraversal(database),\n    cleanup: () => database.close(),\n  };\n});\n\nrunGraphTraversalContract('FakeGraphTraversal contract', () => ({\n  port: createFakeGraphTraversal(),\n  cleanup: () => {},\n}));\n\nrunLexicalSearchContract('PackedBm25LexicalSearch contract', () => ({\n  port: new PackedBm25LexicalSearch(),\n  cleanup: () => {},\n}));\n\nrunLexicalSearchContract('FakeLexicalSearch contract', () => ({\n  port: new FakeLexicalSearch(),\n  cleanup: () => {},\n}));\n\nrunVectorStoreContract('BetterSqliteVectorStore contract', createBetterSqliteVectorSubject);\n\nrunVectorStoreContract('FakeVectorStore contract', () => ({\n  port: new FakeVectorStore<VectorFixtureMetadata>(),\n  cleanup: () => {},\n}));\n\nrunMaintenanceContract('BetterSqliteMaintenance contract', createBetterSqliteMaintenanceSubject);\n\nrunMaintenanceContract('FakeMaintenance contract', () => ({\n  port: new FakeMaintenance({ ok: true, message: 'healthy' }),\n  cleanup: () => {},\n}));\n\nrunContentionPolicyContract('BetterSqliteContentionPolicy contract', createBetterSqliteContentionSubject);\n\nrunContentionPolicyContract('FakeContentionPolicy contract', () => ({\n  port: new FakeContentionPolicy(),\n  cleanup: () => {},\n}));\n\ndescribe('BetterSqliteContentionPolicy', () => {\n  it('applies better-sqlite busy_timeout pragmas through the port', () => {\n    const subject = createBetterSqliteContentionSubject();\n    try {\n      subject.port.setBusyTimeout(subject.database, 1234);\n\n      expect(subject.database.pragma('busy_timeout', { simple: true })).toBe(1234);\n    } finally {\n      subject.cleanup();\n    }\n  });\n});\n\ndescribe('storage port fakes', () => {\n  it('FakeVectorStore stores vectors and returns cosine-ranked matches', () => {\n    const store = new FakeVectorStore<{ readonly type: string }>();\n    store.upsert({ id: 'left', embedding: [1, 0], metadata: { type: 'axis' } });\n    store.upsert({ id: 'right', embedding: [0, 1], metadata: { type: 'axis' } });\n\n    const results = store.search([1, 0], { limit: 2, minScore: 0 });\n\n    expect(results.map((result) => result.id)).toEqual(['left', 'right']);\n    expect(store.get('left')?.metadata.type).toBe('axis');\n    expect(store.delete('left')).toBe(true);\n    expect(store.get('left')).toBeNull();\n  });\n\n  it('FakeMaintenance records calls and returns configured results', () => {\n    const maintenance = new FakeMaintenance({ ok: true, message: 'healthy' });\n\n    expect(maintenance.integrityCheck()).toEqual({ ok: true, message: 'healthy' });\n    expect(maintenance.vacuum()).toEqual({ ok: true, message: 'healthy' });\n    expect(maintenance.checkpoint({ mode: 'truncate' })).toEqual({ ok: true, message: 'healthy' });\n    expect(maintenance.calls).toEqual(['integrityCheck', 'vacuum', 'checkpoint:truncate']);\n  });\n\n  it('FakeContentionPolicy retries transient failures', async () => {\n    const policy = new FakeContentionPolicy();\n    let attempts = 0;\n\n    const result = await policy.withRetry(() => {\n      attempts += 1;\n      if (attempts === 1) {\n        const error = new Error('SQLITE_BUSY: database is locked');\n        (error as unknown as { code: string }).code = 'SQLITE_BUSY';\n        throw error;\n      }\n      return 'ok';\n    }, { attempts: 2 });\n\n    expect(result).toBe('ok');\n    expect(attempts).toBe(2);\n    await expect(policy.withWriteLock(() => 'locked')).resolves.toBe('locked');\n    const database = new Database(':memory:');\n    policy.setBusyTimeout(database, 250);\n    database.close();\n    expect(policy.busyTimeouts).toEqual([250]);\n  });\n});","lineStart":1,"lineEnd":501,"totalLines":501,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/storage-ports-contract.vitest.ts","time":{"start":1781144201374,"end":1781144201381}},"metadata":{"openai":{"itemId":"fc_02d0ac507d0d4065016a2a1a88c77481919a5a10fe0c6094a7"}},"id":"prt_eb477a861001i0EPxjH8Su32KP","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb4778162001F2alOO06lz0MYE"}}
{"type":"tool_use","timestamp":1781144201384,"sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","part":{"type":"tool","tool":"read","callID":"call_zokwPRBsuvKN1PrtjpKKCVd7","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/fakes/storage-ports.ts","offset":1,"limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/fakes/storage-ports.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Port Fakes\n3: // -------------------------------------------------------------------\n4: \n5: import {\n6:   collectDirectedReachability,\n7:   collectWeightedWalk,\n8:   type DirectedReachabilityOptions,\n9:   type DirectedTraversalEdge,\n10:   type WeightedTraversalEdge,\n11:   type WeightedWalkOptions,\n12:   type WeightedWalkResult,\n13: } from '../../lib/graph/bfs-traversal';\n14: import { isSqliteContentionError } from '../../lib/storage/ports';\n15: import type {\n16:   CheckpointOptions,\n17:   ContentionOperationOptions,\n18:   ContentionPolicy,\n19:   GraphTraversal,\n20:   GraphTraversalNode,\n21:   LexicalDocumentFields,\n22:   LexicalSearch,\n23:   LexicalSearchOptions,\n24:   LexicalSearchResult,\n25:   LexicalSearchStats,\n26:   Maintenance,\n27:   MaintenanceResult,\n28:   StorageId,\n29:   VectorMetadata,\n30:   VectorRecord,\n31:   VectorSearchOptions,\n32:   VectorSearchResult,\n33:   VectorStore,\n34: } from '../../lib/storage/ports';\n35: import type Database from 'better-sqlite3';\n36: \n37: interface FakeCausalEdge {\n38:   readonly sourceId: number;\n39:   readonly targetId: number;\n40:   readonly relation: string;\n41:   readonly strength?: number;\n42: }\n43: \n44: interface FakeDependencyEdge {\n45:   readonly parentPath: string;\n46:   readonly childPath: string;\n47: }\n48: \n49: interface FakeGraphTraversalOptions {\n50:   readonly causalEdges?: readonly FakeCausalEdge[];\n51:   readonly dependencyEdges?: readonly FakeDependencyEdge[];\n52: }\n53: \n54: /** Storage-free graph traversal test double. */\n55: export class FakeGraphTraversal implements GraphTraversal {\n56:   private readonly causalEdges: readonly FakeCausalEdge[];\n57:   private readonly dependencyEdges: readonly FakeDependencyEdge[];\n58: \n59:   constructor(options: FakeGraphTraversalOptions = {}) {\n60:     this.causalEdges = options.causalEdges ?? [];\n61:     this.dependencyEdges = options.dependencyEdges ?? [];\n62:   }\n63: \n64:   collectWeightedWalk<TNode extends GraphTraversalNode>(\n65:     options: WeightedWalkOptions<TNode>,\n66:   ): Map<TNode, WeightedWalkResult<TNode>> {\n67:     return collectWeightedWalk(options);\n68:   }\n69: \n70:   collectDirectedReachability<TNode extends GraphTraversalNode>(\n71:     options: DirectedReachabilityOptions<TNode>,\n72:   ): TNode[] {\n73:     return collectDirectedReachability(options);\n74:   }\n75: \n76:   collectCausalWeightedNeighbors(\n77:     seeds: readonly number[],\n78:     maxHops: number,\n79:     relationWeights: Readonly<Record<string, number>>,\n80:   ): Map<number, WeightedWalkResult<number>> {\n81:     return this.collectWeightedWalk({\n82:       seeds,\n83:       maxHops,\n84:       readEdges: (nodeIds) => this.readCausalEdges(nodeIds, relationWeights),\n85:     });\n86:   }\n87: \n88:   collectDependencyReachability(roots: readonly string[]): string[] {\n89:     return this.collectDirectedReachability({\n90:       roots,\n91:       readEdges: (nodeIds) => this.readDependencyEdges(nodeIds),\n92:     });\n93:   }\n94: \n95:   private readCausalEdges(\n96:     nodeIds: readonly number[],\n97:     relationWeights: Readonly<Record<string, number>>,\n98:   ): WeightedTraversalEdge<number>[] {\n99:     const nodeSet = new Set(nodeIds);\n100:     const edges: WeightedTraversalEdge<number>[] = [];\n101:     for (const edge of this.causalEdges) {\n102:       const weight = relationWeights[edge.relation] ?? 1.0;\n103:       const strength = edge.strength ?? 1.0;\n104:       if (nodeSet.has(edge.sourceId)) {\n105:         edges.push({ from: edge.sourceId, to: edge.targetId, weight, strength });\n106:       }\n107:       if (nodeSet.has(edge.targetId)) {\n108:         edges.push({ from: edge.targetId, to: edge.sourceId, weight, strength });\n109:       }\n110:     }\n111:     return edges;\n112:   }\n113: \n114:   private readDependencyEdges(nodeIds: readonly string[]): DirectedTraversalEdge<string>[] {\n115:     const nodeSet = new Set(nodeIds);\n116:     return this.dependencyEdges\n117:       .filter((edge) => nodeSet.has(edge.parentPath))\n118:       .map((edge) => ({ from: edge.parentPath, to: edge.childPath }));\n119:   }\n120: }\n121: \n122: /** Storage-free lexical search test double. */\n123: export class FakeLexicalSearch implements LexicalSearch {\n124:   private readonly documents = new Map<string, string>();\n125: \n126:   addDocument(id: string, text: string): void {\n127:     this.documents.set(id, text);\n128:   }\n129: \n130:   addDocumentFields(id: string, fields: LexicalDocumentFields): void {\n131:     this.addDocument(id, fieldsToText(fields));\n132:   }\n133: \n134:   removeDocument(id: string): boolean {\n135:     return this.documents.delete(id);\n136:   }\n137: \n138:   search(query: string, options: LexicalSearchOptions = {}): LexicalSearchResult[] {\n139:     const queryTokens = tokenizeForFake(query);\n140:     if (queryTokens.length === 0) {\n141:       return [];\n142:     }\n143: \n144:     const results: LexicalSearchResult[] = [];\n145:     for (const [id, text] of this.documents) {\n146:       const textTokens = tokenizeForFake(text);\n147:       const score = queryTokens.reduce(\n148:         (sum, token) => sum + textTokens.filter((textToken) => textToken === token).length,\n149:         0,\n150:       );\n151:       if (score > 0) {\n152:         results.push({ id, score });\n153:       }\n154:     }\n155: \n156:     return results\n157:       .sort((left, right) => right.score - left.score || left.id.localeCompare(right.id))\n158:       .slice(0, options.limit ?? 10);\n159:   }\n160: \n161:   getStats(): LexicalSearchStats {\n162:     const terms = new Set<string>();\n163:     let totalLength = 0;\n164:     for (const text of this.documents.values()) {\n165:       const tokens = tokenizeForFake(text);\n166:       totalLength += tokens.length;\n167:       for (const token of tokens) {\n168:         terms.add(token);\n169:       }\n170:     }\n171:     const documentCount = this.documents.size;\n172:     return {\n173:       documentCount,\n174:       termCount: terms.size,\n175:       avgDocLength: documentCount === 0 ? 0 : totalLength / documentCount,\n176:     };\n177:   }\n178: \n179:   clear(): void {\n180:     this.documents.clear();\n181:   }\n182: }\n183: \n184: /** Storage-free vector store test double. */\n185: export class FakeVectorStore<TMetadata extends VectorMetadata = VectorMetadata> implements VectorStore<TMetadata> {\n186:   private readonly records = new Map<StorageId, VectorRecord<TMetadata>>();\n187: \n188:   upsert(record: VectorRecord<TMetadata>): void {\n189:     this.records.set(record.id, record);\n190:   }\n191: \n192:   delete(id: StorageId): boolean {\n193:     return this.records.delete(id);\n194:   }\n195: \n196:   get(id: StorageId): VectorRecord<TMetadata> | null {\n197:     return this.records.get(id) ?? null;\n198:   }\n199: \n200:   search(\n201:     embedding: readonly number[] | Float32Array,\n202:     options: VectorSearchOptions,\n203:   ): VectorSearchResult<TMetadata>[] {\n204:     return Array.from(this.records.values())\n205:       .map((record) => ({\n206:         id: record.id,\n207:         score: cosineSimilarity(embedding, record.embedding),\n208:         metadata: record.metadata,\n209:       }))\n210:       .filter((result) => result.score >= (options.minScore ?? Number.NEGATIVE_INFINITY))\n211:       .sort((left, right) => right.score - left.score)\n212:       .slice(0, options.limit);\n213:   }\n214: \n215:   clear(): void {\n216:     this.records.clear();\n217:   }\n218: }\n219: \n220: /** Storage-free maintenance test double. */\n221: export class FakeMaintenance implements Maintenance {\n222:   readonly calls: string[] = [];\n223: \n224:   constructor(private readonly result: MaintenanceResult = { ok: true }) {}\n225: \n226:   integrityCheck(): MaintenanceResult {\n227:     this.calls.push('integrityCheck');\n228:     return this.result;\n229:   }\n230: \n231:   vacuum(): MaintenanceResult {\n232:     this.calls.push('vacuum');\n233:     return this.result;\n234:   }\n235: \n236:   checkpoint(options: CheckpointOptions = {}): MaintenanceResult {\n237:     this.calls.push(`checkpoint:${options.mode ?? 'passive'}`);\n238:     return this.result;\n239:   }\n240: }\n241: \n242: /** Storage-free contention policy test double. */\n243: export class FakeContentionPolicy implements ContentionPolicy {\n244:   readonly busyTimeouts: number[] = [];\n245: \n246:   async withRetry<T>(\n247:     operation: () => T | Promise<T>,\n248:     options: ContentionOperationOptions = {},\n249:   ): Promise<T> {\n250:     const attempts = Math.max(1, options.attempts ?? 1);\n251:     const retryable = options.retryable ?? isSqliteContentionError;\n252:     for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n253:       try {\n254:         return await operation();\n255:       } catch (error: unknown) {\n256:         const canRetry = retryable(error) && attemptIndex < attempts - 1;\n257:         if (!canRetry) {\n258:           throw error;\n259:         }\n260:         const delayMs = resolveFakeDelayMs(options, attemptIndex);\n261:         options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n262:       }\n263:     }\n264:     throw new Error('FakeContentionPolicy.withRetry: unreachable');\n265:   }\n266: \n267:   withWriteLock<T>(\n268:     operation: () => T | Promise<T>,\n269:     options: ContentionOperationOptions = {},\n270:   ): Promise<T> {\n271:     return this.withRetry(operation, options);\n272:   }\n273: \n274:   setBusyTimeout(\n275:     _database: Database.Database,\n276:     timeoutMs: number,\n277:   ): void {\n278:     this.busyTimeouts.push(timeoutMs);\n279:   }\n280: }\n281: \n282: function resolveFakeDelayMs(options: ContentionOperationOptions, attemptIndex: number): number {\n283:   const configuredDelay = options.retryDelaysMs?.[attemptIndex] ?? options.delayMs ?? 0;\n284:   const delay = typeof configuredDelay === 'function' ? configuredDelay() : configuredDelay;\n285:   return Math.max(0, delay);\n286: }\n287: \n288: function fieldsToText(fields: LexicalDocumentFields): string {\n289:   return [\n290:     fields.title ?? '',\n291:     arrayOrStringToText(fields.trigger_phrases),\n292:     fields.content_generic ?? '',\n293:     fields.body ?? '',\n294:   ].filter((part) => part.trim().length > 0).join(' ');\n295: }\n296: \n297: function arrayOrStringToText(value: string | string[] | null | undefined): string {\n298:   return Array.isArray(value) ? value.join(' ') : (value ?? '');\n299: }\n300: \n301: function tokenizeForFake(text: string): string[] {\n302:   return text.toLowerCase().match(/[a-z0-9_-]+/g) ?? [];\n303: }\n304: \n305: function cosineSimilarity(\n306:   left: readonly number[] | Float32Array,\n307:   right: readonly number[] | Float32Array,\n308: ): number {\n309:   const length = Math.min(left.length, right.length);\n310:   let dot = 0;\n311:   let leftMagnitude = 0;\n312:   let rightMagnitude = 0;\n313:   for (let index = 0; index < length; index += 1) {\n314:     const leftValue = left[index] ?? 0;\n315:     const rightValue = right[index] ?? 0;\n316:     dot += leftValue * rightValue;\n317:     leftMagnitude += leftValue * leftValue;\n318:     rightMagnitude += rightValue * rightValue;\n319:   }\n320:   if (leftMagnitude === 0 || rightMagnitude === 0) {\n321:     return 0;\n322:   }\n323:   return dot / (Math.sqrt(leftMagnitude) * Math.sqrt(rightMagnitude));\n324: }\n\n(End of file - total 324 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Port Fakes\n// -------------------------------------------------------------------\n\nimport {\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type DirectedTraversalEdge,\n  type WeightedTraversalEdge,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../lib/graph/bfs-traversal';\nimport { isSqliteContentionError } from '../../lib/storage/ports';\nimport type {\n  CheckpointOptions,\n  ContentionOperationOptions,\n  ContentionPolicy,\n  GraphTraversal,\n  GraphTraversalNode,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/fakes/storage-ports.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Port Fakes\n// -------------------------------------------------------------------\n\nimport {\n  collectDirectedReachability,\n  collectWeightedWalk,\n  type DirectedReachabilityOptions,\n  type DirectedTraversalEdge,\n  type WeightedTraversalEdge,\n  type WeightedWalkOptions,\n  type WeightedWalkResult,\n} from '../../lib/graph/bfs-traversal';\nimport { isSqliteContentionError } from '../../lib/storage/ports';\nimport type {\n  CheckpointOptions,\n  ContentionOperationOptions,\n  ContentionPolicy,\n  GraphTraversal,\n  GraphTraversalNode,\n  LexicalDocumentFields,\n  LexicalSearch,\n  LexicalSearchOptions,\n  LexicalSearchResult,\n  LexicalSearchStats,\n  Maintenance,\n  MaintenanceResult,\n  StorageId,\n  VectorMetadata,\n  VectorRecord,\n  VectorSearchOptions,\n  VectorSearchResult,\n  VectorStore,\n} from '../../lib/storage/ports';\nimport type Database from 'better-sqlite3';\n\ninterface FakeCausalEdge {\n  readonly sourceId: number;\n  readonly targetId: number;\n  readonly relation: string;\n  readonly strength?: number;\n}\n\ninterface FakeDependencyEdge {\n  readonly parentPath: string;\n  readonly childPath: string;\n}\n\ninterface FakeGraphTraversalOptions {\n  readonly causalEdges?: readonly FakeCausalEdge[];\n  readonly dependencyEdges?: readonly FakeDependencyEdge[];\n}\n\n/** Storage-free graph traversal test double. */\nexport class FakeGraphTraversal implements GraphTraversal {\n  private readonly causalEdges: readonly FakeCausalEdge[];\n  private readonly dependencyEdges: readonly FakeDependencyEdge[];\n\n  constructor(options: FakeGraphTraversalOptions = {}) {\n    this.causalEdges = options.causalEdges ?? [];\n    this.dependencyEdges = options.dependencyEdges ?? [];\n  }\n\n  collectWeightedWalk<TNode extends GraphTraversalNode>(\n    options: WeightedWalkOptions<TNode>,\n  ): Map<TNode, WeightedWalkResult<TNode>> {\n    return collectWeightedWalk(options);\n  }\n\n  collectDirectedReachability<TNode extends GraphTraversalNode>(\n    options: DirectedReachabilityOptions<TNode>,\n  ): TNode[] {\n    return collectDirectedReachability(options);\n  }\n\n  collectCausalWeightedNeighbors(\n    seeds: readonly number[],\n    maxHops: number,\n    relationWeights: Readonly<Record<string, number>>,\n  ): Map<number, WeightedWalkResult<number>> {\n    return this.collectWeightedWalk({\n      seeds,\n      maxHops,\n      readEdges: (nodeIds) => this.readCausalEdges(nodeIds, relationWeights),\n    });\n  }\n\n  collectDependencyReachability(roots: readonly string[]): string[] {\n    return this.collectDirectedReachability({\n      roots,\n      readEdges: (nodeIds) => this.readDependencyEdges(nodeIds),\n    });\n  }\n\n  private readCausalEdges(\n    nodeIds: readonly number[],\n    relationWeights: Readonly<Record<string, number>>,\n  ): WeightedTraversalEdge<number>[] {\n    const nodeSet = new Set(nodeIds);\n    const edges: WeightedTraversalEdge<number>[] = [];\n    for (const edge of this.causalEdges) {\n      const weight = relationWeights[edge.relation] ?? 1.0;\n      const strength = edge.strength ?? 1.0;\n      if (nodeSet.has(edge.sourceId)) {\n        edges.push({ from: edge.sourceId, to: edge.targetId, weight, strength });\n      }\n      if (nodeSet.has(edge.targetId)) {\n        edges.push({ from: edge.targetId, to: edge.sourceId, weight, strength });\n      }\n    }\n    return edges;\n  }\n\n  private readDependencyEdges(nodeIds: readonly string[]): DirectedTraversalEdge<string>[] {\n    const nodeSet = new Set(nodeIds);\n    return this.dependencyEdges\n      .filter((edge) => nodeSet.has(edge.parentPath))\n      .map((edge) => ({ from: edge.parentPath, to: edge.childPath }));\n  }\n}\n\n/** Storage-free lexical search test double. */\nexport class FakeLexicalSearch implements LexicalSearch {\n  private readonly documents = new Map<string, string>();\n\n  addDocument(id: string, text: string): void {\n    this.documents.set(id, text);\n  }\n\n  addDocumentFields(id: string, fields: LexicalDocumentFields): void {\n    this.addDocument(id, fieldsToText(fields));\n  }\n\n  removeDocument(id: string): boolean {\n    return this.documents.delete(id);\n  }\n\n  search(query: string, options: LexicalSearchOptions = {}): LexicalSearchResult[] {\n    const queryTokens = tokenizeForFake(query);\n    if (queryTokens.length === 0) {\n      return [];\n    }\n\n    const results: LexicalSearchResult[] = [];\n    for (const [id, text] of this.documents) {\n      const textTokens = tokenizeForFake(text);\n      const score = queryTokens.reduce(\n        (sum, token) => sum + textTokens.filter((textToken) => textToken === token).length,\n        0,\n      );\n      if (score > 0) {\n        results.push({ id, score });\n      }\n    }\n\n    return results\n      .sort((left, right) => right.score - left.score || left.id.localeCompare(right.id))\n      .slice(0, options.limit ?? 10);\n  }\n\n  getStats(): LexicalSearchStats {\n    const terms = new Set<string>();\n    let totalLength = 0;\n    for (const text of this.documents.values()) {\n      const tokens = tokenizeForFake(text);\n      totalLength += tokens.length;\n      for (const token of tokens) {\n        terms.add(token);\n      }\n    }\n    const documentCount = this.documents.size;\n    return {\n      documentCount,\n      termCount: terms.size,\n      avgDocLength: documentCount === 0 ? 0 : totalLength / documentCount,\n    };\n  }\n\n  clear(): void {\n    this.documents.clear();\n  }\n}\n\n/** Storage-free vector store test double. */\nexport class FakeVectorStore<TMetadata extends VectorMetadata = VectorMetadata> implements VectorStore<TMetadata> {\n  private readonly records = new Map<StorageId, VectorRecord<TMetadata>>();\n\n  upsert(record: VectorRecord<TMetadata>): void {\n    this.records.set(record.id, record);\n  }\n\n  delete(id: StorageId): boolean {\n    return this.records.delete(id);\n  }\n\n  get(id: StorageId): VectorRecord<TMetadata> | null {\n    return this.records.get(id) ?? null;\n  }\n\n  search(\n    embedding: readonly number[] | Float32Array,\n    options: VectorSearchOptions,\n  ): VectorSearchResult<TMetadata>[] {\n    return Array.from(this.records.values())\n      .map((record) => ({\n        id: record.id,\n        score: cosineSimilarity(embedding, record.embedding),\n        metadata: record.metadata,\n      }))\n      .filter((result) => result.score >= (options.minScore ?? Number.NEGATIVE_INFINITY))\n      .sort((left, right) => right.score - left.score)\n      .slice(0, options.limit);\n  }\n\n  clear(): void {\n    this.records.clear();\n  }\n}\n\n/** Storage-free maintenance test double. */\nexport class FakeMaintenance implements Maintenance {\n  readonly calls: string[] = [];\n\n  constructor(private readonly result: MaintenanceResult = { ok: true }) {}\n\n  integrityCheck(): MaintenanceResult {\n    this.calls.push('integrityCheck');\n    return this.result;\n  }\n\n  vacuum(): MaintenanceResult {\n    this.calls.push('vacuum');\n    return this.result;\n  }\n\n  checkpoint(options: CheckpointOptions = {}): MaintenanceResult {\n    this.calls.push(`checkpoint:${options.mode ?? 'passive'}`);\n    return this.result;\n  }\n}\n\n/** Storage-free contention policy test double. */\nexport class FakeContentionPolicy implements ContentionPolicy {\n  readonly busyTimeouts: number[] = [];\n\n  async withRetry<T>(\n    operation: () => T | Promise<T>,\n    options: ContentionOperationOptions = {},\n  ): Promise<T> {\n    const attempts = Math.max(1, options.attempts ?? 1);\n    const retryable = options.retryable ?? isSqliteContentionError;\n    for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n      try {\n        return await operation();\n      } catch (error: unknown) {\n        const canRetry = retryable(error) && attemptIndex < attempts - 1;\n        if (!canRetry) {\n          throw error;\n        }\n        const delayMs = resolveFakeDelayMs(options, attemptIndex);\n        options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n      }\n    }\n    throw new Error('FakeContentionPolicy.withRetry: unreachable');\n  }\n\n  withWriteLock<T>(\n    operation: () => T | Promise<T>,\n    options: ContentionOperationOptions = {},\n  ): Promise<T> {\n    return this.withRetry(operation, options);\n  }\n\n  setBusyTimeout(\n    _database: Database.Database,\n    timeoutMs: number,\n  ): void {\n    this.busyTimeouts.push(timeoutMs);\n  }\n}\n\nfunction resolveFakeDelayMs(options: ContentionOperationOptions, attemptIndex: number): number {\n  const configuredDelay = options.retryDelaysMs?.[attemptIndex] ?? options.delayMs ?? 0;\n  const delay = typeof configuredDelay === 'function' ? configuredDelay() : configuredDelay;\n  return Math.max(0, delay);\n}\n\nfunction fieldsToText(fields: LexicalDocumentFields): string {\n  return [\n    fields.title ?? '',\n    arrayOrStringToText(fields.trigger_phrases),\n    fields.content_generic ?? '',\n    fields.body ?? '',\n  ].filter((part) => part.trim().length > 0).join(' ');\n}\n\nfunction arrayOrStringToText(value: string | string[] | null | undefined): string {\n  return Array.isArray(value) ? value.join(' ') : (value ?? '');\n}\n\nfunction tokenizeForFake(text: string): string[] {\n  return text.toLowerCase().match(/[a-z0-9_-]+/g) ?? [];\n}\n\nfunction cosineSimilarity(\n  left: readonly number[] | Float32Array,\n  right: readonly number[] | Float32Array,\n): number {\n  const length = Math.min(left.length, right.length);\n  let dot = 0;\n  let leftMagnitude = 0;\n  let rightMagnitude = 0;\n  for (let index = 0; index < length; index += 1) {\n    const leftValue = left[index] ?? 0;\n    const rightValue = right[index] ?? 0;\n    dot += leftValue * rightValue;\n    leftMagnitude += leftValue * leftValue;\n    rightMagnitude += rightValue * rightValue;\n  }\n  if (leftMagnitude === 0 || rightMagnitude === 0) {\n    return 0;\n  }\n  return dot / (Math.sqrt(leftMagnitude) * Math.sqrt(rightMagnitude));\n}","lineStart":1,"lineEnd":324,"totalLines":324,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/fakes/storage-ports.ts","time":{"start":1781144201377,"end":1781144201383}},"metadata":{"openai":{"itemId":"fc_02d0ac507d0d4065016a2a1a88c77c8191a9225c498c620f9d"}},"id":"prt_eb477a89f001QEtxmu67ws1Zj2","sessionID":"ses_14b8a0217ffeP6eGAP16BZOkoX","messageID":"msg_eb4778162001F2alOO06lz0MYE"}}
