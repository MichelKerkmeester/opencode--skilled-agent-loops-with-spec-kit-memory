{"type":"tool_use","timestamp":1784619117976,"sessionID":"ses_07c97d905ffee2yzbow793KIc8","part":{"type":"tool","tool":"read","callID":"call_G3kbqcYAHiBAPncsWgrAq5NQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/continuity-thread.cjs","offset":1,"limit":300},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/continuity-thread.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Continuity Threading Helpers                                             ║\n3: // ╚══════════════════════════════════════════════════════════════════════════╝\n4: \n5: 'use strict';\n6: \n7: const crypto = require('node:crypto');\n8: \n9: const DEFAULT_TERMINAL_NEXT_FOCUS = '[All tracked questions are resolved]';\n10: const MAX_DERIVED_FOCUS_LENGTH = 220;\n11: \n12: function normalizeText(value) {\n13:   return String(value ?? '').replace(/\\s+/g, ' ').trim();\n14: }\n15: \n16: function normalizeKey(value) {\n17:   return normalizeText(value).toLowerCase();\n18: }\n19: \n20: function contentOrderKey(value) {\n21:   return crypto.createHash('sha256').update(normalizeKey(value)).digest('hex');\n22: }\n23: \n24: function textFromQuestion(value) {\n25:   if (typeof value === 'string') {\n26:     return normalizeText(value);\n27:   }\n28:   if (value && typeof value === 'object' && typeof value.text === 'string') {\n29:     return normalizeText(value.text);\n30:   }\n31:   return '';\n32: }\n33: \n34: function toTextArray(value) {\n35:   return Array.isArray(value)\n36:     ? value.map(textFromQuestion).filter(Boolean)\n37:     : [];\n38: }\n39: \n40: function getRunNumber(item) {\n41:   return Number.isFinite(item?.run)\n42:     ? item.run\n43:     : Number.isFinite(item?.iteration)\n44:       ? item.iteration\n45:       : 0;\n46: }\n47: \n48: function truncateFocus(value) {\n49:   const normalized = normalizeText(value);\n50:   if (normalized.length <= MAX_DERIVED_FOCUS_LENGTH) {\n51:     return normalized;\n52:   }\n53:   return `${normalized.slice(0, MAX_DERIVED_FOCUS_LENGTH - 3).trimEnd()}...`;\n54: }\n55: \n56: function getLatestByRun(items) {\n57:   return [...items].sort((left, right) => getRunNumber(left) - getRunNumber(right)).at(-1) || null;\n58: }\n59: \n60: function buildCarriedForwardOpenQuestions({\n61:   iterationFiles = [],\n62:   iterationRecords = [],\n63:   machineOpenQuestions = [],\n64: } = {}) {\n65:   const machineQuestionKeys = new Set(toTextArray(machineOpenQuestions).map(normalizeKey));\n66:   const seen = new Set();\n67:   const candidates = [];\n68: \n69:   for (const iteration of iterationFiles) {\n70:     for (const question of toTextArray(iteration.questionsRemaining)) {\n71:       const key = normalizeKey(question);\n72:       if (!key || machineQuestionKeys.has(key) || seen.has(key)) {\n73:         continue;\n74:       }\n75:       seen.add(key);\n76:       candidates.push({\n77:         text: question,\n78:         addedAtIteration: getRunNumber(iteration),\n79:         source: 'iteration-markdown',\n80:       });\n81:     }\n82:   }\n83: \n84:   for (const record of iterationRecords) {\n85:     for (const question of toTextArray(record.openQuestions).concat(toTextArray(record.questionsRemaining))) {\n86:       const key = normalizeKey(question);\n87:       if (!key || machineQuestionKeys.has(key) || seen.has(key)) {\n88:         continue;\n89:       }\n90:       seen.add(key);\n91:       candidates.push({\n92:         text: question,\n93:         addedAtIteration: getRunNumber(record),\n94:         source: 'iteration-record',\n95:       });\n96:     }\n97:   }\n98: \n99:   return candidates.sort((left, right) =>\n100:     left.addedAtIteration - right.addedAtIteration || contentOrderKey(left.text).localeCompare(contentOrderKey(right.text)),\n101:   );\n102: }\n103: \n104: function formatCarriedForwardOpenQuestions(questions) {\n105:   if (!Array.isArray(questions) || questions.length === 0) {\n106:     return '[None yet]';\n107:   }\n108: \n109:   return questions\n110:     .map((question) => `- ${question.text} (iteration ${question.addedAtIteration || 0})`)\n111:     .join('\\n');\n112: }\n113: \n114: function deriveNextFocusFromContinuity({\n115:   iterationFiles = [],\n116:   iterationRecords = [],\n117:   carriedForwardOpenQuestions = [],\n118:   machineOpenQuestions = [],\n119:   terminalSentinel = DEFAULT_TERMINAL_NEXT_FOCUS,\n120: } = {}) {\n121:   const machineQuestions = toTextArray(machineOpenQuestions);\n122:   if (machineQuestions.length === 0) {\n123:     return terminalSentinel;\n124:   }\n125: \n126:   const latestThreadQuestion = getLatestByRun(carriedForwardOpenQuestions);\n127:   if (latestThreadQuestion?.text) {\n128:     return latestThreadQuestion.text;\n129:   }\n130: \n131:   const latestIteration = getLatestByRun(iterationFiles);\n132:   const latestFinding = Array.isArray(latestIteration?.findings)\n133:     ? latestIteration.findings.map(normalizeText).filter(Boolean).at(-1)\n134:     : null;\n135:   if (latestFinding) {\n136:     return `Follow up on: ${truncateFocus(latestFinding)}`;\n137:   }\n138: \n139:   const latestRecord = getLatestByRun(iterationRecords);\n140:   const latestRecordFinding = Array.isArray(latestRecord?.findings)\n141:     ? latestRecord.findings.map(textFromQuestion).filter(Boolean).at(-1)\n142:     : null;\n143:   if (latestRecordFinding) {\n144:     return `Follow up on: ${truncateFocus(latestRecordFinding)}`;\n145:   }\n146: \n147:   return machineQuestions[0] || terminalSentinel;\n148: }\n149: \n150: module.exports = {\n151:   buildCarriedForwardOpenQuestions,\n152:   deriveNextFocusFromContinuity,\n153:   formatCarriedForwardOpenQuestions,\n154: };\n\n(End of file - total 154 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Continuity Threading Helpers                                             ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst crypto = require('node:crypto');\n\nconst DEFAULT_TERMINAL_NEXT_FOCUS = '[All tracked questions are resolved]';\nconst MAX_DERIVED_FOCUS_LENGTH = 220;\n\nfunction normalizeText(value) {\n  return String(value ?? '').replace(/\\s+/g, ' ').trim();\n}\n\nfunction normalizeKey(value) {\n  return normalizeText(value).toLowerCase();\n}\n\nfunction contentOrderKey(value) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/continuity-thread.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Continuity Threading Helpers                                             ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst crypto = require('node:crypto');\n\nconst DEFAULT_TERMINAL_NEXT_FOCUS = '[All tracked questions are resolved]';\nconst MAX_DERIVED_FOCUS_LENGTH = 220;\n\nfunction normalizeText(value) {\n  return String(value ?? '').replace(/\\s+/g, ' ').trim();\n}\n\nfunction normalizeKey(value) {\n  return normalizeText(value).toLowerCase();\n}\n\nfunction contentOrderKey(value) {\n  return crypto.createHash('sha256').update(normalizeKey(value)).digest('hex');\n}\n\nfunction textFromQuestion(value) {\n  if (typeof value === 'string') {\n    return normalizeText(value);\n  }\n  if (value && typeof value === 'object' && typeof value.text === 'string') {\n    return normalizeText(value.text);\n  }\n  return '';\n}\n\nfunction toTextArray(value) {\n  return Array.isArray(value)\n    ? value.map(textFromQuestion).filter(Boolean)\n    : [];\n}\n\nfunction getRunNumber(item) {\n  return Number.isFinite(item?.run)\n    ? item.run\n    : Number.isFinite(item?.iteration)\n      ? item.iteration\n      : 0;\n}\n\nfunction truncateFocus(value) {\n  const normalized = normalizeText(value);\n  if (normalized.length <= MAX_DERIVED_FOCUS_LENGTH) {\n    return normalized;\n  }\n  return `${normalized.slice(0, MAX_DERIVED_FOCUS_LENGTH - 3).trimEnd()}...`;\n}\n\nfunction getLatestByRun(items) {\n  return [...items].sort((left, right) => getRunNumber(left) - getRunNumber(right)).at(-1) || null;\n}\n\nfunction buildCarriedForwardOpenQuestions({\n  iterationFiles = [],\n  iterationRecords = [],\n  machineOpenQuestions = [],\n} = {}) {\n  const machineQuestionKeys = new Set(toTextArray(machineOpenQuestions).map(normalizeKey));\n  const seen = new Set();\n  const candidates = [];\n\n  for (const iteration of iterationFiles) {\n    for (const question of toTextArray(iteration.questionsRemaining)) {\n      const key = normalizeKey(question);\n      if (!key || machineQuestionKeys.has(key) || seen.has(key)) {\n        continue;\n      }\n      seen.add(key);\n      candidates.push({\n        text: question,\n        addedAtIteration: getRunNumber(iteration),\n        source: 'iteration-markdown',\n      });\n    }\n  }\n\n  for (const record of iterationRecords) {\n    for (const question of toTextArray(record.openQuestions).concat(toTextArray(record.questionsRemaining))) {\n      const key = normalizeKey(question);\n      if (!key || machineQuestionKeys.has(key) || seen.has(key)) {\n        continue;\n      }\n      seen.add(key);\n      candidates.push({\n        text: question,\n        addedAtIteration: getRunNumber(record),\n        source: 'iteration-record',\n      });\n    }\n  }\n\n  return candidates.sort((left, right) =>\n    left.addedAtIteration - right.addedAtIteration || contentOrderKey(left.text).localeCompare(contentOrderKey(right.text)),\n  );\n}\n\nfunction formatCarriedForwardOpenQuestions(questions) {\n  if (!Array.isArray(questions) || questions.length === 0) {\n    return '[None yet]';\n  }\n\n  return questions\n    .map((question) => `- ${question.text} (iteration ${question.addedAtIteration || 0})`)\n    .join('\\n');\n}\n\nfunction deriveNextFocusFromContinuity({\n  iterationFiles = [],\n  iterationRecords = [],\n  carriedForwardOpenQuestions = [],\n  machineOpenQuestions = [],\n  terminalSentinel = DEFAULT_TERMINAL_NEXT_FOCUS,\n} = {}) {\n  const machineQuestions = toTextArray(machineOpenQuestions);\n  if (machineQuestions.length === 0) {\n    return terminalSentinel;\n  }\n\n  const latestThreadQuestion = getLatestByRun(carriedForwardOpenQuestions);\n  if (latestThreadQuestion?.text) {\n    return latestThreadQuestion.text;\n  }\n\n  const latestIteration = getLatestByRun(iterationFiles);\n  const latestFinding = Array.isArray(latestIteration?.findings)\n    ? latestIteration.findings.map(normalizeText).filter(Boolean).at(-1)\n    : null;\n  if (latestFinding) {\n    return `Follow up on: ${truncateFocus(latestFinding)}`;\n  }\n\n  const latestRecord = getLatestByRun(iterationRecords);\n  const latestRecordFinding = Array.isArray(latestRecord?.findings)\n    ? latestRecord.findings.map(textFromQuestion).filter(Boolean).at(-1)\n    : null;\n  if (latestRecordFinding) {\n    return `Follow up on: ${truncateFocus(latestRecordFinding)}`;\n  }\n\n  return machineQuestions[0] || terminalSentinel;\n}\n\nmodule.exports = {\n  buildCarriedForwardOpenQuestions,\n  deriveNextFocusFromContinuity,\n  formatCarriedForwardOpenQuestions,\n};","lineStart":1,"lineEnd":154,"totalLines":154,"truncated":false}},"title":".opencode/skills/system-deep-loop/runtime/lib/deep-loop/continuity-thread.cjs","time":{"start":1784619117970,"end":1784619117975}},"metadata":{"openai":{"itemId":"fc_021377aa6040d59b016a5f206cf0888191905ddf9ce707b29f"}},"id":"prt_f8396a9a70015nkLdQCybmT34r","sessionID":"ses_07c97d905ffee2yzbow793KIc8","messageID":"msg_f83968485001IjnyAC17KgaqcP"}}
