 logic can observe malformed raw tool arguments.\n1057:     const validatedArgs: Record<string, unknown> = KNOWN_TOOL_NAMES.has(name)\n1058:       ? validateToolArgs(name, args) as Record<string, unknown>\n1059:       : args;\n1060: \n1061:     // Track last tool call timestamp for all tools except session_health.\n1062:     if (name !== 'session_health') {\n1063:       recordToolCall(sessionTrackingId);\n1064: \n1065:       // Record metric event for context quality tracking\n1066:       recordMetricEvent({ kind: 'tool_call', toolName: name });\n1067:     }\n1068:     // Classify specific tool calls for finer-grained metrics\n1069:     if (name === 'memory_context' && validatedArgs.mode === 'resume') {\n1070:       recordMetricEvent({ kind: 'memory_recovery' });\n1071:     }\n1072:     // Code-graph MCP metrics now originate from standalone mk-code-index\n1073:     if (typeof validatedArgs.specFolder === 'string' && validatedArgs.specFolder) {\n1074:       recordMetricEvent({ kind: 'spec_folder_change', specFolder: validatedArgs.specFolder as string });\n1075:     }\n1076: \n1077:     const memoryRuntimeRequired = MEMORY_RUNTIME_TOOL_NAMES.has(name);\n1078:     if (memoryRuntimeRequired) {\n1079:       await ensureMemoryRuntimeInitialized(`handler:${name}`);\n1080:     }\n1081: \n1082:     const dbReinitialized = memoryRuntimeRequired\n1083:       ? await checkDatabaseUpdated()\n1084:       : false;\n1085:     if (dbReinitialized) {\n1086:       await invalidateReinitializedDbCaches();\n1087:     }\n1088: \n1089:     let sessionPrimeContext: AutoSurfaceResult | null = null;\n1090:     const memoryRuntimeAvailable = memoryRuntimeRequired || isMemoryRuntimeInitialized();\n1091:     if (memoryRuntimeAvailable) {\n1092:       try {\n1093:         sessionPrimeContext = await primeSessionIfNeeded(\n1094:           name,\n1095:           validatedArgs,\n1096:           sessionTrackingId,\n1097:         );\n1098:       } catch (primeErr: unknown) {\n1099:         const msg = primeErr instanceof Error ? primeErr.message : String(primeErr);\n1100:         console.error(`[context-server] Session priming failed (non-fatal): ${msg}`);\n1101:       }\n1102:     }\n1103: \n1104:     // SK-004: Auto-surface memories before dispatch (after validation)\n1105:     let autoSurfacedContext: AutoSurfaceResult | null = null;\n1106:     const isCompactionLifecycleCall =\n1107:       name === 'memory_context' && validatedArgs.mode === 'resume';\n1108: \n1109:     const autoSurfaceStart = Date.now();\n1110:     if (MEMORY_AWARE_TOOLS.has(name) && memoryRuntimeAvailable) {\n1111:       const contextHint: string | null = extractContextHint(validatedArgs);\n1112:       if (contextHint) {\n1113:         try {\n1114:           if (isCompactionLifecycleCall) {\n1115:             autoSurfacedContext = await autoSurfaceAtCompaction(contextHint);\n1116:           } else {\n1117:             autoSurfacedContext = await autoSurfaceMemories(contextHint);\n1118:           }\n1119:         } catch (surfaceErr: unknown) {\n1120:           const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n1121:           console.error(`[context-server] Auto-surface failed (non-fatal): ${msg}`);\n1122:         }\n1123:       }\n1124:     } else if (memoryRuntimeAvailable) {\n1125:       try {\n1126:         autoSurfacedContext = await autoSurfaceAtToolDispatch(name, validatedArgs);\n1127:       } catch (surfaceErr: unknown) {\n1128:         const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n1129:         console.error(`[context-server] Tool-dispatch auto-surface failed (non-fatal): ${msg}`);\n1130:       }\n1131:     }\n1132:     const autoSurfaceLatencyMs = Date.now() - autoSurfaceStart;\n1133:     if (autoSurfaceLatencyMs > 250) {\n1134:       console.warn(`[context-server] Auto-surface precheck exceeded p95 target: ${autoSurfaceLatencyMs}ms`);\n1135:     }\n1136: \n1137:     // Dispatch to tool modules\n1138:     const result = await runWithCallerContext(\n1139:       callerContext,\n1140:       async () => dispatchTool(name, validatedArgs, callerContext),\n1141:     ) as ToolCallResponse | null;\n1142:     if (!result) {\n1143:       throw new Error(`Unknown tool: ${name}`);\n1144:     }\n1145: \n1146:     let dispatchGraphContext: DispatchGraphContextMeta | null = null;\n1147:     if (!result.isError) {\n1148:       dispatchGraphContext = await resolveDispatchGraphContext(name, validatedArgs);\n1149:     }\n1150: \n1151:     runAfterToolCallbacks(name, callId, structuredClone(result));\n1152: \n1153:     // Log follow_on_tool_use when a non-search tool is called after a recent search\n1154:     // Shadow-only: no ranking side effects. Fail-safe, never throws.\n1155:     if (isMemoryRuntimeInitialized() && name !== 'memory_search' && name !== 'memory_context' && name !== 'session_health') {\n1156:       try {\n1157:         const { logFollowOnToolUse } = await import('./lib/feedback/query-flow-tracker.js');\n1158:         const { requireDb } = await import('./utils/index.js');\n1159:         const db = (() => { try { return requireDb(); } catch { return null; } })();\n1160:         const followOnSessionId = sessionTrackingId ?? lastKnownSessionId;\n1161:         if (db && followOnSessionId) {\n1162:           logFollowOnToolUse(db, followOnSessionId);\n1163:         }\n1164:       } catch { /* follow_on_tool_use logging must never break dispatch */ }\n1165:     }\n1166: \n1167:     // Code-search redirect hint for memory tools\n1168:     if ((name === 'memory_search' || name === 'memory_context') && result && !result.isError && result.content?.[0]?.text) {\n1169:       const queryStr = typeof args.query === 'string' ? args.query : typeof args.input === 'string' ? args.input : '';\n\n(Showing lines 1030-1169 of 2205. Use offset=1170 to continue.)\n</content>","metadata":{"preview":"   TOOL DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nfunction registerContextServerHandlers(targetServer: Server): void {\n  targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n    tools: TOOL_DEFINITIONS\n  }));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DISPATCH\n──────────────────────────────────────────────────────────────── */\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\n  targetServer.setRequestHandler(CallToolRequestSchema, async (request, _extra: unknown): Promise<any> => {\n  const requestParams = request.params as { name: string; arguments?: Record<string, unknown> };\n  const { name } = requestParams;\n  const args: Record<string, unknown> = requestParams.arguments ?? {};\n  const callId = resolveToolCallId(request as { id?: unknown });\n  const sessionTrackingId = resolveSessionTrackingId(args, _extra);\n  const callerContext = buildCallerContext(_extra);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"   TOOL DEFINITIONS\n──────────────────────────────────────────────────────────────── */\n\nfunction registerContextServerHandlers(targetServer: Server): void {\n  targetServer.setRequestHandler(ListToolsRequestSchema, async () => ({\n    tools: TOOL_DEFINITIONS\n  }));\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DISPATCH\n──────────────────────────────────────────────────────────────── */\n\n// eslint-disable-next-line @typescript-eslint/no-explicit-any\n  targetServer.setRequestHandler(CallToolRequestSchema, async (request, _extra: unknown): Promise<any> => {\n  const requestParams = request.params as { name: string; arguments?: Record<string, unknown> };\n  const { name } = requestParams;\n  const args: Record<string, unknown> = requestParams.arguments ?? {};\n  const callId = resolveToolCallId(request as { id?: unknown });\n  const sessionTrackingId = resolveSessionTrackingId(args, _extra);\n  const callerContext = buildCallerContext(_extra);\n  if (sessionTrackingId) lastKnownSessionId = sessionTrackingId;\n\n  try {\n    // SEC-003: Validate input lengths before processing (CWE-400 mitigation)\n    validateInputLengths(args);\n    // Validate at the server boundary before metrics, session priming, and\n    // auto-surface logic can observe malformed raw tool arguments.\n    const validatedArgs: Record<string, unknown> = KNOWN_TOOL_NAMES.has(name)\n      ? validateToolArgs(name, args) as Record<string, unknown>\n      : args;\n\n    // Track last tool call timestamp for all tools except session_health.\n    if (name !== 'session_health') {\n      recordToolCall(sessionTrackingId);\n\n      // Record metric event for context quality tracking\n      recordMetricEvent({ kind: 'tool_call', toolName: name });\n    }\n    // Classify specific tool calls for finer-grained metrics\n    if (name === 'memory_context' && validatedArgs.mode === 'resume') {\n      recordMetricEvent({ kind: 'memory_recovery' });\n    }\n    // Code-graph MCP metrics now originate from standalone mk-code-index\n    if (typeof validatedArgs.specFolder === 'string' && validatedArgs.specFolder) {\n      recordMetricEvent({ kind: 'spec_folder_change', specFolder: validatedArgs.specFolder as string });\n    }\n\n    const memoryRuntimeRequired = MEMORY_RUNTIME_TOOL_NAMES.has(name);\n    if (memoryRuntimeRequired) {\n      await ensureMemoryRuntimeInitialized(`handler:${name}`);\n    }\n\n    const dbReinitialized = memoryRuntimeRequired\n      ? await checkDatabaseUpdated()\n      : false;\n    if (dbReinitialized) {\n      await invalidateReinitializedDbCaches();\n    }\n\n    let sessionPrimeContext: AutoSurfaceResult | null = null;\n    const memoryRuntimeAvailable = memoryRuntimeRequired || isMemoryRuntimeInitialized();\n    if (memoryRuntimeAvailable) {\n      try {\n        sessionPrimeContext = await primeSessionIfNeeded(\n          name,\n          validatedArgs,\n          sessionTrackingId,\n        );\n      } catch (primeErr: unknown) {\n        const msg = primeErr instanceof Error ? primeErr.message : String(primeErr);\n        console.error(`[context-server] Session priming failed (non-fatal): ${msg}`);\n      }\n    }\n\n    // SK-004: Auto-surface memories before dispatch (after validation)\n    let autoSurfacedContext: AutoSurfaceResult | null = null;\n    const isCompactionLifecycleCall =\n      name === 'memory_context' && validatedArgs.mode === 'resume';\n\n    const autoSurfaceStart = Date.now();\n    if (MEMORY_AWARE_TOOLS.has(name) && memoryRuntimeAvailable) {\n      const contextHint: string | null = extractContextHint(validatedArgs);\n      if (contextHint) {\n        try {\n          if (isCompactionLifecycleCall) {\n            autoSurfacedContext = await autoSurfaceAtCompaction(contextHint);\n          } else {\n            autoSurfacedContext = await autoSurfaceMemories(contextHint);\n          }\n        } catch (surfaceErr: unknown) {\n          const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n          console.error(`[context-server] Auto-surface failed (non-fatal): ${msg}`);\n        }\n      }\n    } else if (memoryRuntimeAvailable) {\n      try {\n        autoSurfacedContext = await autoSurfaceAtToolDispatch(name, validatedArgs);\n      } catch (surfaceErr: unknown) {\n        const msg = surfaceErr instanceof Error ? surfaceErr.message : String(surfaceErr);\n        console.error(`[context-server] Tool-dispatch auto-surface failed (non-fatal): ${msg}`);\n      }\n    }\n    const autoSurfaceLatencyMs = Date.now() - autoSurfaceStart;\n    if (autoSurfaceLatencyMs > 250) {\n      console.warn(`[context-server] Auto-surface precheck exceeded p95 target: ${autoSurfaceLatencyMs}ms`);\n    }\n\n    // Dispatch to tool modules\n    const result = await runWithCallerContext(\n      callerContext,\n      async () => dispatchTool(name, validatedArgs, callerContext),\n    ) as ToolCallResponse | null;\n    if (!result) {\n      throw new Error(`Unknown tool: ${name}`);\n    }\n\n    let dispatchGraphContext: DispatchGraphContextMeta | null = null;\n    if (!result.isError) {\n      dispatchGraphContext = await resolveDispatchGraphContext(name, validatedArgs);\n    }\n\n    runAfterToolCallbacks(name, callId, structuredClone(result));\n\n    // Log follow_on_tool_use when a non-search tool is called after a recent search\n    // Shadow-only: no ranking side effects. Fail-safe, never throws.\n    if (isMemoryRuntimeInitialized() && name !== 'memory_search' && name !== 'memory_context' && name !== 'session_health') {\n      try {\n        const { logFollowOnToolUse } = await import('./lib/feedback/query-flow-tracker.js');\n        const { requireDb } = await import('./utils/index.js');\n        const db = (() => { try { return requireDb(); } catch { return null; } })();\n        const followOnSessionId = sessionTrackingId ?? lastKnownSessionId;\n        if (db && followOnSessionId) {\n          logFollowOnToolUse(db, followOnSessionId);\n        }\n      } catch { /* follow_on_tool_use logging must never break dispatch */ }\n    }\n\n    // Code-search redirect hint for memory tools\n    if ((name === 'memory_search' || name === 'memory_context') && result && !result.isError && result.content?.[0]?.text) {\n      const queryStr = typeof args.query === 'string' ? args.query : typeof args.input === 'string' ? args.input : '';","lineStart":1030,"lineEnd":1169,"totalLines":2205,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1780738312654,"end":1780738312660}},"metadata":{"openai":{"itemId":"fc_0d13bffc736b6061016a23e9084ab081919a5e918b7795d05c"}},"id":"prt_e9c4649cc001MvRkx3Oxs6ycEk","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c4620d1001Np54i4Id3LJzQR"}}
