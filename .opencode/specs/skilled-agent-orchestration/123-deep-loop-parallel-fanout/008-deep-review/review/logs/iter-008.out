deep-loop-runtime/scripts/lib/cli-guards.cjs\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/README.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/08--council/03-adjudicator-verdict-scoring.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/08--council/04-cost-guards.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/08--council/02-round-state-jsonl.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/08--council/01-multi-seat-dispatch.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/08--council/05-session-state-hierarchy.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/06--coverage-graph/02-coverage-graph-query.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/06--coverage-graph/01-coverage-graph-db.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/06--coverage-graph/03-coverage-graph-signals.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/01--executor/03-fallback-router.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/01--executor/02-executor-audit.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_catalog/01--executor/01-executor-config.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/feature_ca