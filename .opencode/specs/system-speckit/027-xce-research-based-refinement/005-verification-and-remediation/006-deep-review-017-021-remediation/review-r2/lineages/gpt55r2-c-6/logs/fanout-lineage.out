{"type":"text","timestamp":1781763114343,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"id":"prt_ed95b6dcc001X2q9InAaCzh7ml","messageID":"msg_ed95b5aba001hQutA9bBaBQJ5v","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","type":"text","text":"The launcher bridge/proxy live under `.opencode/bin/lib`, not the skill package; I’m including them because the scope explicitly includes daemon-backed CLI IPC.","time":{"start":1781763108300,"end":1781763114340},"metadata":{"openai":{"itemId":"msg_0ab8fbf40fc27ea4016a338c24427c819181cb6ea208cfa085","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781763114428,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"read","callID":"call_CrrWVyA7t4hObMcwdA0071jx","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","offset":1,"limit":2600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: IPC Socket Server (multi-client launcher bridge)\n3: // ───────────────────────────────────────────────────────────────\n4: // Canonical bridge logic shared by every daemon launcher (memory,\n5: // code-index, skill-advisor). Each service supplies its own socket/db\n6: // PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n7: // and race-safety contract stays identical across services.\n8: \n9: import fs from 'node:fs';\n10: import net from 'node:net';\n11: import os from 'node:os';\n12: import path from 'node:path';\n13: \n14: import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n15: \n16: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n17: // Every live session's launcher holds one persistent slot, and multi-seat\n18: // fan-outs run well past 8 concurrent sessions. A refused connection is\n19: // accepted then closed, which probes cannot distinguish from a dead daemon,\n20: // so the cap must exceed any realistic session fleet.\n21: const DEFAULT_MAX_SECONDARY_CLIENTS = 64;\n22: const TCP_EADDRINUSE_RETRY_DELAYS_MS = [100, 250, 500, 1000, 1500] as const;\n23: \n24: interface IpcBridgeStats {\n25:   socket_path: string | null;\n26:   secondary_clients_count: number;\n27:   total_secondary_messages_in: number;\n28:   total_secondary_messages_out: number;\n29: }\n30: \n31: // Structural shape of the only MCP server capability this bridge uses. Typed structurally (a\n32: // method, so its transport param is bivariant) rather than against a concrete `Server` import so\n33: // every consuming package satisfies it with its own `@modelcontextprotocol/sdk` copy — the three\n34: // daemons each install the SDK separately and its private members make the classes nominally\n35: // distinct, which a concrete import would reject across package boundaries.\n36: interface McpServerLike {\n37:   connect(transport: StdioServerTransport): Promise<void>;\n38: }\n39: \n40: interface IpcSocketServerOptions {\n41:   readonly socketPath: string;\n42:   readonly createServer: () => McpServerLike;\n43:   readonly maxClients?: number;\n44:   readonly log?: (message: string) => void;\n45:   readonly onActivity?: () => void;\n46: }\n47: \n48: interface IpcSocketServerHandle {\n49:   readonly socketPath: string;\n50:   readonly close: () => Promise<void>;\n51: }\n52: \n53: let activeServer: net.Server | null = null;\n54: let activeSocketPath: string | null = null;\n55: const activeSockets = new Set<net.Socket>();\n56: const activeTransports = new Map<net.Socket, StdioServerTransport>();\n57: let totalSecondaryMessagesIn = 0;\n58: let totalSecondaryMessagesOut = 0;\n59: \n60: function countJsonRpcFrames(chunk: unknown): number {\n61:   const text = Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n62:   const newlineCount = text.split('\\n').length - 1;\n63:   return Math.max(1, newlineCount);\n64: }\n65: \n66: // Window for a connection refused at the client cap to identify itself as a\n67: // liveness probe by sending its first JSON-RPC frame. Kept short so a non-probe\n68: // (real bridge client) is refused promptly, and bounded so probe traffic cannot\n69: // accumulate durable resources above the cap.\n70: const PROBE_AT_CAP_WINDOW_MS = 1000;\n71: \n72: // When at the durable client cap, peek the first frame. A liveness probe sends a\n73: // JSON-RPC `initialize` with clientInfo.name === 'liveness-probe' and treats ANY\n74: // reply carrying its id (result OR error) as proof the daemon is alive. Answer it\n75: // with a matching-id JSON-RPC error and close, without ever adding it to\n76: // activeSockets — so transient probe bursts can never exhaust the cap that exists\n77: // for durable bridge sessions. A non-probe first frame is refused like before.\n78: function answerProbeOrRefuseAtCap(\n79:   socket: net.Socket,\n80:   maxClients: number,\n81:   log: (message: string) => void,\n82: ): void {\n83:   let settled = false;\n84:   let buffer = '';\n85:   const finish = (refusedReason: string) => {\n86:     if (settled) return;\n87:     settled = true;\n88:     clearTimeout(timer);\n89:     log(`[ipc-bridge] refusing secondary connection: max clients ${maxClients} reached${refusedReason}`);\n90:     socket.end();\n91:     socket.destroy();\n92:   };\n93:   const timer = setTimeout(() => finish(' (no probe frame)'), PROBE_AT_CAP_WINDOW_MS);\n94:   timer.unref?.();\n95:   socket.on('error', () => finish(' (socket error)'));\n96:   socket.on('data', (chunk: Buffer | string) => {\n97:     if (settled) return;\n98:     buffer += Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n99:     let newlineIndex = buffer.indexOf('\\n');\n100:     while (newlineIndex !== -1) {\n101:       const line = buffer.slice(0, newlineIndex).trim();\n102:       buffer = buffer.slice(newlineIndex + 1);\n103:       newlineIndex = buffer.indexOf('\\n');\n104:       if (!line) continue;\n105:       let parsed: unknown;\n106:       try {\n107:         parsed = JSON.parse(line);\n108:       } catch {\n109:         finish(' (non-json frame at cap)');\n110:         return;\n111:       }\n112:       const frame = parsed as { id?: unknown; method?: unknown; params?: { clientInfo?: { name?: unknown } } };\n113:       const isProbe = frame\n114:         && frame.method === 'initialize'\n115:         && frame.params?.clientInfo?.name === 'liveness-probe';\n116:       if (isProbe) {\n117:         settled = true;\n118:         clearTimeout(timer);\n119:         const reply = `${JSON.stringify({\n120:           jsonrpc: '2.0',\n121:           id: frame.id ?? null,\n122:           error: { code: -32000, message: 'daemon at client capacity; liveness probe acknowledged' },\n123:         })}\\n`;\n124:         socket.end(reply);\n125:         log('[ipc-bridge] answered liveness probe at client cap without occupying a durable slot');\n126:         return;\n127:       }\n128:       finish(' (non-probe frame at cap)');\n129:       return;\n130:     }\n131:   });\n132: }\n133: \n134: function parseMaxClients(rawValue = process.env.SPECKIT_MAX_SECONDARY_CLIENTS): number {\n135:   if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') {\n136:     return DEFAULT_MAX_SECONDARY_CLIENTS;\n137:   }\n138:   const parsed = Number.parseInt(String(rawValue), 10);\n139:   if (!Number.isFinite(parsed) || parsed < 1) {\n140:     return DEFAULT_MAX_SECONDARY_CLIENTS;\n141:   }\n142:   return parsed;\n143: }\n144: \n145: function sleep(ms: number): Promise<void> {\n146:   return new Promise((resolve) => setTimeout(resolve, ms));\n147: }\n148: \n149: // Canonicalize a path via realpath, even when the leaf does not exist yet. realpath the nearest\n150: // existing ancestor (so symlinked roots like macOS `/tmp` -> `/private/tmp` normalize) and\n151: // re-append the missing tail. Without ancestor canonicalization, a socket dir that was cleared\n152: // (e.g. `/tmp/<service>` after a reboot) stays literal `/tmp/...` and fails the allowed-root\n153: // check below — which canonicalizes `/tmp` to `/private/tmp` — crashing the server.\n154: // Fail closed: an existing ancestor that cannot be canonicalized (permission/loop error) must\n155: // abort rather than return a non-canonical path, which would weaken the allowed-root containment\n156: // check that downstream binds rely on.\n157: function canonicalizePath(target: string): string {\n158:   const resolved = path.resolve(target);\n159:   const tail: string[] = [];\n160:   let current = resolved;\n161:   while (!fs.existsSync(current)) {\n162:     const parent = path.dirname(current);\n163:     if (parent === current) {\n164:       return resolved;\n165:     }\n166:     tail.unshift(path.basename(current));\n167:     current = parent;\n168:   }\n169:   return path.join(fs.realpathSync.native(current), ...tail);\n170: }\n171: \n172: // Prefix-match containment: true iff `candidate` is `root` itself or a descendant of it.\n173: // Both inputs MUST already be canonicalized. Inlined here so the shared bridge carries no\n174: // cross-module dependency for a single containment call.\n175: function isWithinRoot(root: string, candidate: string): boolean {\n176:   if (candidate === root) {\n177:     return true;\n178:   }\n179:   const prefix = root.endsWith(path.sep) ? root : `${root}${path.sep}`;\n180:   return candidate.startsWith(prefix);\n181: }\n182: \n183: // Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n184: // The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n185: // `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n186: // `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n187: // the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n188: // `canUnlinkExistingSocket` preserves the unlink-hardening intent.\n189: function allowedSocketRoots(): string[] {\n190:   const roots = new Set<string>();\n191:   roots.add(canonicalizePath(process.cwd()));\n192:   roots.add(canonicalizePath(os.tmpdir()));\n193:   roots.add(canonicalizePath('/tmp'));\n194:   return [...roots];\n195: }\n196: \n197: function isWithinAllowedSocketRoot(candidate: string): boolean {\n198:   return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n199: }\n200: \n201: function resolveIpcSocketPath(dbDir: string): string {\n202:   const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n203:     ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n204:     : path.resolve(dbDir);\n205:   const socketDir = canonicalizePath(rawSocketDir);\n206:   if (!isWithinAllowedSocketRoot(socketDir)) {\n207:     throw new Error(\n208:       `IPC socket directory must stay within the workspace root or a system temp dir: ${socketDir}`,\n209:     );\n210:   }\n211:   return path.join(socketDir, SOCKET_FILE_NAME);\n212: }\n213: \n214: // Only remove a stale socket at `socketPath` when it is provably ours: the parent dir resolves\n215: // inside an allowed root, the path is an actual socket, and it is owned by the current uid.\n216: // Guards against socket-hijack on shared hosts where an attacker plants a non-socket file or a\n217: // socket they own at the bind path.\n218: function canUnlinkExistingSocket(socketPath: string): boolean {\n219:   let parent: string;\n220:   try {\n221:     parent = fs.realpathSync.native(path.dirname(socketPath));\n222:   } catch (error: unknown) {\n223:     // A racing peer can remove the socket directory between the EADDRINUSE failure and this\n224:     // resolve; a vanished node is safe to reclaim, so never abort the bind on a missing path.\n225:     if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n226:       return true;\n227:     }\n228:     throw error;\n229:   }\n230:   if (!isWithinAllowedSocketRoot(parent)) {\n231:     return false;\n232:   }\n233:   try {\n234:     const stat = fs.lstatSync(socketPath);\n235:     if (!stat.isSocket()) {\n236:       return false;\n237:     }\n238:     if (typeof process.getuid === 'function' && stat.uid !== process.getuid()) {\n239:       return false;\n240:     }\n241:     return true;\n242:   } catch (error: unknown) {\n243:     // Same race on the socket node itself: if it is already gone the prior EADDRINUSE was\n244:     // transient, so treat the path as reclaimable instead of throwing and orphaning the bind.\n245:     if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n246:       return true;\n247:     }\n248:     throw error;\n249:   }\n250: }\n251: \n252: function getIpcBridgeStats(): IpcBridgeStats {\n253:   return {\n254:     socket_path: activeSocketPath,\n255:     secondary_clients_count: activeSockets.size,\n256:     total_secondary_messages_in: totalSecondaryMessagesIn,\n257:     total_secondary_messages_out: totalSecondaryMessagesOut,\n258:   };\n259: }\n260: \n261: async function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n262:   await new Promise<void>((resolve, reject) => {\n263:     const onError = (error: NodeJS.ErrnoException) => {\n264:       server.off('listening', onListening);\n265:       reject(error);\n266:     };\n267:     const onListening = () => {\n268:       server.off('error', onError);\n269:       resolve();\n270:     };\n271:     server.once('error', onError);\n272:     server.once('listening', onListening);\n273:     if (socketPath.startsWith('tcp://')) {\n274:       const url = new URL(socketPath);\n275:       server.listen(Number.parseInt(url.port, 10), url.hostname);\n276:       return;\n277:     }\n278:     server.listen(socketPath);\n279:   });\n280: }\n281: \n282: // TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n283: // unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n284: // few times before giving up. Returns true once a retry binds, false if the port stays in use.\n285: async function retryTcpListenAfterEaddrInUse(\n286:   server: net.Server,\n287:   socketPath: string,\n288:   log: (message: string) => void,\n289: ): Promise<boolean> {\n290:   for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n291:     log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n292:     await sleep(delayMs);\n293:     try {\n294:       await listenOnce(server, socketPath);\n295:       return true;\n296:     } catch (error: unknown) {\n297:       const err = error as NodeJS.ErrnoException;\n298:       if (err.code !== 'EADDRINUSE') {\n299:         throw err;\n300:       }\n301:     }\n302:   }\n303:   return false;\n304: }\n305: \n306: // Tear down any server still registered in the module-global slots before a new bind reuses them.\n307: // startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n308: // dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n309: // shared stats. Re-entrancy must close the prior server first.\n310: async function disposeActiveServer(): Promise<void> {\n311:   const priorServer = activeServer;\n312:   for (const socket of activeSockets) {\n313:     socket.destroy();\n314:   }\n315:   activeSockets.clear();\n316:   activeTransports.clear();\n317:   if (priorServer) {\n318:     await new Promise<void>((resolve) => {\n319:       priorServer.close(() => resolve());\n320:     });\n321:   }\n322:   activeServer = null;\n323:   activeSocketPath = null;\n324: }\n325: \n326: async function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n327:   if (activeServer) {\n328:     await disposeActiveServer();\n329:   }\n330:   const socketPath = options.socketPath.startsWith('tcp://')\n331:     ? options.socketPath\n332:     : path.resolve(options.socketPath);\n333:   const log = options.log ?? ((message: string) => console.error(message));\n334:   const maxClients = options.maxClients ?? parseMaxClients();\n335:   const onActivity = options.onActivity ?? (() => undefined);\n336:   if (!socketPath.startsWith('tcp://')) {\n337:     const socketDir = path.dirname(socketPath);\n338:     fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n339:     // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n340:     // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n341:     // so refuse to bind under a dir not owned by us or that is group/world-writable.\n342:     try {\n343:       const st = fs.statSync(socketDir);\n344:       const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n345:       if (uid !== null && st.uid !== uid) {\n346:         throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n347:       }\n348:       if ((st.mode & 0o022) !== 0) {\n349:         throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n350:       }\n351:     } catch (error: unknown) {\n352:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n353:       if (code !== 'ENOENT') throw error;\n354:     }\n355:     // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n356:     // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n357:     // protection so a symlink whose target we would later chmod cannot be used to redirect the\n358:     // permission change onto an arbitrary file.\n359:     try {\n360:       const linkStat = fs.lstatSync(socketPath);\n361:       if (linkStat.isSymbolicLink()) {\n362:         throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n363:       }\n364:     } catch (error: unknown) {\n365:       const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n366:       if (code !== 'ENOENT') throw error;\n367:     }\n368:   }\n369: \n370:   const server = net.createServer((socket) => {\n371:     if (activeSockets.size >= maxClients) {\n372:       // A bare close here is indistinguishable from a dead daemon to a liveness\n373:       // probe, which makes a sibling launcher reap a healthy-but-cap-saturated\n374:       // daemon. Give the connection a brief window to send its first frame: if it\n375:       // is a liveness probe, answer it (proving the daemon alive) and close WITHOUT\n376:       // occupying a durable slot; only refuse genuine bridge clients at the cap.\n377:       answerProbeOrRefuseAtCap(socket, maxClients, log);\n378:       return;\n379:     }\n380: \n381:     activeSockets.add(socket);\n382:     onActivity();\n383:     log('[ipc-bridge] secondary connected pid=?');\n384: \n385:     const originalWrite = socket.write.bind(socket);\n386:     socket.write = ((chunk: unknown, ...args: unknown[]) => {\n387:       onActivity();\n388:       totalSecondaryMessagesOut += countJsonRpcFrames(chunk);\n389:       return originalWrite(chunk as string | Uint8Array, ...(args as [BufferEncoding?, (() => void)?]));\n390:     }) as typeof socket.write;\n391: \n392:     socket.on('data', (chunk) => {\n393:       onActivity();\n394:       totalSecondaryMessagesIn += countJsonRpcFrames(chunk);\n395:     });\n396: \n397:     const transport = new StdioServerTransport(socket, socket);\n398:     activeTransports.set(socket, transport);\n399:     const secondaryServer = options.createServer();\n400:     secondaryServer.connect(transport).catch((error: unknown) => {\n401:       const message = error instanceof Error ? error.message : String(error);\n402:       log(`[ipc-bridge] secondary connect error: ${message}`);\n403:       socket.destroy();\n404:     });\n405: \n406:     socket.once('close', () => {\n407:       activeSockets.delete(socket);\n408:       activeTransports.delete(socket);\n409:       void transport.close();\n410:       log('[ipc-bridge] disconnect');\n411:     });\n412:     socket.once('error', (error) => {\n413:       log(`[ipc-bridge] socket error: ${error.message}`);\n414:     });\n415:   });\n416: \n417:   try {\n418:     await listenOnce(server, socketPath);\n419:   } catch (error: unknown) {\n420:     const err = error as NodeJS.ErrnoException;\n421:     if (err.code !== 'EADDRINUSE') {\n422:       throw err;\n423:     }\n424:     if (socketPath.startsWith('tcp://')) {\n425:       // A TCP port in use cannot be reclaimed by unlinking; back off and retry a few times. If it\n426:       // never frees, run without the secondary bridge rather than aborting the whole daemon.\n427:       const listened = await retryTcpListenAfterEaddrInUse(server, socketPath, log);\n428:       if (!listened) {\n429:         log(`[ipc-bridge] tcp socket remained in use at ${socketPath}; secondary bridge disabled`);\n430:         return {\n431:           socketPath,\n432:           close: async () => {\n433:             for (const socket of activeSockets) {\n434:               socket.destroy();\n435:             }\n436:             activeSockets.clear();\n437:             activeTransports.clear();\n438:           },\n439:         };\n440:       }\n441:     } else {\n442:       // Unix socket path: only reclaim a stale node that is provably ours (the fence). On a benign\n443:       // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n444:       // as reclaimable, so we re-bind instead of aborting; a foreign-owned node still refuses.\n445:       if (!canUnlinkExistingSocket(socketPath)) {\n446:         throw err;\n447:       }\n448:       try {\n449:         fs.unlinkSync(socketPath);\n450:       } catch (unlinkError: unknown) {\n451:         const unlinkErr = unlinkError as NodeJS.ErrnoException;\n452:         if (unlinkErr.code !== 'ENOENT') {\n453:           throw unlinkErr;\n454:         }\n455:       }\n456:       await listenOnce(server, socketPath);\n457:     }\n458:   }\n459: \n460:   const address = server.address();\n461:   const listenedPath = typeof address === 'object' && address\n462:     ? `tcp://${address.address}:${address.port}`\n463:     : socketPath;\n464:   if (!socketPath.startsWith('tcp://')) {\n465:     // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n466:     // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n467:     const boundStat = fs.lstatSync(socketPath);\n468:     if (boundStat.isSymbolicLink() || !boundStat.isSocket()) {\n469:       throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n470:     }\n471:     fs.chmodSync(socketPath, 0o600);\n472:   }\n473:   activeServer = server;\n474:   activeSocketPath = listenedPath;\n475:   log(`[ipc-bridge] socket listening at ${listenedPath}`);\n476: \n477:   return {\n478:     socketPath: listenedPath,\n479:     close: async () => {\n480:       for (const socket of activeSockets) {\n481:         socket.destroy();\n482:       }\n483:       activeSockets.clear();\n484:       activeTransports.clear();\n485:       await new Promise<void>((resolve) => {\n486:         server.close(() => resolve());\n487:       });\n488:       if (activeServer === server) {\n489:         activeServer = null;\n490:         activeSocketPath = null;\n491:       }\n492:       if (!socketPath.startsWith('tcp://')) {\n493:         try {\n494:           fs.unlinkSync(socketPath);\n495:         } catch (error: unknown) {\n496:           const err = error as NodeJS.ErrnoException;\n497:           if (err.code !== 'ENOENT') {\n498:             throw err;\n499:           }\n500:         }\n501:       }\n502:     },\n503:   };\n504: }\n505: \n506: export {\n507:   canUnlinkExistingSocket,\n508:   getIpcBridgeStats,\n509:   parseMaxClients,\n510:   resolveIpcSocketPath,\n511:   startIpcSocketServer,\n512: };\n513: \n514: export type {\n515:   IpcBridgeStats,\n516:   IpcSocketServerHandle,\n517:   IpcSocketServerOptions,\n518: };\n\n(End of file - total 518 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Canonical bridge logic shared by every daemon launcher (memory,\n// code-index, skill-advisor). Each service supplies its own socket/db\n// PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n// and race-safety contract stays identical across services.\n\nimport fs from 'node:fs';\nimport net from 'node:net';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\n// Every live session's launcher holds one persistent slot, and multi-seat\n// fan-outs run well past 8 concurrent sessions. A refused connection is\n// accepted then closed, which probes cannot distinguish from a dead daemon,\n// so the cap must exceed any realistic session fleet.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: IPC Socket Server (multi-client launcher bridge)\n// ───────────────────────────────────────────────────────────────\n// Canonical bridge logic shared by every daemon launcher (memory,\n// code-index, skill-advisor). Each service supplies its own socket/db\n// PATHS; only the bind/reclaim/serve LOGIC lives here so the security\n// and race-safety contract stays identical across services.\n\nimport fs from 'node:fs';\nimport net from 'node:net';\nimport os from 'node:os';\nimport path from 'node:path';\n\nimport { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';\n\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\n// Every live session's launcher holds one persistent slot, and multi-seat\n// fan-outs run well past 8 concurrent sessions. A refused connection is\n// accepted then closed, which probes cannot distinguish from a dead daemon,\n// so the cap must exceed any realistic session fleet.\nconst DEFAULT_MAX_SECONDARY_CLIENTS = 64;\nconst TCP_EADDRINUSE_RETRY_DELAYS_MS = [100, 250, 500, 1000, 1500] as const;\n\ninterface IpcBridgeStats {\n  socket_path: string | null;\n  secondary_clients_count: number;\n  total_secondary_messages_in: number;\n  total_secondary_messages_out: number;\n}\n\n// Structural shape of the only MCP server capability this bridge uses. Typed structurally (a\n// method, so its transport param is bivariant) rather than against a concrete `Server` import so\n// every consuming package satisfies it with its own `@modelcontextprotocol/sdk` copy — the three\n// daemons each install the SDK separately and its private members make the classes nominally\n// distinct, which a concrete import would reject across package boundaries.\ninterface McpServerLike {\n  connect(transport: StdioServerTransport): Promise<void>;\n}\n\ninterface IpcSocketServerOptions {\n  readonly socketPath: string;\n  readonly createServer: () => McpServerLike;\n  readonly maxClients?: number;\n  readonly log?: (message: string) => void;\n  readonly onActivity?: () => void;\n}\n\ninterface IpcSocketServerHandle {\n  readonly socketPath: string;\n  readonly close: () => Promise<void>;\n}\n\nlet activeServer: net.Server | null = null;\nlet activeSocketPath: string | null = null;\nconst activeSockets = new Set<net.Socket>();\nconst activeTransports = new Map<net.Socket, StdioServerTransport>();\nlet totalSecondaryMessagesIn = 0;\nlet totalSecondaryMessagesOut = 0;\n\nfunction countJsonRpcFrames(chunk: unknown): number {\n  const text = Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n  const newlineCount = text.split('\\n').length - 1;\n  return Math.max(1, newlineCount);\n}\n\n// Window for a connection refused at the client cap to identify itself as a\n// liveness probe by sending its first JSON-RPC frame. Kept short so a non-probe\n// (real bridge client) is refused promptly, and bounded so probe traffic cannot\n// accumulate durable resources above the cap.\nconst PROBE_AT_CAP_WINDOW_MS = 1000;\n\n// When at the durable client cap, peek the first frame. A liveness probe sends a\n// JSON-RPC `initialize` with clientInfo.name === 'liveness-probe' and treats ANY\n// reply carrying its id (result OR error) as proof the daemon is alive. Answer it\n// with a matching-id JSON-RPC error and close, without ever adding it to\n// activeSockets — so transient probe bursts can never exhaust the cap that exists\n// for durable bridge sessions. A non-probe first frame is refused like before.\nfunction answerProbeOrRefuseAtCap(\n  socket: net.Socket,\n  maxClients: number,\n  log: (message: string) => void,\n): void {\n  let settled = false;\n  let buffer = '';\n  const finish = (refusedReason: string) => {\n    if (settled) return;\n    settled = true;\n    clearTimeout(timer);\n    log(`[ipc-bridge] refusing secondary connection: max clients ${maxClients} reached${refusedReason}`);\n    socket.end();\n    socket.destroy();\n  };\n  const timer = setTimeout(() => finish(' (no probe frame)'), PROBE_AT_CAP_WINDOW_MS);\n  timer.unref?.();\n  socket.on('error', () => finish(' (socket error)'));\n  socket.on('data', (chunk: Buffer | string) => {\n    if (settled) return;\n    buffer += Buffer.isBuffer(chunk) ? chunk.toString('utf8') : String(chunk ?? '');\n    let newlineIndex = buffer.indexOf('\\n');\n    while (newlineIndex !== -1) {\n      const line = buffer.slice(0, newlineIndex).trim();\n      buffer = buffer.slice(newlineIndex + 1);\n      newlineIndex = buffer.indexOf('\\n');\n      if (!line) continue;\n      let parsed: unknown;\n      try {\n        parsed = JSON.parse(line);\n      } catch {\n        finish(' (non-json frame at cap)');\n        return;\n      }\n      const frame = parsed as { id?: unknown; method?: unknown; params?: { clientInfo?: { name?: unknown } } };\n      const isProbe = frame\n        && frame.method === 'initialize'\n        && frame.params?.clientInfo?.name === 'liveness-probe';\n      if (isProbe) {\n        settled = true;\n        clearTimeout(timer);\n        const reply = `${JSON.stringify({\n          jsonrpc: '2.0',\n          id: frame.id ?? null,\n          error: { code: -32000, message: 'daemon at client capacity; liveness probe acknowledged' },\n        })}\\n`;\n        socket.end(reply);\n        log('[ipc-bridge] answered liveness probe at client cap without occupying a durable slot');\n        return;\n      }\n      finish(' (non-probe frame at cap)');\n      return;\n    }\n  });\n}\n\nfunction parseMaxClients(rawValue = process.env.SPECKIT_MAX_SECONDARY_CLIENTS): number {\n  if (rawValue === undefined || rawValue === null || String(rawValue).trim() === '') {\n    return DEFAULT_MAX_SECONDARY_CLIENTS;\n  }\n  const parsed = Number.parseInt(String(rawValue), 10);\n  if (!Number.isFinite(parsed) || parsed < 1) {\n    return DEFAULT_MAX_SECONDARY_CLIENTS;\n  }\n  return parsed;\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\n// Canonicalize a path via realpath, even when the leaf does not exist yet. realpath the nearest\n// existing ancestor (so symlinked roots like macOS `/tmp` -> `/private/tmp` normalize) and\n// re-append the missing tail. Without ancestor canonicalization, a socket dir that was cleared\n// (e.g. `/tmp/<service>` after a reboot) stays literal `/tmp/...` and fails the allowed-root\n// check below — which canonicalizes `/tmp` to `/private/tmp` — crashing the server.\n// Fail closed: an existing ancestor that cannot be canonicalized (permission/loop error) must\n// abort rather than return a non-canonical path, which would weaken the allowed-root containment\n// check that downstream binds rely on.\nfunction canonicalizePath(target: string): string {\n  const resolved = path.resolve(target);\n  const tail: string[] = [];\n  let current = resolved;\n  while (!fs.existsSync(current)) {\n    const parent = path.dirname(current);\n    if (parent === current) {\n      return resolved;\n    }\n    tail.unshift(path.basename(current));\n    current = parent;\n  }\n  return path.join(fs.realpathSync.native(current), ...tail);\n}\n\n// Prefix-match containment: true iff `candidate` is `root` itself or a descendant of it.\n// Both inputs MUST already be canonicalized. Inlined here so the shared bridge carries no\n// cross-module dependency for a single containment call.\nfunction isWithinRoot(root: string, candidate: string): boolean {\n  if (candidate === root) {\n    return true;\n  }\n  const prefix = root.endsWith(path.sep) ? root : `${root}${path.sep}`;\n  return candidate.startsWith(prefix);\n}\n\n// Allowed roots for the IPC socket directory: the workspace itself plus the system temp dirs.\n// The macOS `sun_path` limit (104 chars) forces deep in-workspace socket paths into a short\n// `/tmp` path, so a workspace-only constraint is incompatible with the documented config.\n// `os.tmpdir()` is portable (Linux/CI; macOS resolves to `/var/folders/...`), and `/tmp` covers\n// the project convention (`SPECKIT_IPC_SOCKET_DIR=/tmp/<service>`). The owner check in\n// `canUnlinkExistingSocket` preserves the unlink-hardening intent.\nfunction allowedSocketRoots(): string[] {\n  const roots = new Set<string>();\n  roots.add(canonicalizePath(process.cwd()));\n  roots.add(canonicalizePath(os.tmpdir()));\n  roots.add(canonicalizePath('/tmp'));\n  return [...roots];\n}\n\nfunction isWithinAllowedSocketRoot(candidate: string): boolean {\n  return allowedSocketRoots().some((root) => isWithinRoot(root, candidate));\n}\n\nfunction resolveIpcSocketPath(dbDir: string): string {\n  const rawSocketDir = process.env.SPECKIT_IPC_SOCKET_DIR\n    ? path.resolve(process.env.SPECKIT_IPC_SOCKET_DIR)\n    : path.resolve(dbDir);\n  const socketDir = canonicalizePath(rawSocketDir);\n  if (!isWithinAllowedSocketRoot(socketDir)) {\n    throw new Error(\n      `IPC socket directory must stay within the workspace root or a system temp dir: ${socketDir}`,\n    );\n  }\n  return path.join(socketDir, SOCKET_FILE_NAME);\n}\n\n// Only remove a stale socket at `socketPath` when it is provably ours: the parent dir resolves\n// inside an allowed root, the path is an actual socket, and it is owned by the current uid.\n// Guards against socket-hijack on shared hosts where an attacker plants a non-socket file or a\n// socket they own at the bind path.\nfunction canUnlinkExistingSocket(socketPath: string): boolean {\n  let parent: string;\n  try {\n    parent = fs.realpathSync.native(path.dirname(socketPath));\n  } catch (error: unknown) {\n    // A racing peer can remove the socket directory between the EADDRINUSE failure and this\n    // resolve; a vanished node is safe to reclaim, so never abort the bind on a missing path.\n    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n      return true;\n    }\n    throw error;\n  }\n  if (!isWithinAllowedSocketRoot(parent)) {\n    return false;\n  }\n  try {\n    const stat = fs.lstatSync(socketPath);\n    if (!stat.isSocket()) {\n      return false;\n    }\n    if (typeof process.getuid === 'function' && stat.uid !== process.getuid()) {\n      return false;\n    }\n    return true;\n  } catch (error: unknown) {\n    // Same race on the socket node itself: if it is already gone the prior EADDRINUSE was\n    // transient, so treat the path as reclaimable instead of throwing and orphaning the bind.\n    if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n      return true;\n    }\n    throw error;\n  }\n}\n\nfunction getIpcBridgeStats(): IpcBridgeStats {\n  return {\n    socket_path: activeSocketPath,\n    secondary_clients_count: activeSockets.size,\n    total_secondary_messages_in: totalSecondaryMessagesIn,\n    total_secondary_messages_out: totalSecondaryMessagesOut,\n  };\n}\n\nasync function listenOnce(server: net.Server, socketPath: string): Promise<void> {\n  await new Promise<void>((resolve, reject) => {\n    const onError = (error: NodeJS.ErrnoException) => {\n      server.off('listening', onListening);\n      reject(error);\n    };\n    const onListening = () => {\n      server.off('error', onError);\n      resolve();\n    };\n    server.once('error', onError);\n    server.once('listening', onListening);\n    if (socketPath.startsWith('tcp://')) {\n      const url = new URL(socketPath);\n      server.listen(Number.parseInt(url.port, 10), url.hostname);\n      return;\n    }\n    server.listen(socketPath);\n  });\n}\n\n// TCP fallback (used when a unix socket path exceeds the sun_path limit) cannot be reclaimed by\n// unlinking a node — a stale TCP port frees itself once the prior owner exits, so retry the bind a\n// few times before giving up. Returns true once a retry binds, false if the port stays in use.\nasync function retryTcpListenAfterEaddrInUse(\n  server: net.Server,\n  socketPath: string,\n  log: (message: string) => void,\n): Promise<boolean> {\n  for (const delayMs of TCP_EADDRINUSE_RETRY_DELAYS_MS) {\n    log(`[ipc-bridge] tcp socket in use at ${socketPath}; retrying listen in ${delayMs}ms`);\n    await sleep(delayMs);\n    try {\n      await listenOnce(server, socketPath);\n      return true;\n    } catch (error: unknown) {\n      const err = error as NodeJS.ErrnoException;\n      if (err.code !== 'EADDRINUSE') {\n        throw err;\n      }\n    }\n  }\n  return false;\n}\n\n// Tear down any server still registered in the module-global slots before a new bind reuses them.\n// startIpcSocketServer tracks its server/sockets in module globals, so a second start without a\n// dispose would orphan the prior listener (leaking the socket and its clients) and corrupt the\n// shared stats. Re-entrancy must close the prior server first.\nasync function disposeActiveServer(): Promise<void> {\n  const priorServer = activeServer;\n  for (const socket of activeSockets) {\n    socket.destroy();\n  }\n  activeSockets.clear();\n  activeTransports.clear();\n  if (priorServer) {\n    await new Promise<void>((resolve) => {\n      priorServer.close(() => resolve());\n    });\n  }\n  activeServer = null;\n  activeSocketPath = null;\n}\n\nasync function startIpcSocketServer(options: IpcSocketServerOptions): Promise<IpcSocketServerHandle> {\n  if (activeServer) {\n    await disposeActiveServer();\n  }\n  const socketPath = options.socketPath.startsWith('tcp://')\n    ? options.socketPath\n    : path.resolve(options.socketPath);\n  const log = options.log ?? ((message: string) => console.error(message));\n  const maxClients = options.maxClients ?? parseMaxClients();\n  const onActivity = options.onActivity ?? (() => undefined);\n  if (!socketPath.startsWith('tcp://')) {\n    const socketDir = path.dirname(socketPath);\n    fs.mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n    // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n    // (e.g. an attacker-planted dir on a shared host) is not protected by the mkdir above,\n    // so refuse to bind under a dir not owned by us or that is group/world-writable.\n    try {\n      const st = fs.statSync(socketDir);\n      const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n      if (uid !== null && st.uid !== uid) {\n        throw new Error(`IPC socket dir ${socketDir} not owned by current user (uid ${st.uid} != ${uid})`);\n      }\n      if ((st.mode & 0o022) !== 0) {\n        throw new Error(`IPC socket dir ${socketDir} is group/world-writable (mode ${(st.mode & 0o777).toString(8)})`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n    // Refuse to bind over a symlink planted at the socket path. The EADDRINUSE reclaim branch\n    // fences a stale node via canUnlinkExistingSocket (lstat); the fresh-bind path needs the same\n    // protection so a symlink whose target we would later chmod cannot be used to redirect the\n    // permission change onto an arbitrary file.\n    try {\n      const linkStat = fs.lstatSync(socketPath);\n      if (linkStat.isSymbolicLink()) {\n        throw new Error(`IPC socket path ${socketPath} is a symlink; refusing to bind`);\n      }\n    } catch (error: unknown) {\n      const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n      if (code !== 'ENOENT') throw error;\n    }\n  }\n\n  const server = net.createServer((socket) => {\n    if (activeSockets.size >= maxClients) {\n      // A bare close here is indistinguishable from a dead daemon to a liveness\n      // probe, which makes a sibling launcher reap a healthy-but-cap-saturated\n      // daemon. Give the connection a brief window to send its first frame: if it\n      // is a liveness probe, answer it (proving the daemon alive) and close WITHOUT\n      // occupying a durable slot; only refuse genuine bridge clients at the cap.\n      answerProbeOrRefuseAtCap(socket, maxClients, log);\n      return;\n    }\n\n    activeSockets.add(socket);\n    onActivity();\n    log('[ipc-bridge] secondary connected pid=?');\n\n    const originalWrite = socket.write.bind(socket);\n    socket.write = ((chunk: unknown, ...args: unknown[]) => {\n      onActivity();\n      totalSecondaryMessagesOut += countJsonRpcFrames(chunk);\n      return originalWrite(chunk as string | Uint8Array, ...(args as [BufferEncoding?, (() => void)?]));\n    }) as typeof socket.write;\n\n    socket.on('data', (chunk) => {\n      onActivity();\n      totalSecondaryMessagesIn += countJsonRpcFrames(chunk);\n    });\n\n    const transport = new StdioServerTransport(socket, socket);\n    activeTransports.set(socket, transport);\n    const secondaryServer = options.createServer();\n    secondaryServer.connect(transport).catch((error: unknown) => {\n      const message = error instanceof Error ? error.message : String(error);\n      log(`[ipc-bridge] secondary connect error: ${message}`);\n      socket.destroy();\n    });\n\n    socket.once('close', () => {\n      activeSockets.delete(socket);\n      activeTransports.delete(socket);\n      void transport.close();\n      log('[ipc-bridge] disconnect');\n    });\n    socket.once('error', (error) => {\n      log(`[ipc-bridge] socket error: ${error.message}`);\n    });\n  });\n\n  try {\n    await listenOnce(server, socketPath);\n  } catch (error: unknown) {\n    const err = error as NodeJS.ErrnoException;\n    if (err.code !== 'EADDRINUSE') {\n      throw err;\n    }\n    if (socketPath.startsWith('tcp://')) {\n      // A TCP port in use cannot be reclaimed by unlinking; back off and retry a few times. If it\n      // never frees, run without the secondary bridge rather than aborting the whole daemon.\n      const listened = await retryTcpListenAfterEaddrInUse(server, socketPath, log);\n      if (!listened) {\n        log(`[ipc-bridge] tcp socket remained in use at ${socketPath}; secondary bridge disabled`);\n        return {\n          socketPath,\n          close: async () => {\n            for (const socket of activeSockets) {\n              socket.destroy();\n            }\n            activeSockets.clear();\n            activeTransports.clear();\n          },\n        };\n      }\n    } else {\n      // Unix socket path: only reclaim a stale node that is provably ours (the fence). On a benign\n      // concurrent-primary race the node may already be gone — canUnlinkExistingSocket treats ENOENT\n      // as reclaimable, so we re-bind instead of aborting; a foreign-owned node still refuses.\n      if (!canUnlinkExistingSocket(socketPath)) {\n        throw err;\n      }\n      try {\n        fs.unlinkSync(socketPath);\n      } catch (unlinkError: unknown) {\n        const unlinkErr = unlinkError as NodeJS.ErrnoException;\n        if (unlinkErr.code !== 'ENOENT') {\n          throw unlinkErr;\n        }\n      }\n      await listenOnce(server, socketPath);\n    }\n  }\n\n  const address = server.address();\n  const listenedPath = typeof address === 'object' && address\n    ? `tcp://${address.address}:${address.port}`\n    : socketPath;\n  if (!socketPath.startsWith('tcp://')) {\n    // Do not chmod through a symlink. lstat first and only chmod a real socket node so the 0o600\n    // tightening cannot be redirected onto an attacker-pointed target between bind and chmod.\n    const boundStat = fs.lstatSync(socketPath);\n    if (boundStat.isSymbolicLink() || !boundStat.isSocket()) {\n      throw new Error(`IPC socket path ${socketPath} is not a bound socket; refusing to chmod`);\n    }\n    fs.chmodSync(socketPath, 0o600);\n  }\n  activeServer = server;\n  activeSocketPath = listenedPath;\n  log(`[ipc-bridge] socket listening at ${listenedPath}`);\n\n  return {\n    socketPath: listenedPath,\n    close: async () => {\n      for (const socket of activeSockets) {\n        socket.destroy();\n      }\n      activeSockets.clear();\n      activeTransports.clear();\n      await new Promise<void>((resolve) => {\n        server.close(() => resolve());\n      });\n      if (activeServer === server) {\n        activeServer = null;\n        activeSocketPath = null;\n      }\n      if (!socketPath.startsWith('tcp://')) {\n        try {\n          fs.unlinkSync(socketPath);\n        } catch (error: unknown) {\n          const err = error as NodeJS.ErrnoException;\n          if (err.code !== 'ENOENT') {\n            throw err;\n          }\n        }\n      }\n    },\n  };\n}\n\nexport {\n  canUnlinkExistingSocket,\n  getIpcBridgeStats,\n  parseMaxClients,\n  resolveIpcSocketPath,\n  startIpcSocketServer,\n};\n\nexport type {\n  IpcBridgeStats,\n  IpcSocketServerHandle,\n  IpcSocketServerOptions,\n};","lineStart":1,"lineEnd":518,"totalLines":518,"truncated":false}},"title":".opencode/skills/system-spec-kit/shared/ipc/socket-server.ts","time":{"start":1781763114405,"end":1781763114426}},"metadata":{"openai":{"itemId":"fc_0ab8fbf40fc27ea4016a338c2a43bc81918277fd083585f893"}},"id":"prt_ed95b856a001lHJk2GC466pVG7","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95b5aba001hQutA9bBaBQJ5v"}}
{"type":"tool_use","timestamp":1781763114622,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"glob","callID":"call_JO8z44VmC6GnKupwS4hXcyhS","state":{"status":"completed","input":{"pattern":".opencode/bin/lib/*ipc*.cjs","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public"},"output":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-ipc-bridge.cjs","metadata":{"count":1,"truncated":false},"title":"","time":{"start":1781763114484,"end":1781763114621}},"metadata":{"openai":{"itemId":"fc_0ab8fbf40fc27ea4016a338c2a43d08191b6281aa7d0724a29"}},"id":"prt_ed95b85a9001oh4EtECoICK0Iu","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95b5aba001hQutA9bBaBQJ5v"}}
{"type":"tool_use","timestamp":1781763114657,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"glob","callID":"call_cKHcr6KBq9GLU4jDt7RbnxPF","state":{"status":"completed","input":{"pattern":".opencode/bin/lib/*session*.cjs","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public"},"output":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/launcher-session-proxy.cjs","metadata":{"count":1,"truncated":false},"title":"","time":{"start":1781763114549,"end":1781763114656}},"metadata":{"openai":{"itemId":"fc_0ab8fbf40fc27ea4016a338c2a43fc8191b8d61532ed0561bc"}},"id":"prt_ed95b85fe0018Qt88qDT4JK1mE","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95b5aba001hQutA9bBaBQJ5v"}}
{"type":"tool_use","timestamp":1781763114666,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"read","callID":"call_fl1sEVQUQACkkX3fmAS4H9iu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","offset":1,"limit":2600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ---------------------------------------------------------------\n3: // MODULE: Spec Memory CLI\n4: // ---------------------------------------------------------------\n5: // Daemon-backed command line client for the mk-spec-memory tool\n6: // surface. The CLI is intentionally IPC-only: all persistence remains\n7: // owned by the already-running context server daemon.\n8: \n9: import { spawn } from 'node:child_process';\n10: import { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\n11: import net from 'node:net';\n12: import { createRequire } from 'node:module';\n13: import path from 'node:path';\n14: import { StringDecoder } from 'node:string_decoder';\n15: import { fileURLToPath } from 'node:url';\n16: \n17: import {\n18:   TOOL_DEFINITIONS,\n19:   type ToolDefinition,\n20:   ToolSchemaValidationError,\n21:   validateToolArgs,\n22: } from './tool-schemas.js';\n23: \n24: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n25: const DEFAULT_TIMEOUT_MS = 30_000;\n26: const DEFAULT_SOCKET_DIR = '/tmp/mk-spec-memory';\n27: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n28: const RESERVED_COMMANDS = new Set(['list-tools', 'completion']);\n29: \n30: const EXIT_SUCCESS = 0;\n31: const EXIT_RUNTIME = 1;\n32: const EXIT_USAGE = 64;\n33: const EXIT_PROTOCOL = 69;\n34: const EXIT_RETRYABLE = 75;\n35: \n36: type OutputFormat = 'json' | 'text' | 'jsonl';\n37: type ToolListMode = 'full' | 'compact' | 'names-only';\n38: type CompletionShell = 'bash' | 'zsh';\n39: \n40: interface ParsedCommand {\n41:   readonly command: string;\n42:   readonly format: OutputFormat;\n43:   readonly timeoutMs: number;\n44:   readonly sessionId?: string;\n45:   readonly warmOnly: boolean;\n46:   readonly toolListMode: ToolListMode;\n47:   readonly completionShell?: CompletionShell;\n48:   readonly args: Record<string, unknown>;\n49:   readonly help: boolean;\n50:   readonly version: boolean;\n51: }\n52: \n53: interface CliIo {\n54:   readonly stdout: Pick<NodeJS.WriteStream, 'write'>;\n55:   readonly stderr: Pick<NodeJS.WriteStream, 'write'>;\n56: }\n57: \n58: interface RepoPaths {\n59:   readonly opencodeDir: string;\n60:   readonly repoRoot: string;\n61:   readonly launcherPath: string;\n62:   readonly bridgePath: string;\n63:   readonly dbDir: string;\n64:   readonly packageJsonPath: string;\n65: }\n66: \n67: interface BridgeProbeResult {\n68:   readonly status: string;\n69:   readonly reason?: string;\n70: }\n71: \n72: interface BridgeModule {\n73:   readonly getIpcSocketPath: (serviceName: string, options?: { dbDir?: string }) => string;\n74:   readonly probeDaemon: (socketPath: string, options?: { timeoutMs?: number; deepProbe?: boolean }) => Promise<BridgeProbeResult>;\n75:   readonly toConnectionOptions: (socketPath: string) => string | net.NetConnectOpts;\n76: }\n77: \n78: interface JsonRpcResponse {\n79:   readonly jsonrpc?: string;\n80:   readonly id?: unknown;\n81:   readonly result?: unknown;\n82:   readonly error?: {\n83:     readonly code?: number;\n84:     readonly message?: string;\n85:     readonly data?: unknown;\n86:   };\n87: }\n88: \n89: interface InitializeResult {\n90:   readonly protocolVersion?: string;\n91: }\n92: \n93: interface ToolResult {\n94:   readonly content?: Array<{ readonly type?: string; readonly text?: string }>;\n95:   readonly isError?: boolean;\n96: }\n97: \n98: class CliUsageError extends Error {\n99:   constructor(message: string) {\n100:     super(message);\n101:     this.name = 'CliUsageError';\n102:   }\n103: }\n104: \n105: class CliRetryableError extends Error {\n106:   constructor(message: string) {\n107:     super(message);\n108:     this.name = 'CliRetryableError';\n109:   }\n110: }\n111: \n112: class CliProtocolError extends Error {\n113:   constructor(message: string) {\n114:     super(message);\n115:     this.name = 'CliProtocolError';\n116:   }\n117: }\n118: \n119: class JsonRpcError extends Error {\n120:   public readonly code?: number;\n121:   public readonly data?: unknown;\n122: \n123:   constructor(error: NonNullable<JsonRpcResponse['error']>) {\n124:     super(error.message ?? 'JSON-RPC request failed');\n125:     this.name = 'JsonRpcError';\n126:     this.code = error.code;\n127:     this.data = error.data;\n128:   }\n129: }\n130: \n131: // Awaits drain when the kernel pipe buffer is full: a fire-and-forget\n132: // write followed by process.exit() truncates large payloads at the pipe\n133: // buffer boundary (observed as exactly 64KB on darwin). Streams without\n134: // emitter methods (test fakes) resolve immediately.\n135: async function writeLine(stream: Pick<NodeJS.WriteStream, 'write'>, value: string): Promise<void> {\n136:   const flushed = stream.write(`${value}\\n`);\n137:   if (flushed) return;\n138:   const drainable = stream as Pick<NodeJS.WriteStream, 'write'> & Partial<Pick<NodeJS.WriteStream, 'once' | 'off'>>;\n139:   if (typeof drainable.once !== 'function') return;\n140:   await new Promise<void>((resolve) => {\n141:     const settle = (): void => {\n142:       drainable.off?.('drain', settle);\n143:       drainable.off?.('error', settle);\n144:       drainable.off?.('close', settle);\n145:       resolve();\n146:     };\n147:     drainable.once?.('drain', settle);\n148:     drainable.once?.('error', settle);\n149:     drainable.once?.('close', settle);\n150:   });\n151: }\n152: \n153: function currentModulePath(): string {\n154:   return fileURLToPath(import.meta.url);\n155: }\n156: \n157: function findRepoPaths(startFile = currentModulePath()): RepoPaths {\n158:   let current = path.dirname(startFile);\n159: \n160:   while (true) {\n161:     const directOpencodeDir = path.basename(current) === '.opencode' ? current : path.join(current, '.opencode');\n162:     const launcherPath = path.join(directOpencodeDir, 'bin', 'mk-spec-memory-launcher.cjs');\n163:     const bridgePath = path.join(directOpencodeDir, 'bin', 'lib', 'launcher-ipc-bridge.cjs');\n164:     if (existsSync(launcherPath) && existsSync(bridgePath)) {\n165:       const repoRoot = path.dirname(directOpencodeDir);\n166:       return {\n167:         opencodeDir: directOpencodeDir,\n168:         repoRoot,\n169:         launcherPath,\n170:         bridgePath,\n171:         dbDir: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'),\n172:         packageJsonPath: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'package.json'),\n173:       };\n174:     }\n175: \n176:     const parent = path.dirname(current);\n177:     if (parent === current) {\n178:       throw new CliProtocolError('Unable to locate .opencode/bin launcher assets from CLI path');\n179:     }\n180:     current = parent;\n181:   }\n182: }\n183: \n184: function loadBridge(paths: RepoPaths): BridgeModule {\n185:   const require = createRequire(import.meta.url);\n186:   return require(paths.bridgePath) as BridgeModule;\n187: }\n188: \n189: function readCliVersion(paths: RepoPaths): string {\n190:   const require = createRequire(import.meta.url);\n191:   const pkg = require(paths.packageJsonPath) as { version?: unknown };\n192:   return typeof pkg.version === 'string' ? pkg.version : '0.0.0';\n193: }\n194: \n195: function toKebabCommand(name: string): string {\n196:   return name.replace(/_/g, '-');\n197: }\n198: \n199: function toCamelCommand(name: string): string {\n200:   return name.replace(/_([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n201: }\n202: \n203: function commandAliases(name: string): string[] {\n204:   return Array.from(new Set([name, toKebabCommand(name), toCamelCommand(name)]));\n205: }\n206: \n207: function usageText(command?: string): string {\n208:   const tool = command ? getToolDefinition(command) : null;\n209:   if (tool) {\n210:     return `spec-memory ${tool.name}\n211: \n212: Description:\n213:   ${tool.description}\n214: \n215: Aliases:\n216:   ${commandAliases(tool.name).join(', ')}\n217: \n218: Input schema:\n219: ${JSON.stringify(tool.inputSchema, null, 2)}`;\n220:   }\n221: \n222:   return `spec-memory - daemon-backed CLI for mk-spec-memory\n223: \n224: Usage:\n225:   spec-memory list-tools [--format json|text|jsonl] [--compact|--names-only]\n226:   spec-memory completion bash|zsh\n227:   spec-memory <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--session-id ID] [--warm-only]\n228:   spec-memory <tool_name> --param value [--another-param value]\n229: \n230: Examples:\n231:   spec-memory list-tools --format text\n232:   spec-memory list-tools --compact\n233:   spec-memory completion zsh\n234:   spec-memory memory_stats --format json\n235:   spec-memory memory_search --query \"gold query battery\" --limit 3\n236:   spec-memory memory_context --json '{\"input\":\"resume\", \"mode\":\"resume\"}'\n237: \n238: Exit codes:\n239:   0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error\n240: \n241: Exit 69 recovery:\n242:   - Missing or stale dist entrypoint: run npm run build --workspace=@spec-kit/mcp-server.\n243:     - Backend protocol version changed: rebuild the CLI and daemon from the same checkout, then update any pinned client.\n244:     - Socket path or daemon config mismatch: check SPECKIT_IPC_SOCKET_DIR, socket length, and daemon config before retrying.`;\n245: }\n246: \n247: function parseCompletionShell(raw: string): CompletionShell {\n248:   if (raw === 'bash' || raw === 'zsh') return raw;\n249:   throw new CliUsageError('completion shell must be one of: bash, zsh');\n250: }\n251: \n252: function normalizeName(value: string): string {\n253:   return value.replace(/[-_]/g, '').toLowerCase();\n254: }\n255: \n256: function toCamelCaseFlag(value: string): string {\n257:   return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n258: }\n259: \n260: function commandMap(): Map<string, ToolDefinition> {\n261:   const map = new Map<string, ToolDefinition>();\n262:   for (const tool of TOOL_DEFINITIONS) {\n263:     for (const alias of commandAliases(tool.name)) {\n264:       const existing = map.get(alias);\n265:       if (existing && existing.name !== tool.name) {\n266:         throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n267:       }\n268:       map.set(alias, tool);\n269:     }\n270:   }\n271:   return map;\n272: }\n273: \n274: function getToolDefinition(command: string): ToolDefinition | null {\n275:   return commandMap().get(command) ?? null;\n276: }\n277: \n278: function inputPropertyNames(tool: ToolDefinition): string[] {\n279:   const schema = tool.inputSchema;\n280:   const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n281:     ? (schema as { readonly properties?: unknown }).properties\n282:     : null;\n283:   if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n284:   return Object.keys(properties);\n285: }\n286: \n287: function resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n288:   const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n289:   if (exact) return exact;\n290: \n291:   const normalized = normalizeName(rawFlag);\n292:   const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n293:   if (matched) return matched;\n294: \n295:   return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n296: }\n297: \n298: function parseValue(raw: string): unknown {\n299:   const trimmed = raw.trim();\n300:   if (trimmed === 'true') return true;\n301:   if (trimmed === 'false') return false;\n302:   if (trimmed === 'null') return null;\n303:   if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n304:     try {\n305:       return JSON.parse(trimmed) as unknown;\n306:     } catch (error: unknown) {\n307:       const message = error instanceof Error ? error.message : String(error);\n308:       throw new CliUsageError(`Invalid JSON value: ${message}`);\n309:     }\n310:   }\n311:   return raw;\n312: }\n313: \n314: function parsePositiveInteger(raw: string, flagName: string): number {\n315:   if (!/^\\d+$/.test(raw)) {\n316:     throw new CliUsageError(`${flagName} must be a positive integer`);\n317:   }\n318:   const value = Number.parseInt(raw, 10);\n319:   if (!Number.isFinite(value) || value <= 0) {\n320:     throw new CliUsageError(`${flagName} must be a positive integer`);\n321:   }\n322:   return value;\n323: }\n324: \n325: function parseFormat(raw: string): OutputFormat {\n326:   if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n327:   throw new CliUsageError('--format must be one of: json, text, jsonl');\n328: }\n329: \n330: function parseInlineBoolean(raw: string, flagName: string): boolean {\n331:   if (raw === 'true' || raw === '1') return true;\n332:   if (raw === 'false' || raw === '0') return false;\n333:   throw new CliUsageError(`${flagName} must be true or false`);\n334: }\n335: \n336: function readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n337:   const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n338:   if (inline) return { value: inline[1], nextIndex: index + 1 };\n339:   const value = tokens[index + 1];\n340:   if (value === undefined) {\n341:     throw new CliUsageError(`${flagName} requires a value`);\n342:   }\n343:   return { value, nextIndex: index + 2 };\n344: }\n345: \n346: function parseJsonObject(raw: string): Record<string, unknown> {\n347:   let parsed: unknown;\n348:   try {\n349:     parsed = JSON.parse(raw) as unknown;\n350:   } catch (error: unknown) {\n351:     const message = error instanceof Error ? error.message : String(error);\n352:     throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n353:   }\n354:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n355:     throw new CliUsageError('--json must be a JSON object');\n356:   }\n357:   return parsed as Record<string, unknown>;\n358: }\n359: \n360: function envFlagEnabled(name: string): boolean {\n361:   const raw = process.env[name];\n362:   if (raw === undefined || raw === null) return false;\n363:   return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n364: }\n365: \n366: function defaultWarmOnly(): boolean {\n367:   return envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_WARM_ONLY')\n368:     || envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME')\n369:     || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n370:     || envFlagEnabled('OPENCODE_PROMPT_TIME')\n371:     || envFlagEnabled('CODEX_PROMPT_TIME')\n372:     || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n373: }\n374: \n375: export function parseCliArgs(argv: string[]): ParsedCommand {\n376:   const command = argv[0];\n377:   const warmOnlyDefault = defaultWarmOnly();\n378:   if (!command || command === '--help' || command === '-h') {\n379:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n380:   }\n381:   if (command === '--version' || command === '-v') {\n382:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n383:   }\n384: \n385:   let format: OutputFormat = 'json';\n386:   let timeoutMs = DEFAULT_TIMEOUT_MS;\n387:   let sessionId: string | undefined;\n388:   let warmOnly = warmOnlyDefault;\n389:   let toolListMode: ToolListMode = 'full';\n390:   let completionShell: CompletionShell | undefined;\n391:   let jsonPayload: Record<string, unknown> | null = null;\n392:   const tool = getToolDefinition(command);\n393:   const parsedArgs: Record<string, unknown> = {};\n394:   const tokens = argv.slice(1);\n395:   let index = 0;\n396: \n397:   while (index < tokens.length) {\n398:     const token = tokens[index];\n399:     if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n400:       completionShell = parseCompletionShell(token);\n401:       index += 1;\n402:       continue;\n403:     }\n404:     if (!token.startsWith('--')) {\n405:       throw new CliUsageError(`Unexpected positional argument: ${token}`);\n406:     }\n407:     const rawFlag = token.slice(2).split('=', 1)[0];\n408:     const option = `--${rawFlag}`;\n409: \n410:     if (rawFlag === 'help' || rawFlag === 'h') {\n411:       return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n412:     }\n413:     if (rawFlag === 'format') {\n414:       const read = readOptionValue(tokens, index, option);\n415:       format = parseFormat(read.value);\n416:       index = read.nextIndex;\n417:       continue;\n418:     }\n419:     if (rawFlag === 'timeout-ms') {\n420:       const read = readOptionValue(tokens, index, option);\n421:       timeoutMs = parsePositiveInteger(read.value, option);\n422:       index = read.nextIndex;\n423:       continue;\n424:     }\n425:     if (rawFlag === 'session-id') {\n426:       const read = readOptionValue(tokens, index, option);\n427:       sessionId = read.value;\n428:       index = read.nextIndex;\n429:       continue;\n430:     }\n431:     if (rawFlag === 'warm-only') {\n432:       const inline = token.match(/^--[^=]+=(.*)$/);\n433:       warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n434:       index += 1;\n435:       continue;\n436:     }\n437:     if (rawFlag === 'no-warm-only') {\n438:       warmOnly = false;\n439:       index += 1;\n440:       continue;\n441:     }\n442:     if (rawFlag === 'compact') {\n443:       toolListMode = 'compact';\n444:       index += 1;\n445:       continue;\n446:     }\n447:     if (rawFlag === 'names-only') {\n448:       toolListMode = 'names-only';\n449:       index += 1;\n450:       continue;\n451:     }\n452:     if (rawFlag === 'json') {\n453:       const read = readOptionValue(tokens, index, option);\n454:       jsonPayload = parseJsonObject(read.value);\n455:       index = read.nextIndex;\n456:       continue;\n457:     }\n458: \n459:     if (!tool) {\n460:       throw new CliUsageError(`Unknown command: ${command}`);\n461:     }\n462: \n463:     const propertyName = resolvePropertyName(rawFlag, tool);\n464:     const inline = token.match(/^--[^=]+=(.*)$/);\n465:     if (inline) {\n466:       parsedArgs[propertyName] = parseValue(inline[1]);\n467:       index += 1;\n468:       continue;\n469:     }\n470: \n471:     const next = tokens[index + 1];\n472:     if (next === undefined || next.startsWith('--')) {\n473:       parsedArgs[propertyName] = true;\n474:       index += 1;\n475:       continue;\n476:     }\n477:     parsedArgs[propertyName] = parseValue(next);\n478:     index += 2;\n479:   }\n480: \n481:   if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n482:     throw new CliUsageError('--json cannot be combined with per-parameter flags');\n483:   }\n484: \n485:   return {\n486:     command,\n487:     format,\n488:     timeoutMs,\n489:     sessionId,\n490:     warmOnly,\n491:     toolListMode,\n492:     completionShell,\n493:     args: jsonPayload ?? parsedArgs,\n494:     help: false,\n495:     version: false,\n496:   };\n497: }\n498: \n499: function validateCommand(parsed: ParsedCommand): { readonly tool: ToolDefinition; readonly args: Record<string, unknown> } | null {\n500:   if (RESERVED_COMMANDS.has(parsed.command)) return null;\n501:   const tool = getToolDefinition(parsed.command);\n502:   if (!tool) {\n503:     throw new CliUsageError(`Unknown command: ${parsed.command}`);\n504:   }\n505: \n506:   const args = { ...parsed.args };\n507:   const properties = new Set(inputPropertyNames(tool));\n508:   if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'sessionId') && properties.has('sessionId')) {\n509:     args.sessionId = parsed.sessionId;\n510:   } else if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'session_id') && properties.has('session_id')) {\n511:     args.session_id = parsed.sessionId;\n512:   }\n513: \n514:   return {\n515:     tool,\n516:     args: validateToolArgs(tool.name, args) as Record<string, unknown>,\n517:   };\n518: }\n519: \n520: function renderJson(value: unknown, format: OutputFormat): string {\n521:   if (format === 'jsonl') return JSON.stringify(value);\n522:   return JSON.stringify(value, null, 2);\n523: }\n524: \n525: function compactTool(tool: ToolDefinition): Record<string, unknown> {\n526:   return {\n527:     name: tool.name,\n528:     command: tool.name,\n529:     kebabCommand: toKebabCommand(tool.name),\n530:     camelCommand: toCamelCommand(tool.name),\n531:     aliases: commandAliases(tool.name),\n532:     description: tool.description,\n533:   };\n534: }\n535: \n536: function renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n537:   const payload = {\n538:     status: 'ok',\n539:     data: {\n540:       count: TOOL_DEFINITIONS.length,\n541:       mode,\n542:       tools: TOOL_DEFINITIONS.map((tool) => ({\n543:         name: tool.name,\n544:         command: tool.name,\n545:         kebabCommand: toKebabCommand(tool.name),\n546:         camelCommand: toCamelCommand(tool.name),\n547:         aliases: commandAliases(tool.name),\n548:         description: tool.description,\n549:         inputSchema: tool.inputSchema,\n550:       })),\n551:     },\n552:   };\n553:   const compactPayload = {\n554:     status: 'ok',\n555:     data: {\n556:       count: TOOL_DEFINITIONS.length,\n557:       mode,\n558:       tools: TOOL_DEFINITIONS.map(compactTool),\n559:     },\n560:   };\n561:   const namesOnlyPayload = {\n562:     status: 'ok',\n563:     data: {\n564:       count: TOOL_DEFINITIONS.length,\n565:       mode,\n566:       names: TOOL_DEFINITIONS.map((tool) => tool.name),\n567:     },\n568:   };\n569: \n570:   if (format === 'text') {\n571:     return TOOL_DEFINITIONS.map((tool) => tool.name).join('\\n');\n572:   }\n573:   if (mode === 'compact') return renderJson(compactPayload, format);\n574:   if (mode === 'names-only') return renderJson(namesOnlyPayload, format);\n575:   return renderJson(payload, format);\n576: }\n577: \n578: function completionWords(): string[] {\n579:   return ['list-tools', 'completion', ...TOOL_DEFINITIONS.map((tool) => tool.name)];\n580: }\n581: \n582: function shellWords(words: readonly string[]): string {\n583:   return words.join(' ');\n584: }\n585: \n586: function renderBashCompletion(): string {\n587:   const commands = shellWords(completionWords());\n588:   const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n589:   const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n590:   return `_spec_memory_completion() {\n591:   local cur\n592:   COMPREPLY=()\n593:   cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n594:   if [[ \\${COMP_CWORD} -eq 1 ]]; then\n595:     COMPREPLY=( $(compgen -W \"${commands}\" -- \"\\${cur}\") )\n596:     return 0\n597:   fi\n598:   case \"\\${COMP_WORDS[1]}\" in\n599:     completion) COMPREPLY=( $(compgen -W \"bash zsh\" -- \"\\${cur}\") ) ;;\n600:     list-tools) COMPREPLY=( $(compgen -W \"${listFlags}\" -- \"\\${cur}\") ) ;;\n601:     *) COMPREPLY=( $(compgen -W \"${commonFlags}\" -- \"\\${cur}\") ) ;;\n602:   esac\n603: }\n604: complete -F _spec_memory_completion spec-memory`;\n605: }\n606: \n607: function renderZshCompletion(): string {\n608:   const commands = shellWords(completionWords());\n609:   const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n610:   const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n611:   return `#compdef spec-memory\n612: _spec_memory() {\n613:   local -a commands common_flags list_flags shells\n614:   commands=(${commands})\n615:   common_flags=(${commonFlags})\n616:   list_flags=(${listFlags})\n617:   shells=(bash zsh)\n618:   if (( CURRENT == 2 )); then\n619:     _describe 'commands' commands\n620:     return\n621:   fi\n622:   case \\${words[2]} in\n623:     completion) _describe 'shells' shells ;;\n624:     list-tools) _describe 'flags' list_flags ;;\n625:     *) _describe 'flags' common_flags ;;\n626:   esac\n627: }\n628: _spec_memory \"$@\"`;\n629: }\n630: \n631: function renderCompletion(shell: CompletionShell): string {\n632:   return shell === 'bash' ? renderBashCompletion() : renderZshCompletion();\n633: }\n634: \n635: function isErrorPayload(payload: unknown): boolean {\n636:   return Boolean(payload)\n637:     && typeof payload === 'object'\n638:     && !Array.isArray(payload)\n639:     && (payload as { readonly status?: unknown }).status === 'error';\n640: }\n641: \n642: function extractToolPayload(toolName: string, result: unknown): { readonly payload: unknown; readonly isError: boolean } {\n643:   const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n644:   const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n645:   if (firstText) {\n646:     try {\n647:       return {\n648:         payload: JSON.parse(firstText) as unknown,\n649:         isError: toolResult?.isError === true,\n650:       };\n651:     } catch {\n652:       return {\n653:         payload: {\n654:           status: toolResult?.isError ? 'error' : 'ok',\n655:           tool: toolName,\n656:           text: firstText,\n657:         },\n658:         isError: toolResult?.isError === true,\n659:       };\n660:     }\n661:   }\n662:   return {\n663:     payload: {\n664:       status: toolResult?.isError ? 'error' : 'ok',\n665:       tool: toolName,\n666:       result,\n667:     },\n668:     isError: toolResult?.isError === true,\n669:   };\n670: }\n671: \n672: function renderPayload(payload: unknown, format: OutputFormat): string {\n673:   if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n674:   if (payload && typeof payload === 'object' && !Array.isArray(payload)) {\n675:     const record = payload as Record<string, unknown>;\n676:     if (typeof record.summary === 'string') return record.summary;\n677:     if (typeof record.error === 'string') return record.error;\n678:     if (typeof record.message === 'string') return record.message;\n679:   }\n680:   return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n681: }\n682: \n683: function isProtocolMismatch(error: unknown): boolean {\n684:   if (error instanceof JsonRpcError && error.code === -32002) return true;\n685:   const message = error instanceof Error ? error.message : String(error);\n686:   return /protocol.*(mismatch|changed|version)/i.test(message);\n687: }\n688: \n689: function isRetryableError(error: unknown): boolean {\n690:   if (error instanceof CliRetryableError) return true;\n691:   if (error instanceof JsonRpcError && error.code === -32001) return true;\n692:   const message = error instanceof Error ? error.message : String(error);\n693:   return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n694: }\n695: \n696: function exitCodeForError(error: unknown): number {\n697:   if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n698:   if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n699:   if (isRetryableError(error)) return EXIT_RETRYABLE;\n700:   if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n701:   return EXIT_RUNTIME;\n702: }\n703: \n704: function levenshteinDistance(left: string, right: string): number {\n705:   const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n706:   const current = new Array<number>(right.length + 1);\n707: \n708:   for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n709:     current[0] = leftIndex;\n710:     for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n711:       const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n712:       current[rightIndex] = Math.min(\n713:         current[rightIndex - 1] + 1,\n714:         previous[rightIndex] + 1,\n715:         previous[rightIndex - 1] + cost,\n716:       );\n717:     }\n718:     previous.splice(0, previous.length, ...current);\n719:   }\n720: \n721:   return previous[right.length];\n722: }\n723: \n724: function closestCommand(command: string): string | undefined {\n725:   const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n726:   targets.set('completion', 'completion');\n727:   for (const tool of TOOL_DEFINITIONS) {\n728:     for (const alias of commandAliases(tool.name)) {\n729:       targets.set(alias, tool.name);\n730:     }\n731:   }\n732: \n733:   let best: { readonly command: string; readonly distance: number } | null = null;\n734:   for (const [alias, canonical] of targets) {\n735:     const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n736:     if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n737:       best = { command: canonical, distance };\n738:     }\n739:   }\n740: \n741:   if (!best) return undefined;\n742:   const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n743:   return best.distance <= threshold ? best.command : undefined;\n744: }\n745: \n746: function unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n747:   const match = message.match(/^Unknown command: (.+)$/);\n748:   if (!match) return null;\n749:   return {\n750:     hint: 'Try `list-tools` to see available commands.',\n751:     suggestion: closestCommand(match[1]),\n752:   };\n753: }\n754: \n755: function socketPathTooLong(socketPath: string): boolean {\n756:   if (socketPath.startsWith('tcp://')) return false;\n757:   return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n758: }\n759: \n760: // `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n761: // (e.g. an attacker-planted dir or symlink on a shared host) is not protected by the\n762: // mkdir above, so the client must refuse to probe/connect under a dir it does not own,\n763: // a symlinked dir, or a group/world-writable dir, and must reject a foreign-owned or\n764: // symlinked socket node — otherwise a fake daemon could answer initialize and spoof results.\n765: function assertSocketPerimeter(socketDir: string): void {\n766:   const dirLink = lstatSync(socketDir);\n767:   if (dirLink.isSymbolicLink()) {\n768:     throw new CliProtocolError(`IPC socket directory is a symlink; refusing to connect: ${socketDir}`);\n769:   }\n770:   const dirStat = statSync(socketDir);\n771:   const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n772:   if (uid !== null && dirStat.uid !== uid) {\n773:     throw new CliProtocolError(`IPC socket directory is not owned by the current user (uid ${dirStat.uid} != ${uid}): ${socketDir}`);\n774:   }\n775:   if ((dirStat.mode & 0o022) !== 0) {\n776:     throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n777:   }\n778:   const socketPath = path.join(socketDir, SOCKET_FILE_NAME);\n779:   let nodeLink;\n780:   try {\n781:     nodeLink = lstatSync(socketPath);\n782:   } catch (error: unknown) {\n783:     const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n784:     if (code === 'ENOENT') return;\n785:     throw error;\n786:   }\n787:   if (nodeLink.isSymbolicLink()) {\n788:     throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n789:   }\n790:   if (uid !== null && nodeLink.uid !== uid) {\n791:     throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n792:   }\n793: }\n794: \n795: function ensureSocketEnvironment(): void {\n796:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n797:     process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n798:   }\n799:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n800:   if (!socketDir || socketDir.startsWith('tcp://')) return;\n801:   mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n802:   assertSocketPerimeter(socketDir);\n803: }\n804: \n805: function sleep(ms: number): Promise<void> {\n806:   return new Promise((resolve) => setTimeout(resolve, ms));\n807: }\n808: \n809: function spawnLauncher(paths: RepoPaths): void {\n810:   const child = spawn(process.execPath, [paths.launcherPath], {\n811:     cwd: paths.repoRoot,\n812:     env: process.env,\n813:     detached: true,\n814:     stdio: 'ignore',\n815:   });\n816:   child.unref();\n817: }\n818: \n819: async function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n820:   const deadline = Date.now() + timeoutMs;\n821:   let lastReason = 'not probed';\n822: \n823:   while (Date.now() <= deadline) {\n824:     const remaining = Math.max(1, deadline - Date.now());\n825:     const probe = await bridge.probeDaemon(socketPath, {\n826:       timeoutMs: Math.min(remaining, 5000),\n827:       deepProbe: true,\n828:     });\n829:     if (probe.status === 'alive') return;\n830:     lastReason = probe.reason ?? probe.status;\n831:     await sleep(100);\n832:   }\n833: \n834:   throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n835: }\n836: \n837: class JsonRpcSocketClient {\n838:   private nextId = 1;\n839:   private readonly decoder = new StringDecoder('utf8');\n840: \n841:   private constructor(\n842:     private readonly socket: net.Socket,\n843:   ) {}\n844: \n845:   static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n846:     return new Promise((resolve, reject) => {\n847:       let socket: net.Socket;\n848:       let settled = false;\n849:       const finish = (error?: Error): void => {\n850:         if (settled) return;\n851:         settled = true;\n852:         clearTimeout(timer);\n853:         socket.off?.('connect', onConnect);\n854:         socket.off?.('error', onError);\n855:         if (error) {\n856:           socket.destroy?.();\n857:           reject(error);\n858:           return;\n859:         }\n860:         resolve(new JsonRpcSocketClient(socket));\n861:       };\n862:       const onConnect = (): void => finish();\n863:       const onError = (error: Error): void => finish(error);\n864:       const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n865:       timer.unref?.();\n866: \n867:       try {\n868:         const connectionOptions = bridge.toConnectionOptions(socketPath);\n869:         socket = typeof connectionOptions === 'string'\n870:           ? net.createConnection(connectionOptions)\n871:           : net.createConnection(connectionOptions);\n872:       } catch (error: unknown) {\n873:         clearTimeout(timer);\n874:         reject(error instanceof Error ? error : new Error(String(error)));\n875:         return;\n876:       }\n877:       socket.once('connect', onConnect);\n878:       socket.once('error', onError);\n879:     });\n880:   }\n881: \n882:   notify(method: string, params?: unknown): void {\n883:     const frame = params === undefined\n884:       ? { jsonrpc: '2.0', method }\n885:       : { jsonrpc: '2.0', method, params };\n886:     this.socket.write(`${JSON.stringify(frame)}\\n`);\n887:   }\n888: \n889:   request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n890:     const id = this.nextId++;\n891:     const request = { jsonrpc: '2.0', id, method, params };\n892:     return new Promise((resolve, reject) => {\n893:       let buffer = '';\n894:       let settled = false;\n895: \n896:       const cleanup = (): void => {\n897:         clearTimeout(timer);\n898:         this.socket.off('data', onData);\n899:         this.socket.off('error', onError);\n900:         this.socket.off('close', onClose);\n901:       };\n902:       const finish = (error: unknown, value?: unknown): void => {\n903:         if (settled) return;\n904:         settled = true;\n905:         cleanup();\n906:         if (error) {\n907:           reject(error);\n908:           return;\n909:         }\n910:         resolve(value);\n911:       };\n912:       const onData = (chunk: Buffer | string): void => {\n913:         buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n914:         let newlineIndex = buffer.indexOf('\\n');\n915:         while (newlineIndex !== -1) {\n916:           const line = buffer.slice(0, newlineIndex).trim();\n917:           buffer = buffer.slice(newlineIndex + 1);\n918:           newlineIndex = buffer.indexOf('\\n');\n919:           if (!line) continue;\n920:           let parsed: JsonRpcResponse;\n921:           try {\n922:             parsed = JSON.parse(line) as JsonRpcResponse;\n923:           } catch {\n924:             continue;\n925:           }\n926:           if (parsed.id !== id) continue;\n927:           if (parsed.error) {\n928:             finish(new JsonRpcError(parsed.error));\n929:             return;\n930:           }\n931:           finish(null, parsed.result);\n932:           return;\n933:         }\n934:       };\n935:       const onError = (error: Error): void => finish(error);\n936:       const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n937:       const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n938:       timer.unref?.();\n939: \n940:       this.socket.on('data', onData);\n941:       this.socket.once('error', onError);\n942:       this.socket.once('close', onClose);\n943:       this.socket.write(`${JSON.stringify(request)}\\n`);\n944:     });\n945:   }\n946: \n947:   close(): void {\n948:     this.socket.end();\n949:     this.socket.destroy();\n950:   }\n951: }\n952: \n953: async function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n954:   const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n955:   if (initialProbe.status === 'alive') return;\n956:   if (warmOnly) {\n957:     throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n958:   }\n959:   spawnLauncher(paths);\n960:   await waitForDaemon(socketPath, bridge, timeoutMs);\n961: }\n962: \n963: async function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n964:   ensureSocketEnvironment();\n965:   const paths = findRepoPaths();\n966:   const bridge = loadBridge(paths);\n967:   const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n968:   if (socketPathTooLong(socketPath)) {\n969:     throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n970:   }\n971: \n972:   await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n973: \n974:   const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n975:   try {\n976:     const initialize = await client.request('initialize', {\n977:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n978:       capabilities: {},\n979:       clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n980:     }, timeoutMs) as InitializeResult;\n981:     if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n982:       throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n983:     }\n984:     client.notify('notifications/initialized');\n985:     return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n986:   } finally {\n987:     client.close();\n988:   }\n989: }\n990: \n991: export async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n992:   try {\n993:     const parsed = parseCliArgs(argv);\n994:     if (parsed.help) {\n995:       await writeLine(io.stdout, usageText(parsed.command || undefined));\n996:       return EXIT_SUCCESS;\n997:     }\n998:     if (parsed.version) {\n999:       await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n1000:       return EXIT_SUCCESS;\n1001:     }\n1002:     if (parsed.command === 'list-tools') {\n1003:       await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n1004:       return EXIT_SUCCESS;\n1005:     }\n1006:     if (parsed.command === 'completion') {\n1007:       if (!parsed.completionShell) {\n1008:         throw new CliUsageError('completion requires a shell: bash or zsh');\n1009:       }\n1010:       await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n1011:       return EXIT_SUCCESS;\n1012:     }\n1013: \n1014:     const validated = validateCommand(parsed);\n1015:     if (!validated) {\n1016:       throw new CliUsageError(`Unknown command: ${parsed.command}`);\n1017:     }\n1018:     const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n1019:     const { payload, isError } = extractToolPayload(validated.tool.name, result);\n1020:     await writeLine(io.stdout, renderPayload(payload, parsed.format));\n1021:     return isError || isErrorPayload(payload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n1022:   } catch (error: unknown) {\n1023:     const exitCode = exitCodeForError(error);\n1024:     const message = error instanceof Error ? error.message : String(error);\n1025:     const unknownCommand = unknownCommandContext(message);\n1026:     const payload = {\n1027:       status: 'error',\n1028:       error: message,\n1029:       exitCode,\n1030:       ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n1031:       ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n1032:     };\n1033:     const format = (() => {\n1034:       try {\n1035:         return parseCliArgs(argv).format;\n1036:       } catch {\n1037:         return 'text' as OutputFormat;\n1038:       }\n1039:     })();\n1040:     if (format === 'json' || format === 'jsonl') {\n1041:       await writeLine(io.stderr, renderJson(payload, format));\n1042:     } else {\n1043:       await writeLine(io.stderr, [\n1044:         `ERROR: ${message}`,\n1045:         unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n1046:         unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n1047:       ].filter((line): line is string => Boolean(line)).join('\\n'));\n1048:     }\n1049:     return exitCode;\n1050:   }\n1051: }\n1052: \n1053: function isCliEntrypoint(): boolean {\n1054:   const invoked = process.argv[1];\n1055:   if (!invoked) return false;\n1056:   return path.resolve(invoked) === path.resolve(currentModulePath());\n1057: }\n1058: \n1059: export const __testing = {\n1060:   DEFAULT_SOCKET_DIR,\n1061:   EXIT_PROTOCOL,\n1062:   EXIT_RETRYABLE,\n1063:   EXIT_RUNTIME,\n1064:   EXIT_USAGE,\n1065:   commandMap,\n1066:   commandAliases,\n1067:   assertSocketPerimeter,\n1068:   ensureSocketEnvironment,\n1069:   exitCodeForError,\n1070:   findRepoPaths,\n1071:   isErrorPayload,\n1072:   closestCommand,\n1073:   renderCompletion,\n1074:   renderToolList,\n1075:   resolvePropertyName,\n1076: };\n1077: \n1078: if (isCliEntrypoint()) {\n1079:   // Natural exit via process.exitCode: a hard process.exit() drops any\n1080:   // stdout bytes still queued behind the kernel pipe buffer, truncating\n1081:   // large payloads. Pending pipe writes keep the event loop alive until\n1082:   // they flush; all sockets and timers are closed or unref'd by here.\n1083:   process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n1084: }\n\n(End of file - total 1084 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ---------------------------------------------------------------\n// MODULE: Spec Memory CLI\n// ---------------------------------------------------------------\n// Daemon-backed command line client for the mk-spec-memory tool\n// surface. The CLI is intentionally IPC-only: all persistence remains\n// owned by the already-running context server daemon.\n\nimport { spawn } from 'node:child_process';\nimport { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\nimport net from 'node:net';\nimport { createRequire } from 'node:module';\nimport path from 'node:path';\nimport { StringDecoder } from 'node:string_decoder';\nimport { fileURLToPath } from 'node:url';\n\nimport {\n  TOOL_DEFINITIONS,\n  type ToolDefinition,\n  ToolSchemaValidationError,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","text":"#!/usr/bin/env node\n// ---------------------------------------------------------------\n// MODULE: Spec Memory CLI\n// ---------------------------------------------------------------\n// Daemon-backed command line client for the mk-spec-memory tool\n// surface. The CLI is intentionally IPC-only: all persistence remains\n// owned by the already-running context server daemon.\n\nimport { spawn } from 'node:child_process';\nimport { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\nimport net from 'node:net';\nimport { createRequire } from 'node:module';\nimport path from 'node:path';\nimport { StringDecoder } from 'node:string_decoder';\nimport { fileURLToPath } from 'node:url';\n\nimport {\n  TOOL_DEFINITIONS,\n  type ToolDefinition,\n  ToolSchemaValidationError,\n  validateToolArgs,\n} from './tool-schemas.js';\n\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst DEFAULT_TIMEOUT_MS = 30_000;\nconst DEFAULT_SOCKET_DIR = '/tmp/mk-spec-memory';\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst RESERVED_COMMANDS = new Set(['list-tools', 'completion']);\n\nconst EXIT_SUCCESS = 0;\nconst EXIT_RUNTIME = 1;\nconst EXIT_USAGE = 64;\nconst EXIT_PROTOCOL = 69;\nconst EXIT_RETRYABLE = 75;\n\ntype OutputFormat = 'json' | 'text' | 'jsonl';\ntype ToolListMode = 'full' | 'compact' | 'names-only';\ntype CompletionShell = 'bash' | 'zsh';\n\ninterface ParsedCommand {\n  readonly command: string;\n  readonly format: OutputFormat;\n  readonly timeoutMs: number;\n  readonly sessionId?: string;\n  readonly warmOnly: boolean;\n  readonly toolListMode: ToolListMode;\n  readonly completionShell?: CompletionShell;\n  readonly args: Record<string, unknown>;\n  readonly help: boolean;\n  readonly version: boolean;\n}\n\ninterface CliIo {\n  readonly stdout: Pick<NodeJS.WriteStream, 'write'>;\n  readonly stderr: Pick<NodeJS.WriteStream, 'write'>;\n}\n\ninterface RepoPaths {\n  readonly opencodeDir: string;\n  readonly repoRoot: string;\n  readonly launcherPath: string;\n  readonly bridgePath: string;\n  readonly dbDir: string;\n  readonly packageJsonPath: string;\n}\n\ninterface BridgeProbeResult {\n  readonly status: string;\n  readonly reason?: string;\n}\n\ninterface BridgeModule {\n  readonly getIpcSocketPath: (serviceName: string, options?: { dbDir?: string }) => string;\n  readonly probeDaemon: (socketPath: string, options?: { timeoutMs?: number; deepProbe?: boolean }) => Promise<BridgeProbeResult>;\n  readonly toConnectionOptions: (socketPath: string) => string | net.NetConnectOpts;\n}\n\ninterface JsonRpcResponse {\n  readonly jsonrpc?: string;\n  readonly id?: unknown;\n  readonly result?: unknown;\n  readonly error?: {\n    readonly code?: number;\n    readonly message?: string;\n    readonly data?: unknown;\n  };\n}\n\ninterface InitializeResult {\n  readonly protocolVersion?: string;\n}\n\ninterface ToolResult {\n  readonly content?: Array<{ readonly type?: string; readonly text?: string }>;\n  readonly isError?: boolean;\n}\n\nclass CliUsageError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliUsageError';\n  }\n}\n\nclass CliRetryableError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliRetryableError';\n  }\n}\n\nclass CliProtocolError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliProtocolError';\n  }\n}\n\nclass JsonRpcError extends Error {\n  public readonly code?: number;\n  public readonly data?: unknown;\n\n  constructor(error: NonNullable<JsonRpcResponse['error']>) {\n    super(error.message ?? 'JSON-RPC request failed');\n    this.name = 'JsonRpcError';\n    this.code = error.code;\n    this.data = error.data;\n  }\n}\n\n// Awaits drain when the kernel pipe buffer is full: a fire-and-forget\n// write followed by process.exit() truncates large payloads at the pipe\n// buffer boundary (observed as exactly 64KB on darwin). Streams without\n// emitter methods (test fakes) resolve immediately.\nasync function writeLine(stream: Pick<NodeJS.WriteStream, 'write'>, value: string): Promise<void> {\n  const flushed = stream.write(`${value}\\n`);\n  if (flushed) return;\n  const drainable = stream as Pick<NodeJS.WriteStream, 'write'> & Partial<Pick<NodeJS.WriteStream, 'once' | 'off'>>;\n  if (typeof drainable.once !== 'function') return;\n  await new Promise<void>((resolve) => {\n    const settle = (): void => {\n      drainable.off?.('drain', settle);\n      drainable.off?.('error', settle);\n      drainable.off?.('close', settle);\n      resolve();\n    };\n    drainable.once?.('drain', settle);\n    drainable.once?.('error', settle);\n    drainable.once?.('close', settle);\n  });\n}\n\nfunction currentModulePath(): string {\n  return fileURLToPath(import.meta.url);\n}\n\nfunction findRepoPaths(startFile = currentModulePath()): RepoPaths {\n  let current = path.dirname(startFile);\n\n  while (true) {\n    const directOpencodeDir = path.basename(current) === '.opencode' ? current : path.join(current, '.opencode');\n    const launcherPath = path.join(directOpencodeDir, 'bin', 'mk-spec-memory-launcher.cjs');\n    const bridgePath = path.join(directOpencodeDir, 'bin', 'lib', 'launcher-ipc-bridge.cjs');\n    if (existsSync(launcherPath) && existsSync(bridgePath)) {\n      const repoRoot = path.dirname(directOpencodeDir);\n      return {\n        opencodeDir: directOpencodeDir,\n        repoRoot,\n        launcherPath,\n        bridgePath,\n        dbDir: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'),\n        packageJsonPath: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'package.json'),\n      };\n    }\n\n    const parent = path.dirname(current);\n    if (parent === current) {\n      throw new CliProtocolError('Unable to locate .opencode/bin launcher assets from CLI path');\n    }\n    current = parent;\n  }\n}\n\nfunction loadBridge(paths: RepoPaths): BridgeModule {\n  const require = createRequire(import.meta.url);\n  return require(paths.bridgePath) as BridgeModule;\n}\n\nfunction readCliVersion(paths: RepoPaths): string {\n  const require = createRequire(import.meta.url);\n  const pkg = require(paths.packageJsonPath) as { version?: unknown };\n  return typeof pkg.version === 'string' ? pkg.version : '0.0.0';\n}\n\nfunction toKebabCommand(name: string): string {\n  return name.replace(/_/g, '-');\n}\n\nfunction toCamelCommand(name: string): string {\n  return name.replace(/_([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandAliases(name: string): string[] {\n  return Array.from(new Set([name, toKebabCommand(name), toCamelCommand(name)]));\n}\n\nfunction usageText(command?: string): string {\n  const tool = command ? getToolDefinition(command) : null;\n  if (tool) {\n    return `spec-memory ${tool.name}\n\nDescription:\n  ${tool.description}\n\nAliases:\n  ${commandAliases(tool.name).join(', ')}\n\nInput schema:\n${JSON.stringify(tool.inputSchema, null, 2)}`;\n  }\n\n  return `spec-memory - daemon-backed CLI for mk-spec-memory\n\nUsage:\n  spec-memory list-tools [--format json|text|jsonl] [--compact|--names-only]\n  spec-memory completion bash|zsh\n  spec-memory <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--session-id ID] [--warm-only]\n  spec-memory <tool_name> --param value [--another-param value]\n\nExamples:\n  spec-memory list-tools --format text\n  spec-memory list-tools --compact\n  spec-memory completion zsh\n  spec-memory memory_stats --format json\n  spec-memory memory_search --query \"gold query battery\" --limit 3\n  spec-memory memory_context --json '{\"input\":\"resume\", \"mode\":\"resume\"}'\n\nExit codes:\n  0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error\n\nExit 69 recovery:\n  - Missing or stale dist entrypoint: run npm run build --workspace=@spec-kit/mcp-server.\n    - Backend protocol version changed: rebuild the CLI and daemon from the same checkout, then update any pinned client.\n    - Socket path or daemon config mismatch: check SPECKIT_IPC_SOCKET_DIR, socket length, and daemon config before retrying.`;\n}\n\nfunction parseCompletionShell(raw: string): CompletionShell {\n  if (raw === 'bash' || raw === 'zsh') return raw;\n  throw new CliUsageError('completion shell must be one of: bash, zsh');\n}\n\nfunction normalizeName(value: string): string {\n  return value.replace(/[-_]/g, '').toLowerCase();\n}\n\nfunction toCamelCaseFlag(value: string): string {\n  return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandMap(): Map<string, ToolDefinition> {\n  const map = new Map<string, ToolDefinition>();\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      const existing = map.get(alias);\n      if (existing && existing.name !== tool.name) {\n        throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n      }\n      map.set(alias, tool);\n    }\n  }\n  return map;\n}\n\nfunction getToolDefinition(command: string): ToolDefinition | null {\n  return commandMap().get(command) ?? null;\n}\n\nfunction inputPropertyNames(tool: ToolDefinition): string[] {\n  const schema = tool.inputSchema;\n  const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n    ? (schema as { readonly properties?: unknown }).properties\n    : null;\n  if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n  return Object.keys(properties);\n}\n\nfunction resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n  const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n  if (exact) return exact;\n\n  const normalized = normalizeName(rawFlag);\n  const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n  if (matched) return matched;\n\n  return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n}\n\nfunction parseValue(raw: string): unknown {\n  const trimmed = raw.trim();\n  if (trimmed === 'true') return true;\n  if (trimmed === 'false') return false;\n  if (trimmed === 'null') return null;\n  if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n    try {\n      return JSON.parse(trimmed) as unknown;\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      throw new CliUsageError(`Invalid JSON value: ${message}`);\n    }\n  }\n  return raw;\n}\n\nfunction parsePositiveInteger(raw: string, flagName: string): number {\n  if (!/^\\d+$/.test(raw)) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  const value = Number.parseInt(raw, 10);\n  if (!Number.isFinite(value) || value <= 0) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  return value;\n}\n\nfunction parseFormat(raw: string): OutputFormat {\n  if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n  throw new CliUsageError('--format must be one of: json, text, jsonl');\n}\n\nfunction parseInlineBoolean(raw: string, flagName: string): boolean {\n  if (raw === 'true' || raw === '1') return true;\n  if (raw === 'false' || raw === '0') return false;\n  throw new CliUsageError(`${flagName} must be true or false`);\n}\n\nfunction readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n  const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n  if (inline) return { value: inline[1], nextIndex: index + 1 };\n  const value = tokens[index + 1];\n  if (value === undefined) {\n    throw new CliUsageError(`${flagName} requires a value`);\n  }\n  return { value, nextIndex: index + 2 };\n}\n\nfunction parseJsonObject(raw: string): Record<string, unknown> {\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw) as unknown;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n    throw new CliUsageError('--json must be a JSON object');\n  }\n  return parsed as Record<string, unknown>;\n}\n\nfunction envFlagEnabled(name: string): boolean {\n  const raw = process.env[name];\n  if (raw === undefined || raw === null) return false;\n  return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n}\n\nfunction defaultWarmOnly(): boolean {\n  return envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_WARM_ONLY')\n    || envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME')\n    || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n    || envFlagEnabled('OPENCODE_PROMPT_TIME')\n    || envFlagEnabled('CODEX_PROMPT_TIME')\n    || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n}\n\nexport function parseCliArgs(argv: string[]): ParsedCommand {\n  const command = argv[0];\n  const warmOnlyDefault = defaultWarmOnly();\n  if (!command || command === '--help' || command === '-h') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n  }\n  if (command === '--version' || command === '-v') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n  }\n\n  let format: OutputFormat = 'json';\n  let timeoutMs = DEFAULT_TIMEOUT_MS;\n  let sessionId: string | undefined;\n  let warmOnly = warmOnlyDefault;\n  let toolListMode: ToolListMode = 'full';\n  let completionShell: CompletionShell | undefined;\n  let jsonPayload: Record<string, unknown> | null = null;\n  const tool = getToolDefinition(command);\n  const parsedArgs: Record<string, unknown> = {};\n  const tokens = argv.slice(1);\n  let index = 0;\n\n  while (index < tokens.length) {\n    const token = tokens[index];\n    if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n      completionShell = parseCompletionShell(token);\n      index += 1;\n      continue;\n    }\n    if (!token.startsWith('--')) {\n      throw new CliUsageError(`Unexpected positional argument: ${token}`);\n    }\n    const rawFlag = token.slice(2).split('=', 1)[0];\n    const option = `--${rawFlag}`;\n\n    if (rawFlag === 'help' || rawFlag === 'h') {\n      return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n    }\n    if (rawFlag === 'format') {\n      const read = readOptionValue(tokens, index, option);\n      format = parseFormat(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'timeout-ms') {\n      const read = readOptionValue(tokens, index, option);\n      timeoutMs = parsePositiveInteger(read.value, option);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'session-id') {\n      const read = readOptionValue(tokens, index, option);\n      sessionId = read.value;\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'warm-only') {\n      const inline = token.match(/^--[^=]+=(.*)$/);\n      warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'no-warm-only') {\n      warmOnly = false;\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'compact') {\n      toolListMode = 'compact';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'names-only') {\n      toolListMode = 'names-only';\n      index += 1;\n      continue;\n    }\n    if (rawFlag === 'json') {\n      const read = readOptionValue(tokens, index, option);\n      jsonPayload = parseJsonObject(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n\n    if (!tool) {\n      throw new CliUsageError(`Unknown command: ${command}`);\n    }\n\n    const propertyName = resolvePropertyName(rawFlag, tool);\n    const inline = token.match(/^--[^=]+=(.*)$/);\n    if (inline) {\n      parsedArgs[propertyName] = parseValue(inline[1]);\n      index += 1;\n      continue;\n    }\n\n    const next = tokens[index + 1];\n    if (next === undefined || next.startsWith('--')) {\n      parsedArgs[propertyName] = true;\n      index += 1;\n      continue;\n    }\n    parsedArgs[propertyName] = parseValue(next);\n    index += 2;\n  }\n\n  if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n    throw new CliUsageError('--json cannot be combined with per-parameter flags');\n  }\n\n  return {\n    command,\n    format,\n    timeoutMs,\n    sessionId,\n    warmOnly,\n    toolListMode,\n    completionShell,\n    args: jsonPayload ?? parsedArgs,\n    help: false,\n    version: false,\n  };\n}\n\nfunction validateCommand(parsed: ParsedCommand): { readonly tool: ToolDefinition; readonly args: Record<string, unknown> } | null {\n  if (RESERVED_COMMANDS.has(parsed.command)) return null;\n  const tool = getToolDefinition(parsed.command);\n  if (!tool) {\n    throw new CliUsageError(`Unknown command: ${parsed.command}`);\n  }\n\n  const args = { ...parsed.args };\n  const properties = new Set(inputPropertyNames(tool));\n  if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'sessionId') && properties.has('sessionId')) {\n    args.sessionId = parsed.sessionId;\n  } else if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'session_id') && properties.has('session_id')) {\n    args.session_id = parsed.sessionId;\n  }\n\n  return {\n    tool,\n    args: validateToolArgs(tool.name, args) as Record<string, unknown>,\n  };\n}\n\nfunction renderJson(value: unknown, format: OutputFormat): string {\n  if (format === 'jsonl') return JSON.stringify(value);\n  return JSON.stringify(value, null, 2);\n}\n\nfunction compactTool(tool: ToolDefinition): Record<string, unknown> {\n  return {\n    name: tool.name,\n    command: tool.name,\n    kebabCommand: toKebabCommand(tool.name),\n    camelCommand: toCamelCommand(tool.name),\n    aliases: commandAliases(tool.name),\n    description: tool.description,\n  };\n}\n\nfunction renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n  const payload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      tools: TOOL_DEFINITIONS.map((tool) => ({\n        name: tool.name,\n        command: tool.name,\n        kebabCommand: toKebabCommand(tool.name),\n        camelCommand: toCamelCommand(tool.name),\n        aliases: commandAliases(tool.name),\n        description: tool.description,\n        inputSchema: tool.inputSchema,\n      })),\n    },\n  };\n  const compactPayload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      tools: TOOL_DEFINITIONS.map(compactTool),\n    },\n  };\n  const namesOnlyPayload = {\n    status: 'ok',\n    data: {\n      count: TOOL_DEFINITIONS.length,\n      mode,\n      names: TOOL_DEFINITIONS.map((tool) => tool.name),\n    },\n  };\n\n  if (format === 'text') {\n    return TOOL_DEFINITIONS.map((tool) => tool.name).join('\\n');\n  }\n  if (mode === 'compact') return renderJson(compactPayload, format);\n  if (mode === 'names-only') return renderJson(namesOnlyPayload, format);\n  return renderJson(payload, format);\n}\n\nfunction completionWords(): string[] {\n  return ['list-tools', 'completion', ...TOOL_DEFINITIONS.map((tool) => tool.name)];\n}\n\nfunction shellWords(words: readonly string[]): string {\n  return words.join(' ');\n}\n\nfunction renderBashCompletion(): string {\n  const commands = shellWords(completionWords());\n  const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n  const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n  return `_spec_memory_completion() {\n  local cur\n  COMPREPLY=()\n  cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n  if [[ \\${COMP_CWORD} -eq 1 ]]; then\n    COMPREPLY=( $(compgen -W \"${commands}\" -- \"\\${cur}\") )\n    return 0\n  fi\n  case \"\\${COMP_WORDS[1]}\" in\n    completion) COMPREPLY=( $(compgen -W \"bash zsh\" -- \"\\${cur}\") ) ;;\n    list-tools) COMPREPLY=( $(compgen -W \"${listFlags}\" -- \"\\${cur}\") ) ;;\n    *) COMPREPLY=( $(compgen -W \"${commonFlags}\" -- \"\\${cur}\") ) ;;\n  esac\n}\ncomplete -F _spec_memory_completion spec-memory`;\n}\n\nfunction renderZshCompletion(): string {\n  const commands = shellWords(completionWords());\n  const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n  const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n  return `#compdef spec-memory\n_spec_memory() {\n  local -a commands common_flags list_flags shells\n  commands=(${commands})\n  common_flags=(${commonFlags})\n  list_flags=(${listFlags})\n  shells=(bash zsh)\n  if (( CURRENT == 2 )); then\n    _describe 'commands' commands\n    return\n  fi\n  case \\${words[2]} in\n    completion) _describe 'shells' shells ;;\n    list-tools) _describe 'flags' list_flags ;;\n    *) _describe 'flags' common_flags ;;\n  esac\n}\n_spec_memory \"$@\"`;\n}\n\nfunction renderCompletion(shell: CompletionShell): string {\n  return shell === 'bash' ? renderBashCompletion() : renderZshCompletion();\n}\n\nfunction isErrorPayload(payload: unknown): boolean {\n  return Boolean(payload)\n    && typeof payload === 'object'\n    && !Array.isArray(payload)\n    && (payload as { readonly status?: unknown }).status === 'error';\n}\n\nfunction extractToolPayload(toolName: string, result: unknown): { readonly payload: unknown; readonly isError: boolean } {\n  const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n  const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n  if (firstText) {\n    try {\n      return {\n        payload: JSON.parse(firstText) as unknown,\n        isError: toolResult?.isError === true,\n      };\n    } catch {\n      return {\n        payload: {\n          status: toolResult?.isError ? 'error' : 'ok',\n          tool: toolName,\n          text: firstText,\n        },\n        isError: toolResult?.isError === true,\n      };\n    }\n  }\n  return {\n    payload: {\n      status: toolResult?.isError ? 'error' : 'ok',\n      tool: toolName,\n      result,\n    },\n    isError: toolResult?.isError === true,\n  };\n}\n\nfunction renderPayload(payload: unknown, format: OutputFormat): string {\n  if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n  if (payload && typeof payload === 'object' && !Array.isArray(payload)) {\n    const record = payload as Record<string, unknown>;\n    if (typeof record.summary === 'string') return record.summary;\n    if (typeof record.error === 'string') return record.error;\n    if (typeof record.message === 'string') return record.message;\n  }\n  return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n}\n\nfunction isProtocolMismatch(error: unknown): boolean {\n  if (error instanceof JsonRpcError && error.code === -32002) return true;\n  const message = error instanceof Error ? error.message : String(error);\n  return /protocol.*(mismatch|changed|version)/i.test(message);\n}\n\nfunction isRetryableError(error: unknown): boolean {\n  if (error instanceof CliRetryableError) return true;\n  if (error instanceof JsonRpcError && error.code === -32001) return true;\n  const message = error instanceof Error ? error.message : String(error);\n  return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n}\n\nfunction exitCodeForError(error: unknown): number {\n  if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n  if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n  if (isRetryableError(error)) return EXIT_RETRYABLE;\n  if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n  return EXIT_RUNTIME;\n}\n\nfunction levenshteinDistance(left: string, right: string): number {\n  const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n  const current = new Array<number>(right.length + 1);\n\n  for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n    current[0] = leftIndex;\n    for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n      const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n      current[rightIndex] = Math.min(\n        current[rightIndex - 1] + 1,\n        previous[rightIndex] + 1,\n        previous[rightIndex - 1] + cost,\n      );\n    }\n    previous.splice(0, previous.length, ...current);\n  }\n\n  return previous[right.length];\n}\n\nfunction closestCommand(command: string): string | undefined {\n  const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n  targets.set('completion', 'completion');\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      targets.set(alias, tool.name);\n    }\n  }\n\n  let best: { readonly command: string; readonly distance: number } | null = null;\n  for (const [alias, canonical] of targets) {\n    const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n    if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n      best = { command: canonical, distance };\n    }\n  }\n\n  if (!best) return undefined;\n  const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n  return best.distance <= threshold ? best.command : undefined;\n}\n\nfunction unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n  const match = message.match(/^Unknown command: (.+)$/);\n  if (!match) return null;\n  return {\n    hint: 'Try `list-tools` to see available commands.',\n    suggestion: closestCommand(match[1]),\n  };\n}\n\nfunction socketPathTooLong(socketPath: string): boolean {\n  if (socketPath.startsWith('tcp://')) return false;\n  return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n}\n\n// `mode: 0o700` only applies when mkdir CREATES the dir. A pre-existing socket dir\n// (e.g. an attacker-planted dir or symlink on a shared host) is not protected by the\n// mkdir above, so the client must refuse to probe/connect under a dir it does not own,\n// a symlinked dir, or a group/world-writable dir, and must reject a foreign-owned or\n// symlinked socket node — otherwise a fake daemon could answer initialize and spoof results.\nfunction assertSocketPerimeter(socketDir: string): void {\n  const dirLink = lstatSync(socketDir);\n  if (dirLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket directory is a symlink; refusing to connect: ${socketDir}`);\n  }\n  const dirStat = statSync(socketDir);\n  const uid = typeof process.getuid === 'function' ? process.getuid() : null;\n  if (uid !== null && dirStat.uid !== uid) {\n    throw new CliProtocolError(`IPC socket directory is not owned by the current user (uid ${dirStat.uid} != ${uid}): ${socketDir}`);\n  }\n  if ((dirStat.mode & 0o022) !== 0) {\n    throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n  }\n  const socketPath = path.join(socketDir, SOCKET_FILE_NAME);\n  let nodeLink;\n  try {\n    nodeLink = lstatSync(socketPath);\n  } catch (error: unknown) {\n    const code = error && typeof error === 'object' && 'code' in error ? (error as NodeJS.ErrnoException).code : undefined;\n    if (code === 'ENOENT') return;\n    throw error;\n  }\n  if (nodeLink.isSymbolicLink()) {\n    throw new CliProtocolError(`IPC socket path is a symlink; refusing to connect: ${socketPath}`);\n  }\n  if (uid !== null && nodeLink.uid !== uid) {\n    throw new CliProtocolError(`IPC socket is not owned by the current user (uid ${nodeLink.uid} != ${uid}): ${socketPath}`);\n  }\n}\n\nfunction ensureSocketEnvironment(): void {\n  if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n    process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n  }\n  const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n  if (!socketDir || socketDir.startsWith('tcp://')) return;\n  mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n  assertSocketPerimeter(socketDir);\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction spawnLauncher(paths: RepoPaths): void {\n  const child = spawn(process.execPath, [paths.launcherPath], {\n    cwd: paths.repoRoot,\n    env: process.env,\n    detached: true,\n    stdio: 'ignore',\n  });\n  child.unref();\n}\n\nasync function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n  const deadline = Date.now() + timeoutMs;\n  let lastReason = 'not probed';\n\n  while (Date.now() <= deadline) {\n    const remaining = Math.max(1, deadline - Date.now());\n    const probe = await bridge.probeDaemon(socketPath, {\n      timeoutMs: Math.min(remaining, 5000),\n      deepProbe: true,\n    });\n    if (probe.status === 'alive') return;\n    lastReason = probe.reason ?? probe.status;\n    await sleep(100);\n  }\n\n  throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n}\n\nclass JsonRpcSocketClient {\n  private nextId = 1;\n  private readonly decoder = new StringDecoder('utf8');\n\n  private constructor(\n    private readonly socket: net.Socket,\n  ) {}\n\n  static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n    return new Promise((resolve, reject) => {\n      let socket: net.Socket;\n      let settled = false;\n      const finish = (error?: Error): void => {\n        if (settled) return;\n        settled = true;\n        clearTimeout(timer);\n        socket.off?.('connect', onConnect);\n        socket.off?.('error', onError);\n        if (error) {\n          socket.destroy?.();\n          reject(error);\n          return;\n        }\n        resolve(new JsonRpcSocketClient(socket));\n      };\n      const onConnect = (): void => finish();\n      const onError = (error: Error): void => finish(error);\n      const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n      timer.unref?.();\n\n      try {\n        const connectionOptions = bridge.toConnectionOptions(socketPath);\n        socket = typeof connectionOptions === 'string'\n          ? net.createConnection(connectionOptions)\n          : net.createConnection(connectionOptions);\n      } catch (error: unknown) {\n        clearTimeout(timer);\n        reject(error instanceof Error ? error : new Error(String(error)));\n        return;\n      }\n      socket.once('connect', onConnect);\n      socket.once('error', onError);\n    });\n  }\n\n  notify(method: string, params?: unknown): void {\n    const frame = params === undefined\n      ? { jsonrpc: '2.0', method }\n      : { jsonrpc: '2.0', method, params };\n    this.socket.write(`${JSON.stringify(frame)}\\n`);\n  }\n\n  request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n    const id = this.nextId++;\n    const request = { jsonrpc: '2.0', id, method, params };\n    return new Promise((resolve, reject) => {\n      let buffer = '';\n      let settled = false;\n\n      const cleanup = (): void => {\n        clearTimeout(timer);\n        this.socket.off('data', onData);\n        this.socket.off('error', onError);\n        this.socket.off('close', onClose);\n      };\n      const finish = (error: unknown, value?: unknown): void => {\n        if (settled) return;\n        settled = true;\n        cleanup();\n        if (error) {\n          reject(error);\n          return;\n        }\n        resolve(value);\n      };\n      const onData = (chunk: Buffer | string): void => {\n        buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n        let newlineIndex = buffer.indexOf('\\n');\n        while (newlineIndex !== -1) {\n          const line = buffer.slice(0, newlineIndex).trim();\n          buffer = buffer.slice(newlineIndex + 1);\n          newlineIndex = buffer.indexOf('\\n');\n          if (!line) continue;\n          let parsed: JsonRpcResponse;\n          try {\n            parsed = JSON.parse(line) as JsonRpcResponse;\n          } catch {\n            continue;\n          }\n          if (parsed.id !== id) continue;\n          if (parsed.error) {\n            finish(new JsonRpcError(parsed.error));\n            return;\n          }\n          finish(null, parsed.result);\n          return;\n        }\n      };\n      const onError = (error: Error): void => finish(error);\n      const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n      const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n      timer.unref?.();\n\n      this.socket.on('data', onData);\n      this.socket.once('error', onError);\n      this.socket.once('close', onClose);\n      this.socket.write(`${JSON.stringify(request)}\\n`);\n    });\n  }\n\n  close(): void {\n    this.socket.end();\n    this.socket.destroy();\n  }\n}\n\nasync function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n  const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n  if (initialProbe.status === 'alive') return;\n  if (warmOnly) {\n    throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n  }\n  spawnLauncher(paths);\n  await waitForDaemon(socketPath, bridge, timeoutMs);\n}\n\nasync function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, warmOnly: boolean): Promise<unknown> {\n  ensureSocketEnvironment();\n  const paths = findRepoPaths();\n  const bridge = loadBridge(paths);\n  const socketPath = bridge.getIpcSocketPath('mk-spec-memory', { dbDir: paths.dbDir });\n  if (socketPathTooLong(socketPath)) {\n    throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n  }\n\n  await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n\n  const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n  try {\n    const initialize = await client.request('initialize', {\n      protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n      capabilities: {},\n      clientInfo: { name: 'spec-memory-cli', version: readCliVersion(paths) },\n    }, timeoutMs) as InitializeResult;\n    if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n      throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n    }\n    client.notify('notifications/initialized');\n    return await client.request('tools/call', { name: toolName, arguments: args }, timeoutMs);\n  } finally {\n    client.close();\n  }\n}\n\nexport async function runSpecMemoryCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n  try {\n    const parsed = parseCliArgs(argv);\n    if (parsed.help) {\n      await writeLine(io.stdout, usageText(parsed.command || undefined));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.version) {\n      await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'list-tools') {\n      await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n      return EXIT_SUCCESS;\n    }\n    if (parsed.command === 'completion') {\n      if (!parsed.completionShell) {\n        throw new CliUsageError('completion requires a shell: bash or zsh');\n      }\n      await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n      return EXIT_SUCCESS;\n    }\n\n    const validated = validateCommand(parsed);\n    if (!validated) {\n      throw new CliUsageError(`Unknown command: ${parsed.command}`);\n    }\n    const result = await callTool(validated.tool.name, validated.args, parsed.timeoutMs, parsed.warmOnly);\n    const { payload, isError } = extractToolPayload(validated.tool.name, result);\n    await writeLine(io.stdout, renderPayload(payload, parsed.format));\n    return isError || isErrorPayload(payload) ? EXIT_RUNTIME : EXIT_SUCCESS;\n  } catch (error: unknown) {\n    const exitCode = exitCodeForError(error);\n    const message = error instanceof Error ? error.message : String(error);\n    const unknownCommand = unknownCommandContext(message);\n    const payload = {\n      status: 'error',\n      error: message,\n      exitCode,\n      ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n      ...(unknownCommand?.suggestion ? { suggestion: unknownCommand.suggestion } : {}),\n    };\n    const format = (() => {\n      try {\n        return parseCliArgs(argv).format;\n      } catch {\n        return 'text' as OutputFormat;\n      }\n    })();\n    if (format === 'json' || format === 'jsonl') {\n      await writeLine(io.stderr, renderJson(payload, format));\n    } else {\n      await writeLine(io.stderr, [\n        `ERROR: ${message}`,\n        unknownCommand ? `Hint: ${unknownCommand.hint}` : null,\n        unknownCommand?.suggestion ? `Did you mean \\`${unknownCommand.suggestion}\\`?` : null,\n      ].filter((line): line is string => Boolean(line)).join('\\n'));\n    }\n    return exitCode;\n  }\n}\n\nfunction isCliEntrypoint(): boolean {\n  const invoked = process.argv[1];\n  if (!invoked) return false;\n  return path.resolve(invoked) === path.resolve(currentModulePath());\n}\n\nexport const __testing = {\n  DEFAULT_SOCKET_DIR,\n  EXIT_PROTOCOL,\n  EXIT_RETRYABLE,\n  EXIT_RUNTIME,\n  EXIT_USAGE,\n  commandMap,\n  commandAliases,\n  assertSocketPerimeter,\n  ensureSocketEnvironment,\n  exitCodeForError,\n  findRepoPaths,\n  isErrorPayload,\n  closestCommand,\n  renderCompletion,\n  renderToolList,\n  resolvePropertyName,\n};\n\nif (isCliEntrypoint()) {\n  // Natural exit via process.exitCode: a hard process.exit() drops any\n  // stdout bytes still queued behind the kernel pipe buffer, truncating\n  // large payloads. Pending pipe writes keep the event loop alive until\n  // they flush; all sockets and timers are closed or unref'd by here.\n  process.exitCode = await runSpecMemoryCli(process.argv.slice(2));\n}","lineStart":1,"lineEnd":1084,"totalLines":1084,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","time":{"start":1781763114658,"end":1781763114664}},"metadata":{"openai":{"itemId":"fc_0ab8fbf40fc27ea4016a338c2a44048191b0c3bc54de8ebfd5"}},"id":"prt_ed95b864d001V2Fuf3oJB7eejm","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95b5aba001hQutA9bBaBQJ5v"}}
{"type":"tool_use","timestamp":1781763114731,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"read","callID":"call_21fNr0lHWrsYvLfA4ReaRorh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":1258,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n1258: // Launcher-local factory that pre-seeds the launcher-aware defaults (writeLease/shouldExitLauncher/\n1259: // onRssBreach) the shared lib intentionally leaves as generic no-ops. Keeps the launcher's exported\n1260: // createModelServerSupervisor + launchModelServer(options) seam byte-equivalent to pre-extraction HEAD.\n1261: // Explicit caller options still win via the trailing spread for targeted writeLease injection.\n1262: function createModelServerSupervisor(options = {}) {\n1263:   return baseCreateModelServerSupervisor({\n1264:     writeLease: () => writeLeaseFile(),\n1265:     shouldExitLauncher: () => launcherShutdownInProgress,\n1266:     onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n1267:     ...options,\n1268:   });\n1269: }\n1270: \n1271: function launchModelServer(options = null) {\n1272:   if (options && typeof options === 'object') {\n1273:     return createModelServerSupervisor(options).launch();\n1274:   }\n1275:   return hfControl.launch();\n1276: }\n1277: \n1278: function startModelServerDemandListener(options = {}) {\n1279:   return hfControl.startDemandListener(options);\n1280: }\n1281: \n1282: function stopModelServerDemandListener() {\n1283:   return hfControl.stopDemandListener();\n1284: }\n1285: \n1286: const BOOTSTRAP_LOCK_OWNER_FILE = 'owner.pid';\n1287: \n1288: // Returns the pid recorded inside the lock dir, or null when no readable pid\n1289: // stamp exists (legacy lock dirs, or a holder that died before stamping).\n1290: function readBootstrapLockOwnerPid() {\n1291:   try {\n1292:     const raw = fs.readFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), 'utf8').trim();\n1293:     const pid = Number.parseInt(raw, 10);\n1294:     return Number.isInteger(pid) && pid > 0 ? pid : null;\n1295:   } catch {\n1296:     return null;\n1297:   }\n1298: }\n1299: \n1300: // Reclaim a stale bootstrap lockdir. A lock is reclaimable as soon as its\n1301: // recorded holder is provably dead; the mtime TTL is only a fallback for lock\n1302: // dirs with no readable pid stamp (legacy dirs) or a holder whose liveness\n1303: // cannot be determined. Without the dead-holder check, a holder killed less than\n1304: // BOOTSTRAP_LOCK_STALE_MS ago wedges every requireLock respawn for the full wait\n1305: // deadline (the TTL exceeds the deadline by design for a slow-but-live build).\n1306: function removeStaleBootstrapLock(staleMs = BOOTSTRAP_LOCK_STALE_MS) {\n1307:   let ageMs;\n1308:   try {\n1309:     ageMs = Date.now() - fs.statSync(lockDir).mtimeMs;\n1310:   } catch (error) {\n1311:     if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;\n1312:     throw error;\n1313:   }\n1314:   const ownerPid = readBootstrapLockOwnerPid();\n1315:   const ownerDead = ownerPid !== null && processLiveness(ownerPid) === 'dead';\n1316:   if (!ownerDead && ageMs <= staleMs) {\n1317:     return false;\n1318:   }\n1319:   // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n1320:   // racer wins the rename; a successor that mkdir'd a fresh lockDir after our stat\n1321:   // creates a new inode that our rename/rmSync cannot touch, so we never delete a\n1322:   // live successor lock. A losing racer's rename throws ENOENT and falls through to\n1323:   // the outer retry.\n1324:   const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n1325:   try {\n1326:     fs.renameSync(lockDir, staleClaim);\n1327:     fs.rmSync(staleClaim, { recursive: true, force: true });\n1328:     const reason = ownerDead ? `dead holder pid=${ownerPid}` : `mtime ${Math.round(ageMs / 1000)}s old`;\n1329:     log(`reclaiming stale bootstrap lock ${rel(lockDir)} (${reason})`);\n1330:     return true;\n1331:   } catch (error) {\n1332:     if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;\n1333:     throw error;\n1334:   }\n1335: }\n1336: \n1337: async function acquireBootstrapLock(options = {}) {\n1338:   const requireLock = options.requireLock === true;\n1339:   fs.mkdirSync(dbDir, { recursive: true });\n1340:   const deadline = Date.now() + (options.timeoutMs ?? 120000);\n1341:   const staleMs = options.staleMs ?? BOOTSTRAP_LOCK_STALE_MS;\n1342:   const retrySleepMs = options.retrySleepMs ?? 1000;\n1343:   while (true) {\n1344:     try {\n1345:       fs.mkdirSync(lockDir);\n1346:       // Stamp the holder pid so a later launcher can reclaim this lock the\n1347:       // instant we die, instead of waiting out the mtime TTL. Best-effort: a\n1348:       // failed stamp degrades to the TTL path, never blocks acquisition.\n1349:       try {\n1350:         fs.writeFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), String(process.pid), { mode: 0o600 });\n1351:       } catch { /* TTL fallback covers an unstamped lock */ }\n1352:       return true;\n1353:     } catch (error) {\n1354:       if (error.code !== 'EEXIST') {\n1355:         throw error;\n1356:       }\n1357:       if (removeStaleBootstrapLock(staleMs)) {\n1358:         continue;\n1359:       }\n1360:       if (artifactsReady() && !requireLock) {\n1361:         return false;\n1362:       }\n1363:       if (Date.now() > deadline) {\n1364:         throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n1365:       }\n1366:       await sleep(retrySleepMs);\n1367:     }\n1368:   }\n1369: }\n1370: \n1371: function launchServer() {\n1372:   if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n1373:     log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n1374:     return false;\n1375:   }\n1376:   if (shouldSkipLaunch(childProcess)) {\n1377:     log('launchServer skipped: a context-server child is already running in this launcher process');\n1378:     return false;\n1379:   }\n1380:   if (!crashLoopGuard) crashLoopGuard = createCrashLoopGuard(getCrashLoopConfig());\n1381:   if (supervisorRelaunchTimer) {\n1382:     clearTimeout(supervisorRelaunchTimer);\n1383:     supervisorRelaunchTimer = null;\n1384:   }\n1385:   const server = path.join(kitDir, 'mcp_server', 'dist', 'context-server.js');\n1386:   const nodeArgs = getContextServerNodeArgs();\n1387:   const reelectionEnabled = daemonReelectionEnabled();\n1388:   const spawnIo = contextServerSpawnIo(reelectionEnabled);\n1389:   childProcess = spawn(process.execPath, [...nodeArgs, server], {\n1390:     cwd: root,\n1391:     env: {\n1392:       ...process.env,\n1393:       SPECKIT_BACKEND_ONLY: '1',\n1394:     },\n1395:     stdio: spawnIo.stdio,\n1396:     detached: spawnIo.detached,\n1397:   });\n1398:   // Re-election only: let the launcher exit without keeping the detached daemon tethered to it.\n1399:   if (reelectionEnabled) childProcess.unref();\n1400:   const childPid = childProcess.pid;\n1401:   const refreshed = refreshOwnerLeaseFile(process.pid);\n1402:   if (!refreshed) {\n1403:     log('owner lease refresh failed after child spawn; launcher pid remains the recorded owner');\n1404:   }\n1405:   startOwnerLeaseHeartbeat(process.pid);\n1406:   writeLeaseFile(childPid);\n1407:   startRssWatchdog(childPid);\n1408: \n1409:   childProcess.on('exit', (code, signal) => {\n1410:     if (launcherShutdownInProgress) {\n1411:       return;\n1412:     }\n1413:     if (code === EXIT_DB_LOCK_HELD) {\n1414:       void handleDbLockHeldChildExit();\n1415:       return;\n1416:     }\n1417:     const result = superviseChildExit(\n1418:       { code, signal, childPid, intentional: false },\n1419:       {\n1420:         crashLoopGuard,\n1421:         clearLease: clearAllLeaseFiles,\n1422:         reapProcessGroup: reapProcessTreeGroups,\n1423:         mirrorSignal: (exitSignal) => process.kill(process.pid, exitSignal),\n1424:         exit: (exitCode) => process.exit(exitCode),\n1425:         scheduleRelaunch: (backoffMs) => {\n1426:           log(`context-server child exited code=${code ?? 'null'} signal=${signal ?? 'null'}; relaunching in ${backoffMs}ms`);\n1427:           supervisorRelaunchTimer = setTimeout(() => {\n1428:             // Owner-disposal race guard: by the time the backoff fires, re-check that this\n1429:             // launcher is still live AND its owning runtime is still present. Respawning the\n1430:             // daemon under a disposing session is what produced the SIGTERM/relaunch flap that\n1431:             // dropped every bridged session's transport. Crash-recovery and RSS-recycle are\n1432:             // unaffected — both run with the owning runtime alive and no shutdown in progress.\n1433:             if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) {\n1434:               log('relaunch aborted: launcher shutting down or owning runtime gone; releasing lease and exiting');\n1435:               clearAllLeaseFiles();\n1436:               process.exit(0);\n1437:               return;\n1438:             }\n1439:             launchServer();\n1440:           }, backoffMs);\n1441:           supervisorRelaunchTimer.unref?.();\n1442:         },\n1443:       },\n1444:     );\n1445:     if (result.action === 'give-up') {\n1446:       log(`context-server crash loop detected after ${result.deathsInWindow} deaths; clearing lease and mirroring child exit`);\n1447:     }\n1448:   });\n1449: \n1450:   childProcess.on('error', (error) => {\n1451:     log(error.stack || error.message);\n1452:     process.exit(1);\n1453:   });\n1454:   if (rssBreachSelfExitInProgress) {\n1455:     rssBreachSelfExitInProgress = false;\n1456:   }\n1457:   return true;\n1458: }\n1459: \n1460: // Pure decision for the exit-86 flow (exported for tests). A lease whose\n1461: // owner is THIS launcher is NOT a bridge target: in supervised mode the\n1462: // pid-lease records the launcher's own pid, so after its child exits 86 the\n1463: // lease still reads \"held by a live owner\" — us. Bridging would deep-probe\n1464: // our own dead socket and route into a self-reap. Only a DIFFERENT live\n1465: // owner is bridgeable; a self-held lease means a non-daemon process (e.g. a\n1466: // standalone save mid-run) owns the database lock, so retry in place.\n1467: function decideDbLockHeldAction({ leaseHeld, leaseOwnerPid, selfPid, attempt, maxRetries }) {\n1468:   if (attempt > maxRetries + 2) return { action: 'report', reason: 'db-lock-held-persistent' };\n1469:   if (leaseHeld && leaseOwnerPid !== selfPid) return { action: 'bridge' };\n1470:   if (attempt <= maxRetries) return { action: 'retry', backoffMs: 2000 * 2 ** (attempt - 1) };\n1471:   return { action: 'report', reason: 'db-lock-held' };\n1472: }\n1473: \n1474: // The daemon refused to become a second writer on a database another live\n1475: // process holds. Prefer bridging to that owner; when the holder is not a\n1476: // bridgeable daemon (e.g. a maintenance script mid-run), retry the launch a\n1477: // few times so a short-lived holder can finish, then report and exit clean.\n1478: async function handleDbLockHeldChildExit() {\n1479:   dbLockHeldRetries += 1;\n1480:   const leaseResult = isLeaseHeld();\n1481:   const decision = decideDbLockHeldAction({\n1482:     leaseHeld: leaseResult.held,\n1483:     leaseOwnerPid: leaseResult.ownerPid,\n1484:     selfPid: process.pid,\n1485:     attempt: dbLockHeldRetries,\n1486:     maxRetries: DB_LOCK_HELD_MAX_RETRIES,\n1487:   });\n1488:   if (decision.action === 'bridge') {\n1489:     log(`context-server exited: database single-writer lock held; bridging to live owner pid=${leaseResult.ownerPid}`);\n1490:     await bridgeOrReportLeaseHeldAndExit(leaseResult);\n1491:     return;\n1492:   }\n1493:   if (decision.action === 'retry') {\n1494:     log(`database single-writer lock held by a non-bridgeable holder; retrying launch in ${decision.backoffMs}ms (attempt ${dbLockHeldRetries}/${DB_LOCK_HELD_MAX_RETRIES})`);\n1495:     if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n1496:     supervisorRelaunchTimer = setTimeout(() => {\n1497:       // Abort if the owning runtime vanished (shutdown in progress, or the launcher\n1498:       // was reparented to init without a SIGTERM) — same guard as the primary\n1499:       // backoff-relaunch path, so neither relaunches a daemon under a disposed session.\n1500:       if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) return;\n1501:       launchServer();\n1502:     }, decision.backoffMs);\n1503:     if (supervisorRelaunchTimer.unref) supervisorRelaunchTimer.unref();\n1504:     return;\n1505:   }\n1506:   log('database single-writer lock still held after launch retries; reporting and exiting');\n1507:   writeLeaseHeldJsonRpcError(\n1508:     { ownerPid: leaseResult.ownerPid ?? 'unknown', startedAt: leaseResult.startedAt ?? new Date().toISOString() },\n1509:     decision.reason,\n1510:   );\n1511:   clearAllLeaseFiles();\n1512:   process.exit(0);\n1513: }\n1514: \n1515: async function shutdownLauncherForSignal(signal) {\n1516:   if (launcherShutdownInProgress) return;\n1517:   launcherShutdownInProgress = true;\n1518:   if (rssWatchdogTimer) clearInterval(rssWatchdogTimer);\n1519:   if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n1520:   clearOwnerLeaseHeartbeat();\n1521:   hfControl.clearTimers();\n1522:   await hfControl.stopDemandListener();\n1523: \n1524:   // Re-election release path (on by default): release the detached context-server for a live secondary to adopt\n1525:   // instead of killing it. Reap only the non-adoptable model-server, KEEP the daemon lease (its socket\n1526:   // stays findable for adoption), drop only OWNERSHIP, and exit without killing the daemon. When the\n1527:   // flag is off this branch is skipped and the original kill path below runs unchanged.\n1528:   if (shouldReleaseDaemonForReelection({ enabled: daemonReelectionEnabled(), hasLiveDaemon: isChildRunning(childProcess) })) {\n1529:     const releasedModelServer = hfControl.getChild();\n1530:     if (isChildRunning(releasedModelServer)) {\n1531:       hfControl.reapProcessTree(releasedModelServer.pid);\n1532:       releasedModelServer.kill(signal);\n1533:       // Escalate to SIGKILL if the non-adoptable model-server does not exit within the grace window,\n1534:       // so the release path does not leave a wedged sidecar behind on its way out.\n1535:       const exited = await waitForChildExit(releasedModelServer, RESPAWN_REAP_GRACE_MS);\n1536:       if (!exited && isChildRunning(releasedModelServer)) {\n1537:         releasedModelServer.kill('SIGKILL');\n1538:       }\n1539:     }\n1540:     log('daemon re-election: releasing context-server for adoption (not killing); dropping ownership lease only');\n1541:     // The process 'exit' handler clears BOTH leases; detach it first so the daemon lease (its socket\n1542:     // path) survives for a secondary to adopt. Ownership is still dropped explicitly below.\n1543:     process.removeListener('exit', clearAllLeaseFiles);\n1544:     clearOwnerLeaseFile();\n1545:     process.exit(0);\n1546:     return;\n1547:   }\n1548: \n1549:   const children = [];\n1550:   if (isChildRunning(childProcess)) {\n1551:     children.push({ child: childProcess, label: 'context-server' });\n1552:   }\n1553:   const modelServerChild = hfControl.getChild();\n1554:   if (isChildRunning(modelServerChild)) {\n1555:     children.push({ child: modelServerChild, label: 'hf-model-server' });\n1556:   }\n1557: \n1558:   if (children.length === 0) {\n1559:     clearAllLeaseFiles();\n1560:     process.exit(128);\n1561:     return;\n1562:   }\n1563: \n1564:   for (const { child, label } of children) {\n1565:     if (label === 'hf-model-server') {\n1566:       hfControl.reapProcessTree(child.pid);\n1567:     }\n1568:     child.kill(signal);\n1569:   }\n1570: \n1571:   const exited = await Promise.race([\n1572:     Promise.all(children.map(({ child }) => waitForChildExit(child, RESPAWN_REAP_GRACE_MS))).then((results) => results.every(Boolean)),\n1573:     sleep(RESPAWN_REAP_GRACE_MS).then(() => false),\n1574:   ]);\n1575:   if (!exited) {\n1576:     for (const { child } of children) {\n1577:       if (isChildRunning(child)) child.kill('SIGKILL');\n1578:     }\n1579:   }\n1580:   clearAllLeaseFiles();\n1581:   process.exit(128);\n1582: }\n1583: \n1584: function installSignalHandlers() {\n1585:   for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n1586:     process.on(signal, () => {\n1587:       void shutdownLauncherForSignal(signal).catch((error) => {\n1588:         log(error.stack || error.message);\n1589:         clearAllLeaseFiles();\n1590:         process.exit(128);\n1591:       });\n1592:     });\n1593:   }\n1594:   process.on('uncaughtException', (err) => {\n1595:     try {\n1596:       clearAllLeaseFiles();\n1597:     } catch {\n1598:       // Preserve default uncaughtException crash behavior.\n1599:     }\n1600:     throw err;\n1601:   });\n1602: }\n1603: \n1604: async function main() {\n1605:   loadProjectEnvFiles();\n1606:   const started = now();\n1607:   const actions = [];\n1608:   let lockHeld = false;\n1609:   let staleRespawnLock = null;\n1610: \n1611:   try {\n1612:     installSignalHandlers();\n1613:     // Lease cleanup runs unconditionally regardless of child termination path.\n1614:     process.on('exit', clearAllLeaseFiles);\n1615:     refreshPaths();\n1616: \n1617:     const strictSingleWriter = !isStrictModeDisabled(process.env.MK_SPEC_MEMORY_STRICT_SINGLE_WRITER);\n1618:     ownerLeaseRequired = strictSingleWriter;\n1619:     if (strictSingleWriter) {\n1620:       const legacyLeaseResult = isLeaseHeld();\n1621:       if (legacyLeaseResult.held && legacyLeaseResult.legacyPath && !legacyLeaseResult.staleReclaimable) {\n1622:         await bridgeOrReportLeaseHeldAndExit(legacyLeaseResult);\n1623:         return;\n1624:       }\n1625:     }\n1626: \n1627:     ensureLayout(actions);\n1628:     refreshPaths();\n1629:     enforceStandaloneCodeGraphDb(actions);\n1630: \n1631:     if (strictSingleWriter) {\n1632:       const ownerLeaseResult = acquireOwnerLeaseFile();\n1633:       if (!ownerLeaseResult.acquired) {\n1634:         log(`liveOwnerDetected: ownerPid=${ownerLeaseResult.holder.ownerPid} classification=${ownerLeaseResult.classification}`);\n1635:         await bridgeOrReportLeaseHeldAndExit(leaseResultForOwnerLease(ownerLeaseResult.holder));\n1636:         return;\n1637:       }\n1638: \n1639:       const leaseResult = isLeaseHeld();\n1640:       if (leaseResult.held && !leaseResult.staleReclaimable) {\n1641:         clearOwnerLeaseFile();\n1642:         await bridgeOrReportLeaseHeldAndExit(leaseResult);\n1643:         return;\n1644:       }\n1645:       if (leaseResult.staleReclaimable) {\n1646:         log(`staleReclaimed: true${leaseResult.legacyPath ? ' (legacy path)' : ''}`);\n1647:         // A re-election daemon released by a disposing owner (or orphaned by a crashed owner) stays\n1648:         // alive under this stale lease, which records the live daemon as childPid. ADOPT it: if the\n1649:         // daemon is still alive and its recorded socket is bridgeable, bridge to the live socket\n1650:         // instead of reaping and respawning. This reuses the warm daemon and never tears down a\n1651:         // daemon a live secondary may still be bridged to. The reap+respawn path below runs only\n1652:         // when the daemon is genuinely gone.\n1653:         const staleLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n1654:         const orphanChildPid = staleLease?.childPid;\n1655:         if (Number.isInteger(orphanChildPid) && orphanChildPid > 0 && processLiveness(orphanChildPid) !== 'dead') {\n1656:           const adoptResult = { ...leaseResult, socketPath: staleLease.socketPath || leaseResult.socketPath };\n1657:           const readiness = bridgeReadiness(adoptResult);\n1658:           if (readiness.ready) {\n1659:             // A live pid that still owns its socket can be WEDGED: its event loop is starved, so the\n1660:             // kernel accepts the connection into the listen backlog but the daemon never services a\n1661:             // request. bridgeReadiness only proves the socket file exists — adopting on that alone\n1662:             // bridges every client into a dead end, and the launcher can never recover because the pid\n1663:             // stays alive forever and is never reaped. Require a real JSON-RPC reply (the same deep\n1664:             // probe the dead-socket decision uses, with its tuned timeout + retry that tolerates a\n1665:             // busy-but-responsive daemon) before adopting. A non-responsive daemon falls through to the\n1666:             // reap+respawn block below, which tears it down and spawns a fresh one under the lock.\n1667:             const { probeLeaseHolderWithRetries } = loadBridgeModule();\n1668:             let probe;\n1669:             try {\n1670:               probe = await probeLeaseHolderWithRetries(readiness.socketPath, {\n1671:                 onRetry: (attempt, total, result) => log(`stale-reclaim adopt probe ${attempt}/${total} not alive (${result.reason}); retrying`),\n1672:               });\n1673:             } catch (error) {\n1674:               // The probe resolves to a status even on socket failure; a thrown error means the probe\n1675:               // infrastructure itself failed. Treat that as not-alive so control falls through to\n1676:               // reap+respawn, rather than letting the exception abort startup and strand the daemon.\n1677:               probe = { status: 'dead', reason: `probe-threw: ${error instanceof Error ? error.message : String(error)}` };\n1678:             }\n1679:             if (probe.status === 'alive') {\n1680:               log(`stale-reclaim adopting live daemon pid ${orphanChildPid} via bridge instead of reaping`);\n1681:               clearOwnerLeaseFile();\n1682:               await bridgeOrReportLeaseHeldAndExit(adoptResult);\n1683:               return;\n1684:             }\n1685:             // The probe can fail because the daemon is busy-by-design (a background\n1686:             // index scan starves its event loop), not wedged. A fresh maintenance\n1687:             // marker naming this live child means adopt rather than reap+respawn.\n1688:             const adoptMarker = readMaintenanceMarker(maintenanceMarkerDir());\n1689:             if (shouldAdoptDespiteProbe({ marker: adoptMarker, childPid: orphanChildPid, childLiveness: processLiveness(orphanChildPid) })) {\n1690:               log(`stale-reclaim adopting busy daemon pid ${orphanChildPid} via bridge: probe failed (${probe.reason}) but a fresh maintenance marker is active (until ${new Date(adoptMarker.activeUntilMs).toISOString()})`);\n1691:               clearOwnerLeaseFile();\n1692:               await bridgeOrReportLeaseHeldAndExit(adoptResult);\n1693:               return;\n1694:             }\n1695:             log(`stale-reclaim NOT adopting pid ${orphanChildPid}: liveness probe failed (${probe.reason}); reaping and respawning instead`);\n1696:           }\n1697:         }\n1698:         // Daemon is dead, unbridgeable, or alive but failing its liveness probe. Reclaiming an existing STALE owner lease is a\n1699:         // non-exclusive write (the owner-lease O_EXCL above only covers the no-prior-lease case), so\n1700:         // two fresh launchers racing a crashed owner could both reach the reap and spawn. Take the\n1701:         // exclusive respawn lock to serialize it, the same lock the dead-socket respawn path uses;\n1702:         // the loser bails and reconnects.\n1703:         staleRespawnLock = acquireRespawnLockFile();\n1704:         if (!staleRespawnLock.acquired) {\n1705:           log('stale-reclaim deferred: another launcher holds the respawn lock; reporting lease held');\n1706:           clearOwnerLeaseFile();\n1707:           writeLeaseHeldJsonRpcError(leaseResult, 'respawn-lock-held');\n1708:           process.exit(0);\n1709:         }\n1710:         if (Number.isInteger(orphanChildPid) && orphanChildPid > 0) {\n1711:           // Re-validate under the respawn lock. The liveness probe above can take seconds, during which\n1712:           // a racing launcher may have reaped this same orphan and spawned a fresh daemon (recording a\n1713:           // new childPid) before we acquired the lock. Reaping now would tear down that replacement and\n1714:           // risk a second writer, so if the recorded lease no longer names the orphan we snapshotted,\n1715:           // defer and reconnect. Mirrors the dead-socket respawn path's post-lock lease re-read.\n1716:           const recheckLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n1717:           if (recheckLease && recheckLease.childPid !== orphanChildPid) {\n1718:             log('stale-reclaim deferred: lease childPid changed after acquiring respawn lock (replacement already present); reporting lease held');\n1719:             releaseRespawnLockFile(staleRespawnLock);\n1720:             staleRespawnLock = null;\n1721:             clearOwnerLeaseFile();\n1722:             writeLeaseHeldJsonRpcError(leaseResult, 'respawn-superseded');\n1723:             process.exit(0);\n1724:           }\n1725:           const reap = await reapLeaseChildBeforeRespawn(orphanChildPid);\n1726:           if (!reap.allowed) {\n1727:             // Cannot confirm the released daemon is gone (EPERM, or it outlived SIGKILL); spawning\n1728:             // now would create a second writer, so report the lease as held and let the host\n1729:             // reconnect instead.\n1730:             log(`stale-reclaim aborted: ${reap.reason} for childPid=${orphanChildPid}; reporting lease held`);\n1731:             releaseRespawnLockFile(staleRespawnLock);\n1732:             staleRespawnLock = null;\n1733:             clearOwnerLeaseFile();\n1734:             writeLeaseHeldJsonRpcError(leaseResult, reap.reason);\n1735:             process.exit(0);\n1736:           }\n1737:         }\n1738:       }\n1739:     } else {\n1740:       log('MK_SPEC_MEMORY_STRICT_SINGLE_WRITER is disabled; skipping lease check');\n1741:     }\n1742: \n1743:     lockHeld = await acquireBootstrapLock();\n1744:     if (lockHeld) {\n1745:       buildIfNeeded(actions);\n1746:       writeState({\n1747:         command: 'mk-spec-memory-launcher',\n1748:         start: started,\n1749:         end: now(),\n1750:         status: 'ready',\n1751:         actions,\n1752:         server: rel(path.join(kitDir, 'mcp_server', 'dist', 'context-server.js')),\n1753:       });\n1754:       fs.rmSync(lockDir, { recursive: true, force: true });\n1755:       lockHeld = false;\n1756:     }\n1757: \n1758:     writeLeaseFile();\n1759:     const reprobe = readLeaseFile();\n1760:     if (!reprobe || reprobe.pid !== process.pid) {\n1761:       const startedAt = reprobe?.startedAt ?? new Date(0).toISOString();\n1762:       clearOwnerLeaseFile();\n1763:       writeLeaseHeldJsonRpcError({ ownerPid: reprobe ? reprobe.pid : 'unknown', startedAt }, 'lease-reprobe-lost');\n1764:       process.exit(0);\n1765:     }\n1766:     const launched = launchServer();\n1767:     // Reap + spawn critical section is over; let other respawn paths proceed.\n1768:     if (staleRespawnLock) {\n1769:       releaseRespawnLockFile(staleRespawnLock);\n1770:       staleRespawnLock = null;\n1771:     }\n1772:     if (!launched) return;\n1773:     if (launched) {\n1774:       const sessionProxy = createSessionProxy({\n1775:         socketPath: resolveSessionProxySocketPath(),\n1776:         stdin: process.stdin,\n1777:         stdout: process.stdout,\n1778:         log,\n1779:       });\n1780:       await sessionProxy.start();\n1781:     }\n1782:     void startModelServerDemandListener().catch((error) => {\n1783:       log(`hf-model-server demand listener failed: ${error.stack || error.message}`);\n1784:     });\n1785:   } catch (error) {\n1786:     try {\n1787:       writeState({\n1788:         command: 'mk-spec-memory-launcher',\n1789:         start: started,\n1790:         end: now(),\n1791:         status: 'failed',\n1792:         actions,\n1793:         error: error.message,\n1794:       });\n1795:     } catch {\n1796:       // If state logging itself fails, stderr still carries the actionable error.\n1797:     }\n1798:     log(error.stack || error.message);\n1799:     process.exit(1);\n1800:   } finally {\n1801:     if (lockHeld) {\n1802:       fs.rmSync(lockDir, { recursive: true, force: true });\n1803:     }\n1804:     if (staleRespawnLock) {\n1805:       releaseRespawnLockFile(staleRespawnLock);\n1806:       staleRespawnLock = null;\n1807:     }\n1808:   }\n1809: }\n1810: \n1811: function configureLauncherPathsForTesting(nextPaths) {\n1812:   if (nextPaths.skillsDir) skillsDir = nextPaths.skillsDir;\n1813:   if (nextPaths.kitDir) kitDir = nextPaths.kitDir;\n1814:   if (nextPaths.dbDir) dbDir = nextPaths.dbDir;\n1815:   if (nextPaths.lockDir) lockDir = nextPaths.lockDir;\n1816:   if (nextPaths.stateFile) stateFile = nextPaths.stateFile;\n1817: }\n1818: \n1819: module.exports = {\n1820:   acquireBootstrapLock,\n1821:   acquireModelServerRespawnLockFile,\n1822:   acquireOwnerLeaseFile,\n1823:   artifactsReady,\n1824:   bridgeStdioThroughSessionProxy,\n1825:   buildLeaseObject,\n1826:   buildOwnerLease,\n1827:   classifyOwnerLease,\n1828:   clearOwnerLeaseFile,\n1829:   configureLauncherPathsForTesting,\n1830:   ownerLeasePath,\n1831:   readBootstrapLockOwnerPid,\n1832:   readOwnerLeaseFile,\n1833:   reapOwnerBeforeRespawn,\n1834:   removeStaleBootstrapLock,\n1835:   computeBackoffMs,\n1836:   decideDbLockHeldAction,\n1837:   EXIT_DB_LOCK_HELD,\n1838:   contextServerSpawnIo,\n1839:   createCrashLoopGuard,\n1840:   daemonReelectionEnabled,\n1841:   createModelServerSupervisor,\n1842:   getModelServerWatchdogConfig,\n1843:   getWatchdogConfig,\n1844:   isRespawnLockStale,\n1845:   maintenanceMarkerDir,\n1846:   readMaintenanceMarker,\n1847:   shouldAdoptDespiteProbe,\n1848:   launchModelServer,\n1849:   launcherLogIsEnabled,\n1850:   launcherLogMaxBytes,\n1851:   modelServerRespawnLockPath,\n1852:   persistLauncherLogLine,\n1853:   resolveLauncherLogPath,\n1854:   shouldRotateLauncherLog,\n1855:   normalizeWatchdogGraceMs,\n1856:   parseProcessRows,\n1857:   processLiveness,\n1858:   reapProcessTreeGroups,\n1859:   refreshDescendantSnapshot,\n1860:   resolvedDbDir,\n1861:   uncleanShutdownMarkerPath,\n1862:   uncleanMarkerPresent,\n1863:   cleanCloseAfterReap,\n1864:   reapLeaseChildBeforeRespawn,\n1865:   recycleDaemonInPlace,\n1866:   resolveModelServerSocketPath,\n1867:   sampleProcessTreeRssMb,\n1868:   shouldAbortRelaunchOnFire,\n1869:   shouldReleaseDaemonForReelection,\n1870:   shouldSkipLaunch,\n1871:   signalProcess,\n1872:   startModelServerDemandListener,\n1873:   startRssWatchdog,\n1874:   stopModelServerDemandListener,\n1875:   superviseChildExit,\n1876:   writeLeaseFile,\n1877:   writeSharedModelServerPid,\n1878: };\n1879: \n1880: if (require.main === module) {\n1881:   void main();\n1882: }\n\n(End of file - total 1882 lines)\n</content>","metadata":{"preview":"// Launcher-local factory that pre-seeds the launcher-aware defaults (writeLease/shouldExitLauncher/\n// onRssBreach) the shared lib intentionally leaves as generic no-ops. Keeps the launcher's exported\n// createModelServerSupervisor + launchModelServer(options) seam byte-equivalent to pre-extraction HEAD.\n// Explicit caller options still win via the trailing spread for targeted writeLease injection.\nfunction createModelServerSupervisor(options = {}) {\n  return baseCreateModelServerSupervisor({\n    writeLease: () => writeLeaseFile(),\n    shouldExitLauncher: () => launcherShutdownInProgress,\n    onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n    ...options,\n  });\n}\n\nfunction launchModelServer(options = null) {\n  if (options && typeof options === 'object') {\n    return createModelServerSupervisor(options).launch();\n  }\n  return hfControl.launch();\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"// Launcher-local factory that pre-seeds the launcher-aware defaults (writeLease/shouldExitLauncher/\n// onRssBreach) the shared lib intentionally leaves as generic no-ops. Keeps the launcher's exported\n// createModelServerSupervisor + launchModelServer(options) seam byte-equivalent to pre-extraction HEAD.\n// Explicit caller options still win via the trailing spread for targeted writeLease injection.\nfunction createModelServerSupervisor(options = {}) {\n  return baseCreateModelServerSupervisor({\n    writeLease: () => writeLeaseFile(),\n    shouldExitLauncher: () => launcherShutdownInProgress,\n    onRssBreach: (cfg) => recycleDaemonInPlace(cfg.graceMs),\n    ...options,\n  });\n}\n\nfunction launchModelServer(options = null) {\n  if (options && typeof options === 'object') {\n    return createModelServerSupervisor(options).launch();\n  }\n  return hfControl.launch();\n}\n\nfunction startModelServerDemandListener(options = {}) {\n  return hfControl.startDemandListener(options);\n}\n\nfunction stopModelServerDemandListener() {\n  return hfControl.stopDemandListener();\n}\n\nconst BOOTSTRAP_LOCK_OWNER_FILE = 'owner.pid';\n\n// Returns the pid recorded inside the lock dir, or null when no readable pid\n// stamp exists (legacy lock dirs, or a holder that died before stamping).\nfunction readBootstrapLockOwnerPid() {\n  try {\n    const raw = fs.readFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), 'utf8').trim();\n    const pid = Number.parseInt(raw, 10);\n    return Number.isInteger(pid) && pid > 0 ? pid : null;\n  } catch {\n    return null;\n  }\n}\n\n// Reclaim a stale bootstrap lockdir. A lock is reclaimable as soon as its\n// recorded holder is provably dead; the mtime TTL is only a fallback for lock\n// dirs with no readable pid stamp (legacy dirs) or a holder whose liveness\n// cannot be determined. Without the dead-holder check, a holder killed less than\n// BOOTSTRAP_LOCK_STALE_MS ago wedges every requireLock respawn for the full wait\n// deadline (the TTL exceeds the deadline by design for a slow-but-live build).\nfunction removeStaleBootstrapLock(staleMs = BOOTSTRAP_LOCK_STALE_MS) {\n  let ageMs;\n  try {\n    ageMs = Date.now() - fs.statSync(lockDir).mtimeMs;\n  } catch (error) {\n    if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;\n    throw error;\n  }\n  const ownerPid = readBootstrapLockOwnerPid();\n  const ownerDead = ownerPid !== null && processLiveness(ownerPid) === 'dead';\n  if (!ownerDead && ageMs <= staleMs) {\n    return false;\n  }\n  // Atomically CLAIM the stale lockdir via rename before deleting it. Only one\n  // racer wins the rename; a successor that mkdir'd a fresh lockDir after our stat\n  // creates a new inode that our rename/rmSync cannot touch, so we never delete a\n  // live successor lock. A losing racer's rename throws ENOENT and falls through to\n  // the outer retry.\n  const staleClaim = `${lockDir}.stale.${process.pid}.${Date.now()}`;\n  try {\n    fs.renameSync(lockDir, staleClaim);\n    fs.rmSync(staleClaim, { recursive: true, force: true });\n    const reason = ownerDead ? `dead holder pid=${ownerPid}` : `mtime ${Math.round(ageMs / 1000)}s old`;\n    log(`reclaiming stale bootstrap lock ${rel(lockDir)} (${reason})`);\n    return true;\n  } catch (error) {\n    if (error.code === 'ENOENT' || error.code === 'ENOTEMPTY') return false;\n    throw error;\n  }\n}\n\nasync function acquireBootstrapLock(options = {}) {\n  const requireLock = options.requireLock === true;\n  fs.mkdirSync(dbDir, { recursive: true });\n  const deadline = Date.now() + (options.timeoutMs ?? 120000);\n  const staleMs = options.staleMs ?? BOOTSTRAP_LOCK_STALE_MS;\n  const retrySleepMs = options.retrySleepMs ?? 1000;\n  while (true) {\n    try {\n      fs.mkdirSync(lockDir);\n      // Stamp the holder pid so a later launcher can reclaim this lock the\n      // instant we die, instead of waiting out the mtime TTL. Best-effort: a\n      // failed stamp degrades to the TTL path, never blocks acquisition.\n      try {\n        fs.writeFileSync(path.join(lockDir, BOOTSTRAP_LOCK_OWNER_FILE), String(process.pid), { mode: 0o600 });\n      } catch { /* TTL fallback covers an unstamped lock */ }\n      return true;\n    } catch (error) {\n      if (error.code !== 'EEXIST') {\n        throw error;\n      }\n      if (removeStaleBootstrapLock(staleMs)) {\n        continue;\n      }\n      if (artifactsReady() && !requireLock) {\n        return false;\n      }\n      if (Date.now() > deadline) {\n        throw new Error(`bootstrap lock timed out at ${rel(lockDir)}`);\n      }\n      await sleep(retrySleepMs);\n    }\n  }\n}\n\nfunction launchServer() {\n  if (ownerLeaseRequired && !ownsOwnerLeaseFile(process.pid)) {\n    log('launchServer skipped: spec-memory owner lease is absent or owned by another launcher');\n    return false;\n  }\n  if (shouldSkipLaunch(childProcess)) {\n    log('launchServer skipped: a context-server child is already running in this launcher process');\n    return false;\n  }\n  if (!crashLoopGuard) crashLoopGuard = createCrashLoopGuard(getCrashLoopConfig());\n  if (supervisorRelaunchTimer) {\n    clearTimeout(supervisorRelaunchTimer);\n    supervisorRelaunchTimer = null;\n  }\n  const server = path.join(kitDir, 'mcp_server', 'dist', 'context-server.js');\n  const nodeArgs = getContextServerNodeArgs();\n  const reelectionEnabled = daemonReelectionEnabled();\n  const spawnIo = contextServerSpawnIo(reelectionEnabled);\n  childProcess = spawn(process.execPath, [...nodeArgs, server], {\n    cwd: root,\n    env: {\n      ...process.env,\n      SPECKIT_BACKEND_ONLY: '1',\n    },\n    stdio: spawnIo.stdio,\n    detached: spawnIo.detached,\n  });\n  // Re-election only: let the launcher exit without keeping the detached daemon tethered to it.\n  if (reelectionEnabled) childProcess.unref();\n  const childPid = childProcess.pid;\n  const refreshed = refreshOwnerLeaseFile(process.pid);\n  if (!refreshed) {\n    log('owner lease refresh failed after child spawn; launcher pid remains the recorded owner');\n  }\n  startOwnerLeaseHeartbeat(process.pid);\n  writeLeaseFile(childPid);\n  startRssWatchdog(childPid);\n\n  childProcess.on('exit', (code, signal) => {\n    if (launcherShutdownInProgress) {\n      return;\n    }\n    if (code === EXIT_DB_LOCK_HELD) {\n      void handleDbLockHeldChildExit();\n      return;\n    }\n    const result = superviseChildExit(\n      { code, signal, childPid, intentional: false },\n      {\n        crashLoopGuard,\n        clearLease: clearAllLeaseFiles,\n        reapProcessGroup: reapProcessTreeGroups,\n        mirrorSignal: (exitSignal) => process.kill(process.pid, exitSignal),\n        exit: (exitCode) => process.exit(exitCode),\n        scheduleRelaunch: (backoffMs) => {\n          log(`context-server child exited code=${code ?? 'null'} signal=${signal ?? 'null'}; relaunching in ${backoffMs}ms`);\n          supervisorRelaunchTimer = setTimeout(() => {\n            // Owner-disposal race guard: by the time the backoff fires, re-check that this\n            // launcher is still live AND its owning runtime is still present. Respawning the\n            // daemon under a disposing session is what produced the SIGTERM/relaunch flap that\n            // dropped every bridged session's transport. Crash-recovery and RSS-recycle are\n            // unaffected — both run with the owning runtime alive and no shutdown in progress.\n            if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) {\n              log('relaunch aborted: launcher shutting down or owning runtime gone; releasing lease and exiting');\n              clearAllLeaseFiles();\n              process.exit(0);\n              return;\n            }\n            launchServer();\n          }, backoffMs);\n          supervisorRelaunchTimer.unref?.();\n        },\n      },\n    );\n    if (result.action === 'give-up') {\n      log(`context-server crash loop detected after ${result.deathsInWindow} deaths; clearing lease and mirroring child exit`);\n    }\n  });\n\n  childProcess.on('error', (error) => {\n    log(error.stack || error.message);\n    process.exit(1);\n  });\n  if (rssBreachSelfExitInProgress) {\n    rssBreachSelfExitInProgress = false;\n  }\n  return true;\n}\n\n// Pure decision for the exit-86 flow (exported for tests). A lease whose\n// owner is THIS launcher is NOT a bridge target: in supervised mode the\n// pid-lease records the launcher's own pid, so after its child exits 86 the\n// lease still reads \"held by a live owner\" — us. Bridging would deep-probe\n// our own dead socket and route into a self-reap. Only a DIFFERENT live\n// owner is bridgeable; a self-held lease means a non-daemon process (e.g. a\n// standalone save mid-run) owns the database lock, so retry in place.\nfunction decideDbLockHeldAction({ leaseHeld, leaseOwnerPid, selfPid, attempt, maxRetries }) {\n  if (attempt > maxRetries + 2) return { action: 'report', reason: 'db-lock-held-persistent' };\n  if (leaseHeld && leaseOwnerPid !== selfPid) return { action: 'bridge' };\n  if (attempt <= maxRetries) return { action: 'retry', backoffMs: 2000 * 2 ** (attempt - 1) };\n  return { action: 'report', reason: 'db-lock-held' };\n}\n\n// The daemon refused to become a second writer on a database another live\n// process holds. Prefer bridging to that owner; when the holder is not a\n// bridgeable daemon (e.g. a maintenance script mid-run), retry the launch a\n// few times so a short-lived holder can finish, then report and exit clean.\nasync function handleDbLockHeldChildExit() {\n  dbLockHeldRetries += 1;\n  const leaseResult = isLeaseHeld();\n  const decision = decideDbLockHeldAction({\n    leaseHeld: leaseResult.held,\n    leaseOwnerPid: leaseResult.ownerPid,\n    selfPid: process.pid,\n    attempt: dbLockHeldRetries,\n    maxRetries: DB_LOCK_HELD_MAX_RETRIES,\n  });\n  if (decision.action === 'bridge') {\n    log(`context-server exited: database single-writer lock held; bridging to live owner pid=${leaseResult.ownerPid}`);\n    await bridgeOrReportLeaseHeldAndExit(leaseResult);\n    return;\n  }\n  if (decision.action === 'retry') {\n    log(`database single-writer lock held by a non-bridgeable holder; retrying launch in ${decision.backoffMs}ms (attempt ${dbLockHeldRetries}/${DB_LOCK_HELD_MAX_RETRIES})`);\n    if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n    supervisorRelaunchTimer = setTimeout(() => {\n      // Abort if the owning runtime vanished (shutdown in progress, or the launcher\n      // was reparented to init without a SIGTERM) — same guard as the primary\n      // backoff-relaunch path, so neither relaunches a daemon under a disposed session.\n      if (shouldAbortRelaunchOnFire({ shuttingDown: launcherShutdownInProgress, currentPpid: process.ppid, initialPpid: LAUNCHER_INITIAL_PPID })) return;\n      launchServer();\n    }, decision.backoffMs);\n    if (supervisorRelaunchTimer.unref) supervisorRelaunchTimer.unref();\n    return;\n  }\n  log('database single-writer lock still held after launch retries; reporting and exiting');\n  writeLeaseHeldJsonRpcError(\n    { ownerPid: leaseResult.ownerPid ?? 'unknown', startedAt: leaseResult.startedAt ?? new Date().toISOString() },\n    decision.reason,\n  );\n  clearAllLeaseFiles();\n  process.exit(0);\n}\n\nasync function shutdownLauncherForSignal(signal) {\n  if (launcherShutdownInProgress) return;\n  launcherShutdownInProgress = true;\n  if (rssWatchdogTimer) clearInterval(rssWatchdogTimer);\n  if (supervisorRelaunchTimer) clearTimeout(supervisorRelaunchTimer);\n  clearOwnerLeaseHeartbeat();\n  hfControl.clearTimers();\n  await hfControl.stopDemandListener();\n\n  // Re-election release path (on by default): release the detached context-server for a live secondary to adopt\n  // instead of killing it. Reap only the non-adoptable model-server, KEEP the daemon lease (its socket\n  // stays findable for adoption), drop only OWNERSHIP, and exit without killing the daemon. When the\n  // flag is off this branch is skipped and the original kill path below runs unchanged.\n  if (shouldReleaseDaemonForReelection({ enabled: daemonReelectionEnabled(), hasLiveDaemon: isChildRunning(childProcess) })) {\n    const releasedModelServer = hfControl.getChild();\n    if (isChildRunning(releasedModelServer)) {\n      hfControl.reapProcessTree(releasedModelServer.pid);\n      releasedModelServer.kill(signal);\n      // Escalate to SIGKILL if the non-adoptable model-server does not exit within the grace window,\n      // so the release path does not leave a wedged sidecar behind on its way out.\n      const exited = await waitForChildExit(releasedModelServer, RESPAWN_REAP_GRACE_MS);\n      if (!exited && isChildRunning(releasedModelServer)) {\n        releasedModelServer.kill('SIGKILL');\n      }\n    }\n    log('daemon re-election: releasing context-server for adoption (not killing); dropping ownership lease only');\n    // The process 'exit' handler clears BOTH leases; detach it first so the daemon lease (its socket\n    // path) survives for a secondary to adopt. Ownership is still dropped explicitly below.\n    process.removeListener('exit', clearAllLeaseFiles);\n    clearOwnerLeaseFile();\n    process.exit(0);\n    return;\n  }\n\n  const children = [];\n  if (isChildRunning(childProcess)) {\n    children.push({ child: childProcess, label: 'context-server' });\n  }\n  const modelServerChild = hfControl.getChild();\n  if (isChildRunning(modelServerChild)) {\n    children.push({ child: modelServerChild, label: 'hf-model-server' });\n  }\n\n  if (children.length === 0) {\n    clearAllLeaseFiles();\n    process.exit(128);\n    return;\n  }\n\n  for (const { child, label } of children) {\n    if (label === 'hf-model-server') {\n      hfControl.reapProcessTree(child.pid);\n    }\n    child.kill(signal);\n  }\n\n  const exited = await Promise.race([\n    Promise.all(children.map(({ child }) => waitForChildExit(child, RESPAWN_REAP_GRACE_MS))).then((results) => results.every(Boolean)),\n    sleep(RESPAWN_REAP_GRACE_MS).then(() => false),\n  ]);\n  if (!exited) {\n    for (const { child } of children) {\n      if (isChildRunning(child)) child.kill('SIGKILL');\n    }\n  }\n  clearAllLeaseFiles();\n  process.exit(128);\n}\n\nfunction installSignalHandlers() {\n  for (const signal of ['SIGINT', 'SIGTERM', 'SIGHUP', 'SIGQUIT']) {\n    process.on(signal, () => {\n      void shutdownLauncherForSignal(signal).catch((error) => {\n        log(error.stack || error.message);\n        clearAllLeaseFiles();\n        process.exit(128);\n      });\n    });\n  }\n  process.on('uncaughtException', (err) => {\n    try {\n      clearAllLeaseFiles();\n    } catch {\n      // Preserve default uncaughtException crash behavior.\n    }\n    throw err;\n  });\n}\n\nasync function main() {\n  loadProjectEnvFiles();\n  const started = now();\n  const actions = [];\n  let lockHeld = false;\n  let staleRespawnLock = null;\n\n  try {\n    installSignalHandlers();\n    // Lease cleanup runs unconditionally regardless of child termination path.\n    process.on('exit', clearAllLeaseFiles);\n    refreshPaths();\n\n    const strictSingleWriter = !isStrictModeDisabled(process.env.MK_SPEC_MEMORY_STRICT_SINGLE_WRITER);\n    ownerLeaseRequired = strictSingleWriter;\n    if (strictSingleWriter) {\n      const legacyLeaseResult = isLeaseHeld();\n      if (legacyLeaseResult.held && legacyLeaseResult.legacyPath && !legacyLeaseResult.staleReclaimable) {\n        await bridgeOrReportLeaseHeldAndExit(legacyLeaseResult);\n        return;\n      }\n    }\n\n    ensureLayout(actions);\n    refreshPaths();\n    enforceStandaloneCodeGraphDb(actions);\n\n    if (strictSingleWriter) {\n      const ownerLeaseResult = acquireOwnerLeaseFile();\n      if (!ownerLeaseResult.acquired) {\n        log(`liveOwnerDetected: ownerPid=${ownerLeaseResult.holder.ownerPid} classification=${ownerLeaseResult.classification}`);\n        await bridgeOrReportLeaseHeldAndExit(leaseResultForOwnerLease(ownerLeaseResult.holder));\n        return;\n      }\n\n      const leaseResult = isLeaseHeld();\n      if (leaseResult.held && !leaseResult.staleReclaimable) {\n        clearOwnerLeaseFile();\n        await bridgeOrReportLeaseHeldAndExit(leaseResult);\n        return;\n      }\n      if (leaseResult.staleReclaimable) {\n        log(`staleReclaimed: true${leaseResult.legacyPath ? ' (legacy path)' : ''}`);\n        // A re-election daemon released by a disposing owner (or orphaned by a crashed owner) stays\n        // alive under this stale lease, which records the live daemon as childPid. ADOPT it: if the\n        // daemon is still alive and its recorded socket is bridgeable, bridge to the live socket\n        // instead of reaping and respawning. This reuses the warm daemon and never tears down a\n        // daemon a live secondary may still be bridged to. The reap+respawn path below runs only\n        // when the daemon is genuinely gone.\n        const staleLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n        const orphanChildPid = staleLease?.childPid;\n        if (Number.isInteger(orphanChildPid) && orphanChildPid > 0 && processLiveness(orphanChildPid) !== 'dead') {\n          const adoptResult = { ...leaseResult, socketPath: staleLease.socketPath || leaseResult.socketPath };\n          const readiness = bridgeReadiness(adoptResult);\n          if (readiness.ready) {\n            // A live pid that still owns its socket can be WEDGED: its event loop is starved, so the\n            // kernel accepts the connection into the listen backlog but the daemon never services a\n            // request. bridgeReadiness only proves the socket file exists — adopting on that alone\n            // bridges every client into a dead end, and the launcher can never recover because the pid\n            // stays alive forever and is never reaped. Require a real JSON-RPC reply (the same deep\n            // probe the dead-socket decision uses, with its tuned timeout + retry that tolerates a\n            // busy-but-responsive daemon) before adopting. A non-responsive daemon falls through to the\n            // reap+respawn block below, which tears it down and spawns a fresh one under the lock.\n            const { probeLeaseHolderWithRetries } = loadBridgeModule();\n            let probe;\n            try {\n              probe = await probeLeaseHolderWithRetries(readiness.socketPath, {\n                onRetry: (attempt, total, result) => log(`stale-reclaim adopt probe ${attempt}/${total} not alive (${result.reason}); retrying`),\n              });\n            } catch (error) {\n              // The probe resolves to a status even on socket failure; a thrown error means the probe\n              // infrastructure itself failed. Treat that as not-alive so control falls through to\n              // reap+respawn, rather than letting the exception abort startup and strand the daemon.\n              probe = { status: 'dead', reason: `probe-threw: ${error instanceof Error ? error.message : String(error)}` };\n            }\n            if (probe.status === 'alive') {\n              log(`stale-reclaim adopting live daemon pid ${orphanChildPid} via bridge instead of reaping`);\n              clearOwnerLeaseFile();\n              await bridgeOrReportLeaseHeldAndExit(adoptResult);\n              return;\n            }\n            // The probe can fail because the daemon is busy-by-design (a background\n            // index scan starves its event loop), not wedged. A fresh maintenance\n            // marker naming this live child means adopt rather than reap+respawn.\n            const adoptMarker = readMaintenanceMarker(maintenanceMarkerDir());\n            if (shouldAdoptDespiteProbe({ marker: adoptMarker, childPid: orphanChildPid, childLiveness: processLiveness(orphanChildPid) })) {\n              log(`stale-reclaim adopting busy daemon pid ${orphanChildPid} via bridge: probe failed (${probe.reason}) but a fresh maintenance marker is active (until ${new Date(adoptMarker.activeUntilMs).toISOString()})`);\n              clearOwnerLeaseFile();\n              await bridgeOrReportLeaseHeldAndExit(adoptResult);\n              return;\n            }\n            log(`stale-reclaim NOT adopting pid ${orphanChildPid}: liveness probe failed (${probe.reason}); reaping and respawning instead`);\n          }\n        }\n        // Daemon is dead, unbridgeable, or alive but failing its liveness probe. Reclaiming an existing STALE owner lease is a\n        // non-exclusive write (the owner-lease O_EXCL above only covers the no-prior-lease case), so\n        // two fresh launchers racing a crashed owner could both reach the reap and spawn. Take the\n        // exclusive respawn lock to serialize it, the same lock the dead-socket respawn path uses;\n        // the loser bails and reconnects.\n        staleRespawnLock = acquireRespawnLockFile();\n        if (!staleRespawnLock.acquired) {\n          log('stale-reclaim deferred: another launcher holds the respawn lock; reporting lease held');\n          clearOwnerLeaseFile();\n          writeLeaseHeldJsonRpcError(leaseResult, 'respawn-lock-held');\n          process.exit(0);\n        }\n        if (Number.isInteger(orphanChildPid) && orphanChildPid > 0) {\n          // Re-validate under the respawn lock. The liveness probe above can take seconds, during which\n          // a racing launcher may have reaped this same orphan and spawned a fresh daemon (recording a\n          // new childPid) before we acquired the lock. Reaping now would tear down that replacement and\n          // risk a second writer, so if the recorded lease no longer names the orphan we snapshotted,\n          // defer and reconnect. Mirrors the dead-socket respawn path's post-lock lease re-read.\n          const recheckLease = readLeaseFile(leaseResult.legacyPath || leasePath());\n          if (recheckLease && recheckLease.childPid !== orphanChildPid) {\n            log('stale-reclaim deferred: lease childPid changed after acquiring respawn lock (replacement already present); reporting lease held');\n            releaseRespawnLockFile(staleRespawnLock);\n            staleRespawnLock = null;\n            clearOwnerLeaseFile();\n            writeLeaseHeldJsonRpcError(leaseResult, 'respawn-superseded');\n            process.exit(0);\n          }\n          const reap = await reapLeaseChildBeforeRespawn(orphanChildPid);\n          if (!reap.allowed) {\n            // Cannot confirm the released daemon is gone (EPERM, or it outlived SIGKILL); spawning\n            // now would create a second writer, so report the lease as held and let the host\n            // reconnect instead.\n            log(`stale-reclaim aborted: ${reap.reason} for childPid=${orphanChildPid}; reporting lease held`);\n            releaseRespawnLockFile(staleRespawnLock);\n            staleRespawnLock = null;\n            clearOwnerLeaseFile();\n            writeLeaseHeldJsonRpcError(leaseResult, reap.reason);\n            process.exit(0);\n          }\n        }\n      }\n    } else {\n      log('MK_SPEC_MEMORY_STRICT_SINGLE_WRITER is disabled; skipping lease check');\n    }\n\n    lockHeld = await acquireBootstrapLock();\n    if (lockHeld) {\n      buildIfNeeded(actions);\n      writeState({\n        command: 'mk-spec-memory-launcher',\n        start: started,\n        end: now(),\n        status: 'ready',\n        actions,\n        server: rel(path.join(kitDir, 'mcp_server', 'dist', 'context-server.js')),\n      });\n      fs.rmSync(lockDir, { recursive: true, force: true });\n      lockHeld = false;\n    }\n\n    writeLeaseFile();\n    const reprobe = readLeaseFile();\n    if (!reprobe || reprobe.pid !== process.pid) {\n      const startedAt = reprobe?.startedAt ?? new Date(0).toISOString();\n      clearOwnerLeaseFile();\n      writeLeaseHeldJsonRpcError({ ownerPid: reprobe ? reprobe.pid : 'unknown', startedAt }, 'lease-reprobe-lost');\n      process.exit(0);\n    }\n    const launched = launchServer();\n    // Reap + spawn critical section is over; let other respawn paths proceed.\n    if (staleRespawnLock) {\n      releaseRespawnLockFile(staleRespawnLock);\n      staleRespawnLock = null;\n    }\n    if (!launched) return;\n    if (launched) {\n      const sessionProxy = createSessionProxy({\n        socketPath: resolveSessionProxySocketPath(),\n        stdin: process.stdin,\n        stdout: process.stdout,\n        log,\n      });\n      await sessionProxy.start();\n    }\n    void startModelServerDemandListener().catch((error) => {\n      log(`hf-model-server demand listener failed: ${error.stack || error.message}`);\n    });\n  } catch (error) {\n    try {\n      writeState({\n        command: 'mk-spec-memory-launcher',\n        start: started,\n        end: now(),\n        status: 'failed',\n        actions,\n        error: error.message,\n      });\n    } catch {\n      // If state logging itself fails, stderr still carries the actionable error.\n    }\n    log(error.stack || error.message);\n    process.exit(1);\n  } finally {\n    if (lockHeld) {\n      fs.rmSync(lockDir, { recursive: true, force: true });\n    }\n    if (staleRespawnLock) {\n      releaseRespawnLockFile(staleRespawnLock);\n      staleRespawnLock = null;\n    }\n  }\n}\n\nfunction configureLauncherPathsForTesting(nextPaths) {\n  if (nextPaths.skillsDir) skillsDir = nextPaths.skillsDir;\n  if (nextPaths.kitDir) kitDir = nextPaths.kitDir;\n  if (nextPaths.dbDir) dbDir = nextPaths.dbDir;\n  if (nextPaths.lockDir) lockDir = nextPaths.lockDir;\n  if (nextPaths.stateFile) stateFile = nextPaths.stateFile;\n}\n\nmodule.exports = {\n  acquireBootstrapLock,\n  acquireModelServerRespawnLockFile,\n  acquireOwnerLeaseFile,\n  artifactsReady,\n  bridgeStdioThroughSessionProxy,\n  buildLeaseObject,\n  buildOwnerLease,\n  classifyOwnerLease,\n  clearOwnerLeaseFile,\n  configureLauncherPathsForTesting,\n  ownerLeasePath,\n  readBootstrapLockOwnerPid,\n  readOwnerLeaseFile,\n  reapOwnerBeforeRespawn,\n  removeStaleBootstrapLock,\n  computeBackoffMs,\n  decideDbLockHeldAction,\n  EXIT_DB_LOCK_HELD,\n  contextServerSpawnIo,\n  createCrashLoopGuard,\n  daemonReelectionEnabled,\n  createModelServerSupervisor,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  isRespawnLockStale,\n  maintenanceMarkerDir,\n  readMaintenanceMarker,\n  shouldAdoptDespiteProbe,\n  launchModelServer,\n  launcherLogIsEnabled,\n  launcherLogMaxBytes,\n  modelServerRespawnLockPath,\n  persistLauncherLogLine,\n  resolveLauncherLogPath,\n  shouldRotateLauncherLog,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  reapProcessTreeGroups,\n  refreshDescendantSnapshot,\n  resolvedDbDir,\n  uncleanShutdownMarkerPath,\n  uncleanMarkerPresent,\n  cleanCloseAfterReap,\n  reapLeaseChildBeforeRespawn,\n  recycleDaemonInPlace,\n  resolveModelServerSocketPath,\n  sampleProcessTreeRssMb,\n  shouldAbortRelaunchOnFire,\n  shouldReleaseDaemonForReelection,\n  shouldSkipLaunch,\n  signalProcess,\n  startModelServerDemandListener,\n  startRssWatchdog,\n  stopModelServerDemandListener,\n  superviseChildExit,\n  writeLeaseFile,\n  writeSharedModelServerPid,\n};\n\nif (require.main === module) {\n  void main();\n}","lineStart":1258,"lineEnd":1882,"totalLines":1882,"truncated":false}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1781763114725,"end":1781763114730}},"metadata":{"openai":{"itemId":"fc_0ab8fbf40fc27ea4016a338c2a44148191851a06e9d76a83bb"}},"id":"prt_ed95b86e1001g3q35CRyArWrOz","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95b5aba001hQutA9bBaBQJ5v"}}
{"type":"tool_use","timestamp":1781763114734,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"read","callID":"call_0akk0AnckYxR0OuYxEFxVYt8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","offset":1270,"limit":1500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts</path>\n<type>file</type>\n<content>\n1270:           if (dispatchGraphContext && !result.isError) {\n1271:             meta.graphContext = dispatchGraphContext;\n1272:           }\n1273:           const budget = getTokenBudget(name);\n1274:           meta.tokenBudget = budget;\n1275:           syncEnvelopeTokenCount(envelope);\n1276: \n1277:           if (typeof meta.tokenCount === 'number' && meta.tokenCount > budget) {\n1278:             console.error(`[token-budget] ${name} response (${meta.tokenCount} tokens) exceeds budget (${budget})`);\n1279: \n1280:             // First-call session priming rides along in meta and can dwarf a\n1281:             // small tool's own payload. Slim it BEFORE touching the tool's\n1282:             // results: the tool's answer is the caller's data, the priming\n1283:             // payload is recoverable via memory_search/memory_context.\n1284:             if (isRecord(meta.sessionPriming)) {\n1285:               const priming = meta.sessionPriming as Record<string, unknown>;\n1286:               const alreadyTrimmed = priming.trimmed === true;\n1287:               if (!alreadyTrimmed) {\n1288:                 const constitutionalCount = Array.isArray(priming.constitutional)\n1289:                   ? priming.constitutional.length\n1290:                   : 0;\n1291:                 meta.sessionPriming = {\n1292:                   trimmed: true,\n1293:                   constitutionalCount,\n1294:                   ...(isRecord(priming.primePackage) ? { primePackage: priming.primePackage } : {}),\n1295:                 };\n1296:                 syncEnvelopeTokenCount(envelope);\n1297:                 if (Array.isArray(envelope.hints)) {\n1298:                   envelope.hints.push(`Session priming trimmed to fit the ${budget} token budget; full constitutional content remains retrievable via memory_search`);\n1299:                 }\n1300:                 meta.sessionPrimingTrimmed = true;\n1301:               }\n1302:             }\n1303: \n1304:             // Attempt to truncate results array to fit within budget — only\n1305:             // when still over after the priming slim above, because the loop\n1306:             // below pops a result before it re-measures.\n1307:             const stillOverBudget = typeof meta.tokenCount === 'number' && meta.tokenCount > budget;\n1308:             const innerResults = data?.results;\n1309:             if (stillOverBudget && Array.isArray(innerResults) && innerResults.length > 1) {\n1310:               const originalCount = innerResults.length;\n1311:               // Results are typically sorted by score (highest first)\n1312:               // Remove from end (lowest-scored) until within budget\n1313:               while (innerResults.length > 1) {\n1314:                 innerResults.pop();\n1315:                 // Recalculate token count from the full envelope\n1316:                 // (not just results) so trace metadata is included in the budget.\n1317:                 syncEnvelopeTokenCount(envelope);\n1318:                 if (typeof meta.tokenCount === 'number' && meta.tokenCount <= budget) break;\n1319:               }\n1320:               if (data && data.count !== undefined) {\n1321:                 data.count = innerResults.length;\n1322:               }\n1323:               // Recompute constitutionalCount from the results that survived truncation\n1324:               // so consumers reading data.constitutionalCount or envelope.summary see\n1325:               // counts that agree with data.results.length.\n1326:               if (data) {\n1327:                 const survivingConstitutionalCount = innerResults.filter(\n1328:                   (r: unknown) => r !== null && typeof r === 'object' && (r as Record<string, unknown>).isConstitutional === true\n1329:                 ).length;\n1330:                 data.constitutionalCount = survivingConstitutionalCount;\n1331:                 if (typeof envelope.summary === 'string') {\n1332:                   envelope.summary = survivingConstitutionalCount > 0\n1333:                     ? `Found ${innerResults.length} memories (${survivingConstitutionalCount} constitutional)`\n1334:                     : `Found ${innerResults.length} memories`;\n1335:                 }\n1336:               }\n1337:               if (Array.isArray(envelope.hints)) {\n1338:                 envelope.hints.push(`Token budget enforced: truncated ${originalCount} → ${innerResults.length} results to fit ${budget} token budget`);\n1339:               }\n1340:               meta.tokenBudgetTruncated = true;\n1341:               meta.originalResultCount = originalCount;\n1342:               meta.returnedResultCount = innerResults.length;\n1343:             } else if (stillOverBudget) {\n1344:               // No truncatable results array — add warning hint only\n1345:               if (Array.isArray(envelope.hints)) {\n1346:                 envelope.hints.push(`Response exceeds token budget (${meta.tokenCount}/${budget})`);\n1347:               }\n1348:             }\n1349:           }\n1350:           result.content[0].text = serializeEnvelopeWithTokenCount(envelope);\n1351:         }\n1352:       } catch (_parseErr: unknown) {\n1353:         // Non-JSON response, skip token budget injection\n1354:       }\n1355:     }\n1356: \n1357:     return result;\n1358:   } catch (error: unknown) {\n1359:     // Include recovery hints in all error responses\n1360:     const err = error instanceof Error ? error : new Error(String(error));\n1361:     try {\n1362:       const errorResponse = buildErrorResponse(name, err, args);\n1363:       // eslint-disable-next-line @typescript-eslint/no-explicit-any\n1364:       return wrapForMCP(errorResponse as any, true);\n1365:     } catch (wrapError: unknown) {\n1366:       const fallbackError = wrapError instanceof Error ? wrapError.message : String(wrapError);\n1367:       console.error(`[context-server] Failed to build MCP error envelope for '${name}': ${fallbackError}`);\n1368:       const fallbackCode = getDefaultErrorCodeForTool(name);\n1369:       return createMCPErrorResponse({\n1370:         tool: name,\n1371:         error: 'Request failed.',\n1372:         code: fallbackCode,\n1373:         recovery: getRecoveryHint(name, fallbackCode),\n1374:       });\n1375:     }\n1376:   }\n1377:   });\n1378: }\n1379: \n1380: registerContextServerHandlers(server);\n1381: \n1382: /* ───────────────────────────────────────────────────────────────\n1383:    6. STARTUP SCAN & PENDING FILE RECOVERY\n1384: ──────────────────────────────────────────────────────────────── */\n1385: \n1386: let startupScanInProgress = false;\n1387: // Tracked (not fire-and-forget) so fatalShutdown can await the scan to a safe stopping point before\n1388: // closeDb — a resuming scan writes through the DB and would otherwise reopen a closed connection.\n1389: let startupScanPromise: Promise<void> | null = null;\n1390: \n1391: function getStartupWorkspaceRoots(basePath: string): string[] {\n1392:   const configuredMemoryRoot = process.env.MEMORY_BASE_PATH?.trim();\n1393:   const derivedMemoryRoot = configuredMemoryRoot ? path.resolve(process.cwd(), configuredMemoryRoot) : null;\n1394:   return Array.from(new Set(\n1395:     [basePath, derivedMemoryRoot, ...ALLOWED_BASE_PATHS]\n1396:       .filter((root): root is string => typeof root === 'string' && root.trim().length > 0)\n1397:       .map((root) => path.resolve(root))\n1398:   ));\n1399: }\n1400: \n1401: function getPendingRecoveryLocations(basePath: string): string[] {\n1402:   const scanLocations: string[] = [];\n1403:   for (const root of getStartupWorkspaceRoots(basePath)) {\n1404:     scanLocations.push(path.join(root, 'specs'));\n1405:     scanLocations.push(path.join(root, '.opencode', 'specs'));\n1406:     const skillDir = path.join(root, '.opencode', 'skills');\n1407:     try {\n1408:       if (!fs.existsSync(skillDir)) continue;\n1409:       for (const entry of fs.readdirSync(skillDir, { withFileTypes: true })) {\n1410:         if (!entry.isDirectory() || entry.name.startsWith('.')) continue;\n1411:         const constDir = path.join(skillDir, entry.name, 'constitutional');\n1412:         if (fs.existsSync(constDir)) scanLocations.push(constDir);\n1413:       }\n1414:     } catch (_error: unknown) {\n1415:       // Non-fatal: constitutional directory discovery failed\n1416:     }\n1417:   }\n1418:   return Array.from(new Set(scanLocations.filter((location) => fs.existsSync(location))));\n1419: }\n1420: \n1421: /**\n1422:  * Recover pending memory files on MCP startup.\n1423:  * Pending files processed by recovery job on next startup.\n1424:  *\n1425:  * Scans for files with _pending suffix (created when index failed after file write)\n1426:  * and attempts to index them.\n1427:  */\n1428: async function recoverPendingFiles(basePath: string): Promise<PendingRecoveryResult> {\n1429:   console.error('[context-server] Checking for pending memory files...');\n1430: \n1431:   try {\n1432:     // Restrict scan to known memory file locations to prevent OOM when scanning large workspaces.\n1433:     // Share the same allowed-root expansion that startup indexing uses.\n1434:     const existingScanLocations = getPendingRecoveryLocations(basePath);\n1435: \n1436:     // P1 FIX: Wire isCommittedInDb callback so stale pending files are detected at startup.\n1437:     // VectorIndex.getDb() is an initializing accessor — always returns a valid DB after initializeDb().\n1438:     const database = vectorIndex.getDb();\n1439:     const isCommittedInDb = (originalPath: string): boolean => {\n1440:       const row = (database.prepare('SELECT 1 FROM memory_index WHERE file_path = ?') as import('better-sqlite3').Statement).get(originalPath);\n1441:       return !!row;\n1442:     };\n1443: \n1444:     const rawResults = existingScanLocations.flatMap((location) =>\n1445:       transactionManager.recoverAllPendingFiles(location, isCommittedInDb)\n1446:     );\n1447: \n1448:     // Aggregate per-file results into a summary\n1449:     const found = rawResults.length;\n1450:     const recovered = rawResults.filter(r => r.recovered).length;\n1451:     const failed = found - recovered;\n1452: \n1453:     const recoveryResult: PendingRecoveryResult = {\n1454:       found,\n1455:       processed: found,\n1456:       recovered,\n1457:       failed,\n1458:       results: rawResults,\n1459:     };\n1460: \n1461:     if (recoveryResult.found > 0) {\n1462:       console.error(`[context-server] Pending file recovery: ${recoveryResult.recovered} recovered, ${recoveryResult.failed} failed (${recoveryResult.found} total)`);\n1463:     } else {\n1464:       console.error('[context-server] No pending memory files found');\n1465:     }\n1466: \n1467:     return recoveryResult;\n1468:   } catch (error: unknown) {\n1469:     const message = error instanceof Error ? error.message : String(error);\n1470:     console.error(`[context-server] Pending file recovery error: ${message}`);\n1471:     return { found: 0, processed: 0, recovered: 0, failed: 0, results: [] };\n1472:   }\n1473: }\n1474: \n1475: async function startupScan(basePath: string): Promise<void> {\n1476:   if (startupScanInProgress) {\n1477:     console.error('[context-server] Startup scan already in progress, skipping');\n1478:     return;\n1479:   }\n1480: \n1481:   startupScanInProgress = true;\n1482:   try {\n1483:     if (shuttingDown) return; // shutdown began before/at scan start — do not touch the DB before closeDb (the loop below also breaks on shuttingDown)\n1484:     // Recover any pending files from previous failed index operations\n1485:     await recoverPendingFiles(basePath);\n1486: \n1487:     console.error('[context-server] Starting background scan for spec documents and constitutional memories...');\n1488:     const scanRoots = Array.from(\n1489:       new Set(\n1490:         [basePath, ...ALLOWED_BASE_PATHS]\n1491:           .filter((root): root is string => typeof root === 'string' && root.trim().length > 0)\n1492:           .map((root) => path.resolve(root))\n1493:       )\n1494:     );\n1495:     const allFiles: string[] = [];\n1496:     const seen = new Set<string>();\n1497: \n1498:     for (const root of scanRoots) {\n1499:       try {\n1500:         const rootFiles = [\n1501:           ...memoryIndexDiscovery.findConstitutionalFiles(root),\n1502:           ...memoryIndexDiscovery.findSpecDocuments(root),\n1503:         ];\n1504: \n1505:         for (const filePath of rootFiles) {\n1506:           const resolved = path.resolve(filePath);\n1507:           if (!seen.has(resolved)) {\n1508:             seen.add(resolved);\n1509:             allFiles.push(filePath);\n1510:           }\n1511:         }\n1512:       } catch (_error: unknown) {\n1513:         // Non-fatal: skip inaccessible startup roots.\n1514:       }\n1515:     }\n1516: \n1517:     if (allFiles.length === 0) {\n1518:       console.error('[context-server] No spec documents or constitutional memories found in workspace');\n1519:       return;\n1520:     }\n1521: \n1522:     console.error(`[context-server] Found ${allFiles.length} indexable files, checking for changes...`);\n1523:     let indexed = 0, updated = 0, unchanged = 0, failed = 0;\n1524: \n1525:     for (const filePath of allFiles) {\n1526:       if (shuttingDown) break; // stop touching the DB once shutdown begins so closeDb's checkpoint stays clean\n1527:       try {\n1528:         const result: IndexResult = await indexSingleFile(filePath, false);\n1529:         if (result.status === 'indexed') indexed++;\n1530:         else if (result.status === 'updated') updated++;\n1531:         else unchanged++;\n1532:       } catch (error: unknown) {\n1533:         failed++;\n1534:         const message = error instanceof Error ? error.message : String(error);\n1535:         console.error(`[context-server] Failed to index ${path.basename(filePath)}: ${message}`);\n1536:       }\n1537:       // Yield to the poll phase periodically. indexSingleFile is mostly synchronous better-sqlite3\n1538:       // work, so a large scan would otherwise drain as one uninterrupted microtask run and starve the\n1539:       // IPC accept() loop for the scan's full duration. setImmediate hands control back between batches.\n1540:       if ((indexed + updated + unchanged + failed) % 50 === 0) {\n1541:         await new Promise<void>((resolve) => setImmediate(resolve));\n1542:       }\n1543:     }\n1544: \n1545:     if (indexed > 0 || updated > 0) {\n1546:       console.error(`[context-server] Startup scan: ${indexed} new, ${updated} updated, ${unchanged} unchanged, ${failed} failed`);\n1547:     } else {\n1548:       console.error(`[context-server] Startup scan: all ${unchanged} files up to date`);\n1549:     }\n1550: \n1551:     if (indexed > 0 || updated > 0) {\n1552:       try {\n1553:         runPostMutationHooks('scan', {\n1554:           indexed,\n1555:           updated,\n1556:           staleDeleted: 0,\n1557:           staleDeleteFailed: 0,\n1558:           operation: 'startup-scan',\n1559:         });\n1560:       } catch (_error: unknown) {\n1561:         // Non-fatal: startup scan must continue even if invalidation hooks fail.\n1562:       }\n1563:     }\n1564: \n1565:     // Log atomicity metrics for monitoring\n1566:     const metrics = transactionManager.getMetrics();\n1567:     if (metrics.totalRecoveries > 0 || metrics.totalErrors > 0) {\n1568:       console.error(`[context-server] Atomicity metrics: ${metrics.totalAtomicWrites} successful, ${metrics.totalErrors} failed, ${metrics.totalRecoveries} recovered`);\n1569:     }\n1570:   } catch (error: unknown) {\n1571:     const message = error instanceof Error ? error.message : String(error);\n1572:     console.error(`[context-server] Startup scan error: ${message}`);\n1573:   } finally {\n1574:     startupScanInProgress = false;\n1575:   }\n1576: }\n1577: \n1578: /* ───────────────────────────────────────────────────────────────\n1579:    7. GRACEFUL SHUTDOWN\n1580: ──────────────────────────────────────────────────────────────── */\n1581: \n1582: let shuttingDown = false;\n1583: // Hoist transport to module scope so shutdown handlers can close it\n1584: let transport: StdioServerTransport | null = null;\n1585: let transportConnectedAt: string | null = null;\n1586: let fileWatcher: FSWatcher | null = null;\n1587: let ipcBridge: IpcSocketServerHandle | null = null;\n1588: let launcherIdleMonitor: LauncherIdleMonitor | null = null;\n1589: \n1590: /** Maximum time (ms) to wait for async cleanup before force-exiting. */\n1591: const SHUTDOWN_DEADLINE_MS = 5000;\n1592: \n1593: /**\n1594:  * Exit code telling the launcher \"another live process holds the database\n1595:  * single-writer lock\": bridge to that owner instead of counting this exit\n1596:  * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n1597:  * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n1598:  * mk-spec-memory-launcher.cjs.\n1599:  */\n1600: const EXIT_DB_LOCK_HELD = 86;\n1601: \n1602: export const __testables = {\n1603:   runCleanupStep,\n1604:   runAsyncCleanupStep,\n1605:   main: () => main(),\n1606:   getBootFtsIntegrityHealth,\n1607:   runCheckpointNeedsRebuildRepair,\n1608:   normalizeGraphFilePath,\n1609:   extractFilePathsFromToolArgs,\n1610: };\n1611: \n1612: async function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n1613:   if (shuttingDown) return;\n1614:   shuttingDown = true;\n1615:   console.error(`[context-server] ${reason}`);\n1616: \n1617:   runCleanupStep('sessionManager', () => sessionManager.shutdown());\n1618:   runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n1619:   // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n1620:   // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n1621:   // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n1622:   runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n1623:   runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n1624:   runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n1625:   runCleanupStep('accessTracker', () => accessTracker.reset());\n1626:   runCleanupStep('toolCache', () => toolCache.shutdown());\n1627:   runCleanupStep('launcherIdleMonitor', () => {\n1628:     if (launcherIdleMonitor) {\n1629:       launcherIdleMonitor.stop();\n1630:       launcherIdleMonitor = null;\n1631:     }\n1632:   });\n1633: \n1634:   let deadlineTimer: NodeJS.Timeout | undefined;\n1635:   const cleanup = (async () => {\n1636:     // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n1637:     // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n1638:     // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n1639:     await runAsyncCleanupStep('startupScan', async () => {\n1640:       if (startupScanPromise) await startupScanPromise;\n1641:     });\n1642:     // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n1643:     // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n1644:     // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n1645:     // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n1646:     // at rest and defeating the durability guarantee. closeDb() is\n1647:     // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n1648:     // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n1649:     // small even if a pathologically slow drain starves this step.\n1650:     await runAsyncCleanupStep('fileWatcher', async () => {\n1651:       if (fileWatcher) {\n1652:         await fileWatcher.close();\n1653:         fileWatcher = null;\n1654:       }\n1655:     });\n1656:     // Fence the ingest worker before closeDb for the same reason as the file\n1657:     // watcher above: the worker writes through the DB and would otherwise reopen\n1658:     // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n1659:     await runAsyncCleanupStep('ingestWorker', async () => {\n1660:       await stopIngestWorker();\n1661:     });\n1662:     runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n1663:     // Close MCP transport on shutdown\n1664:     runCleanupStep('transport', () => {\n1665:       if (transport) {\n1666:         transport.close();\n1667:         transport = null;\n1668:         transportConnectedAt = null;\n1669:       }\n1670:     });\n1671:     await runAsyncCleanupStep('ipcBridge', async () => {\n1672:       if (ipcBridge) {\n1673:         await ipcBridge.close();\n1674:         ipcBridge = null;\n1675:       }\n1676:     });\n1677:     await runAsyncCleanupStep('shutdownHooks', async () => {\n1678:       await runShutdownHooks();\n1679:     });\n1680:     runCleanupStep('registeredTimers', () => clearAllTimers());\n1681:   })();\n1682: \n1683:   const timedOut = await Promise.race([\n1684:     cleanup.then(() => false),\n1685:     new Promise<boolean>((resolve) => {\n1686:       deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n1687:     }),\n1688:   ]);\n1689: \n1690:   if (deadlineTimer) {\n1691:     clearRegisteredTimer(deadlineTimer);\n1692:   }\n1693: \n1694:   if (timedOut) {\n1695:     console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n1696:   }\n1697: \n1698:   process.exit(exitCode);\n1699: }\n1700: \n1701: /** Remove indexed rows for watcher delete and rename events. */\n1702: async function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n1703:   const database = vectorIndex.getDb();\n1704:   if (!database) {\n1705:     return;\n1706:   }\n1707: \n1708:   const canonicalPath = getCanonicalPathKey(filePath);\n1709:   let rows: Array<{ id: number; spec_folder: string | null }> = [];\n1710: \n1711:   try {\n1712:     rows = database.prepare(`\n1713:       SELECT id, spec_folder\n1714:       FROM memory_index\n1715:       WHERE canonical_file_path = ? OR file_path = ?\n1716:       ORDER BY id ASC\n1717:     `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n1718:   } catch (_error: unknown) {\n1719:     rows = database.prepare(`\n1720:       SELECT id, spec_folder\n1721:       FROM memory_index\n1722:       WHERE file_path = ?\n1723:       ORDER BY id ASC\n1724:     `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n1725:   }\n1726: \n1727:   let deletedCount = 0;\n1728:   for (const row of rows) {\n1729:     if (typeof row.id === 'number') {\n1730:       if (vectorIndex.deleteMemory(row.id)) {\n1731:         deletedCount += 1;\n1732:         // Record DELETE history only after confirmed deletion.\n1733:         try {\n1734:           recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n1735:         } catch (_histErr: unknown) {\n1736:           // History recording is best-effort in file-watcher path\n1737:         }\n1738:       }\n1739:     }\n1740:   }\n1741: \n1742:   if (deletedCount > 0) {\n1743:     try {\n1744:       runPostMutationHooks('delete', { filePath, deletedCount });\n1745:     } catch (_error: unknown) {\n1746:       // Non-throwing by design: file-watcher path must not crash the server.\n1747:     }\n1748:   }\n1749: }\n1750: \n1751: process.on('SIGTERM', () => {\n1752:   void fatalShutdown('Received SIGTERM, shutting down...', 0);\n1753: });\n1754: process.on('SIGINT', () => {\n1755:   void fatalShutdown('Received SIGINT, shutting down...', 0);\n1756: });\n1757: process.on('SIGHUP', () => {\n1758:   void fatalShutdown('Received SIGHUP, shutting down...', 0);\n1759: });\n1760: process.on('SIGQUIT', () => {\n1761:   void fatalShutdown('Received SIGQUIT, shutting down...', 0);\n1762: });\n1763: \n1764: process.on('uncaughtException', (err: Error) => {\n1765:   void fatalShutdown(`Uncaught exception: ${err.stack ?? err.message}`, 1);\n1766: });\n1767: \n1768: process.on('unhandledRejection', (reason: unknown, promise: Promise<unknown>) => {\n1769:   void fatalShutdown(\n1770:     `Unhandled rejection at: ${String(promise)} reason: ${reason instanceof Error ? reason.stack ?? reason.message : String(reason)}`,\n1771:     1,\n1772:   );\n1773: });\n1774: \n1775: /* ───────────────────────────────────────────────────────────────\n1776:    8. MAIN\n1777: ──────────────────────────────────────────────────────────────── */\n1778: \n1779: async function main(): Promise<void> {\n1780:   // Node version mismatch detection (non-blocking)\n1781:   detectNodeVersionMismatch();\n1782:   detectedRuntime = detectRuntime();\n1783:   console.error(\n1784:     `[context-server] Detected runtime: ${detectedRuntime.runtime} (hookPolicy=${detectedRuntime.hookPolicy})`,\n1785:   );\n1786: \n1787:   validateConfiguredEmbeddingsProvider();\n1788: \n1789:   // Refuse to boot as a second writer BEFORE anything else initializes. The\n1790:   // kernel-held sidecar lock survives every crash mode; a losing cold-spawn\n1791:   // must exit before it can touch the database, and the launcher converts\n1792:   // this exit code into a bridge to the live owner.\n1793:   try {\n1794:     acquireDbInstanceLock(vectorIndex.getDbPath() || DATABASE_PATH);\n1795:   } catch (error: unknown) {\n1796:     if (error instanceof VectorIndexError && error.code === VectorIndexErrorCode.DB_LOCK_HELD) {\n1797:       console.error(`[context-server] ${error.message}`);\n1798:       process.exit(EXIT_DB_LOCK_HELD);\n1799:     }\n1800:     throw error;\n1801:   }\n1802: \n1803:   registerInitTasks(async () => {\n1804:     console.error('[context-server] Initializing database...');\n1805:     let startupDb: Database.Database;\n1806:     try {\n1807:       startupDb = vectorIndex.initializeDb();\n1808:     } catch (error: unknown) {\n1809:       if (error instanceof VectorIndexError && error.code === VectorIndexErrorCode.DB_LOCK_HELD) {\n1810:         // Fail this caller's request with a structured error, then exit with\n1811:         // the lock-held code so the launcher bridges to the live owner\n1812:         // instead of relaunching a doomed second writer.\n1813:         setImmediate(() => { void fatalShutdown(error.message, EXIT_DB_LOCK_HELD); });\n1814:       }\n1815:       throw error;\n1816:     }\n1817:     console.error('[context-server] Database initialized');\n1818:     console.error('[context-server] Database path: ' + DATABASE_PATH);\n1819: \n1820:     // Idempotency receipts are replay caches. This is the ONLY sweep: it runs\n1821:     // once at boot, so the TTL is enforced across daemon restarts only. A warm\n1822:     // daemon running longer than the receipt TTL never re-sweeps, so rows past\n1823:     // TTL persist and the table grows until the next restart. That unbounded\n1824:     // growth is the accepted tradeoff (receipts are small and stale replays are\n1825:     // already gated by the active-row identity recheck at lookup time); if a\n1826:     // long-lived daemon needs mid-run expiry, add a bounded periodic/on-write\n1827:     // sweep here. Best-effort: a sweep failure never blocks boot.\n1828:     try {\n1829:       const prunedReceipts = pruneExpiredIdempotencyReceipts(startupDb);\n1830:       if (prunedReceipts > 0) {\n1831:         console.error(`[context-server] Pruned ${prunedReceipts} expired idempotency receipt(s)`);\n1832:       }\n1833:     } catch (_: unknown) { /* best-effort */ }\n1834: \n1835:     // Opt-in (SPECKIT_INCLUDE_ARCHIVED_VECTOR, default off): admit archived/cold rows\n1836:     // whose logical key has no active winner into the vector projection so the semantic\n1837:     // lane can reach them. Self-gated and idempotent; best-effort never blocks boot.\n1838:     try {\n1839:       const cold = backfillColdOrphanProjection(startupDb);\n1840:       if (cold.admitted > 0) {\n1841:         console.error(`[context-server] Admitted ${cold.admitted} archived/cold row(s) into the vector projection`);\n1842:       }\n1843:     } catch (_: unknown) { /* best-effort */ }\n1844: \n1845:   try {\n1846:     const active = await ensureActiveEmbedder(startupDb, { timeoutMs: API_KEY_VALIDATION_TIMEOUT_MS });\n1847:     vectorIndex.attachActiveVectorShardForActiveProfile(startupDb);\n1848:     console.error(\n1849:       `[context-server] Active embedder: ${active.name} (${active.dim}d${active.provider ? `, ${active.provider}` : ''})`,\n1850:     );\n1851:   } catch (error: unknown) {\n1852:     const message = error instanceof Error ? error.message : String(error);\n1853:     console.error(`[context-server] FATAL: ${message}`);\n1854:     // Throw (not process.exit) so a bad first call fails THAT caller's tool request with a\n1855:     // structured error while the shared daemon stays alive. The init guard resets and retries\n1856:     // on the next memory-runtime call, so a transient embedder failure self-heals.\n1857:     throw new Error(`memory runtime init failed (embedder): ${message}`);\n1858:   }\n1859: \n1860:   // Pre-Flight API Key Validation\n1861:   // Validates API key at startup to fail fast with actionable error messages\n1862:   // Skip validation if SPECKIT_SKIP_API_VALIDATION=true (for testing/CI)\n1863:   let startupEmbeddingConfig: Awaited<ReturnType<typeof resolveStartupEmbeddingConfig>> | null = null;\n1864:   if (process.env.SPECKIT_SKIP_API_VALIDATION !== 'true') {\n1865:     console.error('[context-server] Validating embedding API key...');\n1866:     try {\n1867:       startupEmbeddingConfig = await resolveStartupEmbeddingConfig({ timeout: API_KEY_VALIDATION_TIMEOUT_MS });\n1868:       const validation: ApiKeyValidation = startupEmbeddingConfig.validation;\n1869: \n1870:       if (!validation.valid) {\n1871:         if (validation.networkError) {\n1872:           // Transient network failure — warn and continue, validation will occur on first use\n1873:           console.warn('[context-server] ===== API KEY VALIDATION SKIPPED (network error) =====');\n1874:           console.warn(`[context-server] Provider: ${validation.provider}`);\n1875:           console.warn(`[context-server] Error: ${validation.error}`);\n1876:           if (validation.actions) {\n1877:             console.warn('[context-server] Recovery Actions:');\n1878:             validation.actions.forEach((action: string, i: number) => {\n1879:               console.warn(`[context-server]   ${i + 1}. ${action}`);\n1880:             });\n1881:           }\n1882:           console.warn('[context-server] Continuing startup — validation will occur on first use');\n1883:         } else {\n1884:           console.error('[context-server] ===== API KEY VALIDATION FAILED =====');\n1885:           console.error(`[context-server] Provider: ${validation.provider}`);\n1886:           console.error(`[context-server] Error: ${validation.error}`);\n1887:           console.error(`[context-server] Error Code: ${validation.errorCode || 'E050'}`);\n1888:           if (validation.actions) {\n1889:             console.error('[context-server] Recovery Actions:');\n1890:             validation.actions.forEach((action: string, i: number) => {\n1891:               console.error(`[context-server]   ${i + 1}. ${action}`);\n1892:             });\n1893:           }\n1894:           console.error('[context-server] =====================================');\n1895:           console.error('[context-server] FATAL: Cannot start MCP server with invalid API key');\n1896:           console.error('[context-server] Set SPECKIT_SKIP_API_VALIDATION=true to bypass (not recommended)');\n1897:           // Throw (not process.exit) so the shared daemon survives one bad first call. Tagged so\n1898:           // the enclosing transient-error catch RE-THROWS it (rather than swallowing it into the\n1899:           // \"continue\" path), letting the init guard surface it as a structured tool error + retry.\n1900:           throw Object.assign(\n1901:             new Error(`embedding API key validation failed: ${validation.error ?? validation.errorCode ?? 'invalid key'}`),\n1902:             { speckitInitHardFail: true },\n1903:           );\n1904:         }\n1905:       }\n1906: \n1907:       if (validation.warning) {\n1908:         console.warn(`[context-server] API key warning: ${validation.warning}`);\n1909:       }\n1910: \n1911:       if (validation.valid) {\n1912:         console.error(`[context-server] API key validated (provider: ${validation.provider})`);\n1913:       }\n1914:     } catch (validationError: unknown) {\n1915:       // A tagged hard-fail (invalid API key) must propagate to the init guard so the daemon does\n1916:       // not silently start with a known-bad key; only genuine transient validation errors fall\n1917:       // through to \"continue, validate on first use\".\n1918:       if (validationError && typeof validationError === 'object'\n1919:           && (validationError as { speckitInitHardFail?: boolean }).speckitInitHardFail) {\n1920:         throw validationError;\n1921:       }\n1922:       const message = validationError instanceof Error ? validationError.message : String(validationError);\n1923:       console.error(`[context-server] API key validation error: ${message}`);\n1924:       console.error('[context-server] Continuing startup - validation will occur on first use');\n1925:     }\n1926:   } else {\n1927:     console.warn('[context-server] API key validation skipped (SPECKIT_SKIP_API_VALIDATION=true)');\n1928:   }\n1929: \n1930:   if (!process.env.EMBEDDING_DIM) {\n1931:     process.env.EMBEDDING_DIM = String(\n1932:       startupEmbeddingConfig?.dimension ?? getStartupEmbeddingDimension(),\n1933:     );\n1934:   }\n1935: \n1936:   // Initialize db-state module with dependencies\n1937:   // P4-12/P4-19 FIX: Pass sessionManager and incrementalIndex so db-state can\n1938:   // Refresh their DB handles during reinitializeDatabase(), preventing stale refs.\n1939:   initDbState({\n1940:     vectorIndex,\n1941:     checkpoints: checkpointsLib,\n1942:     accessTracker,\n1943:     hybridSearch,\n1944:     sessionManager,\n1945:     incrementalIndex,\n1946:     dbConsumers: [\n1947:       sessionBoost,\n1948:       causalBoost,\n1949:       historyStore,\n1950:       workingMemory,\n1951:       attentionDecay,\n1952:       coActivation,\n1953:     ],\n1954:   });\n1955: \n1956:   console.error('[context-server] Lazy loading enabled - embedding model will initialize on first use');\n1957:   console.error('[context-server] SPECKIT_EAGER_WARMUP and SPECKIT_LAZY_LOADING are deprecated compatibility flags');\n1958: \n1959:   // Integrity check and module initialization\n1960:   try {\n1961:     const report = vectorIndex.verifyIntegrity();\n1962:     console.error(`[context-server] Integrity check: ${report.totalMemories}/${report.totalMemories + report.missingVectors} valid entries`);\n1963:     if (report.orphanedVectors > 0) console.error(`[context-server] WARNING: ${report.orphanedVectors} orphaned entries detected`);\n1964: \n1965:     // Validate embedding dimension matches database\n1966:     const dimValidation = vectorIndex.validateEmbeddingDimension();\n1967:     if (!dimValidation.valid) {\n1968:       console.error(`[context-server] ===== EMBEDDING DIMENSION MISMATCH =====`);\n1969:       console.error(`[context-server] ${dimValidation.warning}`);\n1970:       console.error(`[context-server] =========================================`);\n1971:       console.error('[context-server] FATAL: Refusing to start with mismatched embedding dimensions');\n1972:       throw new Error(dimValidation.warning ?? 'Embedding dimension mismatch between provider and database');\n1973:     } else if (dimValidation.stored) {\n1974:       console.error(`[context-server] Embedding dimension validated: ${dimValidation.stored}`);\n1975:     }\n1976: \n1977:     const database = vectorIndex.getDb();\n1978:     if (!database) {\n1979:       throw new Error('Database not initialized after initializeDb(). Cannot start server.');\n1980:     }\n1981: \n1982:     try {\n1983:       initScoringObservability(database);\n1984:       console.error('[context-server] Scoring observability initialized');\n1985:     } catch (scoringObsErr: unknown) {\n1986:       const message = scoringObsErr instanceof Error ? scoringObsErr.message : String(scoringObsErr);\n1987:       console.warn('[context-server] Scoring observability init failed (non-fatal):', message);\n1988:     }\n1989: \n1990:     const installGraphRefresh = (refreshDb: Database.Database): void => {\n1991:       registerGlobalRefreshFn(() => {\n1992:         const dirtyNodeIds = Array.from(getDirtyNodes().nodeIds);\n1993:         if (dirtyNodeIds.length === 0) {\n1994:           return;\n1995:         }\n1996: \n1997:         const updatedEdges = recomputeLocal(refreshDb, dirtyNodeIds);\n1998:         clearDirtyNodes();\n1999:         console.error(\n2000:           '[context-server] Scheduled graph refresh applied: dirty_nodes=%d, updated_edges=%d',\n2001:           dirtyNodeIds.length,\n2002:           updatedEdges,\n2003:         );\n2004:       });\n2005:     };\n2006: \n2007:     registerDatabaseRebindListener((nextDatabase) => {\n2008:       const reboundDatabase = nextDatabase as Database.Database;\n2009:       rebindScoringObservability(reboundDatabase);\n2010:       rebindExtractionAdapter(reboundDatabase);\n2011: \n2012:       cancelScheduledRefresh();\n2013:       installGraphRefresh(reboundDatabase);\n2014:       if (getDirtyNodes().nodeIds.size > 0) {\n2015:         scheduleGlobalRefresh();\n2016:       }\n2017: \n2018:       shadowEvaluationRuntime.stopShadowEvaluationScheduler();\n2019:       shadowEvaluationRuntime.startShadowEvaluationScheduler(reboundDatabase);\n2020:     });\n2021: \n2022:     if (isLearnedFeedbackEnabled()) {\n2023:       try {\n2024:         const migrated = migrateLearnedTriggers(database);\n2025:         const isolated = verifyFts5Isolation(database);\n2026:         console.error(`[context-server] Learned triggers ready (migrated=${migrated}, fts5Isolated=${isolated})`);\n2027:       } catch (learnedErr: unknown) {\n2028:         const message = learnedErr instanceof Error ? learnedErr.message : String(learnedErr);\n2029:         throw new Error(`[context-server] Learned feedback migration/isolation failed: ${message}`);\n2030:       }\n2031:     }\n2032: \n2033:     // Check SQLite version meets minimum requirement (3.35.0+)\n2034:     checkSqliteVersion(database);\n2035: \n2036:     // Verify WAL mode is active for operational concurrency guarantees.\n2037:     const walRow = database.prepare('PRAGMA journal_mode').get() as { journal_mode?: string } | undefined;\n2038:     const journalMode = String(walRow?.journal_mode ?? '').toLowerCase();\n2039:     if (journalMode !== 'wal') {\n2040:       database.pragma('journal_mode = WAL');\n2041:       console.warn('[context-server] journal_mode was not WAL; forcing WAL mode');\n2042:     }\n2043: \n2044:     const memoryCountRow = database.prepare('SELECT COUNT(*) as cnt FROM memory_index').get() as { cnt?: number } | undefined;\n2045:     const memoryCount = Number(memoryCountRow?.cnt ?? 0);\n2046:     let projectionCount = 0;\n2047:     let projectionTableExists = true;\n2048: \n2049:     try {\n2050:       const projectionCountRow = database.prepare('SELECT COUNT(*) as cnt FROM active_memory_projection').get() as { cnt?: number } | undefined;\n2051:       projectionCount = Number(projectionCountRow?.cnt ?? 0);\n2052:     } catch {\n2053:       projectionTableExists = false;\n2054:     }\n2055: \n2056:     console.error('[context-server] Startup health: memory_index=%d, active_memory_projection=%d', memoryCount, projectionCount);\n2057: \n2058:     if (memoryCount > 0 && (!projectionTableExists || projectionCount === 0)) {\n2059:       const result = runLineageBackfill(database);\n2060:       console.error('[context-server] Auto-backfill triggered: %d rows seeded into active_memory_projection', result.seeded);\n2061:     }\n2062: \n2063:     if (memoryCount === 0 && projectionCount === 0) {\n2064:       console.error('[context-server] WARNING: Database has 0 memories — search will return no results until memories are saved');\n2065:     }\n2066: \n2067:     const graphSearchFn = isGraphUnifiedEnabled()\n2068:       ? createUnifiedGraphSearchFn(database)\n2069:       : null;\n2070: \n2071:     checkpointsLib.init(database);\n2072:     accessTracker.init(database);\n2073:     hybridSearch.init(database, vectorIndex.vectorSearch, graphSearchFn);\n2074: \n2075:     // Keep db-state reinitialization wiring aligned with startup search wiring.\n2076:     initDbState({ graphSearchFn });\n2077:     sessionBoost.init(database);\n2078:     causalBoost.init(database);\n2079:     installGraphRefresh(database);\n2080:     console.error('[context-server] Checkpoints, access tracker, hybrid search, session boost, and causal boost initialized');\n2081:     runCheckpointNeedsRebuildRepair(database, 'boot');\n2082: \n2083:     // P3-04/014: Warm in-memory BM25 only when the selected lexical engine needs it.\n2084:     if (bm25Index.shouldWarmInMemoryBm25(database)) {\n2085:       try {\n2086:         const bm25 = bm25Index.getIndex();\n2087:         const count = bm25.rebuildFromDatabase(database);\n2088:         console.error(`[context-server] BM25 index rebuilt from database: ${count} documents`);\n2089:       } catch (bm25Err: unknown) {\n2090:         const message = bm25Err instanceof Error ? bm25Err.message : String(bm25Err);\n2091:         console.warn('[context-server] BM25 index rebuild failed:', message);\n2092:       }\n2093:     }\n2094: \n2095:     // Cognitive memory modules\n2096:     try {\n2097:       workingMemory.init(database);\n2098:       attentionDecay.init(database);\n2099:       coActivation.init(database);\n2100:       console.error('[context-server] Cognitive memory modules initialized');\n2101:       console.error(`[context-server] Working memory: ${workingMemory.isEnabled()}, Co-activation: ${coActivation.isEnabled()}`);\n2102:     } catch (cognitiveErr: unknown) {\n2103:       const message = cognitiveErr instanceof Error ? cognitiveErr.message : String(cognitiveErr);\n2104:       console.warn('[context-server] Cognitive modules partially failed:', message);\n2105:     }\n2106: \n2107:     try {\n2108:       initExtractionAdapter(database, registerAfterToolCallback);\n2109:       console.error('[context-server] Extraction adapter initialized');\n2110:     } catch (extractionErr: unknown) {\n2111:       const message = extractionErr instanceof Error ? extractionErr.message : String(extractionErr);\n2112:       throw new Error(`[context-server] Extraction adapter startup failed: ${message}`);\n2113:     }\n2114: \n2115:     try {\n2116:       const resumedEmbedderJobs = resumeReindexJobs(database);\n2117:       if (resumedEmbedderJobs.length > 0) {\n2118:         console.error('[context-server] Resumed embedder re-index jobs: %d', resumedEmbedderJobs.length);\n2119:       }\n2120:     } catch (reindexErr: unknown) {\n2121:       const message = reindexErr instanceof Error ? reindexErr.message : String(reindexErr);\n2122:       console.warn('[context-server] Embedder re-index resume failed:', message);\n2123:     }\n2124: \n2125:     // Background retry job for pending embeddings\n2126:     // Processes memories with failed embeddings in the background.\n2127:     // No options passed: use BACKGROUND_JOB_CONFIG, which reads SPECKIT_RETRY_INTERVAL_MS /\n2128:     // SPECKIT_RETRY_BATCH_SIZE / SPECKIT_RETRY_ENABLED. Passing hardcoded options here would\n2129:     // spread after the env-derived config and silently clobber the tuned values.\n2130:     try {\n2131:       const retryJobResult = retryManager.startBackgroundJob();\n2132:       if (retryJobResult) {\n2133:         const { intervalMs, batchSize } = retryManager.BACKGROUND_JOB_CONFIG;\n2134:         console.error(`[context-server] Background retry job started (interval: ${intervalMs}ms, batch: ${batchSize})`);\n2135:       } else {\n2136:         console.error('[context-server] Background retry job already running or disabled');\n2137:       }\n2138:     } catch (retryErr: unknown) {\n2139:       const message = retryErr instanceof Error ? retryErr.message : String(retryErr);\n2140:       console.warn('[context-server] Background retry job failed to start:', message);\n2141:     }\n2142: \n2143:     // Shadow feedback holdout evaluation background scheduler.\n2144:     // Replays recent production queries through a shadow-only path once the\n2145:     // weekly holdout cycle is due. Fail-safe and gated by SPECKIT_SHADOW_FEEDBACK.\n2146:     try {\n2147:       const shadowSchedulerStarted = shadowEvaluationRuntime.startShadowEvaluationScheduler(database);\n2148:       if (shadowSchedulerStarted) {\n2149:         console.error('[context-server] Shadow feedback evaluation scheduler started');\n2150:       } else {\n2151:         console.error('[context-server] Shadow feedback evaluation scheduler not started (already running or disabled)');\n2152:       }\n2153:     } catch (shadowEvalErr: unknown) {\n2154:       const message = shadowEvalErr instanceof Error ? shadowEvalErr.message : String(shadowEvalErr);\n2155:       console.warn('[context-server] Shadow feedback evaluation scheduler failed to start:', message);\n2156:     }\n2157: \n2158:     // Batch feedback learning — runs one cycle at startup (shadow-only, no live ranking mutations).\n2159:     // Feature-flag gated by SPECKIT_BATCH_LEARNED_FEEDBACK (default ON, graduated).\n2160:     try {\n2161:       const batchResult = runBatchLearning(database);\n2162:       if (batchResult.candidatesEvaluated > 0) {\n2163:         console.error(`[context-server] Batch learning: ${batchResult.shadowApplied} shadow-applied, ${batchResult.skippedMinSupport} skipped (min-support), window=${Math.round((batchResult.runAt - batchResult.windowStart) / 86_400_000)}d`);\n2164:       } else {\n2165:         console.error('[context-server] Batch learning: no eligible candidates in window (or flag disabled)');\n2166:       }\n2167:     } catch (batchErr: unknown) {\n2168:       const message = batchErr instanceof Error ? batchErr.message : String(batchErr);\n2169:       console.warn('[context-server] Batch learning failed (non-fatal):', message);\n2170:     }\n2171: \n2172:     // Session deduplication module\n2173:     try {\n2174:       const sessionResult = sessionManager.init(database);\n2175:       if (sessionResult.success) {\n2176:         console.error(`[context-server] Session manager initialized (enabled: ${sessionManager.isEnabled()})`);\n2177: \n2178:         // Crash Recovery Pattern\n2179:         // Reset any sessions that were active when server last crashed\n2180:         const recoveryResult = sessionManager.resetInterruptedSessions();\n2181:         if (recoveryResult.interruptedCount > 0) {\n2182:           console.error(`[context-server] Crash recovery: marked ${recoveryResult.interruptedCount} sessions as interrupted`);\n2183:           // Log interrupted sessions for visibility\n2184:           const interrupted = sessionManager.getInterruptedSessions();\n2185:           if (interrupted.sessions && interrupted.sessions.length > 0) {\n2186:             console.error('[context-server] Recoverable sessions:', interrupted.sessions.map((s: { sessionId: string }) => s.sessionId).join(', '));\n2187:           }\n2188:         }\n2189:       } else {\n2190:         console.warn('[context-server] Session manager initialization returned:', sessionResult.error);\n2191:       }\n2192:     } catch (sessionErr: unknown) {\n2193:       const message = sessionErr instanceof Error ? sessionErr.message : String(sessionErr);\n2194:       console.warn('[context-server] Session manager failed:', message);\n2195:     }\n2196: \n2197:     // Async ingestion job queue initialization + crash recovery reset.\n2198:     try {\n2199:       const ingestInit = initIngestJobQueue({\n2200:         processFile: async (filePath: string, governance) => {\n2201:           await indexSingleFile(filePath, false, governance\n2202:             ? { governance }\n2203:             : {\n2204:                 provenance: {\n2205:                   provenanceSource: 'memory_ingest_start',\n2206:                   provenanceActor: 'async-ingest',\n2207:                   tool: 'memory_ingest_start',\n2208:                 },\n2209:               });\n2210:         },\n2211:       });\n2212:       if (ingestInit.resetCount > 0) {\n2213:         console.error(`[context-server] Ingest crash recovery reset ${ingestInit.resetCount} incomplete job(s) to queued`);\n2214:       }\n2215:     } catch (ingestInitErr: unknown) {\n2216:       const message = ingestInitErr instanceof Error ? ingestInitErr.message : String(ingestInitErr);\n2217:       console.warn('[context-server] Ingest queue init failed:', message);\n2218:     }\n2219: \n2220:     // Background index-scan job store init + crash-recovery reset. An interrupted\n2221:     // scan re-runs fresh, so incomplete jobs are marked failed (never re-enqueued);\n2222:     // a hard-crash scan lease is already reaped by the lease-expiry path.\n2223:     try {\n2224:       ensureMaintenanceJobsTable();\n2225:       const resetScanJobs = resetRunningJobsForKind('index_scan', { to: 'failed' });\n2226:       if (resetScanJobs.length > 0) {\n2227:         console.error(`[context-server] Index scan crash recovery marked ${resetScanJobs.length} incomplete job(s) failed`);\n2228:       }\n2229:     } catch (scanJobInitErr: unknown) {\n2230:       const message = scanJobInitErr instanceof Error ? scanJobInitErr.message : String(scanJobInitErr);\n2231:       console.warn('[context-server] Maintenance job store init failed:', message);\n2232:     }\n2233: \n2234:     // Optional real-time markdown watcher for automatic re-indexing.\n2235:     if (isFileWatcherEnabled()) {\n2236:       try {\n2237:         const watchPaths = getSpecsBasePaths(DEFAULT_BASE_PATH);\n2238:         if (watchPaths.length > 0) {\n2239:           fileWatcher = startFileWatcher({\n2240:             paths: watchPaths,\n2241:             reindexFn: async (filePath: string) => {\n2242:               const result = await indexSingleFile(filePath, false);\n2243:               if (isMutationStatus(result.status)) {\n2244:                 try {\n2245:                   runPostMutationHooks('scan', {\n2246:                     indexed: result.status === 'indexed' || result.status === 'deferred' ? 1 : 0,\n2247:                     updated: result.status === 'updated' || result.status === 'reinforced' ? 1 : 0,\n2248:                     staleDeleted: 0,\n2249:                     staleDeleteFailed: 0,\n2250:                     operation: 'file-watcher-reindex',\n2251:                     filePath,\n2252:                     status: result.status,\n2253:                   });\n2254:                 } catch (_error: unknown) {\n2255:                   // Non-fatal by design for file-watcher callback path.\n2256:                 }\n2257:               }\n2258:             },\n2259:             removeFn: async (filePath: string) => {\n2260:               await removeIndexedMemoriesForFile(filePath);\n2261:             },\n2262:           });\n2263:           console.error(`[context-server] File watcher started for ${watchPaths.length} path(s)`);\n2264:         } else {\n2265:           console.warn('[context-server] File watcher enabled, but no spec directories were found');\n2266:         }\n2267:       } catch (watchErr: unknown) {\n2268:         const message = watchErr instanceof Error ? watchErr.message : String(watchErr);\n2269:         console.warn('[context-server] File watcher startup failed:', message);\n2270:       }\n2271: \n2272:     }\n2273:   } catch (err: unknown) {\n2274:     const message = err instanceof Error ? err.message : String(err);\n2275:     console.error('[context-server] Integrity check failed:', message);\n2276:     throw err instanceof Error ? err : new Error(message);\n2277:   }\n2278: \n2279:     // Background startup scan\n2280:     setImmediate(() => {\n2281:       try {\n2282:         runCheckpointNeedsRebuildRepair(vectorIndex.getDb(), 'startup-scan');\n2283:       } catch (repairErr: unknown) {\n2284:         const message = repairErr instanceof Error ? repairErr.message : String(repairErr);\n2285:         console.warn('[context-server] Pre-scan checkpoint derived rebuild repair failed (non-fatal):', message);\n2286:       }\n2287:       startupScanPromise = startupScan(DEFAULT_BASE_PATH);\n2288:     });\n2289:   });\n2290: \n2291:   // Assign to module-level transport (not const) so shutdown handlers can close it\n2292:   if (isDynamicInitEnabled()) {\n2293:     try {\n2294:       const dynamicInstructions = await buildServerInstructions();\n2295:       if (dynamicInstructions.length > 0) {\n2296:         serverWithInstructions.setInstructions?.(dynamicInstructions);\n2297:       }\n2298:     } catch (instructionErr: unknown) {\n2299:       const message = instructionErr instanceof Error ? instructionErr.message : String(instructionErr);\n2300:       console.warn('[context-server] Dynamic instructions init failed (non-fatal):', message);\n2301:     }\n2302:   }\n2303: \n2304:   const backendOnly = process.env.SPECKIT_BACKEND_ONLY === '1';\n2305:   if (!backendOnly) {\n2306:     transportConnectedAt = new Date().toISOString();\n2307:     transport = new StdioServerTransport();\n2308:     await server.connect(transport);\n2309:   }\n2310:   scheduleBootFtsIntegrityCheck();\n2311:   registerInterval(() => vectorIndex.checkpointAllWal(), 300_000, { unref: true });\n2312:   launcherIdleMonitor = createLauncherIdleMonitor({\n2313:     serviceName: 'context-server',\n2314:     getActiveClientCount: () => getIpcBridgeStats().secondary_clients_count,\n2315:     onIdle: () => fatalShutdown('Launcher idle timeout reached, shutting down...', 0),\n2316:     log: (message) => console.error(message),\n2317:     stdin: backendOnly ? null : undefined,\n2318:   });\n2319:   ipcBridge = await startIpcSocketServer({\n2320:     socketPath: resolveIpcSocketPath(DATABASE_DIR),\n2321:     createServer: () => {\n2322:       const secondaryServer = createContextMcpServer();\n2323:       registerContextServerHandlers(secondaryServer);\n2324:       return secondaryServer;\n2325:     },\n2326:     log: (message) => console.error(message),\n2327:     onActivity: () => launcherIdleMonitor?.markActivity(),\n2328:   });\n2329:   const rssMb = Math.round(process.memoryUsage().rss / 1024 / 1024);\n2330:   console.error(`[health] startup pid=${process.pid} rss=${rssMb}MB uptime=0s`);\n2331:   console.error(backendOnly\n2332:     ? '[context-server] Context MCP server running on IPC socket only'\n2333:     : '[context-server] Context MCP server running on stdio and IPC socket');\n2334: \n2335: }\n2336: \n2337: const isMain = process.argv[1] && decodeURIComponent(import.meta.url).endsWith(process.argv[1].replace(/\\\\/g, '/'));\n2338: \n2339: if (isMain) {\n2340:   main().catch((err: unknown) => { console.error('[context-server] Fatal error:', err); process.exit(1); });\n2341: }\n\n(End of file - total 2341 lines)\n</content>","metadata":{"preview":"          if (dispatchGraphContext && !result.isError) {\n            meta.graphContext = dispatchGraphContext;\n          }\n          const budget = getTokenBudget(name);\n          meta.tokenBudget = budget;\n          syncEnvelopeTokenCount(envelope);\n\n          if (typeof meta.tokenCount === 'number' && meta.tokenCount > budget) {\n            console.error(`[token-budget] ${name} response (${meta.tokenCount} tokens) exceeds budget (${budget})`);\n\n            // First-call session priming rides along in meta and can dwarf a\n            // small tool's own payload. Slim it BEFORE touching the tool's\n            // results: the tool's answer is the caller's data, the priming\n            // payload is recoverable via memory_search/memory_context.\n            if (isRecord(meta.sessionPriming)) {\n              const priming = meta.sessionPriming as Record<string, unknown>;\n              const alreadyTrimmed = priming.trimmed === true;\n              if (!alreadyTrimmed) {\n                const constitutionalCount = Array.isArray(priming.constitutional)\n                  ? priming.constitutional.length","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/context-server.ts","text":"          if (dispatchGraphContext && !result.isError) {\n            meta.graphContext = dispatchGraphContext;\n          }\n          const budget = getTokenBudget(name);\n          meta.tokenBudget = budget;\n          syncEnvelopeTokenCount(envelope);\n\n          if (typeof meta.tokenCount === 'number' && meta.tokenCount > budget) {\n            console.error(`[token-budget] ${name} response (${meta.tokenCount} tokens) exceeds budget (${budget})`);\n\n            // First-call session priming rides along in meta and can dwarf a\n            // small tool's own payload. Slim it BEFORE touching the tool's\n            // results: the tool's answer is the caller's data, the priming\n            // payload is recoverable via memory_search/memory_context.\n            if (isRecord(meta.sessionPriming)) {\n              const priming = meta.sessionPriming as Record<string, unknown>;\n              const alreadyTrimmed = priming.trimmed === true;\n              if (!alreadyTrimmed) {\n                const constitutionalCount = Array.isArray(priming.constitutional)\n                  ? priming.constitutional.length\n                  : 0;\n                meta.sessionPriming = {\n                  trimmed: true,\n                  constitutionalCount,\n                  ...(isRecord(priming.primePackage) ? { primePackage: priming.primePackage } : {}),\n                };\n                syncEnvelopeTokenCount(envelope);\n                if (Array.isArray(envelope.hints)) {\n                  envelope.hints.push(`Session priming trimmed to fit the ${budget} token budget; full constitutional content remains retrievable via memory_search`);\n                }\n                meta.sessionPrimingTrimmed = true;\n              }\n            }\n\n            // Attempt to truncate results array to fit within budget — only\n            // when still over after the priming slim above, because the loop\n            // below pops a result before it re-measures.\n            const stillOverBudget = typeof meta.tokenCount === 'number' && meta.tokenCount > budget;\n            const innerResults = data?.results;\n            if (stillOverBudget && Array.isArray(innerResults) && innerResults.length > 1) {\n              const originalCount = innerResults.length;\n              // Results are typically sorted by score (highest first)\n              // Remove from end (lowest-scored) until within budget\n              while (innerResults.length > 1) {\n                innerResults.pop();\n                // Recalculate token count from the full envelope\n                // (not just results) so trace metadata is included in the budget.\n                syncEnvelopeTokenCount(envelope);\n                if (typeof meta.tokenCount === 'number' && meta.tokenCount <= budget) break;\n              }\n              if (data && data.count !== undefined) {\n                data.count = innerResults.length;\n              }\n              // Recompute constitutionalCount from the results that survived truncation\n              // so consumers reading data.constitutionalCount or envelope.summary see\n              // counts that agree with data.results.length.\n              if (data) {\n                const survivingConstitutionalCount = innerResults.filter(\n                  (r: unknown) => r !== null && typeof r === 'object' && (r as Record<string, unknown>).isConstitutional === true\n                ).length;\n                data.constitutionalCount = survivingConstitutionalCount;\n                if (typeof envelope.summary === 'string') {\n                  envelope.summary = survivingConstitutionalCount > 0\n                    ? `Found ${innerResults.length} memories (${survivingConstitutionalCount} constitutional)`\n                    : `Found ${innerResults.length} memories`;\n                }\n              }\n              if (Array.isArray(envelope.hints)) {\n                envelope.hints.push(`Token budget enforced: truncated ${originalCount} → ${innerResults.length} results to fit ${budget} token budget`);\n              }\n              meta.tokenBudgetTruncated = true;\n              meta.originalResultCount = originalCount;\n              meta.returnedResultCount = innerResults.length;\n            } else if (stillOverBudget) {\n              // No truncatable results array — add warning hint only\n              if (Array.isArray(envelope.hints)) {\n                envelope.hints.push(`Response exceeds token budget (${meta.tokenCount}/${budget})`);\n              }\n            }\n          }\n          result.content[0].text = serializeEnvelopeWithTokenCount(envelope);\n        }\n      } catch (_parseErr: unknown) {\n        // Non-JSON response, skip token budget injection\n      }\n    }\n\n    return result;\n  } catch (error: unknown) {\n    // Include recovery hints in all error responses\n    const err = error instanceof Error ? error : new Error(String(error));\n    try {\n      const errorResponse = buildErrorResponse(name, err, args);\n      // eslint-disable-next-line @typescript-eslint/no-explicit-any\n      return wrapForMCP(errorResponse as any, true);\n    } catch (wrapError: unknown) {\n      const fallbackError = wrapError instanceof Error ? wrapError.message : String(wrapError);\n      console.error(`[context-server] Failed to build MCP error envelope for '${name}': ${fallbackError}`);\n      const fallbackCode = getDefaultErrorCodeForTool(name);\n      return createMCPErrorResponse({\n        tool: name,\n        error: 'Request failed.',\n        code: fallbackCode,\n        recovery: getRecoveryHint(name, fallbackCode),\n      });\n    }\n  }\n  });\n}\n\nregisterContextServerHandlers(server);\n\n/* ───────────────────────────────────────────────────────────────\n   6. STARTUP SCAN & PENDING FILE RECOVERY\n──────────────────────────────────────────────────────────────── */\n\nlet startupScanInProgress = false;\n// Tracked (not fire-and-forget) so fatalShutdown can await the scan to a safe stopping point before\n// closeDb — a resuming scan writes through the DB and would otherwise reopen a closed connection.\nlet startupScanPromise: Promise<void> | null = null;\n\nfunction getStartupWorkspaceRoots(basePath: string): string[] {\n  const configuredMemoryRoot = process.env.MEMORY_BASE_PATH?.trim();\n  const derivedMemoryRoot = configuredMemoryRoot ? path.resolve(process.cwd(), configuredMemoryRoot) : null;\n  return Array.from(new Set(\n    [basePath, derivedMemoryRoot, ...ALLOWED_BASE_PATHS]\n      .filter((root): root is string => typeof root === 'string' && root.trim().length > 0)\n      .map((root) => path.resolve(root))\n  ));\n}\n\nfunction getPendingRecoveryLocations(basePath: string): string[] {\n  const scanLocations: string[] = [];\n  for (const root of getStartupWorkspaceRoots(basePath)) {\n    scanLocations.push(path.join(root, 'specs'));\n    scanLocations.push(path.join(root, '.opencode', 'specs'));\n    const skillDir = path.join(root, '.opencode', 'skills');\n    try {\n      if (!fs.existsSync(skillDir)) continue;\n      for (const entry of fs.readdirSync(skillDir, { withFileTypes: true })) {\n        if (!entry.isDirectory() || entry.name.startsWith('.')) continue;\n        const constDir = path.join(skillDir, entry.name, 'constitutional');\n        if (fs.existsSync(constDir)) scanLocations.push(constDir);\n      }\n    } catch (_error: unknown) {\n      // Non-fatal: constitutional directory discovery failed\n    }\n  }\n  return Array.from(new Set(scanLocations.filter((location) => fs.existsSync(location))));\n}\n\n/**\n * Recover pending memory files on MCP startup.\n * Pending files processed by recovery job on next startup.\n *\n * Scans for files with _pending suffix (created when index failed after file write)\n * and attempts to index them.\n */\nasync function recoverPendingFiles(basePath: string): Promise<PendingRecoveryResult> {\n  console.error('[context-server] Checking for pending memory files...');\n\n  try {\n    // Restrict scan to known memory file locations to prevent OOM when scanning large workspaces.\n    // Share the same allowed-root expansion that startup indexing uses.\n    const existingScanLocations = getPendingRecoveryLocations(basePath);\n\n    // P1 FIX: Wire isCommittedInDb callback so stale pending files are detected at startup.\n    // VectorIndex.getDb() is an initializing accessor — always returns a valid DB after initializeDb().\n    const database = vectorIndex.getDb();\n    const isCommittedInDb = (originalPath: string): boolean => {\n      const row = (database.prepare('SELECT 1 FROM memory_index WHERE file_path = ?') as import('better-sqlite3').Statement).get(originalPath);\n      return !!row;\n    };\n\n    const rawResults = existingScanLocations.flatMap((location) =>\n      transactionManager.recoverAllPendingFiles(location, isCommittedInDb)\n    );\n\n    // Aggregate per-file results into a summary\n    const found = rawResults.length;\n    const recovered = rawResults.filter(r => r.recovered).length;\n    const failed = found - recovered;\n\n    const recoveryResult: PendingRecoveryResult = {\n      found,\n      processed: found,\n      recovered,\n      failed,\n      results: rawResults,\n    };\n\n    if (recoveryResult.found > 0) {\n      console.error(`[context-server] Pending file recovery: ${recoveryResult.recovered} recovered, ${recoveryResult.failed} failed (${recoveryResult.found} total)`);\n    } else {\n      console.error('[context-server] No pending memory files found');\n    }\n\n    return recoveryResult;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] Pending file recovery error: ${message}`);\n    return { found: 0, processed: 0, recovered: 0, failed: 0, results: [] };\n  }\n}\n\nasync function startupScan(basePath: string): Promise<void> {\n  if (startupScanInProgress) {\n    console.error('[context-server] Startup scan already in progress, skipping');\n    return;\n  }\n\n  startupScanInProgress = true;\n  try {\n    if (shuttingDown) return; // shutdown began before/at scan start — do not touch the DB before closeDb (the loop below also breaks on shuttingDown)\n    // Recover any pending files from previous failed index operations\n    await recoverPendingFiles(basePath);\n\n    console.error('[context-server] Starting background scan for spec documents and constitutional memories...');\n    const scanRoots = Array.from(\n      new Set(\n        [basePath, ...ALLOWED_BASE_PATHS]\n          .filter((root): root is string => typeof root === 'string' && root.trim().length > 0)\n          .map((root) => path.resolve(root))\n      )\n    );\n    const allFiles: string[] = [];\n    const seen = new Set<string>();\n\n    for (const root of scanRoots) {\n      try {\n        const rootFiles = [\n          ...memoryIndexDiscovery.findConstitutionalFiles(root),\n          ...memoryIndexDiscovery.findSpecDocuments(root),\n        ];\n\n        for (const filePath of rootFiles) {\n          const resolved = path.resolve(filePath);\n          if (!seen.has(resolved)) {\n            seen.add(resolved);\n            allFiles.push(filePath);\n          }\n        }\n      } catch (_error: unknown) {\n        // Non-fatal: skip inaccessible startup roots.\n      }\n    }\n\n    if (allFiles.length === 0) {\n      console.error('[context-server] No spec documents or constitutional memories found in workspace');\n      return;\n    }\n\n    console.error(`[context-server] Found ${allFiles.length} indexable files, checking for changes...`);\n    let indexed = 0, updated = 0, unchanged = 0, failed = 0;\n\n    for (const filePath of allFiles) {\n      if (shuttingDown) break; // stop touching the DB once shutdown begins so closeDb's checkpoint stays clean\n      try {\n        const result: IndexResult = await indexSingleFile(filePath, false);\n        if (result.status === 'indexed') indexed++;\n        else if (result.status === 'updated') updated++;\n        else unchanged++;\n      } catch (error: unknown) {\n        failed++;\n        const message = error instanceof Error ? error.message : String(error);\n        console.error(`[context-server] Failed to index ${path.basename(filePath)}: ${message}`);\n      }\n      // Yield to the poll phase periodically. indexSingleFile is mostly synchronous better-sqlite3\n      // work, so a large scan would otherwise drain as one uninterrupted microtask run and starve the\n      // IPC accept() loop for the scan's full duration. setImmediate hands control back between batches.\n      if ((indexed + updated + unchanged + failed) % 50 === 0) {\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n    }\n\n    if (indexed > 0 || updated > 0) {\n      console.error(`[context-server] Startup scan: ${indexed} new, ${updated} updated, ${unchanged} unchanged, ${failed} failed`);\n    } else {\n      console.error(`[context-server] Startup scan: all ${unchanged} files up to date`);\n    }\n\n    if (indexed > 0 || updated > 0) {\n      try {\n        runPostMutationHooks('scan', {\n          indexed,\n          updated,\n          staleDeleted: 0,\n          staleDeleteFailed: 0,\n          operation: 'startup-scan',\n        });\n      } catch (_error: unknown) {\n        // Non-fatal: startup scan must continue even if invalidation hooks fail.\n      }\n    }\n\n    // Log atomicity metrics for monitoring\n    const metrics = transactionManager.getMetrics();\n    if (metrics.totalRecoveries > 0 || metrics.totalErrors > 0) {\n      console.error(`[context-server] Atomicity metrics: ${metrics.totalAtomicWrites} successful, ${metrics.totalErrors} failed, ${metrics.totalRecoveries} recovered`);\n    }\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] Startup scan error: ${message}`);\n  } finally {\n    startupScanInProgress = false;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. GRACEFUL SHUTDOWN\n──────────────────────────────────────────────────────────────── */\n\nlet shuttingDown = false;\n// Hoist transport to module scope so shutdown handlers can close it\nlet transport: StdioServerTransport | null = null;\nlet transportConnectedAt: string | null = null;\nlet fileWatcher: FSWatcher | null = null;\nlet ipcBridge: IpcSocketServerHandle | null = null;\nlet launcherIdleMonitor: LauncherIdleMonitor | null = null;\n\n/** Maximum time (ms) to wait for async cleanup before force-exiting. */\nconst SHUTDOWN_DEADLINE_MS = 5000;\n\n/**\n * Exit code telling the launcher \"another live process holds the database\n * single-writer lock\": bridge to that owner instead of counting this exit\n * toward the crash loop. Chosen clear of the daemon's 0/1, the launcher's\n * 0/1/128, and the CLI contract's 0/1/64/69/75. Mirrored in\n * mk-spec-memory-launcher.cjs.\n */\nconst EXIT_DB_LOCK_HELD = 86;\n\nexport const __testables = {\n  runCleanupStep,\n  runAsyncCleanupStep,\n  main: () => main(),\n  getBootFtsIntegrityHealth,\n  runCheckpointNeedsRebuildRepair,\n  normalizeGraphFilePath,\n  extractFilePathsFromToolArgs,\n};\n\nasync function fatalShutdown(reason: string, exitCode: number): Promise<void> {\n  if (shuttingDown) return;\n  shuttingDown = true;\n  console.error(`[context-server] ${reason}`);\n\n  runCleanupStep('sessionManager', () => sessionManager.shutdown());\n  runCleanupStep('retryManager', () => retryManager.stopBackgroundJob());\n  // Fence the background-enrichment scheduler synchronously here, before the awaited drains below: a\n  // queued/in-flight enrichment run re-resolves the DB via requireDb() (which reopens a closed\n  // connection), so without this it could reopen the DB and re-dirty the WAL after closeDb's checkpoint.\n  runCleanupStep('backgroundEnrichment', () => shutdownBackgroundEnrichment());\n  runCleanupStep('shadowEvaluationRuntime', () => shadowEvaluationRuntime.stopShadowEvaluationScheduler());\n  runCleanupStep('scheduledGraphRefresh', () => cancelScheduledRefresh());\n  runCleanupStep('accessTracker', () => accessTracker.reset());\n  runCleanupStep('toolCache', () => toolCache.shutdown());\n  runCleanupStep('launcherIdleMonitor', () => {\n    if (launcherIdleMonitor) {\n      launcherIdleMonitor.stop();\n      launcherIdleMonitor = null;\n    }\n  });\n\n  let deadlineTimer: NodeJS.Timeout | undefined;\n  const cleanup = (async () => {\n    // Fence the startup scan before closeDb: it is otherwise fire-and-forget and writes through the\n    // DB, so a resuming scan would reopen a closed connection. It breaks on `shuttingDown` at its loop\n    // head, so awaiting it here resolves within the current file (and is bounded by SHUTDOWN_DEADLINE).\n    await runAsyncCleanupStep('startupScan', async () => {\n      if (startupScanPromise) await startupScanPromise;\n    });\n    // Drain the file watcher FIRST: fileWatcher.close() awaits in-flight reindex/remove tasks,\n    // which write through requireDb()/getDb() — and getDb() REOPENS the connection if it was\n    // already closed. So closeDb() must run AFTER the drain, otherwise a draining task reopens\n    // the DB and writes fresh WAL frames after the TRUNCATE checkpoint, leaving a non-empty WAL\n    // at rest and defeating the durability guarantee. closeDb() is\n    // synchronous, so it still runs to completion uninterrupted once reached; the SHUTDOWN_DEADLINE\n    // race only bounds the awaited drains before it, and 010's autocheckpoint keeps the at-rest WAL\n    // small even if a pathologically slow drain starves this step.\n    await runAsyncCleanupStep('fileWatcher', async () => {\n      if (fileWatcher) {\n        await fileWatcher.close();\n        fileWatcher = null;\n      }\n    });\n    // Fence the ingest worker before closeDb for the same reason as the file\n    // watcher above: the worker writes through the DB and would otherwise reopen\n    // a closed connection, re-dirtying the WAL and the unclean-shutdown marker.\n    await runAsyncCleanupStep('ingestWorker', async () => {\n      await stopIngestWorker();\n    });\n    runCleanupStep('vectorIndex', () => vectorIndex.closeDb());\n    // Close MCP transport on shutdown\n    runCleanupStep('transport', () => {\n      if (transport) {\n        transport.close();\n        transport = null;\n        transportConnectedAt = null;\n      }\n    });\n    await runAsyncCleanupStep('ipcBridge', async () => {\n      if (ipcBridge) {\n        await ipcBridge.close();\n        ipcBridge = null;\n      }\n    });\n    await runAsyncCleanupStep('shutdownHooks', async () => {\n      await runShutdownHooks();\n    });\n    runCleanupStep('registeredTimers', () => clearAllTimers());\n  })();\n\n  const timedOut = await Promise.race([\n    cleanup.then(() => false),\n    new Promise<boolean>((resolve) => {\n      deadlineTimer = registerTimeout(() => resolve(true), SHUTDOWN_DEADLINE_MS, { unref: true });\n    }),\n  ]);\n\n  if (deadlineTimer) {\n    clearRegisteredTimer(deadlineTimer);\n  }\n\n  if (timedOut) {\n    console.error(`[context-server] Shutdown deadline exceeded after ${SHUTDOWN_DEADLINE_MS}ms`);\n  }\n\n  process.exit(exitCode);\n}\n\n/** Remove indexed rows for watcher delete and rename events. */\nasync function removeIndexedMemoriesForFile(filePath: string): Promise<void> {\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return;\n  }\n\n  const canonicalPath = getCanonicalPathKey(filePath);\n  let rows: Array<{ id: number; spec_folder: string | null }> = [];\n\n  try {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE canonical_file_path = ? OR file_path = ?\n      ORDER BY id ASC\n    `).all(canonicalPath, filePath) as Array<{ id: number; spec_folder: string | null }>;\n  } catch (_error: unknown) {\n    rows = database.prepare(`\n      SELECT id, spec_folder\n      FROM memory_index\n      WHERE file_path = ?\n      ORDER BY id ASC\n    `).all(filePath) as Array<{ id: number; spec_folder: string | null }>;\n  }\n\n  let deletedCount = 0;\n  for (const row of rows) {\n    if (typeof row.id === 'number') {\n      if (vectorIndex.deleteMemory(row.id)) {\n        deletedCount += 1;\n        // Record DELETE history only after confirmed deletion.\n        try {\n          recordHistory(row.id, 'DELETE', filePath ?? null, null, 'mcp:file_watcher', row.spec_folder ?? null);\n        } catch (_histErr: unknown) {\n          // History recording is best-effort in file-watcher path\n        }\n      }\n    }\n  }\n\n  if (deletedCount > 0) {\n    try {\n      runPostMutationHooks('delete', { filePath, deletedCount });\n    } catch (_error: unknown) {\n      // Non-throwing by design: file-watcher path must not crash the server.\n    }\n  }\n}\n\nprocess.on('SIGTERM', () => {\n  void fatalShutdown('Received SIGTERM, shutting down...', 0);\n});\nprocess.on('SIGINT', () => {\n  void fatalShutdown('Received SIGINT, shutting down...', 0);\n});\nprocess.on('SIGHUP', () => {\n  void fatalShutdown('Received SIGHUP, shutting down...', 0);\n});\nprocess.on('SIGQUIT', () => {\n  void fatalShutdown('Received SIGQUIT, shutting down...', 0);\n});\n\nprocess.on('uncaughtException', (err: Error) => {\n  void fatalShutdown(`Uncaught exception: ${err.stack ?? err.message}`, 1);\n});\n\nprocess.on('unhandledRejection', (reason: unknown, promise: Promise<unknown>) => {\n  void fatalShutdown(\n    `Unhandled rejection at: ${String(promise)} reason: ${reason instanceof Error ? reason.stack ?? reason.message : String(reason)}`,\n    1,\n  );\n});\n\n/* ───────────────────────────────────────────────────────────────\n   8. MAIN\n──────────────────────────────────────────────────────────────── */\n\nasync function main(): Promise<void> {\n  // Node version mismatch detection (non-blocking)\n  detectNodeVersionMismatch();\n  detectedRuntime = detectRuntime();\n  console.error(\n    `[context-server] Detected runtime: ${detectedRuntime.runtime} (hookPolicy=${detectedRuntime.hookPolicy})`,\n  );\n\n  validateConfiguredEmbeddingsProvider();\n\n  // Refuse to boot as a second writer BEFORE anything else initializes. The\n  // kernel-held sidecar lock survives every crash mode; a losing cold-spawn\n  // must exit before it can touch the database, and the launcher converts\n  // this exit code into a bridge to the live owner.\n  try {\n    acquireDbInstanceLock(vectorIndex.getDbPath() || DATABASE_PATH);\n  } catch (error: unknown) {\n    if (error instanceof VectorIndexError && error.code === VectorIndexErrorCode.DB_LOCK_HELD) {\n      console.error(`[context-server] ${error.message}`);\n      process.exit(EXIT_DB_LOCK_HELD);\n    }\n    throw error;\n  }\n\n  registerInitTasks(async () => {\n    console.error('[context-server] Initializing database...');\n    let startupDb: Database.Database;\n    try {\n      startupDb = vectorIndex.initializeDb();\n    } catch (error: unknown) {\n      if (error instanceof VectorIndexError && error.code === VectorIndexErrorCode.DB_LOCK_HELD) {\n        // Fail this caller's request with a structured error, then exit with\n        // the lock-held code so the launcher bridges to the live owner\n        // instead of relaunching a doomed second writer.\n        setImmediate(() => { void fatalShutdown(error.message, EXIT_DB_LOCK_HELD); });\n      }\n      throw error;\n    }\n    console.error('[context-server] Database initialized');\n    console.error('[context-server] Database path: ' + DATABASE_PATH);\n\n    // Idempotency receipts are replay caches. This is the ONLY sweep: it runs\n    // once at boot, so the TTL is enforced across daemon restarts only. A warm\n    // daemon running longer than the receipt TTL never re-sweeps, so rows past\n    // TTL persist and the table grows until the next restart. That unbounded\n    // growth is the accepted tradeoff (receipts are small and stale replays are\n    // already gated by the active-row identity recheck at lookup time); if a\n    // long-lived daemon needs mid-run expiry, add a bounded periodic/on-write\n    // sweep here. Best-effort: a sweep failure never blocks boot.\n    try {\n      const prunedReceipts = pruneExpiredIdempotencyReceipts(startupDb);\n      if (prunedReceipts > 0) {\n        console.error(`[context-server] Pruned ${prunedReceipts} expired idempotency receipt(s)`);\n      }\n    } catch (_: unknown) { /* best-effort */ }\n\n    // Opt-in (SPECKIT_INCLUDE_ARCHIVED_VECTOR, default off): admit archived/cold rows\n    // whose logical key has no active winner into the vector projection so the semantic\n    // lane can reach them. Self-gated and idempotent; best-effort never blocks boot.\n    try {\n      const cold = backfillColdOrphanProjection(startupDb);\n      if (cold.admitted > 0) {\n        console.error(`[context-server] Admitted ${cold.admitted} archived/cold row(s) into the vector projection`);\n      }\n    } catch (_: unknown) { /* best-effort */ }\n\n  try {\n    const active = await ensureActiveEmbedder(startupDb, { timeoutMs: API_KEY_VALIDATION_TIMEOUT_MS });\n    vectorIndex.attachActiveVectorShardForActiveProfile(startupDb);\n    console.error(\n      `[context-server] Active embedder: ${active.name} (${active.dim}d${active.provider ? `, ${active.provider}` : ''})`,\n    );\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.error(`[context-server] FATAL: ${message}`);\n    // Throw (not process.exit) so a bad first call fails THAT caller's tool request with a\n    // structured error while the shared daemon stays alive. The init guard resets and retries\n    // on the next memory-runtime call, so a transient embedder failure self-heals.\n    throw new Error(`memory runtime init failed (embedder): ${message}`);\n  }\n\n  // Pre-Flight API Key Validation\n  // Validates API key at startup to fail fast with actionable error messages\n  // Skip validation if SPECKIT_SKIP_API_VALIDATION=true (for testing/CI)\n  let startupEmbeddingConfig: Awaited<ReturnType<typeof resolveStartupEmbeddingConfig>> | null = null;\n  if (process.env.SPECKIT_SKIP_API_VALIDATION !== 'true') {\n    console.error('[context-server] Validating embedding API key...');\n    try {\n      startupEmbeddingConfig = await resolveStartupEmbeddingConfig({ timeout: API_KEY_VALIDATION_TIMEOUT_MS });\n      const validation: ApiKeyValidation = startupEmbeddingConfig.validation;\n\n      if (!validation.valid) {\n        if (validation.networkError) {\n          // Transient network failure — warn and continue, validation will occur on first use\n          console.warn('[context-server] ===== API KEY VALIDATION SKIPPED (network error) =====');\n          console.warn(`[context-server] Provider: ${validation.provider}`);\n          console.warn(`[context-server] Error: ${validation.error}`);\n          if (validation.actions) {\n            console.warn('[context-server] Recovery Actions:');\n            validation.actions.forEach((action: string, i: number) => {\n              console.warn(`[context-server]   ${i + 1}. ${action}`);\n            });\n          }\n          console.warn('[context-server] Continuing startup — validation will occur on first use');\n        } else {\n          console.error('[context-server] ===== API KEY VALIDATION FAILED =====');\n          console.error(`[context-server] Provider: ${validation.provider}`);\n          console.error(`[context-server] Error: ${validation.error}`);\n          console.error(`[context-server] Error Code: ${validation.errorCode || 'E050'}`);\n          if (validation.actions) {\n            console.error('[context-server] Recovery Actions:');\n            validation.actions.forEach((action: string, i: number) => {\n              console.error(`[context-server]   ${i + 1}. ${action}`);\n            });\n          }\n          console.error('[context-server] =====================================');\n          console.error('[context-server] FATAL: Cannot start MCP server with invalid API key');\n          console.error('[context-server] Set SPECKIT_SKIP_API_VALIDATION=true to bypass (not recommended)');\n          // Throw (not process.exit) so the shared daemon survives one bad first call. Tagged so\n          // the enclosing transient-error catch RE-THROWS it (rather than swallowing it into the\n          // \"continue\" path), letting the init guard surface it as a structured tool error + retry.\n          throw Object.assign(\n            new Error(`embedding API key validation failed: ${validation.error ?? validation.errorCode ?? 'invalid key'}`),\n            { speckitInitHardFail: true },\n          );\n        }\n      }\n\n      if (validation.warning) {\n        console.warn(`[context-server] API key warning: ${validation.warning}`);\n      }\n\n      if (validation.valid) {\n        console.error(`[context-server] API key validated (provider: ${validation.provider})`);\n      }\n    } catch (validationError: unknown) {\n      // A tagged hard-fail (invalid API key) must propagate to the init guard so the daemon does\n      // not silently start with a known-bad key; only genuine transient validation errors fall\n      // through to \"continue, validate on first use\".\n      if (validationError && typeof validationError === 'object'\n          && (validationError as { speckitInitHardFail?: boolean }).speckitInitHardFail) {\n        throw validationError;\n      }\n      const message = validationError instanceof Error ? validationError.message : String(validationError);\n      console.error(`[context-server] API key validation error: ${message}`);\n      console.error('[context-server] Continuing startup - validation will occur on first use');\n    }\n  } else {\n    console.warn('[context-server] API key validation skipped (SPECKIT_SKIP_API_VALIDATION=true)');\n  }\n\n  if (!process.env.EMBEDDING_DIM) {\n    process.env.EMBEDDING_DIM = String(\n      startupEmbeddingConfig?.dimension ?? getStartupEmbeddingDimension(),\n    );\n  }\n\n  // Initialize db-state module with dependencies\n  // P4-12/P4-19 FIX: Pass sessionManager and incrementalIndex so db-state can\n  // Refresh their DB handles during reinitializeDatabase(), preventing stale refs.\n  initDbState({\n    vectorIndex,\n    checkpoints: checkpointsLib,\n    accessTracker,\n    hybridSearch,\n    sessionManager,\n    incrementalIndex,\n    dbConsumers: [\n      sessionBoost,\n      causalBoost,\n      historyStore,\n      workingMemory,\n      attentionDecay,\n      coActivation,\n    ],\n  });\n\n  console.error('[context-server] Lazy loading enabled - embedding model will initialize on first use');\n  console.error('[context-server] SPECKIT_EAGER_WARMUP and SPECKIT_LAZY_LOADING are deprecated compatibility flags');\n\n  // Integrity check and module initialization\n  try {\n    const report = vectorIndex.verifyIntegrity();\n    console.error(`[context-server] Integrity check: ${report.totalMemories}/${report.totalMemories + report.missingVectors} valid entries`);\n    if (report.orphanedVectors > 0) console.error(`[context-server] WARNING: ${report.orphanedVectors} orphaned entries detected`);\n\n    // Validate embedding dimension matches database\n    const dimValidation = vectorIndex.validateEmbeddingDimension();\n    if (!dimValidation.valid) {\n      console.error(`[context-server] ===== EMBEDDING DIMENSION MISMATCH =====`);\n      console.error(`[context-server] ${dimValidation.warning}`);\n      console.error(`[context-server] =========================================`);\n      console.error('[context-server] FATAL: Refusing to start with mismatched embedding dimensions');\n      throw new Error(dimValidation.warning ?? 'Embedding dimension mismatch between provider and database');\n    } else if (dimValidation.stored) {\n      console.error(`[context-server] Embedding dimension validated: ${dimValidation.stored}`);\n    }\n\n    const database = vectorIndex.getDb();\n    if (!database) {\n      throw new Error('Database not initialized after initializeDb(). Cannot start server.');\n    }\n\n    try {\n      initScoringObservability(database);\n      console.error('[context-server] Scoring observability initialized');\n    } catch (scoringObsErr: unknown) {\n      const message = scoringObsErr instanceof Error ? scoringObsErr.message : String(scoringObsErr);\n      console.warn('[context-server] Scoring observability init failed (non-fatal):', message);\n    }\n\n    const installGraphRefresh = (refreshDb: Database.Database): void => {\n      registerGlobalRefreshFn(() => {\n        const dirtyNodeIds = Array.from(getDirtyNodes().nodeIds);\n        if (dirtyNodeIds.length === 0) {\n          return;\n        }\n\n        const updatedEdges = recomputeLocal(refreshDb, dirtyNodeIds);\n        clearDirtyNodes();\n        console.error(\n          '[context-server] Scheduled graph refresh applied: dirty_nodes=%d, updated_edges=%d',\n          dirtyNodeIds.length,\n          updatedEdges,\n        );\n      });\n    };\n\n    registerDatabaseRebindListener((nextDatabase) => {\n      const reboundDatabase = nextDatabase as Database.Database;\n      rebindScoringObservability(reboundDatabase);\n      rebindExtractionAdapter(reboundDatabase);\n\n      cancelScheduledRefresh();\n      installGraphRefresh(reboundDatabase);\n      if (getDirtyNodes().nodeIds.size > 0) {\n        scheduleGlobalRefresh();\n      }\n\n      shadowEvaluationRuntime.stopShadowEvaluationScheduler();\n      shadowEvaluationRuntime.startShadowEvaluationScheduler(reboundDatabase);\n    });\n\n    if (isLearnedFeedbackEnabled()) {\n      try {\n        const migrated = migrateLearnedTriggers(database);\n        const isolated = verifyFts5Isolation(database);\n        console.error(`[context-server] Learned triggers ready (migrated=${migrated}, fts5Isolated=${isolated})`);\n      } catch (learnedErr: unknown) {\n        const message = learnedErr instanceof Error ? learnedErr.message : String(learnedErr);\n        throw new Error(`[context-server] Learned feedback migration/isolation failed: ${message}`);\n      }\n    }\n\n    // Check SQLite version meets minimum requirement (3.35.0+)\n    checkSqliteVersion(database);\n\n    // Verify WAL mode is active for operational concurrency guarantees.\n    const walRow = database.prepare('PRAGMA journal_mode').get() as { journal_mode?: string } | undefined;\n    const journalMode = String(walRow?.journal_mode ?? '').toLowerCase();\n    if (journalMode !== 'wal') {\n      database.pragma('journal_mode = WAL');\n      console.warn('[context-server] journal_mode was not WAL; forcing WAL mode');\n    }\n\n    const memoryCountRow = database.prepare('SELECT COUNT(*) as cnt FROM memory_index').get() as { cnt?: number } | undefined;\n    const memoryCount = Number(memoryCountRow?.cnt ?? 0);\n    let projectionCount = 0;\n    let projectionTableExists = true;\n\n    try {\n      const projectionCountRow = database.prepare('SELECT COUNT(*) as cnt FROM active_memory_projection').get() as { cnt?: number } | undefined;\n      projectionCount = Number(projectionCountRow?.cnt ?? 0);\n    } catch {\n      projectionTableExists = false;\n    }\n\n    console.error('[context-server] Startup health: memory_index=%d, active_memory_projection=%d', memoryCount, projectionCount);\n\n    if (memoryCount > 0 && (!projectionTableExists || projectionCount === 0)) {\n      const result = runLineageBackfill(database);\n      console.error('[context-server] Auto-backfill triggered: %d rows seeded into active_memory_projection', result.seeded);\n    }\n\n    if (memoryCount === 0 && projectionCount === 0) {\n      console.error('[context-server] WARNING: Database has 0 memories — search will return no results until memories are saved');\n    }\n\n    const graphSearchFn = isGraphUnifiedEnabled()\n      ? createUnifiedGraphSearchFn(database)\n      : null;\n\n    checkpointsLib.init(database);\n    accessTracker.init(database);\n    hybridSearch.init(database, vectorIndex.vectorSearch, graphSearchFn);\n\n    // Keep db-state reinitialization wiring aligned with startup search wiring.\n    initDbState({ graphSearchFn });\n    sessionBoost.init(database);\n    causalBoost.init(database);\n    installGraphRefresh(database);\n    console.error('[context-server] Checkpoints, access tracker, hybrid search, session boost, and causal boost initialized');\n    runCheckpointNeedsRebuildRepair(database, 'boot');\n\n    // P3-04/014: Warm in-memory BM25 only when the selected lexical engine needs it.\n    if (bm25Index.shouldWarmInMemoryBm25(database)) {\n      try {\n        const bm25 = bm25Index.getIndex();\n        const count = bm25.rebuildFromDatabase(database);\n        console.error(`[context-server] BM25 index rebuilt from database: ${count} documents`);\n      } catch (bm25Err: unknown) {\n        const message = bm25Err instanceof Error ? bm25Err.message : String(bm25Err);\n        console.warn('[context-server] BM25 index rebuild failed:', message);\n      }\n    }\n\n    // Cognitive memory modules\n    try {\n      workingMemory.init(database);\n      attentionDecay.init(database);\n      coActivation.init(database);\n      console.error('[context-server] Cognitive memory modules initialized');\n      console.error(`[context-server] Working memory: ${workingMemory.isEnabled()}, Co-activation: ${coActivation.isEnabled()}`);\n    } catch (cognitiveErr: unknown) {\n      const message = cognitiveErr instanceof Error ? cognitiveErr.message : String(cognitiveErr);\n      console.warn('[context-server] Cognitive modules partially failed:', message);\n    }\n\n    try {\n      initExtractionAdapter(database, registerAfterToolCallback);\n      console.error('[context-server] Extraction adapter initialized');\n    } catch (extractionErr: unknown) {\n      const message = extractionErr instanceof Error ? extractionErr.message : String(extractionErr);\n      throw new Error(`[context-server] Extraction adapter startup failed: ${message}`);\n    }\n\n    try {\n      const resumedEmbedderJobs = resumeReindexJobs(database);\n      if (resumedEmbedderJobs.length > 0) {\n        console.error('[context-server] Resumed embedder re-index jobs: %d', resumedEmbedderJobs.length);\n      }\n    } catch (reindexErr: unknown) {\n      const message = reindexErr instanceof Error ? reindexErr.message : String(reindexErr);\n      console.warn('[context-server] Embedder re-index resume failed:', message);\n    }\n\n    // Background retry job for pending embeddings\n    // Processes memories with failed embeddings in the background.\n    // No options passed: use BACKGROUND_JOB_CONFIG, which reads SPECKIT_RETRY_INTERVAL_MS /\n    // SPECKIT_RETRY_BATCH_SIZE / SPECKIT_RETRY_ENABLED. Passing hardcoded options here would\n    // spread after the env-derived config and silently clobber the tuned values.\n    try {\n      const retryJobResult = retryManager.startBackgroundJob();\n      if (retryJobResult) {\n        const { intervalMs, batchSize } = retryManager.BACKGROUND_JOB_CONFIG;\n        console.error(`[context-server] Background retry job started (interval: ${intervalMs}ms, batch: ${batchSize})`);\n      } else {\n        console.error('[context-server] Background retry job already running or disabled');\n      }\n    } catch (retryErr: unknown) {\n      const message = retryErr instanceof Error ? retryErr.message : String(retryErr);\n      console.warn('[context-server] Background retry job failed to start:', message);\n    }\n\n    // Shadow feedback holdout evaluation background scheduler.\n    // Replays recent production queries through a shadow-only path once the\n    // weekly holdout cycle is due. Fail-safe and gated by SPECKIT_SHADOW_FEEDBACK.\n    try {\n      const shadowSchedulerStarted = shadowEvaluationRuntime.startShadowEvaluationScheduler(database);\n      if (shadowSchedulerStarted) {\n        console.error('[context-server] Shadow feedback evaluation scheduler started');\n      } else {\n        console.error('[context-server] Shadow feedback evaluation scheduler not started (already running or disabled)');\n      }\n    } catch (shadowEvalErr: unknown) {\n      const message = shadowEvalErr instanceof Error ? shadowEvalErr.message : String(shadowEvalErr);\n      console.warn('[context-server] Shadow feedback evaluation scheduler failed to start:', message);\n    }\n\n    // Batch feedback learning — runs one cycle at startup (shadow-only, no live ranking mutations).\n    // Feature-flag gated by SPECKIT_BATCH_LEARNED_FEEDBACK (default ON, graduated).\n    try {\n      const batchResult = runBatchLearning(database);\n      if (batchResult.candidatesEvaluated > 0) {\n        console.error(`[context-server] Batch learning: ${batchResult.shadowApplied} shadow-applied, ${batchResult.skippedMinSupport} skipped (min-support), window=${Math.round((batchResult.runAt - batchResult.windowStart) / 86_400_000)}d`);\n      } else {\n        console.error('[context-server] Batch learning: no eligible candidates in window (or flag disabled)');\n      }\n    } catch (batchErr: unknown) {\n      const message = batchErr instanceof Error ? batchErr.message : String(batchErr);\n      console.warn('[context-server] Batch learning failed (non-fatal):', message);\n    }\n\n    // Session deduplication module\n    try {\n      const sessionResult = sessionManager.init(database);\n      if (sessionResult.success) {\n        console.error(`[context-server] Session manager initialized (enabled: ${sessionManager.isEnabled()})`);\n\n        // Crash Recovery Pattern\n        // Reset any sessions that were active when server last crashed\n        const recoveryResult = sessionManager.resetInterruptedSessions();\n        if (recoveryResult.interruptedCount > 0) {\n          console.error(`[context-server] Crash recovery: marked ${recoveryResult.interruptedCount} sessions as interrupted`);\n          // Log interrupted sessions for visibility\n          const interrupted = sessionManager.getInterruptedSessions();\n          if (interrupted.sessions && interrupted.sessions.length > 0) {\n            console.error('[context-server] Recoverable sessions:', interrupted.sessions.map((s: { sessionId: string }) => s.sessionId).join(', '));\n          }\n        }\n      } else {\n        console.warn('[context-server] Session manager initialization returned:', sessionResult.error);\n      }\n    } catch (sessionErr: unknown) {\n      const message = sessionErr instanceof Error ? sessionErr.message : String(sessionErr);\n      console.warn('[context-server] Session manager failed:', message);\n    }\n\n    // Async ingestion job queue initialization + crash recovery reset.\n    try {\n      const ingestInit = initIngestJobQueue({\n        processFile: async (filePath: string, governance) => {\n          await indexSingleFile(filePath, false, governance\n            ? { governance }\n            : {\n                provenance: {\n                  provenanceSource: 'memory_ingest_start',\n                  provenanceActor: 'async-ingest',\n                  tool: 'memory_ingest_start',\n                },\n              });\n        },\n      });\n      if (ingestInit.resetCount > 0) {\n        console.error(`[context-server] Ingest crash recovery reset ${ingestInit.resetCount} incomplete job(s) to queued`);\n      }\n    } catch (ingestInitErr: unknown) {\n      const message = ingestInitErr instanceof Error ? ingestInitErr.message : String(ingestInitErr);\n      console.warn('[context-server] Ingest queue init failed:', message);\n    }\n\n    // Background index-scan job store init + crash-recovery reset. An interrupted\n    // scan re-runs fresh, so incomplete jobs are marked failed (never re-enqueued);\n    // a hard-crash scan lease is already reaped by the lease-expiry path.\n    try {\n      ensureMaintenanceJobsTable();\n      const resetScanJobs = resetRunningJobsForKind('index_scan', { to: 'failed' });\n      if (resetScanJobs.length > 0) {\n        console.error(`[context-server] Index scan crash recovery marked ${resetScanJobs.length} incomplete job(s) failed`);\n      }\n    } catch (scanJobInitErr: unknown) {\n      const message = scanJobInitErr instanceof Error ? scanJobInitErr.message : String(scanJobInitErr);\n      console.warn('[context-server] Maintenance job store init failed:', message);\n    }\n\n    // Optional real-time markdown watcher for automatic re-indexing.\n    if (isFileWatcherEnabled()) {\n      try {\n        const watchPaths = getSpecsBasePaths(DEFAULT_BASE_PATH);\n        if (watchPaths.length > 0) {\n          fileWatcher = startFileWatcher({\n            paths: watchPaths,\n            reindexFn: async (filePath: string) => {\n              const result = await indexSingleFile(filePath, false);\n              if (isMutationStatus(result.status)) {\n                try {\n                  runPostMutationHooks('scan', {\n                    indexed: result.status === 'indexed' || result.status === 'deferred' ? 1 : 0,\n                    updated: result.status === 'updated' || result.status === 'reinforced' ? 1 : 0,\n                    staleDeleted: 0,\n                    staleDeleteFailed: 0,\n                    operation: 'file-watcher-reindex',\n                    filePath,\n                    status: result.status,\n                  });\n                } catch (_error: unknown) {\n                  // Non-fatal by design for file-watcher callback path.\n                }\n              }\n            },\n            removeFn: async (filePath: string) => {\n              await removeIndexedMemoriesForFile(filePath);\n            },\n          });\n          console.error(`[context-server] File watcher started for ${watchPaths.length} path(s)`);\n        } else {\n          console.warn('[context-server] File watcher enabled, but no spec directories were found');\n        }\n      } catch (watchErr: unknown) {\n        const message = watchErr instanceof Error ? watchErr.message : String(watchErr);\n        console.warn('[context-server] File watcher startup failed:', message);\n      }\n\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.error('[context-server] Integrity check failed:', message);\n    throw err instanceof Error ? err : new Error(message);\n  }\n\n    // Background startup scan\n    setImmediate(() => {\n      try {\n        runCheckpointNeedsRebuildRepair(vectorIndex.getDb(), 'startup-scan');\n      } catch (repairErr: unknown) {\n        const message = repairErr instanceof Error ? repairErr.message : String(repairErr);\n        console.warn('[context-server] Pre-scan checkpoint derived rebuild repair failed (non-fatal):', message);\n      }\n      startupScanPromise = startupScan(DEFAULT_BASE_PATH);\n    });\n  });\n\n  // Assign to module-level transport (not const) so shutdown handlers can close it\n  if (isDynamicInitEnabled()) {\n    try {\n      const dynamicInstructions = await buildServerInstructions();\n      if (dynamicInstructions.length > 0) {\n        serverWithInstructions.setInstructions?.(dynamicInstructions);\n      }\n    } catch (instructionErr: unknown) {\n      const message = instructionErr instanceof Error ? instructionErr.message : String(instructionErr);\n      console.warn('[context-server] Dynamic instructions init failed (non-fatal):', message);\n    }\n  }\n\n  const backendOnly = process.env.SPECKIT_BACKEND_ONLY === '1';\n  if (!backendOnly) {\n    transportConnectedAt = new Date().toISOString();\n    transport = new StdioServerTransport();\n    await server.connect(transport);\n  }\n  scheduleBootFtsIntegrityCheck();\n  registerInterval(() => vectorIndex.checkpointAllWal(), 300_000, { unref: true });\n  launcherIdleMonitor = createLauncherIdleMonitor({\n    serviceName: 'context-server',\n    getActiveClientCount: () => getIpcBridgeStats().secondary_clients_count,\n    onIdle: () => fatalShutdown('Launcher idle timeout reached, shutting down...', 0),\n    log: (message) => console.error(message),\n    stdin: backendOnly ? null : undefined,\n  });\n  ipcBridge = await startIpcSocketServer({\n    socketPath: resolveIpcSocketPath(DATABASE_DIR),\n    createServer: () => {\n      const secondaryServer = createContextMcpServer();\n      registerContextServerHandlers(secondaryServer);\n      return secondaryServer;\n    },\n    log: (message) => console.error(message),\n    onActivity: () => launcherIdleMonitor?.markActivity(),\n  });\n  const rssMb = Math.round(process.memoryUsage().rss / 1024 / 1024);\n  console.error(`[health] startup pid=${process.pid} rss=${rssMb}MB uptime=0s`);\n  console.error(backendOnly\n    ? '[context-server] Context MCP server running on IPC socket only'\n    : '[context-server] Context MCP server running on stdio and IPC socket');\n\n}\n\nconst isMain = process.argv[1] && decodeURIComponent(import.meta.url).endsWith(process.argv[1].replace(/\\\\/g, '/'));\n\nif (isMain) {\n  main().catch((err: unknown) => { console.error('[context-server] Fatal error:', err); process.exit(1); });\n}","lineStart":1270,"lineEnd":2341,"totalLines":2341,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/context-server.ts","time":{"start":1781763114720,"end":1781763114732}},"metadata":{"openai":{"itemId":"fc_0ab8fbf40fc27ea4016a338c2a440c8191955fafebd0a005a9"}},"id":"prt_ed95b86d0001uA36D0aWrtE3fi","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95b5aba001hQutA9bBaBQJ5v"}}
{"type":"tool_use","timestamp":1781763114737,"sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","part":{"type":"tool","tool":"read","callID":"call_fIS2y2EAhZGSTvjCA3goruE3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","offset":1284,"limit":1800},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs</path>\n<type>file</type>\n<content>\n1284:       logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; crash-loop cooldown active for ${cooldown.retryAfterMs}ms`);\n1285:       writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n1286:         state: 'error',\n1287:         reason: 'crash-loop-cooldown',\n1288:         retryAfterMs: cooldown.retryAfterMs,\n1289:       });\n1290:       return;\n1291:     }\n1292:     logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; spawning launcher-owned sibling`);\n1293:     releaseModelServerDemandListenerForSpawn({ keepRespawnLock: true });\n1294:     const launched = getSupervisor().launch();\n1295:     releaseDemandRespawnLock();\n1296:     if (!launched) {\n1297:       // launch() returned false (spawn produced no pid, or a child is already running). The\n1298:       // demand server was already torn down above and the respawn lock released, so without re-arming\n1299:       // the launcher is stranded — no listener, no resident, and no scheduled relaunch (the child\n1300:       // 'exit' handler is never wired when there is no valid child). Re-arm the lazy demand listener so\n1301:       // a later demand can retry. Fire-and-forget with a .catch: the interval/HTTP context has no\n1302:       // awaiter, and startModelServerDemandListener() self-guards via already-owned / lock-held when a\n1303:       // sibling won the race.\n1304:       logger('hf-model-server demand-driven launch produced no resident; re-arming lazy demand listener');\n1305:       void startModelServerDemandListener().catch((error) => {\n1306:         logger(`hf-model-server demand listener re-arm after spawn failure failed (will retry on next demand): ${error && error.message ? error.message : error}`);\n1307:       });\n1308:     }\n1309:     writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n1310:       state: 'loading',\n1311:       modelServerLaunchRequested: true,\n1312:       launched,\n1313:     });\n1314:   }\n1315: \n1316:   async function startModelServerDemandListener(options = {}) {\n1317:     if (state.demandServer || getPid()) {\n1318:       return { started: false, reason: 'already-owned' };\n1319:     }\n1320: \n1321:     const socketPath = options.socketPath || resolveSocketPath();\n1322:     const prepared = options.skipPrepare ? { shouldListen: true } : await prepareModelServerDemandTarget(socketPath);\n1323:     if (!prepared.shouldListen) {\n1324:       logger(`hf-model-server demand listener skipped: ${prepared.reason}`);\n1325:       return { started: false, reason: prepared.reason, socketPath, lockPath: prepared.lockPath };\n1326:     }\n1327: \n1328:     const server = (deps.httpCreateServer || http.createServer)(handleModelServerDemand);\n1329:     try {\n1330:       await new Promise((resolve, reject) => {\n1331:         let reclaimedStaleSocket = false;\n1332:         const onError = (error) => {\n1333:           if (error && error.code === 'EADDRINUSE' && !socketPath.startsWith('tcp://') && !reclaimedStaleSocket) {\n1334:             // Only reclaim a CONFIRMED-STALE socket. If the shared pid still records a live resident,\n1335:             // a sibling launcher's server bound first — do not unlink its live socket (it serves embeds\n1336:             // for everyone). Reject so this launcher backs off rather than clobbering a working server.\n1337:             const recordedPid = readModelServerPid();\n1338:             if (Number.isInteger(recordedPid) && recordedPid > 0 && liveness(recordedPid) !== 'dead') {\n1339:               server.off('listening', onListening);\n1340:               reject(new Error(`hf-model-server socket ${socketPath} owned by a live resident (pid ${recordedPid}); not reclaiming`));\n1341:               return;\n1342:             }\n1343:             reclaimedStaleSocket = true;\n1344:             // The re-assert + reclaim runs inside this 'error' handler, which fires in a\n1345:             // microtask — a synchronous throw here would ESCAPE the Promise executor instead of\n1346:             // rejecting it. Wrap so a perimeter violation (symlinked node, etc.) or unlink failure\n1347:             // fails the listener closed (rejects → outer catch releases the lock and rethrows).\n1348:             try {\n1349:               assertSocketDirOwnership(socketPath, { statApi, getuid, logger });\n1350:               unlinkModelServerSocket(socketPath);\n1351:               server.listen(socketPath);\n1352:             } catch (reclaimError) {\n1353:               server.off('listening', onListening);\n1354:               reject(reclaimError);\n1355:             }\n1356:             return;\n1357:           }\n1358:           server.off('listening', onListening);\n1359:           reject(error);\n1360:         };\n1361:         const onListening = () => {\n1362:           server.off('error', onError);\n1363:           resolve();\n1364:         };\n1365:         server.on('error', onError);\n1366:         server.once('listening', onListening);\n1367:         if (socketPath.startsWith('tcp://')) {\n1368:           const url = new URL(socketPath);\n1369:           server.listen(Number.parseInt(url.port, 10), url.hostname || '127.0.0.1');\n1370:         } else {\n1371:           server.listen(socketPath);\n1372:         }\n1373:       });\n1374:     } catch (error) {\n1375:       releaseDemandRespawnLock();\n1376:       throw error;\n1377:     }\n1378: \n1379:     if (!socketPath.startsWith('tcp://')) {\n1380:       fs.chmodSync(socketPath, 0o600);\n1381:     }\n1382:     state.demandServer = server;\n1383:     state.demandTarget = socketPath;\n1384:     armIdleMonitor();\n1385:     logger(`hf-model-server lazy demand listener ready at ${socketPath}`);\n1386:     return { started: true, socketPath };\n1387:   }\n1388: \n1389:   return {\n1390:     start: startModelServerDemandListener,\n1391:     startDemandListener: startModelServerDemandListener,\n1392:     stopDemandListener: stopModelServerDemandListener,\n1393:     releaseDemandListenerForSpawn: releaseModelServerDemandListenerForSpawn,\n1394:     launch: () => getSupervisor().launch(),\n1395:     getPid,\n1396:     getChild: () => (state.supervisor ? state.supervisor.getChild() : null),\n1397:     getSnapshotPids: () => (state.supervisor ? state.supervisor.getSnapshotPids() : [...state.lastKnownDescendantPids]),\n1398:     clearTimers: () => {\n1399:       disarmIdleMonitor();\n1400:       if (state.supervisor) state.supervisor.clearTimers();\n1401:     },\n1402:     reapProcessTree: (childPid) => getSupervisor().reapProcessTree(childPid),\n1403:     reapBeforeRespawn: (childPid) => getSupervisor().reapBeforeRespawn(childPid),\n1404:     reapRecordedBeforeRespawn: reapRecordedModelServerBeforeRespawn,\n1405:     resolveSocketPath,\n1406:   };\n1407: }\n1408: \n1409: module.exports = {\n1410:   SHUTDOWN_DEADLINE_MS,\n1411:   RESPAWN_REAP_GRACE_MS,\n1412:   RESPAWN_LOCK_STALE_MS,\n1413:   DEFAULT_WATCHDOG_GRACE_MS,\n1414:   DEFAULT_WATCHDOG_INTERVAL_MS,\n1415:   DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES,\n1416:   DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS,\n1417:   DEFAULT_CRASH_LOOP_MAX_DEATHS,\n1418:   DEFAULT_CRASH_LOOP_WINDOW_MS,\n1419:   DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS,\n1420:   DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS,\n1421:   DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS,\n1422:   HF_MODEL_SERVER_SOCKET_FILE_NAME,\n1423:   HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME,\n1424:   HF_MODEL_SERVER_PID_FILE_NAME,\n1425:   HF_MODEL_SERVER_GIVEUP_FILE_NAME,\n1426:   MAINTENANCE_MARKER_FILE_NAME,\n1427:   MODEL_SERVER_DEMAND_STATUS,\n1428:   maintenanceMarkerPath,\n1429:   readMaintenanceMarker,\n1430:   shouldAdoptDespiteProbe,\n1431:   acquireModelServerRespawnLockFile,\n1432:   acquireRespawnLockFileAt,\n1433:   buildLeaseObject,\n1434:   canonicalizePath,\n1435:   computeBackoffMs,\n1436:   createCrashLoopGuard,\n1437:   createModelServerControl,\n1438:   createModelServerSupervisor,\n1439:   defaultProcessRowsRunner,\n1440:   ensureCanonicalDir,\n1441:   getCrashLoopConfig,\n1442:   getModelServerGiveUpCooldownMs,\n1443:   getModelServerIdleConfig,\n1444:   getModelServerWatchdogConfig,\n1445:   getWatchdogConfig,\n1446:   assertSocketDirOwnership,\n1447:   assertSunPathLimit,\n1448:   isDurableWriteUnavailable,\n1449:   isChildRunning,\n1450:   isPermissionError,\n1451:   isRespawnLockStale,\n1452:   modelServerGiveUpPath,\n1453:   modelServerRespawnLockPath,\n1454:   normalizeModelServerTarget,\n1455:   normalizeWatchdogGraceMs,\n1456:   parseProcessRows,\n1457:   processLiveness,\n1458:   reapProcessTreeGroups,\n1459:   refreshDescendantSnapshot,\n1460:   releaseRespawnLockFile,\n1461:   resolveModelServerSocketPath,\n1462:   resolveProcessTreeRows,\n1463:   sampleProcessTreeRssMb,\n1464:   shouldAbortRelaunchOnFire,\n1465:   shouldSkipLaunch,\n1466:   signalProcess,\n1467:   startRssWatchdog,\n1468:   superviseChildExit,\n1469:   unlinkModelServerSocket,\n1470:   waitForPidExit,\n1471:   readModelServerGiveUpUntil,\n1472:   writeDemandResponse,\n1473:   writeModelServerGiveUpUntil,\n1474: };\n\n(End of file - total 1474 lines)\n</content>","metadata":{"preview":"      logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; crash-loop cooldown active for ${cooldown.retryAfterMs}ms`);\n      writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n        state: 'error',\n        reason: 'crash-loop-cooldown',\n        retryAfterMs: cooldown.retryAfterMs,\n      });\n      return;\n    }\n    logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; spawning launcher-owned sibling`);\n    releaseModelServerDemandListenerForSpawn({ keepRespawnLock: true });\n    const launched = getSupervisor().launch();\n    releaseDemandRespawnLock();\n    if (!launched) {\n      // launch() returned false (spawn produced no pid, or a child is already running). The\n      // demand server was already torn down above and the respawn lock released, so without re-arming\n      // the launcher is stranded — no listener, no resident, and no scheduled relaunch (the child\n      // 'exit' handler is never wired when there is no valid child). Re-arm the lazy demand listener so\n      // a later demand can retry. Fire-and-forget with a .catch: the interval/HTTP context has no\n      // awaiter, and startModelServerDemandListener() self-guards via already-owned / lock-held when a\n      // sibling won the race.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/lib/model-server-supervision.cjs","text":"      logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; crash-loop cooldown active for ${cooldown.retryAfterMs}ms`);\n      writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n        state: 'error',\n        reason: 'crash-loop-cooldown',\n        retryAfterMs: cooldown.retryAfterMs,\n      });\n      return;\n    }\n    logger(`hf-model-server demand received ${request.method || 'GET'} ${routePath}; spawning launcher-owned sibling`);\n    releaseModelServerDemandListenerForSpawn({ keepRespawnLock: true });\n    const launched = getSupervisor().launch();\n    releaseDemandRespawnLock();\n    if (!launched) {\n      // launch() returned false (spawn produced no pid, or a child is already running). The\n      // demand server was already torn down above and the respawn lock released, so without re-arming\n      // the launcher is stranded — no listener, no resident, and no scheduled relaunch (the child\n      // 'exit' handler is never wired when there is no valid child). Re-arm the lazy demand listener so\n      // a later demand can retry. Fire-and-forget with a .catch: the interval/HTTP context has no\n      // awaiter, and startModelServerDemandListener() self-guards via already-owned / lock-held when a\n      // sibling won the race.\n      logger('hf-model-server demand-driven launch produced no resident; re-arming lazy demand listener');\n      void startModelServerDemandListener().catch((error) => {\n        logger(`hf-model-server demand listener re-arm after spawn failure failed (will retry on next demand): ${error && error.message ? error.message : error}`);\n      });\n    }\n    writeDemandResponse(response, MODEL_SERVER_DEMAND_STATUS, {\n      state: 'loading',\n      modelServerLaunchRequested: true,\n      launched,\n    });\n  }\n\n  async function startModelServerDemandListener(options = {}) {\n    if (state.demandServer || getPid()) {\n      return { started: false, reason: 'already-owned' };\n    }\n\n    const socketPath = options.socketPath || resolveSocketPath();\n    const prepared = options.skipPrepare ? { shouldListen: true } : await prepareModelServerDemandTarget(socketPath);\n    if (!prepared.shouldListen) {\n      logger(`hf-model-server demand listener skipped: ${prepared.reason}`);\n      return { started: false, reason: prepared.reason, socketPath, lockPath: prepared.lockPath };\n    }\n\n    const server = (deps.httpCreateServer || http.createServer)(handleModelServerDemand);\n    try {\n      await new Promise((resolve, reject) => {\n        let reclaimedStaleSocket = false;\n        const onError = (error) => {\n          if (error && error.code === 'EADDRINUSE' && !socketPath.startsWith('tcp://') && !reclaimedStaleSocket) {\n            // Only reclaim a CONFIRMED-STALE socket. If the shared pid still records a live resident,\n            // a sibling launcher's server bound first — do not unlink its live socket (it serves embeds\n            // for everyone). Reject so this launcher backs off rather than clobbering a working server.\n            const recordedPid = readModelServerPid();\n            if (Number.isInteger(recordedPid) && recordedPid > 0 && liveness(recordedPid) !== 'dead') {\n              server.off('listening', onListening);\n              reject(new Error(`hf-model-server socket ${socketPath} owned by a live resident (pid ${recordedPid}); not reclaiming`));\n              return;\n            }\n            reclaimedStaleSocket = true;\n            // The re-assert + reclaim runs inside this 'error' handler, which fires in a\n            // microtask — a synchronous throw here would ESCAPE the Promise executor instead of\n            // rejecting it. Wrap so a perimeter violation (symlinked node, etc.) or unlink failure\n            // fails the listener closed (rejects → outer catch releases the lock and rethrows).\n            try {\n              assertSocketDirOwnership(socketPath, { statApi, getuid, logger });\n              unlinkModelServerSocket(socketPath);\n              server.listen(socketPath);\n            } catch (reclaimError) {\n              server.off('listening', onListening);\n              reject(reclaimError);\n            }\n            return;\n          }\n          server.off('listening', onListening);\n          reject(error);\n        };\n        const onListening = () => {\n          server.off('error', onError);\n          resolve();\n        };\n        server.on('error', onError);\n        server.once('listening', onListening);\n        if (socketPath.startsWith('tcp://')) {\n          const url = new URL(socketPath);\n          server.listen(Number.parseInt(url.port, 10), url.hostname || '127.0.0.1');\n        } else {\n          server.listen(socketPath);\n        }\n      });\n    } catch (error) {\n      releaseDemandRespawnLock();\n      throw error;\n    }\n\n    if (!socketPath.startsWith('tcp://')) {\n      fs.chmodSync(socketPath, 0o600);\n    }\n    state.demandServer = server;\n    state.demandTarget = socketPath;\n    armIdleMonitor();\n    logger(`hf-model-server lazy demand listener ready at ${socketPath}`);\n    return { started: true, socketPath };\n  }\n\n  return {\n    start: startModelServerDemandListener,\n    startDemandListener: startModelServerDemandListener,\n    stopDemandListener: stopModelServerDemandListener,\n    releaseDemandListenerForSpawn: releaseModelServerDemandListenerForSpawn,\n    launch: () => getSupervisor().launch(),\n    getPid,\n    getChild: () => (state.supervisor ? state.supervisor.getChild() : null),\n    getSnapshotPids: () => (state.supervisor ? state.supervisor.getSnapshotPids() : [...state.lastKnownDescendantPids]),\n    clearTimers: () => {\n      disarmIdleMonitor();\n      if (state.supervisor) state.supervisor.clearTimers();\n    },\n    reapProcessTree: (childPid) => getSupervisor().reapProcessTree(childPid),\n    reapBeforeRespawn: (childPid) => getSupervisor().reapBeforeRespawn(childPid),\n    reapRecordedBeforeRespawn: reapRecordedModelServerBeforeRespawn,\n    resolveSocketPath,\n  };\n}\n\nmodule.exports = {\n  SHUTDOWN_DEADLINE_MS,\n  RESPAWN_REAP_GRACE_MS,\n  RESPAWN_LOCK_STALE_MS,\n  DEFAULT_WATCHDOG_GRACE_MS,\n  DEFAULT_WATCHDOG_INTERVAL_MS,\n  DEFAULT_WATCHDOG_CONSECUTIVE_BREACHES,\n  DEFAULT_DESCENDANT_SNAPSHOT_INTERVAL_MS,\n  DEFAULT_CRASH_LOOP_MAX_DEATHS,\n  DEFAULT_CRASH_LOOP_WINDOW_MS,\n  DEFAULT_CRASH_LOOP_INITIAL_BACKOFF_MS,\n  DEFAULT_CRASH_LOOP_MAX_BACKOFF_MS,\n  DEFAULT_MODEL_SERVER_GIVEUP_COOLDOWN_MS,\n  HF_MODEL_SERVER_SOCKET_FILE_NAME,\n  HF_MODEL_SERVER_RESPAWN_LOCK_FILE_NAME,\n  HF_MODEL_SERVER_PID_FILE_NAME,\n  HF_MODEL_SERVER_GIVEUP_FILE_NAME,\n  MAINTENANCE_MARKER_FILE_NAME,\n  MODEL_SERVER_DEMAND_STATUS,\n  maintenanceMarkerPath,\n  readMaintenanceMarker,\n  shouldAdoptDespiteProbe,\n  acquireModelServerRespawnLockFile,\n  acquireRespawnLockFileAt,\n  buildLeaseObject,\n  canonicalizePath,\n  computeBackoffMs,\n  createCrashLoopGuard,\n  createModelServerControl,\n  createModelServerSupervisor,\n  defaultProcessRowsRunner,\n  ensureCanonicalDir,\n  getCrashLoopConfig,\n  getModelServerGiveUpCooldownMs,\n  getModelServerIdleConfig,\n  getModelServerWatchdogConfig,\n  getWatchdogConfig,\n  assertSocketDirOwnership,\n  assertSunPathLimit,\n  isDurableWriteUnavailable,\n  isChildRunning,\n  isPermissionError,\n  isRespawnLockStale,\n  modelServerGiveUpPath,\n  modelServerRespawnLockPath,\n  normalizeModelServerTarget,\n  normalizeWatchdogGraceMs,\n  parseProcessRows,\n  processLiveness,\n  reapProcessTreeGroups,\n  refreshDescendantSnapshot,\n  releaseRespawnLockFile,\n  resolveModelServerSocketPath,\n  resolveProcessTreeRows,\n  sampleProcessTreeRssMb,\n  shouldAbortRelaunchOnFire,\n  shouldSkipLaunch,\n  signalProcess,\n  startRssWatchdog,\n  superviseChildExit,\n  unlinkModelServerSocket,\n  waitForPidExit,\n  readModelServerGiveUpUntil,\n  writeDemandResponse,\n  writeModelServerGiveUpUntil,\n};","lineStart":1284,"lineEnd":1474,"totalLines":1474,"truncated":false}},"title":".opencode/bin/lib/model-server-supervision.cjs","time":{"start":1781763114733,"end":1781763114736}},"metadata":{"openai":{"itemId":"fc_0ab8fbf40fc27ea4016a338c2a44188191ba095f7d0d070049"}},"id":"prt_ed95b86e6001SwHbiFGHhtH61e","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95b5aba001hQutA9bBaBQJ5v"}}
