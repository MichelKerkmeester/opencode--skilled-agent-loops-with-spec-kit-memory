marker","status":"pending","priority":"medium"}],"truncated":false},"title":"4 todos","time":{"start":1782918981658,"end":1782918981660}},"metadata":{"openai":{"itemId":"fc_0976e2ff8342559a016a452f41edf08191a7be2961661719f3"}},"id":"prt_f1e409985001UdCTEf5ZcmRq3C","sessionID":"ses_0e1c12f14ffe56Cs01FOXHPL99","messageID":"msg_f1e407bb6001ZMeh3mxEdQfBtj"}}
