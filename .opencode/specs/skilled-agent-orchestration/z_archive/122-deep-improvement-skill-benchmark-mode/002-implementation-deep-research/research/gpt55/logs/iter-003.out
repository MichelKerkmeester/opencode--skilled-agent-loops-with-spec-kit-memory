    21	function parseArgs(argv) {
    22	  const args = {};
    23	  for (let index = 0; index < argv.length; index += 1) {
    24	    const entry = argv[index];
    25	    if (!entry.startsWith('--')) {
    26	      continue;
    27	    }
    28	    const [key, ...rest] = entry.slice(2).split('=');
    29	    if (rest.length > 0) {
    30	      args[key] = rest.join('=');
    31	    } else if (argv[index + 1] && !argv[index + 1].startsWith('--')) {
    32	      args[key] = argv[index + 1];
    33	      index += 1;
    34	    } else {
    35	      args[key] = true;
    36	    }
    37	  }
    38	  return args;
    39	}
