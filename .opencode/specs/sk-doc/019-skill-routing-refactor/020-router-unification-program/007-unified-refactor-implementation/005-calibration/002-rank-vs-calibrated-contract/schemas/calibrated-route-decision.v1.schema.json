{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speckit.local/router/calibration-evidence-envelope.v1.schema.json",
  "title": "CalibrationEvidenceEnvelopeV1",
  "description": "Out-of-band calibration evidence accompanying an unchanged RouteDecisionV1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "decision", "calibration"],
  "properties": {
    "schemaVersion": { "const": "CalibrationEvidenceEnvelopeV1" },
    "decision": {
      "$ref": "../../../000-contract-schemas/schemas/route-decision.v1.schema.json#/$defs/routeDecision"
    },
    "calibration": { "$ref": "#/$defs/calibration" }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1, "pattern": "\\S" },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "evaluationWindow": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["corpusVersion", "sampleCount"],
          "properties": {
            "corpusVersion": { "$ref": "#/$defs/nonEmpty" },
            "sampleCount": { "type": "integer", "minimum": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to"],
          "properties": {
            "from": { "type": "string", "format": "date-time" },
            "to": { "type": "string", "format": "date-time" }
          }
        }
      ]
    },
    "calibration": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status"],
          "properties": { "status": { "const": "unvalidated" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "certificateId",
            "corpusId",
            "method",
            "policyHash",
            "riskSlice",
            "evaluationWindow",
            "estimatedError"
          ],
          "properties": {
            "status": { "const": "validated" },
            "certificateId": { "$ref": "#/$defs/digest" },
            "corpusId": { "$ref": "#/$defs/digest" },
            "method": {
              "enum": [
                "temperature-scaling",
                "selective-classification-threshold"
              ]
            },
            "policyHash": { "$ref": "#/$defs/digest" },
            "riskSlice": { "$ref": "#/$defs/nonEmpty" },
            "evaluationWindow": { "$ref": "#/$defs/evaluationWindow" },
            "estimatedError": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      ]
    }
  }
}
