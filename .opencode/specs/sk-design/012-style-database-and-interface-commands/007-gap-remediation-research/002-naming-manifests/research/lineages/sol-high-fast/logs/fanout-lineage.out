gn/manual-testing-playbook/styles-library-utilization/generation-guarded-hydration-mismatch.md:42] [SOURCE: .opencode/skills/sk-design/manual-testing-playbook/styles-library-utilization/retrieval-query-eligible-cards.md:46] [SOURCE: .opencode/skills/sk-design/styles/manual-testing-playbook.md:13]\",\n358:       \"addedAtIteration\": 1,\n359:       \"sources\": [\n360:         \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n361:         \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n362:         \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n363:         \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n364:         \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n365:         \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n366:         \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n367:         \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n368:         \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n369:       ]\n370:     },\n371:     {\n372:       \"id\": \"finding-1-11-mode-corpus-tests-fixtures-design-motion-corpus-tests-motion-evidence-test-mjs-d\",\n373:       \"text\": \"Mode-corpus tests/fixtures: `design-motion/corpus/__tests__/motion-evidence.test.mjs`, `design-motion/corpus/__tests__/fixtures.mjs`, `design-foundations/corpus/__tests__/relationship-blueprint.test.mjs`, `design-foundations/corpus/__tests__/fixtures.mjs`, `design-interface/corpus/__tests__/relational-exemplar.test.mjs`, `design-interface/corpus/__tests__/fixtures.mjs`, `design-audit/corpus/__tests__/comparison-lane.test.mjs`, and `design-audit/corpus/__tests__/fixtures.mjs`. [SOURCE: .opencode/skills/sk-design/design-motion/corpus/__tests__/motion-evidence.test.mjs:16] [SOURCE: .opencode/skills/sk-design/design-foundations/corpus/__tests__/relationship-blueprint.test.mjs:16] [SOURCE: .opencode/skills/sk-design/design-interface/corpus/__tests__/relational-exemplar.test.mjs:16] [SOURCE: .opencode/skills/sk-design/design-audit/corpus/__tests__/comparison-lane.test.mjs:16]\",\n374:       \"addedAtIteration\": 1,\n375:       \"sources\": [\n376:         \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n377:         \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n378:         \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n379:         \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n380:         \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n381:         \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n382:         \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n383:         \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n384:         \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n385:       ]\n386:     },\n387:     {\n388:       \"id\": \"finding-1-15-root-contract-docs-readme-md-and-skill-md-source-opencode-skills-sk-design-readm\",\n389:       \"text\": \"Root contract docs: `README.md` and `SKILL.md`. [SOURCE: .opencode/skills/sk-design/README.md:74] [SOURCE: .opencode/skills/sk-design/SKILL.md:215]\",\n390:       \"addedAtIteration\": 1,\n391:       \"sources\": [\n392:         \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n393:         \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n394:         \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n395:         \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n396:         \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n397:         \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n398:         \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n399:         \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n400:         \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n\n(Showing lines 1-400 of 494. Use offset=401 to continue.)\n</content>","metadata":{"preview":"{\n  \"sessionId\": \"fanout-sol-high-fast-1784619539276-ffno9q\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"terminalStop\": null,\n  \"keyQuestions\": [],\n  \"openQuestions\": [],\n  \"resolvedQuestions\": [],\n  \"carriedForwardOpenQuestions\": [\n    {\n      \"text\": \"Confirm indirect/runtime-computed path construction and the exact baseline/post-cutover validation command set.\",\n      \"addedAtIteration\": 1,\n      \"source\": \"iteration-markdown\"\n    },\n    {\n      \"text\": \"Decide which data is canonical versus derived, and specify hash/provenance/deterministic-regeneration semantics.\",\n      \"addedAtIteration\": 1,\n      \"source\": \"iteration-markdown\"","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/002-naming-manifests/research/lineages/sol-high-fast/findings-registry.json","text":"{\n  \"sessionId\": \"fanout-sol-high-fast-1784619539276-ffno9q\",\n  \"parentSessionId\": null,\n  \"lineageMode\": \"new\",\n  \"generation\": 1,\n  \"continuedFromRun\": null,\n  \"terminalStop\": null,\n  \"keyQuestions\": [],\n  \"openQuestions\": [],\n  \"resolvedQuestions\": [],\n  \"carriedForwardOpenQuestions\": [\n    {\n      \"text\": \"Confirm indirect/runtime-computed path construction and the exact baseline/post-cutover validation command set.\",\n      \"addedAtIteration\": 1,\n      \"source\": \"iteration-markdown\"\n    },\n    {\n      \"text\": \"Decide which data is canonical versus derived, and specify hash/provenance/deterministic-regeneration semantics.\",\n      \"addedAtIteration\": 1,\n      \"source\": \"iteration-markdown\"\n    },\n    {\n      \"text\": \"Define rollback and cutover proof for both naming and later consolidation, including stale generated artifacts.\",\n      \"addedAtIteration\": 1,\n      \"source\": \"iteration-markdown\"\n    },\n    {\n      \"text\": \"Map every field, invariant, and lifecycle role in both manifest schemas, including writer ownership and ordering guarantees.\",\n      \"addedAtIteration\": 1,\n      \"source\": \"iteration-markdown\"\n    }\n  ],\n  \"uncoveredQuestions\": [],\n  \"keyFindings\": [\n    {\n      \"id\": \"finding-1-2-exact-rename-map-the-dependency-closure-rename-is\",\n      \"text\": \"**Exact rename map.** The dependency-closure rename is:\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-3-exhaustive-live-surface-direct-reference-inventory-140-occurrences-in-46-files-t\",\n      \"text\": \"**Exhaustive live-surface direct-reference inventory: 140 occurrences in 46 files.** The files are grouped by migration responsibility; every listed mutable reference must be updated in the same dependency-closure cutover unless explicitly identified as frozen history. [INFERENCE: repository-scoped exact-token inventory, grouped from `rg --count-matches` output]\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-1-naming-authority-and-exemption-result-the-canon-states-that-directory-names-and-\",\n      \"text\": \"**Naming authority and exemption result.** The canon states that directory names and filenames use kebab-case; exemptions cover Python source/package names, generated/tool-mandated names, runner magic, vendored trees, and frozen history. The three JavaScript backend directories and two authored JSON manifests match none of those exemptions. [SOURCE: .opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18] [SOURCE: .opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:24] [SOURCE: .opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:34]\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-20-repository-wide-references-need-scope-classification-not-blind-replacement-activ\",\n      \"text\": \"**Repository-wide references need scope classification, not blind replacement.** Active external consumers such as the styles Rust-opportunity packet point at `_db/retrieval.mjs`, but completed spec history is explicitly frozen; those paths should be recorded as historical rather than rewritten. [SOURCE: .opencode/specs/sk-design/013-styles-database-rust-opportunities/spec.md:19] [SOURCE: .opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:56]\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-21-safe-rename-sequence-capture-a-baseline-on-all-current-engine-database-mode-corp\",\n      \"text\": \"**Safe rename sequence.** Capture a baseline on all current engine/database/mode-corpus tests; perform all five moves and all mutable references as one dependency-closure change; update cross-directory imports and runtime path constants first, then fixtures/tests, scripts, and mutable docs; run the same complete gates; only after name-only parity should manifest consolidation change schema or remove a file. Do not leave compatibility symlinks or duplicate manifests after the atomic cutover, because coordinated consumers are fully inventoried. [INFERENCE: the direct-reference closure above makes a single atomic cutover smaller and safer than prolonged dual paths, while a separate schema phase isolates behavioral failures]\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-22-the-manifests-overlap-in-membership-but-are-not-schema-equivalent-the-crawl-file\",\n      \"text\": \"**The manifests overlap in membership but are not schema-equivalent.** The crawl file is a top-level array of capture lifecycle records (`uuid`, source URL/time, slug, capture status/time, error); the retrieval file is a versioned generation object with `generationHash`, `crawlManifestHash`, `recordCount`, and enriched searchable `styles` records. The retrieval schema already declares its derivation relationship through `crawlManifestHash`. [SOURCE: .opencode/skills/sk-design/styles/_manifest.json:1] [SOURCE: .opencode/skills/sk-design/styles/_manifest.json:3] [SOURCE: .opencode/skills/sk-design/styles/_retrieval-manifest.json:1] [SOURCE: .opencode/skills/sk-design/styles/_retrieval-manifest.json:3]\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-23-this-iteration-does-not-choose-the-canonical-manifest-renaming-both-files-is-mec\",\n      \"text\": \"**This iteration does not choose the canonical manifest.** Renaming both files is mechanically resolved, but choosing one physical source of truth requires tracing generation code, hash construction, writer ownership, invalidation behavior, and deterministic regeneration. Treating the richer retrieval manifest as automatically canonical would invert its current declared dependency on the crawl hash. [INFERENCE: `_retrieval-manifest.json` includes `crawlManifestHash`, so canonicality cannot be inferred from schema richness alone]\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-19-changelog-v1-6-0-0-md-records-the-paths-as-shipped-and-remains-unchanged-under-t\",\n      \"text\": \"`changelog/v1.6.0.0.md` records the paths as shipped and remains unchanged under the canon's frozen-history exception. [SOURCE: .opencode/skills/sk-design/changelog/v1.6.0.0.md:14] [SOURCE: .opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:56]\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-4-design-md-generator-backend-scripts-study-prepare-ts-excludes-legacy-backend-man\",\n      \"text\": \"`design-md-generator/backend/scripts/study-prepare.ts` excludes legacy backend/manifest names and must use the renamed entries. [SOURCE: .opencode/skills/sk-design/design-md-generator/backend/scripts/study-prepare.ts:60]\",\n      \"addedAtIteration\": 1,\n      \"sources\": [\n        \"`.opencode/skills/sk-doc/shared/references/filesystem-naming-convention.md:18-88`\",\n        \"`.opencode/specs/sk-design/012-style-database-and-interface-commands/007-gap-remediation-research/gap-analysis.md:22-105`\",\n        \"`.opencode/skills/sk-design/styles/_manifest.json:1-10`\",\n        \"`.opencode/skills/sk-design/styles/_retrieval-manifest.json:1-100`\",\n        \"`.opencode/skills/sk-design/styles/_engine/manifest.mjs:30-32`\",\n        \"`.opencode/skills/sk-design/styles/_engine/style-library.mjs:36-172`\",\n        \"`.opencode/skills/sk-design/styles/_harness/extract-refero.mjs:44`\",\n        \"`.opencode/skills/sk-design/styles/_db/indexer.mjs:649`\",\n        \"Exact-reference Grep/`rg --count-matches` inventory across `.opencode/skills/sk-design`\"\n      ]\n    },\n    {\n      \"id\": \"finding-1-5-design-motion-corpus-motion-evidence-mjs-