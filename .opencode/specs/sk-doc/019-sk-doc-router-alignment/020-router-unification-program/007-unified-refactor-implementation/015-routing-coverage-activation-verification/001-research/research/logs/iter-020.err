   117	function spawnSequence(children, calls = []) {
   118	  return (binary, args, options) => {
   119	    const child = children[Math.min(calls.length, children.length - 1)];
   120	    calls.push({ binary, args, options, child });
   121	    return child;
   122	  };
   123	}
