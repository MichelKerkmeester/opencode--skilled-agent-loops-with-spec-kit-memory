{
  "color": {
    "indigo-navy": {
      "$value": "#111a4a",
      "$type": "color",
      "$description": "Indigo Navy — Primary brand color — filled CTAs, navigation active states, heading text, logo wordmark. The deep violet-tinted navy carries institutional weight without going pure black; pairs with white text for the site's most confident button"
    },
    "midnight-ink": {
      "$value": "#011821",
      "$type": "color",
      "$description": "Midnight Ink — Dark surface and emphasis text — product card backgrounds, high-contrast body copy. Near-gray with a cool blue-green undertone; works as the dark-mode substrate when a section needs to invert"
    },
    "slate-ink": {
      "$value": "#3b3e47",
      "$type": "color",
      "$description": "Slate Ink — Secondary heading and body text — slightly warmer than Midnight Ink, used where pure black feels too harsh against the light canvas"
    },
    "steel": {
      "$value": "#7c7f88",
      "$type": "color",
      "$description": "Steel — Body and link text — the dominant muted text color (245 occurrences in body). Neutral gray-blue that reads as quiet, never washed out"
    },
    "fog": {
      "$value": "#a9acb6",
      "$type": "color",
      "$description": "Fog — Icon strokes, tertiary borders, placeholder text. Mid-gray that separates without competing with text"
    },
    "mist": {
      "$value": "#cbcccf",
      "$type": "color",
      "$description": "Mist — Lightest body text — captions, disclaimers, fine print. Stays legible on white but recedes visually"
    },
    "silver-lining": {
      "$value": "#e3e4e8",
      "$type": "color",
      "$description": "Silver Lining — Card borders, input borders, divider lines. The structural hairline color — appears wherever two surfaces need to separate without shadow"
    },
    "cloud-canvas": {
      "$value": "#f6f6f8",
      "$type": "color",
      "$description": "Cloud Canvas — Page background — the dominant canvas color. Near-white with a barely-perceptible cool tint that keeps the page from feeling sterile"
    },
    "pure-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Pure White — Card surfaces, nav background, button fills, secondary text. The top layer of the surface stack"
    },
    "charcoal": {
      "$value": "#232730",
      "$type": "color",
      "$description": "Charcoal — Nav icons, dark icon strokes — slightly bluer than pure black, used in icon contexts where Slate Ink would be too warm"
    },
    "obsidian": {
      "$value": "#12161e",
      "$type": "color",
      "$description": "Obsidian — Deep icon strokes and nav elements. Near-black with a blue undertone that matches the indigo navy family"
    },
    "pure-black": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure Black — Maximum contrast text, dark fills in illustrations. Used sparingly — Indigo Navy or Slate Ink carry most text work"
    },
    "signal-orange": {
      "$value": "#ec652b",
      "$type": "color",
      "$description": "Signal Orange — Accent CTA fill and featured card background — one of the few saturated warm colors in the system. Appears on the Brex highlight card and select buttons to draw the eye without feeling decorative"
    },
    "peach-glow": {
      "$value": "#f2936b",
      "$type": "color",
      "$description": "Peach Glow — Soft accent surface — lighter companion to Signal Orange, used as card backgrounds where warmth is needed at lower intensity"
    },
    "seafoam-600": {
      "$value": "#44b48b",
      "$type": "color",
      "$description": "Seafoam 600 — Code and data text — the signature color for JSON keys, identifiers, and financial values in code snippets. Also used for chart data points and growth visualizations"
    },
    "seafoam-700": {
      "$value": "#167e6c",
      "$type": "color",
      "$description": "Seafoam 700 — Darker seafoam for strokes, chart lines, and icon accents in data contexts. Anchors the seafoam scale on darker backgrounds"
    },
    "seafoam-400": {
      "$value": "#94efb7",
      "$type": "color",
      "$description": "Seafoam 400 — Highlighted code text — string values, URLs, API endpoints in code blocks. The lightest seafoam, reads as green-tinted monospace"
    },
    "deep-sea": {
      "$value": "#023247",
      "$type": "color",
      "$description": "Deep Sea — Decorative stroke and chart accent — deep teal used in SVG illustrations and data visualizations alongside the seafoam scale"
    },
    "sky-cyan": {
      "$value": "#88deeb",
      "$type": "color",
      "$description": "Sky Cyan — Soft accent surface and stroke — appears as background washes behind data widgets and as decorative chart strokes"
    },
    "cobalt-edge": {
      "$value": "#1e4199",
      "$type": "color",
      "$description": "Cobalt Edge — Violet wash for highlight backgrounds, decorative bands, and soft emphasis behind content. Do not promote it to the primary CTA color"
    },
    "ocean-depth": {
      "$value": "#0c6997",
      "$type": "color",
      "$description": "Ocean Depth — Decorative fill — medium blue used in illustration and SVG contexts"
    }
  },
  "font": {
    "suisseintl": {
      "$value": "SuisseIntl",
      "$type": "fontFamily",
      "$description": "Primary typeface — used for all headings, body, buttons, nav, links, and card text. The custom geometric grotesque gives Column a distinctive editorial register that distinguishes it from Inter-only fintechs. Weight 600 at 52–60px for display, weight 500 for sub-headings, weight 400 for body, weight 300 for low-emphasis links."
    },
    "suisseintlmono": {
      "$value": "SuisseIntlMono",
      "$type": "fontFamily",
      "$description": "Monospace companion to SuisseIntl — used for technical labels, API identifiers, and inline data in UI chrome. Maintains the same proportions as SuisseIntl so mono and proportional text align cleanly in mixed contexts."
    },
    "sfmono": {
      "$value": "SFMono",
      "$type": "fontFamily",
      "$description": "Code snippet rendering — appears in JSON examples and API documentation blocks. Tinted in seafoam green scale to visually distinguish code from UI prose."
    },
    "inter": {
      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "UI fallback font — used in dashboard and product surface contexts where Inter's wider character set and system familiarity take priority over brand identity."
    }
  },
