try + INTENT_SIGNALS.\n <!-- /ANCHOR:next-focus -->\n \n ---\n \n","additions":1,"deletions":1},"truncated":false},"title":".opencode/specs/sk-doc/019-sk-doc-router-alignment/021-default-mode-policy-research/research/lineages/glm-max/deep-research-strategy.md","time":{"start":1784314029975,"end":1784314029976}},"id":"prt_f71676793001rlZ7OXfU6acxVi","sessionID":"ses_08ea082cdffeOdjcwgjfes92M1","messageID":"msg_f71673781001haiiVoRSr9y0gq"}}
