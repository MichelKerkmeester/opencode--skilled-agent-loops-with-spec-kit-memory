{"type":"text","timestamp":1783489172036,"sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","part":{"id":"prt_f403cfa2c001SbCZmpq0BV3xNW","messageID":"msg_f403cbc480018ajiAmXXfQafxy","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","type":"text","text":"The YAML includes spec anchoring and memory save branches, but the user’s detached-lineage boundary is stricter: outputs only under `research/lineages/gpt55-fast-10`. I’ll treat spec anchoring and continuity save as skipped/deferred inside the lineage audit rather than writing outside the allowed path.","time":{"start":1783489165868,"end":1783489172034},"metadata":{"openai":{"itemId":"msg_01fb4a25ac0d7cd3016a4de28ddb0c81919a7c110d9609c7ad","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1783489172212,"sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","part":{"type":"tool","tool":"read","callID":"call_uPbiAfa12OFLWbEteeelTtgR","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","offset":737,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml</path>\n<type>file</type>\n<content>\n737:             values:\n738:               - \"{next_focus}\"\n739:               - \"{remaining_questions_list}\"\n740:               - \"{carried_forward_open_questions}\"\n741:           recovery:\n742:             category: \"recovery\"\n743:             values:\n744:               - \"{recovery_strategy}\"\n745:               - \"{least_explored}\"\n746:           ideas:\n747:             category: \"ideas\"\n748:             values:\n749:               - \"{promoted_ideas_list}\"\n750:             optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n751:         algorithm: |\n752:           Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n753:           reducer pass as the source of truth.\n754:           Compare normalized exact text first. Then compare fuzzy similarity with\n755:           rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n756:           are compatible. Remove suppressed candidates from next_focus, recovery, and ideas\n757:           selection before rendering the dispatch prompt. If all candidates are suppressed,\n758:           halt for operator input instead of reusing a rejected idea.\n759:         outputs:\n760:           - accepted_next_focus: \"First unsuppressed next-focus candidate, or null\"\n761:           - accepted_recovery_candidate: \"First unsuppressed recovery candidate, or null\"\n762:           - accepted_idea_candidate: \"First unsuppressed ideas candidate, or null\"\n763:           - rejected_candidate_matches: \"Suppressed candidate diagnostics from registry.suppressedCandidates plus any current-step matches\"\n764:         if_next_focus_suppressed:\n765:           set: { next_focus: \"{accepted_next_focus || accepted_recovery_candidate || accepted_idea_candidate}\" }\n766:           log: \"Rejected-pattern cache suppressed the prior candidate; dispatching the next accepted candidate.\"\n767:         if_all_candidates_suppressed:\n768:           halt: true\n769:           message: \"All next-focus, recovery, and ideas candidates match active rejected patterns. Remove/reset the rejected pattern or provide a new focus.\"\n770: \n771:       step_ideas_backlog_lifecycle:\n772:         action: \"Track reducer-owned observed/promoted/rejected idea lifecycle before dispatch\"\n773:         read:\n774:           - \"{state_paths.state_log}\"\n775:           - \"{state_paths.registry}\"\n776:           - \"{state_paths.config}\"\n777:         lifecycle:\n778:           observed_event: \"idea_observed\"\n779:           promoted_event: \"idea_promoted\"\n780:           rejected_event: \"idea_rejected\"\n781:           min_observations: \"{min_idea_observations}\"\n782:           authority: \"Leaf agents emit observations only; reducer emits promotions and owns ranking.\"\n783:         validate:\n784:           - \"If new leaf-authored output includes idea_promoted, fail validation; only reducer output may append idea_promoted.\"\n785:           - \"If promoted_ideas_count > 0 and next_focus is empty or all questions are resolved, prefer the first unsuppressed promoted idea.\"\n786:           - \"If suppressed_ideas_count > 0, do not render those ideas into dispatch context.\"\n787:         outputs:\n788:           - observed_ideas_count: \"Reducer-derived observed ideas count\"\n789:           - promoted_ideas_count: \"Reducer-derived promoted ideas count after minIdeaObservations\"\n790:           - suppressed_ideas_count: \"Reducer-derived rejected/suppressed ideas count\"\n791:           - accepted_idea_candidate: \"First unsuppressed promoted idea, or null\"\n792: \n793:       step_normalize_pause_events:\n794:         action: \"Normalize pause and recovery lifecycle events to the frozen STOP_REASONS enum at emission time\"\n795:         stop_reasons_enum: [converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n796:         rule_pause_sentinel:\n797:           raw_event_forbidden: '{\"type\":\"event\",\"event\":\"paused\"}'\n798:           canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n799:         rule_stuck_recovery:\n800:           raw_event_forbidden: '{\"type\":\"event\",\"event\":\"stuck_recovery\"}'\n801:           canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n802: \n803:       step_marker_scan:\n804:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested research marker\"\n805:         algorithm: |\n806:           if current_iteration > 1:\n807:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n808:             if file_exists(PREV_PROMPT_PATH):\n809:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n810:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n811:                 log \"ERROR: nested research-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n812:                 halt with exit code 2\n813:         note: |\n814:           False-positive prevention: only matches when the first line is exactly one of the\n815:           three canonical markers. Markers appearing in comments or body text are ignored.\n816:           True-positive triggers only when a previous iteration's rendered prompt literally\n817:           starts with a deep-loop marker, indicating a nested research-of-review dispatch.\n818: \n819:       step_dispatch_iteration:\n820:         action: \"Dispatch one iteration via the selected executor\"\n821:         resolve_executor:\n822:           source: \"config.executor\"\n823:           loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n824:         pre_dispatch:\n825:           generate_summary: |\n826:             STATE SUMMARY (auto-generated):\n827:             Segment: {current_segment} | Iteration: {current_iteration} of {max_iterations}\n828:             Questions: {answered_count}/{total_questions} answered | Last focus: {last_focus}\n829:             Last 2 ratios: {ratio_prev} -> {ratio_latest} | Stuck count: {stuck_count}\n830:             {resource_map_prompt_line}\n831:             {memory_context_prompt_line}\n832:             Next focus: {next_focus}\n833:           render_prompt_pack:\n834:             template_path: \".opencode/skills/deep-loop-workflows/deep-research/assets/prompt_pack_iteration.md.tmpl\"\n835:             renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n836:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n837:             variables:\n838:               state_summary: \"{state_summary}\"\n839:               research_topic: \"{research_topic}\"\n840:               current_iteration: \"{current_iteration}\"\n841:               max_iterations: \"{max_iterations}\"\n842:               next_focus: \"{next_focus}\"\n843:               remaining_questions_list: \"{remaining_questions_list}\"\n844:               carried_forward_open_questions: \"{carried_forward_open_questions}\"\n845:               last_3_summaries: \"{last_3_summaries}\"\n846:               state_paths_config: \"{state_paths.config}\"\n847:               state_paths_state_log: \"{state_paths.state_log}\"\n848:               state_paths_strategy: \"{state_paths.strategy}\"\n849:               state_paths_registry: \"{state_paths.registry}\"\n850:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n851:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n852:         pre_dispatch_audit:\n853:           skip_when: \"config.executor.type == 'native'\"\n854:           call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n855:           args:\n856:             stateLogPath: \"{state_paths.state_log}\"\n857:             executor: \"{config.executor}\"\n858:             iteration: \"{current_iteration}\"\n859:         branch_on: \"config.executor.type\"\n860:         if_native:\n861:           dispatch:\n862:             agent: deep-research\n863:             model: opus\n864:             context_source: \"rendered_prompt_pack\"\n865:           wait_for_completion: true\n866:         if_cli_claude_code:\n867:           command: |\n868:             node --experimental-strip-types --input-type=module <<'EOF'\n869:             import { readFileSync } from 'node:fs';\n870:             import { createHash } from 'node:crypto';\n871: \n872:             import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n873:             import { resolveClaudePermissionMode } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n874: \n875:             const executor = {\n876:               kind: 'cli-claude-code',\n877:               model: '{config.executor.model}',\n878:               reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n879:               serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n880:               sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n881:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n882:             };\n883:             const args = [\n884:               '-p',\n885:               readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n886:               '--model',\n887:               executor.model,\n888:               '--permission-mode',\n889:               resolveClaudePermissionMode(executor.sandboxMode),\n890:               '--output-format',\n891:               'text',\n892:             ];\n893:             if (executor.reasoningEffort) {\n894:               args.push('--effort', executor.reasoningEffort);\n895:             }\n896: \n897:             const dispatchFacts = {\n898:               command: 'deep/research',\n899:               mode: 'research',\n900:               specFolder: '{spec_folder}',\n901:               artifactDir: '{state_paths.packet_dir}',\n902:               iteration: Number('{current_iteration}'),\n903:               executorKind: '{config.executor.type}',\n904:               branchId: '{config.executor.type}',\n905:               sessionId: '{config.lineage.sessionId}',\n906:               generation: Number('{config.lineage.generation}'),\n907:             };\n908:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n909:             process.exit(\n910:               runAuditedExecutorCommand({\n911:                 command: 'claude',\n912:                 args,\n913:                 cwd: '{repo_root}',\n914:                 timeoutSeconds: executor.timeoutSeconds,\n915:                 stateLogPath: '{state_paths.state_log}',\n916:                 executor,\n917:                 iteration: Number('{current_iteration}'),\n918:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n919:                 dispatchId,\n920:               }),\n921:             );\n922:             EOF\n923:           working_directory: \"{repo_root}\"\n924:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n925:           wait_for_completion: true\n926:           notes:\n927:             - \"sandboxMode maps to permission-mode: read-only -> plan, workspace-write -> acceptEdits, danger-full-access -> bypassPermissions\"\n928:             - \"claude-code has no serviceTier flag\"\n929:             - \"claude-code supports --effort for reasoning depth\"\n930:         record_executor_audit:\n931:           skip_when: \"config.executor.type == 'native'\"\n932:           target: \"{state_paths.state_log}\"\n933:           field: \"executor\"\n934:           value:\n935:             kind: \"{config.executor.type}\"\n936:             model: \"{config.executor.model}\"\n937:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n938:             serviceTier: \"{config.executor.serviceTier}\"\n939:         if_cli_opencode:\n940:           command: |\n941:             node --experimental-strip-types --input-type=module <<'EOF'\n942:             import { readFileSync } from 'node:fs';\n943:             import { createHash } from 'node:crypto';\n944: \n945:             import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n946: \n947:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n948:             const executor = {\n949:               kind: 'cli-opencode',\n950:               model: '{config.executor.model}',\n951:               configDir: null,\n952:               reasoningEffort,\n953:               serviceTier: null,\n954:               sandboxMode: null,\n955:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n956:               governor: null,\n957:             };\n958:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n959:             const message = 'Resolved route: mode=research; target_agent=@deep-research; execution=single_iteration; state_source=externalized_files; do_not_switch_mode=true'\n960:               + '\\n\\n'\n961:               + promptBody;\n962:             const args = [\n963:               'run',\n964:               '--model',\n965:               executor.model,\n966:               '--format',\n967:               'json',\n968:               '--dangerously-skip-permissions',\n969:               '--pure',\n970:               '--dir',\n971:               '{repo_root}',\n972:             ];\n973:             if (executor.reasoningEffort) {\n974:               args.push('--variant', executor.reasoningEffort);\n975:             }\n976:             args.push(message);\n977: \n978:             const dispatchFacts = {\n979:               command: 'deep/research',\n980:               mode: 'research',\n981:               specFolder: '{spec_folder}',\n982:               artifactDir: '{state_paths.packet_dir}',\n983:               iteration: Number('{current_iteration}'),\n984:               executorKind: '{config.executor.type}',\n985:               branchId: '{config.executor.type}',\n986:               sessionId: '{config.lineage.sessionId}',\n987:               generation: Number('{config.lineage.generation}'),\n988:             };\n989:             const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n990:             process.exit(\n991:               runAuditedExecutorCommand({\n992:                 command: 'opencode',\n993:                 args,\n994:                 cwd: '{repo_root}',\n995:                 timeoutSeconds: executor.timeoutSeconds,\n996:                 stateLogPath: '{state_paths.state_log}',\n997:                 executor,\n998:                 iteration: Number('{current_iteration}'),\n999:                 // opencode v1.14.39 reads stdin at startup before session creation;\n1000:                 // an empty input gives EOF stdin, equivalent to </dev/null.\n1001:                 input: '',\n1002:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1003:                 dispatchId,\n1004:               }),\n1005:             );\n1006:             EOF\n1007:           working_directory: \"{repo_root}\"\n1008:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1009:           wait_for_completion: true\n1010:           notes:\n1011:             - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1012:             - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (cli-opencode SKILL.md §4 ALWAYS rule)\"\n1013:             - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n1014:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n1015:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n1016:             - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n1017:         post_dispatch_validate:\n1018:           validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n1019:           command: \"node .opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs --loop-type research --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n1020:           command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n1021:           assert_exists: \"{state_paths.iteration_pattern}\"\n1022:           assert_appended: \"{state_paths.state_log}\"\n1023:           assert_jsonl_fields: [type, iteration, newInfoRatio, status, focus, mode]\n1024:           route_proof:\n1025:             mode: research\n1026:             target_agent: deep-research\n1027:             agent_definition_loaded: true\n1028:             resolved_route: \"Resolved route: mode=research target_agent=deep-research\"\n1029:           dispatchReceipt:\n1030:             receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n1031:             dispatchId: \"research-i{current_iteration}-g{config.lineage.generation}\"\n1032:           optional_jsonl_fields:\n1033:             logOffset: \"Byte offset where the seekable log region starts\"\n1034:             logSize: \"Byte length of the seekable log region\"\n1035:             logPath: \"Absolute path to the file containing the seekable log region\"\n1036:             skippedCount: \"Missed fixed-rate slots counted for the completed dispatch; 0 when no slot was missed\"\n1037:             slotDurationMs: \"Monotonic elapsed duration for the completed dispatch slot\"\n1038:           assert_canonical_type: \"iteration\"\n1039:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n1040:           assert_delta_file_has_iteration_record: true\n1041:           on_failure:\n1042:             action: \"emit schema_mismatch canonical conflict event\"\n1043:             redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error and continue. Never re-dispatch a given iteration more than once.\"\n1044:             escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n1045:           failure_reasons_reference:\n1046:             - \"iteration_file_missing — iteration narrative markdown not written\"\n1047:             - \"iteration_file_empty — iteration narrative markdown is zero bytes\"\n1048:             - \"jsonl_not_appended — state log file did not grow since pre-dispatch snapshot\"\n1049:             - \"jsonl_missing_fields — last state-log record omits required schema fields\"\n1050:             - \"jsonl_parse_error — last state-log line is not valid JSON\"\n1051:             - \"jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop\"\n1052:             - \"delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written\"\n1053:             - \"delta_file_empty — per-iteration delta file exists but has zero bytes\"\n1054:             - \"delta_file_missing_iteration_record — delta file lacks any record with type='iteration'\"\n1055:             - \"route_proof_missing — state-log or delta iteration record omits route-proof fields\"\n1056:             - \"route_proof_mismatch — state-log or delta iteration record does not match the resolved deep route\"\n1057:             - \"executor_missing — non-native executor did not record provenance\"\n1058:             - \"dispatch_failure_logged — last record is an explicit dispatch_failure event\"\n1059: \n1060:       step_run_now_restore_check:\n1061:         action: \"Record a run-now sentinel recreated during the completed dispatch\"\n1062:         command: |\n1063:           node <<'EOF'\n1064:           const { appendFileSync, existsSync, readFileSync } = require('node:fs');\n1065: \n1066:           const stateLogPath = \"{state_paths.state_log}\";\n1067:           const sentinelPath = \"{state_paths.run_now_sentinel}\";\n1068:           const timestamp = \"{ISO_8601_NOW}\";\n1069:           const sessionId = \"{config.lineage.sessionId}\";\n1070:           const generation = Number(\"{config.lineage.generation}\");\n1071:           const run = Number(\"{current_iteration}\");\n1072: \n1073:           function hasAcceptedCurrentRun() {\n1074:             if (!existsSync(stateLogPath)) return false;\n1075:             const lines = readFileSync(stateLogPath, \"utf8\").trim().split(/\\r?\\n/).filter(Boolean);\n1076:             for (let index = lines.length - 1; index >= 0; index -= 1) {\n1077:               const record = JSON.parse(lines[index]);\n1078:               if (record.run !== run || record.sessionId !== sessionId) continue;\n1079:               if (record.event === \"run_now_accepted\") return true;\n1080:               if (record.event === \"run_now_rejected\") return false;\n1081:             }\n1082:             return false;\n1083:           }\n1084: \n1085:           if (existsSync(sentinelPath) && hasAcceptedCurrentRun()) {\n1086:             appendFileSync(\n1087:               stateLogPath,\n1088:               `${JSON.stringify({\n1089:                 type: \"event\",\n1090:                 event: \"run_now_restored\",\n1091:                 mode: \"research\",\n1092:                 run,\n1093:                 sentinelPath,\n1094:                 timestamp,\n1095:                 sessionId,\n1096:                 generation,\n1097:               })}\\n`,\n1098:               \"utf8\",\n1099:             );\n1100:           }\n1101:           EOF\n1102:         outputs:\n1103:           - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n1104: \n1105:       step_reduce_state:\n1106:         action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n1107:         command: \"node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n1108:         inputs:\n1109:           latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n1110:           newIterationFile: \"{state_paths.iteration_pattern}\"\n1111:           priorReducedState: \"{state_paths.registry}\"\n1112:         outputs:\n1113:           - \"{state_paths.registry}\"\n1114:           - \"{state_paths.dashboard}\"\n1115:           - \"{state_paths.strategy}\"\n1116:           - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n1117:           - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n1118:           - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n1119:         failure_modes:\n1120:           malformed_delta: \"skip + warn\"\n1121:           missing_iteration_file: \"no-op + error\"\n1122:           schema_mismatch: \"reject + conflict event\"\n1123:           question_conflict: \"keep registry value + append question_conflict event with inboxValue, registryValue, and operatorDecision\"\n1124:         guarantee: \"Idempotent for identical inputs\"\n1125: \n1126:       step_graph_upsert:\n1127:         action: \"Persist the latest iteration graph delta after the reducer refresh and after the iteration file exists\"\n1128:         read:\n1129:           - \"{state_paths.state_log}\"\n1130:         extract:\n1131:           - latest_graph_events: \"Read graphEvents from the latest iteration record, else []\"\n1132:           - graph_upsert_nodes_json: \"Map latest_graph_events where type == 'node' to node payloads with label -> name and preserve remaining node fields\"\n1133:           - graph_upsert_edges_json: \"Map latest_graph_events where type == 'edge' to edge payloads with source -> sourceId, target -> targetId, relation -> uppercase(relation), and preserve remaining edge fields\"\n1134:           - graph_upsert_event_count: \"Count mapped node and edge events\"\n1135:         if_graph_events_present:\n1136:           bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"research\\\" --session-id \\\"{config.lineage.sessionId}\\\" --nodes '{graph_upsert_nodes_json}' --edges '{graph_upsert_edges_json}'\"\n1137:           note: \"Skip silently when graphEvents is missing or empty.\"\n1138:         if_graph_events_missing:\n1139:           proceed: true\n1140: \n1141:       step_memory_upsert_iteration:\n1142:         action: \"Upsert the canonical iteration evidence into Spec Kit Memory after reducer and graph persistence\"\n1143:         mcp_tool: memory_save\n1144:         invocation: 'memory_save({ filePath: \"{state_paths.iteration_pattern}\" })'\n1145:         timeout_seconds: 5\n1146:         idempotency: \"Re-running the same iteration file is safe because the memory backend upserts by path/content.\"\n1147:         failure_policy:\n1148:           mcp_error: \"non-fatal; log advisory warning and continue\"\n1149:           timeout: \"non-fatal after timeout_seconds; log advisory warning and continue\"\n1150:         outputs:\n1151:           - memory_upsert_iteration_file: \"{state_paths.iteration_pattern}\"\n1152:           - memory_upsert_status: \"upserted | advisory_error\"\n1153: \n1154:       step_refresh_memory_context:\n1155:         action: \"Refresh focused Spec Kit Memory context before the next prompt render\"\n1156:         mcp_tool: memory_context\n1157:         invocation: 'memory_context({ input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true })'\n1158:         timeout_seconds: 5\n1159:         use_response:\n1160:           - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n1161:         failure_policy:\n1162:           mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n1163:           timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n1164:         outputs:\n1165:           - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n1166:           - memory_context_refresh_status: \"refreshed | advisory_error\"\n1167: \n1168:       step_evaluate_results:\n1169:         action: \"Verify iteration outputs and extract metrics\"\n1170:         verify:\n1171:           - file_exists: \"{state_paths.iteration_pattern}\"\n1172:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1173:           - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n1174:           - registry_updated: \"Reducer refreshed deep-research-findings-registry.json\"\n1175:         extract:\n1176:           - newInfoRatio: \"From latest JSONL iteration record\"\n1177:           - findings_count: \"From latest JSONL iteration record\"\n1178:           - status: \"From latest JSONL iteration record\"\n1179:           - latest_focus: \"From latest JSONL iteration record\"\n1180:         on_missing_outputs:\n1181:           action: \"Mark iteration as 'error', continue to next\"\n1182:           # Canonical iteration record: include mode, sessionId, generation, durationMs, keyQuestions, answeredQuestions\n1183:           # so the reducer can persist the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1184:           append_jsonl: '{\"type\":\"iteration\",\"run\":{current_iteration},\"mode\":\"research\",\"status\":\"error\",\"focus\":\"{next_focus}\",\"findingsCount\":0,\"newInfoRatio\":0.0,\"keyQuestions\":[],\"answeredQuestions\":[],\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n1185: \n1186:       step_telemetry_heartbeat_progress:\n1187:         action: \"Emit a single-loop progress row when iteration state changes\"\n1188:         skip_when: \"config.fanout is present\"\n1189:         command: |\n1190:           node --experimental-strip-types --input-type=module <<'EOF'\n1191:           import { existsSync, readFileSync } from 'node:fs';\n1192: \n1193:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n1194:           import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n1195: \n1196:           const { appendObservabilityEvent } = observabilityEvents;\n1197:           const stateLogPath = '{state_paths.state_log}';\n1198:           const timestamp = '{ISO_8601_NOW}';\n1199:           const sessionId = '{config.lineage.sessionId}';\n1200:           const generation = Number('{config.lineage.generation}');\n1201:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1202: \n1203:           function readRecords(path) {\n1204:             if (!existsSync(path)) return [];\n1205:             return readFileSync(path, 'utf8')\n1206:               .split(/\\r?\\n/)\n1207:               .map((line) => line.trim())\n1208:               .filter(Boolean)\n1209:               .map((line) => JSON.parse(line));\n1210:           }\n1211: \n1212:           function elapsedSince(value) {\n1213:             const startedAtMs = Date.parse(String(value ?? ''));\n1214:             const nowMs = Date.parse(timestamp);\n1215:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1216:             return Math.max(0, nowMs - startedAtMs);\n1217:           }\n1218: \n1219:           const records = readRecords(stateLogPath);\n1220:           const iterations = records.filter((record) => record.type === 'iteration');\n1221:           const latest = iterations.at(-1) ?? {};\n1222:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1223:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1224:             ?? timestamp;\n1225:           const elapsedMs = elapsedSince(startedAt);\n1226:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1227:           const run = Number.isFinite(Number(latest.run)) ? Number(latest.run) : Number('{current_iteration}');\n1228:           const status = typeof latest.status === 'string' ? latest.status : 'unknown';\n1229:           const row = {\n1230:             event: 'progress',\n1231:             label: 'single',\n1232:             at: timestamp,\n1233:             duration_ms: elapsedMs,\n1234:             loop_type: 'research',\n1235:             sessionId,\n1236:             generation,\n1237:             run,\n1238:             status,\n1239:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1240:           };\n1241: \n1242:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1243:             diffData: { event: row.event, label: row.label, sessionId, generation, run, status, gauges: { iterations: iterations.length, score } },\n1244:             diffField: 'state_hash',\n1245:           });\n1246:           if (appended) {\n1247:             try {\n1248:               appendObservabilityEvent(observabilityPath, row, {\n1249:                 producer: 'deep-research-auto',\n1250:                 stream: 'single-loop-telemetry',\n1251:                 subject: { label: row.label, sessionId, generation, run },\n1252:                 event: row.event,\n1253:                 status,\n1254:               });\n1255:             } catch {}\n1256:           }\n1257:           EOF\n1258:         working_directory: \"{repo_root}\"\n1259:         outputs:\n1260:           - status_ledger_progress: \"A fan-out-shaped status row with label single and event progress\"\n1261: \n1262:       step_generate_dashboard:\n1263:         action: \"Generate or refresh the human-readable dashboard\"\n1264:         read:\n1265:           - \"{state_paths.state_log}\"\n1266:           - \"{state_paths.registry}\"\n1267:           - \"{state_paths.strategy}\"\n1268:         template: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_dashboard.md\n1269:         output: \"{state_paths.dashboard}\"\n1270:         note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n1271: \n1272:       step_update_tracking:\n1273:         action: \"Update loop tracking variables\"\n1274:         set:\n1275:           current_iteration: \"{current_iteration + 1}\"\n1276:           stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n1277:         log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n1278: \n1279:       step_loop_decision:\n1280:         action: \"Return to step_read_state for next iteration\"\n1281:         goto: step_read_state\n1282: \n1283:   # ═══════════════════════════════════════════════════════════════\n1284:   # PHASE 3: SYNTHESIS\n1285:   # ═══════════════════════════════════════════════════════════════\n1286:   phase_synthesis:\n1287:     purpose: Compile all iteration findings into final research/research.md\n1288:     steps:\n1289: \n1290:       step_fanout_merge:\n1291:         description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n1292:         skip_when: \"config.fanout is absent\"\n1293:         command: |\n1294:           node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n1295:             --loop-type research \\\n1296:             --artifact-dir {artifact_dir}\n1297:         working_directory: \"{repo_root}\"\n1298:         wait_for_completion: true\n1299: \n1300:       step_hydrate_summary_metrics:\n1301:         action: \"Hydrate summary metrics before synthesis\"\n1302:         read:\n1303:           - \"{state_paths.config}\"\n1304:           - \"{state_paths.state_log}\"\n1305:           - \"{state_paths.registry}\"\n1306:           - \"{state_paths.strategy}\"\n1307:         extract:\n1308:           - iteration_count: \"Count lines where type === 'iteration'\"\n1309:           - current_iteration: \"iteration_count + 1\"\n1310:           - current_segment: \"Latest segment_start event segment, else 1\"\n1311:           - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n1312:           - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n1313:           - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n1314:           - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n1315:           - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n1316:           - answered_count: \"Count answered questions from strategy.md\"\n1317:           - total_questions: \"Count total questions tracked in strategy.md\"\n1318:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n1319:           - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1320: \n1321:       step_read_all_iterations:\n1322:         action: \"Read all iteration files and strategy\"\n1323:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1324:         read_also: \"{state_paths.strategy}\"\n1325: \n1326:       step_emit_resource_map:\n1327:         action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n1328:         command: \"node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n1329:         read:\n1330:           - \"{state_paths.config}\"\n1331:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1332:         write:\n1333:           - \"{state_paths.resource_map_output}\"\n1334:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1335: \n1336:       step_compile_research:\n1337:         action: \"Compile or finalize research/research.md\"\n1338:         instructions: |\n1339:           If research/research.md exists (progressive synthesis was active):\n1340:             1. Read current research/research.md\n1341:             2. Consolidate and deduplicate findings across all iterations\n1342:             3. Fill any empty sections with findings from iteration files\n1343:             4. Remove redundancy while preserving all unique findings\n1344:             5. Add convergence report as appendix\n1345:             6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1346: \n1347:           If research/research.md does not exist:\n1348:             1. Create research/research.md following 17-section template\n1349:             2. Populate sections from iteration files\n1350:             3. Add citations from original sources\n1351:             4. Note unanswered questions in Open Questions section\n1352:             5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n1353:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n1354:         output: \"{state_paths.research_output}\"\n1355: \n1356:       step_convergence_report:\n1357:         action: \"Generate and append convergence report\"\n1358:         report: |\n1359:           ## Convergence Report\n1360:           - Stop reason: {reason}\n1361:           - Total iterations: {iteration_count}\n1362:           - Questions answered: {answered_count} / {total_questions}\n1363:           - Remaining questions: {remaining_questions}\n1364:           - Last 3 iteration summaries: {last_3_summaries}\n1365:           - Convergence threshold: {convergence_threshold}\n1366:           - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n1367:         command: |\n1368:           node --input-type=module <<'EOF'\n1369:           import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n1370: \n1371:           const paths = {\n1372:             stateLog: String.raw`{state_paths.state_log}`,\n1373:             registry: String.raw`{state_paths.registry}`,\n1374:             research: String.raw`{state_paths.research_output}`,\n1375:             dashboard: String.raw`{state_paths.dashboard}`,\n1376:           };\n1377: \n1378:           function hasFile(filePath) {\n1379:             try {\n1380:               return existsSync(filePath) && statSync(filePath).isFile();\n1381:             } catch {\n1382:               return false;\n1383:             }\n1384:           }\n1385: \n1386:           function readJson(filePath) {\n1387:             try {\n1388:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1389:             } catch {\n1390:               return null;\n1391:             }\n1392:           }\n1393: \n1394:           function readJsonl(filePath) {\n1395:             if (!hasFile(filePath)) return [];\n1396:             return readFileSync(filePath, 'utf8')\n1397:               .split(/\\r?\\n/)\n1398:               .map((line) => line.trim())\n1399:               .filter(Boolean)\n1400:               .flatMap((line) => {\n1401:                 try {\n1402:                   return [JSON.parse(line)];\n1403:                 } catch {\n1404:                   return [];\n1405:                 }\n1406:               });\n1407:           }\n1408: \n1409:           function countIterationFindings(record) {\n1410:             if (!record || record.type !== 'iteration') return 0;\n1411:             const numeric = Number(record.findingsCount);\n1412:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1413:             if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n1414:             if (Array.isArray(record.findings)) return record.findings.length;\n1415:             return 0;\n1416:           }\n1417: \n1418:           function normalizeFindingKey(value) {\n1419:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1420:           }\n1421: \n1422:           function findingKeys(candidate) {\n1423:             if (typeof candidate === 'string') {\n1424:               const key = normalizeFindingKey(candidate);\n1425:               return key ? [key] : [];\n1426:             }\n1427:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1428:             return [...new Set([\n1429:               candidate.id,\n1430:               candidate.title,\n1431:               candidate.summary,\n1432:               candidate.text,\n1433:               candidate.finding,\n1434:               candidate.description,\n1435:             ].map(normalizeFindingKey).filter(Boolean))];\n1436:           }\n1437: \n1438:           function collectIterationFindingGroups(record) {\n1439:             if (!record || record.type !== 'iteration') return [];\n1440:             const structured = [record.keyFindings, record.findings]\n1441:               .find((value) => Array.isArray(value) && value.length > 0);\n1442:             if (!Array.isArray(structured)) return [];\n1443:             return structured\n1444:               .map(findingKeys)\n1445:               .filter((keys) => keys.length > 0);\n1446:           }\n1447: \n1448:           function collectRegistryFindingKeys(registry) {\n1449:             if (!Array.isArray(registry?.keyFindings)) return [];\n1450:             return registry.keyFindings\n1451:               .flatMap(findingKeys);\n1452:           }\n1453: \n1454:           function appendEvent(event) {\n1455:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1456:           }\n1457: \n1458:           const registry = readJson(paths.registry);\n1459:           const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n1460:           const stateRecords = readJsonl(paths.stateLog);\n1461:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1462:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1463:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1464:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1465:           const identifiableFindingCount = identifiableFindingGroups.length;\n1466:           const missingArtifacts = [\n1467:             ['registry', paths.registry],\n1468:             ['research', paths.research],\n1469:             ['dashboard', paths.dashboard],\n1470:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1471:           const invariantFailures = [];\n1472:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1473:           if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n1474:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1475:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1476:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1477: \n1478:           if (invariantFailures.length > 0) {\n1479:             appendEvent({\n1480:               type: 'event',\n1481:               event: 'synthesis_incomplete',\n1482:               mode: 'research',\n1483:               severity: 'warning',\n1484:               totalIterations: Number('{iteration_count}'),\n1485:               answeredCount: Number('{answered_count}'),\n1486:               totalQuestions: Number('{total_questions}'),\n1487:               stopReason: '{reason}',\n1488:               reason: 'synthesis_artifact_invariant_failed',\n1489:               invariantFailures,\n1490:               missingArtifacts,\n1491:               registryFindingCount,\n1492:               iterationFindingCount,\n1493:               identifiableFindingCount,\n1494:               missingStructuredFindingCount,\n1495:               timestamp: '{ISO_8601_NOW}',\n1496:             });\n1497:           } else {\n1498:             appendEvent({\n1499:               type: 'event',\n1500:               event: 'synthesis_complete',\n1501:               totalIterations: Number('{iteration_count}'),\n1502:               answeredCount: Number('{answered_count}'),\n1503:               totalQuestions: Number('{total_questions}'),\n1504:               stopReason: '{reason}',\n1505:               timestamp: '{ISO_8601_NOW}',\n1506:             });\n1507:           }\n1508:           EOF\n1509: \n1510:       step_writeback_spec_findings:\n1511:         action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n1512:         edit: \"{spec_folder}/spec.md\"\n1513:         host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n1514:         generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n1515:         generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n1516:         fail_closed_conflict_check:\n1517:           if_existing_generated_fence_present:\n1518:             detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n1519:             on_manual_edit_conflict:\n1520:               append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1521:               halt: true\n1522:         instructions:\n1523:           - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n1524:           - \"Replace exactly one generated findings block under the chosen host anchor.\"\n1525:           - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n1526:           - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n1527:           - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n1528:         append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1529: \n1530:       step_validate_post_synthesis_spec_doc:\n1531:         action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n1532:         command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n1533:         note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n1534: \n1535:       step_update_config_status:\n1536:         action: \"Mark config as complete\"\n1537:         edit: \"{state_paths.config}\"\n1538:         set_field: { status: \"complete\" }\n1539: \n1540:       step_telemetry_heartbeat_terminal:\n1541:         action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n1542:         skip_when: \"config.fanout is present\"\n1543:         terminal_events: [completed, failed, stopped]\n1544:         command: |\n1545:           node --experimental-strip-types --input-type=module <<'EOF'\n1546:           import { existsSync, readFileSync } from 'node:fs';\n1547: \n1548:           import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n1549:           import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n1550: \n1551:           const { appendObservabilityEvent } = observabilityEvents;\n1552:           const stateLogPath = '{state_paths.state_log}';\n1553:           const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n1554:           const timestamp = '{ISO_8601_NOW}';\n1555:           const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n1556:           const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n1557:           const reason = '{reason}';\n1558:           const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n1559: \n1560:           function readRecords(path) {\n1561:             if (!existsSync(path)) return [];\n1562:             return readFileSync(path, 'utf8')\n1563:               .split(/\\r?\\n/)\n1564:               .map((line) => line.trim())\n1565:               .filter(Boolean)\n1566:               .map((line) => JSON.parse(line));\n1567:           }\n1568: \n1569:           function elapsedSince(value) {\n1570:             const startedAtMs = Date.parse(String(value ?? ''));\n1571:             const nowMs = Date.parse(timestamp);\n1572:             if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n1573:             return Math.max(0, nowMs - startedAtMs);\n1574:           }\n1575: \n1576:           function terminalEvent(stopReason) {\n1577:             if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n1578:             if (stopReason === 'error') return 'failed';\n1579:             return 'completed';\n1580:           }\n1581: \n1582:           const records = readRecords(stateLogPath);\n1583:           const iterations = records.filter((record) => record.type === 'iteration');\n1584:           const latest = iterations.at(-1) ?? {};\n1585:           const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n1586:             ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n1587:             ?? timestamp;\n1588:           const elapsedMs = elapsedSince(startedAt);\n1589:           const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n1590:           const event = terminalEvent(reason);\n1591:           const row = {\n1592:             event,\n1593:             label: 'single',\n1594:             terminal: true,\n1595:             reason,\n1596:             at: timestamp,\n1597:             duration_ms: elapsedMs,\n1598:             loop_type: 'research',\n1599:             sessionId,\n1600:             generation,\n1601:             gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n1602:           };\n1603: \n1604:           const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n1605:             diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n1606:             diffField: 'state_hash',\n1607:           });\n1608:           if (appended) {\n1609:             try {\n1610:               appendObservabilityEvent(observabilityPath, row, {\n1611:                 producer: 'deep-research-auto',\n1612:                 stream: 'single-loop-telemetry',\n1613:                 subject: { label: row.label, sessionId, generation, reason },\n1614:                 event,\n1615:                 status: event,\n1616:               });\n1617:             } catch {}\n1618:           }\n1619:           EOF\n1620:         working_directory: \"{repo_root}\"\n1621:         outputs:\n1622:           - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n1623: \n1624:       step_stage_artifact_dir:\n1625:         action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n1626:         command: \"git add {state_paths.packet_dir}\"\n1627:         note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n1628:         on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n1629: \n1630:   # ═══════════════════════════════════════════════════════════════\n1631:   # PHASE 4: SAVE\n1632:   # ═══════════════════════════════════════════════════════════════\n1633:   phase_save:\n1634:     purpose: Preserve research context to memory system\n1635:     steps:\n1636: \n1637:       step_compose_save_payload:\n1638:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1639:         output: \"/tmp/save-context-data-<session-id>.json\"\n1640:         requirements:\n1641:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1642:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n1643:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1644:         example_payload: |\n1645:           {\n1646:             \"specFolder\": \"{spec_folder}\",\n1647:             \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",\n\n(Output capped at 50 KB. Showing lines 737-1647. Use offset=1648 to continue.)\n</content>","metadata":{"preview":"            values:\n              - \"{next_focus}\"\n              - \"{remaining_questions_list}\"\n              - \"{carried_forward_open_questions}\"\n          recovery:\n            category: \"recovery\"\n            values:\n              - \"{recovery_strategy}\"\n              - \"{least_explored}\"\n          ideas:\n            category: \"ideas\"\n            values:\n              - \"{promoted_ideas_list}\"\n            optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n        algorithm: |\n          Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n          reducer pass as the source of truth.\n          Compare normalized exact text first. Then compare fuzzy similarity with\n          rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n          are compatible. Remove suppressed candidates from next_focus, recovery, and ideas","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_research_auto.yaml","text":"            values:\n              - \"{next_focus}\"\n              - \"{remaining_questions_list}\"\n              - \"{carried_forward_open_questions}\"\n          recovery:\n            category: \"recovery\"\n            values:\n              - \"{recovery_strategy}\"\n              - \"{least_explored}\"\n          ideas:\n            category: \"ideas\"\n            values:\n              - \"{promoted_ideas_list}\"\n            optional_file: \"{state_paths.packet_dir}/research-ideas.md\"\n        algorithm: |\n          Use registry.rejectedPatternIndex and registry.promotedIdeas from the latest\n          reducer pass as the source of truth.\n          Compare normalized exact text first. Then compare fuzzy similarity with\n          rejected_pattern_fuzzy_threshold, but only when candidate and rejected categories\n          are compatible. Remove suppressed candidates from next_focus, recovery, and ideas\n          selection before rendering the dispatch prompt. If all candidates are suppressed,\n          halt for operator input instead of reusing a rejected idea.\n        outputs:\n          - accepted_next_focus: \"First unsuppressed next-focus candidate, or null\"\n          - accepted_recovery_candidate: \"First unsuppressed recovery candidate, or null\"\n          - accepted_idea_candidate: \"First unsuppressed ideas candidate, or null\"\n          - rejected_candidate_matches: \"Suppressed candidate diagnostics from registry.suppressedCandidates plus any current-step matches\"\n        if_next_focus_suppressed:\n          set: { next_focus: \"{accepted_next_focus || accepted_recovery_candidate || accepted_idea_candidate}\" }\n          log: \"Rejected-pattern cache suppressed the prior candidate; dispatching the next accepted candidate.\"\n        if_all_candidates_suppressed:\n          halt: true\n          message: \"All next-focus, recovery, and ideas candidates match active rejected patterns. Remove/reset the rejected pattern or provide a new focus.\"\n\n      step_ideas_backlog_lifecycle:\n        action: \"Track reducer-owned observed/promoted/rejected idea lifecycle before dispatch\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.config}\"\n        lifecycle:\n          observed_event: \"idea_observed\"\n          promoted_event: \"idea_promoted\"\n          rejected_event: \"idea_rejected\"\n          min_observations: \"{min_idea_observations}\"\n          authority: \"Leaf agents emit observations only; reducer emits promotions and owns ranking.\"\n        validate:\n          - \"If new leaf-authored output includes idea_promoted, fail validation; only reducer output may append idea_promoted.\"\n          - \"If promoted_ideas_count > 0 and next_focus is empty or all questions are resolved, prefer the first unsuppressed promoted idea.\"\n          - \"If suppressed_ideas_count > 0, do not render those ideas into dispatch context.\"\n        outputs:\n          - observed_ideas_count: \"Reducer-derived observed ideas count\"\n          - promoted_ideas_count: \"Reducer-derived promoted ideas count after minIdeaObservations\"\n          - suppressed_ideas_count: \"Reducer-derived rejected/suppressed ideas count\"\n          - accepted_idea_candidate: \"First unsuppressed promoted idea, or null\"\n\n      step_normalize_pause_events:\n        action: \"Normalize pause and recovery lifecycle events to the frozen STOP_REASONS enum at emission time\"\n        stop_reasons_enum: [converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n        rule_pause_sentinel:\n          raw_event_forbidden: '{\"type\":\"event\",\"event\":\"paused\"}'\n          canonical_event: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"userPaused\",\"sentinelPath\":\"{state_paths.pause_sentinel}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n        rule_stuck_recovery:\n          raw_event_forbidden: '{\"type\":\"event\",\"event\":\"stuck_recovery\"}'\n          canonical_event: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"research\",\"run\":{current_iteration},\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"outcome\":\"recovered\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested research marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested research-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested research-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch one iteration via the selected executor\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Segment: {current_segment} | Iteration: {current_iteration} of {max_iterations}\n            Questions: {answered_count}/{total_questions} answered | Last focus: {last_focus}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest} | Stuck count: {stuck_count}\n            {resource_map_prompt_line}\n            {memory_context_prompt_line}\n            Next focus: {next_focus}\n          render_prompt_pack:\n            template_path: \".opencode/skills/deep-loop-workflows/deep-research/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/deep-loop-runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              research_topic: \"{research_topic}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_focus: \"{next_focus}\"\n              remaining_questions_list: \"{remaining_questions_list}\"\n              carried_forward_open_questions: \"{carried_forward_open_questions}\"\n              last_3_summaries: \"{last_3_summaries}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_registry: \"{state_paths.registry}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.type == 'native'\"\n          call: \".opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.type\"\n        if_native:\n          dispatch:\n            agent: deep-research\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_claude_code:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n            import { resolveClaudePermissionMode } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-config.ts';\n\n            const executor = {\n              kind: 'cli-claude-code',\n              model: '{config.executor.model}',\n              reasoningEffort: '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}',\n              serviceTier: '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}',\n              sandboxMode: '{config.executor.sandboxMode}' === 'null' ? null : '{config.executor.sandboxMode}',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n            };\n            const args = [\n              '-p',\n              readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n              '--model',\n              executor.model,\n              '--permission-mode',\n              resolveClaudePermissionMode(executor.sandboxMode),\n              '--output-format',\n              'text',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--effort', executor.reasoningEffort);\n            }\n\n            const dispatchFacts = {\n              command: 'deep/research',\n              mode: 'research',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.type}',\n              branchId: '{config.executor.type}',\n              sessionId: '{config.lineage.sessionId}',\n              generation: Number('{config.lineage.generation}'),\n            };\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'claude',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"sandboxMode maps to permission-mode: read-only -> plan, workspace-write -> acceptEdits, danger-full-access -> bypassPermissions\"\n            - \"claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        record_executor_audit:\n          skip_when: \"config.executor.type == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.type}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n        if_cli_opencode:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/executor-audit.ts';\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-opencode',\n              model: '{config.executor.model}',\n              configDir: null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n            const message = 'Resolved route: mode=research; target_agent=@deep-research; execution=single_iteration; state_source=externalized_files; do_not_switch_mode=true'\n              + '\\n\\n'\n              + promptBody;\n            const args = [\n              'run',\n              '--model',\n              executor.model,\n              '--format',\n              'json',\n              '--dangerously-skip-permissions',\n              '--pure',\n              '--dir',\n              '{repo_root}',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--variant', executor.reasoningEffort);\n            }\n            args.push(message);\n\n            const dispatchFacts = {\n              command: 'deep/research',\n              mode: 'research',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.type}',\n              branchId: '{config.executor.type}',\n              sessionId: '{config.lineage.sessionId}',\n              generation: Number('{config.lineage.generation}'),\n            };\n            const dispatchId = 'research-i{current_iteration}-g{config.lineage.generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'opencode',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                // opencode v1.14.39 reads stdin at startup before session creation;\n                // an empty input gives EOF stdin, equivalent to </dev/null.\n                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (cli-opencode SKILL.md §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). The cli-opencode skill SKILL.md §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/deep-loop-runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs --loop-type research --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, newInfoRatio, status, focus, mode]\n          route_proof:\n            mode: research\n            target_agent: deep-research\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=research target_agent=deep-research\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"research-i{current_iteration}-g{config.lineage.generation}\"\n          optional_jsonl_fields:\n            logOffset: \"Byte offset where the seekable log region starts\"\n            logSize: \"Byte length of the seekable log region\"\n            logPath: \"Absolute path to the file containing the seekable log region\"\n            skippedCount: \"Missed fixed-rate slots counted for the completed dispatch; 0 when no slot was missed\"\n            slotDurationMs: \"Monotonic elapsed duration for the completed dispatch slot\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error and continue. Never re-dispatch a given iteration more than once.\"\n            escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n          failure_reasons_reference:\n            - \"iteration_file_missing — iteration narrative markdown not written\"\n            - \"iteration_file_empty — iteration narrative markdown is zero bytes\"\n            - \"jsonl_not_appended — state log file did not grow since pre-dispatch snapshot\"\n            - \"jsonl_missing_fields — last state-log record omits required schema fields\"\n            - \"jsonl_parse_error — last state-log line is not valid JSON\"\n            - \"jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop\"\n            - \"delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written\"\n            - \"delta_file_empty — per-iteration delta file exists but has zero bytes\"\n            - \"delta_file_missing_iteration_record — delta file lacks any record with type='iteration'\"\n            - \"route_proof_missing — state-log or delta iteration record omits route-proof fields\"\n            - \"route_proof_mismatch — state-log or delta iteration record does not match the resolved deep route\"\n            - \"executor_missing — non-native executor did not record provenance\"\n            - \"dispatch_failure_logged — last record is an explicit dispatch_failure event\"\n\n      step_run_now_restore_check:\n        action: \"Record a run-now sentinel recreated during the completed dispatch\"\n        command: |\n          node <<'EOF'\n          const { appendFileSync, existsSync, readFileSync } = require('node:fs');\n\n          const stateLogPath = \"{state_paths.state_log}\";\n          const sentinelPath = \"{state_paths.run_now_sentinel}\";\n          const timestamp = \"{ISO_8601_NOW}\";\n          const sessionId = \"{config.lineage.sessionId}\";\n          const generation = Number(\"{config.lineage.generation}\");\n          const run = Number(\"{current_iteration}\");\n\n          function hasAcceptedCurrentRun() {\n            if (!existsSync(stateLogPath)) return false;\n            const lines = readFileSync(stateLogPath, \"utf8\").trim().split(/\\r?\\n/).filter(Boolean);\n            for (let index = lines.length - 1; index >= 0; index -= 1) {\n              const record = JSON.parse(lines[index]);\n              if (record.run !== run || record.sessionId !== sessionId) continue;\n              if (record.event === \"run_now_accepted\") return true;\n              if (record.event === \"run_now_rejected\") return false;\n            }\n            return false;\n          }\n\n          if (existsSync(sentinelPath) && hasAcceptedCurrentRun()) {\n            appendFileSync(\n              stateLogPath,\n              `${JSON.stringify({\n                type: \"event\",\n                event: \"run_now_restored\",\n                mode: \"research\",\n                run,\n                sentinelPath,\n                timestamp,\n                sessionId,\n                generation,\n              })}\\n`,\n              \"utf8\",\n            );\n          }\n          EOF\n        outputs:\n          - run_now_restored: \"Emitted when an operator recreates the sentinel before the accepted dispatch completes\"\n\n      step_reduce_state:\n        action: \"Run the reducer to synchronize registry, dashboard, and strategy\"\n        command: \"node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs {spec_folder}\"\n        inputs:\n          latestJSONLDelta: \"Latest JSONL records written since the previous iteration\"\n          newIterationFile: \"{state_paths.iteration_pattern}\"\n          priorReducedState: \"{state_paths.registry}\"\n        outputs:\n          - \"{state_paths.registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.state_log} question_conflict events when inbox text disagrees with registry-owned question text\"\n          - \"{state_paths.state_log} idempotent idea_promoted events when observed ideas reach minIdeaObservations\"\n          - \"{state_paths.registry} observedIdeas, promotedIdeas, suppressedIdeas, rejectedPatterns, and suppressedCandidates from idea lifecycle events\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n          question_conflict: \"keep registry value + append question_conflict event with inboxValue, registryValue, and operatorDecision\"\n        guarantee: \"Idempotent for identical inputs\"\n\n      step_graph_upsert:\n        action: \"Persist the latest iteration graph delta after the reducer refresh and after the iteration file exists\"\n        read:\n          - \"{state_paths.state_log}\"\n        extract:\n          - latest_graph_events: \"Read graphEvents from the latest iteration record, else []\"\n          - graph_upsert_nodes_json: \"Map latest_graph_events where type == 'node' to node payloads with label -> name and preserve remaining node fields\"\n          - graph_upsert_edges_json: \"Map latest_graph_events where type == 'edge' to edge payloads with source -> sourceId, target -> targetId, relation -> uppercase(relation), and preserve remaining edge fields\"\n          - graph_upsert_event_count: \"Count mapped node and edge events\"\n        if_graph_events_present:\n          bash: \"node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"research\\\" --session-id \\\"{config.lineage.sessionId}\\\" --nodes '{graph_upsert_nodes_json}' --edges '{graph_upsert_edges_json}'\"\n          note: \"Skip silently when graphEvents is missing or empty.\"\n        if_graph_events_missing:\n          proceed: true\n\n      step_memory_upsert_iteration:\n        action: \"Upsert the canonical iteration evidence into Spec Kit Memory after reducer and graph persistence\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"{state_paths.iteration_pattern}\" })'\n        timeout_seconds: 5\n        idempotency: \"Re-running the same iteration file is safe because the memory backend upserts by path/content.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue\"\n        outputs:\n          - memory_upsert_iteration_file: \"{state_paths.iteration_pattern}\"\n          - memory_upsert_status: \"upserted | advisory_error\"\n\n      step_refresh_memory_context:\n        action: \"Refresh focused Spec Kit Memory context before the next prompt render\"\n        mcp_tool: memory_context\n        invocation: 'memory_context({ input: \"{research_topic}\", mode: \"focused\", intent: \"understand\", includeContent: true })'\n        timeout_seconds: 5\n        use_response:\n          - \"Update memory_context_prompt_line with a concise summary for the next step_dispatch_iteration.pre_dispatch.generate_summary.\"\n        failure_policy:\n          mcp_error: \"non-fatal; log advisory warning and continue with the previous memory_context_prompt_line\"\n          timeout: \"non-fatal after timeout_seconds; log advisory warning and continue with the previous memory_context_prompt_line\"\n        outputs:\n          - memory_context_prompt_line: \"Fresh focused context summary for the next iteration prompt\"\n          - memory_context_refresh_status: \"refreshed | advisory_error\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Reducer refreshed strategy machine-owned sections\"\n          - registry_updated: \"Reducer refreshed deep-research-findings-registry.json\"\n        extract:\n          - newInfoRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - latest_focus: \"From latest JSONL iteration record\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # Canonical iteration record: include mode, sessionId, generation, durationMs, keyQuestions, answeredQuestions\n          # so the reducer can persist the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"run\":{current_iteration},\"mode\":\"research\",\"status\":\"error\",\"focus\":\"{next_focus}\",\"findingsCount\":0,\"newInfoRatio\":0.0,\"keyQuestions\":[],\"answeredQuestions\":[],\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation}}'\n\n      step_telemetry_heartbeat_progress:\n        action: \"Emit a single-loop progress row when iteration state changes\"\n        skip_when: \"config.fanout is present\"\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = '{config.lineage.sessionId}';\n          const generation = Number('{config.lineage.generation}');\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const run = Number.isFinite(Number(latest.run)) ? Number(latest.run) : Number('{current_iteration}');\n          const status = typeof latest.status === 'string' ? latest.status : 'unknown';\n          const row = {\n            event: 'progress',\n            label: 'single',\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            run,\n            status,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event: row.event, label: row.label, sessionId, generation, run, status, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, run },\n                event: row.event,\n                status,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_progress: \"A fan-out-shaped status row with label single and event progress\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the human-readable dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        template: .opencode/skills/deep-loop-workflows/deep-research/assets/deep_research_dashboard.md\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + reducer registry + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          stuck_count: \"if status == 'thought': unchanged (skip). if status == 'insight': 0 (reset). if newInfoRatio < convergence_threshold: stuck_count + 1, else: 0\"\n        log: \"Iteration {N} complete. newInfoRatio: {newInfoRatio}. Findings: {findings_count}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into final research/research.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries into one consolidated registry; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs \\\n            --loop-type research \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - current_segment: \"Latest segment_start event segment, else 1\"\n          - last_focus: \"Extract focus from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newInfoRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newInfoRatio from latest iteration record, else 'N/A'\"\n          - remaining_questions: \"Count unchecked items in 'Key Questions'\"\n          - remaining_questions_list: \"List unchecked key questions from strategy.md\"\n          - answered_count: \"Count answered questions from strategy.md\"\n          - total_questions: \"Count total questions tracked in strategy.md\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: focus (ratio)'\"\n          - reason: \"Use the latest synthesis/recovery stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged research deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs {spec_folder} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_compile_research:\n        action: \"Compile or finalize research/research.md\"\n        instructions: |\n          If research/research.md exists (progressive synthesis was active):\n            1. Read current research/research.md\n            2. Consolidate and deduplicate findings across all iterations\n            3. Fill any empty sections with findings from iteration files\n            4. Remove redundancy while preserving all unique findings\n            5. Add convergence report as appendix\n            6. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n\n          If research/research.md does not exist:\n            1. Create research/research.md following 17-section template\n            2. Populate sections from iteration files\n            3. Add citations from original sources\n            4. Note unanswered questions in Open Questions section\n            5. If `resource_map_present` is true, cite `{spec_folder}/resource-map.md` in References; otherwise omit any placeholder map citation\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-research/references/protocol/loop_protocol.md §Lifecycle Branch Contract`.)\n        output: \"{state_paths.research_output}\"\n\n      step_convergence_report:\n        action: \"Generate and append convergence report\"\n        report: |\n          ## Convergence Report\n          - Stop reason: {reason}\n          - Total iterations: {iteration_count}\n          - Questions answered: {answered_count} / {total_questions}\n          - Remaining questions: {remaining_questions}\n          - Last 3 iteration summaries: {last_3_summaries}\n          - Convergence threshold: {convergence_threshold}\n          - Segment transitions, wave scores, and checkpoint metrics are experimental and omitted from the live report.\n        command: |\n          node --input-type=module <<'EOF'\n          import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n\n          const paths = {\n            stateLog: String.raw`{state_paths.state_log}`,\n            registry: String.raw`{state_paths.registry}`,\n            research: String.raw`{state_paths.research_output}`,\n            dashboard: String.raw`{state_paths.dashboard}`,\n          };\n\n          function hasFile(filePath) {\n            try {\n              return existsSync(filePath) && statSync(filePath).isFile();\n            } catch {\n              return false;\n            }\n          }\n\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.keyFindings)) return record.keyFindings.length;\n            if (Array.isArray(record.findings)) return record.findings.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }\n\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration') return [];\n            const structured = [record.keyFindings, record.findings]\n              .find((value) => Array.isArray(value) && value.length > 0);\n            if (!Array.isArray(structured)) return [];\n            return structured\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            if (!Array.isArray(registry?.keyFindings)) return [];\n            return registry.keyFindings\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const registryFindingCount = Array.isArray(registry?.keyFindings) ? registry.keyFindings.length : null;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['research', paths.research],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_keyFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'research',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              totalIterations: Number('{iteration_count}'),\n              answeredCount: Number('{answered_count}'),\n              totalQuestions: Number('{total_questions}'),\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n\n      step_writeback_spec_findings:\n        action: \"Write or replace the bounded generated findings block in spec.md before config completion\"\n        edit: \"{spec_folder}/spec.md\"\n        host_anchor: \"Use the chosen host anchor required by spec_check_protocol\"\n        generated_fence_begin: \"<!-- BEGIN GENERATED: deep-research/spec-findings -->\"\n        generated_fence_end: \"<!-- END GENERATED: deep-research/spec-findings -->\"\n        fail_closed_conflict_check:\n          if_existing_generated_fence_present:\n            detect_manual_edits: \"Use generated checksum metadata or an explicit MANUAL-EDIT marker inside the existing fence to detect human edits before overwrite.\"\n            on_manual_edit_conflict:\n              append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation_conflict\",\"folder_state\":\"conflict-detected\",\"reason\":\"Manual edits detected inside existing generated findings fence.\",\"specPath\":\"{spec_folder}/spec.md\",\"generatedFence\":\"deep-research/spec-findings\",\"conflictKind\":\"generated-fence-manual-edit\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n              halt: true\n        instructions:\n          - \"Read `{state_paths.research_output}` as the canonical synthesis source.\"\n          - \"Replace exactly one generated findings block under the chosen host anchor.\"\n          - \"Fail closed if the host anchor is missing, duplicate markers exist, or human edits are detected inside the generated block.\"\n          - \"Do not overwrite a generated block that fails checksum validation or carries an explicit MANUAL-EDIT marker.\"\n          - \"Emit `spec_synthesis_deferred` instead of partial output when synthesis cannot safely write back.\"\n        append_to_jsonl: '{\"type\":\"spec_mutation\",\"event\":\"spec_mutation\",\"phase\":\"post-synthesis\",\"anchors_touched\":[\"<chosen host anchor>\"],\"diff_summary\":\"Replaced generated deep-research findings fence from research/research.md.\",\"generatedFence\":\"deep-research/spec-findings\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n      step_validate_post_synthesis_spec_doc:\n        action: \"Run targeted strict validation after deep-research writes back into spec.md\"\n        command: \"SPECKIT_RULES=FRONTMATTER_VALID,LEVEL_DECLARED,TEMPLATE_SOURCE,TEMPLATE_HEADERS,PLACEHOLDER_FILLED,SECTIONS_PRESENT,ANCHORS_VALID,SPEC_DOC_INTEGRITY,TOC_POLICY bash .opencode/skills/system-spec-kit/scripts/spec/validate.sh {spec_folder} --strict\"\n        note: \"Fail closed before completion if the deep-research spec.md sync breaks the authored-spec structural contract. This targeted check uses the fast Node validation orchestrator.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_telemetry_heartbeat_terminal:\n        action: \"Emit a single-loop terminal row in the orchestration status ledger\"\n        skip_when: \"config.fanout is present\"\n        terminal_events: [completed, failed, stopped]\n        command: |\n          node --experimental-strip-types --input-type=module <<'EOF'\n          import { existsSync, readFileSync } from 'node:fs';\n\n          import { appendJsonlIfChangedAtomic } from './.opencode/skills/deep-loop-runtime/lib/deep-loop/atomic-state.ts';\n          import observabilityEvents from './.opencode/skills/deep-loop-runtime/lib/deep-loop/observability-events.cjs';\n\n          const { appendObservabilityEvent } = observabilityEvents;\n          const stateLogPath = '{state_paths.state_log}';\n          const config = JSON.parse(readFileSync('{state_paths.config}', 'utf8'));\n          const timestamp = '{ISO_8601_NOW}';\n          const sessionId = String(config.lineage?.sessionId ?? '{config.lineage.sessionId}');\n          const generation = Number(config.lineage?.generation ?? '{config.lineage.generation}');\n          const reason = '{reason}';\n          const observabilityPath = '{state_paths.packet_dir}/observability-events.jsonl';\n\n          function readRecords(path) {\n            if (!existsSync(path)) return [];\n            return readFileSync(path, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .map((line) => JSON.parse(line));\n          }\n\n          function elapsedSince(value) {\n            const startedAtMs = Date.parse(String(value ?? ''));\n            const nowMs = Date.parse(timestamp);\n            if (!Number.isFinite(startedAtMs) || !Number.isFinite(nowMs)) return 0;\n            return Math.max(0, nowMs - startedAtMs);\n          }\n\n          function terminalEvent(stopReason) {\n            if (stopReason === 'manualStop' || stopReason === 'userPaused') return 'stopped';\n            if (stopReason === 'error') return 'failed';\n            return 'completed';\n          }\n\n          const records = readRecords(stateLogPath);\n          const iterations = records.filter((record) => record.type === 'iteration');\n          const latest = iterations.at(-1) ?? {};\n          const startedAt = records.find((record) => typeof record.createdAt === 'string')?.createdAt\n            ?? records.find((record) => typeof record.timestamp === 'string')?.timestamp\n            ?? timestamp;\n          const elapsedMs = elapsedSince(startedAt);\n          const score = Number.isFinite(Number(latest.newInfoRatio)) ? Number(latest.newInfoRatio) : 0;\n          const event = terminalEvent(reason);\n          const row = {\n            event,\n            label: 'single',\n            terminal: true,\n            reason,\n            at: timestamp,\n            duration_ms: elapsedMs,\n            loop_type: 'research',\n            sessionId,\n            generation,\n            gauges: { iterations: iterations.length, elapsed_ms: elapsedMs, score },\n          };\n\n          const appended = appendJsonlIfChangedAtomic('{state_paths.status_ledger}', row, {\n            diffData: { event, label: row.label, reason, sessionId, generation, gauges: { iterations: iterations.length, score } },\n            diffField: 'state_hash',\n          });\n          if (appended) {\n            try {\n              appendObservabilityEvent(observabilityPath, row, {\n                producer: 'deep-research-auto',\n                stream: 'single-loop-telemetry',\n                subject: { label: row.label, sessionId, generation, reason },\n                event,\n                status: event,\n              });\n            } catch {}\n          }\n          EOF\n        working_directory: \"{repo_root}\"\n        outputs:\n          - status_ledger_terminal: \"A fan-out-shaped status row with label single and event completed, failed, or stopped\"\n\n      step_stage_artifact_dir:\n        action: \"Stage all skill-owned artifacts under artifact_dir for the operator's next git commit\"\n        command: \"git add {state_paths.packet_dir}\"\n        note: \"Skill-owned contract fix (028): without this stage step, operators who do `git add research-report.md` lose the iteration trail (iterations/, deltas/, state.jsonl, strategy, etc.). Staging the whole artifact_dir keeps the audit trail intact. Operators retain commit authority and can `git restore --staged {path}` to unstage anything before commit. Failure is non-fatal — log warning and continue.\"\n        on_fail: \"Log warning. Do not block synthesis. The artifact_dir may be outside a git repo (e.g., temp test fixture) which is a valid case.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve research context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed research loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep research completed; see research/research.md for synthesized findings.\",","lineStart":737,"lineEnd":1647,"totalLines":1648,"truncated":true}},"title":".opencode/commands/deep/assets/deep_research_auto.yaml","time":{"start":1783489172205,"end":1783489172210}},"metadata":{"openai":{"itemId":"fc_01fb4a25ac0d7cd3016a4de293e7408191be639881de2cdbda"}},"id":"prt_f403d125e001niT3Aqf4KUQN1E","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","messageID":"msg_f403cbc480018ajiAmXXfQafxy"}}
{"type":"tool_use","timestamp":1783489172325,"sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","part":{"type":"tool","tool":"read","callID":"call_yzyy5kFeSqjwduPmIg5uylCC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: \n3: // ╔══════════════════════════════════════════════════════════════════════════╗\n4: // ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n5: // ╠══════════════════════════════════════════════════════════════════════════╣\n6: // ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n7: // ║         --base-artifact-dir).                                            ║\n8: // ║ Output: JSON to stdout.                                                  ║\n9: // ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n10: // ╚══════════════════════════════════════════════════════════════════════════╝\n11: \n12: 'use strict';\n13: \n14: // ─────────────────────────────────────────────────────────────────────────────\n15: // 1. IMPORTS\n16: // ─────────────────────────────────────────────────────────────────────────────\n17: \n18: const fs = require('node:fs');\n19: const os = require('node:os');\n20: const path = require('node:path');\n21: const { spawn } = require('node:child_process');\n22: \n23: const {\n24:   classifyExitCode,\n25:   maybeThrowTestFault,\n26:   validateNamespaceValue,\n27: } = require('./lib/cli-guards.cjs');\n28: \n29: const {\n30:   runCappedPool,\n31:   appendStatusLedger,\n32:   markOrphanedLineages,\n33:   readRetryCountsFromLedger,\n34:   createWavePlannerInterface,\n35:   writeOrchestrationSummary,\n36: } = require('./fanout-pool.cjs');\n37: \n38: const {\n39:   runSalvageSweep,\n40:   extractTextFromOpencodeJson,\n41: } = require('./fanout-salvage.cjs');\n42: \n43: const {\n44:   appendObservabilityEvent,\n45: } = require('../lib/deep-loop/observability-events.cjs');\n46: \n47: // ─────────────────────────────────────────────────────────────────────────────\n48: // 2. TSX BOOTSTRAP\n49: // ─────────────────────────────────────────────────────────────────────────────\n50: \n51: const TSX_LOADER = require.resolve('tsx');\n52: const isTsxLoaded = process.env.DEEP_LOOP_TSX_LOADED === '1';\n53: \n54: function runTsxBootstrap() {\n55:   const child = spawn(\n56:     process.execPath,\n57:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n58:     {\n59:       cwd: process.cwd(),\n60:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n61:       stdio: [process.stdin.isTTY ? 'ignore' : 'pipe', 'pipe', 'pipe'],\n62:     },\n63:   );\n64: \n65:   if (!process.stdin.isTTY && child.stdin) {\n66:     child.stdin.on('error', () => {});\n67:     process.stdin.pipe(child.stdin);\n68:   }\n69: \n70:   child.stdout?.pipe(process.stdout);\n71:   child.stderr?.pipe(process.stderr);\n72: \n73:   for (const signal of ['SIGINT', 'SIGTERM']) {\n74:     process.once(signal, () => {\n75:       child.kill(signal);\n76:     });\n77:   }\n78: \n79:   child.on('close', (status, signal) => {\n80:     if (status !== null) {\n81:       process.exit(status);\n82:     }\n83:     process.exit(signal === 'SIGINT' ? 130 : signal === 'SIGTERM' ? 143 : 1);\n84:   });\n85: }\n86: \n87: if (require.main === module && !isTsxLoaded) {\n88:   runTsxBootstrap();\n89: }\n90: \n91: // ─────────────────────────────────────────────────────────────────────────────\n92: // 3. HELPERS\n93: // ─────────────────────────────────────────────────────────────────────────────\n94: \n95: function parseArgs(argv = process.argv.slice(2)) {\n96:   const args = {};\n97:   for (let i = 0; i < argv.length; i += 1) {\n98:     const token = argv[i];\n99:     if (!token.startsWith('--')) {\n100:       throw inputError(`Unexpected positional argument: ${token}`);\n101:     }\n102:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n103:     const next = argv[i + 1];\n104:     if (next === undefined || next.startsWith('--')) {\n105:       args[key] = true;\n106:     } else {\n107:       args[key] = next;\n108:       i += 1;\n109:     }\n110:   }\n111:   return args;\n112: }\n113: \n114: function inputError(message) {\n115:   const err = new Error(message);\n116:   err.code = 'INPUT_VALIDATION';\n117:   return err;\n118: }\n119: \n120: function ensureString(args, key) {\n121:   if (!args[key] || typeof args[key] !== 'string') {\n122:     throw inputError(`${key} is required`);\n123:   }\n124:   return args[key];\n125: }\n126: \n127: function parseOptionalNumber(args, key) {\n128:   const raw = args[key];\n129:   if (raw === undefined || raw === false || raw === null || raw === '') {\n130:     return null;\n131:   }\n132:   if (raw === true || typeof raw !== 'string') {\n133:     throw inputError(`${key} must be a number`);\n134:   }\n135:   const value = Number(raw);\n136:   if (!Number.isFinite(value) || value < 0) {\n137:     throw inputError(`${key} must be a non-negative number`);\n138:   }\n139:   return value;\n140: }\n141: \n142: function readRawConfigNumber(rawConfig, names, fieldName) {\n143:   if (!isRecord(rawConfig)) return null;\n144:   for (const name of names) {\n145:     if (!Object.prototype.hasOwnProperty.call(rawConfig, name)) continue;\n146:     const raw = rawConfig[name];\n147:     if (raw === undefined || raw === null || raw === '') return null;\n148:     if (raw === true || raw === false) {\n149:       throw inputError(`${fieldName} must be a non-negative number`);\n150:     }\n151:     const value = Number(raw);\n152:     if (!Number.isFinite(value) || value < 0) {\n153:       throw inputError(`${fieldName} must be a non-negative number`);\n154:     }\n155:     return Math.floor(value);\n156:   }\n157:   return null;\n158: }\n159: \n160: function readPositiveRawConfigNumber(rawConfig, names, fieldName, fallback) {\n161:   const value = readRawConfigNumber(rawConfig, names, fieldName);\n162:   if (value === null) return fallback;\n163:   if (value <= 0) {\n164:     throw inputError(`${fieldName} must be greater than 0`);\n165:   }\n166:   return value;\n167: }\n168: \n169: function rawConfigWithCliBudgetOverrides(rawConfig, args) {\n170:   const merged = { ...(isRecord(rawConfig) ? rawConfig : {}) };\n171:   const mappings = [\n172:     ['stallWatchdogMs', 'stallWatchdogMs'],\n173:     ['maxCostUnitsPerLineage', 'maxCostUnitsPerLineage'],\n174:     ['maxTokensPerLineage', 'maxTokensPerLineage'],\n175:     ['maxTokenBudget', 'maxTokenBudget'],\n176:     ['maxTokenBudgetPerLineage', 'maxTokenBudgetPerLineage'],\n177:     ['costUnitsPerIteration', 'costUnitsPerIteration'],\n178:     ['estimatedTokensPerIteration', 'estimatedTokensPerIteration'],\n179:   ];\n180:   for (const [targetKey, argKey] of mappings) {\n181:     if (Object.prototype.hasOwnProperty.call(args, argKey)) {\n182:       merged[targetKey] = args[argKey];\n183:     }\n184:   }\n185:   return merged;\n186: }\n187: \n188: function normalizeStopPolicy(raw) {\n189:   if (raw === undefined || raw === false || raw === null || raw === '') {\n190:     return 'convergence';\n191:   }\n192:   if (raw === true || typeof raw !== 'string') {\n193:     throw inputError('stopPolicy must be convergence or max-iterations');\n194:   }\n195:   if (raw !== 'convergence' && raw !== 'max-iterations') {\n196:     throw inputError('stopPolicy must be convergence or max-iterations');\n197:   }\n198:   return raw;\n199: }\n200: \n201: function jsonOut(payload) {\n202:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n203: }\n204: \n205: function signalExitCode(signal) {\n206:   return signal === 'SIGINT' ? 130 : 143;\n207: }\n208: \n209: let fanoutSignalHandlersInstalled = false;\n210: \n211: function installFanoutSignalHandlers(onStop) {\n212:   if (fanoutSignalHandlersInstalled) return;\n213:   fanoutSignalHandlersInstalled = true;\n214: \n215:   for (const signal of ['SIGINT', 'SIGTERM']) {\n216:     process.once(signal, () => {\n217:       try {\n218:         onStop(signal);\n219:       } finally {\n220:         process.exit(signalExitCode(signal));\n221:       }\n222:     });\n223:   }\n224: }\n225: \n226: function updateLineageSnapshot(snapshots, event) {\n227:   if (!event || typeof event.label !== 'string') return;\n228:   const existing = snapshots.get(event.label) || { label: event.label };\n229: \n230:   if (event.event === 'started') {\n231:     snapshots.set(event.label, { ...existing, status: 'running', started_at_iso: event.at });\n232:     return;\n233:   }\n234:   if (event.event === 'completed') {\n235:     snapshots.set(event.label, {\n236:       ...existing,\n237:       status: 'fulfilled',\n238:       completed_at_iso: event.at,\n239:       duration_ms: event.duration_ms,\n240:     });\n241:     return;\n242:   }\n243:   if (event.event === 'failed') {\n244:     snapshots.set(event.label, {\n245:       ...existing,\n246:       status: event.terminal === false ? 'retrying' : 'rejected',\n247:       completed_at_iso: event.at,\n248:       duration_ms: event.duration_ms,\n249:       error: event.error,\n250:     });\n251:     return;\n252:   }\n253:   if (event.event === 'retry_scheduled' || event.event === 'orphan_requeued') {\n254:     snapshots.set(event.label, { ...existing, status: 'requeued', updated_at_iso: event.at });\n255:     return;\n256:   }\n257:   if (event.event === 'progress') {\n258:     snapshots.set(event.label, {\n259:       ...existing,\n260:       status: 'running',\n261:       updated_at_iso: event.at,\n262:       duration_ms: event.duration_ms,\n263:     });\n264:   }\n265: }\n266: \n267: function buildLineageSnapshots(lineages, snapshots) {\n268:   return lineages.map((lineage) => snapshots.get(lineage.label) || { label: lineage.label, status: 'pending' });\n269: }\n270: \n271: function summarizeSnapshots(lineages, snapshots) {\n272:   const results = buildLineageSnapshots(lineages, snapshots);\n273:   const succeeded = results.filter((result) => result.status === 'fulfilled').length;\n274:   const failed = results.filter((result) => result.status === 'rejected').length;\n275:   return {\n276:     results,\n277:     summary: {\n278:       total: lineages.length,\n279:       succeeded,\n280:       failed,\n281:       all_failed: lineages.length > 0 && failed === lineages.length,\n282:     },\n283:   };\n284: }\n285: \n286: function observabilityPathForLedger(ledgerPath) {\n287:   return path.join(path.dirname(ledgerPath), OBSERVABILITY_EVENTS_FILENAME);\n288: }\n289: \n290: function statusForLedgerEvent(entry) {\n291:   if (entry && typeof entry.status === 'string' && entry.status.trim() !== '') {\n292:     return entry.status;\n293:   }\n294:   if (!entry || typeof entry.event !== 'string') return 'unknown';\n295:   if (entry.event === 'started' || entry.event === 'progress' || entry.event === 'resume_waiting') return 'running';\n296:   if (entry.event === 'completed' || entry.event === 'resume_waiting_complete') return 'completed';\n297:   if (entry.event === 'failed') return entry.terminal === false ? 'retrying' : 'failed';\n298:   if (entry.event === 'stopped') return 'stopped';\n299:   if (entry.event === 'retry_scheduled' || entry.event === 'orphan_requeued') return 'retrying';\n300:   // Lag-ceiling signals from the pool: a stall warning while work remains pending, or a\n301:   // forced abort of the stalled attempt. Map both to typed statuses instead of 'unknown'.\n302:   if (entry.event === 'lag_ceiling_exceeded') return entry.action === 'abort' ? 'failed' : 'warning';\n303:   if (entry.event === 'lag_ceiling_abort') return 'failed';\n304:   if (entry.event === 'stall_detected') return 'warning';\n305:   if (entry.event === 'budget_cap_exceeded') return 'failed';\n306:   return 'unknown';\n307: }\n308: \n309: function appendFanoutStatusLedger(ledgerPath, entry) {\n310:   appendStatusLedger(ledgerPath, entry);\n311:   try {\n312:     appendObservabilityEvent(observabilityPathForLedger(ledgerPath), entry, {\n313:       producer: 'fanout-run',\n314:       stream: 'orchestration-status',\n315:       subject: {\n316:         run_id: entry.run_id ?? null,\n317:         label: entry.label ?? null,\n318:         loop_type: entry.loop_type ?? null,\n319:         spec_folder: entry.spec_folder ?? null,\n320:       },\n321:       event: entry.event,\n322:       status: statusForLedgerEvent(entry),\n323:     });\n324:   } catch {\n325:     // Observability must not make the primary orchestration ledger fail.\n326:   }\n327: }\n328: \n329: const FLAT_POOL_ASSIGNMENT_MODEL = 'flat_pool';\n330: const WAVE_ASSIGNMENT_MODEL = 'wave';\n331: const WAVE_ASSIGNMENT_MODEL_REJECTION = 'REJECTED: wave assignment_model requires conflict-safety substrate';\n332: const WAVE_ASSIGNMENT_METADATA_REJECTION = 'REJECTED: wave assignment metadata requires conflict-safety substrate';\n333: const STATE_LOG_BY_LOOP_TYPE = {\n334:   research: 'deep-research-state.jsonl',\n335:   review: 'deep-review-state.jsonl',\n336: };\n337: const ACTIVE_FANOUT_LOOP_TYPES = new Set(['research', 'review']);\n338: const DEPRECATED_CONTEXT_FANOUT_MESSAGE = 'loopType must be \"research\" or \"review\"; context fan-out is deprecated. Use @context for one-shot retrieval, /deep:research or /deep:review bounded snapshots for iterative work, or /speckit:plan for implementation planning.';\n339: \n340: function assertActiveFanoutLoopType(loopType) {\n341:   if (!ACTIVE_FANOUT_LOOP_TYPES.has(loopType)) {\n342:     throw inputError(DEPRECATED_CONTEXT_FANOUT_MESSAGE);\n343:   }\n344: }\n345: \n346: function hasNonEmptyArrayField(value) {\n347:   return Array.isArray(value) && value.length > 0;\n348: }\n349: \n350: function collectFlatPoolGuardRejections(fanoutConfig) {\n351:   const rejections = [];\n352:   if (fanoutConfig.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n353:     rejections.push({\n354:       scope: 'fanout',\n355:       label: null,\n356:       field: 'assignment_model',\n357:       message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n358:     });\n359:   }\n360: \n361:   for (const lineage of fanoutConfig.executors) {\n362:     if (lineage.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n363:       rejections.push({\n364:         scope: 'lineage',\n365:         label: lineage.label,\n366:         field: 'assignment_model',\n367:         message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n368:       });\n369:     }\n370: \n371:     const reservedFields = [];\n372:     if (hasNonEmptyArrayField(lineage.depends_on)) {\n373:       reservedFields.push('depends_on');\n374:     }\n375:     if (hasNonEmptyArrayField(lineage.touches)) {\n376:       reservedFields.push('touches');\n377:     }\n378:     if (reservedFields.length > 0) {\n379:       rejections.push({\n380:         scope: 'lineage',\n381:         label: lineage.label,\n382:         field: reservedFields.join(','),\n383:         message: WAVE_ASSIGNMENT_METADATA_REJECTION,\n384:       });\n385:     }\n386:   }\n387: \n388:   return rejections;\n389: }\n390: \n391: /**\n392:  * Force fan-out execution onto the existing flat pool while wave planning is gated.\n393:  *\n394:  * @param {Object} fanoutConfig - Parsed fan-out config.\n395:  * @returns {{ config: Object, rejections: Array<Object> }} Guarded config and rejection records.\n396:  */\n397: function applyFlatPoolAssignmentGuard(fanoutConfig) {\n398:   const rejections = collectFlatPoolGuardRejections(fanoutConfig);\n399:   return {\n400:     config: {\n401:       ...fanoutConfig,\n402:       assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n403:       executors: fanoutConfig.executors.map((lineage) => ({\n404:         ...lineage,\n405:         assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n406:       })),\n407:     },\n408:     rejections,\n409:   };\n410: }\n411: \n412: function logFlatPoolGuardRejections({ rejections, ledgerPath, runId, loopType, specFolder }) {\n413:   if (rejections.length === 0) {\n414:     return;\n415:   }\n416:   const wavePlanner = createWavePlannerInterface();\n417:   for (const rejection of rejections) {\n418:     const labelSuffix = rejection.label ? ` lineage=${rejection.label}` : '';\n419:     process.stderr.write(`[fanout-run] ${rejection.message}${labelSuffix}\\n`);\n420:     appendFanoutStatusLedger(ledgerPath, {\n421:       event: 'assignment_model_rejected',\n422:       severity: 'warning',\n423:       at: new Date().toISOString(),\n424:       run_id: runId,\n425:       loop_type: loopType,\n426:       spec_folder: specFolder,\n427:       planner_status: wavePlanner.status,\n428:       fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n429:       ...rejection,\n430:     });\n431:   }\n432: }\n433: \n434: // Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\n435: const SPECKIT_STATE_ENV_BY_KIND = {\n436:   'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n437:   'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n438: };\n439: \n440: const activeLineageProcesses = new Set();\n441: const WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\n442: const WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\n443: const WAIT_SLEEP_CHUNK_MS = 200;\n444: const OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\n445: const DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n446: \n447: function stopActiveLineageProcesses(signal) {\n448:   for (const child of activeLineageProcesses) {\n449:     terminateLineageProcess(child, signal);\n450:   }\n451: }\n452: \n453: function expandHomeDir(inputPath) {\n454:   if (inputPath === '~') {\n455:     return os.homedir();\n456:   }\n457:   if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n458:     return path.join(os.homedir(), inputPath.slice(2));\n459:   }\n460:   return inputPath;\n461: }\n462: \n463: function isPathInside(childPath, parentPath) {\n464:   const relative = path.relative(parentPath, childPath);\n465:   return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n466: }\n467: \n468: function physicalPathForValidation(targetPath) {\n469:   try {\n470:     return fs.realpathSync.native(targetPath);\n471:   } catch {\n472:     const parentPath = path.dirname(targetPath);\n473:     try {\n474:       return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n475:     } catch {\n476:       return targetPath;\n477:     }\n478:   }\n479: }\n480: \n481: function validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n482:   if (baseArtifactDir.includes('\\0')) {\n483:     throw inputError('baseArtifactDir must not contain null bytes');\n484:   }\n485:   if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n486:     throw inputError('baseArtifactDir must not contain \"..\" path segments');\n487:   }\n488:   const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n489:   const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n490:   const expectedRoot = path.join(resolvedSpecFolder, loopType);\n491:   if (!isPathInside(resolvedBase, expectedRoot)) {\n492:     throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n493:   }\n494:   return baseArtifactDir;\n495: }\n496: \n497: function validateClaudeConfigDir(configDir) {\n498:   if (typeof configDir !== 'string' || configDir.trim() === '') {\n499:     throw inputError('configDir must be a non-empty string when set');\n500:   }\n501:   validateNamespaceValue(configDir, 'configDir', inputError);\n502: \n503:   const expanded = expandHomeDir(configDir);\n504:   const resolved = path.resolve(process.cwd(), expanded);\n505:   const homeDir = path.resolve(os.homedir());\n506:   const cwd = path.resolve(process.cwd());\n507:   const homeRelative = path.relative(homeDir, resolved);\n508:   const cwdRelative = path.relative(cwd, resolved);\n509:   const homeTop = homeRelative.split(path.sep)[0] || '';\n510:   const cwdTop = cwdRelative.split(path.sep)[0] || '';\n511:   const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n512: \n513:   if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n514:     return resolved;\n515:   }\n516:   if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n517:     return resolved;\n518:   }\n519:   throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n520: }\n521: \n522: function terminateLineageProcess(child, signal) {\n523:   if (!child || child.killed) return;\n524:   if (process.platform !== 'win32' && child.pid) {\n525:     try {\n526:       process.kill(-child.pid, signal);\n527:       return;\n528:     } catch (error) {\n529:       if (error && error.code !== 'ESRCH') {\n530:         try {\n531:           child.kill(signal);\n532:         } catch {\n533:           // The process may have already exited between the group and direct kill attempts.\n534:         }\n535:       }\n536:       return;\n537:     }\n538:   }\n539:   try {\n540:     child.kill(signal);\n541:   } catch {\n542:     // The process may have already exited.\n543:   }\n544: }\n545: \n546: function expectedLineageArtifactPaths(loopType, lineageDir) {\n547:   assertActiveFanoutLoopType(loopType);\n548:   if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n549:   return [path.join(lineageDir, 'research.md')];\n550: }\n551: \n552: function hasNonEmptyFile(filePath) {\n553:   try {\n554:     return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n555:   } catch {\n556:     return false;\n557:   }\n558: }\n559: \n560: function findMissingLineageArtifacts(loopType, lineageDir) {\n561:   return expectedLineageArtifactPaths(loopType, lineageDir)\n562:     .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n563: }\n564: \n565: function parseJsonlRecords(filePath) {\n566:   const text = fs.readFileSync(filePath, 'utf8');\n567:   return text\n568:     .split(/\\r?\\n/)\n569:     .filter((line) => line.trim() !== '')\n570:     .map((line) => JSON.parse(line));\n571: }\n572: \n573: function lineageStateLogName(loopType) {\n574:   return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n575: }\n576: \n577: function readLineageStateRecords(loopType, lineageDir) {\n578:   const stateLogName = lineageStateLogName(loopType);\n579:   if (!stateLogName) {\n580:     return { statePath: null, records: [], missing: true, parseError: null };\n581:   }\n582:   const statePath = path.join(lineageDir, stateLogName);\n583:   if (!hasNonEmptyFile(statePath)) {\n584:     return { statePath, records: [], missing: true, parseError: null };\n585:   }\n586:   try {\n587:     return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n588:   } catch (error) {\n589:     return {\n590:       statePath,\n591:       records: [],\n592:       missing: false,\n593:       parseError: error instanceof Error ? error.message : String(error),\n594:     };\n595:   }\n596: }\n597: \n598: // A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n599: // spelling. The iteration-count check above already proves the lineage ran every iteration,\n600: // so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n601: // \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n602: // such as convergence, a manual stop, or an error.\n603: function isMaxIterationsStopReason(stopReason) {\n604:   if (typeof stopReason !== 'string') return false;\n605:   return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n606: }\n607: \n608: function findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n609:   if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n610:   if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n611:     return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n612:   }\n613: \n614:   if (!stateRead || stateRead.missing) {\n615:     return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n616:   }\n617:   if (stateRead.parseError) {\n618:     return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n619:   }\n620: \n621:   const records = stateRead.records;\n622:   const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n623:   const synthesis = [...records]\n624:     .reverse()\n625:     .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n626:   if (!synthesis) {\n627:     return 'missing synthesis_complete event for max-iterations stop-policy validation';\n628:   }\n629: \n630:   const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n631:     ? Number(synthesis.totalIterations)\n632:     : iterationCount;\n633:   if (totalIterations !== lineage.iterations) {\n634:     return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n635:   }\n636:   if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n637:     return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n638:   }\n639:   return null;\n640: }\n641: \n642: function isRecord(value) {\n643:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n644: }\n645: \n646: function normalizeStallWatchdogMs(rawConfig) {\n647:   // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n648:   // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n649:   // because this knob is intentionally outside fanoutConfigSchema. Set 0 to opt out.\n650:   return readRawConfigNumber(rawConfig, [\n651:     'stallWatchdogMs',\n652:     'stall_watchdog_ms',\n653:     'stallWatchdogMillis',\n654:     'stall_watchdog_millis',\n655:   ], 'stallWatchdogMs') ?? 300000;\n656: }\n657: \n658: function normalizeLineageBudgetGuards(rawConfig = {}) {\n659:   return {\n660:     max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n661:       'maxCostUnitsPerLineage',\n662:       'max_cost_units_per_lineage',\n663:       'maxLineageCostUnits',\n664:       'max_lineage_cost_units',\n665:       'maxTokensPerLineage',\n666:       'max_tokens_per_lineage',\n667:       'maxTokenBudget',\n668:       'max_token_budget',\n669:       'maxTokenBudgetPerLineage',\n670:       'max_token_budget_per_lineage',\n671:     ], 'maxCostUnitsPerLineage') ?? 0,\n672:     cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n673:       'costUnitsPerIteration',\n674:       'cost_units_per_iteration',\n675:       'estimatedTokensPerIteration',\n676:       'estimated_tokens_per_iteration',\n677:     ], 'costUnitsPerIteration', 1),\n678:   };\n679: }\n680: \n681: function computeLineageBudgetUpperBound(lineage, guardsInput = {}) {\n682:   const guards = normalizeLineageBudgetGuards(guardsInput);\n683:   const rawIterations = Number(lineage && lineage.iterations);\n684:   const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n685:   return {\n686:     ...guards,\n687:     iterations,\n688:     estimated_cost_units: iterations * guards.cost_units_per_iteration,\n689:   };\n690: }\n691: \n692: function evaluateLineageBudgetCap(input = {}) {\n693:   const upperBound = computeLineageBudgetUpperBound(input.lineage || {}, input.guards || input);\n694:   const exceeded = upperBound.max_cost_units_per_lineage > 0\n695:     && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n696:   return {\n697:     continue_allowed: !exceeded,\n698:     stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n699:     upper_bound: upperBound,\n700:   };\n701: }\n702: \n703: function buildTimestampAnomalyCounts(check) {\n704:   return {\n705:     anomalous: check.anomalous,\n706:     untimestamped: check.untimestamped,\n707:     unparseable: check.unparseable,\n708:     total: check.total,\n709:   };\n710: }\n711: \n712: function buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n713:   return {\n714:     label: lineage.label,\n715:     state_log: statePath,\n716:     window: {\n717:       start_at_iso: check.windowStart,\n718:       end_at_iso: check.windowEnd,\n719:       tolerance_ms: check.toleranceMs,\n720:     },\n721:     counts: buildTimestampAnomalyCounts(check),\n722:     sample: check.sample,\n723:   };\n724: }\n725: \n726: function collectTimestampAnomalies(results) {\n727:   return results\n728:     .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n729:     .map((result) => result.output.timestamp_anomaly);\n730: }\n731: \n732: function normalizeNonNegativeDelayMs(value) {\n733:   if (value === undefined || value === null) return null;\n734:   const n = Number(value);\n735:   if (!Number.isFinite(n) || n < 0) return null;\n736:   return Math.floor(n);\n737: }\n738: \n739: function normalizeWaitDurationMs(value) {\n740:   return normalizeNonNegativeDelayMs(value) ?? 0;\n741: }\n742: \n743: function waitCheckpointPath(baseArtifactDir) {\n744:   return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n745: }\n746: \n747: function atomicWriteJson(filePath, payload) {\n748:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n749:   const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n750:   fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n751:   fs.renameSync(tmpPath, filePath);\n752: }\n753: \n754: function buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n755:   const durationMs = normalizeWaitDurationMs(waitMs);\n756:   const updatedAt = new Date(nowMs).toISOString();\n757:   if (durationMs <= 0) {\n758:     return {\n759:       schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n760:       status: 'idle',\n761:       nextRunAt: null,\n762:       remainingDelayMs: null,\n763:       updatedAt,\n764:       runId,\n765:       loopType,\n766:       specFolder,\n767:     };\n768:   }\n769: \n770:   return {\n771:     schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n772:     status: 'waiting',\n773:     nextRunAt: new Date(nowMs + durationMs).toISOString(),\n774:     remainingDelayMs: durationMs,\n775:     updatedAt,\n776:     runId,\n777:     loopType,\n778:     specFolder,\n779:   };\n780: }\n781: \n782: function normalizeWaitCheckpoint(raw, context) {\n783:   if (!isRecord(raw)) {\n784:     throw inputError('wait checkpoint must be a JSON object');\n785:   }\n786: \n787:   const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n788:   const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n789:   const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n790:   const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n791:     ? raw.nextRunAt\n792:     : null;\n793:   const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n794:   const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n795:   const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n796:   const base = {\n797:     runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n798:     loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n799:     specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n800:   };\n801: \n802:   const checkpoint = waiting\n803:     ? {\n804:         schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n805:         status: 'waiting',\n806:         nextRunAt,\n807:         remainingDelayMs,\n808:         updatedAt: new Date(nowMs).toISOString(),\n809:         ...base,\n810:       }\n811:     : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n812:   const staleWaitingFields = !waiting\n813:     && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n814:   const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n815: \n816:   return {\n817:     checkpoint,\n818:     migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n819:   };\n820: }\n821: \n822: function readWaitCheckpoint(checkpointPath, context) {\n823:   if (!fs.existsSync(checkpointPath)) {\n824:     return { exists: false, checkpoint: null, migrated: false };\n825:   }\n826: \n827:   let raw;\n828:   try {\n829:     raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n830:   } catch (error) {\n831:     throw inputError(\n832:       `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n833:     );\n834:   }\n835: \n836:   const normalized = normalizeWaitCheckpoint(raw, context);\n837:   if (normalized.migrated) {\n838:     atomicWriteJson(checkpointPath, normalized.checkpoint);\n839:   }\n840:   return { exists: true, ...normalized };\n841: }\n842: \n843: function sleepWaitChunk(ms) {\n844:   return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n845: }\n846: \n847: async function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n848:   const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n849:   let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n850: \n851:   while (remainingDelayMs > 0) {\n852:     atomicWriteJson(checkpointPath, {\n853:       ...checkpoint,\n854:       remainingDelayMs,\n855:       updatedAt: new Date().toISOString(),\n856:     });\n857:     await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n858:     remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n859:   }\n860: \n861:   atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n862: }\n863: \n864: async function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n865:   const context = { runId, loopType, specFolder, nowMs: Date.now() };\n866:   const loaded = readWaitCheckpoint(checkpointPath, context);\n867:   if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n868:     return { didWait: false, migrated: loaded.migrated };\n869:   }\n870: \n871:   appendFanoutStatusLedger(ledgerPath, {\n872:     event: 'resume_waiting',\n873:     at: new Date().toISOString(),\n874:     run_id: runId,\n875:     loop_type: loopType,\n876:     spec_folder: specFolder,\n877:     nextRunAt: loaded.checkpoint.nextRunAt,\n878:     remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n879:   });\n880: \n881:   await waitUntilCheckpointExpires({\n882:     checkpointPath,\n883:     checkpoint: loaded.checkpoint,\n884:     context: { runId, loopType, specFolder },\n885:   });\n886: \n887:   appendFanoutStatusLedger(ledgerPath, {\n888:     event: 'resume_waiting_complete',\n889:     at: new Date().toISOString(),\n890:     run_id: runId,\n891:     loop_type: loopType,\n892:     spec_folder: specFolder,\n893:   });\n894: \n895:   return { didWait: true, migrated: loaded.migrated };\n896: }\n897: \n898: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n899:   const durationMs = normalizeWaitDurationMs(waitMs);\n900:   if (durationMs <= 0) {\n901:     return { didWait: false };\n902:   }\n903: \n904:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n905:   atomicWriteJson(checkpointPath, checkpoint);\n906:   appendFanoutStatusLedger(ledgerPath, {\n907:     event: 'wait_checkpoint_persisted',\n908:     at: checkpoint.updatedAt,\n909:     run_id: runId,\n910:     loop_type: loopType,\n911:     spec_folder: specFolder,\n912:     nextRunAt: checkpoint.nextRunAt,\n913:     remainingDelayMs: checkpoint.remainingDelayMs,\n914:   });\n915: \n916:   await waitUntilCheckpointExpires({\n917:     checkpointPath,\n918:     checkpoint,\n919:     context: { runId, loopType, specFolder },\n920:   });\n921: \n922:   appendFanoutStatusLedger(ledgerPath, {\n923:     event: 'wait_checkpoint_cleared',\n924:     at: new Date().toISOString(),\n925:     run_id: runId,\n926:     loop_type: loopType,\n927:     spec_folder: specFolder,\n928:   });\n929: \n930:   return { didWait: true };\n931: }\n932: \n933: /**\n934:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n935:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n936:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n937:  */\n938: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n939:   assertActiveFanoutLoopType(loopType);\n940:   const skillFile =\n941:     loopType === 'review'\n942:       ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n943:       : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n944:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n945:   const detachedIntro = lineage.kind === 'cli-opencode'\n946:     ? [\n947:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n948:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n949:         ``,\n950:       ]\n951:     : lineage.kind === 'native'\n952:       ? [\n953:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n954:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n955:           ``,\n956:         ]\n957:       : [];\n958:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n959:   const stopPolicy = options.stopPolicy || 'convergence';\n960:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n961:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n962:     : hasIterationCap\n963:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n964:       : 'to legal convergence';\n965:   const params = [\n966:     `  spec_folder: ${specFolder}`,\n967:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n968:     `  session_id: ${sessionId}`,\n969:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n970:     `  loop_type: ${loopType}`,\n971:     `  config.stopPolicy: ${stopPolicy}`,\n972:   ];\n973:   if (researchTopic) {\n974:     // A research lineage's phase_init binds research_topic from this line. Without it a\n975:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n976:     // Review loops scope by spec_folder and intentionally pass no topic.\n977:     params.push(`  research_topic: ${researchTopic}`);\n978:   }\n979:   if (hasIterationCap) {\n980:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n981:   }\n982:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n983:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n984:   }\n985:   // Review lineages scope by spec_folder but the auto-workflow preflight\n986:   // still requires the same review setup bindings the native command path pre-binds.\n987:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n988:   // different setup contract than native lineages.\n989:   const setupBindings =\n990:     loopType === 'review'\n991:       ? [\n992:           ``,\n993:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n994:           `review_target: ${specFolder}`,\n995:           `review_target_type: spec-folder`,\n996:           `review_dimensions: all`,\n997:           `spec_folder: ${specFolder}`,\n998:           `execution_mode: AUTONOMOUS`,\n999:           `lineage_mode: auto`,\n1000:           ``,\n1001:         ]\n1002:       : [];\n1003:   return [\n1004:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1005:     ...detachedIntro,\n1006:     ``,\n1007:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1008:     ...params,\n1009:     ...setupBindings,\n1010:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1011:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1012:     `command; bind artifact_dir directly to the override value.`,\n1013:     ``,\n1014:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1015:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1016:     ``,\n1017:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1018:   ].join('\\n');\n1019: }\n1020: \n1021: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1022:   assertActiveFanoutLoopType(loopType);\n1023:   const maxIterations = lineage.iterations || 12;\n1024:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1025:   const stopPolicy = options.stopPolicy || 'convergence';\n1026:   const sessionId = options.sessionId || '';\n1027:   const args = [\n1028:     ':auto',\n1029:     JSON.stringify(specFolder),\n1030:     `--spec-folder=${specFolder}`,\n1031:     `--max-iterations=${maxIterations}`,\n1032:     `--convergence=${convergenceThreshold}`,\n1033:     `--stop-policy=${stopPolicy}`,\n1034:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1035:     '--lineage-mode=auto',\n1036:   ];\n1037:   if (loopType === 'research' && options.researchTopic) {\n1038:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1039:   }\n1040: \n1041:   return [\n1042:     args.join(' '),\n1043:     '',\n1044:     'PRE-BOUND SETUP ANSWERS:',\n1045:     `review_target: ${specFolder}`,\n1046:     'review_target_type: spec-folder',\n1047:     'review_dimensions: all',\n1048:     `spec_folder: ${specFolder}`,\n1049:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1050:     'execution_mode: AUTONOMOUS',\n1051:     'lineage_mode: auto',\n1052:     `maxIterations: ${maxIterations}`,\n1053:     `convergenceThreshold: ${convergenceThreshold}`,\n1054:     `stop_policy: ${stopPolicy}`,\n1055:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1056:   ].join('\\n');\n1057: }\n1058: \n1059: /**\n1060:  * Compute a generous timeout for a full lineage loop run.\n1061:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1062:  * We double it for safety and cap at 4 hours.\n1063:  */\n1064: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1065:   const iters = lineage.iterations || 12;\n1066:   const perIterSecs = lineage.timeoutSeconds || 900;\n1067:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n1068:     ? ceilingHoursOverride * 60 * 60 * 1000\n1069:     : 4 * 60 * 60 * 1000;\n1070:   return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n1071: }\n1072: \n1073: function normalizeProgressHeartbeatMs(seconds) {\n1074:   const value = Number(seconds);\n1075:   if (!Number.isFinite(value) || value <= 0) return 0;\n1076:   return Math.max(1, Math.floor(value * 1000));\n1077: }\n1078: \n1079: function normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n1080:   const explicit = readRawConfigNumber(rawConfig, [\n1081:     'postExitGraceMs',\n1082:     'post_exit_grace_ms',\n1083:     'postSubprocessExitGraceMs',\n1084:     'post_subprocess_exit_grace_ms',\n1085:     'orchestratorPostExitGraceMs',\n1086:     'orchestrator_post_exit_grace_ms',\n1087:   ], 'postExitGraceMs');\n1088:   if (explicit !== null) return explicit;\n1089: \n1090:   const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n1091:     ? progressHeartbeatMs * 2\n1092:     : 0;\n1093:   return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n1094: }\n1095: \n1096: function slotDurationMsFromHrtime(hrStart) {\n1097:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n1098:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n1099: }\n1100: \n1101: function computeSkippedCount(slotDurationMs, intervalMs) {\n1102:   const elapsed = Number(slotDurationMs);\n1103:   const interval = Number(intervalMs);\n1104:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n1105:     return 0;\n1106:   }\n1107:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n1108: }\n1109: \n1110: function buildSlotAccounting(hrStart, intervalMs) {\n1111:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n1112:   return {\n1113:     slotDurationMs,\n1114:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n1115:   };\n1116: }\n1117: \n1118: function decorateSlotAccountingEvent(event, accountingByLabel) {\n1119:   if (!event || typeof event.label !== 'string') return event;\n1120:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n1121: \n1122:   const accounting = accountingByLabel.get(event.label);\n1123:   if (!accounting) return event;\n1124:   return {\n1125:     ...event,\n1126:     skippedCount: accounting.skippedCount,\n1127:     slotDurationMs: accounting.slotDurationMs,\n1128:   };\n1129: }\n1130: \n1131: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n1132:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n1133:     return () => {};\n1134:   }\n1135:   const startedAtMs = Date.now();\n1136:   const timer = setInterval(() => {\n1137:     appendFanoutStatusLedger(ledgerPath, {\n1138:       event: 'progress',\n1139:       label,\n1140:       at: new Date().toISOString(),\n1141:       duration_ms: Math.max(0, Date.now() - startedAtMs),\n1142:         gauges: getGauges(),\n1143:       });\n1144:       if (typeof onProgress === 'function') onProgress();\n1145:     }, cadenceMs);\n1146:   timer.unref?.();\n1147:   return () => clearInterval(timer);\n1148: }\n1149: \n1150: function startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n1151:   if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n1152:     return () => {};\n1153:   }\n1154: \n1155:   let timer = null;\n1156:   let fired = false;\n1157:   const schedule = () => {\n1158:     if (fired) return;\n1159:     const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1160:     const delayMs = Math.max(1, thresholdMs - quietMs);\n1161:     timer = setTimeout(() => {\n1162:       timer = null;\n1163:       const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n1164:       if (latestQuietMs >= thresholdMs) {\n1165:         fired = true;\n1166:         appendFanoutStatusLedger(ledgerPath, {\n1167:           event: 'stall_detected',\n1168:           label,\n1169:           at: new Date().toISOString(),\n1170:           severity: 'warning',\n1171:           metric: 'time_since_last_lineage_event',\n1172:           stall_watchdog_ms: thresholdMs,\n1173:           quiet_ms: Math.floor(latestQuietMs),\n1174:           gauges: getGauges(),\n1175:         });\n1176:         return;\n1177:       }\n1178:       schedule();\n1179:     }, delayMs);\n1180:     timer.unref?.();\n1181:   };\n1182: \n1183:   schedule();\n1184:   return () => {\n1185:     fired = true;\n1186:     if (timer) clearTimeout(timer);\n1187:   };\n1188: }\n1189: \n1190: /**\n1191:  * Run a lineage subprocess without blocking the Node event loop.\n1192:  *\n1193:  * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n1194:  * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n1195:  * thread until each child exited, serializing every lineage regardless of the\n1196:  * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n1197:  *\n1198:  * On timeout the child is killed with SIGTERM and result.signal is set to\n1199:  * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n1200:  *\n1201:  * @param {string} command - Executable to run.\n1202:  * @param {string[]} cmdArgs - Arguments for the executable.\n1203:  * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n1204:  * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n1205:  */\n1206: function runLineageProcess(command, cmdArgs, opts) {\n1207:   const { cwd, env, timeoutMs, maxBuffer } = opts;\n1208:   const hasInput = typeof opts.input === 'string';\n1209: \n1210:   return new Promise((resolvePromise) => {\n1211:     let child;\n1212:     try {\n1213:       child = spawn(command, cmdArgs, {\n1214:         cwd,\n1215:         env,\n1216:         stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n1217:         detached: process.platform !== 'win32',\n1218:       });\n1219:     } catch (error) {\n1220:       resolvePromise({ status: null, signal: null, stdout: '', error });\n1221:       return;\n1222:     }\n1223:     activeLineageProcesses.add(child);\n1224:     if (typeof opts.onSpawn === 'function') {\n1225:       opts.onSpawn({ pid: child.pid });\n1226:     }\n1227: \n1228:     let stdout = '';\n1229:     let stdoutBytes = 0;\n1230:     let truncated = false;\n1231:     let timedOut = false;\n1232:     let settled = false;\n1233:     let spawnError;\n1234: \n1235:     const timer = setTimeout(() => {\n1236:       timedOut = true;\n1237:       terminateLineageProcess(child, 'SIGTERM');\n1238:     }, timeoutMs);\n1239:     timer.unref?.();\n1240: \n1241:     const abortHandler = () => {\n1242:       terminateLineageProcess(child, 'SIGTERM');\n1243:     };\n1244:     if (opts.abortSignal) {\n1245:       if (opts.abortSignal.aborted) {\n1246:         abortHandler();\n1247:       } else {\n1248:         opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n1249:       }\n1250:     }\n1251: \n1252:     child.stdout?.setEncoding('utf8');\n1253:     child.stdout?.on('data', (chunk) => {\n1254:       if (truncated) return;\n1255:       stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n1256:       if (stdoutBytes > maxBuffer) {\n1257:         truncated = true;\n1258:         terminateLineageProcess(child, 'SIGTERM');\n1259:         return;\n1260:       }\n1261:       stdout += chunk;\n1262:     });\n1263:     // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n1264:     child.stderr?.resume();\n1265: \n1266:     child.on('error', (error) => {\n1267:       spawnError = error;\n1268:     });\n1269: \n1270:     child.on('close', (code, signal) => {\n1271:       if (settled) return;\n1272:       settled = true;\n1273:       activeLineageProcesses.delete(child);\n1274:       clearTimeout(timer);\n1275:       opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n1276:       const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n1277:       if (typeof opts.onExit === 'function') {\n1278:         opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n1279:       }\n1280:       resolvePromise({\n1281:         status: timedOut ? null : code,\n1282:         signal: effectiveSignal,\n1283:         stdout,\n1284:         ...(spawnError ? { error: spawnError } : {}),\n1285:       });\n1286:     });\n1287: \n1288:     if (hasInput) {\n1289:       child.stdin?.on('error', () => {});\n1290:       child.stdin?.end(opts.input);\n1291:     }\n1292:   });\n1293: }\n1294: \n1295: /**\n1296:  * Build the subprocess command for a fan-out lineage.\n1297:  * Returns { command, args, input?, env } where input is stdin content when applicable.\n1298:  */\n1299: function buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n1300:   const kind = lineage.kind;\n1301: \n1302:   if (kind === 'cli-claude-code') {\n1303:     const args = [\n1304:       '-p',\n1305:       prompt,\n1306:       '--model',\n1307:       lineage.model || 'claude-opus-4-8',\n1308:       '--permission-mode',\n1309:       resolvedPermission,\n1310:       '--output-format',\n1311:       'text',\n1312:     ];\n1313:     if (lineage.reasoningEffort) {\n1314:       args.push('--effort', lineage.reasoningEffort);\n1315:     }\n1316:     return { command: 'claude', args };\n1317:   }\n1318: \n1319:   if (kind === 'native') {\n1320:     // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n1321:     // For review runs this is the real deep/review command surface with a lineage\n1322:     // artifact override, so the command YAML owns init, loop, and synthesis.\n1323:     const args = [\n1324:       'run',\n1325:       '--format',\n1326:       'json',\n1327:       '--dangerously-skip-permissions',\n1328:       '--dir',\n1329:       process.cwd(),\n1330:       '--command',\n1331:       `deep/${options.loopType || 'review'}`,\n1332:     ];\n1333:     args.push(buildNativeCommandInput(\n1334:       options.loopType || 'review',\n1335:       options.specFolder || '',\n1336:       options.lineageDir || '',\n1337:       lineage,\n1338:       options,\n1339:     ));\n1340:     return { command: 'opencode', args, input: '' };\n1341:   }\n1342: \n1343:   if (kind === 'cli-opencode') {\n1344:     // No --agent: current opencode treats `general` as a subagent and rejects it\n1345:     // on a top-level `run`. The default agent runs when none is named, and a\n1346:     // specific agent profile can be requested in the prompt body instead.\n1347:     const args = [\n1348:       'run',\n1349:       '--model',\n1350:       lineage.model || 'anthropic/claude-opus-4-8',\n1351:       '--format',\n1352:       'json',\n1353:       '--pure',\n1354:       '--dir',\n1355:       process.cwd(),\n1356:     ];\n1357:     // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n1358:     // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n1359:     // --dangerously-skip-permissions so their writes are subject to the CLI permission\n1360:     // boundary. opencode has no path-scoped write flag, so a workspace-write review\n1361:     // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n1362:     // must now opt into full bypass rather than getting it silently by default.\n1363:     const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n1364:     if (useDangerousBypass) {\n1365:       args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n1366:       process.stderr.write(\n1367:         `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n1368:           + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n1369:       );\n1370:     }\n1371:     if (lineage.reasoningEffort) {\n1372:       args.push('--variant', lineage.reasoningEffort);\n1373:     }\n1374:     args.push(prompt);\n1375:     return { command: 'opencode', args, input: '' };\n1376:   }\n1377: \n1378:   throw inputError(`Unknown fan-out executor kind: ${kind}`);\n1379: }\n1380: \n1381: // ─────────────────────────────────────────────────────────────────────────────\n1382: // 4. CORE LOGIC\n1383: // ─────────────────────────────────────────────────────────────────────────────\n1384: \n1385: async function main() {\n1386:   const args = parseArgs();\n1387:   const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n1388:   const loopType = ensureString(args, 'loopType');\n1389:   assertActiveFanoutLoopType(loopType);\n1390:   // Optional shared research question, threaded into each lineage prompt so a research\n1391:   // fan-out can bind research_topic. Absent for review, which scopes by folder.\n1392:   const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n1393:     ? args.researchTopic.trim()\n1394:     : null;\n1395:   const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n1396:   const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n1397:   const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n1398:   const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n1399:   const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n1400: \n1401:   const {\n1402:     parseFanoutConfig,\n1403:     expandLineages,\n1404:     resolveSandboxMode,\n1405:     resolveClaudePermissionMode,\n1406:   } = await import('../lib/deep-loop/executor-config.ts');\n1407:   const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n1408:   const {\n1409:     DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n1410:     checkLineageTimestampWindow,\n1411:   } = await import('../lib/deep-loop/lineage-timestamp-window.ts');\n1412: \n1413:   maybeThrowTestFault();\n1414: \n1415:   let rawConfig;\n1416:   try {\n1417:     rawConfig = JSON.parse(fanoutConfigJson);\n1418:   } catch {\n1419:     throw inputError('fanoutConfigJson is not valid JSON');\n1420:   }\n1421: \n1422:   const lineagesDir = path.join(baseArtifactDir, 'lineages');\n1423:   const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n1424:   const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n1425:   const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n1426:   const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n1427:   const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n1428:   const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n1429:   const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n1430:   const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n1431:   const fanoutConfig = guardedAssignment.config;\n1432:   const allLineages = expandLineages(fanoutConfig);\n\n(Output capped at 50 KB. Showing lines 1-1432. Use offset=1433 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n// ║         --base-artifact-dir).                                            ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out CLI Lineage Pool Runner                      ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--spec-folder, --loop-type, --fanout-config-json,      ║\n// ║         --base-artifact-dir).                                            ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=all ok, 1=script error, 2=some failed, 3=all failed.          ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst os = require('node:os');\nconst path = require('node:path');\nconst { spawn } = require('node:child_process');\n\nconst {\n  classifyExitCode,\n  maybeThrowTestFault,\n  validateNamespaceValue,\n} = require('./lib/cli-guards.cjs');\n\nconst {\n  runCappedPool,\n  appendStatusLedger,\n  markOrphanedLineages,\n  readRetryCountsFromLedger,\n  createWavePlannerInterface,\n  writeOrchestrationSummary,\n} = require('./fanout-pool.cjs');\n\nconst {\n  runSalvageSweep,\n  extractTextFromOpencodeJson,\n} = require('./fanout-salvage.cjs');\n\nconst {\n  appendObservabilityEvent,\n} = require('../lib/deep-loop/observability-events.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\nconst isTsxLoaded = process.env.DEEP_LOOP_TSX_LOADED === '1';\n\nfunction runTsxBootstrap() {\n  const child = spawn(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      stdio: [process.stdin.isTTY ? 'ignore' : 'pipe', 'pipe', 'pipe'],\n    },\n  );\n\n  if (!process.stdin.isTTY && child.stdin) {\n    child.stdin.on('error', () => {});\n    process.stdin.pipe(child.stdin);\n  }\n\n  child.stdout?.pipe(process.stdout);\n  child.stderr?.pipe(process.stderr);\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      child.kill(signal);\n    });\n  }\n\n  child.on('close', (status, signal) => {\n    if (status !== null) {\n      process.exit(status);\n    }\n    process.exit(signal === 'SIGINT' ? 130 : signal === 'SIGTERM' ? 143 : 1);\n  });\n}\n\nif (require.main === module && !isTsxLoaded) {\n  runTsxBootstrap();\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction parseArgs(argv = process.argv.slice(2)) {\n  const args = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      args[key] = true;\n    } else {\n      args[key] = next;\n      i += 1;\n    }\n  }\n  return args;\n}\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction ensureString(args, key) {\n  if (!args[key] || typeof args[key] !== 'string') {\n    throw inputError(`${key} is required`);\n  }\n  return args[key];\n}\n\nfunction parseOptionalNumber(args, key) {\n  const raw = args[key];\n  if (raw === undefined || raw === false || raw === null || raw === '') {\n    return null;\n  }\n  if (raw === true || typeof raw !== 'string') {\n    throw inputError(`${key} must be a number`);\n  }\n  const value = Number(raw);\n  if (!Number.isFinite(value) || value < 0) {\n    throw inputError(`${key} must be a non-negative number`);\n  }\n  return value;\n}\n\nfunction readRawConfigNumber(rawConfig, names, fieldName) {\n  if (!isRecord(rawConfig)) return null;\n  for (const name of names) {\n    if (!Object.prototype.hasOwnProperty.call(rawConfig, name)) continue;\n    const raw = rawConfig[name];\n    if (raw === undefined || raw === null || raw === '') return null;\n    if (raw === true || raw === false) {\n      throw inputError(`${fieldName} must be a non-negative number`);\n    }\n    const value = Number(raw);\n    if (!Number.isFinite(value) || value < 0) {\n      throw inputError(`${fieldName} must be a non-negative number`);\n    }\n    return Math.floor(value);\n  }\n  return null;\n}\n\nfunction readPositiveRawConfigNumber(rawConfig, names, fieldName, fallback) {\n  const value = readRawConfigNumber(rawConfig, names, fieldName);\n  if (value === null) return fallback;\n  if (value <= 0) {\n    throw inputError(`${fieldName} must be greater than 0`);\n  }\n  return value;\n}\n\nfunction rawConfigWithCliBudgetOverrides(rawConfig, args) {\n  const merged = { ...(isRecord(rawConfig) ? rawConfig : {}) };\n  const mappings = [\n    ['stallWatchdogMs', 'stallWatchdogMs'],\n    ['maxCostUnitsPerLineage', 'maxCostUnitsPerLineage'],\n    ['maxTokensPerLineage', 'maxTokensPerLineage'],\n    ['maxTokenBudget', 'maxTokenBudget'],\n    ['maxTokenBudgetPerLineage', 'maxTokenBudgetPerLineage'],\n    ['costUnitsPerIteration', 'costUnitsPerIteration'],\n    ['estimatedTokensPerIteration', 'estimatedTokensPerIteration'],\n  ];\n  for (const [targetKey, argKey] of mappings) {\n    if (Object.prototype.hasOwnProperty.call(args, argKey)) {\n      merged[targetKey] = args[argKey];\n    }\n  }\n  return merged;\n}\n\nfunction normalizeStopPolicy(raw) {\n  if (raw === undefined || raw === false || raw === null || raw === '') {\n    return 'convergence';\n  }\n  if (raw === true || typeof raw !== 'string') {\n    throw inputError('stopPolicy must be convergence or max-iterations');\n  }\n  if (raw !== 'convergence' && raw !== 'max-iterations') {\n    throw inputError('stopPolicy must be convergence or max-iterations');\n  }\n  return raw;\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\nfunction signalExitCode(signal) {\n  return signal === 'SIGINT' ? 130 : 143;\n}\n\nlet fanoutSignalHandlersInstalled = false;\n\nfunction installFanoutSignalHandlers(onStop) {\n  if (fanoutSignalHandlersInstalled) return;\n  fanoutSignalHandlersInstalled = true;\n\n  for (const signal of ['SIGINT', 'SIGTERM']) {\n    process.once(signal, () => {\n      try {\n        onStop(signal);\n      } finally {\n        process.exit(signalExitCode(signal));\n      }\n    });\n  }\n}\n\nfunction updateLineageSnapshot(snapshots, event) {\n  if (!event || typeof event.label !== 'string') return;\n  const existing = snapshots.get(event.label) || { label: event.label };\n\n  if (event.event === 'started') {\n    snapshots.set(event.label, { ...existing, status: 'running', started_at_iso: event.at });\n    return;\n  }\n  if (event.event === 'completed') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: 'fulfilled',\n      completed_at_iso: event.at,\n      duration_ms: event.duration_ms,\n    });\n    return;\n  }\n  if (event.event === 'failed') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: event.terminal === false ? 'retrying' : 'rejected',\n      completed_at_iso: event.at,\n      duration_ms: event.duration_ms,\n      error: event.error,\n    });\n    return;\n  }\n  if (event.event === 'retry_scheduled' || event.event === 'orphan_requeued') {\n    snapshots.set(event.label, { ...existing, status: 'requeued', updated_at_iso: event.at });\n    return;\n  }\n  if (event.event === 'progress') {\n    snapshots.set(event.label, {\n      ...existing,\n      status: 'running',\n      updated_at_iso: event.at,\n      duration_ms: event.duration_ms,\n    });\n  }\n}\n\nfunction buildLineageSnapshots(lineages, snapshots) {\n  return lineages.map((lineage) => snapshots.get(lineage.label) || { label: lineage.label, status: 'pending' });\n}\n\nfunction summarizeSnapshots(lineages, snapshots) {\n  const results = buildLineageSnapshots(lineages, snapshots);\n  const succeeded = results.filter((result) => result.status === 'fulfilled').length;\n  const failed = results.filter((result) => result.status === 'rejected').length;\n  return {\n    results,\n    summary: {\n      total: lineages.length,\n      succeeded,\n      failed,\n      all_failed: lineages.length > 0 && failed === lineages.length,\n    },\n  };\n}\n\nfunction observabilityPathForLedger(ledgerPath) {\n  return path.join(path.dirname(ledgerPath), OBSERVABILITY_EVENTS_FILENAME);\n}\n\nfunction statusForLedgerEvent(entry) {\n  if (entry && typeof entry.status === 'string' && entry.status.trim() !== '') {\n    return entry.status;\n  }\n  if (!entry || typeof entry.event !== 'string') return 'unknown';\n  if (entry.event === 'started' || entry.event === 'progress' || entry.event === 'resume_waiting') return 'running';\n  if (entry.event === 'completed' || entry.event === 'resume_waiting_complete') return 'completed';\n  if (entry.event === 'failed') return entry.terminal === false ? 'retrying' : 'failed';\n  if (entry.event === 'stopped') return 'stopped';\n  if (entry.event === 'retry_scheduled' || entry.event === 'orphan_requeued') return 'retrying';\n  // Lag-ceiling signals from the pool: a stall warning while work remains pending, or a\n  // forced abort of the stalled attempt. Map both to typed statuses instead of 'unknown'.\n  if (entry.event === 'lag_ceiling_exceeded') return entry.action === 'abort' ? 'failed' : 'warning';\n  if (entry.event === 'lag_ceiling_abort') return 'failed';\n  if (entry.event === 'stall_detected') return 'warning';\n  if (entry.event === 'budget_cap_exceeded') return 'failed';\n  return 'unknown';\n}\n\nfunction appendFanoutStatusLedger(ledgerPath, entry) {\n  appendStatusLedger(ledgerPath, entry);\n  try {\n    appendObservabilityEvent(observabilityPathForLedger(ledgerPath), entry, {\n      producer: 'fanout-run',\n      stream: 'orchestration-status',\n      subject: {\n        run_id: entry.run_id ?? null,\n        label: entry.label ?? null,\n        loop_type: entry.loop_type ?? null,\n        spec_folder: entry.spec_folder ?? null,\n      },\n      event: entry.event,\n      status: statusForLedgerEvent(entry),\n    });\n  } catch {\n    // Observability must not make the primary orchestration ledger fail.\n  }\n}\n\nconst FLAT_POOL_ASSIGNMENT_MODEL = 'flat_pool';\nconst WAVE_ASSIGNMENT_MODEL = 'wave';\nconst WAVE_ASSIGNMENT_MODEL_REJECTION = 'REJECTED: wave assignment_model requires conflict-safety substrate';\nconst WAVE_ASSIGNMENT_METADATA_REJECTION = 'REJECTED: wave assignment metadata requires conflict-safety substrate';\nconst STATE_LOG_BY_LOOP_TYPE = {\n  research: 'deep-research-state.jsonl',\n  review: 'deep-review-state.jsonl',\n};\nconst ACTIVE_FANOUT_LOOP_TYPES = new Set(['research', 'review']);\nconst DEPRECATED_CONTEXT_FANOUT_MESSAGE = 'loopType must be \"research\" or \"review\"; context fan-out is deprecated. Use @context for one-shot retrieval, /deep:research or /deep:review bounded snapshots for iterative work, or /speckit:plan for implementation planning.';\n\nfunction assertActiveFanoutLoopType(loopType) {\n  if (!ACTIVE_FANOUT_LOOP_TYPES.has(loopType)) {\n    throw inputError(DEPRECATED_CONTEXT_FANOUT_MESSAGE);\n  }\n}\n\nfunction hasNonEmptyArrayField(value) {\n  return Array.isArray(value) && value.length > 0;\n}\n\nfunction collectFlatPoolGuardRejections(fanoutConfig) {\n  const rejections = [];\n  if (fanoutConfig.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n    rejections.push({\n      scope: 'fanout',\n      label: null,\n      field: 'assignment_model',\n      message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n    });\n  }\n\n  for (const lineage of fanoutConfig.executors) {\n    if (lineage.assignment_model === WAVE_ASSIGNMENT_MODEL) {\n      rejections.push({\n        scope: 'lineage',\n        label: lineage.label,\n        field: 'assignment_model',\n        message: WAVE_ASSIGNMENT_MODEL_REJECTION,\n      });\n    }\n\n    const reservedFields = [];\n    if (hasNonEmptyArrayField(lineage.depends_on)) {\n      reservedFields.push('depends_on');\n    }\n    if (hasNonEmptyArrayField(lineage.touches)) {\n      reservedFields.push('touches');\n    }\n    if (reservedFields.length > 0) {\n      rejections.push({\n        scope: 'lineage',\n        label: lineage.label,\n        field: reservedFields.join(','),\n        message: WAVE_ASSIGNMENT_METADATA_REJECTION,\n      });\n    }\n  }\n\n  return rejections;\n}\n\n/**\n * Force fan-out execution onto the existing flat pool while wave planning is gated.\n *\n * @param {Object} fanoutConfig - Parsed fan-out config.\n * @returns {{ config: Object, rejections: Array<Object> }} Guarded config and rejection records.\n */\nfunction applyFlatPoolAssignmentGuard(fanoutConfig) {\n  const rejections = collectFlatPoolGuardRejections(fanoutConfig);\n  return {\n    config: {\n      ...fanoutConfig,\n      assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      executors: fanoutConfig.executors.map((lineage) => ({\n        ...lineage,\n        assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      })),\n    },\n    rejections,\n  };\n}\n\nfunction logFlatPoolGuardRejections({ rejections, ledgerPath, runId, loopType, specFolder }) {\n  if (rejections.length === 0) {\n    return;\n  }\n  const wavePlanner = createWavePlannerInterface();\n  for (const rejection of rejections) {\n    const labelSuffix = rejection.label ? ` lineage=${rejection.label}` : '';\n    process.stderr.write(`[fanout-run] ${rejection.message}${labelSuffix}\\n`);\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'assignment_model_rejected',\n      severity: 'warning',\n      at: new Date().toISOString(),\n      run_id: runId,\n      loop_type: loopType,\n      spec_folder: specFolder,\n      planner_status: wavePlanner.status,\n      fallback_assignment_model: FLAT_POOL_ASSIGNMENT_MODEL,\n      ...rejection,\n    });\n  }\n}\n\n// Per-kind first state-dir env var (used for lockfile isolation across same-kind replicas).\nconst SPECKIT_STATE_ENV_BY_KIND = {\n  'cli-claude-code': 'SPECKIT_CLAUDE_CODE_STATE_DIR',\n  'cli-opencode': 'SPECKIT_OPENCODE_STATE_DIR',\n};\n\nconst activeLineageProcesses = new Set();\nconst WAIT_CHECKPOINT_FILENAME = 'orchestration-wait-checkpoint.json';\nconst WAIT_CHECKPOINT_SCHEMA_VERSION = 1;\nconst WAIT_SLEEP_CHUNK_MS = 200;\nconst OBSERVABILITY_EVENTS_FILENAME = 'observability-events.jsonl';\nconst DEFAULT_POST_EXIT_GRACE_MS = 5 * 60 * 1000;\n\nfunction stopActiveLineageProcesses(signal) {\n  for (const child of activeLineageProcesses) {\n    terminateLineageProcess(child, signal);\n  }\n}\n\nfunction expandHomeDir(inputPath) {\n  if (inputPath === '~') {\n    return os.homedir();\n  }\n  if (typeof inputPath === 'string' && inputPath.startsWith('~/')) {\n    return path.join(os.homedir(), inputPath.slice(2));\n  }\n  return inputPath;\n}\n\nfunction isPathInside(childPath, parentPath) {\n  const relative = path.relative(parentPath, childPath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction physicalPathForValidation(targetPath) {\n  try {\n    return fs.realpathSync.native(targetPath);\n  } catch {\n    const parentPath = path.dirname(targetPath);\n    try {\n      return path.join(fs.realpathSync.native(parentPath), path.basename(targetPath));\n    } catch {\n      return targetPath;\n    }\n  }\n}\n\nfunction validateBaseArtifactDir(baseArtifactDir, specFolder, loopType) {\n  if (baseArtifactDir.includes('\\0')) {\n    throw inputError('baseArtifactDir must not contain null bytes');\n  }\n  if (baseArtifactDir.split(/[\\\\/]+/).includes('..')) {\n    throw inputError('baseArtifactDir must not contain \"..\" path segments');\n  }\n  const resolvedBase = physicalPathForValidation(path.resolve(process.cwd(), baseArtifactDir));\n  const resolvedSpecFolder = physicalPathForValidation(path.resolve(process.cwd(), specFolder));\n  const expectedRoot = path.join(resolvedSpecFolder, loopType);\n  if (!isPathInside(resolvedBase, expectedRoot)) {\n    throw inputError(`baseArtifactDir must resolve inside the spec folder's ${loopType} artifact tree`);\n  }\n  return baseArtifactDir;\n}\n\nfunction validateClaudeConfigDir(configDir) {\n  if (typeof configDir !== 'string' || configDir.trim() === '') {\n    throw inputError('configDir must be a non-empty string when set');\n  }\n  validateNamespaceValue(configDir, 'configDir', inputError);\n\n  const expanded = expandHomeDir(configDir);\n  const resolved = path.resolve(process.cwd(), expanded);\n  const homeDir = path.resolve(os.homedir());\n  const cwd = path.resolve(process.cwd());\n  const homeRelative = path.relative(homeDir, resolved);\n  const cwdRelative = path.relative(cwd, resolved);\n  const homeTop = homeRelative.split(path.sep)[0] || '';\n  const cwdTop = cwdRelative.split(path.sep)[0] || '';\n  const allowedConfigRoot = (segment) => segment === '.claude' || segment.startsWith('.claude-');\n\n  if (isPathInside(resolved, homeDir) && allowedConfigRoot(homeTop)) {\n    return resolved;\n  }\n  if (isPathInside(resolved, cwd) && allowedConfigRoot(cwdTop)) {\n    return resolved;\n  }\n  throw inputError('configDir must resolve under ~/.claude*, or a repo-local .claude* directory');\n}\n\nfunction terminateLineageProcess(child, signal) {\n  if (!child || child.killed) return;\n  if (process.platform !== 'win32' && child.pid) {\n    try {\n      process.kill(-child.pid, signal);\n      return;\n    } catch (error) {\n      if (error && error.code !== 'ESRCH') {\n        try {\n          child.kill(signal);\n        } catch {\n          // The process may have already exited between the group and direct kill attempts.\n        }\n      }\n      return;\n    }\n  }\n  try {\n    child.kill(signal);\n  } catch {\n    // The process may have already exited.\n  }\n}\n\nfunction expectedLineageArtifactPaths(loopType, lineageDir) {\n  assertActiveFanoutLoopType(loopType);\n  if (loopType === 'review') return [path.join(lineageDir, 'review-report.md')];\n  return [path.join(lineageDir, 'research.md')];\n}\n\nfunction hasNonEmptyFile(filePath) {\n  try {\n    return fs.statSync(filePath).isFile() && fs.statSync(filePath).size > 0;\n  } catch {\n    return false;\n  }\n}\n\nfunction findMissingLineageArtifacts(loopType, lineageDir) {\n  return expectedLineageArtifactPaths(loopType, lineageDir)\n    .filter((artifactPath) => !hasNonEmptyFile(artifactPath));\n}\n\nfunction parseJsonlRecords(filePath) {\n  const text = fs.readFileSync(filePath, 'utf8');\n  return text\n    .split(/\\r?\\n/)\n    .filter((line) => line.trim() !== '')\n    .map((line) => JSON.parse(line));\n}\n\nfunction lineageStateLogName(loopType) {\n  return STATE_LOG_BY_LOOP_TYPE[loopType] || null;\n}\n\nfunction readLineageStateRecords(loopType, lineageDir) {\n  const stateLogName = lineageStateLogName(loopType);\n  if (!stateLogName) {\n    return { statePath: null, records: [], missing: true, parseError: null };\n  }\n  const statePath = path.join(lineageDir, stateLogName);\n  if (!hasNonEmptyFile(statePath)) {\n    return { statePath, records: [], missing: true, parseError: null };\n  }\n  try {\n    return { statePath, records: parseJsonlRecords(statePath), missing: false, parseError: null };\n  } catch (error) {\n    return {\n      statePath,\n      records: [],\n      missing: false,\n      parseError: error instanceof Error ? error.message : String(error),\n    };\n  }\n}\n\n// A lineage's synthesis stopReason is written by its model and cannot be held to an exact\n// spelling. The iteration-count check above already proves the lineage ran every iteration,\n// so this only needs to confirm the reason belongs to the max-iterations family (e.g.\n// \"maxIterationsReached\", \"max-iterations (10/10)\") and is not a genuinely different outcome\n// such as convergence, a manual stop, or an error.\nfunction isMaxIterationsStopReason(stopReason) {\n  if (typeof stopReason !== 'string') return false;\n  return stopReason.toLowerCase().replace(/[^a-z]/g, '').startsWith('maxiteration');\n}\n\nfunction findMaxIterationsPolicyViolation({ loopType, stateRead, lineage, stopPolicy }) {\n  if (loopType !== 'review' || stopPolicy !== 'max-iterations') return null;\n  if (typeof lineage.iterations !== 'number' || lineage.iterations <= 0) {\n    return 'stopPolicy=max-iterations requires a positive lineage iteration cap';\n  }\n\n  if (!stateRead || stateRead.missing) {\n    return 'missing deep-review-state.jsonl for max-iterations stop-policy validation';\n  }\n  if (stateRead.parseError) {\n    return `could not parse deep-review-state.jsonl: ${stateRead.parseError}`;\n  }\n\n  const records = stateRead.records;\n  const iterationCount = records.filter((record) => record && record.type === 'iteration').length;\n  const synthesis = [...records]\n    .reverse()\n    .find((record) => record && record.type === 'event' && record.event === 'synthesis_complete');\n  if (!synthesis) {\n    return 'missing synthesis_complete event for max-iterations stop-policy validation';\n  }\n\n  const totalIterations = Number.isFinite(Number(synthesis.totalIterations))\n    ? Number(synthesis.totalIterations)\n    : iterationCount;\n  if (totalIterations !== lineage.iterations) {\n    return `expected ${lineage.iterations} iterations, got ${totalIterations}`;\n  }\n  if (!isMaxIterationsStopReason(synthesis.stopReason)) {\n    return `expected stopReason=maxIterationsReached, got ${synthesis.stopReason || 'unknown'}`;\n  }\n  return null;\n}\n\nfunction isRecord(value) {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeStallWatchdogMs(rawConfig) {\n  // Defaults ON (mirrors the fan-out lagCeilingMs default): without a watchdog a stalled\n  // lineage hangs silently until the hours-scale timeout. Read through the raw alias set\n  // because this knob is intentionally outside fanoutConfigSchema. Set 0 to opt out.\n  return readRawConfigNumber(rawConfig, [\n    'stallWatchdogMs',\n    'stall_watchdog_ms',\n    'stallWatchdogMillis',\n    'stall_watchdog_millis',\n  ], 'stallWatchdogMs') ?? 300000;\n}\n\nfunction normalizeLineageBudgetGuards(rawConfig = {}) {\n  return {\n    max_cost_units_per_lineage: readRawConfigNumber(rawConfig, [\n      'maxCostUnitsPerLineage',\n      'max_cost_units_per_lineage',\n      'maxLineageCostUnits',\n      'max_lineage_cost_units',\n      'maxTokensPerLineage',\n      'max_tokens_per_lineage',\n      'maxTokenBudget',\n      'max_token_budget',\n      'maxTokenBudgetPerLineage',\n      'max_token_budget_per_lineage',\n    ], 'maxCostUnitsPerLineage') ?? 0,\n    cost_units_per_iteration: readPositiveRawConfigNumber(rawConfig, [\n      'costUnitsPerIteration',\n      'cost_units_per_iteration',\n      'estimatedTokensPerIteration',\n      'estimated_tokens_per_iteration',\n    ], 'costUnitsPerIteration', 1),\n  };\n}\n\nfunction computeLineageBudgetUpperBound(lineage, guardsInput = {}) {\n  const guards = normalizeLineageBudgetGuards(guardsInput);\n  const rawIterations = Number(lineage && lineage.iterations);\n  const iterations = Number.isFinite(rawIterations) && rawIterations > 0 ? Math.floor(rawIterations) : 12;\n  return {\n    ...guards,\n    iterations,\n    estimated_cost_units: iterations * guards.cost_units_per_iteration,\n  };\n}\n\nfunction evaluateLineageBudgetCap(input = {}) {\n  const upperBound = computeLineageBudgetUpperBound(input.lineage || {}, input.guards || input);\n  const exceeded = upperBound.max_cost_units_per_lineage > 0\n    && upperBound.estimated_cost_units > upperBound.max_cost_units_per_lineage;\n  return {\n    continue_allowed: !exceeded,\n    stop_reasons: exceeded ? ['max_cost_units_per_lineage'] : [],\n    upper_bound: upperBound,\n  };\n}\n\nfunction buildTimestampAnomalyCounts(check) {\n  return {\n    anomalous: check.anomalous,\n    untimestamped: check.untimestamped,\n    unparseable: check.unparseable,\n    total: check.total,\n  };\n}\n\nfunction buildTimestampAnomalyPayload({ lineage, statePath, check }) {\n  return {\n    label: lineage.label,\n    state_log: statePath,\n    window: {\n      start_at_iso: check.windowStart,\n      end_at_iso: check.windowEnd,\n      tolerance_ms: check.toleranceMs,\n    },\n    counts: buildTimestampAnomalyCounts(check),\n    sample: check.sample,\n  };\n}\n\nfunction collectTimestampAnomalies(results) {\n  return results\n    .filter((result) => result && result.status === 'fulfilled' && result.output && result.output.timestamp_anomaly)\n    .map((result) => result.output.timestamp_anomaly);\n}\n\nfunction normalizeNonNegativeDelayMs(value) {\n  if (value === undefined || value === null) return null;\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) return null;\n  return Math.floor(n);\n}\n\nfunction normalizeWaitDurationMs(value) {\n  return normalizeNonNegativeDelayMs(value) ?? 0;\n}\n\nfunction waitCheckpointPath(baseArtifactDir) {\n  return path.join(baseArtifactDir, WAIT_CHECKPOINT_FILENAME);\n}\n\nfunction atomicWriteJson(filePath, payload) {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  const tmpPath = `${filePath}.${process.pid}.${Date.now()}.tmp`;\n  fs.writeFileSync(tmpPath, `${JSON.stringify(payload, null, 2)}\\n`, 'utf8');\n  fs.renameSync(tmpPath, filePath);\n}\n\nfunction buildWaitCheckpoint({ waitMs, runId, loopType, specFolder, nowMs = Date.now() }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  const updatedAt = new Date(nowMs).toISOString();\n  if (durationMs <= 0) {\n    return {\n      schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n      status: 'idle',\n      nextRunAt: null,\n      remainingDelayMs: null,\n      updatedAt,\n      runId,\n      loopType,\n      specFolder,\n    };\n  }\n\n  return {\n    schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n    status: 'waiting',\n    nextRunAt: new Date(nowMs + durationMs).toISOString(),\n    remainingDelayMs: durationMs,\n    updatedAt,\n    runId,\n    loopType,\n    specFolder,\n  };\n}\n\nfunction normalizeWaitCheckpoint(raw, context) {\n  if (!isRecord(raw)) {\n    throw inputError('wait checkpoint must be a JSON object');\n  }\n\n  const nowMs = Number.isFinite(Number(context.nowMs)) ? Number(context.nowMs) : Date.now();\n  const hasNextRunAt = Object.prototype.hasOwnProperty.call(raw, 'nextRunAt');\n  const hasRemainingDelayMs = Object.prototype.hasOwnProperty.call(raw, 'remainingDelayMs');\n  const nextRunAt = typeof raw.nextRunAt === 'string' && raw.nextRunAt.trim() !== ''\n    ? raw.nextRunAt\n    : null;\n  const nextRunAtMs = nextRunAt === null ? NaN : Date.parse(nextRunAt);\n  const waiting = Number.isFinite(nextRunAtMs) && nextRunAtMs > nowMs;\n  const remainingDelayMs = waiting ? Math.max(0, Math.ceil(nextRunAtMs - nowMs)) : null;\n  const base = {\n    runId: typeof raw.runId === 'string' && raw.runId ? raw.runId : context.runId,\n    loopType: typeof raw.loopType === 'string' && raw.loopType ? raw.loopType : context.loopType,\n    specFolder: typeof raw.specFolder === 'string' && raw.specFolder ? raw.specFolder : context.specFolder,\n  };\n\n  const checkpoint = waiting\n    ? {\n        schemaVersion: WAIT_CHECKPOINT_SCHEMA_VERSION,\n        status: 'waiting',\n        nextRunAt,\n        remainingDelayMs,\n        updatedAt: new Date(nowMs).toISOString(),\n        ...base,\n      }\n    : buildWaitCheckpoint({ waitMs: 0, nowMs, ...base });\n  const staleWaitingFields = !waiting\n    && (raw.nextRunAt !== null || raw.remainingDelayMs !== null || raw.status === 'waiting');\n  const staleRemainingDelay = waiting && Number(raw.remainingDelayMs) !== remainingDelayMs;\n\n  return {\n    checkpoint,\n    migrated: !hasNextRunAt || !hasRemainingDelayMs || staleWaitingFields || staleRemainingDelay,\n  };\n}\n\nfunction readWaitCheckpoint(checkpointPath, context) {\n  if (!fs.existsSync(checkpointPath)) {\n    return { exists: false, checkpoint: null, migrated: false };\n  }\n\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(checkpointPath, 'utf8'));\n  } catch (error) {\n    throw inputError(\n      `wait checkpoint is not valid JSON: ${error instanceof Error ? error.message : String(error)}`,\n    );\n  }\n\n  const normalized = normalizeWaitCheckpoint(raw, context);\n  if (normalized.migrated) {\n    atomicWriteJson(checkpointPath, normalized.checkpoint);\n  }\n  return { exists: true, ...normalized };\n}\n\nfunction sleepWaitChunk(ms) {\n  return new Promise((resolvePromise) => setTimeout(resolvePromise, ms));\n}\n\nasync function waitUntilCheckpointExpires({ checkpointPath, checkpoint, context, sleep = sleepWaitChunk }) {\n  const nextRunAtMs = Date.parse(checkpoint.nextRunAt);\n  let remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n\n  while (remainingDelayMs > 0) {\n    atomicWriteJson(checkpointPath, {\n      ...checkpoint,\n      remainingDelayMs,\n      updatedAt: new Date().toISOString(),\n    });\n    await sleep(Math.min(remainingDelayMs, WAIT_SLEEP_CHUNK_MS));\n    remainingDelayMs = Math.max(0, Math.ceil(nextRunAtMs - Date.now()));\n  }\n\n  atomicWriteJson(checkpointPath, buildWaitCheckpoint({ waitMs: 0, ...context }));\n}\n\nasync function resumeWaitingCheckpoint({ checkpointPath, ledgerPath, runId, loopType, specFolder }) {\n  const context = { runId, loopType, specFolder, nowMs: Date.now() };\n  const loaded = readWaitCheckpoint(checkpointPath, context);\n  if (!loaded.checkpoint || loaded.checkpoint.status !== 'waiting') {\n    return { didWait: false, migrated: loaded.migrated };\n  }\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: loaded.checkpoint.nextRunAt,\n    remainingDelayMs: loaded.checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint: loaded.checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'resume_waiting_complete',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,\n    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/deep-loop-workflows/deep-review/SKILL.md'\n      : '.opencode/skills/deep-loop-workflows/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n    ? ceilingHoursOverride * 60 * 60 * 1000\n    : 4 * 60 * 60 * 1000;\n  return Math.min(iters * perIterSecs * 2 * 1000, ceilingMs);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction normalizePostExitGraceMs(rawConfig, progressHeartbeatMs = 0) {\n  const explicit = readRawConfigNumber(rawConfig, [\n    'postExitGraceMs',\n    'post_exit_grace_ms',\n    'postSubprocessExitGraceMs',\n    'post_subprocess_exit_grace_ms',\n    'orchestratorPostExitGraceMs',\n    'orchestrator_post_exit_grace_ms',\n  ], 'postExitGraceMs');\n  if (explicit !== null) return explicit;\n\n  const heartbeatDerived = Number.isFinite(progressHeartbeatMs) && progressHeartbeatMs > 0\n    ? progressHeartbeatMs * 2\n    : 0;\n  return Math.max(DEFAULT_POST_EXIT_GRACE_MS, heartbeatDerived);\n}\n\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges, onProgress }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,\n      at: new Date().toISOString(),\n      duration_ms: Math.max(0, Date.now() - startedAtMs),\n        gauges: getGauges(),\n      });\n      if (typeof onProgress === 'function') onProgress();\n    }, cadenceMs);\n  timer.unref?.();\n  return () => clearInterval(timer);\n}\n\nfunction startLineageStallWatchdog({ thresholdMs, label, ledgerPath, getLastEventAtMs, getGauges }) {\n  if (!Number.isFinite(thresholdMs) || thresholdMs <= 0) {\n    return () => {};\n  }\n\n  let timer = null;\n  let fired = false;\n  const schedule = () => {\n    if (fired) return;\n    const quietMs = Math.max(0, Date.now() - getLastEventAtMs());\n    const delayMs = Math.max(1, thresholdMs - quietMs);\n    timer = setTimeout(() => {\n      timer = null;\n      const latestQuietMs = Math.max(0, Date.now() - getLastEventAtMs());\n      if (latestQuietMs >= thresholdMs) {\n        fired = true;\n        appendFanoutStatusLedger(ledgerPath, {\n          event: 'stall_detected',\n          label,\n          at: new Date().toISOString(),\n          severity: 'warning',\n          metric: 'time_since_last_lineage_event',\n          stall_watchdog_ms: thresholdMs,\n          quiet_ms: Math.floor(latestQuietMs),\n          gauges: getGauges(),\n        });\n        return;\n      }\n      schedule();\n    }, delayMs);\n    timer.unref?.();\n  };\n\n  schedule();\n  return () => {\n    fired = true;\n    if (timer) clearTimeout(timer);\n  };\n}\n\n/**\n * Run a lineage subprocess without blocking the Node event loop.\n *\n * Resolves a spawnSync-shaped result ({ status, signal, stdout, error }) so the\n * pool's K-in-flight cap actually overlaps lineages. spawnSync blocked the single\n * thread until each child exited, serializing every lineage regardless of the\n * concurrency cap; an awaited async spawn yields to the loop so K run at once.\n *\n * On timeout the child is killed with SIGTERM and result.signal is set to\n * 'SIGTERM', preserving the timeout-as-failure signal the caller relies on.\n *\n * @param {string} command - Executable to run.\n * @param {string[]} cmdArgs - Arguments for the executable.\n * @param {Object} opts - { cwd, env, timeoutMs, maxBuffer, input? }.\n * @returns {Promise<{status:number|null, signal:string|null, stdout:string, error?:Error}>}\n */\nfunction runLineageProcess(command, cmdArgs, opts) {\n  const { cwd, env, timeoutMs, maxBuffer } = opts;\n  const hasInput = typeof opts.input === 'string';\n\n  return new Promise((resolvePromise) => {\n    let child;\n    try {\n      child = spawn(command, cmdArgs, {\n        cwd,\n        env,\n        stdio: [hasInput ? 'pipe' : 'ignore', 'pipe', 'pipe'],\n        detached: process.platform !== 'win32',\n      });\n    } catch (error) {\n      resolvePromise({ status: null, signal: null, stdout: '', error });\n      return;\n    }\n    activeLineageProcesses.add(child);\n    if (typeof opts.onSpawn === 'function') {\n      opts.onSpawn({ pid: child.pid });\n    }\n\n    let stdout = '';\n    let stdoutBytes = 0;\n    let truncated = false;\n    let timedOut = false;\n    let settled = false;\n    let spawnError;\n\n    const timer = setTimeout(() => {\n      timedOut = true;\n      terminateLineageProcess(child, 'SIGTERM');\n    }, timeoutMs);\n    timer.unref?.();\n\n    const abortHandler = () => {\n      terminateLineageProcess(child, 'SIGTERM');\n    };\n    if (opts.abortSignal) {\n      if (opts.abortSignal.aborted) {\n        abortHandler();\n      } else {\n        opts.abortSignal.addEventListener('abort', abortHandler, { once: true });\n      }\n    }\n\n    child.stdout?.setEncoding('utf8');\n    child.stdout?.on('data', (chunk) => {\n      if (truncated) return;\n      stdoutBytes += Buffer.byteLength(chunk, 'utf8');\n      if (stdoutBytes > maxBuffer) {\n        truncated = true;\n        terminateLineageProcess(child, 'SIGTERM');\n        return;\n      }\n      stdout += chunk;\n    });\n    // Drain stderr so the child never blocks on a full pipe; we do not capture it.\n    child.stderr?.resume();\n\n    child.on('error', (error) => {\n      spawnError = error;\n    });\n\n    child.on('close', (code, signal) => {\n      if (settled) return;\n      settled = true;\n      activeLineageProcesses.delete(child);\n      clearTimeout(timer);\n      opts.abortSignal?.removeEventListener?.('abort', abortHandler);\n      const effectiveSignal = timedOut ? 'SIGTERM' : signal;\n      if (typeof opts.onExit === 'function') {\n        opts.onExit({ status: timedOut ? null : code, signal: effectiveSignal, pid: child.pid, exitedAtMs: Date.now() });\n      }\n      resolvePromise({\n        status: timedOut ? null : code,\n        signal: effectiveSignal,\n        stdout,\n        ...(spawnError ? { error: spawnError } : {}),\n      });\n    });\n\n    if (hasInput) {\n      child.stdin?.on('error', () => {});\n      child.stdin?.end(opts.input);\n    }\n  });\n}\n\n/**\n * Build the subprocess command for a fan-out lineage.\n * Returns { command, args, input?, env } where input is stdin content when applicable.\n */\nfunction buildLineageCommand(lineage, prompt, resolvedSandbox, resolvedPermission, options = {}) {\n  const kind = lineage.kind;\n\n  if (kind === 'cli-claude-code') {\n    const args = [\n      '-p',\n      prompt,\n      '--model',\n      lineage.model || 'claude-opus-4-8',\n      '--permission-mode',\n      resolvedPermission,\n      '--output-format',\n      'text',\n    ];\n    if (lineage.reasoningEffort) {\n      args.push('--effort', lineage.reasoningEffort);\n    }\n    return { command: 'claude', args };\n  }\n\n  if (kind === 'native') {\n    // Native fan-out cannot call the LEAF @deep-review agent with a full-loop prompt.\n    // For review runs this is the real deep/review command surface with a lineage\n    // artifact override, so the command YAML owns init, loop, and synthesis.\n    const args = [\n      'run',\n      '--format',\n      'json',\n      '--dangerously-skip-permissions',\n      '--dir',\n      process.cwd(),\n      '--command',\n      `deep/${options.loopType || 'review'}`,\n    ];\n    args.push(buildNativeCommandInput(\n      options.loopType || 'review',\n      options.specFolder || '',\n      options.lineageDir || '',\n      lineage,\n      options,\n    ));\n    return { command: 'opencode', args, input: '' };\n  }\n\n  if (kind === 'cli-opencode') {\n    // No --agent: current opencode treats `general` as a subagent and rejects it\n    // on a top-level `run`. The default agent runs when none is named, and a\n    // specific agent profile can be requested in the prompt body instead.\n    const args = [\n      'run',\n      '--model',\n      lineage.model || 'anthropic/claude-opus-4-8',\n      '--format',\n      'json',\n      '--pure',\n      '--dir',\n      process.cwd(),\n    ];\n    // Permission bypass is opt-in: only detach the sandbox for lineages that explicitly\n    // request danger-full-access. workspace-write/read-only lineages run WITHOUT\n    // --dangerously-skip-permissions so their writes are subject to the CLI permission\n    // boundary. opencode has no path-scoped write flag, so a workspace-write review\n    // lineage's lineageDir-only boundary still relies on the prompt — but the operator\n    // must now opt into full bypass rather than getting it silently by default.\n    const useDangerousBypass = resolvedSandbox === 'danger-full-access';\n    if (useDangerousBypass) {\n      args.splice(args.indexOf('--pure'), 0, '--dangerously-skip-permissions');\n      process.stderr.write(\n        `FATAL WARN: lineage ${lineage.label || '(cli-opencode)'} runs with --dangerously-skip-permissions. `\n          + `The lineageDir write boundary is prompt-only, not sandbox-enforced.\\n`,\n      );\n    }\n    if (lineage.reasoningEffort) {\n      args.push('--variant', lineage.reasoningEffort);\n    }\n    args.push(prompt);\n    return { command: 'opencode', args, input: '' };\n  }\n\n  throw inputError(`Unknown fan-out executor kind: ${kind}`);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const args = parseArgs();\n  const specFolder = validateNamespaceValue(ensureString(args, 'specFolder'), 'specFolder', inputError);\n  const loopType = ensureString(args, 'loopType');\n  assertActiveFanoutLoopType(loopType);\n  // Optional shared research question, threaded into each lineage prompt so a research\n  // fan-out can bind research_topic. Absent for review, which scopes by folder.\n  const researchTopic = typeof args.researchTopic === 'string' && args.researchTopic.trim()\n    ? args.researchTopic.trim()\n    : null;\n  const fanoutConfigJson = ensureString(args, 'fanoutConfigJson');\n  const baseArtifactDir = validateBaseArtifactDir(ensureString(args, 'baseArtifactDir'), specFolder, loopType);\n  const convergenceThreshold = parseOptionalNumber(args, 'convergenceThreshold');\n  const lineageTimeoutHoursOverride = parseOptionalNumber(args, 'lineageTimeoutHours');\n  const stopPolicy = normalizeStopPolicy(args.stopPolicy);\n\n  const {\n    parseFanoutConfig,\n    expandLineages,\n    resolveSandboxMode,\n    resolveClaudePermissionMode,\n  } = await import('../lib/deep-loop/executor-config.ts');\n  const { buildExecutorDispatchEnv, detectSameKindFromStack, CLI_DISPATCH_STACK_ENV } = await import('../lib/deep-loop/executor-audit.ts');\n  const {\n    DEFAULT_LINEAGE_TIMESTAMP_TOLERANCE_MS,\n    checkLineageTimestampWindow,\n  } = await import('../lib/deep-loop/lineage-timestamp-window.ts');\n\n  maybeThrowTestFault();\n\n  let rawConfig;\n  try {\n    rawConfig = JSON.parse(fanoutConfigJson);\n  } catch {\n    throw inputError('fanoutConfigJson is not valid JSON');\n  }\n\n  const lineagesDir = path.join(baseArtifactDir, 'lineages');\n  const ledgerPath = path.join(baseArtifactDir, 'orchestration-status.log');\n  const summaryPath = path.join(baseArtifactDir, 'orchestration-summary.json');\n  const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n  const parsedFanoutConfig = parseFanoutConfig(rawConfig);\n  const rawGuardConfig = rawConfigWithCliBudgetOverrides(rawConfig, args);\n  const stallWatchdogMs = normalizeStallWatchdogMs(rawGuardConfig);\n  const lineageBudgetGuards = normalizeLineageBudgetGuards(rawGuardConfig);\n  const guardedAssignment = applyFlatPoolAssignmentGuard(parsedFanoutConfig);\n  const fanoutConfig = guardedAssignment.config;\n  const allLineages = expandLineages(fanoutConfig);","lineStart":1,"lineEnd":1432,"totalLines":1433,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1783489172318,"end":1783489172323}},"metadata":{"openai":{"itemId":"fc_01fb4a25ac0d7cd3016a4de293e75881919e1a459e91fe1265"}},"id":"prt_f403d130a001fYxY1pq6mpdIEU","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","messageID":"msg_f403cbc480018ajiAmXXfQafxy"}}
{"type":"tool_use","timestamp":1783489172471,"sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","part":{"type":"tool","tool":"read","callID":"call_1J6nLt5RfzqdjD1NH0nmMtJK","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: // After-dispatch leaf-reliability check for the deep-loop iteration loop.\n5: //\n6: // A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n7: // (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n8: // per-iteration delta file. The state-log record must also carry route-proof\n9: // fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n10: // resolved_route). A model-driven loop is trusted to self-check today, which lets a\n11: // silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n12: // non-zero with a single machine reason so the workflow can re-dispatch the same\n13: // iteration once before recording an error and continuing.\n14: \n15: const fs = require('node:fs');\n16: const path = require('node:path');\n17: \n18: const LEAF_BY_LOOP = {\n19:   review: 'deep-review',\n20:   research: 'deep-research',\n21: };\n22: \n23: const STATE_LOG_BY_LOOP = {\n24:   review: 'deep-review-state.jsonl',\n25:   research: 'deep-research-state.jsonl',\n26: };\n27: \n28: const REASONS = {\n29:   ITERATION_FILE_MISSING: 'iteration_file_missing',\n30:   ITERATION_VERDICT_MISSING: 'iteration_verdict_missing',\n31:   STATE_RECORD_MISSING: 'state_record_missing',\n32:   ROUTE_PROOF_MISSING: 'route_proof_missing',\n33:   ROUTE_PROOF_MISMATCH: 'route_proof_mismatch',\n34:   DELTA_FILE_MISSING: 'delta_file_missing',\n35: };\n36: \n37: function pad3(n) {\n38:   return String(n).padStart(3, '0');\n39: }\n40: \n41: function parseArgs(argv) {\n42:   const out = { json: false };\n43:   for (let i = 0; i < argv.length; i += 1) {\n44:     const a = argv[i];\n45:     if (a === '--loop-type') { out.loopType = argv[i + 1]; i += 1; }\n46:     else if (a === '--artifact-dir') { out.artifactDir = argv[i + 1]; i += 1; }\n47:     else if (a === '--iteration') { out.iteration = parseInt(argv[i + 1], 10); i += 1; }\n48:     else if (a === '--json') { out.json = true; }\n49:     else if (a === '--help' || a === '-h') { out.help = true; }\n50:     else { out.error = `unknown flag: ${a}`; }\n51:   }\n52:   return out;\n53: }\n54: \n55: // Read a JSONL file and return parsed objects, skipping blank/malformed lines so a\n56: // single corrupt append never crashes the gate.\n57: function readJsonlRecords(filePath) {\n58:   let raw;\n59:   try {\n60:     raw = fs.readFileSync(filePath, 'utf8');\n61:   } catch (_) {\n62:     return null; // file absent/unreadable\n63:   }\n64:   const records = [];\n65:   for (const line of raw.split('\\n')) {\n66:     const trimmed = line.trim();\n67:     if (!trimmed) continue;\n68:     try {\n69:       records.push(JSON.parse(trimmed));\n70:     } catch (_) {\n71:       // skip malformed line\n72:     }\n73:   }\n74:   return records;\n75: }\n76: \n77: // The narrative file is written as iteration-NNN.md but the leaf may append a\n78: // descriptive suffix (iteration-NNN-some-focus.md), so match the padded number as a\n79: // prefix bounded by \".\" or \"-\" to avoid confusing 002 with 020.\n80: function findIterationNarrative(iterationsDir, iteration) {\n81:   const nnn = pad3(iteration);\n82:   let entries;\n83:   try {\n84:     entries = fs.readdirSync(iterationsDir);\n85:   } catch (_) {\n86:     return null;\n87:   }\n88:   const re = new RegExp(`^iteration-${nnn}(?:\\\\.md$|-.*\\\\.md$)`);\n89:   for (const name of entries) {\n90:     if (re.test(name)) return path.join(iterationsDir, name);\n91:   }\n92:   return null;\n93: }\n94: \n95: function isNonEmptyString(value) {\n96:   return typeof value === 'string' && value.trim().length > 0;\n97: }\n98: \n99: // Route-proof lives on the canonical iteration record. Absent fields => the leaf did\n100: // not emit route-proof at all; present-but-wrong => it ran as something other than\n101: // its own leaf identity or in the wrong mode.\n102: function checkRouteProof(record, loopType, leaf) {\n103:   const hasMode = 'mode' in record;\n104:   const hasTarget = 'target_agent' in record;\n105:   const hasLoaded = 'agent_definition_loaded' in record;\n106:   const hasRoute = 'resolved_route' in record;\n107:   if (!hasMode || !hasTarget || !hasLoaded || !hasRoute) {\n108:     return REASONS.ROUTE_PROOF_MISSING;\n109:   }\n110:   if (\n111:     record.mode !== loopType ||\n112:     record.target_agent !== leaf ||\n113:     record.agent_definition_loaded !== true ||\n114:     !isNonEmptyString(record.resolved_route)\n115:   ) {\n116:     return REASONS.ROUTE_PROOF_MISMATCH;\n117:   }\n118:   return null;\n119: }\n120: \n121: function verify(loopType, artifactDir, iteration) {\n122:   const leaf = LEAF_BY_LOOP[loopType];\n123:   const stateLogName = STATE_LOG_BY_LOOP[loopType];\n124: \n125:   // 1. Iteration narrative markdown.\n126:   const narrativePath = findIterationNarrative(path.join(artifactDir, 'iterations'), iteration);\n127:   if (!narrativePath) {\n128:     return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `no iterations/iteration-${pad3(iteration)}*.md under ${artifactDir}` };\n129:   }\n130:   const narrative = fs.readFileSync(narrativePath, 'utf8');\n131:   if (!narrative.trim()) {\n132:     return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `${narrativePath} is empty` };\n133:   }\n134:   // Review narratives must end on a machine-readable verdict; research/context use a\n135:   // different closing shape, so only review enforces the verdict line here.\n136:   if (loopType === 'review' && !/Review verdict:\\s*(PASS|CONDITIONAL|FAIL)/i.test(narrative)) {\n137:     return { ok: false, reason: REASONS.ITERATION_VERDICT_MISSING, detail: `${narrativePath} lacks a \"Review verdict: PASS|CONDITIONAL|FAIL\" line` };\n138:   }\n139: \n140:   // 2. Canonical state-log record for this iteration + route-proof.\n141:   const stateRecords = readJsonlRecords(path.join(artifactDir, stateLogName));\n142:   // Review/research key the iteration number as `iteration`; context keys it as `run`.\n143:   // Match either so one shim covers all three modes (a non-numeric run-id yields NaN\n144:   // and never false-matches). Take the LAST matching record, not the first: the state\n145:   // log is append-only, so a re-dispatched iteration appends a corrected record after\n146:   // the bad one -- matching the first would keep reporting the stale failure and defeat\n147:   // the bounded retry. The state reducer applies the same latest-record-wins rule.\n148:   const iterationRecord = (stateRecords || []).findLast(\n149:     (r) => r && r.type === 'iteration' && (Number(r.iteration) === iteration || Number(r.run) === iteration),\n150:   );\n151:   if (!iterationRecord) {\n152:     return { ok: false, reason: REASONS.STATE_RECORD_MISSING, detail: `no type=iteration record with iteration=${iteration} in ${stateLogName}` };\n153:   }\n154:   const routeReason = checkRouteProof(iterationRecord, loopType, leaf);\n155:   if (routeReason) {\n156:     return { ok: false, reason: routeReason, detail: `iteration ${iteration} state record failed route-proof (expected mode=${loopType} target_agent=${leaf})` };\n157:   }\n158: \n159:   // 3. Per-iteration delta file with at least one iteration record.\n160:   const deltaRecords = readJsonlRecords(path.join(artifactDir, 'deltas', `iter-${pad3(iteration)}.jsonl`));\n161:   if (!deltaRecords || !deltaRecords.some((r) => r && r.type === 'iteration')) {\n162:     return { ok: false, reason: REASONS.DELTA_FILE_MISSING, detail: `deltas/iter-${pad3(iteration)}.jsonl missing or has no type=iteration record` };\n163:   }\n164: \n165:   return { ok: true, reason: null, detail: `iteration ${iteration} complete: narrative + route-proof + delta` };\n166: }\n167: \n168: function main(argv = process.argv.slice(2)) {\n169:   const args = parseArgs(argv);\n170:   if (args.help) {\n171:     process.stdout.write('Usage: verify-iteration.cjs --loop-type review|research|context --artifact-dir <dir> --iteration <N> [--json]\\n');\n172:     return 0;\n173:   }\n174:   if (args.error) { process.stderr.write(`${args.error}\\n`); return 2; }\n175:   if (!args.loopType || !LEAF_BY_LOOP[args.loopType]) { process.stderr.write('--loop-type must be one of review|research\\n'); return 2; }\n176:   if (!args.artifactDir) { process.stderr.write('--artifact-dir is required\\n'); return 2; }\n177:   if (!Number.isInteger(args.iteration) || args.iteration < 1) { process.stderr.write('--iteration must be a positive integer\\n'); return 2; }\n178: \n179:   const result = verify(args.loopType, args.artifactDir, args.iteration);\n180:   if (args.json) {\n181:     process.stdout.write(`${JSON.stringify(result)}\\n`);\n182:   } else if (result.ok) {\n183:     process.stdout.write(`OK ${result.detail}\\n`);\n184:   } else {\n185:     process.stderr.write(`${result.reason} ${result.detail}\\n`);\n186:   }\n187:   return result.ok ? 0 : 1;\n188: }\n189: \n190: if (require.main === module) {\n191:   process.exit(main());\n192: }\n193: \n194: module.exports = { verify, checkRouteProof, findIterationNarrative, readJsonlRecords, pad3, REASONS, LEAF_BY_LOOP, STATE_LOG_BY_LOOP };\n\n(End of file - total 194 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n// After-dispatch leaf-reliability check for the deep-loop iteration loop.\n//\n// A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n// (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n// per-iteration delta file. The state-log record must also carry route-proof\n// fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n// resolved_route). A model-driven loop is trusted to self-check today, which lets a\n// silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n// non-zero with a single machine reason so the workflow can re-dispatch the same\n// iteration once before recording an error and continuing.\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst LEAF_BY_LOOP = {\n  review: 'deep-review',\n  research: 'deep-research',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs","text":"#!/usr/bin/env node\n'use strict';\n\n// After-dispatch leaf-reliability check for the deep-loop iteration loop.\n//\n// A dispatched leaf owes THREE artifacts per iteration: the narrative markdown\n// (iterations/iteration-NNN.md), an appended canonical state-log record, and a\n// per-iteration delta file. The state-log record must also carry route-proof\n// fields proving the leaf ran as itself (mode, target_agent, agent_definition_loaded,\n// resolved_route). A model-driven loop is trusted to self-check today, which lets a\n// silently-incomplete leaf advance the loop. This makes the check mechanical: exit\n// non-zero with a single machine reason so the workflow can re-dispatch the same\n// iteration once before recording an error and continuing.\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nconst LEAF_BY_LOOP = {\n  review: 'deep-review',\n  research: 'deep-research',\n};\n\nconst STATE_LOG_BY_LOOP = {\n  review: 'deep-review-state.jsonl',\n  research: 'deep-research-state.jsonl',\n};\n\nconst REASONS = {\n  ITERATION_FILE_MISSING: 'iteration_file_missing',\n  ITERATION_VERDICT_MISSING: 'iteration_verdict_missing',\n  STATE_RECORD_MISSING: 'state_record_missing',\n  ROUTE_PROOF_MISSING: 'route_proof_missing',\n  ROUTE_PROOF_MISMATCH: 'route_proof_mismatch',\n  DELTA_FILE_MISSING: 'delta_file_missing',\n};\n\nfunction pad3(n) {\n  return String(n).padStart(3, '0');\n}\n\nfunction parseArgs(argv) {\n  const out = { json: false };\n  for (let i = 0; i < argv.length; i += 1) {\n    const a = argv[i];\n    if (a === '--loop-type') { out.loopType = argv[i + 1]; i += 1; }\n    else if (a === '--artifact-dir') { out.artifactDir = argv[i + 1]; i += 1; }\n    else if (a === '--iteration') { out.iteration = parseInt(argv[i + 1], 10); i += 1; }\n    else if (a === '--json') { out.json = true; }\n    else if (a === '--help' || a === '-h') { out.help = true; }\n    else { out.error = `unknown flag: ${a}`; }\n  }\n  return out;\n}\n\n// Read a JSONL file and return parsed objects, skipping blank/malformed lines so a\n// single corrupt append never crashes the gate.\nfunction readJsonlRecords(filePath) {\n  let raw;\n  try {\n    raw = fs.readFileSync(filePath, 'utf8');\n  } catch (_) {\n    return null; // file absent/unreadable\n  }\n  const records = [];\n  for (const line of raw.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed) continue;\n    try {\n      records.push(JSON.parse(trimmed));\n    } catch (_) {\n      // skip malformed line\n    }\n  }\n  return records;\n}\n\n// The narrative file is written as iteration-NNN.md but the leaf may append a\n// descriptive suffix (iteration-NNN-some-focus.md), so match the padded number as a\n// prefix bounded by \".\" or \"-\" to avoid confusing 002 with 020.\nfunction findIterationNarrative(iterationsDir, iteration) {\n  const nnn = pad3(iteration);\n  let entries;\n  try {\n    entries = fs.readdirSync(iterationsDir);\n  } catch (_) {\n    return null;\n  }\n  const re = new RegExp(`^iteration-${nnn}(?:\\\\.md$|-.*\\\\.md$)`);\n  for (const name of entries) {\n    if (re.test(name)) return path.join(iterationsDir, name);\n  }\n  return null;\n}\n\nfunction isNonEmptyString(value) {\n  return typeof value === 'string' && value.trim().length > 0;\n}\n\n// Route-proof lives on the canonical iteration record. Absent fields => the leaf did\n// not emit route-proof at all; present-but-wrong => it ran as something other than\n// its own leaf identity or in the wrong mode.\nfunction checkRouteProof(record, loopType, leaf) {\n  const hasMode = 'mode' in record;\n  const hasTarget = 'target_agent' in record;\n  const hasLoaded = 'agent_definition_loaded' in record;\n  const hasRoute = 'resolved_route' in record;\n  if (!hasMode || !hasTarget || !hasLoaded || !hasRoute) {\n    return REASONS.ROUTE_PROOF_MISSING;\n  }\n  if (\n    record.mode !== loopType ||\n    record.target_agent !== leaf ||\n    record.agent_definition_loaded !== true ||\n    !isNonEmptyString(record.resolved_route)\n  ) {\n    return REASONS.ROUTE_PROOF_MISMATCH;\n  }\n  return null;\n}\n\nfunction verify(loopType, artifactDir, iteration) {\n  const leaf = LEAF_BY_LOOP[loopType];\n  const stateLogName = STATE_LOG_BY_LOOP[loopType];\n\n  // 1. Iteration narrative markdown.\n  const narrativePath = findIterationNarrative(path.join(artifactDir, 'iterations'), iteration);\n  if (!narrativePath) {\n    return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `no iterations/iteration-${pad3(iteration)}*.md under ${artifactDir}` };\n  }\n  const narrative = fs.readFileSync(narrativePath, 'utf8');\n  if (!narrative.trim()) {\n    return { ok: false, reason: REASONS.ITERATION_FILE_MISSING, detail: `${narrativePath} is empty` };\n  }\n  // Review narratives must end on a machine-readable verdict; research/context use a\n  // different closing shape, so only review enforces the verdict line here.\n  if (loopType === 'review' && !/Review verdict:\\s*(PASS|CONDITIONAL|FAIL)/i.test(narrative)) {\n    return { ok: false, reason: REASONS.ITERATION_VERDICT_MISSING, detail: `${narrativePath} lacks a \"Review verdict: PASS|CONDITIONAL|FAIL\" line` };\n  }\n\n  // 2. Canonical state-log record for this iteration + route-proof.\n  const stateRecords = readJsonlRecords(path.join(artifactDir, stateLogName));\n  // Review/research key the iteration number as `iteration`; context keys it as `run`.\n  // Match either so one shim covers all three modes (a non-numeric run-id yields NaN\n  // and never false-matches). Take the LAST matching record, not the first: the state\n  // log is append-only, so a re-dispatched iteration appends a corrected record after\n  // the bad one -- matching the first would keep reporting the stale failure and defeat\n  // the bounded retry. The state reducer applies the same latest-record-wins rule.\n  const iterationRecord = (stateRecords || []).findLast(\n    (r) => r && r.type === 'iteration' && (Number(r.iteration) === iteration || Number(r.run) === iteration),\n  );\n  if (!iterationRecord) {\n    return { ok: false, reason: REASONS.STATE_RECORD_MISSING, detail: `no type=iteration record with iteration=${iteration} in ${stateLogName}` };\n  }\n  const routeReason = checkRouteProof(iterationRecord, loopType, leaf);\n  if (routeReason) {\n    return { ok: false, reason: routeReason, detail: `iteration ${iteration} state record failed route-proof (expected mode=${loopType} target_agent=${leaf})` };\n  }\n\n  // 3. Per-iteration delta file with at least one iteration record.\n  const deltaRecords = readJsonlRecords(path.join(artifactDir, 'deltas', `iter-${pad3(iteration)}.jsonl`));\n  if (!deltaRecords || !deltaRecords.some((r) => r && r.type === 'iteration')) {\n    return { ok: false, reason: REASONS.DELTA_FILE_MISSING, detail: `deltas/iter-${pad3(iteration)}.jsonl missing or has no type=iteration record` };\n  }\n\n  return { ok: true, reason: null, detail: `iteration ${iteration} complete: narrative + route-proof + delta` };\n}\n\nfunction main(argv = process.argv.slice(2)) {\n  const args = parseArgs(argv);\n  if (args.help) {\n    process.stdout.write('Usage: verify-iteration.cjs --loop-type review|research|context --artifact-dir <dir> --iteration <N> [--json]\\n');\n    return 0;\n  }\n  if (args.error) { process.stderr.write(`${args.error}\\n`); return 2; }\n  if (!args.loopType || !LEAF_BY_LOOP[args.loopType]) { process.stderr.write('--loop-type must be one of review|research\\n'); return 2; }\n  if (!args.artifactDir) { process.stderr.write('--artifact-dir is required\\n'); return 2; }\n  if (!Number.isInteger(args.iteration) || args.iteration < 1) { process.stderr.write('--iteration must be a positive integer\\n'); return 2; }\n\n  const result = verify(args.loopType, args.artifactDir, args.iteration);\n  if (args.json) {\n    process.stdout.write(`${JSON.stringify(result)}\\n`);\n  } else if (result.ok) {\n    process.stdout.write(`OK ${result.detail}\\n`);\n  } else {\n    process.stderr.write(`${result.reason} ${result.detail}\\n`);\n  }\n  return result.ok ? 0 : 1;\n}\n\nif (require.main === module) {\n  process.exit(main());\n}\n\nmodule.exports = { verify, checkRouteProof, findIterationNarrative, readJsonlRecords, pad3, REASONS, LEAF_BY_LOOP, STATE_LOG_BY_LOOP };","lineStart":1,"lineEnd":194,"totalLines":194,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/scripts/verify-iteration.cjs","time":{"start":1783489172467,"end":1783489172470}},"metadata":{"openai":{"itemId":"fc_01fb4a25ac0d7cd3016a4de293e7608191ae366281f51487c7"}},"id":"prt_f403d139d001bv1MJFspW2DkMZ","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","messageID":"msg_f403cbc480018ajiAmXXfQafxy"}}
{"type":"tool_use","timestamp":1783489172640,"sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","part":{"type":"tool","tool":"read","callID":"call_11kvnJTf6f9w8U9Wmj42G3Ph","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep-Loop Runtime — Fan-Out Cross-Lineage Merge                          ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ Input:  CLI args (--loop-type, --artifact-dir).                          ║\n5: // ║ Output: JSON to stdout.                                                  ║\n6: // ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n7: // ║                                                                          ║\n8: // ║ Reads every {artifact-dir}/lineages/{label}/ sub-packet and produces:   ║\n9: // ║   research: deduplicated deep-research-findings-registry.json +          ║\n10: // ║             fanout-attribution.md                                        ║\n11: // ║   review:   severity-rollup deep-review-findings-registry.json           ║\n12: // ║             (strongest-restriction: any lineage P0 → merged FAIL) +     ║\n13: // ║             fanout-attribution.md                                        ║\n14: // ╚══════════════════════════════════════════════════════════════════════════╝\n15: \n16: 'use strict';\n17: \n18: const crypto = require('node:crypto');\n19: const fs = require('node:fs');\n20: const path = require('node:path');\n21: const { spawnSync } = require('node:child_process');\n22: \n23: const SEVERITY_RANK = { P0: 3, P1: 2, P2: 1 };\n24: \n25: // ─────────────────────────────────────────────────────────────────────────────\n26: // 1. TSX BOOTSTRAP\n27: // ─────────────────────────────────────────────────────────────────────────────\n28: \n29: const TSX_LOADER = require.resolve('tsx');\n30: \n31: // The merged registry and attribution share the runtime's atomic-state helpers,\n32: // which are TypeScript ESM. Re-exec once under the tsx loader so the dynamic\n33: // import below resolves them; mirrors convergence.cjs. Only the CLI entrypoint\n34: // re-execs — module consumers (unit tests) import the pure helpers directly.\n35: if (require.main === module && process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n36:   const child = spawnSync(\n37:     process.execPath,\n38:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n39:     {\n40:       cwd: process.cwd(),\n41:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n42:       encoding: 'utf8',\n43:     },\n44:   );\n45:   if (child.stdout) process.stdout.write(child.stdout);\n46:   if (child.stderr) process.stderr.write(child.stderr);\n47:   process.exit(child.status === null ? 1 : child.status);\n48: }\n49: \n50: // ─────────────────────────────────────────────────────────────────────────────\n51: // 2. HELPERS\n52: // ─────────────────────────────────────────────────────────────────────────────\n53: \n54: function inputError(message) {\n55:   const err = new Error(message);\n56:   err.code = 'INPUT_VALIDATION';\n57:   return err;\n58: }\n59: \n60: function jsonOut(payload) {\n61:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n62: }\n63: \n64: function parseArgs(argv = process.argv.slice(2)) {\n65:   const args = {};\n66:   for (let i = 0; i < argv.length; i += 1) {\n67:     const token = argv[i];\n68:     if (!token.startsWith('--')) {\n69:       throw inputError(`Unexpected positional argument: ${token}`);\n70:     }\n71:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n72:     const next = argv[i + 1];\n73:     if (next === undefined || next.startsWith('--')) {\n74:       args[key] = true;\n75:     } else {\n76:       args[key] = next;\n77:       i += 1;\n78:     }\n79:   }\n80:   return args;\n81: }\n82: \n83: function ensureString(args, key) {\n84:   if (!args[key] || typeof args[key] !== 'string') {\n85:     throw inputError(`${key} is required`);\n86:   }\n87:   return args[key];\n88: }\n89: \n90: function tryReadJson(filePath) {\n91:   if (!fs.existsSync(filePath)) return null;\n92:   try {\n93:     return JSON.parse(fs.readFileSync(filePath, 'utf8'));\n94:   } catch {\n95:     return null;\n96:   }\n97: }\n98: \n99: function readStateLog(stateLogPath) {\n100:   if (!fs.existsSync(stateLogPath)) return [];\n101:   const lines = fs.readFileSync(stateLogPath, 'utf8').trim().split('\\n').filter(Boolean);\n102:   return lines.flatMap((line) => {\n103:     try {\n104:       return [JSON.parse(line)];\n105:     } catch {\n106:       return [];\n107:     }\n108:   });\n109: }\n110: \n111: function stableValue(value) {\n112:   if (Array.isArray(value)) {\n113:     return value.map(stableValue);\n114:   }\n115:   if (value && typeof value === 'object') {\n116:     const sorted = {};\n117:     for (const key of Object.keys(value).sort()) {\n118:       sorted[key] = stableValue(value[key]);\n119:     }\n120:     return sorted;\n121:   }\n122:   return value;\n123: }\n124: \n125: function stableStringify(value) {\n126:   return JSON.stringify(stableValue(value));\n127: }\n128: \n129: function normalizeSortText(value) {\n130:   return typeof value === 'string' ? value.trim().toLowerCase().replace(/\\s+/g, ' ') : '';\n131: }\n132: \n133: function contentSortKey(record) {\n134:   const durableText = [\n135:     record.title,\n136:     record.summary,\n137:     record.description,\n138:     record.finding,\n139:     record.question,\n140:     record.direction,\n141:     record.severity,\n142:     record.status,\n143:   ].map(normalizeSortText).filter(Boolean).join('\\u0001');\n144:   return durableText || stableStringify({ ...record, _lineages: undefined });\n145: }\n146: \n147: function contentIdentityKey(record) {\n148:   const durableText = [\n149:     record.title,\n150:     record.summary,\n151:     record.description,\n152:     record.finding,\n153:     record.question,\n154:     record.direction,\n155:   ].map(normalizeSortText).filter(Boolean).join('\\u0001');\n156:   return durableText || stableStringify({\n157:     ...record,\n158:     _conflictOf: undefined,\n159:     _conflict_id: undefined,\n160:     _conflicts: undefined,\n161:     _lineages: undefined,\n162:     severity: undefined,\n163:     status: undefined,\n164:   });\n165: }\n166: \n167: function nearDuplicateContentKey(record) {\n168:   const durableText = [\n169:     record.summary,\n170:     record.description,\n171:     record.finding,\n172:     record.question,\n173:     record.direction,\n174:   ].map(normalizeSortText).filter(Boolean).join('\\u0001');\n175:   return durableText || contentIdentityKey(record);\n176: }\n177: \n178: // Stopwords stripped before comparing titles so the overlap signal keys on the content\n179: // nouns/verbs that distinguish one finding from another, not on filler.\n180: const TITLE_STOPWORDS = new Set([\n181:   'a', 'an', 'the', 'in', 'on', 'at', 'to', 'of', 'for', 'and', 'or', 'with', 'without',\n182:   'is', 'are', 'was', 'were', 'be', 'no', 'not', 'so', 'that', 'this', 'it', 'its', 'as',\n183:   'by', 'from', 'into', 'after', 'before', 'when', 'where', 'which', 'has', 'have',\n184: ]);\n185: \n186: function titleContentTokens(record) {\n187:   const raw = typeof record.title === 'string' ? record.title : '';\n188:   return new Set(\n189:     normalizeSortText(raw)\n190:       .split(/[^a-z0-9]+/)\n191:       .filter((tok) => tok && !TITLE_STOPWORDS.has(tok)),\n192:   );\n193: }\n194: \n195: // Jaccard overlap of two title token sets. 1 when both are empty (no title signal to\n196: // distinguish on → fall back to body-only collapse, the original contract for title-less\n197: // findings).\n198: function titleOverlap(aTokens, bTokens) {\n199:   if (aTokens.size === 0 && bTokens.size === 0) return 1;\n200:   if (aTokens.size === 0 || bTokens.size === 0) return 0;\n201:   let shared = 0;\n202:   for (const tok of aTokens) if (bTokens.has(tok)) shared += 1;\n203:   const union = aTokens.size + bTokens.size - shared;\n204:   return union === 0 ? 1 : shared / union;\n205: }\n206: \n207: // Below this title overlap two same-body findings are treated as DISTINCT (their titles\n208: // name substantively different things — e.g. a generic \"missing auth check\" body whose\n209: // titles name two different endpoints with no shared subject). At or above it the titles\n210: // are paraphrases of one point that share their subject noun, and the same-body findings\n211: // collapse, preserving the designed-for restatement collapse. The threshold is low because\n212: // legitimate restatement titles often share only the one key subject noun (\"cache\",\n213: // \"retry\") while genuinely-distinct titles share no content token at all.\n214: const TITLE_DISTINCT_OVERLAP_THRESHOLD = 0.15;\n215: \n216: // Title-aware near-dup match (deep-review P2-15 fix): two findings are near-duplicates\n217: // only if their body-content key matches AND their titles are not substantively divergent.\n218: // This closes the title blind spot — genuinely-distinct findings that share an identical\n219: // body but carry different distinguishing titles no longer collapse — without breaking the\n220: // designed-for collapse of restatements that share a body and paraphrase the same title.\n221: function nearDuplicateMatches(a, b) {\n222:   if (nearDuplicateContentKey(a) !== nearDuplicateContentKey(b)) return false;\n223:   return titleOverlap(titleContentTokens(a), titleContentTokens(b)) >= TITLE_DISTINCT_OVERLAP_THRESHOLD;\n224: }\n225: \n226: function contentDigest(record) {\n227:   return crypto.createHash('sha256').update(contentIdentityKey(record)).digest('hex').slice(0, 12);\n228: }\n229: \n230: function compareByContentThenId(left, right, idKeys) {\n231:   const leftContent = contentSortKey(left);\n232:   const rightContent = contentSortKey(right);\n233:   if (leftContent < rightContent) return -1;\n234:   if (leftContent > rightContent) return 1;\n235: \n236:   const leftId = normalizeSortText(idKeys.map((key) => left[key]).find(Boolean));\n237:   const rightId = normalizeSortText(idKeys.map((key) => right[key]).find(Boolean));\n238:   if (leftId < rightId) return -1;\n239:   if (leftId > rightId) return 1;\n240: \n241:   const leftFull = stableStringify(left);\n242:   const rightFull = stableStringify(right);\n243:   if (leftFull < rightFull) return -1;\n244:   if (leftFull > rightFull) return 1;\n245:   return 0;\n246: }\n247: \n248: function sortByContentThenId(records, idKeys) {\n249:   return [...records].sort((left, right) => compareByContentThenId(left, right, idKeys));\n250: }\n251: \n252: function addLineage(existing, label) {\n253:   if (!existing._lineages) existing._lineages = [];\n254:   if (!existing._lineages.includes(label)) existing._lineages.push(label);\n255:   existing._lineages.sort();\n256: }\n257: \n258: function mergeLineageLabels(existing, incoming, label) {\n259:   const lineages = new Set([...(existing._lineages || []), ...(incoming._lineages || []), label].filter(Boolean));\n260:   return [...lineages].sort();\n261: }\n262: \n263: function comparableRecord(record) {\n264:   const copy = { ...record };\n265:   delete copy._conflictOf;\n266:   delete copy._conflict_id;\n267:   delete copy._conflicts;\n268:   delete copy._lineages;\n269:   return copy;\n270: }\n271: \n272: function replaceRecord(target, source, lineages) {\n273:   const next = { ...source, _lineages: lineages };\n274:   for (const key of Object.keys(target)) {\n275:     delete target[key];\n276:   }\n277:   Object.assign(target, next);\n278: }\n279: \n280: function chooseCanonicalRecord(existing, incoming, idKeys) {\n281:   return compareByContentThenId(comparableRecord(incoming), comparableRecord(existing), idKeys) < 0\n282:     ? incoming\n283:     : existing;\n284: }\n285: \n286: function chooseReviewCanonicalRecord(existing, incoming, idKeys) {\n287:   const incomingRank = SEVERITY_RANK[incoming.severity] ?? 0;\n288:   const existingRank = SEVERITY_RANK[existing.severity] ?? 0;\n289:   if (incomingRank > existingRank) return incoming;\n290:   if (incomingRank < existingRank) return existing;\n291:   return chooseCanonicalRecord(existing, incoming, idKeys);\n292: }\n293: \n294: function conflictSafeRecord(record, baseId, idKey) {\n295:   const conflictId = `${baseId}--${contentDigest(record)}`;\n296:   return {\n297:     ...record,\n298:     [idKey]: conflictId,\n299:     _conflictOf: baseId,\n300:     _conflict_id: conflictId,\n301:   };\n302: }\n303: \n304: function attachConflictMarkers(records, baseId, idKey) {\n305:   if (records.length < 2) return records;\n306:   return records.map((record) => ({\n307:     ...record,\n308:     _conflicts: records\n309:       .filter((other) => other !== record)\n310:       .map((other) => ({\n311:         relation: 'CONTRADICTS',\n312:         originalId: baseId,\n313:         peerId: other[idKey],\n314:         peerLineages: other._lineages || [],\n315:         basis: 'same-id-different-content',\n316:       })),\n317:   }));\n318: }\n319: \n320: function parseBooleanOption(value) {\n321:   if (value === true) return true;\n322:   if (typeof value !== 'string') return false;\n323:   return ['1', 'true', 'yes', 'on'].includes(value.trim().toLowerCase());\n324: }\n325: \n326: function resolveMergeOptions(options = {}) {\n327:   return {\n328:     enableNearDuplicateDedup: parseBooleanOption(\n329:       options.enableNearDuplicateDedup ?? process.env.SPECKIT_FANOUT_NEAR_DUP_DEDUP,\n330:     ),\n331:   };\n332: }\n333: \n334: function createFindingBucketIndex() {\n335:   return {\n336:     buckets: [],\n337:     byContent: new Map(),\n338:     byId: new Map(),\n339:   };\n340: }\n341: \n342: function getFindingBucket(index, id, finding, enableNearDuplicateDedup) {\n343:   const contentKey = enableNearDuplicateDedup ? nearDuplicateContentKey(finding) : '';\n344:   const exactBucket = index.byId.get(id);\n345:   if (exactBucket) {\n346:     return exactBucket;\n347:   }\n348: \n349:   // Title-aware bucketing (deep-review P2-15 fix): a content key can host MORE than one\n350:   // bucket when several genuinely-distinct findings share an identical body but carry\n351:   // divergent titles. byContent maps a content key to the LIST of buckets seen for it; a\n352:   // same-body finding joins the bucket whose records its title actually matches, and\n353:   // otherwise opens a new bucket. Without this a distinct finding would share a bucket with\n354:   // a different finding and be mis-tagged as a same-id conflict variant by\n355:   // flattenFindingBucketIndex.\n356:   const candidateBuckets = contentKey ? index.byContent.get(contentKey) : undefined;\n357:   if (candidateBuckets) {\n358:     const titleMatch = enableNearDuplicateDedup\n359:       ? candidateBuckets.find((b) => b.records.some((entry) => nearDuplicateMatches(entry, finding)))\n360:       : candidateBuckets[0];\n361:     if (titleMatch) {\n362:       index.byId.set(id, titleMatch);\n363:       return titleMatch;\n364:     }\n365:   }\n366: \n367:   const bucket = { baseId: id, records: [] };\n368:   index.buckets.push(bucket);\n369:   index.byId.set(id, bucket);\n370:   if (contentKey) {\n371:     if (candidateBuckets) candidateBuckets.push(bucket);\n372:     else index.byContent.set(contentKey, [bucket]);\n373:   }\n374:   return bucket;\n375: }\n376: \n377: function flattenFindingBucketIndex(index, idKey, sortKeys) {\n378:   const records = [];\n379:   for (const { baseId, records: bucket } of index.buckets) {\n380:     const variants = sortByContentThenId(bucket, sortKeys);\n381:     if (variants.length === 1) {\n382:       records.push(variants[0]);\n383:       continue;\n384:     }\n385:     records.push(...attachConflictMarkers(\n386:       variants.map((variant) => conflictSafeRecord(variant, baseId, idKey)),\n387:       baseId,\n388:       idKey,\n389:     ));\n390:   }\n391:   return sortByContentThenId(records, sortKeys);\n392: }\n393: \n394: function addResearchFinding(bucket, finding, label, options = {}) {\n395:   const matches = options.enableNearDuplicateDedup\n396:     ? (entry) => nearDuplicateMatches(entry, finding)\n397:     : (entry) => contentIdentityKey(entry) === contentIdentityKey(finding);\n398:   const existing = bucket.find(matches);\n399:   if (existing) {\n400:     if (options.enableNearDuplicateDedup) {\n401:       replaceRecord(existing, chooseCanonicalRecord(existing, finding, ['id', 'title']), mergeLineageLabels(existing, finding, label));\n402:       return;\n403:     }\n404:     addLineage(existing, label);\n405:     return;\n406:   }\n407:   bucket.push({ ...finding, _lineages: [label] });\n408: }\n409: \n410: function addReviewFinding(bucket, finding, label, options = {}) {\n411:   const matches = options.enableNearDuplicateDedup\n412:     ? (entry) => nearDuplicateMatches(entry, finding)\n413:     : (entry) => contentIdentityKey(entry) === contentIdentityKey(finding);\n414:   const existing = bucket.find(matches);\n415:   if (!existing) {\n416:     bucket.push({ ...finding, _lineages: [label] });\n417:     return;\n418:   }\n419: \n420:   if (options.enableNearDuplicateDedup) {\n421:     replaceRecord(\n422:       existing,\n423:       chooseReviewCanonicalRecord(existing, finding, ['findingId', 'title']),\n424:       mergeLineageLabels(existing, finding, label),\n425:     );\n426:     return;\n427:   }\n428: \n429:   const incomingRank = SEVERITY_RANK[finding.severity] ?? 0;\n430:   const existingRank = SEVERITY_RANK[existing.severity] ?? 0;\n431:   if (incomingRank > existingRank) {\n432:     Object.assign(existing, {\n433:       ...finding,\n434:       _lineages: mergeLineageLabels(existing, finding, label),\n435:     });\n436:     return;\n437:   }\n438:   addLineage(existing, label);\n439: }\n440: \n441: function flattenFindingBuckets(findingById, idKey, sortKeys) {\n442:   const records = [];\n443:   for (const [baseId, bucket] of findingById) {\n444:     const variants = sortByContentThenId(bucket, sortKeys);\n445:     if (variants.length === 1) {\n446:       records.push(variants[0]);\n447:       continue;\n448:     }\n449:     records.push(...attachConflictMarkers(\n450:       variants.map((variant) => conflictSafeRecord(variant, baseId, idKey)),\n451:       baseId,\n452:       idKey,\n453:     ));\n454:   }\n455:   return sortByContentThenId(records, sortKeys);\n456: }\n457: \n458: // ─────────────────────────────────────────────────────────────────────────────\n459: // 2b. SCHEMA NORMALIZATION\n460: // ─────────────────────────────────────────────────────────────────────────────\n461: \n462: /**\n463:  * Normalize a registry object so that the canonical findings key is populated,\n464:  * tolerating known aliases (e.g. `findings` → `keyFindings` for research,\n465:  * `findings` → `openFindings` for review).\n466:  *\n467:  * Returns { registry, warnings } where warnings is an array of structured\n468:  * schema_mismatch events for every alias hit or unusable-registry skip.\n469:  *\n470:  * @param {object|null} registry\n471:  * @param {{ canonicalKey: string, aliases: Record<string, string>, lineage: string }} opts\n472:  * @returns {{ registry: object|null, warnings: object[] }}\n473:  */\n474: function normalizeRegistrySchema(registry, { canonicalKey, aliases, lineage }) {\n475:   if (!registry) return { registry, warnings: [] };\n476:   const warnings = [];\n477: \n478:   // If canonical key is already present and an array, nothing to do.\n479:   if (Array.isArray(registry[canonicalKey])) {\n480:     return { registry, warnings };\n481:   }\n482: \n483:   // Try each alias in priority order.\n484:   for (const [aliasKey, targetKey] of Object.entries(aliases)) {\n485:     if (Array.isArray(registry[aliasKey])) {\n486:       // Alias found — coerce to canonical key.\n487:       registry[targetKey] = registry[aliasKey];\n488:       warnings.push({\n489:         type: 'schema_mismatch',\n490:         severity: 'warn',\n491:         lineage,\n492:         message: `Registry uses non-canonical key \"${aliasKey}\" instead of \"${targetKey}\"; coerced ${registry[aliasKey].length} entries.`,\n493:         aliasKey,\n494:         canonicalKey: targetKey,\n495:         coercedCount: registry[aliasKey].length,\n496:       });\n497:       return { registry, warnings };\n498:     }\n499:   }\n500: \n501:   // No usable findings array found — registry will be skipped.\n502:   // We cannot count entries that don't exist, but report the skip.\n503:   warnings.push({\n504:     type: 'schema_mismatch',\n505:     severity: 'warn',\n506:     lineage,\n507:     message: `Registry has no usable \"${canonicalKey}\" array (checked aliases: ${Object.keys(aliases).join(', ')}); lineage findings will be skipped.`,\n508:     aliasKey: null,\n509:     canonicalKey,\n510:     coercedCount: 0,\n511:   });\n512: \n513:   return { registry, warnings };\n514: }\n515: \n516: // ─────────────────────────────────────────────────────────────────────────────\n517: // 3. RESEARCH MERGE\n518: // ─────────────────────────────────────────────────────────────────────────────\n519: \n520: /**\n521:  * Merge research findings registries from all lineages.\n522:  * Deduplicates by findingId; cross-model attribution via lineage labels.\n523:  * Returns the merged registry object.\n524:  */\n525: function mergeResearchRegistries(lineageData, options = {}) {\n526:   const mergeOptions = resolveMergeOptions(options);\n527:   const findingById = mergeOptions.enableNearDuplicateDedup ? createFindingBucketIndex() : new Map();\n528:   const schemaWarnings = [];\n529: \n530:   for (const { label, registry: rawRegistry } of lineageData) {\n531:     const { registry, warnings } = normalizeRegistrySchema(rawRegistry, {\n532:       canonicalKey: 'keyFindings',\n533:       aliases: { findings: 'keyFindings' },\n534:       lineage: label,\n535:     });\n536:     for (const w of warnings) {\n537:       schemaWarnings.push(w);\n538:       process.stderr.write(JSON.stringify(w) + '\\n');\n539:     }\n540:     if (!registry || !Array.isArray(registry.keyFindings)) continue;\n541:     for (const finding of registry.keyFindings) {\n542:       const id = finding.id || finding.title;\n543:       if (!id) continue;\n544:       if (mergeOptions.enableNearDuplicateDedup) {\n545:         addResearchFinding(getFindingBucket(findingById, id, finding, true).records, finding, label, mergeOptions);\n546:       } else {\n547:         if (!findingById.has(id)) findingById.set(id, []);\n548:         addResearchFinding(findingById.get(id), finding, label, mergeOptions);\n549:       }\n550:     }\n551:   }\n552: \n553:   const mergedFindings = mergeOptions.enableNearDuplicateDedup\n554:     ? flattenFindingBucketIndex(findingById, 'id', ['id', 'title'])\n555:     : flattenFindingBuckets(findingById, 'id', ['id', 'title']);\n556:   const openQuestionsById = new Map();\n557:   const resolvedQuestionsById = new Map();\n558:   const ruledOutById = new Map();\n559: \n560:   for (const { label, registry } of lineageData) {\n561:     if (!registry) continue;\n562:     for (const q of registry.openQuestions ?? []) {\n563:       const id = q.id || q.question || q.text;\n564:       if (!id) continue;\n565:       if (!openQuestionsById.has(id)) openQuestionsById.set(id, { ...q, _lineages: [label] });\n566:       else {\n567:         const existing = openQuestionsById.get(id);\n568:         addLineage(existing, label);\n569:       }\n570:     }\n571:     // Resolved questions are produced per-lineage by the research reducer but\n572:     // were previously dropped here, under-reporting answered coverage in the\n573:     // merged registry. Collect them with the same id/_lineages discipline.\n574:     for (const q of registry.resolvedQuestions ?? []) {\n575:       const id = q.id || q.question || q.text;\n576:       if (!id) continue;\n577:       if (!resolvedQuestionsById.has(id)) resolvedQuestionsById.set(id, { ...q, _lineages: [label] });\n578:       else {\n579:         const existing = resolvedQuestionsById.get(id);\n580:         addLineage(existing, label);\n581:       }\n582:     }\n583:     for (const d of registry.ruledOutDirections ?? []) {\n584:       const id = d.id || d.direction;\n585:       if (!id) continue;\n586:       if (!ruledOutById.has(id)) ruledOutById.set(id, { ...d, _lineages: [label] });\n587:     }\n588:   }\n589: \n590:   const totalIters = lineageData.reduce((sum, { registry }) => {\n591:     return sum + (registry?.metrics?.iterationsCompleted ?? 0);\n592:   }, 0);\n593: \n594:   const avgConvergence =\n595:     lineageData.length > 0\n596:       ? lineageData.reduce((sum, { registry }) => sum + (registry?.metrics?.convergenceScore ?? 0), 0) /\n597:         lineageData.length\n598:       : 0;\n599: \n600:   return {\n601:     mergedFrom: lineageData.map(({ label }) => label).sort(),\n602:     openQuestions: sortByContentThenId([...openQuestionsById.values()], ['id', 'question', 'text']),\n603:     resolvedQuestions: sortByContentThenId([...resolvedQuestionsById.values()], ['id', 'question', 'text']),\n604:     keyFindings: mergedFindings,\n605:     ruledOutDirections: sortByContentThenId([...ruledOutById.values()], ['id', 'direction']),\n606:     metrics: {\n607:       iterationsCompleted: totalIters,\n608:       openQuestions: openQuestionsById.size,\n609:       resolvedQuestions: resolvedQuestionsById.size,\n610:       keyFindings: mergedFindings.length,\n611:       convergenceScore: Math.round(avgConvergence * 1000) / 1000,\n612:       coverageBySources: {},\n613:     },\n614:     ...(schemaWarnings.length > 0 ? { schema_mismatch: schemaWarnings } : {}),\n615:   };\n616: }\n617: \n618: // ─────────────────────────────────────────────────────────────────────────────\n619: // 4. REVIEW MERGE  (strongest-restriction)\n620: // ─────────────────────────────────────────────────────────────────────────────\n621: \n622: /**\n623:  * Merge review findings registries with strongest-restriction severity rollup.\n624:  * Any lineage with an active P0 finding causes the merged result to be FAIL.\n625:  * Deduplication is by findingId; cross-lineage P0 wins if any lineage reports it.\n626:  */\n627: function mergeReviewRegistries(lineageData, options = {}) {\n628:   const mergeOptions = resolveMergeOptions(options);\n629:   const findingById = mergeOptions.enableNearDuplicateDedup ? createFindingBucketIndex() : new Map();\n630:   const schemaWarnings = [];\n631: \n632:   for (const { label, registry: rawRegistry } of lineageData) {\n633:     const { registry, warnings } = normalizeRegistrySchema(rawRegistry, {\n634:       canonicalKey: 'openFindings',\n635:       aliases: { findings: 'openFindings' },\n636:       lineage: label,\n637:     });\n638:     for (const w of warnings) {\n639:       schemaWarnings.push(w);\n640:       process.stderr.write(JSON.stringify(w) + '\\n');\n641:     }\n642:     if (!registry || !Array.isArray(registry.openFindings)) continue;\n643:     for (const finding of registry.openFindings) {\n644:       if (finding.status !== 'active') continue;\n645:       const id = finding.findingId || finding.title;\n646:       if (!id) continue;\n647:       if (mergeOptions.enableNearDuplicateDedup) {\n648:         addReviewFinding(getFindingBucket(findingById, id, finding, true).records, finding, label, mergeOptions);\n649:       } else {\n650:         if (!findingById.has(id)) findingById.set(id, []);\n651:         addReviewFinding(findingById.get(id), finding, label, mergeOptions);\n652:       }\n653:     }\n654:   }\n655: \n656:   // Resolved findings are tracked separately per lineage and were previously\n657:   // dropped here, zeroing the merged resolved coverage. Collect them by id with\n658:   // _lineages attribution, without touching open-finding/verdict semantics.\n659:   const resolvedFindingById = mergeOptions.enableNearDuplicateDedup ? createFindingBucketIndex() : new Map();\n660:   for (const { label, registry } of lineageData) {\n661:     if (!registry || !Array.isArray(registry.resolvedFindings)) continue;\n662:     for (const finding of registry.resolvedFindings) {\n663:       const id = finding.findingId || finding.title;\n664:       if (!id) continue;\n665:       if (mergeOptions.enableNearDuplicateDedup) {\n666:         addReviewFinding(getFindingBucket(resolvedFindingById, id, finding, true).records, finding, label, mergeOptions);\n667:       } else if (resolvedFindingById.has(id)) {\n668:         addLineage(resolvedFindingById.get(id), label);\n669:       } else {\n670:         resolvedFindingById.set(id, { ...finding, _lineages: [label] });\n671:       }\n672:     }\n673:   }\n674:   const mergedResolvedFindings = mergeOptions.enableNearDuplicateDedup\n675:     ? flattenFindingBucketIndex(resolvedFindingById, 'findingId', ['findingId', 'title'])\n676:     : sortByContentThenId([...resolvedFindingById.values()], ['findingId', 'title']);\n677: \n678:   const mergedFindings = mergeOptions.enableNearDuplicateDedup\n679:     ? flattenFindingBucketIndex(findingById, 'findingId', ['findingId', 'title'])\n680:     : flattenFindingBuckets(findingById, 'findingId', ['findingId', 'title']);\n681:   const activeP0 = mergedFindings.filter((f) => f.severity === 'P0' && f.status === 'active').length;\n682:   const activeP1 = mergedFindings.filter((f) => f.severity === 'P1' && f.status === 'active').length;\n683:   const activeP2 = mergedFindings.filter((f) => f.severity === 'P2' && f.status === 'active').length;\n684: \n685:   // Strongest-restriction verdict\n686:   let mergedVerdict;\n687:   if (activeP0 > 0) {\n688:     mergedVerdict = 'FAIL';\n689:   } else if (activeP1 > 0) {\n690:     mergedVerdict = 'CONDITIONAL';\n691:   } else {\n692:     mergedVerdict = 'PASS';\n693:   }\n694: \n695:   return {\n696:     mergedFrom: lineageData.map(({ label }) => label).sort(),\n697:     mergedVerdict,\n698:     openFindings: mergedFindings,\n699:     resolvedFindings: mergedResolvedFindings,\n700:     findingsBySeverity: { P0: activeP0, P1: activeP1, P2: activeP2 },\n701:     openFindingsCount: mergedFindings.length,\n702:     resolvedFindingsCount: mergedResolvedFindings.length,\n703:     activeP0,\n704:     activeP1,\n705:     activeP2,\n706:     ...(schemaWarnings.length > 0 ? { schema_mismatch: schemaWarnings } : {}),\n707:   };\n708: }\n709: \n710: // ─────────────────────────────────────────────────────────────────────────────\n711: // 5. ATTRIBUTION\n712: // ─────────────────────────────────────────────────────────────────────────────\n713: \n714: /**\n715:  * Build fanout-attribution.md summarizing per-lineage convergence, iters, salvage, model.\n716:  */\n717: function buildAttributionMd(lineageData, loopType) {\n718:   const lines = [\n719:     `# Fan-Out Attribution`,\n720:     ``,\n721:     `Loop type: **${loopType}**  |  Lineage count: **${lineageData.length}**`,\n722:     ``,\n723:     `| Label | Kind | Model | Iterations | Convergence | Salvaged | Verdict |`,\n724:     `|-------|------|-------|-----------|-------------|----------|---------|`,\n725:   ];\n726: \n727:   for (const { label, registry, stateRecords, kind, model } of lineageData) {\n728:     const iters = stateRecords.filter((r) => r.type === 'iteration').length;\n729:     const salvage = stateRecords.filter((r) => r.type === 'event' && r.event === 'salvaged_from_stdout').length;\n730:     const convergenceScore = registry?.metrics?.convergenceScore ?? registry?.convergenceScore ?? 'n/a';\n731:     const verdict =\n732:       loopType === 'review'\n733:         ? registry?.findingsBySeverity?.P0 > 0\n734:           ? 'FAIL'\n735:           : registry?.findingsBySeverity?.P1 > 0\n736:           ? 'CONDITIONAL'\n737:           : 'PASS'\n738:         : 'n/a';\n739:     lines.push(`| ${label} | ${kind ?? 'unknown'} | ${model ?? 'default'} | ${iters} | ${convergenceScore} | ${salvage} | ${verdict} |`);\n740:   }\n741: \n742:   lines.push('');\n743:   return lines.join('\\n');\n744: }\n745: \n746: // ─────────────────────────────────────────────────────────────────────────────\n747: // 6. MAIN\n748: // ─────────────────────────────────────────────────────────────────────────────\n749: \n750: /**\n751:  * Reconstruct a minimal review findings registry from a lineage state log.\n752:  *\n753:  * Leaf-only review lineages may carry active findings only in their state log\n754:  * iteration records (`findingDetails`), with no registry file on disk. This maps\n755:  * those findingDetails into the openFindings shape mergeReviewRegistries consumes,\n756:  * so registry-absent lineages are not silently dropped from merge/synthesis.\n757:  *\n758:  * @param {Array<Object>} stateRecords - Parsed JSONL state records.\n759:  * @param {string} label - Lineage label, for attribution.\n760:  * @returns {{openFindings:Array,Object}|null} Reconstructed registry, or null when no findings exist.\n761:  */\n762: function reconstructReviewRegistryFromState(stateRecords, label) {\n763:   if (!Array.isArray(stateRecords)) return null;\n764:   const openFindings = [];\n765:   const resolvedFindings = [];\n766:   for (const record of stateRecords) {\n767:     if (!record || record.type !== 'iteration' || !Array.isArray(record.findingDetails)) continue;\n768:     for (const detail of record.findingDetails) {\n769:       if (!detail || typeof detail !== 'object') continue;\n770:       const id = detail.id || detail.findingId || detail.title;\n771:       if (!id) continue;\n772:       const isActive = (detail.disposition || detail.status || 'active') === 'active';\n773:       const mapped = {\n774:         findingId: id,\n775:         title: detail.title || id,\n776:         severity: detail.severity || 'P2',\n777:         status: isActive ? 'active' : 'resolved',\n778:         ...(detail.dimension ? { dimension: detail.dimension } : {}),\n779:         ...(detail.file ? { file: detail.file } : {}),\n780:         ...(detail.recommendation ? { recommendation: detail.recommendation } : {}),\n781:         _lineages: [label],\n782:         _reconstructed_from_state: true,\n783:       };\n784:       if (isActive) openFindings.push(mapped);\n785:       else resolvedFindings.push(mapped);\n786:     }\n787:   }\n788:   if (openFindings.length === 0 && resolvedFindings.length === 0) return null;\n789:   const bySeverity = {\n790:     P0: openFindings.filter((f) => f.severity === 'P0').length,\n791:     P1: openFindings.filter((f) => f.severity === 'P1').length,\n792:     P2: openFindings.filter((f) => f.severity === 'P2').length,\n793:   };\n794:   return { openFindings, resolvedFindings, findingsBySeverity: bySeverity, _reconstructed: true };\n795: }\n796: \n797: function firstNonEmptyString(values) {\n798:   for (const value of values) {\n799:     if (typeof value === 'string' && value.trim() !== '') return value.trim();\n800:     if (value && typeof value === 'object' && !Array.isArray(value)) {\n801:       const objectText = firstNonEmptyString([value.title, value.summary, value.text, value.finding, value.description]);\n802:       if (objectText) return objectText;\n803:     }\n804:   }\n805:   return '';\n806: }\n807: \n808: function normalizeResearchFindingCandidate(candidate, record, index) {\n809:   const run = Number.isFinite(Number(record.run ?? record.iteration)) ? Math.floor(Number(record.run ?? record.iteration)) : 0;\n810:   if (typeof candidate === 'string') {\n811:     const text = candidate.trim();\n812:     if (!text) return null;\n813:     return {\n814:       id: `state-finding-${run}-${index + 1}-${crypto.createHash('sha256').update(text).digest('hex').slice(0, 12)}`,\n815:       title: text,\n816:       text,\n817:       addedAtIteration: run,\n818:       _reconstructed_from_state: true,\n819:     };\n820:   }\n821:   if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return null;\n822:   const text = firstNonEmptyString([candidate.title, candidate.summary, candidate.text, candidate.finding, candidate.description]);\n823:   if (!text) return null;\n824:   return {\n825:     id: candidate.id || candidate.findingId || `state-finding-${run}-${index + 1}-${crypto.createHash('sha256').update(text).digest('hex').slice(0, 12)}`,\n826:     title: candidate.title || text,\n827:     ...(candidate.summary ? { summary: candidate.summary } : {}),\n828:     ...(candidate.text ? { text: candidate.text } : { text }),\n829:     ...(candidate.confidence ? { confidence: candidate.confidence } : {}),\n830:     addedAtIteration: candidate.addedAtIteration ?? run,\n831:     _reconstructed_from_state: true,\n832:   };\n833: }\n834: \n835: function researchCandidatesFromIteration(record) {\n836:   if (!record || record.type !== 'iteration') return [];\n837:   const structured = [record.keyFindings, record.findings, record.findingDetails]\n838:     .find((value) => Array.isArray(value) && value.length > 0);\n839:   if (Array.isArray(structured)) {\n840:     return structured;\n841:   }\n842: \n843:   const findingsCount = Number(record.findingsCount);\n844:   if (!Number.isFinite(findingsCount) || findingsCount <= 0) return [];\n845:   const run = Number.isFinite(Number(record.run ?? record.iteration)) ? Math.floor(Number(record.run ?? record.iteration)) : 0;\n846:   const narrative = firstNonEmptyString([\n847:     record.summary,\n848:     record.findingsSummary,\n849:     record.focus,\n850:     record.nextFocus,\n851:     record.reflection,\n852:   ]);\n853:   return [{\n854:     id: `state-finding-${run}-1-${crypto.createHash('sha256').update(narrative || String(run)).digest('hex').slice(0, 12)}`,\n855:     title: narrative || `Iteration ${run} recorded ${Math.floor(findingsCount)} finding(s)`,\n856:     summary: narrative || `State log recorded ${Math.floor(findingsCount)} finding(s) but no structured finding text.`,\n857:     addedAtIteration: run,\n858:   }];\n859: }\n860: \n861: /**\n862:  * Reconstruct a minimal research findings registry from a lineage state log.\n863:  *\n864:  * Leaf-only research lineages may have substantive iteration records but no\n865:  * registry file on disk. This maps state-log findings into keyFindings so the\n866:  * research merge does not silently drop a registry-absent lineage.\n867:  *\n868:  * @param {Array<Object>} stateRecords - Parsed JSONL state records.\n869:  * @param {string} label - Lineage label, for attribution.\n870:  * @returns {{keyFindings:Array,Object}|null} Reconstructed registry, or null when no findings exist.\n871:  */\n872: function reconstructResearchRegistryFromState(stateRecords, label) {\n873:   if (!Array.isArray(stateRecords)) return null;\n874:   const keyFindings = [];\n875:   for (const record of stateRecords) {\n876:     const candidates = researchCandidatesFromIteration(record);\n877:     candidates.forEach((candidate, index) => {\n878:       const mapped = normalizeResearchFindingCandidate(candidate, record, index);\n879:       if (!mapped) return;\n880:       keyFindings.push({ ...mapped, _lineages: [label] });\n881:     });\n882:   }\n883:   if (keyFindings.length === 0) return null;\n884:   const iterationsCompleted = stateRecords.filter((record) => record?.type === 'iteration').length;\n885:   const latestIteration = stateRecords.filter((record) => record?.type === 'iteration').at(-1);\n886:   const convergenceScore = latestIteration?.convergenceSignals?.compositeStop\n887:     ?? latestIteration?.newInfoRatio\n888:     ?? 0;\n889:   return {\n890:     keyFindings,\n891:     openQuestions: [],\n892:     resolvedQuestions: [],\n893:     ruledOutDirections: [],\n894:     metrics: {\n895:       iterationsCompleted,\n896:       openQuestions: 0,\n897:       resolvedQuestions: 0,\n898:       keyFindings: keyFindings.length,\n899:       convergenceScore,\n900:       coverageBySources: {},\n901:     },\n902:     _reconstructed: true,\n903:   };\n904: }\n905: \n906: async function main() {\n907:   const { writeStateAtomic, writeTextAtomic } = await import('../lib/deep-loop/atomic-state.ts');\n908:   const args = parseArgs();\n909:   const loopType = ensureString(args, 'loopType');\n910:   if (loopType !== 'research' && loopType !== 'review' && loopType !== 'context') {\n911:     throw inputError('loopType must be \"research\", \"review\", or \"context\"');\n912:   }\n913:   const artifactDir = ensureString(args, 'artifactDir');\n914:   const lineagesDir = path.join(artifactDir, 'lineages');\n915: \n916:   if (!fs.existsSync(lineagesDir)) {\n917:     jsonOut({ status: 'ok', message: 'no lineages directory — nothing to merge', merged: 0 });\n918:     return;\n919:   }\n920: \n921:   const labelDirs = fs.readdirSync(lineagesDir)\n922:     .filter((entry) => fs.statSync(path.join(lineagesDir, entry)).isDirectory())\n923:     .sort();\n924: \n925:   if (labelDirs.length === 0) {\n926:     jsonOut({ status: 'ok', message: 'no lineage subdirs found', merged: 0 });\n927:     return;\n928:   }\n929: \n930:   // Load per-lineage data\n931:   const registryName =\n932:     loopType === 'review' ? 'deep-review-findings-registry.json' : 'deep-research-findings-registry.json';\n933:   const stateLogName = loopType === 'review' ? 'deep-review-state.jsonl' : 'deep-research-state.jsonl';\n934:   const summaryPath = path.join(artifactDir, 'orchestration-summary.json');\n935:   const orchestrationSummary = tryReadJson(summaryPath) ?? {};\n936: \n937:   const lineageData = labelDirs.map((label) => {\n938:     const lineageDir = path.join(lineagesDir, label);\n939:     let registry = tryReadJson(path.join(lineageDir, registryName));\n940:     const stateRecords = readStateLog(path.join(lineageDir, stateLogName));\n941:     // Leaf-only review/research lineages (orchestrator-managed direct-leaf convention) may carry\n942:     // active findings only in their state log's findingDetails, with no registry file.\n943:     // Without a registry, such a lineage was silently skipped by the registry-only merge,\n944:     // dropping its findings from synthesis. Reconstruct a minimal registry from the\n945:     // state log so leaf-only lineages reach merge without a separate reducer step.\n946:     if (!registry && loopType === 'review') {\n947:       registry = reconstructReviewRegistryFromState(stateRecords, label);\n948:     }\n949:     if (!registry && loopType === 'research') {\n950:       registry = reconstructResearchRegistryFromState(stateRecords, label);\n951:     }\n952:     // Infer kind/model from state log executor records\n953:     const executorRecord = stateRecords.find((r) => r.type === 'event' && r.event === 'executor_start');\n954:     return {\n955:       label,\n956:       lineageDir,\n957:       registry,\n958:       stateRecords,\n959:       kind: executorRecord?.kind ?? orchestrationSummary?.[label]?.kind ?? 'unknown',\n960:       model: executorRecord?.model ?? orchestrationSummary?.[label]?.model ?? 'unknown',\n961:     };\n962:   });\n963: \n964:   const lineagesWithRegistry = lineageData.filter((d) => d.registry !== null);\n965: \n966:   let mergedRegistry;\n967:   if (loopType === 'review') {\n968:     mergedRegistry = mergeReviewRegistries(lineagesWithRegistry, resolveMergeOptions(args));\n969:   } else {\n970:     mergedRegistry = mergeResearchRegistries(lineagesWithRegistry, resolveMergeOptions(args));\n971:   }\n972: \n973:   // Write merged registry to base artifact dir (replacing single-executor path).\n974:   // Atomic temp+fsync+rename so a mid-write kill never hands synthesis a\n975:   // truncated registry — readers see the prior file or the complete new one.\n976:   const mergedRegistryPath = path.join(artifactDir, registryName);\n977:   writeStateAtomic(mergedRegistryPath, mergedRegistry);\n978: \n979:   // Write attribution markdown atomically (same torn-write guarantee; text, not JSON).\n980:   const attributionPath = path.join(artifactDir, 'fanout-attribution.md');\n981:   writeTextAtomic(attributionPath, buildAttributionMd(lineageData, loopType));\n982: \n983:   jsonOut({\n984:     status: 'ok',\n985:     loop_type: loopType,\n986:     merged_lineages: lineagesWithRegistry.length,\n987:     skipped_no_registry: lineageData.length - lineagesWithRegistry.length,\n988:     merged_registry_path: mergedRegistryPath,\n989:     attribution_path: attributionPath,\n990:     ...(loopType === 'review'\n991:       ? { merged_verdict: mergedRegistry.mergedVerdict, active_p0: mergedRegistry.activeP0, active_p1: mergedRegistry.activeP1 }\n992:       : { key_findings: mergedRegistry.keyFindings?.length ?? 0 }),\n993:   });\n994: }\n995: \n996: // Exports for unit testing\n997: module.exports = { mergeResearchRegistries, mergeReviewRegistries, buildAttributionMd, reconstructReviewRegistryFromState, reconstructResearchRegistryFromState, normalizeRegistrySchema };\n998: \n999: if (require.main === module) {\n1000:   main().catch((err) => {\n1001:     const code = err && err.code === 'INPUT_VALIDATION' ? 3 : 1;\n1002:     jsonOut({\n1003:       status: 'error',\n1004:       error: err instanceof Error ? err.message : String(err),\n1005:       code: err && err.code ? err.code : 'SCRIPT_ERROR',\n1006:     });\n1007:     if (code === 1) {\n1008:       process.stderr.write(\n1009:         JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\\n',\n1010:       );\n1011:     }\n1012:     process.exit(code);\n1013:   });\n1014: }\n\n(End of file - total 1014 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out Cross-Lineage Merge                          ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--loop-type, --artifact-dir).                          ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n// ║                                                                          ║\n// ║ Reads every {artifact-dir}/lineages/{label}/ sub-packet and produces:   ║\n// ║   research: deduplicated deep-research-findings-registry.json +          ║\n// ║             fanout-attribution.md                                        ║\n// ║   review:   severity-rollup deep-review-findings-registry.json           ║\n// ║             (strongest-restriction: any lineage P0 → merged FAIL) +     ║\n// ║             fanout-attribution.md                                        ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst crypto = require('node:crypto');\nconst fs = require('node:fs');\nconst path = require('node:path');","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out Cross-Lineage Merge                          ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Input:  CLI args (--loop-type, --artifact-dir).                          ║\n// ║ Output: JSON to stdout.                                                  ║\n// ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n// ║                                                                          ║\n// ║ Reads every {artifact-dir}/lineages/{label}/ sub-packet and produces:   ║\n// ║   research: deduplicated deep-research-findings-registry.json +          ║\n// ║             fanout-attribution.md                                        ║\n// ║   review:   severity-rollup deep-review-findings-registry.json           ║\n// ║             (strongest-restriction: any lineage P0 → merged FAIL) +     ║\n// ║             fanout-attribution.md                                        ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst crypto = require('node:crypto');\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { spawnSync } = require('node:child_process');\n\nconst SEVERITY_RANK = { P0: 3, P1: 2, P2: 1 };\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\n\n// The merged registry and attribution share the runtime's atomic-state helpers,\n// which are TypeScript ESM. Re-exec once under the tsx loader so the dynamic\n// import below resolves them; mirrors convergence.cjs. Only the CLI entrypoint\n// re-execs — module consumers (unit tests) import the pure helpers directly.\nif (require.main === module && process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n  const child = spawnSync(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      encoding: 'utf8',\n    },\n  );\n  if (child.stdout) process.stdout.write(child.stdout);\n  if (child.stderr) process.stderr.write(child.stderr);\n  process.exit(child.status === null ? 1 : child.status);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\nfunction parseArgs(argv = process.argv.slice(2)) {\n  const args = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      args[key] = true;\n    } else {\n      args[key] = next;\n      i += 1;\n    }\n  }\n  return args;\n}\n\nfunction ensureString(args, key) {\n  if (!args[key] || typeof args[key] !== 'string') {\n    throw inputError(`${key} is required`);\n  }\n  return args[key];\n}\n\nfunction tryReadJson(filePath) {\n  if (!fs.existsSync(filePath)) return null;\n  try {\n    return JSON.parse(fs.readFileSync(filePath, 'utf8'));\n  } catch {\n    return null;\n  }\n}\n\nfunction readStateLog(stateLogPath) {\n  if (!fs.existsSync(stateLogPath)) return [];\n  const lines = fs.readFileSync(stateLogPath, 'utf8').trim().split('\\n').filter(Boolean);\n  return lines.flatMap((line) => {\n    try {\n      return [JSON.parse(line)];\n    } catch {\n      return [];\n    }\n  });\n}\n\nfunction stableValue(value) {\n  if (Array.isArray(value)) {\n    return value.map(stableValue);\n  }\n  if (value && typeof value === 'object') {\n    const sorted = {};\n    for (const key of Object.keys(value).sort()) {\n      sorted[key] = stableValue(value[key]);\n    }\n    return sorted;\n  }\n  return value;\n}\n\nfunction stableStringify(value) {\n  return JSON.stringify(stableValue(value));\n}\n\nfunction normalizeSortText(value) {\n  return typeof value === 'string' ? value.trim().toLowerCase().replace(/\\s+/g, ' ') : '';\n}\n\nfunction contentSortKey(record) {\n  const durableText = [\n    record.title,\n    record.summary,\n    record.description,\n    record.finding,\n    record.question,\n    record.direction,\n    record.severity,\n    record.status,\n  ].map(normalizeSortText).filter(Boolean).join('\\u0001');\n  return durableText || stableStringify({ ...record, _lineages: undefined });\n}\n\nfunction contentIdentityKey(record) {\n  const durableText = [\n    record.title,\n    record.summary,\n    record.description,\n    record.finding,\n    record.question,\n    record.direction,\n  ].map(normalizeSortText).filter(Boolean).join('\\u0001');\n  return durableText || stableStringify({\n    ...record,\n    _conflictOf: undefined,\n    _conflict_id: undefined,\n    _conflicts: undefined,\n    _lineages: undefined,\n    severity: undefined,\n    status: undefined,\n  });\n}\n\nfunction nearDuplicateContentKey(record) {\n  const durableText = [\n    record.summary,\n    record.description,\n    record.finding,\n    record.question,\n    record.direction,\n  ].map(normalizeSortText).filter(Boolean).join('\\u0001');\n  return durableText || contentIdentityKey(record);\n}\n\n// Stopwords stripped before comparing titles so the overlap signal keys on the content\n// nouns/verbs that distinguish one finding from another, not on filler.\nconst TITLE_STOPWORDS = new Set([\n  'a', 'an', 'the', 'in', 'on', 'at', 'to', 'of', 'for', 'and', 'or', 'with', 'without',\n  'is', 'are', 'was', 'were', 'be', 'no', 'not', 'so', 'that', 'this', 'it', 'its', 'as',\n  'by', 'from', 'into', 'after', 'before', 'when', 'where', 'which', 'has', 'have',\n]);\n\nfunction titleContentTokens(record) {\n  const raw = typeof record.title === 'string' ? record.title : '';\n  return new Set(\n    normalizeSortText(raw)\n      .split(/[^a-z0-9]+/)\n      .filter((tok) => tok && !TITLE_STOPWORDS.has(tok)),\n  );\n}\n\n// Jaccard overlap of two title token sets. 1 when both are empty (no title signal to\n// distinguish on → fall back to body-only collapse, the original contract for title-less\n// findings).\nfunction titleOverlap(aTokens, bTokens) {\n  if (aTokens.size === 0 && bTokens.size === 0) return 1;\n  if (aTokens.size === 0 || bTokens.size === 0) return 0;\n  let shared = 0;\n  for (const tok of aTokens) if (bTokens.has(tok)) shared += 1;\n  const union = aTokens.size + bTokens.size - shared;\n  return union === 0 ? 1 : shared / union;\n}\n\n// Below this title overlap two same-body findings are treated as DISTINCT (their titles\n// name substantively different things — e.g. a generic \"missing auth check\" body whose\n// titles name two different endpoints with no shared subject). At or above it the titles\n// are paraphrases of one point that share their subject noun, and the same-body findings\n// collapse, preserving the designed-for restatement collapse. The threshold is low because\n// legitimate restatement titles often share only the one key subject noun (\"cache\",\n// \"retry\") while genuinely-distinct titles share no content token at all.\nconst TITLE_DISTINCT_OVERLAP_THRESHOLD = 0.15;\n\n// Title-aware near-dup match (deep-review P2-15 fix): two findings are near-duplicates\n// only if their body-content key matches AND their titles are not substantively divergent.\n// This closes the title blind spot — genuinely-distinct findings that share an identical\n// body but carry different distinguishing titles no longer collapse — without breaking the\n// designed-for collapse of restatements that share a body and paraphrase the same title.\nfunction nearDuplicateMatches(a, b) {\n  if (nearDuplicateContentKey(a) !== nearDuplicateContentKey(b)) return false;\n  return titleOverlap(titleContentTokens(a), titleContentTokens(b)) >= TITLE_DISTINCT_OVERLAP_THRESHOLD;\n}\n\nfunction contentDigest(record) {\n  return crypto.createHash('sha256').update(contentIdentityKey(record)).digest('hex').slice(0, 12);\n}\n\nfunction compareByContentThenId(left, right, idKeys) {\n  const leftContent = contentSortKey(left);\n  const rightContent = contentSortKey(right);\n  if (leftContent < rightContent) return -1;\n  if (leftContent > rightContent) return 1;\n\n  const leftId = normalizeSortText(idKeys.map((key) => left[key]).find(Boolean));\n  const rightId = normalizeSortText(idKeys.map((key) => right[key]).find(Boolean));\n  if (leftId < rightId) return -1;\n  if (leftId > rightId) return 1;\n\n  const leftFull = stableStringify(left);\n  const rightFull = stableStringify(right);\n  if (leftFull < rightFull) return -1;\n  if (leftFull > rightFull) return 1;\n  return 0;\n}\n\nfunction sortByContentThenId(records, idKeys) {\n  return [...records].sort((left, right) => compareByContentThenId(left, right, idKeys));\n}\n\nfunction addLineage(existing, label) {\n  if (!existing._lineages) existing._lineages = [];\n  if (!existing._lineages.includes(label)) existing._lineages.push(label);\n  existing._lineages.sort();\n}\n\nfunction mergeLineageLabels(existing, incoming, label) {\n  const lineages = new Set([...(existing._lineages || []), ...(incoming._lineages || []), label].filter(Boolean));\n  return [...lineages].sort();\n}\n\nfunction comparableRecord(record) {\n  const copy = { ...record };\n  delete copy._conflictOf;\n  delete copy._conflict_id;\n  delete copy._conflicts;\n  delete copy._lineages;\n  return copy;\n}\n\nfunction replaceRecord(target, source, lineages) {\n  const next = { ...source, _lineages: lineages };\n  for (const key of Object.keys(target)) {\n    delete target[key];\n  }\n  Object.assign(target, next);\n}\n\nfunction chooseCanonicalRecord(existing, incoming, idKeys) {\n  return compareByContentThenId(comparableRecord(incoming), comparableRecord(existing), idKeys) < 0\n    ? incoming\n    : existing;\n}\n\nfunction chooseReviewCanonicalRecord(existing, incoming, idKeys) {\n  const incomingRank = SEVERITY_RANK[incoming.severity] ?? 0;\n  const existingRank = SEVERITY_RANK[existing.severity] ?? 0;\n  if (incomingRank > existingRank) return incoming;\n  if (incomingRank < existingRank) return existing;\n  return chooseCanonicalRecord(existing, incoming, idKeys);\n}\n\nfunction conflictSafeRecord(record, baseId, idKey) {\n  const conflictId = `${baseId}--${contentDigest(record)}`;\n  return {\n    ...record,\n    [idKey]: conflictId,\n    _conflictOf: baseId,\n    _conflict_id: conflictId,\n  };\n}\n\nfunction attachConflictMarkers(records, baseId, idKey) {\n  if (records.length < 2) return records;\n  return records.map((record) => ({\n    ...record,\n    _conflicts: records\n      .filter((other) => other !== record)\n      .map((other) => ({\n        relation: 'CONTRADICTS',\n        originalId: baseId,\n        peerId: other[idKey],\n        peerLineages: other._lineages || [],\n        basis: 'same-id-different-content',\n      })),\n  }));\n}\n\nfunction parseBooleanOption(value) {\n  if (value === true) return true;\n  if (typeof value !== 'string') return false;\n  return ['1', 'true', 'yes', 'on'].includes(value.trim().toLowerCase());\n}\n\nfunction resolveMergeOptions(options = {}) {\n  return {\n    enableNearDuplicateDedup: parseBooleanOption(\n      options.enableNearDuplicateDedup ?? process.env.SPECKIT_FANOUT_NEAR_DUP_DEDUP,\n    ),\n  };\n}\n\nfunction createFindingBucketIndex() {\n  return {\n    buckets: [],\n    byContent: new Map(),\n    byId: new Map(),\n  };\n}\n\nfunction getFindingBucket(index, id, finding, enableNearDuplicateDedup) {\n  const contentKey = enableNearDuplicateDedup ? nearDuplicateContentKey(finding) : '';\n  const exactBucket = index.byId.get(id);\n  if (exactBucket) {\n    return exactBucket;\n  }\n\n  // Title-aware bucketing (deep-review P2-15 fix): a content key can host MORE than one\n  // bucket when several genuinely-distinct findings share an identical body but carry\n  // divergent titles. byContent maps a content key to the LIST of buckets seen for it; a\n  // same-body finding joins the bucket whose records its title actually matches, and\n  // otherwise opens a new bucket. Without this a distinct finding would share a bucket with\n  // a different finding and be mis-tagged as a same-id conflict variant by\n  // flattenFindingBucketIndex.\n  const candidateBuckets = contentKey ? index.byContent.get(contentKey) : undefined;\n  if (candidateBuckets) {\n    const titleMatch = enableNearDuplicateDedup\n      ? candidateBuckets.find((b) => b.records.some((entry) => nearDuplicateMatches(entry, finding)))\n      : candidateBuckets[0];\n    if (titleMatch) {\n      index.byId.set(id, titleMatch);\n      return titleMatch;\n    }\n  }\n\n  const bucket = { baseId: id, records: [] };\n  index.buckets.push(bucket);\n  index.byId.set(id, bucket);\n  if (contentKey) {\n    if (candidateBuckets) candidateBuckets.push(bucket);\n    else index.byContent.set(contentKey, [bucket]);\n  }\n  return bucket;\n}\n\nfunction flattenFindingBucketIndex(index, idKey, sortKeys) {\n  const records = [];\n  for (const { baseId, records: bucket } of index.buckets) {\n    const variants = sortByContentThenId(bucket, sortKeys);\n    if (variants.length === 1) {\n      records.push(variants[0]);\n      continue;\n    }\n    records.push(...attachConflictMarkers(\n      variants.map((variant) => conflictSafeRecord(variant, baseId, idKey)),\n      baseId,\n      idKey,\n    ));\n  }\n  return sortByContentThenId(records, sortKeys);\n}\n\nfunction addResearchFinding(bucket, finding, label, options = {}) {\n  const matches = options.enableNearDuplicateDedup\n    ? (entry) => nearDuplicateMatches(entry, finding)\n    : (entry) => contentIdentityKey(entry) === contentIdentityKey(finding);\n  const existing = bucket.find(matches);\n  if (existing) {\n    if (options.enableNearDuplicateDedup) {\n      replaceRecord(existing, chooseCanonicalRecord(existing, finding, ['id', 'title']), mergeLineageLabels(existing, finding, label));\n      return;\n    }\n    addLineage(existing, label);\n    return;\n  }\n  bucket.push({ ...finding, _lineages: [label] });\n}\n\nfunction addReviewFinding(bucket, finding, label, options = {}) {\n  const matches = options.enableNearDuplicateDedup\n    ? (entry) => nearDuplicateMatches(entry, finding)\n    : (entry) => contentIdentityKey(entry) === contentIdentityKey(finding);\n  const existing = bucket.find(matches);\n  if (!existing) {\n    bucket.push({ ...finding, _lineages: [label] });\n    return;\n  }\n\n  if (options.enableNearDuplicateDedup) {\n    replaceRecord(\n      existing,\n      chooseReviewCanonicalRecord(existing, finding, ['findingId', 'title']),\n      mergeLineageLabels(existing, finding, label),\n    );\n    return;\n  }\n\n  const incomingRank = SEVERITY_RANK[finding.severity] ?? 0;\n  const existingRank = SEVERITY_RANK[existing.severity] ?? 0;\n  if (incomingRank > existingRank) {\n    Object.assign(existing, {\n      ...finding,\n      _lineages: mergeLineageLabels(existing, finding, label),\n    });\n    return;\n  }\n  addLineage(existing, label);\n}\n\nfunction flattenFindingBuckets(findingById, idKey, sortKeys) {\n  const records = [];\n  for (const [baseId, bucket] of findingById) {\n    const variants = sortByContentThenId(bucket, sortKeys);\n    if (variants.length === 1) {\n      records.push(variants[0]);\n      continue;\n    }\n    records.push(...attachConflictMarkers(\n      variants.map((variant) => conflictSafeRecord(variant, baseId, idKey)),\n      baseId,\n      idKey,\n    ));\n  }\n  return sortByContentThenId(records, sortKeys);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2b. SCHEMA NORMALIZATION\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Normalize a registry object so that the canonical findings key is populated,\n * tolerating known aliases (e.g. `findings` → `keyFindings` for research,\n * `findings` → `openFindings` for review).\n *\n * Returns { registry, warnings } where warnings is an array of structured\n * schema_mismatch events for every alias hit or unusable-registry skip.\n *\n * @param {object|null} registry\n * @param {{ canonicalKey: string, aliases: Record<string, string>, lineage: string }} opts\n * @returns {{ registry: object|null, warnings: object[] }}\n */\nfunction normalizeRegistrySchema(registry, { canonicalKey, aliases, lineage }) {\n  if (!registry) return { registry, warnings: [] };\n  const warnings = [];\n\n  // If canonical key is already present and an array, nothing to do.\n  if (Array.isArray(registry[canonicalKey])) {\n    return { registry, warnings };\n  }\n\n  // Try each alias in priority order.\n  for (const [aliasKey, targetKey] of Object.entries(aliases)) {\n    if (Array.isArray(registry[aliasKey])) {\n      // Alias found — coerce to canonical key.\n      registry[targetKey] = registry[aliasKey];\n      warnings.push({\n        type: 'schema_mismatch',\n        severity: 'warn',\n        lineage,\n        message: `Registry uses non-canonical key \"${aliasKey}\" instead of \"${targetKey}\"; coerced ${registry[aliasKey].length} entries.`,\n        aliasKey,\n        canonicalKey: targetKey,\n        coercedCount: registry[aliasKey].length,\n      });\n      return { registry, warnings };\n    }\n  }\n\n  // No usable findings array found — registry will be skipped.\n  // We cannot count entries that don't exist, but report the skip.\n  warnings.push({\n    type: 'schema_mismatch',\n    severity: 'warn',\n    lineage,\n    message: `Registry has no usable \"${canonicalKey}\" array (checked aliases: ${Object.keys(aliases).join(', ')}); lineage findings will be skipped.`,\n    aliasKey: null,\n    canonicalKey,\n    coercedCount: 0,\n  });\n\n  return { registry, warnings };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. RESEARCH MERGE\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Merge research findings registries from all lineages.\n * Deduplicates by findingId; cross-model attribution via lineage labels.\n * Returns the merged registry object.\n */\nfunction mergeResearchRegistries(lineageData, options = {}) {\n  const mergeOptions = resolveMergeOptions(options);\n  const findingById = mergeOptions.enableNearDuplicateDedup ? createFindingBucketIndex() : new Map();\n  const schemaWarnings = [];\n\n  for (const { label, registry: rawRegistry } of lineageData) {\n    const { registry, warnings } = normalizeRegistrySchema(rawRegistry, {\n      canonicalKey: 'keyFindings',\n      aliases: { findings: 'keyFindings' },\n      lineage: label,\n    });\n    for (const w of warnings) {\n      schemaWarnings.push(w);\n      process.stderr.write(JSON.stringify(w) + '\\n');\n    }\n    if (!registry || !Array.isArray(registry.keyFindings)) continue;\n    for (const finding of registry.keyFindings) {\n      const id = finding.id || finding.title;\n      if (!id) continue;\n      if (mergeOptions.enableNearDuplicateDedup) {\n        addResearchFinding(getFindingBucket(findingById, id, finding, true).records, finding, label, mergeOptions);\n      } else {\n        if (!findingById.has(id)) findingById.set(id, []);\n        addResearchFinding(findingById.get(id), finding, label, mergeOptions);\n      }\n    }\n  }\n\n  const mergedFindings = mergeOptions.enableNearDuplicateDedup\n    ? flattenFindingBucketIndex(findingById, 'id', ['id', 'title'])\n    : flattenFindingBuckets(findingById, 'id', ['id', 'title']);\n  const openQuestionsById = new Map();\n  const resolvedQuestionsById = new Map();\n  const ruledOutById = new Map();\n\n  for (const { label, registry } of lineageData) {\n    if (!registry) continue;\n    for (const q of registry.openQuestions ?? []) {\n      const id = q.id || q.question || q.text;\n      if (!id) continue;\n      if (!openQuestionsById.has(id)) openQuestionsById.set(id, { ...q, _lineages: [label] });\n      else {\n        const existing = openQuestionsById.get(id);\n        addLineage(existing, label);\n      }\n    }\n    // Resolved questions are produced per-lineage by the research reducer but\n    // were previously dropped here, under-reporting answered coverage in the\n    // merged registry. Collect them with the same id/_lineages discipline.\n    for (const q of registry.resolvedQuestions ?? []) {\n      const id = q.id || q.question || q.text;\n      if (!id) continue;\n      if (!resolvedQuestionsById.has(id)) resolvedQuestionsById.set(id, { ...q, _lineages: [label] });\n      else {\n        const existing = resolvedQuestionsById.get(id);\n        addLineage(existing, label);\n      }\n    }\n    for (const d of registry.ruledOutDirections ?? []) {\n      const id = d.id || d.direction;\n      if (!id) continue;\n      if (!ruledOutById.has(id)) ruledOutById.set(id, { ...d, _lineages: [label] });\n    }\n  }\n\n  const totalIters = lineageData.reduce((sum, { registry }) => {\n    return sum + (registry?.metrics?.iterationsCompleted ?? 0);\n  }, 0);\n\n  const avgConvergence =\n    lineageData.length > 0\n      ? lineageData.reduce((sum, { registry }) => sum + (registry?.metrics?.convergenceScore ?? 0), 0) /\n        lineageData.length\n      : 0;\n\n  return {\n    mergedFrom: lineageData.map(({ label }) => label).sort(),\n    openQuestions: sortByContentThenId([...openQuestionsById.values()], ['id', 'question', 'text']),\n    resolvedQuestions: sortByContentThenId([...resolvedQuestionsById.values()], ['id', 'question', 'text']),\n    keyFindings: mergedFindings,\n    ruledOutDirections: sortByContentThenId([...ruledOutById.values()], ['id', 'direction']),\n    metrics: {\n      iterationsCompleted: totalIters,\n      openQuestions: openQuestionsById.size,\n      resolvedQuestions: resolvedQuestionsById.size,\n      keyFindings: mergedFindings.length,\n      convergenceScore: Math.round(avgConvergence * 1000) / 1000,\n      coverageBySources: {},\n    },\n    ...(schemaWarnings.length > 0 ? { schema_mismatch: schemaWarnings } : {}),\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. REVIEW MERGE  (strongest-restriction)\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Merge review findings registries with strongest-restriction severity rollup.\n * Any lineage with an active P0 finding causes the merged result to be FAIL.\n * Deduplication is by findingId; cross-lineage P0 wins if any lineage reports it.\n */\nfunction mergeReviewRegistries(lineageData, options = {}) {\n  const mergeOptions = resolveMergeOptions(options);\n  const findingById = mergeOptions.enableNearDuplicateDedup ? createFindingBucketIndex() : new Map();\n  const schemaWarnings = [];\n\n  for (const { label, registry: rawRegistry } of lineageData) {\n    const { registry, warnings } = normalizeRegistrySchema(rawRegistry, {\n      canonicalKey: 'openFindings',\n      aliases: { findings: 'openFindings' },\n      lineage: label,\n    });\n    for (const w of warnings) {\n      schemaWarnings.push(w);\n      process.stderr.write(JSON.stringify(w) + '\\n');\n    }\n    if (!registry || !Array.isArray(registry.openFindings)) continue;\n    for (const finding of registry.openFindings) {\n      if (finding.status !== 'active') continue;\n      const id = finding.findingId || finding.title;\n      if (!id) continue;\n      if (mergeOptions.enableNearDuplicateDedup) {\n        addReviewFinding(getFindingBucket(findingById, id, finding, true).records, finding, label, mergeOptions);\n      } else {\n        if (!findingById.has(id)) findingById.set(id, []);\n        addReviewFinding(findingById.get(id), finding, label, mergeOptions);\n      }\n    }\n  }\n\n  // Resolved findings are tracked separately per lineage and were previously\n  // dropped here, zeroing the merged resolved coverage. Collect them by id with\n  // _lineages attribution, without touching open-finding/verdict semantics.\n  const resolvedFindingById = mergeOptions.enableNearDuplicateDedup ? createFindingBucketIndex() : new Map();\n  for (const { label, registry } of lineageData) {\n    if (!registry || !Array.isArray(registry.resolvedFindings)) continue;\n    for (const finding of registry.resolvedFindings) {\n      const id = finding.findingId || finding.title;\n      if (!id) continue;\n      if (mergeOptions.enableNearDuplicateDedup) {\n        addReviewFinding(getFindingBucket(resolvedFindingById, id, finding, true).records, finding, label, mergeOptions);\n      } else if (resolvedFindingById.has(id)) {\n        addLineage(resolvedFindingById.get(id), label);\n      } else {\n        resolvedFindingById.set(id, { ...finding, _lineages: [label] });\n      }\n    }\n  }\n  const mergedResolvedFindings = mergeOptions.enableNearDuplicateDedup\n    ? flattenFindingBucketIndex(resolvedFindingById, 'findingId', ['findingId', 'title'])\n    : sortByContentThenId([...resolvedFindingById.values()], ['findingId', 'title']);\n\n  const mergedFindings = mergeOptions.enableNearDuplicateDedup\n    ? flattenFindingBucketIndex(findingById, 'findingId', ['findingId', 'title'])\n    : flattenFindingBuckets(findingById, 'findingId', ['findingId', 'title']);\n  const activeP0 = mergedFindings.filter((f) => f.severity === 'P0' && f.status === 'active').length;\n  const activeP1 = mergedFindings.filter((f) => f.severity === 'P1' && f.status === 'active').length;\n  const activeP2 = mergedFindings.filter((f) => f.severity === 'P2' && f.status === 'active').length;\n\n  // Strongest-restriction verdict\n  let mergedVerdict;\n  if (activeP0 > 0) {\n    mergedVerdict = 'FAIL';\n  } else if (activeP1 > 0) {\n    mergedVerdict = 'CONDITIONAL';\n  } else {\n    mergedVerdict = 'PASS';\n  }\n\n  return {\n    mergedFrom: lineageData.map(({ label }) => label).sort(),\n    mergedVerdict,\n    openFindings: mergedFindings,\n    resolvedFindings: mergedResolvedFindings,\n    findingsBySeverity: { P0: activeP0, P1: activeP1, P2: activeP2 },\n    openFindingsCount: mergedFindings.length,\n    resolvedFindingsCount: mergedResolvedFindings.length,\n    activeP0,\n    activeP1,\n    activeP2,\n    ...(schemaWarnings.length > 0 ? { schema_mismatch: schemaWarnings } : {}),\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. ATTRIBUTION\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Build fanout-attribution.md summarizing per-lineage convergence, iters, salvage, model.\n */\nfunction buildAttributionMd(lineageData, loopType) {\n  const lines = [\n    `# Fan-Out Attribution`,\n    ``,\n    `Loop type: **${loopType}**  |  Lineage count: **${lineageData.length}**`,\n    ``,\n    `| Label | Kind | Model | Iterations | Convergence | Salvaged | Verdict |`,\n    `|-------|------|-------|-----------|-------------|----------|---------|`,\n  ];\n\n  for (const { label, registry, stateRecords, kind, model } of lineageData) {\n    const iters = stateRecords.filter((r) => r.type === 'iteration').length;\n    const salvage = stateRecords.filter((r) => r.type === 'event' && r.event === 'salvaged_from_stdout').length;\n    const convergenceScore = registry?.metrics?.convergenceScore ?? registry?.convergenceScore ?? 'n/a';\n    const verdict =\n      loopType === 'review'\n        ? registry?.findingsBySeverity?.P0 > 0\n          ? 'FAIL'\n          : registry?.findingsBySeverity?.P1 > 0\n          ? 'CONDITIONAL'\n          : 'PASS'\n        : 'n/a';\n    lines.push(`| ${label} | ${kind ?? 'unknown'} | ${model ?? 'default'} | ${iters} | ${convergenceScore} | ${salvage} | ${verdict} |`);\n  }\n\n  lines.push('');\n  return lines.join('\\n');\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. MAIN\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Reconstruct a minimal review findings registry from a lineage state log.\n *\n * Leaf-only review lineages may carry active findings only in their state log\n * iteration records (`findingDetails`), with no registry file on disk. This maps\n * those findingDetails into the openFindings shape mergeReviewRegistries consumes,\n * so registry-absent lineages are not silently dropped from merge/synthesis.\n *\n * @param {Array<Object>} stateRecords - Parsed JSONL state records.\n * @param {string} label - Lineage label, for attribution.\n * @returns {{openFindings:Array,Object}|null} Reconstructed registry, or null when no findings exist.\n */\nfunction reconstructReviewRegistryFromState(stateRecords, label) {\n  if (!Array.isArray(stateRecords)) return null;\n  const openFindings = [];\n  const resolvedFindings = [];\n  for (const record of stateRecords) {\n    if (!record || record.type !== 'iteration' || !Array.isArray(record.findingDetails)) continue;\n    for (const detail of record.findingDetails) {\n      if (!detail || typeof detail !== 'object') continue;\n      const id = detail.id || detail.findingId || detail.title;\n      if (!id) continue;\n      const isActive = (detail.disposition || detail.status || 'active') === 'active';\n      const mapped = {\n        findingId: id,\n        title: detail.title || id,\n        severity: detail.severity || 'P2',\n        status: isActive ? 'active' : 'resolved',\n        ...(detail.dimension ? { dimension: detail.dimension } : {}),\n        ...(detail.file ? { file: detail.file } : {}),\n        ...(detail.recommendation ? { recommendation: detail.recommendation } : {}),\n        _lineages: [label],\n        _reconstructed_from_state: true,\n      };\n      if (isActive) openFindings.push(mapped);\n      else resolvedFindings.push(mapped);\n    }\n  }\n  if (openFindings.length === 0 && resolvedFindings.length === 0) return null;\n  const bySeverity = {\n    P0: openFindings.filter((f) => f.severity === 'P0').length,\n    P1: openFindings.filter((f) => f.severity === 'P1').length,\n    P2: openFindings.filter((f) => f.severity === 'P2').length,\n  };\n  return { openFindings, resolvedFindings, findingsBySeverity: bySeverity, _reconstructed: true };\n}\n\nfunction firstNonEmptyString(values) {\n  for (const value of values) {\n    if (typeof value === 'string' && value.trim() !== '') return value.trim();\n    if (value && typeof value === 'object' && !Array.isArray(value)) {\n      const objectText = firstNonEmptyString([value.title, value.summary, value.text, value.finding, value.description]);\n      if (objectText) return objectText;\n    }\n  }\n  return '';\n}\n\nfunction normalizeResearchFindingCandidate(candidate, record, index) {\n  const run = Number.isFinite(Number(record.run ?? record.iteration)) ? Math.floor(Number(record.run ?? record.iteration)) : 0;\n  if (typeof candidate === 'string') {\n    const text = candidate.trim();\n    if (!text) return null;\n    return {\n      id: `state-finding-${run}-${index + 1}-${crypto.createHash('sha256').update(text).digest('hex').slice(0, 12)}`,\n      title: text,\n      text,\n      addedAtIteration: run,\n      _reconstructed_from_state: true,\n    };\n  }\n  if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return null;\n  const text = firstNonEmptyString([candidate.title, candidate.summary, candidate.text, candidate.finding, candidate.description]);\n  if (!text) return null;\n  return {\n    id: candidate.id || candidate.findingId || `state-finding-${run}-${index + 1}-${crypto.createHash('sha256').update(text).digest('hex').slice(0, 12)}`,\n    title: candidate.title || text,\n    ...(candidate.summary ? { summary: candidate.summary } : {}),\n    ...(candidate.text ? { text: candidate.text } : { text }),\n    ...(candidate.confidence ? { confidence: candidate.confidence } : {}),\n    addedAtIteration: candidate.addedAtIteration ?? run,\n    _reconstructed_from_state: true,\n  };\n}\n\nfunction researchCandidatesFromIteration(record) {\n  if (!record || record.type !== 'iteration') return [];\n  const structured = [record.keyFindings, record.findings, record.findingDetails]\n    .find((value) => Array.isArray(value) && value.length > 0);\n  if (Array.isArray(structured)) {\n    return structured;\n  }\n\n  const findingsCount = Number(record.findingsCount);\n  if (!Number.isFinite(findingsCount) || findingsCount <= 0) return [];\n  const run = Number.isFinite(Number(record.run ?? record.iteration)) ? Math.floor(Number(record.run ?? record.iteration)) : 0;\n  const narrative = firstNonEmptyString([\n    record.summary,\n    record.findingsSummary,\n    record.focus,\n    record.nextFocus,\n    record.reflection,\n  ]);\n  return [{\n    id: `state-finding-${run}-1-${crypto.createHash('sha256').update(narrative || String(run)).digest('hex').slice(0, 12)}`,\n    title: narrative || `Iteration ${run} recorded ${Math.floor(findingsCount)} finding(s)`,\n    summary: narrative || `State log recorded ${Math.floor(findingsCount)} finding(s) but no structured finding text.`,\n    addedAtIteration: run,\n  }];\n}\n\n/**\n * Reconstruct a minimal research findings registry from a lineage state log.\n *\n * Leaf-only research lineages may have substantive iteration records but no\n * registry file on disk. This maps state-log findings into keyFindings so the\n * research merge does not silently drop a registry-absent lineage.\n *\n * @param {Array<Object>} stateRecords - Parsed JSONL state records.\n * @param {string} label - Lineage label, for attribution.\n * @returns {{keyFindings:Array,Object}|null} Reconstructed registry, or null when no findings exist.\n */\nfunction reconstructResearchRegistryFromState(stateRecords, label) {\n  if (!Array.isArray(stateRecords)) return null;\n  const keyFindings = [];\n  for (const record of stateRecords) {\n    const candidates = researchCandidatesFromIteration(record);\n    candidates.forEach((candidate, index) => {\n      const mapped = normalizeResearchFindingCandidate(candidate, record, index);\n      if (!mapped) return;\n      keyFindings.push({ ...mapped, _lineages: [label] });\n    });\n  }\n  if (keyFindings.length === 0) return null;\n  const iterationsCompleted = stateRecords.filter((record) => record?.type === 'iteration').length;\n  const latestIteration = stateRecords.filter((record) => record?.type === 'iteration').at(-1);\n  const convergenceScore = latestIteration?.convergenceSignals?.compositeStop\n    ?? latestIteration?.newInfoRatio\n    ?? 0;\n  return {\n    keyFindings,\n    openQuestions: [],\n    resolvedQuestions: [],\n    ruledOutDirections: [],\n    metrics: {\n      iterationsCompleted,\n      openQuestions: 0,\n      resolvedQuestions: 0,\n      keyFindings: keyFindings.length,\n      convergenceScore,\n      coverageBySources: {},\n    },\n    _reconstructed: true,\n  };\n}\n\nasync function main() {\n  const { writeStateAtomic, writeTextAtomic } = await import('../lib/deep-loop/atomic-state.ts');\n  const args = parseArgs();\n  const loopType = ensureString(args, 'loopType');\n  if (loopType !== 'research' && loopType !== 'review' && loopType !== 'context') {\n    throw inputError('loopType must be \"research\", \"review\", or \"context\"');\n  }\n  const artifactDir = ensureString(args, 'artifactDir');\n  const lineagesDir = path.join(artifactDir, 'lineages');\n\n  if (!fs.existsSync(lineagesDir)) {\n    jsonOut({ status: 'ok', message: 'no lineages directory — nothing to merge', merged: 0 });\n    return;\n  }\n\n  const labelDirs = fs.readdirSync(lineagesDir)\n    .filter((entry) => fs.statSync(path.join(lineagesDir, entry)).isDirectory())\n    .sort();\n\n  if (labelDirs.length === 0) {\n    jsonOut({ status: 'ok', message: 'no lineage subdirs found', merged: 0 });\n    return;\n  }\n\n  // Load per-lineage data\n  const registryName =\n    loopType === 'review' ? 'deep-review-findings-registry.json' : 'deep-research-findings-registry.json';\n  const stateLogName = loopType === 'review' ? 'deep-review-state.jsonl' : 'deep-research-state.jsonl';\n  const summaryPath = path.join(artifactDir, 'orchestration-summary.json');\n  const orchestrationSummary = tryReadJson(summaryPath) ?? {};\n\n  const lineageData = labelDirs.map((label) => {\n    const lineageDir = path.join(lineagesDir, label);\n    let registry = tryReadJson(path.join(lineageDir, registryName));\n    const stateRecords = readStateLog(path.join(lineageDir, stateLogName));\n    // Leaf-only review/research lineages (orchestrator-managed direct-leaf convention) may carry\n    // active findings only in their state log's findingDetails, with no registry file.\n    // Without a registry, such a lineage was silently skipped by the registry-only merge,\n    // dropping its findings from synthesis. Reconstruct a minimal registry from the\n    // state log so leaf-only lineages reach merge without a separate reducer step.\n    if (!registry && loopType === 'review') {\n      registry = reconstructReviewRegistryFromState(stateRecords, label);\n    }\n    if (!registry && loopType === 'research') {\n      registry = reconstructResearchRegistryFromState(stateRecords, label);\n    }\n    // Infer kind/model from state log executor records\n    const executorRecord = stateRecords.find((r) => r.type === 'event' && r.event === 'executor_start');\n    return {\n      label,\n      lineageDir,\n      registry,\n      stateRecords,\n      kind: executorRecord?.kind ?? orchestrationSummary?.[label]?.kind ?? 'unknown',\n      model: executorRecord?.model ?? orchestrationSummary?.[label]?.model ?? 'unknown',\n    };\n  });\n\n  const lineagesWithRegistry = lineageData.filter((d) => d.registry !== null);\n\n  let mergedRegistry;\n  if (loopType === 'review') {\n    mergedRegistry = mergeReviewRegistries(lineagesWithRegistry, resolveMergeOptions(args));\n  } else {\n    mergedRegistry = mergeResearchRegistries(lineagesWithRegistry, resolveMergeOptions(args));\n  }\n\n  // Write merged registry to base artifact dir (replacing single-executor path).\n  // Atomic temp+fsync+rename so a mid-write kill never hands synthesis a\n  // truncated registry — readers see the prior file or the complete new one.\n  const mergedRegistryPath = path.join(artifactDir, registryName);\n  writeStateAtomic(mergedRegistryPath, mergedRegistry);\n\n  // Write attribution markdown atomically (same torn-write guarantee; text, not JSON).\n  const attributionPath = path.join(artifactDir, 'fanout-attribution.md');\n  writeTextAtomic(attributionPath, buildAttributionMd(lineageData, loopType));\n\n  jsonOut({\n    status: 'ok',\n    loop_type: loopType,\n    merged_lineages: lineagesWithRegistry.length,\n    skipped_no_registry: lineageData.length - lineagesWithRegistry.length,\n    merged_registry_path: mergedRegistryPath,\n    attribution_path: attributionPath,\n    ...(loopType === 'review'\n      ? { merged_verdict: mergedRegistry.mergedVerdict, active_p0: mergedRegistry.activeP0, active_p1: mergedRegistry.activeP1 }\n      : { key_findings: mergedRegistry.keyFindings?.length ?? 0 }),\n  });\n}\n\n// Exports for unit testing\nmodule.exports = { mergeResearchRegistries, mergeReviewRegistries, buildAttributionMd, reconstructReviewRegistryFromState, reconstructResearchRegistryFromState, normalizeRegistrySchema };\n\nif (require.main === module) {\n  main().catch((err) => {\n    const code = err && err.code === 'INPUT_VALIDATION' ? 3 : 1;\n    jsonOut({\n      status: 'error',\n      error: err instanceof Error ? err.message : String(err),\n      code: err && err.code ? err.code : 'SCRIPT_ERROR',\n    });\n    if (code === 1) {\n      process.stderr.write(\n        JSON.stringify({ error: err instanceof Error ? err.message : String(err), stack: err && err.stack }) + '\\n',\n      );\n    }\n    process.exit(code);\n  });\n}","lineStart":1,"lineEnd":1014,"totalLines":1014,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs","time":{"start":1783489172631,"end":1783489172638}},"metadata":{"openai":{"itemId":"fc_01fb4a25ac0d7cd3016a4de293e7688191a5991d098404ea7e"}},"id":"prt_f403d1409001eADWl740kzfgn8","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","messageID":"msg_f403cbc480018ajiAmXXfQafxy"}}
