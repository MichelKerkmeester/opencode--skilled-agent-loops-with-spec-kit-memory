 {\n          \"id\": 9378,\n          \"specFolder\": \"system-spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/spec-folder-naming.md\",\n          \"title\": \"Spec-Folder Naming & Rename Convention\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: rule applies — NEVER delete + recreate. | Prioritize when: never hand-edit (e.g. advisor `skill-graph.json` via `skill_graph_compiler.py --export-json`).\"\n        },\n        {\n          \"id\": 9376,\n          \"specFolder\": \"system-spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/post-implementation-deep-review.md\",\n          \"title\": \"POST-IMPLEMENTATION DEEP-REVIEW — Mandatory after substantive ship\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: asserting new invariant | | Prioritize when: asserting new invariant |\"\n        },\n        {\n          \"id\": 9375,\n          \"specFolder\": \"system-spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/memory-system-spec-kit-only.md\",\n          \"title\": \"MEMORY — Spec-Kit System Only\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: rule applies — do not silently choose n | Prioritize when: constitutional rule is active for current task\"\n        },\n        {\n          \"id\": 9374,\n          \"specFolder\": \"system-spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/memory-db-file-topology.md\",\n          \"title\": \"MEMORY — Spec-Kit DB File Topology (index vs vectors are SEPARATE files)\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: MEMORY — Spec-Kit DB File Topology (index vs vectors are SEPARATE files) | Prioritize when: task context aligns with \\\"MEMORY — Spec-Kit DB File Topology (index vs vectors are SEPARATE files)\\\"\"\n        },\n        {\n          \"id\": 9373,\n          \"specFolder\": \"system-spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/main-branch-direct-push.md\",\n          \"title\": \"Main Branch — Owner's AIs Push Directly\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: rule applies — Do NOT default to a feature-branch + PR flow, do NOT re-ask whether to use a PR, and do NOT flag the bypass or the unsi… | Prioritize when: only (the tree often has concurrent parallel-session work + daemon metadata churn — NEVER `git add -A` blindly; use exp…\"\n        },\n        {\n          \"id\": 9372,\n          \"specFolder\": \"system-spec-kit\",\n          \"filePath\": \"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/constitutional/gate-tool-routing.md\",\n          \"title\": \"TOOL ROUTING - Search & Retrieval Decision Tree\",\n          \"importanceTier\": \"constitutional\",\n          \"retrieval_directive\": \"Always surface when: TOOL ROUTING - Search & Retrieval Decision Tree | Prioritize when: task context aligns with \\\"TOOL ROUTING - Search & Retrieval Decision Tree\\\"\"\n        }\n      ],\n      \"triggered\": [\n        {\n          \"memory_id\": 1757,\n          \"spec_folder\": \"skilled-agent-orchestration/z_archive/042-sk-deep-research-review-improvement-2/010-root-level-review-research-convention\",\n          \"title\": \"...killed-agent-orchestration/042-sk-deep-research-review-improvement-2/010-root-level-review-research-convention/tasks]\",\n          \"matched_phrases\": [\n            \"agent\",\n            \"orchestration\",\n            \"deep\"\n          ]\n        },\n        {\n          \"memory_id\": 1745,\n          \"spec_folder\": \"skilled-agent-orchestration/z_archive/042-sk-deep-research-review-improvement-2/010-root-level-review-research-convention\",\n          \"title\": \"...ed-agent-orchestration/042-sk-deep-research-review-improvement-2/010-root-level-review-research-convention/checklist]\",\n          \"matched_phrases\": [\n            \"agent\",\n            \"orchestration\",\n            \"deep\"\n          ]\n        },\n        {\n          \"memory_id\": 8109,\n          \"spec_folder\": \"system-spec-kit/z_archive/022-hybrid-rag-fusion/013-agents-alignment\",\n          \"title\": \"013 — Agent Alignment: Runtime Lineage Truth [system-spec-kit/022-hybrid-rag-fusion/013-agents-alignment/spec]\",\n          \"matched_phrases\": [\n            \"agent\",\n            \"lineage\"\n          ]\n        },\n        {\n          \"memory_id\": 7188,\n          \"spec_folder\": \"system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/090-opencode-naming-conventions\",\n          \"title\": \"Feature Specific [system-spec-kit/z_archive/001-fix-command-dispatch/z_archive/090-opencode-naming-conventions/spec]\",\n          \"matched_phrases\": [\n            \"feature\",\n            \"opencode\"\n          ]\n        },\n        {\n          \"memory_id\": 1498,\n          \"spec_folder\": \"skilled-agent-orchestration/z_archive/024-sk-deep-research-refinement\",\n          \"title\": \"Feature Specification: sk-deep-research Refinement [skilled-agent-orchestration/024-sk-deep-research-refinement/spec]\",\n          \"matched_phrases\": [\n            \"feature\",\n            \"deep\"\n          ]\n        }\n      ],\n      \"surfaced_at\": \"2026-06-10T22:06:40.815Z\",\n      \"latencyMs\": 770\n    },\n    \"tokenBudget\": 3500\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1781129200042,"end":1781129200830}},"metadata":{"openai":{"itemId":"fc_063536529adaa946016a29dfeeff148191bf73c379d55fc385"}},"id":"prt_eb392be000013F4ekUfOMJ132x","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb392a5e6001xyyWwMMPx41GTu"}}
