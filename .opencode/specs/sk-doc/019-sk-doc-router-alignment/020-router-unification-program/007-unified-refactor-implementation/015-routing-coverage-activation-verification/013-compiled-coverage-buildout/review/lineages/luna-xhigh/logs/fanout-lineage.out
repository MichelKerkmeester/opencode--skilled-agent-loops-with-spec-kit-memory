{"type":"tool_use","timestamp":1784693189254,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_SIQasDD8qTdOkXfLMroeE4N1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-route-sync.cjs","offset":1,"limit":190},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-route-sync.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: // Build/copy step for the promoted compiled-routing runtime closure.\n5: //\n6: // The authored source of the runtime resolver, the engine loader, the activation\n7: // manifests, and every per-hub bundle lives under the mutable spec tree. Serving\n8: // from there couples the runtime to spec-folder churn: a single renumber can\n9: // sever routing fleet-wide. This tool promotes the closure to a stable runtime\n10: // path so nothing on the serving path ever reads under `.opencode/specs`.\n11: //\n12: // It does not hand-enumerate the closure. It instruments `require` resolution and\n13: // file reads, drives the authored resolver across every hub with the flag forced\n14: // on, and copies exactly the files the serving path actually touches — preserving\n15: // each file's location relative to the authored root so the byte-identical copies\n16: // keep resolving their own dependencies. That makes the promoted set complete by\n17: // construction and immune to a missed transitive read.\n18: //\n19: // Modes:\n20: //   (default)   trace the authored closure and (re)build the promoted mirror\n21: //   --verify    trace the PROMOTED closure and assert no path reads under\n22: //               `.opencode/specs` while every hub still resolves (the move\n23: //               simulation: if the serving graph never touches the spec tree,\n24: //               relocating the spec tree cannot affect it)\n25: //   --check     print the traced closure without writing anything\n26: \n27: const fs = require('fs');\n28: const path = require('path');\n29: const Module = require('module');\n30: \n31: const {\n32:   isCanonicalHubId,\n33:   validateCanonicalManifestBytes,\n34: } = require('./lib/compiled-route-manifest.cjs');\n35: \n36: const REPO_ROOT = path.resolve(__dirname, '..', '..');\n37: const SPECS_ROOT = path.join(REPO_ROOT, '.opencode', 'specs');\n38: const IMPL_ROOT = path.join(\n39:   REPO_ROOT,\n40:   '.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program',\n41:   '007-unified-refactor-implementation',\n42: );\n43: const AUTHORED_RESOLVER = path.join(IMPL_ROOT, '011-runtime-engine', 'lib', 'resolve.cjs');\n44: const RUNTIME_ROOT = path.join(REPO_ROOT, '.opencode', 'bin', 'lib', 'compiled-routing');\n45: const ACTIVATION_ROOT = path.join(RUNTIME_ROOT, '010-live-activation', 'activation');\n46: const PROMOTED_RESOLVER = path.join(RUNTIME_ROOT, '011-runtime-engine', 'lib', 'resolve.cjs');\n47: const MANIFEST_PATH = path.join(RUNTIME_ROOT, 'serving-closure.manifest.json');\n48: \n49: const HUBS = [\n50:   'sk-code',\n51:   'system-deep-loop',\n52:   'mcp-tooling',\n53:   'cli-external-orchestration',\n54:   'sk-prompt',\n55:   'sk-design',\n56:   'sk-doc',\n57: ];\n58: \n59: // Diverse probes maximize the branches (route/clarify/defer) the engine walks,\n60: // so no conditionally-loaded module is missed by the trace.\n61: const PROBES = [\n62:   'quality review of the code',\n63:   'design a distinctive interface with motion',\n64:   'run a deep research loop with convergence',\n65:   'improve this prompt with a framework',\n66:   'create a new skill and validate the docs',\n67:   'use the figma mcp transport',\n68:   'commit and open a pull request',\n69: ];\n70: \n71: function instrument() {\n72:   const touched = new Set();\n73:   const record = (p) => {\n74:     if (typeof p !== 'string') return;\n75:     try {\n76:       const abs = path.isAbsolute(p) ? p : path.resolve(p);\n77:       touched.add(abs);\n78:     } catch { /* ignore un-resolvable */ }\n79:   };\n80:   const origResolveFilename = Module._resolveFilename;\n81:   Module._resolveFilename = function patched(request, parent, ...rest) {\n82:     const resolved = origResolveFilename.call(this, request, parent, ...rest);\n83:     record(resolved);\n84:     return resolved;\n85:   };\n86:   const origReadSync = fs.readFileSync;\n87:   fs.readFileSync = function patched(p, ...rest) { record(p); return origReadSync.call(this, p, ...rest); };\n88:   const origExists = fs.existsSync;\n89:   fs.existsSync = function patched(p, ...rest) { record(p); return origExists.call(this, p, ...rest); };\n90:   const origRead = fs.readFile;\n91:   fs.readFile = function patched(p, ...rest) { record(p); return origRead.call(this, p, ...rest); };\n92:   return {\n93:     touched,\n94:     restore() {\n95:       Module._resolveFilename = origResolveFilename;\n96:       fs.readFileSync = origReadSync;\n97:       fs.existsSync = origExists;\n98:       fs.readFile = origRead;\n99:     },\n100:   };\n101: }\n102: \n103: // Drive the resolver across every hub and return the set of absolute paths the\n104: // serving path touched. `resolverPath` selects the authored or promoted graph.\n105: function traceClosure(resolverPath) {\n106:   const probe = instrument();\n107:   const priorFlag = process.env.SPECKIT_COMPILED_ROUTING;\n108:   process.env.SPECKIT_COMPILED_ROUTING = '1';\n109:   const resolved = {};\n110:   try {\n111:     // eslint-disable-next-line global-require, import/no-dynamic-require\n112:     const { resolveRoute } = require(resolverPath);\n113:     for (const hub of HUBS) {\n114:       let decision = null;\n115:       for (const prompt of PROBES) {\n116:         const route = resolveRoute(hub, prompt);\n117:         if (route) decision = route;\n118:       }\n119:       resolved[hub] = decision;\n120:     }\n121:   } finally {\n122:     if (priorFlag === undefined) delete process.env.SPECKIT_COMPILED_ROUTING;\n123:     else process.env.SPECKIT_COMPILED_ROUTING = priorFlag;\n124:     probe.restore();\n125:   }\n126:   return { touched: probe.touched, resolved };\n127: }\n128: \n129: function underImplRoot(abs) {\n130:   const rel = path.relative(IMPL_ROOT, abs);\n131:   return rel && !rel.startsWith('..') && !path.isAbsolute(rel);\n132: }\n133: \n134: function underSpecs(abs) {\n135:   const rel = path.relative(SPECS_ROOT, abs);\n136:   return rel === '' || (rel && !rel.startsWith('..') && !path.isAbsolute(rel));\n137: }\n138: \n139: function syncConflict(hubId) {\n140:   throw new Error(`sync-conflict: external activation manifest for ${hubId}`);\n141: }\n142: \n143: function activationManifestPath(activationRoot, hubId) {\n144:   if (!isCanonicalHubId(hubId)) syncConflict(String(hubId));\n145:   const root = path.resolve(activationRoot);\n146:   const manifestPath = path.resolve(root, hubId, 'manifest.json');\n147:   const relative = path.relative(root, manifestPath);\n148:   if (!relative || relative.startsWith('..') || path.isAbsolute(relative)) syncConflict(hubId);\n149:   return manifestPath;\n150: }\n151: \n152: function safeActivationRoot(activationRoot, create = false) {\n153:   const resolvedRoot = path.resolve(activationRoot);\n154:   if (create) fs.mkdirSync(resolvedRoot, { recursive: true, mode: 0o700 });\n155:   if (!fs.existsSync(resolvedRoot)) return null;\n156:   const rootStats = fs.lstatSync(resolvedRoot);\n157:   if (rootStats.isSymbolicLink() || !rootStats.isDirectory()) {\n158:     syncConflict('activation-root');\n159:   }\n160:   return { resolvedRoot, realRoot: fs.realpathSync(resolvedRoot) };\n161: }\n162: \n163: function ensureSafeManifestDirectory(root, manifestPath, hubId) {\n164:   const directoryPath = path.dirname(manifestPath);\n165:   if (fs.existsSync(directoryPath)) {\n166:     const directoryStats = fs.lstatSync(directoryPath);\n167:     if (directoryStats.isSymbolicLink() || !directoryStats.isDirectory()) {\n168:       syncConflict(hubId);\n169:     }\n170:   } else {\n171:     fs.mkdirSync(directoryPath, { recursive: true, mode: 0o700 });\n172:   }\n173:   const relative = path.relative(root.realRoot, fs.realpathSync(directoryPath));\n174:   if (relative.startsWith('..') || path.isAbsolute(relative)) syncConflict(hubId);\n175: }\n176: \n177: function readSafeManifestBytes(manifestPath, hubId) {\n178:   let manifestStats;\n179:   try {\n180:     manifestStats = fs.lstatSync(manifestPath);\n181:   } catch {\n182:     syncConflict(hubId);\n183:   }\n184:   if (manifestStats.isSymbolicLink() || !manifestStats.isFile()) syncConflict(hubId);\n185:   try {\n186:     return fs.readFileSync(manifestPath);\n187:   } catch {\n188:     syncConflict(hubId);\n189:   }\n190: }\n\n(Showing lines 1-190 of 399. Use offset=191 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n// Build/copy step for the promoted compiled-routing runtime closure.\n//\n// The authored source of the runtime resolver, the engine loader, the activation\n// manifests, and every per-hub bundle lives under the mutable spec tree. Serving\n// from there couples the runtime to spec-folder churn: a single renumber can\n// sever routing fleet-wide. This tool promotes the closure to a stable runtime\n// path so nothing on the serving path ever reads under `.opencode/specs`.\n//\n// It does not hand-enumerate the closure. It instruments `require` resolution and\n// file reads, drives the authored resolver across every hub with the flag forced\n// on, and copies exactly the files the serving path actually touches — preserving\n// each file's location relative to the authored root so the byte-identical copies\n// keep resolving their own dependencies. That makes the promoted set complete by\n// construction and immune to a missed transitive read.\n//\n// Modes:\n//   (default)   trace the authored closure and (re)build the promoted mirror","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/compiled-route-sync.cjs","text":"#!/usr/bin/env node\n'use strict';\n\n// Build/copy step for the promoted compiled-routing runtime closure.\n//\n// The authored source of the runtime resolver, the engine loader, the activation\n// manifests, and every per-hub bundle lives under the mutable spec tree. Serving\n// from there couples the runtime to spec-folder churn: a single renumber can\n// sever routing fleet-wide. This tool promotes the closure to a stable runtime\n// path so nothing on the serving path ever reads under `.opencode/specs`.\n//\n// It does not hand-enumerate the closure. It instruments `require` resolution and\n// file reads, drives the authored resolver across every hub with the flag forced\n// on, and copies exactly the files the serving path actually touches — preserving\n// each file's location relative to the authored root so the byte-identical copies\n// keep resolving their own dependencies. That makes the promoted set complete by\n// construction and immune to a missed transitive read.\n//\n// Modes:\n//   (default)   trace the authored closure and (re)build the promoted mirror\n//   --verify    trace the PROMOTED closure and assert no path reads under\n//               `.opencode/specs` while every hub still resolves (the move\n//               simulation: if the serving graph never touches the spec tree,\n//               relocating the spec tree cannot affect it)\n//   --check     print the traced closure without writing anything\n\nconst fs = require('fs');\nconst path = require('path');\nconst Module = require('module');\n\nconst {\n  isCanonicalHubId,\n  validateCanonicalManifestBytes,\n} = require('./lib/compiled-route-manifest.cjs');\n\nconst REPO_ROOT = path.resolve(__dirname, '..', '..');\nconst SPECS_ROOT = path.join(REPO_ROOT, '.opencode', 'specs');\nconst IMPL_ROOT = path.join(\n  REPO_ROOT,\n  '.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program',\n  '007-unified-refactor-implementation',\n);\nconst AUTHORED_RESOLVER = path.join(IMPL_ROOT, '011-runtime-engine', 'lib', 'resolve.cjs');\nconst RUNTIME_ROOT = path.join(REPO_ROOT, '.opencode', 'bin', 'lib', 'compiled-routing');\nconst ACTIVATION_ROOT = path.join(RUNTIME_ROOT, '010-live-activation', 'activation');\nconst PROMOTED_RESOLVER = path.join(RUNTIME_ROOT, '011-runtime-engine', 'lib', 'resolve.cjs');\nconst MANIFEST_PATH = path.join(RUNTIME_ROOT, 'serving-closure.manifest.json');\n\nconst HUBS = [\n  'sk-code',\n  'system-deep-loop',\n  'mcp-tooling',\n  'cli-external-orchestration',\n  'sk-prompt',\n  'sk-design',\n  'sk-doc',\n];\n\n// Diverse probes maximize the branches (route/clarify/defer) the engine walks,\n// so no conditionally-loaded module is missed by the trace.\nconst PROBES = [\n  'quality review of the code',\n  'design a distinctive interface with motion',\n  'run a deep research loop with convergence',\n  'improve this prompt with a framework',\n  'create a new skill and validate the docs',\n  'use the figma mcp transport',\n  'commit and open a pull request',\n];\n\nfunction instrument() {\n  const touched = new Set();\n  const record = (p) => {\n    if (typeof p !== 'string') return;\n    try {\n      const abs = path.isAbsolute(p) ? p : path.resolve(p);\n      touched.add(abs);\n    } catch { /* ignore un-resolvable */ }\n  };\n  const origResolveFilename = Module._resolveFilename;\n  Module._resolveFilename = function patched(request, parent, ...rest) {\n    const resolved = origResolveFilename.call(this, request, parent, ...rest);\n    record(resolved);\n    return resolved;\n  };\n  const origReadSync = fs.readFileSync;\n  fs.readFileSync = function patched(p, ...rest) { record(p); return origReadSync.call(this, p, ...rest); };\n  const origExists = fs.existsSync;\n  fs.existsSync = function patched(p, ...rest) { record(p); return origExists.call(this, p, ...rest); };\n  const origRead = fs.readFile;\n  fs.readFile = function patched(p, ...rest) { record(p); return origRead.call(this, p, ...rest); };\n  return {\n    touched,\n    restore() {\n      Module._resolveFilename = origResolveFilename;\n      fs.readFileSync = origReadSync;\n      fs.existsSync = origExists;\n      fs.readFile = origRead;\n    },\n  };\n}\n\n// Drive the resolver across every hub and return the set of absolute paths the\n// serving path touched. `resolverPath` selects the authored or promoted graph.\nfunction traceClosure(resolverPath) {\n  const probe = instrument();\n  const priorFlag = process.env.SPECKIT_COMPILED_ROUTING;\n  process.env.SPECKIT_COMPILED_ROUTING = '1';\n  const resolved = {};\n  try {\n    // eslint-disable-next-line global-require, import/no-dynamic-require\n    const { resolveRoute } = require(resolverPath);\n    for (const hub of HUBS) {\n      let decision = null;\n      for (const prompt of PROBES) {\n        const route = resolveRoute(hub, prompt);\n        if (route) decision = route;\n      }\n      resolved[hub] = decision;\n    }\n  } finally {\n    if (priorFlag === undefined) delete process.env.SPECKIT_COMPILED_ROUTING;\n    else process.env.SPECKIT_COMPILED_ROUTING = priorFlag;\n    probe.restore();\n  }\n  return { touched: probe.touched, resolved };\n}\n\nfunction underImplRoot(abs) {\n  const rel = path.relative(IMPL_ROOT, abs);\n  return rel && !rel.startsWith('..') && !path.isAbsolute(rel);\n}\n\nfunction underSpecs(abs) {\n  const rel = path.relative(SPECS_ROOT, abs);\n  return rel === '' || (rel && !rel.startsWith('..') && !path.isAbsolute(rel));\n}\n\nfunction syncConflict(hubId) {\n  throw new Error(`sync-conflict: external activation manifest for ${hubId}`);\n}\n\nfunction activationManifestPath(activationRoot, hubId) {\n  if (!isCanonicalHubId(hubId)) syncConflict(String(hubId));\n  const root = path.resolve(activationRoot);\n  const manifestPath = path.resolve(root, hubId, 'manifest.json');\n  const relative = path.relative(root, manifestPath);\n  if (!relative || relative.startsWith('..') || path.isAbsolute(relative)) syncConflict(hubId);\n  return manifestPath;\n}\n\nfunction safeActivationRoot(activationRoot, create = false) {\n  const resolvedRoot = path.resolve(activationRoot);\n  if (create) fs.mkdirSync(resolvedRoot, { recursive: true, mode: 0o700 });\n  if (!fs.existsSync(resolvedRoot)) return null;\n  const rootStats = fs.lstatSync(resolvedRoot);\n  if (rootStats.isSymbolicLink() || !rootStats.isDirectory()) {\n    syncConflict('activation-root');\n  }\n  return { resolvedRoot, realRoot: fs.realpathSync(resolvedRoot) };\n}\n\nfunction ensureSafeManifestDirectory(root, manifestPath, hubId) {\n  const directoryPath = path.dirname(manifestPath);\n  if (fs.existsSync(directoryPath)) {\n    const directoryStats = fs.lstatSync(directoryPath);\n    if (directoryStats.isSymbolicLink() || !directoryStats.isDirectory()) {\n      syncConflict(hubId);\n    }\n  } else {\n    fs.mkdirSync(directoryPath, { recursive: true, mode: 0o700 });\n  }\n  const relative = path.relative(root.realRoot, fs.realpathSync(directoryPath));\n  if (relative.startsWith('..') || path.isAbsolute(relative)) syncConflict(hubId);\n}\n\nfunction readSafeManifestBytes(manifestPath, hubId) {\n  let manifestStats;\n  try {\n    manifestStats = fs.lstatSync(manifestPath);\n  } catch {\n    syncConflict(hubId);\n  }\n  if (manifestStats.isSymbolicLink() || !manifestStats.isFile()) syncConflict(hubId);\n  try {\n    return fs.readFileSync(manifestPath);\n  } catch {\n    syncConflict(hubId);\n  }\n}","lineStart":1,"lineEnd":190,"totalLines":399,"truncated":true}},"title":".opencode/bin/compiled-route-sync.cjs","time":{"start":1784693189214,"end":1784693189241}},"metadata":{"openai":{"itemId":"fc_0ecaf28beaf32475016a6041c518e881919febf81d24924519"}},"id":"prt_f8800ea580010L1GHkwW0qBTn6","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f8800bfe8001fiMdt5YeOKJQRy"}}
{"type":"tool_use","timestamp":1784693189254,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_BtuKLBVV12Dxs9gCbIkoATu5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: // Serving-authority resolver — the safety gate around the compiled engine.\n5: //\n6: // The compiled route is authoritative for a hub ONLY when all three hold:\n7: //   1. the runtime flag permits it — SPECKIT_COMPILED_ROUTING=1 forces compiled,\n8: //      unset lets the per-hub default-on cohort decide, and 0/false/off is the\n9: //      explicit fleet-wide kill-switch back to legacy;\n10: //   2. the hub's activation manifest has serving authority flipped to 'compiled';\n11: //   3. the routed snapshot's identity (effectivePolicyHash + generation) matches\n12: //      the manifest's selected policy — a drifted rollout artifact fails safe.\n13: //\n14: // Otherwise `resolveRoute` returns null and the caller keeps legacy routing.\n15: // The cutover stays reversible two ways — set the flag to 0 (fleet-wide) or flip\n16: // a hub's serving authority back to 'legacy' (per hub).\n17: \n18: const fs = require('fs');\n19: const path = require('path');\n20: const { compiledRoute } = require('./compiled-route.cjs');\n21: \n22: // Activation state root. Tests point SPECKIT_ACTIVATION_ROOT_OVERRIDE at a temp\n23: // copy so the harness never reads or mutates live committed state.\n24: const ACTIVATION_ROOT = process.env.SPECKIT_ACTIVATION_ROOT_OVERRIDE\n25:   || path.resolve(__dirname, '..', '..', '010-live-activation', 'activation');\n26: const FLAG = 'SPECKIT_COMPILED_ROUTING';\n27: const DEBUG_FLAG = 'SPECKIT_COMPILED_ROUTING_DEBUG';\n28: \n29: // Per-hub default-on cohort. All seven compiled-eligible hubs are verified\n30: // compiled-serving (Lane C parity: compiled byte-identical to legacy on every\n31: // scenario, 0 drift) and have been cut over together, so an unset flag now\n32: // resolves to compiled for every eligible hub. SPECKIT_COMPILED_ROUTING=0\n33: // remains the explicit fleet-wide kill-switch back to legacy.\n34: const DEFAULT_ON_HUBS = new Set([\n35:   'sk-code',\n36:   'system-deep-loop',\n37:   'mcp-tooling',\n38:   'cli-external-orchestration',\n39:   'sk-prompt',\n40:   'sk-design',\n41:   'sk-doc',\n42: ]);\n43: \n44: // Emit-only diagnostic. Gated behind an explicit debug flag and written to\n45: // stderr, so it never reaches stdout (the routing channel) or the TUI.\n46: function breadcrumb(message) {\n47:   if (process.env[DEBUG_FLAG]) {\n48:     process.stderr.write(`[compiled-routing] ${message}\\n`);\n49:   }\n50: }\n51: \n52: // Tri-state parse of the runtime flag:\n53: //   'force-on'     '1'                    serve compiled where a hub is eligible\n54: //   'force-legacy' '0' | 'false' | 'off'  explicit fleet-wide kill-switch\n55: //   'default'      unset                  per-hub cohort decides (empty => legacy)\n56: //   'invalid'      anything else          fail closed to legacy with a breadcrumb\n57: function parseFlagMode(raw) {\n58:   if (raw === undefined || raw === '') return 'default';\n59:   if (raw === '1') return 'force-on';\n60:   if (raw === '0' || raw === 'false' || raw === 'off') return 'force-legacy';\n61:   return 'invalid';\n62: }\n63: \n64: // Whether the flag permits compiled serving for this hub. The manifest\n65: // serving-authority gate in resolveRoute still applies on top of this, so a\n66: // permitted hub without a compiled manifest still routes legacy.\n67: function flagPermitsCompiled(hubId) {\n68:   const mode = parseFlagMode(process.env[FLAG]);\n69:   if (mode === 'force-on') return true;\n70:   if (mode === 'default') return DEFAULT_ON_HUBS.has(hubId);\n71:   if (mode === 'invalid') {\n72:     breadcrumb(`ignoring invalid ${FLAG}=${JSON.stringify(process.env[FLAG])}; serving legacy`);\n73:     return false;\n74:   }\n75:   return false; // force-legacy\n76: }\n77: \n78: // Retained export: true only when the operator forced the flag on, which is the\n79: // exact bi-state meaning callers of this predicate relied on before tri-state.\n80: function flagEnabled() {\n81:   return parseFlagMode(process.env[FLAG]) === 'force-on';\n82: }\n83: \n84: function readManifest(hubId) {\n85:   const manifest = path.join(ACTIVATION_ROOT, hubId, 'manifest.json');\n86:   if (!fs.existsSync(manifest)) return null;\n87:   try {\n88:     return JSON.parse(fs.readFileSync(manifest, 'utf8'));\n89:   } catch {\n90:     return null;\n91:   }\n92: }\n93: \n94: function servingAuthority(hubId) {\n95:   const manifest = readManifest(hubId);\n96:   return (manifest && manifest.servingAuthority) || 'legacy';\n97: }\n98: \n99: // Returns a normalized compiled decision when this hub is served by the compiled\n100: // contract and the flag is on; otherwise null (use legacy routing). Fails safe:\n101: // any error resolving the compiled route returns null rather than throwing into\n102: // a routing hot path.\n103: function resolveRoute(hubId, taskText) {\n104:   if (!flagPermitsCompiled(hubId)) return null;\n105:   const manifest = readManifest(hubId);\n106:   if (!manifest || manifest.servingAuthority !== 'compiled') return null;\n107:   try {\n108:     const route = compiledRoute(hubId, taskText);\n109:     // Serve-time identity binding: the snapshot we routed through MUST be the\n110:     // exact generation the manifest selected. If a rollout artifact drifted after\n111:     // the flip, the identities diverge — fail safe to legacy rather than serve an\n112:     // unselected policy on the routing hot path.\n113:     const selected = manifest.selectedPolicy || {};\n114:     if (route.effectivePolicyHash !== selected.effectivePolicyHash\n115:       || route.generation !== selected.generation) {\n116:       return null;\n117:     }\n118:     return route;\n119:   } catch (err) {\n120:     breadcrumb(`resolveRoute fell back to legacy for hub=${hubId}: ${err && err.message}`);\n121:     return null;\n122:   }\n123: }\n124: \n125: module.exports = {\n126:   resolveRoute,\n127:   servingAuthority,\n128:   flagEnabled,\n129:   flagPermitsCompiled,\n130:   parseFlagMode,\n131:   DEFAULT_ON_HUBS,\n132:   FLAG,\n133:   DEBUG_FLAG,\n134:   ACTIVATION_ROOT,\n135: };\n136: \n137: // CLI front door: the invocable entry a compiled-serving hub's SKILL.md routing\n138: // directive calls. Prints the compiled decision when authoritative, else a\n139: // legacy sentinel so the caller falls back to the prose smart-router.\n140: if (require.main === module) {\n141:   const args = process.argv.slice(2);\n142:   const hub = args[args.indexOf('--hub') + 1];\n143:   const promptIdx = args.indexOf('--prompt');\n144:   const prompt = promptIdx >= 0 ? args[promptIdx + 1] : '';\n145:   if (!hub) {\n146:     process.stderr.write('usage: resolve.cjs --hub <hubId> --prompt <text>\\n');\n147:     process.exit(2);\n148:   }\n149:   const route = resolveRoute(hub, prompt);\n150:   process.stdout.write(`${JSON.stringify(route || { servingAuthority: 'legacy', hubId: hub })}\\n`);\n151: }\n\n(End of file - total 151 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n// Serving-authority resolver — the safety gate around the compiled engine.\n//\n// The compiled route is authoritative for a hub ONLY when all three hold:\n//   1. the runtime flag permits it — SPECKIT_COMPILED_ROUTING=1 forces compiled,\n//      unset lets the per-hub default-on cohort decide, and 0/false/off is the\n//      explicit fleet-wide kill-switch back to legacy;\n//   2. the hub's activation manifest has serving authority flipped to 'compiled';\n//   3. the routed snapshot's identity (effectivePolicyHash + generation) matches\n//      the manifest's selected policy — a drifted rollout artifact fails safe.\n//\n// Otherwise `resolveRoute` returns null and the caller keeps legacy routing.\n// The cutover stays reversible two ways — set the flag to 0 (fleet-wide) or flip\n// a hub's serving authority back to 'legacy' (per hub).\n\nconst fs = require('fs');\nconst path = require('path');\nconst { compiledRoute } = require('./compiled-route.cjs');","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs","text":"#!/usr/bin/env node\n'use strict';\n\n// Serving-authority resolver — the safety gate around the compiled engine.\n//\n// The compiled route is authoritative for a hub ONLY when all three hold:\n//   1. the runtime flag permits it — SPECKIT_COMPILED_ROUTING=1 forces compiled,\n//      unset lets the per-hub default-on cohort decide, and 0/false/off is the\n//      explicit fleet-wide kill-switch back to legacy;\n//   2. the hub's activation manifest has serving authority flipped to 'compiled';\n//   3. the routed snapshot's identity (effectivePolicyHash + generation) matches\n//      the manifest's selected policy — a drifted rollout artifact fails safe.\n//\n// Otherwise `resolveRoute` returns null and the caller keeps legacy routing.\n// The cutover stays reversible two ways — set the flag to 0 (fleet-wide) or flip\n// a hub's serving authority back to 'legacy' (per hub).\n\nconst fs = require('fs');\nconst path = require('path');\nconst { compiledRoute } = require('./compiled-route.cjs');\n\n// Activation state root. Tests point SPECKIT_ACTIVATION_ROOT_OVERRIDE at a temp\n// copy so the harness never reads or mutates live committed state.\nconst ACTIVATION_ROOT = process.env.SPECKIT_ACTIVATION_ROOT_OVERRIDE\n  || path.resolve(__dirname, '..', '..', '010-live-activation', 'activation');\nconst FLAG = 'SPECKIT_COMPILED_ROUTING';\nconst DEBUG_FLAG = 'SPECKIT_COMPILED_ROUTING_DEBUG';\n\n// Per-hub default-on cohort. All seven compiled-eligible hubs are verified\n// compiled-serving (Lane C parity: compiled byte-identical to legacy on every\n// scenario, 0 drift) and have been cut over together, so an unset flag now\n// resolves to compiled for every eligible hub. SPECKIT_COMPILED_ROUTING=0\n// remains the explicit fleet-wide kill-switch back to legacy.\nconst DEFAULT_ON_HUBS = new Set([\n  'sk-code',\n  'system-deep-loop',\n  'mcp-tooling',\n  'cli-external-orchestration',\n  'sk-prompt',\n  'sk-design',\n  'sk-doc',\n]);\n\n// Emit-only diagnostic. Gated behind an explicit debug flag and written to\n// stderr, so it never reaches stdout (the routing channel) or the TUI.\nfunction breadcrumb(message) {\n  if (process.env[DEBUG_FLAG]) {\n    process.stderr.write(`[compiled-routing] ${message}\\n`);\n  }\n}\n\n// Tri-state parse of the runtime flag:\n//   'force-on'     '1'                    serve compiled where a hub is eligible\n//   'force-legacy' '0' | 'false' | 'off'  explicit fleet-wide kill-switch\n//   'default'      unset                  per-hub cohort decides (empty => legacy)\n//   'invalid'      anything else          fail closed to legacy with a breadcrumb\nfunction parseFlagMode(raw) {\n  if (raw === undefined || raw === '') return 'default';\n  if (raw === '1') return 'force-on';\n  if (raw === '0' || raw === 'false' || raw === 'off') return 'force-legacy';\n  return 'invalid';\n}\n\n// Whether the flag permits compiled serving for this hub. The manifest\n// serving-authority gate in resolveRoute still applies on top of this, so a\n// permitted hub without a compiled manifest still routes legacy.\nfunction flagPermitsCompiled(hubId) {\n  const mode = parseFlagMode(process.env[FLAG]);\n  if (mode === 'force-on') return true;\n  if (mode === 'default') return DEFAULT_ON_HUBS.has(hubId);\n  if (mode === 'invalid') {\n    breadcrumb(`ignoring invalid ${FLAG}=${JSON.stringify(process.env[FLAG])}; serving legacy`);\n    return false;\n  }\n  return false; // force-legacy\n}\n\n// Retained export: true only when the operator forced the flag on, which is the\n// exact bi-state meaning callers of this predicate relied on before tri-state.\nfunction flagEnabled() {\n  return parseFlagMode(process.env[FLAG]) === 'force-on';\n}\n\nfunction readManifest(hubId) {\n  const manifest = path.join(ACTIVATION_ROOT, hubId, 'manifest.json');\n  if (!fs.existsSync(manifest)) return null;\n  try {\n    return JSON.parse(fs.readFileSync(manifest, 'utf8'));\n  } catch {\n    return null;\n  }\n}\n\nfunction servingAuthority(hubId) {\n  const manifest = readManifest(hubId);\n  return (manifest && manifest.servingAuthority) || 'legacy';\n}\n\n// Returns a normalized compiled decision when this hub is served by the compiled\n// contract and the flag is on; otherwise null (use legacy routing). Fails safe:\n// any error resolving the compiled route returns null rather than throwing into\n// a routing hot path.\nfunction resolveRoute(hubId, taskText) {\n  if (!flagPermitsCompiled(hubId)) return null;\n  const manifest = readManifest(hubId);\n  if (!manifest || manifest.servingAuthority !== 'compiled') return null;\n  try {\n    const route = compiledRoute(hubId, taskText);\n    // Serve-time identity binding: the snapshot we routed through MUST be the\n    // exact generation the manifest selected. If a rollout artifact drifted after\n    // the flip, the identities diverge — fail safe to legacy rather than serve an\n    // unselected policy on the routing hot path.\n    const selected = manifest.selectedPolicy || {};\n    if (route.effectivePolicyHash !== selected.effectivePolicyHash\n      || route.generation !== selected.generation) {\n      return null;\n    }\n    return route;\n  } catch (err) {\n    breadcrumb(`resolveRoute fell back to legacy for hub=${hubId}: ${err && err.message}`);\n    return null;\n  }\n}\n\nmodule.exports = {\n  resolveRoute,\n  servingAuthority,\n  flagEnabled,\n  flagPermitsCompiled,\n  parseFlagMode,\n  DEFAULT_ON_HUBS,\n  FLAG,\n  DEBUG_FLAG,\n  ACTIVATION_ROOT,\n};\n\n// CLI front door: the invocable entry a compiled-serving hub's SKILL.md routing\n// directive calls. Prints the compiled decision when authoritative, else a\n// legacy sentinel so the caller falls back to the prose smart-router.\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const hub = args[args.indexOf('--hub') + 1];\n  const promptIdx = args.indexOf('--prompt');\n  const prompt = promptIdx >= 0 ? args[promptIdx + 1] : '';\n  if (!hub) {\n    process.stderr.write('usage: resolve.cjs --hub <hubId> --prompt <text>\\n');\n    process.exit(2);\n  }\n  const route = resolveRoute(hub, prompt);\n  process.stdout.write(`${JSON.stringify(route || { servingAuthority: 'legacy', hubId: hub })}\\n`);\n}","lineStart":1,"lineEnd":151,"totalLines":151,"truncated":false}},"title":".opencode/bin/lib/compiled-routing/011-runtime-engine/lib/resolve.cjs","time":{"start":1784693189194,"end":1784693189250}},"metadata":{"openai":{"itemId":"fc_0ecaf28beaf32475016a6041c518d08191be6b02db97975cee"}},"id":"prt_f8800ea12001oGEjCCaIu87RjC","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f8800bfe8001fiMdt5YeOKJQRy"}}
{"type":"tool_use","timestamp":1784693189266,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"glob","callID":"call_D7NrQGUXuWtWF6WzbQolqshW","state":{"status":"completed","input":{"pattern":"**/011-runtime-engine/lib/resolve.cjs","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/specs/sk-doc/019-sk-doc-router-alignment"},"output":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/resolve.cjs","metadata":{"count":1,"truncated":false},"title":".opencode/specs/sk-doc/019-sk-doc-router-alignment","time":{"start":1784693189206,"end":1784693189255}},"metadata":{"openai":{"itemId":"fc_0ecaf28beaf32475016a6041c518e08191a8492b9e6eb3d05c"}},"id":"prt_f8800ea4e00177R0CU274s1I7e","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f8800bfe8001fiMdt5YeOKJQRy"}}
{"type":"tool_use","timestamp":1784693189266,"sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","part":{"type":"tool","tool":"read","callID":"call_fcYSkaKhuaNDgDyzJ9v2QUTZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-skill-advisor/mcp-server/lib/compiled-routing-flag.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-skill-advisor/mcp-server/lib/compiled-routing-flag.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Compiled-routing flag (tri-state) + hub eligibility set\n3: // ───────────────────────────────────────────────────────────────\n4: //\n5: // Single source for the advisor recommend path's view of the compiled-routing\n6: // runtime flag and the hubs it may enrich. Kept dependency-free so the runtime\n7: // and the cross-site truth-table test read exactly the same semantics, and so a\n8: // cross-check test can assert this hub set never diverges from the runtime\n9: // engine-dispatch map.\n10: \n11: // Hubs the advisor may attach a compiled route for. Eligibility to actually\n12: // serve compiled is decided downstream by manifest freshness in the resolver;\n13: // this is only the set the advisor will probe.\n14: export const COMPILED_ROUTING_HUBS: ReadonlySet<string> = new Set([\n15:   'sk-code',\n16:   'mcp-tooling',\n17:   'system-deep-loop',\n18:   'cli-external-orchestration',\n19:   'sk-prompt',\n20:   'sk-design',\n21:   'sk-doc',\n22: ]);\n23: \n24: // Per-hub default-on cohort. Mirrors the runtime resolver's own default-on\n25: // cohort (all 7 hubs verified compiled-serving, 0 drift — see\n26: // `011-runtime-engine/lib/resolve.cjs`): this enrichment shells out to the same\n27: // public front door (`.opencode/bin/compiled-route.cjs`), which delegates to\n28: // that identical resolver, so surfacing it here attaches only additive\n29: // metadata and never changes which skill is recommended. An unset flag now\n30: // attaches `compiledRoute` for these hubs; SPECKIT_COMPILED_ROUTING=0 remains\n31: // the explicit fleet-wide kill-switch (no field attached, legacy shape).\n32: export const DEFAULT_ON_HUBS: ReadonlySet<string> = new Set([\n33:   'sk-code',\n34:   'mcp-tooling',\n35:   'system-deep-loop',\n36:   'cli-external-orchestration',\n37:   'sk-prompt',\n38:   'sk-design',\n39:   'sk-doc',\n40: ]);\n41: \n42: export type CompiledRoutingFlagMode = 'force-on' | 'force-legacy' | 'default' | 'invalid';\n43: \n44: // Tri-state parse of SPECKIT_COMPILED_ROUTING:\n45: //   'force-on'     '1'                    serve compiled where a hub is eligible\n46: //   'force-legacy' '0' | 'false' | 'off'  explicit fleet-wide kill-switch\n47: //   'default'      unset                  per-hub cohort decides (empty => legacy)\n48: //   'invalid'      anything else          fail closed to legacy\n49: export function parseCompiledRoutingFlagMode(raw: string | undefined): CompiledRoutingFlagMode {\n50:   if (raw === undefined || raw === '') return 'default';\n51:   if (raw === '1') return 'force-on';\n52:   if (raw === '0' || raw === 'false' || raw === 'off') return 'force-legacy';\n53:   return 'invalid';\n54: }\n55: \n56: // Whether the flag permits the advisor to attach a compiled route for this hub.\n57: export function compiledRoutingEnabledForHub(\n58:   hubId: string,\n59:   raw: string | undefined = process.env.SPECKIT_COMPILED_ROUTING,\n60: ): boolean {\n61:   const mode = parseCompiledRoutingFlagMode(raw);\n62:   if (mode === 'force-on') return true;\n63:   if (mode === 'default') return DEFAULT_ON_HUBS.has(hubId);\n64:   return false; // force-legacy | invalid\n65: }\n\n(End of file - total 65 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Compiled-routing flag (tri-state) + hub eligibility set\n// ───────────────────────────────────────────────────────────────\n//\n// Single source for the advisor recommend path's view of the compiled-routing\n// runtime flag and the hubs it may enrich. Kept dependency-free so the runtime\n// and the cross-site truth-table test read exactly the same semantics, and so a\n// cross-check test can assert this hub set never diverges from the runtime\n// engine-dispatch map.\n\n// Hubs the advisor may attach a compiled route for. Eligibility to actually\n// serve compiled is decided downstream by manifest freshness in the resolver;\n// this is only the set the advisor will probe.\nexport const COMPILED_ROUTING_HUBS: ReadonlySet<string> = new Set([\n  'sk-code',\n  'mcp-tooling',\n  'system-deep-loop',\n  'cli-external-orchestration',\n  'sk-prompt',\n  'sk-design',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0089-sk-doc-default-routing-cutover/.opencode/skills/system-skill-advisor/mcp-server/lib/compiled-routing-flag.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Compiled-routing flag (tri-state) + hub eligibility set\n// ───────────────────────────────────────────────────────────────\n//\n// Single source for the advisor recommend path's view of the compiled-routing\n// runtime flag and the hubs it may enrich. Kept dependency-free so the runtime\n// and the cross-site truth-table test read exactly the same semantics, and so a\n// cross-check test can assert this hub set never diverges from the runtime\n// engine-dispatch map.\n\n// Hubs the advisor may attach a compiled route for. Eligibility to actually\n// serve compiled is decided downstream by manifest freshness in the resolver;\n// this is only the set the advisor will probe.\nexport const COMPILED_ROUTING_HUBS: ReadonlySet<string> = new Set([\n  'sk-code',\n  'mcp-tooling',\n  'system-deep-loop',\n  'cli-external-orchestration',\n  'sk-prompt',\n  'sk-design',\n  'sk-doc',\n]);\n\n// Per-hub default-on cohort. Mirrors the runtime resolver's own default-on\n// cohort (all 7 hubs verified compiled-serving, 0 drift — see\n// `011-runtime-engine/lib/resolve.cjs`): this enrichment shells out to the same\n// public front door (`.opencode/bin/compiled-route.cjs`), which delegates to\n// that identical resolver, so surfacing it here attaches only additive\n// metadata and never changes which skill is recommended. An unset flag now\n// attaches `compiledRoute` for these hubs; SPECKIT_COMPILED_ROUTING=0 remains\n// the explicit fleet-wide kill-switch (no field attached, legacy shape).\nexport const DEFAULT_ON_HUBS: ReadonlySet<string> = new Set([\n  'sk-code',\n  'mcp-tooling',\n  'system-deep-loop',\n  'cli-external-orchestration',\n  'sk-prompt',\n  'sk-design',\n  'sk-doc',\n]);\n\nexport type CompiledRoutingFlagMode = 'force-on' | 'force-legacy' | 'default' | 'invalid';\n\n// Tri-state parse of SPECKIT_COMPILED_ROUTING:\n//   'force-on'     '1'                    serve compiled where a hub is eligible\n//   'force-legacy' '0' | 'false' | 'off'  explicit fleet-wide kill-switch\n//   'default'      unset                  per-hub cohort decides (empty => legacy)\n//   'invalid'      anything else          fail closed to legacy\nexport function parseCompiledRoutingFlagMode(raw: string | undefined): CompiledRoutingFlagMode {\n  if (raw === undefined || raw === '') return 'default';\n  if (raw === '1') return 'force-on';\n  if (raw === '0' || raw === 'false' || raw === 'off') return 'force-legacy';\n  return 'invalid';\n}\n\n// Whether the flag permits the advisor to attach a compiled route for this hub.\nexport function compiledRoutingEnabledForHub(\n  hubId: string,\n  raw: string | undefined = process.env.SPECKIT_COMPILED_ROUTING,\n): boolean {\n  const mode = parseCompiledRoutingFlagMode(raw);\n  if (mode === 'force-on') return true;\n  if (mode === 'default') return DEFAULT_ON_HUBS.has(hubId);\n  return false; // force-legacy | invalid\n}","lineStart":1,"lineEnd":65,"totalLines":65,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp-server/lib/compiled-routing-flag.ts","time":{"start":1784693189221,"end":1784693189263}},"metadata":{"openai":{"itemId":"fc_0ecaf28beaf32475016a6041c518ec8191b0bf805bb5d85857"}},"id":"prt_f8800ea60001yPFpTp3g4864fM","sessionID":"ses_07813ae6bffeXSfNUcMKmjadEz","messageID":"msg_f8800bfe8001fiMdt5YeOKJQRy"}}
