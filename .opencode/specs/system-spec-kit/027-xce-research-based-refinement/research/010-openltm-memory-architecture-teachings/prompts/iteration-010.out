{"type":"tool_use","timestamp":1780925753526,"sessionID":"ses_158903c24ffeYh4HmE3B8vB3CW","part":{"type":"tool","tool":"read","callID":"call_0FSa1BDKPsLLpLKwll3IcQd3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/src/mcp-server.ts","offset":1,"limit":75},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/src/mcp-server.ts</path>\n<type>file</type>\n<content>\n1: /**\n2:  * mcp-server.ts — LTM MCP Server (STDIO transport)\n3:  * Exposes the Long-Term Memory system as a proper MCP server.\n4:  * IMPORTANT: Never use console.log() — STDIO transport uses stdout for protocol.\n5:  */\n6: import { McpServer, ResourceTemplate } from \"@modelcontextprotocol/sdk/server/mcp.js\";\n7: import { StdioServerTransport } from \"@modelcontextprotocol/sdk/server/stdio.js\";\n8: import { z } from \"zod\";\n9: import { getDb, learn, recall, relate, forget, getContextMerge, type Memory,\n10:          queryAudit, getItems, traverseGraph, buildReasoningContext } from \"@rohirik/openltm-core\";\n11: \n12: // ─── Config check ────────────────────────────────────────────────────────────\n13: \n14: async function isEnabled(): Promise<boolean> {\n15:   try {\n16:     const { readConfigSync } = await import(\"./config.js\");\n17:     const cfg = readConfigSync() as Record<string, unknown>;\n18:     const mcp = cfg[\"mcp\"] as { enabled?: boolean } | undefined;\n19:     return mcp?.enabled !== false; // default true if not set\n20:   } catch {\n21:     return true;\n22:   }\n23: }\n24: \n25: // Embedding excluded at the SQL query level — strip() is now a no-op passthrough kept for call-site compatibility.\n26: function strip(obj: unknown): unknown { return obj; }\n27: \n28: /** Compact formatter — strips verbose fields and truncates content to keep MCP responses small. */\n29: function compact(memories: unknown[]): unknown[] {\n30:   const MAX_CONTENT = 300;\n31:   return memories.map(m => {\n32:     const mem = m as Record<string, unknown>;\n33:     const content = typeof mem.content === \"string\" && mem.content.length > MAX_CONTENT\n34:       ? mem.content.slice(0, MAX_CONTENT) + \"…\"\n35:       : mem.content;\n36:     const relations = Array.isArray(mem.relations) && mem.relations.length > 0\n37:       ? { relations: mem.relations.map((r: Record<string, unknown>) => ({ id: (r.memory as Record<string, unknown>)?.id, type: r.relationship_type, dir: r.direction })) }\n38:       : {};\n39:     const exp = mem.explainer as Record<string, unknown> | undefined;\n40:     const score = exp\n41:       ? { temperature: exp.temperature, score: typeof exp.totalScore === \"number\" ? Math.round(exp.totalScore * 100) / 100 : undefined }\n42:       : {};\n43:     return { id: mem.id, content, category: mem.category, importance: mem.importance, tags: mem.tags, project_scope: mem.project_scope, ...score, ...relations };\n44:   });\n45: }\n46: \n47: // ─── Server ──────────────────────────────────────────────────────────────────\n48: \n49: const server = new McpServer(\n50:   { name: \"openltm\", version: \"1.0.0\" },\n51:   {},\n52: );\n53: \n54: // ─── Tools ───────────────────────────────────────────────────────────────────\n55: \n56: server.tool(\n57:   \"recall\",\n58:   \"Surface prior decisions, gotchas, and patterns before a non-trivial task, or when starting work in an unfamiliar area. Ranks long-term memories by query, category, project scope, or tags. Skip for trivial one-liners.\",\n59:   {\n60:     query: z.string().optional().describe(\"Full-text search query\"),\n61:     project: z.string().optional().describe(\"Filter by project scope\"),\n62:     limit: z.number().int().min(1).max(50).optional().describe(\"Max results (default 10)\"),\n63:     category: z.enum([\"preference\", \"architecture\", \"gotcha\", \"pattern\", \"workflow\", \"constraint\"]).optional(),\n64:     verbose: z.boolean().optional().describe(\"Return full memory objects (default false)\"),\n65:     since: z.string().optional().describe(\"Filter: memories after this ISO date\"),\n66:     until: z.string().optional().describe(\"Filter: memories before this ISO date\"),\n67:     sort_by: z.enum([\"relevance\", \"created\", \"last_recalled\", \"recall_count\"]).optional().describe(\"Sort results by\"),\n68:     workspace_id: z.string().optional().describe(\"Filter by workspace\"),\n69:     agent_id: z.string().optional().describe(\"Filter by agent\"),\n70:     includeProvenance: z.boolean().optional().default(false).describe(\"Attach provenance chain to each result (off by default)\"),\n71:   },\n72:   async ({ query, project, limit, category, verbose, since, until, sort_by, includeProvenance }) => {\n73:     const results = await recall({ query, project, limit, category, since, until, sort_by, includeProvenance });\n74:     const payload = verbose ? strip(results) : compact(strip(results) as unknown[]);\n75:     return { content: [{ type: \"text\", text: JSON.stringify(payload) }] };\n\n(Showing lines 1-75 of 433. Use offset=76 to continue.)\n</content>","metadata":{"preview":"/**\n * mcp-server.ts — LTM MCP Server (STDIO transport)\n * Exposes the Long-Term Memory system as a proper MCP server.\n * IMPORTANT: Never use console.log() — STDIO transport uses stdout for protocol.\n */\nimport { McpServer, ResourceTemplate } from \"@modelcontextprotocol/sdk/server/mcp.js\";\nimport { StdioServerTransport } from \"@modelcontextprotocol/sdk/server/stdio.js\";\nimport { z } from \"zod\";\nimport { getDb, learn, recall, relate, forget, getContextMerge, type Memory,\n         queryAudit, getItems, traverseGraph, buildReasoningContext } from \"@rohirik/openltm-core\";\n\n// ─── Config check ────────────────────────────────────────────────────────────\n\nasync function isEnabled(): Promise<boolean> {\n  try {\n    const { readConfigSync } = await import(\"./config.js\");\n    const cfg = readConfigSync() as Record<string, unknown>;\n    const mcp = cfg[\"mcp\"] as { enabled?: boolean } | undefined;\n    return mcp?.enabled !== false; // default true if not set\n  } catch {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/src/mcp-server.ts","text":"/**\n * mcp-server.ts — LTM MCP Server (STDIO transport)\n * Exposes the Long-Term Memory system as a proper MCP server.\n * IMPORTANT: Never use console.log() — STDIO transport uses stdout for protocol.\n */\nimport { McpServer, ResourceTemplate } from \"@modelcontextprotocol/sdk/server/mcp.js\";\nimport { StdioServerTransport } from \"@modelcontextprotocol/sdk/server/stdio.js\";\nimport { z } from \"zod\";\nimport { getDb, learn, recall, relate, forget, getContextMerge, type Memory,\n         queryAudit, getItems, traverseGraph, buildReasoningContext } from \"@rohirik/openltm-core\";\n\n// ─── Config check ────────────────────────────────────────────────────────────\n\nasync function isEnabled(): Promise<boolean> {\n  try {\n    const { readConfigSync } = await import(\"./config.js\");\n    const cfg = readConfigSync() as Record<string, unknown>;\n    const mcp = cfg[\"mcp\"] as { enabled?: boolean } | undefined;\n    return mcp?.enabled !== false; // default true if not set\n  } catch {\n    return true;\n  }\n}\n\n// Embedding excluded at the SQL query level — strip() is now a no-op passthrough kept for call-site compatibility.\nfunction strip(obj: unknown): unknown { return obj; }\n\n/** Compact formatter — strips verbose fields and truncates content to keep MCP responses small. */\nfunction compact(memories: unknown[]): unknown[] {\n  const MAX_CONTENT = 300;\n  return memories.map(m => {\n    const mem = m as Record<string, unknown>;\n    const content = typeof mem.content === \"string\" && mem.content.length > MAX_CONTENT\n      ? mem.content.slice(0, MAX_CONTENT) + \"…\"\n      : mem.content;\n    const relations = Array.isArray(mem.relations) && mem.relations.length > 0\n      ? { relations: mem.relations.map((r: Record<string, unknown>) => ({ id: (r.memory as Record<string, unknown>)?.id, type: r.relationship_type, dir: r.direction })) }\n      : {};\n    const exp = mem.explainer as Record<string, unknown> | undefined;\n    const score = exp\n      ? { temperature: exp.temperature, score: typeof exp.totalScore === \"number\" ? Math.round(exp.totalScore * 100) / 100 : undefined }\n      : {};\n    return { id: mem.id, content, category: mem.category, importance: mem.importance, tags: mem.tags, project_scope: mem.project_scope, ...score, ...relations };\n  });\n}\n\n// ─── Server ──────────────────────────────────────────────────────────────────\n\nconst server = new McpServer(\n  { name: \"openltm\", version: \"1.0.0\" },\n  {},\n);\n\n// ─── Tools ───────────────────────────────────────────────────────────────────\n\nserver.tool(\n  \"recall\",\n  \"Surface prior decisions, gotchas, and patterns before a non-trivial task, or when starting work in an unfamiliar area. Ranks long-term memories by query, category, project scope, or tags. Skip for trivial one-liners.\",\n  {\n    query: z.string().optional().describe(\"Full-text search query\"),\n    project: z.string().optional().describe(\"Filter by project scope\"),\n    limit: z.number().int().min(1).max(50).optional().describe(\"Max results (default 10)\"),\n    category: z.enum([\"preference\", \"architecture\", \"gotcha\", \"pattern\", \"workflow\", \"constraint\"]).optional(),\n    verbose: z.boolean().optional().describe(\"Return full memory objects (default false)\"),\n    since: z.string().optional().describe(\"Filter: memories after this ISO date\"),\n    until: z.string().optional().describe(\"Filter: memories before this ISO date\"),\n    sort_by: z.enum([\"relevance\", \"created\", \"last_recalled\", \"recall_count\"]).optional().describe(\"Sort results by\"),\n    workspace_id: z.string().optional().describe(\"Filter by workspace\"),\n    agent_id: z.string().optional().describe(\"Filter by agent\"),\n    includeProvenance: z.boolean().optional().default(false).describe(\"Attach provenance chain to each result (off by default)\"),\n  },\n  async ({ query, project, limit, category, verbose, since, until, sort_by, includeProvenance }) => {\n    const results = await recall({ query, project, limit, category, since, until, sort_by, includeProvenance });\n    const payload = verbose ? strip(results) : compact(strip(results) as unknown[]);\n    return { content: [{ type: \"text\", text: JSON.stringify(payload) }] };","lineStart":1,"lineEnd":75,"totalLines":433,"truncated":true}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/src/mcp-server.ts","time":{"start":1780925753504,"end":1780925753524}},"metadata":{"openai":{"itemId":"fc_02fe22e433e53793016a26c53873548191a1afd38a1d458c54"}},"id":"prt_ea77264a1001hK7d10KVJeHjZw","sessionID":"ses_158903c24ffeYh4HmE3B8vB3CW","messageID":"msg_ea7725353001BtSK1j4YOoLXDA"}}
