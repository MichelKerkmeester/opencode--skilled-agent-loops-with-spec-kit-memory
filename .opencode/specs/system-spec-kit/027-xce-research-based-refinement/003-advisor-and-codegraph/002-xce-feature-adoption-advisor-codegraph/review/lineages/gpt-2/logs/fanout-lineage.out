  \"depends_on\": [],\n19:     \"supersedes\": [],\n20:     \"related_to\": []\n21:   },\n22:   \"derived\": {\n23:     \"trigger_phrases\": [\n24:       \"145-xce-feature-adoption-advisor-codegraph\",\n25:       \"advisor 027 feature adoption\",\n26:       \"code graph 027 feature adoption\",\n27:       \"phase parent\"\n28:     ],\n29:     \"key_topics\": [\n30:       \"145-xce-feature-adoption-advisor-codegraph\",\n31:       \"advisor\",\n32:       \"027\",\n33:       \"feature\",\n34:       \"adoption\",\n35:       \"code\",\n36:       \"graph\",\n37:       \"phase\",\n38:       \"parent\",\n39:       \"spec-027\",\n40:       \"hardened\",\n41:       \"spec\"\n42:     ],\n43:     \"importance_tier\": \"important\",\n44:     \"status\": \"planned\",\n45:     \"key_files\": [\n46:       \"spec.md\"\n47:     ],\n48:     \"entities\": [\n49:       {\n50:         \"name\": \"spec.md\",\n51:         \"kind\": \"doc\",\n52:         \"path\": \"spec.md\",\n53:         \"source\": \"derived\"\n54:       },\n55:       {\n56:         \"name\": \"Feature Specification\",\n57:         \"kind\": \"proper_noun\",\n58:         \"path\": \"spec.md\",\n59:         \"source\": \"derived\"\n60:       },\n61:       {\n62:         \"name\": \"Skill Advisor\",\n63:         \"kind\": \"proper_noun\",\n64:         \"path\": \"spec.md\",\n65:         \"source\": \"derived\"\n66:       },\n67:       {\n68:         \"name\": \"Code Graph\",\n69:         \"kind\": \"proper_noun\",\n70:         \"path\": \"spec.md\",\n71:         \"source\": \"derived\"\n72:       },\n73:       {\n74:         \"name\": \"Parent Spec\",\n75:         \"kind\": \"proper_noun\",\n76:         \"path\": \"spec.md\",\n77:         \"source\": \"derived\"\n78:       },\n79:       {\n80:         \"name\": \"Parent Packet\",\n81:         \"kind\": \"proper_noun\",\n82:         \"path\": \"spec.md\",\n83:         \"source\": \"derived\"\n84:       },\n85:       {\n86:         \"name\": \"Handoff Criteria\",\n87:         \"kind\": \"proper_noun\",\n88:         \"path\": \"spec.md\",\n89:         \"source\": \"derived\"\n90:       }\n91:     ],\n92:     \"causal_summary\": \"Spec-027 hardened the Spec Kit Memory system with retrieval observability, a provenance-overwrite guard, packed BM25/BM25F lexical search, shared app-level BFS traversal, shadow feedback reducers, and soft-delete tombstones. The sibling daemon systems (`mk_skill_advisor` and `mk_code_index`) carry the same gaps that 027 closed: the advisor strips ranker evidence at output, has no manual-provenance guard on auto-edge writes, runs a token-overlap lexical lane, hand-rolls BFS, and never reuses validate outcomes; the code graph hard-deletes nodes/edges without audit, hand-rolls two BFS paths, returns no per-file chain breadcrumbs, and matches symbols by exact equality only. A ranked read-only analysis identified the ten transfers worth doing and rejected the rest.\",\n93:     \"created_at\": \"2026-06-10T19:24:08Z\",\n94:     \"last_save_at\": \"2026-06-10T19:41:16.121Z\",\n95:     \"save_lineage\": \"graph_only\",\n96:     \"last_accessed_at\": null,\n97:     \"source_docs\": [\n98:       \"spec.md\"\n99:     ],\n100:     \"last_active_child_id\": null,\n101:     \"last_active_at\": null\n102:   }\n103: }\n\n(End of file - total 103 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 1,\n  \"packet_id\": \"skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph\",\n  \"spec_folder\": \"skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph\",\n  \"parent_id\": null,\n  \"children_ids\": [\n    \"skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/001-advisor-observability\",\n    \"skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/002-advisor-provenance-guard\",\n    \"skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/003-advisor-packed-bm25-lexical\",\n    \"skilled-agent-orchestration/145-xce-feature-adopti