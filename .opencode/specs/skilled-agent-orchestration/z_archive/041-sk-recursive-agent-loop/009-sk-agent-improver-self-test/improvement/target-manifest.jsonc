{
  // Full-skill surface classification for sk-improve-agent.
  "version": 2,
  "defaultMode": "proposal-first",

  // When true, agents without a static profile in profileCatalog can be
  // evaluated using generate-profile.cjs to derive scoring from the agent's
  // own structure and rules. Dynamic profiles are not promotion-eligible.
  "dynamicProfileEnabled": true,

  // Path to the script that generates a dynamic target profile on the fly.
  // Called with --dynamic <agent-path> when dynamicProfileEnabled is true
  // and no static profile matches the target.
  "dynamicProfileScript": ".opencode/skills/sk-improve-agent/scripts/generate-profile.cjs",

  // Path to the integration-surface scanner that checks mirror parity,
  // command coverage, permission alignment, and resource references
  // for a given target agent across all runtime directories.
  "integrationScanScript": ".opencode/skills/sk-improve-agent/scripts/scan-integration.cjs",
  "profileCatalog": ".opencode/skills/sk-improve-agent/assets/target-profiles",
  "targets": [
    {
      "id": "handover-canonical",
      "profileId": "handover",
      "family": "session-handover",
      "path": ".opencode/agents/handover.md",
      "classification": "canonical",
      "mutableInPhase1": false,
      "candidateOnly": false,
      "promotionEligible": true,
      "evaluationMode": "prompt-surface+benchmark",
      "requiredReferences": [
        "spec.md",
        "plan.md",
        "tasks.md",
        "checklist.md",
        "memory/",
        ".opencode/skills/system-spec-kit/templates/handover.md"
      ]
    },
    {
      "id": "handover-claude",
      "profileId": "handover",
      "family": "session-handover",
      "path": ".claude/agents/handover.md",
      "classification": "derived",
      "mutableInPhase1": false
    },
    {
      "id": "handover-codex",
      "profileId": "handover",
      "family": "session-handover",
      "path": ".codex/agents/handover.toml",
      "classification": "derived",
      "mutableInPhase1": false
    },
    {
      "id": "handover-gemini",
      "profileId": "handover",
      "family": "session-handover",
      "path": ".gemini/agents/handover.md",
      "classification": "derived",
      "mutableInPhase1": false
    },
    {
      "id": "handover-agents-runtime",
      "profileId": "handover",
      "family": "session-handover",
      "path": ".agents/agents/handover.md",
      "classification": "derived",
      "mutableInPhase1": false
    },
    {
      "id": "context-prime-candidate-only",
      "profileId": "context-prime",
      "family": "session-bootstrap",
      "path": ".opencode/agents/context-prime.md",
      "classification": "candidate-only",
      "mutableInPhase1": false,
      "candidateOnly": true,
      "promotionEligible": false,
      "evaluationMode": "prompt-surface+benchmark",
      "requiredReferences": [
        "session_bootstrap",
        "session_health",
        "fallback",
        "Prime Package",
        "read-only",
        "under 15 seconds"
      ]
    }
  ],
  "fixed": [
    ".opencode/commands/speckit/handover.md",
    ".agents/commands/speckit/handover.toml",
    ".gemini/commands/speckit/handover.toml",
    ".opencode/skills/system-spec-kit/templates/handover.md"
  ],
  "forbidden": [
    ".opencode/commands/speckit/handover.md",
    ".agents/commands/speckit/handover.toml",
    ".gemini/commands/speckit/handover.toml",
    ".opencode/skills/system-spec-kit/templates/handover.md"
  ],
  "packaging": {
    "mirrorSyncMode": "downstream-only",
    "forbidMirrorEvidenceAsBenchmarkTruth": true
  }
}
