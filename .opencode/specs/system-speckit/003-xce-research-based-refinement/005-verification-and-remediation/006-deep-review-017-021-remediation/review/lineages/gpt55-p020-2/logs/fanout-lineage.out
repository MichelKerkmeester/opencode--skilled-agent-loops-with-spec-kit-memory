{"type":"tool_use","timestamp":1781756786797,"sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","part":{"type":"tool","tool":"read","callID":"call_rWyHQZxMNpvOOYvmrl130G97","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Maintenance-Active Marker\n3: // ───────────────────────────────────────────────────────────────\n4: // Signals the launcher that this daemon is busy-by-design (a background index\n5: // scan or a background-embedding burst) so a competing launcher adopts it\n6: // instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n7: // and refuses to reap a live daemon that holds a fresh marker (see the\n8: // shouldAdoptDespiteProbe guard in the launcher supervision lib).\n9: //\n10: // Reference-counted: the scan and the embedding queue can overlap (the scan\n11: // defers embeddings the queue then drains), so the marker stays present while\n12: // ANY maintenance source is active and is removed only when the last one ends.\n13: // A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n14: // becomes reapable again.\n15: \n16: import { rmSync } from 'node:fs';\n17: import path from 'node:path';\n18: \n19: import { DATABASE_DIR } from '../../core/config.js';\n20: import { atomicWriteFile } from './transaction-manager.js';\n21: \n22: const MAINTENANCE_MARKER_FILE = '.maintenance-active.json';\n23: // The TTL must exceed the longest single synchronous phase that cannot fire the\n24: // refresh timer. 180s is a margin over the longest observed blocking phase (~79s).\n25: const MAINTENANCE_MARKER_TTL_MS = 180_000;\n26: const MAINTENANCE_MARKER_REFRESH_MS = 20_000;\n27: \n28: export interface MaintenanceMarkerHandle {\n29:   // Refresh at a known progress point too: a non-yielding phase cannot fire the\n30:   // interval timer, so it only gets the refresh its caller makes explicitly.\n31:   refresh(): void;\n32:   // Idempotent. Decrements the active count and removes the marker at zero.\n33:   end(): void;\n34: }\n35: \n36: let activeCount = 0;\n37: let refreshTimer: ReturnType<typeof setInterval> | null = null;\n38: let activeLabels: string[] = [];\n39: \n40: function markerPath(): string {\n41:   return path.join(DATABASE_DIR, MAINTENANCE_MARKER_FILE);\n42: }\n43: \n44: function writeMarker(): void {\n45:   atomicWriteFile(markerPath(), `${JSON.stringify({\n46:     childPid: process.pid,\n47:     activeUntilMs: Date.now() + MAINTENANCE_MARKER_TTL_MS,\n48:     labels: activeLabels,\n49:     refreshedAtIso: new Date().toISOString(),\n50:   }, null, 2)}\\n`);\n51: }\n52: \n53: /**\n54:  * Begin signalling busy-by-design maintenance. Call when a busy burst starts and\n55:  * `end()` it in a finally so the marker is cleared on every exit. Safe to nest or\n56:  * overlap with other maintenance sources.\n57:  */\n58: export function beginMaintenance(label: string): MaintenanceMarkerHandle {\n59:   activeCount += 1;\n60:   activeLabels.push(label);\n61:   writeMarker();\n62:   if (!refreshTimer) {\n63:     refreshTimer = setInterval(writeMarker, MAINTENANCE_MARKER_REFRESH_MS);\n64:     refreshTimer.unref?.();\n65:   }\n66: \n67:   let ended = false;\n68:   return {\n69:     refresh(): void {\n70:       if (!ended && activeCount > 0) writeMarker();\n71:     },\n72:     end(): void {\n73:       if (ended) return;\n74:       ended = true;\n75:       activeCount = Math.max(0, activeCount - 1);\n76:       const idx = activeLabels.indexOf(label);\n77:       if (idx >= 0) activeLabels.splice(idx, 1);\n78:       // A non-final end() prunes the in-memory label only; the on-disk labels[]\n79:       // is not re-serialized here and stays best-effort diagnostic until the next\n80:       // write (begin/refresh/timer). The launcher reads only childPid +\n81:       // activeUntilMs, so a momentarily stale label set is harmless.\n82:       if (activeCount === 0) {\n83:         if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n84:         try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n85:       }\n86:     },\n87:   };\n88: }\n89: \n90: // Test-only: reset module state between cases. Removes the on-disk marker too,\n91: // so a later test reusing the same DATABASE_DIR cannot observe a stale marker.\n92: export function __resetMaintenanceMarkerForTest(): void {\n93:   if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n94:   try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n95:   activeCount = 0;\n96:   activeLabels = [];\n97: }\n\n(End of file - total 97 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance-Active Marker\n// ───────────────────────────────────────────────────────────────\n// Signals the launcher that this daemon is busy-by-design (a background index\n// scan or a background-embedding burst) so a competing launcher adopts it\n// instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n// and refuses to reap a live daemon that holds a fresh marker (see the\n// shouldAdoptDespiteProbe guard in the launcher supervision lib).\n//\n// Reference-counted: the scan and the embedding queue can overlap (the scan\n// defers embeddings the queue then drains), so the marker stays present while\n// ANY maintenance source is active and is removed only when the last one ends.\n// A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n// becomes reapable again.\n\nimport { rmSync } from 'node:fs';\nimport path from 'node:path';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { atomicWriteFile } from './transaction-manager.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance-Active Marker\n// ───────────────────────────────────────────────────────────────\n// Signals the launcher that this daemon is busy-by-design (a background index\n// scan or a background-embedding burst) so a competing launcher adopts it\n// instead of reaping it as wedged. The launcher reads <DATABASE_DIR>/.maintenance-active.json\n// and refuses to reap a live daemon that holds a fresh marker (see the\n// shouldAdoptDespiteProbe guard in the launcher supervision lib).\n//\n// Reference-counted: the scan and the embedding queue can overlap (the scan\n// defers embeddings the queue then drains), so the marker stays present while\n// ANY maintenance source is active and is removed only when the last one ends.\n// A genuinely wedged daemon cannot refresh the marker, so it still lapses and\n// becomes reapable again.\n\nimport { rmSync } from 'node:fs';\nimport path from 'node:path';\n\nimport { DATABASE_DIR } from '../../core/config.js';\nimport { atomicWriteFile } from './transaction-manager.js';\n\nconst MAINTENANCE_MARKER_FILE = '.maintenance-active.json';\n// The TTL must exceed the longest single synchronous phase that cannot fire the\n// refresh timer. 180s is a margin over the longest observed blocking phase (~79s).\nconst MAINTENANCE_MARKER_TTL_MS = 180_000;\nconst MAINTENANCE_MARKER_REFRESH_MS = 20_000;\n\nexport interface MaintenanceMarkerHandle {\n  // Refresh at a known progress point too: a non-yielding phase cannot fire the\n  // interval timer, so it only gets the refresh its caller makes explicitly.\n  refresh(): void;\n  // Idempotent. Decrements the active count and removes the marker at zero.\n  end(): void;\n}\n\nlet activeCount = 0;\nlet refreshTimer: ReturnType<typeof setInterval> | null = null;\nlet activeLabels: string[] = [];\n\nfunction markerPath(): string {\n  return path.join(DATABASE_DIR, MAINTENANCE_MARKER_FILE);\n}\n\nfunction writeMarker(): void {\n  atomicWriteFile(markerPath(), `${JSON.stringify({\n    childPid: process.pid,\n    activeUntilMs: Date.now() + MAINTENANCE_MARKER_TTL_MS,\n    labels: activeLabels,\n    refreshedAtIso: new Date().toISOString(),\n  }, null, 2)}\\n`);\n}\n\n/**\n * Begin signalling busy-by-design maintenance. Call when a busy burst starts and\n * `end()` it in a finally so the marker is cleared on every exit. Safe to nest or\n * overlap with other maintenance sources.\n */\nexport function beginMaintenance(label: string): MaintenanceMarkerHandle {\n  activeCount += 1;\n  activeLabels.push(label);\n  writeMarker();\n  if (!refreshTimer) {\n    refreshTimer = setInterval(writeMarker, MAINTENANCE_MARKER_REFRESH_MS);\n    refreshTimer.unref?.();\n  }\n\n  let ended = false;\n  return {\n    refresh(): void {\n      if (!ended && activeCount > 0) writeMarker();\n    },\n    end(): void {\n      if (ended) return;\n      ended = true;\n      activeCount = Math.max(0, activeCount - 1);\n      const idx = activeLabels.indexOf(label);\n      if (idx >= 0) activeLabels.splice(idx, 1);\n      // A non-final end() prunes the in-memory label only; the on-disk labels[]\n      // is not re-serialized here and stays best-effort diagnostic until the next\n      // write (begin/refresh/timer). The launcher reads only childPid +\n      // activeUntilMs, so a momentarily stale label set is harmless.\n      if (activeCount === 0) {\n        if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n        try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n      }\n    },\n  };\n}\n\n// Test-only: reset module state between cases. Removes the on-disk marker too,\n// so a later test reusing the same DATABASE_DIR cannot observe a stale marker.\nexport function __resetMaintenanceMarkerForTest(): void {\n  if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }\n  try { rmSync(markerPath(), { force: true }); } catch { /* best-effort cleanup */ }\n  activeCount = 0;\n  activeLabels = [];\n}","lineStart":1,"lineEnd":97,"totalLines":97,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/maintenance-marker.ts","time":{"start":1781756786789,"end":1781756786796}},"metadata":{"openai":{"itemId":"fc_03ebecbc6e88b563016a337372a92c8191a82b68f1a3811e79"}},"id":"prt_ed8faf831001OIVdWsOboDYlP4","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fab5ed0015PC9Bi455AYh43"}}
{"type":"tool_use","timestamp":1781756786834,"sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","part":{"type":"tool","tool":"read","callID":"call_4E7JheZULdh4uiaZCg0ojrtb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","offset":1480,"limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts</path>\n<type>file</type>\n<content>\n1480:     },\n1481:     hints\n1482:   });\n1483:   } finally {\n1484:     if (leaseHeartbeat) {\n1485:       clearInterval(leaseHeartbeat);\n1486:       leaseHeartbeat = null;\n1487:     }\n1488:     if (loopLagTimer) {\n1489:       clearInterval(loopLagTimer);\n1490:       loopLagTimer = null;\n1491:       console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n1492:     }\n1493:     await releaseScanLease();\n1494:   }\n1495: }\n1496: \n1497: /** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n1498:  *  Without background the call is byte-for-byte identical to the prior synchronous path. */\n1499: async function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n1500:   if (!args.background) {\n1501:     return runIndexScan(args, {});\n1502:   }\n1503: \n1504:   const jobId = createJobId();\n1505:   await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n1506: \n1507:   setImmediate(() => {\n1508:     void (async () => {\n1509:       // Mark the daemon busy-by-design so a competing launcher adopts it rather\n1510:       // than reaping it mid-scan. The shared marker is reference-counted, so the\n1511:       // background-embedding queue draining this scan's deferred embeddings can\n1512:       // keep it held past the scan itself.\n1513:       const maintenance = beginMaintenance('index_scan');\n1514:       try {\n1515:         await setJobState(jobId, 'running');\n1516:         const response = await runIndexScan(args, {\n1517:           isCancelled: () => isCancelRequestedFast(jobId),\n1518:           onPhase: (phase) => {\n1519:             // Refresh at each phase boundary so a long synchronous tail phase (which\n1520:             // cannot fire the interval timer) still enters with a full TTL ahead.\n1521:             maintenance.refresh();\n1522:             void setJobPhase(jobId, phase).catch(() => {});\n1523:           },\n1524:           onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n1525:         });\n1526:         const scanData = extractEnvelopeData(response);\n1527:         const wasCancelled = !!(scanData && typeof scanData === 'object'\n1528:           && (scanData as { cancelled?: unknown }).cancelled === true);\n1529:         if (wasCancelled) {\n1530:           // The run itself short-circuited on cancellation. A cancel that arrives\n1531:           // after the scan already finished does not retroactively cancel it.\n1532:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1533:         } else if (response.isError === true) {\n1534:           // An error envelope (not a thrown error) still means the scan failed.\n1535:           await appendJobError(jobId, '__scan__', scanData);\n1536:           await setJobState(jobId, 'failed');\n1537:         } else {\n1538:           await completeJob(jobId, { state: 'complete', result: scanData });\n1539:         }\n1540:       } catch (error: unknown) {\n1541:         try {\n1542:           await appendJobError(jobId, '__job__', error);\n1543:           await setJobState(jobId, 'failed');\n1544:         } catch (_secondaryError: unknown) {\n1545:           // Best-effort failure record; never surface a background unhandled rejection.\n1546:         }\n1547:       } finally {\n1548:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1549:         // Release this scan's hold; the marker stays present only while the\n1550:         // background-embedding queue still holds it.\n1551:         maintenance.end();\n1552:       }\n1553:     })();\n1554:   });\n1555: \n1556:   return createMCPSuccessResponse({\n1557:     tool: 'memory_index_scan',\n1558:     summary: `Queued background index scan ${jobId}`,\n1559:     data: { jobId, state: 'queued', background: true },\n1560:     hints: [\n1561:       'Use memory_index_scan_status with jobId to poll progress',\n1562:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1563:     ],\n1564:   });\n1565: }\n1566: \n1567: /* ───────────────────────────────────────────────────────────────\n1568:    9. EXPORTS\n1569: ──────────────────────────────────────────────────────────────── */\n1570: \n1571: export {\n1572:   handleMemoryIndexScan,\n1573:   indexSingleFile,\n1574:   findConstitutionalFiles,\n1575:   findSpecDocuments,\n1576:   detectSpecLevel,\n1577:   summarizeAliasConflicts,\n1578:   runDivergenceReconcileHooks,\n1579: };\n\n(Showing lines 1480-1579 of 1598. Use offset=1580 to continue.)\n</content>","metadata":{"preview":"    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"    },\n    hints\n  });\n  } finally {\n    if (leaseHeartbeat) {\n      clearInterval(leaseHeartbeat);\n      leaseHeartbeat = null;\n    }\n    if (loopLagTimer) {\n      clearInterval(loopLagTimer);\n      loopLagTimer = null;\n      console.error(`[memory-index-scan] max-event-loop-lag ms=${maxLoopLagMs}`);\n    }\n    await releaseScanLease();\n  }\n}\n\n/** Handle memory_index_scan tool — dispatches to a synchronous run or a background job.\n *  Without background the call is byte-for-byte identical to the prior synchronous path. */\nasync function handleMemoryIndexScan(args: ScanArgs): Promise<MCPResponse> {\n  if (!args.background) {\n    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  handleMemoryIndexScan,\n  indexSingleFile,\n  findConstitutionalFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n};","lineStart":1480,"lineEnd":1579,"totalLines":1598,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781756786828,"end":1781756786833}},"metadata":{"openai":{"itemId":"fc_03ebecbc6e88b563016a337372a9488191915163f7985c636e"}},"id":"prt_ed8faf87e001ZbAoMuHgBTnsnT","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fab5ed0015PC9Bi455AYh43"}}
{"type":"tool_use","timestamp":1781756786867,"sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","part":{"type":"tool","tool":"read","callID":"call_yVNGt1z3Z0AoVCDp6r59HHWL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Retry Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Embedding retry orchestrator\n5: // Node stdlib\n6: import * as fsPromises from 'fs/promises';\n7: \n8: // Internal modules\n9: import * as vectorIndex from '../search/vector-index.js';\n10: import { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\n11: import { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\n12: import { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\n13: import { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\n14: import { registerShutdownHook } from '../runtime/shutdown-hooks.js';\n15: import { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n16: \n17: // Type imports\n18: import type { MemoryDbRow } from '@spec-kit/shared/types';\n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. TYPES\n22: ──────────────────────────────────────────────────────────────── */\n23: \n24: interface BackgroundJobConfig {\n25:   intervalMs: number;\n26:   batchSize: number;\n27:   enabled: boolean;\n28: }\n29: \n30: interface RetryStats {\n31:   pending: number;\n32:   retry: number;\n33:   failed: number;\n34:   success: number;\n35:   total: number;\n36:   queue_size: number;\n37: }\n38: \n39: /** In-memory-only snapshot of embedding retry health — no DB access. */\n40: export interface EmbeddingRetryStats {\n41:   pending: number;\n42:   failed: number;\n43:   retryAttempts: number;\n44:   circuitBreakerOpen: boolean;\n45:   lastRun: string | null;\n46:   queueDepth: number;\n47: }\n48: \n49: interface RetryResult {\n50:   success: boolean;\n51:   id?: number;\n52:   dimensions?: number;\n53:   error?: string;\n54:   permanent?: boolean;\n55: }\n56: \n57: interface BatchResult {\n58:   processed: number;\n59:   succeeded: number;\n60:   failed: number;\n61:   details?: RetryDetailEntry[];\n62: }\n63: \n64: interface RetryDetailEntry {\n65:   id: number;\n66:   success: boolean;\n67:   error?: string;\n68:   dimensions?: number;\n69: }\n70: \n71: interface BackgroundJobResult {\n72:   processed?: number;\n73:   succeeded?: number;\n74:   failed?: number;\n75:   details?: RetryDetailEntry[];\n76:   skipped?: boolean;\n77:   reason?: string;\n78:   queue_empty?: boolean;\n79:   error?: string;\n80: }\n81: \n82: /**\n83:  * Retry-specific memory row with required id and file_path.\n84:  * Uses MemoryDbRow as the base type with Record<string, unknown>\n85:  * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n86:  */\n87: type RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n88:   id: number;\n89:   file_path: string;\n90: };\n91: \n92: type ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\n93: type RetryQueueStatus = 'pending' | 'retry';\n94: \n95: type EmbeddingFailureCode =\n96:   | 'EMBEDDING_PROVIDER_ERROR'\n97:   | 'EMBEDDING_TIMEOUT'\n98:   | 'EMBEDDING_RATE_LIMIT';\n99: \n100: interface SanitizeEmbeddingFailureOptions {\n101:   provider?: string | null;\n102:   force?: boolean;\n103: }\n104: \n105: interface SanitizedEmbeddingFailure {\n106:   code: EmbeddingFailureCode | null;\n107:   provider: string | null;\n108:   errorType: string | null;\n109:   publicMessage: string;\n110:   sanitized: boolean;\n111: }\n112: \n113: interface RetryClaimResult {\n114:   claimed: boolean;\n115:   previousStatus: RetryQueueStatus | null;\n116: }\n117: \n118: function getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n119:   const status = typeof memory.embedding_status === 'string'\n120:     ? memory.embedding_status\n121:     : typeof memory.embeddingStatus === 'string'\n122:       ? memory.embeddingStatus\n123:       : null;\n124: \n125:   return status === 'pending' || status === 'retry' ? status : null;\n126: }\n127: \n128: function getRetryCountValue(memory: RetryMemoryRow): number {\n129:   return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n130: }\n131: \n132: function getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n133:   const value = typeof memory.last_retry_at === 'string'\n134:     ? memory.last_retry_at\n135:     : typeof memory.lastRetryAt === 'string'\n136:       ? memory.lastRetryAt\n137:       : null;\n138:   return value && value.trim().length > 0 ? value : null;\n139: }\n140: \n141: function detectEmbeddingProviderName(source: string | null | undefined): string | null {\n142:   if (typeof source !== 'string' || source.trim().length === 0) {\n143:     return null;\n144:   }\n145: \n146:   const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n147:   if (explicitProvider?.[1]) {\n148:     return explicitProvider[1].toLowerCase();\n149:   }\n150: \n151:   const lower = source.toLowerCase();\n152:   if (lower.includes('voyage')) return 'voyage';\n153:   if (lower.includes('azure')) return 'azure-openai';\n154:   if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n155:   if (lower.includes('system')) return 'system';\n156: \n157:   return null;\n158: }\n159: \n160: function shouldSanitizeEmbeddingFailure(message: string): boolean {\n161:   const lower = message.toLowerCase();\n162:   return (\n163:     /^embedding_[a-z_]+/.test(lower) ||\n164:     lower.includes('openai') ||\n165:     lower.includes('voyage') ||\n166:     lower.includes('azure') ||\n167:     lower.includes('text-embedding') ||\n168:     lower.includes('rate limit') ||\n169:     lower.includes('too many requests') ||\n170:     lower.includes('429') ||\n171:     lower.includes('timeout') ||\n172:     lower.includes('timed out') ||\n173:     lower.includes('api key') ||\n174:     lower.includes('unauthorized') ||\n175:     lower.includes('forbidden') ||\n176:     lower.includes('quota') ||\n177:     lower.includes('embedding provider')\n178:   );\n179: }\n180: \n181: function inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n182:   const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n183:   const lower = message.toLowerCase();\n184: \n185:   if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n186:     return {\n187:       code: 'EMBEDDING_TIMEOUT',\n188:       errorType: explicitType ?? 'timeout',\n189:     };\n190:   }\n191: \n192:   if (\n193:     lower.includes('embedding_rate_limit') ||\n194:     lower.includes('rate limit') ||\n195:     lower.includes('too many requests') ||\n196:     lower.includes('429')\n197:   ) {\n198:     return {\n199:       code: 'EMBEDDING_RATE_LIMIT',\n200:       errorType: explicitType ?? 'rate_limit',\n201:     };\n202:   }\n203: \n204:   if (\n205:     explicitType === 'auth' ||\n206:     lower.includes('api key') ||\n207:     lower.includes('unauthorized') ||\n208:     lower.includes('forbidden')\n209:   ) {\n210:     return {\n211:       code: 'EMBEDDING_PROVIDER_ERROR',\n212:       errorType: 'auth',\n213:     };\n214:   }\n215: \n216:   return {\n217:     code: 'EMBEDDING_PROVIDER_ERROR',\n218:     errorType: explicitType ?? 'provider_error',\n219:   };\n220: }\n221: \n222: function sanitizeEmbeddingFailure(\n223:   raw: unknown,\n224:   options: SanitizeEmbeddingFailureOptions = {},\n225: ): SanitizedEmbeddingFailure {\n226:   const publicMessage = raw instanceof Error\n227:     ? raw.message.trim()\n228:     : String(raw ?? '').trim();\n229: \n230:   if (publicMessage.length === 0) {\n231:     return {\n232:       code: null,\n233:       provider: null,\n234:       errorType: null,\n235:       publicMessage,\n236:       sanitized: false,\n237:     };\n238:   }\n239: \n240:   if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {\n\n(Showing lines 1-240 of 1141. Use offset=241 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BackgroundJobConfig {\n  intervalMs: number;\n  batchSize: number;\n  enabled: boolean;\n}\n\ninterface RetryStats {\n  pending: number;\n  retry: number;\n  failed: number;\n  success: number;\n  total: number;\n  queue_size: number;\n}\n\n/** In-memory-only snapshot of embedding retry health — no DB access. */\nexport interface EmbeddingRetryStats {\n  pending: number;\n  failed: number;\n  retryAttempts: number;\n  circuitBreakerOpen: boolean;\n  lastRun: string | null;\n  queueDepth: number;\n}\n\ninterface RetryResult {\n  success: boolean;\n  id?: number;\n  dimensions?: number;\n  error?: string;\n  permanent?: boolean;\n}\n\ninterface BatchResult {\n  processed: number;\n  succeeded: number;\n  failed: number;\n  details?: RetryDetailEntry[];\n}\n\ninterface RetryDetailEntry {\n  id: number;\n  success: boolean;\n  error?: string;\n  dimensions?: number;\n}\n\ninterface BackgroundJobResult {\n  processed?: number;\n  succeeded?: number;\n  failed?: number;\n  details?: RetryDetailEntry[];\n  skipped?: boolean;\n  reason?: string;\n  queue_empty?: boolean;\n  error?: string;\n}\n\n/**\n * Retry-specific memory row with required id and file_path.\n * Uses MemoryDbRow as the base type with Record<string, unknown>\n * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n */\ntype RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n  id: number;\n  file_path: string;\n};\n\ntype ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\ntype RetryQueueStatus = 'pending' | 'retry';\n\ntype EmbeddingFailureCode =\n  | 'EMBEDDING_PROVIDER_ERROR'\n  | 'EMBEDDING_TIMEOUT'\n  | 'EMBEDDING_RATE_LIMIT';\n\ninterface SanitizeEmbeddingFailureOptions {\n  provider?: string | null;\n  force?: boolean;\n}\n\ninterface SanitizedEmbeddingFailure {\n  code: EmbeddingFailureCode | null;\n  provider: string | null;\n  errorType: string | null;\n  publicMessage: string;\n  sanitized: boolean;\n}\n\ninterface RetryClaimResult {\n  claimed: boolean;\n  previousStatus: RetryQueueStatus | null;\n}\n\nfunction getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n  const status = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof memory.embeddingStatus === 'string'\n      ? memory.embeddingStatus\n      : null;\n\n  return status === 'pending' || status === 'retry' ? status : null;\n}\n\nfunction getRetryCountValue(memory: RetryMemoryRow): number {\n  return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n}\n\nfunction getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n  const value = typeof memory.last_retry_at === 'string'\n    ? memory.last_retry_at\n    : typeof memory.lastRetryAt === 'string'\n      ? memory.lastRetryAt\n      : null;\n  return value && value.trim().length > 0 ? value : null;\n}\n\nfunction detectEmbeddingProviderName(source: string | null | undefined): string | null {\n  if (typeof source !== 'string' || source.trim().length === 0) {\n    return null;\n  }\n\n  const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n  if (explicitProvider?.[1]) {\n    return explicitProvider[1].toLowerCase();\n  }\n\n  const lower = source.toLowerCase();\n  if (lower.includes('voyage')) return 'voyage';\n  if (lower.includes('azure')) return 'azure-openai';\n  if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n  if (lower.includes('system')) return 'system';\n\n  return null;\n}\n\nfunction shouldSanitizeEmbeddingFailure(message: string): boolean {\n  const lower = message.toLowerCase();\n  return (\n    /^embedding_[a-z_]+/.test(lower) ||\n    lower.includes('openai') ||\n    lower.includes('voyage') ||\n    lower.includes('azure') ||\n    lower.includes('text-embedding') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429') ||\n    lower.includes('timeout') ||\n    lower.includes('timed out') ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden') ||\n    lower.includes('quota') ||\n    lower.includes('embedding provider')\n  );\n}\n\nfunction inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n  const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n  const lower = message.toLowerCase();\n\n  if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n    return {\n      code: 'EMBEDDING_TIMEOUT',\n      errorType: explicitType ?? 'timeout',\n    };\n  }\n\n  if (\n    lower.includes('embedding_rate_limit') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429')\n  ) {\n    return {\n      code: 'EMBEDDING_RATE_LIMIT',\n      errorType: explicitType ?? 'rate_limit',\n    };\n  }\n\n  if (\n    explicitType === 'auth' ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden')\n  ) {\n    return {\n      code: 'EMBEDDING_PROVIDER_ERROR',\n      errorType: 'auth',\n    };\n  }\n\n  return {\n    code: 'EMBEDDING_PROVIDER_ERROR',\n    errorType: explicitType ?? 'provider_error',\n  };\n}\n\nfunction sanitizeEmbeddingFailure(\n  raw: unknown,\n  options: SanitizeEmbeddingFailureOptions = {},\n): SanitizedEmbeddingFailure {\n  const publicMessage = raw instanceof Error\n    ? raw.message.trim()\n    : String(raw ?? '').trim();\n\n  if (publicMessage.length === 0) {\n    return {\n      code: null,\n      provider: null,\n      errorType: null,\n      publicMessage,\n      sanitized: false,\n    };\n  }\n\n  if (!options.force && !shouldSanitizeEmbeddingFailure(publicMessage)) {","lineStart":1,"lineEnd":240,"totalLines":1141,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781756786860,"end":1781756786866}},"metadata":{"openai":{"itemId":"fc_03ebecbc6e88b563016a337372a96481919499505eedcc7e89"}},"id":"prt_ed8faf88e001Vm1VdOTDiP03Z0","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fab5ed0015PC9Bi455AYh43"}}
{"type":"tool_use","timestamp":1781756786881,"sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","part":{"type":"tool","tool":"read","callID":"call_PmHxS7VRavuLaqvGv0HBFEtz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts</path>\n<type>file</type>\n<content>\n1: import { describe, it, expect, beforeEach, afterEach } from 'vitest';\n2: import fs from 'fs';\n3: import path from 'path';\n4: import os from 'os';\n5: \n6: import {\n7:   beginMaintenance,\n8:   __resetMaintenanceMarkerForTest,\n9: } from '../lib/storage/maintenance-marker';\n10: import { resolveDatabasePaths } from '../core/config';\n11: \n12: const MARKER_FILE = '.maintenance-active.json';\n13: \n14: interface MarkerShape {\n15:   childPid: number;\n16:   activeUntilMs: number;\n17:   labels: string[];\n18:   refreshedAtIso: string;\n19: }\n20: \n21: let tmpDir: string;\n22: const originalSpecKitDbDir = process.env.SPEC_KIT_DB_DIR;\n23: const originalSpeckitDbDir = process.env.SPECKIT_DB_DIR;\n24: \n25: function markerPath(): string {\n26:   return path.join(tmpDir, MARKER_FILE);\n27: }\n28: \n29: function markerExists(): boolean {\n30:   return fs.existsSync(markerPath());\n31: }\n32: \n33: function readMarker(): MarkerShape {\n34:   return JSON.parse(fs.readFileSync(markerPath(), 'utf8')) as MarkerShape;\n35: }\n36: \n37: beforeEach(() => {\n38:   // Point DATABASE_DIR at a throwaway directory so the marker module's real-fs\n39:   // writes never touch a live database. The marker reads DATABASE_DIR as a live\n40:   // ESM binding, so reassigning it via resolveDatabasePaths() redirects writes.\n41:   tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintmarker.'));\n42:   process.env.SPEC_KIT_DB_DIR = tmpDir;\n43:   delete process.env.SPECKIT_DB_DIR;\n44:   resolveDatabasePaths();\n45: });\n46: \n47: afterEach(() => {\n48:   __resetMaintenanceMarkerForTest();\n49:   try {\n50:     fs.rmSync(tmpDir, { recursive: true, force: true });\n51:   } catch {\n52:     // Best-effort cleanup\n53:   }\n54:   if (originalSpecKitDbDir === undefined) {\n55:     delete process.env.SPEC_KIT_DB_DIR;\n56:   } else {\n57:     process.env.SPEC_KIT_DB_DIR = originalSpecKitDbDir;\n58:   }\n59:   if (originalSpeckitDbDir === undefined) {\n60:     delete process.env.SPECKIT_DB_DIR;\n61:   } else {\n62:     process.env.SPECKIT_DB_DIR = originalSpeckitDbDir;\n63:   }\n64:   // Re-resolve so a subsequent suite/test sees a consistent DATABASE_DIR.\n65:   resolveDatabasePaths();\n66: });\n67: \n68: describe('maintenance-marker', () => {\n69:   it('beginMaintenance writes a marker with this pid, a future TTL, and the label', () => {\n70:     const before = Date.now();\n71:     const handle = beginMaintenance('scan');\n72: \n73:     expect(markerExists()).toBe(true);\n74:     const marker = readMarker();\n75:     expect(marker.childPid).toBe(process.pid);\n76:     expect(marker.activeUntilMs).toBeGreaterThan(before);\n77:     expect(marker.labels).toContain('scan');\n78: \n79:     handle.end();\n80:   });\n81: \n82:   it('is reference-counted: marker persists until the LAST holder ends', () => {\n83:     const first = beginMaintenance('scan');\n84:     const second = beginMaintenance('embedding-queue');\n85: \n86:     expect(markerExists()).toBe(true);\n87:     let marker = readMarker();\n88:     expect(marker.labels).toContain('scan');\n89:     expect(marker.labels).toContain('embedding-queue');\n90: \n91:     // Ending the FIRST holder: marker must STILL exist (second is active).\n92:     // The on-disk file is only rewritten on a write event (begin/refresh/timer),\n93:     // so end() does NOT itself re-serialize the pruned label set — it just\n94:     // decrements the in-memory ref count. The reference-counting contract under\n95:     // test is file PERSISTENCE while >=1 holder remains.\n96:     first.end();\n97:     expect(markerExists()).toBe(true);\n98: \n99:     // The next write (refresh on the surviving holder) reflects the pruned label\n100:     // set, confirming the first holder's label was decremented from live state.\n101:     second.refresh();\n102:     marker = readMarker();\n103:     expect(marker.labels).toContain('embedding-queue');\n104:     expect(marker.labels).not.toContain('scan');\n105: \n106:     // Ending the SECOND (last) holder: marker is REMOVED.\n107:     second.end();\n108:     expect(markerExists()).toBe(false);\n109:   });\n110: \n111:   it('end() is idempotent: calling twice on the sole holder removes the file once and does not throw', () => {\n112:     const handle = beginMaintenance('scan');\n113:     expect(markerExists()).toBe(true);\n114: \n115:     expect(() => {\n116:       handle.end();\n117:       handle.end();\n118:     }).not.toThrow();\n119: \n120:     expect(markerExists()).toBe(false);\n121:   });\n122: \n123:   it('refresh() rewrites the marker with a non-decreasing activeUntilMs and a refreshed timestamp', () => {\n124:     const handle = beginMaintenance('scan');\n125:     const first = readMarker();\n126: \n127:     handle.refresh();\n128:     const second = readMarker();\n129: \n130:     // TTL is recomputed from Date.now(); never goes backwards on refresh.\n131:     expect(second.activeUntilMs).toBeGreaterThanOrEqual(first.activeUntilMs);\n132:     // refreshedAtIso must be a valid ISO timestamp and not predate the first write.\n133:     expect(Date.parse(second.refreshedAtIso)).toBeGreaterThanOrEqual(\n134:       Date.parse(first.refreshedAtIso),\n135:     );\n136:     expect(Number.isNaN(Date.parse(second.refreshedAtIso))).toBe(false);\n137: \n138:     handle.end();\n139:   });\n140: \n141:   it('removes the marker once all handles have ended', () => {\n142:     const a = beginMaintenance('scan');\n143:     const b = beginMaintenance('embedding-queue');\n144:     const c = beginMaintenance('checkpoint');\n145:     expect(markerExists()).toBe(true);\n146: \n147:     a.end();\n148:     b.end();\n149:     expect(markerExists()).toBe(true);\n150: \n151:     c.end();\n152:     expect(markerExists()).toBe(false);\n153:   });\n154: \n155:   it('__resetMaintenanceMarkerForTest removes the on-disk marker, not just in-memory state', () => {\n156:     // Leave a holder active so the marker is on disk and the ref count is non-zero.\n157:     beginMaintenance('scan');\n158:     expect(markerExists()).toBe(true);\n159: \n160:     __resetMaintenanceMarkerForTest();\n161: \n162:     // The reset must clear the on-disk marker so a later test reusing the same\n163:     // DATABASE_DIR cannot observe a stale marker.\n164:     expect(markerExists()).toBe(false);\n165: \n166:     // A fresh begin after reset starts from a clean slate (no leaked labels).\n167:     const handle = beginMaintenance('embedding-queue');\n168:     const marker = readMarker();\n169:     expect(marker.labels).toEqual(['embedding-queue']);\n170:     handle.end();\n171:   });\n172: \n173:   it('two holders sharing a label: ending one keeps the marker until the other ends', () => {\n174:     const first = beginMaintenance('scan');\n175:     const second = beginMaintenance('scan');\n176:     expect(markerExists()).toBe(true);\n177: \n178:     // Ending one of two same-label holders leaves the marker present (ref count 1).\n179:     first.end();\n180:     expect(markerExists()).toBe(true);\n181: \n182:     // The surviving holder still sees the shared label on the next write.\n183:     second.refresh();\n184:     expect(readMarker().labels).toContain('scan');\n185: \n186:     // Ending the last holder removes the marker.\n187:     second.end();\n188:     expect(markerExists()).toBe(false);\n189:   });\n190: });\n\n(End of file - total 190 lines)\n</content>","metadata":{"preview":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\nimport {\n  beginMaintenance,\n  __resetMaintenanceMarkerForTest,\n} from '../lib/storage/maintenance-marker';\nimport { resolveDatabasePaths } from '../core/config';\n\nconst MARKER_FILE = '.maintenance-active.json';\n\ninterface MarkerShape {\n  childPid: number;\n  activeUntilMs: number;\n  labels: string[];\n  refreshedAtIso: string;\n}\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts","text":"import { describe, it, expect, beforeEach, afterEach } from 'vitest';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\nimport {\n  beginMaintenance,\n  __resetMaintenanceMarkerForTest,\n} from '../lib/storage/maintenance-marker';\nimport { resolveDatabasePaths } from '../core/config';\n\nconst MARKER_FILE = '.maintenance-active.json';\n\ninterface MarkerShape {\n  childPid: number;\n  activeUntilMs: number;\n  labels: string[];\n  refreshedAtIso: string;\n}\n\nlet tmpDir: string;\nconst originalSpecKitDbDir = process.env.SPEC_KIT_DB_DIR;\nconst originalSpeckitDbDir = process.env.SPECKIT_DB_DIR;\n\nfunction markerPath(): string {\n  return path.join(tmpDir, MARKER_FILE);\n}\n\nfunction markerExists(): boolean {\n  return fs.existsSync(markerPath());\n}\n\nfunction readMarker(): MarkerShape {\n  return JSON.parse(fs.readFileSync(markerPath(), 'utf8')) as MarkerShape;\n}\n\nbeforeEach(() => {\n  // Point DATABASE_DIR at a throwaway directory so the marker module's real-fs\n  // writes never touch a live database. The marker reads DATABASE_DIR as a live\n  // ESM binding, so reassigning it via resolveDatabasePaths() redirects writes.\n  tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'maintmarker.'));\n  process.env.SPEC_KIT_DB_DIR = tmpDir;\n  delete process.env.SPECKIT_DB_DIR;\n  resolveDatabasePaths();\n});\n\nafterEach(() => {\n  __resetMaintenanceMarkerForTest();\n  try {\n    fs.rmSync(tmpDir, { recursive: true, force: true });\n  } catch {\n    // Best-effort cleanup\n  }\n  if (originalSpecKitDbDir === undefined) {\n    delete process.env.SPEC_KIT_DB_DIR;\n  } else {\n    process.env.SPEC_KIT_DB_DIR = originalSpecKitDbDir;\n  }\n  if (originalSpeckitDbDir === undefined) {\n    delete process.env.SPECKIT_DB_DIR;\n  } else {\n    process.env.SPECKIT_DB_DIR = originalSpeckitDbDir;\n  }\n  // Re-resolve so a subsequent suite/test sees a consistent DATABASE_DIR.\n  resolveDatabasePaths();\n});\n\ndescribe('maintenance-marker', () => {\n  it('beginMaintenance writes a marker with this pid, a future TTL, and the label', () => {\n    const before = Date.now();\n    const handle = beginMaintenance('scan');\n\n    expect(markerExists()).toBe(true);\n    const marker = readMarker();\n    expect(marker.childPid).toBe(process.pid);\n    expect(marker.activeUntilMs).toBeGreaterThan(before);\n    expect(marker.labels).toContain('scan');\n\n    handle.end();\n  });\n\n  it('is reference-counted: marker persists until the LAST holder ends', () => {\n    const first = beginMaintenance('scan');\n    const second = beginMaintenance('embedding-queue');\n\n    expect(markerExists()).toBe(true);\n    let marker = readMarker();\n    expect(marker.labels).toContain('scan');\n    expect(marker.labels).toContain('embedding-queue');\n\n    // Ending the FIRST holder: marker must STILL exist (second is active).\n    // The on-disk file is only rewritten on a write event (begin/refresh/timer),\n    // so end() does NOT itself re-serialize the pruned label set — it just\n    // decrements the in-memory ref count. The reference-counting contract under\n    // test is file PERSISTENCE while >=1 holder remains.\n    first.end();\n    expect(markerExists()).toBe(true);\n\n    // The next write (refresh on the surviving holder) reflects the pruned label\n    // set, confirming the first holder's label was decremented from live state.\n    second.refresh();\n    marker = readMarker();\n    expect(marker.labels).toContain('embedding-queue');\n    expect(marker.labels).not.toContain('scan');\n\n    // Ending the SECOND (last) holder: marker is REMOVED.\n    second.end();\n    expect(markerExists()).toBe(false);\n  });\n\n  it('end() is idempotent: calling twice on the sole holder removes the file once and does not throw', () => {\n    const handle = beginMaintenance('scan');\n    expect(markerExists()).toBe(true);\n\n    expect(() => {\n      handle.end();\n      handle.end();\n    }).not.toThrow();\n\n    expect(markerExists()).toBe(false);\n  });\n\n  it('refresh() rewrites the marker with a non-decreasing activeUntilMs and a refreshed timestamp', () => {\n    const handle = beginMaintenance('scan');\n    const first = readMarker();\n\n    handle.refresh();\n    const second = readMarker();\n\n    // TTL is recomputed from Date.now(); never goes backwards on refresh.\n    expect(second.activeUntilMs).toBeGreaterThanOrEqual(first.activeUntilMs);\n    // refreshedAtIso must be a valid ISO timestamp and not predate the first write.\n    expect(Date.parse(second.refreshedAtIso)).toBeGreaterThanOrEqual(\n      Date.parse(first.refreshedAtIso),\n    );\n    expect(Number.isNaN(Date.parse(second.refreshedAtIso))).toBe(false);\n\n    handle.end();\n  });\n\n  it('removes the marker once all handles have ended', () => {\n    const a = beginMaintenance('scan');\n    const b = beginMaintenance('embedding-queue');\n    const c = beginMaintenance('checkpoint');\n    expect(markerExists()).toBe(true);\n\n    a.end();\n    b.end();\n    expect(markerExists()).toBe(true);\n\n    c.end();\n    expect(markerExists()).toBe(false);\n  });\n\n  it('__resetMaintenanceMarkerForTest removes the on-disk marker, not just in-memory state', () => {\n    // Leave a holder active so the marker is on disk and the ref count is non-zero.\n    beginMaintenance('scan');\n    expect(markerExists()).toBe(true);\n\n    __resetMaintenanceMarkerForTest();\n\n    // The reset must clear the on-disk marker so a later test reusing the same\n    // DATABASE_DIR cannot observe a stale marker.\n    expect(markerExists()).toBe(false);\n\n    // A fresh begin after reset starts from a clean slate (no leaked labels).\n    const handle = beginMaintenance('embedding-queue');\n    const marker = readMarker();\n    expect(marker.labels).toEqual(['embedding-queue']);\n    handle.end();\n  });\n\n  it('two holders sharing a label: ending one keeps the marker until the other ends', () => {\n    const first = beginMaintenance('scan');\n    const second = beginMaintenance('scan');\n    expect(markerExists()).toBe(true);\n\n    // Ending one of two same-label holders leaves the marker present (ref count 1).\n    first.end();\n    expect(markerExists()).toBe(true);\n\n    // The surviving holder still sees the shared label on the next write.\n    second.refresh();\n    expect(readMarker().labels).toContain('scan');\n\n    // Ending the last holder removes the marker.\n    second.end();\n    expect(markerExists()).toBe(false);\n  });\n});","lineStart":1,"lineEnd":190,"totalLines":190,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/maintenance-marker.vitest.ts","time":{"start":1781756786872,"end":1781756786879}},"metadata":{"openai":{"itemId":"fc_03ebecbc6e88b563016a337372a97c8191bf895c3a2633451c"}},"id":"prt_ed8faf8b7001ps6w3hFg00FyeN","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fab5ed0015PC9Bi455AYh43"}}
