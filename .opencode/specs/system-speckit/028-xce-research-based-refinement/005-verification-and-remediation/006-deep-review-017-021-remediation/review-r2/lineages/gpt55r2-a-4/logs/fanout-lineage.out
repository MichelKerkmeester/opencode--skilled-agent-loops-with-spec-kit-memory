ng; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db) return [];\n\n  const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n  if (tokens.length === 0) return [];\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n  const normalizedQuery = normalizeTriggerText(query);\n  const exactPhraseLike = `%${normalizedQuery}%`;\n  const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n  const conditions = [\n    `m.trigger_phrases IS NOT NULL`,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"  if (!Number.isFinite(parsed)) return 0;\n  const ageDays = Math.max(0, (Date.now() - parsed) / 86_400_000);\n  return 1 / (1 + ageDays / 30);\n}\n\nfunction exactTriggerSearch(\n  query: string,\n  options: { limit?: number; specFolder?: string; includeArchived?: boolean } = {}\n): HybridSearchResult[] {\n  if (!db) return [];\n\n  const tokens = triggerQueryTokens(query).filter((token) => token.length >= 3).slice(0, 8);\n  if (tokens.length === 0) return [];\n\n  const { limit = DEFAULT_LIMIT, specFolder } = options;\n  const normalizedQuery = normalizeTriggerText(query);\n  const exactPhraseLike = `%${normalizedQuery}%`;\n  const candidateLimit = Math.max(200, Math.min(1000, limit * 100));\n  const conditions = [\n    `m.trigger_phrases IS NOT NULL`,\n    `m.trigger_phrases != ''`,\n    `m.trigger_phrases != '[]'`,\n    // Cold/deprecated-tier rows are included by default (FSRS retrievability ranks\n    // them below hot memories); the hard exclusion only applies when archived\n    // retrieval is disabled.\n    ...(isArchivedRetrievalIncludedByDefault()\n      ? []\n      : [`(m.importance_tier IS NULL OR m.importance_tier != 'deprecated')`]),\n    `(m.expires_at IS NULL OR m.expires_at > datetime('now'))`,\n    `(${tokens.map(() => 'LOWER(m.trigger_phrases) LIKE ?').join(' OR ')})`,\n  ];\n  const params: unknown[] = tokens.map((token) => `%${token}%`);\n\n  if (specFolder) {\n    conditions.push(`(m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')`);\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  try {\n    const rows = db.prepare(`\n      SELECT m.*\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE ${conditions.join(' AND ')}\n      ORDER BY\n        CASE WHEN LOWER(m.trigger_phrases) LIKE ? THEN 0 ELSE 1 END,\n        COALESCE(m.updated_at, m.created_at, '') DESC\n      LIMIT ${candidateLimit}\n    `).all(...params, exactPhraseLike) as Array<Record<string, unknown>>;\n\n    return rows\n      .map((row): HybridSearchResult | null => {\n        const phrases = parse_trigger_phrases(row.trigger_phrases as string | string[] | null | undefined);\n        const matchScore = Math.max(0, ...phrases.map((phrase) => computeTriggerMatchScore(query, phrase)));\n        if (matchScore <= 0) return null;\n\n        const importance = typeof row.importance_weight === 'number' && Number.isFinite(row.importance_weight)\n          ? Math.max(0, Math.min(1, row.importance_weight))\n          : 0.5;\n        const recency = timestampBoost(row.updated_at ?? row.created_at);\n        const score = Math.min(1, matchScore + importance * 0.03 + recency * 0.04);\n\n        return {\n          ...row,\n          id: row.id as number,","lineStart":700,"lineEnd":764,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781762001160,"end":1781762001163}},"metadata":{"openai":{"itemId":"fc_04b1a8c76e7da141016a3387d0ef888191b2b61672f19fcbe2"}},"id":"prt_ed94a88f50018Yd272KOMK2lmn","sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","messageID":"msg_ed94a5471001hkTtDTRJeQO1ew"}}
{"type":"tool_use","timestamp":1781762001212,"sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","part":{"type":"tool","tool":"read","callID":"call_5tawJ0dMSTzARl3a84dSgpTG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","offset":170,"limit":45},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts</path>\n<type>file</type>\n<content>\n170:   const { limit = 20, specFolder, includeArchived = false } = options;\n171:   // Include cold/deprecated-tier rows by default (or on explicit includeArchived) —\n172:   // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n173:   const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n174: \n175:   // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n176:   const sanitized = normalizeLexicalQueryTokens(query).fts;\n177: \n178:   if (!sanitized) {\n179:     setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n180:     return [];\n181:   }\n182: \n183:   const folderFilter = specFolder\n184:     ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n185:     : '';\n186:   const deprecatedTierFilter = includeCold\n187:     ? ''\n188:     : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n189: \n190:   const params: (string | number)[] = specFolder\n191:     ? [sanitized, specFolder, specFolderLikePattern(specFolder), limit]\n192:     : [sanitized, limit];\n193: \n194:   // Bm25() returns negative scores (lower = better), so we negate\n195:   // To produce positive scores where higher = better match.\n196:   const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n197:   const sql = `\n198:     SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n199:     FROM memory_fts\n200:     JOIN memory_index m ON m.id = memory_fts.rowid\n201:     WHERE memory_fts MATCH ?\n202:       ${folderFilter}\n203:       ${deprecatedTierFilter}\n204:     ORDER BY fts_score DESC\n205:     LIMIT ?\n206:   `;\n207: \n208:   const capability = probeFts5Capability(db);\n209:   setLastLexicalCapabilitySnapshot(capability);\n210:   if (capability.fallbackState !== 'ok') {\n211:     console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n212:     return [];\n213:   }\n214: \n\n(Showing lines 170-214 of 299. Use offset=215 to continue.)\n</content>","metadata":{"preview":"  const { limit = 20, specFolder, includeArchived = false } = options;\n  // Include cold/deprecated-tier rows by default (or on explicit includeArchived) —\n  // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n  const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n\n  // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n  const sanitized = normalizeLexicalQueryTokens(query).fts;\n\n  if (!sanitized) {\n    setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n    return [];\n  }\n\n  const folderFilter = specFolder\n    ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n    : '';\n  const deprecatedTierFilter = includeCold\n    ? ''\n    : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","text":"  const { limit = 20, specFolder, includeArchived = false } = options;\n  // Include cold/deprecated-tier rows by default (or on explicit includeArchived) —\n  // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n  const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n\n  // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n  const sanitized = normalizeLexicalQueryTokens(query).fts;\n\n  if (!sanitized) {\n    setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n    return [];\n  }\n\n  const folderFilter = specFolder\n    ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n    : '';\n  const deprecatedTierFilter = includeCold\n    ? ''\n    : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n\n  const params: (string | number)[] = specFolder\n    ? [sanitized, specFolder, specFolderLikePattern(specFolder), limit]\n    : [sanitized, limit];\n\n  // Bm25() returns negative scores (lower = better), so we negate\n  // To produce positive scores where higher = better match.\n  const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n  const sql = `\n    SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n    FROM memory_fts\n    JOIN memory_index m ON m.id = memory_fts.rowid\n    WHERE memory_fts MATCH ?\n      ${folderFilter}\n      ${deprecatedTierFilter}\n    ORDER BY fts_score DESC\n    LIMIT ?\n  `;\n\n  const capability = probeFts5Capability(db);\n  setLastLexicalCapabilitySnapshot(capability);\n  if (capability.fallbackState !== 'ok') {\n    console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n    return [];\n  }\n","lineStart":170,"lineEnd":214,"totalLines":299,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","time":{"start":1781762001209,"end":1781762001211}},"metadata":{"openai":{"itemId":"fc_04b1a8c76e7da141016a3387d0ef8c8191bf70c5d437b79487"}},"id":"prt_ed94a890c001JibyOn424ayqiu","sessionID":"ses_126b79683ffe1J61Cb0HgstWBi","messageID":"msg_ed94a5471001hkTtDTRJeQO1ew"}}
