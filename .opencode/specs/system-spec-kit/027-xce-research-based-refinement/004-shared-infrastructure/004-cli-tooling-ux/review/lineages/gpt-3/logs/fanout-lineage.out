 codes:\n239:   0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error\n240: \n241: Exit 69 recovery:\n242:   - Missing or stale dist entrypoint: run npm run build --workspace=@spec-kit/mcp-server.\n243:     - Backend protocol version changed: rebuild the CLI and daemon from the same checkout, then update any pinned client.\n244:     - Socket path or daemon config mismatch: check SPECKIT_IPC_SOCKET_DIR, socket length, and daemon config before retrying.`;\n245: }\n246: \n247: function parseCompletionShell(raw: string): CompletionShell {\n248:   if (raw === 'bash' || raw === 'zsh') return raw;\n249:   throw new CliUsageError('completion shell must be one of: bash, zsh');\n250: }\n251: \n252: function normalizeName(value: string): string {\n253:   return value.replace(/[-_]/g, '').toLowerCase();\n254: }\n255: \n256: function toCamelCaseFlag(value: string): string {\n257:   return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n258: }\n259: \n260: function commandMap(): Map<string, ToolDefinition> {\n261:   const map = new Map<string, ToolDefinition>();\n262:   for (const tool of TOOL_DEFINITIONS) {\n263:     for (const alias of commandAliases(tool.name)) {\n264:       const existing = map.get(alias);\n265:       if (existing && existing.name !== tool.name) {\n266:         throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n267:       }\n268:       map.set(alias, tool);\n269:     }\n270:   }\n271:   return map;\n272: }\n273: \n274: function getToolDefinition(command: string): ToolDefinition | null {\n275:   return commandMap().get(command) ?? null;\n276: }\n277: \n278: function inputPropertyNames(tool: ToolDefinition): string[] {\n279:   const schema = tool.inputSchema;\n280:   const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n281:     ? (schema as { readonly properties?: unknown }).properties\n282:     : null;\n283:   if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n284:   return Object.keys(properties);\n285: }\n286: \n287: function resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n288:   const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n289:   if (exact) return exact;\n290: \n291:   const normalized = normalizeName(rawFlag);\n292:   const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n293:   if (matched) return matched;\n294: \n295:   return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n296: }\n297: \n298: function parseValue(raw: string): unknown {\n299:   const trimmed = raw.trim();\n300:   if (trimmed === 'true') return true;\n301:   if (trimmed === 'false') return false;\n302:   if (trimmed === 'null') return null;\n303:   if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n304:     try {\n305:       return JSON.parse(trimmed) as unknown;\n306:     } catch (error: unknown) {\n307:       const message = error instanceof Error ? error.message : String(error);\n308:       throw new CliUsageError(`Invalid JSON value: ${message}`);\n309:     }\n310:   }\n311:   return raw;\n312: }\n313: \n314: function parsePositiveInteger(raw: string, flagName: string): number {\n315:   if (!/^\\d+$/.test(raw)) {\n316:     throw new CliUsageError(`${flagName} must be a positive integer`);\n317:   }\n318:   const value = Number.parseInt(raw, 10);\n319:   if (!Number.isFinite(value) || value <= 0) {\n320:     throw new CliUsageError(`${flagName} must be a positive integer`);\n321:   }\n322:   return value;\n323: }\n324: \n325: function parseFormat(raw: string): OutputFormat {\n326:   if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n327:   throw new CliUsageError('--format must be one of: json, text, jsonl');\n328: }\n329: \n330: function parseInlineBoolean(raw: string, flagName: string): boolean {\n331:   if (raw === 'true' || raw === '1') return true;\n332:   if (raw === 'false' || raw === '0') return false;\n333:   throw new CliUsageError(`${flagName} must be true or false`);\n334: }\n335: \n336: function readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n337:   const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n338:   if (inline) return { value: inline[1], nextIndex: index + 1 };\n339:   const value = tokens[index + 1];\n340:   if (value === undefined) {\n341:     throw new CliUsageError(`${flagName} requires a value`);\n342:   }\n343:   return { value, nextIndex: index + 2 };\n344: }\n345: \n346: function parseJsonObject(raw: string): Record<string, unknown> {\n347:   let parsed: unknown;\n348:   try {\n349:     parsed = JSON.parse(raw) as unknown;\n350:   } catch (error: unknown) {\n351:     const message = error instanceof Error ? error.message : String(error);\n352:     throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n353:   }\n354:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n355:     throw new CliUsageError('--json must be a JSON object');\n356:   }\n357:   return parsed as Record<string, unknown>;\n358: }\n359: \n360: function envFlagEnabled(name: string): boolean {\n361:   const raw = process.env[name];\n362:   if (raw === undefined || raw === null) return false;\n363:   return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n364: }\n365: \n366: function defaultWarmOnly(): boolean {\n367:   return envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_WARM_ONLY')\n368:     || envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME')\n369:     || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n370:     || envFlagEnabled('OPENCODE_PROMPT_TIME')\n371:     || envFlagEnabled('CODEX_PROMPT_TIME')\n372:     || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n373: }\n374: \n375: export function parseCliArgs(argv: string[]): ParsedCommand {\n376:   const command = argv[0];\n377:   const warmOnlyDefault = defaultWarmOnly();\n378:   if (!command || command === '--help' || command === '-h') {\n379:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n380:   }\n381:   if (command === '--version' || command === '-v') {\n382:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n383:   }\n384: \n385:   let format: OutputFormat = 'json';\n386:   let timeoutMs = DEFAULT_TIMEOUT_MS;\n387:   let sessionId: string | undefined;\n388:   let warmOnly = warmOnlyDefault;\n389:   let toolListMode: ToolListMode = 'full';\n390:   let completionShell: CompletionShell | undefined;\n391:   let jsonPayload: Record<string, unknown> | null = null;\n392:   const tool = getToolDefinition(command);\n393:   const parsedArgs: Record<string, unknown> = {};\n394:   const tokens = argv.slice(1);\n395:   let index = 0;\n396: \n397:   while (index < tokens.length) {\n398:     const token = tokens[index];\n399:     if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n400:       completionShell = parseCompletionShell(token);\n401:       index += 1;\n402:       continue;\n403:     }\n404:     if (!token.startsWith('--')) {\n405:       throw new CliUsageError(`Unexpected positional argument: ${token}`);\n406:     }\n407:     const rawFlag = token.slice(2).split('=', 1)[0];\n408:     const option = `--${rawFlag}`;\n409: \n410:     if (rawFlag === 'help' || rawFlag === 'h') {\n411:       return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n412:     }\n413:     if (rawFlag === 'format') {\n414:       const read = readOptionValue(tokens, index, option);\n415:       format = parseFormat(read.value);\n416:       index = read.nextIndex;\n417:       continue;\n418:     }\n419:     if (rawFlag === 'timeout-ms') {\n420:       const read = readOptionValue(tokens, index, option);\n421:       timeoutMs = parsePositiveInteger(read.value, option);\n422:       index = read.nextIndex;\n423:       continue;\n424:     }\n425:     if (rawFlag === 'session-id') {\n426:       const read = readOptionValue(tokens, index, option);\n427:       sessionId = read.value;\n428:       index = read.nextIndex;\n429:       continue;\n430:     }\n431:     if (rawFlag === 'warm-only') {\n432:       const inline = token.match(/^--[^=]+=(.*)$/);\n433:       warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n434:       index += 1;\n435:       continue;\n436:     }\n437:     if (rawFlag === 'no-warm-only') {\n438:       warmOnly = false;\n439:       index += 1;\n440:       continue;\n441:     }\n442:     if (rawFlag === 'compact') {\n443:       toolListMode = 'compact';\n444:       index += 1;\n445:       continue;\n446:     }\n447:     if (rawFlag === 'names-only') {\n448:       toolListMode = 'names-only';\n449:       index += 1;\n450:       continue;\n451:     }\n452:     if (rawFlag === 'json') {\n453:       const read = readOptionValue(tokens, index, option);\n454:       jsonPayload = parseJsonObject(read.value);\n455:       index = read.nextIndex;\n456:       continue;\n457:     }\n458: \n459:     if (!tool) {\n460:       throw new CliUsageError(`Unknown command: ${command}`);\n461:     }\n462: \n463:     const propertyName = resolvePropertyName(rawFlag, tool);\n464:     const inline = token.match(/^--[^=]+=(.*)$/);\n465:     if (inline) {\n466:       parsedArgs[propertyName] = parseValue(inline[1]);\n467:       index += 1;\n468:       continue;\n469:     }\n470: \n471:     const next = tokens[index + 1];\n472:     if (next === undefined || next.startsWith('--')) {\n473:       parsedArgs[propertyName] = true;\n474:       index += 1;\n475:       continue;\n476:     }\n477:     parsedArgs[propertyName] = parseValue(next);\n478:     index += 2;\n479:   }\n480: \n481:   if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n482:     throw new CliUsageError('--json cannot be combined with per-parameter flags');\n483:   }\n484: \n485:   return {\n486:     command,\n487:     format,\n488:     timeoutMs,\n489:     sessionId,\n490:     warmOnly,\n491:     toolListMode,\n492:     completionShell,\n493:     args: jsonPayload ?? parsedArgs,\n494:     help: false,\n495:     version: false,\n496:   };\n497: }\n498: \n499: function validateCommand(parsed: ParsedCommand): { readonly tool: ToolDefinition; readonly args: Record<string, unknown> } | null {\n500:   if (RESERVED_COMMANDS.has(parsed.command)) return null;\n501:   const tool = getToolDefinition(parsed.command);\n502:   if (!tool) {\n503:     throw new CliUsageError(`Unknown command: ${parsed.command}`);\n504:   }\n505: \n506:   const args = { ...parsed.args };\n507:   const properties = new Set(inputPropertyNames(tool));\n508:   if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'sessionId') && properties.has('sessionId')) {\n509:     args.sessionId = parsed.sessionId;\n510:   } else if (parsed.sessionId && !Object.prototype.hasOwnProperty.call(args, 'session_id') && properties.has('session_id')) {\n511:     args.session_id = parsed.sessionId;\n512:   }\n513: \n514:   return {\n515:     tool,\n516:     args: validateToolArgs(tool.name, args) as Record<string, unknown>,\n517:   };\n518: }\n519: \n520: function renderJson(value: unknown, format: OutputFormat): string {\n521:   if (format === 'jsonl') return JSON.stringify(value);\n522:   return JSON.stringify(value, null, 2);\n523: }\n524: \n525: function compactTool(tool: ToolDefinition): Record<string, unknown> {\n526:   return {\n527:     name: tool.name,\n528:     command: tool.name,\n529:     kebabCommand: toKebabCommand(tool.name),\n530:     camelCommand: toCamelCommand(tool.name),\n531:     aliases: commandAliases(tool.name),\n532:     description: tool.description,\n533:   };\n534: }\n535: \n536: function renderToolList(format: OutputFormat, mode: ToolListMode = 'full'): string {\n537:   const payload = {\n538:     status: 'ok',\n539:     data: {\n540:       count: TOOL_DEFINITIONS.length,\n541:       mode,\n542:       tools: TOOL_DEFINITIONS.map((tool) => ({\n543:         name: tool.name,\n544:         command: tool.name,\n545:         kebabCommand: toKebabCommand(tool.name),\n546:         camelCommand: toCamelCommand(tool.name),\n547:         aliases: commandAliases(tool.name),\n548:         description: tool.description,\n549:         inputSchema: tool.inputSchema,\n550:       })),\n551:     },\n552:   };\n553:   const compactPayload = {\n554:     status: 'ok',\n555:     data: {\n556:       count: TOOL_DEFINITIONS.length,\n557:       mode,\n558:       tools: TOOL_DEFINITIONS.map(compactTool),\n559:     },\n560:   };\n561:   const namesOnlyPayload = {\n562:     status: 'ok',\n563:     data: {\n564:       count: TOOL_DEFINITIONS.length,\n565:       mode,\n566:       names: TOOL_DEFINITIONS.map((tool) => tool.name),\n567:     },\n568:   };\n569: \n570:   if (format === 'text') {\n571:     return TOOL_DEFINITIONS.map((tool) => tool.name).join('\\n');\n572:   }\n573:   if (mode === 'compact') return renderJson(compactPayload, format);\n574:   if (mode === 'names-only') return renderJson(namesOnlyPayload, format);\n575:   return renderJson(payload, format);\n576: }\n577: \n578: function completionWords(): string[] {\n579:   return ['list-tools', 'completion', ...TOOL_DEFINITIONS.map((tool) => tool.name)];\n580: }\n581: \n582: function shellWords(words: readonly string[]): string {\n583:   return words.join(' ');\n584: }\n585: \n586: function renderBashCompletion(): string {\n587:   const commands = shellWords(completionWords());\n588:   const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n589:   const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n590:   return `_spec_memory_completion() {\n591:   local cur\n592:   COMPREPLY=()\n593:   cur=\"\\${COMP_WORDS[COMP_CWORD]}\"\n594:   if [[ \\${COMP_CWORD} -eq 1 ]]; then\n595:     COMPREPLY=( $(compgen -W \"${commands}\" -- \"\\${cur}\") )\n596:     return 0\n597:   fi\n598:   case \"\\${COMP_WORDS[1]}\" in\n599:     completion) COMPREPLY=( $(compgen -W \"bash zsh\" -- \"\\${cur}\") ) ;;\n600:     list-tools) COMPREPLY=( $(compgen -W \"${listFlags}\" -- \"\\${cur}\") ) ;;\n601:     *) COMPREPLY=( $(compgen -W \"${commonFlags}\" -- \"\\${cur}\") ) ;;\n602:   esac\n603: }\n604: complete -F _spec_memory_completion spec-memory`;\n605: }\n606: \n607: function renderZshCompletion(): string {\n608:   const commands = shellWords(completionWords());\n609:   const commonFlags = shellWords(['--help', '--format', '--json', '--timeout-ms', '--session-id', '--warm-only', '--no-warm-only']);\n610:   const listFlags = shellWords(['--help', '--format', '--compact', '--names-only']);\n611:   return `#compdef spec-memory\n612: _spec_memory() {\n613:   local -a commands common_flags list_flags shells\n614:   commands=(${commands})\n615:   common_flags=(${commonFlags})\n616:   list_flags=(${listFlags})\n617:   shells=(bash zsh)\n618:   if (( CURRENT == 2 )); then\n619:     _describe 'commands' commands\n\n(Showing lines 200-619 of 1042. Use offset=620 to continue.)\n</content>","metadata":{"preview":"  return name.replace(/_([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandAliases(name: string): string[] {\n  return Array.from(new Set([name, toKebabCommand(name), toCamelCommand(name)]));\n}\n\nfunction usageText(command?: string): string {\n  const tool = command ? getToolDefinition(command) : null;\n  if (tool) {\n    return `spec-memory ${tool.name}\n\nDescription:\n  ${tool.description}\n\nAliases:\n  ${commandAliases(tool.name).join(', '