ata.session_created as number\\n.opencode/skills/system-spec-kit/scripts/utils/input-normalizer.ts:1728:      : typeof metadata?.session_updated === 'number'\\n.opencode/skills/system-spec-kit/scripts/utils/input-normalizer.ts:1729:        ? metadata.session_updated as number\\n.opencode/skills/system-spec-kit/scripts/rules/check-template-source.sh:45:        # (frontmatter with trigger_phrases arrays can exceed 10 lines)\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:3:description: \\\"Decomposed pipeline modules for the memory_save MCP tool handler, covering dedup, embedding, PE gating, record creation, reconsolidation and response assembly.\\\"\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:4:trigger_phrases:\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:27:`handlers/save/` contains the decomposed pipeline for the `memory_save` MCP tool. Each file owns a single stage of the save flow, from deduplication through embedding generation, save quality gating, prediction-error gating, reconsolidation, record creation, post-insert enrichment, and final response assembly.\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:45:| `post-insert.ts`            | Post-insert enrichment pipeline. Runs causal links processing, R10 entity extraction, R8 summary generation and S5 cross-document entity linking. Each step is feature-flag gated and independently error-guarded. |\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:46:| `response-builder.ts`       | Final response assembly. `buildIndexResult` constructs the `IndexResult` with PE actions, causal links and warnings. `buildSaveResponse` wraps it in a standard MCP success envelope with hints, triggers post-mutation hooks and runs N3-lite consolidation. |\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:53:1. dedup          -- Skip if unchanged or duplicate content hash\\n.opencode/skills/system-spec-kit/mcp_server/handlers/save/README.md:60:8. post-insert    -- Enrich with entities, summaries, causal links\\n.opencode/skills/system-spec-kit/mcp_server/utils/README.md:4:trigger_phrases:\\n.opencode/skills/system-spec-kit/mcp_server/api/search.ts:16:  fts5Bm25Search,\\n.opencode/skills/system-spec-kit/mcp_server/api/search.ts:18:} from '../lib/search/sqlite-fts.js';\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:8:// Extracts implementation guidance and step-by-step instructions from session observations\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:13:// O3-2: Use canonical types from session-types (no local duplicates)\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:20:} from '../types/session-types';\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:71:  return `topic-${digest}`;\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:88:    const topicSlug = slugify(baseTitle).substring(0, 40);\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:89:    return topicSlug || createTopicFallback(baseTitle || implObs.title);\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:131:        DESCRIPTION: description || 'Implemented during session'\\n.opencode/skills/system-spec-kit/scripts/extractors/implementation-guide-extractor.ts:200:        !existingDesc.toLowerCase().includes('modified during session')) {\\n.opencode/skills/system-spec-kit/scripts/spec/check-placeholders.sh:106:    # Memory/ contains generated session context markdown that legitimately\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:89:    reason: 'Sparse trigger phrases are diagnostic, but not enough to reject an otherwise valid rendered memory.',\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:129:    name: 'session-source-mismatch',\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:147:    name: 'topical-coherence-mismatch',\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:152:    reason: 'Memory content with zero topical overlap with spec trigger_phrases suggests off-target capture.',\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:213:  { pattern: /^(to promote a memory|epistemic state captured at session start|table of contents)\\\\b/i, label: 'template instructional heading' },\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:215:  { pattern: /^(untitled|draft|todo|tbd)(?:\\\\s+(memory|session|summary|document|notes?))?$/i, label: 'generic stub title' },\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:468:  // When one count is 0, the session produced no file references\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:469:  // (newly created specs, research sessions, non-file-tool CLIs).\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:570: * Example: \\\"010-perfect-session-capturing/012-template-compliance\\\"\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:571: *   -> allowed = { \\\"010-perfect-session-capturing\\\", \\\"012-template-compliance\\\" }\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:764:  const triggerPhrases = parseYamlListFromContent(content, 'trigger_phrases');\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:765:  const sparseSemantic = toolCount >= 5 && triggerPhrases.length === 0;\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:769:    message: sparseSemantic ? 'sparse semantic fields: trigger_phrases empty' : 'ok',\\n.opencode/skills/system-spec-kit/scripts/lib/validate-memory-quality.ts:822:  const keyTopics = parseYamlListFromContent(co