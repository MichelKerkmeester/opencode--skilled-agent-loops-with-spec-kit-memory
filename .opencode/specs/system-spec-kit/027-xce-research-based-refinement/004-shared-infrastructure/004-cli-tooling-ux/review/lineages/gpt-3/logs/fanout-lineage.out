ion extractToolPayload(toolName: string, result: unknown): ToolPayloadResult {\n858:   const toolResult = result && typeof result === 'object' ? result as ToolResult : null;\n859:   const firstText = toolResult?.content?.find((entry) => typeof entry.text === 'string')?.text;\n860:   if (firstText) {\n861:     try {\n862:       const payload = JSON.parse(firstText) as unknown;\n863:       return {\n864:         payload,\n865:         isError: toolResult?.isError === true || isErrorPayload(payload),\n866:       };\n867:     } catch {\n868:       return {\n869:         payload: {\n870:           status: toolResult?.isError ? 'error' : 'ok',\n871:           tool: toolName,\n872:           text: firstText,\n873:         },\n874:         isError: toolResult?.isError === true,\n875:       };\n876:     }\n877:   }\n878:   return {\n879:     payload: {\n880:       status: toolResult?.isError ? 'error' : 'ok',\n881:       tool: toolName,\n882:       result,\n883:     },\n884:     isError: toolResult?.isError === true,\n885:   };\n886: }\n887: \n888: function getDataRecord(payload: unknown): Record<string, unknown> | null {\n889:   if (!isRecord(payload) || !isRecord(payload.data)) return null;\n890:   return payload.data;\n891: }\n892: \n893: function renderJobText(toolName: string, payload: unknown): string | null {\n894:   const data = getDataRecord(payload);\n895:   if (!data) return null;\n896: \n897:   if (toolName === 'advisor_rebuild') {\n898:     return [\n899:       `advisor_rebuild: ${data.rebuilt === true ? 'rebuilt' : 'skipped'}`,\n900:       `reason: ${String(data.reason ?? 'unknown')}`,\n901:       `freshness: ${String(data.freshnessBefore ?? 'unknown')} -> ${String(data.freshnessAfter ?? 'unknown')}`,\n902:       `generation: ${String(data.generationBefore ?? 'unknown')} -> ${String(data.generationAfter ?? 'unknown')}`,\n903:       `skillCount: ${String(data.skillCount ?? 'unknown')}`,\n904:     ].join('\\n');\n905:   }\n906: \n907:   if (toolName === 'skill_graph_scan') {\n908:     const scan = isRecord(data.scan) ? data.scan : data;\n909:     return [\n910:       'skill_graph_scan: completed',\n911:       `generation: ${String(data.generationBefore ?? 'unknown')} -> ${String(data.generationAfter ?? 'unknown')}`,\n912:       `scannedFiles: ${String(scan.scannedFiles ?? 'unknown')}`,\n913:       `indexedFiles: ${String(scan.indexedFiles ?? 'unknown')}`,\n914:       `indexedEdges: ${String(scan.indexedEdges ?? 'unknown')}`,\n915:       `rejectedEdges: ${String(scan.rejectedEdges ?? 'unknown')}`,\n916:     ].join('\\n');\n917:   }\n918: \n919:   return null;\n920: }\n921: \n922: function renderPayload(payload: unknown, format: OutputFormat, toolName?: string): string {\n923:   if (format === 'json' || format === 'jsonl') return renderJson(payload, format);\n924:   if (toolName) {\n925:     const jobText = renderJobText(toolName, payload);\n926:     if (jobText) return jobText;\n927:   }\n928:   if (isRecord(payload)) {\n929:     if (typeof payload.summary === 'string') return payload.summary;\n930:     if (typeof payload.error === 'string') return payload.error;\n931:     if (typeof payload.message === 'string') return payload.message;\n932:   }\n933:   return typeof payload === 'string' ? payload : JSON.stringify(payload, null, 2);\n934: }\n935: \n936: function isProtocolMismatch(error: unknown): boolean {\n937:   if (error instanceof JsonRpcError && error.code === -32002) return true;\n938:   const message = error instanceof Error ? error.message : String(error);\n939:   return /protocol.*(mismatch|changed|version)/i.test(message);\n940: }\n941: \n942: function isRetryableError(error: unknown): boolean {\n943:   if (error instanceof CliRetryableError) return true;\n944:   if (error instanceof JsonRpcError && error.code === -32001) return true;\n945:   const message = error instanceof Error ? error.message : String(error);\n946:   return /SQLITE_BUSY|ECONNREFUSED|ENOENT|ECONNRESET|EPIPE|ETIMEDOUT|backend unavailable|retry/i.test(message);\n947: }\n948: \n949: function exitCodeForError(error: unknown): number {\n950:   if (error instanceof CliUsageError || error instanceof ToolSchemaValidationError) return EXIT_USAGE;\n951:   if (error instanceof CliProtocolError || isProtocolMismatch(error)) return EXIT_PROTOCOL;\n952:   if (isRetryableError(error)) return EXIT_RETRYABLE;\n953:   if (error instanceof JsonRpcError && error.code === -32602) return EXIT_USAGE;\n954:   return EXIT_RUNTIME;\n955: }\n956: \n957: function levenshteinDistance(left: string, right: string): number {\n958:   const previous = Array.from({ length: right.length + 1 }, (_value, index) => index);\n959:   const current = new Array<number>(right.length + 1);\n960: \n961:   for (let leftIndex = 1; leftIndex <= left.length; leftIndex += 1) {\n962:     current[0] = leftIndex;\n963:     for (let rightIndex = 1; rightIndex <= right.length; rightIndex += 1) {\n964:       const cost = left[leftIndex - 1] === right[rightIndex - 1] ? 0 : 1;\n965:       current[rightIndex] = Math.min(\n966:         current[rightIndex - 1] + 1,\n967:         previous[rightIndex] + 1,\n968:         previous[rightIndex - 1] + cost,\n969:       );\n970:     }\n971:     previous.splice(0, previous.length, ...current);\n972:   }\n973: \n974:   return previous[right.length];\n975: }\n976: \n977: function closestCommand(command: string): string | undefined {\n978:   const targets = new Map<string, string>([['list-tools', 'list-tools']]);\n979:   targets.set('completion', 'completion');\n980:   for (const tool of SKILL_ADVISOR_CLI_TOOL_MANIFEST) {\n981:     for (const alias of tool.aliases) {\n982:       targets.set(alias, tool.name);\n983:     }\n984:   }\n985: \n986:   let best: { readonly command: string; readonly distance: number } | null = null;\n987:   for (const [alias, canonical] of targets) {\n988:     const distance = levenshteinDistance(normalizeName(command), normalizeName(alias));\n989:     if (!best || distance < best.distance || (distance === best.distance && canonical < best.command)) {\n990:       best = { command: canonical, distance };\n991:     }\n992:   }\n993: \n994:   if (!best) return undefined;\n995:   const threshold = Math.max(2, Math.floor(normalizeName(command).length * 0.4));\n996:   return best.distance <= threshold ? best.command : undefined;\n997: }\n998: \n999: function unknownCommandContext(message: string): { readonly hint: string; readonly suggestion?: string } | null {\n1000:   const match = message.match(/^Unknown command: (.+)$/);\n1001:   if (!match) return null;\n1002:   return {\n1003:     hint: 'Try `list-tools` to see available commands.',\n1004:     suggestion: closestCommand(match[1]),\n1005:   };\n1006: }\n1007: \n1008: function socketPathTooLong(socketPath: string): boolean {\n1009:   if (socketPath.startsWith('tcp://')) return false;\n1010:   return process.platform === 'darwin' && Buffer.byteLength(socketPath) > 103;\n1011: }\n1012: \n1013: function ensureSocketEnvironment(): void {\n1014:   if (!process.env.SPECKIT_IPC_SOCKET_DIR) {\n1015:     process.env.SPECKIT_IPC_SOCKET_DIR = DEFAULT_SOCKET_DIR;\n1016:   }\n1017:   const socketDir = process.env.SPECKIT_IPC_SOCKET_DIR;\n1018:   if (!socketDir || socketDir.startsWith('tcp://')) return;\n1019:   mkdirSync(socketDir, { recursive: true, mode: 0o700 });\n1020:   const stat = statSync(socketDir);\n1021:   if ((stat.mode & 0o022) !== 0) {\n1022:     throw new CliProtocolError(`IPC socket directory is group/world-writable: ${socketDir}`);\n1023:   }\n1024: }\n1025: \n1026: function sleep(ms: number): Promise<void> {\n1027:   return new Promise((resolve) => setTimeout(resolve, ms));\n1028: }\n1029: \n1030: function spawnLauncher(paths: RepoPaths): void {\n1031:   const child = spawn(process.execPath, [paths.launcherPath], {\n1032:     cwd: paths.repoRoot,\n1033:     env: process.env,\n1034:     detached: true,\n1035:     stdio: 'ignore',\n1036:   });\n1037:   child.unref();\n1038: }\n1039: \n1040: async function waitForDaemon(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<void> {\n1041:   const deadline = Date.now() + timeoutMs;\n1042:   let lastReason = 'not probed';\n1043: \n1044:   while (Date.now() <= deadline) {\n1045:     const remaining = Math.max(1, deadline - Date.now());\n1046:     const probe = await bridge.probeDaemon(socketPath, {\n1047:       timeoutMs: Math.min(remaining, 5000),\n1048:       deepProbe: true,\n1049:     });\n1050:     if (probe.status === 'alive') return;\n1051:     lastReason = probe.reason ?? probe.status;\n1052:     await sleep(100);\n1053:   }\n1054: \n1055:   throw new CliRetryableError(`backend unavailable: ${lastReason}`);\n1056: }\n1057: \n1058: class JsonRpcSocketClient {\n1059:   private nextId = 1;\n1060:   private readonly decoder = new StringDecoder('utf8');\n1061: \n1062:   private constructor(\n1063:     private readonly socket: net.Socket,\n1064:   ) {}\n1065: \n1066:   static connect(socketPath: string, bridge: BridgeModule, timeoutMs: number): Promise<JsonRpcSocketClient> {\n1067:     return new Promise((resolve, reject) => {\n1068:       let socket: net.Socket;\n1069:       let settled = false;\n1070:       const finish = (error?: Error): void => {\n1071:         if (settled) return;\n1072:         settled = true;\n1073:         clearTimeout(timer);\n1074:         socket.off?.('connect', onConnect);\n1075:         socket.off?.('error', onError);\n1076:         if (error) {\n1077:           socket.destroy?.();\n1078:           reject(error);\n1079:           return;\n1080:         }\n1081:         resolve(new JsonRpcSocketClient(socket));\n1082:       };\n1083:       const onConnect = (): void => finish();\n1084:       const onError = (error: Error): void => finish(error);\n1085:       const timer = setTimeout(() => finish(new CliRetryableError('connection timed out')), timeoutMs);\n1086:       timer.unref?.();\n1087: \n1088:       try {\n1089:         const connectionOptions = bridge.toConnectionOptions(socketPath);\n1090:         socket = typeof connectionOptions === 'string'\n1091:           ? net.createConnection(connectionOptions)\n1092:           : net.createConnection(connectionOptions);\n1093:       } catch (error: unknown) {\n1094:         clearTimeout(timer);\n1095:         reject(error instanceof Error ? error : new Error(String(error)));\n1096:         return;\n1097:       }\n1098:       socket.once('connect', onConnect);\n1099:       socket.once('error', onError);\n1100:     });\n1101:   }\n1102: \n1103:   notify(method: string, params?: unknown): void {\n1104:     const frame = params === undefined\n1105:       ? { jsonrpc: '2.0', method }\n1106:       : { jsonrpc: '2.0', method, params };\n1107:     this.socket.write(`${JSON.stringify(frame)}\\n`);\n1108:   }\n1109: \n1110:   request(method: string, params: unknown, timeoutMs: number): Promise<unknown> {\n1111:     const id = this.nextId++;\n1112:     const request = { jsonrpc: '2.0', id, method, params };\n1113:     return new Promise((resolve, reject) => {\n1114:       let buffer = '';\n1115:       let settled = false;\n1116: \n1117:       const cleanup = (): void => {\n1118:         clearTimeout(timer);\n1119:         this.socket.off('data', onData);\n1120:         this.socket.off('error', onError);\n1121:         this.socket.off('close', onClose);\n1122:       };\n1123:       const finish = (error: unknown, value?: unknown): void => {\n1124:         if (settled) return;\n1125:         settled = true;\n1126:         cleanup();\n1127:         if (error) {\n1128:           reject(error);\n1129:           return;\n1130:         }\n1131:         resolve(value);\n1132:       };\n1133:       const onData = (chunk: Buffer | string): void => {\n1134:         buffer += Buffer.isBuffer(chunk) ? this.decoder.write(chunk) : String(chunk ?? '');\n1135:         let newlineIndex = buffer.indexOf('\\n');\n1136:         while (newlineIndex !== -1) {\n1137:           const line = buffer.slice(0, newlineIndex).trim();\n1138:           buffer = buffer.slice(newlineIndex + 1);\n1139:           newlineIndex = buffer.indexOf('\\n');\n1140:           if (!line) continue;\n1141:           let parsed: JsonRpcResponse;\n1142:           try {\n1143:             parsed = JSON.parse(line) as JsonRpcResponse;\n1144:           } catch {\n1145:             continue;\n1146:           }\n1147:           if (parsed.id !== id) continue;\n1148:           if (parsed.error) {\n1149:             finish(new JsonRpcError(parsed.error));\n1150:             return;\n1151:           }\n1152:           finish(null, parsed.result);\n1153:           return;\n1154:         }\n1155:       };\n1156:       const onError = (error: Error): void => finish(error);\n1157:       const onClose = (): void => finish(new CliRetryableError('socket closed before response'));\n1158:       const timer = setTimeout(() => finish(new CliRetryableError(`${method} timed out`)), timeoutMs);\n1159:       timer.unref?.();\n1160: \n1161:       this.socket.on('data', onData);\n1162:       this.socket.once('error', onError);\n1163:       this.socket.once('close', onClose);\n1164:       this.socket.write(`${JSON.stringify(request)}\\n`);\n1165:     });\n1166:   }\n1167: \n1168:   close(): void {\n1169:     this.socket.end();\n1170:     this.socket.destroy();\n1171:   }\n1172: }\n1173: \n1174: function callerMeta(trusted: boolean): Record<string, unknown> {\n1175:   return {\n1176:     transport: 'cli',\n1177:     trusted,\n1178:     callerAuthority: trusted ? 'trusted' : 'untrusted',\n1179:     pid: process.pid,\n1180:     client: 'skill-advisor-cli',\n1181:   };\n1182: }\n1183: \n1184: async function ensureDaemonReady(socketPath: string, bridge: BridgeModule, paths: RepoPaths, timeoutMs: number, warmOnly: boolean): Promise<void> {\n1185:   const initialProbe = await bridge.probeDaemon(socketPath, { timeoutMs: Math.min(timeoutMs, 5000), deepProbe: true });\n1186:   if (initialProbe.status === 'alive') return;\n1187:   if (warmOnly) {\n1188:     throw new CliRetryableError(`backend unavailable: ${initialProbe.reason ?? initialProbe.status}`);\n1189:   }\n1190:   spawnLauncher(paths);\n1191:   await waitForDaemon(socketPath, bridge, timeoutMs);\n1192: }\n1193: \n1194: async function callTool(toolName: string, args: Record<string, unknown>, timeoutMs: number, trusted: boolean, warmOnly: boolean): Promise<unknown> {\n1195:   ensureSocketEnvironment();\n1196:   const paths = findRepoPaths();\n1197:   const bridge = loadBridge(paths);\n1198:   const socketPath = bridge.getIpcSocketPath('mk-skill-advisor', { dbDir: paths.dbDir });\n1199:   if (socketPathTooLong(socketPath)) {\n1200:     throw new CliProtocolError(`IPC socket path exceeds the Darwin sun_path limit: ${socketPath}`);\n1201:   }\n1202: \n1203:   await ensureDaemonReady(socketPath, bridge, paths, timeoutMs, warmOnly);\n1204: \n1205:   const client = await JsonRpcSocketClient.connect(socketPath, bridge, timeoutMs);\n1206:   try {\n1207:     const initialize = await client.request('initialize', {\n1208:       protocolVersion: JSON_RPC_PROTOCOL_VERSION,\n1209:       capabilities: {},\n1210:       clientInfo: { name: 'skill-advisor-cli', version: readCliVersion(paths) },\n1211:     }, timeoutMs) as InitializeResult;\n1212:     if (initialize.protocolVersion && initialize.protocolVersion !== JSON_RPC_PROTOCOL_VERSION) {\n1213:       throw new CliProtocolError(`backend protocol version changed: ${initialize.protocolVersion}`);\n1214:     }\n1215:     client.notify('notifications/initialized');\n1216:     return await client.request('tools/call', {\n1217:       name: toolName,\n1218:       arguments: args,\n1219:       _meta: callerMeta(trusted),\n1220:     }, timeoutMs);\n1221:   } finally {\n1222:     client.close();\n1223:   }\n1224: }\n1225: \n1226: async function invokeToolPayload(toolName: string, args: Record<string, unknown>, timeoutMs: number, trusted: boolean, warmOnly: boolean): Promise<ToolPayloadResult> {\n1227:   const result = await callTool(toolName, args, timeoutMs, trusted, warmOnly);\n1228:   return extractToolPayload(toolName, result);\n1229: }\n1230: \n1231: function generationFromPayload(payload: unknown): unknown {\n1232:   return getDataRecord(payload)?.generation ?? null;\n1233: }\n1234: \n1235: async function runSkillGraphScanJob(args: Record<string, unknown>, timeoutMs: number, trusted: boolean, warmOnly: boolean): Promise<ToolPayloadResult> {\n1236:   const workspaceRoot = findRepoPaths().repoRoot;\n1237:   const before = await invokeToolPayload('advisor_status', { workspaceRoot }, timeoutMs, false, warmOnly);\n1238:   const scan = await invokeToolPayload('skill_graph_scan', args, timeoutMs, trusted, warmOnly);\n1239:   const after = await invokeToolPayload('advisor_status', { workspaceRoot }, timeoutMs, false, warmOnly);\n1240:   const status = isRecord(scan.payload) && typeof scan.payload.status === 'string' ? scan.payload.status : 'ok';\n1241:   const scanData = getDataRecord(scan.payload) ?? scan.payload;\n1242: \n1243:   return {\n1244:     payload: {\n1245:       status,\n1246:       data: {\n1247:         progress: [\n1248:           { step: 'advisor_status_before', generation: generationFromPayload(before.payload), ok: !before.isError },\n1249:           { step: 'skill_graph_scan', ok: !scan.isError },\n1250:           { step: 'advisor_status_after', generation: generationFromPayload(after.payload), ok: !after.isError },\n1251:         ],\n1252:         generationBefore: generationFromPayload(before.payload),\n1253:         generationAfter: generationFromPayload(after.payload),\n1254:         scan: scanData,\n1255:       },\n1256:       ...(isRecord(scan.payload) && typeof scan.payload.error === 'string' ? { error: scan.payload.error } : {}),\n1257:     },\n1258:     isError: before.isError || scan.isError || after.isError,\n1259:   };\n1260: }\n1261: \n1262: export async function runSkillAdvisorCli(argv: string[], io: CliIo = { stdout: process.stdout, stderr: process.stderr }): Promise<number> {\n1263:   try {\n1264:     const parsed = parseCliArgs(argv);\n1265:     if (parsed.help) {\n1266:       await writeLine(io.stdout, usageText(parsed.command || undefined));\n1267:       return EXIT_SUCCESS;\n1268:     }\n1269:     if (parsed.version) {\n1270:       await writeLine(io.stdout, readCliVersion(findRepoPaths()));\n1271:       return EXIT_SUCCESS;\n1272:     }\n1273:     if (parsed.command === 'list-tools') {\n1274:       await writeLine(io.stdout, renderToolList(parsed.format, parsed.toolListMode));\n1275:       return EXIT_SUCCESS;\n1276:     }\n1277:     if (parsed.command === 'completion') {\n1278:       if (!parsed.completionShell) {\n1279:         throw new CliUsageError('completion requires a shell: bash or zsh');\n1280:       }\n1281:       await writeLine(io.stdout, renderCompletion(parsed.completionShell));\n1282:       return EXIT_SUCCESS;\n1283:     }\n1284: \n1285:     const validated = validateCommand(parsed);\n1286:     if (!validated) {\n1287:       throw new CliUsageError(`Unknown command: ${parsed.command}`);\n1288:     }\n1289: \n1290:     const invoked = validated.tool.name === 'skill_graph_scan'\n1291:       ? await runSkillGraphScanJob(validated.args, parsed.timeoutMs, parsed.trusted, parsed.warmOnly)\n1292:       : await invokeToolPayload(validated.tool.name, validated.args, parsed.timeoutMs, parsed.trusted, parsed.warmOnly);\n1293:     await writeLine(io.stdout, renderPayload(invoked.payload, parsed.format, validated.tool.name));\n1294:     return invoked.isError ? EXIT_RUNTIME : EXIT_SUCCESS;\n1295:   } catch (error: unknown) {\n1296:     const exitCode = exitCodeForError(error);\n1297:     const message = error instanceof Error ? error.message : String(error);\n1298:     const unknownCommand = unknownCommandContext(message);\n1299:     const payload = {\n1300:       status: 'error',\n1301:       error: message,\n1302:       exitCode,\n1303:       ...(unknownCommand ? { hint: unknownCommand.hint } : {}),\n1304:  