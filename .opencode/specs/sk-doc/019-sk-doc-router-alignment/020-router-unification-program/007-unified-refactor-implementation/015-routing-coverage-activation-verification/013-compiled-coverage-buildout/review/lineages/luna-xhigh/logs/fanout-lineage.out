ion/013-compiled-coverage-buildout/spec.md\",\n77:     \".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/013-compiled-coverage-buildout/plan.md\",\n78:     \".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/013-compiled-coverage-buildout/tasks.md\",\n79:     \".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/013-compiled-coverage-buildout/checklist.md\",\n80:     \".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/013-compiled-coverage-buildout/decision-record.md\",\n81:     \".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/013-compiled-coverage-buildout/implementation-summary.md\",\n82:     \".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/013-compiled-coverage-buildout/handover.md\"\n83:   ],\n84:   \"runtimeCapabilityResolver\": \".opencode/skills/system-deep-loop/deep-review/scripts/runtime-capabilities.cjs\",\n85:   \"reducerScriptPath\": \".opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs\",\n86:   \"fileProtection\": {\n87:     \"deep-review-config.json\": \"immutable\",\n88:     \"deep-review-state.jsonl\": \"append-only\",\n89:     \"deep-review-findings-registry.json\": \"auto-generated\",\n90:     \"deep-review-strategy.md\": \"mutable\",\n91:     \"deep-review-dashboard.md\": \"auto-generated\",\n92:     \".deep-review-pause\": \"operator-controlled\",\n93:     \"r