{
  "color": {
    "canvas-white": {
      "$value": "#ffffff",
      "$type": "color",
      "$description": "Canvas White — Page background, card surfaces, popover panels — the absolute base of every screen"
    },
    "paper-mist": {
      "$value": "#f5f5f5",
      "$type": "color",
      "$description": "Paper Mist — Subtle alt-surface for nested cards, secondary panels, and hover fills"
    },
    "ash": {
      "$value": "#e5e5e5",
      "$type": "color",
      "$description": "Ash — Hairline borders on cards, inputs, and dividers — the structural line that holds the system together"
    },
    "smoke": {
      "$value": "#d4d4d4",
      "$type": "color",
      "$description": "Smoke — Stronger borders for emphasis containers and secondary button outlines"
    },
    "pebble": {
      "$value": "#c8c8c8",
      "$type": "color",
      "$description": "Pebble — Medium-contrast borders, control outlines, and structural separators. Do not promote it to the primary CTA color"
    },
    "midnight-ink": {
      "$value": "#0a0a0a",
      "$type": "color",
      "$description": "Midnight Ink — Primary button text, high-emphasis buttons, nav text — near-black for maximum contrast"
    },
