   139	// P2 (014 review, regex DoS): fixture/profile-authored requiredPatterns and
   140	// forbiddenPatterns are compiled with `new RegExp(value, 'i')` and tested
   141	// against full model output. A crafted pattern with nested quantifiers can
   142	// trigger catastrophic backtracking. Bound the authored pattern length so a
   143	// single pattern cannot encode an exponential-backtracking construct over a
   144	// long input, and anchor matching cost by capping the tested input length.
   145	const MAX_PATTERN_LENGTH = 512;
   146	const MAX_MATCH_INPUT_LENGTH = 200000;
   147	
   148	function compilePatterns(patterns) {
   149	  return (patterns || []).map((value) => {
   150	    const source = String(value);
   151	    if (source.length > MAX_PATTERN_LENGTH) {
   152	      throw new Error(`run-benchmark: pattern exceeds ${MAX_PATTERN_LENGTH} chars (len=${source.length}); refusing to compile to avoid regex DoS`);
   153	    }
   154	    return new RegExp(source, 'i');
   155	  });
   156	}
   157	
   158	// Bound the input a regex is tested against so a pathological pattern that
   159	// slipped past the length guard still cannot run unbounded over huge output.
   160	function safeRegexTest(regex, content) {
   161	  const input = content.length > MAX_MATCH_INPUT_LENGTH
   162	    ? content.slice(0, MAX_MATCH_INPUT_LENGTH)
   163	    : content;
   164	  return regex.test(input);
   165	}
