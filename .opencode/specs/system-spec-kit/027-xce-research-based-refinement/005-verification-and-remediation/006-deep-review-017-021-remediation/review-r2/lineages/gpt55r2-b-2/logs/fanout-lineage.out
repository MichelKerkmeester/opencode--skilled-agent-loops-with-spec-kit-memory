s(normalized as SourceKind) ? normalized as SourceKind : null;\n41: }\n42: \n43: export function isManualSourceKind(value: unknown): boolean {\n44:   if (typeof value !== 'string') {\n45:     return false;\n46:   }\n47:   const normalized = value.trim().toLowerCase();\n48:   return normalized === 'manual' || normalizeSourceKind(normalized) === 'human';\n49: }\n50: \n51: function normalizeOptionalString(value: unknown): string | null {\n52:   if (typeof value !== 'string') {\n53:     return null;\n54:   }\n55:   const normalized = value.trim();\n56:   return normalized.length > 0 ? normalized : null;\n57: }\n58: \n59: function sourceKindFromLabel(value: unknown): SourceKind | null {\n60:   const normalized = normalizeOptionalString(value)?.toLowerCase();\n61:   if (!normalized) {\n62:     return null;\n63:   }\n64:   if (/\\b(human|manual|user|operator|author)\\b/.test(normalized)) {\n65:     return 'human';\n66:   }\n67:   if (normalized.includes('feedback') || normalized.includes('validate') || normalized.includes('validation')) {\n68:     return 'feedback';\n69:   }\n70:   if (normalized.includes('import') || normalized.includes('ingest') || normalized.includes('scan') || normalized.includes('index')) {\n71:     return 'import';\n72:   }\n73:   if (/\\b(agent|assistant|claude|codex|opencode|automation|bot)\\b/.test(normalized)) {\n74:     return 'agent';\n75:   }\n76:   if (/\\b(system|runtime|daemon|scheduler|hook|reconsolidation)\\b/.test(normalized)) {\n77:     return 'system';\n78:   }\n79:   return null;\n80: }\n81: \n82: export function deriveSourceKindFromContext(context: WriteProvenanceContext = {}): SourceKind {\n83:   const fromSource = sourceKindFromLabel(context.provenanceSource ?? context.provenance_source);\n84:   if (fromSource) {\n85:     return fromSource;\n86:   }\n87:   const fromActor = sourceKindFromLabel(context.provenanceActor ?? context.provenance_actor);\n88:   if (fromActor) {\n89:     return fromActor;\n90:   }\n91:   const fromTool = sourceKindFromLabel(context.tool);\n92:   if (fromTool) {\n93:     return fromTool;\n94:   }\n95:   const scope = context.scope ?? {};\n96:   const hasUser = normalizeScopeValue(scope.userId) !== null;\n97:   const hasAgent = normalizeScopeValue(scope.agentId) !== null;\n98:   if (hasAgent && !hasUser) {\n99:     return 'agent';\n100:   }\n101:   // No filePath heuristic: a human save whose path merely contains a word\n102:   // like \"index\" or \"scan\" must not be classified as an automated import,\n103:   // because that strips the manual-overwrite protection from the row. Real\n104:   // scan/ingest writes are classified by their tool label or explicit tags.\n105:   return 'human';\n106: }\n107: \n108: function getTableColumns(database: WriteProvenanceDatabase, tableName: string): Set<string> {\n109:   try {\n110:     return new Set(\n111:       (database.prepare(`PRAGMA table_info(${tableName})`).all() as Array<{ name: string }>)\n112:         .map((column) => column.name),\n113:     );\n114:   } catch {\n115:     return new Set();\n116:   }\n117: }\n118: \n119: function scrubOptional(value: string | null | undefined): string | null | undefined {\n120:   return value == null ? value : scrubSecrets(value);\n121: }\n122: \n123: export function buildPostInsertProvenanceFields(context: WriteProvenanceContext): {\n124:   provenance_source?: string;\n125:   provenance_actor?: string;\n126: } {\n127:   // Provenance labels are caller-supplied free text that lands in a persisted\n128:   // column, so they pass through the same fail-closed scrubber as content.\n129:   const provenanceSource = scrubOptional(normalizeOptionalString(context.provenanceSource ?? context.provenance_source));\n130:   const provenanceActor = scrubOptional(normalizeOptionalString(context.provenanceActor ?? context.provenance_actor));\n131:   return {\n132:     ...(provenanceSource ? { provenance_source: provenanceSource } : {}),\n133:     ...(provenanceActor ? { provenance_actor: provenanceActor } : {}),\n134:   };\n135: }\n136: \n137: export function persistSourceKind(\n138:   database: WriteProvenanceDatabase | null | undefined,\n139:   memoryId: number,\n140:   sourceKind: SourceKind,\n141: ): void {\n142:   if (!database || !getTableColumns(database, 'memory_index').has('source_kind')) {\n143:     return;\n144:   }\n145:   database.prepare('UPDATE memory_index SET source_kind = ? WHERE id = ?').run(sourceKind, memoryId);\n146: }\n147: \n148: export function persistProvenanceMetadata(\n149:   database: WriteProvenanceDatabase | null | undefined,\n150:   memoryId: number,\n151:   context: WriteProvenanceContext,\n152: ): void {\n153:   if (!database) {\n154:     return;\n155:   }\n156:   const fields = buildPostInsertProvenanceFields(context);\n157:   const columns = getTableColumns(database, 'memory_index');\n158:   const setClauses: string[] = [];\n159:   const values: string[] = [];\n160:   for (const [column, value] of Object.entries(fields)) {\n161:     if (!columns.has(column)) {\n162:       continue;\n163:     }\n164:     setClauses.push(`${column} = ?`);\n165:     values.push(value);\n166:   }\n167:   if (setClauses.length === 0) {\n168:     return;\n169:   }\n170:   database.prepare(`UPDATE memory_index SET ${setClauses.join(', ')} WHERE id = ?`).run(...values, memoryId);\n171: }\n172: \n173: export function applyWriteProvenance(\n174:   database: WriteProvenanceDatabase | null | undefined,\n175:   memoryId: number,\n176:   context: WriteProvenanceContext = {},\n177: ): SourceKind {\n178:   const sourceKind = deriveSourceKindFromContext(context);\n179:   persistSourceKind(database, memoryId, sourceKind);\n180:   persistProvenanceMetadata(database, memoryId, context);\n181:   return sourceKind;\n182: }\n\n(End of file - total 182 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Write Provenance\n// ───────────────────────────────────────────────────────────────\nimport { normalizeScopeValue } from '../governance/scope-governance.js';\nimport { scrubSecrets } from '../parsing/secret-scrubber.js';\n\nexport type SourceKind = 'human' | 'agent' | 'system' | 'import' | 'feedback';\n\nexport interface WriteProvenanceContext {\n  provenanceSource?: unknown;\n  provenanceActor?: unknown;\n  provenance_source?: unknown;\n  provenance_actor?: unknown;\n  tool?: unknown;\n  filePath?: unknown;\n  scope?: {\n    tenantId?: string | null;\n    userId?: string | null;\n    agentId?: string | null;\n    sessionId?: string | null;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/write-provenance.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Write Provenance\n// ───────────────────────────────────────────────────────────────\nimport { normalizeScopeValue } from '../governance/scope-governance.js';\nimport { scrubSecrets } from '../parsing/secret-scrubber.js';\n\nexport type SourceKind = 'human' | 'agent' | 'system' | 'import' | 'feedback';\n\nexport interface WriteProvenanceContext {\n  provenanceSource?: unknown;\n  provenanceActor?: unknown;\n  provenance_source?: unknown;\n  provenance_actor?: unknown;\n  tool?: unknown;\n  filePath?: unknown;\n  scope?: {\n    tenantId?: string | null;\n    userId?: string | null;\n    agentId?: string | null;\n    sessionId?: string | null;\n  };\n}\n\ntype WriteProvenanceStatement = {\n  all: (...params: any[]) => unknown[];\n  run: (...params: any[]) => unknown;\n};\n\nexport type WriteProvenanceDatabase = {\n  prepare: (sql: string) => WriteProvenanceStatement;\n};\n\nconst SOURCE_KINDS = new Set<SourceKind>(['human', 'agent', 'system', 'import', 'feedback']);\n\nexport function normalizeSourceKind(value: unknown): SourceKind | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim().toLowerCase();\n  return SOURCE_KINDS.has(normalized as SourceKind) ? normalized as SourceKind : null;\n}\n\nexport function isManualSourceKind(value: unknown): boolean {\n  if (typeof value !== 'string') {\n    return false;\n  }\n  const normalized = value.trim().toLowerCase();\n  return normalized === 'manual' || normalizeSourceKind(normalized) === 'human';\n}\n\nfunction normalizeOptionalString(value: unknown): string | null {\n  if (typeof value !== 'string') {\n    return null;\n  }\n  const normalized = value.trim();\n  return normalized.length > 0 ? normalized : null;\n}\n\nfunction sourceKindFromLabel(value: unknown): SourceKind | null {\n  const normalized = normalizeOptionalString(value)?.toLowerCase();\n  if (!normalized) {\n    return null;\n  }\n  if (/\\b(human|manual|user|operator|author)\\b/.test(normalized)) {\n    return 'human';\n  }\n  if (normalized.includes('feedback') || normalized.includes('validate') || normalized.includes('validation')) {\n    return 'feedback';\n  }\n  if (normalized.includes('import') || normalized.includes('ingest') || normalized.includes('scan') || normalized.includes('index')) {\n    return 'import';\n  }\n  if (/\\b(agent|assistant|claude|codex|opencode|automation|bot)\\b/.test(normalized)) {\n    return 'agent';\n  }\n  if (/\\b(system|runtime|daemon|scheduler|hook|reconsolidation)\\b/.test(normalized)) {\n    return 'system';\n  }\n  return null;\n}\n\nexport function deriveSourceKindFromContext(context: WriteProvenanceContext = {}): SourceKind {\n  const fromSource = sourceKindFromLabel(context.provenanceSource ?? context.provenance_source);\n  if (fromSource) {\n    return fromSource;\n  }\n  const fromActor = sourceKindFromLabel(context.provenanceActor ?? context.provenance_actor);\n  if (fromActor) {\n    return fromActor;\n  }\n  const fromTool = sourceKindFromLabel(context.tool);\n  if (fromTool) {\n    return fromTool;\n  }\n  const scope = context.scope ?? {};\n  const hasUser = normalizeScopeValue(scope.userId) !== null;\n  const hasAgent = normalizeScopeValue(scope.agentId) !== null;\n  if (hasAgent && !hasUser) {\n    return 'agent';\n  }\n  // No filePath heuristic: a human save whose path merely contains a word\n  // like \"index\" or \"scan\" must not be classified as an automated import,\n  // because that strips the manual-overwrite protection from the row. Real\n  // scan/ingest writes are classified by their tool label or explicit tags.\n  return 'human';\n}\n\nfunction getTableColumns(database: WriteProvenanceDatabase, tableName: string): Set<string> {\n  try {\n    return new Set(\n      (database.prepare(`PRAGMA table_info(${tableName})`).all() as Array<{ name: string }>)\n        .map((column) => column.name),\n    );\n  } catch {\n    return new Set();\n  }\n}\n\nfunction scrubOptional(value: string | null | undefined): string | null | undefined {\n  return value == null ? value : scrubSecrets(value);\n}\n\nexport function buildPostInsertProvenanceFields(context: WriteProvenanceContext): {\n  provenance_source?: string;\n  provenance_actor?: string;\n} {\n  // Provenance labels are caller-supplied free text that lands in a persisted\n  // column, so they pass through the same fail-closed scrubber as content.\n  const provenanceSource = scrubOptional(normalizeOptionalString(context.provenanceSource ?? context.provenance_source));\n  const provenanceActor = scrubOptional(normalizeOptionalString(context.provenanceActor ?? context.provenance_actor));\n  return {\n    ...(provenanceSource ? { provenance_source: provenanceSource } : {}),\n    ...(provenanceActor ? { provenance_actor: provenanceActor } : {}),\n  };\n}\n\nexport function persistSourceKind(\n  database: WriteProvenanceDatabase | null | undefined,\n  memoryId: number,\n  sourceKind: SourceKind,\n): void {\n  if (!database || !getTableColumns(database, 'memory_index').has('source_kind')) {\n    return;\n  }\n  database.prepare('UPDATE memory_index SET source_kind = ? WHERE id = ?').run(sourceKind, memoryId);\n}\n\nexport function persistProvenanceMetadata(\n  database: WriteProvenanceDatabase | null | undefined,\n  memoryId: number,\n  context: WriteProvenanceContext,\n): void {\n  if (!database) {\n    return;\n  }\n  const fields = buildPostInsertProvenanceFields(context);\n  const columns = getTableColumns(database, 'memory_index');\n  const setClauses: string[] = [];\n  const values: string[] = [];\n  for (const [column, value] of Object.entries(fields)) {\n    if (!columns.has(column)) {\n      continue;\n    }\n    setClauses.push(`${column} = ?`);\n    values.push(value);\n  }\n  if (setClauses.length === 0) {\n    return;\n  }\n  database.prepare(`UPDATE memory_index SET ${setClauses.join(', ')} WHERE id = ?`).run(...values, memoryId);\n}\n\nexport function applyWriteProvenance(\n  database: WriteProvenanceDatabase | null | undefined,\n  memoryId: number,\n  context: WriteProvenanceContext = {},\n): SourceKind {\n  const sourceKind = deriveSourceKindFromContext(context);\n  persistSourceKind(database, memoryId, sourceKind);\n  persistProvenanceMetadata(database, memoryId, context);\n  return sourceKind;\n}","lineStart":1,"lineEnd":182,"totalLines":182,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/write-provenance.ts","time":{"start":1781761500805,"end":1781761500808}},"metadata":{"openai":{"itemId":"fc_0972a96b15dcd547016a3385dc863481919b1bc62b2b1ee6dc"}},"id":"prt_ed942e684001dnrH9996Gfwn3x","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed942bc09001oe5fdEnB0WEeBW"}}
