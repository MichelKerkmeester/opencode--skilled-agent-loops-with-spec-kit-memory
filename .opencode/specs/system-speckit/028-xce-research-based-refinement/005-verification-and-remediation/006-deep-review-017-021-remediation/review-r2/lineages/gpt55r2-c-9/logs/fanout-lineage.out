te for individual deletions.`);\n\n  Line 134:       tool: 'memory_bulk_delete',\n\n  Line 135:       error: 'Memory bulk delete aborted: database unavailable',\n\n  Line 169:       tool: 'memory_bulk_delete',\n\n  Line 171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n\n  Line 180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n  Line 187:           reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n\n  Line 197:           throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n\n  Line 199:         console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n\n  Line 202:         console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n\n  Line 206:       console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n\n  Line 215:     console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n\n  Line 240:   let deletedCount = 0;\n\n  Line 241:   const deletedIds: number[] = [];\n\n  Line 248:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n\n  Line 255:             'mcp:memory_bulk_delete',\n\n  Line 259:           // History recording is best-effort inside bulk delete\n\n  Line 261:         deletedCount++;\n\n  Line 262:         deletedIds.push(memory.id);\n\n  Line 267:         // When memory rows were successfully deleted but edge cleanup failed.\n\n  Line 268:         causalEdges.deleteEdgesForMemory(String(memory.id), {\n\n  Line 270:           command: 'memory-bulk-delete.handleMemoryBulkDelete',\n\n  Line 271:           restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n\n  Line 281:     mutationType: 'delete',\n\n  Line 282:     reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n\n  Line 284:     newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n\n  Line 285:     linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n\n  Line 287:       tool: 'memory_bulk_delete',\n\n  Line 291:       totalDeleted: deletedCount,\n\n  Line 295:     actor: 'mcp:memory_bulk_delete',\n\n  Line 300:   if (deletedCount > 0) {\n\n  Line 303:       postMutationHooks = runPostMutationHooks('bulk-delete', {\n\n  Line 306:         deletedCount,\n\n  Line 307:         statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n\n  Line 310:           sourceOperation: 'bulk-delete',\n\n  Line 323:     postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n\n  Line 326:   const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n\n  Line 330:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n\n  Line 332:     hints.push('Checkpoint skipped: restore is not available for this operation');\n\n  Line 343:     deleted: deletedCount,\n\n  Line 351:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n\n  Line 361:     tool: 'memory_bulk_delete',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts:\n  Line 743:       delete data[key];\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/session-bootstrap.ts:\n  Line 308:   const restorePanel = memoryResume?.restorePanel as { markdown?: unknown; restoredCount?: unknown; omittedCount?: unknown } | undefined;\n\n  Line 309:   if (typeof restorePanel?.markdown === 'string') {\n\n  Line 310:     allHints.push(`Startup restore panel restored ${String(restorePanel.restoredCount ?? 0)} item(s) and omitted ${String(restorePanel.omittedCount ?? 0)} item(s).`);\n\n  Line 358:   if (typeof restorePanel?.markdown === 'string') {\n\n  Line 360:       key: 'startup-restore-panel',\n\n  Line 362:       content: restorePanel.markdown,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud.ts:\n  Line 5: import { handleMemoryDelete } from './memory-crud-delete.js';\n\n  Line 29: const handle_memory_delete = handleMemoryDelete;\n\n  Line 36:   handle_memory_delete,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts:\n  Line 69:   const action = operation.includes('delete') || operation.includes('unlink') ? 'delete' : 'upsert';\n\n  Line 111:       mutation_type: operation.includes('delete') ? 'delete' : 'update',\n\n  Line 156:   // (e.g. memory deletes cascade causal-edge deletes that arrive as\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/handler-utils.ts:\n  Line 20: // Feature catalog: Single and folder delete (memory_delete)\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts:\n  Line 118:    * dry run (no writes); pass { dryRun: false } to commit bounded auto edges.\n\n  Line 121:     dryRun?: boolean;\n\n  Line 972:           dryRun: backfillRequest.dryRun !== false,\n\n  Line 1030:         : 'Top N unlinked records unavailable; run memory_health({ autoRepair: true, confirmed: true }) to backfill.';\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"confirm|confirmed|dryRun|delete|restore|clearExisting|mode === 'apply'|mode !== 'dry-run'","time":{"start":1781764020752,"end":1781764020774}},"metadata":{"openai":{"itemId":"fc_0f62038bf7812bee016a338fb190d481919588f98bff797888"}