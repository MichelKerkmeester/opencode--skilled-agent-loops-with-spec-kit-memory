testing/GEMINI.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/.gemini/extensions/prototyping-testing/gemini-extension.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/ux-strategy/skills/business-design/SKILL.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/design-ops/skills/design-sprint-plan/SKILL.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/ui-design/skills/law-of-proximity/SKILL.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/prototyping-testing/skills/accessibility-test-plan/SKILL.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/.gemini/extensions/design-systems/GEMINI.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/.gemini/extensions/design-systems/gemini-extension.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/visual-critique/skills/critique-brand-consistency/SKILL.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/154-sk-design-parent/external/designer-skills-main/ux-strategy/skills/competitive-analysis/SKILL.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Pu