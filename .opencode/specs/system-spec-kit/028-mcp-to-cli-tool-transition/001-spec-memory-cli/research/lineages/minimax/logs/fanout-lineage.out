grate-deep-research-paths.ts\nnode_modules\nobservability\nops\noptimizer\npackage.json\nregistry-loader.sh\nrenderers\nresource-map\nrules\nscripts-registry.json\nseed-council-value-fixture.cjs\nsetup\nspec\nspec-folder\ntemplates\ntest-council-matrix.sh\ntest-fixtures\ntests\ntsconfig.json\ntypes\nutils\nvalidation\n","exit":0,"description":"List all memory CLI scripts and other scripts","truncated":false},"title":"List all memory CLI scripts and other scripts","time":{"start":1780736204053,"end":1780736204055}},"id":"prt_e9c261639001j3IfVX0uIUM2CR","sessionID":"ses_163de1863ffeLd3K58IkmWaFwL","messageID":"msg_e9c25f75d001KeMHFzyOOzjjls"}}
