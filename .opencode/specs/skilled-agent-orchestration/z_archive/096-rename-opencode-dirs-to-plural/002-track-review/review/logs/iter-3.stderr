   725	          on_failure:
   726	            action: "emit schema_mismatch canonical conflict event"
   727	            escalation: "After 3 consecutive failures, trigger stuck_recovery event with diagnostic context"
   728	          failure_reasons_reference:
   729	            - "iteration_file_missing — iteration narrative markdown not written"
   730	            - "iteration_file_empty — iteration narrative markdown is zero bytes"
   731	            - "jsonl_not_appended — state log file did not grow since pre-dispatch snapshot"
   732	            - "jsonl_missing_fields — last state-log record omits required schema fields"
   733	            - "jsonl_parse_error — last state-log line is not valid JSON"
   734	            - "jsonl_wrong_type — last state-log record uses type!='iteration' (e.g. 'iteration_delta'); reducer will silently drop"
   735	            - "delta_file_missing — per-iteration deltas/iter-NNN.jsonl not written"
   736	            - "delta_file_empty — per-iteration delta file exists but has zero bytes"
   737	            - "delta_file_missing_iteration_record — delta file lacks any record with type='iteration'"
   738	            - "executor_missing — non-native executor did not record provenance"
   739	            - "dispatch_failure_logged — last record is an explicit dispatch_failure event"
   740	
   741	      step_reduce_state:
