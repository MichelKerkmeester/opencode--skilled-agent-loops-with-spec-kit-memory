{"type":"text","timestamp":1781764258667,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"id":"prt_ed96ce3a6001Q5yyjGojBChYK8","messageID":"msg_ed96cc029001sLIhXPsAafhA8L","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","type":"text","text":"One plausible risk is the soft-delete tombstone path: it updates `memory_index.deleted_at` directly instead of calling the normal vector/FTS delete path. IвҖҷm checking query filters and mutation behavior before recording it as a finding.","time":{"start":1781764252582,"end":1781764258665},"metadata":{"openai":{"itemId":"msg_03f5d3efadbd529a016a33909c8ec08191b4a7f8f21604187a","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781764258716,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_rhdwZepu8UqZeihozYrrhWoZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Vector Index Mutations\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts вҖ” contains ALL mutation functions:\n6: // Index, update, delete, and status/confidence updates.\n7: \n8: import * as embeddingsProvider from '../providers/embeddings.js';\n9: import {\n10:   buildGovernanceLogicalKey,\n11:   normalizeScopeValue,\n12:   recordTierDowngradeAudit,\n13: } from '../governance/scope-governance.js';\n14: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n15: import { recordHistory } from '../storage/history.js';\n16: import { buildMemoryLogicalKey } from '../storage/lineage-state.js';\n17: import { getCanonicalPathKey } from '../utils/canonical-path.js';\n18: import { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n19: import { createLogger } from '../utils/logger.js';\n20: import { deleteByContentHash } from '../cache/embedding-cache.js';\n21: import { clearDegreeCacheForDb } from './graph-search-fn.js';\n22: import { sweepCausalEdges } from '../causal/sweep.js';\n23: import { bumpCausalEdgesGeneration } from '../storage/causal-generation.js';\n24: import * as bm25Index from './bm25-index.js';\n25: import {\n26:   clear_search_cache,\n27: } from './vector-index-aliases.js';\n28: import { invalidateEntityDensityCache } from './entity-density.js';\n29: import {\n30:   get_error_message,\n31:   to_embedding_buffer,\n32:   VectorIndexError,\n33:   VectorIndexErrorCode,\n34: } from './vector-index-types.js';\n35: import {\n36:   clear_constitutional_cache,\n37:   get_embedding_dim,\n38:   initialize_db,\n39:   init_prepared_statements,\n40:   refresh_interference_scores_for_folder,\n41:   sqlite_vec_available as get_sqlite_vec_available,\n42:   activeVectorSource,\n43: } from './vector-index-store.js';\n44: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder, vecTableNameForDim } from '../embedders/schema.js';\n45: import type {\n46:   IndexMemoryParams as SharedIndexMemoryParams,\n47:   MemoryScopeParams,\n48:   UpdateMemoryParams as SharedUpdateMemoryParams,\n49: } from './vector-index-types.js';\n50: import type Database from 'better-sqlite3';\n51: \n52: const logger = createLogger('VectorIndex');\n53: \n54: function isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n55:   const message = get_error_message(error).toLowerCase();\n56:   return message.includes('no such table') && message.includes('vec_memories');\n57: }\n58: \n59: function activeVectorTableExists(database: Database.Database, tableName: string): boolean {\n60:   try {\n61:     const row = database.prepare(`\n62:       SELECT 1 AS found\n63:       FROM ${activeVectorSource('sqlite_master')}\n64:       WHERE type = 'table' AND name = ?\n65:       LIMIT 1\n66:     `).get(tableName) as { found?: number } | undefined;\n67:     return row?.found === 1;\n68:   } catch (_error: unknown) {\n69:     return false;\n70:   }\n71: }\n72: \n73: function activeDimVectorSource(database: Database.Database): string | null {\n74:   const active = getActiveEmbedder(database);\n75:   if (active.name === DEFAULT_ACTIVE_EMBEDDER.name) {\n76:     return null;\n77:   }\n78:   const tableName = vecTableNameForDim(active.dim);\n79:   return activeVectorTableExists(database, tableName) ? activeVectorSource(tableName) : null;\n80: }\n81: \n82: function writeActiveVectorPayload(database: Database.Database, id: bigint, embeddingBuffer: Buffer): void {\n83:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n84:   database.prepare(`\n85:     INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)\n86:   `).run(id, embeddingBuffer);\n87: \n88:   const dimSource = activeDimVectorSource(database);\n89:   if (dimSource) {\n90:     database.prepare(`INSERT OR REPLACE INTO ${dimSource} (id, vec) VALUES (?, ?)`).run(id, embeddingBuffer);\n91:   }\n92: }\n93: \n94: function deleteActiveVectorPayload(database: Database.Database, id: bigint): void {\n95:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n96:   const dimSource = activeDimVectorSource(database);\n97:   if (dimSource) {\n98:     database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n99:   }\n100: }\n101: \n102: function invalidateGraphCaches(database: Database.Database): void {\n103:   // Bump the generation FIRST so every cache key that includes it (e.g.\n104:   // memory_search with causal boost) goes stale before the per-db caches clear;\n105:   // without this, memory-delete sweeps served stale causal-boosted search results.\n106:   bumpCausalEdgesGeneration();\n107: \n108:   try {\n109:     clearDegreeCacheForDb(database);\n110:   } catch (_error: unknown) {\n111:     // Degree cache invalidation is best-effort for legacy mutation paths.\n112:   }\n113: \n114:   try {\n115:     clearGraphSignalsCache();\n116:   } catch (_error: unknown) {\n117:     // Graph signal cache invalidation is best-effort for legacy mutation paths.\n118:   }\n119: }\n120: \n121: function tryRecordTierDowngradeAudit(\n122:   database: Database.Database,\n123:   params: {\n124:     memoryId: number;\n125:     specFolder: string | null | undefined;\n126:     anchorId: string | null | undefined;\n127:     filePath: string | null | undefined;\n128:     canonicalFilePath: string | null | undefined;\n129:     requestedTier?: string | null | undefined;\n130:     previousTier?: string | null | undefined;\n131:     nextTier: string;\n132:     source: string;\n133:   },\n134: ): void {\n135:   try {\n136:     recordTierDowngradeAudit(database, {\n137:       memoryId: params.memoryId,\n138:       logicalKey: buildGovernanceLogicalKey(\n139:         params.specFolder,\n140:         params.canonicalFilePath || params.filePath,\n141:         params.anchorId,\n142:       ),\n143:       requestedTier: params.requestedTier ?? undefined,\n144:       previousTier: params.previousTier ?? undefined,\n145:       nextTier: params.nextTier,\n146:       source: params.source,\n147:       filePath: params.filePath ?? null,\n148:       canonicalFilePath: params.canonicalFilePath ?? null,\n149:     });\n150:   } catch (error: unknown) {\n151:     logger.warn('Failed to record governance audit for tier downgrade', {\n152:       memoryId: params.memoryId,\n153:       source: params.source,\n154:       message: get_error_message(error),\n155:     });\n156:   }\n157: }\n158: \n159: function deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n160:   const ancillaryTables = [\n161:     'DELETE FROM degree_snapshots WHERE memory_id = ?',\n162:     'DELETE FROM community_assignments WHERE memory_id = ?',\n163:     'DELETE FROM memory_summaries WHERE memory_id = ?',\n164:     'DELETE FROM memory_entities WHERE memory_id = ?',\n165:     'DELETE FROM memory_lineage WHERE memory_id = ?',\n166:   ];\n167: \n168:   for (const sql of ancillaryTables) {\n169:     try {\n170:       const paramCount = (sql.match(/\\?/g) || []).length;\n171:       if (paramCount === 2) {\n172:         database.prepare(sql).run(id, id);\n173:       } else {\n174:         database.prepare(sql).run(id);\n175:       }\n176:     } catch (_error: unknown) {\n177:       // Best-effort for legacy databases that may not have these tables yet.\n178:     }\n179:   }\n180: \n181:   // Clean active_memory_projection rows referencing this memory.\n182:   try {\n183:     database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n184:   } catch (_error: unknown) {\n185:     // Best-effort for legacy databases that may not have projection tables yet.\n186:   }\n187: \n188:   try {\n189:     const result = sweepCausalEdges(database, {\n190:       memoryIds: [id, String(id)],\n191:       reason: 'memory row mutation cleanup',\n192:       command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n193:       restoreContext: { memoryId: id },\n194:       invalidateCaches: false,\n195:     });\n196:     if (result.deleted > 0) {\n197:       invalidateGraphCaches(database);\n198:     }\n199:   } catch (error: unknown) {\n200:     // Tolerate only legacy databases that predate the causal-edge tables. Scope\n201:     // the match to those table names so an unrelated missing-table error still\n202:     // propagates and rolls back the surrounding delete instead of committing a\n203:     // hard delete without its tombstone audit row.\n204:     const message = error instanceof Error ? error.message : String(error);\n205:     if (!/no such table:\\s*causal_edge/i.test(message)) {\n206:       throw error;\n207:     }\n208:   }\n209: }\n210: \n211: function upsert_active_projection(\n212:   database: ReturnType<typeof initialize_db>,\n213:   specFolder: string,\n214:   canonicalFilePath: string,\n215:   anchorId: string | null,\n216:   memoryId: number,\n217:   updatedAt: string,\n218:   scope: NormalizedMemoryScope,\n219: ): void {\n220:   const logicalKey = buildMemoryLogicalKey({\n221:     specFolder,\n222:     filePath: canonicalFilePath,\n223:     canonicalFilePath,\n224:     anchorId,\n225:     ...scope,\n226:   });\n227:   // Evict any stale projection row that maps a *different* logical_key to the\n228:   // same active_memory_id вҖ” prevents UNIQUE constraint violation on re-index\n229:   // when the logical_key changes (e.g. anchor or path normalization drift).\n230:   database.prepare(\n231:     'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n232:   ).run(memoryId, logicalKey);\n233:   database.prepare(`\n234:     INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n235:     VALUES (?, ?, ?, ?)\n236:     ON CONFLICT(logical_key) DO UPDATE SET\n237:       root_memory_id = excluded.root_memory_id,\n238:       active_memory_id = excluded.active_memory_id,\n239:       updated_at = excluded.updated_at\n240:   `).run(logicalKey, memoryId, memoryId, updatedAt);\n241: }\n242: \n243: // These mutation-local extensions are intentional until the shared query/store\n244: // contract adopts appendOnly and canonicalFilePath semantics.\n245: type IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n246:   readonly appendOnly?: boolean;\n247: };\n248: type IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n249:   readonly failureReason?: string | null;\n250: };\n251: type UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n252:   readonly canonicalFilePath?: string;\n253:   // Set when the row's document now lives at a new on-disk location, so a\n254:   // moved file repoints its existing row instead of leaving a stale path.\n255:   readonly filePath?: string;\n256: };\n257: \n258: type NormalizedMemoryScope = {\n259:   tenant_id: string | null;\n260:   user_id: string | null;\n261:   agent_id: string | null;\n262:   session_id: string | null;\n263: };\n264: \n265: function normalizeMemoryScope(scope?: MemoryScopeParams): NormalizedMemoryScope {\n266:   return {\n267:     tenant_id: normalizeScopeValue(scope?.tenantId),\n268:     user_id: normalizeScopeValue(scope?.userId),\n269:     agent_id: normalizeScopeValue(scope?.agentId),\n270:     session_id: normalizeScopeValue(scope?.sessionId),\n271:   };\n272: }\n273: \n274: /**\n275:  * Indexes a memory with an embedding payload.\n276:  * @param params - The memory values to index.\n277:  * @returns The indexed memory identifier.\n278:  * @throws {VectorIndexError} When embedding validation fails or the mutation cannot be applied.\n279:  * @example\n280:  * ```ts\n281:  * const id = index_memory({\n282:  *   specFolder: 'specs/001-demo',\n283:  *   filePath: 'spec.md',\n284:  *   embedding,\n285:  * });\n286:  * ```\n287:  */\n288: export function index_memory(\n289:   params: IndexMemoryParams,\n290:   database: Database.Database = initialize_db(),\n291: ): number {\n292:   const {\n293:     specFolder,\n294:     filePath,\n295:     parentId = null,\n296:     anchorId = null,\n297:     title = null,\n298:     triggerPhrases = [],\n299:     importanceWeight = 0.5,\n300:     embedding,\n301:     encodingIntent,\n302:     documentType = 'memory',\n303:     specLevel = null,\n304:     contentText = null,\n305:     qualityScore = 0,\n306:     qualityFlags = [],\n307:     appendOnly = false,\n308:   } = params;\n309:   const scope = normalizeMemoryScope(params.scope);\n310: \n311:   if (!embedding) {\n312:     throw new VectorIndexError('Embedding is required', VectorIndexErrorCode.EMBEDDING_VALIDATION);\n313:   }\n314: \n315:   const expected_dim = get_embedding_dim();\n316:   if (embedding.length !== expected_dim) {\n317:     console.warn(`[vector-index] Embedding dimension mismatch: expected ${expected_dim}, got ${embedding.length}`);\n318:     throw new VectorIndexError(\n319:       `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n320:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n321:     );\n322:   }\n323: \n324:   const now = new Date().toISOString();\n325:   const triggers_json = JSON.stringify(triggerPhrases);\n326:   const embedding_buffer = to_embedding_buffer(embedding);\n327:   const canonicalFilePath = getCanonicalPathKey(filePath);\n328: \n329:   const stmts = init_prepared_statements(database);\n330:   const existing = appendOnly\n331:     ? null\n332:     : stmts.get_by_folder_and_path.get(\n333:         specFolder,\n334:         canonicalFilePath,\n335:         filePath,\n336:         canonicalFilePath,\n337:         filePath,\n338:         anchorId,\n339:         scope.tenant_id,\n340:         scope.user_id,\n341:         scope.agent_id,\n342:         scope.session_id,\n343:       );\n344: \n345:   if (existing && !appendOnly) {\n346:     return update_memory({\n347:       id: existing.id,\n348:       title: title ?? undefined,\n349:       triggerPhrases,\n350:       importanceWeight,\n351:       embedding,\n352:       encodingIntent,\n353:       documentType,\n354:       specLevel,\n355:       contentText,\n356:       qualityScore,\n357:       qualityFlags,\n358:       canonicalFilePath,\n359:       filePath,\n360:     }, database);\n361:   }\n362: \n363:   const sqlite_vec = get_sqlite_vec_available();\n364: \n365:   const index_memory_tx = database.transaction(() => {\n366:     const embedding_status = sqlite_vec ? 'success' : 'pending';\n367: \n368:     const result = database.prepare(`\n369:       INSERT INTO memory_index (\n370:         spec_folder, file_path, canonical_file_path, anchor_id, title, trigger_phrases,\n371:         importance_weight, created_at, updated_at, embedding_model,\n372:         embedding_generated_at, embedding_status, encoding_intent, document_type, spec_level,\n373:         content_text, quality_score, quality_flags, parent_id,\n374:         tenant_id, user_id, agent_id, session_id\n375:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n376:     `).run(\n377:       specFolder, filePath, canonicalFilePath, anchorId, title, triggers_json,\n378:       importanceWeight, now, now, embeddingsProvider.getModelName(), now, embedding_status,\n379:       encodingIntent ?? 'document', documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), parentId,\n380:       scope.tenant_id, scope.user_id, scope.agent_id, scope.session_id\n381:     );\n382: \n383:     const row_id = BigInt(result.lastInsertRowid);\n384:     const metadata_id = Number(row_id);\n385: \n386:     upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, metadata_id, now, scope);\n387: \n388:     if (sqlite_vec) {\n389:       writeActiveVectorPayload(database, row_id, embedding_buffer);\n390:     }\n391: \n392:     refresh_interference_scores_for_folder(database, specFolder);\n393:     clear_search_cache();\n394: \n395:     return metadata_id;\n396:   });\n397: \n398:   return index_memory_tx();\n399: }\n400: \n401: // Deferred indexing - entry searchable via BM25/FTS5 only\n402: /**\n403:  * Indexes a memory record without storing an embedding yet.\n404:  * @param params - The deferred memory values to index.\n405:  * @returns The indexed memory identifier.\n406:  */\n407: export function index_memory_deferred(\n408:   params: IndexMemoryDeferredParams,\n409:   database: Database.Database = initialize_db(),\n410: ): number {\n411:   const {\n412:     specFolder,\n413:     filePath,\n414:     parentId = null,\n415:     anchorId = null,\n416:     title = null,\n417:     triggerPhrases = [],\n418:     importanceWeight = 0.5,\n419:     failureReason = null,\n420:     encodingIntent,\n421:     documentType = 'memory',\n422:     specLevel = null,\n423:     contentText = null,\n424:     qualityScore = 0,\n425:     qualityFlags = [],\n426:     appendOnly = false,\n427:   } = params;\n428:   const scope = normalizeMemoryScope(params.scope);\n429: \n430:   const now = new Date().toISOString();\n431:   const triggers_json = JSON.stringify(triggerPhrases);\n432:   const canonicalFilePath = getCanonicalPathKey(filePath);\n433: \n434:   const stmts = init_prepared_statements(database);\n435:   const existing = appendOnly\n436:     ? null\n437:     : stmts.get_by_folder_and_path.get(\n438:         specFolder,\n439:         canonicalFilePath,\n440:         filePath,\n441:         canonicalFilePath,\n442:         filePath,\n443:         anchorId,\n444:         scope.tenant_id,\n445:         scope.user_id,\n446:         scope.agent_id,\n447:         scope.session_id,\n448:       );\n449: \n450:   const index_memory_deferred_tx = database.transaction(() => {\n451:     if (existing && !appendOnly) {\n452:       database.prepare(`\n453:         UPDATE memory_index\n454:         SET title = ?,\n455:             trigger_phrases = ?,\n456:             importance_weight = ?,\n457:             file_path = ?,\n458:             canonical_file_path = ?,\n459:             embedding_status = 'pending',\n460:             failure_reason = ?,\n461:             updated_at = ?,\n462:             encoding_intent = COALESCE(?, encoding_intent),\n463:             document_type = ?,\n464:             spec_level = ?,\n465:             content_text = ?,\n466:             quality_score = ?,\n467:             quality_flags = ?,\n468:             retry_count = 0,\n469:             last_retry_at = NULL\n470:         WHERE id = ?\n471:       `).run(title, triggers_json, importanceWeight, filePath, canonicalFilePath, failureReason, now, encodingIntent, documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), existing.id);\n472:       upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, existing.id, now, scope);\n473:       refresh_interference_scores_for_folder(database, specFolder);\n474:       return existing.id;\n475:     }\n476: \n477:     const result = database.prepare(`\n478:       INSERT INTO memory_index (\n479:         spec_folder, file_path, canonical_file_path, anchor_id, title, trigger_phrases,\n480:         importance_weight, created_at, updated_at, embedding_status,\n481:         failure_reason, retry_count, encoding_intent, document_type, spec_level,\n482:         content_text, quality_score, quality_flags, parent_id,\n483:         tenant_id, user_id, agent_id, session_id\n484:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?, 0, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n485:     `).run(\n486:       specFolder, filePath, canonicalFilePath, anchorId, title, triggers_json,\n487:       importanceWeight, now, now, failureReason, encodingIntent ?? 'document', documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), parentId,\n488:       scope.tenant_id, scope.user_id, scope.agent_id, scope.session_id\n489:     );\n490: \n491:     const row_id = BigInt(result.lastInsertRowid);\n492:     upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, Number(row_id), now, scope);\n493:     refresh_interference_scores_for_folder(database, specFolder);\n494:     logger.info(`Deferred indexing: Memory ${Number(row_id)} saved without embedding (BM25/FTS5 searchable)`);\n495: \n496:     return Number(row_id);\n497:   });\n498: \n499:   return index_memory_deferred_tx();\n500: }\n501: \n502: /**\n503:  * Updates stored memory metadata and embeddings.\n504:  * @param params - The memory values to update.\n505:  * @returns The updated memory identifier.\n506:  * @throws {VectorIndexError} When embedding validation fails or the mutation transaction cannot complete.\n507:  * @example\n508:  * ```ts\n509:  * const id = update_memory({ id: 42, title: 'Updated title', embedding });\n510:  * ```\n511:  */\n512: export function update_memory(\n513:   params: UpdateMemoryParams,\n514:   database: Database.Database = initialize_db(),\n515: ): number {\n516:   const {\n517:     id,\n518:     title,\n519:     triggerPhrases,\n520:     importanceWeight,\n521:     importanceTier,\n522:     embedding,\n523:     canonicalFilePath,\n524:     filePath,\n525:     encodingIntent,\n526:     documentType,\n527:     specLevel,\n528:     contentText,\n529:     qualityScore,\n530:     qualityFlags,\n531:   } = params;\n532: \n533:   const now = new Date().toISOString();\n534: \n535:   const update_memory_tx = database.transaction(() => {\n536:     const existingRow = database.prepare(`\n537:       SELECT spec_folder, anchor_id, canonical_file_path, file_path, importance_tier,\n538:              tenant_id, user_id, agent_id, session_id\n539:       FROM memory_index\n540:       WHERE id = ?\n541:     `).get(id) as {\n542:       spec_folder: string | null;\n543:       anchor_id: string | null;\n544:       canonical_file_path: string | null;\n545:       file_path: string | null;\n546:       importance_tier: string | null;\n547:       tenant_id: string | null;\n548:       user_id: string | null;\n549:       agent_id: string | null;\n550:       session_id: string | null;\n551:     } | undefined;\n552:     const updates = ['updated_at = ?'];\n553:     const values: unknown[] = [now];\n554: \n555:     if (title !== undefined) {\n556:       updates.push('title = ?');\n557:       values.push(title);\n558:     }\n559:     if (triggerPhrases !== undefined) {\n560:       updates.push('trigger_phrases = ?');\n561:       values.push(JSON.stringify(triggerPhrases));\n562:     }\n563:     if (importanceWeight !== undefined) {\n564:       updates.push('importance_weight = ?');\n565:       values.push(importanceWeight);\n566:     }\n567:     if (importanceTier !== undefined) {\n568:       let nextImportanceTier = importanceTier;\n569:       const previousTier = existingRow?.importance_tier ?? null;\n570:       if (\n571:         existingRow\n572:       ) {\n573:         const guardPath = existingRow.canonical_file_path || existingRow.file_path;\n574:         const hasNonConstitutionalPath = guardPath && !isIndexableConstitutionalMemoryPath(guardPath);\n575:         if (hasNonConstitutionalPath && importanceTier === 'constitutional') {\n576:           // Non-constitutional paths cannot be promoted to constitutional tier.\n577:           nextImportanceTier = 'important';\n578:         }\n579:         if (\n580:           hasNonConstitutionalPath\n581:           && (\n582:             importanceTier === 'constitutional'\n583:             || (previousTier === 'constitutional' && nextImportanceTier !== 'constitutional')\n584:           )\n585:         ) {\n586:           tryRecordTierDowngradeAudit(database, {\n587:             memoryId: id,\n588:             specFolder: existingRow.spec_folder,\n589:             anchorId: existingRow.anchor_id,\n590:             filePath: existingRow.file_path,\n591:             canonicalFilePath: existingRow.canonical_file_path,\n592:             requestedTier: importanceTier,\n593:             previousTier,\n594:             nextTier: nextImportanceTier,\n595:             source: 'update_memory',\n596:           });\n597:         }\n598:       }\n599:       updates.push('importance_tier = ?');\n600:       values.push(nextImportanceTier);\n601:       clear_constitutional_cache();\n602:     }\n603:     if (canonicalFilePath !== undefined) {\n604:       updates.push('canonical_file_path = ?');\n605:       values.push(canonicalFilePath);\n606:     }\n607:     if (filePath !== undefined) {\n608:       updates.push('file_path = ?');\n609:       values.push(filePath);\n610:     }\n611:     if (encodingIntent !== undefined) {\n612:       updates.push('encoding_intent = ?');\n613:       values.push(encodingIntent);\n614:     }\n615:     if (documentType !== undefined) {\n616:       updates.push('document_type = ?');\n617:       values.push(documentType);\n618:     }\n619:     if (specLevel !== undefined) {\n620:       updates.push('spec_level = ?');\n621:       values.push(specLevel);\n622:     }\n623:     if (contentText !== undefined) {\n624:       updates.push('content_text = ?');\n625:       values.push(contentText);\n626:     }\n627:     if (qualityScore !== undefined) {\n628:       updates.push('quality_score = ?');\n629:       values.push(qualityScore);\n630:     }\n631:     if (qualityFlags !== undefined) {\n632:       updates.push('quality_flags = ?');\n633:       values.push(JSON.stringify(qualityFlags));\n634:     }\n635:     if (embedding) {\n636:       updates.push('embedding_model = ?');\n637:       updates.push('embedding_generated_at = ?');\n638:       updates.push('embedding_status = ?');\n639:       values.push(embeddingsProvider.getModelName(), now, 'pending');\n640:     }\n641: \n642:     values.push(id);\n643: \n644:     const updateResult = database.prepare(`\n645:       UPDATE memory_index SET ${updates.join(', ')} WHERE id = ?\n646:     `).run(...values);\n647: \n648:     // Return early if the target row no longer exists.\n649:     if (updateResult.changes === 0) {\n650:       return id;\n651:     }\n652: \n653:     const sqlite_vec = get_sqlite_vec_available();\n654:     if (embedding && sqlite_vec) {\n655:       const expected_dim = get_embedding_dim();\n656:       if (embedding.length !== expected_dim) {\n657:         console.warn(`[vector-index] Embedding dimension mismatch in update: expected ${expected_dim}, got ${embedding.length}`);\n658:         throw new VectorIndexError(\n659:           `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n660:           VectorIndexErrorCode.EMBEDDING_VALIDATION,\n661:         );\n662:       }\n663: \n664:       const embedding_buffer = to_embedding_buffer(embedding);\n665:       writeActiveVectorPayload(database, BigInt(id), embedding_buffer);\n666:       database.prepare('UPDATE memory_index SET embedding_status = ? WHERE id = ?').run('success', id);\n667:     }\n668: \n669:     if (existingRow?.spec_folder) {\n670:       const projectionPath = canonicalFilePath\n671:         ?? existingRow.canonical_file_path\n672:         ?? getCanonicalPathKey(existingRow.file_path ?? '');\n673:       upsert_active_projection(database, existingRow.spec_folder, projectionPath, existingRow.anchor_id ?? null, id, now, {\n674:         tenant_id: existingRow.tenant_id,\n675:         user_id: existingRow.user_id,\n676:         agent_id: existingRow.agent_id,\n677:         session_id: existingRow.session_id,\n678:       });\n679:     }\n680: \n681:     if (existingRow?.spec_folder) {\n682:       refresh_interference_scores_for_folder(database, existingRow.spec_folder);\n683:     }\n684:     clear_search_cache();\n685: \n686:     return id;\n687:   });\n688: \n689:   return update_memory_tx();\n690: }\n691: \n692: /**\n693:  * Deletes a memory and its related index records.\n694:  * @param id - The memory identifier.\n695:  * @returns True when a memory was deleted.\n696:  * @throws {VectorIndexError} Propagates mutation or store initialization failures from the delete pipeline.\n697:  * @example\n698:  * ```ts\n699:  * const deleted = delete_memory(42);\n700:  * ```\n701:  */\n702: export function delete_memory(id: number, database: Database.Database = initialize_db()): boolean {\n703:   return delete_memory_from_database(database, id);\n704: }\n705: \n706: /**\n707:  * Deletes a memory and related index records using the provided database handle.\n708:  * @param database - The database containing the target memory.\n709:  * @param id - The memory identifier.\n710:  * @returns True when a memory was deleted.\n711:  * @throws {VectorIndexError} Propagates mutation failures encountered while deleting the memory.\n712:  * @example\n713:  * ```ts\n714:  * const deleted = delete_memory_from_database(database, 42);\n715:  * ```\n716:  */\n717: export function delete_memory_from_database(database: Database.Database, id: number): boolean {\n718:   const sqlite_vec = get_sqlite_vec_available();\n719: \n720:   const delete_memory_tx = database.transaction(() => {\n721:     // Memory_history rows are intentionally preserved after deletion\n722:     // So DELETE audit events recorded by handlers persist as audit trail.\n723:     const row = database.prepare('SELECT content_hash FROM memory_index WHERE id = ?').get(id) as\n724:       | { content_hash: string | null }\n725:       | undefined;\n726: \n727:     if (sqlite_vec) {\n728:       try {\n729:         deleteActiveVectorPayload(database, BigInt(id));\n730:       } catch (e: unknown) {\n731:         if (!isExpectedMissingVecMemoriesTable(e)) {\n732:           throw new VectorIndexError(\n733:             `Vector deletion failed for memory ${id}: ${get_error_message(e)}`,\n734:             VectorIndexErrorCode.MUTATION_FAILED,\n735:           );\n736:         }\n737:       }\n738:     }\n739: \n740:     // Clean ancillary records so deletes do not leave graph residue behind.\n741:     deleteAncillaryMemoryRows(database, id);\n742: \n743:     if (row?.content_hash) {\n744:       // Governed retention delete semantics include derived embedding-cache rows.\n745:       try {\n746:         deleteByContentHash(database, row.content_hash);\n747:       } catch (_error: unknown) {\n748:         // Legacy or test databases may not have embedding_cache yet.\n749:       }\n750:     }\n751: \n752:     const result = database.prepare('DELETE FROM memory_index WHERE id = ?').run(id);\n753: \n754:     clear_search_cache();\n755:     clear_constitutional_cache();\n756: \n757:     return result.changes > 0;\n758:   });\n759: \n760:   // Remove the BM25 document only after the source row is deleted.\n761:   const deleted = delete_memory_tx();\n762:   if (deleted) {\n763:     // Invalidate entity-density cache so deleted memory's tokens are not routed\n764:     // to the graph channel beyond the 60s TTL window. Best-effort: non-fatal.\n765:     try {\n766:       invalidateEntityDensityCache();\n767:     } catch (_error: unknown) {\n768:       // Cache invalidation is best-effort; do not mask a successful delete.\n769:     }\n770:   }\n771:   if (deleted) {\n772:     try {\n773:       if (bm25Index.isBm25Enabled()) {\n774:         bm25Index.getIndex().removeDocument(String(id));\n775:       }\n776:     } catch (_error: unknown) {\n777:       // BEST-EFFORT BM25 CLEANUP MUST NOT MASK A SUCCESSFUL PRIMARY DELETE.\n778:     }\n779:   }\n780:   return deleted;\n781: }\n782: \n783: /**\n784:  * Deletes the latest memory for a file path and optional anchor.\n785:  * @param spec_folder - The owning spec folder.\n786:  * @param file_path - The file path to delete.\n787:  * @param anchor_id - The optional anchor identifier.\n788:  * @returns True when a memory was deleted.\n789:  * @throws {VectorIndexError} Propagates delete failures from the underlying mutation helpers.\n790:  * @example\n791:  * ```ts\n792:  * const deleted = delete_memory_by_path('specs/001-demo', 'spec.md');\n793:  * ```\n794:  */\n795: export function delete_memory_by_path(\n796:   spec_folder: string,\n797:   file_path: string,\n798:   anchor_id: string | null = null,\n799:   database: Database.Database = initialize_db(),\n800: ): boolean {\n801:   const canonicalPath = getCanonicalPathKey(file_path);\n802: \n803:   const row = database.prepare(`\n804:     SELECT id, spec_folder FROM memory_index\n805:     WHERE spec_folder = ?\n806:       AND (canonical_file_path = ? OR file_path = ?)\n807:       AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))\n808:     ORDER BY id DESC\n809:     LIMIT 1\n810:   `).get(spec_folder, canonicalPath, file_path, anchor_id, anchor_id) as { id: number; spec_folder?: string | null } | undefined;\n811: \n812:   if (row) {\n813:     const deleted = delete_memory_from_database(database, row.id);\n814:     if (deleted) {\n815:       // Self-record DELETE history only after the delete succeeded.\n816:       try {\n817:         recordHistory(row.id, 'DELETE', file_path ?? null, null, 'mcp:delete_by_path', row.spec_folder ?? spec_folder);\n818:       } catch (_histErr: unknown) {\n819:         // BEST-EFFORT HISTORY WRITES MUST NOT MASK A SUCCESSFUL DELETE.\n820:       }\n821:     }\n822:     return deleted;\n823:   }\n824:   return false;\n825: }\n826: \n827: /**\n828:  * Deletes multiple memories in a single transaction.\n829:  * @param memory_ids - The memory identifiers to delete.\n830:  * @returns Counts for deleted and failed items.\n831:  * @throws {VectorIndexError} When one or more deletes fail and the transaction is rolled back.\n832:  * @example\n833:  * ```ts\n834:  * const outcome = delete_memories([1, 2, 3]);\n835:  * ```\n836:  */\n837: export function delete_memories(\n838:   memory_ids: number[],\n839:   database: Database.Database = initialize_db(),\n840: ): { deleted: number; failed: number } {\n841:   if (!memory_ids || memory_ids.length === 0) {\n842:     return { deleted: 0, failed: 0 };\n843:   }\n844:   const sqlite_vec = get_sqlite_vec_available();\n845:   let deleted = 0;\n846:   let failed = 0;\n847:   const deletedIds: number[] = [];\n848: \n849:   const specFolderById = new Map<number, string | null>();\n850:   for (const id of memory_ids) {\n851:     if (!Number.isInteger(id) || id <= 0) {\n852:       continue;\n853:     }\n854:     try {\n855:       const row = database.prepare('SELECT spec_folder FROM memory_index WHERE id = ?').get(id) as { spec_folder?: string | null } | undefined;\n856:       specFolderById.set(id, row?.spec_folder ?? null);\n857:     } catch (_error: unknown) {\n858:       specFolderById.set(id, null);\n859:     }\n860:   }\n861: \n862:   const delete_transaction = database.transaction(() => {\n863:     let transactionDeleted = 0;\n864:     let transactionFailed = 0;\n865:     const failed_ids: number[] = [];\n866: \n867:     for (const id of memory_ids) {\n868:       try {\n869:         if (sqlite_vec) {\n870:           try {\n871:             deleteActiveVectorPayload(database, BigInt(id));\n872:           } catch (vec_error: unknown) {\n873:             console.warn(`[VectorIndex] Failed to delete vector for memory ${id}: ${get_error_message(vec_error)}`);\n874:           }\n875:         }\n876: \n877:         deleteAncillaryMemoryRows(database, id);\n878:         const result = database.prepare('DELETE FROM memory_index WHERE id = ?').run(id);\n879:         if (result.changes > 0) {\n880:           // Memory_history rows are intentionally preserved after deletion\n881:           // So DELETE audit events recorded here persist as audit trail.\n882:           try {\n883:             recordHistory(id, 'DELETE', null, null, 'mcp:delete_memories', specFolderById.get(id) ?? null);\n884:           } catch (_histErr: unknown) {\n885:             // BEST-EFFORT HISTORY WRITES MUST NOT MASK A SUCCESSFUL DELETE.\n886:           }\n887:           transactionDeleted++;\n888:           deletedIds.push(id);\n889:         } else {\n890:           transactionFailed++;\n891:           failed_ids.push(id);\n892:         }\n893:       } catch (e: unknown) {\n894:         console.warn(`[vector-index] Failed to delete memory ${id}: ${get_error_message(e)}`);\n895:         transactionFailed++;\n896:         failed_ids.push(id);\n897:       }\n898:     }\n899: \n900:     if (failed_ids.length > 0) {\n901:       throw new VectorIndexError(\n902:         `Failed to delete memories: ${failed_ids.join(', ')}. Transaction rolled back.`,\n903:         VectorIndexErrorCode.MUTATION_FAILED,\n904:       );\n905:     }\n906: \n907:     return {\n908:       deleted: transactionDeleted,\n909:       failed: transactionFailed,\n910:     };\n911:   });\n912: \n913:   try {\n914:     const outcome = delete_transaction();\n915:     deleted = outcome.deleted;\n916:     failed = outcome.failed;\n917:     if (deleted > 0) {\n918:       clear_constitutional_cache();\n919:       clear_search_cache();\n920:       // Invalidate entity-density cache so deleted memories' tokens are evicted\n921:       // immediately rather than persisting for up to the 60s TTL. Best-effort.\n922:       try {\n923:         invalidateEntityDensityCache();\n924:       } catch (_error: unknown) {\n925:         // Cache invalidation is best-effort; do not mask a successful delete.\n926:       }\n927:       try {\n928:         if (bm25Index.isBm25Enabled()) {\n929:           const bm25 = bm25Index.getIndex();\n930:           for (const id of deletedIds) {\n931:             bm25.removeDocument(String(id));\n932:           }\n933:         }\n934:       } catch (_error: unknown) {\n935:         // BM25 cleanup is best-effort for bulk deletes as well.\n936:       }\n937:     }\n938:   } catch (e: unknown) {\n939:     console.warn(`[vector-index] delete_memories transaction error: ${get_error_message(e)}`);\n940:     deleted = 0;\n941:     failed = memory_ids.length;\n942:   }\n943: \n944:   return { deleted, failed };\n945: }\n946: \n947: // Valid statuses: 'pending', 'success', 'failed', 'retry', 'partial'\n948: /**\n949:  * Updates the embedding status for a memory.\n950:  * @param id - The memory identifier.\n951:  * @param status - The new embedding status.\n952:  * @returns True when the status was updated.\n953:  */\n954: export function update_embedding_status(\n955:   id: number,\n956:   status: string,\n957:   database: Database.Database = initialize_db(),\n958: ): boolean {\n959:   const valid_statuses = ['pending', 'success', 'failed', 'retry', 'partial'];\n960:   if (!valid_statuses.includes(status)) {\n961:     console.warn(`[vector-index] Invalid embedding status: ${status}`);\n962:     return false;\n963:   }\n964: \n965:   try {\n966:     const result = database.prepare(`\n967:       UPDATE memory_index\n968:       SET embedding_status = ?, updated_at = datetime('now')\n969:       WHERE id = ?\n970:     `).run(status, id);\n971: \n972:     return result.changes > 0;\n973:   } catch (error: unknown) {\n974:     console.warn(`[vector-index] Failed to update embedding status for ${id}: ${get_error_message(error)}`);\n975:     return false;\n976:   }\n977: }\n978: \n979: /**\n980:  * Updates the confidence value for a memory.\n981:  * @param memory_id - The memory identifier.\n982:  * @param confidence - The confidence value to store.\n983:  * @returns True when the confidence was updated.\n984:  */\n985: export function update_confidence(\n986:   memory_id: number,\n987:   confidence: number,\n988:   database: Database.Database = initialize_db(),\n989: ): boolean {\n990:   if (typeof confidence !== 'number' || confidence < 0 || confidence > 1) {\n991:     console.warn(`[vector-index] Invalid confidence value: ${confidence}`);\n992:     return false;\n993:   }\n994: \n995:   try {\n996:     const result = database.prepare(`\n997:       UPDATE memory_index\n998:       SET confidence = ?\n999:       WHERE id = ?\n1000:     `).run(confidence, memory_id);\n1001: \n1002:     return result.changes > 0;\n1003:   } catch (error: unknown) {\n1004:     console.warn(`[vector-index] Failed to update confidence for ${memory_id}: ${get_error_message(error)}`);\n1005:     return false;\n1006:   }\n1007: }\n1008: \n1009: // Exported so the store-port clear() can resolve and purge the active per-dim\n1010: // vector shard, mirroring the per-record delete path.\n1011: export { activeDimVectorSource };\n1012: \n1013: // CamelCase aliases\n1014: export { index_memory as indexMemory };\n1015: export { index_memory_deferred as indexMemoryDeferred };\n1016: export { update_memory as updateMemory };\n1017: export { delete_memory as deleteMemory };\n1018: export { delete_memory_by_path as deleteMemoryByPath };\n1019: export { delete_memories as deleteMemories };\n1020: export { update_embedding_status as updateEmbeddingStatus };\n1021: export { update_confidence as updateConfidence };\n\n(End of file - total 1021 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Vector Index Mutations\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts вҖ” contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Vector Index Mutations\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts вҖ” contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';\nimport { clearDegreeCacheForDb } from './graph-search-fn.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration } from '../storage/causal-generation.js';\nimport * as bm25Index from './bm25-index.js';\nimport {\n  clear_search_cache,\n} from './vector-index-aliases.js';\nimport { invalidateEntityDensityCache } from './entity-density.js';\nimport {\n  get_error_message,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  clear_constitutional_cache,\n  get_embedding_dim,\n  initialize_db,\n  init_prepared_statements,\n  refresh_interference_scores_for_folder,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource,\n} from './vector-index-store.js';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder, vecTableNameForDim } from '../embedders/schema.js';\nimport type {\n  IndexMemoryParams as SharedIndexMemoryParams,\n  MemoryScopeParams,\n  UpdateMemoryParams as SharedUpdateMemoryParams,\n} from './vector-index-types.js';\nimport type Database from 'better-sqlite3';\n\nconst logger = createLogger('VectorIndex');\n\nfunction isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n  const message = get_error_message(error).toLowerCase();\n  return message.includes('no such table') && message.includes('vec_memories');\n}\n\nfunction activeVectorTableExists(database: Database.Database, tableName: string): boolean {\n  try {\n    const row = database.prepare(`\n      SELECT 1 AS found\n      FROM ${activeVectorSource('sqlite_master')}\n      WHERE type = 'table' AND name = ?\n      LIMIT 1\n    `).get(tableName) as { found?: number } | undefined;\n    return row?.found === 1;\n  } catch (_error: unknown) {\n    return false;\n  }\n}\n\nfunction activeDimVectorSource(database: Database.Database): string | null {\n  const active = getActiveEmbedder(database);\n  if (active.name === DEFAULT_ACTIVE_EMBEDDER.name) {\n    return null;\n  }\n  const tableName = vecTableNameForDim(active.dim);\n  return activeVectorTableExists(database, tableName) ? activeVectorSource(tableName) : null;\n}\n\nfunction writeActiveVectorPayload(database: Database.Database, id: bigint, embeddingBuffer: Buffer): void {\n  database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n  database.prepare(`\n    INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)\n  `).run(id, embeddingBuffer);\n\n  const dimSource = activeDimVectorSource(database);\n  if (dimSource) {\n    database.prepare(`INSERT OR REPLACE INTO ${dimSource} (id, vec) VALUES (?, ?)`).run(id, embeddingBuffer);\n  }\n}\n\nfunction deleteActiveVectorPayload(database: Database.Database, id: bigint): void {\n  database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n  const dimSource = activeDimVectorSource(database);\n  if (dimSource) {\n    database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n  }\n}\n\nfunction invalidateGraphCaches(database: Database.Database): void {\n  // Bump the generation FIRST so every cache key that includes it (e.g.\n  // memory_search with causal boost) goes stale before the per-db caches clear;\n  // without this, memory-delete sweeps served stale causal-boosted search results.\n  bumpCausalEdgesGeneration();\n\n  try {\n    clearDegreeCacheForDb(database);\n  } catch (_error: unknown) {\n    // Degree cache invalidation is best-effort for legacy mutation paths.\n  }\n\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signal cache invalidation is best-effort for legacy mutation paths.\n  }\n}\n\nfunction tryRecordTierDowngradeAudit(\n  database: Database.Database,\n  params: {\n    memoryId: number;\n    specFolder: string | null | undefined;\n    anchorId: string | null | undefined;\n    filePath: string | null | undefined;\n    canonicalFilePath: string | null | undefined;\n    requestedTier?: string | null | undefined;\n    previousTier?: string | null | undefined;\n    nextTier: string;\n    source: string;\n  },\n): void {\n  try {\n    recordTierDowngradeAudit(database, {\n      memoryId: params.memoryId,\n      logicalKey: buildGovernanceLogicalKey(\n        params.specFolder,\n        params.canonicalFilePath || params.filePath,\n        params.anchorId,\n      ),\n      requestedTier: params.requestedTier ?? undefined,\n      previousTier: params.previousTier ?? undefined,\n      nextTier: params.nextTier,\n      source: params.source,\n      filePath: params.filePath ?? null,\n      canonicalFilePath: params.canonicalFilePath ?? null,\n    });\n  } catch (error: unknown) {\n    logger.warn('Failed to record governance audit for tier downgrade', {\n      memoryId: params.memoryId,\n      source: params.source,\n      message: get_error_message(error),\n    });\n  }\n}\n\nfunction deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n  const ancillaryTables = [\n    'DELETE FROM degree_snapshots WHERE memory_id = ?',\n    'DELETE FROM community_assignments WHERE memory_id = ?',\n    'DELETE FROM memory_summaries WHERE memory_id = ?',\n    'DELETE FROM memory_entities WHERE memory_id = ?',\n    'DELETE FROM memory_lineage WHERE memory_id = ?',\n  ];\n\n  for (const sql of ancillaryTables) {\n    try {\n      const paramCount = (sql.match(/\\?/g) || []).length;\n      if (paramCount === 2) {\n        database.prepare(sql).run(id, id);\n      } else {\n        database.prepare(sql).run(id);\n      }\n    } catch (_error: unknown) {\n      // Best-effort for legacy databases that may not have these tables yet.\n    }\n  }\n\n  // Clean active_memory_projection rows referencing this memory.\n  try {\n    database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n  } catch (_error: unknown) {\n    // Best-effort for legacy databases that may not have projection tables yet.\n  }\n\n  try {\n    const result = sweepCausalEdges(database, {\n      memoryIds: [id, String(id)],\n      reason: 'memory row mutation cleanup',\n      command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n      restoreContext: { memoryId: id },\n      invalidateCaches: false,\n    });\n    if (result.deleted > 0) {\n      invalidateGraphCaches(database);\n    }\n  } catch (error: unknown) {\n    // Tolerate only legacy databases that predate the causal-edge tables. Scope\n    // the match to those table names so an unrelated missing-table error still\n    // propagates and rolls back the surrounding delete instead of committing a\n    // hard delete without its tombstone audit row.\n    const message = error instanceof Error ? error.message : String(error);\n    if (!/no such table:\\s*causal_edge/i.test(message)) {\n      throw error;\n    }\n  }\n}\n\nfunction upsert_active_projection(\n  database: ReturnType<typeof initialize_db>,\n  specFolder: string,\n  canonicalFilePath: string,\n  anchorId: string | null,\n  memoryId: number,\n  updatedAt: string,\n  scope: NormalizedMemoryScope,\n): void {\n  const logicalKey = buildMemoryLogicalKey({\n    specFolder,\n    filePath: canonicalFilePath,\n    canonicalFilePath,\n    anchorId,\n    ...scope,\n  });\n  // Evict any stale projection row that maps a *different* logical_key to the\n  // same active_memory_id вҖ” prevents UNIQUE constraint violation on re-index\n  // when the logical_key changes (e.g. anchor or path normalization drift).\n  database.prepare(\n    'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n  ).run(memoryId, logicalKey);\n  database.prepare(`\n    INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n    VALUES (?, ?, ?, ?)\n    ON CONFLICT(logical_key) DO UPDATE SET\n      root_memory_id = excluded.root_memory_id,\n      active_memory_id = excluded.active_memory_id,\n      updated_at = excluded.updated_at\n  `).run(logicalKey, memoryId, memoryId, updatedAt);\n}\n\n// These mutation-local extensions are intentional until the shared query/store\n// contract adopts appendOnly and canonicalFilePath semantics.\ntype IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n  readonly appendOnly?: boolean;\n};\ntype IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n  readonly failureReason?: string | null;\n};\ntype UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n  readonly canonicalFilePath?: string;\n  // Set when the row's document now lives at a new on-disk location, so a\n  // moved file repoints its existing row instead of leaving a stale path.\n  readonly filePath?: string;\n};\n\ntype NormalizedMemoryScope = {\n  tenant_id: string | null;\n  user_id: string | null;\n  agent_id: string | null;\n  session_id: string | null;\n};\n\nfunction normalizeMemoryScope(scope?: MemoryScopeParams): NormalizedMemoryScope {\n  return {\n    tenant_id: normalizeScopeValue(scope?.tenantId),\n    user_id: normalizeScopeValue(scope?.userId),\n    agent_id: normalizeScopeValue(scope?.agentId),\n    session_id: normalizeScopeValue(scope?.sessionId),\n  };\n}\n\n/**\n * Indexes a memory with an embedding payload.\n * @param params - The memory values to index.\n * @returns The indexed memory identifier.\n * @throws {VectorIndexError} When embedding validation fails or the mutation cannot be applied.\n * @example\n * ```ts\n * const id = index_memory({\n *   specFolder: 'specs/001-demo',\n *   filePath: 'spec.md',\n *   embedding,\n * });\n * ```\n */\nexport function index_memory(\n  params: IndexMemoryParams,\n  database: Database.Database = initialize_db(),\n): number {\n  const {\n    specFolder,\n    filePath,\n    parentId = null,\n    anchorId = null,\n    title = null,\n    triggerPhrases = [],\n    importanceWeight = 0.5,\n    embedding,\n    encodingIntent,\n    documentType = 'memory',\n    specLevel = null,\n    contentText = null,\n    qualityScore = 0,\n    qualityFlags = [],\n    appendOnly = false,\n  } = params;\n  const scope = normalizeMemoryScope(params.scope);\n\n  if (!embedding) {\n    throw new VectorIndexError('Embedding is required', VectorIndexErrorCode.EMBEDDING_VALIDATION);\n  }\n\n  const expected_dim = get_embedding_dim();\n  if (embedding.length !== expected_dim) {\n    console.warn(`[vector-index] Embedding dimension mismatch: expected ${expected_dim}, got ${embedding.length}`);\n    throw new VectorIndexError(\n      `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const now = new Date().toISOString();\n  const triggers_json = JSON.stringify(triggerPhrases);\n  const embedding_buffer = to_embedding_buffer(embedding);\n  const canonicalFilePath = getCanonicalPathKey(filePath);\n\n  const stmts = init_prepared_statements(database);\n  const existing = appendOnly\n    ? null\n    : stmts.get_by_folder_and_path.get(\n        specFolder,\n        canonicalFilePath,\n        filePath,\n        canonicalFilePath,\n        filePath,\n        anchorId,\n        scope.tenant_id,\n        scope.user_id,\n        scope.agent_id,\n        scope.session_id,\n      );\n\n  if (existing && !appendOnly) {\n    return update_memory({\n      id: existing.id,\n      title: title ?? undefined,\n      triggerPhrases,\n      importanceWeight,\n      embedding,\n      encodingIntent,\n      documentType,\n      specLevel,\n      contentText,\n      qualityScore,\n      qualityFlags,\n      canonicalFilePath,\n      filePath,\n    }, database);\n  }\n\n  const sqlite_vec = get_sqlite_vec_available();\n\n  const index_memory_tx = database.transaction(() => {\n    const embedding_status = sqlite_vec ? 'success' : 'pending';\n\n    const result = database.prepare(`\n      INSERT INTO memory_index (\n        spec_folder, file_path, canonical_file_path, anchor_id, title, trigger_phrases,\n        importance_weight, created_at, updated_at, embedding_model,\n        embedding_generated_at, embedding_status, encoding_intent, document_type, spec_level,\n        content_text, quality_score, quality_flags, parent_id,\n        tenant_id, user_id, agent_id, session_id\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      specFolder, filePath, canonicalFilePath, anchorId, title, triggers_json,\n      importanceWeight, now, now, embeddingsProvider.getModelName(), now, embedding_status,\n      encodingIntent ?? 'document', documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), parentId,\n      scope.tenant_id, scope.user_id, scope.agent_id, scope.session_id\n    );\n\n    const row_id = BigInt(result.lastInsertRowid);\n    const metadata_id = Number(row_id);\n\n    upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, metadata_id, now, scope);\n\n    if (sqlite_vec) {\n      writeActiveVectorPayload(database, row_id, embedding_buffer);\n    }\n\n    refresh_interference_scores_for_folder(database, specFolder);\n    clear_search_cache();\n\n    return metadata_id;\n  });\n\n  return index_memory_tx();\n}\n\n// Deferred indexing - entry searchable via BM25/FTS5 only\n/**\n * Indexes a memory record without storing an embedding yet.\n * @param params - The deferred memory values to index.\n * @returns The indexed memory identifier.\n */\nexport function index_memory_deferred(\n  params: IndexMemoryDeferredParams,\n  database: Database.Database = initialize_db(),\n): number {\n  const {\n    specFolder,\n    filePath,\n    parentId = null,\n    anchorId = null,\n    title = null,\n    triggerPhrases = [],\n    importanceWeight = 0.5,\n    failureReason = null,\n    encodingIntent,\n    documentType = 'memory',\n    specLevel = null,\n    contentText = null,\n    qualityScore = 0,\n    qualityFlags = [],\n    appendOnly = false,\n  } = params;\n  const scope = normalizeMemoryScope(params.scope);\n\n  const now = new Date().toISOString();\n  const triggers_json = JSON.stringify(triggerPhrases);\n  const canonicalFilePath = getCanonicalPathKey(filePath);\n\n  const stmts = init_prepared_statements(database);\n  const existing = appendOnly\n    ? null\n    : stmts.get_by_folder_and_path.get(\n        specFolder,\n        canonicalFilePath,\n        filePath,\n        canonicalFilePath,\n        filePath,\n        anchorId,\n        scope.tenant_id,\n        scope.user_id,\n        scope.agent_id,\n        scope.session_id,\n      );\n\n  const index_memory_deferred_tx = database.transaction(() => {\n    if (existing && !appendOnly) {\n      database.prepare(`\n        UPDATE memory_index\n        SET title = ?,\n            trigger_phrases = ?,\n            importance_weight = ?,\n            file_path = ?,\n            canonical_file_path = ?,\n            embedding_status = 'pending',\n            failure_reason = ?,\n            updated_at = ?,\n            encoding_intent = COALESCE(?, encoding_intent),\n            document_type = ?,\n            spec_level = ?,\n            content_text = ?,\n            quality_score = ?,\n            quality_flags = ?,\n            retry_count = 0,\n            last_retry_at = NULL\n        WHERE id = ?\n      `).run(title, triggers_json, importanceWeight, filePath, canonicalFilePath, failureReason, now, encodingIntent, documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), existing.id);\n      upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, existing.id, now, scope);\n      refresh_interference_scores_for_folder(database, specFolder);\n      return existing.id;\n    }\n\n    const result = database.prepare(`\n      INSERT INTO memory_index (\n        spec_folder, file_path, canonical_file_path, anchor_id, title, trigger_phrases,\n        importance_weight, created_at, updated_at, embedding_status,\n        failure_reason, retry_count, encoding_intent, document_type, spec_level,\n        content_text, quality_score, quality_flags, parent_id,\n        tenant_id, user_id, agent_id, session_id\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?, 0, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      specFolder, filePath, canonicalFilePath, anchorId, title, triggers_json,\n      importanceWeight, now, now, failureReason, encodingIntent ?? 'document', documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), parentId,\n      scope.tenant_id, scope.user_id, scope.agent_id, scope.session_id\n    );\n\n    const row_id = BigInt(result.lastInsertRowid);\n    upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, Number(row_id), now, scope);\n    refresh_interference_scores_for_folder(database, specFolder);\n    logger.info(`Deferred indexing: Memory ${Number(row_id)} saved without embedding (BM25/FTS5 searchable)`);\n\n    return Number(row_id);\n  });\n\n  return index_memory_deferred_tx();\n}\n\n/**\n * Updates stored memory metadata and embeddings.\n * @param params - The memory values to update.\n * @returns The updated memory identifier.\n * @throws {VectorIndexError} When embedding validation fails or the mutation transaction cannot complete.\n * @example\n * ```ts\n * const id = update_memory({ id: 42, title: 'Updated title', embedding });\n * ```\n */\nexport function update_memory(\n  params: UpdateMemoryParams,\n  database: Database.Database = initialize_db(),\n): number {\n  const {\n    id,\n    title,\n    triggerPhrases,\n    importanceWeight,\n    importanceTier,\n    embedding,\n    canonicalFilePath,\n    filePath,\n    encodingIntent,\n    documentType,\n    specLevel,\n    contentText,\n    qualityScore,\n    qualityFlags,\n  } = params;\n\n  const now = new Date().toISOString();\n\n  const update_memory_tx = database.transaction(() => {\n    const existingRow = database.prepare(`\n      SELECT spec_folder, anchor_id, canonical_file_path, file_path, importance_tier,\n             tenant_id, user_id, agent_id, session_id\n      FROM memory_index\n      WHERE id = ?\n    `).get(id) as {\n      spec_folder: string | null;\n      anchor_id: string | null;\n      canonical_file_path: string | null;\n      file_path: string | null;\n      importance_tier: string | null;\n      tenant_id: string | null;\n      user_id: string | null;\n      agent_id: string | null;\n      session_id: string | null;\n    } | undefined;\n    const updates = ['updated_at = ?'];\n    const values: unknown[] = [now];\n\n    if (title !== undefined) {\n      updates.push('title = ?');\n      values.push(title);\n    }\n    if (triggerPhrases !== undefined) {\n      updates.push('trigger_phrases = ?');\n      values.push(JSON.stringify(triggerPhrases));\n    }\n    if (importanceWeight !== undefined) {\n      updates.push('importance_weight = ?');\n      values.push(importanceWeight);\n    }\n    if (importanceTier !== undefined) {\n      let nextImportanceTier = importanceTier;\n      const previousTier = existingRow?.importance_tier ?? null;\n      if (\n        existingRow\n      ) {\n        const guardPath = existingRow.canonical_file_path || existingRow.file_path;\n        const hasNonConstitutionalPath = guardPath && !isIndexableConstitutionalMemoryPath(guardPath);\n        if (hasNonConstitutionalPath && importanceTier === 'constitutional') {\n          // Non-constitutional paths cannot be promoted to constitutional tier.\n          nextImportanceTier = 'important';\n        }\n        if (\n          hasNonConstitutionalPath\n          && (\n            importanceTier === 'constitutional'\n            || (previousTier === 'constitutional' && nextImportanceTier !== 'constitutional')\n          )\n        ) {\n          tryRecordTierDowngradeAudit(database, {\n            memoryId: id,\n            specFolder: existingRow.spec_folder,\n            anchorId: existingRow.anchor_id,\n            filePath: existingRow.file_path,\n            canonicalFilePath: existingRow.canonical_file_path,\n            requestedTier: importanceTier,\n            previousTier,\n            nextTier: nextImportanceTier,\n            source: 'update_memory',\n          });\n        }\n      }\n      updates.push('importance_tier = ?');\n      values.push(nextImportanceTier);\n      clear_constitutional_cache();\n    }\n    if (canonicalFilePath !== undefined) {\n      updates.push('canonical_file_path = ?');\n      values.push(canonicalFilePath);\n    }\n    if (filePath !== undefined) {\n      updates.push('file_path = ?');\n      values.push(filePath);\n    }\n    if (encodingIntent !== undefined) {\n      updates.push('encoding_intent = ?');\n      values.push(encodingIntent);\n    }\n    if (documentType !== undefined) {\n      updates.push('document_type = ?');\n      values.push(documentType);\n    }\n    if (specLevel !== undefined) {\n      updates.push('spec_level = ?');\n      values.push(specLevel);\n    }\n    if (contentText !== undefined) {\n      updates.push('content_text = ?');\n      values.push(contentText);\n    }\n    if (qualityScore !== undefined) {\n      updates.push('quality_score = ?');\n      values.push(qualityScore);\n    }\n    if (qualityFlags !== undefined) {\n      updates.push('quality_flags = ?');\n      values.push(JSON.stringify(qualityFlags));\n    }\n    if (embedding) {\n      updates.push('embedding_model = ?');\n      updates.push('embedding_generated_at = ?');\n      updates.push('embedding_status = ?');\n      values.push(embeddingsProvider.getModelName(), now, 'pending');\n    }\n\n    values.push(id);\n\n    const updateResult = database.prepare(`\n      UPDATE memory_index SET ${updates.join(', ')} WHERE id = ?\n    `).run(...values);\n\n    // Return early if the target row no longer exists.\n    if (updateResult.changes === 0) {\n      return id;\n    }\n\n    const sqlite_vec = get_sqlite_vec_available();\n    if (embedding && sqlite_vec) {\n      const expected_dim = get_embedding_dim();\n      if (embedding.length !== expected_dim) {\n        console.warn(`[vector-index] Embedding dimension mismatch in update: expected ${expected_dim}, got ${embedding.length}`);\n        throw new VectorIndexError(\n          `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n          VectorIndexErrorCode.EMBEDDING_VALIDATION,\n        );\n      }\n\n      const embedding_buffer = to_embedding_buffer(embedding);\n      writeActiveVectorPayload(database, BigInt(id), embedding_buffer);\n      database.prepare('UPDATE memory_index SET embedding_status = ? WHERE id = ?').run('success', id);\n    }\n\n    if (existingRow?.spec_folder) {\n      const projectionPath = canonicalFilePath\n        ?? existingRow.canonical_file_path\n        ?? getCanonicalPathKey(existingRow.file_path ?? '');\n      upsert_active_projection(database, existingRow.spec_folder, projectionPath, existingRow.anchor_id ?? null, id, now, {\n        tenant_id: existingRow.tenant_id,\n        user_id: existingRow.user_id,\n        agent_id: existingRow.agent_id,\n        session_id: existingRow.session_id,\n      });\n    }\n\n    if (existingRow?.spec_folder) {\n      refresh_interference_scores_for_folder(database, existingRow.spec_folder);\n    }\n    clear_search_cache();\n\n    return id;\n  });\n\n  return update_memory_tx();\n}\n\n/**\n * Deletes a memory and its related index records.\n * @param id - The memory identifier.\n * @returns True when a memory was deleted.\n * @throws {VectorIndexError} Propagates mutation or store initialization failures from the delete pipeline.\n * @example\n * ```ts\n * const deleted = delete_memory(42);\n * ```\n */\nexport function delete_memory(id: number, database: Database.Database = initialize_db()): boolean {\n  return delete_memory_from_database(database, id);\n}\n\n/**\n * Deletes a memory and related index records using the provided database handle.\n * @param database - The database containing the target memory.\n * @param id - The memory identifier.\n * @returns True when a memory was deleted.\n * @throws {VectorIndexError} Propagates mutation failures encountered while deleting the memory.\n * @example\n * ```ts\n * const deleted = delete_memory_from_database(database, 42);\n * ```\n */\nexport function delete_memory_from_database(database: Database.Database, id: number): boolean {\n  const sqlite_vec = get_sqlite_vec_available();\n\n  const delete_memory_tx = database.transaction(() => {\n    // Memory_history rows are intentionally preserved after deletion\n    // So DELETE audit events recorded by handlers persist as audit trail.\n    const row = database.prepare('SELECT content_hash FROM memory_index WHERE id = ?').get(id) as\n      | { content_hash: string | null }\n      | undefined;\n\n    if (sqlite_vec) {\n      try {\n        deleteActiveVectorPayload(database, BigInt(id));\n      } catch (e: unknown) {\n        if (!isExpectedMissingVecMemoriesTable(e)) {\n          throw new VectorIndexError(\n            `Vector deletion failed for memory ${id}: ${get_error_message(e)}`,\n            VectorIndexErrorCode.MUTATION_FAILED,\n          );\n        }\n      }\n    }\n\n    // Clean ancillary records so deletes do not leave graph residue behind.\n    deleteAncillaryMemoryRows(database, id);\n\n    if (row?.content_hash) {\n      // Governed retention delete semantics include derived embedding-cache rows.\n      try {\n        deleteByContentHash(database, row.content_hash);\n      } catch (_error: unknown) {\n        // Legacy or test databases may not have embedding_cache yet.\n      }\n    }\n\n    const result = database.prepare('DELETE FROM memory_index WHERE id = ?').run(id);\n\n    clear_search_cache();\n    clear_constitutional_cache();\n\n    return result.changes > 0;\n  });\n\n  // Remove the BM25 document only after the source row is deleted.\n  const deleted = delete_memory_tx();\n  if (deleted) {\n    // Invalidate entity-density cache so deleted memory's tokens are not routed\n    // to the graph channel beyond the 60s TTL window. Best-effort: non-fatal.\n    try {\n      invalidateEntityDensityCache();\n    } catch (_error: unknown) {\n      // Cache invalidation is best-effort; do not mask a successful delete.\n    }\n  }\n  if (deleted) {\n    try {\n      if (bm25Index.isBm25Enabled()) {\n        bm25Index.getIndex().removeDocument(String(id));\n      }\n    } catch (_error: unknown) {\n      // BEST-EFFORT BM25 CLEANUP MUST NOT MASK A SUCCESSFUL PRIMARY DELETE.\n    }\n  }\n  return deleted;\n}\n\n/**\n * Deletes the latest memory for a file path and optional anchor.\n * @param spec_folder - The owning spec folder.\n * @param file_path - The file path to delete.\n * @param anchor_id - The optional anchor identifier.\n * @returns True when a memory was deleted.\n * @throws {VectorIndexError} Propagates delete failures from the underlying mutation helpers.\n * @example\n * ```ts\n * const deleted = delete_memory_by_path('specs/001-demo', 'spec.md');\n * ```\n */\nexport function delete_memory_by_path(\n  spec_folder: string,\n  file_path: string,\n  anchor_id: string | null = null,\n  database: Database.Database = initialize_db(),\n): boolean {\n  const canonicalPath = getCanonicalPathKey(file_path);\n\n  const row = database.prepare(`\n    SELECT id, spec_folder FROM memory_index\n    WHERE spec_folder = ?\n      AND (canonical_file_path = ? OR file_path = ?)\n      AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))\n    ORDER BY id DESC\n    LIMIT 1\n  `).get(spec_folder, canonicalPath, file_path, anchor_id, anchor_id) as { id: number; spec_folder?: string | null } | undefined;\n\n  if (row) {\n    const deleted = delete_memory_from_database(database, row.id);\n    if (deleted) {\n      // Self-record DELETE history only after the delete succeeded.\n      try {\n        recordHistory(row.id, 'DELETE', file_path ?? null, null, 'mcp:delete_by_path', row.spec_folder ?? spec_folder);\n      } catch (_histErr: unknown) {\n        // BEST-EFFORT HISTORY WRITES MUST NOT MASK A SUCCESSFUL DELETE.\n      }\n    }\n    return deleted;\n  }\n  return false;\n}\n\n/**\n * Deletes multiple memories in a single transaction.\n * @param memory_ids - The memory identifiers to delete.\n * @returns Counts for deleted and failed items.\n * @throws {VectorIndexError} When one or more deletes fail and the transaction is rolled back.\n * @example\n * ```ts\n * const outcome = delete_memories([1, 2, 3]);\n * ```\n */\nexport function delete_memories(\n  memory_ids: number[],\n  database: Database.Database = initialize_db(),\n): { deleted: number; failed: number } {\n  if (!memory_ids || memory_ids.length === 0) {\n    return { deleted: 0, failed: 0 };\n  }\n  const sqlite_vec = get_sqlite_vec_available();\n  let deleted = 0;\n  let failed = 0;\n  const deletedIds: number[] = [];\n\n  const specFolderById = new Map<number, string | null>();\n  for (const id of memory_ids) {\n    if (!Number.isInteger(id) || id <= 0) {\n      continue;\n    }\n    try {\n      const row = database.prepare('SELECT spec_folder FROM memory_index WHERE id = ?').get(id) as { spec_folder?: string | null } | undefined;\n      specFolderById.set(id, row?.spec_folder ?? null);\n    } catch (_error: unknown) {\n      specFolderById.set(id, null);\n    }\n  }\n\n  const delete_transaction = database.transaction(() => {\n    let transactionDeleted = 0;\n    let transactionFailed = 0;\n    const failed_ids: number[] = [];\n\n    for (const id of memory_ids) {\n      try {\n        if (sqlite_vec) {\n          try {\n            deleteActiveVectorPayload(database, BigInt(id));\n          } catch (vec_error: unknown) {\n            console.warn(`[VectorIndex] Failed to delete vector for memory ${id}: ${get_error_message(vec_error)}`);\n          }\n        }\n\n        deleteAncillaryMemoryRows(database, id);\n        const result = database.prepare('DELETE FROM memory_index WHERE id = ?').run(id);\n        if (result.changes > 0) {\n          // Memory_history rows are intentionally preserved after deletion\n          // So DELETE audit events recorded here persist as audit trail.\n          try {\n            recordHistory(id, 'DELETE', null, null, 'mcp:delete_memories', specFolderById.get(id) ?? null);\n          } catch (_histErr: unknown) {\n            // BEST-EFFORT HISTORY WRITES MUST NOT MASK A SUCCESSFUL DELETE.\n          }\n          transactionDeleted++;\n          deletedIds.push(id);\n        } else {\n          transactionFailed++;\n          failed_ids.push(id);\n        }\n      } catch (e: unknown) {\n        console.warn(`[vector-index] Failed to delete memory ${id}: ${get_error_message(e)}`);\n        transactionFailed++;\n        failed_ids.push(id);\n      }\n    }\n\n    if (failed_ids.length > 0) {\n      throw new VectorIndexError(\n        `Failed to delete memories: ${failed_ids.join(', ')}. Transaction rolled back.`,\n        VectorIndexErrorCode.MUTATION_FAILED,\n      );\n    }\n\n    return {\n      deleted: transactionDeleted,\n      failed: transactionFailed,\n    };\n  });\n\n  try {\n    const outcome = delete_transaction();\n    deleted = outcome.deleted;\n    failed = outcome.failed;\n    if (deleted > 0) {\n      clear_constitutional_cache();\n      clear_search_cache();\n      // Invalidate entity-density cache so deleted memories' tokens are evicted\n      // immediately rather than persisting for up to the 60s TTL. Best-effort.\n      try {\n        invalidateEntityDensityCache();\n      } catch (_error: unknown) {\n        // Cache invalidation is best-effort; do not mask a successful delete.\n      }\n      try {\n        if (bm25Index.isBm25Enabled()) {\n          const bm25 = bm25Index.getIndex();\n          for (const id of deletedIds) {\n            bm25.removeDocument(String(id));\n          }\n        }\n      } catch (_error: unknown) {\n        // BM25 cleanup is best-effort for bulk deletes as well.\n      }\n    }\n  } catch (e: unknown) {\n    console.warn(`[vector-index] delete_memories transaction error: ${get_error_message(e)}`);\n    deleted = 0;\n    failed = memory_ids.length;\n  }\n\n  return { deleted, failed };\n}\n\n// Valid statuses: 'pending', 'success', 'failed', 'retry', 'partial'\n/**\n * Updates the embedding status for a memory.\n * @param id - The memory identifier.\n * @param status - The new embedding status.\n * @returns True when the status was updated.\n */\nexport function update_embedding_status(\n  id: number,\n  status: string,\n  database: Database.Database = initialize_db(),\n): boolean {\n  const valid_statuses = ['pending', 'success', 'failed', 'retry', 'partial'];\n  if (!valid_statuses.includes(status)) {\n    console.warn(`[vector-index] Invalid embedding status: ${status}`);\n    return false;\n  }\n\n  try {\n    const result = database.prepare(`\n      UPDATE memory_index\n      SET embedding_status = ?, updated_at = datetime('now')\n      WHERE id = ?\n    `).run(status, id);\n\n    return result.changes > 0;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to update embedding status for ${id}: ${get_error_message(error)}`);\n    return false;\n  }\n}\n\n/**\n * Updates the confidence value for a memory.\n * @param memory_id - The memory identifier.\n * @param confidence - The confidence value to store.\n * @returns True when the confidence was updated.\n */\nexport function update_confidence(\n  memory_id: number,\n  confidence: number,\n  database: Database.Database = initialize_db(),\n): boolean {\n  if (typeof confidence !== 'number' || confidence < 0 || confidence > 1) {\n    console.warn(`[vector-index] Invalid confidence value: ${confidence}`);\n    return false;\n  }\n\n  try {\n    const result = database.prepare(`\n      UPDATE memory_index\n      SET confidence = ?\n      WHERE id = ?\n    `).run(confidence, memory_id);\n\n    return result.changes > 0;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to update confidence for ${memory_id}: ${get_error_message(error)}`);\n    return false;\n  }\n}\n\n// Exported so the store-port clear() can resolve and purge the active per-dim\n// vector shard, mirroring the per-record delete path.\nexport { activeDimVectorSource };\n\n// CamelCase aliases\nexport { index_memory as indexMemory };\nexport { index_memory_deferred as indexMemoryDeferred };\nexport { update_memory as updateMemory };\nexport { delete_memory as deleteMemory };\nexport { delete_memory_by_path as deleteMemoryByPath };\nexport { delete_memories as deleteMemories };\nexport { update_embedding_status as updateEmbeddingStatus };\nexport { update_confidence as updateConfidence };","lineStart":1,"lineEnd":1021,"totalLines":1021,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","time":{"start":1781764258706,"end":1781764258714}},"metadata":{"openai":{"itemId":"fc_03f5d3efadbd529a016a3390a283c08191ba741c360b179774"}},"id":"prt_ed96cfb6a001xdXjIFk1EoyOZR","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96cc029001sLIhXPsAafhA8L"}}
{"type":"tool_use","timestamp":1781764258744,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_EICMJQnb5ga1CEp66PMlcSyg","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":1,"limit":2200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Vector Index Queries\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts вҖ” contains ALL query/search functions,\n6: // Content extraction, ranking, stats, cleanup, and integrity checks.\n7: \n8: import * as path from 'path';\n9: import * as fs from 'fs';\n10: import type Database from 'better-sqlite3';\n11: import { formatAgeString as format_age_string } from '../utils/format-helpers.js';\n12: import { createLogger } from '../utils/logger.js';\n13: import { recordHistory } from '../storage/history.js';\n14: import { isArchivedVectorInclusionEnabled } from './search-flags.js';\n15: import * as embeddingsProvider from '../providers/embeddings.js';\n16: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\n17: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n18: import { getEmbedderAdapter } from '../embedders/execution-router.js';\n19: import { getManifest } from '../embedders/registry.js';\n20: import {\n21:   computeContentHash,\n22:   getActiveEmbeddingProfileKey,\n23:   lookupEmbedding,\n24:   storeEmbedding,\n25: } from '../cache/embedding-cache.js';\n26: import {\n27:   get_error_message,\n28:   parse_trigger_phrases,\n29:   specFolderLikePattern,\n30:   to_embedding_buffer,\n31:   VectorIndexError,\n32:   VectorIndexErrorCode,\n33: } from './vector-index-types.js';\n34: import {\n35:   initialize_db,\n36:   get_embedding_dim,\n37:   get_constitutional_memories,\n38:   init_prepared_statements,\n39:   validate_file_path_local,\n40:   safe_read_file_async,\n41:   safe_parse_json,\n42:   search_weights,\n43:   sqlite_vec_available as get_sqlite_vec_available,\n44:   activeVectorSource as activeVectorSchema,\n45: } from './vector-index-store.js';\n46: import { delete_memory_from_database } from './vector-index-mutations.js';\n47: import type {\n48:   EmbeddingInput,\n49:   EnrichedSearchResult,\n50:   MemoryRow,\n51:   VectorSearchOptions,\n52: } from './vector-index-types.js';\n53: \n54: const logger = createLogger('VectorIndex');\n55: \n56: type RelatedMemoryLink = { id: number; similarity: number };\n57: type UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\n58: type CleanupOptions = {\n59:   maxAgeDays?: number;\n60:   maxAccessCount?: number;\n61:   maxConfidence?: number;\n62:   limit?: number;\n63: };\n64: type VectorSource = {\n65:   dim: number;\n66:   tableName: string;\n67:   idColumn: string;\n68:   embeddingColumn: string;\n69: };\n70: \n71: export interface KnnQueryShapeBenchmarkResult {\n72:   readonly corpusSize: number;\n73:   readonly iterations: number;\n74:   readonly scalarJoinAverageMs: number;\n75:   readonly matchAverageMs: number | null;\n76:   readonly matchSupported: boolean;\n77:   readonly matchImprovementPct: number | null;\n78:   readonly decision: 'adopt_match' | 'keep_scalar_join';\n79:   readonly reason: string;\n80: }\n81: \n82: const KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n83: \n84: function appendSpecFolderScope(\n85:   clauses: string[],\n86:   params: unknown[],\n87:   specFolder: string | null | undefined,\n88:   column = 'm.spec_folder',\n89: ): void {\n90:   if (!specFolder) return;\n91:   clauses.push(`(${column} = ? OR ${column} LIKE ? ESCAPE '\\\\')`);\n92:   params.push(specFolder, specFolderLikePattern(specFolder));\n93: }\n94: \n95: function tableExists(database: Database.Database, tableName: string): boolean {\n96:   const row = database.prepare(`\n97:     SELECT 1 AS found\n98:     FROM active_vec.sqlite_master\n99:     WHERE type = 'table' AND name = ?\n100:     LIMIT 1\n101:   `).get(tableName) as { found?: number } | undefined;\n102:   return row?.found === 1;\n103: }\n104: \n105: function getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n106:   const active = getActiveEmbedder(database);\n107:   const dimTableName = `vec_${active.dim}`;\n108:   if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n109:     return {\n110:       dim: active.dim,\n111:       tableName: activeVectorSchema(dimTableName),\n112:       idColumn: 'id',\n113:       embeddingColumn: 'vec',\n114:     };\n115:   }\n116: \n117:   return {\n118:     dim: get_embedding_dim(),\n119:     tableName: activeVectorSchema('vec_memories'),\n120:     idColumn: 'rowid',\n121:     embeddingColumn: 'embedding',\n122:   };\n123: }\n124: \n125: function elapsedMs(start: bigint): number {\n126:   return Number(process.hrtime.bigint() - start) / 1_000_000;\n127: }\n128: \n129: function average(values: number[]): number {\n130:   if (values.length === 0) return 0;\n131:   return values.reduce((sum, value) => sum + value, 0) / values.length;\n132: }\n133: \n134: export function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n135:   return result.matchSupported === true\n136:     && typeof result.matchImprovementPct === 'number'\n137:     && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n138: }\n139: \n140: export function benchmarkKnnQueryShapes(\n141:   query_embedding: EmbeddingInput,\n142:   options: { iterations?: number; limit?: number } = {},\n143:   database: Database.Database = initialize_db(),\n144: ): KnnQueryShapeBenchmarkResult {\n145:   const vectorSource = getActiveVectorSourceForQuery(database);\n146:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n147:     throw new VectorIndexError(\n148:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n149:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n150:     );\n151:   }\n152: \n153:   const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n154:   const limit = Math.max(1, Math.floor(options.limit ?? 20));\n155:   const queryBuffer = to_embedding_buffer(query_embedding);\n156:   const corpusSize = (database.prepare(`\n157:     SELECT COUNT(*) AS count\n158:     FROM memory_index m\n159:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n160:     WHERE m.embedding_status = 'success'\n161:   `).get() as { count: number }).count;\n162: \n163:   const scalarSql = `\n164:     SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n165:     FROM memory_index m\n166:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n167:     JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n168:     WHERE m.embedding_status = 'success'\n169:     ORDER BY distance ASC\n170:     LIMIT ?\n171:   `;\n172:   const scalarStmt = database.prepare(scalarSql);\n173:   scalarStmt.all(queryBuffer, limit);\n174:   const scalarRuns: number[] = [];\n175:   for (let i = 0; i < iterations; i += 1) {\n176:     const start = process.hrtime.bigint();\n177:     scalarStmt.all(queryBuffer, limit);\n178:     scalarRuns.push(elapsedMs(start));\n179:   }\n180: \n181:   const matchTable = activeVectorSchema('vec_memories');\n182:   const matchAvailable = tableExists(database, 'vec_memories');\n183:   let matchAverageMs: number | null = null;\n184:   let matchError: string | null = null;\n185: \n186:   if (matchAvailable) {\n187:     try {\n188:       const matchSql = `\n189:         WITH knn AS (\n190:           SELECT rowid, distance\n191:           FROM ${matchTable}\n192:           WHERE embedding MATCH ? AND k = ?\n193:         )\n194:         SELECT m.id, knn.distance\n195:         FROM knn\n196:         JOIN memory_index m ON m.id = knn.rowid\n197:         JOIN active_memory_projection p ON p.active_memory_id = m.id\n198:         WHERE m.embedding_status = 'success'\n199:         ORDER BY knn.distance ASC\n200:         LIMIT ?\n201:       `;\n202:       const matchStmt = database.prepare(matchSql);\n203:       matchStmt.all(queryBuffer, limit, limit);\n204:       const matchRuns: number[] = [];\n205:       for (let i = 0; i < iterations; i += 1) {\n206:         const start = process.hrtime.bigint();\n207:         matchStmt.all(queryBuffer, limit, limit);\n208:         matchRuns.push(elapsedMs(start));\n209:       }\n210:       matchAverageMs = average(matchRuns);\n211:     } catch (error: unknown) {\n212:       matchError = get_error_message(error);\n213:     }\n214:   }\n215: \n216:   const scalarJoinAverageMs = average(scalarRuns);\n217:   const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n218:     ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n219:     : null;\n220:   const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n221:     matchSupported: matchAverageMs !== null,\n222:     matchImprovementPct,\n223:   };\n224:   const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n225: \n226:   return {\n227:     corpusSize,\n228:     iterations,\n229:     scalarJoinAverageMs,\n230:     matchAverageMs,\n231:     matchSupported: matchAverageMs !== null,\n232:     matchImprovementPct,\n233:     decision,\n234:     reason: decision === 'adopt_match'\n235:       ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n236:       : matchError\n237:         ? `MATCH unavailable: ${matchError}`\n238:         : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n239:   };\n240: }\n241: \n242: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n243:    SIMPLE QUERIES\n244: ----------------------------------------------------------------*/\n245: \n246: /**\n247:  * Gets one indexed memory by identifier.\n248:  * @param id - The memory identifier.\n249:  * @returns The matching memory row, if found.\n250:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n251:  * @example\n252:  * ```ts\n253:  * const memory = get_memory(42);\n254:  * ```\n255:  */\n256: export function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n257:   const stmts = init_prepared_statements(database);\n258:   const row = stmts.get_by_id.get(id);\n259: \n260:   if (row) {\n261:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n262:     row.isConstitutional = row.importance_tier === 'constitutional';\n263:   }\n264: \n265:   return row || null;\n266: }\n267: \n268: /**\n269:  * Gets indexed memories for a spec folder.\n270:  * @param spec_folder - The spec folder to query.\n271:  * @returns The memory rows for the folder.\n272:  */\n273: export function get_memories_by_folder(\n274:   spec_folder: string,\n275:   database: Database.Database = initialize_db(),\n276: ): MemoryRow[] {\n277:   const rows = database.prepare(`\n278:     SELECT m.*\n279:     FROM memory_index m\n280:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n281:     WHERE (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\n282:     ORDER BY m.created_at DESC\n283:   `).all(spec_folder, specFolderLikePattern(spec_folder)) as MemoryRow[];\n284: \n285:   return rows.map((row: MemoryRow) => {\n286:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n287:     row.isConstitutional = row.importance_tier === 'constitutional';\n288:     return row;\n289:   });\n290: }\n291: \n292: /**\n293:  * Gets the total number of indexed memories.\n294:  * @returns The total memory count.\n295:  */\n296: export function get_memory_count(database: Database.Database = initialize_db()): number {\n297:   const stmts = init_prepared_statements(database);\n298:   const result = stmts.count_all.get();\n299:   return result?.count ?? 0;\n300: }\n301: \n302: /**\n303:  * Gets memory counts grouped by embedding status.\n304:  * @returns The counts for each embedding status.\n305:  */\n306: export function get_status_counts(\n307:   database: Database.Database = initialize_db(),\n308: ): { pending: number; success: number; failed: number; retry: number; partial: number } {\n309:   const rows = database.prepare(`\n310:     SELECT m.embedding_status, COUNT(*) as count\n311:     FROM memory_index m\n312:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n313:     GROUP BY m.embedding_status\n314:   `).all();\n315: \n316:   // Include 'partial' status in counts.\n317:   const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n318:   for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n319:     if (row.embedding_status in counts) {\n320:       counts[row.embedding_status] = row.count;\n321:     }\n322:   }\n323: \n324:   return counts;\n325: }\n326: \n327: /**\n328:  * Gets summary counts for indexed memories.\n329:  * @returns The aggregate memory statistics.\n330:  */\n331: export function get_stats(\n332:   database: Database.Database = initialize_db(),\n333: ): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n334:   const counts = get_status_counts(database);\n335:   const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n336: \n337:   return {\n338:     total,\n339:     ...counts\n340:   };\n341: }\n342: \n343: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n344:    VECTOR SEARCH\n345: ----------------------------------------------------------------*/\n346: \n347: /**\n348:  * Searches indexed memories by vector similarity.\n349:  * @param query_embedding - The query embedding to search with.\n350:  * @param options - Search options.\n351:  * @returns The matching memory rows.\n352:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n353:  * @example\n354:  * ```ts\n355:  * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n356:  * ```\n357:  */\n358: export function vector_search(\n359:   query_embedding: EmbeddingInput,\n360:   options: VectorSearchOptions = {},\n361:   database: Database.Database = initialize_db(),\n362: ): MemoryRow[] {\n363:   const sqlite_vec = get_sqlite_vec_available();\n364:   if (!sqlite_vec) {\n365:     console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n366:     return [];\n367:   }\n368: \n369:   const {\n370:     limit = 10,\n371:     specFolder = null,\n372:     minSimilarity = 0,\n373:     useDecay = true,\n374:     tier = null,\n375:     contextType = null,\n376:     includeConstitutional = true,\n377:     includeArchived = false\n378:   } = options;\n379: \n380:   const vectorSource = getActiveVectorSourceForQuery(database);\n381:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n382:     throw new VectorIndexError(\n383:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n384:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n385:     );\n386:   }\n387: \n388:   const query_buffer = to_embedding_buffer(query_embedding);\n389:   const max_distance = 2 * (1 - minSimilarity / 100);\n390: \n391:   // FSRS-preferred decay with half-life fallback\n392:   const decay_expr = useDecay\n393:     ? `CASE\n394:          WHEN m.is_pinned = 1 THEN m.importance_weight\n395:          WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n396:            m.importance_weight * POWER(\n397:              1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n398:              -0.5\n399:            )\n400:          ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n401:        END`\n402:     : 'm.importance_weight';\n403: \n404:   let constitutional_results: MemoryRow[] = [];\n405: \n406:   if (includeConstitutional && tier !== 'constitutional') {\n407:     constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n408:   }\n409: \n410:   const where_clauses = ['m.embedding_status = \\'success\\''];\n411:   const params: unknown[] = [query_buffer];\n412: \n413:   where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n414: \n415:   if (tier === 'deprecated') {\n416:     where_clauses.push('m.importance_tier = ?');\n417:     params.push('deprecated');\n418:   } else if (tier === 'constitutional') {\n419:     where_clauses.push('m.importance_tier = ?');\n420:     params.push('constitutional');\n421:   } else if (tier) {\n422:     where_clauses.push('m.importance_tier = ?');\n423:     params.push(tier);\n424:   } else if (isArchivedVectorInclusionEnabled()) {\n425:     // Cold/archived rows admitted to the projection (option A) must not be re-excluded\n426:     // here; still keep constitutional on its own injected path.\n427:     where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier != \\'constitutional\\')');\n428:   } else {\n429:     where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n430:   }\n431: \n432:   appendSpecFolderScope(where_clauses, params, specFolder);\n433: \n434:   if (contextType) {\n435:     where_clauses.push('m.context_type = ?');\n436:     params.push(contextType);\n437:   }\n438: \n439:   // If constitutional results already satisfy limit, return them directly.\n440:   if (constitutional_results.length >= limit) {\n441:     return constitutional_results.slice(0, limit);\n442:   }\n443:   const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n444:   params.push(max_distance, adjusted_limit);\n445: \n446:   const sql = `\n447:     SELECT sub.*,\n448:            ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n449:     FROM (\n450:       SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n451:              ${decay_expr} as effective_importance\n452:       FROM memory_index m\n453:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n454:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n455:       WHERE ${where_clauses.join(' AND ')}\n456:     ) sub\n457:     WHERE sub.distance <= ?\n458:     ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n459:     LIMIT ?\n460:   `;\n461: \n462:   const rows = database.prepare(sql).all(...params);\n463: \n464:   const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n465:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n466:     row.isConstitutional = row.importance_tier === 'constitutional';\n467:     return row;\n468:   });\n469: \n470:   return [...constitutional_results, ...regular_results];\n471: }\n472: \n473: /**\n474:  * Gets constitutional memories for prompt assembly.\n475:  * @param options - Retrieval options.\n476:  * @returns The constitutional memory rows.\n477:  */\n478: export function get_constitutional_memories_public(\n479:   options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n480:   database: Database.Database = initialize_db(),\n481: ): MemoryRow[] {\n482:   const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n483: \n484:   let results = get_constitutional_memories(database, specFolder, includeArchived);\n485: \n486:   const TOKENS_PER_MEMORY = 100;\n487:   const max_count = Math.floor(maxTokens / TOKENS_PER_MEMORY);\n488:   if (results.length > max_count) {\n489:     results = results.slice(0, max_count);\n490:   }\n491: \n492:   return results;\n493: }\n494: \n495: /**\n496:  * Searches indexed memories with multiple concept embeddings.\n497:  * @param concept_embeddings - The concept embeddings to search with.\n498:  * @param options - Search options.\n499:  * @returns The matching memory rows.\n500:  * @throws {VectorIndexError} When concept count or embedding dimensions are invalid, or when store initialization fails.\n501:  * @example\n502:  * ```ts\n503:  * const rows = multi_concept_search([embA, embB], { limit: 8, specFolder: 'specs/001-demo' });\n504:  * ```\n505:  */\n506: export function multi_concept_search(\n507:   concept_embeddings: EmbeddingInput[],\n508:   options: { limit?: number; specFolder?: string | null; minSimilarity?: number } = {}\n509: ): MemoryRow[] {\n510:   const sqlite_vec = get_sqlite_vec_available();\n511:   if (!sqlite_vec) {\n512:     console.warn('[vector-index] Multi-concept search unavailable - sqlite-vec not loaded');\n513:     return [];\n514:   }\n515: \n516:   const database = initialize_db();\n517: \n518:   const concepts = concept_embeddings;\n519:   if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n520:     throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n521:   }\n522: \n523:   const vectorSource = getActiveVectorSourceForQuery(database);\n524:   for (const emb of concepts) {\n525:     if (!emb || emb.length !== vectorSource.dim) {\n526:       throw new VectorIndexError(\n527:         `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n528:         VectorIndexErrorCode.QUERY_FAILED,\n529:       );\n530:     }\n531:   }\n532: \n533:   const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n534: \n535:   const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n536:   const max_distance = 2 * (1 - minSimilarity / 100);\n537: \n538:   const distance_expressions = concept_buffers.map((_, i) =>\n539:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n540:   ).join(', ');\n541: \n542:   const distance_filters = concept_buffers.map((_, _i) =>\n543:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n544:   ).join(' AND ');\n545: \n546:   const folder_filter = specFolder ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\" : '';\n547:   const similarity_select = concept_buffers.map((_, i) =>\n548:     `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n549:   ).join(', ');\n550: \n551:   const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n552: \n553:   const sql = `\n554:     SELECT\n555:       sub.*,\n556:       ${similarity_select},\n557:       (${avg_distance_expr}) / ${concepts.length} as avg_distance\n558:     FROM (\n559:       SELECT\n560:         m.*,\n561:         ${distance_expressions}\n562:       FROM memory_index m\n563:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n564:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n565:       WHERE m.embedding_status = 'success'\n566:         AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n567:         ${folder_filter}\n568:         AND ${distance_filters}\n569:     ) sub\n570:     ORDER BY avg_distance ASC\n571:     LIMIT ?\n572:   `;\n573: \n574:   const params = [\n575:     ...concept_buffers,\n576:     ...(specFolder ? [specFolder, specFolderLikePattern(specFolder)] : []),\n577:     ...concept_buffers.flatMap(b => [b, max_distance]),\n578:     limit\n579:   ];\n580: \n581:   const rows = database.prepare(sql).all(...params);\n582: \n583:   return (rows as MemoryRow[]).map((row: MemoryRow) => {\n584:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n585:     row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n586:     row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n587:     row.isConstitutional = row.importance_tier === 'constitutional';\n588:     return row;\n589:   });\n590: }\n591: \n592: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n593:    CONTENT EXTRACTION HELPERS\n594: ----------------------------------------------------------------*/\n595: \n596: /**\n597:  * Extracts a display title from indexed content.\n598:  * @param content - The content to inspect.\n599:  * @param filename - The optional source filename.\n600:  * @returns The extracted title.\n601:  */\n602: export function extract_title(content: unknown, filename?: string): string {\n603:   if (!content || typeof content !== 'string') {\n604:     return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n605:   }\n606: \n607:   const h1_match = content.match(/^#\\s+(.+)$/m);\n608:   if (h1_match && h1_match[1]) {\n609:     return h1_match[1].trim();\n610:   }\n611: \n612:   const h2_match = content.match(/^##\\s+(.+)$/m);\n613:   if (h2_match && h2_match[1]) {\n614:     return h2_match[1].trim();\n615:   }\n616: \n617:   const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n618:   if (yaml_match && yaml_match[1]) {\n619:     return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n620:   }\n621: \n622:   const lines = content.split('\\n').filter(l => l.trim().length > 0);\n623:   if (lines.length > 0) {\n624:     const first_line = lines[0].trim();\n625:     return first_line.replace(/^#+\\s*/, '').substring(0, 100);\n626:   }\n627: \n628:   return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n629: }\n630: \n631: /**\n632:  * Extracts a preview snippet from indexed content.\n633:  * @param content - The content to inspect.\n634:  * @param max_length - The maximum snippet length.\n635:  * @returns The extracted snippet.\n636:  */\n637: export function extract_snippet(content: unknown, max_length = 200): string {\n638:   if (!content || typeof content !== 'string') {\n639:     return '';\n640:   }\n641: \n642:   const text = content.replace(/^---[\\s\\S]*?---\\n*/m, '');\n643:   const lines = text.split('\\n');\n644:   const snippet_lines: string[] = [];\n645: \n646:   for (const line of lines) {\n647:     const trimmed = line.trim();\n648: \n649:     if (!trimmed || /^#+\\s/.test(trimmed)) {\n650:       if (snippet_lines.length > 0) {\n651:         break;\n652:       }\n653:       continue;\n654:     }\n655: \n656:     if (/^[a-z_-]+:\\s/i.test(trimmed) && snippet_lines.length === 0) {\n657:       continue;\n658:     }\n659: \n660:     snippet_lines.push(trimmed);\n661: \n662:     const current_length = snippet_lines.join(' ').length;\n663:     if (current_length >= max_length) {\n664:       break;\n665:     }\n666:   }\n667: \n668:   let snippet = snippet_lines.join(' ');\n669: \n670:   if (snippet.length > max_length) {\n671:     snippet = snippet.substring(0, max_length);\n672:     const last_space = snippet.lastIndexOf(' ');\n673:     if (last_space > max_length * 0.7) {\n674:       snippet = snippet.substring(0, last_space);\n675:     }\n676:     snippet += '...';\n677:   }\n678: \n679:   return snippet;\n680: }\n681: \n682: /**\n683:  * Extracts tags from indexed content.\n684:  * @param content - The content to inspect.\n685:  * @returns The extracted tags.\n686:  */\n687: export function extract_tags(content: unknown): string[] {\n688:   if (!content || typeof content !== 'string') {\n689:     console.warn('[vector-index] extract_tags: invalid content type, expected string');\n690:     return [];\n691:   }\n692: \n693:   const tags = new Set<string>();\n694: \n695:   const yaml_tags_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\[([^\\]]+)\\]/m);\n696:   if (yaml_tags_match && yaml_tags_match[1]) {\n697:     yaml_tags_match[1].split(',').forEach(tag => {\n698:       const cleaned = tag.trim().replace(/^[\"']|[\"']$/g, '');\n699:       if (cleaned) tags.add(cleaned.toLowerCase());\n700:     });\n701:   }\n702: \n703:   const yaml_list_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/m);\n704:   if (yaml_list_match && yaml_list_match[1]) {\n705:     yaml_list_match[1].match(/-\\s*(.+)/g)?.forEach(match => {\n706:       const tag = match.replace(/^-\\s*/, '').trim().replace(/^[\"']|[\"']$/g, '');\n707:       if (tag) tags.add(tag.toLowerCase());\n708:     });\n709:   }\n710: \n711:   const hashtag_matches = content.match(/(?:^|\\s)#([a-zA-Z][a-zA-Z0-9_-]*)/g);\n712:   if (hashtag_matches) {\n713:     hashtag_matches.forEach(match => {\n714:       const tag = match.trim().replace(/^#/, '');\n715:       if (tag && !tag.match(/^[0-9]+$/)) {\n716:         tags.add(tag.toLowerCase());\n717:       }\n718:     });\n719:   }\n720: \n721:   return Array.from(tags);\n722: }\n723: \n724: /**\n725:  * Extracts a relevant date from indexed content or path.\n726:  * @param content - The content to inspect.\n727:  * @param file_path - The optional source file path.\n728:  * @returns The extracted date, if available.\n729:  */\n730: export function extract_date(content: unknown, file_path?: string): string | null {\n731:   if (content && typeof content === 'string') {\n732:     const date_match = content.match(/^---[\\s\\S]*?^date:\\s*(.+)$/m);\n733:     if (date_match && date_match[1]) {\n734:       const date_str = date_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n735:       try {\n736:         const parsed = new Date(date_str);\n737:         if (!isNaN(parsed.getTime())) {\n738:           return parsed.toISOString().split('T')[0];\n739:         }\n740:       } catch (_e: unknown) {\n741:         console.warn('[vector-index-queries] Date parsing failed', { error: _e instanceof Error ? _e.message : String(_e) });\n742:       }\n743:     }\n744:   }\n745: \n746:   if (file_path) {\n747:     const filename = path.basename(file_path);\n748: \n749:     const iso_match = filename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n750:     if (iso_match) {\n751:       return iso_match[1];\n752:     }\n753: \n754:     const ddmmyy_match = filename.match(/(\\d{2})-(\\d{2})-(\\d{2})/);\n755:     if (ddmmyy_match) {\n756:       const [, day, month, year] = ddmmyy_match;\n757:       const full_year = parseInt(year) > 50 ? `19${year}` : `20${year}`;\n758:       return `${full_year}-${month}-${day}`;\n759:     }\n760:   }\n761: \n762:   return null;\n763: }\n764: \n765: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n766:    EMBEDDING GENERATION WRAPPER\n767: ----------------------------------------------------------------*/\n768: \n769: /**\n770:  * Generates an embedding for a search query.\n771:  * @param query - The search query.\n772:  * @returns A promise that resolves to the embedding, if generated.\n773:  */\n774: export async function generate_query_embedding(query: string): Promise<Float32Array | null> {\n775:   if (!query || typeof query !== 'string' || query.trim().length === 0) {\n776:     console.warn('[vector-index] Empty query provided for embedding');\n777:     return null;\n778:   }\n779: \n780:   try {\n781:     const database = initialize_db();\n782:     const active = getActiveEmbedder(database);\n783:     const trimmedQuery = query.trim();\n784:     const modelId = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n785:       ? active.name\n786:       : embeddingsProvider.getModelName();\n787:     const embeddingDim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n788:       ? active.dim\n789:       : embeddingsProvider.getEmbeddingDimension();\n790:     const profileKey = getActiveEmbeddingProfileKey(database, modelId, embeddingDim);\n791:     const contentHash = computeContentHash(trimmedQuery);\n792:     const cached = lookupEmbedding(database, contentHash, modelId, embeddingDim, {\n793:       profileKey,\n794:       inputKind: 'query',\n795:     });\n796:     if (cached) {\n797:       return new Float32Array(\n798:         cached.buffer,\n799:         cached.byteOffset,\n800:         Math.floor(cached.byteLength / Float32Array.BYTES_PER_ELEMENT),\n801:       );\n802:     }\n803: \n804:     const provider = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n805:       ? active.provider ?? getManifest(active.name)?.backend ?? 'ollama'\n806:       : getStartupEmbeddingProfile().provider;\n807:     const adapter = getEmbedderAdapter(provider, modelId, embeddingDim);\n808:     const activeAdapter = adapter as typeof adapter & {\n809:       embed: (\n810:         texts: ReadonlyArray<string>,\n811:         options?: { inputType?: 'query' | 'document' },\n812:       ) => Promise<Float32Array[]>;\n813:     };\n814:     const [activeEmbedding] = await activeAdapter.embed([trimmedQuery], { inputType: 'query' });\n815:     const embedding: Float32Array | null = activeEmbedding ?? null;\n816: \n817:     if (embedding) {\n818:       storeEmbedding(\n819:         database,\n820:         contentHash,\n821:         modelId,\n822:         Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n823:         embedding.length,\n824:         { profileKey, inputKind: 'query' },\n825:       );\n826:     }\n827: \n828:     return embedding;\n829:   } catch (error: unknown) {\n830:     console.warn(`[vector-index] Query embedding failed: ${get_error_message(error)}`);\n831:     return null;\n832:   }\n833: }\n834: \n835: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n836:    KEYWORD SEARCH FALLBACK\n837: ----------------------------------------------------------------*/\n838: \n839: /**\n840:  * Searches indexed memories using keyword matching.\n841:  * @param query - The search query.\n842:  * @param options - Search options.\n843:  * @returns The matching memory rows.\n844:  */\n845: export function keyword_search(\n846:   query: string,\n847:   options: { limit?: number; specFolder?: string | null } = {},\n848:   database: Database.Database = initialize_db(),\n849: ): MemoryRow[] {\n850:   const { limit = 20, specFolder = null } = options;\n851: \n852:   if (!query || typeof query !== 'string') {\n853:     console.warn('[vector-index] keyword_search: invalid query, expected non-empty string');\n854:     return [];\n855:   }\n856: \n857:   const search_terms = query.toLowerCase().trim().split(/\\s+/).filter(t => t.length >= 2);\n858:   if (search_terms.length === 0) {\n859:     console.warn('[vector-index] keyword_search: no valid search terms after tokenization');\n860:     return [];\n861:   }\n862: \n863:   let where_clause = '1=1';\n864:   const params: unknown[] = [];\n865: \n866:   if (specFolder) {\n867:     where_clause += \" AND (spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')\";\n868:     params.push(specFolder, specFolderLikePattern(specFolder));\n869:   }\n870: \n871:   const sql = `\n872:     SELECT m.* FROM memory_index m\n873:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n874:     WHERE ${where_clause}\n875:     ORDER BY m.importance_weight DESC, m.created_at DESC\n876:   `;\n877: \n878:   const rows = database.prepare(sql).all(...params);\n879: \n880:   const scored = (rows as MemoryRow[]).map((row: MemoryRow) => {\n881:     let score = 0;\n882:     const searchable_text = [\n883:       row.title || '',\n884:       parse_trigger_phrases(row.trigger_phrases).join(' '),\n885:       row.spec_folder || '',\n886:       row.file_path || ''\n887:     ].join(' ').toLowerCase();\n888: \n889:     for (const term of search_terms) {\n890:       if (searchable_text.includes(term)) {\n891:         score += 1;\n892:         if ((row.title || '').toLowerCase().includes(term)) {\n893:           score += 2;\n894:         }\n895:         if (parse_trigger_phrases(row.trigger_phrases).join(' ').toLowerCase().includes(term)) {\n896:           score += 1.5;\n897:         }\n898:       }\n899:     }\n900: \n901:     score *= (0.5 + (row.importance_weight ?? 0));\n902:     return { ...row, keyword_score: score };\n903:   });\n904: \n905:   const filtered = scored\n906:     .filter((row: MemoryRow) => Number(row.keyword_score ?? 0) > 0)\n907:     .sort((a: MemoryRow, b: MemoryRow) => Number(b.keyword_score ?? 0) - Number(a.keyword_score ?? 0))\n908:     .slice(0, limit);\n909: \n910:   return filtered.map((row: MemoryRow) => {\n911:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n912:     row.isConstitutional = row.importance_tier === 'constitutional';\n913:     return row;\n914:   });\n915: }\n916: \n917: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n918:    ENRICHED VECTOR SEARCH\n919: ----------------------------------------------------------------*/\n920: \n921: /**\n922:  * Runs enriched vector search for a text query.\n923:  * @param query - The search query.\n924:  * @param limit - The maximum number of results to return.\n925:  * @param options - Search options.\n926:  * @returns A promise that resolves to enriched search results.\n927:  * @throws {VectorIndexError} Propagates vector-store initialization failures from the underlying search pipeline.\n928:  * @example\n929:  * ```ts\n930:  * const results = await vector_search_enriched('sqlite vec mismatch', 10, { specFolder: 'specs/001-demo' });\n931:  * ```\n932:  */\n933: export async function vector_search_enriched(\n934:   query: string,\n935:   limit = 20,\n936:   options: { specFolder?: string | null; minSimilarity?: number } = {},\n937:   database: Database.Database = initialize_db(),\n938: ): Promise<EnrichedSearchResult[]> {\n939:   const start_time = Date.now();\n940:   const { specFolder = null, minSimilarity = 30 } = options;\n941: \n942:   const query_embedding = await generate_query_embedding(query);\n943: \n944:   let raw_results;\n945:   let search_method = 'vector';\n946: \n947:   const sqlite_vec = get_sqlite_vec_available();\n948:   if (query_embedding && sqlite_vec) {\n949:     raw_results = vector_search(query_embedding, {\n950:       limit,\n951:       specFolder,\n952:       minSimilarity\n953:     }, database);\n954:   } else {\n955:     console.warn('[vector-index] Falling back to keyword search');\n956:     search_method = 'keyword';\n957:     raw_results = keyword_search(query, { limit, specFolder }, database);\n958:   }\n959: \n960:   // HIGH-004 FIX: Read all files concurrently\n961:   const file_contents = await Promise.all(\n962:     raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n963:   );\n964: \n965:   const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n966:     const content = file_contents[i];\n967:     const title = row.title || extract_title(content, row.file_path);\n968:     const snippet = extract_snippet(content);\n969:     const tags = extract_tags(content);\n970:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n971: \n972:     const similarity = search_method === 'vector'\n973:       ? (row.similarity || 0)\n974:       : Math.min(100, (row.keyword_score || 0) * 20);\n975: \n976:     return {\n977:       rank: i + 1,\n978:       similarity: Math.round(similarity * 100) / 100,\n979:       title,\n980:       specFolder: row.spec_folder,\n981:       filePath: row.file_path,\n982:       date,\n983:       tags,\n984:       snippet,\n985:       id: row.id,\n986:       importanceWeight: row.importance_weight ?? 0.5,\n987:       searchMethod: search_method,\n988:       isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n989:     };\n990:   });\n991: \n992:   const elapsed = Date.now() - start_time;\n993:   if (elapsed > 500) {\n994:     console.warn(`[vector-index] Enriched search took ${elapsed}ms (target <500ms)`);\n995:   }\n996: \n997:   return enriched_results;\n998: }\n999: \n1000: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n1001:    MULTI-CONCEPT ENRICHED SEARCH\n1002: ----------------------------------------------------------------*/\n1003: \n1004: /**\n1005:  * Runs enriched search across multiple concepts.\n1006:  * @param concepts - The concept queries or embeddings.\n1007:  * @param limit - The maximum number of results to return.\n1008:  * @param options - Search options.\n1009:  * @returns A promise that resolves to enriched search results.\n1010:  * @throws {VectorIndexError} When concept validation fails or the vector search pipeline cannot execute.\n1011:  * @example\n1012:  * ```ts\n1013:  * const results = await multi_concept_search_enriched(['sqlite', 'vector'], 10, { specFolder: 'specs/001-demo' });\n1014:  * ```\n1015:  */\n1016: export async function multi_concept_search_enriched(\n1017:   concepts: Array<string | EmbeddingInput>,\n1018:   limit = 20,\n1019:   options: { specFolder?: string | null; minSimilarity?: number } = {}\n1020: ): Promise<EnrichedSearchResult[]> {\n1021:   const start_time = Date.now();\n1022: \n1023:   if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n1024:     throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n1025:   }\n1026: \n1027:   const { specFolder = null, minSimilarity = 50 } = options;\n1028: \n1029:   const concept_embeddings: EmbeddingInput[] = [];\n1030:   for (const concept of concepts) {\n1031:     if (typeof concept === 'string') {\n1032:       const embedding = await generate_query_embedding(concept);\n1033:       if (!embedding) {\n1034:         console.warn(`[vector-index] Failed to embed concept: \"${concept}\"`);\n1035:         return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n1036:       }\n1037:       concept_embeddings.push(embedding);\n1038:     } else {\n1039:       concept_embeddings.push(concept);\n1040:     }\n1041:   }\n1042: \n1043:   const sqlite_vec = get_sqlite_vec_available();\n1044:   if (!sqlite_vec) {\n1045:     console.warn('[vector-index] Falling back to keyword multi-concept search');\n1046:     return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n1047:   }\n1048: \n1049:   const raw_results = multi_concept_search(concept_embeddings, { limit, specFolder, minSimilarity });\n1050: \n1051:   const file_contents = await Promise.all(\n1052:     raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n1053:   );\n1054: \n1055:   const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n1056:     const content = file_contents[i];\n1057:     const title = row.title || extract_title(content, row.file_path);\n1058:     const snippet = extract_snippet(content);\n1059:     const tags = extract_tags(content);\n1060:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n1061: \n1062:     return {\n1063:       rank: i + 1,\n1064:       avgSimilarity: Math.round((row.avg_similarity || 0) * 100) / 100,\n1065:       conceptSimilarities: (row.concept_similarities as number[] | undefined) || [],\n1066:       title,\n1067:       specFolder: row.spec_folder,\n1068:       filePath: row.file_path,\n1069:       date,\n1070:       tags,\n1071:       snippet,\n1072:       id: row.id,\n1073:       importanceWeight: row.importance_weight ?? 0.5,\n1074:       isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n1075:     };\n1076:   });\n1077: \n1078:   const elapsed = Date.now() - start_time;\n1079:   if (elapsed > 500) {\n1080:     console.warn(`[vector-index] Multi-concept search took ${elapsed}ms (target <500ms)`);\n1081:   }\n1082: \n1083:   return enriched_results;\n1084: }\n1085: \n1086: /**\n1087:  * Runs keyword search for multiple concepts.\n1088:  * @param concepts - The concept terms to search for.\n1089:  * @param limit - The maximum number of results to return.\n1090:  * @param options - Search options.\n1091:  * @returns A promise that resolves to enriched search results.\n1092:  */\n1093: export async function multi_concept_keyword_search(\n1094:   concepts: string[],\n1095:   limit = 20,\n1096:   options: { specFolder?: string | null } = {}\n1097: ): Promise<EnrichedSearchResult[]> {\n1098:   const { specFolder = null } = options;\n1099: \n1100:   if (!concepts.length) {\n1101:     console.warn('[vector-index] multi_concept_keyword_search: empty concepts array');\n1102:     return [];\n1103:   }\n1104: \n1105:   const concept_results = concepts.map((concept: string) =>\n1106:     keyword_search(concept, { limit: 100, specFolder })\n1107:   );\n1108: \n1109:   const id_counts = new Map<number, number>();\n1110:   const id_to_row = new Map<number, MemoryRow>();\n1111: \n1112:   for (const results of concept_results) {\n1113:     for (const row of results) {\n1114:       const count = id_counts.get(row.id) || 0;\n1115:       id_counts.set(row.id, count + 1);\n1116:       if (!id_to_row.has(row.id)) {\n1117:         id_to_row.set(row.id, row);\n1118:       }\n1119:     }\n1120:   }\n1121: \n1122:   const matching_ids: number[] = [];\n1123:   for (const [id, count] of id_counts) {\n1124:     if (count === concepts.length) {\n1125:       matching_ids.push(id);\n1126:     }\n1127:   }\n1128: \n1129:   const limited_ids = matching_ids.slice(0, limit);\n1130:   const rows = limited_ids.map(id => id_to_row.get(id)).filter((row): row is MemoryRow => Boolean(row));\n1131: \n1132:   const file_contents = await Promise.all(\n1133:     rows.map(row => safe_read_file_async(row.file_path))\n1134:   );\n1135: \n1136:   const enriched_results = rows.map((row, i) => {\n1137:     const content = file_contents[i];\n1138:     const title = row.title || extract_title(content, row.file_path);\n1139:     const snippet = extract_snippet(content);\n1140:     const tags = extract_tags(content);\n1141:     const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n1142: \n1143:     return {\n1144:       rank: i + 1,\n1145:       avgSimilarity: Math.min(100, (row.keyword_score || 1) * 15),\n1146:       conceptSimilarities: concepts.map(() => row.keyword_score || 1),\n1147:       title,\n1148:       specFolder: row.spec_folder,\n1149:       filePath: row.file_path,\n1150:       date,\n1151:       tags,\n1152:       snippet,\n1153:       id: row.id,\n1154:       importanceWeight: row.importance_weight ?? 0.5,\n1155:       searchMethod: 'keyword',\n1156:       isConstitutional: row.importance_tier === 'constitutional'\n1157:     };\n1158:   });\n1159: \n1160:   return enriched_results;\n1161: }\n1162: \n1163: /**\n1164:  * Parses quoted phrases from a search query.\n1165:  * @param query - The search query.\n1166:  * @returns The quoted search terms.\n1167:  */\n1168: export function parse_quoted_terms(query: string): string[] {\n1169:   if (!query || typeof query !== 'string') {\n1170:     console.warn('[vector-index] parse_quoted_terms: invalid query, expected non-empty string');\n1171:     return [];\n1172:   }\n1173: \n1174:   const quoted: string[] = [];\n1175:   const regex = /\"([^\"]+)\"/g;\n1176:   let match;\n1177: \n1178:   while ((match = regex.exec(query)) !== null) {\n1179:     if (match[1] && match[1].trim()) {\n1180:       quoted.push(match[1].trim());\n1181:     }\n1182:   }\n1183: \n1184:   return quoted;\n1185: }\n1186: \n1187: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n1188:    SMART RANKING AND DIVERSITY\n1189: ----------------------------------------------------------------*/\n1190: \n1191: // Weights read from config instead of hardcoded\n1192: /**\n1193:  * Applies smart ranking weights to enriched results.\n1194:  * @param results - The results to rank.\n1195:  * @returns The ranked results.\n1196:  */\n1197: export function apply_smart_ranking(results: EnrichedSearchResult[]): EnrichedSearchResult[] {\n1198:   if (!results || results.length === 0) return results;\n1199: \n1200:   const recency_weight = search_weights.smartRanking?.recencyWeight || 0.3;\n1201:   const access_weight = search_weights.smartRanking?.accessWeight || 0.2;\n1202:   const relevance_weight = search_weights.smartRanking?.relevanceWeight || 0.5;\n1203: \n1204:   const now = Date.now();\n1205:   const week_ms = 7 * 24 * 60 * 60 * 1000;\n1206:   const month_ms = 30 * 24 * 60 * 60 * 1000;\n1207: \n1208:   return results.map((r: EnrichedSearchResult) => {\n1209:     const created_at = r.created_at ? new Date(r.created_at).getTime() : now;\n1210:     const age = now - created_at;\n1211:     let recency_factor;\n1212:     if (age < week_ms) {\n1213:       recency_factor = 1.0;\n1214:     } else if (age < month_ms) {\n1215:       recency_factor = 0.8;\n1216:     } else {\n1217:       recency_factor = 0.5;\n1218:     }\n1219: \n1220:     const usage_factor = Math.min(1.0, (r.access_count || 0) / 10);\n1221:     const similarity_factor = (r.similarity || 0) / 100;\n1222: \n1223:     r.smartScore = (similarity_factor * relevance_weight) + (recency_factor * recency_weight) + (usage_factor * access_weight);\n1224:     r.smartScore = Math.round(r.smartScore * 100) / 100;\n1225: \n1226:     return r;\n1227:   }).sort((a, b) => Number(b.smartScore ?? 0) - Number(a.smartScore ?? 0));\n1228: }\n1229: \n1230: // Apply diversity filtering using MMR (Maximal Marginal Relevance)\n1231: /**\n1232:  * Applies diversity reordering to enriched results.\n1233:  * @param results - The results to diversify.\n1234:  * @param diversity_factor - The diversity weight to apply.\n1235:  * @returns The diversified results.\n1236:  */\n1237: export function apply_diversity(results: EnrichedSearchResult[], diversity_factor = 0.3): EnrichedSearchResult[] {\n1238:   if (!results || results.length <= 3) return results;\n1239: \n1240:   const selected = [results[0]];\n1241:   const remaining = [...results.slice(1)];\n1242: \n1243:   while (selected.length < results.length && remaining.length > 0) {\n1244:     let best_idx = 0;\n1245:     let best_score = -Infinity;\n1246: \n1247:     for (let i = 0; i < remaining.length; i++) {\n1248:       const candidate = remaining[i];\n1249:       const relevance = candidate.smartScore || ((candidate.similarity ?? 0) / 100) || 0;\n1250: \n1251:       let max_similarity_to_selected = 0;\n1252:       for (const sel of selected) {\n1253:         if (sel.specFolder === candidate.specFolder || sel.spec_folder === candidate.spec_folder) {\n1254:           max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.8);\n1255:         }\n1256:         if (sel.date === candidate.date) {\n1257:           max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.5);\n1258:         }\n1259:       }\n1260: \n1261:       const mmr_score = relevance - (diversity_factor * max_similarity_to_selected);\n1262: \n1263:       if (mmr_score > best_score) {\n1264:         best_score = mmr_score;\n1265:         best_idx = i;\n1266:       }\n1267:     }\n1268: \n1269:     selected.push(remaining.splice(best_idx, 1)[0]);\n1270:   }\n1271: \n1272:   return selected;\n1273: }\n1274: \n1275: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n1276:    RELATED MEMORIES AND USAGE TRACKING\n1277: ----------------------------------------------------------------*/\n1278: \n1279: /**\n1280:  * Gets memories related to a stored memory.\n1281:  * @param memory_id - The memory identifier.\n1282:  * @returns The related memory rows.\n1283:  */\n1284: export function get_related_memories(memory_id: number): MemoryRow[] {\n1285:   try {\n1286:     const database = initialize_db();\n1287: \n1288:     const memory = database.prepare(`\n1289:       SELECT related_memories FROM memory_index WHERE id = ?\n1290:     `).get(memory_id) as { related_memories?: string | null } | undefined;\n1291: \n1292:     if (!memory || !memory.related_memories) {\n1293:       return [];\n1294:     }\n1295: \n1296:     const related = safe_parse_json(memory.related_memories, []);\n1297: \n1298:     return (related as RelatedMemoryLink[]).map((rel: RelatedMemoryLink): MemoryRow | null => {\n1299:       const full_memory = get_memory(rel.id);\n1300:       if (full_memory) {\n1301:         return {\n1302:           ...full_memory,\n1303:           relationSimilarity: rel.similarity\n1304:         };\n1305:       }\n1306:       return null;\n1307:     }).filter((relatedMemory): relatedMemory is MemoryRow => Boolean(relatedMemory));\n1308:   } catch (error: unknown) {\n1309:     console.warn(`[vector-index] Failed to get related memories for ${memory_id}: ${get_error_message(error)}`);\n1310:     return [];\n1311:   }\n1312: }\n1313: \n1314: /**\n1315:  * Gets usage statistics for indexed memories.\n1316:  * @param options - Sorting and limit options.\n1317:  * @returns The usage statistics rows.\n1318:  */\n1319: export function get_usage_stats(options: UsageStatsOptions = {}): Array<{ id: number; title: string | null; spec_folder: string; file_path: string; access_count: number; last_accessed: number | null; confidence: number | null; created_at: string }> {\n1320:   const {\n1321:     sortBy = 'access_count',\n1322:     order = 'DESC',\n1323:     limit = 20\n1324:   } = options;\n1325: \n1326:   const valid_sort_fields = ['access_count', 'last_accessed', 'confidence'];\n1327:   const sort_field = valid_sort_fields.includes(sortBy) ? sortBy : 'access_count';\n1328:   const sort_order = order.toUpperCase() === 'ASC' ? 'ASC' : 'DESC';\n1329: \n1330:   const database = initialize_db();\n1331: \n1332:   const rows = database.prepare(`\n1333:     SELECT id, title, spec_folder, file_path, access_count,\n1334:            last_accessed, confidence, created_at\n1335:     FROM memory_index\n1336:     WHERE access_count > 0\n1337:     ORDER BY ${sort_field} ${sort_order}\n1338:     LIMIT ?\n1339:   `).all(limit) as Array<{\n1340:     id: number;\n1341:     title: string | null;\n1342:     spec_folder: string;\n1343:     file_path: string;\n1344:     access_count: number;\n1345:     last_accessed: number | null;\n1346:     confidence: number | null;\n1347:     created_at: string;\n1348:   }>;\n1349: \n1350:   return rows;\n1351: }\n1352: \n1353: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n1354:    CLEANUP FUNCTIONS\n1355: ----------------------------------------------------------------*/\n1356: \n1357: /**\n1358:  * Finds memory records that are candidates for cleanup.\n1359:  * @param options - Cleanup thresholds and limits.\n1360:  * @returns The cleanup candidate details.\n1361:  */\n1362: export function find_cleanup_candidates(options: CleanupOptions = {}): Array<{ id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; reasons: string[] }> {\n1363:   const database = initialize_db();\n1364: \n1365:   const {\n1366:     maxAgeDays = 90,\n1367:     maxAccessCount = 2,\n1368:     maxConfidence = 0.4,\n1369:     limit = 50\n1370:   } = options;\n1371: \n1372:   const cutoff_date = new Date();\n1373:   cutoff_date.setDate(cutoff_date.getDate() - maxAgeDays);\n1374:   const cutoff_iso = cutoff_date.toISOString();\n1375: \n1376:   const sql = `\n1377:     SELECT\n1378:       id,\n1379:       spec_folder,\n1380:       file_path,\n1381:       title,\n1382:       created_at,\n1383:       last_accessed,\n1384:       access_count,\n1385:       confidence,\n1386:       importance_weight\n1387:     FROM memory_index\n1388:     WHERE\n1389:       created_at < ?\n1390:       OR access_count <= ?\n1391:       OR confidence <= ?\n1392:       OR (last_accessed IS NULL AND created_at < ?)\n1393:     ORDER BY\n1394:       last_accessed ASC NULLS FIRST,\n1395:       access_count ASC,\n1396:       confidence ASC\n1397:     LIMIT ?\n1398:   `;\n1399: \n1400:   let rows;\n1401:   try {\n1402:     rows = database.prepare(sql).all(\n1403:       cutoff_iso,\n1404:       maxAccessCount,\n1405:       maxConfidence,\n1406:       cutoff_iso,\n1407:       limit\n1408:     );\n1409:   } catch (e: unknown) {\n1410:     console.warn(`[vector-index] find_cleanup_candidates error: ${get_error_message(e)}`);\n1411:     return [];\n1412:   }\n1413: \n1414:   return (rows as MemoryRow[]).map((row: MemoryRow) => {\n1415:     const age_string = format_age_string(row.created_at ?? null);\n1416:     const last_access_string = format_age_string(\n1417:       typeof row.last_accessed === 'number' ? new Date(row.last_accessed).toISOString() : null\n1418:     );\n1419: \n1420:     const reasons: string[] = [];\n1421:     if (row.created_at && new Date(row.created_at) < cutoff_date) {\n1422:       reasons.push(`created ${age_string}`);\n1423:     }\n1424:     if ((row.access_count || 0) <= maxAccessCount) {\n1425:       const count = row.access_count || 0;\n1426:       reasons.push(`accessed ${count} time${count !== 1 ? 's' : ''}`);\n1427:     }\n1428:     if ((row.confidence || 0.5) <= maxConfidence) {\n1429:       reasons.push(`low importance (${Math.round((row.confidence || 0.5) * 100)}%)`);\n1430:     }\n1431: \n1432:     return {\n1433:       id: row.id,\n1434:       specFolder: row.spec_folder,\n1435:       filePath: row.file_path,\n1436:       title: row.title || 'Untitled',\n1437:       createdAt: row.created_at,\n1438:       lastAccessedAt: row.last_accessed,\n1439:       accessCount: row.access_count || 0,\n1440:       confidence: row.confidence || 0.5,\n1441:       ageString: age_string,\n1442:       lastAccessString: last_access_string,\n1443:       reasons\n1444:     };\n1445:   });\n1446: }\n1447: \n1448: /**\n1449:  * Builds a preview payload for a stored memory.\n1450:  * @param memory_id - The memory identifier.\n1451:  * @param max_lines - The maximum number of file lines to include.\n1452:  * @returns The memory preview, if found.\n1453:  */\n1454: export function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n1455:   const database = initialize_db();\n1456: \n1457:   let memory: MemoryRow | undefined;\n1458:   try {\n1459:     memory = database.prepare(`\n1460:       SELECT * FROM memory_index WHERE id = ?\n1461:     `).get(memory_id) as MemoryRow | undefined;\n1462:   } catch (e: unknown) {\n1463:     console.warn(`[vector-index] get_memory_preview query error: ${get_error_message(e)}`);\n1464:     return null;\n1465:   }\n1466: \n1467:   if (!memory) return null;\n1468: \n1469:   let content = '';\n1470:   try {\n1471:     // Validate DB-stored file paths before reading\n1472:     if (memory.file_path) {\n1473:       const valid_path = validate_file_path_local(memory.file_path);\n1474:       if (valid_path && fs.existsSync(valid_path)) {\n1475:         const full_content = fs.readFileSync(valid_path, 'utf-8');\n1476:         const lines = full_content.split('\\n');\n1477:         content = lines.slice(0, max_lines).join('\\n');\n1478:         if (lines.length > max_lines) {\n1479:           content += `\\n... (${lines.length - max_lines} more lines)`;\n1480:         }\n1481:       }\n1482:     }\n1483:   } catch (e: unknown) {\n1484:     console.warn('[vector-index] get_memory_preview file read warning', {\n\n(Output capped at 50 KB. Showing lines 1-1484. Use offset=1485 to continue.)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Vector Index Queries\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts вҖ” contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport { isArchivedVectorInclusionEnabled } from './search-flags.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Vector Index Queries\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts вҖ” contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport { isArchivedVectorInclusionEnabled } from './search-flags.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport {\n  get_error_message,\n  parse_trigger_phrases,\n  specFolderLikePattern,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  initialize_db,\n  get_embedding_dim,\n  get_constitutional_memories,\n  init_prepared_statements,\n  validate_file_path_local,\n  safe_read_file_async,\n  safe_parse_json,\n  search_weights,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource as activeVectorSchema,\n} from './vector-index-store.js';\nimport { delete_memory_from_database } from './vector-index-mutations.js';\nimport type {\n  EmbeddingInput,\n  EnrichedSearchResult,\n  MemoryRow,\n  VectorSearchOptions,\n} from './vector-index-types.js';\n\nconst logger = createLogger('VectorIndex');\n\ntype RelatedMemoryLink = { id: number; similarity: number };\ntype UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\ntype CleanupOptions = {\n  maxAgeDays?: number;\n  maxAccessCount?: number;\n  maxConfidence?: number;\n  limit?: number;\n};\ntype VectorSource = {\n  dim: number;\n  tableName: string;\n  idColumn: string;\n  embeddingColumn: string;\n};\n\nexport interface KnnQueryShapeBenchmarkResult {\n  readonly corpusSize: number;\n  readonly iterations: number;\n  readonly scalarJoinAverageMs: number;\n  readonly matchAverageMs: number | null;\n  readonly matchSupported: boolean;\n  readonly matchImprovementPct: number | null;\n  readonly decision: 'adopt_match' | 'keep_scalar_join';\n  readonly reason: string;\n}\n\nconst KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n\nfunction appendSpecFolderScope(\n  clauses: string[],\n  params: unknown[],\n  specFolder: string | null | undefined,\n  column = 'm.spec_folder',\n): void {\n  if (!specFolder) return;\n  clauses.push(`(${column} = ? OR ${column} LIKE ? ESCAPE '\\\\')`);\n  params.push(specFolder, specFolderLikePattern(specFolder));\n}\n\nfunction tableExists(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS found\n    FROM active_vec.sqlite_master\n    WHERE type = 'table' AND name = ?\n    LIMIT 1\n  `).get(tableName) as { found?: number } | undefined;\n  return row?.found === 1;\n}\n\nfunction getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n  const active = getActiveEmbedder(database);\n  const dimTableName = `vec_${active.dim}`;\n  if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n    return {\n      dim: active.dim,\n      tableName: activeVectorSchema(dimTableName),\n      idColumn: 'id',\n      embeddingColumn: 'vec',\n    };\n  }\n\n  return {\n    dim: get_embedding_dim(),\n    tableName: activeVectorSchema('vec_memories'),\n    idColumn: 'rowid',\n    embeddingColumn: 'embedding',\n  };\n}\n\nfunction elapsedMs(start: bigint): number {\n  return Number(process.hrtime.bigint() - start) / 1_000_000;\n}\n\nfunction average(values: number[]): number {\n  if (values.length === 0) return 0;\n  return values.reduce((sum, value) => sum + value, 0) / values.length;\n}\n\nexport function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n  return result.matchSupported === true\n    && typeof result.matchImprovementPct === 'number'\n    && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n}\n\nexport function benchmarkKnnQueryShapes(\n  query_embedding: EmbeddingInput,\n  options: { iterations?: number; limit?: number } = {},\n  database: Database.Database = initialize_db(),\n): KnnQueryShapeBenchmarkResult {\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n  const limit = Math.max(1, Math.floor(options.limit ?? 20));\n  const queryBuffer = to_embedding_buffer(query_embedding);\n  const corpusSize = (database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE m.embedding_status = 'success'\n  `).get() as { count: number }).count;\n\n  const scalarSql = `\n    SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n    WHERE m.embedding_status = 'success'\n    ORDER BY distance ASC\n    LIMIT ?\n  `;\n  const scalarStmt = database.prepare(scalarSql);\n  scalarStmt.all(queryBuffer, limit);\n  const scalarRuns: number[] = [];\n  for (let i = 0; i < iterations; i += 1) {\n    const start = process.hrtime.bigint();\n    scalarStmt.all(queryBuffer, limit);\n    scalarRuns.push(elapsedMs(start));\n  }\n\n  const matchTable = activeVectorSchema('vec_memories');\n  const matchAvailable = tableExists(database, 'vec_memories');\n  let matchAverageMs: number | null = null;\n  let matchError: string | null = null;\n\n  if (matchAvailable) {\n    try {\n      const matchSql = `\n        WITH knn AS (\n          SELECT rowid, distance\n          FROM ${matchTable}\n          WHERE embedding MATCH ? AND k = ?\n        )\n        SELECT m.id, knn.distance\n        FROM knn\n        JOIN memory_index m ON m.id = knn.rowid\n        JOIN active_memory_projection p ON p.active_memory_id = m.id\n        WHERE m.embedding_status = 'success'\n        ORDER BY knn.distance ASC\n        LIMIT ?\n      `;\n      const matchStmt = database.prepare(matchSql);\n      matchStmt.all(queryBuffer, limit, limit);\n      const matchRuns: number[] = [];\n      for (let i = 0; i < iterations; i += 1) {\n        const start = process.hrtime.bigint();\n        matchStmt.all(queryBuffer, limit, limit);\n        matchRuns.push(elapsedMs(start));\n      }\n      matchAverageMs = average(matchRuns);\n    } catch (error: unknown) {\n      matchError = get_error_message(error);\n    }\n  }\n\n  const scalarJoinAverageMs = average(scalarRuns);\n  const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n    ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n    : null;\n  const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n  };\n  const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n\n  return {\n    corpusSize,\n    iterations,\n    scalarJoinAverageMs,\n    matchAverageMs,\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n    decision,\n    reason: decision === 'adopt_match'\n      ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n      : matchError\n        ? `MATCH unavailable: ${matchError}`\n        : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n  };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   SIMPLE QUERIES\n----------------------------------------------------------------*/\n\n/**\n * Gets one indexed memory by identifier.\n * @param id - The memory identifier.\n * @returns The matching memory row, if found.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const memory = get_memory(42);\n * ```\n */\nexport function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n  const stmts = init_prepared_statements(database);\n  const row = stmts.get_by_id.get(id);\n\n  if (row) {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n  }\n\n  return row || null;\n}\n\n/**\n * Gets indexed memories for a spec folder.\n * @param spec_folder - The spec folder to query.\n * @returns The memory rows for the folder.\n */\nexport function get_memories_by_folder(\n  spec_folder: string,\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const rows = database.prepare(`\n    SELECT m.*\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\n    ORDER BY m.created_at DESC\n  `).all(spec_folder, specFolderLikePattern(spec_folder)) as MemoryRow[];\n\n  return rows.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/**\n * Gets the total number of indexed memories.\n * @returns The total memory count.\n */\nexport function get_memory_count(database: Database.Database = initialize_db()): number {\n  const stmts = init_prepared_statements(database);\n  const result = stmts.count_all.get();\n  return result?.count ?? 0;\n}\n\n/**\n * Gets memory counts grouped by embedding status.\n * @returns The counts for each embedding status.\n */\nexport function get_status_counts(\n  database: Database.Database = initialize_db(),\n): { pending: number; success: number; failed: number; retry: number; partial: number } {\n  const rows = database.prepare(`\n    SELECT m.embedding_status, COUNT(*) as count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    GROUP BY m.embedding_status\n  `).all();\n\n  // Include 'partial' status in counts.\n  const counts = { pending: 0, success: 0, failed: 0, retry: 0, partial: 0 };\n  for (const row of rows as Array<{ embedding_status: keyof typeof counts; count: number }>) {\n    if (row.embedding_status in counts) {\n      counts[row.embedding_status] = row.count;\n    }\n  }\n\n  return counts;\n}\n\n/**\n * Gets summary counts for indexed memories.\n * @returns The aggregate memory statistics.\n */\nexport function get_stats(\n  database: Database.Database = initialize_db(),\n): { total: number; pending: number; success: number; failed: number; retry: number; partial: number } {\n  const counts = get_status_counts(database);\n  const total = counts.pending + counts.success + counts.failed + counts.retry + counts.partial;\n\n  return {\n    total,\n    ...counts\n  };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories by vector similarity.\n * @param query_embedding - The query embedding to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const rows = vector_search(queryEmbedding, { limit: 5, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function vector_search(\n  query_embedding: EmbeddingInput,\n  options: VectorSearchOptions = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Vector search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const {\n    limit = 10,\n    specFolder = null,\n    minSimilarity = 0,\n    useDecay = true,\n    tier = null,\n    contextType = null,\n    includeConstitutional = true,\n    includeArchived = false\n  } = options;\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const query_buffer = to_embedding_buffer(query_embedding);\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  // FSRS-preferred decay with half-life fallback\n  const decay_expr = useDecay\n    ? `CASE\n         WHEN m.is_pinned = 1 THEN m.importance_weight\n         WHEN m.last_review IS NOT NULL AND m.review_count > 0 THEN\n           m.importance_weight * POWER(\n             1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n             -0.5\n           )\n         ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n       END`\n    : 'm.importance_weight';\n\n  let constitutional_results: MemoryRow[] = [];\n\n  if (includeConstitutional && tier !== 'constitutional') {\n    constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n  }\n\n  const where_clauses = ['m.embedding_status = \\'success\\''];\n  const params: unknown[] = [query_buffer];\n\n  where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n\n  if (tier === 'deprecated') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('deprecated');\n  } else if (tier === 'constitutional') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('constitutional');\n  } else if (tier) {\n    where_clauses.push('m.importance_tier = ?');\n    params.push(tier);\n  } else if (isArchivedVectorInclusionEnabled()) {\n    // Cold/archived rows admitted to the projection (option A) must not be re-excluded\n    // here; still keep constitutional on its own injected path.\n    where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier != \\'constitutional\\')');\n  } else {\n    where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n  }\n\n  appendSpecFolderScope(where_clauses, params, specFolder);\n\n  if (contextType) {\n    where_clauses.push('m.context_type = ?');\n    params.push(contextType);\n  }\n\n  // If constitutional results already satisfy limit, return them directly.\n  if (constitutional_results.length >= limit) {\n    return constitutional_results.slice(0, limit);\n  }\n  const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n  params.push(max_distance, adjusted_limit);\n\n  const sql = `\n    SELECT sub.*,\n           ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n    FROM (\n      SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n             ${decay_expr} as effective_importance\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE ${where_clauses.join(' AND ')}\n    ) sub\n    WHERE sub.distance <= ?\n    ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n    LIMIT ?\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n\n  return [...constitutional_results, ...regular_results];\n}\n\n/**\n * Gets constitutional memories for prompt assembly.\n * @param options - Retrieval options.\n * @returns The constitutional memory rows.\n */\nexport function get_constitutional_memories_public(\n  options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n\n  let results = get_constitutional_memories(database, specFolder, includeArchived);\n\n  const TOKENS_PER_MEMORY = 100;\n  const max_count = Math.floor(maxTokens / TOKENS_PER_MEMORY);\n  if (results.length > max_count) {\n    results = results.slice(0, max_count);\n  }\n\n  return results;\n}\n\n/**\n * Searches indexed memories with multiple concept embeddings.\n * @param concept_embeddings - The concept embeddings to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} When concept count or embedding dimensions are invalid, or when store initialization fails.\n * @example\n * ```ts\n * const rows = multi_concept_search([embA, embB], { limit: 8, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function multi_concept_search(\n  concept_embeddings: EmbeddingInput[],\n  options: { limit?: number; specFolder?: string | null; minSimilarity?: number } = {}\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Multi-concept search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const database = initialize_db();\n\n  const concepts = concept_embeddings;\n  if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  for (const emb of concepts) {\n    if (!emb || emb.length !== vectorSource.dim) {\n      throw new VectorIndexError(\n        `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n        VectorIndexErrorCode.QUERY_FAILED,\n      );\n    }\n  }\n\n  const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  const distance_expressions = concept_buffers.map((_, i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n  ).join(', ');\n\n  const distance_filters = concept_buffers.map((_, _i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n  ).join(' AND ');\n\n  const folder_filter = specFolder ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\" : '';\n  const similarity_select = concept_buffers.map((_, i) =>\n    `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n  ).join(', ');\n\n  const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n\n  const sql = `\n    SELECT\n      sub.*,\n      ${similarity_select},\n      (${avg_distance_expr}) / ${concepts.length} as avg_distance\n    FROM (\n      SELECT\n        m.*,\n        ${distance_expressions}\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE m.embedding_status = 'success'\n        AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n        ${folder_filter}\n        AND ${distance_filters}\n    ) sub\n    ORDER BY avg_distance ASC\n    LIMIT ?\n  `;\n\n  const params = [\n    ...concept_buffers,\n    ...(specFolder ? [specFolder, specFolderLikePattern(specFolder)] : []),\n    ...concept_buffers.flatMap(b => [b, max_distance]),\n    limit\n  ];\n\n  const rows = database.prepare(sql).all(...params);\n\n  return (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n    row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   CONTENT EXTRACTION HELPERS\n----------------------------------------------------------------*/\n\n/**\n * Extracts a display title from indexed content.\n * @param content - The content to inspect.\n * @param filename - The optional source filename.\n * @returns The extracted title.\n */\nexport function extract_title(content: unknown, filename?: string): string {\n  if (!content || typeof content !== 'string') {\n    return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n  }\n\n  const h1_match = content.match(/^#\\s+(.+)$/m);\n  if (h1_match && h1_match[1]) {\n    return h1_match[1].trim();\n  }\n\n  const h2_match = content.match(/^##\\s+(.+)$/m);\n  if (h2_match && h2_match[1]) {\n    return h2_match[1].trim();\n  }\n\n  const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n  if (yaml_match && yaml_match[1]) {\n    return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n  }\n\n  const lines = content.split('\\n').filter(l => l.trim().length > 0);\n  if (lines.length > 0) {\n    const first_line = lines[0].trim();\n    return first_line.replace(/^#+\\s*/, '').substring(0, 100);\n  }\n\n  return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n}\n\n/**\n * Extracts a preview snippet from indexed content.\n * @param content - The content to inspect.\n * @param max_length - The maximum snippet length.\n * @returns The extracted snippet.\n */\nexport function extract_snippet(content: unknown, max_length = 200): string {\n  if (!content || typeof content !== 'string') {\n    return '';\n  }\n\n  const text = content.replace(/^---[\\s\\S]*?---\\n*/m, '');\n  const lines = text.split('\\n');\n  const snippet_lines: string[] = [];\n\n  for (const line of lines) {\n    const trimmed = line.trim();\n\n    if (!trimmed || /^#+\\s/.test(trimmed)) {\n      if (snippet_lines.length > 0) {\n        break;\n      }\n      continue;\n    }\n\n    if (/^[a-z_-]+:\\s/i.test(trimmed) && snippet_lines.length === 0) {\n      continue;\n    }\n\n    snippet_lines.push(trimmed);\n\n    const current_length = snippet_lines.join(' ').length;\n    if (current_length >= max_length) {\n      break;\n    }\n  }\n\n  let snippet = snippet_lines.join(' ');\n\n  if (snippet.length > max_length) {\n    snippet = snippet.substring(0, max_length);\n    const last_space = snippet.lastIndexOf(' ');\n    if (last_space > max_length * 0.7) {\n      snippet = snippet.substring(0, last_space);\n    }\n    snippet += '...';\n  }\n\n  return snippet;\n}\n\n/**\n * Extracts tags from indexed content.\n * @param content - The content to inspect.\n * @returns The extracted tags.\n */\nexport function extract_tags(content: unknown): string[] {\n  if (!content || typeof content !== 'string') {\n    console.warn('[vector-index] extract_tags: invalid content type, expected string');\n    return [];\n  }\n\n  const tags = new Set<string>();\n\n  const yaml_tags_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\[([^\\]]+)\\]/m);\n  if (yaml_tags_match && yaml_tags_match[1]) {\n    yaml_tags_match[1].split(',').forEach(tag => {\n      const cleaned = tag.trim().replace(/^[\"']|[\"']$/g, '');\n      if (cleaned) tags.add(cleaned.toLowerCase());\n    });\n  }\n\n  const yaml_list_match = content.match(/^---[\\s\\S]*?^tags:\\s*\\n((?:\\s*-\\s*.+\\n?)+)/m);\n  if (yaml_list_match && yaml_list_match[1]) {\n    yaml_list_match[1].match(/-\\s*(.+)/g)?.forEach(match => {\n      const tag = match.replace(/^-\\s*/, '').trim().replace(/^[\"']|[\"']$/g, '');\n      if (tag) tags.add(tag.toLowerCase());\n    });\n  }\n\n  const hashtag_matches = content.match(/(?:^|\\s)#([a-zA-Z][a-zA-Z0-9_-]*)/g);\n  if (hashtag_matches) {\n    hashtag_matches.forEach(match => {\n      const tag = match.trim().replace(/^#/, '');\n      if (tag && !tag.match(/^[0-9]+$/)) {\n        tags.add(tag.toLowerCase());\n      }\n    });\n  }\n\n  return Array.from(tags);\n}\n\n/**\n * Extracts a relevant date from indexed content or path.\n * @param content - The content to inspect.\n * @param file_path - The optional source file path.\n * @returns The extracted date, if available.\n */\nexport function extract_date(content: unknown, file_path?: string): string | null {\n  if (content && typeof content === 'string') {\n    const date_match = content.match(/^---[\\s\\S]*?^date:\\s*(.+)$/m);\n    if (date_match && date_match[1]) {\n      const date_str = date_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n      try {\n        const parsed = new Date(date_str);\n        if (!isNaN(parsed.getTime())) {\n          return parsed.toISOString().split('T')[0];\n        }\n      } catch (_e: unknown) {\n        console.warn('[vector-index-queries] Date parsing failed', { error: _e instanceof Error ? _e.message : String(_e) });\n      }\n    }\n  }\n\n  if (file_path) {\n    const filename = path.basename(file_path);\n\n    const iso_match = filename.match(/(\\d{4}-\\d{2}-\\d{2})/);\n    if (iso_match) {\n      return iso_match[1];\n    }\n\n    const ddmmyy_match = filename.match(/(\\d{2})-(\\d{2})-(\\d{2})/);\n    if (ddmmyy_match) {\n      const [, day, month, year] = ddmmyy_match;\n      const full_year = parseInt(year) > 50 ? `19${year}` : `20${year}`;\n      return `${full_year}-${month}-${day}`;\n    }\n  }\n\n  return null;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   EMBEDDING GENERATION WRAPPER\n----------------------------------------------------------------*/\n\n/**\n * Generates an embedding for a search query.\n * @param query - The search query.\n * @returns A promise that resolves to the embedding, if generated.\n */\nexport async function generate_query_embedding(query: string): Promise<Float32Array | null> {\n  if (!query || typeof query !== 'string' || query.trim().length === 0) {\n    console.warn('[vector-index] Empty query provided for embedding');\n    return null;\n  }\n\n  try {\n    const database = initialize_db();\n    const active = getActiveEmbedder(database);\n    const trimmedQuery = query.trim();\n    const modelId = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.name\n      : embeddingsProvider.getModelName();\n    const embeddingDim = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.dim\n      : embeddingsProvider.getEmbeddingDimension();\n    const profileKey = getActiveEmbeddingProfileKey(database, modelId, embeddingDim);\n    const contentHash = computeContentHash(trimmedQuery);\n    const cached = lookupEmbedding(database, contentHash, modelId, embeddingDim, {\n      profileKey,\n      inputKind: 'query',\n    });\n    if (cached) {\n      return new Float32Array(\n        cached.buffer,\n        cached.byteOffset,\n        Math.floor(cached.byteLength / Float32Array.BYTES_PER_ELEMENT),\n      );\n    }\n\n    const provider = active.name !== DEFAULT_ACTIVE_EMBEDDER.name\n      ? active.provider ?? getManifest(active.name)?.backend ?? 'ollama'\n      : getStartupEmbeddingProfile().provider;\n    const adapter = getEmbedderAdapter(provider, modelId, embeddingDim);\n    const activeAdapter = adapter as typeof adapter & {\n      embed: (\n        texts: ReadonlyArray<string>,\n        options?: { inputType?: 'query' | 'document' },\n      ) => Promise<Float32Array[]>;\n    };\n    const [activeEmbedding] = await activeAdapter.embed([trimmedQuery], { inputType: 'query' });\n    const embedding: Float32Array | null = activeEmbedding ?? null;\n\n    if (embedding) {\n      storeEmbedding(\n        database,\n        contentHash,\n        modelId,\n        Buffer.from(embedding.buffer, embedding.byteOffset, embedding.byteLength),\n        embedding.length,\n        { profileKey, inputKind: 'query' },\n      );\n    }\n\n    return embedding;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Query embedding failed: ${get_error_message(error)}`);\n    return null;\n  }\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   KEYWORD SEARCH FALLBACK\n----------------------------------------------------------------*/\n\n/**\n * Searches indexed memories using keyword matching.\n * @param query - The search query.\n * @param options - Search options.\n * @returns The matching memory rows.\n */\nexport function keyword_search(\n  query: string,\n  options: { limit?: number; specFolder?: string | null } = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const { limit = 20, specFolder = null } = options;\n\n  if (!query || typeof query !== 'string') {\n    console.warn('[vector-index] keyword_search: invalid query, expected non-empty string');\n    return [];\n  }\n\n  const search_terms = query.toLowerCase().trim().split(/\\s+/).filter(t => t.length >= 2);\n  if (search_terms.length === 0) {\n    console.warn('[vector-index] keyword_search: no valid search terms after tokenization');\n    return [];\n  }\n\n  let where_clause = '1=1';\n  const params: unknown[] = [];\n\n  if (specFolder) {\n    where_clause += \" AND (spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')\";\n    params.push(specFolder, specFolderLikePattern(specFolder));\n  }\n\n  const sql = `\n    SELECT m.* FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE ${where_clause}\n    ORDER BY m.importance_weight DESC, m.created_at DESC\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const scored = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    let score = 0;\n    const searchable_text = [\n      row.title || '',\n      parse_trigger_phrases(row.trigger_phrases).join(' '),\n      row.spec_folder || '',\n      row.file_path || ''\n    ].join(' ').toLowerCase();\n\n    for (const term of search_terms) {\n      if (searchable_text.includes(term)) {\n        score += 1;\n        if ((row.title || '').toLowerCase().includes(term)) {\n          score += 2;\n        }\n        if (parse_trigger_phrases(row.trigger_phrases).join(' ').toLowerCase().includes(term)) {\n          score += 1.5;\n        }\n      }\n    }\n\n    score *= (0.5 + (row.importance_weight ?? 0));\n    return { ...row, keyword_score: score };\n  });\n\n  const filtered = scored\n    .filter((row: MemoryRow) => Number(row.keyword_score ?? 0) > 0)\n    .sort((a: MemoryRow, b: MemoryRow) => Number(b.keyword_score ?? 0) - Number(a.keyword_score ?? 0))\n    .slice(0, limit);\n\n  return filtered.map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   ENRICHED VECTOR SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Runs enriched vector search for a text query.\n * @param query - The search query.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n * @throws {VectorIndexError} Propagates vector-store initialization failures from the underlying search pipeline.\n * @example\n * ```ts\n * const results = await vector_search_enriched('sqlite vec mismatch', 10, { specFolder: 'specs/001-demo' });\n * ```\n */\nexport async function vector_search_enriched(\n  query: string,\n  limit = 20,\n  options: { specFolder?: string | null; minSimilarity?: number } = {},\n  database: Database.Database = initialize_db(),\n): Promise<EnrichedSearchResult[]> {\n  const start_time = Date.now();\n  const { specFolder = null, minSimilarity = 30 } = options;\n\n  const query_embedding = await generate_query_embedding(query);\n\n  let raw_results;\n  let search_method = 'vector';\n\n  const sqlite_vec = get_sqlite_vec_available();\n  if (query_embedding && sqlite_vec) {\n    raw_results = vector_search(query_embedding, {\n      limit,\n      specFolder,\n      minSimilarity\n    }, database);\n  } else {\n    console.warn('[vector-index] Falling back to keyword search');\n    search_method = 'keyword';\n    raw_results = keyword_search(query, { limit, specFolder }, database);\n  }\n\n  // HIGH-004 FIX: Read all files concurrently\n  const file_contents = await Promise.all(\n    raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    const similarity = search_method === 'vector'\n      ? (row.similarity || 0)\n      : Math.min(100, (row.keyword_score || 0) * 20);\n\n    return {\n      rank: i + 1,\n      similarity: Math.round(similarity * 100) / 100,\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      searchMethod: search_method,\n      isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n    };\n  });\n\n  const elapsed = Date.now() - start_time;\n  if (elapsed > 500) {\n    console.warn(`[vector-index] Enriched search took ${elapsed}ms (target <500ms)`);\n  }\n\n  return enriched_results;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   MULTI-CONCEPT ENRICHED SEARCH\n----------------------------------------------------------------*/\n\n/**\n * Runs enriched search across multiple concepts.\n * @param concepts - The concept queries or embeddings.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n * @throws {VectorIndexError} When concept validation fails or the vector search pipeline cannot execute.\n * @example\n * ```ts\n * const results = await multi_concept_search_enriched(['sqlite', 'vector'], 10, { specFolder: 'specs/001-demo' });\n * ```\n */\nexport async function multi_concept_search_enriched(\n  concepts: Array<string | EmbeddingInput>,\n  limit = 20,\n  options: { specFolder?: string | null; minSimilarity?: number } = {}\n): Promise<EnrichedSearchResult[]> {\n  const start_time = Date.now();\n\n  if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const { specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_embeddings: EmbeddingInput[] = [];\n  for (const concept of concepts) {\n    if (typeof concept === 'string') {\n      const embedding = await generate_query_embedding(concept);\n      if (!embedding) {\n        console.warn(`[vector-index] Failed to embed concept: \"${concept}\"`);\n        return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n      }\n      concept_embeddings.push(embedding);\n    } else {\n      concept_embeddings.push(concept);\n    }\n  }\n\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Falling back to keyword multi-concept search');\n    return await multi_concept_keyword_search(concepts.filter(c => typeof c === 'string'), limit, options);\n  }\n\n  const raw_results = multi_concept_search(concept_embeddings, { limit, specFolder, minSimilarity });\n\n  const file_contents = await Promise.all(\n    raw_results.map((row: MemoryRow) => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = raw_results.map((row: MemoryRow, i: number) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    return {\n      rank: i + 1,\n      avgSimilarity: Math.round((row.avg_similarity || 0) * 100) / 100,\n      conceptSimilarities: (row.concept_similarities as number[] | undefined) || [],\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      isConstitutional: row.isConstitutional || row.importance_tier === 'constitutional'\n    };\n  });\n\n  const elapsed = Date.now() - start_time;\n  if (elapsed > 500) {\n    console.warn(`[vector-index] Multi-concept search took ${elapsed}ms (target <500ms)`);\n  }\n\n  return enriched_results;\n}\n\n/**\n * Runs keyword search for multiple concepts.\n * @param concepts - The concept terms to search for.\n * @param limit - The maximum number of results to return.\n * @param options - Search options.\n * @returns A promise that resolves to enriched search results.\n */\nexport async function multi_concept_keyword_search(\n  concepts: string[],\n  limit = 20,\n  options: { specFolder?: string | null } = {}\n): Promise<EnrichedSearchResult[]> {\n  const { specFolder = null } = options;\n\n  if (!concepts.length) {\n    console.warn('[vector-index] multi_concept_keyword_search: empty concepts array');\n    return [];\n  }\n\n  const concept_results = concepts.map((concept: string) =>\n    keyword_search(concept, { limit: 100, specFolder })\n  );\n\n  const id_counts = new Map<number, number>();\n  const id_to_row = new Map<number, MemoryRow>();\n\n  for (const results of concept_results) {\n    for (const row of results) {\n      const count = id_counts.get(row.id) || 0;\n      id_counts.set(row.id, count + 1);\n      if (!id_to_row.has(row.id)) {\n        id_to_row.set(row.id, row);\n      }\n    }\n  }\n\n  const matching_ids: number[] = [];\n  for (const [id, count] of id_counts) {\n    if (count === concepts.length) {\n      matching_ids.push(id);\n    }\n  }\n\n  const limited_ids = matching_ids.slice(0, limit);\n  const rows = limited_ids.map(id => id_to_row.get(id)).filter((row): row is MemoryRow => Boolean(row));\n\n  const file_contents = await Promise.all(\n    rows.map(row => safe_read_file_async(row.file_path))\n  );\n\n  const enriched_results = rows.map((row, i) => {\n    const content = file_contents[i];\n    const title = row.title || extract_title(content, row.file_path);\n    const snippet = extract_snippet(content);\n    const tags = extract_tags(content);\n    const date = extract_date(content, row.file_path) || row.created_at?.split('T')[0] || null;\n\n    return {\n      rank: i + 1,\n      avgSimilarity: Math.min(100, (row.keyword_score || 1) * 15),\n      conceptSimilarities: concepts.map(() => row.keyword_score || 1),\n      title,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      date,\n      tags,\n      snippet,\n      id: row.id,\n      importanceWeight: row.importance_weight ?? 0.5,\n      searchMethod: 'keyword',\n      isConstitutional: row.importance_tier === 'constitutional'\n    };\n  });\n\n  return enriched_results;\n}\n\n/**\n * Parses quoted phrases from a search query.\n * @param query - The search query.\n * @returns The quoted search terms.\n */\nexport function parse_quoted_terms(query: string): string[] {\n  if (!query || typeof query !== 'string') {\n    console.warn('[vector-index] parse_quoted_terms: invalid query, expected non-empty string');\n    return [];\n  }\n\n  const quoted: string[] = [];\n  const regex = /\"([^\"]+)\"/g;\n  let match;\n\n  while ((match = regex.exec(query)) !== null) {\n    if (match[1] && match[1].trim()) {\n      quoted.push(match[1].trim());\n    }\n  }\n\n  return quoted;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   SMART RANKING AND DIVERSITY\n----------------------------------------------------------------*/\n\n// Weights read from config instead of hardcoded\n/**\n * Applies smart ranking weights to enriched results.\n * @param results - The results to rank.\n * @returns The ranked results.\n */\nexport function apply_smart_ranking(results: EnrichedSearchResult[]): EnrichedSearchResult[] {\n  if (!results || results.length === 0) return results;\n\n  const recency_weight = search_weights.smartRanking?.recencyWeight || 0.3;\n  const access_weight = search_weights.smartRanking?.accessWeight || 0.2;\n  const relevance_weight = search_weights.smartRanking?.relevanceWeight || 0.5;\n\n  const now = Date.now();\n  const week_ms = 7 * 24 * 60 * 60 * 1000;\n  const month_ms = 30 * 24 * 60 * 60 * 1000;\n\n  return results.map((r: EnrichedSearchResult) => {\n    const created_at = r.created_at ? new Date(r.created_at).getTime() : now;\n    const age = now - created_at;\n    let recency_factor;\n    if (age < week_ms) {\n      recency_factor = 1.0;\n    } else if (age < month_ms) {\n      recency_factor = 0.8;\n    } else {\n      recency_factor = 0.5;\n    }\n\n    const usage_factor = Math.min(1.0, (r.access_count || 0) / 10);\n    const similarity_factor = (r.similarity || 0) / 100;\n\n    r.smartScore = (similarity_factor * relevance_weight) + (recency_factor * recency_weight) + (usage_factor * access_weight);\n    r.smartScore = Math.round(r.smartScore * 100) / 100;\n\n    return r;\n  }).sort((a, b) => Number(b.smartScore ?? 0) - Number(a.smartScore ?? 0));\n}\n\n// Apply diversity filtering using MMR (Maximal Marginal Relevance)\n/**\n * Applies diversity reordering to enriched results.\n * @param results - The results to diversify.\n * @param diversity_factor - The diversity weight to apply.\n * @returns The diversified results.\n */\nexport function apply_diversity(results: EnrichedSearchResult[], diversity_factor = 0.3): EnrichedSearchResult[] {\n  if (!results || results.length <= 3) return results;\n\n  const selected = [results[0]];\n  const remaining = [...results.slice(1)];\n\n  while (selected.length < results.length && remaining.length > 0) {\n    let best_idx = 0;\n    let best_score = -Infinity;\n\n    for (let i = 0; i < remaining.length; i++) {\n      const candidate = remaining[i];\n      const relevance = candidate.smartScore || ((candidate.similarity ?? 0) / 100) || 0;\n\n      let max_similarity_to_selected = 0;\n      for (const sel of selected) {\n        if (sel.specFolder === candidate.specFolder || sel.spec_folder === candidate.spec_folder) {\n          max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.8);\n        }\n        if (sel.date === candidate.date) {\n          max_similarity_to_selected = Math.max(max_similarity_to_selected, 0.5);\n        }\n      }\n\n      const mmr_score = relevance - (diversity_factor * max_similarity_to_selected);\n\n      if (mmr_score > best_score) {\n        best_score = mmr_score;\n        best_idx = i;\n      }\n    }\n\n    selected.push(remaining.splice(best_idx, 1)[0]);\n  }\n\n  return selected;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   RELATED MEMORIES AND USAGE TRACKING\n----------------------------------------------------------------*/\n\n/**\n * Gets memories related to a stored memory.\n * @param memory_id - The memory identifier.\n * @returns The related memory rows.\n */\nexport function get_related_memories(memory_id: number): MemoryRow[] {\n  try {\n    const database = initialize_db();\n\n    const memory = database.prepare(`\n      SELECT related_memories FROM memory_index WHERE id = ?\n    `).get(memory_id) as { related_memories?: string | null } | undefined;\n\n    if (!memory || !memory.related_memories) {\n      return [];\n    }\n\n    const related = safe_parse_json(memory.related_memories, []);\n\n    return (related as RelatedMemoryLink[]).map((rel: RelatedMemoryLink): MemoryRow | null => {\n      const full_memory = get_memory(rel.id);\n      if (full_memory) {\n        return {\n          ...full_memory,\n          relationSimilarity: rel.similarity\n        };\n      }\n      return null;\n    }).filter((relatedMemory): relatedMemory is MemoryRow => Boolean(relatedMemory));\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to get related memories for ${memory_id}: ${get_error_message(error)}`);\n    return [];\n  }\n}\n\n/**\n * Gets usage statistics for indexed memories.\n * @param options - Sorting and limit options.\n * @returns The usage statistics rows.\n */\nexport function get_usage_stats(options: UsageStatsOptions = {}): Array<{ id: number; title: string | null; spec_folder: string; file_path: string; access_count: number; last_accessed: number | null; confidence: number | null; created_at: string }> {\n  const {\n    sortBy = 'access_count',\n    order = 'DESC',\n    limit = 20\n  } = options;\n\n  const valid_sort_fields = ['access_count', 'last_accessed', 'confidence'];\n  const sort_field = valid_sort_fields.includes(sortBy) ? sortBy : 'access_count';\n  const sort_order = order.toUpperCase() === 'ASC' ? 'ASC' : 'DESC';\n\n  const database = initialize_db();\n\n  const rows = database.prepare(`\n    SELECT id, title, spec_folder, file_path, access_count,\n           last_accessed, confidence, created_at\n    FROM memory_index\n    WHERE access_count > 0\n    ORDER BY ${sort_field} ${sort_order}\n    LIMIT ?\n  `).all(limit) as Array<{\n    id: number;\n    title: string | null;\n    spec_folder: string;\n    file_path: string;\n    access_count: number;\n    last_accessed: number | null;\n    confidence: number | null;\n    created_at: string;\n  }>;\n\n  return rows;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   CLEANUP FUNCTIONS\n----------------------------------------------------------------*/\n\n/**\n * Finds memory records that are candidates for cleanup.\n * @param options - Cleanup thresholds and limits.\n * @returns The cleanup candidate details.\n */\nexport function find_cleanup_candidates(options: CleanupOptions = {}): Array<{ id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; reasons: string[] }> {\n  const database = initialize_db();\n\n  const {\n    maxAgeDays = 90,\n    maxAccessCount = 2,\n    maxConfidence = 0.4,\n    limit = 50\n  } = options;\n\n  const cutoff_date = new Date();\n  cutoff_date.setDate(cutoff_date.getDate() - maxAgeDays);\n  const cutoff_iso = cutoff_date.toISOString();\n\n  const sql = `\n    SELECT\n      id,\n      spec_folder,\n      file_path,\n      title,\n      created_at,\n      last_accessed,\n      access_count,\n      confidence,\n      importance_weight\n    FROM memory_index\n    WHERE\n      created_at < ?\n      OR access_count <= ?\n      OR confidence <= ?\n      OR (last_accessed IS NULL AND created_at < ?)\n    ORDER BY\n      last_accessed ASC NULLS FIRST,\n      access_count ASC,\n      confidence ASC\n    LIMIT ?\n  `;\n\n  let rows;\n  try {\n    rows = database.prepare(sql).all(\n      cutoff_iso,\n      maxAccessCount,\n      maxConfidence,\n      cutoff_iso,\n      limit\n    );\n  } catch (e: unknown) {\n    console.warn(`[vector-index] find_cleanup_candidates error: ${get_error_message(e)}`);\n    return [];\n  }\n\n  return (rows as MemoryRow[]).map((row: MemoryRow) => {\n    const age_string = format_age_string(row.created_at ?? null);\n    const last_access_string = format_age_string(\n      typeof row.last_accessed === 'number' ? new Date(row.last_accessed).toISOString() : null\n    );\n\n    const reasons: string[] = [];\n    if (row.created_at && new Date(row.created_at) < cutoff_date) {\n      reasons.push(`created ${age_string}`);\n    }\n    if ((row.access_count || 0) <= maxAccessCount) {\n      const count = row.access_count || 0;\n      reasons.push(`accessed ${count} time${count !== 1 ? 's' : ''}`);\n    }\n    if ((row.confidence || 0.5) <= maxConfidence) {\n      reasons.push(`low importance (${Math.round((row.confidence || 0.5) * 100)}%)`);\n    }\n\n    return {\n      id: row.id,\n      specFolder: row.spec_folder,\n      filePath: row.file_path,\n      title: row.title || 'Untitled',\n      createdAt: row.created_at,\n      lastAccessedAt: row.last_accessed,\n      accessCount: row.access_count || 0,\n      confidence: row.confidence || 0.5,\n      ageString: age_string,\n      lastAccessString: last_access_string,\n      reasons\n    };\n  });\n}\n\n/**\n * Builds a preview payload for a stored memory.\n * @param memory_id - The memory identifier.\n * @param max_lines - The maximum number of file lines to include.\n * @returns The memory preview, if found.\n */\nexport function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n  const database = initialize_db();\n\n  let memory: MemoryRow | undefined;\n  try {\n    memory = database.prepare(`\n      SELECT * FROM memory_index WHERE id = ?\n    `).get(memory_id) as MemoryRow | undefined;\n  } catch (e: unknown) {\n    console.warn(`[vector-index] get_memory_preview query error: ${get_error_message(e)}`);\n    return null;\n  }\n\n  if (!memory) return null;\n\n  let content = '';\n  try {\n    // Validate DB-stored file paths before reading\n    if (memory.file_path) {\n      const valid_path = validate_file_path_local(memory.file_path);\n      if (valid_path && fs.existsSync(valid_path)) {\n        const full_content = fs.readFileSync(valid_path, 'utf-8');\n        const lines = full_content.split('\\n');\n        content = lines.slice(0, max_lines).join('\\n');\n        if (lines.length > max_lines) {\n          content += `\\n... (${lines.length - max_lines} more lines)`;\n        }\n      }\n    }\n  } catch (e: unknown) {\n    console.warn('[vector-index] get_memory_preview file read warning', {","lineStart":1,"lineEnd":1484,"totalLines":1485,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781764258737,"end":1781764258742}},"metadata":{"openai":{"itemId":"fc_03f5d3efadbd529a016a3390a283d48191ab351dede9e417eb"}},"id":"prt_ed96cfb9e001Lam0G5NofmWYru","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96cc029001sLIhXPsAafhA8L"}}
{"type":"tool_use","timestamp":1781764258896,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_eKCnvu8Z9gAIHSkzx3cu6fiW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Crud Delete\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: \n5: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n6:    IMPORTS\n7: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n34:    CORE LOGIC\n35: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper вҖ” wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n181:     const deletedIds: number[] = [];\n182:     const hashById = new Map<number, MemoryHashSnapshot>();\n183: \n184:     if (database && 'prepare' in database) {\n185:       try {\n186:         const rows = database.prepare(`\n187:           SELECT id, content_hash, spec_folder, file_path\n188:           FROM memory_index\n189:           WHERE spec_folder = ?\n190:         `).all(specFolder as string) as MemoryHashSnapshot[];\n191: \n192:         for (const row of rows) {\n193:           hashById.set(row.id, row);\n194:         }\n195:       } catch (_err: unknown) {\n196:         // Non-fatal вҖ” bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n197:       }\n198:     }\n199: \n200:     if (memories.length > 0) {\n201:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n202:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n203:       try {\n204:         const checkpoint = checkpoints.createCheckpoint({\n205:           name: proposedCheckpointName,\n206:           specFolder,\n207:           metadata: {\n208:             reason: 'auto-checkpoint before bulk delete',\n209:             memoryCount: memories.length,\n210:           },\n211:         });\n212: \n213:         if (checkpoint) {\n214:           checkpointName = checkpoint.name;\n215:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n216:         } else {\n217:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n218:           checkpointName = null;\n219:         }\n220:       } catch (cpErr: unknown) {\n221:         const message = toErrorMessage(cpErr);\n222:         console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n223:         // Confirm is always true here (validated at function entry) вҖ” safe to proceed without checkpoint.\n224:         console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n225:         checkpointName = null;\n226:       }\n227:     }\n228: \n229:     // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n230:     causalEdges.init(database);\n231:     const bulkDeleteTx = database.transaction(() => {\n232:       for (const memory of memories) {\n233:         if (tombstoneMemory(database, memory.id)) {\n234:           // Record DELETE history after confirmed delete (no FK, history rows survive).\n235:           try {\n236:             const snapshot = hashById.get(memory.id);\n237:             recordHistory(\n238:               memory.id,\n239:               'DELETE',\n240:               snapshot?.file_path ?? null,\n241:               null,\n242:               'mcp:memory_delete',\n243:               snapshot?.spec_folder ?? null,\n244:             );\n245:           } catch (_histErr: unknown) {\n246:             // History recording is best-effort inside bulk delete\n247:           }\n248:           deletedCount++;\n249:           deletedIds.push(memory.id);\n250:           causalEdges.deleteEdgesForMemory(String(memory.id), {\n251:             reason: 'memory row mutation cleanup',\n252:             command: 'memory-crud-delete.handleMemoryDelete',\n253:             restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n254:           });\n255:         }\n256:       }\n257: \n258:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n259:       for (const deletedId of deletedIds) {\n260:         const snapshot = hashById.get(deletedId) ?? null;\n261:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n262:           mutationType: 'delete',\n263:           reason: 'memory_delete: bulk delete by spec folder',\n264:           priorHash: snapshot?.content_hash ?? null,\n265:           newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n266:           linkedMemoryIds: [deletedId],\n267:           decisionMeta: {\n268:             tool: 'memory_delete',\n269:             bulk: true,\n270:             specFolder,\n271:             checkpoint: checkpointName,\n272:             memoryId: deletedId,\n273:             filePath: snapshot?.file_path ?? null,\n274:           },\n275:           actor: 'mcp:memory_delete',\n276:         });\n277:         if (!ledgerRecorded) {\n278:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n279:         }\n280:       }\n281:     });\n282:     bulkDeleteTx();\n283:   }\n284: \n285:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n286:   if (deletedCount > 0) {\n287:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n288:     try {\n289:       postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n290:     } catch (hookError: unknown) {\n291:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n292:       postMutationHooks = {\n293:         latencyMs: 0, triggerCacheCleared: false,\n294:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n295:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n296:         errors: [msg],\n297:       };\n298:     }\n299:     postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n300:   }\n301: \n302:   const summary = deletedCount > 0\n303:     ? `Deleted ${deletedCount} memory(s)`\n304:     : 'No spec-doc records found to delete';\n305: \n306:   const hints: string[] = [];\n307:   if (checkpointName) {\n308:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n309:   }\n310:   if (deletedCount === 0) {\n311:     hints.push('Use memory_list() to find existing memories');\n312:   }\n313:   if (postMutationFeedback) {\n314:     hints.push(...postMutationFeedback.hints);\n315:   }\n316:   if (mutationLedgerWarning) {\n317:     hints.push(mutationLedgerWarning);\n318:   }\n319: \n320:   const data: Record<string, unknown> = { deleted: deletedCount };\n321:   if (checkpointName) {\n322:     data.checkpoint = checkpointName;\n323:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n324:   }\n325:   if (postMutationFeedback) {\n326:     data.postMutationHooks = postMutationFeedback.data;\n327:   }\n328:   if (mutationLedgerWarning) {\n329:     data.warning = mutationLedgerWarning;\n330:   }\n331: \n332:   return createMCPSuccessResponse({\n333:     tool: 'memory_delete',\n334:     summary,\n335:     data,\n336:     hints,\n337:   });\n338: }\n339: \n340: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n341:    EXPORTS\n342: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n343: \n344: export { handleMemoryDelete };\n\n(End of file - total 344 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Crud Delete\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Crud Delete\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   CORE LOGIC\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper вҖ” wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal вҖ” bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {\n        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) вҖ” safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id), {\n            reason: 'memory row mutation cleanup',\n            command: 'memory-crud-delete.handleMemoryDelete',\n            restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n          });\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: bulk delete by spec folder',\n          priorHash: snapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n          linkedMemoryIds: [deletedId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: true,\n            specFolder,\n            checkpoint: checkpointName,\n            memoryId: deletedId,\n            filePath: snapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    });\n    bulkDeleteTx();\n  }\n\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n  }\n\n  const summary = deletedCount > 0\n    ? `Deleted ${deletedCount} memory(s)`\n    : 'No spec-doc records found to delete';\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  }\n  if (deletedCount === 0) {\n    hints.push('Use memory_list() to find existing memories');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n\n  const data: Record<string, unknown> = { deleted: deletedCount };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (mutationLedgerWarning) {\n    data.warning = mutationLedgerWarning;\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   EXPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport { handleMemoryDelete };","lineStart":1,"lineEnd":344,"totalLines":344,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781764258892,"end":1781764258895}},"metadata":{"openai":{"itemId":"fc_03f5d3efadbd529a016a3390a283dc8191be6a55358bf0df58"}},"id":"prt_ed96cfbd5001FZqXoF7zUDHohK","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96cc029001sLIhXPsAafhA8L"}}
