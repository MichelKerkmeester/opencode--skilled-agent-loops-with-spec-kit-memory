  1337	// ─────────────────────────────────────────────────────────────────────────────
  1338	// 15. CLI ENTRYPOINT
  1339	// ─────────────────────────────────────────────────────────────────────────────
  1340	
  1341	async function main() {
  1342	  const started = now();
  1343	  const actions = [];
  1344	  let lockHeld = false;
  1345	
  1346	  try {
  1347	    installSignalHandlers();
  1348	    // Lease cleanup runs unconditionally regardless of child termination path.
  1349	    process.on('exit', clearAllLeaseFiles);
  1350	    refreshPaths();
  1351	    debug(`DB: ${advisorDbPath()}`);
  1352	
  1353	    const strictSingleWriter = !isStrictModeDisabled(process.env.MK_SKILL_ADVISOR_STRICT_SINGLE_WRITER);
  1354	    ownerLeaseRequired = strictSingleWriter;
  1355	    if (strictSingleWriter) {
  1356	      if (await checkStrictSingleWriter()) return;
  1357	    } else {
  1358	      log('MK_SKILL_ADVISOR_STRICT_SINGLE_WRITER is disabled; skipping lease check');
  1359	    }
  1360	
  1361	    lockHeld = await acquireBootstrapLock();
  1362	    if (lockHeld) {
  1363	      if (Number.isInteger(pendingBootstrapReapPid) && pendingBootstrapReapPid > 0) {
  1364	        // The bootstrap lock is held through replacement launch, so stale-child cleanup
  1365	        // and spawn share one serialization point without a separate respawn lock.
  1366	        const reapOwnerLease = readOwnerLeaseFile();
  1367	        const reapExecutablePath = reapOwnerLease?.ownerPid === pendingBootstrapReapPid ? reapOwnerLease.executablePath : null;
  1368	        const reapResult = await reapOwnerBeforeRespawn(pendingBootstrapReapPid, reapExecutablePath);
  1369	        if (!reapResult.allowed) {
  1370	          log(`stale launcher lease reap skipped; ${reapResult.reason} for daemonPid=${pendingBootstrapReapPid}`);
  1371	          clearOwnerLeaseFile();
  1372	          return;
  1373	        }
  1374	        pendingBootstrapReapPid = null;
  1375	      }
  1376	      buildIfNeeded(actions);
  1377	      writeState({
  1378	        command: 'mk-skill-advisor-launcher',
  1379	        start: started,
  1380	        end: now(),
  1381	        status: 'ready',
  1382	        actions,
  1383	        server: rel(serverEntrypoint()),
  1384	        database: rel(advisorDbPath()),
  1385	      });
  1386	
  1387	      // PID guard write + reprobe stay inside the bootstrap-lock critical section.
  1388	      // Closes the visual race window: two
  1389	      // launchers cannot simultaneously pass the strict-single-writer check and race to write
  1390	      // their PID guards because both writers serialize on the bootstrap lock.
  1391	      if (strictSingleWriter && !ownsOwnerLeaseFile(process.pid)) {
  1392	        log('bootstrap reprobe lost owner lease before PID guard write');
  1393	        return;
  1394	      }
  1395	      writeLeaseFile();
  1396	      const reprobe = readLeaseFile();
  1397	      if (!reprobe || reprobe.pid !== process.pid) {
  1398	        const startedAt = reprobe?.startedAt ?? new Date(0).toISOString();
  1399	        clearOwnerLeaseFile();
  1400	        process.stdout.write(`LEASE_HELD_BY:${reprobe ? reprobe.pid : 'unknown'} startedAt=${startedAt}\n`);
  1401	        return;
  1402	      }
  1403	    }
  1404	
  1405	    const launched = launchServer();
  1406	    if (!launched) return;
  1407	    if (isModelServerEnabled()) {
  1408	      if (!hfControl) throw new Error('SPECKIT_SKILL_ADVISOR_MODEL_SERVER_ENABLED=1 but model-server supervision lib is unavailable');
  1409	      void hfControl.startDemandListener().catch((error) => {
  1410	        log(error.stack || error.message);
  1411	      });
  1412	    }
  1413	  } catch (error) {
  1414	    try {
  1415	      writeState({
  1416	        command: 'mk-skill-advisor-launcher',
  1417	        start: started,
  1418	        end: now(),
  1419	        status: 'failed',
  1420	        actions,
  1421	        error: error.message,
  1422	      });
  1423	    } catch {
  1424	      // If state logging itself fails, stderr still carries the actionable error.
  1425	    }
  1426	    log(`launcher failed: ${error.message}`);
