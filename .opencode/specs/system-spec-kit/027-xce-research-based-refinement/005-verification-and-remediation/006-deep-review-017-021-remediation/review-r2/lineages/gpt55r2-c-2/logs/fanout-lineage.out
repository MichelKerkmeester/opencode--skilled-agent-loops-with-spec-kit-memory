ed: number;\n34:   success: number;\n35:   total: number;\n36:   queue_size: number;\n37: }\n38: \n39: /** In-memory-only snapshot of embedding retry health — no DB access. */\n40: export interface EmbeddingRetryStats {\n41:   pending: number;\n42:   failed: number;\n43:   retryAttempts: number;\n44:   circuitBreakerOpen: boolean;\n45:   lastRun: string | null;\n46:   queueDepth: number;\n47: }\n48: \n49: interface RetryResult {\n50:   success: boolean;\n51:   id?: number;\n52:   dimensions?: number;\n53:   error?: string;\n54:   permanent?: boolean;\n55: }\n56: \n57: interface BatchResult {\n58:   processed: number;\n59:   succeeded: number;\n60:   failed: number;\n61:   details?: RetryDetailEntry[];\n62: }\n63: \n64: interface RetryDetailEntry {\n65:   id: number;\n66:   success: boolean;\n67:   error?: string;\n68:   dimensions?: number;\n69: }\n70: \n71: interface BackgroundJobResult {\n72:   processed?: number;\n73:   succeeded?: number;\n74:   failed?: number;\n75:   details?: RetryDetailEntry[];\n76:   skipped?: boolean;\n77:   reason?: string;\n78:   queue_empty?: boolean;\n79:   error?: string;\n80: }\n81: \n82: /**\n83:  * Retry-specific memory row with required id and file_path.\n84:  * Uses MemoryDbRow as the base type with Record<string, unknown>\n85:  * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n86:  */\n87: type RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n88:   id: number;\n89:   file_path: string;\n90: };\n91: \n92: type ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\n93: type RetryQueueStatus = 'pending' | 'retry';\n94: \n95: type EmbeddingFailureCode =\n96:   | 'EMBEDDING_PROVIDER_ERROR'\n97:   | 'EMBEDDING_TIMEOUT'\n98:   | 'EMBEDDING_RATE_LIMIT';\n99: \n100: interface SanitizeEmbeddingFailureOptions {\n101:   provider?: string | null;\n102:   force?: boolean;\n103: }\n104: \n105: interface SanitizedEmbeddingFailure {\n106:   code: EmbeddingFailureCode | null;\n107:   provider: string | null;\n108:   errorType: string | null;\n109:   publicMessage: string;\n110:   sanitized: boolean;\n111: }\n112: \n113: interface RetryClaimResult {\n114:   claimed: boolean;\n115:   previousStatus: RetryQueueStatus | null;\n116: }\n117: \n118: function getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n119:   const status = typeof memory.embedding_status === 'string'\n120:     ? memory.embedding_status\n121:     : typeof memory.embeddingStatus === 'string'\n122:       ? memory.embeddingStatus\n123:       : null;\n124: \n125:   return status === 'pending' || status === 'retry' ? status : null;\n126: }\n127: \n128: function getRetryCountValue(memory: RetryMemoryRow): number {\n129:   return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n130: }\n131: \n132: function getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n133:   const value = typeof memory.last_retry_at === 'string'\n134:     ? memory.last_retry_at\n135:     : typeof memory.lastRetryAt === 'string'\n136:       ? memory.lastRetryAt\n137:       : null;\n138:   return value && value.trim().length > 0 ? value : null;\n139: }\n140: \n141: function detectEmbeddingProviderName(source: string | null | undefined): string | null {\n142:   if (typeof source !== 'string' || source.trim().length === 0) {\n143:     return null;\n144:   }\n145: \n146:   const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n147:   if (explicitProvider?.[1]) {\n148:     return explicitProvider[1].toLowerCase();\n149:   }\n150: \n151:   const lower = source.toLowerCase();\n152:   if (lower.includes('voyage')) return 'voyage';\n153:   if (lower.includes('azure')) return 'azure-openai';\n154:   if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n155:   if (lower.includes('system')) return 'system';\n156: \n157:   return null;\n158: }\n159: \n160: function shouldSanitizeEmbeddingFailure(message: string): boolean {\n161:   const lower = message.toLowerCase();\n162:   return (\n163:     /^embedding_[a-z_]+/.test(lower) ||\n164:     lower.includes('openai') ||\n165:     lower.includes('voyage') ||\n166:     lower.includes('azure') ||\n167:     lower.includes('text-embedding') ||\n168:     lower.includes('rate limit') ||\n169:     lower.includes('too many requests') ||\n170:     lower.includes('429') ||\n171:     lower.includes('timeout') ||\n172:     lower.includes('timed out') ||\n173:     lower.includes('api key') ||\n174:     lower.includes('unauthorized') ||\n175:     lower.includes('forbidden') ||\n176:     lower.includes('quota') ||\n177:     lower.includes('embedding provider')\n178:   );\n179: }\n180: \n181: function inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n182:   const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n183:   const lower = message.toLowerCase();\n184: \n185:   if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n186:     return {\n187:       code: 'EMBEDDING_TIMEOUT',\n188:       errorType: explicitType ?? 'timeout',\n189:     };\n190:   }\n191: \n192:   if (\n193:     lower.includes('embedding_rate_limit') ||\n194:     lower.includes('rate limit') ||\n195:     lower.includes('too many requests') ||\n196:     lower.includes('429')\n197:   ) {\n198:     return {\n199:       code: 'EMBEDDING_RATE_LIMIT',\n200:       errorType: explicitType ?? 'rate_limit',\n201:     };\n202:   }\n203: \n204:   if (\n205:     explicitType === 'auth' ||\n206:     lower.includes('api key') ||\n207:     lower.includes('unauthorized') ||\n208:     lower.includes('forbidden')\n209:   ) {\n210:     return {\n211:       code: 'EMBEDDING_PROVIDER_ERROR',\n212:       errorType: 'auth',\n213:     };\n214:   }\n215: \n216:   return {\n217:     code: 'EMBEDDING_PROVIDER_ERROR',\n218:     errorType: explicitType ?? 'provider_error',\n219:   };\n220: }\n\n(Showing lines 1-220 of 1141. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Retry Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Embedding retry orchestrator\n// Node stdlib\nimport * as fsPromises from 'fs/promises';\n\n// Internal modules\nimport * as vectorIndex from '../search/vector-index.js';\nimport { computeContentHash, lookupEmbedding, storeEmbedding } from '../cache/embedding-cache.js';\nimport { normalizeContentForEmbedding } from '../parsing/content-normalizer.js';\nimport { generateDocumentEmbedding, getEmbeddingDimension, getModelName } from './embeddings.js';\nimport { clearRegisteredTimer, registerInterval } from '../runtime/timer-registry.js';\nimport { registerShutdownHook } from '../runtime/shutdown-hooks.js';\nimport { beginMaintenance, type MaintenanceMarkerHandle } from '../storage/maintenance-marker.js';\n\n// Type imports\nimport type { MemoryDbRow } from '@spec-kit/shared/types';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface BackgroundJobConfig {\n  intervalMs: number;\n  batchSize: number;\n  enabled: boolean;\n}\n\ninterface RetryStats {\n  pending: number;\n  retry: number;\n  failed: number;\n  success: number;\n  total: number;\n  queue_size: number;\n}\n\n/** In-memory-only snapshot of embedding retry health — no DB access. */\nexport interface EmbeddingRetryStats {\n  pending: number;\n  failed: number;\n  retryAttempts: number;\n  circuitBreakerOpen: boolean;\n  lastRun: string | null;\n  queueDepth: number;\n}\n\ninterface RetryResult {\n  success: boolean;\n  id?: number;\n  dimensions?: number;\n  error?: string;\n  permanent?: boolean;\n}\n\ninterface BatchResult {\n  processed: number;\n  succeeded: number;\n  failed: number;\n  details?: RetryDetailEntry[];\n}\n\ninterface RetryDetailEntry {\n  id: number;\n  success: boolean;\n  error?: string;\n  dimensions?: number;\n}\n\ninterface BackgroundJobResult {\n  processed?: number;\n  succeeded?: number;\n  failed?: number;\n  details?: RetryDetailEntry[];\n  skipped?: boolean;\n  reason?: string;\n  queue_empty?: boolean;\n  error?: string;\n}\n\n/**\n * Retry-specific memory row with required id and file_path.\n * Uses MemoryDbRow as the base type with Record<string, unknown>\n * for camelCase fallback fields (e.g. retryCount, triggerPhrases).\n */\ntype RetryMemoryRow = Partial<MemoryDbRow> & Record<string, unknown> & {\n  id: number;\n  file_path: string;\n};\n\ntype ContentLoader = (memory: RetryMemoryRow) => Promise<string | null>;\ntype RetryQueueStatus = 'pending' | 'retry';\n\ntype EmbeddingFailureCode =\n  | 'EMBEDDING_PROVIDER_ERROR'\n  | 'EMBEDDING_TIMEOUT'\n  | 'EMBEDDING_RATE_LIMIT';\n\ninterface SanitizeEmbeddingFailureOptions {\n  provider?: string | null;\n  force?: boolean;\n}\n\ninterface SanitizedEmbeddingFailure {\n  code: EmbeddingFailureCode | null;\n  provider: string | null;\n  errorType: string | null;\n  publicMessage: string;\n  sanitized: boolean;\n}\n\ninterface RetryClaimResult {\n  claimed: boolean;\n  previousStatus: RetryQueueStatus | null;\n}\n\nfunction getRetryStatus(memory: RetryMemoryRow): RetryQueueStatus | null {\n  const status = typeof memory.embedding_status === 'string'\n    ? memory.embedding_status\n    : typeof memory.embeddingStatus === 'string'\n      ? memory.embeddingStatus\n      : null;\n\n  return status === 'pending' || status === 'retry' ? status : null;\n}\n\nfunction getRetryCountValue(memory: RetryMemoryRow): number {\n  return Number(memory.retry_count ?? memory.retryCount ?? 0) || 0;\n}\n\nfunction getLastRetryAtValue(memory: RetryMemoryRow): string | null {\n  const value = typeof memory.last_retry_at === 'string'\n    ? memory.last_retry_at\n    : typeof memory.lastRetryAt === 'string'\n      ? memory.lastRetryAt\n      : null;\n  return value && value.trim().length > 0 ? value : null;\n}\n\nfunction detectEmbeddingProviderName(source: string | null | undefined): string | null {\n  if (typeof source !== 'string' || source.trim().length === 0) {\n    return null;\n  }\n\n  const explicitProvider = source.match(/provider=([a-z0-9._-]+)/i);\n  if (explicitProvider?.[1]) {\n    return explicitProvider[1].toLowerCase();\n  }\n\n  const lower = source.toLowerCase();\n  if (lower.includes('voyage')) return 'voyage';\n  if (lower.includes('azure')) return 'azure-openai';\n  if (lower.includes('openai') || lower.includes('text-embedding')) return 'openai';\n  if (lower.includes('system')) return 'system';\n\n  return null;\n}\n\nfunction shouldSanitizeEmbeddingFailure(message: string): boolean {\n  const lower = message.toLowerCase();\n  return (\n    /^embedding_[a-z_]+/.test(lower) ||\n    lower.includes('openai') ||\n    lower.includes('voyage') ||\n    lower.includes('azure') ||\n    lower.includes('text-embedding') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429') ||\n    lower.includes('timeout') ||\n    lower.includes('timed out') ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden') ||\n    lower.includes('quota') ||\n    lower.includes('embedding provider')\n  );\n}\n\nfunction inferEmbeddingFailure(message: string): { code: EmbeddingFailureCode; errorType: string } {\n  const explicitType = message.match(/type=([a-z0-9._-]+)/i)?.[1]?.toLowerCase();\n  const lower = message.toLowerCase();\n\n  if (lower.includes('embedding_timeout') || lower.includes('timeout') || lower.includes('timed out')) {\n    return {\n      code: 'EMBEDDING_TIMEOUT',\n      errorType: explicitType ?? 'timeout',\n    };\n  }\n\n  if (\n    lower.includes('embedding_rate_limit') ||\n    lower.includes('rate limit') ||\n    lower.includes('too many requests') ||\n    lower.includes('429')\n  ) {\n    return {\n      code: 'EMBEDDING_RATE_LIMIT',\n      errorType: explicitType ?? 'rate_limit',\n    };\n  }\n\n  if (\n    explicitType === 'auth' ||\n    lower.includes('api key') ||\n    lower.includes('unauthorized') ||\n    lower.includes('forbidden')\n  ) {\n    return {\n      code: 'EMBEDDING_PROVIDER_ERROR',\n      errorType: 'auth',\n    };\n  }\n\n  return {\n    code: 'EMBEDDING_PROVIDER_ERROR',\n    errorType: explicitType ?? 'provider_error',\n  };\n}","lineStart":1,"lineEnd":220,"totalLines":1141,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781761504500,"end":1781761504504}},"metadata":{"openai":{"itemId":"fc_0ee61f3e8657645f016a3385e04648819188c90f4a48f95b37"}},"id":"prt_ed942f4f3001T2xk5pzE9OTmJI","sessionID":"ses_126bf2c74ffeVn7GN2uRmNhN2M","messageID":"msg_ed942d148001aZBB9WMNHQszL0"}}
