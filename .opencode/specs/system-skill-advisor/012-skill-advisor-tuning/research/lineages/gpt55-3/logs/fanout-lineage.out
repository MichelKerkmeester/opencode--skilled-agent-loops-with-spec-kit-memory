r((lane) => lane.status === 'runtime_degraded')\n    .map((lane) => lane.lane);\n  const runtimeDegradedLanes = new Set(degradedLanes);\n  const graphConflictIndex = buildConflictMatchIndex(graphConflictMatches);\n  const rrfFusion = useRrfFusion\n    ? fuseAdvisorLaneRanks(laneScores, weights, disabled, runtimeDegradedLanes)\n    : null;\n  const laneScoreIndexes = Object.fromEntries(\n    SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),\n  ) as Record<ScorerLane, LaneMatchIndex>;\n  const liveTotal = SCORER_LANES\n    .filter((lane) => !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n    .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();\n  const runtimeLiveLaneCount = SCORER_LANES\n    .filter((lane) => isLiveScorerLane(lane) && !disabled.has(lane) && !runtimeDegradedLanes.has(lane))\n    .length;\n  if (isSpeckitMetricsEnabled() && liveTotal > 0) {\n    for (const lane of SCORER_LANES) {\n      if (!isLiveScorerLane(lane) || disabled.has(lane) || runtimeDegradedLanes.has(lane)) continue;\n      speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });\n    }\n  }\n  const readOnlyExplainer = isReadOnlyExplainer(promptLower);\n  const hasTaskIntent = TASK_INTENT.test(promptLower);\n  const recommendations: AdvisorScoredRecommendation[] = [];\n\n  for (const skill of projection.skills) {\n    if (!isDefaultRoutable(promptLower, skill)) continue;\n    const contributions: LaneContribution[] = SCORER_LANES.map((lane) => {\n      const laneMatch = laneScoreIndexes[lane].get(skill.id);\n      const rawScore = laneMatch?.rawScore ?? 0;\n      const shadowOnly = !isLiveScorerLane(lane);\n      const runtimeDegraded = runtimeDegradedLanes.has(lane);\n      return {\n        lane,\n        rawScore,\n        weightedScore: shadowOnly || disabled.has(lane) || runtimeDegraded ? 0 : rawScore * weights[lane],\n        weight: disabled.has(lane) || runtimeDegraded ? 0 : weights[lane],\n        evidence: laneMatch?.evidence ?? [],\n        shadowOnly,\n      };\n    });\n    const weightedScore = contributions.reduce((total, contribution) => total + contribution.weightedScore, 0);\n    const rrfScore = rrfFusion?.scoreBySkill.get(skill.id);\n    const score = useRrfFusion ? rrfScore ?? 0 : weightedScore;\n    if (score <= 0 && contributions.every((contribution) => contribution.rawScore <= 0)) continue;\n    if (isSpeckitMetricsEnabled()) {\n      for (const contribution of contributions) {\n        if (contribution.weightedScore !== 0) {\n          speckitMetrics.setGauge('spec_kit.scorer.lane_contribution', contribution.weightedScore, { lane: contribution.lane, skill_id: skill.id });\n        }\n      }\n    }\n\n    const directScore = Math.max(\n      contributions.find((contribution) => contribution.lane === 'explicit_author')?.rawScore ?? 0,\n      contributions.find((contribution) => contribution.lane === 'lexical')?.rawScore ?? 0,\n    );\n    const derivedDominant = isDerivedDominant(contributions);\n    const explicitSignal = hasExplicitWorkflowSignal(contributions, skill.id);\n    const explicitMatch = laneScoreIndexes.explicit_author.get(skill.id);\n    const liveNormalized = score / liveTotal;\n    let confidence = confidenceFor({\n      liveNormalized,\n      directScore,\n      readOnlyExplainer,\n      hasExplicitWorkflowSignal: explicitSignal,\n      hasTaskIntent,\n      readOnlyRouteAllowed: readOnlyRouteAllowed(promptLower, skill.id),\n      derivedDominant,\n      skillId: skill.id,\n      selfRecommendationGuardEnabled,\n      hasAdvisorSelfAuthoredSignal: hasAdvisorSelfAuthoredSignal(skill.id, explicitMatch),\n    });\n    if ((skill.id === 'memory:save' || skill.id === 'command-memory-save') && isPlainFileSavePrompt(promptLower)) {\n      confidence = Math.min(confidence, 0.49);\n    }\n    recommendations.push({\n      skill: skill.id,\n      kind: skill.kind,\n      confidence,\n      uncertainty: uncertaintyFor(contributions, confidence, 0),\n      passes_threshold: false,\n      reason: attributionReason(contributions),\n      score: useRrfFusion ? score : Number(score.toFixed(6)),\n      laneContributions: contributions,\n      dominantLane: dominantLane(contributions),\n      redirectTo: skill.redirectTo ?? undefined,\n      redirectFrom: skill.redirectFrom,\n      lifecycleStatus: skill.lifecycleStatus,\n    });\n  }\n\n  if (isSpeckitMetricsEnabled()) {\n    for (const recommendation of recommendations) {\n      if (primaryIntentBonus(promptLower, recommendation, selfRecommendationGuardEnabled) !== 0) {\n        speckitMetrics.incrementCounter('spec_kit.scorer.primary_intent_bonus_applied_total', { skill_id: recommendation.skill });\n      }\n      if (useRrfFusion && graphConflictAdjustment(graphConflictIndex, recommendation) !== 0) {\n        speckitMetrics.incrementCounter('spec_kit.scorer.graph_conflict_demote_applied_total', { skill_id: recommendation.skill });\n      }\n    }\n  }\n  const exactSemanticRerankIndex = useExactSemanticRerank\n    ? buildExactSemanticRerankIndex(prompt, projection, recommendations, rrfFusion)\n    : new Map<string, ExactSemanticRerankEntry>();\n  let ranked = recommendations.sort((left, right) => {\n    const leftCommandBonus = left.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const rightCommandBonus = right.kind === 'command' && !promptLower.includes('/') ? -0.08 : 0;\n    const leftIntent = primaryIntentBonus(promptLower, left, selfRecommendationGuardEnabled);\n    const rightIntent = primaryIntentBonus(promptLower, right, selfRecommendationGuardEnabled);\n    const leftConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, left) : 0;\n    const rightConflict = useRrfFusion ? graphConflictAdjustment(graphConflictIndex, right) : 0;\n    const adjustedScoreDiff = (right.score + rightCommandBonus + rightIntent + rightConflict)\n      - (left.score + leftCommandBonus + leftIntent + leftConflict);\n    if (useRrfFusion) {\n      const leftExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, left);\n      const rightExactSemantic = exactSemanticRerankScore(exactSemanticRerankIndex, right);\n      if (leftExactSemantic !== null\n        && rightExactSemantic !== null\n        && Math.abs(adjustedScoreDiff) <= ADVISOR_EXACT_SEMANTIC_RERANK_WINDOW) {\n        const exactSemanticDiff = rightExactSemantic - leftExactSemantic;\n        if (exactSemanticDiff !== 0) {\n          return exactSemanticDiff;\n        }\n      }\n      return adjustedScoreDiff\n        || rrfRankFor(rrfFusion, left) - rrfRankFor(rrfFusion, right)\n        || left.skill.localeCompare(right.skill);\n    }\n    return adjustedScoreDiff\n      || right.confidence - left.confidence\n      || left.skill.localeCompare(right.skill);\n  });\n\n  ranked = ranked.map((recommendation, index) => {\n    const next = ranked[index + 1];\n    const ambiguityPressure = next && Math.abs(recommendation.confidence - next.confidence) <= 0.05 ? 0.04 : 0;\n    const uncertainty = uncertaintyFor(recommendation.laneContributions, recommendation.confidence, ambiguityPressure);\n    return {\n      ...recommendation,\n      uncertainty,\n      passes_threshold: recommendation.confidence >= (options.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)\n        && uncertainty <= (options.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD),\n    };\n  });\n  ranked = applyAmbiguity(ranked);\n\n  // Low-information ambiguity abstention: a short, intent-less prompt that lands\n  // in a multi-candidate ambiguity cluster is genuinely under-specified. Floor\n  // every cluster member's uncertainty above the strict threshold so strict\n  // callers abstain, while confidence-only callers still surface the best guess\n  // (the disambiguated top-ranked candidate).\n  const meaningfulTokenCount = promptLower.split(/\\s+/).filter((token) => token.length > 1).length;\n  const lowInfoPrompt = meaningfulTokenCount <= 3 && !hasTaskIntent && !promptLower.includes('/');\n  if (lowInfoPrompt) {\n    const clusterMembers = ranked.filter((recommendation) => (recommendation.ambiguousWith?.length ?? 0) > 0);\n    // Only abstain when the cluster's lead is built from diffuse, shared\n    // single-word keyword matches rather than a distinctive multi-word phrase\n    // anchor (an explicit-author/derived phrase match such as \"code audit\").\n    // A multi-word anchor means the prompt does pin a specific skill, so it","lineStart":630,"lineEnd":819,"totalLines":911,"truncated":true}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/fusion.ts","time":{"start":1783437267578,"end":1783437267586}},"metadata":{"openai":{"itemId":"fc_0b81288b6af006b9016a4d17d35c70819188223d84ff76e186"}},"id":"prt_f3d251264001GHTpTXP2aaWdkm","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d24e568001v7g5HAo6oWWDiT"}}
{"type":"tool_use","timestamp":1783437267634,"sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","part":{"type":"tool","tool":"read","callID":"call_lIvhBH1zF4sNKZnsV592f0a1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/weights-config.ts","offset":1,"limit":120},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/weights-config.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Scorer Weights Config\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: import { z } from 'zod';\n6: import {\n7:   DEFAULT_SCORER_LANE_WEIGHTS,\n8:   SCORER_LANE_IDS,\n9:   SCORER_LANE_REGISTRY,\n10:   isLiveScorerLane,\n11: } from './lane-registry.js';\n12: import type { ScorerLane } from './types.js';\n13: \n14: export const EXPLICIT_AUTHOR_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.explicit_author;\n15: export const LEXICAL_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.lexical;\n16: export const GRAPH_CAUSAL_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.graph_causal;\n17: export const DERIVED_GENERATED_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.derived_generated;\n18: export const SEMANTIC_SHADOW_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.semantic_shadow;\n19: \n20: export const DEFAULT_SCORER_WEIGHTS = DEFAULT_SCORER_LANE_WEIGHTS as Readonly<Record<ScorerLane, number>>;\n21: \n22: export const SCORER_LANES = SCORER_LANE_IDS;\n23: \n24: export const ScorerWeightsSchema = z.object(Object.fromEntries(\n25:   SCORER_LANE_REGISTRY.map((lane) => [lane.id, z.literal(lane.weight)]),\n26: ) as Record<ScorerLane, z.ZodLiteral<number>>).strict();\n27: \n28: export type ScorerWeights = z.infer<typeof ScorerWeightsSchema>;\n29: \n30: export interface ScorerCalibrationThresholds {\n31:   readonly confidenceThreshold: number;\n32:   readonly uncertaintyThreshold: number;\n33: }\n34: \n35: export interface ReadOnlyScorerCalibrationProposal {\n36:   readonly model: 'advisor-feedback-calibration-shadow-v1';\n37:   readonly liveWeightsFrozen: true;\n38:   readonly autoPromotion: false;\n39:   readonly heldOutValidationRequired: true;\n40:   readonly currentWeights: ScorerWeights;\n41:   readonly proposedWeights: Readonly<Record<ScorerLane, number>>;\n42:   readonly currentThresholds: ScorerCalibrationThresholds;\n43:   readonly proposedThresholds: ScorerCalibrationThresholds;\n44: }\n45: \n46: export function parseScorerWeights(input: unknown = DEFAULT_SCORER_WEIGHTS): ScorerWeights {\n47:   return ScorerWeightsSchema.parse(input);\n48: }\n49: \n50: export function liveWeightTotal(weights: ScorerWeights = DEFAULT_SCORER_WEIGHTS): number {\n51:   return SCORER_LANES.reduce((total, lane) => {\n52:     if (!isLiveScorerLane(lane)) return total;\n53:     return total + weights[lane];\n54:   }, 0);\n55: }\n56: \n57: function boundedUnit(value: number): number {\n58:   return Number(Math.max(0, Math.min(1, value)).toFixed(4));\n59: }\n60: \n61: export function buildReadOnlyScorerCalibrationProposal(input: {\n62:   readonly proposedWeightDeltas?: Partial<Record<ScorerLane, number>>;\n63:   readonly currentThresholds: ScorerCalibrationThresholds;\n64:   readonly proposedThresholdDeltas?: Partial<ScorerCalibrationThresholds>;\n65: }): ReadOnlyScorerCalibrationProposal {\n66:   const currentWeights = parseScorerWeights(DEFAULT_SCORER_WEIGHTS);\n67:   const proposedWeights = Object.fromEntries(SCORER_LANES.map((lane) => {\n68:     const delta = input.proposedWeightDeltas?.[lane] ?? 0;\n69:     return [lane, boundedUnit(currentWeights[lane] + delta)];\n70:   })) as Readonly<Record<ScorerLane, number>>;\n71:   return {\n72:     model: 'advisor-feedback-calibration-shadow-v1',\n73:     liveWeightsFrozen: true,\n74:     autoPromotion: false,\n75:     heldOutValidationRequired: true,\n76:     currentWeights,\n77:     proposedWeights,\n78:     currentThresholds: {\n79:       confidenceThreshold: boundedUnit(input.currentThresholds.confidenceThreshold),\n80:       uncertaintyThreshold: boundedUnit(input.currentThresholds.uncertaintyThreshold),\n81:     },\n82:     proposedThresholds: {\n83:       confidenceThreshold: boundedUnit(\n84:         input.currentThresholds.confidenceThreshold + (input.proposedThresholdDeltas?.confidenceThreshold ?? 0),\n85:       ),\n86:       uncertaintyThreshold: boundedUnit(\n87:         input.currentThresholds.uncertaintyThreshold + (input.proposedThresholdDeltas?.uncertaintyThreshold ?? 0),\n88:       ),\n89:     },\n90:   };\n91: }\n\n(End of file - total 91 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Scorer Weights Config\n// ───────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\nimport {\n  DEFAULT_SCORER_LANE_WEIGHTS,\n  SCORER_LANE_IDS,\n  SCORER_LANE_REGISTRY,\n  isLiveScorerLane,\n} from './lane-registry.js';\nimport type { ScorerLane } from './types.js';\n\nexport const EXPLICIT_AUTHOR_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.explicit_author;\nexport const LEXICAL_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.lexical;\nexport const GRAPH_CAUSAL_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.graph_causal;\nexport const DERIVED_GENERATED_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.derived_generated;\nexport const SEMANTIC_SHADOW_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.semantic_shadow;\n\nexport const DEFAULT_SCORER_WEIGHTS = DEFAULT_SCORER_LANE_WEIGHTS as Readonly<Record<ScorerLane, number>>;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/weights-config.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Scorer Weights Config\n// ───────────────────────────────────────────────────────────────\n\nimport { z } from 'zod';\nimport {\n  DEFAULT_SCORER_LANE_WEIGHTS,\n  SCORER_LANE_IDS,\n  SCORER_LANE_REGISTRY,\n  isLiveScorerLane,\n} from './lane-registry.js';\nimport type { ScorerLane } from './types.js';\n\nexport const EXPLICIT_AUTHOR_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.explicit_author;\nexport const LEXICAL_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.lexical;\nexport const GRAPH_CAUSAL_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.graph_causal;\nexport const DERIVED_GENERATED_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.derived_generated;\nexport const SEMANTIC_SHADOW_WEIGHT = DEFAULT_SCORER_LANE_WEIGHTS.semantic_shadow;\n\nexport const DEFAULT_SCORER_WEIGHTS = DEFAULT_SCORER_LANE_WEIGHTS as Readonly<Record<ScorerLane, number>>;\n\nexport const SCORER_LANES = SCORER_LANE_IDS;\n\nexport const ScorerWeightsSchema = z.object(Object.fromEntries(\n  SCORER_LANE_REGISTRY.map((lane) => [lane.id, z.literal(lane.weight)]),\n) as Record<ScorerLane, z.ZodLiteral<number>>).strict();\n\nexport type ScorerWeights = z.infer<typeof ScorerWeightsSchema>;\n\nexport interface ScorerCalibrationThresholds {\n  readonly confidenceThreshold: number;\n  readonly uncertaintyThreshold: number;\n}\n\nexport interface ReadOnlyScorerCalibrationProposal {\n  readonly model: 'advisor-feedback-calibration-shadow-v1';\n  readonly liveWeightsFrozen: true;\n  readonly autoPromotion: false;\n  readonly heldOutValidationRequired: true;\n  readonly currentWeights: ScorerWeights;\n  readonly proposedWeights: Readonly<Record<ScorerLane, number>>;\n  readonly currentThresholds: ScorerCalibrationThresholds;\n  readonly proposedThresholds: ScorerCalibrationThresholds;\n}\n\nexport function parseScorerWeights(input: unknown = DEFAULT_SCORER_WEIGHTS): ScorerWeights {\n  return ScorerWeightsSchema.parse(input);\n}\n\nexport function liveWeightTotal(weights: ScorerWeights = DEFAULT_SCORER_WEIGHTS): number {\n  return SCORER_LANES.reduce((total, lane) => {\n    if (!isLiveScorerLane(lane)) return total;\n    return total + weights[lane];\n  }, 0);\n}\n\nfunction boundedUnit(value: number): number {\n  return Number(Math.max(0, Math.min(1, value)).toFixed(4));\n}\n\nexport function buildReadOnlyScorerCalibrationProposal(input: {\n  readonly proposedWeightDeltas?: Partial<Record<ScorerLane, number>>;\n  readonly currentThresholds: ScorerCalibrationThresholds;\n  readonly proposedThresholdDeltas?: Partial<ScorerCalibrationThresholds>;\n}): ReadOnlyScorerCalibrationProposal {\n  const currentWeights = parseScorerWeights(DEFAULT_SCORER_WEIGHTS);\n  const proposedWeights = Object.fromEntries(SCORER_LANES.map((lane) => {\n    const delta = input.proposedWeightDeltas?.[lane] ?? 0;\n    return [lane, boundedUnit(currentWeights[lane] + delta)];\n  })) as Readonly<Record<ScorerLane, number>>;\n  return {\n    model: 'advisor-feedback-calibration-shadow-v1',\n    liveWeightsFrozen: true,\n    autoPromotion: false,\n    heldOutValidationRequired: true,\n    currentWeights,\n    proposedWeights,\n    currentThresholds: {\n      confidenceThreshold: boundedUnit(input.currentThresholds.confidenceThreshold),\n      uncertaintyThreshold: boundedUnit(input.currentThresholds.uncertaintyThreshold),\n    },\n    proposedThresholds: {\n      confidenceThreshold: boundedUnit(\n        input.currentThresholds.confidenceThreshold + (input.proposedThresholdDeltas?.confidenceThreshold ?? 0),\n      ),\n      uncertaintyThreshold: boundedUnit(\n        input.currentThresholds.uncertaintyThreshold + (input.proposedThresholdDeltas?.uncertaintyThreshold ?? 0),\n      ),\n    },\n  };\n}","lineStart":1,"lineEnd":91,"totalLines":91,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/weights-config.ts","time":{"start":1783437267625,"end":1783437267632}},"metadata":{"openai":{"itemId":"fc_0b81288b6af006b9016a4d17d35c7c819187db34ea93830ead"}},"id":"prt_f3d25127b001piXs5RCYszDCxy","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"ms