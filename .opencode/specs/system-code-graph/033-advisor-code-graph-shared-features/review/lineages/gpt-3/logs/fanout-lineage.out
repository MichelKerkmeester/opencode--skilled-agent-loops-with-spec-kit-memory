ts', edgeType: 'IMPORTS', confidence: 0.9 },\n            { fromFile: 'src/b.ts', toFile: 'src/c.ts', edgeType: 'IMPORTS', confidence: 0.8 },\n          ],\n          confidence: 0.8,\n          ambiguous: false,\n          truncationReason: 'max_depth',\n        },\n      },\n    ]);\n  });\n\n  it('surfaces blast-radius ambiguity candidates without choosing a default node', async () => {\n    mocks.getDb.mockReturnValue(createDb({\n      byFq: [\n        {\n          symbolId: 'first-symbol',\n          fqName: 'Ambiguous.handle',","lineStart":1460,"lineEnd":1589,"totalLines":1627,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/tests/code-graph-query-handler.vitest.ts","time":{"start":1781129284256,"end":1781129284264}},"metadata":{"openai":{"itemId":"fc_0b918f31975f7d60016a29e04427948191b6d8b5a884dc6c30"}},"id":"prt_eb3940a9b001NLZqo6dNJ63zXc","sessionID":"ses_14c6db1ddffeUV55sd7d2xz9Di","messageID":"msg_eb393ec69001zviIEZE1IXI3QO"}}
