   138	        command: "node .opencode/skills/deep-agent-improvement/scripts/shared/improvement-journal.cjs --emit session_start --journal {spec_folder}/improvement/improvement-journal.jsonl --details '{\"sessionId\":\"{session_id}\",\"target\":\"{profile}\",\"startedAt\":\"{started_at}\"}'"
   139	
   140	  phase_loop:
   141	    description: "Iterative benchmark -> reduce cycle"
   142	    repeat: true
   143	    max_repeats: "{max_iterations}"
   144	    steps:
