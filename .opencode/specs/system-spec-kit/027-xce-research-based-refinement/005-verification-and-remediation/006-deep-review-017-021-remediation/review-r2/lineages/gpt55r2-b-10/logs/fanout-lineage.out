{"type":"text","timestamp":1781764483684,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"id":"prt_ed9705b0a001vZoMYrYXKbSxVq","messageID":"msg_ed97047fe001GS06tgEG5Sc6ON","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","type":"text","text":"The second candidate is whether tombstoned rows remain visible through FTS/vector surfaces. IвҖҷm reading the delete fallbacks and query filters now; if the search paths exclude `deleted_at`, this candidate will be downgraded or dismissed.","time":{"start":1781764479754,"end":1781764483682},"metadata":{"openai":{"itemId":"msg_06864e8d4f0dcc5c016a33917fb96881919b5129ebb48155a3","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781764483766,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_cMDZw91yedYasa4LkAuCVbZ6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Crud Delete\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: \n5: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n6:    IMPORTS\n7: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n34:    CORE LOGIC\n35: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper вҖ” wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n181:     const deletedIds: number[] = [];\n182:     const hashById = new Map<number, MemoryHashSnapshot>();\n183: \n184:     if (database && 'prepare' in database) {\n185:       try {\n186:         const rows = database.prepare(`\n187:           SELECT id, content_hash, spec_folder, file_path\n188:           FROM memory_index\n189:           WHERE spec_folder = ?\n190:         `).all(specFolder as string) as MemoryHashSnapshot[];\n191: \n192:         for (const row of rows) {\n193:           hashById.set(row.id, row);\n194:         }\n195:       } catch (_err: unknown) {\n196:         // Non-fatal вҖ” bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n197:       }\n198:     }\n199: \n200:     if (memories.length > 0) {\n201:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n202:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n203:       try {\n204:         const checkpoint = checkpoints.createCheckpoint({\n205:           name: proposedCheckpointName,\n206:           specFolder,\n207:           metadata: {\n208:             reason: 'auto-checkpoint before bulk delete',\n209:             memoryCount: memories.length,\n210:           },\n211:         });\n212: \n213:         if (checkpoint) {\n214:           checkpointName = checkpoint.name;\n215:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n216:         } else {\n217:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n218:           checkpointName = null;\n219:         }\n220:       } catch (cpErr: unknown) {\n221:         const message = toErrorMessage(cpErr);\n222:         console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n223:         // Confirm is always true here (validated at function entry) вҖ” safe to proceed without checkpoint.\n224:         console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n225:         checkpointName = null;\n226:       }\n227:     }\n228: \n229:     // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n230:     causalEdges.init(database);\n231:     const bulkDeleteTx = database.transaction(() => {\n232:       for (const memory of memories) {\n233:         if (tombstoneMemory(database, memory.id)) {\n234:           // Record DELETE history after confirmed delete (no FK, history rows survive).\n235:           try {\n236:             const snapshot = hashById.get(memory.id);\n237:             recordHistory(\n238:               memory.id,\n239:               'DELETE',\n240:               snapshot?.file_path ?? null,\n241:               null,\n242:               'mcp:memory_delete',\n243:               snapshot?.spec_folder ?? null,\n244:             );\n245:           } catch (_histErr: unknown) {\n246:             // History recording is best-effort inside bulk delete\n247:           }\n248:           deletedCount++;\n249:           deletedIds.push(memory.id);\n250:           causalEdges.deleteEdgesForMemory(String(memory.id), {\n251:             reason: 'memory row mutation cleanup',\n252:             command: 'memory-crud-delete.handleMemoryDelete',\n253:             restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n254:           });\n255:         }\n256:       }\n257: \n258:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n259:       for (const deletedId of deletedIds) {\n260:         const snapshot = hashById.get(deletedId) ?? null;\n\n(Showing lines 1-260 of 344. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Crud Delete\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Crud Delete\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   CORE LOGIC\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper вҖ” wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal вҖ” bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {\n        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) вҖ” safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id), {\n            reason: 'memory row mutation cleanup',\n            command: 'memory-crud-delete.handleMemoryDelete',\n            restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n          });\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;","lineStart":1,"lineEnd":260,"totalLines":344,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781764483750,"end":1781764483765}},"metadata":{"openai":{"itemId":"fc_06864e8d4f0dcc5c016a3391839f48819180efca37e09f0a49"}},"id":"prt_ed9706a66001Uo80pg0zPr32AI","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed97047fe001GS06tgEG5Sc6ON"}}
{"type":"tool_use","timestamp":1781764483787,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_hA1bcqsGHYKJg6NIpZxsvjZP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Bulk Delete\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Tier-based bulk deletion of memories with safety gates.\n5: // Eliminates the need for direct DB scripts when cleaning up\n6: // Deprecated/temporary memories at scale.\n7: import { checkDatabaseUpdated } from '../core/index.js';\n8: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n9: import * as vectorIndex from '../lib/search/vector-index.js';\n10: import * as checkpoints from '../lib/storage/checkpoints.js';\n11: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { createStatediffAction } from '../lib/storage/statediff.js';\n14: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { recordHistory } from '../lib/storage/history.js';\n18: import { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\n19: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: \n23: import type { MCPResponse } from './types.js';\n24: \n25: // Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n26: // Feature catalog: Per-memory history log\n27: \n28: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n29:    1. TYPES\n30: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n31: \n32: interface BulkDeleteArgs {\n33:   tier: string;\n34:   specFolder?: string;\n35:   confirm: boolean;\n36:   olderThanDays?: number;\n37:   skipCheckpoint?: boolean;\n38: }\n39: \n40: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n41:   if (!database || !('prepare' in database)) return false;\n42:   try {\n43:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n44:     return columns.some((column) => column.name === 'deleted_at');\n45:   } catch {\n46:     return false;\n47:   }\n48: }\n49: \n50: function isSoftDeleteTombstonesEnabled(): boolean {\n51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n52: }\n53: \n54: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n55:   if (!isSoftDeleteTombstonesEnabled()) {\n56:     return vectorIndex.deleteMemory(memoryId, database);\n57:   }\n58: \n59:   if (!hasDeletedAtColumn(database)) {\n60:     return vectorIndex.deleteMemory(memoryId, database);\n61:   }\n62: \n63:   const deletedAt = new Date().toISOString();\n64:   const result = database.prepare(`\n65:     UPDATE memory_index\n66:     SET deleted_at = COALESCE(deleted_at, ?),\n67:         updated_at = datetime('now')\n68:     WHERE id = ?\n69:   `).run(deletedAt, memoryId);\n70:   return result.changes > 0;\n71: }\n72: \n73: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n74:     2. HANDLER\n75: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n76: \n77: async function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n78:   await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n79:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n80:   if (restoreBarrier) {\n81:     return createMCPErrorResponse({\n82:       tool: 'memory_bulk_delete',\n83:       error: restoreBarrier.message,\n84:       code: restoreBarrier.code,\n85:       details: {\n86:         tier: args.tier ?? null,\n87:         specFolder: args.specFolder ?? null,\n88:       },\n89:       recovery: {\n90:         hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n91:         actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   await checkDatabaseUpdated();\n98: \n99:   const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n100: \n101:   // Validation\n102:   if (!tier || typeof tier !== 'string') {\n103:     throw new Error('tier is required and must be a string');\n104:   }\n105: \n106:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n107:   if (!validTiers.includes(tier)) {\n108:     throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n109:   }\n110: \n111:   if (!confirm) {\n112:     throw new Error('Bulk delete requires confirm: true as a safety gate');\n113:   }\n114: \n115:   // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n116:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n117:     throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n118:   }\n119: \n120:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n121:     throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n122:   }\n123: \n124:   if (\n125:     olderThanDays !== undefined\n126:     && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n127:   ) {\n128:     throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n129:   }\n130: \n131:   const database = vectorIndex.getDb();\n132:   if (!database) {\n133:     return createMCPErrorResponse({\n134:       tool: 'memory_bulk_delete',\n135:       error: 'Memory bulk delete aborted: database unavailable',\n136:       code: 'E_DB_UNAVAILABLE',\n137:       details: {\n138:         tier,\n139:         specFolder: specFolder || null,\n140:         olderThanDays: olderThanDays || null,\n141:       },\n142:       recovery: {\n143:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n144:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n145:         severity: 'error',\n146:       },\n147:     });\n148:   }\n149: \n150:   // Build query to count affected memories\n151:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n152:   const countParams: unknown[] = [tier];\n153: \n154:   if (specFolder) {\n155:     countSql += ' AND spec_folder = ?';\n156:     countParams.push(specFolder);\n157:   }\n158: \n159:   if (olderThanDays !== undefined) {\n160:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n161:     countParams.push(olderThanDays);\n162:   }\n163: \n164:   const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n165:   const affectedCount = countResult.count;\n166: \n167:   if (affectedCount === 0) {\n168:     return createMCPSuccessResponse({\n169:       tool: 'memory_bulk_delete',\n170:       summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n172:       hints: ['Use memory_list() to browse existing memories'],\n173:     });\n174:   }\n175: \n176:   // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n177:   let checkpointName: string | null = null;\n178:   if (!skipCheckpoint) {\n179:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n181: \n182:     try {\n183:       const checkpoint = checkpoints.createCheckpoint({\n184:         name: proposedCheckpointName,\n185:         specFolder,\n186:         metadata: {\n187:           reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n188:           tier,\n189:           affectedCount,\n190:           olderThanDays: olderThanDays || null,\n191:         },\n192:       });\n193: \n194:       if (!checkpoint) {\n195:         const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n196:         if (tier === 'constitutional' || tier === 'critical') {\n197:           throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n198:         }\n199:         console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n200:       } else {\n201:         checkpointName = checkpoint.name;\n202:         console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n203:       }\n204:     } catch (cpErr: unknown) {\n205:       const message = toErrorMessage(cpErr);\n206:       console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n207:       // High-safety tiers require a valid checkpoint.\n208:       if (tier === 'constitutional' || tier === 'critical') {\n209:         throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n210:       }\n211:       // Lower tiers can proceed with explicit no-rollback notice.\n212:       checkpointName = null;\n213:     }\n214:   } else {\n215:     console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n216:   }\n217: \n218:   // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n219:   let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n220:   const selectParams: unknown[] = [tier];\n221: \n222:   if (specFolder) {\n223:     selectSql += ' AND spec_folder = ?';\n224:     selectParams.push(specFolder);\n225:   }\n226: \n227:   if (olderThanDays !== undefined) {\n228:     selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n229:     selectParams.push(olderThanDays);\n230:   }\n231: \n232:   const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n233:     id: number;\n234:     content_hash: string | null;\n235:     file_path: string | null;\n236:     spec_folder: string | null;\n237:   }>;\n238: \n239:   // Perform deletion in a transaction\n240:   let deletedCount = 0;\n241:   const deletedIds: number[] = [];\n242: \n243:   causalEdges.init(database);\n244: \n245:   const bulkDeleteTx = database.transaction(() => {\n246:     for (const memory of memoriesToDelete) {\n247:       if (tombstoneMemory(database, memory.id)) {\n248:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n249:         try {\n250:           recordHistory(\n251:             memory.id,\n252:             'DELETE',\n253:             memory.file_path ?? null,\n254:             null,\n255:             'mcp:memory_bulk_delete',\n256:             memory.spec_folder ?? null,\n257:           );\n258:         } catch (_histErr: unknown) {\n259:           // History recording is best-effort inside bulk delete\n260:         }\n\n(Showing lines 1-260 of 372. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Bulk Delete\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Bulk Delete\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n// Feature catalog: Per-memory history log\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\ninterface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    2. HANDLER\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nasync function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        tier: args.tier ?? null,\n        specFolder: args.specFolder ?? null,\n      },\n      recovery: {\n        hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n\n  // Validation\n  if (!tier || typeof tier !== 'string') {\n    throw new Error('tier is required and must be a string');\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n  }\n\n  if (!confirm) {\n    throw new Error('Bulk delete requires confirm: true as a safety gate');\n  }\n\n  // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n  }\n\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n  }\n\n  if (\n    olderThanDays !== undefined\n    && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n  ) {\n    throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n  }\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: 'Memory bulk delete aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        tier,\n        specFolder: specFolder || null,\n        olderThanDays: olderThanDays || null,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Build query to count affected memories\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(olderThanDays);\n  }\n\n  const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  if (affectedCount === 0) {\n    return createMCPSuccessResponse({\n      tool: 'memory_bulk_delete',\n      summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n      data: { deleted: 0, tier, specFolder: specFolder || null },\n      hints: ['Use memory_list() to browse existing memories'],\n    });\n  }\n\n  // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n    try {\n      const checkpoint = checkpoints.createCheckpoint({\n        name: proposedCheckpointName,\n        specFolder,\n        metadata: {\n          reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n          tier,\n          affectedCount,\n          olderThanDays: olderThanDays || null,\n        },\n      });\n\n      if (!checkpoint) {\n        const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n        if (tier === 'constitutional' || tier === 'critical') {\n          throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n        }\n        console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n      } else {\n        checkpointName = checkpoint.name;\n        console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n      }\n    } catch (cpErr: unknown) {\n      const message = toErrorMessage(cpErr);\n      console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n      // High-safety tiers require a valid checkpoint.\n      if (tier === 'constitutional' || tier === 'critical') {\n        throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n      }\n      // Lower tiers can proceed with explicit no-rollback notice.\n      checkpointName = null;\n    }\n  } else {\n    console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n  }\n\n  // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n  let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n  const selectParams: unknown[] = [tier];\n\n  if (specFolder) {\n    selectSql += ' AND spec_folder = ?';\n    selectParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    selectParams.push(olderThanDays);\n  }\n\n  const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n    id: number;\n    content_hash: string | null;\n    file_path: string | null;\n    spec_folder: string | null;\n  }>;\n\n  // Perform deletion in a transaction\n  let deletedCount = 0;\n  const deletedIds: number[] = [];\n\n  causalEdges.init(database);\n\n  const bulkDeleteTx = database.transaction(() => {\n    for (const memory of memoriesToDelete) {\n      if (tombstoneMemory(database, memory.id)) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        try {\n          recordHistory(\n            memory.id,\n            'DELETE',\n            memory.file_path ?? null,\n            null,\n            'mcp:memory_bulk_delete',\n            memory.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort inside bulk delete\n        }","lineStart":1,"lineEnd":260,"totalLines":372,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","time":{"start":1781764483776,"end":1781764483785}},"metadata":{"openai":{"itemId":"fc_06864e8d4f0dcc5c016a3391839f588191a7aad281041404e7"}},"id":"prt_ed9706ab2001X51A0xOSN6o6iD","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed97047fe001GS06tgEG5Sc6ON"}}
{"type":"tool_use","timestamp":1781764483789,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_cGitTxDPwcQRmP8LV4FCDZ9D","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Vector Index Mutations\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts вҖ” contains ALL mutation functions:\n6: // Index, update, delete, and status/confidence updates.\n7: \n8: import * as embeddingsProvider from '../providers/embeddings.js';\n9: import {\n10:   buildGovernanceLogicalKey,\n11:   normalizeScopeValue,\n12:   recordTierDowngradeAudit,\n13: } from '../governance/scope-governance.js';\n14: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n15: import { recordHistory } from '../storage/history.js';\n16: import { buildMemoryLogicalKey } from '../storage/lineage-state.js';\n17: import { getCanonicalPathKey } from '../utils/canonical-path.js';\n18: import { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n19: import { createLogger } from '../utils/logger.js';\n20: import { deleteByContentHash } from '../cache/embedding-cache.js';\n21: import { clearDegreeCacheForDb } from './graph-search-fn.js';\n22: import { sweepCausalEdges } from '../causal/sweep.js';\n23: import { bumpCausalEdgesGeneration } from '../storage/causal-generation.js';\n24: import * as bm25Index from './bm25-index.js';\n25: import {\n26:   clear_search_cache,\n27: } from './vector-index-aliases.js';\n28: import { invalidateEntityDensityCache } from './entity-density.js';\n29: import {\n30:   get_error_message,\n31:   to_embedding_buffer,\n32:   VectorIndexError,\n33:   VectorIndexErrorCode,\n34: } from './vector-index-types.js';\n35: import {\n36:   clear_constitutional_cache,\n37:   get_embedding_dim,\n38:   initialize_db,\n39:   init_prepared_statements,\n40:   refresh_interference_scores_for_folder,\n41:   sqlite_vec_available as get_sqlite_vec_available,\n42:   activeVectorSource,\n43: } from './vector-index-store.js';\n44: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder, vecTableNameForDim } from '../embedders/schema.js';\n45: import type {\n46:   IndexMemoryParams as SharedIndexMemoryParams,\n47:   MemoryScopeParams,\n48:   UpdateMemoryParams as SharedUpdateMemoryParams,\n49: } from './vector-index-types.js';\n50: import type Database from 'better-sqlite3';\n51: \n52: const logger = createLogger('VectorIndex');\n53: \n54: function isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n55:   const message = get_error_message(error).toLowerCase();\n56:   return message.includes('no such table') && message.includes('vec_memories');\n57: }\n58: \n59: function activeVectorTableExists(database: Database.Database, tableName: string): boolean {\n60:   try {\n61:     const row = database.prepare(`\n62:       SELECT 1 AS found\n63:       FROM ${activeVectorSource('sqlite_master')}\n64:       WHERE type = 'table' AND name = ?\n65:       LIMIT 1\n66:     `).get(tableName) as { found?: number } | undefined;\n67:     return row?.found === 1;\n68:   } catch (_error: unknown) {\n69:     return false;\n70:   }\n71: }\n72: \n73: function activeDimVectorSource(database: Database.Database): string | null {\n74:   const active = getActiveEmbedder(database);\n75:   if (active.name === DEFAULT_ACTIVE_EMBEDDER.name) {\n76:     return null;\n77:   }\n78:   const tableName = vecTableNameForDim(active.dim);\n79:   return activeVectorTableExists(database, tableName) ? activeVectorSource(tableName) : null;\n80: }\n81: \n82: function writeActiveVectorPayload(database: Database.Database, id: bigint, embeddingBuffer: Buffer): void {\n83:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n84:   database.prepare(`\n85:     INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)\n86:   `).run(id, embeddingBuffer);\n87: \n88:   const dimSource = activeDimVectorSource(database);\n89:   if (dimSource) {\n90:     database.prepare(`INSERT OR REPLACE INTO ${dimSource} (id, vec) VALUES (?, ?)`).run(id, embeddingBuffer);\n91:   }\n92: }\n93: \n94: function deleteActiveVectorPayload(database: Database.Database, id: bigint): void {\n95:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n96:   const dimSource = activeDimVectorSource(database);\n97:   if (dimSource) {\n98:     database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n99:   }\n100: }\n101: \n102: function invalidateGraphCaches(database: Database.Database): void {\n103:   // Bump the generation FIRST so every cache key that includes it (e.g.\n104:   // memory_search with causal boost) goes stale before the per-db caches clear;\n105:   // without this, memory-delete sweeps served stale causal-boosted search results.\n106:   bumpCausalEdgesGeneration();\n107: \n108:   try {\n109:     clearDegreeCacheForDb(database);\n110:   } catch (_error: unknown) {\n111:     // Degree cache invalidation is best-effort for legacy mutation paths.\n112:   }\n113: \n114:   try {\n115:     clearGraphSignalsCache();\n116:   } catch (_error: unknown) {\n117:     // Graph signal cache invalidation is best-effort for legacy mutation paths.\n118:   }\n119: }\n120: \n121: function tryRecordTierDowngradeAudit(\n122:   database: Database.Database,\n123:   params: {\n124:     memoryId: number;\n125:     specFolder: string | null | undefined;\n126:     anchorId: string | null | undefined;\n127:     filePath: string | null | undefined;\n128:     canonicalFilePath: string | null | undefined;\n129:     requestedTier?: string | null | undefined;\n130:     previousTier?: string | null | undefined;\n131:     nextTier: string;\n132:     source: string;\n133:   },\n134: ): void {\n135:   try {\n136:     recordTierDowngradeAudit(database, {\n137:       memoryId: params.memoryId,\n138:       logicalKey: buildGovernanceLogicalKey(\n139:         params.specFolder,\n140:         params.canonicalFilePath || params.filePath,\n141:         params.anchorId,\n142:       ),\n143:       requestedTier: params.requestedTier ?? undefined,\n144:       previousTier: params.previousTier ?? undefined,\n145:       nextTier: params.nextTier,\n146:       source: params.source,\n147:       filePath: params.filePath ?? null,\n148:       canonicalFilePath: params.canonicalFilePath ?? null,\n149:     });\n150:   } catch (error: unknown) {\n151:     logger.warn('Failed to record governance audit for tier downgrade', {\n152:       memoryId: params.memoryId,\n153:       source: params.source,\n154:       message: get_error_message(error),\n155:     });\n156:   }\n157: }\n158: \n159: function deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n160:   const ancillaryTables = [\n161:     'DELETE FROM degree_snapshots WHERE memory_id = ?',\n162:     'DELETE FROM community_assignments WHERE memory_id = ?',\n163:     'DELETE FROM memory_summaries WHERE memory_id = ?',\n164:     'DELETE FROM memory_entities WHERE memory_id = ?',\n165:     'DELETE FROM memory_lineage WHERE memory_id = ?',\n166:   ];\n167: \n168:   for (const sql of ancillaryTables) {\n169:     try {\n170:       const paramCount = (sql.match(/\\?/g) || []).length;\n171:       if (paramCount === 2) {\n172:         database.prepare(sql).run(id, id);\n173:       } else {\n174:         database.prepare(sql).run(id);\n175:       }\n176:     } catch (_error: unknown) {\n177:       // Best-effort for legacy databases that may not have these tables yet.\n178:     }\n179:   }\n180: \n181:   // Clean active_memory_projection rows referencing this memory.\n182:   try {\n183:     database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n184:   } catch (_error: unknown) {\n185:     // Best-effort for legacy databases that may not have projection tables yet.\n186:   }\n187: \n188:   try {\n189:     const result = sweepCausalEdges(database, {\n190:       memoryIds: [id, String(id)],\n191:       reason: 'memory row mutation cleanup',\n192:       command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n193:       restoreContext: { memoryId: id },\n194:       invalidateCaches: false,\n195:     });\n196:     if (result.deleted > 0) {\n197:       invalidateGraphCaches(database);\n198:     }\n199:   } catch (error: unknown) {\n200:     // Tolerate only legacy databases that predate the causal-edge tables. Scope\n201:     // the match to those table names so an unrelated missing-table error still\n202:     // propagates and rolls back the surrounding delete instead of committing a\n203:     // hard delete without its tombstone audit row.\n204:     const message = error instanceof Error ? error.message : String(error);\n205:     if (!/no such table:\\s*causal_edge/i.test(message)) {\n206:       throw error;\n207:     }\n208:   }\n209: }\n210: \n211: function upsert_active_projection(\n212:   database: ReturnType<typeof initialize_db>,\n213:   specFolder: string,\n214:   canonicalFilePath: string,\n215:   anchorId: string | null,\n216:   memoryId: number,\n217:   updatedAt: string,\n218:   scope: NormalizedMemoryScope,\n219: ): void {\n220:   const logicalKey = buildMemoryLogicalKey({\n221:     specFolder,\n222:     filePath: canonicalFilePath,\n223:     canonicalFilePath,\n224:     anchorId,\n225:     ...scope,\n226:   });\n227:   // Evict any stale projection row that maps a *different* logical_key to the\n228:   // same active_memory_id вҖ” prevents UNIQUE constraint violation on re-index\n229:   // when the logical_key changes (e.g. anchor or path normalization drift).\n230:   database.prepare(\n231:     'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n232:   ).run(memoryId, logicalKey);\n233:   database.prepare(`\n234:     INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n235:     VALUES (?, ?, ?, ?)\n236:     ON CONFLICT(logical_key) DO UPDATE SET\n237:       root_memory_id = excluded.root_memory_id,\n238:       active_memory_id = excluded.active_memory_id,\n239:       updated_at = excluded.updated_at\n240:   `).run(logicalKey, memoryId, memoryId, updatedAt);\n241: }\n242: \n243: // These mutation-local extensions are intentional until the shared query/store\n244: // contract adopts appendOnly and canonicalFilePath semantics.\n245: type IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n246:   readonly appendOnly?: boolean;\n247: };\n248: type IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n249:   readonly failureReason?: string | null;\n250: };\n251: type UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n252:   readonly canonicalFilePath?: string;\n253:   // Set when the row's document now lives at a new on-disk location, so a\n254:   // moved file repoints its existing row instead of leaving a stale path.\n255:   readonly filePath?: string;\n256: };\n257: \n258: type NormalizedMemoryScope = {\n259:   tenant_id: string | null;\n260:   user_id: string | null;\n\n(Showing lines 1-260 of 1021. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Vector Index Mutations\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts вҖ” contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Vector Index Mutations\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts вҖ” contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';\nimport { clearDegreeCacheForDb } from './graph-search-fn.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration } from '../storage/causal-generation.js';\nimport * as bm25Index from './bm25-index.js';\nimport {\n  clear_search_cache,\n} from './vector-index-aliases.js';\nimport { invalidateEntityDensityCache } from './entity-density.js';\nimport {\n  get_error_message,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  clear_constitutional_cache,\n  get_embedding_dim,\n  initialize_db,\n  init_prepared_statements,\n  refresh_interference_scores_for_folder,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource,\n} from './vector-index-store.js';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder, vecTableNameForDim } from '../embedders/schema.js';\nimport type {\n  IndexMemoryParams as SharedIndexMemoryParams,\n  MemoryScopeParams,\n  UpdateMemoryParams as SharedUpdateMemoryParams,\n} from './vector-index-types.js';\nimport type Database from 'better-sqlite3';\n\nconst logger = createLogger('VectorIndex');\n\nfunction isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n  const message = get_error_message(error).toLowerCase();\n  return message.includes('no such table') && message.includes('vec_memories');\n}\n\nfunction activeVectorTableExists(database: Database.Database, tableName: string): boolean {\n  try {\n    const row = database.prepare(`\n      SELECT 1 AS found\n      FROM ${activeVectorSource('sqlite_master')}\n      WHERE type = 'table' AND name = ?\n      LIMIT 1\n    `).get(tableName) as { found?: number } | undefined;\n    return row?.found === 1;\n  } catch (_error: unknown) {\n    return false;\n  }\n}\n\nfunction activeDimVectorSource(database: Database.Database): string | null {\n  const active = getActiveEmbedder(database);\n  if (active.name === DEFAULT_ACTIVE_EMBEDDER.name) {\n    return null;\n  }\n  const tableName = vecTableNameForDim(active.dim);\n  return activeVectorTableExists(database, tableName) ? activeVectorSource(tableName) : null;\n}\n\nfunction writeActiveVectorPayload(database: Database.Database, id: bigint, embeddingBuffer: Buffer): void {\n  database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n  database.prepare(`\n    INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)\n  `).run(id, embeddingBuffer);\n\n  const dimSource = activeDimVectorSource(database);\n  if (dimSource) {\n    database.prepare(`INSERT OR REPLACE INTO ${dimSource} (id, vec) VALUES (?, ?)`).run(id, embeddingBuffer);\n  }\n}\n\nfunction deleteActiveVectorPayload(database: Database.Database, id: bigint): void {\n  database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n  const dimSource = activeDimVectorSource(database);\n  if (dimSource) {\n    database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n  }\n}\n\nfunction invalidateGraphCaches(database: Database.Database): void {\n  // Bump the generation FIRST so every cache key that includes it (e.g.\n  // memory_search with causal boost) goes stale before the per-db caches clear;\n  // without this, memory-delete sweeps served stale causal-boosted search results.\n  bumpCausalEdgesGeneration();\n\n  try {\n    clearDegreeCacheForDb(database);\n  } catch (_error: unknown) {\n    // Degree cache invalidation is best-effort for legacy mutation paths.\n  }\n\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signal cache invalidation is best-effort for legacy mutation paths.\n  }\n}\n\nfunction tryRecordTierDowngradeAudit(\n  database: Database.Database,\n  params: {\n    memoryId: number;\n    specFolder: string | null | undefined;\n    anchorId: string | null | undefined;\n    filePath: string | null | undefined;\n    canonicalFilePath: string | null | undefined;\n    requestedTier?: string | null | undefined;\n    previousTier?: string | null | undefined;\n    nextTier: string;\n    source: string;\n  },\n): void {\n  try {\n    recordTierDowngradeAudit(database, {\n      memoryId: params.memoryId,\n      logicalKey: buildGovernanceLogicalKey(\n        params.specFolder,\n        params.canonicalFilePath || params.filePath,\n        params.anchorId,\n      ),\n      requestedTier: params.requestedTier ?? undefined,\n      previousTier: params.previousTier ?? undefined,\n      nextTier: params.nextTier,\n      source: params.source,\n      filePath: params.filePath ?? null,\n      canonicalFilePath: params.canonicalFilePath ?? null,\n    });\n  } catch (error: unknown) {\n    logger.warn('Failed to record governance audit for tier downgrade', {\n      memoryId: params.memoryId,\n      source: params.source,\n      message: get_error_message(error),\n    });\n  }\n}\n\nfunction deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n  const ancillaryTables = [\n    'DELETE FROM degree_snapshots WHERE memory_id = ?',\n    'DELETE FROM community_assignments WHERE memory_id = ?',\n    'DELETE FROM memory_summaries WHERE memory_id = ?',\n    'DELETE FROM memory_entities WHERE memory_id = ?',\n    'DELETE FROM memory_lineage WHERE memory_id = ?',\n  ];\n\n  for (const sql of ancillaryTables) {\n    try {\n      const paramCount = (sql.match(/\\?/g) || []).length;\n      if (paramCount === 2) {\n        database.prepare(sql).run(id, id);\n      } else {\n        database.prepare(sql).run(id);\n      }\n    } catch (_error: unknown) {\n      // Best-effort for legacy databases that may not have these tables yet.\n    }\n  }\n\n  // Clean active_memory_projection rows referencing this memory.\n  try {\n    database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n  } catch (_error: unknown) {\n    // Best-effort for legacy databases that may not have projection tables yet.\n  }\n\n  try {\n    const result = sweepCausalEdges(database, {\n      memoryIds: [id, String(id)],\n      reason: 'memory row mutation cleanup',\n      command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n      restoreContext: { memoryId: id },\n      invalidateCaches: false,\n    });\n    if (result.deleted > 0) {\n      invalidateGraphCaches(database);\n    }\n  } catch (error: unknown) {\n    // Tolerate only legacy databases that predate the causal-edge tables. Scope\n    // the match to those table names so an unrelated missing-table error still\n    // propagates and rolls back the surrounding delete instead of committing a\n    // hard delete without its tombstone audit row.\n    const message = error instanceof Error ? error.message : String(error);\n    if (!/no such table:\\s*causal_edge/i.test(message)) {\n      throw error;\n    }\n  }\n}\n\nfunction upsert_active_projection(\n  database: ReturnType<typeof initialize_db>,\n  specFolder: string,\n  canonicalFilePath: string,\n  anchorId: string | null,\n  memoryId: number,\n  updatedAt: string,\n  scope: NormalizedMemoryScope,\n): void {\n  const logicalKey = buildMemoryLogicalKey({\n    specFolder,\n    filePath: canonicalFilePath,\n    canonicalFilePath,\n    anchorId,\n    ...scope,\n  });\n  // Evict any stale projection row that maps a *different* logical_key to the\n  // same active_memory_id вҖ” prevents UNIQUE constraint violation on re-index\n  // when the logical_key changes (e.g. anchor or path normalization drift).\n  database.prepare(\n    'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n  ).run(memoryId, logicalKey);\n  database.prepare(`\n    INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n    VALUES (?, ?, ?, ?)\n    ON CONFLICT(logical_key) DO UPDATE SET\n      root_memory_id = excluded.root_memory_id,\n      active_memory_id = excluded.active_memory_id,\n      updated_at = excluded.updated_at\n  `).run(logicalKey, memoryId, memoryId, updatedAt);\n}\n\n// These mutation-local extensions are intentional until the shared query/store\n// contract adopts appendOnly and canonicalFilePath semantics.\ntype IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n  readonly appendOnly?: boolean;\n};\ntype IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n  readonly failureReason?: string | null;\n};\ntype UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n  readonly canonicalFilePath?: string;\n  // Set when the row's document now lives at a new on-disk location, so a\n  // moved file repoints its existing row instead of leaving a stale path.\n  readonly filePath?: string;\n};\n\ntype NormalizedMemoryScope = {\n  tenant_id: string | null;\n  user_id: string | null;","lineStart":1,"lineEnd":260,"totalLines":1021,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","time":{"start":1781764483782,"end":1781764483788}},"metadata":{"openai":{"itemId":"fc_06864e8d4f0dcc5c016a3391839f648191947a1621a49de928"}},"id":"prt_ed9706ac10017v03BAGYyLjnAG","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed97047fe001GS06tgEG5Sc6ON"}}
{"type":"tool_use","timestamp":1781764483792,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_xI7OwlyYxmjtxti1bgesUylE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Vector Index Queries\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts вҖ” contains ALL query/search functions,\n6: // Content extraction, ranking, stats, cleanup, and integrity checks.\n7: \n8: import * as path from 'path';\n9: import * as fs from 'fs';\n10: import type Database from 'better-sqlite3';\n11: import { formatAgeString as format_age_string } from '../utils/format-helpers.js';\n12: import { createLogger } from '../utils/logger.js';\n13: import { recordHistory } from '../storage/history.js';\n14: import { isArchivedVectorInclusionEnabled } from './search-flags.js';\n15: import * as embeddingsProvider from '../providers/embeddings.js';\n16: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\n17: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n18: import { getEmbedderAdapter } from '../embedders/execution-router.js';\n19: import { getManifest } from '../embedders/registry.js';\n20: import {\n21:   computeContentHash,\n22:   getActiveEmbeddingProfileKey,\n23:   lookupEmbedding,\n24:   storeEmbedding,\n25: } from '../cache/embedding-cache.js';\n26: import {\n27:   get_error_message,\n28:   parse_trigger_phrases,\n29:   specFolderLikePattern,\n30:   to_embedding_buffer,\n31:   VectorIndexError,\n32:   VectorIndexErrorCode,\n33: } from './vector-index-types.js';\n34: import {\n35:   initialize_db,\n36:   get_embedding_dim,\n37:   get_constitutional_memories,\n38:   init_prepared_statements,\n39:   validate_file_path_local,\n40:   safe_read_file_async,\n41:   safe_parse_json,\n42:   search_weights,\n43:   sqlite_vec_available as get_sqlite_vec_available,\n44:   activeVectorSource as activeVectorSchema,\n45: } from './vector-index-store.js';\n46: import { delete_memory_from_database } from './vector-index-mutations.js';\n47: import type {\n48:   EmbeddingInput,\n49:   EnrichedSearchResult,\n50:   MemoryRow,\n51:   VectorSearchOptions,\n52: } from './vector-index-types.js';\n53: \n54: const logger = createLogger('VectorIndex');\n55: \n56: type RelatedMemoryLink = { id: number; similarity: number };\n57: type UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\n58: type CleanupOptions = {\n59:   maxAgeDays?: number;\n60:   maxAccessCount?: number;\n61:   maxConfidence?: number;\n62:   limit?: number;\n63: };\n64: type VectorSource = {\n65:   dim: number;\n66:   tableName: string;\n67:   idColumn: string;\n68:   embeddingColumn: string;\n69: };\n70: \n71: export interface KnnQueryShapeBenchmarkResult {\n72:   readonly corpusSize: number;\n73:   readonly iterations: number;\n74:   readonly scalarJoinAverageMs: number;\n75:   readonly matchAverageMs: number | null;\n76:   readonly matchSupported: boolean;\n77:   readonly matchImprovementPct: number | null;\n78:   readonly decision: 'adopt_match' | 'keep_scalar_join';\n79:   readonly reason: string;\n80: }\n81: \n82: const KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n83: \n84: function appendSpecFolderScope(\n85:   clauses: string[],\n86:   params: unknown[],\n87:   specFolder: string | null | undefined,\n88:   column = 'm.spec_folder',\n89: ): void {\n90:   if (!specFolder) return;\n91:   clauses.push(`(${column} = ? OR ${column} LIKE ? ESCAPE '\\\\')`);\n92:   params.push(specFolder, specFolderLikePattern(specFolder));\n93: }\n94: \n95: function tableExists(database: Database.Database, tableName: string): boolean {\n96:   const row = database.prepare(`\n97:     SELECT 1 AS found\n98:     FROM active_vec.sqlite_master\n99:     WHERE type = 'table' AND name = ?\n100:     LIMIT 1\n101:   `).get(tableName) as { found?: number } | undefined;\n102:   return row?.found === 1;\n103: }\n104: \n105: function getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n106:   const active = getActiveEmbedder(database);\n107:   const dimTableName = `vec_${active.dim}`;\n108:   if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n109:     return {\n110:       dim: active.dim,\n111:       tableName: activeVectorSchema(dimTableName),\n112:       idColumn: 'id',\n113:       embeddingColumn: 'vec',\n114:     };\n115:   }\n116: \n117:   return {\n118:     dim: get_embedding_dim(),\n119:     tableName: activeVectorSchema('vec_memories'),\n120:     idColumn: 'rowid',\n121:     embeddingColumn: 'embedding',\n122:   };\n123: }\n124: \n125: function elapsedMs(start: bigint): number {\n126:   return Number(process.hrtime.bigint() - start) / 1_000_000;\n127: }\n128: \n129: function average(values: number[]): number {\n130:   if (values.length === 0) return 0;\n131:   return values.reduce((sum, value) => sum + value, 0) / values.length;\n132: }\n133: \n134: export function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n135:   return result.matchSupported === true\n136:     && typeof result.matchImprovementPct === 'number'\n137:     && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n138: }\n139: \n140: export function benchmarkKnnQueryShapes(\n141:   query_embedding: EmbeddingInput,\n142:   options: { iterations?: number; limit?: number } = {},\n143:   database: Database.Database = initialize_db(),\n144: ): KnnQueryShapeBenchmarkResult {\n145:   const vectorSource = getActiveVectorSourceForQuery(database);\n146:   if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n147:     throw new VectorIndexError(\n148:       `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n149:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n150:     );\n151:   }\n152: \n153:   const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n154:   const limit = Math.max(1, Math.floor(options.limit ?? 20));\n155:   const queryBuffer = to_embedding_buffer(query_embedding);\n156:   const corpusSize = (database.prepare(`\n157:     SELECT COUNT(*) AS count\n158:     FROM memory_index m\n159:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n160:     WHERE m.embedding_status = 'success'\n161:   `).get() as { count: number }).count;\n162: \n163:   const scalarSql = `\n164:     SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n165:     FROM memory_index m\n166:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n167:     JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n168:     WHERE m.embedding_status = 'success'\n169:     ORDER BY distance ASC\n170:     LIMIT ?\n171:   `;\n172:   const scalarStmt = database.prepare(scalarSql);\n173:   scalarStmt.all(queryBuffer, limit);\n174:   const scalarRuns: number[] = [];\n175:   for (let i = 0; i < iterations; i += 1) {\n176:     const start = process.hrtime.bigint();\n177:     scalarStmt.all(queryBuffer, limit);\n178:     scalarRuns.push(elapsedMs(start));\n179:   }\n180: \n181:   const matchTable = activeVectorSchema('vec_memories');\n182:   const matchAvailable = tableExists(database, 'vec_memories');\n183:   let matchAverageMs: number | null = null;\n184:   let matchError: string | null = null;\n185: \n186:   if (matchAvailable) {\n187:     try {\n188:       const matchSql = `\n189:         WITH knn AS (\n190:           SELECT rowid, distance\n191:           FROM ${matchTable}\n192:           WHERE embedding MATCH ? AND k = ?\n193:         )\n194:         SELECT m.id, knn.distance\n195:         FROM knn\n196:         JOIN memory_index m ON m.id = knn.rowid\n197:         JOIN active_memory_projection p ON p.active_memory_id = m.id\n198:         WHERE m.embedding_status = 'success'\n199:         ORDER BY knn.distance ASC\n200:         LIMIT ?\n201:       `;\n202:       const matchStmt = database.prepare(matchSql);\n203:       matchStmt.all(queryBuffer, limit, limit);\n204:       const matchRuns: number[] = [];\n205:       for (let i = 0; i < iterations; i += 1) {\n206:         const start = process.hrtime.bigint();\n207:         matchStmt.all(queryBuffer, limit, limit);\n208:         matchRuns.push(elapsedMs(start));\n209:       }\n210:       matchAverageMs = average(matchRuns);\n211:     } catch (error: unknown) {\n212:       matchError = get_error_message(error);\n213:     }\n214:   }\n215: \n216:   const scalarJoinAverageMs = average(scalarRuns);\n217:   const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n218:     ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n219:     : null;\n220:   const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n221:     matchSupported: matchAverageMs !== null,\n222:     matchImprovementPct,\n223:   };\n224:   const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n225: \n226:   return {\n227:     corpusSize,\n228:     iterations,\n229:     scalarJoinAverageMs,\n230:     matchAverageMs,\n231:     matchSupported: matchAverageMs !== null,\n232:     matchImprovementPct,\n233:     decision,\n234:     reason: decision === 'adopt_match'\n235:       ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n236:       : matchError\n237:         ? `MATCH unavailable: ${matchError}`\n238:         : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n239:   };\n240: }\n241: \n242: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n243:    SIMPLE QUERIES\n244: ----------------------------------------------------------------*/\n245: \n246: /**\n247:  * Gets one indexed memory by identifier.\n248:  * @param id - The memory identifier.\n249:  * @returns The matching memory row, if found.\n250:  * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n251:  * @example\n252:  * ```ts\n253:  * const memory = get_memory(42);\n254:  * ```\n255:  */\n256: export function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n257:   const stmts = init_prepared_statements(database);\n258:   const row = stmts.get_by_id.get(id);\n259: \n260:   if (row) {\n\n(Showing lines 1-260 of 1742. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Vector Index Queries\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts вҖ” contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport { isArchivedVectorInclusionEnabled } from './search-flags.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Vector Index Queries\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts вҖ” contains ALL query/search functions,\n// Content extraction, ranking, stats, cleanup, and integrity checks.\n\nimport * as path from 'path';\nimport * as fs from 'fs';\nimport type Database from 'better-sqlite3';\nimport { formatAgeString as format_age_string } from '../utils/format-helpers.js';\nimport { createLogger } from '../utils/logger.js';\nimport { recordHistory } from '../storage/history.js';\nimport { isArchivedVectorInclusionEnabled } from './search-flags.js';\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { getEmbedderAdapter } from '../embedders/execution-router.js';\nimport { getManifest } from '../embedders/registry.js';\nimport {\n  computeContentHash,\n  getActiveEmbeddingProfileKey,\n  lookupEmbedding,\n  storeEmbedding,\n} from '../cache/embedding-cache.js';\nimport {\n  get_error_message,\n  parse_trigger_phrases,\n  specFolderLikePattern,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  initialize_db,\n  get_embedding_dim,\n  get_constitutional_memories,\n  init_prepared_statements,\n  validate_file_path_local,\n  safe_read_file_async,\n  safe_parse_json,\n  search_weights,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource as activeVectorSchema,\n} from './vector-index-store.js';\nimport { delete_memory_from_database } from './vector-index-mutations.js';\nimport type {\n  EmbeddingInput,\n  EnrichedSearchResult,\n  MemoryRow,\n  VectorSearchOptions,\n} from './vector-index-types.js';\n\nconst logger = createLogger('VectorIndex');\n\ntype RelatedMemoryLink = { id: number; similarity: number };\ntype UsageStatsOptions = { sortBy?: string; order?: string; limit?: number };\ntype CleanupOptions = {\n  maxAgeDays?: number;\n  maxAccessCount?: number;\n  maxConfidence?: number;\n  limit?: number;\n};\ntype VectorSource = {\n  dim: number;\n  tableName: string;\n  idColumn: string;\n  embeddingColumn: string;\n};\n\nexport interface KnnQueryShapeBenchmarkResult {\n  readonly corpusSize: number;\n  readonly iterations: number;\n  readonly scalarJoinAverageMs: number;\n  readonly matchAverageMs: number | null;\n  readonly matchSupported: boolean;\n  readonly matchImprovementPct: number | null;\n  readonly decision: 'adopt_match' | 'keep_scalar_join';\n  readonly reason: string;\n}\n\nconst KNN_MATCH_ADOPTION_THRESHOLD_PCT = 20;\n\nfunction appendSpecFolderScope(\n  clauses: string[],\n  params: unknown[],\n  specFolder: string | null | undefined,\n  column = 'm.spec_folder',\n): void {\n  if (!specFolder) return;\n  clauses.push(`(${column} = ? OR ${column} LIKE ? ESCAPE '\\\\')`);\n  params.push(specFolder, specFolderLikePattern(specFolder));\n}\n\nfunction tableExists(database: Database.Database, tableName: string): boolean {\n  const row = database.prepare(`\n    SELECT 1 AS found\n    FROM active_vec.sqlite_master\n    WHERE type = 'table' AND name = ?\n    LIMIT 1\n  `).get(tableName) as { found?: number } | undefined;\n  return row?.found === 1;\n}\n\nfunction getActiveVectorSourceForQuery(database: Database.Database): VectorSource {\n  const active = getActiveEmbedder(database);\n  const dimTableName = `vec_${active.dim}`;\n  if (active.name !== DEFAULT_ACTIVE_EMBEDDER.name && tableExists(database, dimTableName)) {\n    return {\n      dim: active.dim,\n      tableName: activeVectorSchema(dimTableName),\n      idColumn: 'id',\n      embeddingColumn: 'vec',\n    };\n  }\n\n  return {\n    dim: get_embedding_dim(),\n    tableName: activeVectorSchema('vec_memories'),\n    idColumn: 'rowid',\n    embeddingColumn: 'embedding',\n  };\n}\n\nfunction elapsedMs(start: bigint): number {\n  return Number(process.hrtime.bigint() - start) / 1_000_000;\n}\n\nfunction average(values: number[]): number {\n  if (values.length === 0) return 0;\n  return values.reduce((sum, value) => sum + value, 0) / values.length;\n}\n\nexport function shouldAdoptMatchQueryShape(result: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'>): boolean {\n  return result.matchSupported === true\n    && typeof result.matchImprovementPct === 'number'\n    && result.matchImprovementPct > KNN_MATCH_ADOPTION_THRESHOLD_PCT;\n}\n\nexport function benchmarkKnnQueryShapes(\n  query_embedding: EmbeddingInput,\n  options: { iterations?: number; limit?: number } = {},\n  database: Database.Database = initialize_db(),\n): KnnQueryShapeBenchmarkResult {\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  if (!query_embedding || query_embedding.length !== vectorSource.dim) {\n    throw new VectorIndexError(\n      `Invalid embedding dimension: expected ${vectorSource.dim}, got ${query_embedding?.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const iterations = Math.max(1, Math.floor(options.iterations ?? 5));\n  const limit = Math.max(1, Math.floor(options.limit ?? 20));\n  const queryBuffer = to_embedding_buffer(query_embedding);\n  const corpusSize = (database.prepare(`\n    SELECT COUNT(*) AS count\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    WHERE m.embedding_status = 'success'\n  `).get() as { count: number }).count;\n\n  const scalarSql = `\n    SELECT m.id, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) AS distance\n    FROM memory_index m\n    JOIN active_memory_projection p ON p.active_memory_id = m.id\n    JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n    WHERE m.embedding_status = 'success'\n    ORDER BY distance ASC\n    LIMIT ?\n  `;\n  const scalarStmt = database.prepare(scalarSql);\n  scalarStmt.all(queryBuffer, limit);\n  const scalarRuns: number[] = [];\n  for (let i = 0; i < iterations; i += 1) {\n    const start = process.hrtime.bigint();\n    scalarStmt.all(queryBuffer, limit);\n    scalarRuns.push(elapsedMs(start));\n  }\n\n  const matchTable = activeVectorSchema('vec_memories');\n  const matchAvailable = tableExists(database, 'vec_memories');\n  let matchAverageMs: number | null = null;\n  let matchError: string | null = null;\n\n  if (matchAvailable) {\n    try {\n      const matchSql = `\n        WITH knn AS (\n          SELECT rowid, distance\n          FROM ${matchTable}\n          WHERE embedding MATCH ? AND k = ?\n        )\n        SELECT m.id, knn.distance\n        FROM knn\n        JOIN memory_index m ON m.id = knn.rowid\n        JOIN active_memory_projection p ON p.active_memory_id = m.id\n        WHERE m.embedding_status = 'success'\n        ORDER BY knn.distance ASC\n        LIMIT ?\n      `;\n      const matchStmt = database.prepare(matchSql);\n      matchStmt.all(queryBuffer, limit, limit);\n      const matchRuns: number[] = [];\n      for (let i = 0; i < iterations; i += 1) {\n        const start = process.hrtime.bigint();\n        matchStmt.all(queryBuffer, limit, limit);\n        matchRuns.push(elapsedMs(start));\n      }\n      matchAverageMs = average(matchRuns);\n    } catch (error: unknown) {\n      matchError = get_error_message(error);\n    }\n  }\n\n  const scalarJoinAverageMs = average(scalarRuns);\n  const matchImprovementPct = matchAverageMs !== null && scalarJoinAverageMs > 0\n    ? ((scalarJoinAverageMs - matchAverageMs) / scalarJoinAverageMs) * 100\n    : null;\n  const preliminary: Pick<KnnQueryShapeBenchmarkResult, 'matchSupported' | 'matchImprovementPct'> = {\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n  };\n  const decision = shouldAdoptMatchQueryShape(preliminary) ? 'adopt_match' : 'keep_scalar_join';\n\n  return {\n    corpusSize,\n    iterations,\n    scalarJoinAverageMs,\n    matchAverageMs,\n    matchSupported: matchAverageMs !== null,\n    matchImprovementPct,\n    decision,\n    reason: decision === 'adopt_match'\n      ? `MATCH exceeded ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`\n      : matchError\n        ? `MATCH unavailable: ${matchError}`\n        : `MATCH did not exceed ${KNN_MATCH_ADOPTION_THRESHOLD_PCT}% threshold`,\n  };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   SIMPLE QUERIES\n----------------------------------------------------------------*/\n\n/**\n * Gets one indexed memory by identifier.\n * @param id - The memory identifier.\n * @returns The matching memory row, if found.\n * @throws {VectorIndexError} Propagates store initialization failures from the vector index.\n * @example\n * ```ts\n * const memory = get_memory(42);\n * ```\n */\nexport function get_memory(id: number, database: Database.Database = initialize_db()): MemoryRow | null {\n  const stmts = init_prepared_statements(database);\n  const row = stmts.get_by_id.get(id);\n\n  if (row) {","lineStart":1,"lineEnd":260,"totalLines":1742,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781764483787,"end":1781764483791}},"metadata":{"openai":{"itemId":"fc_06864e8d4f0dcc5c016a3391839f6c8191b82a2fa4903159c4"}},"id":"prt_ed9706ac7001YuTzYGGV9ps3wm","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed97047fe001GS06tgEG5Sc6ON"}}
