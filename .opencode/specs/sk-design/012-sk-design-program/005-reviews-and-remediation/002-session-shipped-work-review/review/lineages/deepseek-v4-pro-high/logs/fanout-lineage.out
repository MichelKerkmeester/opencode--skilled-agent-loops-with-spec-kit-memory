eneration-manifest.mjs:\n  Line 240:  * The payload is written to a fresh temp file, fsynced, then renamed over the\n\n  Line 251:   const temporaryPath = `${pointerPath}.tmp-${process.pid}-${Date.now()}`;\n\n  Line 252:   let temporaryHandle;\n\n  Line 254:     temporaryHandle = await open(temporaryPath, 'wx');\n\n  Line 255:     await temporaryHandle.writeFile(serialized);\n\n  Line 256:     await temporaryHandle.sync();\n\n  Line 257:     await temporaryHandle.close();\n\n  Line 258:     temporaryHandle = null;\n\n  Line 259:     await rename(temporaryPath, pointerPath);\n\n  Line 268:     if (temporaryHandle) await temporaryHandle.close();\n\n  Line 269:     await rm(temporaryPath, { force: true });\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/indexer.mjs:\n  Line 583:     SET status = 'pending', updated_at = ?, last_error = NULL, next_attempt_at = NULL\n\n  Line 1055:   const buildingPath = `${databasePath}.building-${process.pid}-${Date.now()}`;\n\n  Line 1092:       + `.${process.pid}-${Date.now()}.sqlite`;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/schema.mjs:\n  Line 181:     attempts INTEGER NOT NULL DEFAULT 0 CHECK (attempts >= 0),\n\n  Line 182:     next_attempt_at TEXT,\n\n  Line 264:     ON style_vector_jobs(status, next_attempt_at, job_id);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/__tests__/retrieval.test.mjs:\n  Line 138:     SET status = 'running', attempts = 1, updated_at = '2000-01-01T00:00:00.000Z'\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/replay-fixtures.mjs:\n  Line 12: import { mkdir, mkdtemp, readFile, readdir, rm } from 'node:fs/promises';\n\n  Line 29: // a handful of duplicated templates, so ranking and fusion are exercised for\n\n  Line 120:  * Materialize a deterministic corpus of the requested size to a temp directory.\n\n  Line 129:   const base = await mkdtemp(path.join(os.tmpdir(), 'style-replay-fixture-'));\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0092-deep-review-session-shipped-work/.opencode/skills/sk-design/styles/_db/oracle/differential-oracle.mjs:\n  Line 62:     } while (drained.attempted > 0);\n","metadata":{"matches":55,"truncated":false},"title":"\\.tmp-|process\\.pid|Date\\.now\\(\\)|temp|race","time":{"start":1784606469478,"end":1784606469488}},"id":"prt_f82d5a94e001QqF2WdDWyHEB9a","sessionID":"ses_07d2d6659ffe0JNz4C04306Spy","messageID":"msg_f82d57f55001h4EdazT6a6WGuT"}}
