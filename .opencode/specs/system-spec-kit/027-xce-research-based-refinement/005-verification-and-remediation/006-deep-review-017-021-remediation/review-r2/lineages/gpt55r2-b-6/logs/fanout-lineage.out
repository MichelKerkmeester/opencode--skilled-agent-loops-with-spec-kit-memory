{"type":"text","timestamp":1781762899877,"sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","part":{"id":"prt_ed958305a0011aZ3o46bSvpc6q","messageID":"msg_ed957ea1e0012RwDNrKGwoAGkn","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","type":"text","text":"I found a candidate cancellation/data-integrity issue, but IвҖҷm verifying the downstream mutation hooks before recording it so the impact is grounded rather than inferred.","time":{"start":1781762895962,"end":1781762899875},"metadata":{"openai":{"itemId":"msg_046d09565c0fc701016a338b4fe9d08191a082eed7f237ef78","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781762899907,"sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","part":{"type":"tool","tool":"read","callID":"call_u3CmWyrzyk29sG12TAylqXpZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Mutation Hooks\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: import * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\n5: import { clearSemanticTriggerCache } from '../lib/triggers/semantic-trigger-matcher.js';\n6: import * as toolCache from '../lib/cache/tool-cache.js';\n7: import { clearConstitutionalCache } from '../hooks/memory-surface.js';\n8: import { clearGraphSignalsCache } from '../lib/graph/graph-signals.js';\n9: import { clearRelatedCache } from '../lib/cognitive/co-activation.js';\n10: import { clearDegreeCache } from '../lib/search/graph-search-fn.js';\n11: import { invalidateEntityDensityCache } from '../lib/search/entity-density.js';\n12: import { createStatediffAction } from '../lib/storage/statediff.js';\n13: import { appendAutomatedMutationAudit } from '../lib/storage/mutation-ledger.js';\n14: \n15: import type Database from 'better-sqlite3';\n16: import type { MutationHookResult } from './memory-crud-types.js';\n17: import type { StatediffAction, StatediffTargetType } from '../lib/storage/statediff.js';\n18: \n19: // Feature catalog: Transaction wrappers on mutation handlers\n20: // Feature catalog: Shared post-mutation hook wiring\n21: // Feature catalog: Mutation hook result contract expansion\n22: \n23: \n24: export type { MutationHookResult };\n25: \n26: type HookSubscriberName =\n27:   | 'trigger-cache'\n28:   | 'semantic-trigger-cache'\n29:   | 'tool-cache'\n30:   | 'constitutional-cache'\n31:   | 'graph-cache'\n32:   | 'coactivation-cache'\n33:   | 'entity-density-cache';\n34: \n35: interface HookSubscriberReport {\n36:   name: HookSubscriberName;\n37:   actionCount: number;\n38:   ok: boolean;\n39:   error?: string;\n40: }\n41: \n42: interface HookSubscriber {\n43:   name: HookSubscriberName;\n44:   shouldRun(actions: readonly StatediffAction[]): boolean;\n45:   run(operation: string, context: Record<string, unknown>, actions: readonly StatediffAction[]): number | void;\n46: }\n47: \n48: function isStatediffAction(value: unknown): value is StatediffAction {\n49:   if (!value || typeof value !== 'object') {\n50:     return false;\n51:   }\n52:   const candidate = value as Partial<StatediffAction>;\n53:   return typeof candidate.action === 'string'\n54:     && typeof candidate.target === 'string'\n55:     && typeof candidate.key === 'string'\n56:     && typeof candidate.sourceOperation === 'string';\n57: }\n58: \n59: function actionsFromContext(operation: string, context: Record<string, unknown>): StatediffAction[] {\n60:   const explicitActions = context.statediffActions;\n61:   if (Array.isArray(explicitActions)) {\n62:     return explicitActions.filter(isStatediffAction);\n63:   }\n64: \n65:   const memoryId = typeof context.memoryId === 'number' || typeof context.memoryId === 'string'\n66:     ? String(context.memoryId)\n67:     : operation;\n68:   const target: StatediffTargetType = operation.startsWith('causal-') ? 'causal_edge' : 'memory_index';\n69:   const action = operation.includes('delete') || operation.includes('unlink') ? 'delete' : 'upsert';\n70:   return [createStatediffAction(action, {\n71:     target,\n72:     key: memoryId,\n73:     sourceOperation: operation,\n74:   })];\n75: }\n76: \n77: function hasTarget(actions: readonly StatediffAction[], targets: readonly StatediffTargetType[]): boolean {\n78:   return actions.some((action) => targets.includes(action.target));\n79: }\n80: \n81: function maybeAppendAutomatedMutationAudit(\n82:   operation: string,\n83:   context: Record<string, unknown>,\n84:   actions: readonly StatediffAction[],\n85: ): string | null {\n86:   const sourceKind = typeof context.sourceKind === 'string' ? context.sourceKind : null;\n87:   if (!sourceKind || sourceKind === 'human') {\n88:     return null;\n89:   }\n90:   if (!['agent', 'system', 'import', 'feedback'].includes(sourceKind)) {\n91:     return `automated audit skipped: unknown sourceKind=${sourceKind}`;\n92:   }\n93: \n94:   const database = context.database as Database.Database | undefined;\n95:   if (!database || typeof database.prepare !== 'function') {\n96:     return 'automated audit skipped: database unavailable';\n97:   }\n98: \n99:   const actor = typeof context.actor === 'string' && context.actor.trim().length > 0\n100:     ? context.actor.trim()\n101:     : `mcp:${operation}`;\n102:   const reason = typeof context.auditReason === 'string' && context.auditReason.trim().length > 0\n103:     ? context.auditReason.trim()\n104:     : operation;\n105:   const linkedMemoryIds = actions\n106:     .filter((action) => action.target === 'memory_index' && /^\\d+$/.test(action.key))\n107:     .map((action) => Number(action.key));\n108: \n109:   try {\n110:     appendAutomatedMutationAudit(database, {\n111:       mutation_type: operation.includes('delete') ? 'delete' : 'update',\n112:       actor,\n113:       source_kind: sourceKind as 'agent' | 'system' | 'import' | 'feedback',\n114:       reason,\n115:       linked_memory_ids: linkedMemoryIds,\n116:       session_id: typeof context.sessionId === 'string' ? context.sessionId : null,\n117:       decision_meta: { operation },\n118:     });\n119:     return null;\n120:   } catch (error: unknown) {\n121:     const message = error instanceof Error ? error.message : String(error);\n122:     console.warn(`[mutation-hooks] automated audit append failed for operation=\"${operation}\":`, message);\n123:     return `automated-audit: ${message}`;\n124:   }\n125: }\n126: \n127: const hookSubscribers: HookSubscriber[] = [\n128:   {\n129:     name: 'trigger-cache',\n130:     shouldRun: (actions) => actions.length > 0,\n131:     run: () => {\n132:       triggerMatcher.clearCache();\n133:     },\n134:   },\n135:   {\n136:     name: 'semantic-trigger-cache',\n137:     shouldRun: (actions) => actions.length > 0,\n138:     run: () => {\n139:       clearSemanticTriggerCache();\n140:     },\n141:   },\n142:   {\n143:     name: 'tool-cache',\n144:     shouldRun: (actions) => actions.length > 0,\n145:     run: (operation, context) => toolCache.invalidateOnWrite(operation, context),\n146:   },\n147:   {\n148:     name: 'constitutional-cache',\n149:     shouldRun: (actions) => actions.length > 0,\n150:     run: () => {\n151:       clearConstitutionalCache();\n152:     },\n153:   },\n154:   // Graph and co-activation clears stay unconditional (fail-safe): action\n155:   // batches are an advisory subscriber aid and may under-report graph effects\n156:   // (e.g. memory deletes cascade causal-edge deletes that arrive as\n157:   // memory_index actions only). Cache clears are cheap O(1) resets, so\n158:   // over-invalidating is always safe; skipping on incomplete batches is not.\n159:   {\n160:     name: 'graph-cache',\n161:     shouldRun: (actions) => actions.length > 0,\n162:     run: () => {\n163:       clearGraphSignalsCache();\n164:       clearDegreeCache();\n165:     },\n166:   },\n167:   {\n168:     name: 'coactivation-cache',\n169:     shouldRun: (actions) => actions.length > 0,\n170:     run: () => {\n171:       clearRelatedCache();\n172:     },\n173:   },\n174:   {\n175:     name: 'entity-density-cache',\n176:     shouldRun: (actions) => hasTarget(actions, ['memory_index', 'graph_edge', 'causal_edge']),\n177:     run: () => {\n178:       invalidateEntityDensityCache();\n179:     },\n180:   },\n181: ];\n182: \n183: function subscriberFailed(report: HookSubscriberReport[], name: HookSubscriberName): boolean {\n184:   return report.some((item) => item.name === name && !item.ok);\n185: }\n186: \n187: function subscriberSucceeded(report: HookSubscriberReport[], name: HookSubscriberName): boolean {\n188:   return report.some((item) => item.name === name && item.ok);\n189: }\n190: \n191: function runPostMutationHooks(\n192:   operation: string,\n193:   context: Record<string, unknown> = {}\n194: ): MutationHookResult {\n195:   const startTime = Date.now();\n196:   const errors: string[] = [];\n197:   const actions = actionsFromContext(operation, context);\n198:   const subscriberReports: HookSubscriberReport[] = [];\n199:   let toolCacheInvalidated = 0;\n200: \n201:   for (const subscriber of hookSubscribers) {\n202:     if (!subscriber.shouldRun(actions)) {\n203:       continue;\n204:     }\n205:     try {\n206:       const result = subscriber.run(operation, context, actions);\n207:       if (subscriber.name === 'tool-cache' && typeof result === 'number') {\n208:         toolCacheInvalidated = result;\n209:       }\n210:       subscriberReports.push({ name: subscriber.name, actionCount: actions.length, ok: true });\n211:     } catch (error: unknown) {\n212:       const message = error instanceof Error ? error.message : String(error);\n213:       console.warn(\n214:         `[mutation-hooks] subscriber \"${subscriber.name}\" failed for operation=\"${operation}\":`,\n215:         message\n216:       );\n217:       errors.push(`${subscriber.name}: ${message}`);\n218:       subscriberReports.push({ name: subscriber.name, actionCount: actions.length, ok: false, error: message });\n219:       if (subscriber.name === 'tool-cache') {\n220:         toolCacheInvalidated = 0;\n221:       }\n222:     }\n223:   }\n224: \n225:   const auditWarning = maybeAppendAutomatedMutationAudit(operation, context, actions);\n226:   if (auditWarning) {\n227:     errors.push(auditWarning);\n228:   }\n229: \n230:   return {\n231:     latencyMs: Date.now() - startTime,\n232:     actionCount: actions.length,\n233:     triggerCacheCleared: subscriberSucceeded(subscriberReports, 'trigger-cache') && !subscriberFailed(subscriberReports, 'trigger-cache'),\n234:     constitutionalCacheCleared: subscriberSucceeded(subscriberReports, 'constitutional-cache') && !subscriberFailed(subscriberReports, 'constitutional-cache'),\n235:     toolCacheInvalidated,\n236:     graphSignalsCacheCleared: subscriberSucceeded(subscriberReports, 'graph-cache') && !subscriberFailed(subscriberReports, 'graph-cache'),\n237:     coactivationCacheCleared: subscriberSucceeded(subscriberReports, 'coactivation-cache') && !subscriberFailed(subscriberReports, 'coactivation-cache'),\n238:     entityDensityCacheCleared: subscriberSucceeded(subscriberReports, 'entity-density-cache') && !subscriberFailed(subscriberReports, 'entity-density-cache'),\n239:     subscribers: subscriberReports,\n240:     errors,\n241:   };\n242: }\n243: \n244: export { runPostMutationHooks };\n\n(End of file - total 244 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Mutation Hooks\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport { clearSemanticTriggerCache } from '../lib/triggers/semantic-trigger-matcher.js';\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport { clearConstitutionalCache } from '../hooks/memory-surface.js';\nimport { clearGraphSignalsCache } from '../lib/graph/graph-signals.js';\nimport { clearRelatedCache } from '../lib/cognitive/co-activation.js';\nimport { clearDegreeCache } from '../lib/search/graph-search-fn.js';\nimport { invalidateEntityDensityCache } from '../lib/search/entity-density.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { appendAutomatedMutationAudit } from '../lib/storage/mutation-ledger.js';\n\nimport type Database from 'better-sqlite3';\nimport type { MutationHookResult } from './memory-crud-types.js';\nimport type { StatediffAction, StatediffTargetType } from '../lib/storage/statediff.js';\n\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Shared post-mutation hook wiring","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Mutation Hooks\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport * as triggerMatcher from '../lib/parsing/trigger-matcher.js';\nimport { clearSemanticTriggerCache } from '../lib/triggers/semantic-trigger-matcher.js';\nimport * as toolCache from '../lib/cache/tool-cache.js';\nimport { clearConstitutionalCache } from '../hooks/memory-surface.js';\nimport { clearGraphSignalsCache } from '../lib/graph/graph-signals.js';\nimport { clearRelatedCache } from '../lib/cognitive/co-activation.js';\nimport { clearDegreeCache } from '../lib/search/graph-search-fn.js';\nimport { invalidateEntityDensityCache } from '../lib/search/entity-density.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { appendAutomatedMutationAudit } from '../lib/storage/mutation-ledger.js';\n\nimport type Database from 'better-sqlite3';\nimport type { MutationHookResult } from './memory-crud-types.js';\nimport type { StatediffAction, StatediffTargetType } from '../lib/storage/statediff.js';\n\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Shared post-mutation hook wiring\n// Feature catalog: Mutation hook result contract expansion\n\n\nexport type { MutationHookResult };\n\ntype HookSubscriberName =\n  | 'trigger-cache'\n  | 'semantic-trigger-cache'\n  | 'tool-cache'\n  | 'constitutional-cache'\n  | 'graph-cache'\n  | 'coactivation-cache'\n  | 'entity-density-cache';\n\ninterface HookSubscriberReport {\n  name: HookSubscriberName;\n  actionCount: number;\n  ok: boolean;\n  error?: string;\n}\n\ninterface HookSubscriber {\n  name: HookSubscriberName;\n  shouldRun(actions: readonly StatediffAction[]): boolean;\n  run(operation: string, context: Record<string, unknown>, actions: readonly StatediffAction[]): number | void;\n}\n\nfunction isStatediffAction(value: unknown): value is StatediffAction {\n  if (!value || typeof value !== 'object') {\n    return false;\n  }\n  const candidate = value as Partial<StatediffAction>;\n  return typeof candidate.action === 'string'\n    && typeof candidate.target === 'string'\n    && typeof candidate.key === 'string'\n    && typeof candidate.sourceOperation === 'string';\n}\n\nfunction actionsFromContext(operation: string, context: Record<string, unknown>): StatediffAction[] {\n  const explicitActions = context.statediffActions;\n  if (Array.isArray(explicitActions)) {\n    return explicitActions.filter(isStatediffAction);\n  }\n\n  const memoryId = typeof context.memoryId === 'number' || typeof context.memoryId === 'string'\n    ? String(context.memoryId)\n    : operation;\n  const target: StatediffTargetType = operation.startsWith('causal-') ? 'causal_edge' : 'memory_index';\n  const action = operation.includes('delete') || operation.includes('unlink') ? 'delete' : 'upsert';\n  return [createStatediffAction(action, {\n    target,\n    key: memoryId,\n    sourceOperation: operation,\n  })];\n}\n\nfunction hasTarget(actions: readonly StatediffAction[], targets: readonly StatediffTargetType[]): boolean {\n  return actions.some((action) => targets.includes(action.target));\n}\n\nfunction maybeAppendAutomatedMutationAudit(\n  operation: string,\n  context: Record<string, unknown>,\n  actions: readonly StatediffAction[],\n): string | null {\n  const sourceKind = typeof context.sourceKind === 'string' ? context.sourceKind : null;\n  if (!sourceKind || sourceKind === 'human') {\n    return null;\n  }\n  if (!['agent', 'system', 'import', 'feedback'].includes(sourceKind)) {\n    return `automated audit skipped: unknown sourceKind=${sourceKind}`;\n  }\n\n  const database = context.database as Database.Database | undefined;\n  if (!database || typeof database.prepare !== 'function') {\n    return 'automated audit skipped: database unavailable';\n  }\n\n  const actor = typeof context.actor === 'string' && context.actor.trim().length > 0\n    ? context.actor.trim()\n    : `mcp:${operation}`;\n  const reason = typeof context.auditReason === 'string' && context.auditReason.trim().length > 0\n    ? context.auditReason.trim()\n    : operation;\n  const linkedMemoryIds = actions\n    .filter((action) => action.target === 'memory_index' && /^\\d+$/.test(action.key))\n    .map((action) => Number(action.key));\n\n  try {\n    appendAutomatedMutationAudit(database, {\n      mutation_type: operation.includes('delete') ? 'delete' : 'update',\n      actor,\n      source_kind: sourceKind as 'agent' | 'system' | 'import' | 'feedback',\n      reason,\n      linked_memory_ids: linkedMemoryIds,\n      session_id: typeof context.sessionId === 'string' ? context.sessionId : null,\n      decision_meta: { operation },\n    });\n    return null;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[mutation-hooks] automated audit append failed for operation=\"${operation}\":`, message);\n    return `automated-audit: ${message}`;\n  }\n}\n\nconst hookSubscribers: HookSubscriber[] = [\n  {\n    name: 'trigger-cache',\n    shouldRun: (actions) => actions.length > 0,\n    run: () => {\n      triggerMatcher.clearCache();\n    },\n  },\n  {\n    name: 'semantic-trigger-cache',\n    shouldRun: (actions) => actions.length > 0,\n    run: () => {\n      clearSemanticTriggerCache();\n    },\n  },\n  {\n    name: 'tool-cache',\n    shouldRun: (actions) => actions.length > 0,\n    run: (operation, context) => toolCache.invalidateOnWrite(operation, context),\n  },\n  {\n    name: 'constitutional-cache',\n    shouldRun: (actions) => actions.length > 0,\n    run: () => {\n      clearConstitutionalCache();\n    },\n  },\n  // Graph and co-activation clears stay unconditional (fail-safe): action\n  // batches are an advisory subscriber aid and may under-report graph effects\n  // (e.g. memory deletes cascade causal-edge deletes that arrive as\n  // memory_index actions only). Cache clears are cheap O(1) resets, so\n  // over-invalidating is always safe; skipping on incomplete batches is not.\n  {\n    name: 'graph-cache',\n    shouldRun: (actions) => actions.length > 0,\n    run: () => {\n      clearGraphSignalsCache();\n      clearDegreeCache();\n    },\n  },\n  {\n    name: 'coactivation-cache',\n    shouldRun: (actions) => actions.length > 0,\n    run: () => {\n      clearRelatedCache();\n    },\n  },\n  {\n    name: 'entity-density-cache',\n    shouldRun: (actions) => hasTarget(actions, ['memory_index', 'graph_edge', 'causal_edge']),\n    run: () => {\n      invalidateEntityDensityCache();\n    },\n  },\n];\n\nfunction subscriberFailed(report: HookSubscriberReport[], name: HookSubscriberName): boolean {\n  return report.some((item) => item.name === name && !item.ok);\n}\n\nfunction subscriberSucceeded(report: HookSubscriberReport[], name: HookSubscriberName): boolean {\n  return report.some((item) => item.name === name && item.ok);\n}\n\nfunction runPostMutationHooks(\n  operation: string,\n  context: Record<string, unknown> = {}\n): MutationHookResult {\n  const startTime = Date.now();\n  const errors: string[] = [];\n  const actions = actionsFromContext(operation, context);\n  const subscriberReports: HookSubscriberReport[] = [];\n  let toolCacheInvalidated = 0;\n\n  for (const subscriber of hookSubscribers) {\n    if (!subscriber.shouldRun(actions)) {\n      continue;\n    }\n    try {\n      const result = subscriber.run(operation, context, actions);\n      if (subscriber.name === 'tool-cache' && typeof result === 'number') {\n        toolCacheInvalidated = result;\n      }\n      subscriberReports.push({ name: subscriber.name, actionCount: actions.length, ok: true });\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      console.warn(\n        `[mutation-hooks] subscriber \"${subscriber.name}\" failed for operation=\"${operation}\":`,\n        message\n      );\n      errors.push(`${subscriber.name}: ${message}`);\n      subscriberReports.push({ name: subscriber.name, actionCount: actions.length, ok: false, error: message });\n      if (subscriber.name === 'tool-cache') {\n        toolCacheInvalidated = 0;\n      }\n    }\n  }\n\n  const auditWarning = maybeAppendAutomatedMutationAudit(operation, context, actions);\n  if (auditWarning) {\n    errors.push(auditWarning);\n  }\n\n  return {\n    latencyMs: Date.now() - startTime,\n    actionCount: actions.length,\n    triggerCacheCleared: subscriberSucceeded(subscriberReports, 'trigger-cache') && !subscriberFailed(subscriberReports, 'trigger-cache'),\n    constitutionalCacheCleared: subscriberSucceeded(subscriberReports, 'constitutional-cache') && !subscriberFailed(subscriberReports, 'constitutional-cache'),\n    toolCacheInvalidated,\n    graphSignalsCacheCleared: subscriberSucceeded(subscriberReports, 'graph-cache') && !subscriberFailed(subscriberReports, 'graph-cache'),\n    coactivationCacheCleared: subscriberSucceeded(subscriberReports, 'coactivation-cache') && !subscriberFailed(subscriberReports, 'coactivation-cache'),\n    entityDensityCacheCleared: subscriberSucceeded(subscriberReports, 'entity-density-cache') && !subscriberFailed(subscriberReports, 'entity-density-cache'),\n    subscribers: subscriberReports,\n    errors,\n  };\n}\n\nexport { runPostMutationHooks };","lineStart":1,"lineEnd":244,"totalLines":244,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/mutation-hooks.ts","time":{"start":1781762899901,"end":1781762899905}},"metadata":{"openai":{"itemId":"fc_046d09565c0fc701016a338b53ca108191a8ce086c09828fcc"}},"id":"prt_ed9583fa6001OLz2lKg2nX7yB3","sessionID":"ses_126aa1e86ffe3voro0xMEMegIU","messageID":"msg_ed957ea1e0012RwDNrKGwoAGkn"}}
