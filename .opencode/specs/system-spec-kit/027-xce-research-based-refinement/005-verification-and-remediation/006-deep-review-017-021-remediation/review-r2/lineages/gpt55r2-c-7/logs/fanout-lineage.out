{"type":"tool_use","timestamp":1781763040329,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_jDNStfTQU5xxDJKraUN2ntYb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages</path>\n<type>directory</type>\n<entries>\ngpt55r2-a-1/\ngpt55r2-a-2/\ngpt55r2-a-3/\ngpt55r2-a-4/\ngpt55r2-a-5/\ngpt55r2-a-6/\ngpt55r2-a-smoke/\ngpt55r2-b-1/\ngpt55r2-b-2/\ngpt55r2-b-3/\ngpt55r2-b-4/\ngpt55r2-b-5/\ngpt55r2-b-6/\ngpt55r2-c-1/\ngpt55r2-c-2/\ngpt55r2-c-3/\ngpt55r2-c-4/\ngpt55r2-c-5/\ngpt55r2-c-6/\ngpt55r2-c-7/\n\n(20 entries)\n</entries>","metadata":{"preview":"gpt55r2-a-1/\ngpt55r2-a-2/\ngpt55r2-a-3/\ngpt55r2-a-4/\ngpt55r2-a-5/\ngpt55r2-a-6/\ngpt55r2-a-smoke/\ngpt55r2-b-1/\ngpt55r2-b-2/\ngpt55r2-b-3/\ngpt55r2-b-4/\ngpt55r2-b-5/\ngpt55r2-b-6/\ngpt55r2-c-1/\ngpt55r2-c-2/\ngpt55r2-c-3/\ngpt55r2-c-4/\ngpt55r2-c-5/\ngpt55r2-c-6/\ngpt55r2-c-7/","truncated":false,"loaded":[],"display":{"type":"directory","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages","entries":["gpt55r2-a-1/","gpt55r2-a-2/","gpt55r2-a-3/","gpt55r2-a-4/","gpt55r2-a-5/","gpt55r2-a-6/","gpt55r2-a-smoke/","gpt55r2-b-1/","gpt55r2-b-2/","gpt55r2-b-3/","gpt55r2-b-4/","gpt55r2-b-5/","gpt55r2-b-6/","gpt55r2-c-1/","gpt55r2-c-2/","gpt55r2-c-3/","gpt55r2-c-4/","gpt55r2-c-5/","gpt55r2-c-6/","gpt55r2-c-7/"],"offset":1,"totalEntries":20,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages","time":{"start":1781763040326,"end":1781763040328}},"metadata":{"openai":{"itemId":"fc_0c5728e2594de0e4016a338be02168819190b6c3dbbdda6e8f"}},"id":"prt_ed95a64320010LlCRUkJGXDcaH","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95a18fe001rHpM3r0FG5EE16"}}
{"type":"tool_use","timestamp":1781763040374,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_dimj2w7RBoPXnGtfzRa3i8zl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages/gpt55r2-c-7","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages/gpt55r2-c-7</path>\n<type>directory</type>\n<entries>\n.executor-state/\n\n(1 entries)\n</entries>","metadata":{"preview":".executor-state/","truncated":false,"loaded":[],"display":{"type":"directory","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages/gpt55r2-c-7","entries":[".executor-state/"],"offset":1,"totalEntries":1,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/005-verification-and-remediation/006-deep-review-017-021-remediation/review-r2/lineages/gpt55r2-c-7","time":{"start":1781763040371,"end":1781763040373}},"metadata":{"openai":{"itemId":"fc_0c5728e2594de0e4016a338be021748191bf725d2872668e80"}},"id":"prt_ed95a6449001jF5UoAzbirAcuZ","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95a18fe001rHpM3r0FG5EE16"}}
{"type":"tool_use","timestamp":1781763040385,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_L5zgp9voQko15eVFIEn0SCPU","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n3: # ─────────────────────────────────────────────────────────────────\n4: # DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n5: # ─────────────────────────────────────────────────────────────────\n6: role: Deep Review Loop Manager\n7: purpose: Iterative code/spec review with convergence detection across review dimensions\n8: action: Run deep-review loop from initialization through synthesis\n9: operating_mode:\n10:   workflow: iterative_loop\n11:   workflow_compliance: MANDATORY\n12:   workflow_execution: autonomous\n13:   approvals: none\n14:   tracking: progressive_review_state\n15:   validation: convergence_detection\n16: \n17: # ─────────────────────────────────────────────────────────────────\n18: # OPERATING PRINCIPLES\n19: # ─────────────────────────────────────────────────────────────────\n20: operating_principles:\n21:   core: \"Fresh context per iteration + externalized state = no context degradation\"\n22:   approach: \"Dispatch focused review agent per dimension, evaluate convergence, repeat or stop\"\n23:   mandate: \"Never hold findings in memory; write everything to files. Review target is READ-ONLY.\"\n24: \n25: # ─────────────────────────────────────────────────────────────────\n26: # USER INPUTS (from setup phase)\n27: # ─────────────────────────────────────────────────────────────────\n28: user_inputs:\n29:   review_target: \"[REVIEW_TARGET] - What to review. REQUIRED.\"\n30:   review_target_type: \"[spec-folder|skill|agent|track|files] - Target type for scope derivation. REQUIRED.\"\n31:   review_dimensions: \"[all|correctness,security,traceability,maintainability] - Dimensions to check. Default: all.\"\n32:   spec_folder: \"[SPEC_FOLDER] - Spec folder path for state files. REQUIRED.\"\n33:   lineage_mode: \"[auto|resume|restart] - Session lifecycle intent. Default: auto. The runtime only persists lineage events for `resume` (same sessionId, no archive) and `restart` (new sessionId, generation+1, prior review/ archived). `fork` and `completed-continue` are deferred and no longer accepted — see deep-review/references/protocol/loop_protocol.md §Lifecycle Branches.\"\n34:   max_iterations: 7\n35:   convergence_threshold: 0.10\n36: \n37: # ─────────────────────────────────────────────────────────────────\n38: # CONTEXT LOADING\n39: # ─────────────────────────────────────────────────────────────────\n40: context_loading:\n41:   trigger: \"At workflow START, before phase_init\"\n42:   purpose: \"Load prior review context for the target and buffer it until strategy.md exists\"\n43:   mcp_integration:\n44:     tool: memory_context\n45:     note: \"Call MCP tools directly - NEVER through Code Mode\"\n46:     parameters: { input: \"{review_target}\", mode: \"focused\", intent: \"understand\", includeContent: true }\n47:   when_to_skip: [\"User says 'skip context' or 'fresh start'\"]\n48:   behavior:\n49:     if_context_found: \"Store full results as prior_context plus a concise prior_context_summary; inject after strategy.md is created.\"\n50:     if_no_context: \"Set prior_context and prior_context_summary to 'None' and continue.\"\n51: \n52: # ─────────────────────────────────────────────────────────────────\n53: # SKILL REFERENCE\n54: # ─────────────────────────────────────────────────────────────────\n55: skill_reference:\n56:   skill: deep-loop-workflows\n57:   skill_md: .opencode/skills/deep-loop-workflows/deep-review/SKILL.md\n58:   references:\n59:     loop_protocol: .opencode/skills/deep-loop-workflows/deep-review/references/protocol/loop_protocol.md\n60:     state_format: .opencode/skills/deep-loop-workflows/deep-review/references/state/state_format.md\n61:     convergence: .opencode/skills/deep-loop-workflows/deep-review/references/convergence/convergence.md\n62:   templates:\n63:     config: .opencode/skills/deep-loop-workflows/deep-review/assets/deep_review_config.json\n64:     strategy: .opencode/skills/deep-loop-workflows/deep-review/assets/deep_review_strategy.md\n65: \n66: # ─────────────────────────────────────────────────────────────────\n67: # AGENT CONFIGURATION\n68: # ─────────────────────────────────────────────────────────────────\n69: agent_config:\n70:   agent: deep-review\n71:   agent_file: \".opencode/agents/deep-review.md\"\n72:   # Canonical path. Runtime-specific directories (e.g. .claude/agents/) reference this source.\n73:   mode: subagent\n74:   model: opus\n75:   leaf_only: true\n76:   tools: [Read, Write, Edit, Bash, Grep, Glob]\n77:   mcp_servers: [mk-spec-memory]\n78:   tool_call_budget: { target: 9, soft_max: 12, hard_max: 13 }\n79: \n80: # ─────────────────────────────────────────────────────────────────\n81: # STATE FILE PATHS\n82: # ─────────────────────────────────────────────────────────────────\n83: state_paths:\n84:   # Template paths document the canonical packet layout. Runtime resolution happens via\n85:   # step_resolve_artifact_root plus the shared resolver, so root specs keep\n86:   # root-local review/ and child phases keep local review/ packet dirs.\n87:   # Canonical root-spec write targets remain review/deep-review-config.json,\n88:   # review/deep-review-state.jsonl, and review/deep-review-findings-registry.json.\n89:   packet_dir: \"{artifact_dir}\"\n90:   local_packet_dir: \"{spec_folder}/review\"\n91:   legacy_root_report: \"{spec_folder}/review-report.md\"\n92:   config: \"{artifact_dir}/deep-review-config.json\"\n93:   state_log: \"{artifact_dir}/deep-review-state.jsonl\"\n94:   findings_registry: \"{artifact_dir}/deep-review-findings-registry.json\"\n95:   strategy: \"{artifact_dir}/deep-review-strategy.md\"\n96:   dashboard: \"{artifact_dir}/deep-review-dashboard.md\"\n97:   pause_sentinel: \"{artifact_dir}/.deep-review-pause\"\n98:   lock_file: \"{artifact_dir}/.deep-review.lock\"\n99:   prompt_dir: \"{artifact_dir}/prompts\"\n100:   iteration_dir: \"{artifact_dir}/iterations\"\n101:   iteration_pattern: \"{artifact_dir}/iterations/iteration-{NNN}.md\"\n102:   # Per-iteration structured delta stream — complement to the canonical state_log\n103:   # append. MUST contain at least one record with `type === \"iteration\"`; variants\n104:   # like `\"iteration_delta\"` are silently dropped by the reducer.\n105:   delta_dir: \"{artifact_dir}/deltas\"\n106:   delta_pattern: \"{artifact_dir}/deltas/iter-{NNN}.jsonl\"\n107:   review_output: \"{artifact_dir}/review-report.md\"\n108:   resource_map_output: \"{artifact_dir}/resource-map.md\"\n109:   archive_root: \"{artifact_archive_root}\"\n110: \n111: # ─────────────────────────────────────────────────────────────────\n112: # WORKFLOW\n113: # ─────────────────────────────────────────────────────────────────\n114: workflow:\n115: \n116:   step_resolve_artifact_root:\n117:     description: \"Resolve artifact directory — use fan-out lineage override when provided, else resolve from spec_folder\"\n118:     note: \"Root specs keep review artifacts directly in {spec_folder}/review/. Child phases and sub-phases keep local packet directories in {spec_folder}/review/{packet}/, and archives stay local at {spec_folder}/review_archive/{packet}/.\"\n119:     branch_on: \"config.fanout_lineage_artifact_dir\"\n120:     if_present:\n121:       bind:\n122:         artifact_dir: \"{config.fanout_lineage_artifact_dir}\"\n123:         artifact_root_dir: \"{config.fanout_lineage_artifact_dir}\"\n124:         artifact_subfolder: null\n125:         artifact_archive_root: \"{config.fanout_lineage_artifact_dir}/_archive\"\n126:     if_absent:\n127:       command: \"node -e \\\"const { resolveArtifactRoot } = require('.opencode/skills/system-spec-kit/shared/review-research-paths.cjs'); console.log(JSON.stringify(resolveArtifactRoot('{spec_folder}', 'review')));\\\"\"\n128:       outputs:\n129:         - artifact_root_dir: \"Resolved local review owner directory\"\n130:         - artifact_subfolder: \"Local packet subfolder ({ownerSlug}-pt-{NN}), else null\"\n131:         - artifact_dir: \"Resolved review packet directory for this target\"\n132:         - artifact_archive_root: \"Resolved local review archive directory for this target\"\n133: \n134:   step_fanout_spawn:\n135:     description: \"Spawn fan-out lineages; skip and proceed to phase_init normally when single-executor\"\n136:     skip_when: \"config.fanout is absent\"\n137:     instructions: |\n138:       Fan-out mode is active. Spawn all lineages. Each lineage runs the full loop in its own\n139:       isolated sub-packet under {artifact_dir}/lineages/{label}/.\n140:       After all lineages complete, jump directly to phase_synthesis — skip phase_init and\n141:       phase_main_loop entirely (those are the single-executor path). The merge step in\n142:       phase_synthesis will consolidate results across all lineages.\n143:     sub_steps:\n144:       step_fanout_spawn_cli:\n145:         description: \"Spawn all CLI lineages in capped worker pool\"\n146:         skip_when: \"no entries in config.fanout.executors with kind != 'native'\"\n147:         command: |\n148:           node .opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs \\\n149:             --spec-folder {spec_folder} \\\n150:             --loop-type review \\\n151:             --fanout-config-json '{config.fanout_json}' \\\n152:             --base-artifact-dir {artifact_dir}\n153:         working_directory: \"{repo_root}\"\n154:         wait_for_completion: true\n155:       step_fanout_spawn_native:\n156:         description: \"Dispatch each native lineage as a sequential deep-review sub-agent\"\n157:         skip_when: \"no entries in config.fanout.executors with kind == 'native'\"\n158:         for_each: \"lineage in expanded native entries of config.fanout\"\n159:         dispatch:\n160:           agent: deep-review\n161:           model: opus\n162:           context: |\n163:             Execute the deep-review loop with these parameters:\n164:               spec_folder: {spec_folder}\n165:               config.fanout_lineage_artifact_dir: {artifact_dir}/lineages/{lineage.label}\n166:               session_id: fanout-{lineage.label}-{fanout_run_id}\n167:               executor: native\n168:             Run to convergence. Write all outputs to the override directory.\n169:         wait_for_completion: true\n170: \n171:   # ═══════════════════════════════════════════════════════════════\n172:   # PHASE 1: INITIALIZATION\n173:   # ═══════════════════════════════════════════════════════════════\n174:   phase_init:\n175:     purpose: Create all state files for the review session and resolve review scope\n176:     steps:\n177: \n178:       step_preflight_contract:\n179:         action: \"Validate required setup bindings and executable workflow contract before any file writes\"\n180:         verify:\n181:           - required_values_present: [review_target, review_target_type, review_dimensions, spec_folder, max_iterations, convergence_threshold]\n182:           - spec_folder_is_within: \"specs/ or .opencode/specs/ (canonicalize alias roots before validation)\"\n183:           - unresolved_placeholders: \"FAIL if any user-facing template references placeholders not produced by earlier steps\"\n184:           - tool_contract: \"FAIL if executable steps reference tools outside the command allowlist\"\n185:         on_fail: \"Halt with STATUS=FAIL and report the missing binding or unsupported contract reference\"\n186: \n187:       step_create_directories:\n188:         action: \"Create spec folder and canonical review packet directories if they don't exist\"\n189:         command: \"mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}\"\n190: \n191:       step_detect_resource_map:\n192:         action: \"Detect resource-map.md before config creation so init can persist coverage-gate state\"\n193:         inspect:\n194:           - \"{spec_folder}/resource-map.md\"\n195:         classify:\n196:           present: \"resource-map.md exists at init\"\n197:           absent: \"resource-map.md does not exist at init\"\n198:         outputs:\n199:           - resource_map_present: \"Boolean true when {spec_folder}/resource-map.md exists, else false\"\n200:           - resource_map_known_context: \"When present: concise resource-map snapshot for Known Context and charter framing. When absent: 'resource-map.md not present; skipping coverage gate'.\"\n201: \n202:       step_migrate_legacy_review_state:\n203:         action: \"Rehome legacy review artifacts into review/iterations before session classification\"\n204:         detect:\n205:           canonical_review_state:\n206:             - \"{state_paths.config}\"\n207:             - \"{state_paths.state_log}\"\n208:             - \"{state_paths.findings_registry}\"\n209:             - \"{state_paths.strategy}\"\n210:           legacy_review_state:\n211:             - \"{spec_folder}/scratch/deep-research-config.json\"\n212:             - \"{spec_folder}/scratch/deep-research-state.jsonl\"\n213:             - \"{spec_folder}/scratch/deep-review-strategy.md\"\n214:             - \"{spec_folder}/scratch/deep-review-dashboard.md\"\n215:             - \"{spec_folder}/scratch/iteration-*.md\"\n216:             - \"{spec_folder}/scratch/.deep-research-pause\"\n217:             - \"{state_paths.local_packet_dir}/iteration-*.md\"\n218:             - \"{state_paths.legacy_root_report}\"\n219:           legacy_review_markers:\n220:             - \"scratch/deep-review-strategy.md exists\"\n221:             - \"scratch/deep-research-config.json declares mode == 'review' OR scratch/deep-research-state.jsonl contains mode == 'review'\"\n222:         migrate_only:\n223:           - \"{spec_folder}/scratch/deep-research-config.json -> {state_paths.config}\"\n224:           - \"{spec_folder}/scratch/deep-research-state.jsonl -> {state_paths.state_log}\"\n225:           - \"{spec_folder}/scratch/deep-review-strategy.md -> {state_paths.strategy}\"\n226:           - \"{spec_folder}/scratch/deep-review-dashboard.md -> {state_paths.dashboard}\"\n227:           - \"{spec_folder}/scratch/iteration-*.md -> {state_paths.iteration_dir}/\"\n228:           - \"{spec_folder}/scratch/.deep-research-pause -> {state_paths.pause_sentinel}\"\n229:           - \"{state_paths.local_packet_dir}/iteration-*.md -> {state_paths.iteration_dir}/\"\n230:           - \"{state_paths.legacy_root_report} -> {state_paths.review_output}\"\n231:         on_canonical_present: \"Leave canonical review/ state untouched and do not overwrite it with legacy scratch artifacts.\"\n232:         on_legacy_detected: \"Move only the review-specific whitelist, append a migration event to the canonical JSONL, and leave unrelated scratch files untouched.\"\n233:         on_conflict: \"If canonical review/ state and legacy scratch review state both exist but disagree, halt for operator repair instead of merging contradictory state.\"\n234:         command: \"mkdir -p {state_paths.iteration_dir} && if [ ! -e {state_paths.config} ] && [ ! -e {state_paths.state_log} ] && [ ! -e {state_paths.strategy} ] && [ -e {spec_folder}/scratch/deep-review-strategy.md ] && ( [ -e {spec_folder}/scratch/deep-research-config.json ] || [ -e {spec_folder}/scratch/deep-research-state.jsonl ] ); then [ -e {spec_folder}/scratch/deep-research-config.json ] && mv {spec_folder}/scratch/deep-research-config.json {state_paths.config}; [ -e {spec_folder}/scratch/deep-research-state.jsonl ] && mv {spec_folder}/scratch/deep-research-state.jsonl {state_paths.state_log}; [ -e {spec_folder}/scratch/deep-review-strategy.md ] && mv {spec_folder}/scratch/deep-review-strategy.md {state_paths.strategy}; [ -e {spec_folder}/scratch/deep-review-dashboard.md ] && mv {spec_folder}/scratch/deep-review-dashboard.md {state_paths.dashboard}; find {spec_folder}/scratch -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; ; [ -e {spec_folder}/scratch/.deep-research-pause ] && mv {spec_folder}/scratch/.deep-research-pause {state_paths.pause_sentinel}; [ -e {state_paths.legacy_root_report} ] && mv {state_paths.legacy_root_report} {state_paths.review_output}; if [ -e {state_paths.state_log} ]; then printf '%s\\n' '{\\\"type\\\":\\\"event\\\",\\\"event\\\":\\\"migration\\\",\\\"mode\\\":\\\"review\\\",\\\"legacyArtifacts\\\":[\\\"deep-research-config.json\\\",\\\"deep-research-state.jsonl\\\",\\\".deep-research-pause\\\"],\\\"canonicalArtifacts\\\":[\\\"deep-review-config.json\\\",\\\"deep-review-state.jsonl\\\",\\\".deep-review-pause\\\"],\\\"timestamp\\\":\\\"{ISO_8601_NOW}\\\"}' >> {state_paths.state_log}; fi; fi; find {state_paths.local_packet_dir} -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; 2>/dev/null || true\"\n235: \n236:       step_acquire_lock:\n237:         action: \"Acquire the single-writer advisory lock before session classification\"\n238:         command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs acquire --lock-path {state_paths.lock_file} --packet-id {spec_folder}\"\n239:         on_acquire: \"Capture ownerPid from the JSON output and reuse it for every release below. If acquired=false, fail closed — another deep-review run already holds this packet.\"\n240:         note: \"Uses the promoted deep-loop-runtime loop-lock CLI (single source of truth: stale-lock reclaim, clean owner-scoped release). macOS/BSD locking is advisory — best-effort single-writer, not a hard mutex across host calls; stale-lock override is confirm-only or explicit recovery-only.\"\n241:         # Lock-cleanup contract: the lock file MUST be released on every terminal exit path that follows acquisition.\n242:         # Runtimes honoring step_acquire_lock are required to perform this cleanup before halting or pausing.\n243:         on_halt:\n244:           action: \"Release the lock before any terminal halt branch returns control\"\n245:           applies_to: [\"step_classify_session.on_invalid_state\", \"step_classify_session.on_completed_session\"]\n246:           command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; failures here are logged but do not block the halt\"\n247:         on_cancel:\n248:           action: \"Release the lock on user cancel or pause-sentinel detection before sentinel processing\"\n249:           command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; cancel completes regardless of cleanup result\"\n250:         on_workflow_exit:\n251:           action: \"Release the lock as the final step of any workflow exit path (success or failure)\"\n252:           command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; idempotent — safe to invoke when already released\"\n253: \n254:       step_classify_session:\n255:         action: \"Classify the session before writing files\"\n256:         inspect:\n257:           - \"{state_paths.config}\"\n258:           - \"{state_paths.state_log}\"\n259:           - \"{state_paths.findings_registry}\"\n260:           - \"{state_paths.strategy}\"\n261:         classify:\n262:           fresh: \"None of the three state artifacts exist\"\n263:           resume: \"Config, JSONL, and strategy all exist and config.mode == 'review' and agree on target/spec folder\"\n264:           completed-session: \"Resume artifacts exist and config.status == 'complete'\"\n265:           invalid-state: \"Any partial, missing, or contradictory combination\"\n266:         outputs:\n267:           - session_state: \"fresh | resume | completed-session | invalid-state\"\n268:         on_resume:\n269:           log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n270:           append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n271:           skip_to: phase_loop\n272:         on_restart:\n273:           action: \"Archive the current review packet under the root-level review_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n274:           command: \"if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi\"\n275:           set:\n276:             lineage_mode: \"restart\"\n277:             parent_session_id: \"{prior_session_id}\"\n278:             generation: \"{prior_generation + 1}\"\n279:           append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n280:           skip_to: step_create_config\n281:         note_deferred_branches: \"fork and completed-continue are deferred and no longer runtime-supported in this release. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are live. See deep-review/references/protocol/loop_protocol.md §Lifecycle Branches for the one-session contract.\"\n282:         on_completed_session:\n283:           log: \"Prior session already completed. Either archive the completed review/ tree and start a fresh session, or jump straight to synthesis with the existing artifacts.\"\n284:           skip_to: phase_synthesis\n285:         on_invalid_state:\n286:           halt: true\n287:           message: \"Existing deep-review state in review/ is incomplete or contradictory. Repair or archive the invalid review packet before continuing.\"\n288:         on_fresh:\n289:           action: \"Proceed with a new session\"\n290: \n291:       step_scope_discovery:\n292:         action: \"Resolve review target to a concrete file list based on target type\"\n293:         resolve:\n294:           spec-folder: |\n295:             1. Read spec.md, plan.md, tasks.md, checklist.md, implementation-summary.md\n296:             2. Discover implementation files referenced in spec artifacts\n297:             3. Discover test files associated with implementation\n298:             4. Set scope = all discovered files\n299:           skill: |\n300:             1. Read SKILL.md from .opencode/skills/{skill_name}/\n301:             2. Discover references/, assets/, scripts/ contents\n302:             3. Find agent definitions referencing this skill across runtimes\n303:             4. Find command entry points referencing this skill\n304:             5. Set scope = all discovered files\n305:           agent: |\n306:             1. Find agent definition across repo-managed runtimes (.claude/agents/, .opencode/agents/, .codex/agents/, .agents/)\n307:             2. Compare agent definitions for consistency\n308:             3. Set scope = all discovered agent files\n309:           track: |\n310:             1. List all child spec folders under specs/{track}/ or .opencode/specs/{track}/\n311:             2. For each: read spec.md + checklist.md\n312:             3. Set scope = all child spec artifacts\n313:           files: |\n314:             1. Expand glob patterns from review_target\n315:             2. Validate all files exist\n316:             3. Discover immediate cross-references (imports, links)\n317:             4. Set scope = expanded file list + cross-references\n318:         outputs:\n319:           - review_scope_files: \"List of all files in review scope\"\n320:           - cross_reference_targets: \"{ spec_paths: [...], code_paths: [...], test_paths: [...] }\"\n321: \n322:       step_order_dimensions:\n323:         action: \"Order review dimensions based on risk priority\"\n324:         algorithm: |\n325:           1. Iteration 0 (inventory pass): Build artifact map, identify file types, estimate complexity\n326:           2. Subsequent iterations follow risk-ordered deep passes:\n327:              correctness → security → traceability → maintainability\n328:           3. If review_dimensions != \"all\", filter to only requested dimensions\n329:           4. Derive traceability protocol plan:\n330:              - core: spec_code, checklist_evidence\n331:              - overlay: skill_agent, agent_cross_runtime, feature_catalog_code, playbook_capability\n332:           5. If resource_map_present, reserve at least one traceability-oriented pass to cross-check target_files from applied/T-*.md against resource-map.md and classify touched / expected-by-scope / gap / absent-from-map outcomes\n333:           6. Store ordered list as dimension_queue\n334:         outputs:\n335:           - dimension_queue: \"Ordered list of dimensions to review\"\n336:           - inventory_pass: true\n337: \n338:       step_normalize_review_dimensions:\n339:         action: \"Normalize reviewDimensions once during init for config + JSONL reuse\"\n340:         outputs:\n341:           - review_dimensions_normalized: \"Canonical string[] for deep-review-config.json\"\n342:           - review_dimensions_json: \"JSON.stringify(review_dimensions_normalized) for JSONL config record\"\n343:         normalize: |\n344:           Accept {review_dimensions} in any of these shapes and convert once:\n345:             - \"all\" → [\"correctness\",\"security\",\"traceability\",\"maintainability\"]\n346:             - \"correctness,security\" → [\"correctness\",\"security\"]\n347:             - [\"correctness\"] → [\"correctness\"]\n348:           Every element MUST be one of the four canonical dimension names.\n349: \n350:       step_create_config:\n351:         action: \"Create deep-review-config.json from template with review-specific fields\"\n352:         template: .opencode/skills/deep-loop-workflows/deep-review/assets/deep_review_config.json\n353:         populate:\n354:           topic: \"Review: {review_target}\"\n355:           mode: \"review\"\n356:           sessionId: \"{ISO_8601_NOW}\"\n357:           parentSessionId: null\n358:           lineageMode: \"new\"\n359:           generation: 1\n360:           continuedFromRun: null\n361:           reviewTarget: \"{review_target}\"\n362:           reviewTargetType: \"{review_target_type}\"\n363:           # Reuse the single normalized init-time value from step_normalize_review_dimensions.\n364:           reviewDimensions: \"{review_dimensions_normalized}\"\n365:           resource_map_present: \"{resource_map_present}\"\n366:           reviewScopeFiles: \"{review_scope_files}\"\n367:           severityThreshold: \"P2\"\n368:           crossReference:\n369:             core: [\"spec_code\", \"checklist_evidence\"]\n370:             overlay: [\"skill_agent\", \"agent_cross_runtime\", \"feature_catalog_code\", \"playbook_capability\"]\n371:           maxIterations: \"{max_iterations}\"\n372:           # Semantic: weighted P0/P1/P2 severity ratio. See SKILL.md §\"Convergence Threshold Semantics\".\n373:           convergenceThreshold: \"{convergence_threshold}\"\n374:           stuckThreshold: 2\n375:           maxDurationMinutes: 120\n376:           specFolder: \"{spec_folder}\"\n377:           # <!-- F-010-B5-04 -->\n378:           # Honor the parsed --no-resource-map flag from deep-review.md:71 (default true; false when flag is set).\n379:           # The markdown command parses $ARGUMENTS and binds {resource_map_emit} before this step runs.\n380:           resource_map.emit: \"{resource_map_emit}\"\n381:           createdAt: \"{ISO_8601_NOW}\"\n382:           status: \"initialized\"\n383:           releaseReadinessState: \"in-progress\"\n384:           executionMode: \"auto\"\n385:         output: \"{state_paths.config}\"\n386: \n387:       step_create_state_log:\n388:         action: \"Initialize JSONL state log with config record including review fields and lineage metadata\"\n389:         note: \"Reuse review_dimensions_json from step_normalize_review_dimensions. Never re-normalize or wrap the raw template value.\"\n390:         # <!-- F-010-B5-04 -->\n391:         # Same parsed --no-resource-map flag honored here so config and state_log agree from line 1.\n392:         content: '{\"type\":\"config\",\"mode\":\"review\",\"reviewTarget\":\"{review_target}\",\"reviewTargetType\":\"{review_target_type}\",\"reviewDimensions\":{review_dimensions_json},\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"sessionId\":\"{ISO_8601_NOW}\",\"parentSessionId\":null,\"lineageMode\":\"new\",\"generation\":1,\"continuedFromRun\":null,\"maxIterations\":{max_iterations},\"convergenceThreshold\":{convergence_threshold},\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\"}'\n393:         output: \"{state_paths.state_log}\"\n394: \n395:       step_create_findings_registry:\n396:         action: \"Initialize reducer-owned review findings registry\"\n397:         content: '{\"sessionId\":\"{ISO_8601_NOW}\",\"generation\":1,\"lineageMode\":\"new\",\"openFindings\":[],\"resolvedFindings\":[],\"repeatedFindings\":[],\"dimensionCoverage\":{\"correctness\":false,\"security\":false,\"traceability\":false,\"maintainability\":false},\"findingsBySeverity\":{\"P0\":0,\"P1\":0,\"P2\":0},\"openFindingsCount\":0,\"resolvedFindingsCount\":0,\"convergenceScore\":0.0}'\n398:         output: \"{state_paths.findings_registry}\"\n399: \n400:       step_create_strategy:\n401:         action: \"Create review strategy file from deep_review_strategy.md template\"\n402:         template: .opencode/skills/deep-loop-workflows/deep-review/assets/deep_review_strategy.md\n403:         populate:\n404:           review_target: \"{review_target}\"\n405:           review_target_type: \"{review_target_type}\"\n406:           dimensions: \"{dimension_queue}\"\n407:           scope_files: \"{review_scope_files}\"\n408:           cross_reference_targets: \"{cross_reference_targets}\"\n409:           max_iterations: \"{max_iterations}\"\n410:           convergence_threshold: \"{convergence_threshold}\"\n411:         output: \"{state_paths.strategy}\"\n412: \n413:       step_enrich_strategy_context:\n414:         action: \"Ensure Known Context is written only after strategy.md exists\"\n415:         condition: \"prior_context_found\"\n416:         edit: \"{state_paths.strategy}\"\n417:         note: \"Append or replace the Known Context section with prior_context_summary and retained detail from prior_context\"\n418: \n419:       step_enrich_strategy_resource_map:\n420:         action: \"Inject resource-map status into Known Context after strategy.md exists\"\n421:         edit: \"{state_paths.strategy}\"\n422:         note: \"When resource_map_present is true, append the resource_map_known_context snapshot and add Resource Map Coverage to the Review Charter. When false, append 'resource-map.md not present; skipping coverage gate'.\"\n423: \n424:       step_init_complete:\n425:         log: \"Initialization complete. Config, state, and strategy files created. Review scope: {review_scope_files_count} files, {dimension_queue_count} dimensions.\"\n426:         set: { current_iteration: 1, stuck_count: 0, p0_count: 0, p1_count: 0, p2_count: 0 }\n427: \n428:   # ═══════════════════════════════════════════════════════════════\n429:   # PHASE 2: ITERATION LOOP\n430:   # ═══════════════════════════════════════════════════════════════\n431:   phase_loop:\n432:     purpose: Dispatch review agent iterations until convergence\n433:     repeat: true\n434:     max_repeats: \"{max_iterations}\"\n435:     steps:\n436: \n437:       step_read_state:\n438:         action: \"Read current state from JSONL, strategy, and config\"\n439:         read:\n440:           - \"{state_paths.state_log}\"\n441:           - \"{state_paths.findings_registry}\"\n442:           - \"{state_paths.strategy}\"\n443:           - \"{state_paths.config}\"\n444:         extract:\n445:           - iteration_count: \"Count lines where type === 'iteration'\"\n446:           - current_iteration: \"iteration_count + 1\"\n447:           - last_newFindingsRatio: \"Extract newFindingsRatio from last iteration record\"\n448:           - last_focus: \"Extract focus/dimension from latest iteration record, else 'none yet'\"\n449:           - ratio_prev: \"Extract newFindingsRatio from second-latest iteration record, else 'N/A'\"\n450:           - ratio_latest: \"Extract newFindingsRatio from latest iteration record, else 'N/A'\"\n451:           - next_dimension: \"Next uncovered dimension from dimension_queue in strategy.md\"\n452:           - dimensions_covered: \"List of dimensions already reviewed\"\n453:           - dimensions_remaining: \"List of dimensions not yet reviewed\"\n454:           - dimension_coverage: \"covered / total dimensions\"\n455:           - coverage_age: \"Iterations since dimension coverage last changed; require >= 1 before STOP\"\n456:           - p0_count: \"Count P0 findings across all iterations\"\n457:           - p1_count: \"Count P1 findings across all iterations\"\n458:           - p2_count: \"Count P2 findings across all iterations\"\n459:           - resource_map_present: \"Extract boolean from deep-review-config.json, default false\"\n460:           - resource_map_prompt_line: \"If resource_map_present is true, return 'Resource Map Coverage: cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md and classify only missed coverage as gaps.' Else return 'Resource Map Coverage: resource-map.md not present; skipping coverage gate.'\"\n461:           - session_id: \"Extract sessionId from deep-review-config.json\"\n462:           - generation: \"Extract generation from deep-review-config.json, else 1\"\n463:           - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: dimension (ratio, P0/P1/P2)'\"\n464:           - latest_status: \"Extract status from latest iteration record, else 'none yet'\"\n465:           - last_claim_adjudication_passed: \"Scan state.jsonl for the most recent `claim_adjudication` event; use its `passed` boolean. Default true when no event exists or when activeP0 + activeP1 == 0 (gate is vacuous without adjudicable findings).\"\n466:           - claim_adjudication_active_count: \"Count of active P0/P1 findings at the time of the last claim_adjudication event; 0 when none exist\"\n467:           - security_sensitive_fix_scope: \"Boolean true when the current review is a rerun after fixes involving security, path disclosure, auth/authz, sandboxing, env precedence, public schemas, persistence, or user-visible error payloads; derive from the latest review report, remediation notes, or planning packet when present, else false.\"\n468:           - fix_completeness_replay_required_rows: \"Count prior active or remediated P0/P1 findings, plus any prior security/path P2 findings, that require closed-gate replay before STOP.\"\n469:           - fix_completeness_replay_passing_rows: \"Count required replay rows marked PASS with file:line or command evidence and producer/consumer/matrix coverage.\"\n470: \n471:       step_check_pause_sentinel:\n472:         action: \"Check for pause sentinel file\"\n473:         check: \"Does {state_paths.pause_sentinel} exist?\"\n474:         if_exists:\n475:           set:\n476:             pending_stop_event: \"paused\"\n477:             pending_stop_reason: \"userPaused\"\n478:             pending_stop_detail: \"sentinel file detected\"\n479:           skip_to: step_normalize_pause_events\n480:         if_not_exists:\n481:           proceed: true\n482: \n483:       step_graph_convergence:\n484:         action: \"Evaluate coverage-graph convergence before the inline review convergence vote\"\n485:         inspect:\n486:           - \"{state_paths.state_log}\"\n487:           - \"{state_paths.findings_registry}\"\n488:         transform: |\n489:           1. Call graph convergence on the current review lineage before the inline 3-signal vote.\n490:           2. Record the decision as one of CONTINUE, STOP_ALLOWED, STOP_BLOCKED.\n491:           3. Preserve raw graph signals and blockers for reducer rollup and blocked-stop evidence.\n492:           4. Normalize blockers to both JSON array and CSV forms for downstream stop handling.\n493:           5. Set graph_stop_blocked = true only when graph_decision == \"STOP_BLOCKED\".\n494:         bash: 'node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"review\" --session-id \"{session_id}\"'\n495:         note: \"Invoke the runtime script directly. Review-side graph convergence must run before the inline review stop vote.\"\n496:         append_jsonl: '{\"type\":\"event\",\"event\":\"graph_convergence\",\"mode\":\"review\",\"run\":{current_iteration},\"decision\":\"{graph_decision}\",\"signals\":{graph_signals_json},\"blockers\":{graph_blockers_json},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n497:         outputs:\n498:           - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED\"\n499:           - graph_signals_json: \"JSON object returned by convergence.cjs\"\n500:           - graph_blockers_json: \"JSON array of graph blockers when present, else []\"\n501:           - graph_blockers_csv: \"Comma-separated blocker summary when graph blocks STOP, else empty string\"\n502:           - graph_stop_blocked: \"Boolean true when graph_decision == STOP_BLOCKED\"\n503: \n504:       step_check_convergence:\n505:         action: \"Evaluate graph-assisted review stop conditions and the legal-stop decision tree\"\n506:         algorithm: |\n507:           0. CLAIM-ADJUDICATION PRE-CHECK (universal STOP veto; runs before hard stops and composite convergence):\n508:              claim_adjudication_gate_pass = (last_claim_adjudication_passed != false) OR (p0_count + p1_count == 0)\n509:              If claim_adjudication_gate_pass == false:\n510:                candidate_decision = \"BLOCKED\"\n511:                stop_blocked = true\n512:                stopReason = \"blockedStop\"\n513:                blocked_gates = [\"claimAdjudicationGate\"]\n514:                recovery_strategy = \"Reviewer must add typed claim-adjudication packets (claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger) for every active P0/P1 finding before STOP is allowed.\"\n515:                Skip hard stops (1) and composite convergence (4); proceed directly to step 5 legal-stop decision-tree assembly so blocked_by_json, gate outputs, and the blocked_stop event still populate consistently.\n516:           1. HARD STOPS:\n517:              a) if iteration_count >= max_iterations: set decision = \"STOP\", stopReason = \"maxIterationsReached\", hard_stop_reason = \"max_iterations_reached\", preserve any failed legal-stop gates as terminal evidence, and proceed to synthesis without legal-stop veto\n518:              b) if all dimensions clean AND required traceability protocols are covered AND p0_count == 0 AND p1_count == 0 AND coverage_age >= 1 AND all quality gates pass (evidence: every P0/P1 has file:line; scope: all findings within target; coverage: all dimensions reviewed): mark hard_stop_reason = \"all_dimensions_clean\" and promote to STOP candidate\n519:              Operator stop reasons (`maxIterationsReached`, `manualStop`, `userPaused`, unrecoverable `error`) are terminal ceilings. They do not hide failed gates; they record them in synthesis and stop dispatch.\n520:           2. STUCK DETECTION (threshold 2):\n521:              if stuck_count >= 2: STUCK_RECOVERY\n522:           3. GRAPH CONVERGENCE PREREQUISITE:\n523:                graph_decision, graph_signals_json, and graph_blockers_json are already populated by step_graph_convergence.\n524:                Final STOP is never legal unless the inline review vote says STOP AND graph_decision == \"STOP_ALLOWED\".\n525:                If graph_decision == \"STOP_BLOCKED\", set stop_blocked = true and route through blocked_stop emission instead of stopping.\n526:           4. COMPOSITE CONVERGENCE (3-signal weighted vote with split thresholds):\n527:                signals = []\n528:                a) Rolling average (w=0.30, window=2, needs 2+ iterations):\n529:                   avg = mean(last 2 newFindingsRatios)\n530:                   stop if avg <= 0.08\n531:                b) MAD noise floor (w=0.25, needs 3+ iterations):\n532:                   noiseFloor = MAD(all ratios) * 1.4826\n533:                   stop if latest ratio <= noiseFloor\n534:                c) Dimension coverage (w=0.45):\n535:                   coverage = dimensions_covered / total_dimensions\n536:                   stop if coverage >= 1.0 AND required traceability protocols are covered AND coverage_age >= 1\n537:                Redistribute weights for unavailable signals.\n538:                if latest ratio <= 0.05: mark no_progress_threshold_reached\n539:                if weighted_stop_score >= 0.60: inline STOP becomes a candidate and binary gates must run\n540:           5. LEGAL-STOP DECISION TREE (review-specific gates; runs whenever step 0, all-dimensions-clean, or the composite vote promotes STOP to a candidate; terminal max-iteration/manual/error stops bypass veto and record failed gates as evidence):\n541:                a) convergenceGate: pass when a hard-stop condition is met OR weighted_stop_score >= 0.60; record score\n542:                b) dimensionCoverageGate: pass when configured dimensions and required traceability coverage are complete and coverage_age >= 1; record covered and missing dimensions\n543:                c) p0ResolutionGate: pass when activeP0 == 0; record activeP0\n544:                d) evidenceDensityGate: pass when every active P0/P1 has concrete file:line evidence and no active P0/P1 relies only on inference; record avgEvidencePerFinding\n545:                e) hotspotSaturationGate: pass when review hotspots have been revisited enough times to satisfy the saturation heuristic\n546:                f) claimAdjudicationGate: pass when claim_adjudication_gate_pass == true (i.e. last_claim_adjudication_passed != false OR there are no active P0/P1 findings to adjudicate); record last_claim_adjudication_passed and claim_adjudication_active_count\n547:                g) fixCompletenessReplayGate: pass when security_sensitive_fix_scope == false OR every required closed-gate replay row passes with file:line or command evidence and producer/consumer/matrix coverage; record security_sensitive_fix_scope, fix_completeness_replay_required_rows, and fix_completeness_replay_passing_rows\n548:                h) candidateCoverageGate: skip entirely when `reviewDepthSchemaVersion` is not 2 on the latest iteration. Otherwise pass when the current iteration's `reviewDepthApplicability.scopeClass` is `trivial` with `enforcement: \"skip\"` AND `reviewDepthApplicability.evidenceRefs` is non-empty, OR when the reducer registry's `searchDebt` is empty AND `candidateCoverage.covered` is a superset of `searchCoverage.requiredBugClasses` for the lineage. Otherwise pass = false; record `searchDebt` items as blocked-stop evidence; blocker name = \"candidateCoverageGate\"; recovery_strategy = \"Resolve deferred/blocked obligations in next iteration or downgrade scope explicitly to trivial with cited evidence.\"\n549:                i) graphlessFallbackGate: skip when `reviewDepthSchemaVersion` is not 2 OR the reducer registry's last-iteration `searchCoverage.graphCoverageMode` is `graph`. Applies when graphCoverageMode is `graphless_fallback` or `unavailable_blocked`. Pass when graphCoverageMode is `graphless_fallback` AND at least one `searchLedger` row exists for each entry in `searchCoverage.requiredBugClasses` with `searchActions[].method` in {\"direct_read\",\"exact_grep\",\"semantic_search\",\"code_graph_status_check\",\"producer_consumer_trace\",\"negative_test_inspection\"} AND non-empty `evidenceRefs`. Fail automatically when graphCoverageMode is `unavailable_blocked`; record the explicit unavailability reason. Otherwise pass = false; blocker name = \"graphlessFallbackGate\"; recovery_strategy = \"Add cited fallback ledger rows (direct read, exact search, producer/consumer trace, negative-test inspection) or set graphCoverageMode to 'graph' once graph data is available.\"\n550:              if STOP is a candidate and any gate fails:\n551:                decision = \"BLOCKED\"\n552:                stop_blocked = true\n553:                stopReason = \"blockedStop\"\n554:                blocked_by_json = JSON array of failing gate names (always include \"claimAdjudicationGate\" when claim_adjudication_gate_pass == false, \"fixCompletenessReplayGate\" when fix_completeness_replay_gate_pass == false, \"candidateCoverageGate\" when candidate_coverage_gate_pass == false, and \"graphlessFallbackGate\" when graphless_fallback_gate_pass == false)\n555:                blocked_by_csv = comma-separated list of failing gate names\n556:                convergence_gate_pass = boolean\n557:                convergence_gate_score = numeric convergence score\n558:                dimension_coverage_gate_pass = boolean\n559:                dimension_coverage_gate_covered_json = JSON array of covered review dimensions\n560:                dimension_coverage_gate_missing_json = JSON array of missing review dimensions\n561:                p0_resolution_gate_pass = boolean\n562:                active_p0_count = number of active P0 findings\n563:                evidence_density_gate_pass = boolean\n564:                avg_evidence_per_finding = numeric evidence density\n565:                hotspot_saturation_gate_pass = boolean\n566:                claim_adjudication_gate_pass = boolean\n567:                claim_adjudication_active_count = numeric count of active P0/P1 at the gate\n568:                fix_completeness_replay_gate_pass = boolean\n569:                security_sensitive_fix_scope = boolean\n570:                fix_completeness_replay_required_rows = numeric count of closed-gate replay rows required for security-sensitive fix reruns\n571:                fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n572:                candidate_coverage_gate_pass = boolean\n573:                candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n574:                candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n575:                graphless_fallback_gate_pass = boolean\n576:                graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n577:                graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n578:                graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n579:                recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n580:           6. COMBINED STOP RULE:\n581:                a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n582:                b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n583:                     decision = \"BLOCKED\"\n584:                     stop_blocked = true\n585:                     stopReason = \"blockedStop\"\n586:                     # Blocked-stop closure: blockedBy must be string[] per the\n587:                     # published review blocked-stop contract. Extract the `.type`\n588:                     # field from each structured graph blocker; preserve the full\n589:                     # objects in graph_blocker_detail_json for operator inspection.\n590:                     blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n591:                     blocked_by_csv = graph_blockers_csv\n592:                     graph_blocker_detail_json = graph_blockers_json\n593:                     recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n594:                c) if STOP is legal AND graph_decision == \"CONTINUE\":\n595:                     decision = \"CONTINUE\"\n596:                     stop_blocked = false\n597:                     reason = \"graph_convergence_continue\"\n598:                d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n599:         outputs:\n600:           - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n601:           - reason: \"Human-readable stop reason\"\n602:           - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n603:           - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n604:           - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n605:           - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n606:           - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n607:           - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n608:           - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n609:           - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n610:           - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n611:           - active_p0_count: \"Active P0 finding count at stop-check time\"\n612:           - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n613:           - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n614:           - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n615:           - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n616:           - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n617:           - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n618:           - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n619:           - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n620:           - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n621:           - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n622:           - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n623:           - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n624:           - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n625:           - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n626:           - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n627:           - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n628:           - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n629:           - graph_signals_json: \"JSON object returned by graph convergence\"\n630:           - graph_blockers_json: \"JSON array of graph blockers\"\n631:           - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n632:           - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n633: \n634:       step_emit_blocked_stop:\n\n(Output capped at 50 KB. Showing lines 1-634. Use offset=635 to continue.)\n</content>\n\n<system-reminder>\nInstructions from: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/CONTEXT.md\n---\ndescription: Codebase-context loop: heterogeneous parallel sweep with convergence detection. Modes :auto, :confirm.\nargument-hint: \"<scope> [:auto|:confirm] [--max-iterations=N] [--convergence=N] [--executor=<type> [--model=X] [--prompt-framework=X] [--label=X] ...] [--executors=<json>] [--concurrency=N] (:auto supports PRE-BOUND SETUP ANSWERS: prompt-body block for non-interactive setup)\"\nallowed-tools: Read, Write, Edit, Bash, Grep, Glob, Task, mcp__mk_spec_memory__memory_context, mcp__mk_spec_memory__memory_search, mcp__mk_code_index__code_graph_query, mcp__mk_code_index__code_graph_context\n---\n\n# Deep Start Context Loop\n\nThin router for the deep-context loop. This command verifies the orchestrating agent, resolves setup and execution mode, loads the presentation contract, then executes the owned workflow YAML.\n\n## 1. ROUTER CONTRACT\n\nDo not dispatch agents from this Markdown file. Agent dispatch, workflow steps, and artifact-writing behavior are owned by the workflow YAML assets.\n\nLoad the presentation contract before showing startup questions, dashboards, checkpoints, success output, failure output, examples, or next-step prompts.\n\nThis command is **general-agent based** and must pass the @general verification gate before setup routing continues. Gate 1 (@general verification) and Gate 2 (the BLOCKED Unified Setup Phase) are HARD BLOCKS; neither may be skipped.\n\n### PHASE 0: @GENERAL AGENT VERIFICATION\n\n**STATUS: ☐ BLOCKED**\n\n```\nEXECUTE THIS AUTOMATIC SELF-CHECK (NOT A USER QUESTION):\n\nSELF-CHECK: Are you operating as the @general agent?\n│\n├─ INDICATORS that you ARE @general agent:\n│   ├─ You can orchestrate the deep-context loop (YAML workflow execution)\n│   ├─ You can orchestrate Read/Write/Edit/Bash workflow execution\n│   ├─ You can load skill references and execute defined logic\n│\n├─ IF YES (all indicators present):\n│   └─ general_agent_verified = TRUE → Continue to the Unified Setup Phase (also a HARD BLOCK)\n│\n└─ IF NO or UNCERTAIN:\n    │\n    ├─ ⛔ HARD BLOCK - DO NOT PROCEED\n    │\n    ├─ DISPLAY to user:\n    │   ┌────────────────────────────────────────────────────────────┐\n    │   │ ⛔ GENERAL AGENT REQUIRED                                  │\n    │   │                                                            │\n    │   │ This command orchestrates the deep-context loop and runs   │\n    │   │ general-agent based.                                       │\n    │   │                                                            │\n    │   │ To proceed, restart with:                                  │\n    │   │   /deep:context [arguments]                                │ \n    │   └────────────────────────────────────────────────────────────┘\n    │\n    └─ RETURN: STATUS=FAIL ERROR=\"General agent required\"\n```\n\n**Phase Output:**\n- `general_agent_verified = ________________`\n\n### MANDATORY INPUT GATE\n\n- **DO NOT** dispatch any agent from this document\n- **ALL** agent dispatching is handled by the YAML workflow steps\n- **MARKDOWN OWNS SETUP**: resolve setup inputs here first, then hand off to YAML\n- **YAML START CONDITION**: do not load YAML until ALL required inputs are bound:\n  - `scope`, `spec_folder`, `execution_mode`, `maxIterations`, `convergenceThreshold`\n- Resolve `executor_pool` before persisting config and entering the YAML workflow.\n\n---\n\n## 2. OWNED ASSETS\n\n| Purpose | Asset |\n|---------|-------|\n| Presentation source of truth | `.opencode/commands/deep/assets/deep_context_presentation.txt` |\n| Auto workflow | `.opencode/commands/deep/assets/deep_context_auto.yaml` |\n| Confirm workflow | `.opencode/commands/deep/assets/deep_context_confirm.yaml` |\n\nNo workflow-asset gap exists for this command.\n\n---\n\n## 3. MODE ROUTING\n\n1. Parse `$ARGUMENTS` for attached command suffixes (`:auto` or `:confirm`). Canonical mode syntax is `/deep:context:auto` and `/deep:context:confirm`; keep AGENTS, skills, and quick references synchronized to this entrypoint.\n2. Treat scope text, `--max-iterations`, `--convergence`, relevance/agreement flags, executor pool flags, and pre-bound setup answers as workflow inputs, not execution modes.\n3. If `:auto` is present, set `execution_mode = AUTONOMOUS` and resolve required setup inputs through the presentation contract's three-tier auto setup resolution before loading YAML.\n4. If `:confirm` is present, set `execution_mode = INTERACTIVE` and use the presentation contract's consolidated setup prompt before loading YAML.\n5. If no mode suffix is present, set `execution_mode = ASK` and use the presentation contract's consolidated setup prompt to ask for execution mode.\n6. Load the selected workflow asset only after `scope`, `spec_folder`, `execution_mode`, `maxIterations`, `convergenceThreshold`, and `executor_pool` are bound.\n\n---\n\n## 4. EXECUTION TARGETS\n\n| Mode | Workflow |\n|------|----------|\n| `:auto` | `.opencode/commands/deep/assets/deep_context_auto.yaml` |\n| `:confirm` or interactive choice | `.opencode/commands/deep/assets/deep_context_confirm.yaml` |\n\n---\n\n## 5. PRESENTATION BOUNDARY\n\nThe following content lives only in `.opencode/commands/deep/assets/deep_context_presentation.txt`:\n\n- Startup-question wording, consolidated setup prompt text, question text, and reply-format examples.\n- `:auto` pre-bound setup answer schema, default resolution table, targeted-ask rules, and fail-fast display behavior.\n- Dashboard/checkpoint layouts, workflow overview displays, convergence threshold semantics, runtime robustness/session classification displays, and memory/skill reference displays.\n- Success and failure result templates, output formats, and error-handling displays.\n- Example invocations, executor-pool explanation display, and next-step suggestion wording.\n\n---\n\n## 6. WORKFLOW SUMMARY\n\nThe YAML workflow runs iterative codebase-context gathering by seeding a `SLICE` frontier from the scope, dispatching every executor over the same focus as a parallel sweep, merging findings by `file:symbol` with agreement counts, and synthesizing a reuse-first Context Report under `context/`. Convergence uses deep-context's relevance-gated coverage saturation with agreement and relevance as blocking guards; do not transfer sibling defaults from deep-research or deep-review. Code graph tool IDs remain stable as `code_graph_query` and `code_graph_context`; implementation and docs live under `.opencode/skills/system-code-graph/`.\n\n**Context path:** `/deep:context` -> `/speckit:plan` -> `/speckit:implement`\n**Research:** `/deep:research` -> `/speckit:plan` -> `/speckit:implement`\n**Review:** `/deep:review` -> (if issues) `/speckit:plan` -> `/speckit:implement`\n\n</system-reminder>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\nrole: Deep Review Loop Manager\npurpose: Iterative code/spec review with convergence detection across review dimensions\naction: Run deep-review loop from initialization through synthesis\noperating_mode:\n  workflow: iterative_loop\n  workflow_compliance: MANDATORY\n  workflow_execution: autonomous\n  approvals: none\n  tracking: progressive_review_state\n  validation: convergence_detection\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING PRINCIPLES\n# ─────────────────────────────────────────────────────────────────\noperating_principles:","truncated":true,"loaded":["/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/CONTEXT.md"],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\n# DEEP REVIEW: AUTONOMOUS DEEP REVIEW LOOP (AUTO MODE)\n# ─────────────────────────────────────────────────────────────────\nrole: Deep Review Loop Manager\npurpose: Iterative code/spec review with convergence detection across review dimensions\naction: Run deep-review loop from initialization through synthesis\noperating_mode:\n  workflow: iterative_loop\n  workflow_compliance: MANDATORY\n  workflow_execution: autonomous\n  approvals: none\n  tracking: progressive_review_state\n  validation: convergence_detection\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING PRINCIPLES\n# ─────────────────────────────────────────────────────────────────\noperating_principles:\n  core: \"Fresh context per iteration + externalized state = no context degradation\"\n  approach: \"Dispatch focused review agent per dimension, evaluate convergence, repeat or stop\"\n  mandate: \"Never hold findings in memory; write everything to files. Review target is READ-ONLY.\"\n\n# ─────────────────────────────────────────────────────────────────\n# USER INPUTS (from setup phase)\n# ─────────────────────────────────────────────────────────────────\nuser_inputs:\n  review_target: \"[REVIEW_TARGET] - What to review. REQUIRED.\"\n  review_target_type: \"[spec-folder|skill|agent|track|files] - Target type for scope derivation. REQUIRED.\"\n  review_dimensions: \"[all|correctness,security,traceability,maintainability] - Dimensions to check. Default: all.\"\n  spec_folder: \"[SPEC_FOLDER] - Spec folder path for state files. REQUIRED.\"\n  lineage_mode: \"[auto|resume|restart] - Session lifecycle intent. Default: auto. The runtime only persists lineage events for `resume` (same sessionId, no archive) and `restart` (new sessionId, generation+1, prior review/ archived). `fork` and `completed-continue` are deferred and no longer accepted — see deep-review/references/protocol/loop_protocol.md §Lifecycle Branches.\"\n  max_iterations: 7\n  convergence_threshold: 0.10\n\n# ─────────────────────────────────────────────────────────────────\n# CONTEXT LOADING\n# ─────────────────────────────────────────────────────────────────\ncontext_loading:\n  trigger: \"At workflow START, before phase_init\"\n  purpose: \"Load prior review context for the target and buffer it until strategy.md exists\"\n  mcp_integration:\n    tool: memory_context\n    note: \"Call MCP tools directly - NEVER through Code Mode\"\n    parameters: { input: \"{review_target}\", mode: \"focused\", intent: \"understand\", includeContent: true }\n  when_to_skip: [\"User says 'skip context' or 'fresh start'\"]\n  behavior:\n    if_context_found: \"Store full results as prior_context plus a concise prior_context_summary; inject after strategy.md is created.\"\n    if_no_context: \"Set prior_context and prior_context_summary to 'None' and continue.\"\n\n# ─────────────────────────────────────────────────────────────────\n# SKILL REFERENCE\n# ─────────────────────────────────────────────────────────────────\nskill_reference:\n  skill: deep-loop-workflows\n  skill_md: .opencode/skills/deep-loop-workflows/deep-review/SKILL.md\n  references:\n    loop_protocol: .opencode/skills/deep-loop-workflows/deep-review/references/protocol/loop_protocol.md\n    state_format: .opencode/skills/deep-loop-workflows/deep-review/references/state/state_format.md\n    convergence: .opencode/skills/deep-loop-workflows/deep-review/references/convergence/convergence.md\n  templates:\n    config: .opencode/skills/deep-loop-workflows/deep-review/assets/deep_review_config.json\n    strategy: .opencode/skills/deep-loop-workflows/deep-review/assets/deep_review_strategy.md\n\n# ─────────────────────────────────────────────────────────────────\n# AGENT CONFIGURATION\n# ─────────────────────────────────────────────────────────────────\nagent_config:\n  agent: deep-review\n  agent_file: \".opencode/agents/deep-review.md\"\n  # Canonical path. Runtime-specific directories (e.g. .claude/agents/) reference this source.\n  mode: subagent\n  model: opus\n  leaf_only: true\n  tools: [Read, Write, Edit, Bash, Grep, Glob]\n  mcp_servers: [mk-spec-memory]\n  tool_call_budget: { target: 9, soft_max: 12, hard_max: 13 }\n\n# ─────────────────────────────────────────────────────────────────\n# STATE FILE PATHS\n# ─────────────────────────────────────────────────────────────────\nstate_paths:\n  # Template paths document the canonical packet layout. Runtime resolution happens via\n  # step_resolve_artifact_root plus the shared resolver, so root specs keep\n  # root-local review/ and child phases keep local review/ packet dirs.\n  # Canonical root-spec write targets remain review/deep-review-config.json,\n  # review/deep-review-state.jsonl, and review/deep-review-findings-registry.json.\n  packet_dir: \"{artifact_dir}\"\n  local_packet_dir: \"{spec_folder}/review\"\n  legacy_root_report: \"{spec_folder}/review-report.md\"\n  config: \"{artifact_dir}/deep-review-config.json\"\n  state_log: \"{artifact_dir}/deep-review-state.jsonl\"\n  findings_registry: \"{artifact_dir}/deep-review-findings-registry.json\"\n  strategy: \"{artifact_dir}/deep-review-strategy.md\"\n  dashboard: \"{artifact_dir}/deep-review-dashboard.md\"\n  pause_sentinel: \"{artifact_dir}/.deep-review-pause\"\n  lock_file: \"{artifact_dir}/.deep-review.lock\"\n  prompt_dir: \"{artifact_dir}/prompts\"\n  iteration_dir: \"{artifact_dir}/iterations\"\n  iteration_pattern: \"{artifact_dir}/iterations/iteration-{NNN}.md\"\n  # Per-iteration structured delta stream — complement to the canonical state_log\n  # append. MUST contain at least one record with `type === \"iteration\"`; variants\n  # like `\"iteration_delta\"` are silently dropped by the reducer.\n  delta_dir: \"{artifact_dir}/deltas\"\n  delta_pattern: \"{artifact_dir}/deltas/iter-{NNN}.jsonl\"\n  review_output: \"{artifact_dir}/review-report.md\"\n  resource_map_output: \"{artifact_dir}/resource-map.md\"\n  archive_root: \"{artifact_archive_root}\"\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW\n# ─────────────────────────────────────────────────────────────────\nworkflow:\n\n  step_resolve_artifact_root:\n    description: \"Resolve artifact directory — use fan-out lineage override when provided, else resolve from spec_folder\"\n    note: \"Root specs keep review artifacts directly in {spec_folder}/review/. Child phases and sub-phases keep local packet directories in {spec_folder}/review/{packet}/, and archives stay local at {spec_folder}/review_archive/{packet}/.\"\n    branch_on: \"config.fanout_lineage_artifact_dir\"\n    if_present:\n      bind:\n        artifact_dir: \"{config.fanout_lineage_artifact_dir}\"\n        artifact_root_dir: \"{config.fanout_lineage_artifact_dir}\"\n        artifact_subfolder: null\n        artifact_archive_root: \"{config.fanout_lineage_artifact_dir}/_archive\"\n    if_absent:\n      command: \"node -e \\\"const { resolveArtifactRoot } = require('.opencode/skills/system-spec-kit/shared/review-research-paths.cjs'); console.log(JSON.stringify(resolveArtifactRoot('{spec_folder}', 'review')));\\\"\"\n      outputs:\n        - artifact_root_dir: \"Resolved local review owner directory\"\n        - artifact_subfolder: \"Local packet subfolder ({ownerSlug}-pt-{NN}), else null\"\n        - artifact_dir: \"Resolved review packet directory for this target\"\n        - artifact_archive_root: \"Resolved local review archive directory for this target\"\n\n  step_fanout_spawn:\n    description: \"Spawn fan-out lineages; skip and proceed to phase_init normally when single-executor\"\n    skip_when: \"config.fanout is absent\"\n    instructions: |\n      Fan-out mode is active. Spawn all lineages. Each lineage runs the full loop in its own\n      isolated sub-packet under {artifact_dir}/lineages/{label}/.\n      After all lineages complete, jump directly to phase_synthesis — skip phase_init and\n      phase_main_loop entirely (those are the single-executor path). The merge step in\n      phase_synthesis will consolidate results across all lineages.\n    sub_steps:\n      step_fanout_spawn_cli:\n        description: \"Spawn all CLI lineages in capped worker pool\"\n        skip_when: \"no entries in config.fanout.executors with kind != 'native'\"\n        command: |\n          node .opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs \\\n            --spec-folder {spec_folder} \\\n            --loop-type review \\\n            --fanout-config-json '{config.fanout_json}' \\\n            --base-artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n      step_fanout_spawn_native:\n        description: \"Dispatch each native lineage as a sequential deep-review sub-agent\"\n        skip_when: \"no entries in config.fanout.executors with kind == 'native'\"\n        for_each: \"lineage in expanded native entries of config.fanout\"\n        dispatch:\n          agent: deep-review\n          model: opus\n          context: |\n            Execute the deep-review loop with these parameters:\n              spec_folder: {spec_folder}\n              config.fanout_lineage_artifact_dir: {artifact_dir}/lineages/{lineage.label}\n              session_id: fanout-{lineage.label}-{fanout_run_id}\n              executor: native\n            Run to convergence. Write all outputs to the override directory.\n        wait_for_completion: true\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 1: INITIALIZATION\n  # ═══════════════════════════════════════════════════════════════\n  phase_init:\n    purpose: Create all state files for the review session and resolve review scope\n    steps:\n\n      step_preflight_contract:\n        action: \"Validate required setup bindings and executable workflow contract before any file writes\"\n        verify:\n          - required_values_present: [review_target, review_target_type, review_dimensions, spec_folder, max_iterations, convergence_threshold]\n          - spec_folder_is_within: \"specs/ or .opencode/specs/ (canonicalize alias roots before validation)\"\n          - unresolved_placeholders: \"FAIL if any user-facing template references placeholders not produced by earlier steps\"\n          - tool_contract: \"FAIL if executable steps reference tools outside the command allowlist\"\n        on_fail: \"Halt with STATUS=FAIL and report the missing binding or unsupported contract reference\"\n\n      step_create_directories:\n        action: \"Create spec folder and canonical review packet directories if they don't exist\"\n        command: \"mkdir -p {state_paths.prompt_dir} {state_paths.iteration_dir} {state_paths.delta_dir}\"\n\n      step_detect_resource_map:\n        action: \"Detect resource-map.md before config creation so init can persist coverage-gate state\"\n        inspect:\n          - \"{spec_folder}/resource-map.md\"\n        classify:\n          present: \"resource-map.md exists at init\"\n          absent: \"resource-map.md does not exist at init\"\n        outputs:\n          - resource_map_present: \"Boolean true when {spec_folder}/resource-map.md exists, else false\"\n          - resource_map_known_context: \"When present: concise resource-map snapshot for Known Context and charter framing. When absent: 'resource-map.md not present; skipping coverage gate'.\"\n\n      step_migrate_legacy_review_state:\n        action: \"Rehome legacy review artifacts into review/iterations before session classification\"\n        detect:\n          canonical_review_state:\n            - \"{state_paths.config}\"\n            - \"{state_paths.state_log}\"\n            - \"{state_paths.findings_registry}\"\n            - \"{state_paths.strategy}\"\n          legacy_review_state:\n            - \"{spec_folder}/scratch/deep-research-config.json\"\n            - \"{spec_folder}/scratch/deep-research-state.jsonl\"\n            - \"{spec_folder}/scratch/deep-review-strategy.md\"\n            - \"{spec_folder}/scratch/deep-review-dashboard.md\"\n            - \"{spec_folder}/scratch/iteration-*.md\"\n            - \"{spec_folder}/scratch/.deep-research-pause\"\n            - \"{state_paths.local_packet_dir}/iteration-*.md\"\n            - \"{state_paths.legacy_root_report}\"\n          legacy_review_markers:\n            - \"scratch/deep-review-strategy.md exists\"\n            - \"scratch/deep-research-config.json declares mode == 'review' OR scratch/deep-research-state.jsonl contains mode == 'review'\"\n        migrate_only:\n          - \"{spec_folder}/scratch/deep-research-config.json -> {state_paths.config}\"\n          - \"{spec_folder}/scratch/deep-research-state.jsonl -> {state_paths.state_log}\"\n          - \"{spec_folder}/scratch/deep-review-strategy.md -> {state_paths.strategy}\"\n          - \"{spec_folder}/scratch/deep-review-dashboard.md -> {state_paths.dashboard}\"\n          - \"{spec_folder}/scratch/iteration-*.md -> {state_paths.iteration_dir}/\"\n          - \"{spec_folder}/scratch/.deep-research-pause -> {state_paths.pause_sentinel}\"\n          - \"{state_paths.local_packet_dir}/iteration-*.md -> {state_paths.iteration_dir}/\"\n          - \"{state_paths.legacy_root_report} -> {state_paths.review_output}\"\n        on_canonical_present: \"Leave canonical review/ state untouched and do not overwrite it with legacy scratch artifacts.\"\n        on_legacy_detected: \"Move only the review-specific whitelist, append a migration event to the canonical JSONL, and leave unrelated scratch files untouched.\"\n        on_conflict: \"If canonical review/ state and legacy scratch review state both exist but disagree, halt for operator repair instead of merging contradictory state.\"\n        command: \"mkdir -p {state_paths.iteration_dir} && if [ ! -e {state_paths.config} ] && [ ! -e {state_paths.state_log} ] && [ ! -e {state_paths.strategy} ] && [ -e {spec_folder}/scratch/deep-review-strategy.md ] && ( [ -e {spec_folder}/scratch/deep-research-config.json ] || [ -e {spec_folder}/scratch/deep-research-state.jsonl ] ); then [ -e {spec_folder}/scratch/deep-research-config.json ] && mv {spec_folder}/scratch/deep-research-config.json {state_paths.config}; [ -e {spec_folder}/scratch/deep-research-state.jsonl ] && mv {spec_folder}/scratch/deep-research-state.jsonl {state_paths.state_log}; [ -e {spec_folder}/scratch/deep-review-strategy.md ] && mv {spec_folder}/scratch/deep-review-strategy.md {state_paths.strategy}; [ -e {spec_folder}/scratch/deep-review-dashboard.md ] && mv {spec_folder}/scratch/deep-review-dashboard.md {state_paths.dashboard}; find {spec_folder}/scratch -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; ; [ -e {spec_folder}/scratch/.deep-research-pause ] && mv {spec_folder}/scratch/.deep-research-pause {state_paths.pause_sentinel}; [ -e {state_paths.legacy_root_report} ] && mv {state_paths.legacy_root_report} {state_paths.review_output}; if [ -e {state_paths.state_log} ]; then printf '%s\\n' '{\\\"type\\\":\\\"event\\\",\\\"event\\\":\\\"migration\\\",\\\"mode\\\":\\\"review\\\",\\\"legacyArtifacts\\\":[\\\"deep-research-config.json\\\",\\\"deep-research-state.jsonl\\\",\\\".deep-research-pause\\\"],\\\"canonicalArtifacts\\\":[\\\"deep-review-config.json\\\",\\\"deep-review-state.jsonl\\\",\\\".deep-review-pause\\\"],\\\"timestamp\\\":\\\"{ISO_8601_NOW}\\\"}' >> {state_paths.state_log}; fi; fi; find {state_paths.local_packet_dir} -maxdepth 1 -name 'iteration-*.md' -exec mv {} {state_paths.iteration_dir}/ \\\\; 2>/dev/null || true\"\n\n      step_acquire_lock:\n        action: \"Acquire the single-writer advisory lock before session classification\"\n        command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs acquire --lock-path {state_paths.lock_file} --packet-id {spec_folder}\"\n        on_acquire: \"Capture ownerPid from the JSON output and reuse it for every release below. If acquired=false, fail closed — another deep-review run already holds this packet.\"\n        note: \"Uses the promoted deep-loop-runtime loop-lock CLI (single source of truth: stale-lock reclaim, clean owner-scoped release). macOS/BSD locking is advisory — best-effort single-writer, not a hard mutex across host calls; stale-lock override is confirm-only or explicit recovery-only.\"\n        # Lock-cleanup contract: the lock file MUST be released on every terminal exit path that follows acquisition.\n        # Runtimes honoring step_acquire_lock are required to perform this cleanup before halting or pausing.\n        on_halt:\n          action: \"Release the lock before any terminal halt branch returns control\"\n          applies_to: [\"step_classify_session.on_invalid_state\", \"step_classify_session.on_completed_session\"]\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; failures here are logged but do not block the halt\"\n        on_cancel:\n          action: \"Release the lock on user cancel or pause-sentinel detection before sentinel processing\"\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; cancel completes regardless of cleanup result\"\n        on_workflow_exit:\n          action: \"Release the lock as the final step of any workflow exit path (success or failure)\"\n          command: \"node .opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}; idempotent — safe to invoke when already released\"\n\n      step_classify_session:\n        action: \"Classify the session before writing files\"\n        inspect:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        classify:\n          fresh: \"None of the three state artifacts exist\"\n          resume: \"Config, JSONL, and strategy all exist and config.mode == 'review' and agree on target/spec folder\"\n          completed-session: \"Resume artifacts exist and config.status == 'complete'\"\n          invalid-state: \"Any partial, missing, or contradictory combination\"\n        outputs:\n          - session_state: \"fresh | resume | completed-session | invalid-state\"\n        on_resume:\n          log: \"Auto-resume: state artifacts are complete and consistent. Continue the same lineage (sessionId unchanged, generation unchanged, no archive).\"\n          append_jsonl: '{\"type\":\"event\",\"event\":\"resumed\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{session_id}\",\"lineageMode\":\"resume\",\"continuedFromRun\":{iteration_count},\"generation\":{generation},\"archivedPath\":null,\"timestamp\":\"{ISO_8601_NOW}\"}'\n          skip_to: phase_loop\n        on_restart:\n          action: \"Archive the current review packet under the root-level review_archive/ tree and start a new lineage segment with a fresh sessionId and generation+1.\"\n          command: \"if [ -d {state_paths.packet_dir} ]; then mkdir -p {state_paths.archive_root} && mv {state_paths.packet_dir} {state_paths.archive_root}/{timestamp_slug}; fi\"\n          set:\n            lineage_mode: \"restart\"\n            parent_session_id: \"{prior_session_id}\"\n            generation: \"{prior_generation + 1}\"\n          append_jsonl: '{\"type\":\"event\",\"event\":\"restarted\",\"mode\":\"review\",\"sessionId\":\"{session_id}\",\"parentSessionId\":\"{prior_session_id}\",\"lineageMode\":\"restart\",\"generation\":{generation},\"archivedPath\":\"{state_paths.archive_root}/{timestamp_slug}\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n          skip_to: step_create_config\n        note_deferred_branches: \"fork and completed-continue are deferred and no longer runtime-supported in this release. The reducer still reads `lineageMode` from config for dashboards and analysis, but only `new`, `resume`, and `restart` are live. See deep-review/references/protocol/loop_protocol.md §Lifecycle Branches for the one-session contract.\"\n        on_completed_session:\n          log: \"Prior session already completed. Either archive the completed review/ tree and start a fresh session, or jump straight to synthesis with the existing artifacts.\"\n          skip_to: phase_synthesis\n        on_invalid_state:\n          halt: true\n          message: \"Existing deep-review state in review/ is incomplete or contradictory. Repair or archive the invalid review packet before continuing.\"\n        on_fresh:\n          action: \"Proceed with a new session\"\n\n      step_scope_discovery:\n        action: \"Resolve review target to a concrete file list based on target type\"\n        resolve:\n          spec-folder: |\n            1. Read spec.md, plan.md, tasks.md, checklist.md, implementation-summary.md\n            2. Discover implementation files referenced in spec artifacts\n            3. Discover test files associated with implementation\n            4. Set scope = all discovered files\n          skill: |\n            1. Read SKILL.md from .opencode/skills/{skill_name}/\n            2. Discover references/, assets/, scripts/ contents\n            3. Find agent definitions referencing this skill across runtimes\n            4. Find command entry points referencing this skill\n            5. Set scope = all discovered files\n          agent: |\n            1. Find agent definition across repo-managed runtimes (.claude/agents/, .opencode/agents/, .codex/agents/, .agents/)\n            2. Compare agent definitions for consistency\n            3. Set scope = all discovered agent files\n          track: |\n            1. List all child spec folders under specs/{track}/ or .opencode/specs/{track}/\n            2. For each: read spec.md + checklist.md\n            3. Set scope = all child spec artifacts\n          files: |\n            1. Expand glob patterns from review_target\n            2. Validate all files exist\n            3. Discover immediate cross-references (imports, links)\n            4. Set scope = expanded file list + cross-references\n        outputs:\n          - review_scope_files: \"List of all files in review scope\"\n          - cross_reference_targets: \"{ spec_paths: [...], code_paths: [...], test_paths: [...] }\"\n\n      step_order_dimensions:\n        action: \"Order review dimensions based on risk priority\"\n        algorithm: |\n          1. Iteration 0 (inventory pass): Build artifact map, identify file types, estimate complexity\n          2. Subsequent iterations follow risk-ordered deep passes:\n             correctness → security → traceability → maintainability\n          3. If review_dimensions != \"all\", filter to only requested dimensions\n          4. Derive traceability protocol plan:\n             - core: spec_code, checklist_evidence\n             - overlay: skill_agent, agent_cross_runtime, feature_catalog_code, playbook_capability\n          5. If resource_map_present, reserve at least one traceability-oriented pass to cross-check target_files from applied/T-*.md against resource-map.md and classify touched / expected-by-scope / gap / absent-from-map outcomes\n          6. Store ordered list as dimension_queue\n        outputs:\n          - dimension_queue: \"Ordered list of dimensions to review\"\n          - inventory_pass: true\n\n      step_normalize_review_dimensions:\n        action: \"Normalize reviewDimensions once during init for config + JSONL reuse\"\n        outputs:\n          - review_dimensions_normalized: \"Canonical string[] for deep-review-config.json\"\n          - review_dimensions_json: \"JSON.stringify(review_dimensions_normalized) for JSONL config record\"\n        normalize: |\n          Accept {review_dimensions} in any of these shapes and convert once:\n            - \"all\" → [\"correctness\",\"security\",\"traceability\",\"maintainability\"]\n            - \"correctness,security\" → [\"correctness\",\"security\"]\n            - [\"correctness\"] → [\"correctness\"]\n          Every element MUST be one of the four canonical dimension names.\n\n      step_create_config:\n        action: \"Create deep-review-config.json from template with review-specific fields\"\n        template: .opencode/skills/deep-loop-workflows/deep-review/assets/deep_review_config.json\n        populate:\n          topic: \"Review: {review_target}\"\n          mode: \"review\"\n          sessionId: \"{ISO_8601_NOW}\"\n          parentSessionId: null\n          lineageMode: \"new\"\n          generation: 1\n          continuedFromRun: null\n          reviewTarget: \"{review_target}\"\n          reviewTargetType: \"{review_target_type}\"\n          # Reuse the single normalized init-time value from step_normalize_review_dimensions.\n          reviewDimensions: \"{review_dimensions_normalized}\"\n          resource_map_present: \"{resource_map_present}\"\n          reviewScopeFiles: \"{review_scope_files}\"\n          severityThreshold: \"P2\"\n          crossReference:\n            core: [\"spec_code\", \"checklist_evidence\"]\n            overlay: [\"skill_agent\", \"agent_cross_runtime\", \"feature_catalog_code\", \"playbook_capability\"]\n          maxIterations: \"{max_iterations}\"\n          # Semantic: weighted P0/P1/P2 severity ratio. See SKILL.md §\"Convergence Threshold Semantics\".\n          convergenceThreshold: \"{convergence_threshold}\"\n          stuckThreshold: 2\n          maxDurationMinutes: 120\n          specFolder: \"{spec_folder}\"\n          # <!-- F-010-B5-04 -->\n          # Honor the parsed --no-resource-map flag from deep-review.md:71 (default true; false when flag is set).\n          # The markdown command parses $ARGUMENTS and binds {resource_map_emit} before this step runs.\n          resource_map.emit: \"{resource_map_emit}\"\n          createdAt: \"{ISO_8601_NOW}\"\n          status: \"initialized\"\n          releaseReadinessState: \"in-progress\"\n          executionMode: \"auto\"\n        output: \"{state_paths.config}\"\n\n      step_create_state_log:\n        action: \"Initialize JSONL state log with config record including review fields and lineage metadata\"\n        note: \"Reuse review_dimensions_json from step_normalize_review_dimensions. Never re-normalize or wrap the raw template value.\"\n        # <!-- F-010-B5-04 -->\n        # Same parsed --no-resource-map flag honored here so config and state_log agree from line 1.\n        content: '{\"type\":\"config\",\"mode\":\"review\",\"reviewTarget\":\"{review_target}\",\"reviewTargetType\":\"{review_target_type}\",\"reviewDimensions\":{review_dimensions_json},\"resource_map_present\":{resource_map_present},\"resource_map\":{\"emit\":{resource_map_emit}},\"sessionId\":\"{ISO_8601_NOW}\",\"parentSessionId\":null,\"lineageMode\":\"new\",\"generation\":1,\"continuedFromRun\":null,\"maxIterations\":{max_iterations},\"convergenceThreshold\":{convergence_threshold},\"createdAt\":\"{ISO_8601_NOW}\",\"specFolder\":\"{spec_folder}\"}'\n        output: \"{state_paths.state_log}\"\n\n      step_create_findings_registry:\n        action: \"Initialize reducer-owned review findings registry\"\n        content: '{\"sessionId\":\"{ISO_8601_NOW}\",\"generation\":1,\"lineageMode\":\"new\",\"openFindings\":[],\"resolvedFindings\":[],\"repeatedFindings\":[],\"dimensionCoverage\":{\"correctness\":false,\"security\":false,\"traceability\":false,\"maintainability\":false},\"findingsBySeverity\":{\"P0\":0,\"P1\":0,\"P2\":0},\"openFindingsCount\":0,\"resolvedFindingsCount\":0,\"convergenceScore\":0.0}'\n        output: \"{state_paths.findings_registry}\"\n\n      step_create_strategy:\n        action: \"Create review strategy file from deep_review_strategy.md template\"\n        template: .opencode/skills/deep-loop-workflows/deep-review/assets/deep_review_strategy.md\n        populate:\n          review_target: \"{review_target}\"\n          review_target_type: \"{review_target_type}\"\n          dimensions: \"{dimension_queue}\"\n          scope_files: \"{review_scope_files}\"\n          cross_reference_targets: \"{cross_reference_targets}\"\n          max_iterations: \"{max_iterations}\"\n          convergence_threshold: \"{convergence_threshold}\"\n        output: \"{state_paths.strategy}\"\n\n      step_enrich_strategy_context:\n        action: \"Ensure Known Context is written only after strategy.md exists\"\n        condition: \"prior_context_found\"\n        edit: \"{state_paths.strategy}\"\n        note: \"Append or replace the Known Context section with prior_context_summary and retained detail from prior_context\"\n\n      step_enrich_strategy_resource_map:\n        action: \"Inject resource-map status into Known Context after strategy.md exists\"\n        edit: \"{state_paths.strategy}\"\n        note: \"When resource_map_present is true, append the resource_map_known_context snapshot and add Resource Map Coverage to the Review Charter. When false, append 'resource-map.md not present; skipping coverage gate'.\"\n\n      step_init_complete:\n        log: \"Initialization complete. Config, state, and strategy files created. Review scope: {review_scope_files_count} files, {dimension_queue_count} dimensions.\"\n        set: { current_iteration: 1, stuck_count: 0, p0_count: 0, p1_count: 0, p2_count: 0 }\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 2: ITERATION LOOP\n  # ═══════════════════════════════════════════════════════════════\n  phase_loop:\n    purpose: Dispatch review agent iterations until convergence\n    repeat: true\n    max_repeats: \"{max_iterations}\"\n    steps:\n\n      step_read_state:\n        action: \"Read current state from JSONL, strategy, and config\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n          - \"{state_paths.config}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - current_iteration: \"iteration_count + 1\"\n          - last_newFindingsRatio: \"Extract newFindingsRatio from last iteration record\"\n          - last_focus: \"Extract focus/dimension from latest iteration record, else 'none yet'\"\n          - ratio_prev: \"Extract newFindingsRatio from second-latest iteration record, else 'N/A'\"\n          - ratio_latest: \"Extract newFindingsRatio from latest iteration record, else 'N/A'\"\n          - next_dimension: \"Next uncovered dimension from dimension_queue in strategy.md\"\n          - dimensions_covered: \"List of dimensions already reviewed\"\n          - dimensions_remaining: \"List of dimensions not yet reviewed\"\n          - dimension_coverage: \"covered / total dimensions\"\n          - coverage_age: \"Iterations since dimension coverage last changed; require >= 1 before STOP\"\n          - p0_count: \"Count P0 findings across all iterations\"\n          - p1_count: \"Count P1 findings across all iterations\"\n          - p2_count: \"Count P2 findings across all iterations\"\n          - resource_map_present: \"Extract boolean from deep-review-config.json, default false\"\n          - resource_map_prompt_line: \"If resource_map_present is true, return 'Resource Map Coverage: cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md and classify only missed coverage as gaps.' Else return 'Resource Map Coverage: resource-map.md not present; skipping coverage gate.'\"\n          - session_id: \"Extract sessionId from deep-review-config.json\"\n          - generation: \"Extract generation from deep-review-config.json, else 1\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records as 'run N: dimension (ratio, P0/P1/P2)'\"\n          - latest_status: \"Extract status from latest iteration record, else 'none yet'\"\n          - last_claim_adjudication_passed: \"Scan state.jsonl for the most recent `claim_adjudication` event; use its `passed` boolean. Default true when no event exists or when activeP0 + activeP1 == 0 (gate is vacuous without adjudicable findings).\"\n          - claim_adjudication_active_count: \"Count of active P0/P1 findings at the time of the last claim_adjudication event; 0 when none exist\"\n          - security_sensitive_fix_scope: \"Boolean true when the current review is a rerun after fixes involving security, path disclosure, auth/authz, sandboxing, env precedence, public schemas, persistence, or user-visible error payloads; derive from the latest review report, remediation notes, or planning packet when present, else false.\"\n          - fix_completeness_replay_required_rows: \"Count prior active or remediated P0/P1 findings, plus any prior security/path P2 findings, that require closed-gate replay before STOP.\"\n          - fix_completeness_replay_passing_rows: \"Count required replay rows marked PASS with file:line or command evidence and producer/consumer/matrix coverage.\"\n\n      step_check_pause_sentinel:\n        action: \"Check for pause sentinel file\"\n        check: \"Does {state_paths.pause_sentinel} exist?\"\n        if_exists:\n          set:\n            pending_stop_event: \"paused\"\n            pending_stop_reason: \"userPaused\"\n            pending_stop_detail: \"sentinel file detected\"\n          skip_to: step_normalize_pause_events\n        if_not_exists:\n          proceed: true\n\n      step_graph_convergence:\n        action: \"Evaluate coverage-graph convergence before the inline review convergence vote\"\n        inspect:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n        transform: |\n          1. Call graph convergence on the current review lineage before the inline 3-signal vote.\n          2. Record the decision as one of CONTINUE, STOP_ALLOWED, STOP_BLOCKED.\n          3. Preserve raw graph signals and blockers for reducer rollup and blocked-stop evidence.\n          4. Normalize blockers to both JSON array and CSV forms for downstream stop handling.\n          5. Set graph_stop_blocked = true only when graph_decision == \"STOP_BLOCKED\".\n        bash: 'node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"review\" --session-id \"{session_id}\"'\n        note: \"Invoke the runtime script directly. Review-side graph convergence must run before the inline review stop vote.\"\n        append_jsonl: '{\"type\":\"event\",\"event\":\"graph_convergence\",\"mode\":\"review\",\"run\":{current_iteration},\"decision\":\"{graph_decision}\",\"signals\":{graph_signals_json},\"blockers\":{graph_blockers_json},\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n        outputs:\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED\"\n          - graph_signals_json: \"JSON object returned by convergence.cjs\"\n          - graph_blockers_json: \"JSON array of graph blockers when present, else []\"\n          - graph_blockers_csv: \"Comma-separated blocker summary when graph blocks STOP, else empty string\"\n          - graph_stop_blocked: \"Boolean true when graph_decision == STOP_BLOCKED\"\n\n      step_check_convergence:\n        action: \"Evaluate graph-assisted review stop conditions and the legal-stop decision tree\"\n        algorithm: |\n          0. CLAIM-ADJUDICATION PRE-CHECK (universal STOP veto; runs before hard stops and composite convergence):\n             claim_adjudication_gate_pass = (last_claim_adjudication_passed != false) OR (p0_count + p1_count == 0)\n             If claim_adjudication_gate_pass == false:\n               candidate_decision = \"BLOCKED\"\n               stop_blocked = true\n               stopReason = \"blockedStop\"\n               blocked_gates = [\"claimAdjudicationGate\"]\n               recovery_strategy = \"Reviewer must add typed claim-adjudication packets (claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger) for every active P0/P1 finding before STOP is allowed.\"\n               Skip hard stops (1) and composite convergence (4); proceed directly to step 5 legal-stop decision-tree assembly so blocked_by_json, gate outputs, and the blocked_stop event still populate consistently.\n          1. HARD STOPS:\n             a) if iteration_count >= max_iterations: set decision = \"STOP\", stopReason = \"maxIterationsReached\", hard_stop_reason = \"max_iterations_reached\", preserve any failed legal-stop gates as terminal evidence, and proceed to synthesis without legal-stop veto\n             b) if all dimensions clean AND required traceability protocols are covered AND p0_count == 0 AND p1_count == 0 AND coverage_age >= 1 AND all quality gates pass (evidence: every P0/P1 has file:line; scope: all findings within target; coverage: all dimensions reviewed): mark hard_stop_reason = \"all_dimensions_clean\" and promote to STOP candidate\n             Operator stop reasons (`maxIterationsReached`, `manualStop`, `userPaused`, unrecoverable `error`) are terminal ceilings. They do not hide failed gates; they record them in synthesis and stop dispatch.\n          2. STUCK DETECTION (threshold 2):\n             if stuck_count >= 2: STUCK_RECOVERY\n          3. GRAPH CONVERGENCE PREREQUISITE:\n               graph_decision, graph_signals_json, and graph_blockers_json are already populated by step_graph_convergence.\n               Final STOP is never legal unless the inline review vote says STOP AND graph_decision == \"STOP_ALLOWED\".\n               If graph_decision == \"STOP_BLOCKED\", set stop_blocked = true and route through blocked_stop emission instead of stopping.\n          4. COMPOSITE CONVERGENCE (3-signal weighted vote with split thresholds):\n               signals = []\n               a) Rolling average (w=0.30, window=2, needs 2+ iterations):\n                  avg = mean(last 2 newFindingsRatios)\n                  stop if avg <= 0.08\n               b) MAD noise floor (w=0.25, needs 3+ iterations):\n                  noiseFloor = MAD(all ratios) * 1.4826\n                  stop if latest ratio <= noiseFloor\n               c) Dimension coverage (w=0.45):\n                  coverage = dimensions_covered / total_dimensions\n                  stop if coverage >= 1.0 AND required traceability protocols are covered AND coverage_age >= 1\n               Redistribute weights for unavailable signals.\n               if latest ratio <= 0.05: mark no_progress_threshold_reached\n               if weighted_stop_score >= 0.60: inline STOP becomes a candidate and binary gates must run\n          5. LEGAL-STOP DECISION TREE (review-specific gates; runs whenever step 0, all-dimensions-clean, or the composite vote promotes STOP to a candidate; terminal max-iteration/manual/error stops bypass veto and record failed gates as evidence):\n               a) convergenceGate: pass when a hard-stop condition is met OR weighted_stop_score >= 0.60; record score\n               b) dimensionCoverageGate: pass when configured dimensions and required traceability coverage are complete and coverage_age >= 1; record covered and missing dimensions\n               c) p0ResolutionGate: pass when activeP0 == 0; record activeP0\n               d) evidenceDensityGate: pass when every active P0/P1 has concrete file:line evidence and no active P0/P1 relies only on inference; record avgEvidencePerFinding\n               e) hotspotSaturationGate: pass when review hotspots have been revisited enough times to satisfy the saturation heuristic\n               f) claimAdjudicationGate: pass when claim_adjudication_gate_pass == true (i.e. last_claim_adjudication_passed != false OR there are no active P0/P1 findings to adjudicate); record last_claim_adjudication_passed and claim_adjudication_active_count\n               g) fixCompletenessReplayGate: pass when security_sensitive_fix_scope == false OR every required closed-gate replay row passes with file:line or command evidence and producer/consumer/matrix coverage; record security_sensitive_fix_scope, fix_completeness_replay_required_rows, and fix_completeness_replay_passing_rows\n               h) candidateCoverageGate: skip entirely when `reviewDepthSchemaVersion` is not 2 on the latest iteration. Otherwise pass when the current iteration's `reviewDepthApplicability.scopeClass` is `trivial` with `enforcement: \"skip\"` AND `reviewDepthApplicability.evidenceRefs` is non-empty, OR when the reducer registry's `searchDebt` is empty AND `candidateCoverage.covered` is a superset of `searchCoverage.requiredBugClasses` for the lineage. Otherwise pass = false; record `searchDebt` items as blocked-stop evidence; blocker name = \"candidateCoverageGate\"; recovery_strategy = \"Resolve deferred/blocked obligations in next iteration or downgrade scope explicitly to trivial with cited evidence.\"\n               i) graphlessFallbackGate: skip when `reviewDepthSchemaVersion` is not 2 OR the reducer registry's last-iteration `searchCoverage.graphCoverageMode` is `graph`. Applies when graphCoverageMode is `graphless_fallback` or `unavailable_blocked`. Pass when graphCoverageMode is `graphless_fallback` AND at least one `searchLedger` row exists for each entry in `searchCoverage.requiredBugClasses` with `searchActions[].method` in {\"direct_read\",\"exact_grep\",\"semantic_search\",\"code_graph_status_check\",\"producer_consumer_trace\",\"negative_test_inspection\"} AND non-empty `evidenceRefs`. Fail automatically when graphCoverageMode is `unavailable_blocked`; record the explicit unavailability reason. Otherwise pass = false; blocker name = \"graphlessFallbackGate\"; recovery_strategy = \"Add cited fallback ledger rows (direct read, exact search, producer/consumer trace, negative-test inspection) or set graphCoverageMode to 'graph' once graph data is available.\"\n             if STOP is a candidate and any gate fails:\n               decision = \"BLOCKED\"\n               stop_blocked = true\n               stopReason = \"blockedStop\"\n               blocked_by_json = JSON array of failing gate names (always include \"claimAdjudicationGate\" when claim_adjudication_gate_pass == false, \"fixCompletenessReplayGate\" when fix_completeness_replay_gate_pass == false, \"candidateCoverageGate\" when candidate_coverage_gate_pass == false, and \"graphlessFallbackGate\" when graphless_fallback_gate_pass == false)\n               blocked_by_csv = comma-separated list of failing gate names\n               convergence_gate_pass = boolean\n               convergence_gate_score = numeric convergence score\n               dimension_coverage_gate_pass = boolean\n               dimension_coverage_gate_covered_json = JSON array of covered review dimensions\n               dimension_coverage_gate_missing_json = JSON array of missing review dimensions\n               p0_resolution_gate_pass = boolean\n               active_p0_count = number of active P0 findings\n               evidence_density_gate_pass = boolean\n               avg_evidence_per_finding = numeric evidence density\n               hotspot_saturation_gate_pass = boolean\n               claim_adjudication_gate_pass = boolean\n               claim_adjudication_active_count = numeric count of active P0/P1 at the gate\n               fix_completeness_replay_gate_pass = boolean\n               security_sensitive_fix_scope = boolean\n               fix_completeness_replay_required_rows = numeric count of closed-gate replay rows required for security-sensitive fix reruns\n               fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n               candidate_coverage_gate_pass = boolean\n               candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n               candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n               graphless_fallback_gate_pass = boolean\n               graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n               graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n               graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n               recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n          6. COMBINED STOP RULE:\n               a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n               b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n                    decision = \"BLOCKED\"\n                    stop_blocked = true\n                    stopReason = \"blockedStop\"\n                    # Blocked-stop closure: blockedBy must be string[] per the\n                    # published review blocked-stop contract. Extract the `.type`\n                    # field from each structured graph blocker; preserve the full\n                    # objects in graph_blocker_detail_json for operator inspection.\n                    blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n                    blocked_by_csv = graph_blockers_csv\n                    graph_blocker_detail_json = graph_blockers_json\n                    recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n               c) if STOP is legal AND graph_decision == \"CONTINUE\":\n                    decision = \"CONTINUE\"\n                    stop_blocked = false\n                    reason = \"graph_convergence_continue\"\n               d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n        outputs:\n          - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n          - reason: \"Human-readable stop reason\"\n          - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n          - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n          - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n          - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n          - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n          - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n          - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n          - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n          - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n          - active_p0_count: \"Active P0 finding count at stop-check time\"\n          - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n          - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n          - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n          - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n          - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n          - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n          - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n          - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n          - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n          - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n          - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n          - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n          - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n          - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n          - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n          - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n          - graph_signals_json: \"JSON object returned by graph convergence\"\n          - graph_blockers_json: \"JSON array of graph blockers\"\n          - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n          - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n\n      step_emit_blocked_stop:","lineStart":1,"lineEnd":634,"totalLines":635,"truncated":true}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1781763040380,"end":1781763040383}},"metadata":{"openai":{"itemId":"fc_0c5728e2594de0e4016a338be0218081919a6c561c0a70aeea"}},"id":"prt_ed95a64740016rhxWv5Qzd7HTd","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95a18fe001rHpM3r0FG5EE16"}}
{"type":"tool_use","timestamp":1781763040396,"sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","part":{"type":"tool","tool":"read","callID":"call_i8At8Q6PXHQfvMoYoBdpFzbe","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml</path>\n<type>file</type>\n<content>\n1: # Canonical review-mode contract for deep-review.\n2: # This file is the single source of truth for review-mode taxonomy,\n3: # convergence settings, cross-reference protocols, downstream render targets,\n4: # and validation expectations.\n5: \n6: meta:\n7:   ownerSkill: deep-review\n8:   reviewModeVersion: 2\n9:   generatedNotice:\n10:     warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n11:     beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n12:     endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n13:   sourceOfTruth: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml\n14: \n15: # Core contract definitions consumed by workflows, agents, docs, and validators.\n16: contract:\n17:   defaultTargetType: spec-folder\n18: \n19:   # Review target taxonomy.\n20:   targetTypes:\n21:     - id: spec-folder\n22:       cliValue: spec-folder\n23:       label: Spec Folder\n24:       description: Review a single spec folder and its referenced implementation, tests, and release artifacts.\n25:     - id: skill\n26:       cliValue: skill\n27:       label: Skill\n28:       description: Review a skill package including SKILL.md, references, assets, scripts, and runtime integrations.\n29:     - id: agent\n30:       cliValue: agent\n31:       label: Agent\n32:       description: Review a named agent across runtime-specific definitions and capability parity surfaces.\n33:     - id: track\n34:       cliValue: track\n35:       label: Track\n36:       description: Review a spec track spanning multiple child spec folders and shared coordination artifacts.\n37:     - id: files\n38:       cliValue: files\n39:       label: Files\n40:       description: Review an explicit file set plus immediate cross-references required to evaluate shipped behavior.\n41: \n42:   # Simplified review dimensions. Traceability and maintainability absorb the\n43:   # prior seven-dimension model's overlap.\n44:   dimensions:\n45:     - id: correctness\n46:       priority: 1\n47:       label: Correctness\n48:       checks: Validate logic, invariants, state transitions, edge cases, and behavior against observable intent.\n49:       requiredForSeverityCoverage: true\n50:     - id: security\n51:       priority: 2\n52:       label: Security\n53:       checks: Validate trust boundaries, authz/authn behavior, input handling, secrets exposure, and exploit paths.\n54:       requiredForSeverityCoverage: true\n55:     - id: traceability\n56:       priority: 3\n57:       label: Traceability\n58:       checks: Validate spec alignment, completeness, checklist evidence, and cross-reference integrity across linked artifacts.\n59:       requiredForSeverityCoverage: false\n60:     - id: maintainability\n61:       priority: 4\n62:       label: Maintainability\n63:       checks: Validate codebase patterns, documentation quality, clarity, and ease of safe follow-on changes.\n64:       requiredForSeverityCoverage: false\n65: \n66:   # Severity contract stays stable across review outputs.\n67:   severities:\n68:     - id: P0\n69:       weight: 10.0\n70:       label: Blocker\n71:       requiresFileLineEvidence: true\n72:     - id: P1\n73:       weight: 5.0\n74:       label: Required\n75:       requiresFileLineEvidence: true\n76:     - id: P2\n77:       weight: 1.0\n78:       label: Suggestion\n79:       requiresFileLineEvidence: true\n80: \n81:   # Verdicts collapse PASS WITH NOTES into PASS + hasAdvisories metadata.\n82:   verdicts:\n83:     - id: FAIL\n84:       label: Fail\n85:       condition: \"activeP0 > 0 OR any required quality gate fails\"\n86:       nextCommand: /speckit:plan\n87:     - id: CONDITIONAL\n88:       label: Conditional\n89:       condition: \"activeP0 == 0 AND activeP1 > 0\"\n90:       nextCommand: /speckit:plan\n91:     - id: PASS\n92:       label: Pass\n93:       condition: \"activeP0 == 0 AND activeP1 == 0\"\n94:       hasAdvisoriesMetadata: \"Set hasAdvisories=true when activeP2 > 0.\"\n95:       nextCommand: /create:changelog\n96: \n97:   # Binary gates applied after convergence math votes STOP.\n98:   qualityGates:\n99:     - id: evidence\n100:       label: Evidence\n101:       binary: true\n102:       combines:\n103:         - evidence-completeness\n104:         - no-inference-only\n105:       rule: Every active finding must be backed by concrete file:line evidence and may not rely only on inference.\n106:     - id: scope\n107:       label: Scope\n108:       binary: true\n109:       combines:\n110:         - scope-alignment\n111:       rule: Reviewed files, targets, and conclusions must stay inside the declared review scope.\n112:     - id: coverage\n113:       label: Coverage\n114:       binary: true\n115:       combines:\n116:         - severity-coverage\n117:         - cross-reference\n118:       rule: Required dimensions and required traceability protocols must be covered before STOP is allowed.\n119: \n120:   # Review-specific convergence settings calibrated from the v2 research.\n121:   convergence:\n122:     defaults:\n123:       maxIterations: 7\n124:       convergenceThreshold: 0.10\n125:       stuckThreshold: 2\n126:     signals:\n127:       - id: rolling-average\n128:         weight: 0.30\n129:         description: Rolling average of severity-weighted new findings across recent evidence-bearing iterations.\n130:       - id: mad-noise-floor\n131:         weight: 0.25\n132:         description: Robust noise-floor test comparing the latest severity-weighted ratio against MAD-derived churn.\n133:       - id: dimension-coverage\n134:         weight: 0.45\n135:         description: Coverage vote based on required dimension completion plus required protocol coverage stability.\n136:     severityMath:\n137:       refinementMultiplier: 0.5\n138:       p0OverrideMinRatio: 0.50\n139:       noFindingsRatio: 0.0\n140:     coverageAge:\n141:       minStabilizationPasses: 1\n142:     thresholds:\n143:       rollingStopThreshold: 0.08\n144:       noProgressThreshold: 0.05\n145:       compositeStopScore: 0.60\n146: \n147:   lifecycleModes:\n148:     - id: new\n149:       description: Create a brand-new review lineage with generation 1 and no parent session.\n150:     - id: resume\n151:       description: Continue the current review lineage without changing generation.\n152:     - id: restart\n153:       description: Start a new generation for the same target and archive the prior review packet state.\n154:     - id: fork\n155:       status: deferred\n156:       description: Reserved compatibility branch. The current runtime does not emit or accept fork review lineages.\n157:     - id: completed-continue\n158:       status: deferred\n159:       description: Reserved compatibility branch. The current runtime does not reopen completed sessions under a completed-continue lineage.\n160: \n161:   lineageFields:\n162:     - sessionId\n163:     - parentSessionId\n164:     - lineageMode\n165:     - generation\n166:     - continuedFromRun\n167: \n168:   reducer:\n169:     enabled: true\n170:     inputs:\n171:       - latestJSONLDelta\n172:       - newIterationFile\n173:       - priorReducedState\n174:     outputs:\n175:       - findingsRegistry\n176:       - dashboardMetrics\n177:       - strategyUpdates\n178:     failureModes:\n179:       malformedDelta: skip-and-warn\n180:       missingIterationFile: no-op-with-error\n181:       schemaMismatch: reject-with-conflict-event\n182:     idempotent: true\n183: \n184:   releaseReadinessStates:\n185:     - id: in-progress\n186:       description: Review is ongoing or coverage is incomplete.\n187:     - id: converged\n188:       description: All dimensions are covered and no new P0/P1 findings appeared in the latest stabilization pass.\n189:     - id: release-blocking\n190:       description: At least one unresolved P0 finding is present.\n191: \n192:   # Cross-reference protocols are typed traceability checks. Core protocols are\n193:   # hard gates; overlay protocols apply only to matching target types.\n194:   crossReferenceProtocols:\n195:     - id: spec_code\n196:       dimension: traceability\n197:       level: core\n198:       appliesTo: [spec-folder, skill, agent, track, files]\n199:       gateClass: hard\n200:       passCriteria: All normative claims resolve to shipped behavior or explicitly documented non-applicability with evidence.\n201:       partialCriteria: Some claims resolve, but one or more claims remain ambiguous or blocked by missing evidence.\n202:       failCriteria: A normative claim contradicts shipped behavior, references missing implementation, or cannot be reconciled.\n203:     - id: checklist_evidence\n204:       dimension: traceability\n205:       level: core\n206:       appliesTo: [spec-folder, skill, agent, track, files]\n207:       gateClass: hard\n208:       passCriteria: Every checked checklist-style claim has supporting evidence and no unsupported completion marks remain.\n209:       partialCriteria: Evidence exists for part of the checked set, but some checked items remain unproven or weakly linked.\n210:       failCriteria: Checked items are unsupported, contradicted by evidence, or materially overstate completion.\n211:     - id: skill_agent\n212:       dimension: traceability\n213:       level: overlay\n214:       appliesTo: [skill]\n215:       gateClass: advisory\n216:       passCriteria: SKILL.md contracts, routing guidance, and referenced runtime agents agree on capabilities and boundaries.\n217:       partialCriteria: Shared intent is consistent, but one or more runtime contracts drift in wording, tools, or expectations.\n218:       failCriteria: SKILL.md and runtime agents materially disagree on capability, routing, permissions, or operating contract.\n219:     - id: agent_cross_runtime\n220:       dimension: traceability\n221:       level: overlay\n222:       appliesTo: [agent]\n223:       gateClass: advisory\n224:       passCriteria: Runtime-specific agent definitions express equivalent behavior, constraints, and evidence requirements.\n225:       partialCriteria: Runtime definitions are broadly aligned but contain non-blocking drift in examples, labels, or metadata.\n226:       failCriteria: Runtime definitions materially diverge in contract, permissions, workflow, or severity/evidence rules.\n227:     - id: feature_catalog_code\n228:       dimension: traceability\n229:       level: overlay\n230:       appliesTo: [skill, spec-folder, track, files]\n231:       gateClass: advisory\n232:       passCriteria: Feature catalog claims match current capability, entry points, and discoverable implementation surfaces.\n233:       partialCriteria: Catalog coverage is incomplete or stale, but no confirmed contradiction to shipped behavior is present.\n234:       failCriteria: Catalog claims are materially false, missing required features, or point to absent implementation.\n235:     - id: playbook_capability\n236:       dimension: traceability\n237:       level: overlay\n238:       appliesTo: [skill, agent, spec-folder]\n239:       gateClass: advisory\n240:       passCriteria: Playbook scenario preconditions, steps, and expected signals are executable against current capability.\n241:       partialCriteria: Scenarios mostly match reality, but one or more steps need updates, clarifications, or narrower scoping.\n242:       failCriteria: Playbook scenarios assume capabilities that do not exist or cannot be executed as documented.\n243: \n244:   # Output contracts consumed by synthesis and replay tooling.\n245:   outputs:\n246:     config:\n247:       pathPattern: \"{artifact_dir}/deep-review-config.json\"\n248:       machineOwned: false\n249:       fields:\n250:         - sessionId\n251:         - parentSessionId\n252:         - lineageMode\n253:         - generation\n254:         - continuedFromRun\n255:         - releaseReadinessState\n256:     findingsRegistry:\n257:       pathPattern: \"{artifact_dir}/deep-review-findings-registry.json\"\n258:       machineOwned: true\n259:       sections:\n260:         - openFindings\n261:         - resolvedFindings\n262:         - repeatedFindings\n263:         - dimensionCoverage\n264:         - findingsBySeverity\n265:         - convergenceScore\n266:     reviewReport:\n267:       pathPattern: \"{artifact_dir}/review-report.md\"\n268:       sections:\n269:         - executive-summary\n270:         - planning-trigger\n271:         - active-finding-registry\n272:         - remediation-workstreams\n273:         - spec-seed\n274:         - plan-seed\n275:         - traceability-status\n276:         - deferred-items\n277:         - audit-appendix\n278:     strategy:\n279:       pathPattern: \"{artifact_dir}/deep-review-strategy.md\"\n280:       requiredSections:\n281:         - topic\n282:         - review-dimensions\n283:         - completed-dimensions\n284:         - running-findings\n285:         - what-worked\n286:         - what-failed\n287:         - exhausted-approaches\n288:         - ruled-out-directions\n289:         - next-focus\n290:         - known-context\n291:         - cross-reference-status\n292:         - files-under-review\n293:         - review-boundaries\n294:     dashboard:\n295:       pathPattern: \"{artifact_dir}/deep-review-dashboard.md\"\n296:       machineOwned: true\n297:       sections:\n298:         - status\n299:         - findings-summary\n300:         - dimension-coverage\n301:         - progress\n302:         - next-focus\n303:     pauseSentinel:\n304:       pathPattern: \"{artifact_dir}/.deep-review-pause\"\n305:       machineOwned: false\n306:       description: Operator-controlled sentinel checked between iterations to pause the loop without discarding state.\n307:     jsonl:\n308:       pathPattern: \"{artifact_dir}/deep-review-state.jsonl\"\n309:       iterationRecord:\n310:         required:\n311:           - type\n312:           - mode\n313:           - run\n314:           - status\n315:           - focus\n316:           - dimensions\n317:           - filesReviewed\n318:           - findingsCount\n319:           - findingsSummary\n320:           - findingsNew\n321:           - findingDetails\n322:           - newFindingsRatio\n323:           - sessionId\n324:           - generation\n325:           - lineageMode\n326:           - timestamp\n327:           - durationMs\n328:         optional:\n329:           - parentSessionId\n330:           - continuedFromRun\n331:           - findingsRefined\n332:           - findingRefs\n333:           - traceabilityChecks\n334:           - coverage\n335:           - noveltyJustification\n336:           - ruledOut\n337:           - focusTrack\n338:           - scoreEstimate\n339:           - segment\n340:           - convergenceSignals\n341:           - graphEvents\n342:       synthesisEvent:\n343:         required:\n344:           - type\n345:           - event\n346:           - mode\n347:           - totalIterations\n348:           - verdict\n349:           - activeP0\n350:           - activeP1\n351:           - activeP2\n352:           - dimensionCoverage\n353:           - stopReason\n354:           - timestamp\n355: \n356: # Render targets define where generated or mixed-authored contract fragments land.\n357: render:\n358:   artifacts:\n359:     - id: workflow-auto\n360:       path: .opencode/commands/deep/assets/deep_review_auto.yaml\n361:       ownership: mixed\n362:       format: yaml\n363:       markers:\n364:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-auto -->\"\n365:         end: \"<!-- END GENERATED: review-mode-contract/workflow-auto -->\"\n366:       sections:\n367:         - target-types\n368:         - dimensions\n369:         - verdicts\n370:         - quality-gates\n371:         - convergence\n372:         - cross-reference-protocols\n373:     - id: workflow-confirm\n374:       path: .opencode/commands/deep/assets/deep_review_confirm.yaml\n375:       ownership: mixed\n376:       format: yaml\n377:       markers:\n378:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-confirm -->\"\n379:         end: \"<!-- END GENERATED: review-mode-contract/workflow-confirm -->\"\n380:       sections:\n381:         - target-types\n382:         - dimensions\n383:         - verdicts\n384:         - quality-gates\n385:         - convergence\n386:         - cross-reference-protocols\n387:     - id: agent-opencode\n388:       path: .opencode/agents/deep-review.md\n389:       ownership: mixed\n390:       format: markdown\n391:       markers:\n392:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-opencode -->\"\n393:         end: \"<!-- END GENERATED: review-mode-contract/agent-opencode -->\"\n394:       sections:\n395:         - dimensions\n396:         - severities\n397:         - quality-gates\n398:         - cross-reference-protocols\n399:         - outputs\n400:     - id: agent-claude\n401:       path: .claude/agents/deep-review.md\n402:       ownership: mixed\n403:       format: markdown\n404:       markers:\n405:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-claude -->\"\n406:         end: \"<!-- END GENERATED: review-mode-contract/agent-claude -->\"\n407:       sections:\n408:         - dimensions\n409:         - severities\n410:         - quality-gates\n411:         - cross-reference-protocols\n412:         - outputs\n413:     - id: agent-codex\n414:       path: .codex/agents/deep-review.toml\n415:       ownership: mixed\n416:       format: toml\n417:       markers:\n418:         begin: \"# BEGIN GENERATED: review-mode-contract/agent-codex\"\n419:         end: \"# END GENERATED: review-mode-contract/agent-codex\"\n420:       sections:\n421:         - dimensions\n422:         - severities\n423:         - quality-gates\n424:         - cross-reference-protocols\n425:         - outputs\n426:     - id: quick-reference-review-mode\n427:       path: .opencode/skills/deep-loop-workflows/deep-review/references/protocol/quick_reference.md\n428:       ownership: mixed\n429:       format: markdown\n430:       markers:\n431:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n432:         end: \"<!-- END GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n433:       sections:\n434:         - target-types\n435:         - dimensions\n436:         - verdicts\n437:         - quality-gates\n438:         - outputs\n439:     - id: review-contract-snapshot\n440:       path: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract_snapshot.md\n441:       ownership: generated\n442:       format: markdown\n443:       markers:\n444:         begin: \"<!-- BEGIN GENERATED: review-mode-contract/snapshot -->\"\n445:         end: \"<!-- END GENERATED: review-mode-contract/snapshot -->\"\n446:       sections:\n447:         - meta\n448:         - target-types\n449:         - dimensions\n450:         - severities\n451:         - verdicts\n452:         - quality-gates\n453:         - convergence\n454:         - cross-reference-protocols\n455:         - outputs\n456:         - validation\n457: \n458: # Validator contract for CI, render verification, and drift detection.\n459: validation:\n460:   schemaVersion: 1\n461:   checks:\n462:     - id: schema\n463:       description: Validate this manifest against the canonical review-mode contract schema.\n464:     - id: render-verify\n465:       description: Re-render downstream artifacts in verify mode and fail on drift.\n466:     - id: marker-integrity\n467:       description: Ensure every render target contains intact begin/end markers with no overlapping generated blocks.\n468:     - id: enum-parity\n469:       description: Ensure target types, dimensions, severities, verdicts, and quality gates match across rendered artifacts.\n470:     - id: jsonl-parity\n471:       description: Ensure JSONL iteration and synthesis-event fields match the outputs contract.\n472:     - id: lifecycle-parity\n473:       description: \"Ensure lifecycle mode docs and workflow branches agree on the three supported modes: new, resume, and restart.\"\n474:     - id: reducer-contract\n475:       description: Ensure reducer inputs, outputs, and findings-registry metrics are documented consistently across assets and runtime mirrors.\n476:     - id: duplicate-literal-lint\n477:       description: Detect duplicated hard-coded review taxonomy literals outside generated sections.\n478:     - id: runtime-coverage\n479:       description: Ensure every supported runtime deep-review agent has a declared render artifact and parity coverage.\n480:     - id: playbook-assertions\n481:       description: Assert manual testing playbook scenarios reference the canonical simplified contract where applicable.\n\n(End of file - total 481 lines)\n</content>","metadata":{"preview":"# Canonical review-mode contract for deep-review.\n# This file is the single source of truth for review-mode taxonomy,\n# convergence settings, cross-reference protocols, downstream render targets,\n# and validation expectations.\n\nmeta:\n  ownerSkill: deep-review\n  reviewModeVersion: 2\n  generatedNotice:\n    warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n    beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n    endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n  sourceOfTruth: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml\n\n# Core contract definitions consumed by workflows, agents, docs, and validators.\ncontract:\n  defaultTargetType: spec-folder\n\n  # Review target taxonomy.\n  targetTypes:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml","text":"# Canonical review-mode contract for deep-review.\n# This file is the single source of truth for review-mode taxonomy,\n# convergence settings, cross-reference protocols, downstream render targets,\n# and validation expectations.\n\nmeta:\n  ownerSkill: deep-review\n  reviewModeVersion: 2\n  generatedNotice:\n    warning: \"Generated from review_mode_contract.yaml. Do not manually edit generated sections.\"\n    beginMarker: \"<!-- BEGIN GENERATED: review-mode-contract -->\"\n    endMarker: \"<!-- END GENERATED: review-mode-contract -->\"\n  sourceOfTruth: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml\n\n# Core contract definitions consumed by workflows, agents, docs, and validators.\ncontract:\n  defaultTargetType: spec-folder\n\n  # Review target taxonomy.\n  targetTypes:\n    - id: spec-folder\n      cliValue: spec-folder\n      label: Spec Folder\n      description: Review a single spec folder and its referenced implementation, tests, and release artifacts.\n    - id: skill\n      cliValue: skill\n      label: Skill\n      description: Review a skill package including SKILL.md, references, assets, scripts, and runtime integrations.\n    - id: agent\n      cliValue: agent\n      label: Agent\n      description: Review a named agent across runtime-specific definitions and capability parity surfaces.\n    - id: track\n      cliValue: track\n      label: Track\n      description: Review a spec track spanning multiple child spec folders and shared coordination artifacts.\n    - id: files\n      cliValue: files\n      label: Files\n      description: Review an explicit file set plus immediate cross-references required to evaluate shipped behavior.\n\n  # Simplified review dimensions. Traceability and maintainability absorb the\n  # prior seven-dimension model's overlap.\n  dimensions:\n    - id: correctness\n      priority: 1\n      label: Correctness\n      checks: Validate logic, invariants, state transitions, edge cases, and behavior against observable intent.\n      requiredForSeverityCoverage: true\n    - id: security\n      priority: 2\n      label: Security\n      checks: Validate trust boundaries, authz/authn behavior, input handling, secrets exposure, and exploit paths.\n      requiredForSeverityCoverage: true\n    - id: traceability\n      priority: 3\n      label: Traceability\n      checks: Validate spec alignment, completeness, checklist evidence, and cross-reference integrity across linked artifacts.\n      requiredForSeverityCoverage: false\n    - id: maintainability\n      priority: 4\n      label: Maintainability\n      checks: Validate codebase patterns, documentation quality, clarity, and ease of safe follow-on changes.\n      requiredForSeverityCoverage: false\n\n  # Severity contract stays stable across review outputs.\n  severities:\n    - id: P0\n      weight: 10.0\n      label: Blocker\n      requiresFileLineEvidence: true\n    - id: P1\n      weight: 5.0\n      label: Required\n      requiresFileLineEvidence: true\n    - id: P2\n      weight: 1.0\n      label: Suggestion\n      requiresFileLineEvidence: true\n\n  # Verdicts collapse PASS WITH NOTES into PASS + hasAdvisories metadata.\n  verdicts:\n    - id: FAIL\n      label: Fail\n      condition: \"activeP0 > 0 OR any required quality gate fails\"\n      nextCommand: /speckit:plan\n    - id: CONDITIONAL\n      label: Conditional\n      condition: \"activeP0 == 0 AND activeP1 > 0\"\n      nextCommand: /speckit:plan\n    - id: PASS\n      label: Pass\n      condition: \"activeP0 == 0 AND activeP1 == 0\"\n      hasAdvisoriesMetadata: \"Set hasAdvisories=true when activeP2 > 0.\"\n      nextCommand: /create:changelog\n\n  # Binary gates applied after convergence math votes STOP.\n  qualityGates:\n    - id: evidence\n      label: Evidence\n      binary: true\n      combines:\n        - evidence-completeness\n        - no-inference-only\n      rule: Every active finding must be backed by concrete file:line evidence and may not rely only on inference.\n    - id: scope\n      label: Scope\n      binary: true\n      combines:\n        - scope-alignment\n      rule: Reviewed files, targets, and conclusions must stay inside the declared review scope.\n    - id: coverage\n      label: Coverage\n      binary: true\n      combines:\n        - severity-coverage\n        - cross-reference\n      rule: Required dimensions and required traceability protocols must be covered before STOP is allowed.\n\n  # Review-specific convergence settings calibrated from the v2 research.\n  convergence:\n    defaults:\n      maxIterations: 7\n      convergenceThreshold: 0.10\n      stuckThreshold: 2\n    signals:\n      - id: rolling-average\n        weight: 0.30\n        description: Rolling average of severity-weighted new findings across recent evidence-bearing iterations.\n      - id: mad-noise-floor\n        weight: 0.25\n        description: Robust noise-floor test comparing the latest severity-weighted ratio against MAD-derived churn.\n      - id: dimension-coverage\n        weight: 0.45\n        description: Coverage vote based on required dimension completion plus required protocol coverage stability.\n    severityMath:\n      refinementMultiplier: 0.5\n      p0OverrideMinRatio: 0.50\n      noFindingsRatio: 0.0\n    coverageAge:\n      minStabilizationPasses: 1\n    thresholds:\n      rollingStopThreshold: 0.08\n      noProgressThreshold: 0.05\n      compositeStopScore: 0.60\n\n  lifecycleModes:\n    - id: new\n      description: Create a brand-new review lineage with generation 1 and no parent session.\n    - id: resume\n      description: Continue the current review lineage without changing generation.\n    - id: restart\n      description: Start a new generation for the same target and archive the prior review packet state.\n    - id: fork\n      status: deferred\n      description: Reserved compatibility branch. The current runtime does not emit or accept fork review lineages.\n    - id: completed-continue\n      status: deferred\n      description: Reserved compatibility branch. The current runtime does not reopen completed sessions under a completed-continue lineage.\n\n  lineageFields:\n    - sessionId\n    - parentSessionId\n    - lineageMode\n    - generation\n    - continuedFromRun\n\n  reducer:\n    enabled: true\n    inputs:\n      - latestJSONLDelta\n      - newIterationFile\n      - priorReducedState\n    outputs:\n      - findingsRegistry\n      - dashboardMetrics\n      - strategyUpdates\n    failureModes:\n      malformedDelta: skip-and-warn\n      missingIterationFile: no-op-with-error\n      schemaMismatch: reject-with-conflict-event\n    idempotent: true\n\n  releaseReadinessStates:\n    - id: in-progress\n      description: Review is ongoing or coverage is incomplete.\n    - id: converged\n      description: All dimensions are covered and no new P0/P1 findings appeared in the latest stabilization pass.\n    - id: release-blocking\n      description: At least one unresolved P0 finding is present.\n\n  # Cross-reference protocols are typed traceability checks. Core protocols are\n  # hard gates; overlay protocols apply only to matching target types.\n  crossReferenceProtocols:\n    - id: spec_code\n      dimension: traceability\n      level: core\n      appliesTo: [spec-folder, skill, agent, track, files]\n      gateClass: hard\n      passCriteria: All normative claims resolve to shipped behavior or explicitly documented non-applicability with evidence.\n      partialCriteria: Some claims resolve, but one or more claims remain ambiguous or blocked by missing evidence.\n      failCriteria: A normative claim contradicts shipped behavior, references missing implementation, or cannot be reconciled.\n    - id: checklist_evidence\n      dimension: traceability\n      level: core\n      appliesTo: [spec-folder, skill, agent, track, files]\n      gateClass: hard\n      passCriteria: Every checked checklist-style claim has supporting evidence and no unsupported completion marks remain.\n      partialCriteria: Evidence exists for part of the checked set, but some checked items remain unproven or weakly linked.\n      failCriteria: Checked items are unsupported, contradicted by evidence, or materially overstate completion.\n    - id: skill_agent\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill]\n      gateClass: advisory\n      passCriteria: SKILL.md contracts, routing guidance, and referenced runtime agents agree on capabilities and boundaries.\n      partialCriteria: Shared intent is consistent, but one or more runtime contracts drift in wording, tools, or expectations.\n      failCriteria: SKILL.md and runtime agents materially disagree on capability, routing, permissions, or operating contract.\n    - id: agent_cross_runtime\n      dimension: traceability\n      level: overlay\n      appliesTo: [agent]\n      gateClass: advisory\n      passCriteria: Runtime-specific agent definitions express equivalent behavior, constraints, and evidence requirements.\n      partialCriteria: Runtime definitions are broadly aligned but contain non-blocking drift in examples, labels, or metadata.\n      failCriteria: Runtime definitions materially diverge in contract, permissions, workflow, or severity/evidence rules.\n    - id: feature_catalog_code\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill, spec-folder, track, files]\n      gateClass: advisory\n      passCriteria: Feature catalog claims match current capability, entry points, and discoverable implementation surfaces.\n      partialCriteria: Catalog coverage is incomplete or stale, but no confirmed contradiction to shipped behavior is present.\n      failCriteria: Catalog claims are materially false, missing required features, or point to absent implementation.\n    - id: playbook_capability\n      dimension: traceability\n      level: overlay\n      appliesTo: [skill, agent, spec-folder]\n      gateClass: advisory\n      passCriteria: Playbook scenario preconditions, steps, and expected signals are executable against current capability.\n      partialCriteria: Scenarios mostly match reality, but one or more steps need updates, clarifications, or narrower scoping.\n      failCriteria: Playbook scenarios assume capabilities that do not exist or cannot be executed as documented.\n\n  # Output contracts consumed by synthesis and replay tooling.\n  outputs:\n    config:\n      pathPattern: \"{artifact_dir}/deep-review-config.json\"\n      machineOwned: false\n      fields:\n        - sessionId\n        - parentSessionId\n        - lineageMode\n        - generation\n        - continuedFromRun\n        - releaseReadinessState\n    findingsRegistry:\n      pathPattern: \"{artifact_dir}/deep-review-findings-registry.json\"\n      machineOwned: true\n      sections:\n        - openFindings\n        - resolvedFindings\n        - repeatedFindings\n        - dimensionCoverage\n        - findingsBySeverity\n        - convergenceScore\n    reviewReport:\n      pathPattern: \"{artifact_dir}/review-report.md\"\n      sections:\n        - executive-summary\n        - planning-trigger\n        - active-finding-registry\n        - remediation-workstreams\n        - spec-seed\n        - plan-seed\n        - traceability-status\n        - deferred-items\n        - audit-appendix\n    strategy:\n      pathPattern: \"{artifact_dir}/deep-review-strategy.md\"\n      requiredSections:\n        - topic\n        - review-dimensions\n        - completed-dimensions\n        - running-findings\n        - what-worked\n        - what-failed\n        - exhausted-approaches\n        - ruled-out-directions\n        - next-focus\n        - known-context\n        - cross-reference-status\n        - files-under-review\n        - review-boundaries\n    dashboard:\n      pathPattern: \"{artifact_dir}/deep-review-dashboard.md\"\n      machineOwned: true\n      sections:\n        - status\n        - findings-summary\n        - dimension-coverage\n        - progress\n        - next-focus\n    pauseSentinel:\n      pathPattern: \"{artifact_dir}/.deep-review-pause\"\n      machineOwned: false\n      description: Operator-controlled sentinel checked between iterations to pause the loop without discarding state.\n    jsonl:\n      pathPattern: \"{artifact_dir}/deep-review-state.jsonl\"\n      iterationRecord:\n        required:\n          - type\n          - mode\n          - run\n          - status\n          - focus\n          - dimensions\n          - filesReviewed\n          - findingsCount\n          - findingsSummary\n          - findingsNew\n          - findingDetails\n          - newFindingsRatio\n          - sessionId\n          - generation\n          - lineageMode\n          - timestamp\n          - durationMs\n        optional:\n          - parentSessionId\n          - continuedFromRun\n          - findingsRefined\n          - findingRefs\n          - traceabilityChecks\n          - coverage\n          - noveltyJustification\n          - ruledOut\n          - focusTrack\n          - scoreEstimate\n          - segment\n          - convergenceSignals\n          - graphEvents\n      synthesisEvent:\n        required:\n          - type\n          - event\n          - mode\n          - totalIterations\n          - verdict\n          - activeP0\n          - activeP1\n          - activeP2\n          - dimensionCoverage\n          - stopReason\n          - timestamp\n\n# Render targets define where generated or mixed-authored contract fragments land.\nrender:\n  artifacts:\n    - id: workflow-auto\n      path: .opencode/commands/deep/assets/deep_review_auto.yaml\n      ownership: mixed\n      format: yaml\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-auto -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/workflow-auto -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n    - id: workflow-confirm\n      path: .opencode/commands/deep/assets/deep_review_confirm.yaml\n      ownership: mixed\n      format: yaml\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/workflow-confirm -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/workflow-confirm -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n    - id: agent-opencode\n      path: .opencode/agents/deep-review.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-opencode -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/agent-opencode -->\"\n      sections:\n        - dimensions\n        - severities\n        - quality-gates\n        - cross-reference-protocols\n        - outputs\n    - id: agent-claude\n      path: .claude/agents/deep-review.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/agent-claude -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/agent-claude -->\"\n      sections:\n        - dimensions\n        - severities\n        - quality-gates\n        - cross-reference-protocols\n        - outputs\n    - id: agent-codex\n      path: .codex/agents/deep-review.toml\n      ownership: mixed\n      format: toml\n      markers:\n        begin: \"# BEGIN GENERATED: review-mode-contract/agent-codex\"\n        end: \"# END GENERATED: review-mode-contract/agent-codex\"\n      sections:\n        - dimensions\n        - severities\n        - quality-gates\n        - cross-reference-protocols\n        - outputs\n    - id: quick-reference-review-mode\n      path: .opencode/skills/deep-loop-workflows/deep-review/references/protocol/quick_reference.md\n      ownership: mixed\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/quick-reference-review-mode -->\"\n      sections:\n        - target-types\n        - dimensions\n        - verdicts\n        - quality-gates\n        - outputs\n    - id: review-contract-snapshot\n      path: .opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract_snapshot.md\n      ownership: generated\n      format: markdown\n      markers:\n        begin: \"<!-- BEGIN GENERATED: review-mode-contract/snapshot -->\"\n        end: \"<!-- END GENERATED: review-mode-contract/snapshot -->\"\n      sections:\n        - meta\n        - target-types\n        - dimensions\n        - severities\n        - verdicts\n        - quality-gates\n        - convergence\n        - cross-reference-protocols\n        - outputs\n        - validation\n\n# Validator contract for CI, render verification, and drift detection.\nvalidation:\n  schemaVersion: 1\n  checks:\n    - id: schema\n      description: Validate this manifest against the canonical review-mode contract schema.\n    - id: render-verify\n      description: Re-render downstream artifacts in verify mode and fail on drift.\n    - id: marker-integrity\n      description: Ensure every render target contains intact begin/end markers with no overlapping generated blocks.\n    - id: enum-parity\n      description: Ensure target types, dimensions, severities, verdicts, and quality gates match across rendered artifacts.\n    - id: jsonl-parity\n      description: Ensure JSONL iteration and synthesis-event fields match the outputs contract.\n    - id: lifecycle-parity\n      description: \"Ensure lifecycle mode docs and workflow branches agree on the three supported modes: new, resume, and restart.\"\n    - id: reducer-contract\n      description: Ensure reducer inputs, outputs, and findings-registry metrics are documented consistently across assets and runtime mirrors.\n    - id: duplicate-literal-lint\n      description: Detect duplicated hard-coded review taxonomy literals outside generated sections.\n    - id: runtime-coverage\n      description: Ensure every supported runtime deep-review agent has a declared render artifact and parity coverage.\n    - id: playbook-assertions\n      description: Assert manual testing playbook scenarios reference the canonical simplified contract where applicable.","lineStart":1,"lineEnd":481,"totalLines":481,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/deep-review/assets/review_mode_contract.yaml","time":{"start":1781763040386,"end":1781763040394}},"metadata":{"openai":{"itemId":"fc_0c5728e2594de0e4016a338be0218881919c84e00d7974ea29"}},"id":"prt_ed95a647c001ZfS8Ui8vBuogF1","sessionID":"ses_126a6a1e9ffedEMNRMHv06v6Ez","messageID":"msg_ed95a18fe001rHpM3r0FG5EE16"}}
