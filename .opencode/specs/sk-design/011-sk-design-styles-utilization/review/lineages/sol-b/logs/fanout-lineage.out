{"type":"tool_use","timestamp":1784385657954,"sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","part":{"type":"tool","tool":"read","callID":"call_9riZP4mGSm4U27h4tDvYP5f1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","offset":635,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n635:                dimension_coverage_gate_missing_json = JSON array of missing review dimensions\n636:                p0_resolution_gate_pass = boolean\n637:                active_p0_count = number of active P0 findings\n638:                evidence_density_gate_pass = boolean\n639:                avg_evidence_per_finding = numeric evidence density\n640:                hotspot_saturation_gate_pass = boolean\n641:                claim_adjudication_gate_pass = boolean\n642:                claim_adjudication_active_count = numeric count of active P0/P1 at the gate\n643:                fix_completeness_replay_gate_pass = boolean\n644:                security_sensitive_fix_scope = boolean\n645:                fix_completeness_replay_required_rows = numeric count of closed-gate replay rows required for security-sensitive fix reruns\n646:                fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n647:                candidate_coverage_gate_pass = boolean\n648:                candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n649:                candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n650:                graphless_fallback_gate_pass = boolean\n651:                graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n652:                graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n653:                graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n654:                recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n655:           6. COMBINED STOP RULE:\n656:                a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n657:                b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n658:                     decision = \"BLOCKED\"\n659:                     stop_blocked = true\n660:                     stopReason = \"blockedStop\"\n661:                     # Blocked-stop closure: blockedBy must be string[] per the\n662:                     # published review blocked-stop contract. Extract the `.type`\n663:                     # field from each structured graph blocker; preserve the full\n664:                     # objects in graph_blocker_detail_json for operator inspection.\n665:                     blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n666:                     blocked_by_csv = graph_blockers_csv\n667:                     graph_blocker_detail_json = graph_blockers_json\n668:                     recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n669:                c) if STOP is legal AND graph_decision == \"CONTINUE\":\n670:                     decision = \"CONTINUE\"\n671:                     stop_blocked = false\n672:                     reason = \"graph_convergence_continue\"\n673:                d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n674:         outputs:\n675:           - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n676:           - reason: \"Human-readable stop reason\"\n677:           - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n678:           - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n679:           - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n680:           - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n681:           - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n682:           - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n683:           - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n684:           - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n685:           - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n686:           - active_p0_count: \"Active P0 finding count at stop-check time\"\n687:           - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n688:           - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n689:           - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n690:           - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n691:           - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n692:           - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n693:           - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n694:           - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n695:           - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n696:           - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n697:           - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n698:           - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n699:           - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n700:           - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n701:           - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n702:           - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n703:           - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n704:           - graph_signals_json: \"JSON object returned by graph convergence\"\n705:           - graph_blockers_json: \"JSON array of graph blockers\"\n706:           - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n707:           - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n708: \n709:       step_emit_blocked_stop:\n710:         action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n711:         if_blocked:\n712:           append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n713:           log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n714:         if_not_blocked:\n715:           proceed: true\n716: \n717:       step_handle_convergence:\n718:         action: \"Act on convergence decision\"\n719:         if_stop:\n720:           branch_on: \"convergence_mode == 'divergent' AND reason == 'all_dimensions_clean'\"\n721:           if_divergent_eligible:\n722:             eligibility_contract:\n723:               required_decision: \"STOP\"\n724:               eligible_reasons: [all_dimensions_clean]\n725:               excluded_reasons: [maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n726:               fail_closed: \"Any missing or ambiguous reason uses if_existing_terminal_path without preparing a pivot. The nine legal-stop gates have already run and remain unchanged.\"\n727:             steps:\n728:               step_prepare_divergent_pivot:\n729:                 action: \"Generate state-grounded read-only review candidates and prepare or resume the pivot transaction\"\n730:                 command: |\n731:                   node --experimental-strip-types --input-type=module <<'EOF'\n732:                   import {\n733:                     buildReviewPivotPreparationInput,\n734:                     renderReviewPivotSeatPrompt,\n735:                   } from './.opencode/skills/system-deep-loop/deep-review/scripts/divergent-review-pivot.ts';\n736:                   import {\n737:                     preparePivotTransaction,\n738:                   } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n739: \n740:                   const input = buildReviewPivotPreparationInput({\n741:                     artifactRoot: '{state_paths.packet_dir}',\n742:                     configPath: '{state_paths.config}',\n743:                     stateLogPath: '{state_paths.state_log}',\n744:                     strategyPath: '{state_paths.strategy}',\n745:                     registryPath: '{state_paths.findings_registry}',\n746:                     currentIteration: Number('{current_iteration}'),\n747:                     maxIterations: Number('{max_iterations}'),\n748:                     triggerReason: '{reason}',\n749:                   });\n750:                   const prepared = await preparePivotTransaction(input);\n751:                   const seatPrompts = prepared.status === 'pending'\n752:                     ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n753:                         seat.id,\n754:                         renderReviewPivotSeatPrompt(seat, prepared.dispatchContext),\n755:                       ]))\n756:                     : {};\n757:                   process.stdout.write(`${JSON.stringify({\n758:                     ...prepared,\n759:                     seatPrompts,\n760:                     boundaryRejections: input.boundaryRejections,\n761:                   })}\\n`);\n762:                   EOF\n763:                 working_directory: \"{repo_root}\"\n764:                 outputs:\n765:                   - pivot_prepare_json: \"The complete parsed JSON result\"\n766:                   - pivot_prepare_status: \"status from the prepare result\"\n767:                   - pivot_id: \"pivotId from the prepare result\"\n768:                   - pivot_paths_json: \"paths from the prepare result as JSON\"\n769:                   - pivot_resumed: \"resumed from the prepare result\"\n770:                   - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n771:                   - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n772:                   - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n773:                   - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n774:                   - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n775:                   - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n776:                   - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n777:                   - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n778:                 short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n779: \n780:               step_dispatch_pivot_seat_001:\n781:                 action: \"Natively dispatch the analytical read-only review direction-selection seat\"\n782:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n783:                 capture_timing: true\n784:                 if_native:\n785:                   dispatch:\n786:                     agent: deep-review\n787:                     model: opus\n788:                     context_source: \"pivot_seat_001_prompt\"\n789:                   wait_for_completion: true\n790:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n791:                 outputs:\n792:                   - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n793:                   - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n794:                   - pivot_seat_001_error_json: \"{name,message} when rejected\"\n795:                   - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n796:                   - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n797:                   - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n798: \n799:               step_record_pivot_seat_001:\n800:                 action: \"Durably record the seat-001 native dispatch outcome\"\n801:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n802:                 command: |\n803:                   node --experimental-strip-types --input-type=module <<'EOF'\n804:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n805:                   const status = '{pivot_seat_001_dispatch_status}';\n806:                   const outcome = status === 'fulfilled'\n807:                     ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n808:                     : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n809:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n810:                   EOF\n811:                 working_directory: \"{repo_root}\"\n812: \n813:               step_dispatch_pivot_seat_002:\n814:                 action: \"Natively dispatch the critical read-only review direction-selection seat\"\n815:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n816:                 capture_timing: true\n817:                 if_native:\n818:                   dispatch:\n819:                     agent: deep-review\n820:                     model: opus\n821:                     context_source: \"pivot_seat_002_prompt\"\n822:                   wait_for_completion: true\n823:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n824:                 outputs:\n825:                   - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n826:                   - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n827:                   - pivot_seat_002_error_json: \"{name,message} when rejected\"\n828:                   - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n829:                   - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n830:                   - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n831: \n832:               step_record_pivot_seat_002:\n833:                 action: \"Durably record the seat-002 native dispatch outcome\"\n834:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n835:                 command: |\n836:                   node --experimental-strip-types --input-type=module <<'EOF'\n837:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n838:                   const status = '{pivot_seat_002_dispatch_status}';\n839:                   const outcome = status === 'fulfilled'\n840:                     ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n841:                     : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n842:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n843:                   EOF\n844:                 working_directory: \"{repo_root}\"\n845: \n846:               step_dispatch_pivot_seat_003:\n847:                 action: \"Natively dispatch the pragmatic read-only review direction-selection seat\"\n848:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n849:                 capture_timing: true\n850:                 if_native:\n851:                   dispatch:\n852:                     agent: deep-review\n853:                     model: opus\n854:                     context_source: \"pivot_seat_003_prompt\"\n855:                   wait_for_completion: true\n856:                 failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n857:                 outputs:\n858:                   - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n859:                   - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n860:                   - pivot_seat_003_error_json: \"{name,message} when rejected\"\n861:                   - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n862:                   - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n863:                   - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n864: \n865:               step_record_pivot_seat_003:\n866:                 action: \"Durably record the seat-003 native dispatch outcome\"\n867:                 skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n868:                 command: |\n869:                   node --experimental-strip-types --input-type=module <<'EOF'\n870:                   import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n871:                   const status = '{pivot_seat_003_dispatch_status}';\n872:                   const outcome = status === 'fulfilled'\n873:                     ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n874:                     : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n875:                   process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n876:                   EOF\n877:                 working_directory: \"{repo_root}\"\n878: \n879:               step_finalize_divergent_pivot:\n880:                 action: \"Finalize the prepared pivot after all missing native seats are durable\"\n881:                 skip_when: \"pivot_prepare_status != 'pending'\"\n882:                 command: |\n883:                   node --experimental-strip-types --input-type=module <<'EOF'\n884:                   import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n885:                   process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n886:                   EOF\n887:                 working_directory: \"{repo_root}\"\n888:                 outputs:\n889:                   - pivot_finalize_json: \"The complete parsed final result\"\n890: \n891:               step_resolve_divergent_pivot_result:\n892:                 action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n893:                 branch_on: \"pivot_prepare_status\"\n894:                 if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n895:                 if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n896: \n897:               step_apply_divergent_pivot_result:\n898:                 action: \"Adopt a successful read-only review direction or fail closed to the existing synthesis path\"\n899:                 branch_on: \"pivot_result.status\"\n900:                 if_completed:\n901:                   set:\n902:                     next_dimension: \"{pivot_result.restoredFocus}\"\n903:                     pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n904:                     saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n905:                   command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg}\"\n906:                   log: \"Divergent review pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n907:                   proceed_to: step_normalize_pause_events\n908:                 if_failed:\n909:                   log: \"Divergent review pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n910:                   skip_to: phase_synthesis\n911:             on_error:\n912:               log: \"Divergent review pivot integration error; failing closed to the existing synthesis path.\"\n913:               skip_to: phase_synthesis\n914:           if_existing_terminal_path:\n915:             log: \"Loop stopping. Reason: {reason}\"\n916:             skip_to: phase_synthesis\n917:         if_blocked:\n918:           log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n919:         if_stuck_recovery:\n920:           log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n921:           recovery_strategies:\n922:             - \"Change granularity: file-level → function-level → line-level review\"\n923:             - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n924:             - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n925:           pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n926:           set:\n927:             next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n928:             pending_stop_event: \"stuck_recovery\"\n929:             pending_stop_reason: \"stuckRecovery\"\n930:             pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n931:           reset: { stuck_count: 0 }\n932:         if_continue:\n933:           log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n934: \n935:       step_normalize_pause_events:\n936:         action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n937:         if_pending_pause_event:\n938:           append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n939:           message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n940:           reset:\n941:             pending_stop_event: null\n942:             pending_stop_reason: null\n943:             pending_stop_detail: null\n944:           halt: true\n945:         if_pending_stuck_recovery:\n946:           append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n947:           reset:\n948:             pending_stop_event: null\n949:             pending_stop_reason: null\n950:             pending_stop_detail: null\n951:         if_no_pending_event:\n952:           proceed: true\n953: \n954:       step_generate_state_summary:\n955:         action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n956:         generate: |\n957:           STATE SUMMARY (auto-generated):\n958:           Iteration: {current_iteration} of {max_iterations}\n959:           Dimension: {next_dimension}\n960:           Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n961:           Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n962:           Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n963:           {resource_map_prompt_line}\n964:           Coverage Age: {coverage_age}\n965:           Last 2 ratios: {ratio_prev} -> {ratio_latest}\n966:           Stuck count: {stuck_count}\n967:           Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n968: \n969:       step_marker_scan:\n970:         action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n971:         algorithm: |\n972:           if current_iteration > 1:\n973:             PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n974:             if file_exists(PREV_PROMPT_PATH):\n975:               PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n976:               if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n977:                 log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n978:                 halt with exit code 2\n979:         note: |\n980:           False-positive prevention: only matches when the first line is exactly one of the\n981:           three canonical markers. Markers appearing in comments or body text are ignored.\n982:           True-positive triggers only when a previous iteration's rendered prompt literally\n983:           starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n984: \n985:       step_dispatch_iteration:\n986:         action: \"Dispatch @deep-review agent for one review iteration\"\n987:         resolve_executor:\n988:           source: \"config.executor\"\n989:           loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n990:         pre_dispatch:\n991:           generate_summary: |\n992:             STATE SUMMARY (auto-generated):\n993:             Iteration: {current_iteration} of {max_iterations}\n994:             Dimension: {next_dimension}\n995:             Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n996:             Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n997:             Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n998:             {resource_map_prompt_line}\n999:             Coverage Age: {coverage_age}\n1000:             Last 2 ratios: {ratio_prev} -> {ratio_latest}\n1001:             Stuck count: {stuck_count}\n1002:             Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n1003:           render_prompt_pack:\n1004:             template_path: \".opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n1005:             renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n1006:             output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n1007:             variables:\n1008:               state_summary: \"{state_summary}\"\n1009:               current_iteration: \"{current_iteration}\"\n1010:               max_iterations: \"{max_iterations}\"\n1011:               next_dimension: \"{next_dimension}\"\n1012:               review_target: \"{review_target}\"\n1013:               review_scope_files: \"{review_scope_files}\"\n1014:               p0_count: \"{p0_count}\"\n1015:               p1_count: \"{p1_count}\"\n1016:               p2_count: \"{p2_count}\"\n1017:               pivot_lineage: \"{pivot_lineage}\"\n1018:               saturated_directions: \"{saturated_directions}\"\n1019:               state_paths_config: \"{state_paths.config}\"\n1020:               state_paths_state_log: \"{state_paths.state_log}\"\n1021:               state_paths_findings_registry: \"{state_paths.findings_registry}\"\n1022:               state_paths_strategy: \"{state_paths.strategy}\"\n1023:               state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n1024:               state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n1025:         pre_dispatch_audit:\n1026:           skip_when: \"config.executor.kind == 'native'\"\n1027:           call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n1028:           args:\n1029:             stateLogPath: \"{state_paths.state_log}\"\n1030:             executor: \"{config.executor}\"\n1031:             iteration: \"{current_iteration}\"\n1032:         branch_on: \"config.executor.kind\"\n1033:         if_native:\n1034:           dispatch:\n1035:             agent: deep-review\n1036:             model: opus\n1037:             context_source: \"rendered_prompt_pack\"\n1038:           wait_for_completion: true\n1039:         if_cli_copilot:\n1040:           command: |\n1041:             node --experimental-strip-types --input-type=module <<'EOF'\n1042:             import { readFileSync, writeFileSync } from 'node:fs';\n1043:             import { createHash } from 'node:crypto';\n1044: \n1045:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1046:             import { buildCopilotPromptArg } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n1047: \n1048:             const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n1049:             const prompt = readFileSync(promptPath, 'utf8');\n1050: \n1051:             // Workflow-resolved spec folder is the only legal write authority.\n1052:             // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n1053:             // is the single source of truth for rejecting empty / unresolved\n1054:             // template / whitespace-only / string-coerced empty values. The\n1055:             // YAML hands the raw `{spec_folder}` directly; on rejection the\n1056:             // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n1057:             // enforcement, --allow-all-tools stripped).\n1058:             const specFolderRaw = '{spec_folder}';\n1059:             const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n1060: \n1061:             const baseArgs = [\n1062:               '-p',\n1063:               prompt,\n1064:               '--model',\n1065:               '{config.executor.model}',\n1066:               '--allow-all-tools',\n1067:               '--no-ask-user',\n1068:             ];\n1069: \n1070:             const built = buildCopilotPromptArg({\n1071:               promptPath,\n1072:               prompt,\n1073:               targetAuthority,\n1074:               baseArgv: baseArgs,\n1075:             });\n1076: \n1077:             // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n1078:             // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n1079:             // Write it to disk so the file Copilot reads via @path opens with\n1080:             // the authority block. Without this, recovered/bootstrap folder\n1081:             // mentions inside the file could still anchor the model.\n1082:             if (built.promptFileBody !== undefined) {\n1083:               writeFileSync(promptPath, built.promptFileBody, 'utf8');\n1084:             }\n1085: \n1086:             // Copilot is routed through the audited executor wrapper so it produces\n1087:             // INTENT + COMPLETION dispatch receipts alongside claude-code/opencode\n1088:             // There is no cli-copilot kind in the executor schema, so it\n1089:             // dispatches as kind:'native' (full env passthrough, no recursion-guard\n1090:             // layer configured for copilot); the receipt still records the real\n1091:             // 'copilot' command + built.argv as facts.\n1092:             const dispatchFacts = {\n1093:               command: 'deep/review',\n1094:               mode: 'review',\n1095:               specFolder: '{spec_folder}',\n1096:               artifactDir: '{state_paths.packet_dir}',\n1097:               iteration: Number('{current_iteration}'),\n1098:               executorKind: '{config.executor.kind}',\n1099:               branchId: '{config.executor.kind}',\n1100:               sessionId: '{session_id}',\n1101:               generation: Number('{generation}'),\n1102:             };\n1103:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1104:             process.exit(\n1105:               runAuditedExecutorCommand({\n1106:                 command: 'copilot',\n1107:                 args: built.argv,\n1108:                 cwd: '{repo_root}',\n1109:                 timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1110:                 stateLogPath: '{state_paths.state_log}',\n1111:                 executor: {\n1112:                   kind: 'native',\n1113:                   model: '{config.executor.model}',\n1114:                   configDir: null,\n1115:                   reasoningEffort: null,\n1116:                   serviceTier: null,\n1117:                   sandboxMode: null,\n1118:                   timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1119:                   governor: null,\n1120:                 },\n1121:                 iteration: Number('{current_iteration}'),\n1122:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1123:                 dispatchId,\n1124:               }),\n1125:             );\n1126:             EOF\n1127:           working_directory: \"{repo_root}\"\n1128:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1129:           wait_for_completion: true\n1130:           notes:\n1131:             - \"Routed through runAuditedExecutorCommand so copilot produces INTENT + COMPLETION dispatch receipts; built.argv (@PROMPT_PATH or positional) is forwarded verbatim as the receipt facts\"\n1132:             - \"copilot has no stdin support; prompt is positional\"\n1133:             - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n1134:             - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n1135:             - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n1136:             - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n1137:             - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n1138:         if_cli_claude_code:\n1139:           command: |\n1140:             node --experimental-strip-types --input-type=module <<'EOF'\n1141:             import { readFileSync } from 'node:fs';\n1142:             import { createHash } from 'node:crypto';\n1143: \n1144:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1145: \n1146:             const configDir = '{optional_claude_config_dir}';\n1147:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1148:             const executor = {\n1149:               kind: 'cli-claude-code',\n1150:               model: '{config.executor.model}',\n1151:               configDir: configDir || null,\n1152:               reasoningEffort,\n1153:               serviceTier: null,\n1154:               sandboxMode: null,\n1155:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1156:               governor: null,\n1157:             };\n1158:             const args = [\n1159:               '-p',\n1160:               readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n1161:               '--model',\n1162:               executor.model,\n1163:               '--permission-mode',\n1164:               'acceptEdits',\n1165:               '--output-format',\n1166:               'text',\n1167:             ];\n1168:             if (executor.reasoningEffort) {\n1169:               args.push('--effort', executor.reasoningEffort);\n1170:             }\n1171: \n1172:             // CLAUDE_CONFIG_DIR rides through guardContext.env; the CLAUDE_ prefix is\n1173:             // on the cli-claude-code env allowlist so buildExecutorDispatchEnv admits it.\n1174:             const parentEnv = { ...process.env };\n1175:             if (configDir) {\n1176:               parentEnv.CLAUDE_CONFIG_DIR = configDir;\n1177:             }\n1178: \n1179:             const dispatchFacts = {\n1180:               command: 'deep/review',\n1181:               mode: 'review',\n1182:               specFolder: '{spec_folder}',\n1183:               artifactDir: '{state_paths.packet_dir}',\n1184:               iteration: Number('{current_iteration}'),\n1185:               executorKind: '{config.executor.kind}',\n1186:               branchId: '{config.executor.kind}',\n1187:               sessionId: '{session_id}',\n1188:               generation: Number('{generation}'),\n1189:             };\n1190:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1191:             process.exit(\n1192:               runAuditedExecutorCommand({\n1193:                 command: 'claude',\n1194:                 args,\n1195:                 cwd: '{repo_root}',\n1196:                 timeoutSeconds: executor.timeoutSeconds,\n1197:                 stateLogPath: '{state_paths.state_log}',\n1198:                 executor,\n1199:                 iteration: Number('{current_iteration}'),\n1200:                 guardContext: { env: parentEnv },\n1201:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1202:                 dispatchId,\n1203:               }),\n1204:             );\n1205:             EOF\n1206:           working_directory: \"{repo_root}\"\n1207:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1208:           wait_for_completion: true\n1209:           render_hint:\n1210:             optional_claude_config_dir: |\n1211:               If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n1212:               Otherwise expand to empty string.\n1213:           notes:\n1214:             - \"Routed through runAuditedExecutorCommand so claude-code produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1215:             - \"CLAUDE_CONFIG_DIR is forwarded through guardContext.env (CLAUDE_ prefix is allowlisted) so account-specific Claude Code routing is preserved\"\n1216:             - \"permission-mode stays acceptEdits (review's existing iteration-write behavior); claude-code has no serviceTier flag\"\n1217:             - \"claude-code supports --effort for reasoning depth\"\n1218:         if_cli_opencode:\n1219:           command: |\n1220:             node --experimental-strip-types --input-type=module <<'EOF'\n1221:             import { execFileSync } from 'node:child_process';\n1222:             import { appendFileSync, readFileSync, realpathSync } from 'node:fs';\n1223:             import { createHash } from 'node:crypto';\n1224:             import { isAbsolute, relative, resolve } from 'node:path';\n1225: \n1226:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1227: \n1228:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1229:             const executor = {\n1230:               kind: 'cli-opencode',\n1231:               model: '{config.executor.model}',\n1232:               configDir: null,\n1233:               reasoningEffort,\n1234:               serviceTier: null,\n1235:               sandboxMode: null,\n1236:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1237:               governor: null,\n1238:             };\n1239:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1240:             if (!promptBody.includes('BANNED OPERATIONS') || !promptBody.includes('ALLOWED WRITE PATHS')) {\n1241:               throw new Error('Unsafe cli-opencode dispatch: rendered prompt is missing required write-containment sections');\n1242:             }\n1243: \n1244:             const repoRoot = realpathSync('{repo_root}');\n1245:             const artifactDir = resolve(repoRoot, '{state_paths.packet_dir}');\n1246:             const artifactRelative = relative(repoRoot, artifactDir);\n1247:             if (artifactRelative === '' || artifactRelative.startsWith('..') || isAbsolute(artifactRelative)) {\n1248:               throw new Error('Unsafe cli-opencode dispatch: artifact directory must be a strict descendant of the worktree root');\n1249:             }\n1250: \n1251:             const git = (args, cwd = repoRoot, trim = true) => {\n1252:               const output = execFileSync('git', args, { cwd, encoding: 'utf8' });\n1253:               return trim ? output.trim() : output;\n1254:             };\n1255:             const resolveGitPath = (candidate) => realpathSync(isAbsolute(candidate) ? candidate : resolve(repoRoot, candidate));\n1256:             const gitDir = resolveGitPath(git(['rev-parse', '--git-dir']));\n1257:             const commonGitDir = resolveGitPath(git(['rev-parse', '--git-common-dir']));\n1258:             if (gitDir === commonGitDir) {\n1259:               throw new Error('Unsafe cli-opencode dispatch: --dir must point at an isolated linked worktree');\n1260:             }\n1261: \n1262:             const primaryBlock = git(['worktree', 'list', '--porcelain'])\n1263:               .split(/\\n\\n+/)\n1264:               .find((block) => /^branch refs\\/heads\\/(?:main|master)$/m.test(block));\n1265:             const primaryLine = primaryBlock?.split('\\n').find((line) => line.startsWith('worktree '));\n1266:             if (!primaryLine) {\n1267:               throw new Error('Unsafe cli-opencode dispatch: primary main/master worktree could not be resolved');\n1268:             }\n1269:             const primaryRoot = realpathSync(primaryLine.slice('worktree '.length));\n1270:             const primaryStatus = git(['status', '--porcelain=v1', '--untracked-files=all'], primaryRoot);\n1271:             if (primaryStatus) {\n1272:               throw new Error('Unsafe cli-opencode dispatch: primary worktree must be clean before unrestricted execution');\n1273:             }\n1274: \n1275:             const dirtyPaths = [\n1276:               ...git(['diff', '--name-only', '-z', 'HEAD', '--'], repoRoot, false).split('\\0'),\n1277:               ...git(['ls-files', '--others', '--exclude-standard', '-z'], repoRoot, false).split('\\0'),\n1278:             ].filter(Boolean);\n1279:             const outsideArtifactDir = dirtyPaths.filter((candidate) => {\n1280:               const candidateRelative = relative(artifactDir, resolve(repoRoot, candidate));\n1281:               return candidateRelative.startsWith('..') || isAbsolute(candidateRelative);\n1282:             });\n1283:             if (outsideArtifactDir.length > 0) {\n1284:               throw new Error(`Unsafe cli-opencode dispatch: worktree changes outside the artifact directory: ${outsideArtifactDir.join(', ')}`);\n1285:             }\n1286: \n1287:             const recoveryBaselineCommit = git(['rev-parse', '--verify', 'HEAD']);\n1288:             appendFileSync(\n1289:               '{state_paths.state_log}',\n1290:               `${JSON.stringify({ type: 'event', event: 'recovery_baseline', mode: 'review', iteration: Number('{current_iteration}'), recoveryBaselineCommit, worktree: repoRoot, timestamp: new Date().toISOString() })}\\n`,\n1291:               'utf8',\n1292:             );\n1293:             const message = 'Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true'\n1294:               + '\\n\\n'\n1295:               + promptBody;\n1296:             const args = [\n1297:               'run',\n1298:               '--model',\n1299:               executor.model,\n1300:               '--format',\n1301:               'json',\n1302:               '--dangerously-skip-permissions',\n1303:               '--pure',\n1304:               '--dir',\n1305:               '{repo_root}',\n1306:             ];\n1307:             if (executor.reasoningEffort) {\n1308:               args.push('--variant', executor.reasoningEffort);\n1309:             }\n1310:             args.push(message);\n1311: \n1312:             const dispatchFacts = {\n1313:               command: 'deep/review',\n1314:               mode: 'review',\n1315:               specFolder: '{spec_folder}',\n1316:               artifactDir: '{state_paths.packet_dir}',\n1317:               iteration: Number('{current_iteration}'),\n1318:               executorKind: '{config.executor.kind}',\n1319:               branchId: '{config.executor.kind}',\n1320:               sessionId: '{session_id}',\n1321:               generation: Number('{generation}'),\n1322:             };\n1323:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1324:             process.exit(\n1325:               runAuditedExecutorCommand({\n1326:                 command: 'opencode',\n1327:                 args,\n1328:                 cwd: '{repo_root}',\n1329:                 timeoutSeconds: executor.timeoutSeconds,\n1330:                 stateLogPath: '{state_paths.state_log}',\n1331:                 executor,\n1332:                 iteration: Number('{current_iteration}'),\n1333:                 // opencode v1.14.39 reads stdin at startup before session creation;\n1334:                 // an empty input gives EOF stdin, equivalent to </dev/null.\n\n(Showing lines 635-1334 of 2111. Use offset=1335 to continue.)\n</content>","metadata":{"preview":"               dimension_coverage_gate_missing_json = JSON array of missing review dimensions\n               p0_resolution_gate_pass = boolean\n               active_p0_count = number of active P0 findings\n               evidence_density_gate_pass = boolean\n               avg_evidence_per_finding = numeric evidence density\n               hotspot_saturation_gate_pass = boolean\n               claim_adjudication_gate_pass = boolean\n               claim_adjudication_active_count = numeric count of active P0/P1 at the gate\n               fix_completeness_replay_gate_pass = boolean\n               security_sensitive_fix_scope = boolean\n               fix_completeness_replay_required_rows = numeric count of closed-gate replay rows required for security-sensitive fix reruns\n               fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n               candidate_coverage_gate_pass = boolean\n               candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n               candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n               graphless_fallback_gate_pass = boolean\n               graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n               graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n               graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n               recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"               dimension_coverage_gate_missing_json = JSON array of missing review dimensions\n               p0_resolution_gate_pass = boolean\n               active_p0_count = number of active P0 findings\n               evidence_density_gate_pass = boolean\n               avg_evidence_per_finding = numeric evidence density\n               hotspot_saturation_gate_pass = boolean\n               claim_adjudication_gate_pass = boolean\n               claim_adjudication_active_count = numeric count of active P0/P1 at the gate\n               fix_completeness_replay_gate_pass = boolean\n               security_sensitive_fix_scope = boolean\n               fix_completeness_replay_required_rows = numeric count of closed-gate replay rows required for security-sensitive fix reruns\n               fix_completeness_replay_passing_rows = numeric count of required closed-gate replay rows marked PASS with evidence\n               candidate_coverage_gate_pass = boolean\n               candidate_coverage_search_debt_json = JSON array of reducer-owned searchDebt obligations blocking STOP, else []\n               candidate_coverage_missing_json = JSON array of required bug classes not present in candidateCoverage.covered, else []\n               graphless_fallback_gate_pass = boolean\n               graphless_fallback_mode = latest reducer-owned searchCoverage.graphCoverageMode value\n               graphless_fallback_missing_json = JSON array of required bug classes without cited fallback ledger rows, else []\n               graphless_fallback_unavailability_reason = explicit reason when graphCoverageMode == \"unavailable_blocked\", else empty string\n               recovery_strategy = one-line hint describing the next review action needed to satisfy the failed gates; combine candidateCoverageGate and graphlessFallbackGate recovery guidance when both fail (when claimAdjudicationGate is the failing gate, prefer the step-0 recovery_strategy already set)\n          6. COMBINED STOP RULE:\n               a) if STOP is legal AND graph_decision == \"STOP_ALLOWED\": decision = \"STOP\"\n               b) if STOP is legal AND graph_decision == \"STOP_BLOCKED\":\n                    decision = \"BLOCKED\"\n                    stop_blocked = true\n                    stopReason = \"blockedStop\"\n                    # Blocked-stop closure: blockedBy must be string[] per the\n                    # published review blocked-stop contract. Extract the `.type`\n                    # field from each structured graph blocker; preserve the full\n                    # objects in graph_blocker_detail_json for operator inspection.\n                    blocked_by_json = JSON.stringify(graph_blockers_json.map(b => typeof b === \"string\" ? b : (b && b.type) || \"graph_blocker\"))\n                    blocked_by_csv = graph_blockers_csv\n                    graph_blocker_detail_json = graph_blockers_json\n                    recovery_strategy = \"Resolve review coverage-graph blockers before stopping.\"\n               c) if STOP is legal AND graph_decision == \"CONTINUE\":\n                    decision = \"CONTINUE\"\n                    stop_blocked = false\n                    reason = \"graph_convergence_continue\"\n               d) else keep the existing STUCK_RECOVERY or CONTINUE outcome\n        outputs:\n          - decision: \"STOP | BLOCKED | STUCK_RECOVERY | CONTINUE\"\n          - reason: \"Human-readable stop reason\"\n          - stop_blocked: \"Boolean true when STOP is vetoed by inline legal-stop gates or graph_decision == STOP_BLOCKED\"\n          - blocked_by_json: \"JSON array of failed legal-stop gates when decision == BLOCKED\"\n          - blocked_by_csv: \"Comma-separated list of failed legal-stop gates when decision == BLOCKED\"\n          - convergence_gate_pass: \"Boolean pass/fail for convergenceGate\"\n          - convergence_gate_score: \"Numeric score recorded for convergenceGate\"\n          - dimension_coverage_gate_pass: \"Boolean pass/fail for dimensionCoverageGate\"\n          - dimension_coverage_gate_covered_json: \"JSON array of covered review dimensions\"\n          - dimension_coverage_gate_missing_json: \"JSON array of missing review dimensions\"\n          - p0_resolution_gate_pass: \"Boolean pass/fail for p0ResolutionGate\"\n          - active_p0_count: \"Active P0 finding count at stop-check time\"\n          - evidence_density_gate_pass: \"Boolean pass/fail for evidenceDensityGate\"\n          - avg_evidence_per_finding: \"Numeric evidence density for active findings\"\n          - hotspot_saturation_gate_pass: \"Boolean pass/fail for hotspotSaturationGate\"\n          - claim_adjudication_gate_pass: \"Boolean pass/fail for claimAdjudicationGate (false vetoes STOP)\"\n          - claim_adjudication_active_count: \"Count of active P0/P1 findings evaluated by claimAdjudicationGate\"\n          - fix_completeness_replay_gate_pass: \"Boolean pass/fail for fixCompletenessReplayGate (false vetoes STOP on security-sensitive fix reruns)\"\n          - security_sensitive_fix_scope: \"Boolean true when the review is a security-sensitive fix rerun\"\n          - fix_completeness_replay_required_rows: \"Count of closed-gate replay rows required before STOP\"\n          - fix_completeness_replay_passing_rows: \"Count of required closed-gate replay rows that passed with evidence\"\n          - candidate_coverage_gate_pass: \"Boolean pass/fail for candidateCoverageGate (false vetoes STOP for unresolved reducer-owned search debt or uncovered required bug classes)\"\n          - candidate_coverage_search_debt_json: \"JSON array of reducer-owned searchDebt obligations used as blocked-stop evidence\"\n          - candidate_coverage_missing_json: \"JSON array of required bug classes missing from candidateCoverage.covered\"\n          - graphless_fallback_gate_pass: \"Boolean pass/fail for graphlessFallbackGate (false vetoes STOP when graphless fallback evidence is absent or unavailable_blocked)\"\n          - graphless_fallback_mode: \"Latest reducer-owned searchCoverage.graphCoverageMode value\"\n          - graphless_fallback_missing_json: \"JSON array of required bug classes missing cited fallback ledger rows\"\n          - graphless_fallback_unavailability_reason: \"Explicit unavailability reason when graphCoverageMode == unavailable_blocked\"\n          - graph_decision: \"CONTINUE | STOP_ALLOWED | STOP_BLOCKED from step_graph_convergence\"\n          - graph_signals_json: \"JSON object returned by graph convergence\"\n          - graph_blockers_json: \"JSON array of graph blockers\"\n          - graph_blockers_csv: \"Comma-separated graph blocker summary\"\n          - recovery_strategy: \"One-line hint describing the next review action when decision == BLOCKED or STUCK_RECOVERY\"\n\n      step_emit_blocked_stop:\n        action: \"Persist blocked-stop evidence whenever the review legal-stop decision tree vetoes STOP\"\n        if_blocked:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"blocked_stop\",\"mode\":\"review\",\"run\":{current_iteration},\"blockedBy\":{blocked_by_json},\"gateResults\":{\"convergenceGate\":{\"pass\":{convergence_gate_pass},\"score\":{convergence_gate_score}},\"dimensionCoverageGate\":{\"pass\":{dimension_coverage_gate_pass},\"covered\":{dimension_coverage_gate_covered_json},\"missing\":{dimension_coverage_gate_missing_json}},\"p0ResolutionGate\":{\"pass\":{p0_resolution_gate_pass},\"activeP0\":{active_p0_count}},\"evidenceDensityGate\":{\"pass\":{evidence_density_gate_pass},\"avgEvidencePerFinding\":{avg_evidence_per_finding}},\"hotspotSaturationGate\":{\"pass\":{hotspot_saturation_gate_pass}},\"claimAdjudicationGate\":{\"pass\":{claim_adjudication_gate_pass},\"activeP0P1\":{claim_adjudication_active_count}},\"fixCompletenessReplayGate\":{\"pass\":{fix_completeness_replay_gate_pass},\"securitySensitive\":{security_sensitive_fix_scope},\"requiredRows\":{fix_completeness_replay_required_rows},\"passingRows\":{fix_completeness_replay_passing_rows}},\"candidateCoverageGate\":{\"pass\":{candidate_coverage_gate_pass},\"searchDebt\":{candidate_coverage_search_debt_json},\"missing\":{candidate_coverage_missing_json}},\"graphlessFallbackGate\":{\"pass\":{graphless_fallback_gate_pass},\"mode\":\"{graphless_fallback_mode}\",\"missing\":{graphless_fallback_missing_json},\"unavailabilityReason\":\"{graphless_fallback_unavailability_reason}\"}},\"graphBlockerDetail\":{graph_blockers_json},\"recoveryStrategy\":\"{recovery_strategy}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Blocked STOP persisted for review loop. Failed gates: {blocked_by_csv}. Recovery strategy: {recovery_strategy}\"\n        if_not_blocked:\n          proceed: true\n\n      step_handle_convergence:\n        action: \"Act on convergence decision\"\n        if_stop:\n          branch_on: \"convergence_mode == 'divergent' AND reason == 'all_dimensions_clean'\"\n          if_divergent_eligible:\n            eligibility_contract:\n              required_decision: \"STOP\"\n              eligible_reasons: [all_dimensions_clean]\n              excluded_reasons: [maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused]\n              fail_closed: \"Any missing or ambiguous reason uses if_existing_terminal_path without preparing a pivot. The nine legal-stop gates have already run and remain unchanged.\"\n            steps:\n              step_prepare_divergent_pivot:\n                action: \"Generate state-grounded read-only review candidates and prepare or resume the pivot transaction\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import {\n                    buildReviewPivotPreparationInput,\n                    renderReviewPivotSeatPrompt,\n                  } from './.opencode/skills/system-deep-loop/deep-review/scripts/divergent-review-pivot.ts';\n                  import {\n                    preparePivotTransaction,\n                  } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n\n                  const input = buildReviewPivotPreparationInput({\n                    artifactRoot: '{state_paths.packet_dir}',\n                    configPath: '{state_paths.config}',\n                    stateLogPath: '{state_paths.state_log}',\n                    strategyPath: '{state_paths.strategy}',\n                    registryPath: '{state_paths.findings_registry}',\n                    currentIteration: Number('{current_iteration}'),\n                    maxIterations: Number('{max_iterations}'),\n                    triggerReason: '{reason}',\n                  });\n                  const prepared = await preparePivotTransaction(input);\n                  const seatPrompts = prepared.status === 'pending'\n                    ? Object.fromEntries(prepared.missingSeats.map((seat) => [\n                        seat.id,\n                        renderReviewPivotSeatPrompt(seat, prepared.dispatchContext),\n                      ]))\n                    : {};\n                  process.stdout.write(`${JSON.stringify({\n                    ...prepared,\n                    seatPrompts,\n                    boundaryRejections: input.boundaryRejections,\n                  })}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_prepare_json: \"The complete parsed JSON result\"\n                  - pivot_prepare_status: \"status from the prepare result\"\n                  - pivot_id: \"pivotId from the prepare result\"\n                  - pivot_paths_json: \"paths from the prepare result as JSON\"\n                  - pivot_resumed: \"resumed from the prepare result\"\n                  - pivot_missing_seat_ids: \"missingSeats ids from a pending result\"\n                  - pivot_seat_001_json: \"The seat-001 mandate object from missingSeats\"\n                  - pivot_seat_002_json: \"The seat-002 mandate object from missingSeats\"\n                  - pivot_seat_003_json: \"The seat-003 mandate object from missingSeats\"\n                  - pivot_seat_001_prompt: \"seatPrompts['seat-001']\"\n                  - pivot_seat_002_prompt: \"seatPrompts['seat-002']\"\n                  - pivot_seat_003_prompt: \"seatPrompts['seat-003']\"\n                  - pivot_dispatch_context_json: \"dispatchContext from a pending result as JSON\"\n                short_circuit: \"When status is completed or failed, skip all dispatch and record steps and bind this result as pivot_result.\"\n\n              step_dispatch_pivot_seat_001:\n                action: \"Natively dispatch the analytical read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_001_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_001.\"\n                outputs:\n                  - pivot_seat_001_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_001_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_001_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_001_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_001_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_001_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_001:\n                action: \"Durably record the seat-001 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-001'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_001_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_001_output_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_001_error_json}, startedAtIso: '{pivot_seat_001_started_at_iso}', completedAtIso: '{pivot_seat_001_completed_at_iso}', durationMs: Number('{pivot_seat_001_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_001_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_002:\n                action: \"Natively dispatch the critical read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_002_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_002.\"\n                outputs:\n                  - pivot_seat_002_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_002_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_002_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_002_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_002_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_002_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_002:\n                action: \"Durably record the seat-002 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-002'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_002_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_002_output_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_002_error_json}, startedAtIso: '{pivot_seat_002_started_at_iso}', completedAtIso: '{pivot_seat_002_completed_at_iso}', durationMs: Number('{pivot_seat_002_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_002_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_dispatch_pivot_seat_003:\n                action: \"Natively dispatch the pragmatic read-only review direction-selection seat\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                capture_timing: true\n                if_native:\n                  dispatch:\n                    agent: deep-review\n                    model: opus\n                    context_source: \"pivot_seat_003_prompt\"\n                  wait_for_completion: true\n                failure_contract: \"A native dispatch failure binds status=rejected, a {name,message} error, and the measured timestamps/duration, then proceeds to step_record_pivot_seat_003.\"\n                outputs:\n                  - pivot_seat_003_dispatch_status: \"fulfilled or rejected\"\n                  - pivot_seat_003_output_json: \"Raw native return serialized as JSON when fulfilled\"\n                  - pivot_seat_003_error_json: \"{name,message} when rejected\"\n                  - pivot_seat_003_started_at_iso: \"Dispatch start timestamp\"\n                  - pivot_seat_003_completed_at_iso: \"Dispatch completion timestamp\"\n                  - pivot_seat_003_duration_ms: \"Dispatch duration in milliseconds\"\n\n              step_record_pivot_seat_003:\n                action: \"Durably record the seat-003 native dispatch outcome\"\n                skip_when: \"pivot_prepare_status != 'pending' or pivot_missing_seat_ids does not contain 'seat-003'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { recordPivotSeatResult } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  const status = '{pivot_seat_003_dispatch_status}';\n                  const outcome = status === 'fulfilled'\n                    ? { status, output: {pivot_seat_003_output_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') }\n                    : { status: 'rejected', error: {pivot_seat_003_error_json}, startedAtIso: '{pivot_seat_003_started_at_iso}', completedAtIso: '{pivot_seat_003_completed_at_iso}', durationMs: Number('{pivot_seat_003_duration_ms}') };\n                  process.stdout.write(`${JSON.stringify(recordPivotSeatResult({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', seat: {pivot_seat_003_json}, outcome }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n\n              step_finalize_divergent_pivot:\n                action: \"Finalize the prepared pivot after all missing native seats are durable\"\n                skip_when: \"pivot_prepare_status != 'pending'\"\n                command: |\n                  node --experimental-strip-types --input-type=module <<'EOF'\n                  import { finalizePivotTransaction } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/divergent-pivot.ts';\n                  process.stdout.write(`${JSON.stringify(finalizePivotTransaction({ paths: {pivot_paths_json}, pivotId: '{pivot_id}', resumed: {pivot_resumed} }))}\\n`);\n                  EOF\n                working_directory: \"{repo_root}\"\n                outputs:\n                  - pivot_finalize_json: \"The complete parsed final result\"\n\n              step_resolve_divergent_pivot_result:\n                action: \"Use prepare's terminal result on resume/short-circuit, otherwise use finalize's result\"\n                branch_on: \"pivot_prepare_status\"\n                if_pending: { bind: { pivot_result: \"{pivot_finalize_json}\" } }\n                if_completed_or_failed: { bind: { pivot_result: \"{pivot_prepare_json}\" } }\n\n              step_apply_divergent_pivot_result:\n                action: \"Adopt a successful read-only review direction or fail closed to the existing synthesis path\"\n                branch_on: \"pivot_result.status\"\n                if_completed:\n                  set:\n                    next_dimension: \"{pivot_result.restoredFocus}\"\n                    pivot_lineage: \"Pivot {pivot_result.pivotId} selected {pivot_result.selectedCandidate.id} from source iteration {current_iteration}.\"\n                    saturated_directions: \"{pivot_result.completedEvent.saturatedDirections}\"\n                  command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg}\"\n                  log: \"Divergent review pivot {pivot_result.pivotId} restored focus to {pivot_result.restoredFocus}; continuing iteration {current_iteration}.\"\n                  proceed_to: step_normalize_pause_events\n                if_failed:\n                  log: \"Divergent review pivot {pivot_result.pivotId} failed closed ({pivot_result.failureReason}); proceeding to synthesis.\"\n                  skip_to: phase_synthesis\n            on_error:\n              log: \"Divergent review pivot integration error; failing closed to the existing synthesis path.\"\n              skip_to: phase_synthesis\n          if_existing_terminal_path:\n            log: \"Loop stopping. Reason: {reason}\"\n            skip_to: phase_synthesis\n        if_blocked:\n          log: \"Legal-stop gates blocked STOP. Failed gates: {blocked_by_csv}. Continuing review.\"\n        if_stuck_recovery:\n          log: \"Stuck detected ({stuck_count} consecutive no-progress). Entering recovery.\"\n          recovery_strategies:\n            - \"Change granularity: file-level → function-level → line-level review\"\n            - \"Traceability protocol replay: re-run unresolved core or overlay checks\"\n            - \"Escalate severity review: re-examine P2 findings for potential P1 upgrades\"\n          pivot_target: \"Pivot to the least-covered dimension (the review dimension with the fewest iteration passes and lowest coverage ratio).\"\n          set:\n            next_dimension: \"RECOVERY: {recovery_strategy}. Least-covered dimension: {least_explored}\"\n            pending_stop_event: \"stuck_recovery\"\n            pending_stop_reason: \"stuckRecovery\"\n            pending_stop_detail: \"Recovery path activated after repeated no-progress iterations\"\n          reset: { stuck_count: 0 }\n        if_continue:\n          log: \"Iteration {current_iteration}: Continuing. Dimension: {next_dimension}\"\n\n      step_normalize_pause_events:\n        action: \"Rewrite raw pause and recovery events to the frozen STOP_REASONS enum at emission time: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused\"\n        if_pending_pause_event:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"userPaused\",\"mode\":\"review\",\"stopReason\":\"userPaused\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          message: \"Review paused. Delete review/.deep-review-pause to resume.\"\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n          halt: true\n        if_pending_stuck_recovery:\n          append_jsonl: '{\"type\":\"event\",\"event\":\"stuckRecovery\",\"mode\":\"review\",\"stopReason\":\"stuckRecovery\",\"fromIteration\":{current_iteration},\"strategy\":\"{recovery_strategy}\",\"targetDimension\":\"{least_explored}\",\"outcome\":\"pending\",\"reason\":\"{pending_stop_detail}\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          reset:\n            pending_stop_event: null\n            pending_stop_reason: null\n            pending_stop_detail: null\n        if_no_pending_event:\n          proceed: true\n\n      step_generate_state_summary:\n        action: \"Generate compact state summary for dispatch context (~200 tokens)\"\n        generate: |\n          STATE SUMMARY (auto-generated):\n          Iteration: {current_iteration} of {max_iterations}\n          Dimension: {next_dimension}\n          Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n          Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n          Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n          {resource_map_prompt_line}\n          Coverage Age: {coverage_age}\n          Last 2 ratios: {ratio_prev} -> {ratio_latest}\n          Stuck count: {stuck_count}\n          Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n\n      step_marker_scan:\n        action: \"H-2 loop-prevention guard: scan previous iteration's rendered prompt for nested review marker\"\n        algorithm: |\n          if current_iteration > 1:\n            PREV_PROMPT_PATH = \"{state_paths.prompt_dir}/iteration-{previous_iteration}.md\"\n            if file_exists(PREV_PROMPT_PATH):\n              PREV_PROMPT_FIRST_LINE = head -1 of PREV_PROMPT_PATH\n              if PREV_PROMPT_FIRST_LINE matches ^(DEEP-REVIEW|DEEP-RESEARCH|CODE-REVIEW)$:\n                log \"ERROR: nested review-of-review loop detected (marker found in previous iteration prompt). Aborting.\"\n                halt with exit code 2\n        note: |\n          False-positive prevention: only matches when the first line is exactly one of the\n          three canonical markers. Markers appearing in comments or body text are ignored.\n          True-positive triggers only when a previous iteration's rendered prompt literally\n          starts with a deep-loop marker, indicating a nested review-of-review dispatch.\n\n      step_dispatch_iteration:\n        action: \"Dispatch @deep-review agent for one review iteration\"\n        resolve_executor:\n          source: \"config.executor\"\n          loader: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts#parseExecutorConfig\"\n        pre_dispatch:\n          generate_summary: |\n            STATE SUMMARY (auto-generated):\n            Iteration: {current_iteration} of {max_iterations}\n            Dimension: {next_dimension}\n            Prior Findings: P0={p0_count} P1={p1_count} P2={p2_count}\n            Dimension Coverage: {dimensions_covered_list} ({dimension_coverage})\n            Traceability: core={core_protocol_status} overlay={overlay_protocol_status}\n            {resource_map_prompt_line}\n            Coverage Age: {coverage_age}\n            Last 2 ratios: {ratio_prev} -> {ratio_latest}\n            Stuck count: {stuck_count}\n            Provisional Verdict: {PASS|CONDITIONAL|FAIL|PENDING} hasAdvisories={has_advisories}\n          render_prompt_pack:\n            template_path: \".opencode/skills/system-deep-loop/deep-review/assets/prompt_pack_iteration.md.tmpl\"\n            renderer: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts#renderPromptPack\"\n            output_path: \"{state_paths.prompt_dir}/iteration-{current_iteration}.md\"\n            variables:\n              state_summary: \"{state_summary}\"\n              current_iteration: \"{current_iteration}\"\n              max_iterations: \"{max_iterations}\"\n              next_dimension: \"{next_dimension}\"\n              review_target: \"{review_target}\"\n              review_scope_files: \"{review_scope_files}\"\n              p0_count: \"{p0_count}\"\n              p1_count: \"{p1_count}\"\n              p2_count: \"{p2_count}\"\n              pivot_lineage: \"{pivot_lineage}\"\n              saturated_directions: \"{saturated_directions}\"\n              state_paths_config: \"{state_paths.config}\"\n              state_paths_state_log: \"{state_paths.state_log}\"\n              state_paths_findings_registry: \"{state_paths.findings_registry}\"\n              state_paths_strategy: \"{state_paths.strategy}\"\n              state_paths_iteration_pattern: \"{state_paths.iteration_pattern}\"\n              state_paths_delta_pattern: \"{state_paths.delta_pattern}\"\n        pre_dispatch_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          call: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts#writeFirstRecordExecutor\"\n          args:\n            stateLogPath: \"{state_paths.state_log}\"\n            executor: \"{config.executor}\"\n            iteration: \"{current_iteration}\"\n        branch_on: \"config.executor.kind\"\n        if_native:\n          dispatch:\n            agent: deep-review\n            model: opus\n            context_source: \"rendered_prompt_pack\"\n          wait_for_completion: true\n        if_cli_copilot:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync, writeFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n            import { buildCopilotPromptArg } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-config.ts';\n\n            const promptPath = '{state_paths.prompt_dir}/iteration-{current_iteration}.md';\n            const prompt = readFileSync(promptPath, 'utf8');\n\n            // Workflow-resolved spec folder is the only legal write authority.\n            // The helper (`validateSpecFolder` inside `buildCopilotPromptArg`)\n            // is the single source of truth for rejecting empty / unresolved\n            // template / whitespace-only / string-coerced empty values. The\n            // YAML hands the raw `{spec_folder}` directly; on rejection the\n            // helper safe-fails to `type:\"missing\", writeIntent:true` (Gate-3\n            // enforcement, --allow-all-tools stripped).\n            const specFolderRaw = '{spec_folder}';\n            const targetAuthority = { type: 'approved', specFolder: specFolderRaw };\n\n            const baseArgs = [\n              '-p',\n              prompt,\n              '--model',\n              '{config.executor.model}',\n              '--allow-all-tools',\n              '--no-ask-user',\n            ];\n\n            const built = buildCopilotPromptArg({\n              promptPath,\n              prompt,\n              targetAuthority,\n              baseArgv: baseArgs,\n            });\n\n            // Large-prompt @PROMPT_PATH wrapper: helper emits a `promptFileBody`\n            // containing `<TARGET AUTHORITY preamble>\\n\\n---\\n\\n<original>`.\n            // Write it to disk so the file Copilot reads via @path opens with\n            // the authority block. Without this, recovered/bootstrap folder\n            // mentions inside the file could still anchor the model.\n            if (built.promptFileBody !== undefined) {\n              writeFileSync(promptPath, built.promptFileBody, 'utf8');\n            }\n\n            // Copilot is routed through the audited executor wrapper so it produces\n            // INTENT + COMPLETION dispatch receipts alongside claude-code/opencode\n            // There is no cli-copilot kind in the executor schema, so it\n            // dispatches as kind:'native' (full env passthrough, no recursion-guard\n            // layer configured for copilot); the receipt still records the real\n            // 'copilot' command + built.argv as facts.\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'copilot',\n                args: built.argv,\n                cwd: '{repo_root}',\n                timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n                stateLogPath: '{state_paths.state_log}',\n                executor: {\n                  kind: 'native',\n                  model: '{config.executor.model}',\n                  configDir: null,\n                  reasoningEffort: null,\n                  serviceTier: null,\n                  sandboxMode: null,\n                  timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n                  governor: null,\n                },\n                iteration: Number('{current_iteration}'),\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so copilot produces INTENT + COMPLETION dispatch receipts; built.argv (@PROMPT_PATH or positional) is forwarded verbatim as the receipt facts\"\n            - \"copilot has no stdin support; prompt is positional\"\n            - \"Size check uses 16KB threshold; above that uses @PROMPT_PATH wrapper prompt\"\n            - \"Large-prompt path relies on copilot honoring @path references within its prompt string\"\n            - \"buildCopilotPromptArg attaches a TARGET AUTHORITY preamble bound to the workflow-approved spec folder; recovered context cannot override it (authority guard source: .opencode/commands/speckit/assets/speckit_deep-review_auto.yaml)\"\n            - \"If spec_folder is missing/malformed/unresolved on a write-intent dispatch, the helper enforces plan-only by replacing the prompt with a Gate-3 question and stripping --allow-all-tools\"\n            - \"Large-prompt wrapper mode rewrites the prompt file at promptPath to include the TARGET AUTHORITY preamble (prefix + divider + original body); the argv becomes a bare @promptPath reference\"\n        if_cli_claude_code:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            const configDir = '{optional_claude_config_dir}';\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-claude-code',\n              model: '{config.executor.model}',\n              configDir: configDir || null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const args = [\n              '-p',\n              readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8'),\n              '--model',\n              executor.model,\n              '--permission-mode',\n              'acceptEdits',\n              '--output-format',\n              'text',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--effort', executor.reasoningEffort);\n            }\n\n            // CLAUDE_CONFIG_DIR rides through guardContext.env; the CLAUDE_ prefix is\n            // on the cli-claude-code env allowlist so buildExecutorDispatchEnv admits it.\n            const parentEnv = { ...process.env };\n            if (configDir) {\n              parentEnv.CLAUDE_CONFIG_DIR = configDir;\n            }\n\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'claude',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                guardContext: { env: parentEnv },\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          render_hint:\n            optional_claude_config_dir: |\n              If config.executor.configDir is set and non-null, expand a leading ~ to HOME and bind that path.\n              Otherwise expand to empty string.\n          notes:\n            - \"Routed through runAuditedExecutorCommand so claude-code produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"CLAUDE_CONFIG_DIR is forwarded through guardContext.env (CLAUDE_ prefix is allowlisted) so account-specific Claude Code routing is preserved\"\n            - \"permission-mode stays acceptEdits (review's existing iteration-write behavior); claude-code has no serviceTier flag\"\n            - \"claude-code supports --effort for reasoning depth\"\n        if_cli_opencode:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { execFileSync } from 'node:child_process';\n            import { appendFileSync, readFileSync, realpathSync } from 'node:fs';\n            import { createHash } from 'node:crypto';\n            import { isAbsolute, relative, resolve } from 'node:path';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const executor = {\n              kind: 'cli-opencode',\n              model: '{config.executor.model}',\n              configDir: null,\n              reasoningEffort,\n              serviceTier: null,\n              sandboxMode: null,\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n            if (!promptBody.includes('BANNED OPERATIONS') || !promptBody.includes('ALLOWED WRITE PATHS')) {\n              throw new Error('Unsafe cli-opencode dispatch: rendered prompt is missing required write-containment sections');\n            }\n\n            const repoRoot = realpathSync('{repo_root}');\n            const artifactDir = resolve(repoRoot, '{state_paths.packet_dir}');\n            const artifactRelative = relative(repoRoot, artifactDir);\n            if (artifactRelative === '' || artifactRelative.startsWith('..') || isAbsolute(artifactRelative)) {\n              throw new Error('Unsafe cli-opencode dispatch: artifact directory must be a strict descendant of the worktree root');\n            }\n\n            const git = (args, cwd = repoRoot, trim = true) => {\n              const output = execFileSync('git', args, { cwd, encoding: 'utf8' });\n              return trim ? output.trim() : output;\n            };\n            const resolveGitPath = (candidate) => realpathSync(isAbsolute(candidate) ? candidate : resolve(repoRoot, candidate));\n            const gitDir = resolveGitPath(git(['rev-parse', '--git-dir']));\n            const commonGitDir = resolveGitPath(git(['rev-parse', '--git-common-dir']));\n            if (gitDir === commonGitDir) {\n              throw new Error('Unsafe cli-opencode dispatch: --dir must point at an isolated linked worktree');\n            }\n\n            const primaryBlock = git(['worktree', 'list', '--porcelain'])\n              .split(/\\n\\n+/)\n              .find((block) => /^branch refs\\/heads\\/(?:main|master)$/m.test(block));\n            const primaryLine = primaryBlock?.split('\\n').find((line) => line.startsWith('worktree '));\n            if (!primaryLine) {\n              throw new Error('Unsafe cli-opencode dispatch: primary main/master worktree could not be resolved');\n            }\n            const primaryRoot = realpathSync(primaryLine.slice('worktree '.length));\n            const primaryStatus = git(['status', '--porcelain=v1', '--untracked-files=all'], primaryRoot);\n            if (primaryStatus) {\n              throw new Error('Unsafe cli-opencode dispatch: primary worktree must be clean before unrestricted execution');\n            }\n\n            const dirtyPaths = [\n              ...git(['diff', '--name-only', '-z', 'HEAD', '--'], repoRoot, false).split('\\0'),\n              ...git(['ls-files', '--others', '--exclude-standard', '-z'], repoRoot, false).split('\\0'),\n            ].filter(Boolean);\n            const outsideArtifactDir = dirtyPaths.filter((candidate) => {\n              const candidateRelative = relative(artifactDir, resolve(repoRoot, candidate));\n              return candidateRelative.startsWith('..') || isAbsolute(candidateRelative);\n            });\n            if (outsideArtifactDir.length > 0) {\n              throw new Error(`Unsafe cli-opencode dispatch: worktree changes outside the artifact directory: ${outsideArtifactDir.join(', ')}`);\n            }\n\n            const recoveryBaselineCommit = git(['rev-parse', '--verify', 'HEAD']);\n            appendFileSync(\n              '{state_paths.state_log}',\n              `${JSON.stringify({ type: 'event', event: 'recovery_baseline', mode: 'review', iteration: Number('{current_iteration}'), recoveryBaselineCommit, worktree: repoRoot, timestamp: new Date().toISOString() })}\\n`,\n              'utf8',\n            );\n            const message = 'Resolved route: mode=review; target_agent=@deep-review; execution=single_review_iteration; state_source=externalized_files; do_not_switch_mode=true'\n              + '\\n\\n'\n              + promptBody;\n            const args = [\n              'run',\n              '--model',\n              executor.model,\n              '--format',\n              'json',\n              '--dangerously-skip-permissions',\n              '--pure',\n              '--dir',\n              '{repo_root}',\n            ];\n            if (executor.reasoningEffort) {\n              args.push('--variant', executor.reasoningEffort);\n            }\n            args.push(message);\n\n            const dispatchFacts = {\n              command: 'deep/review',\n              mode: 'review',\n              specFolder: '{spec_folder}',\n              artifactDir: '{state_paths.packet_dir}',\n              iteration: Number('{current_iteration}'),\n              executorKind: '{config.executor.kind}',\n              branchId: '{config.executor.kind}',\n              sessionId: '{session_id}',\n              generation: Number('{generation}'),\n            };\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'opencode',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                // opencode v1.14.39 reads stdin at startup before session creation;\n                // an empty input gives EOF stdin, equivalent to </dev/null.","lineStart":635,"lineEnd":1334,"totalLines":2111,"truncated":true}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1784385657929,"end":1784385657951}},"metadata":{"openai":{"itemId":"fc_0469c5d15e3d3615016a5b9079c5c0819183d407b901537e33"}},"id":"prt_f75ac5bf6001ohONZ4c0z8bNxU","sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","messageID":"msg_f75ac246b001CTHIZaoIVyzeUk"}}
{"type":"tool_use","timestamp":1784385657962,"sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","part":{"type":"tool","tool":"read","callID":"call_Zeu3GGionuOM5UaMN3tETIje","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","offset":960,"limit":190},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs</path>\n<type>file</type>\n<content>\n960:   });\n961: \n962:   return { didWait: true, migrated: loaded.migrated };\n963: }\n964: \n965: async function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n966:   const durationMs = normalizeWaitDurationMs(waitMs);\n967:   if (durationMs <= 0) {\n968:     return { didWait: false };\n969:   }\n970: \n971:   const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n972:   atomicWriteJson(checkpointPath, checkpoint);\n973:   appendFanoutStatusLedger(ledgerPath, {\n974:     event: 'wait_checkpoint_persisted',\n975:     at: checkpoint.updatedAt,\n976:     run_id: runId,\n977:     loop_type: loopType,\n978:     spec_folder: specFolder,\n979:     nextRunAt: checkpoint.nextRunAt,\n980:     remainingDelayMs: checkpoint.remainingDelayMs,\n981:   });\n982: \n983:   await waitUntilCheckpointExpires({\n984:     checkpointPath,\n985:     checkpoint,\n986:     context: { runId, loopType, specFolder },\n987:   });\n988: \n989:   appendFanoutStatusLedger(ledgerPath, {\n990:     event: 'wait_checkpoint_cleared',\n991:     at: new Date().toISOString(),\n992:     run_id: runId,\n993:     loop_type: loopType,\n994:     spec_folder: specFolder,\n995:   });\n996: \n997:   return { didWait: true };\n998: }\n999: \n1000: /**\n1001:  * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n1002:  * The subprocess reads this, loads the skill, and runs the requested stop policy\n1003:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n1004:  */\n1005: function buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n1006:   assertActiveFanoutLoopType(loopType);\n1007:   const skillFile =\n1008:     loopType === 'review'\n1009:       ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n1010:       : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n1011:   const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n1012:   const detachedIntro = lineage.kind === 'cli-opencode'\n1013:     ? [\n1014:         `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n1015:         `Use the separate lineage directory and session id below as the detached state boundary.`,\n1016:         ``,\n1017:       ]\n1018:     : lineage.kind === 'native'\n1019:       ? [\n1020:           `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n1021:           `Use the separate lineage directory and session id below as the detached state boundary.`,\n1022:           ``,\n1023:         ]\n1024:       : [];\n1025:   const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n1026:   const stopPolicy = options.stopPolicy || 'convergence';\n1027:   const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n1028:     ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n1029:     : hasIterationCap\n1030:       ? 'to legal convergence OR config.maxIterations, whichever comes first'\n1031:       : 'to legal convergence';\n1032:   const params = [\n1033:     `  spec_folder: ${specFolder}`,\n1034:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1035:     `  session_id: ${sessionId}`,\n1036:     `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n1037:     `  loop_type: ${loopType}`,\n1038:     `  config.stopPolicy: ${stopPolicy}`,\n1039:   ];\n1040:   if (researchTopic) {\n1041:     // A research lineage's phase_init binds research_topic from this line. Without it a\n1042:     // fan-out research loop has no question to investigate and degrades to an empty topic.\n1043:     // Review loops scope by spec_folder and intentionally pass no topic.\n1044:     params.push(`  research_topic: ${researchTopic}`);\n1045:   }\n1046:   if (hasIterationCap) {\n1047:     params.push(`  config.maxIterations: ${lineage.iterations}`);\n1048:   }\n1049:   if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n1050:     params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n1051:   }\n1052:   // Review lineages scope by spec_folder but the auto-workflow preflight\n1053:   // still requires the same review setup bindings the native command path pre-binds.\n1054:   // Without these, a detached CLI lineage can fail first-run initialization or infer a\n1055:   // different setup contract than native lineages.\n1056:   const setupBindings =\n1057:     loopType === 'review'\n1058:       ? [\n1059:           ``,\n1060:           `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n1061:           `review_target: ${specFolder}`,\n1062:           `review_target_type: spec-folder`,\n1063:           `review_dimensions: all`,\n1064:           `spec_folder: ${specFolder}`,\n1065:           `execution_mode: AUTONOMOUS`,\n1066:           `lineage_mode: auto`,\n1067:           ``,\n1068:         ]\n1069:       : [];\n1070:   return [\n1071:     `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n1072:     ...detachedIntro,\n1073:     ``,\n1074:     `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n1075:     ...params,\n1076:     ...setupBindings,\n1077:     `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n1078:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n1079:     `command; bind artifact_dir directly to the override value.`,\n1080:     ``,\n1081:     `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n1082:     `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n1083:     ``,\n1084:     `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n1085:   ].join('\\n');\n1086: }\n1087: \n1088: function buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n1089:   assertActiveFanoutLoopType(loopType);\n1090:   const maxIterations = lineage.iterations || 12;\n1091:   const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n1092:   const stopPolicy = options.stopPolicy || 'convergence';\n1093:   const sessionId = options.sessionId || '';\n1094:   const args = [\n1095:     ':auto',\n1096:     JSON.stringify(specFolder),\n1097:     `--spec-folder=${specFolder}`,\n1098:     `--max-iterations=${maxIterations}`,\n1099:     `--convergence=${convergenceThreshold}`,\n1100:     `--stop-policy=${stopPolicy}`,\n1101:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n1102:     '--lineage-mode=auto',\n1103:   ];\n1104:   if (loopType === 'research' && options.researchTopic) {\n1105:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n1106:   }\n1107: \n1108:   return [\n1109:     args.join(' '),\n1110:     '',\n1111:     'PRE-BOUND SETUP ANSWERS:',\n1112:     `review_target: ${specFolder}`,\n1113:     'review_target_type: spec-folder',\n1114:     'review_dimensions: all',\n1115:     `spec_folder: ${specFolder}`,\n1116:     ...(sessionId ? [`session_id: ${sessionId}`] : []),\n1117:     'execution_mode: AUTONOMOUS',\n1118:     'lineage_mode: auto',\n1119:     `maxIterations: ${maxIterations}`,\n1120:     `convergenceThreshold: ${convergenceThreshold}`,\n1121:     `stop_policy: ${stopPolicy}`,\n1122:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n1123:   ].join('\\n');\n1124: }\n1125: \n1126: // Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n1127: // ceiling and a positive override may only narrow it, never widen past it.\n1128: const LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n1129: \n1130: function assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n1131:   if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n1132:     throw inputError(\n1133:       `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n1134:         + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n1135:     );\n1136:   }\n1137: }\n1138: \n1139: /**\n1140:  * Compute a generous timeout for a full lineage loop run.\n1141:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n1142:  * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n1143:  * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n1144:  */\n1145: function computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n1146:   assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n1147:   const iters = lineage.iterations || 12;\n1148:   const perIterSecs = lineage.timeoutSeconds || 900;\n1149:   const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0\n\n(Showing lines 960-1149 of 2021. Use offset=1150 to continue.)\n</content>","metadata":{"preview":"  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","text":"  });\n\n  return { didWait: true, migrated: loaded.migrated };\n}\n\nasync function persistPreDispatchWait({ checkpointPath, ledgerPath, runId, loopType, specFolder, waitMs }) {\n  const durationMs = normalizeWaitDurationMs(waitMs);\n  if (durationMs <= 0) {\n    return { didWait: false };\n  }\n\n  const checkpoint = buildWaitCheckpoint({ waitMs: durationMs, runId, loopType, specFolder });\n  atomicWriteJson(checkpointPath, checkpoint);\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_persisted',\n    at: checkpoint.updatedAt,\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n    nextRunAt: checkpoint.nextRunAt,\n    remainingDelayMs: checkpoint.remainingDelayMs,\n  });\n\n  await waitUntilCheckpointExpires({\n    checkpointPath,\n    checkpoint,\n    context: { runId, loopType, specFolder },\n  });\n\n  appendFanoutStatusLedger(ledgerPath, {\n    event: 'wait_checkpoint_cleared',\n    at: new Date().toISOString(),\n    run_id: runId,\n    loop_type: loopType,\n    spec_folder: specFolder,\n  });\n\n  return { didWait: true };\n}\n\n/**\n * Build the \"run the full loop\" prompt text for a CLI lineage subprocess.\n * The subprocess reads this, loads the skill, and runs the requested stop policy\n * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n */\nfunction buildLoopPrompt(loopType, specFolder, lineageDir, sessionId, lineage, researchTopic, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const skillFile =\n    loopType === 'review'\n      ? '.opencode/skills/system-deep-loop/deep-review/SKILL.md'\n      : '.opencode/skills/system-deep-loop/deep-research/SKILL.md';\n  const agentName = loopType === 'review' ? 'deep-review' : 'deep-research';\n  const detachedIntro = lineage.kind === 'cli-opencode'\n    ? [\n        `This is an explicit parallel-detached OpenCode lineage, not a self-invocation of the parent session.`,\n        `Use the separate lineage directory and session id below as the detached state boundary.`,\n        ``,\n      ]\n    : lineage.kind === 'native'\n      ? [\n          `This is an explicit native fan-out adapter running through the command host's OpenCode CLI surface.`,\n          `Use the separate lineage directory and session id below as the detached state boundary.`,\n          ``,\n        ]\n      : [];\n  const hasIterationCap = typeof lineage.iterations === 'number' && lineage.iterations > 0;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const stopClause = hasIterationCap && stopPolicy === 'max-iterations'\n    ? 'until config.maxIterations is reached; treat convergence before that as telemetry only and broaden review angles instead of synthesizing early'\n    : hasIterationCap\n      ? 'to legal convergence OR config.maxIterations, whichever comes first'\n      : 'to legal convergence';\n  const params = [\n    `  spec_folder: ${specFolder}`,\n    `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n    `  session_id: ${sessionId}`,\n    `  executor: ${lineage.kind} model=${lineage.model || 'default'}`,\n    `  loop_type: ${loopType}`,\n    `  config.stopPolicy: ${stopPolicy}`,\n  ];\n  if (researchTopic) {\n    // A research lineage's phase_init binds research_topic from this line. Without it a\n    // fan-out research loop has no question to investigate and degrades to an empty topic.\n    // Review loops scope by spec_folder and intentionally pass no topic.\n    params.push(`  research_topic: ${researchTopic}`);\n  }\n  if (hasIterationCap) {\n    params.push(`  config.maxIterations: ${lineage.iterations}`);\n  }\n  if (options.convergenceThreshold !== null && options.convergenceThreshold !== undefined) {\n    params.push(`  config.convergenceThreshold: ${options.convergenceThreshold}`);\n  }\n  // Review lineages scope by spec_folder but the auto-workflow preflight\n  // still requires the same review setup bindings the native command path pre-binds.\n  // Without these, a detached CLI lineage can fail first-run initialization or infer a\n  // different setup contract than native lineages.\n  const setupBindings =\n    loopType === 'review'\n      ? [\n          ``,\n          `Review setup bindings (emit before any writes, same as native PRE-BOUND SETUP ANSWERS):`,\n          `review_target: ${specFolder}`,\n          `review_target_type: spec-folder`,\n          `review_dimensions: all`,\n          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are orchestrating the ${agentName} workflow YAML as a detached fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  assertActiveFanoutLoopType(loopType);\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? (loopType === 'research' ? 0.05 : 0.1);\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const sessionId = options.sessionId || '';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    ...(sessionId ? [`session_id: ${sessionId}`] : []),\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n// Full-lineage lifetime is non-disableable in autonomous mode: 4 hours is the hard\n// ceiling and a positive override may only narrow it, never widen past it.\nconst LINEAGE_LIFETIME_HARD_MAX_HOURS = 4;\n\nfunction assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride) {\n  if (Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > LINEAGE_LIFETIME_HARD_MAX_HOURS) {\n    throw inputError(\n      `lineageTimeoutHours override (${ceilingHoursOverride}) exceeds the hard maximum of `\n        + `${LINEAGE_LIFETIME_HARD_MAX_HOURS} hours`,\n    );\n  }\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours. A caller-provided ceiling override may only\n * narrow this hard ceiling, never widen it — full-lineage lifetime is non-disableable.\n */\nfunction computeLineageTimeoutMs(lineage, ceilingHoursOverride) {\n  assertLineageTimeoutHoursOverrideWithinCeiling(ceilingHoursOverride);\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  const ceilingMs = Number.isFinite(ceilingHoursOverride) && ceilingHoursOverride > 0","lineStart":960,"lineEnd":1149,"totalLines":2021,"truncated":true}},"title":".opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs","time":{"start":1784385657941,"end":1784385657959}},"metadata":{"openai":{"itemId":"fc_0469c5d15e3d3615016a5b9079c5e0819190a5938ff4ada357"}},"id":"prt_f75ac5c52001nOpd1IytnA2BI2","sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","messageID":"msg_f75ac246b001CTHIZaoIVyzeUk"}}
{"type":"tool_use","timestamp":1784385657963,"sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","part":{"type":"tool","tool":"read","callID":"call_ROMtbxH3YmsHzoEQUViEdRCL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","offset":1335,"limit":750},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml</path>\n<type>file</type>\n<content>\n1335:                 input: '',\n1336:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1337:                 dispatchId,\n1338:               }),\n1339:             );\n1340:             EOF\n1341:           working_directory: \"{repo_root}\"\n1342:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1343:           wait_for_completion: true\n1344:           notes:\n1345:             - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n1346:             - \"Fail closed before dispatch unless the rendered containment sections exist, --dir is an isolated linked worktree, the primary worktree is clean, and current-worktree changes are confined to artifact_dir; append the recovery-baseline commit to state_log\"\n1347:             - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n1348:             - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n1349:             - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n1350:             - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n1351:             - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n1352:         if_cli_codex:\n1353:           command: |\n1354:             node --experimental-strip-types --input-type=module <<'EOF'\n1355:             import { readFileSync } from 'node:fs';\n1356:             import { execFileSync } from 'node:child_process';\n1357: \n1358:             import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n1359: \n1360:             // Fail closed: a requested codex executor must dispatch codex or abort,\n1361:             // never silently degrade to another executor. Undetected absence is what\n1362:             // got Codex deprecated before, so the branch exits non-zero when the\n1363:             // binary is missing instead of falling through to a native/other path.\n1364:             let codexAvailable = false;\n1365:             try {\n1366:               execFileSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], { stdio: 'ignore' });\n1367:               codexAvailable = true;\n1368:             } catch {}\n1369:             if (!codexAvailable) {\n1370:               console.error('cli-codex executor unavailable: command -v codex failed');\n1371:               process.exit(1);\n1372:             }\n1373: \n1374:             const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n1375:             const serviceTier = '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}';\n1376:             const model = '{config.executor.model}' === 'null' ? null : '{config.executor.model}';\n1377:             const executor = {\n1378:               kind: 'cli-codex',\n1379:               model,\n1380:               configDir: null,\n1381:               reasoningEffort,\n1382:               serviceTier,\n1383:               sandboxMode: 'workspace-write',\n1384:               timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n1385:               governor: null,\n1386:             };\n1387: \n1388:             const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n1389: \n1390:             // codex reads the iteration prompt from stdin via the trailing '-'. A review\n1391:             // iteration must WRITE its own iteration file, delta and state record, so the\n1392:             // sandbox is workspace-write — read-only would block those required writes.\n1393:             // approval_policy=never keeps the run non-interactive.\n1394:             const args = ['exec'];\n1395:             if (model) {\n1396:               args.push('--model', model);\n1397:             }\n1398:             args.push('-c', 'model_reasoning_effort=' + (reasoningEffort || 'medium'));\n1399:             if (serviceTier) {\n1400:               args.push('-c', 'service_tier=' + serviceTier);\n1401:             }\n1402:             args.push('-c', 'approval_policy=never', '--sandbox', executor.sandboxMode, '-');\n1403: \n1404:             const dispatchId = 'review-i{current_iteration}-g{generation}';\n1405:             process.exit(\n1406:               runAuditedExecutorCommand({\n1407:                 command: 'codex',\n1408:                 args,\n1409:                 cwd: '{repo_root}',\n1410:                 timeoutSeconds: executor.timeoutSeconds,\n1411:                 stateLogPath: '{state_paths.state_log}',\n1412:                 executor,\n1413:                 iteration: Number('{current_iteration}'),\n1414:                 input: promptBody,\n1415:                 receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n1416:                 dispatchId,\n1417:               }),\n1418:             );\n1419:             EOF\n1420:           working_directory: \"{repo_root}\"\n1421:           timeout_seconds: \"{config.executor.timeoutSeconds}\"\n1422:           wait_for_completion: true\n1423:           notes:\n1424:             - \"Routed through runAuditedExecutorCommand so codex produces INTENT + COMPLETION dispatch receipts; recursion guard (CODEX_SESSION_ID) + env allowlist (CODEX_/OPENAI_/AZURE_OPENAI_) enforced via buildExecutorDispatchEnv\"\n1425:             - \"Fails closed when the codex binary is absent (exit 1) — parity with the fan-out cli-codex lineage guard in fanout-run.cjs; codex routing never degrades to native\"\n1426:             - \"codex exec reads the iteration prompt from stdin via the trailing '-' (input: promptBody); '-c model_reasoning_effort=' maps reasoning depth, default medium; '-c service_tier=' forwarded when configured\"\n1427:             - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n1428:         post_dispatch_validate:\n1429:           validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n1430:           command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n1431:           command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n1432:           assert_exists: \"{state_paths.iteration_pattern}\"\n1433:           assert_appended: \"{state_paths.state_log}\"\n1434:           assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n1435:           route_proof:\n1436:             mode: review\n1437:             target_agent: deep-review\n1438:             agent_definition_loaded: true\n1439:             resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n1440:           dispatchReceipt:\n1441:             receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n1442:             dispatchId: \"review-i{current_iteration}-g{generation}\"\n1443:           assert_canonical_type: \"iteration\"\n1444:           assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n1445:           assert_delta_file_has_iteration_record: true\n1446:           failure_reasons:\n1447:             - iteration_file_missing\n1448:             - iteration_file_empty\n1449:             - jsonl_not_appended\n1450:             - jsonl_missing_fields\n1451:             - jsonl_parse_error\n1452:             - jsonl_wrong_type\n1453:             - delta_file_missing\n1454:             - delta_file_empty\n1455:             - delta_file_missing_iteration_record\n1456:             - executor_missing\n1457:             - dispatch_failure_logged\n1458:             - v2_missing_ledger\n1459:             - v2_uncited_ledger_row\n1460:             - v2_broken_linked_finding\n1461:             - v2_shallow_finding_details\n1462:             - delta_iteration_id_mismatch\n1463:             - state_delta_iteration_mismatch\n1464:             - route_proof_missing\n1465:             - route_proof_mismatch\n1466:           warning_surface:\n1467:             source: \"result.warnings\"\n1468:             action: \"emit schema_advisory canonical conflict event\"\n1469:             severity: \"advisory\"\n1470:             event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n1471:             note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n1472:           on_failure:\n1473:             action: \"emit schema_mismatch canonical conflict event\"\n1474:             redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error (per step_evaluate_results.on_missing_outputs) and continue. Never re-dispatch a given iteration more than once.\"\n1475:             escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n1476:         record_executor_audit:\n1477:           skip_when: \"config.executor.kind == 'native'\"\n1478:           target: \"{state_paths.state_log}\"\n1479:           field: \"executor\"\n1480:           value:\n1481:             kind: \"{config.executor.kind}\"\n1482:             model: \"{config.executor.model}\"\n1483:             reasoningEffort: \"{config.executor.reasoningEffort}\"\n1484:             serviceTier: \"{config.executor.serviceTier}\"\n1485: \n1486:       step_evaluate_results:\n1487:         action: \"Verify iteration outputs and extract metrics\"\n1488:         verify:\n1489:           - file_exists: \"{state_paths.iteration_pattern}\"\n1490:           - jsonl_appended: \"New iteration record in state.jsonl\"\n1491:           - strategy_updated: \"Strategy.md has been modified\"\n1492:         extract:\n1493:           - newFindingsRatio: \"From latest JSONL iteration record\"\n1494:           - findings_count: \"From latest JSONL iteration record\"\n1495:           - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n1496:           - dimensions: \"From latest JSONL iteration record\"\n1497:           - files_reviewed: \"From latest JSONL iteration record\"\n1498:           - status: \"From latest JSONL iteration record\"\n1499:           - reviewed_artifacts: \"From latest JSONL iteration record\"\n1500:           - traceability_checks: \"From latest JSONL iteration record when present\"\n1501:         on_missing_outputs:\n1502:           action: \"Mark iteration as 'error', continue to next\"\n1503:           # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n1504:           # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n1505:           append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n1506: \n1507:       step_post_iteration_claim_adjudication:\n1508:         action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n1509:         verify:\n1510:           - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n1511:           - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n1512:           - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n1513:         on_pass:\n1514:           set:\n1515:             claim_adjudication_passed: true\n1516:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1517:           log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n1518:         on_fail:\n1519:           action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n1520:           set:\n1521:             claim_adjudication_passed: false\n1522:           append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n1523:           log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n1524: \n1525:       step_reduce_review_state:\n1526:         action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n1527:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg}\"\n1528:         read:\n1529:           - \"{state_paths.state_log}\"\n1530:           - \"{state_paths.iteration_pattern}\"\n1531:           - \"{state_paths.findings_registry}\"\n1532:           - \"{state_paths.strategy}\"\n1533:         write:\n1534:           - \"{state_paths.findings_registry}\"\n1535:           - \"{state_paths.dashboard}\"\n1536:           - \"{state_paths.strategy}\"\n1537:         failure_modes:\n1538:           malformed_delta: \"skip + warn\"\n1539:           missing_iteration_file: \"no-op + error\"\n1540:           schema_mismatch: \"reject + conflict event\"\n1541:         guarantee: \"Idempotent for identical inputs\"\n1542:         note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n1543: \n1544:       step_graph_upsert:\n1545:         action: \"Project canonical review coverage plus optional graphEvents into graph nodes and edges, then upsert it\"\n1546:         read:\n1547:           - \"{state_paths.config}\"\n1548:           - \"{state_paths.state_log}\"\n1549:           - \"{state_paths.findings_registry}\"\n1550:         transform: |\n1551:           1. Read the latest iteration JSONL record after reducer completion.\n1552:           2. Seed one stable DIMENSION node for every configured review dimension, falling back to correctness, security, traceability, and maintainability.\n1553:           3. Seed one stable FILE node for every latest-record filesReviewed entry and emit a COVERS edge from each latest-record dimension to each reviewed file.\n1554:           4. Merge optional graphEvents nodes after normalizing type = uppercase(event.kind || event.nodeKind || event.type); keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n1555:           5. Merge optional graphEvents edges after normalizing relation = uppercase(event.relation); keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n1556:           6. Emit nodes as { id, type, name, iteration, metadata } and edges as { id, relation, sourceId, targetId, metadata }, deduplicated by id.\n1557:           7. Discard malformed or unknown optional events without discarding canonical dimension and file coverage.\n1558:         bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n1559:         note: \"Invoke the runtime script directly. Canonical iteration fields provide baseline coverage; graphEvents add richer evidence.\"\n1560:         outputs:\n1561:           - graph_nodes_json: \"JSON array of canonical and optional review graph nodes\"\n1562:           - graph_edges_json: \"JSON array of canonical and optional review graph edges\"\n1563: \n1564:       step_generate_dashboard:\n1565:         action: \"Generate or refresh the review dashboard\"\n1566:         read:\n1567:           - \"{state_paths.state_log}\"\n1568:           - \"{state_paths.findings_registry}\"\n1569:           - \"{state_paths.strategy}\"\n1570:         content: |\n1571:           # Deep Review Dashboard - Session Overview\n1572: \n1573:           Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n1574: \n1575:           ## Status\n1576:           - Review Target: {review_target} ({review_target_type})\n1577:           - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n1578:           - Iteration: {current_iteration} of {max_iterations}\n1579:           - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n1580:           - hasAdvisories: {has_advisories}\n1581: \n1582:           ## Findings Summary\n1583:           | Severity | Count | Trend |\n1584:           |----------|------:|-------|\n1585:           | P0 (Blockers) | {p0_count} | {p0_trend} |\n1586:           | P1 (Required) | {p1_count} | {p1_trend} |\n1587:           | P2 (Suggestions) | {p2_count} | {p2_trend} |\n1588: \n1589:           ## Dimension Coverage\n1590:           | Dimension | Status | Iteration | Findings |\n1591:           |-----------|--------|-----------|----------|\n1592:           | [per dimension from strategy + JSONL] |\n1593: \n1594:           ## Traceability Coverage\n1595:           | Protocol | Level | Status | Findings |\n1596:           |----------|-------|--------|----------|\n1597:           | [per protocol from traceabilityChecks] |\n1598: \n1599:           ## Progress\n1600:           | # | Dimension | Ratio | P0/P1/P2 | Status |\n1601:           |---|-----------|-------|----------|--------|\n1602:           | [per iteration from JSONL] |\n1603: \n1604:           ## Trend\n1605:           - Last 3 ratios: [{ratios}] [{trend}]\n1606:           - Stuck count: {stuck_count}\n1607:           - Gate violations: {guard_violations}\n1608: \n1609:           ## Next Focus\n1610:           {next_dimension}\n1611:         output: \"{state_paths.dashboard}\"\n1612:         note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n1613: \n1614:       step_update_tracking:\n1615:         action: \"Update loop tracking variables\"\n1616:         set:\n1617:           current_iteration: \"{current_iteration + 1}\"\n1618:           p0_count: \"Accumulate from severity_counts\"\n1619:           p1_count: \"Accumulate from severity_counts\"\n1620:           p2_count: \"Accumulate from severity_counts\"\n1621:           stuck_count: |\n1622:             if status == 'thought': unchanged (skip)\n1623:             if status == 'insight': 0 (reset)\n1624:             if newFindingsRatio <= 0.05: stuck_count + 1\n1625:             else: 0\n1626:         log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n1627: \n1628:       step_loop_decision:\n1629:         action: \"Return to step_read_state for next iteration\"\n1630:         goto: step_read_state\n1631: \n1632:   # ═══════════════════════════════════════════════════════════════\n1633:   # PHASE 3: SYNTHESIS\n1634:   # ═══════════════════════════════════════════════════════════════\n1635:   phase_synthesis:\n1636:     purpose: Compile all iteration findings into review/review-report.md\n1637:     steps:\n1638: \n1639:       step_fanout_merge:\n1640:         description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n1641:         skip_when: \"config.fanout is absent\"\n1642:         command: |\n1643:           node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n1644:             --loop-type review \\\n1645:             --artifact-dir {artifact_dir}\n1646:         working_directory: \"{repo_root}\"\n1647:         wait_for_completion: true\n1648:         bind_from_output:\n1649:           p0_count: \"active_p0\"\n1650:           p1_count: \"active_p1\"\n1651:           p2_count: \"active_p2\"\n1652: \n1653:       step_hydrate_summary_metrics:\n1654:         action: \"Hydrate summary metrics before synthesis\"\n1655:         read:\n1656:           - \"{state_paths.config}\"\n1657:           - \"{state_paths.state_log}\"\n1658:           - \"{state_paths.findings_registry}\"\n1659:           - \"{state_paths.strategy}\"\n1660:         extract:\n1661:           - iteration_count: \"Count lines where type === 'iteration'\"\n1662:           - p0_count: \"Total P0 findings across all iterations (deduped)\"\n1663:           - p1_count: \"Total P1 findings across all iterations (deduped)\"\n1664:           - p2_count: \"Total P2 findings across all iterations (deduped)\"\n1665:           - dimensions_covered: \"List of reviewed dimensions\"\n1666:           - dimension_coverage: \"covered / total\"\n1667:           - ac_coverage_signal: \"For spec-folder targets only: if level is 2+ and checklist.md exists and implementation-summary.md is in-progress or later, surface the AC_COVERAGE advisory status; otherwise mark exempt.\"\n1668:           - last_3_summaries: \"Summarize the latest 3 iteration records\"\n1669:           - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n1670: \n1671:       # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n1672:       # - PASS: no P0 or P1 findings (P2-only or clean)\n1673:       # - CONDITIONAL: any P1 findings (no P0)\n1674:       # - FAIL: any P0 findings\n1675:       # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n1676:       step_derive_verdict:\n1677:         action: \"Derive review verdict from accumulated findings\"\n1678:         algorithm: |\n1679:           if p0_count > 0:\n1680:             verdict = \"FAIL\"\n1681:           elif p1_count > 0:\n1682:             verdict = \"CONDITIONAL\"\n1683:           else:\n1684:             verdict = \"PASS\"\n1685:           has_advisories = (verdict == \"PASS\" and p2_count > 0)\n1686:           ac_coverage_signal is advisory while the validation rule is INFO/default-off; include it in synthesis traceability, but do not change the exact verdict enum from this signal alone.\n1687:         outputs:\n1688:           - verdict: \"PASS | CONDITIONAL | FAIL\"\n1689:           - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n1690:           - ac_coverage_signal: \"exempt | disabled | pass | advisory-shortfall\"\n1691:         contract: |\n1692:           Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n1693:           Downstream automation parses this final line via exact string match — do not vary the format.\n1694: \n1695:       step_read_all_iterations:\n1696:         action: \"Read all iteration files and strategy\"\n1697:         read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n1698:         read_also: \"{state_paths.strategy}\"\n1699: \n1700:       step_build_finding_registry:\n1701:         action: \"Build deduplicated finding registry from all iterations\"\n1702:         algorithm: |\n1703:           1. Extract all findings from iteration JSONL delta files\n1704:           2. Compute content_hash for each finding (emission requirement):\n1705:              content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n1706:              Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n1707:           3. Two-tier dedup:\n1708:              PRIMARY: group by content_hash field\n1709:                - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n1710:                - Keep highest severity on duplicates\n1711:              FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n1712:                - Same file:line, multiple dimensions → single finding, multiple dimension tags\n1713:                - Keep highest severity on duplicates\n1714:           4. Track finding lifecycle:\n1715:              - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n1716:              - Record first_seen, upgraded_in, previous_severity for severity changes\n1717:              - Record dimensions array reflecting all dimensions that emitted this finding\n1718:           5. Resolve contradictions:\n1719:              - Findings marked contested across iterations → referee pass\n1720:              - Determine final severity and status\n1721:           6. Count only 'active' findings for totals\n1722:         outputs:\n1723:           - finding_registry: \"Deduplicated list of all findings with metadata\"\n1724:           - active_p0: \"Count of active P0 findings\"\n1725:           - active_p1: \"Count of active P1 findings\"\n1726:           - active_p2: \"Count of active P2 findings\"\n1727: \n1728:       step_adversarial_selfcheck:\n1729:         action: \"Final adversarial self-check on all P0 and P1 findings\"\n1730:         algorithm: |\n1731:           For each active P0/P1 finding:\n1732:             1. Hunter: Re-verify finding against source code (re-read file:line)\n1733:             2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n1734:             3. Referee: Final call — confirm, downgrade, or mark false_positive\n1735:           Update finding_registry with adjudicated results.\n1736: \n1737:       step_emit_resource_map:\n1738:         action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n1739:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg} --emit-resource-map\"\n1740:         read:\n1741:           - \"{state_paths.config}\"\n1742:           - \"{state_paths.delta_dir}/iter-*.jsonl\"\n1743:         write:\n1744:           - \"{state_paths.resource_map_output}\"\n1745:         guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n1746: \n1747:       step_resource_map_coverage_gate:\n1748:         action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n1749:         note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n1750: \n1751:       step_compile_review_report:\n1752:         action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n1753:         instructions: |\n1754:           Create review/review-report.md with the following sections:\n1755: \n1756:           1. **Executive Summary**\n1757:              - Overall verdict: PASS | CONDITIONAL | FAIL\n1758:              - hasAdvisories: true when PASS carries active P2 items\n1759:              - P0/P1/P2 counts (active only)\n1760:              - Review scope summary\n1761: \n1762:           2. **Planning Trigger**\n1763:              - State whether `/speckit:plan` is required\n1764:              - Include a fenced `json` block labeled `Planning Packet`\n1765:              - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n1766:              - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n1767: \n1768:           3. **Active Finding Registry**\n1769:              - Unified registry for active P0/P1/P2 findings\n1770:              - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n1771: \n1772:           4. **Remediation Workstreams**\n1773:              - Ordered action groups: P0 first, then P1, with P2 advisories separated\n1774: \n1775:           5. **Spec Seed**\n1776:              - Concrete seed bullets for follow-on spec updates\n1777: \n1778:           6. **Plan Seed**\n1779:              - Concrete starter tasks for `/speckit:plan`\n1780: \n1781:            7. **Traceability Status**\n1782:               - Summarize required core protocols first, then applicable overlay protocols\n1783:               - Include status, evidence, and any unresolved drift per protocol\n1784:               - Include `AC_COVERAGE` status for lifecycle-active spec-folder targets: exempt, disabled, pass, or advisory-shortfall, with covered/total and floor when available\n1785: \n1786:           If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n1787:              - `Entries touched`: count of resource-map paths that appear in applied reports\n1788:              - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n1789:              - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n1790: \n1791:           8. **Deferred Items**\n1792:              - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n1793: \n1794:           **Dimension Expansion Map**\n1795:              - Insert `## Dimension Expansion Map` after Deferred Items and before Search Ledger.\n1796:              - Render reducer-owned `divergence.saturatedDirections`, completed pivots, failed pivots, audited overrides, Council artifact references, selected review directions, and remaining frontier.\n1797:              - This section records breadth only. It cannot alter the Executive Summary verdict, hasAdvisories, finding registry, or adversarial self-check results.\n1798: \n1799:           9. **Search Ledger**\n1800:              - Always include this section before the appendix.\n1801:              - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n1802:              - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n1803:              - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n1804: \n1805:           10. **Audit Appendix**\n1806:              - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n1807:              - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n1808: \n1809:           Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n1810:         output: \"{state_paths.review_output}\"\n1811: \n1812:       step_convergence_report:\n1813:         action: \"Append convergence report to JSONL\"\n1814:         command: |\n1815:           node --input-type=module <<'EOF'\n1816:           import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n1817: \n1818:           const paths = {\n1819:             stateLog: String.raw`{state_paths.state_log}`,\n1820:             registry: String.raw`{state_paths.findings_registry}`,\n1821:             review: String.raw`{state_paths.review_output}`,\n1822:             dashboard: String.raw`{state_paths.dashboard}`,\n1823:           };\n1824: \n1825:           function hasFile(filePath) {\n1826:             try {\n1827:               return existsSync(filePath) && statSync(filePath).isFile();\n1828:             } catch {\n1829:               return false;\n1830:             }\n1831:           }\n1832: \n1833:           function readJson(filePath) {\n1834:             try {\n1835:               return JSON.parse(readFileSync(filePath, 'utf8'));\n1836:             } catch {\n1837:               return null;\n1838:             }\n1839:           }\n1840: \n1841:           function readJsonl(filePath) {\n1842:             if (!hasFile(filePath)) return [];\n1843:             return readFileSync(filePath, 'utf8')\n1844:               .split(/\\r?\\n/)\n1845:               .map((line) => line.trim())\n1846:               .filter(Boolean)\n1847:               .flatMap((line) => {\n1848:                 try {\n1849:                   return [JSON.parse(line)];\n1850:                 } catch {\n1851:                   return [];\n1852:                 }\n1853:               });\n1854:           }\n1855: \n1856:           function countIterationFindings(record) {\n1857:             if (!record || record.type !== 'iteration') return 0;\n1858:             const numeric = Number(record.findingsCount);\n1859:             if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n1860:             if (Array.isArray(record.findingDetails)) return record.findingDetails.length;\n1861:             return 0;\n1862:           }\n1863: \n1864:           function normalizeFindingKey(value) {\n1865:             return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n1866:           }\n1867: \n1868:           function findingKeys(candidate) {\n1869:             if (typeof candidate === 'string') {\n1870:               const key = normalizeFindingKey(candidate);\n1871:               return key ? [key] : [];\n1872:             }\n1873:             if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n1874:             return [...new Set([\n1875:               candidate.id,\n1876:               candidate.findingId,\n1877:               candidate.title,\n1878:               candidate.summary,\n1879:               candidate.text,\n1880:               candidate.finding,\n1881:               candidate.description,\n1882:             ].map(normalizeFindingKey).filter(Boolean))];\n1883:           }\n1884: \n1885:           function collectIterationFindingGroups(record) {\n1886:             if (!record || record.type !== 'iteration' || !Array.isArray(record.findingDetails)) return [];\n1887:             return record.findingDetails\n1888:               .map(findingKeys)\n1889:               .filter((keys) => keys.length > 0);\n1890:           }\n1891: \n1892:           function collectRegistryFindingKeys(registry) {\n1893:             return [registry?.openFindings, registry?.resolvedFindings, registry?.repeatedFindings]\n1894:               .filter(Array.isArray)\n1895:               .flatMap((findings) => findings)\n1896:               .flatMap(findingKeys);\n1897:           }\n1898: \n1899:           function appendEvent(event) {\n1900:             appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n1901:           }\n1902: \n1903:           const registry = readJson(paths.registry);\n1904:           const openCount = Array.isArray(registry?.openFindings) ? registry.openFindings.length : null;\n1905:           const resolvedCount = Array.isArray(registry?.resolvedFindings) ? registry.resolvedFindings.length : 0;\n1906:           const repeatedCount = Array.isArray(registry?.repeatedFindings) ? registry.repeatedFindings.length : 0;\n1907:           const registryFindingCount = openCount === null ? null : openCount + resolvedCount + repeatedCount;\n1908:           const stateRecords = readJsonl(paths.stateLog);\n1909:           const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n1910:           const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n1911:           const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n1912:           const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n1913:           const identifiableFindingCount = identifiableFindingGroups.length;\n1914:           const missingArtifacts = [\n1915:             ['registry', paths.registry],\n1916:             ['review', paths.review],\n1917:             ['dashboard', paths.dashboard],\n1918:           ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n1919:           const invariantFailures = [];\n1920:           if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n1921:           if (registryFindingCount === null) invariantFailures.push('registry_missing_openFindings');\n1922:           if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n1923:           if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n1924:           if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n1925: \n1926:           if (invariantFailures.length > 0) {\n1927:             appendEvent({\n1928:               type: 'event',\n1929:               event: 'synthesis_incomplete',\n1930:               mode: 'review',\n1931:               severity: 'warning',\n1932:               totalIterations: Number('{iteration_count}'),\n1933:               activeP0: Number('{active_p0}'),\n1934:               activeP1: Number('{active_p1}'),\n1935:               activeP2: Number('{active_p2}'),\n1936:               dimensionCoverage: Number('{dimension_coverage}'),\n1937:               verdict: '{verdict}',\n1938:               releaseReadinessState: '{release_readiness_state}',\n1939:               stopReason: '{reason}',\n1940:               reason: 'synthesis_artifact_invariant_failed',\n1941:               invariantFailures,\n1942:               missingArtifacts,\n1943:               registryFindingCount,\n1944:               iterationFindingCount,\n1945:               identifiableFindingCount,\n1946:               missingStructuredFindingCount,\n1947:               timestamp: '{ISO_8601_NOW}',\n1948:             });\n1949:           } else {\n1950:             appendEvent({\n1951:               type: 'event',\n1952:               event: 'synthesis_complete',\n1953:               mode: 'review',\n1954:               totalIterations: Number('{iteration_count}'),\n1955:               activeP0: Number('{active_p0}'),\n1956:               activeP1: Number('{active_p1}'),\n1957:               activeP2: Number('{active_p2}'),\n1958:               dimensionCoverage: Number('{dimension_coverage}'),\n1959:               verdict: '{verdict}',\n1960:               releaseReadinessState: '{release_readiness_state}',\n1961:               stopReason: '{reason}',\n1962:               timestamp: '{ISO_8601_NOW}',\n1963:             });\n1964:           }\n1965:           EOF\n1966:         note: \"Emit as numeric ratio (e.g., 0.75), not quoted string. Compute: dimensions_covered / total_dimensions.\"\n1967: \n1968:       step_update_config_status:\n1969:         action: \"Mark config as complete\"\n1970:         edit: \"{state_paths.config}\"\n1971:         set_field: { status: \"complete\" }\n1972: \n1973:       step_leave_artifacts_unstaged:\n1974:         action: \"Leave all synthesized artifacts unstaged for explicit operator review\"\n1975:         note: \"Synthesis must not mutate the shared Git index. The operator retains staging and commit authority after reviewing the complete artifact directory.\"\n1976: \n1977:   # ═══════════════════════════════════════════════════════════════\n1978:   # PHASE 4: SAVE\n1979:   # ═══════════════════════════════════════════════════════════════\n1980:   phase_save:\n1981:     purpose: Preserve review context to memory system\n1982:     steps:\n1983: \n1984:       step_compose_save_payload:\n1985:         action: \"Compose the structured JSON payload consumed by generate-context.js\"\n1986:         output: \"/tmp/save-context-data-<session-id>.json\"\n1987:         requirements:\n1988:           - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n1989:           - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed review loop.\"\n1990:           - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n1991:         example_payload: |\n1992:           {\n1993:             \"specFolder\": \"{spec_folder}\",\n1994:             \"sessionSummary\": \"Deep review completed; see review/review-report.md for verdict, findings, and workstreams.\",\n1995:             \"observations\": [\"Summarize the active findings, verdict, and remediation guidance.\"],\n1996:             \"recent_context\": [\"Point to the generated review artifacts and next action.\"],\n1997:             \"exchanges\": [],\n1998:             \"toolCalls\": []\n1999:           }\n2000: \n2001:       step_generate_context:\n2002:         action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n2003:         command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n2004:         critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n2005: \n2006:       step_index_memory:\n2007:         action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n2008:         mcp_tool: memory_save\n2009:         invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n2010:         note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n2011: \n2012:       step_verify_save:\n2013:         action: \"Verify canonical save routed content into the correct spec document\"\n2014:         check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n2015:         on_fail: \"Log warning but do not block completion\"\n2016: \n2017:       step_release_lock:\n2018:         action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n2019:         command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n2020:         append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n2021: \n2022:   # ═══════════════════════════════════════════════════════════════\n2023:   # COMPLETION\n2024:   # ═══════════════════════════════════════════════════════════════\n2025:   completion:\n2026:     message: |\n2027:       Deep review complete.\n2028:       Iterations: {iteration_count} | Stop reason: {reason}\n2029:       Findings: P0={active_p0} P1={active_p1} P2={active_p2}\n2030:       Verdict: {verdict} | hasAdvisories={has_advisories}\n2031: \n2032:       Artifacts:\n2033:         - review/review-report.md (compiled from {iteration_count} iterations)\n2034:         - {iteration_count} iteration files in review/iterations/\n2035:         - State files in review/: deep-review-config.json, deep-review-state.jsonl, deep-review-findings-registry.json, deep-review-strategy.md, deep-review-dashboard.md\n2036:         - Memory context saved\n2037: \n2038:       STATUS=OK PATH={spec_folder}\n2039:     next_steps:\n2040:       - \"/speckit:plan [remediation] (if FAIL or CONDITIONAL verdict)\"\n2041:       - \"/create:changelog (if PASS, including PASS with hasAdvisories=true)\"\n2042:       - \"/deep:review [target] (for another review)\"\n2043:       - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n2044: \n2045: # ─────────────────────────────────────────────────────────────────\n2046: # ERROR RECOVERY\n2047: # ─────────────────────────────────────────────────────────────────\n2048: error_recovery:\n2049:   agent_dispatch_timeout: \"Retry once with reduced scope (fewer files per iteration). If second timeout, mark as 'timeout' and continue.\"\n2050:   state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n2051:   consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n2052:   memory_save_failure: \"Preserve the review packet in review/ as backup. Log warning.\"\n2053: \n2054: # ─────────────────────────────────────────────────────────────────\n2055: # RULES\n2056: # ─────────────────────────────────────────────────────────────────\n2057: rules:\n2058:   ALWAYS:\n2059:     - follow_workflow_phases_in_order\n2060:     - dispatch_deep_review_agent_per_iteration\n2061:     - check_convergence_before_each_iteration\n2062:     - write_all_state_to_files\n2063:     - save_memory_context_after_synthesis\n2064:     - respect_max_iterations_cap\n2065:     - treat_review_target_as_read_only\n2066:     - deduplicate_findings_before_synthesis\n2067:     - run_adversarial_selfcheck_on_p0_p1\n2068:   NEVER:\n2069:     - skip_convergence_check\n2070:     - dispatch_non_leaf_agents\n2071:     - hold_iteration_findings_in_memory_only\n2072:     - modify_config_after_initialization\n2073:     - overwrite_jsonl_state_log\n2074:     - proceed_without_state_file_verification\n2075:     - modify_files_under_review\n2076:     - report_p0_without_file_line_evidence\n2077: \n2078: # ─────────────────────────────────────────────────────────────────\n2079: # REFERENCE-ONLY APPENDIX\n2080: # ─────────────────────────────────────────────────────────────────\n2081: reference_only_appendix:\n2082:   checkpoint_commit:\n2083:     note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n2084:     commands:\n\n(Showing lines 1335-2084 of 2111. Use offset=2085 to continue.)\n</content>","metadata":{"preview":"                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"Fail closed before dispatch unless the rendered containment sections exist, --dir is an isolated linked worktree, the primary worktree is clean, and current-worktree changes are confined to artifact_dir; append the recovery-baseline commit to state_log\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        if_cli_codex:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/deep/assets/deep_review_auto.yaml","text":"                input: '',\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so opencode produces INTENT + COMPLETION dispatch receipts; recursion guard + env allowlist enforced via buildExecutorDispatchEnv\"\n            - \"Fail closed before dispatch unless the rendered containment sections exist, --dir is an isolated linked worktree, the primary worktree is clean, and current-worktree changes are confined to artifact_dir; append the recovery-baseline commit to state_log\"\n            - \"input:'' yields closed stdin (EOF), equivalent to </dev/null — opencode v1.14.39 reads stdin at startup and hangs at 0% CPU after +60s snapshot prune without it (the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §4 ALWAYS rule)\"\n            - \"opencode run takes a positional message; prompt is the route-proof preamble + iteration body\"\n            - \"--variant maps reasoningEffort to opencode's provider-specific reasoning lever (e.g., high, medium, minimal)\"\n            - \"--dangerously-skip-permissions enables hands-off automation; sandboxMode='read-only' is not currently honored (no opencode equivalent)\"\n            - \"cli-opencode self-invocation guard: this single-executor branch must only run from a non-OpenCode dispatch surface (Claude Code/raw shell). Explicit parallel-detached cli-opencode fan-out is handled by step_fanout_spawn_cli/fanout-run.cjs, not this branch. the `cli-external-orchestration/cli-opencode` mode's SKILL.md (`.opencode/skills/cli-external-orchestration/cli-opencode/SKILL.md`) §SELF-INVOCATION PROHIBITED contract is the authoritative gate\"\n        if_cli_codex:\n          command: |\n            node --experimental-strip-types --input-type=module <<'EOF'\n            import { readFileSync } from 'node:fs';\n            import { execFileSync } from 'node:child_process';\n\n            import { runAuditedExecutorCommand } from './.opencode/skills/system-deep-loop/runtime/lib/deep-loop/executor-audit.ts';\n\n            // Fail closed: a requested codex executor must dispatch codex or abort,\n            // never silently degrade to another executor. Undetected absence is what\n            // got Codex deprecated before, so the branch exits non-zero when the\n            // binary is missing instead of falling through to a native/other path.\n            let codexAvailable = false;\n            try {\n              execFileSync('/bin/sh', ['-c', 'command -v codex >/dev/null 2>&1'], { stdio: 'ignore' });\n              codexAvailable = true;\n            } catch {}\n            if (!codexAvailable) {\n              console.error('cli-codex executor unavailable: command -v codex failed');\n              process.exit(1);\n            }\n\n            const reasoningEffort = '{config.executor.reasoningEffort}' === 'null' ? null : '{config.executor.reasoningEffort}';\n            const serviceTier = '{config.executor.serviceTier}' === 'null' ? null : '{config.executor.serviceTier}';\n            const model = '{config.executor.model}' === 'null' ? null : '{config.executor.model}';\n            const executor = {\n              kind: 'cli-codex',\n              model,\n              configDir: null,\n              reasoningEffort,\n              serviceTier,\n              sandboxMode: 'workspace-write',\n              timeoutSeconds: Number('{config.executor.timeoutSeconds}'),\n              governor: null,\n            };\n\n            const promptBody = readFileSync('{state_paths.prompt_dir}/iteration-{current_iteration}.md', 'utf8');\n\n            // codex reads the iteration prompt from stdin via the trailing '-'. A review\n            // iteration must WRITE its own iteration file, delta and state record, so the\n            // sandbox is workspace-write — read-only would block those required writes.\n            // approval_policy=never keeps the run non-interactive.\n            const args = ['exec'];\n            if (model) {\n              args.push('--model', model);\n            }\n            args.push('-c', 'model_reasoning_effort=' + (reasoningEffort || 'medium'));\n            if (serviceTier) {\n              args.push('-c', 'service_tier=' + serviceTier);\n            }\n            args.push('-c', 'approval_policy=never', '--sandbox', executor.sandboxMode, '-');\n\n            const dispatchId = 'review-i{current_iteration}-g{generation}';\n            process.exit(\n              runAuditedExecutorCommand({\n                command: 'codex',\n                args,\n                cwd: '{repo_root}',\n                timeoutSeconds: executor.timeoutSeconds,\n                stateLogPath: '{state_paths.state_log}',\n                executor,\n                iteration: Number('{current_iteration}'),\n                input: promptBody,\n                receiptDir: '{state_paths.packet_dir}/dispatch-receipts',\n                dispatchId,\n              }),\n            );\n            EOF\n          working_directory: \"{repo_root}\"\n          timeout_seconds: \"{config.executor.timeoutSeconds}\"\n          wait_for_completion: true\n          notes:\n            - \"Routed through runAuditedExecutorCommand so codex produces INTENT + COMPLETION dispatch receipts; recursion guard (CODEX_SESSION_ID) + env allowlist (CODEX_/OPENAI_/AZURE_OPENAI_) enforced via buildExecutorDispatchEnv\"\n            - \"Fails closed when the codex binary is absent (exit 1) — parity with the fan-out cli-codex lineage guard in fanout-run.cjs; codex routing never degrades to native\"\n            - \"codex exec reads the iteration prompt from stdin via the trailing '-' (input: promptBody); '-c model_reasoning_effort=' maps reasoning depth, default medium; '-c service_tier=' forwarded when configured\"\n            - \"--sandbox workspace-write is required so the iteration can write its own iteration file/delta/state record (read-only would fail the post-dispatch artifact gate); -c approval_policy=never keeps it non-interactive; --model omitted when unset so ~/.codex/config.toml default applies\"\n        post_dispatch_validate:\n          validator: \".opencode/skills/system-deep-loop/runtime/lib/deep-loop/post-dispatch-validate.ts#validateIterationOutputs\"\n          command: \"node .opencode/skills/system-deep-loop/runtime/scripts/verify-iteration.cjs --loop-type review --artifact-dir {artifact_dir} --iteration {current_iteration}\"\n          command_note: \"Mechanical leaf-reliability gate: exit 0 = complete; non-zero prints one machine reason (iteration_file_missing|iteration_verdict_missing|state_record_missing|route_proof_missing|route_proof_mismatch|delta_file_missing). The script enforces the artifact + route-proof contract instead of trusting the leaf to self-report, and a non-zero exit triggers on_failure.redispatch_once.\"\n          assert_exists: \"{state_paths.iteration_pattern}\"\n          assert_appended: \"{state_paths.state_log}\"\n          assert_jsonl_fields: [type, iteration, mode, run, status, focus, dimensions, filesReviewed, findingsCount, findingsSummary, findingsNew, findingDetails, newFindingsRatio, sessionId, generation, lineageMode, timestamp, durationMs]\n          route_proof:\n            mode: review\n            target_agent: deep-review\n            agent_definition_loaded: true\n            resolved_route: \"Resolved route: mode=review target_agent=deep-review\"\n          dispatchReceipt:\n            receiptDir: \"{state_paths.packet_dir}/dispatch-receipts\"\n            dispatchId: \"review-i{current_iteration}-g{generation}\"\n          assert_canonical_type: \"iteration\"\n          assert_delta_file_exists: \"{state_paths.delta_pattern}\"\n          assert_delta_file_has_iteration_record: true\n          failure_reasons:\n            - iteration_file_missing\n            - iteration_file_empty\n            - jsonl_not_appended\n            - jsonl_missing_fields\n            - jsonl_parse_error\n            - jsonl_wrong_type\n            - delta_file_missing\n            - delta_file_empty\n            - delta_file_missing_iteration_record\n            - executor_missing\n            - dispatch_failure_logged\n            - v2_missing_ledger\n            - v2_uncited_ledger_row\n            - v2_broken_linked_finding\n            - v2_shallow_finding_details\n            - delta_iteration_id_mismatch\n            - state_delta_iteration_mismatch\n            - route_proof_missing\n            - route_proof_mismatch\n          warning_surface:\n            source: \"result.warnings\"\n            action: \"emit schema_advisory canonical conflict event\"\n            severity: \"advisory\"\n            event_shape: '{\"type\":\"event\",\"event\":\"schema_advisory\",\"mode\":\"review\",\"iteration\":{current_iteration},\"warnings\":{result.warnings},\"severity\":\"advisory\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n            note: \"Warnings do not fail dispatch. Hard failures still emit schema_mismatch through on_failure.\"\n          on_failure:\n            action: \"emit schema_mismatch canonical conflict event\"\n            redispatch_once: \"On the FIRST failure of the mechanical command check for this iteration, re-run step_dispatch_iteration exactly once for the same iteration number, then re-run the check. If it still fails, record the iteration as error (per step_evaluate_results.on_missing_outputs) and continue. Never re-dispatch a given iteration more than once.\"\n            escalation: \"After 3 consecutive failures across iterations, trigger stuck_recovery event with diagnostic context\"\n        record_executor_audit:\n          skip_when: \"config.executor.kind == 'native'\"\n          target: \"{state_paths.state_log}\"\n          field: \"executor\"\n          value:\n            kind: \"{config.executor.kind}\"\n            model: \"{config.executor.model}\"\n            reasoningEffort: \"{config.executor.reasoningEffort}\"\n            serviceTier: \"{config.executor.serviceTier}\"\n\n      step_evaluate_results:\n        action: \"Verify iteration outputs and extract metrics\"\n        verify:\n          - file_exists: \"{state_paths.iteration_pattern}\"\n          - jsonl_appended: \"New iteration record in state.jsonl\"\n          - strategy_updated: \"Strategy.md has been modified\"\n        extract:\n          - newFindingsRatio: \"From latest JSONL iteration record\"\n          - findings_count: \"From latest JSONL iteration record\"\n          - severity_counts: \"From latest JSONL iteration record (P0, P1, P2)\"\n          - dimensions: \"From latest JSONL iteration record\"\n          - files_reviewed: \"From latest JSONL iteration record\"\n          - status: \"From latest JSONL iteration record\"\n          - reviewed_artifacts: \"From latest JSONL iteration record\"\n          - traceability_checks: \"From latest JSONL iteration record when present\"\n        on_missing_outputs:\n          action: \"Mark iteration as 'error', continue to next\"\n          # Canonical iteration record: include sessionId, generation, durationMs so the reducer can persist\n          # the failure without dropping the iteration. Schema source: state_format.md §Iteration Records.\n          append_jsonl: '{\"type\":\"iteration\",\"iteration\":{current_iteration},\"run\":{current_iteration},\"mode\":\"review\",\"status\":\"error\",\"focus\":\"{next_dimension}\",\"dimensions\":[\"{next_dimension}\"],\"filesReviewed\":[],\"findingsCount\":0,\"findingsSummary\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingDetails\":[],\"traceabilityChecks\":{\"summary\":{\"required\":0,\"executed\":0,\"pass\":0,\"partial\":0,\"fail\":0,\"blocked\":0,\"notApplicable\":0,\"gatingFailures\":0},\"results\":[]},\"newFindingsRatio\":0.0,\"durationMs\":0,\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{config.lineage.sessionId}\",\"generation\":{config.lineage.generation},\"lineageMode\":\"{config.lineage.lineageMode}\"}'\n\n      step_post_iteration_claim_adjudication:\n        action: \"Validate typed claim-adjudication packets for any new P0/P1 findings and persist the result to state.jsonl so the next iteration's claimAdjudicationGate can read it\"\n        verify:\n          - typed_packets_present: \"Every new P0/P1 finding in review/iterations/iteration-{NNN}.md contains a claim-adjudication JSON block\"\n          - packet_fields: \"Each packet includes claim, evidenceRefs, counterevidenceSought, alternativeExplanation, finalSeverity, confidence, downgradeTrigger\"\n          - missing_packet_ids: \"List of new P0/P1 finding IDs that are missing a typed packet or field; empty array when all packets validate\"\n        on_pass:\n          set:\n            claim_adjudication_passed: true\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":true,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":[],\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication passed for iteration {current_iteration}. All new P0/P1 findings have typed packets.\"\n        on_fail:\n          action: \"Mark the iteration as invalid for convergence. The next iteration's claimAdjudicationGate (step_check_convergence step 0) reads the persisted `passed: false` event and vetoes STOP until a follow-up iteration rewrites the packets.\"\n          set:\n            claim_adjudication_passed: false\n          append_jsonl: '{\"type\":\"event\",\"event\":\"claim_adjudication\",\"mode\":\"review\",\"run\":{current_iteration},\"passed\":false,\"activeP0P1\":{active_p0_p1_count},\"missingPackets\":{missing_packet_ids},\"reason\":\"Missing typed packet fields for new P0/P1 findings\",\"timestamp\":\"{ISO_8601_NOW}\",\"sessionId\":\"{session_id}\",\"generation\":{generation}}'\n          log: \"Claim adjudication incomplete for new P0/P1 findings. Event persisted. The next iteration's step_check_convergence claim-adjudication pre-check will veto STOP while `passed: false` remains the latest event and active P0/P1 > 0.\"\n\n      step_reduce_review_state:\n        action: \"Run reducer to refresh the canonical findings registry before dashboard generation\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg}\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.iteration_pattern}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        write:\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.dashboard}\"\n          - \"{state_paths.strategy}\"\n        failure_modes:\n          malformed_delta: \"skip + warn\"\n          missing_iteration_file: \"no-op + error\"\n          schema_mismatch: \"reject + conflict event\"\n        guarantee: \"Idempotent for identical inputs\"\n        note: \"Reducer outputs findingsRegistry, dashboardMetrics, and strategyUpdates. Re-running the same inputs must be idempotent.\"\n\n      step_graph_upsert:\n        action: \"Project canonical review coverage plus optional graphEvents into graph nodes and edges, then upsert it\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n        transform: |\n          1. Read the latest iteration JSONL record after reducer completion.\n          2. Seed one stable DIMENSION node for every configured review dimension, falling back to correctness, security, traceability, and maintainability.\n          3. Seed one stable FILE node for every latest-record filesReviewed entry and emit a COVERS edge from each latest-record dimension to each reviewed file.\n          4. Merge optional graphEvents nodes after normalizing type = uppercase(event.kind || event.nodeKind || event.type); keep only DIMENSION, FILE, FINDING, EVIDENCE, REMEDIATION, BUG_CLASS, INVARIANT, PRODUCER, CONSUMER, TEST.\n          5. Merge optional graphEvents edges after normalizing relation = uppercase(event.relation); keep only COVERS, EVIDENCE_FOR, CONTRADICTS, RESOLVES, CONFIRMS, ESCALATES, IN_DIMENSION, IN_FILE.\n          6. Emit nodes as { id, type, name, iteration, metadata } and edges as { id, relation, sourceId, targetId, metadata }, deduplicated by id.\n          7. Discard malformed or unknown optional events without discarding canonical dimension and file coverage.\n        bash: \"node .opencode/skills/system-deep-loop/runtime/scripts/upsert.cjs --spec-folder \\\"{spec_folder}\\\" --loop-type \\\"review\\\" --session-id \\\"{session_id}\\\" --nodes '{graph_nodes_json}' --edges '{graph_edges_json}'\"\n        note: \"Invoke the runtime script directly. Canonical iteration fields provide baseline coverage; graphEvents add richer evidence.\"\n        outputs:\n          - graph_nodes_json: \"JSON array of canonical and optional review graph nodes\"\n          - graph_edges_json: \"JSON array of canonical and optional review graph edges\"\n\n      step_generate_dashboard:\n        action: \"Generate or refresh the review dashboard\"\n        read:\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        content: |\n          # Deep Review Dashboard - Session Overview\n\n          Auto-generated from JSONL state log and strategy file. Regenerated after every iteration evaluation.\n\n          ## Status\n          - Review Target: {review_target} ({review_target_type})\n          - Status: [ITERATING | CONVERGING | STUCK_RECOVERY | COMPLETE]\n          - Iteration: {current_iteration} of {max_iterations}\n          - Provisional Verdict: [PASS | CONDITIONAL | FAIL | PENDING]\n          - hasAdvisories: {has_advisories}\n\n          ## Findings Summary\n          | Severity | Count | Trend |\n          |----------|------:|-------|\n          | P0 (Blockers) | {p0_count} | {p0_trend} |\n          | P1 (Required) | {p1_count} | {p1_trend} |\n          | P2 (Suggestions) | {p2_count} | {p2_trend} |\n\n          ## Dimension Coverage\n          | Dimension | Status | Iteration | Findings |\n          |-----------|--------|-----------|----------|\n          | [per dimension from strategy + JSONL] |\n\n          ## Traceability Coverage\n          | Protocol | Level | Status | Findings |\n          |----------|-------|--------|----------|\n          | [per protocol from traceabilityChecks] |\n\n          ## Progress\n          | # | Dimension | Ratio | P0/P1/P2 | Status |\n          |---|-----------|-------|----------|--------|\n          | [per iteration from JSONL] |\n\n          ## Trend\n          - Last 3 ratios: [{ratios}] [{trend}]\n          - Stuck count: {stuck_count}\n          - Gate violations: {guard_violations}\n\n          ## Next Focus\n          {next_dimension}\n        output: \"{state_paths.dashboard}\"\n        note: \"Auto-generated from JSONL + strategy. Never manually edited.\"\n\n      step_update_tracking:\n        action: \"Update loop tracking variables\"\n        set:\n          current_iteration: \"{current_iteration + 1}\"\n          p0_count: \"Accumulate from severity_counts\"\n          p1_count: \"Accumulate from severity_counts\"\n          p2_count: \"Accumulate from severity_counts\"\n          stuck_count: |\n            if status == 'thought': unchanged (skip)\n            if status == 'insight': 0 (reset)\n            if newFindingsRatio <= 0.05: stuck_count + 1\n            else: 0\n        log: \"Iteration {N} complete. Dimensions: {dimensions}. newFindingsRatio: {newFindingsRatio}. Findings: P0={severity_counts.P0} P1={severity_counts.P1} P2={severity_counts.P2}. Stuck count: {stuck_count}.\"\n\n      step_loop_decision:\n        action: \"Return to step_read_state for next iteration\"\n        goto: step_read_state\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 3: SYNTHESIS\n  # ═══════════════════════════════════════════════════════════════\n  phase_synthesis:\n    purpose: Compile all iteration findings into review/review-report.md\n    steps:\n\n      step_fanout_merge:\n        description: \"Merge N lineage registries with strongest-restriction; bind p0/p1/p2 counts for step_derive_verdict; skip when single-executor\"\n        skip_when: \"config.fanout is absent\"\n        command: |\n          node .opencode/skills/system-deep-loop/runtime/scripts/fanout-merge.cjs \\\n            --loop-type review \\\n            --artifact-dir {artifact_dir}\n        working_directory: \"{repo_root}\"\n        wait_for_completion: true\n        bind_from_output:\n          p0_count: \"active_p0\"\n          p1_count: \"active_p1\"\n          p2_count: \"active_p2\"\n\n      step_hydrate_summary_metrics:\n        action: \"Hydrate summary metrics before synthesis\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.state_log}\"\n          - \"{state_paths.findings_registry}\"\n          - \"{state_paths.strategy}\"\n        extract:\n          - iteration_count: \"Count lines where type === 'iteration'\"\n          - p0_count: \"Total P0 findings across all iterations (deduped)\"\n          - p1_count: \"Total P1 findings across all iterations (deduped)\"\n          - p2_count: \"Total P2 findings across all iterations (deduped)\"\n          - dimensions_covered: \"List of reviewed dimensions\"\n          - dimension_coverage: \"covered / total\"\n          - ac_coverage_signal: \"For spec-folder targets only: if level is 2+ and checklist.md exists and implementation-summary.md is in-progress or later, surface the AC_COVERAGE advisory status; otherwise mark exempt.\"\n          - last_3_summaries: \"Summarize the latest 3 iteration records\"\n          - reason: \"Use the latest stop reason if present, else the frozen default 'converged'. (Must be a member of the STOP_REASONS enum: converged, maxIterationsReached, blockedStop, stuckRecovery, error, manualStop, userPaused.)\"\n\n      # H-1 verdict derivation: parse findings JSONL, map highest severity to verdict\n      # - PASS: no P0 or P1 findings (P2-only or clean)\n      # - CONDITIONAL: any P1 findings (no P0)\n      # - FAIL: any P0 findings\n      # Final line of iteration-NNN.md MUST be exactly: \"Review verdict: PASS\" / \"Review verdict: CONDITIONAL\" / \"Review verdict: FAIL\"\n      step_derive_verdict:\n        action: \"Derive review verdict from accumulated findings\"\n        algorithm: |\n          if p0_count > 0:\n            verdict = \"FAIL\"\n          elif p1_count > 0:\n            verdict = \"CONDITIONAL\"\n          else:\n            verdict = \"PASS\"\n          has_advisories = (verdict == \"PASS\" and p2_count > 0)\n          ac_coverage_signal is advisory while the validation rule is INFO/default-off; include it in synthesis traceability, but do not change the exact verdict enum from this signal alone.\n        outputs:\n          - verdict: \"PASS | CONDITIONAL | FAIL\"\n          - has_advisories: \"Boolean true when verdict is PASS and any active P2 findings exist\"\n          - ac_coverage_signal: \"exempt | disabled | pass | advisory-shortfall\"\n        contract: |\n          Every iteration-NNN.md must end with exactly: \"Review verdict: PASS\" (or CONDITIONAL or FAIL).\n          Downstream automation parses this final line via exact string match — do not vary the format.\n\n      step_read_all_iterations:\n        action: \"Read all iteration files and strategy\"\n        read_pattern: \"{state_paths.iteration_dir}/iteration-*.md\"\n        read_also: \"{state_paths.strategy}\"\n\n      step_build_finding_registry:\n        action: \"Build deduplicated finding registry from all iterations\"\n        algorithm: |\n          1. Extract all findings from iteration JSONL delta files\n          2. Compute content_hash for each finding (emission requirement):\n             content_hash = sha256(file_path + \"\\u001f\" + line_range + \"\\u001f\" + finding_type + \"\\u001f\" + normalized_description_80chars)\n             Normalized description = whitespace-collapsed, lowercased, first 80 chars of the finding description.\n          3. Two-tier dedup:\n             PRIMARY: group by content_hash field\n               - Same content_hash, multiple dimensions → single finding, merged `dimensions: [<all>]` array\n               - Keep highest severity on duplicates\n             FALLBACK (legacy records lacking content_hash): file:line + normalized_title\n               - Same file:line, multiple dimensions → single finding, multiple dimension tags\n               - Keep highest severity on duplicates\n          4. Track finding lifecycle:\n             - status: active | duplicate | upgraded | downgraded | contested | resolved_false_positive\n             - Record first_seen, upgraded_in, previous_severity for severity changes\n             - Record dimensions array reflecting all dimensions that emitted this finding\n          5. Resolve contradictions:\n             - Findings marked contested across iterations → referee pass\n             - Determine final severity and status\n          6. Count only 'active' findings for totals\n        outputs:\n          - finding_registry: \"Deduplicated list of all findings with metadata\"\n          - active_p0: \"Count of active P0 findings\"\n          - active_p1: \"Count of active P1 findings\"\n          - active_p2: \"Count of active P2 findings\"\n\n      step_adversarial_selfcheck:\n        action: \"Final adversarial self-check on all P0 and P1 findings\"\n        algorithm: |\n          For each active P0/P1 finding:\n            1. Hunter: Re-verify finding against source code (re-read file:line)\n            2. Skeptic: Challenge severity — is this really P0/P1? Could it be P2?\n            3. Referee: Final call — confirm, downgrade, or mark false_positive\n          Update finding_registry with adjudicated results.\n\n      step_emit_resource_map:\n        action: \"Emit {state_paths.resource_map_output} from converged review deltas unless config.resource_map.emit is false\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/reduce-state.cjs {spec_folder} {reducer_artifact_arg} --emit-resource-map\"\n        read:\n          - \"{state_paths.config}\"\n          - \"{state_paths.delta_dir}/iter-*.jsonl\"\n        write:\n          - \"{state_paths.resource_map_output}\"\n        guarantee: \"Reducer skips cleanly when config.resource_map.emit == false and writes a deterministic resource-map when enabled.\"\n\n      step_resource_map_coverage_gate:\n        action: \"If resource_map_present, compute the Resource Map Coverage Gate synthesis inputs; otherwise preserve the skip note\"\n        note: \"Cross-check target_files from {spec_folder}/applied/T-*.md against {spec_folder}/resource-map.md. Report touched entries, untouched entries split into expected-by-scope vs gap, and implementation paths absent from the map. Findings raised here use category resource-map-coverage with severity calibrated to the gate outcome.\"\n\n      step_compile_review_report:\n        action: \"Compile review/review-report.md with 9 core sections, a conditional Resource Map Coverage Gate section, and an embedded Planning Packet\"\n        instructions: |\n          Create review/review-report.md with the following sections:\n\n          1. **Executive Summary**\n             - Overall verdict: PASS | CONDITIONAL | FAIL\n             - hasAdvisories: true when PASS carries active P2 items\n             - P0/P1/P2 counts (active only)\n             - Review scope summary\n\n          2. **Planning Trigger**\n             - State whether `/speckit:plan` is required\n             - Include a fenced `json` block labeled `Planning Packet`\n             - The packet MUST include: `triggered`, `verdict`, `hasAdvisories`, `activeFindings`, `remediationWorkstreams`, `specSeed`, `planSeed`, `findingClasses`, `affectedSurfacesSeed`, `fixCompletenessRequired`\n             - Build `activeFindings`, `findingClasses`, and `affectedSurfacesSeed` from reducer-owned state plus iteration JSONL `findingDetails`; if a field is missing, mark it `UNKNOWN` instead of inferring it from prose\n\n          3. **Active Finding Registry**\n             - Unified registry for active P0/P1/P2 findings\n             - For each: ID, severity, title, dimension, file:line, evidence, impact, fix recommendation, disposition, findingClass, scopeProof, affectedSurfaceHints\n\n          4. **Remediation Workstreams**\n             - Ordered action groups: P0 first, then P1, with P2 advisories separated\n\n          5. **Spec Seed**\n             - Concrete seed bullets for follow-on spec updates\n\n          6. **Plan Seed**\n             - Concrete starter tasks for `/speckit:plan`\n\n           7. **Traceability Status**\n              - Summarize required core protocols first, then applicable overlay protocols\n              - Include status, evidence, and any unresolved drift per protocol\n              - Include `AC_COVERAGE` status for lifecycle-active spec-folder targets: exempt, disabled, pass, or advisory-shortfall, with covered/total and floor when available\n\n          If `resource_map_present` is true, insert **## Resource Map Coverage Gate** after `Traceability Status` with exactly three bullets:\n             - `Entries touched`: count of resource-map paths that appear in applied reports\n             - `Entries not touched`: paths in resource-map not in implementation, labeled `expected-by-scope` or `gap`\n             - `Implementation paths absent from resource-map`: `target_files` in applied reports not on the map\n\n          8. **Deferred Items**\n             - Advisory-only or backlog-worthy follow-ups that do not block the current verdict\n\n          **Dimension Expansion Map**\n             - Insert `## Dimension Expansion Map` after Deferred Items and before Search Ledger.\n             - Render reducer-owned `divergence.saturatedDirections`, completed pivots, failed pivots, audited overrides, Council artifact references, selected review directions, and remaining frontier.\n             - This section records breadth only. It cannot alter the Executive Summary verdict, hasAdvisories, finding registry, or adversarial self-check results.\n\n          9. **Search Ledger**\n             - Always include this section before the appendix.\n             - Render reducer-owned `searchCoverage`, `candidateCoverage`, `searchDebt`, `ruledOutCandidates`, and `cleanSearchProof`.\n             - If all arrays are empty or absent, include: `*No search-depth state captured (legacy v1 record)*`.\n             - When `searchDebt` is non-empty, state `hasSearchDebt: true` and carry the dashboard verdict as CONDITIONAL unless active P0 findings make it FAIL.\n\n          10. **Audit Appendix**\n             - Convergence summary, coverage summary, ruled-out claims, sources reviewed\n             - Cross-reference appendix MUST be split into `Core Protocols` and `Overlay Protocols`\n\n          Preserve machine-owned markers so the reducer-owned registry, dashboard, and strategy anchors can be refreshed on re-run without mutating prior synthesis. (Note: `completed-continue` lineage branch is deferred — see `deep-review/references/protocol/loop_protocol.md §Lifecycle Branches`.)\n        output: \"{state_paths.review_output}\"\n\n      step_convergence_report:\n        action: \"Append convergence report to JSONL\"\n        command: |\n          node --input-type=module <<'EOF'\n          import { appendFileSync, existsSync, readFileSync, statSync } from 'node:fs';\n\n          const paths = {\n            stateLog: String.raw`{state_paths.state_log}`,\n            registry: String.raw`{state_paths.findings_registry}`,\n            review: String.raw`{state_paths.review_output}`,\n            dashboard: String.raw`{state_paths.dashboard}`,\n          };\n\n          function hasFile(filePath) {\n            try {\n              return existsSync(filePath) && statSync(filePath).isFile();\n            } catch {\n              return false;\n            }\n          }\n\n          function readJson(filePath) {\n            try {\n              return JSON.parse(readFileSync(filePath, 'utf8'));\n            } catch {\n              return null;\n            }\n          }\n\n          function readJsonl(filePath) {\n            if (!hasFile(filePath)) return [];\n            return readFileSync(filePath, 'utf8')\n              .split(/\\r?\\n/)\n              .map((line) => line.trim())\n              .filter(Boolean)\n              .flatMap((line) => {\n                try {\n                  return [JSON.parse(line)];\n                } catch {\n                  return [];\n                }\n              });\n          }\n\n          function countIterationFindings(record) {\n            if (!record || record.type !== 'iteration') return 0;\n            const numeric = Number(record.findingsCount);\n            if (Number.isFinite(numeric) && numeric > 0) return Math.floor(numeric);\n            if (Array.isArray(record.findingDetails)) return record.findingDetails.length;\n            return 0;\n          }\n\n          function normalizeFindingKey(value) {\n            return String(value || '').trim().toLowerCase().replace(/\\s+/g, ' ');\n          }\n\n          function findingKeys(candidate) {\n            if (typeof candidate === 'string') {\n              const key = normalizeFindingKey(candidate);\n              return key ? [key] : [];\n            }\n            if (!candidate || typeof candidate !== 'object' || Array.isArray(candidate)) return [];\n            return [...new Set([\n              candidate.id,\n              candidate.findingId,\n              candidate.title,\n              candidate.summary,\n              candidate.text,\n              candidate.finding,\n              candidate.description,\n            ].map(normalizeFindingKey).filter(Boolean))];\n          }\n\n          function collectIterationFindingGroups(record) {\n            if (!record || record.type !== 'iteration' || !Array.isArray(record.findingDetails)) return [];\n            return record.findingDetails\n              .map(findingKeys)\n              .filter((keys) => keys.length > 0);\n          }\n\n          function collectRegistryFindingKeys(registry) {\n            return [registry?.openFindings, registry?.resolvedFindings, registry?.repeatedFindings]\n              .filter(Array.isArray)\n              .flatMap((findings) => findings)\n              .flatMap(findingKeys);\n          }\n\n          function appendEvent(event) {\n            appendFileSync(paths.stateLog, `${JSON.stringify(event)}\\n`, 'utf8');\n          }\n\n          const registry = readJson(paths.registry);\n          const openCount = Array.isArray(registry?.openFindings) ? registry.openFindings.length : null;\n          const resolvedCount = Array.isArray(registry?.resolvedFindings) ? registry.resolvedFindings.length : 0;\n          const repeatedCount = Array.isArray(registry?.repeatedFindings) ? registry.repeatedFindings.length : 0;\n          const registryFindingCount = openCount === null ? null : openCount + resolvedCount + repeatedCount;\n          const stateRecords = readJsonl(paths.stateLog);\n          const iterationFindingCount = stateRecords.reduce((sum, record) => sum + countIterationFindings(record), 0);\n          const identifiableFindingGroups = stateRecords.flatMap(collectIterationFindingGroups);\n          const registryFindingKeys = new Set(collectRegistryFindingKeys(registry));\n          const missingStructuredFindingCount = identifiableFindingGroups.filter((keys) => !keys.some((key) => registryFindingKeys.has(key))).length;\n          const identifiableFindingCount = identifiableFindingGroups.length;\n          const missingArtifacts = [\n            ['registry', paths.registry],\n            ['review', paths.review],\n            ['dashboard', paths.dashboard],\n          ].filter(([, filePath]) => !hasFile(filePath)).map(([name, filePath]) => ({ name, path: filePath }));\n          const invariantFailures = [];\n          if (missingArtifacts.length > 0) invariantFailures.push('missing_synthesis_artifacts');\n          if (registryFindingCount === null) invariantFailures.push('registry_missing_openFindings');\n          if (iterationFindingCount > 0 && (registryFindingCount ?? 0) === 0) invariantFailures.push('state_findings_not_reflected_in_registry');\n          if (identifiableFindingCount > 0 && registryFindingCount !== null && registryFindingCount < identifiableFindingCount) invariantFailures.push('structured_state_findings_partially_reflected_in_registry');\n          if (missingStructuredFindingCount > 0) invariantFailures.push('structured_state_findings_missing_from_registry');\n\n          if (invariantFailures.length > 0) {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_incomplete',\n              mode: 'review',\n              severity: 'warning',\n              totalIterations: Number('{iteration_count}'),\n              activeP0: Number('{active_p0}'),\n              activeP1: Number('{active_p1}'),\n              activeP2: Number('{active_p2}'),\n              dimensionCoverage: Number('{dimension_coverage}'),\n              verdict: '{verdict}',\n              releaseReadinessState: '{release_readiness_state}',\n              stopReason: '{reason}',\n              reason: 'synthesis_artifact_invariant_failed',\n              invariantFailures,\n              missingArtifacts,\n              registryFindingCount,\n              iterationFindingCount,\n              identifiableFindingCount,\n              missingStructuredFindingCount,\n              timestamp: '{ISO_8601_NOW}',\n            });\n          } else {\n            appendEvent({\n              type: 'event',\n              event: 'synthesis_complete',\n              mode: 'review',\n              totalIterations: Number('{iteration_count}'),\n              activeP0: Number('{active_p0}'),\n              activeP1: Number('{active_p1}'),\n              activeP2: Number('{active_p2}'),\n              dimensionCoverage: Number('{dimension_coverage}'),\n              verdict: '{verdict}',\n              releaseReadinessState: '{release_readiness_state}',\n              stopReason: '{reason}',\n              timestamp: '{ISO_8601_NOW}',\n            });\n          }\n          EOF\n        note: \"Emit as numeric ratio (e.g., 0.75), not quoted string. Compute: dimensions_covered / total_dimensions.\"\n\n      step_update_config_status:\n        action: \"Mark config as complete\"\n        edit: \"{state_paths.config}\"\n        set_field: { status: \"complete\" }\n\n      step_leave_artifacts_unstaged:\n        action: \"Leave all synthesized artifacts unstaged for explicit operator review\"\n        note: \"Synthesis must not mutate the shared Git index. The operator retains staging and commit authority after reviewing the complete artifact directory.\"\n\n  # ═══════════════════════════════════════════════════════════════\n  # PHASE 4: SAVE\n  # ═══════════════════════════════════════════════════════════════\n  phase_save:\n    purpose: Preserve review context to memory system\n    steps:\n\n      step_compose_save_payload:\n        action: \"Compose the structured JSON payload consumed by generate-context.js\"\n        output: \"/tmp/save-context-data-<session-id>.json\"\n        requirements:\n          - \"Write this file before invoking generate-context.js; the loader fails closed if the explicit JSON file is absent.\"\n          - \"Include `specFolder`, a concise `sessionSummary`, curated `observations`, `recent_context`, `toolCalls`, and `exchanges` from the completed review loop.\"\n          - \"Use a session-scoped temp filename; do not use the retired shared `/tmp/save-context-data.json` path.\"\n        example_payload: |\n          {\n            \"specFolder\": \"{spec_folder}\",\n            \"sessionSummary\": \"Deep review completed; see review/review-report.md for verdict, findings, and workstreams.\",\n            \"observations\": [\"Summarize the active findings, verdict, and remediation guidance.\"],\n            \"recent_context\": [\"Point to the generated review artifacts and next action.\"],\n            \"exchanges\": [],\n            \"toolCalls\": []\n          }\n\n      step_generate_context:\n        action: \"Route continuity content into the correct canonical spec document via generate-context.js\"\n        command: \"node .opencode/skills/system-spec-kit/scripts/dist/memory/generate-context.js /tmp/save-context-data-<session-id>.json {spec_folder}\"\n        critical_rule: \"NEVER manually author files under retired memory/ paths (the runtime rejects them); use generate-context.js so the save routes into decision-record.md, implementation-summary.md, or handover.md\"\n\n      step_index_memory:\n        action: \"Index the routed canonical spec document with memory_save when immediate MCP visibility is required\"\n        mcp_tool: memory_save\n        invocation: 'memory_save({ filePath: \"[routed-canonical-spec-doc-path]\" })'\n        note: \"Use the actual canonical spec-doc path returned by generate-context.js (decision-record.md, implementation-summary.md, or handover.md); memory_index_scan remains the bulk fallback\"\n\n      step_verify_save:\n        action: \"Verify canonical save routed content into the correct spec document\"\n        check: \"Does {spec_folder}/implementation-summary.md, {spec_folder}/decision-record.md, or {spec_folder}/handover.md carry the new continuity update?\"\n        on_fail: \"Log warning but do not block completion\"\n\n      step_release_lock:\n        action: \"Release the single-writer lock after save, skip-save, or cancellation cleanup has resolved\"\n        command: \"node .opencode/skills/system-deep-loop/runtime/scripts/loop-lock.cjs release --lock-path {state_paths.lock_file} --owner-pid {captured_owner_pid}\"\n        append_to_jsonl: '{\"type\":\"event\",\"event\":\"lock_released\",\"path\":\"{state_paths.lock_file}\",\"releasePhase\":\"save\",\"timestamp\":\"{ISO_8601_NOW}\"}'\n\n  # ═══════════════════════════════════════════════════════════════\n  # COMPLETION\n  # ═══════════════════════════════════════════════════════════════\n  completion:\n    message: |\n      Deep review complete.\n      Iterations: {iteration_count} | Stop reason: {reason}\n      Findings: P0={active_p0} P1={active_p1} P2={active_p2}\n      Verdict: {verdict} | hasAdvisories={has_advisories}\n\n      Artifacts:\n        - review/review-report.md (compiled from {iteration_count} iterations)\n        - {iteration_count} iteration files in review/iterations/\n        - State files in review/: deep-review-config.json, deep-review-state.jsonl, deep-review-findings-registry.json, deep-review-strategy.md, deep-review-dashboard.md\n        - Memory context saved\n\n      STATUS=OK PATH={spec_folder}\n    next_steps:\n      - \"/speckit:plan [remediation] (if FAIL or CONDITIONAL verdict)\"\n      - \"/create:changelog (if PASS, including PASS with hasAdvisories=true)\"\n      - \"/deep:review [target] (for another review)\"\n      - \"/memory:save {spec_folder} (refresh canonical continuity before the next session)\"\n\n# ─────────────────────────────────────────────────────────────────\n# ERROR RECOVERY\n# ─────────────────────────────────────────────────────────────────\nerror_recovery:\n  agent_dispatch_timeout: \"Retry once with reduced scope (fewer files per iteration). If second timeout, mark as 'timeout' and continue.\"\n  state_file_missing: \"If JSONL missing during loop, reconstruct from iteration files. If strategy missing, create minimal version.\"\n  consecutive_failures: \"After 3 consecutive errors, halt loop and enter synthesis with partial findings.\"\n  memory_save_failure: \"Preserve the review packet in review/ as backup. Log warning.\"\n\n# ─────────────────────────────────────────────────────────────────\n# RULES\n# ─────────────────────────────────────────────────────────────────\nrules:\n  ALWAYS:\n    - follow_workflow_phases_in_order\n    - dispatch_deep_review_agent_per_iteration\n    - check_convergence_before_each_iteration\n    - write_all_state_to_files\n    - save_memory_context_after_synthesis\n    - respect_max_iterations_cap\n    - treat_review_target_as_read_only\n    - deduplicate_findings_before_synthesis\n    - run_adversarial_selfcheck_on_p0_p1\n  NEVER:\n    - skip_convergence_check\n    - dispatch_non_leaf_agents\n    - hold_iteration_findings_in_memory_only\n    - modify_config_after_initialization\n    - overwrite_jsonl_state_log\n    - proceed_without_state_file_verification\n    - modify_files_under_review\n    - report_p0_without_file_line_evidence\n\n# ─────────────────────────────────────────────────────────────────\n# REFERENCE-ONLY APPENDIX\n# ─────────────────────────────────────────────────────────────────\nreference_only_appendix:\n  checkpoint_commit:\n    note: \"Checkpoint commits are intentionally excluded from workflow.steps.\"\n    commands:","lineStart":1335,"lineEnd":2084,"totalLines":2111,"truncated":true}},"title":".opencode/commands/deep/assets/deep_review_auto.yaml","time":{"start":1784385657936,"end":1784385657961}},"metadata":{"openai":{"itemId":"fc_0469c5d15e3d3615016a5b9079c5d4819183ea9a66d60221c5"}},"id":"prt_f75ac5c4a001oGOX9R6PID3kMK","sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","messageID":"msg_f75ac246b001CTHIZaoIVyzeUk"}}
{"type":"tool_use","timestamp":1784385658013,"sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","part":{"type":"tool","tool":"read","callID":"call_fM1Q6YhWeJONVd7MeHW9U0dV","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: Deep Review Strategy Template\n3: description: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\n4: trigger_phrases:\n5:   - \"deep review strategy template\"\n6:   - \"review dimension tracking\"\n7:   - \"exhausted review approaches\"\n8:   - \"review session tracking\"\n9: importance_tier: normal\n10: contextType: planning\n11: version: 1.11.0.13\n12: ---\n13: \n14: # Deep Review Strategy - Session Tracking Template\n15: \n16: Runtime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n17: \n18: ## 1. OVERVIEW\n19: \n20: ### Purpose\n21: \n22: Serves as the \"persistent brain\" for a deep review session. Records which dimensions remain, what was found (P0/P1/P2), what review approaches worked or failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n23: \n24: ### Usage\n25: \n26: - **Init:** Orchestrator copies this template to `{artifact_dir}/deep-review-strategy.md` and populates Topic, Review Dimensions, Known Context, and Review Boundaries from config and memory context.\n27: - **Per iteration:** Agent reads Next Focus, reviews the assigned dimension/files, updates findings, marks dimensions complete, and sets new Next Focus.\n28: - **Mutability:** Mutable, updated by both orchestrator and agents throughout the session.\n29: - **Protection:** None (shared mutable state). Orchestrator validates consistency on resume.\n30: - **Ownership:** Machine-managed metrics and coverage blocks are wrapped in explicit ownership markers. Human commentary and operator overrides live outside those markers.\n31: \n32: ---\n33: \n34: ## 2. TOPIC\n35: [Review target description from config -- set during initialization]\n36: \n37: ---\n38: \n39: ## 3. REVIEW DIMENSIONS (remaining)\n40: <!-- MACHINE-OWNED: START -->\n41: - [ ] D1 Correctness, Logic errors, off-by-one, wrong return types, broken invariants\n42: - [ ] D2 Security, Injection, auth bypass, secrets exposure, unsafe deserialization\n43: - [ ] D3 Traceability, Spec/code alignment, checklist evidence, cross-reference integrity\n44: - [ ] D4 Maintainability, Patterns, clarity, documentation quality, safe follow-on change cost\n45: <!-- MACHINE-OWNED: END -->\n46: \n47: ---\n48: \n49: ## 4. NON-GOALS\n50: [What this review session is NOT trying to assess -- populated during initialization]\n51: \n52: ---\n53: \n54: ## 5. STOP CONDITIONS\n55: [Explicit conditions beyond convergence that should end the session -- populated during initialization]\n56: \n57: ---\n58: \n59: ## 6. COMPLETED DIMENSIONS\n60: <!-- MACHINE-OWNED: START -->\n61: [None yet -- populated as iterations complete dimension reviews]\n62: \n63: | Dimension | Verdict | Iteration | Summary |\n64: |-----------|---------|-----------|---------|\n65: | [D1 Correctness] | [PASS/CONDITIONAL/FAIL] | [N] | [1-sentence result] |\n66: <!-- MACHINE-OWNED: END -->\n67: \n68: ---\n69: \n70: ## 7. RUNNING FINDINGS\n71: <!-- MACHINE-OWNED: START -->\n72: - **P0 (Critical):** 0 active\n73: - **P1 (Major):** 0 active\n74: - **P2 (Minor):** 0 active\n75: - **Delta this iteration:** +0 P0, +0 P1, +0 P2\n76: \n77: [Findings are tracked in `deep-review-findings-registry.json`. This section provides a running count summary updated after each iteration.]\n78: <!-- MACHINE-OWNED: END -->\n79: \n80: ---\n81: \n82: ## 8. WHAT WORKED\n83: [First iteration -- populated after iteration 1 completes]\n84: - [Approach]: [Why it worked] (iteration N)\n85: \n86: ---\n87: \n88: ## 9. WHAT FAILED\n89: [First iteration -- populated after iteration 1 completes]\n90: - [Approach]: [Why it failed] (iteration N)\n91: \n92: ---\n93: \n94: ## 10. EXHAUSTED APPROACHES (do not retry)\n95: [Populated when a review approach has been tried from multiple angles without yielding new findings]\n96: \n97: ### [Category Name] -- BLOCKED (iteration N, N attempts)\n98: - What was tried: [specific review approaches attempted]\n99: - Why blocked: [root cause of exhaustion]\n100: - Do NOT retry: [explicit prohibition]\n101: \n102: ### [Category Name] -- PRODUCTIVE (iteration N)\n103: - What worked: [successful review approaches in this category]\n104: - Prefer for: [related dimensions where this category may help]\n105: \n106: ---\n107: \n108: ## 10A. SATURATED / SWEPT DIMENSIONS AND EXPANSION FRONTIER\n109: <!-- MACHINE-OWNED: START -->\n110: - Completed pivots: 0\n111: - Failed pivots: 0\n112: - Audited overrides: 0\n113: - Swept: none yet\n114: - Pivot lineage: none yet\n115: - Remaining frontier: none recorded\n116: <!-- MACHINE-OWNED: END -->\n117: \n118: ---\n119: \n120: ## 11. RULED OUT DIRECTIONS\n121: [Review angles that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n122: - [Approach]: [Why ruled out] (iteration N, evidence: [source])\n123: \n124: ---\n125: \n126: ## 12. NEXT FOCUS\n127: <!-- MACHINE-OWNED: START -->\n128: [Recommended focus area for the next iteration -- updated at end of each iteration. Includes target dimension and/or specific files to review.]\n129: <!-- MACHINE-OWNED: END -->\n130: \n131: ---\n132: \n133: ## 13. KNOWN CONTEXT\n134: [Populated during initialization from memory_context() results, if any prior work exists]\n135: \n136: ### Bounded Context Snapshot\n137: \n138: Populate during initialization before the first review dimension runs. Keep this pointer-based and scoped to the declared review target:\n139: \n140: - Target pointers: files, specs, symbols, or resource-map entries under review.\n141: - Behavior claims: acceptance criteria, public contracts, or docs to verify.\n142: - Reuse and conventions: existing patterns that define expected implementation shape.\n143: - Review risks and gaps: stale graph or memory caveats, missing files, and out-of-scope areas.\n144: \n145: Do not inline full source bodies. Do not dispatch the retired standalone context loop. Use this snapshot only to seed review dimensions and final traceability.\n146: \n147: ---\n148: \n149: ## 14. CROSS-REFERENCE STATUS\n150: <!-- MACHINE-OWNED: START -->\n151: [Alignment checks completed across core and overlay protocols]\n152: \n153: | Protocol | Level | Status | Iteration | Notes |\n154: |----------|-------|--------|-----------|-------|\n155: | `spec_code` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n156: | `checklist_evidence` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n157: | `skill_agent` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n158: | `agent_cross_runtime` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n159: | `feature_catalog_code` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n160: | `playbook_capability` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n161: <!-- MACHINE-OWNED: END -->\n162: \n163: ---\n164: \n165: ## 15. FILES UNDER REVIEW\n166: <!-- MACHINE-OWNED: START -->\n167: [Per-file coverage state table -- populated during initialization from scope discovery]\n168: \n169: | File | Dimensions Reviewed | Last Iteration | Findings | Status |\n170: |------|-------------------|----------------|----------|--------|\n171: | [path/to/file] | [D1, D3] | [N] | [0 P0, 1 P1, 2 P2] | [partial/complete] |\n172: <!-- MACHINE-OWNED: END -->\n173: \n174: ---\n175: \n176: ## 16. REVIEW BOUNDARIES\n177: <!-- MACHINE-OWNED: START -->\n178: - Max iterations: [from config]\n179: - Convergence threshold: [from config]\n180: - Rolling STOP threshold: 0.08\n181: - No-progress threshold: 0.05\n182: - Coverage stabilization passes required: 1\n183: - Session lineage: sessionId=[from config.sessionId], parentSessionId=[from config.parentSessionId], generation=[from config.generation], lineageMode=[from config.lineageMode]\n184: - Findings registry: `deep-review-findings-registry.json`\n185: - Release-readiness states: in-progress | converged | release-blocking\n186: - Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n187: - Severity threshold: [from config.severityThreshold]\n188: - Review target type: [from config.reviewTargetType]\n189: - Cross-reference checks: core=[from config.crossReference.core], overlay=[from config.crossReference.overlay]\n190: - Started: [timestamp]\n191: <!-- MACHINE-OWNED: END -->\n192: \n193: ---\n194: \n195: ## 17. EXAMPLE (POPULATED)\n196: \n197: Reference snippet showing a partially populated strategy file mid-review. Use this as a visual anchor when opening a live strategy doc.\n198: \n199: ```markdown\n200: ## 1. REVIEW CHARTER\n201: - Target: .opencode/skills/system-deep-loop/deep-research (skill, v1.4.0)\n202: - Dimensions: correctness, test-coverage, cross-runtime-parity, observability\n203: - Stop conditions: rolling newInfoRatio < 0.08 for 2 iterations OR all dimensions converged OR max=7 reached\n204: - Success criteria: zero P0 in correctness; test-coverage P0 resolved or deferred with rationale\n205: \n206: ## 4. NEXT FOCUS\n207: - Dimension: test-coverage\n208: - Files: .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs, .opencode/skills/system-spec-kit/scripts/tests/deep-research-contract-parity.vitest.ts\n209: - Why: Iteration 2 surfaced a P0 (convergence-path coverage gap); needs a focused follow-up before correctness can terminate PASS.\n210: \n211: ## 9. COVERAGE MATRIX\n212: | Dimension            | Status     | Iterations touched |\n213: |----------------------|------------|--------------------|\n214: | correctness          | converged  | 1                  |\n215: | test-coverage        | converging | 2, 4               |\n216: | cross-runtime-parity | converging | 3                  |\n217: | observability        | converging | 4                  |\n218: ```\n\n(End of file - total 218 lines)\n</content>","metadata":{"preview":"---\ntitle: Deep Review Strategy Template\ndescription: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\ntrigger_phrases:\n  - \"deep review strategy template\"\n  - \"review dimension tracking\"\n  - \"exhausted review approaches\"\n  - \"review session tracking\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.11.0.13\n---\n\n# Deep Review Strategy - Session Tracking Template\n\nRuntime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n\n## 1. OVERVIEW\n\n### Purpose","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md","text":"---\ntitle: Deep Review Strategy Template\ndescription: Runtime template copied to review/ during initialization to track review progress, dimension coverage, findings, and outcomes across iterations.\ntrigger_phrases:\n  - \"deep review strategy template\"\n  - \"review dimension tracking\"\n  - \"exhausted review approaches\"\n  - \"review session tracking\"\nimportance_tier: normal\ncontextType: planning\nversion: 1.11.0.13\n---\n\n# Deep Review Strategy - Session Tracking Template\n\nRuntime template copied into the resolved `{artifact_dir}/` during initialization. Tracks review progress across iterations.\n\n## 1. OVERVIEW\n\n### Purpose\n\nServes as the \"persistent brain\" for a deep review session. Records which dimensions remain, what was found (P0/P1/P2), what review approaches worked or failed, and where to focus next. Read by the orchestrator and agents at every iteration.\n\n### Usage\n\n- **Init:** Orchestrator copies this template to `{artifact_dir}/deep-review-strategy.md` and populates Topic, Review Dimensions, Known Context, and Review Boundaries from config and memory context.\n- **Per iteration:** Agent reads Next Focus, reviews the assigned dimension/files, updates findings, marks dimensions complete, and sets new Next Focus.\n- **Mutability:** Mutable, updated by both orchestrator and agents throughout the session.\n- **Protection:** None (shared mutable state). Orchestrator validates consistency on resume.\n- **Ownership:** Machine-managed metrics and coverage blocks are wrapped in explicit ownership markers. Human commentary and operator overrides live outside those markers.\n\n---\n\n## 2. TOPIC\n[Review target description from config -- set during initialization]\n\n---\n\n## 3. REVIEW DIMENSIONS (remaining)\n<!-- MACHINE-OWNED: START -->\n- [ ] D1 Correctness, Logic errors, off-by-one, wrong return types, broken invariants\n- [ ] D2 Security, Injection, auth bypass, secrets exposure, unsafe deserialization\n- [ ] D3 Traceability, Spec/code alignment, checklist evidence, cross-reference integrity\n- [ ] D4 Maintainability, Patterns, clarity, documentation quality, safe follow-on change cost\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 4. NON-GOALS\n[What this review session is NOT trying to assess -- populated during initialization]\n\n---\n\n## 5. STOP CONDITIONS\n[Explicit conditions beyond convergence that should end the session -- populated during initialization]\n\n---\n\n## 6. COMPLETED DIMENSIONS\n<!-- MACHINE-OWNED: START -->\n[None yet -- populated as iterations complete dimension reviews]\n\n| Dimension | Verdict | Iteration | Summary |\n|-----------|---------|-----------|---------|\n| [D1 Correctness] | [PASS/CONDITIONAL/FAIL] | [N] | [1-sentence result] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 7. RUNNING FINDINGS\n<!-- MACHINE-OWNED: START -->\n- **P0 (Critical):** 0 active\n- **P1 (Major):** 0 active\n- **P2 (Minor):** 0 active\n- **Delta this iteration:** +0 P0, +0 P1, +0 P2\n\n[Findings are tracked in `deep-review-findings-registry.json`. This section provides a running count summary updated after each iteration.]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 8. WHAT WORKED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it worked] (iteration N)\n\n---\n\n## 9. WHAT FAILED\n[First iteration -- populated after iteration 1 completes]\n- [Approach]: [Why it failed] (iteration N)\n\n---\n\n## 10. EXHAUSTED APPROACHES (do not retry)\n[Populated when a review approach has been tried from multiple angles without yielding new findings]\n\n### [Category Name] -- BLOCKED (iteration N, N attempts)\n- What was tried: [specific review approaches attempted]\n- Why blocked: [root cause of exhaustion]\n- Do NOT retry: [explicit prohibition]\n\n### [Category Name] -- PRODUCTIVE (iteration N)\n- What worked: [successful review approaches in this category]\n- Prefer for: [related dimensions where this category may help]\n\n---\n\n## 10A. SATURATED / SWEPT DIMENSIONS AND EXPANSION FRONTIER\n<!-- MACHINE-OWNED: START -->\n- Completed pivots: 0\n- Failed pivots: 0\n- Audited overrides: 0\n- Swept: none yet\n- Pivot lineage: none yet\n- Remaining frontier: none recorded\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 11. RULED OUT DIRECTIONS\n[Review angles that were investigated and definitively eliminated -- consolidated from iteration dead-end data]\n- [Approach]: [Why ruled out] (iteration N, evidence: [source])\n\n---\n\n## 12. NEXT FOCUS\n<!-- MACHINE-OWNED: START -->\n[Recommended focus area for the next iteration -- updated at end of each iteration. Includes target dimension and/or specific files to review.]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 13. KNOWN CONTEXT\n[Populated during initialization from memory_context() results, if any prior work exists]\n\n### Bounded Context Snapshot\n\nPopulate during initialization before the first review dimension runs. Keep this pointer-based and scoped to the declared review target:\n\n- Target pointers: files, specs, symbols, or resource-map entries under review.\n- Behavior claims: acceptance criteria, public contracts, or docs to verify.\n- Reuse and conventions: existing patterns that define expected implementation shape.\n- Review risks and gaps: stale graph or memory caveats, missing files, and out-of-scope areas.\n\nDo not inline full source bodies. Do not dispatch the retired standalone context loop. Use this snapshot only to seed review dimensions and final traceability.\n\n---\n\n## 14. CROSS-REFERENCE STATUS\n<!-- MACHINE-OWNED: START -->\n[Alignment checks completed across core and overlay protocols]\n\n| Protocol | Level | Status | Iteration | Notes |\n|----------|-------|--------|-----------|-------|\n| `spec_code` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n| `checklist_evidence` | core | [pending/pass/partial/fail/blocked] | [N] | [details] |\n| `skill_agent` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `agent_cross_runtime` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `feature_catalog_code` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n| `playbook_capability` | overlay | [pending/pass/partial/fail/blocked/notApplicable] | [N] | [details] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 15. FILES UNDER REVIEW\n<!-- MACHINE-OWNED: START -->\n[Per-file coverage state table -- populated during initialization from scope discovery]\n\n| File | Dimensions Reviewed | Last Iteration | Findings | Status |\n|------|-------------------|----------------|----------|--------|\n| [path/to/file] | [D1, D3] | [N] | [0 P0, 1 P1, 2 P2] | [partial/complete] |\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 16. REVIEW BOUNDARIES\n<!-- MACHINE-OWNED: START -->\n- Max iterations: [from config]\n- Convergence threshold: [from config]\n- Rolling STOP threshold: 0.08\n- No-progress threshold: 0.05\n- Coverage stabilization passes required: 1\n- Session lineage: sessionId=[from config.sessionId], parentSessionId=[from config.parentSessionId], generation=[from config.generation], lineageMode=[from config.lineageMode]\n- Findings registry: `deep-review-findings-registry.json`\n- Release-readiness states: in-progress | converged | release-blocking\n- Per-iteration budget: [from config.maxToolCallsPerIteration] tool calls, [from config.maxMinutesPerIteration] minutes\n- Severity threshold: [from config.severityThreshold]\n- Review target type: [from config.reviewTargetType]\n- Cross-reference checks: core=[from config.crossReference.core], overlay=[from config.crossReference.overlay]\n- Started: [timestamp]\n<!-- MACHINE-OWNED: END -->\n\n---\n\n## 17. EXAMPLE (POPULATED)\n\nReference snippet showing a partially populated strategy file mid-review. Use this as a visual anchor when opening a live strategy doc.\n\n```markdown\n## 1. REVIEW CHARTER\n- Target: .opencode/skills/system-deep-loop/deep-research (skill, v1.4.0)\n- Dimensions: correctness, test-coverage, cross-runtime-parity, observability\n- Stop conditions: rolling newInfoRatio < 0.08 for 2 iterations OR all dimensions converged OR max=7 reached\n- Success criteria: zero P0 in correctness; test-coverage P0 resolved or deferred with rationale\n\n## 4. NEXT FOCUS\n- Dimension: test-coverage\n- Files: .opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs, .opencode/skills/system-spec-kit/scripts/tests/deep-research-contract-parity.vitest.ts\n- Why: Iteration 2 surfaced a P0 (convergence-path coverage gap); needs a focused follow-up before correctness can terminate PASS.\n\n## 9. COVERAGE MATRIX\n| Dimension            | Status     | Iterations touched |\n|----------------------|------------|--------------------|\n| correctness          | converged  | 1                  |\n| test-coverage        | converging | 2, 4               |\n| cross-runtime-parity | converging | 3                  |\n| observability        | converging | 4                  |\n```","lineStart":1,"lineEnd":218,"totalLines":218,"truncated":false}},"title":".opencode/skills/system-deep-loop/deep-review/assets/deep_review_strategy.md","time":{"start":1784385657991,"end":1784385658006}},"metadata":{"openai":{"itemId":"fc_0469c5d15e3d3615016a5b9079c8ec8191ac93b5d53d6517bf"}},"id":"prt_f75ac5c86001Gtn3uWBsJgBGP7","sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","messageID":"msg_f75ac246b001CTHIZaoIVyzeUk"}}
{"type":"tool_use","timestamp":1784385658014,"sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","part":{"type":"tool","tool":"read","callID":"call_jvOwKijclQxlgyjuCz5987Y9","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts","limit":500},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts</path>\n<type>file</type>\n<content>\n1: // MODULE: Deep-Loop Prompt Pack Renderer\n2: \n3: import { readFileSync } from 'node:fs';\n4: import { z } from 'zod';\n5: \n6: // ───── TYPE DEFINITIONS ─────\n7: \n8: export type PromptPackVariables = Record<string, string | number>;\n9: \n10: // ───── CONSTANTS ─────\n11: \n12: const PROMPT_PACK_TOKEN_PATTERN = /\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}/g;\n13: const promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);\n14: \n15: // ───── DOMAIN ERRORS ─────\n16: \n17: export class PromptPackError extends Error {\n18:   missingVariables: string[];\n19: \n20:   constructor(missingVariables: string[]) {\n21:     super(`Missing prompt pack variables: ${missingVariables.join(', ')}`);\n22:     this.name = 'PromptPackError';\n23:     this.missingVariables = missingVariables;\n24:   }\n25: }\n26: \n27: // ───── HELPERS ─────\n28: \n29: function extractTemplateTokens(template: string): string[] {\n30:   const tokens = new Set<string>();\n31: \n32:   for (const match of template.matchAll(PROMPT_PACK_TOKEN_PATTERN)) {\n33:     const tokenName = match[1];\n34:     if (promptPackVariableNameSchema.safeParse(tokenName).success) {\n35:       tokens.add(tokenName);\n36:     }\n37:   }\n38: \n39:   return [...tokens];\n40: }\n41: \n42: // ───── EXPORTS ─────\n43: \n44: /**\n45:  * Render a prompt pack template by substituting variables.\n46:  *\n47:  * Reads the template file and replaces all `{variableName}` tokens\n48:  * with values from the variables map.\n49:  *\n50:  * @param templatePath - Path to the prompt pack template file.\n51:  * @param variables - Mapping of variable names to replacement values.\n52:  * @returns Rendered template string with all variables substituted.\n53:  * @throws {@link PromptPackError} If any required variables are missing.\n54:  */\n55: export function renderPromptPack(templatePath: string, variables: PromptPackVariables): string {\n56:   const template = readFileSync(templatePath, 'utf8');\n57:   const missingVariables = new Set<string>();\n58: \n59:   const rendered = template.replace(PROMPT_PACK_TOKEN_PATTERN, (_, tokenName: string) => {\n60:     if (!(tokenName in variables)) {\n61:       missingVariables.add(tokenName);\n62:       return `{${tokenName}}`;\n63:     }\n64: \n65:     return String(variables[tokenName]);\n66:   });\n67: \n68:   if (missingVariables.size > 0) {\n69:     throw new PromptPackError([...missingVariables]);\n70:   }\n71: \n72:   return rendered;\n73: }\n74: \n75: /**\n76:  * Validate that a prompt pack template contains expected variables.\n77:  *\n78:  * @param templatePath - Path to the prompt pack template file.\n79:  * @param expectedVariables - Variable names that should be present.\n80:  * @returns Report with present, missing, and extra variables.\n81:  */\n82: export function validatePromptPackTemplate(\n83:   templatePath: string,\n84:   expectedVariables: string[],\n85: ): { present: string[]; missing: string[]; extra: string[] } {\n86:   const template = readFileSync(templatePath, 'utf8');\n87:   const templateTokens = extractTemplateTokens(template);\n88:   const templateTokenSet = new Set(templateTokens);\n89:   const expectedTokenSet = new Set(expectedVariables.filter((token) => promptPackVariableNameSchema.safeParse(token).success));\n90: \n91:   return {\n92:     present: expectedVariables.filter((token) => expectedTokenSet.has(token) && templateTokenSet.has(token)),\n93:     missing: expectedVariables.filter((token) => expectedTokenSet.has(token) && !templateTokenSet.has(token)),\n94:     extra: templateTokens.filter((token) => !expectedTokenSet.has(token)),\n95:   };\n96: }\n\n(End of file - total 96 lines)\n</content>","metadata":{"preview":"// MODULE: Deep-Loop Prompt Pack Renderer\n\nimport { readFileSync } from 'node:fs';\nimport { z } from 'zod';\n\n// ───── TYPE DEFINITIONS ─────\n\nexport type PromptPackVariables = Record<string, string | number>;\n\n// ───── CONSTANTS ─────\n\nconst PROMPT_PACK_TOKEN_PATTERN = /\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}/g;\nconst promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);\n\n// ───── DOMAIN ERRORS ─────\n\nexport class PromptPackError extends Error {\n  missingVariables: string[];\n\n  constructor(missingVariables: string[]) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts","text":"// MODULE: Deep-Loop Prompt Pack Renderer\n\nimport { readFileSync } from 'node:fs';\nimport { z } from 'zod';\n\n// ───── TYPE DEFINITIONS ─────\n\nexport type PromptPackVariables = Record<string, string | number>;\n\n// ───── CONSTANTS ─────\n\nconst PROMPT_PACK_TOKEN_PATTERN = /\\{([a-zA-Z_][a-zA-Z0-9_]*)\\}/g;\nconst promptPackVariableNameSchema = z.string().regex(/^[a-zA-Z_][a-zA-Z0-9_]*$/);\n\n// ───── DOMAIN ERRORS ─────\n\nexport class PromptPackError extends Error {\n  missingVariables: string[];\n\n  constructor(missingVariables: string[]) {\n    super(`Missing prompt pack variables: ${missingVariables.join(', ')}`);\n    this.name = 'PromptPackError';\n    this.missingVariables = missingVariables;\n  }\n}\n\n// ───── HELPERS ─────\n\nfunction extractTemplateTokens(template: string): string[] {\n  const tokens = new Set<string>();\n\n  for (const match of template.matchAll(PROMPT_PACK_TOKEN_PATTERN)) {\n    const tokenName = match[1];\n    if (promptPackVariableNameSchema.safeParse(tokenName).success) {\n      tokens.add(tokenName);\n    }\n  }\n\n  return [...tokens];\n}\n\n// ───── EXPORTS ─────\n\n/**\n * Render a prompt pack template by substituting variables.\n *\n * Reads the template file and replaces all `{variableName}` tokens\n * with values from the variables map.\n *\n * @param templatePath - Path to the prompt pack template file.\n * @param variables - Mapping of variable names to replacement values.\n * @returns Rendered template string with all variables substituted.\n * @throws {@link PromptPackError} If any required variables are missing.\n */\nexport function renderPromptPack(templatePath: string, variables: PromptPackVariables): string {\n  const template = readFileSync(templatePath, 'utf8');\n  const missingVariables = new Set<string>();\n\n  const rendered = template.replace(PROMPT_PACK_TOKEN_PATTERN, (_, tokenName: string) => {\n    if (!(tokenName in variables)) {\n      missingVariables.add(tokenName);\n      return `{${tokenName}}`;\n    }\n\n    return String(variables[tokenName]);\n  });\n\n  if (missingVariables.size > 0) {\n    throw new PromptPackError([...missingVariables]);\n  }\n\n  return rendered;\n}\n\n/**\n * Validate that a prompt pack template contains expected variables.\n *\n * @param templatePath - Path to the prompt pack template file.\n * @param expectedVariables - Variable names that should be present.\n * @returns Report with present, missing, and extra variables.\n */\nexport function validatePromptPackTemplate(\n  templatePath: string,\n  expectedVariables: string[],\n): { present: string[]; missing: string[]; extra: string[] } {\n  const template = readFileSync(templatePath, 'utf8');\n  const templateTokens = extractTemplateTokens(template);\n  const templateTokenSet = new Set(templateTokens);\n  const expectedTokenSet = new Set(expectedVariables.filter((token) => promptPackVariableNameSchema.safeParse(token).success));\n\n  return {\n    present: expectedVariables.filter((token) => expectedTokenSet.has(token) && templateTokenSet.has(token)),\n    missing: expectedVariables.filter((token) => expectedTokenSet.has(token) && !templateTokenSet.has(token)),\n    extra: templateTokens.filter((token) => !expectedTokenSet.has(token)),\n  };\n}","lineStart":1,"lineEnd":96,"totalLines":96,"truncated":false}},"title":".opencode/skills/system-deep-loop/runtime/lib/deep-loop/prompt-pack.ts","time":{"start":1784385657978,"end":1784385658010}},"metadata":{"openai":{"itemId":"fc_0469c5d15e3d3615016a5b9079c7f88191969070e13e671789"}},"id":"prt_f75ac5c56001Q6CZLZnVbSQsjg","sessionID":"ses_08a55b97fffeEAeDNR9iyiwCDi","messageID":"msg_f75ac246b001CTHIZaoIVyzeUk"}}
