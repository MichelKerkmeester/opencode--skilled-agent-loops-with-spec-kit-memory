{"type":"tool_use","timestamp":1781763792840,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_HBLaCvHuD4bKa3XJT2QUcubh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","offset":1322,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts</path>\n<type>file</type>\n<content>\n1322:                 `SELECT id, title, spec_folder, file_path, importance_tier, importance_weight, quality_score, created_at, context_type, tenant_id, user_id, agent_id, session_id FROM memory_index WHERE id IN (${placeholders})`\n1323:               ).all(...newSummaryIds) as PipelineRow[];\n1324: \n1325:               const memRowMap = new Map(memRows.map((r) => [r.id, r]));\n1326:               for (const sr of summaryResults) {\n1327:                 if (!existingIds.has(String(sr.memoryId))) {\n1328:                   const memRow = memRowMap.get(sr.memoryId);\n1329:                   if (memRow) {\n1330:                     newSummaryHits.push({\n1331:                       ...memRow,\n1332:                       similarity: sr.similarity * 100,\n1333:                       score: sr.similarity,\n1334:                     });\n1335:                     existingIds.add(String(sr.memoryId));\n1336:                   }\n1337:                 }\n1338:               }\n1339:             }\n1340: \n1341:             const archiveFilteredSummaryHits = applyArchiveFilter(newSummaryHits, includeArchived);\n1342:             const folderFilteredSummaryHits = applyFolderFilter(archiveFilteredSummaryHits, specFolder);\n1343:             const tierFilteredSummaryHits = applyTierFilter(folderFilteredSummaryHits, tier);\n1344:             const contextFilteredSummaryHits = contextType\n1345:               ? tierFilteredSummaryHits.filter((r) => resolveRowContextType(r) === contextType)\n1346:               : tierFilteredSummaryHits;\n1347:             const scopeFilteredSummaryHits = shouldApplyScopeFiltering\n1348:               ? filterRowsByScope(contextFilteredSummaryHits, scopeFilter)\n1349:               : contextFilteredSummaryHits;\n1350: \n1351:             // Apply the same quality threshold that other candidates go through\n1352:             const backfilledSummaryHits = backfillMissingQualityScores(scopeFilteredSummaryHits);\n1353:             const filteredSummaryHits = filterByMinQualityScore(backfilledSummaryHits, qualityThreshold);\n1354: \n1355:             if (filteredSummaryHits.length > 0) {\n1356:               candidates = [...candidates, ...filteredSummaryHits];\n1357:               channelCount++;\n1358: \n1359:               if (trace) {\n1360:                 addTraceEntry(trace, 'candidate', 1, filteredSummaryHits.length, 0, {\n1361:                   channel: 'r8-summary-embeddings',\n1362:                   summaryHits: filteredSummaryHits.length,\n1363:                   preFilterCount: newSummaryHits.length,\n1364:                 });\n1365:               }\n1366:             }\n1367:           }\n1368:         }\n1369:       }\n1370:     } catch (r8Err: unknown) {\n1371:       const r8Msg = r8Err instanceof Error ? r8Err.message : String(r8Err);\n1372:       console.warn(`[stage1-candidate-gen] R8 summary channel failed: ${r8Msg}`);\n1373:     }\n1374:   }\n1375: \n1376:   // -- Query Surrogate Matching (SPECKIT_QUERY_SURROGATES) ----\n1377:   //\n1378:   // When SPECKIT_QUERY_SURROGATES is enabled, batch-load stored surrogates for\n1379:   // all candidate IDs and run matchSurrogates() against each. Candidates with\n1380:   // a surrogate match above MIN_MATCH_THRESHOLD receive a score boost (additive,\n1381:   // capped at 0.15) to improve ranking for vocabulary-mismatched queries.\n1382:   //\n1383:   // This is a lightweight post-candidate boost — no new candidates are added,\n1384:   // only existing ones are re-scored. No LLM calls on this path.\n1385:   //\n1386:   // Fail-open: any error leaves candidates unchanged.\n1387: \n1388:   if (isQuerySurrogatesEnabled() && candidates.length > 0) {\n1389:     try {\n1390:       const surrogateDb = requireDb();\n1391:       const candidateIds = candidates\n1392:         .map((r) => r.id)\n1393:         .filter((id): id is number => typeof id === 'number');\n1394: \n1395:       if (candidateIds.length > 0) {\n1396:         const surrogateMap = loadSurrogatesBatch(surrogateDb, candidateIds);\n1397: \n1398:         if (surrogateMap.size > 0) {\n1399:           let boostedCount = 0;\n1400:           const SURROGATE_BOOST_CAP = 0.15;\n1401: \n1402:           candidates = candidates.map((row) => {\n1403:             const surrogates = surrogateMap.get(row.id as number);\n1404:             if (!surrogates) return row;\n1405: \n1406:             const matchResult = matchSurrogates(query, {\n1407:               aliases: surrogates.aliases,\n1408:               headings: surrogates.headings,\n1409:               summary: surrogates.summary,\n1410:               surrogateQuestions: surrogates.surrogateQuestions,\n1411:               generatedAt: surrogates.generatedAt,\n1412:             });\n1413: \n1414:             if (matchResult.score > 0) {\n1415:               boostedCount++;\n1416:               // FIX #2: Use resolveEffectiveScore() as the base instead of\n1417:               // raw row.score. For vector-only rows with only `similarity`,\n1418:               // row.score may be undefined/0 while similarity is 0.82+.\n1419:               // Using the canonical fallback chain prevents overwriting\n1420:               // strong relevance signals with tiny surrogate boosts.\n1421:               const currentScore = resolveEffectiveScore(row);\n1422:               const boost = Math.min(matchResult.score * SURROGATE_BOOST_CAP, SURROGATE_BOOST_CAP);\n1423:               const boostedScore = Math.min(1, currentScore + boost);\n1424:               return {\n1425:                 ...row,\n1426:                 score: boostedScore,\n1427:                 rrfScore: boostedScore,\n1428:                 intentAdjustedScore: boostedScore,\n1429:                 surrogateBoost: boost,\n1430:                 surrogateMatches: matchResult.matchedSurrogates,\n1431:               };\n1432:             }\n1433: \n1434:             return row;\n1435:           });\n1436: \n1437:           if (trace && boostedCount > 0) {\n1438:             addTraceEntry(trace, 'candidate', 0, boostedCount, 0, {\n1439:               channel: 'd2-query-surrogates',\n1440:               surrogatesLoaded: surrogateMap.size,\n1441:               boostedCount,\n1442:             });\n1443:           }\n1444:         }\n1445:       }\n1446:     } catch (surrogateErr: unknown) {\n1447:       const surrogateMsg = surrogateErr instanceof Error ? surrogateErr.message : String(surrogateErr);\n1448:       console.warn(`[stage1-candidate-gen] D2 query surrogate matching failed: ${surrogateMsg}`);\n1449:     }\n1450:   }\n1451: \n1452:   // -- Trace ------------------------------------------------------------------\n1453: \n1454:   const durationMs = Date.now() - startTime;\n1455: \n1456:   if (trace) {\n1457:     addTraceEntry(\n1458:       trace,\n1459:       'candidate',\n1460:       channelCount,\n1461:       candidates.length,\n1462:       durationMs,\n1463:       {\n1464:         searchType,\n1465:         mode: mode ?? null,\n1466:         channelCount,\n1467:         deepExpansion: mode === 'deep' && isMultiQueryEnabled(),\n1468:         r12EmbeddingExpansion: isEmbeddingExpansionEnabled(),\n1469:       }\n1470:     );\n1471:   }\n1472: \n1473:   // activeChannels counts actual retrieval channels (vector, keyword/BM25),\n1474:   // while channelCount counts parallel query variants. In hybrid mode both vector\n1475:   // and keyword channels are always active regardless of query variant count.\n1476:   const activeChannels = searchType === 'hybrid' ? 2 : 1;\n1477: \n1478:   return {\n1479:     candidates,\n1480:     metadata: {\n1481:       searchType,\n1482:       channelCount,\n1483:       activeChannels,\n1484:       candidateCount: candidates.length,\n1485:       constitutionalInjected: constitutionalInjectedCount,\n1486:       durationMs,\n1487:     },\n1488:   };\n1489: }\n1490: \n1491: // -- Test Exports ------------------------------------------------------------\n1492: \n1493: /**\n1494:  * Internal functions exposed for unit testing.\n1495:  * Do NOT use in production code paths.\n1496:  *\n1497:  * @internal\n1498:  */\n1499: export const __testables = {\n1500:   filterByMinQualityScore,\n1501:   resolveRowContextType,\n1502:   isPacketOrientedQuery,\n1503:   boostGraphMetadataCandidates,\n1504:   buildDeepQueryVariants,\n1505:   DEFAULT_EXPANSION_CANDIDATE_LIMIT,\n1506:   decomposeQueryFacets,\n1507:   mergeByFacetCoverage: mergeQueryFacetCoverage,\n1508:   buildQueryDecompositionPool,\n1509:   MAX_QUERY_DECOMPOSITION_FACETS,\n1510: };\n\n(End of file - total 1510 lines)\n</content>","metadata":{"preview":"                `SELECT id, title, spec_folder, file_path, importance_tier, importance_weight, quality_score, created_at, context_type, tenant_id, user_id, agent_id, session_id FROM memory_index WHERE id IN (${placeholders})`\n              ).all(...newSummaryIds) as PipelineRow[];\n\n              const memRowMap = new Map(memRows.map((r) => [r.id, r]));\n              for (const sr of summaryResults) {\n                if (!existingIds.has(String(sr.memoryId))) {\n                  const memRow = memRowMap.get(sr.memoryId);\n                  if (memRow) {\n                    newSummaryHits.push({\n                      ...memRow,\n                      similarity: sr.similarity * 100,\n                      score: sr.similarity,\n                    });\n                    existingIds.add(String(sr.memoryId));\n                  }\n                }\n              }\n            }\n\n            const archiveFilteredSummaryHits = applyArchiveFilter(newSummaryHits, includeArchived);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","text":"                `SELECT id, title, spec_folder, file_path, importance_tier, importance_weight, quality_score, created_at, context_type, tenant_id, user_id, agent_id, session_id FROM memory_index WHERE id IN (${placeholders})`\n              ).all(...newSummaryIds) as PipelineRow[];\n\n              const memRowMap = new Map(memRows.map((r) => [r.id, r]));\n              for (const sr of summaryResults) {\n                if (!existingIds.has(String(sr.memoryId))) {\n                  const memRow = memRowMap.get(sr.memoryId);\n                  if (memRow) {\n                    newSummaryHits.push({\n                      ...memRow,\n                      similarity: sr.similarity * 100,\n                      score: sr.similarity,\n                    });\n                    existingIds.add(String(sr.memoryId));\n                  }\n                }\n              }\n            }\n\n            const archiveFilteredSummaryHits = applyArchiveFilter(newSummaryHits, includeArchived);\n            const folderFilteredSummaryHits = applyFolderFilter(archiveFilteredSummaryHits, specFolder);\n            const tierFilteredSummaryHits = applyTierFilter(folderFilteredSummaryHits, tier);\n            const contextFilteredSummaryHits = contextType\n              ? tierFilteredSummaryHits.filter((r) => resolveRowContextType(r) === contextType)\n              : tierFilteredSummaryHits;\n            const scopeFilteredSummaryHits = shouldApplyScopeFiltering\n              ? filterRowsByScope(contextFilteredSummaryHits, scopeFilter)\n              : contextFilteredSummaryHits;\n\n            // Apply the same quality threshold that other candidates go through\n            const backfilledSummaryHits = backfillMissingQualityScores(scopeFilteredSummaryHits);\n            const filteredSummaryHits = filterByMinQualityScore(backfilledSummaryHits, qualityThreshold);\n\n            if (filteredSummaryHits.length > 0) {\n              candidates = [...candidates, ...filteredSummaryHits];\n              channelCount++;\n\n              if (trace) {\n                addTraceEntry(trace, 'candidate', 1, filteredSummaryHits.length, 0, {\n                  channel: 'r8-summary-embeddings',\n                  summaryHits: filteredSummaryHits.length,\n                  preFilterCount: newSummaryHits.length,\n                });\n              }\n            }\n          }\n        }\n      }\n    } catch (r8Err: unknown) {\n      const r8Msg = r8Err instanceof Error ? r8Err.message : String(r8Err);\n      console.warn(`[stage1-candidate-gen] R8 summary channel failed: ${r8Msg}`);\n    }\n  }\n\n  // -- Query Surrogate Matching (SPECKIT_QUERY_SURROGATES) ----\n  //\n  // When SPECKIT_QUERY_SURROGATES is enabled, batch-load stored surrogates for\n  // all candidate IDs and run matchSurrogates() against each. Candidates with\n  // a surrogate match above MIN_MATCH_THRESHOLD receive a score boost (additive,\n  // capped at 0.15) to improve ranking for vocabulary-mismatched queries.\n  //\n  // This is a lightweight post-candidate boost — no new candidates are added,\n  // only existing ones are re-scored. No LLM calls on this path.\n  //\n  // Fail-open: any error leaves candidates unchanged.\n\n  if (isQuerySurrogatesEnabled() && candidates.length > 0) {\n    try {\n      const surrogateDb = requireDb();\n      const candidateIds = candidates\n        .map((r) => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (candidateIds.length > 0) {\n        const surrogateMap = loadSurrogatesBatch(surrogateDb, candidateIds);\n\n        if (surrogateMap.size > 0) {\n          let boostedCount = 0;\n          const SURROGATE_BOOST_CAP = 0.15;\n\n          candidates = candidates.map((row) => {\n            const surrogates = surrogateMap.get(row.id as number);\n            if (!surrogates) return row;\n\n            const matchResult = matchSurrogates(query, {\n              aliases: surrogates.aliases,\n              headings: surrogates.headings,\n              summary: surrogates.summary,\n              surrogateQuestions: surrogates.surrogateQuestions,\n              generatedAt: surrogates.generatedAt,\n            });\n\n            if (matchResult.score > 0) {\n              boostedCount++;\n              // FIX #2: Use resolveEffectiveScore() as the base instead of\n              // raw row.score. For vector-only rows with only `similarity`,\n              // row.score may be undefined/0 while similarity is 0.82+.\n              // Using the canonical fallback chain prevents overwriting\n              // strong relevance signals with tiny surrogate boosts.\n              const currentScore = resolveEffectiveScore(row);\n              const boost = Math.min(matchResult.score * SURROGATE_BOOST_CAP, SURROGATE_BOOST_CAP);\n              const boostedScore = Math.min(1, currentScore + boost);\n              return {\n                ...row,\n                score: boostedScore,\n                rrfScore: boostedScore,\n                intentAdjustedScore: boostedScore,\n                surrogateBoost: boost,\n                surrogateMatches: matchResult.matchedSurrogates,\n              };\n            }\n\n            return row;\n          });\n\n          if (trace && boostedCount > 0) {\n            addTraceEntry(trace, 'candidate', 0, boostedCount, 0, {\n              channel: 'd2-query-surrogates',\n              surrogatesLoaded: surrogateMap.size,\n              boostedCount,\n            });\n          }\n        }\n      }\n    } catch (surrogateErr: unknown) {\n      const surrogateMsg = surrogateErr instanceof Error ? surrogateErr.message : String(surrogateErr);\n      console.warn(`[stage1-candidate-gen] D2 query surrogate matching failed: ${surrogateMsg}`);\n    }\n  }\n\n  // -- Trace ------------------------------------------------------------------\n\n  const durationMs = Date.now() - startTime;\n\n  if (trace) {\n    addTraceEntry(\n      trace,\n      'candidate',\n      channelCount,\n      candidates.length,\n      durationMs,\n      {\n        searchType,\n        mode: mode ?? null,\n        channelCount,\n        deepExpansion: mode === 'deep' && isMultiQueryEnabled(),\n        r12EmbeddingExpansion: isEmbeddingExpansionEnabled(),\n      }\n    );\n  }\n\n  // activeChannels counts actual retrieval channels (vector, keyword/BM25),\n  // while channelCount counts parallel query variants. In hybrid mode both vector\n  // and keyword channels are always active regardless of query variant count.\n  const activeChannels = searchType === 'hybrid' ? 2 : 1;\n\n  return {\n    candidates,\n    metadata: {\n      searchType,\n      channelCount,\n      activeChannels,\n      candidateCount: candidates.length,\n      constitutionalInjected: constitutionalInjectedCount,\n      durationMs,\n    },\n  };\n}\n\n// -- Test Exports ------------------------------------------------------------\n\n/**\n * Internal functions exposed for unit testing.\n * Do NOT use in production code paths.\n *\n * @internal\n */\nexport const __testables = {\n  filterByMinQualityScore,\n  resolveRowContextType,\n  isPacketOrientedQuery,\n  boostGraphMetadataCandidates,\n  buildDeepQueryVariants,\n  DEFAULT_EXPANSION_CANDIDATE_LIMIT,\n  decomposeQueryFacets,\n  mergeByFacetCoverage: mergeQueryFacetCoverage,\n  buildQueryDecompositionPool,\n  MAX_QUERY_DECOMPOSITION_FACETS,\n};","lineStart":1322,"lineEnd":1510,"totalLines":1510,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage1-candidate-gen.ts","time":{"start":1781763792826,"end":1781763792831}},"metadata":{"openai":{"itemId":"fc_036c3a75fcdce96f016a338ed07dbc8191820235471a7ca11e"}},"id":"prt_ed965dfb0001TTukcdIJWbthRN","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed965a7a6001axABUKSXIuuHDU"}}
{"type":"tool_use","timestamp":1781763792962,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_TbOSwQ4piugSoPQicQiOqxhZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","offset":1246,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts</path>\n<type>file</type>\n<content>\n1246:       const message = err instanceof Error ? err.message : String(err);\n1247:       console.warn(`[stage2-fusion] testing effect skipped (db unavailable): ${message}`);\n1248:     }\n1249:   }\n1250: \n1251:   // -- 4. Intent weights --\n1252:   // G2 PREVENTION: Only apply for non-hybrid search types.\n1253:   // Hybrid search (RRF / RSF) incorporates intent weighting during fusion —\n1254:   // Applying it again here would double-count, causing the G2 bug.\n1255:   if (!isHybrid && config.intentWeights) {\n1256:     try {\n1257:       const weighted = applyIntentWeightsToResults(results, config.intentWeights);\n1258:       results = weighted.map((result) =>\n1259:         typeof result.intentAdjustedScore === 'number'\n1260:           ? withSyncedScoreAliases(result, result.intentAdjustedScore)\n1261:           : result\n1262:       );\n1263:       metadata.intentWeightsApplied = 'applied';\n1264:     } catch (err: unknown) {\n1265:       const message = err instanceof Error ? err.message : String(err);\n1266:       console.warn(`[stage2-fusion] intent weights failed: ${message}`);\n1267:       metadata.intentWeightsApplied = 'failed';\n1268:     }\n1269:   }\n1270: \n1271:   // -- 5. Artifact routing weights --\n1272:   if (config.artifactRouting && config.artifactRouting.confidence > 0) {\n1273:     try {\n1274:       const routed = applyArtifactRouting(results, config.artifactRouting);\n1275:       results = routed;\n1276:       metadata.artifactRoutingApplied = 'applied';\n1277:     } catch (err: unknown) {\n1278:       const message = err instanceof Error ? err.message : String(err);\n1279:       console.warn(`[stage2-fusion] artifact routing failed: ${message}`);\n1280:       metadata.artifactRoutingApplied = 'failed';\n1281:     }\n1282:   }\n1283: \n1284:   // -- 6. Feedback signals --\n1285:   try {\n1286:     const withFeedback = applyFeedbackSignals(results, config.query);\n1287:     // Detect if any score actually changed\n1288:     const changed = withFeedback.some((r, i) => r !== results[i]);\n1289:     if (changed) {\n1290:       results = withFeedback;\n1291:       metadata.feedbackSignalsApplied = 'applied';\n1292:     }\n1293:   } catch (err: unknown) {\n1294:     const message = err instanceof Error ? err.message : String(err);\n1295:     console.warn(`[stage2-fusion] feedback signals failed: ${message}`);\n1296:     metadata.feedbackSignalsApplied = 'failed';\n1297:   }\n1298: \n1299:   // -- 6a. Learned Stage 2 shadow scoring --\n1300:   // Runs the learned linear ranker in parallel with the manual combiner.\n1301:   // Shadow-only — scores are logged for comparison but never affect live ranking.\n1302:   // Gated behind SPECKIT_LEARNED_STAGE2_COMBINER (default ON, graduated).\n1303:   // When SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT is set in (0, 0.05],\n1304:   // a small guarded blend `(1-w)*manual + w*learned` is applied to the live\n1305:   // score. Default 0 preserves shadow-only behavior. The blend weight is\n1306:   // clamped at the source by resolveLearnedBlendWeight().\n1307:   if (isLearnedStage2CombinerEnabled()) {\n1308:     try {\n1309:       const learnedShadowModel = await loadPersistedLearnedStage2Model();\n1310:       // Weight resolved once per pipeline run; flag-gated and\n1311:       // clamped. Zero means shadow-only (today's behavior).\n1312:       const learnedBlendWeight = resolveLearnedBlendWeight();\n1313:       for (let rowIndex = 0; rowIndex < results.length; rowIndex++) {\n1314:         const row = results[rowIndex];\n1315:         const features = extractFeatureVector({\n1316:           rrfScore: row.rrfScore,\n1317:           overlapScore: typeof row.overlapScore === 'number' ? row.overlapScore : undefined,\n1318:           graphScore: (() => {\n1319:             const gc = row.graphContribution as Record<string, unknown> | undefined;\n1320:             const delta = typeof gc?.totalDelta === 'number' ? gc.totalDelta : 0;\n1321:             return Math.max(0, Math.min(1, delta + 0.5));\n1322:           })(),\n1323:           sessionScore: typeof row.sessionScore === 'number' ? row.sessionScore : undefined,\n1324:           causalScore: typeof row.causalScore === 'number' ? row.causalScore : undefined,\n1325:           feedbackScore: typeof row.feedbackScore === 'number' ? row.feedbackScore : undefined,\n1326:           validationScore: (() => {\n1327:             const vm = row.validationMetadata as Record<string, unknown> | undefined;\n1328:             return typeof vm?.qualityScore === 'number' ? vm.qualityScore : undefined;\n1329:           })(),\n1330:           artifactScore: typeof row.artifactBoostApplied === 'number'\n1331:             ? Math.min(1, row.artifactBoostApplied / 2)\n1332:             : undefined,\n1333:         });\n1334:         const shadow = shadowScore(learnedShadowModel, features, resolveBaseScore(row), true);\n1335:         if (shadow) {\n1336:           console.warn(\n1337:             `[stage2-fusion] shadow-learned id=${row.id} manual=${shadow.manualScore.toFixed(4)} learned=${shadow.learnedScore.toFixed(4)} delta=${shadow.delta.toFixed(4)}`\n1338:           );\n1339:           // Apply the small guarded blend when weight > 0 AND a\n1340:           // shadow result is available (model loaded successfully). Mutate\n1341:           // the row through withSyncedScoreAliases so all score aliases stay\n1342:           // aligned. When weight is 0 (default) or model failed to load, this\n1343:           // branch is skipped and behavior is identical to pre-fix.\n1344:           if (learnedBlendWeight > 0) {\n1345:             const blendedScore = (1 - learnedBlendWeight) * shadow.manualScore\n1346:               + learnedBlendWeight * shadow.learnedScore;\n1347:             results[rowIndex] = withSyncedScoreAliases(row, blendedScore);\n1348:           }\n1349:         }\n1350:       }\n1351:     } catch (err: unknown) {\n1352:       const message = err instanceof Error ? err.message : String(err);\n1353:       console.warn(`[stage2-fusion] learned stage2 shadow scoring failed: ${message}`);\n1354:     }\n1355:   }\n1356: \n1357:   // -- 6a. Retrieval rescue + 7. Artifact-based result limiting --\n1358:   // The routing strategy may specify a maxResults count stricter than the\n1359:   // Overall pipeline limit. Apply it here so Stage 3 reranks a pre-trimmed set.\n1360:   syncScoreAliasesInPlace(results);\n1361:   if (isRetrievalRescueEnabled()) {\n1362:     try {\n1363:       let rescueDb: Database.Database | null = null;\n1364:       try {\n1365:         rescueDb = requireDb();\n1366:       } catch {\n1367:         rescueDb = null;\n1368:       }\n1369:       results = applyRetrievalRescueLayer(config.query, results, {\n1370:         db: rescueDb,\n1371:         artifactClass: config.artifactRouting?.strategy?.artifactClass as string | undefined\n1372:           ?? config.artifactRouting?.detectedClass,\n1373:       });\n1374:       logger.debug('retrieval rescue layer completed', {\n1375:         event: 'stage2_retrieval_rescue_success',\n1376:         resultCount: results.length,\n1377:         hasDb: rescueDb !== null,\n1378:         artifactClass: config.artifactRouting?.strategy?.artifactClass\n1379:           ?? config.artifactRouting?.detectedClass\n1380:           ?? null,\n1381:       });\n1382:     } catch (err: unknown) {\n1383:       const message = err instanceof Error ? err.message : String(err);\n1384:       console.warn(`[stage2-fusion] retrieval rescue layer failed: ${message}`);\n1385:     }\n1386:   }\n1387:   results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n1388:   if (\n1389:     config.artifactRouting &&\n1390:     config.artifactRouting.confidence > 0 &&\n1391:     typeof config.artifactRouting.strategy?.maxResults === 'number' &&\n1392:     config.artifactRouting.strategy.maxResults > 0 &&\n1393:     results.length > config.artifactRouting.strategy.maxResults\n1394:   ) {\n1395:     results = results.slice(0, config.artifactRouting.strategy.maxResults);\n1396:   }\n1397: \n1398:   // -- Steps 8-9: Enrichment (extracted to stage2b-enrichment.ts) --\n1399:   // Pure annotation: anchor metadata + validation metadata.\n1400:   // Validation signal SCORING (applyValidationSignalScoring) stays here\n1401:   // because it's a scoring step, not a pure enrichment.\n1402:   results = executeStage2bEnrichment(results);\n1403:   try {\n1404:     results = applyValidationSignalScoring(results);\n1405:   } catch (err: unknown) {\n1406:     const message = err instanceof Error ? err.message : String(err);\n1407:     console.warn(`[stage2-fusion] validation signal scoring failed: ${message}`);\n1408:   }\n1409: \n1410:   // Keep all score aliases aligned after late-stage score mutations.\n1411:   syncScoreAliasesInPlace(results);\n1412:   if (metadata.graphContribution) {\n1413:     metadata.graphContribution.causalBoosted = countGraphContribution(results, 'causalDelta');\n1414:     metadata.graphContribution.coActivationBoosted = countGraphContribution(results, 'coActivationDelta');\n1415:     metadata.graphContribution.communityInjected = countGraphContribution(results, 'communityDelta');\n1416:     metadata.graphContribution.graphSignalsBoosted = countGraphContribution(results, 'graphSignalDelta');\n1417:     metadata.graphContribution.totalGraphInjected = countGraphInjected(results);\n1418: \n1419:     // P2 fix: Diagnostic when graph is activated but contributes nothing\n1420:     if (\n1421:       !metadata.graphContribution.killSwitchActive &&\n1422:       metadata.graphContribution.rolloutState === 'bounded_runtime' &&\n1423:       metadata.graphContribution.causalBoosted === 0 &&\n1424:       metadata.graphContribution.coActivationBoosted === 0 &&\n1425:       metadata.graphContribution.communityInjected === 0 &&\n1426:       metadata.graphContribution.graphSignalsBoosted === 0 &&\n1427:       results.length > 0\n1428:     ) {\n1429:       console.warn(\n1430:         '[stage2-fusion] Graph channel active (bounded_runtime) but zero contribution — causal_edges table may be sparse or candidates lack graph connectivity'\n1431:       );\n1432:     }\n1433:   }\n1434: \n1435:   // -- Trace --\n1436:   if (config.trace) {\n1437:     addTraceEntry(\n1438:       config.trace,\n1439:       'fusion',\n1440:       candidates.length,\n1441:       results.length,\n1442:       Date.now() - start,\n1443:       {\n1444:         sessionBoostApplied: metadata.sessionBoostApplied,\n1445:         causalBoostApplied: metadata.causalBoostApplied,\n1446:         intentWeightsApplied: metadata.intentWeightsApplied,\n1447:         artifactRoutingApplied: metadata.artifactRoutingApplied,\n1448:         feedbackSignalsApplied: metadata.feedbackSignalsApplied,\n1449:         graphContribution: metadata.graphContribution,\n1450:         searchType: config.searchType,\n1451:         isHybrid,\n1452:       }\n1453:     );\n1454:   }\n1455: \n1456:   metadata.durationMs = Date.now() - start;\n1457: \n1458:   return {\n1459:     scored: results,\n1460:     metadata,\n1461:   };\n1462: }\n1463: \n1464: // -- Test surface --\n1465: \n1466: /**\n1467:  * Internal functions exposed for unit testing.\n1468:  *\n1469:  * These are NOT part of the public API and may change without notice.\n1470:  * Access only from `*.test.ts` / `*.vitest.ts` files.\n1471:  */\n1472: export const __testables = {\n1473:   resolveBaseScore,\n1474:   strengthenOnAccess,\n1475:   applyIntentWeightsToResults,\n1476:   applyArtifactRouting,\n1477:   applyFeedbackSignals,\n1478:   applyUsageRankingBoost,\n1479:   applyTestingEffect,\n1480:   enrichResultsWithAnchorMetadata,\n1481:   enrichResultsWithValidationMetadata,\n1482:   applyValidationSignalScoring,\n1483:   // Learned blend weight resolver, exposed for unit testing\n1484:   // the env-var clamp and default-zero behavior.\n1485:   resolveLearnedBlendWeight,\n1486: };\n\n(End of file - total 1486 lines)\n</content>","metadata":{"preview":"      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] testing effect skipped (db unavailable): ${message}`);\n    }\n  }\n\n  // -- 4. Intent weights --\n  // G2 PREVENTION: Only apply for non-hybrid search types.\n  // Hybrid search (RRF / RSF) incorporates intent weighting during fusion —\n  // Applying it again here would double-count, causing the G2 bug.\n  if (!isHybrid && config.intentWeights) {\n    try {\n      const weighted = applyIntentWeightsToResults(results, config.intentWeights);\n      results = weighted.map((result) =>\n        typeof result.intentAdjustedScore === 'number'\n          ? withSyncedScoreAliases(result, result.intentAdjustedScore)\n          : result\n      );\n      metadata.intentWeightsApplied = 'applied';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","text":"      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] testing effect skipped (db unavailable): ${message}`);\n    }\n  }\n\n  // -- 4. Intent weights --\n  // G2 PREVENTION: Only apply for non-hybrid search types.\n  // Hybrid search (RRF / RSF) incorporates intent weighting during fusion —\n  // Applying it again here would double-count, causing the G2 bug.\n  if (!isHybrid && config.intentWeights) {\n    try {\n      const weighted = applyIntentWeightsToResults(results, config.intentWeights);\n      results = weighted.map((result) =>\n        typeof result.intentAdjustedScore === 'number'\n          ? withSyncedScoreAliases(result, result.intentAdjustedScore)\n          : result\n      );\n      metadata.intentWeightsApplied = 'applied';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] intent weights failed: ${message}`);\n      metadata.intentWeightsApplied = 'failed';\n    }\n  }\n\n  // -- 5. Artifact routing weights --\n  if (config.artifactRouting && config.artifactRouting.confidence > 0) {\n    try {\n      const routed = applyArtifactRouting(results, config.artifactRouting);\n      results = routed;\n      metadata.artifactRoutingApplied = 'applied';\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] artifact routing failed: ${message}`);\n      metadata.artifactRoutingApplied = 'failed';\n    }\n  }\n\n  // -- 6. Feedback signals --\n  try {\n    const withFeedback = applyFeedbackSignals(results, config.query);\n    // Detect if any score actually changed\n    const changed = withFeedback.some((r, i) => r !== results[i]);\n    if (changed) {\n      results = withFeedback;\n      metadata.feedbackSignalsApplied = 'applied';\n    }\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] feedback signals failed: ${message}`);\n    metadata.feedbackSignalsApplied = 'failed';\n  }\n\n  // -- 6a. Learned Stage 2 shadow scoring --\n  // Runs the learned linear ranker in parallel with the manual combiner.\n  // Shadow-only — scores are logged for comparison but never affect live ranking.\n  // Gated behind SPECKIT_LEARNED_STAGE2_COMBINER (default ON, graduated).\n  // When SPECKIT_LEARNED_STAGE2_BLEND_WEIGHT is set in (0, 0.05],\n  // a small guarded blend `(1-w)*manual + w*learned` is applied to the live\n  // score. Default 0 preserves shadow-only behavior. The blend weight is\n  // clamped at the source by resolveLearnedBlendWeight().\n  if (isLearnedStage2CombinerEnabled()) {\n    try {\n      const learnedShadowModel = await loadPersistedLearnedStage2Model();\n      // Weight resolved once per pipeline run; flag-gated and\n      // clamped. Zero means shadow-only (today's behavior).\n      const learnedBlendWeight = resolveLearnedBlendWeight();\n      for (let rowIndex = 0; rowIndex < results.length; rowIndex++) {\n        const row = results[rowIndex];\n        const features = extractFeatureVector({\n          rrfScore: row.rrfScore,\n          overlapScore: typeof row.overlapScore === 'number' ? row.overlapScore : undefined,\n          graphScore: (() => {\n            const gc = row.graphContribution as Record<string, unknown> | undefined;\n            const delta = typeof gc?.totalDelta === 'number' ? gc.totalDelta : 0;\n            return Math.max(0, Math.min(1, delta + 0.5));\n          })(),\n          sessionScore: typeof row.sessionScore === 'number' ? row.sessionScore : undefined,\n          causalScore: typeof row.causalScore === 'number' ? row.causalScore : undefined,\n          feedbackScore: typeof row.feedbackScore === 'number' ? row.feedbackScore : undefined,\n          validationScore: (() => {\n            const vm = row.validationMetadata as Record<string, unknown> | undefined;\n            return typeof vm?.qualityScore === 'number' ? vm.qualityScore : undefined;\n          })(),\n          artifactScore: typeof row.artifactBoostApplied === 'number'\n            ? Math.min(1, row.artifactBoostApplied / 2)\n            : undefined,\n        });\n        const shadow = shadowScore(learnedShadowModel, features, resolveBaseScore(row), true);\n        if (shadow) {\n          console.warn(\n            `[stage2-fusion] shadow-learned id=${row.id} manual=${shadow.manualScore.toFixed(4)} learned=${shadow.learnedScore.toFixed(4)} delta=${shadow.delta.toFixed(4)}`\n          );\n          // Apply the small guarded blend when weight > 0 AND a\n          // shadow result is available (model loaded successfully). Mutate\n          // the row through withSyncedScoreAliases so all score aliases stay\n          // aligned. When weight is 0 (default) or model failed to load, this\n          // branch is skipped and behavior is identical to pre-fix.\n          if (learnedBlendWeight > 0) {\n            const blendedScore = (1 - learnedBlendWeight) * shadow.manualScore\n              + learnedBlendWeight * shadow.learnedScore;\n            results[rowIndex] = withSyncedScoreAliases(row, blendedScore);\n          }\n        }\n      }\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] learned stage2 shadow scoring failed: ${message}`);\n    }\n  }\n\n  // -- 6a. Retrieval rescue + 7. Artifact-based result limiting --\n  // The routing strategy may specify a maxResults count stricter than the\n  // Overall pipeline limit. Apply it here so Stage 3 reranks a pre-trimmed set.\n  syncScoreAliasesInPlace(results);\n  if (isRetrievalRescueEnabled()) {\n    try {\n      let rescueDb: Database.Database | null = null;\n      try {\n        rescueDb = requireDb();\n      } catch {\n        rescueDb = null;\n      }\n      results = applyRetrievalRescueLayer(config.query, results, {\n        db: rescueDb,\n        artifactClass: config.artifactRouting?.strategy?.artifactClass as string | undefined\n          ?? config.artifactRouting?.detectedClass,\n      });\n      logger.debug('retrieval rescue layer completed', {\n        event: 'stage2_retrieval_rescue_success',\n        resultCount: results.length,\n        hasDb: rescueDb !== null,\n        artifactClass: config.artifactRouting?.strategy?.artifactClass\n          ?? config.artifactRouting?.detectedClass\n          ?? null,\n      });\n    } catch (err: unknown) {\n      const message = err instanceof Error ? err.message : String(err);\n      console.warn(`[stage2-fusion] retrieval rescue layer failed: ${message}`);\n    }\n  }\n  results = sortDeterministicRows(results as Array<PipelineRow & { id: number }>);\n  if (\n    config.artifactRouting &&\n    config.artifactRouting.confidence > 0 &&\n    typeof config.artifactRouting.strategy?.maxResults === 'number' &&\n    config.artifactRouting.strategy.maxResults > 0 &&\n    results.length > config.artifactRouting.strategy.maxResults\n  ) {\n    results = results.slice(0, config.artifactRouting.strategy.maxResults);\n  }\n\n  // -- Steps 8-9: Enrichment (extracted to stage2b-enrichment.ts) --\n  // Pure annotation: anchor metadata + validation metadata.\n  // Validation signal SCORING (applyValidationSignalScoring) stays here\n  // because it's a scoring step, not a pure enrichment.\n  results = executeStage2bEnrichment(results);\n  try {\n    results = applyValidationSignalScoring(results);\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(`[stage2-fusion] validation signal scoring failed: ${message}`);\n  }\n\n  // Keep all score aliases aligned after late-stage score mutations.\n  syncScoreAliasesInPlace(results);\n  if (metadata.graphContribution) {\n    metadata.graphContribution.causalBoosted = countGraphContribution(results, 'causalDelta');\n    metadata.graphContribution.coActivationBoosted = countGraphContribution(results, 'coActivationDelta');\n    metadata.graphContribution.communityInjected = countGraphContribution(results, 'communityDelta');\n    metadata.graphContribution.graphSignalsBoosted = countGraphContribution(results, 'graphSignalDelta');\n    metadata.graphContribution.totalGraphInjected = countGraphInjected(results);\n\n    // P2 fix: Diagnostic when graph is activated but contributes nothing\n    if (\n      !metadata.graphContribution.killSwitchActive &&\n      metadata.graphContribution.rolloutState === 'bounded_runtime' &&\n      metadata.graphContribution.causalBoosted === 0 &&\n      metadata.graphContribution.coActivationBoosted === 0 &&\n      metadata.graphContribution.communityInjected === 0 &&\n      metadata.graphContribution.graphSignalsBoosted === 0 &&\n      results.length > 0\n    ) {\n      console.warn(\n        '[stage2-fusion] Graph channel active (bounded_runtime) but zero contribution — causal_edges table may be sparse or candidates lack graph connectivity'\n      );\n    }\n  }\n\n  // -- Trace --\n  if (config.trace) {\n    addTraceEntry(\n      config.trace,\n      'fusion',\n      candidates.length,\n      results.length,\n      Date.now() - start,\n      {\n        sessionBoostApplied: metadata.sessionBoostApplied,\n        causalBoostApplied: metadata.causalBoostApplied,\n        intentWeightsApplied: metadata.intentWeightsApplied,\n        artifactRoutingApplied: metadata.artifactRoutingApplied,\n        feedbackSignalsApplied: metadata.feedbackSignalsApplied,\n        graphContribution: metadata.graphContribution,\n        searchType: config.searchType,\n        isHybrid,\n      }\n    );\n  }\n\n  metadata.durationMs = Date.now() - start;\n\n  return {\n    scored: results,\n    metadata,\n  };\n}\n\n// -- Test surface --\n\n/**\n * Internal functions exposed for unit testing.\n *\n * These are NOT part of the public API and may change without notice.\n * Access only from `*.test.ts` / `*.vitest.ts` files.\n */\nexport const __testables = {\n  resolveBaseScore,\n  strengthenOnAccess,\n  applyIntentWeightsToResults,\n  applyArtifactRouting,\n  applyFeedbackSignals,\n  applyUsageRankingBoost,\n  applyTestingEffect,\n  enrichResultsWithAnchorMetadata,\n  enrichResultsWithValidationMetadata,\n  applyValidationSignalScoring,\n  // Learned blend weight resolver, exposed for unit testing\n  // the env-var clamp and default-zero behavior.\n  resolveLearnedBlendWeight,\n};","lineStart":1246,"lineEnd":1486,"totalLines":1486,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/pipeline/stage2-fusion.ts","time":{"start":1781763792950,"end":1781763792961}},"metadata":{"openai":{"itemId":"fc_036c3a75fcdce96f016a338ed07ddc819183ffa3a57e601a4c"}},"id":"prt_ed965dfe60019hj9Dw5RhyYo3q","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed965a7a6001axABUKSXIuuHDU"}}
{"type":"tool_use","timestamp":1781763793025,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_yqTPjdzSnWPe5x1DgVV1AlrL","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","offset":1446,"limit":900},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts</path>\n<type>file</type>\n<content>\n1446:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1447:       }\n1448:     }\n1449: \n1450:     // Degree channel re-ranks based on causal-edge connectivity.\n1451:     // Graduated: default-ON. Set SPECKIT_DEGREE_BOOST=false to disable.\n1452:     // Degree channel — also gated by query-complexity routing\n1453:     if (activeChannels.has('degree') && db && isDegreeBoostEnabled()) {\n1454:       try {\n1455:         graphMetrics.degreeQueries++;\n1456:         // Collect all numeric IDs from existing channels\n1457:         const allResultIds = new Set<number>();\n1458:         for (const list of lists) {\n1459:           for (const r of list.results) {\n1460:             const id = r.id;\n1461:             if (typeof id === 'number') allResultIds.add(id);\n1462:           }\n1463:         }\n1464: \n1465:         if (allResultIds.size > 0) {\n1466:           const degreeScores = computeDegreeScores(db, Array.from(allResultIds));\n1467: \n1468:           // Build a ranked list sorted by degree score (highest first)\n1469:           const degreeItems: Array<{ id: number; degreeScore: number }> = [];\n1470:           for (const [idStr, score] of degreeScores) {\n1471:             const numId = Number(idStr);\n1472:             if (score > 0 && !isNaN(numId)) {\n1473:               degreeItems.push({ id: numId, degreeScore: score });\n1474:             }\n1475:           }\n1476:           degreeItems.sort((a, b) => b.degreeScore - a.degreeScore);\n1477: \n1478:           if (degreeItems.length > 0) {\n1479:             graphMetrics.degreeHits++;\n1480:             graphMetrics.degreeResultCount += degreeItems.length;\n1481:             lists.push({\n1482:               source: 'degree',\n1483:               results: degreeItems.map(item => ({\n1484:                 id: item.id,\n1485:                 degreeScore: item.degreeScore,\n1486:               })),\n1487:               weight: DEGREE_CHANNEL_WEIGHT,\n1488:             });\n1489:           }\n1490:         }\n1491:       } catch (_err: unknown) {\n1492:         // Non-critical — degree channel failure does not block pipeline\n1493:         console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n1494:       }\n1495:     }\n1496: \n1497:     // Merge keyword results after all channels complete\n1498:     const keywordResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [\n1499:       ...ftsChannelResults,\n1500:       ...bm25ChannelResults,\n1501:     ];\n1502: \n1503:     if (options.skipFusion) {\n1504:       return {\n1505:         evaluationMode,\n1506:         intent: options.intent || classifyIntent(query).intent,\n1507:         lists,\n1508:         routeResult,\n1509:         budgetResult,\n1510:         s3meta,\n1511:         vectorEmbeddingCache,\n1512:         fusedResults: collectCandidatesFromLists(\n1513:           lists.filter((list) => list.source !== 'degree'),\n1514:           options.limit ?? DEFAULT_LIMIT\n1515:         ),\n1516:       };\n1517:     }\n1518: \n1519:     if (lists.length === 0) {\n1520:       return null;\n1521:     }\n1522: \n1523:     // Track multi-source and graph-only results\n1524:     const sourceMap = new Map<string, Set<string>>();\n1525:     for (const list of lists) {\n1526:       for (const r of list.results) {\n1527:         const key = canonicalResultId(r.id);\n1528:         if (!sourceMap.has(key)) sourceMap.set(key, new Set());\n1529:         sourceMap.get(key)!.add(list.source); // non-null safe: has() guard above guarantees entry exists\n1530:       }\n1531:     }\n1532:     for (const [, sources] of sourceMap) {\n1533:       if (sources.size > 1) graphMetrics.multiSourceResults++;\n1534:       if (sources.size > 1 && sources.has('graph')) graphMetrics.graphMultiSourceResults++;\n1535:       if (sources.size === 1 && sources.has('graph')) graphMetrics.graphOnlyResults++;\n1536:     }\n1537: \n1538:     // Build weighted fusion lists once from lightweight adaptive\n1539:     // weights, avoiding the heavier hybridAdaptiveFuse() standard-first path.\n1540:     const detectedIntent = classifyIntent(query).intent;\n1541:     const intent = resolveFusionIntentContract({\n1542:       detectedIntent,\n1543:       adaptiveFusionIntent: options.intent ?? null,\n1544:       query,\n1545:     })\n1546:       ?? detectedIntent;\n1547:     const adaptiveEnabled = isAdaptiveFusionEnabled();\n1548:     const documentType = resolveAdaptiveDocumentType(lists.map((list) => ({\n1549:       results: list.results as Array<Record<string, unknown>>,\n1550:     })));\n1551:     const fusionWeights = adaptiveEnabled\n1552:       ? getAdaptiveWeights(intent, documentType)\n1553:       : { semanticWeight: 1.0, keywordWeight: 1.0, recencyWeight: 0 };\n1554:     const { semanticWeight, keywordWeight, graphWeight: adaptiveGraphWeight } = fusionWeights;\n1555:     const keywordFusionResults = keywordResults.map((result) => {\n1556:       const originalSource = typeof result.source === 'string' ? result.source : null;\n1557:       const existingSources = Array.isArray((result as Record<string, unknown>).sources)\n1558:         ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n1559:         : [];\n1560:       return {\n1561:         ...result,\n1562:         source: 'keyword',\n1563:         sources: Array.from(new Set([...existingSources, ...(originalSource ? [originalSource] : []), 'keyword'])),\n1564:       };\n1565:     });\n1566:     const fusionLists = lists\n1567:       .filter((list) => list.source !== 'fts' && list.source !== 'bm25')\n1568:       .map((list) => {\n1569:         if (list.source === 'vector') {\n1570:           return { ...list, weight: semanticWeight };\n1571:         }\n1572:         if (list.source === 'graph' && typeof adaptiveGraphWeight === 'number') {\n1573:           return { ...list, weight: adaptiveGraphWeight };\n1574:         }\n1575:         return { ...list };\n1576:       });\n1577: \n1578:     if (keywordFusionResults.length > 0 && keywordWeight > 0) {\n1579:       fusionLists.push({\n1580:         source: 'keyword',\n1581:         results: keywordFusionResults,\n1582:         weight: keywordWeight,\n1583:       });\n1584:     }\n1585: \n1586:     const graphList = fusionLists.find((list) => list.source === 'graph');\n1587:     const vectorList = fusionLists.find((list) => list.source === 'vector');\n1588:     const passthroughLists = fusionLists.filter((list) => list.source !== 'graph' && list.source !== 'vector' && list.source !== 'keyword');\n1589:     const fused = adaptiveEnabled\n1590:       ? (adaptiveFuse as unknown as (\n1591:         semanticResults: Array<Record<string, unknown>>,\n1592:         keywordResults: Array<Record<string, unknown>>,\n1593:         weights: typeof fusionWeights,\n1594:         options: {\n1595:           graphResults?: Array<Record<string, unknown>>;\n1596:           additionalLists?: typeof passthroughLists;\n1597:         },\n1598:       ) => FusionResult[])(\n1599:         (vectorList?.results ?? []) as Array<Record<string, unknown>>,\n1600:         keywordFusionResults,\n1601:         fusionWeights,\n1602:         {\n1603:           graphResults: (graphList?.results ?? []) as Array<Record<string, unknown>>,\n1604:           additionalLists: passthroughLists,\n1605:         },\n1606:       )\n1607:       : fuseResultsMulti(fusionLists);\n1608: \n1609:     const keywordSourceMap = new Map<string, string[]>();\n1610:     for (const result of keywordFusionResults) {\n1611:       const sources = Array.isArray((result as Record<string, unknown>).sources)\n1612:         ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n1613:         : [];\n1614:       if (sources.length > 0) {\n1615:         keywordSourceMap.set(canonicalResultId(result.id as number | string), sources);\n1616:       }\n1617:     }\n1618:     const triggerScoreMap = new Map<string, number>();\n1619:     for (const result of triggerChannelResults) {\n1620:       if (typeof result.triggerScore === 'number' && Number.isFinite(result.triggerScore)) {\n1621:         triggerScoreMap.set(canonicalResultId(result.id), result.triggerScore);\n1622:       }\n1623:     }\n1624: \n1625:     const fusedResults = fused.map(toHybridResult).map((row) => {\n1626:       const keywordSources = keywordSourceMap.get(canonicalResultId(row.id));\n1627:       if (keywordSources && keywordSources.length > 0) {\n1628:         const rowSources = Array.isArray(row.sources)\n1629:           ? row.sources.filter((source): source is string => typeof source === 'string')\n1630:           : [];\n1631:         const sources = Array.from(new Set([...rowSources, ...keywordSources]));\n1632:         row = {\n1633:           ...row,\n1634:           sources,\n1635:           channelAttribution: sources,\n1636:           source: row.source === 'keyword'\n1637:             ? (keywordSources.find((source) => source !== 'keyword') ?? row.source)\n1638:             : row.source,\n1639:         };\n1640:       }\n1641:       const triggerScore = triggerScoreMap.get(canonicalResultId(row.id));\n1642:       if (triggerScore !== undefined && typeof row.triggerScore !== 'number') {\n1643:         row = {\n1644:           ...row,\n1645:           triggerScore,\n1646:           exactTriggerMatch: triggerScore >= 0.94,\n1647:         };\n1648:       }\n1649:       const rowRecord = row as Record<string, unknown>;\n1650:       if (rowRecord.parentMemoryId !== undefined) return row;\n1651:       const normalizedParentMemoryId = rowRecord.parent_id ?? rowRecord.parentId;\n1652:       if (normalizedParentMemoryId === undefined) return row;\n1653:       return {\n1654:         ...row,\n1655:         parentMemoryId: normalizedParentMemoryId,\n1656:       };\n1657:     });\n1658: \n1659:     return {\n1660:       evaluationMode,\n1661:       intent,\n1662:       lists,\n1663:       routeResult,\n1664:       budgetResult,\n1665:       s3meta,\n1666:       vectorEmbeddingCache,\n1667:       fusedResults,\n1668:     };\n1669:   } catch (error: unknown) {\n1670:     const msg = error instanceof Error ? error.message : String(error);\n1671:     console.warn(`[hybrid-search] Enhanced search failed, falling back: ${msg}`);\n1672:     return null;\n1673:   }\n1674: }\n1675: \n1676: async function enrichFusedResults(\n1677:   query: string,\n1678:   execution: HybridFusionExecution,\n1679:   options: HybridSearchOptions = {},\n1680:   initialResults: HybridSearchResult[] = execution.fusedResults\n1681: ): Promise<HybridSearchResult[]> {\n1682:   enrichFusedResultsObserver?.();\n1683: \n1684:   const {\n1685:     evaluationMode,\n1686:     intent,\n1687:     lists,\n1688:     routeResult,\n1689:     budgetResult,\n1690:     s3meta,\n1691:     vectorEmbeddingCache,\n1692:   } = execution;\n1693:   let fusedHybridResults = initialResults;\n1694:   const limit = options.limit || DEFAULT_LIMIT;\n1695: \n1696:   // -- Aggregation stage: MPAB chunk-to-memory aggregation (after fusion, before state filter) --\n1697:   // When enabled, collapses chunk-level results back to their parent memory\n1698:   // Documents using MPAB scoring (sMax + 0.3 * sum(remaining) / sqrt(N)). This prevents\n1699:   // Multiple chunks from the same document dominating the result list.\n1700:   // MINOR-1 fix: isMpabEnabled() and isDocscoreAggregationEnabled() check the same env var\n1701:   if (isDocscoreAggregationEnabled()) {\n1702:     try {\n1703:       const chunkResults = fusedHybridResults.filter(\n1704:         r => (r as Record<string, unknown>).parentMemoryId != null && (r as Record<string, unknown>).chunkIndex != null\n1705:       );\n1706:       if (chunkResults.length > 0) {\n1707:         const nonChunkResults = fusedHybridResults.filter(\n1708:           r => (r as Record<string, unknown>).parentMemoryId == null || (r as Record<string, unknown>).chunkIndex == null\n1709:         );\n1710:         const collapsed = collapseAndReassembleChunkResults(\n1711:           chunkResults.map(r => ({\n1712:             id: r.id,\n1713:             parentMemoryId: (r as Record<string, unknown>).parentMemoryId as number | string,\n1714:             chunkIndex: (r as Record<string, unknown>).chunkIndex as number,\n1715:             score: r.score,\n1716:           }))\n1717:         );\n1718:         // Merge collapsed chunk results with non-chunk results\n1719:         fusedHybridResults = [\n1720:           ...collapsed.map(c => ({\n1721:             id: c.parentMemoryId,\n1722:             score: c.mpabScore,\n1723:             source: 'mpab' as string,\n1724:             _chunkHits: c._chunkHits,\n1725:           } as HybridSearchResult)),\n1726:           ...nonChunkResults,\n1727:         ];\n1728:       }\n1729:     } catch (_mpabErr: unknown) {\n1730:       // Non-critical — MPAB failure does not block pipeline\n1731:       const msg = _mpabErr instanceof Error ? _mpabErr.message : String(_mpabErr);\n1732:       console.error('[hybrid-search] MPAB error (non-fatal):', msg);\n1733:     }\n1734:   }\n1735: \n1736:   // -- Stage C: Channel Enforcement (SPECKIT_CHANNEL_MIN_REP) --\n1737:   // Ensures every channel that returned results has at least one representative\n1738:   // In the top-k window. Prevents single-channel dominance in fusion output.\n1739:   // When disabled, passes results through unchanged.\n1740:   try {\n1741:     const channelResultSets = new Map<string, Array<{ id: number | string; score: number; [key: string]: unknown }>>();\n1742:     for (const list of lists) {\n1743:       channelResultSets.set(list.source, list.results.map(r => ({\n1744:         ...r,\n1745:         id: r.id,\n1746:         score: typeof (r as Record<string, unknown>).score === 'number'\n1747:           ? (r as Record<string, unknown>).score as number\n1748:           : typeof (r as Record<string, unknown>).similarity === 'number'\n1749:             ? ((r as Record<string, unknown>).similarity as number) / 100\n1750:             : 0,\n1751:       })));\n1752:     }\n1753: \n1754:     const enforcementResult: EnforcementResult = enforceChannelRepresentation(\n1755:       fusedHybridResults.map(r => ({ ...r, source: r.source || 'hybrid' })),\n1756:       channelResultSets,\n1757:       limit,\n1758:     );\n1759: \n1760:     if (enforcementResult.enforcement.applied) {\n1761:       fusedHybridResults = dedupeResultsByCanonicalId(enforcementResult.results as HybridSearchResult[]);\n1762:       s3meta.enforcement = {\n1763:         applied: true,\n1764:         promotedCount: enforcementResult.enforcement.promotedCount,\n1765:         underRepresentedChannels: enforcementResult.enforcement.underRepresentedChannels,\n1766:       };\n1767:     }\n1768:   } catch (err: unknown) {\n1769:     // Non-critical — enforcement failure does not block pipeline\n1770:     console.warn('[hybrid-search] channel enforcement failed:', err instanceof Error ? err.message : String(err));\n1771:   }\n1772: \n1773:   // Preserve non-enumerable eval metadata across later array reallocations.\n1774:   const shadowMeta = initialResults as HybridSearchResult[] & ShadowMetaArray;\n1775:   const s4shadowMeta = shadowMeta._s4shadow;\n1776:   const s4attributionMeta = shadowMeta._s4attribution;\n1777:   const degradationMeta = shadowMeta._degradation;\n1778: \n1779:   // MMR reranking with request-scoped embedding cache.\n1780:   // Reuse embeddings already returned by the vector channel when present and\n1781:   // only query vec_memories for missing IDs.\n1782:   let reranked: HybridSearchResult[] = fusedHybridResults.slice(0, limit);\n1783: \n1784:   if (db && isMMREnabled()) {\n1785:     const numericIds = reranked\n1786:       .map(r => r.id)\n1787:       .filter((id): id is number => typeof id === 'number');\n1788: \n1789:     if (numericIds.length >= MMR_MIN_CANDIDATES) {\n1790:       try {\n1791:         const embeddingMap = new Map<number, Float32Array>(vectorEmbeddingCache);\n1792:         const missingIds = numericIds.filter((id) => !embeddingMap.has(id));\n1793: \n1794:         if (missingIds.length > 0) {\n1795:           const placeholders = missingIds.map(() => '?').join(', ');\n1796:           const embRows = (db.prepare(\n1797:             `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n1798:           ) as Database.Statement).all(...missingIds) as Array<{ rowid: number; embedding: Buffer }>;\n1799: \n1800:           for (const row of embRows) {\n1801:             if (Buffer.isBuffer(row.embedding)) {\n1802:               embeddingMap.set(\n1803:                 row.rowid,\n1804:                 new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n1805:               );\n1806:             }\n1807:           }\n1808:         }\n1809: \n1810:         const mmrCandidates: MMRCandidate[] = [];\n1811:         for (const r of reranked) {\n1812:           const emb = embeddingMap.get(r.id as number);\n1813:           if (emb) {\n1814:             mmrCandidates.push({\n1815:               id: r.id as number,\n1816:               score: (r.score as number) ?? 0,\n1817:               embedding: emb,\n1818:             });\n1819:           }\n1820:         }\n1821: \n1822:         if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n1823:           const mmrLambda = INTENT_LAMBDA_MAP[intent] ?? MMR_DEFAULT_LAMBDA;\n1824:           const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit });\n1825: \n1826:           // FIX #6: Same fix as stage3-rerank FIX #5 — MMR can only diversify\n1827:           // rows that have embeddings. Non-embedded rows (lexical-only hits,\n1828:           // graph injections) must be preserved and merged back in their\n1829:           // original relative order instead of being silently dropped.\n1830:           const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n1831:           const nonEmbeddedRows = reranked.filter(r => !embeddedIdSet.has(r.id as number));\n1832:           const rerankedById = new Map<string, HybridSearchResult>(\n1833:             reranked.map((result) => [canonicalResultId(result.id), result])\n1834:           );\n1835: \n1836:           const diversifiedRows = diversified.map((candidate): HybridSearchResult => {\n1837:             const existing = rerankedById.get(canonicalResultId(candidate.id));\n1838:             if (existing) {\n1839:               return existing;\n1840:             }\n1841: \n1842:             return {\n1843:               id: candidate.id,\n1844:               score: candidate.score,\n1845:               source: 'vector',\n1846:             };\n1847:           });\n1848: \n1849:           // Merge: diversified embedded rows first (MMR-ordered), then\n1850:           // non-embedded rows in their original relative order.\n1851:           reranked = [...diversifiedRows, ...nonEmbeddedRows];\n1852:         }\n1853:       } catch (embErr: unknown) {\n1854:         const msg = embErr instanceof Error ? embErr.message : String(embErr);\n1855:         console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n1856:       }\n1857:     }\n1858:   }\n1859: \n1860:   // Co-activation spreading — enrich with temporal neighbors\n1861:   const topIds = reranked\n1862:     .slice(0, SPREAD_ACTIVATION_TOP_N)\n1863:     .map(r => r.id)\n1864:     .filter((id): id is number => typeof id === 'number');\n1865:   if (topIds.length > 0) {\n1866:     try {\n1867:       const spreadResults: SpreadResult[] = spreadActivation(topIds);\n1868:       // Boost scores of results that appear in co-activation graph\n1869:       if (spreadResults.length > 0) {\n1870:         const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n1871:         for (const result of reranked) {\n1872:           const boost = spreadMap.get(result.id as number);\n1873:           if (boost !== undefined) {\n1874:             // Update all score aliases so downstream consumers see the boost.\n1875:             const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n1876:             (result as Record<string, unknown>).score = boostedScore;\n1877:             if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n1878:             if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n1879:           }\n1880:         }\n1881:       }\n1882:       // Re-sort after co-activation boost to ensure boosted results\n1883:       // Are promoted to their correct position in the ranking\n1884:       reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n1885:     } catch (err: unknown) {\n1886:       // Non-critical enrichment — co-activation failure does not affect core ranking\n1887:       console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n1888:     }\n1889:   }\n1890: \n1891:   // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n1892:   if (db && isFolderScoringEnabled() && reranked.length > 0) {\n1893:     try {\n1894:       const numericIds = reranked\n1895:         .map(r => r.id)\n1896:         .filter((id): id is number => typeof id === 'number');\n1897: \n1898:       if (numericIds.length > 0) {\n1899:         const folderMap = lookupFolders(db, numericIds);\n1900:         if (folderMap.size > 0) {\n1901:           const folderScores = computeFolderRelevanceScores(reranked, folderMap);\n1902:           const rawTopK = process.env.SPECKIT_FOLDER_TOP_K;\n1903:           const parsedTopK = rawTopK ? parseInt(rawTopK, 10) : NaN;\n1904:           const topK = Number.isFinite(parsedTopK) && parsedTopK > 0 ? parsedTopK : 5;\n1905: \n1906:           const twoPhaseResults = twoPhaseRetrieval(reranked, folderScores, folderMap, topK);\n1907:           const postFolderResults = twoPhaseResults.length > 0 ? twoPhaseResults : reranked;\n1908:           reranked = enrichResultsWithFolderScores(postFolderResults, folderScores, folderMap) as HybridSearchResult[];\n1909:         }\n1910:       }\n1911:     } catch (_folderErr: unknown) {\n1912:       // Folder scoring is optional and must not break retrieval\n1913:     }\n1914:   }\n1915: \n1916:   // -- Stage D: Confidence Truncation (SPECKIT_CONFIDENCE_TRUNCATION) --\n1917:   // Run after the ranking pipeline so later boosts/promotions can rescue\n1918:   // candidates before low-confidence tails are trimmed.\n1919:   if (!evaluationMode) {\n1920:     try {\n1921:       const truncationResult: TruncationResult = truncateByConfidence(\n1922:         reranked.map(r => ({ ...r, id: r.id, score: r.score })),\n1923:       );\n1924: \n1925:       if (truncationResult.truncated) {\n1926:         reranked = truncationResult.results.map(r => r as HybridSearchResult);\n1927:         s3meta.truncation = {\n1928:           truncated: true,\n1929:           originalCount: truncationResult.originalCount,\n1930:           truncatedCount: truncationResult.truncatedCount,\n1931:           medianGap: truncationResult.medianGap,\n1932:           cutoffGap: truncationResult.cutoffGap,\n1933:           cutoffIndex: truncationResult.cutoffIndex,\n1934:           thresholdMultiplier: GAP_THRESHOLD_MULTIPLIER,\n1935:           minResultsGuaranteed: DEFAULT_MIN_RESULTS,\n1936:           featureFlagEnabled: isConfidenceTruncationEnabled(),\n1937:         };\n1938:       }\n1939:     } catch (err: unknown) {\n1940:       // Non-critical — truncation failure does not block pipeline\n1941:       console.warn('[hybrid-search] confidence truncation failed:', err instanceof Error ? err.message : String(err));\n1942:     }\n1943:   }\n1944: \n1945:   // Preserve routing and Stage 4 trace metadata as explicit result fields so downstream\n1946:   // Formatters can opt-in to provenance-rich envelopes without relying on\n1947:   // Non-enumerable array shadow properties.\n1948:   if (reranked.length > 0) {\n1949:     reranked = reranked.map((row): HybridSearchResult => {\n1950:       const existingTraceMetadata =\n1951:         typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n1952:           ? row.traceMetadata\n1953:           : {};\n1954: \n1955:       return {\n1956:         ...row,\n1957:         traceMetadata: {\n1958:           ...existingTraceMetadata,\n1959:           ...(s4shadowMeta !== undefined ? { stage4: s4shadowMeta } : {}),\n1960:           ...(s4attributionMeta !== undefined ? { attribution: s4attributionMeta } : {}),\n1961:           ...(degradationMeta !== undefined ? { degradation: degradationMeta } : {}),\n1962:           evaluationMode,\n1963:           // Wire queryComplexity from router classification into trace\n1964:           queryComplexity: routeResult.tier,\n1965:           // Wire confidence truncation metadata into per-result trace (036)\n1966:           ...(s3meta.truncation ? {\n1967:             confidenceTruncation: {\n1968:               truncated: s3meta.truncation.truncated,\n1969:               originalCount: s3meta.truncation.originalCount,\n1970:               truncatedCount: s3meta.truncation.truncatedCount,\n1971:               medianGap: s3meta.truncation.medianGap,\n1972:               cutoffGap: s3meta.truncation.cutoffGap,\n1973:               cutoffIndex: s3meta.truncation.cutoffIndex,\n1974:               thresholdMultiplier: s3meta.truncation.thresholdMultiplier,\n1975:               minResultsGuaranteed: s3meta.truncation.minResultsGuaranteed,\n1976:             },\n1977:           } : {}),\n1978:         },\n1979:       };\n1980:     });\n1981:   }\n1982: \n1983:   if (isContextHeadersEnabled() && reranked.length > 0) {\n1984:     const descriptionCache = buildDescriptionTailMap();\n1985:     if (descriptionCache.size > 0) {\n1986:       reranked = reranked.map((row) => injectContextualTree(row, descriptionCache));\n1987:     }\n1988:   }\n1989: \n1990:   let budgetTruncated = false;\n1991:   let budgetLimit: number | undefined;\n1992:   if (evaluationMode) {\n1993:     reranked = applyResultLimit(reranked, options.limit);\n1994:   } else {\n1995:     // Apply token budget truncation after trace/header enrichment so token\n1996:     // estimates reflect the actual returned payload shape.\n1997:     const headerOverhead = isContextHeadersEnabled()\n1998:       ? reranked.length * CONTEXT_HEADER_TOKEN_OVERHEAD\n1999:       : 0;\n2000:     const adjustedBudget = Math.max(budgetResult.budget - headerOverhead, 200);\n2001: \n2002:     if (s3meta.tokenBudget) {\n2003:       s3meta.tokenBudget.headerOverhead = headerOverhead;\n2004:       s3meta.tokenBudget.adjustedBudget = adjustedBudget;\n2005:     }\n2006: \n2007:     const budgeted = truncateToBudget(reranked, adjustedBudget, {\n2008:       includeContent: options.includeContent ?? false,\n2009:       queryId: `hybrid-${Date.now()}`,\n2010:       limit: options.limit,\n2011:       query,\n2012:     });\n2013:     reranked = budgeted.results;\n2014:     budgetTruncated = budgeted.truncated;\n2015:     budgetLimit = budgetResult.budget;\n2016: \n2017:     // Cosine-primary head reorder (SPECKIT_COSINE_TOPN_REORDER, default-ON).\n2018:     // Must run AFTER truncateToBudget: that step re-sorts the survivors by the\n2019:     // fused `score`, so a pre-truncation reorder would be clobbered. Applied to\n2020:     // the budgeted survivors it is the last word on order without disturbing the\n2021:     // budget membership decision. Skipped in evaluationMode so the labeled-set\n2022:     // top-K window stays exactly as fused.\n2023:     if (isCosineTopnReorderEnabled() && reranked.length > 1) {\n2024:       reranked = reorderTopNByCosine(reranked);\n2025:     }\n2026:   }\n2027: \n2028:   if (reranked.length > 0) {\n2029:     reranked = reranked.map((row): HybridSearchResult => {\n2030:       const existingTraceMetadata =\n2031:         typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n2032:           ? row.traceMetadata\n2033:           : {};\n2034: \n2035:       return {\n2036:         ...row,\n2037:         traceMetadata: {\n2038:           ...existingTraceMetadata,\n2039:           budgetTruncated,\n2040:           ...(budgetLimit !== undefined ? { budgetLimit } : {}),\n2041:         },\n2042:       };\n2043:     });\n2044:   }\n2045: \n2046:   if (s4shadowMeta !== undefined && reranked.length > 0) {\n2047:     Object.defineProperty(reranked, '_s4shadow', {\n2048:       value: s4shadowMeta,\n2049:       enumerable: false,\n2050:       configurable: true,\n2051:     });\n2052:   }\n2053: \n2054:   if (s4attributionMeta !== undefined && reranked.length > 0) {\n2055:     Object.defineProperty(reranked, '_s4attribution', {\n2056:       value: s4attributionMeta,\n2057:       enumerable: false,\n2058:       configurable: true,\n2059:     });\n2060:   }\n2061: \n2062:   // Attach pipeline metadata to results for eval/debugging\n2063:   // Metadata is attached as non-enumerable _s3meta property to avoid\n2064:   // Polluting result serialization while remaining accessible for debugging.\n2065:   if (Object.keys(s3meta).length > 0 && reranked.length > 0) {\n2066:     Object.defineProperty(reranked, '_s3meta', { value: s3meta, enumerable: false, configurable: true });\n2067:   }\n2068: \n2069:   return reranked;\n2070: }\n2071: \n2072: /**\n2073:  * Collect pipeline candidates through the adaptive fallback chain, returning\n2074:  * immediately after intra-query fusion and before downstream aggregation,\n2075:  * reranking, or post-processing.\n2076:  *\n2077:  * @param query - The search query string.\n2078:  * @param embedding - Optional embedding vector for semantic search.\n2079:  * @param options - Hybrid search configuration options.\n2080:  * @returns Unfused candidate results from the first non-empty collection stage.\n2081:  */\n2082: async function collectRawCandidates(\n2083:   query: string,\n2084:   embedding: Float32Array | number[] | null,\n2085:   options: HybridSearchOptions = {}\n2086: ): Promise<HybridSearchResult[]> {\n2087:   const { allowedChannels, stages } = await executeFallbackPlan(\n2088:     query,\n2089:     embedding,\n2090:     options,\n2091:     isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n2092:     { stopAfterFusion: true }\n2093:   );\n2094: \n2095:   const primaryResults = stages[0]?.results ?? [];\n2096:   const retryResults = stages[1]?.results ?? [];\n2097: \n2098:   if (isSearchFallbackEnabled()) {\n2099:     const mergedResults = retryResults.length > 0\n2100:       ? mergeRawCandidateSets(primaryResults, retryResults, options.limit)\n2101:       : primaryResults;\n2102:     if (mergedResults.length > 0) return applyResultLimit(mergedResults, options.limit);\n2103:   } else {\n2104:     const stagedResults = retryResults.length > 0 ? retryResults : primaryResults;\n2105:     if (stagedResults.length > 0) return applyResultLimit(stagedResults, options.limit);\n2106:   }\n2107: \n2108:   if (allowedChannels.has('fts')) {\n2109:     const ftsFallback = collectCandidatesFromLists(\n2110:       [{ source: 'fts', results: ftsSearch(query, options) }],\n2111:       options.limit\n2112:     );\n2113:     if (ftsFallback.length > 0) return ftsFallback;\n2114:   }\n2115: \n2116:   if (allowedChannels.has('bm25')) {\n2117:     const bm25Fallback = collectCandidatesFromLists(\n2118:       [{ source: 'bm25', results: bm25Search(query, options) }],\n2119:       options.limit\n2120:     );\n2121:     if (bm25Fallback.length > 0) return bm25Fallback;\n2122:   }\n2123: \n2124:   console.warn('[hybrid-search] Raw candidate collection returned empty results');\n2125:   return [];\n2126: }\n2127: \n2128: /**\n2129:  * Search with automatic fallback chain.\n2130:  * When SPECKIT_SEARCH_FALLBACK=true: delegates to the 3-tier quality-aware\n2131:    * fallback (searchWithFallbackTiered). Otherwise: two-pass adaptive\n2132:  * fallback — primary at minSimilarity=30, retry at 17.\n2133:  *\n2134:  * @param query - The search query string.\n2135:  * @param embedding - Optional embedding vector for semantic search.\n2136:  * @param options - Hybrid search configuration options.\n2137:  * @returns Results from the first non-empty stage.\n2138:  */\n2139: async function searchWithFallback(\n2140:   query: string,\n2141:   embedding: Float32Array | number[] | null,\n2142:   options: HybridSearchOptions = {}\n2143: ): Promise<HybridSearchResult[]> {\n2144:   // PI-A2: Delegate to tiered fallback when flag is enabled\n2145:   if (isSearchFallbackEnabled()) {\n2146:     return searchWithFallbackTiered(query, embedding, options);\n2147:   }\n2148: \n2149:   // Primary 30 filters noise; fallback 17 widens recall for sparse corpora\n2150:   // Where no result exceeds the primary threshold — chosen empirically via eval.\n2151:   // Use hybridSearchEnhanced (with RRF fusion) instead of\n2152:   // The naive hybridSearch that merges raw scores\n2153:   const { allowedChannels, stages } = await executeFallbackPlan(\n2154:     query,\n2155:     embedding,\n2156:     options,\n2157:     'adaptive'\n2158:   );\n2159:   const primaryStage = stages[0];\n2160:   const retryStage = stages[1];\n2161:   const finalStage = retryStage?.results.length ? retryStage : primaryStage;\n2162:   if (finalStage?.results.length) {\n2163:     return finalStage.execution\n2164:       ? enrichFusedResults(query, finalStage.execution, finalStage.options, finalStage.results)\n2165:       : finalStage.results;\n2166:   }\n2167: \n2168:   // Fallback to FTS only\n2169:   if (allowedChannels.has('fts')) {\n2170:     const ftsResults = ftsSearch(query, options);\n2171:     if (ftsResults.length > 0) return ftsResults;\n2172:   }\n2173: \n2174:   // Fallback to BM25 only\n2175:   if (allowedChannels.has('bm25')) {\n2176:     const bm25Results = bm25Search(query, options);\n2177:     if (bm25Results.length > 0) return bm25Results;\n2178:   }\n2179: \n2180:   console.warn('[hybrid-search] All search methods returned empty results');\n2181:   return [];\n2182: }\n2183: \n2184: // 12. STRUCTURAL SEARCH (PI-A2 TIER 3)\n2185: \n2186: /**\n2187:  * PI-A2: Last-resort structural search against the memory_index table.\n2188:  * Retrieves memories ordered by importance tier and weight, without\n2189:  * requiring embeddings or text similarity. Pure SQL fallback.\n2190:  *\n2191:  * @param options - Search options (specFolder for filtering, limit for cap).\n2192:  * @returns Array of HybridSearchResult with source='structural'.\n2193:  */\n2194: function structuralSearch(\n2195:   options: Pick<HybridSearchOptions, 'specFolder' | 'limit'> = {}\n2196: ): HybridSearchResult[] {\n2197:   if (!db) {\n2198:     console.warn('[hybrid-search] db not initialized — returning empty structuralSearch results');\n2199:     return [];\n2200:   }\n2201: \n2202:   const limit = options.limit ?? DEFAULT_LIMIT;\n2203: \n2204:   try {\n2205:     // Build SQL with optional specFolder filter\n2206:     // Exclude archived rows unless explicitly requested\n2207:     const conditions = [\n2208:       `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n2209:     ];\n2210:     const params: unknown[] = [];\n2211: \n2212:     if (options.specFolder) {\n2213:       conditions.push(`(spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')`);\n2214:       params.push(options.specFolder, specFolderLikePattern(options.specFolder));\n2215:     }\n2216: \n2217:     const whereClause = conditions.join(' AND ');\n2218: \n2219:     const sql = `\n2220:       SELECT id, title, file_path, importance_tier, importance_weight, spec_folder\n2221:       FROM memory_index\n2222:       WHERE ${whereClause}\n2223:       ORDER BY\n2224:         CASE importance_tier\n2225:           WHEN 'constitutional' THEN 1\n2226:           WHEN 'critical' THEN 2\n2227:           WHEN 'important' THEN 3\n2228:           WHEN 'normal' THEN 4\n2229:           WHEN 'temporary' THEN 5\n2230:           ELSE 6\n2231:         END ASC,\n2232:         importance_weight DESC,\n2233:         created_at DESC\n2234:       LIMIT ?\n2235:     `;\n2236:     params.push(limit);\n2237: \n2238:     const stmt = db.prepare(sql);\n2239:     const rows = stmt.all(...params) as Array<Record<string, unknown>>;\n2240: \n2241:     return rows.map((row, index) => ({\n2242:       id: row.id as number,\n2243:       score: Math.max(0, 1.0 - index * 0.05),\n2244:       source: 'structural',\n2245:       title: (row.title as string) ?? undefined,\n2246:       file_path: row.file_path as string,\n2247:       importance_tier: row.importance_tier as string,\n2248:       spec_folder: row.spec_folder as string,\n2249:     }));\n2250:   } catch (error: unknown) {\n2251:     const msg = error instanceof Error ? error.message : String(error);\n2252:     console.warn(`[hybrid-search] Structural search failed: ${msg}`);\n2253:     return [];\n2254:   }\n2255: }\n2256: \n2257: /**\n2258:  * Normalize result IDs to a canonical key used for deduplication and source tracking.\n2259:  * Handles number-vs-string drift (`42` vs `\"42\"`) and legacy `mem:42` forms.\n2260:  */\n2261: function canonicalResultId(id: number | string): string {\n2262:   if (typeof id === 'number') {\n2263:     return String(id);\n2264:   }\n2265: \n2266:   const raw = String(id).trim();\n2267:   const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n2268:   if (memPrefixed) {\n2269:     return String(Number(memPrefixed[1]));\n2270:   }\n2271: \n2272:   if (/^\\d+$/.test(raw)) {\n2273:     return String(Number(raw));\n2274:   }\n2275: \n2276:   return raw;\n2277: }\n2278: \n2279: function truncateChars(input: string, maxChars: number): string {\n2280:   if (input.length <= maxChars) return input;\n2281:   if (maxChars <= 1) return input.slice(0, maxChars);\n2282:   return `${input.slice(0, maxChars - 1).trimEnd()}…`;\n2283: }\n2284: \n2285: function extractSpecSegments(filePath: string): { left: string; right: string; tailKey: string } | null {\n2286:   const normalized = filePath.replace(/\\\\/g, '/');\n2287:   const splitToken = '/specs/';\n2288:   const splitIdx = normalized.lastIndexOf(splitToken);\n2289:   if (splitIdx < 0) return null;\n2290: \n2291:   const relative = normalized.slice(splitIdx + splitToken.length).replace(/^\\/+/, '');\n2292:   const parts = relative.split('/').filter(Boolean);\n2293:   if (parts.length < 2) return null;\n2294: \n2295:   // Prefer spec-folder extraction up to /memory/ so we get [parent > child]\n2296:   // For canonical memory paths like:\n2297:   // .../specs/<parent>/<child>/memory/<file>.md\n2298:   const memoryIdx = parts.indexOf('memory');\n2299:   const scopeParts = memoryIdx >= 0 ? parts.slice(0, memoryIdx) : parts.slice(0, -1);\n2300:   const tailParts = scopeParts.slice(-2);\n2301:   if (tailParts.length < 2) return null;\n2302: \n2303:   return {\n2304:     left: tailParts[0],\n2305:     right: tailParts[1],\n2306:     tailKey: tailParts.join('/'),\n2307:   };\n2308: }\n2309: \n2310: // Memoize description map to avoid rebuilding on every search query.\n2311: // Cache invalidates after 60 seconds so folder renames are eventually picked up.\n2312: // Return stale cache immediately and refresh asynchronously to avoid\n2313: // blocking the search hot path with synchronous filesystem crawls.\n2314: let descMapCache: { map: Map<string, string>; timestamp: number } | null = null;\n2315: let descMapRefreshing = false;\n2316: const DESC_MAP_TTL_MS = 60_000;\n2317: \n2318: function rebuildDescriptionTailMap(): Map<string, string> {\n2319:   const descByTail = new Map<string, string>();\n2320:   const cache = ensureDescriptionCache(getSpecsBasePaths());\n2321:   if (!cache || !Array.isArray(cache.folders)) {\n2322:     return descByTail;\n2323:   }\n2324: \n2325:   for (const entry of cache.folders) {\n2326:     const specFolder = typeof entry.specFolder === 'string' ? entry.specFolder : '';\n2327:     const description = typeof entry.description === 'string' ? entry.description : '';\n2328:     if (!specFolder || !description) continue;\n2329:     const folderParts = specFolder.split('/').filter(Boolean);\n2330:     if (folderParts.length < 2) continue;\n2331:     const tailKey = folderParts.slice(-2).join('/');\n2332:     if (!descByTail.has(tailKey)) {\n2333:       descByTail.set(tailKey, description);\n2334:     }\n2335:   }\n2336: \n2337:   return descByTail;\n2338: }\n2339: \n2340: function buildDescriptionTailMap(): Map<string, string> {\n2341:   // Fresh cache — return immediately\n2342:   if (descMapCache && (Date.now() - descMapCache.timestamp) < DESC_MAP_TTL_MS) {\n2343:     return descMapCache.map;\n2344:   }\n2345: \n\n(Showing lines 1446-2345 of 2972. Use offset=2346 to continue.)\n</content>","metadata":{"preview":"        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // Degree channel re-ranks based on causal-edge connectivity.\n    // Graduated: default-ON. Set SPECKIT_DEGREE_BOOST=false to disable.\n    // Degree channel — also gated by query-complexity routing\n    if (activeChannels.has('degree') && db && isDegreeBoostEnabled()) {\n      try {\n        graphMetrics.degreeQueries++;\n        // Collect all numeric IDs from existing channels\n        const allResultIds = new Set<number>();\n        for (const list of lists) {\n          for (const r of list.results) {\n            const id = r.id;\n            if (typeof id === 'number') allResultIds.add(id);\n          }\n        }\n\n        if (allResultIds.size > 0) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","text":"        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // Degree channel re-ranks based on causal-edge connectivity.\n    // Graduated: default-ON. Set SPECKIT_DEGREE_BOOST=false to disable.\n    // Degree channel — also gated by query-complexity routing\n    if (activeChannels.has('degree') && db && isDegreeBoostEnabled()) {\n      try {\n        graphMetrics.degreeQueries++;\n        // Collect all numeric IDs from existing channels\n        const allResultIds = new Set<number>();\n        for (const list of lists) {\n          for (const r of list.results) {\n            const id = r.id;\n            if (typeof id === 'number') allResultIds.add(id);\n          }\n        }\n\n        if (allResultIds.size > 0) {\n          const degreeScores = computeDegreeScores(db, Array.from(allResultIds));\n\n          // Build a ranked list sorted by degree score (highest first)\n          const degreeItems: Array<{ id: number; degreeScore: number }> = [];\n          for (const [idStr, score] of degreeScores) {\n            const numId = Number(idStr);\n            if (score > 0 && !isNaN(numId)) {\n              degreeItems.push({ id: numId, degreeScore: score });\n            }\n          }\n          degreeItems.sort((a, b) => b.degreeScore - a.degreeScore);\n\n          if (degreeItems.length > 0) {\n            graphMetrics.degreeHits++;\n            graphMetrics.degreeResultCount += degreeItems.length;\n            lists.push({\n              source: 'degree',\n              results: degreeItems.map(item => ({\n                id: item.id,\n                degreeScore: item.degreeScore,\n              })),\n              weight: DEGREE_CHANNEL_WEIGHT,\n            });\n          }\n        }\n      } catch (_err: unknown) {\n        // Non-critical — degree channel failure does not block pipeline\n        console.warn('[hybrid-search] Channel error:', _err instanceof Error ? _err.message : String(_err));\n      }\n    }\n\n    // Merge keyword results after all channels complete\n    const keywordResults: Array<{ id: number | string; source: string; [key: string]: unknown }> = [\n      ...ftsChannelResults,\n      ...bm25ChannelResults,\n    ];\n\n    if (options.skipFusion) {\n      return {\n        evaluationMode,\n        intent: options.intent || classifyIntent(query).intent,\n        lists,\n        routeResult,\n        budgetResult,\n        s3meta,\n        vectorEmbeddingCache,\n        fusedResults: collectCandidatesFromLists(\n          lists.filter((list) => list.source !== 'degree'),\n          options.limit ?? DEFAULT_LIMIT\n        ),\n      };\n    }\n\n    if (lists.length === 0) {\n      return null;\n    }\n\n    // Track multi-source and graph-only results\n    const sourceMap = new Map<string, Set<string>>();\n    for (const list of lists) {\n      for (const r of list.results) {\n        const key = canonicalResultId(r.id);\n        if (!sourceMap.has(key)) sourceMap.set(key, new Set());\n        sourceMap.get(key)!.add(list.source); // non-null safe: has() guard above guarantees entry exists\n      }\n    }\n    for (const [, sources] of sourceMap) {\n      if (sources.size > 1) graphMetrics.multiSourceResults++;\n      if (sources.size > 1 && sources.has('graph')) graphMetrics.graphMultiSourceResults++;\n      if (sources.size === 1 && sources.has('graph')) graphMetrics.graphOnlyResults++;\n    }\n\n    // Build weighted fusion lists once from lightweight adaptive\n    // weights, avoiding the heavier hybridAdaptiveFuse() standard-first path.\n    const detectedIntent = classifyIntent(query).intent;\n    const intent = resolveFusionIntentContract({\n      detectedIntent,\n      adaptiveFusionIntent: options.intent ?? null,\n      query,\n    })\n      ?? detectedIntent;\n    const adaptiveEnabled = isAdaptiveFusionEnabled();\n    const documentType = resolveAdaptiveDocumentType(lists.map((list) => ({\n      results: list.results as Array<Record<string, unknown>>,\n    })));\n    const fusionWeights = adaptiveEnabled\n      ? getAdaptiveWeights(intent, documentType)\n      : { semanticWeight: 1.0, keywordWeight: 1.0, recencyWeight: 0 };\n    const { semanticWeight, keywordWeight, graphWeight: adaptiveGraphWeight } = fusionWeights;\n    const keywordFusionResults = keywordResults.map((result) => {\n      const originalSource = typeof result.source === 'string' ? result.source : null;\n      const existingSources = Array.isArray((result as Record<string, unknown>).sources)\n        ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n        : [];\n      return {\n        ...result,\n        source: 'keyword',\n        sources: Array.from(new Set([...existingSources, ...(originalSource ? [originalSource] : []), 'keyword'])),\n      };\n    });\n    const fusionLists = lists\n      .filter((list) => list.source !== 'fts' && list.source !== 'bm25')\n      .map((list) => {\n        if (list.source === 'vector') {\n          return { ...list, weight: semanticWeight };\n        }\n        if (list.source === 'graph' && typeof adaptiveGraphWeight === 'number') {\n          return { ...list, weight: adaptiveGraphWeight };\n        }\n        return { ...list };\n      });\n\n    if (keywordFusionResults.length > 0 && keywordWeight > 0) {\n      fusionLists.push({\n        source: 'keyword',\n        results: keywordFusionResults,\n        weight: keywordWeight,\n      });\n    }\n\n    const graphList = fusionLists.find((list) => list.source === 'graph');\n    const vectorList = fusionLists.find((list) => list.source === 'vector');\n    const passthroughLists = fusionLists.filter((list) => list.source !== 'graph' && list.source !== 'vector' && list.source !== 'keyword');\n    const fused = adaptiveEnabled\n      ? (adaptiveFuse as unknown as (\n        semanticResults: Array<Record<string, unknown>>,\n        keywordResults: Array<Record<string, unknown>>,\n        weights: typeof fusionWeights,\n        options: {\n          graphResults?: Array<Record<string, unknown>>;\n          additionalLists?: typeof passthroughLists;\n        },\n      ) => FusionResult[])(\n        (vectorList?.results ?? []) as Array<Record<string, unknown>>,\n        keywordFusionResults,\n        fusionWeights,\n        {\n          graphResults: (graphList?.results ?? []) as Array<Record<string, unknown>>,\n          additionalLists: passthroughLists,\n        },\n      )\n      : fuseResultsMulti(fusionLists);\n\n    const keywordSourceMap = new Map<string, string[]>();\n    for (const result of keywordFusionResults) {\n      const sources = Array.isArray((result as Record<string, unknown>).sources)\n        ? ((result as Record<string, unknown>).sources as unknown[]).filter((source): source is string => typeof source === 'string')\n        : [];\n      if (sources.length > 0) {\n        keywordSourceMap.set(canonicalResultId(result.id as number | string), sources);\n      }\n    }\n    const triggerScoreMap = new Map<string, number>();\n    for (const result of triggerChannelResults) {\n      if (typeof result.triggerScore === 'number' && Number.isFinite(result.triggerScore)) {\n        triggerScoreMap.set(canonicalResultId(result.id), result.triggerScore);\n      }\n    }\n\n    const fusedResults = fused.map(toHybridResult).map((row) => {\n      const keywordSources = keywordSourceMap.get(canonicalResultId(row.id));\n      if (keywordSources && keywordSources.length > 0) {\n        const rowSources = Array.isArray(row.sources)\n          ? row.sources.filter((source): source is string => typeof source === 'string')\n          : [];\n        const sources = Array.from(new Set([...rowSources, ...keywordSources]));\n        row = {\n          ...row,\n          sources,\n          channelAttribution: sources,\n          source: row.source === 'keyword'\n            ? (keywordSources.find((source) => source !== 'keyword') ?? row.source)\n            : row.source,\n        };\n      }\n      const triggerScore = triggerScoreMap.get(canonicalResultId(row.id));\n      if (triggerScore !== undefined && typeof row.triggerScore !== 'number') {\n        row = {\n          ...row,\n          triggerScore,\n          exactTriggerMatch: triggerScore >= 0.94,\n        };\n      }\n      const rowRecord = row as Record<string, unknown>;\n      if (rowRecord.parentMemoryId !== undefined) return row;\n      const normalizedParentMemoryId = rowRecord.parent_id ?? rowRecord.parentId;\n      if (normalizedParentMemoryId === undefined) return row;\n      return {\n        ...row,\n        parentMemoryId: normalizedParentMemoryId,\n      };\n    });\n\n    return {\n      evaluationMode,\n      intent,\n      lists,\n      routeResult,\n      budgetResult,\n      s3meta,\n      vectorEmbeddingCache,\n      fusedResults,\n    };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Enhanced search failed, falling back: ${msg}`);\n    return null;\n  }\n}\n\nasync function enrichFusedResults(\n  query: string,\n  execution: HybridFusionExecution,\n  options: HybridSearchOptions = {},\n  initialResults: HybridSearchResult[] = execution.fusedResults\n): Promise<HybridSearchResult[]> {\n  enrichFusedResultsObserver?.();\n\n  const {\n    evaluationMode,\n    intent,\n    lists,\n    routeResult,\n    budgetResult,\n    s3meta,\n    vectorEmbeddingCache,\n  } = execution;\n  let fusedHybridResults = initialResults;\n  const limit = options.limit || DEFAULT_LIMIT;\n\n  // -- Aggregation stage: MPAB chunk-to-memory aggregation (after fusion, before state filter) --\n  // When enabled, collapses chunk-level results back to their parent memory\n  // Documents using MPAB scoring (sMax + 0.3 * sum(remaining) / sqrt(N)). This prevents\n  // Multiple chunks from the same document dominating the result list.\n  // MINOR-1 fix: isMpabEnabled() and isDocscoreAggregationEnabled() check the same env var\n  if (isDocscoreAggregationEnabled()) {\n    try {\n      const chunkResults = fusedHybridResults.filter(\n        r => (r as Record<string, unknown>).parentMemoryId != null && (r as Record<string, unknown>).chunkIndex != null\n      );\n      if (chunkResults.length > 0) {\n        const nonChunkResults = fusedHybridResults.filter(\n          r => (r as Record<string, unknown>).parentMemoryId == null || (r as Record<string, unknown>).chunkIndex == null\n        );\n        const collapsed = collapseAndReassembleChunkResults(\n          chunkResults.map(r => ({\n            id: r.id,\n            parentMemoryId: (r as Record<string, unknown>).parentMemoryId as number | string,\n            chunkIndex: (r as Record<string, unknown>).chunkIndex as number,\n            score: r.score,\n          }))\n        );\n        // Merge collapsed chunk results with non-chunk results\n        fusedHybridResults = [\n          ...collapsed.map(c => ({\n            id: c.parentMemoryId,\n            score: c.mpabScore,\n            source: 'mpab' as string,\n            _chunkHits: c._chunkHits,\n          } as HybridSearchResult)),\n          ...nonChunkResults,\n        ];\n      }\n    } catch (_mpabErr: unknown) {\n      // Non-critical — MPAB failure does not block pipeline\n      const msg = _mpabErr instanceof Error ? _mpabErr.message : String(_mpabErr);\n      console.error('[hybrid-search] MPAB error (non-fatal):', msg);\n    }\n  }\n\n  // -- Stage C: Channel Enforcement (SPECKIT_CHANNEL_MIN_REP) --\n  // Ensures every channel that returned results has at least one representative\n  // In the top-k window. Prevents single-channel dominance in fusion output.\n  // When disabled, passes results through unchanged.\n  try {\n    const channelResultSets = new Map<string, Array<{ id: number | string; score: number; [key: string]: unknown }>>();\n    for (const list of lists) {\n      channelResultSets.set(list.source, list.results.map(r => ({\n        ...r,\n        id: r.id,\n        score: typeof (r as Record<string, unknown>).score === 'number'\n          ? (r as Record<string, unknown>).score as number\n          : typeof (r as Record<string, unknown>).similarity === 'number'\n            ? ((r as Record<string, unknown>).similarity as number) / 100\n            : 0,\n      })));\n    }\n\n    const enforcementResult: EnforcementResult = enforceChannelRepresentation(\n      fusedHybridResults.map(r => ({ ...r, source: r.source || 'hybrid' })),\n      channelResultSets,\n      limit,\n    );\n\n    if (enforcementResult.enforcement.applied) {\n      fusedHybridResults = dedupeResultsByCanonicalId(enforcementResult.results as HybridSearchResult[]);\n      s3meta.enforcement = {\n        applied: true,\n        promotedCount: enforcementResult.enforcement.promotedCount,\n        underRepresentedChannels: enforcementResult.enforcement.underRepresentedChannels,\n      };\n    }\n  } catch (err: unknown) {\n    // Non-critical — enforcement failure does not block pipeline\n    console.warn('[hybrid-search] channel enforcement failed:', err instanceof Error ? err.message : String(err));\n  }\n\n  // Preserve non-enumerable eval metadata across later array reallocations.\n  const shadowMeta = initialResults as HybridSearchResult[] & ShadowMetaArray;\n  const s4shadowMeta = shadowMeta._s4shadow;\n  const s4attributionMeta = shadowMeta._s4attribution;\n  const degradationMeta = shadowMeta._degradation;\n\n  // MMR reranking with request-scoped embedding cache.\n  // Reuse embeddings already returned by the vector channel when present and\n  // only query vec_memories for missing IDs.\n  let reranked: HybridSearchResult[] = fusedHybridResults.slice(0, limit);\n\n  if (db && isMMREnabled()) {\n    const numericIds = reranked\n      .map(r => r.id)\n      .filter((id): id is number => typeof id === 'number');\n\n    if (numericIds.length >= MMR_MIN_CANDIDATES) {\n      try {\n        const embeddingMap = new Map<number, Float32Array>(vectorEmbeddingCache);\n        const missingIds = numericIds.filter((id) => !embeddingMap.has(id));\n\n        if (missingIds.length > 0) {\n          const placeholders = missingIds.map(() => '?').join(', ');\n          const embRows = (db.prepare(\n            `SELECT rowid, embedding FROM vec_memories WHERE rowid IN (${placeholders})`\n          ) as Database.Statement).all(...missingIds) as Array<{ rowid: number; embedding: Buffer }>;\n\n          for (const row of embRows) {\n            if (Buffer.isBuffer(row.embedding)) {\n              embeddingMap.set(\n                row.rowid,\n                new Float32Array(row.embedding.buffer, row.embedding.byteOffset, row.embedding.byteLength / 4)\n              );\n            }\n          }\n        }\n\n        const mmrCandidates: MMRCandidate[] = [];\n        for (const r of reranked) {\n          const emb = embeddingMap.get(r.id as number);\n          if (emb) {\n            mmrCandidates.push({\n              id: r.id as number,\n              score: (r.score as number) ?? 0,\n              embedding: emb,\n            });\n          }\n        }\n\n        if (mmrCandidates.length >= MMR_MIN_CANDIDATES) {\n          const mmrLambda = INTENT_LAMBDA_MAP[intent] ?? MMR_DEFAULT_LAMBDA;\n          const diversified = applyMMR(mmrCandidates, { lambda: mmrLambda, limit });\n\n          // FIX #6: Same fix as stage3-rerank FIX #5 — MMR can only diversify\n          // rows that have embeddings. Non-embedded rows (lexical-only hits,\n          // graph injections) must be preserved and merged back in their\n          // original relative order instead of being silently dropped.\n          const embeddedIdSet = new Set(mmrCandidates.map(c => c.id));\n          const nonEmbeddedRows = reranked.filter(r => !embeddedIdSet.has(r.id as number));\n          const rerankedById = new Map<string, HybridSearchResult>(\n            reranked.map((result) => [canonicalResultId(result.id), result])\n          );\n\n          const diversifiedRows = diversified.map((candidate): HybridSearchResult => {\n            const existing = rerankedById.get(canonicalResultId(candidate.id));\n            if (existing) {\n              return existing;\n            }\n\n            return {\n              id: candidate.id,\n              score: candidate.score,\n              source: 'vector',\n            };\n          });\n\n          // Merge: diversified embedded rows first (MMR-ordered), then\n          // non-embedded rows in their original relative order.\n          reranked = [...diversifiedRows, ...nonEmbeddedRows];\n        }\n      } catch (embErr: unknown) {\n        const msg = embErr instanceof Error ? embErr.message : String(embErr);\n        console.warn(`[hybrid-search] MMR embedding retrieval failed: ${msg}`);\n      }\n    }\n  }\n\n  // Co-activation spreading — enrich with temporal neighbors\n  const topIds = reranked\n    .slice(0, SPREAD_ACTIVATION_TOP_N)\n    .map(r => r.id)\n    .filter((id): id is number => typeof id === 'number');\n  if (topIds.length > 0) {\n    try {\n      const spreadResults: SpreadResult[] = spreadActivation(topIds);\n      // Boost scores of results that appear in co-activation graph\n      if (spreadResults.length > 0) {\n        const spreadMap = new Map(spreadResults.map(sr => [sr.id, sr.activationScore]));\n        for (const result of reranked) {\n          const boost = spreadMap.get(result.id as number);\n          if (boost !== undefined) {\n            // Update all score aliases so downstream consumers see the boost.\n            const boostedScore = ((result.score as number) ?? 0) + boost * CO_ACTIVATION_CONFIG.boostFactor;\n            (result as Record<string, unknown>).score = boostedScore;\n            if ('rrfScore' in result) (result as Record<string, unknown>).rrfScore = boostedScore;\n            if ('intentAdjustedScore' in result) (result as Record<string, unknown>).intentAdjustedScore = boostedScore;\n          }\n        }\n      }\n      // Re-sort after co-activation boost to ensure boosted results\n      // Are promoted to their correct position in the ranking\n      reranked.sort((a, b) => ((b.score as number) ?? 0) - ((a.score as number) ?? 0));\n    } catch (err: unknown) {\n      // Non-critical enrichment — co-activation failure does not affect core ranking\n      console.warn('[hybrid-search] co-activation enrichment failed:', err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  // Folder relevance / two-pass retrieval (SPECKIT_FOLDER_SCORING)\n  if (db && isFolderScoringEnabled() && reranked.length > 0) {\n    try {\n      const numericIds = reranked\n        .map(r => r.id)\n        .filter((id): id is number => typeof id === 'number');\n\n      if (numericIds.length > 0) {\n        const folderMap = lookupFolders(db, numericIds);\n        if (folderMap.size > 0) {\n          const folderScores = computeFolderRelevanceScores(reranked, folderMap);\n          const rawTopK = process.env.SPECKIT_FOLDER_TOP_K;\n          const parsedTopK = rawTopK ? parseInt(rawTopK, 10) : NaN;\n          const topK = Number.isFinite(parsedTopK) && parsedTopK > 0 ? parsedTopK : 5;\n\n          const twoPhaseResults = twoPhaseRetrieval(reranked, folderScores, folderMap, topK);\n          const postFolderResults = twoPhaseResults.length > 0 ? twoPhaseResults : reranked;\n          reranked = enrichResultsWithFolderScores(postFolderResults, folderScores, folderMap) as HybridSearchResult[];\n        }\n      }\n    } catch (_folderErr: unknown) {\n      // Folder scoring is optional and must not break retrieval\n    }\n  }\n\n  // -- Stage D: Confidence Truncation (SPECKIT_CONFIDENCE_TRUNCATION) --\n  // Run after the ranking pipeline so later boosts/promotions can rescue\n  // candidates before low-confidence tails are trimmed.\n  if (!evaluationMode) {\n    try {\n      const truncationResult: TruncationResult = truncateByConfidence(\n        reranked.map(r => ({ ...r, id: r.id, score: r.score })),\n      );\n\n      if (truncationResult.truncated) {\n        reranked = truncationResult.results.map(r => r as HybridSearchResult);\n        s3meta.truncation = {\n          truncated: true,\n          originalCount: truncationResult.originalCount,\n          truncatedCount: truncationResult.truncatedCount,\n          medianGap: truncationResult.medianGap,\n          cutoffGap: truncationResult.cutoffGap,\n          cutoffIndex: truncationResult.cutoffIndex,\n          thresholdMultiplier: GAP_THRESHOLD_MULTIPLIER,\n          minResultsGuaranteed: DEFAULT_MIN_RESULTS,\n          featureFlagEnabled: isConfidenceTruncationEnabled(),\n        };\n      }\n    } catch (err: unknown) {\n      // Non-critical — truncation failure does not block pipeline\n      console.warn('[hybrid-search] confidence truncation failed:', err instanceof Error ? err.message : String(err));\n    }\n  }\n\n  // Preserve routing and Stage 4 trace metadata as explicit result fields so downstream\n  // Formatters can opt-in to provenance-rich envelopes without relying on\n  // Non-enumerable array shadow properties.\n  if (reranked.length > 0) {\n    reranked = reranked.map((row): HybridSearchResult => {\n      const existingTraceMetadata =\n        typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n          ? row.traceMetadata\n          : {};\n\n      return {\n        ...row,\n        traceMetadata: {\n          ...existingTraceMetadata,\n          ...(s4shadowMeta !== undefined ? { stage4: s4shadowMeta } : {}),\n          ...(s4attributionMeta !== undefined ? { attribution: s4attributionMeta } : {}),\n          ...(degradationMeta !== undefined ? { degradation: degradationMeta } : {}),\n          evaluationMode,\n          // Wire queryComplexity from router classification into trace\n          queryComplexity: routeResult.tier,\n          // Wire confidence truncation metadata into per-result trace (036)\n          ...(s3meta.truncation ? {\n            confidenceTruncation: {\n              truncated: s3meta.truncation.truncated,\n              originalCount: s3meta.truncation.originalCount,\n              truncatedCount: s3meta.truncation.truncatedCount,\n              medianGap: s3meta.truncation.medianGap,\n              cutoffGap: s3meta.truncation.cutoffGap,\n              cutoffIndex: s3meta.truncation.cutoffIndex,\n              thresholdMultiplier: s3meta.truncation.thresholdMultiplier,\n              minResultsGuaranteed: s3meta.truncation.minResultsGuaranteed,\n            },\n          } : {}),\n        },\n      };\n    });\n  }\n\n  if (isContextHeadersEnabled() && reranked.length > 0) {\n    const descriptionCache = buildDescriptionTailMap();\n    if (descriptionCache.size > 0) {\n      reranked = reranked.map((row) => injectContextualTree(row, descriptionCache));\n    }\n  }\n\n  let budgetTruncated = false;\n  let budgetLimit: number | undefined;\n  if (evaluationMode) {\n    reranked = applyResultLimit(reranked, options.limit);\n  } else {\n    // Apply token budget truncation after trace/header enrichment so token\n    // estimates reflect the actual returned payload shape.\n    const headerOverhead = isContextHeadersEnabled()\n      ? reranked.length * CONTEXT_HEADER_TOKEN_OVERHEAD\n      : 0;\n    const adjustedBudget = Math.max(budgetResult.budget - headerOverhead, 200);\n\n    if (s3meta.tokenBudget) {\n      s3meta.tokenBudget.headerOverhead = headerOverhead;\n      s3meta.tokenBudget.adjustedBudget = adjustedBudget;\n    }\n\n    const budgeted = truncateToBudget(reranked, adjustedBudget, {\n      includeContent: options.includeContent ?? false,\n      queryId: `hybrid-${Date.now()}`,\n      limit: options.limit,\n      query,\n    });\n    reranked = budgeted.results;\n    budgetTruncated = budgeted.truncated;\n    budgetLimit = budgetResult.budget;\n\n    // Cosine-primary head reorder (SPECKIT_COSINE_TOPN_REORDER, default-ON).\n    // Must run AFTER truncateToBudget: that step re-sorts the survivors by the\n    // fused `score`, so a pre-truncation reorder would be clobbered. Applied to\n    // the budgeted survivors it is the last word on order without disturbing the\n    // budget membership decision. Skipped in evaluationMode so the labeled-set\n    // top-K window stays exactly as fused.\n    if (isCosineTopnReorderEnabled() && reranked.length > 1) {\n      reranked = reorderTopNByCosine(reranked);\n    }\n  }\n\n  if (reranked.length > 0) {\n    reranked = reranked.map((row): HybridSearchResult => {\n      const existingTraceMetadata =\n        typeof row.traceMetadata === 'object' && row.traceMetadata !== null && !Array.isArray(row.traceMetadata)\n          ? row.traceMetadata\n          : {};\n\n      return {\n        ...row,\n        traceMetadata: {\n          ...existingTraceMetadata,\n          budgetTruncated,\n          ...(budgetLimit !== undefined ? { budgetLimit } : {}),\n        },\n      };\n    });\n  }\n\n  if (s4shadowMeta !== undefined && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s4shadow', {\n      value: s4shadowMeta,\n      enumerable: false,\n      configurable: true,\n    });\n  }\n\n  if (s4attributionMeta !== undefined && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s4attribution', {\n      value: s4attributionMeta,\n      enumerable: false,\n      configurable: true,\n    });\n  }\n\n  // Attach pipeline metadata to results for eval/debugging\n  // Metadata is attached as non-enumerable _s3meta property to avoid\n  // Polluting result serialization while remaining accessible for debugging.\n  if (Object.keys(s3meta).length > 0 && reranked.length > 0) {\n    Object.defineProperty(reranked, '_s3meta', { value: s3meta, enumerable: false, configurable: true });\n  }\n\n  return reranked;\n}\n\n/**\n * Collect pipeline candidates through the adaptive fallback chain, returning\n * immediately after intra-query fusion and before downstream aggregation,\n * reranking, or post-processing.\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Unfused candidate results from the first non-empty collection stage.\n */\nasync function collectRawCandidates(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    isSearchFallbackEnabled() ? 'tiered' : 'adaptive',\n    { stopAfterFusion: true }\n  );\n\n  const primaryResults = stages[0]?.results ?? [];\n  const retryResults = stages[1]?.results ?? [];\n\n  if (isSearchFallbackEnabled()) {\n    const mergedResults = retryResults.length > 0\n      ? mergeRawCandidateSets(primaryResults, retryResults, options.limit)\n      : primaryResults;\n    if (mergedResults.length > 0) return applyResultLimit(mergedResults, options.limit);\n  } else {\n    const stagedResults = retryResults.length > 0 ? retryResults : primaryResults;\n    if (stagedResults.length > 0) return applyResultLimit(stagedResults, options.limit);\n  }\n\n  if (allowedChannels.has('fts')) {\n    const ftsFallback = collectCandidatesFromLists(\n      [{ source: 'fts', results: ftsSearch(query, options) }],\n      options.limit\n    );\n    if (ftsFallback.length > 0) return ftsFallback;\n  }\n\n  if (allowedChannels.has('bm25')) {\n    const bm25Fallback = collectCandidatesFromLists(\n      [{ source: 'bm25', results: bm25Search(query, options) }],\n      options.limit\n    );\n    if (bm25Fallback.length > 0) return bm25Fallback;\n  }\n\n  console.warn('[hybrid-search] Raw candidate collection returned empty results');\n  return [];\n}\n\n/**\n * Search with automatic fallback chain.\n * When SPECKIT_SEARCH_FALLBACK=true: delegates to the 3-tier quality-aware\n   * fallback (searchWithFallbackTiered). Otherwise: two-pass adaptive\n * fallback — primary at minSimilarity=30, retry at 17.\n *\n * @param query - The search query string.\n * @param embedding - Optional embedding vector for semantic search.\n * @param options - Hybrid search configuration options.\n * @returns Results from the first non-empty stage.\n */\nasync function searchWithFallback(\n  query: string,\n  embedding: Float32Array | number[] | null,\n  options: HybridSearchOptions = {}\n): Promise<HybridSearchResult[]> {\n  // PI-A2: Delegate to tiered fallback when flag is enabled\n  if (isSearchFallbackEnabled()) {\n    return searchWithFallbackTiered(query, embedding, options);\n  }\n\n  // Primary 30 filters noise; fallback 17 widens recall for sparse corpora\n  // Where no result exceeds the primary threshold — chosen empirically via eval.\n  // Use hybridSearchEnhanced (with RRF fusion) instead of\n  // The naive hybridSearch that merges raw scores\n  const { allowedChannels, stages } = await executeFallbackPlan(\n    query,\n    embedding,\n    options,\n    'adaptive'\n  );\n  const primaryStage = stages[0];\n  const retryStage = stages[1];\n  const finalStage = retryStage?.results.length ? retryStage : primaryStage;\n  if (finalStage?.results.length) {\n    return finalStage.execution\n      ? enrichFusedResults(query, finalStage.execution, finalStage.options, finalStage.results)\n      : finalStage.results;\n  }\n\n  // Fallback to FTS only\n  if (allowedChannels.has('fts')) {\n    const ftsResults = ftsSearch(query, options);\n    if (ftsResults.length > 0) return ftsResults;\n  }\n\n  // Fallback to BM25 only\n  if (allowedChannels.has('bm25')) {\n    const bm25Results = bm25Search(query, options);\n    if (bm25Results.length > 0) return bm25Results;\n  }\n\n  console.warn('[hybrid-search] All search methods returned empty results');\n  return [];\n}\n\n// 12. STRUCTURAL SEARCH (PI-A2 TIER 3)\n\n/**\n * PI-A2: Last-resort structural search against the memory_index table.\n * Retrieves memories ordered by importance tier and weight, without\n * requiring embeddings or text similarity. Pure SQL fallback.\n *\n * @param options - Search options (specFolder for filtering, limit for cap).\n * @returns Array of HybridSearchResult with source='structural'.\n */\nfunction structuralSearch(\n  options: Pick<HybridSearchOptions, 'specFolder' | 'limit'> = {}\n): HybridSearchResult[] {\n  if (!db) {\n    console.warn('[hybrid-search] db not initialized — returning empty structuralSearch results');\n    return [];\n  }\n\n  const limit = options.limit ?? DEFAULT_LIMIT;\n\n  try {\n    // Build SQL with optional specFolder filter\n    // Exclude archived rows unless explicitly requested\n    const conditions = [\n      `(importance_tier IS NULL OR importance_tier NOT IN ('deprecated', 'archived'))`,\n    ];\n    const params: unknown[] = [];\n\n    if (options.specFolder) {\n      conditions.push(`(spec_folder = ? OR spec_folder LIKE ? ESCAPE '\\\\')`);\n      params.push(options.specFolder, specFolderLikePattern(options.specFolder));\n    }\n\n    const whereClause = conditions.join(' AND ');\n\n    const sql = `\n      SELECT id, title, file_path, importance_tier, importance_weight, spec_folder\n      FROM memory_index\n      WHERE ${whereClause}\n      ORDER BY\n        CASE importance_tier\n          WHEN 'constitutional' THEN 1\n          WHEN 'critical' THEN 2\n          WHEN 'important' THEN 3\n          WHEN 'normal' THEN 4\n          WHEN 'temporary' THEN 5\n          ELSE 6\n        END ASC,\n        importance_weight DESC,\n        created_at DESC\n      LIMIT ?\n    `;\n    params.push(limit);\n\n    const stmt = db.prepare(sql);\n    const rows = stmt.all(...params) as Array<Record<string, unknown>>;\n\n    return rows.map((row, index) => ({\n      id: row.id as number,\n      score: Math.max(0, 1.0 - index * 0.05),\n      source: 'structural',\n      title: (row.title as string) ?? undefined,\n      file_path: row.file_path as string,\n      importance_tier: row.importance_tier as string,\n      spec_folder: row.spec_folder as string,\n    }));\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[hybrid-search] Structural search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Normalize result IDs to a canonical key used for deduplication and source tracking.\n * Handles number-vs-string drift (`42` vs `\"42\"`) and legacy `mem:42` forms.\n */\nfunction canonicalResultId(id: number | string): string {\n  if (typeof id === 'number') {\n    return String(id);\n  }\n\n  const raw = String(id).trim();\n  const memPrefixed = /^mem:(\\d+)$/i.exec(raw);\n  if (memPrefixed) {\n    return String(Number(memPrefixed[1]));\n  }\n\n  if (/^\\d+$/.test(raw)) {\n    return String(Number(raw));\n  }\n\n  return raw;\n}\n\nfunction truncateChars(input: string, maxChars: number): string {\n  if (input.length <= maxChars) return input;\n  if (maxChars <= 1) return input.slice(0, maxChars);\n  return `${input.slice(0, maxChars - 1).trimEnd()}…`;\n}\n\nfunction extractSpecSegments(filePath: string): { left: string; right: string; tailKey: string } | null {\n  const normalized = filePath.replace(/\\\\/g, '/');\n  const splitToken = '/specs/';\n  const splitIdx = normalized.lastIndexOf(splitToken);\n  if (splitIdx < 0) return null;\n\n  const relative = normalized.slice(splitIdx + splitToken.length).replace(/^\\/+/, '');\n  const parts = relative.split('/').filter(Boolean);\n  if (parts.length < 2) return null;\n\n  // Prefer spec-folder extraction up to /memory/ so we get [parent > child]\n  // For canonical memory paths like:\n  // .../specs/<parent>/<child>/memory/<file>.md\n  const memoryIdx = parts.indexOf('memory');\n  const scopeParts = memoryIdx >= 0 ? parts.slice(0, memoryIdx) : parts.slice(0, -1);\n  const tailParts = scopeParts.slice(-2);\n  if (tailParts.length < 2) return null;\n\n  return {\n    left: tailParts[0],\n    right: tailParts[1],\n    tailKey: tailParts.join('/'),\n  };\n}\n\n// Memoize description map to avoid rebuilding on every search query.\n// Cache invalidates after 60 seconds so folder renames are eventually picked up.\n// Return stale cache immediately and refresh asynchronously to avoid\n// blocking the search hot path with synchronous filesystem crawls.\nlet descMapCache: { map: Map<string, string>; timestamp: number } | null = null;\nlet descMapRefreshing = false;\nconst DESC_MAP_TTL_MS = 60_000;\n\nfunction rebuildDescriptionTailMap(): Map<string, string> {\n  const descByTail = new Map<string, string>();\n  const cache = ensureDescriptionCache(getSpecsBasePaths());\n  if (!cache || !Array.isArray(cache.folders)) {\n    return descByTail;\n  }\n\n  for (const entry of cache.folders) {\n    const specFolder = typeof entry.specFolder === 'string' ? entry.specFolder : '';\n    const description = typeof entry.description === 'string' ? entry.description : '';\n    if (!specFolder || !description) continue;\n    const folderParts = specFolder.split('/').filter(Boolean);\n    if (folderParts.length < 2) continue;\n    const tailKey = folderParts.slice(-2).join('/');\n    if (!descByTail.has(tailKey)) {\n      descByTail.set(tailKey, description);\n    }\n  }\n\n  return descByTail;\n}\n\nfunction buildDescriptionTailMap(): Map<string, string> {\n  // Fresh cache — return immediately\n  if (descMapCache && (Date.now() - descMapCache.timestamp) < DESC_MAP_TTL_MS) {\n    return descMapCache.map;\n  }\n","lineStart":1446,"lineEnd":2345,"totalLines":2972,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/hybrid-search.ts","time":{"start":1781763793016,"end":1781763793023}},"metadata":{"openai":{"itemId":"fc_036c3a75fcdce96f016a338ed07de88191aa2db102b946c068"}},"id":"prt_ed965e038001euXebR8KYovfXv","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed965a7a6001axABUKSXIuuHDU"}}
{"type":"tool_use","timestamp":1781763793247,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_WvjP9zrQpGNyZFBrM4wHZXRh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","offset":1,"limit":2000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Sqlite Fts\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Semantic and lexical search (memory_search)\n5: // Weighted BM25 scoring for FTS5 full-text search.\n6: // Extracted from hybrid-search.ts ftsSearch() for independent\n7: // Testing and future delegation.\n8: \n9: import { BM25_FTS5_WEIGHTS } from './bm25-index.js';\n10: import { specFolderLikePattern } from './vector-index-types.js';\n11: import { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\n12: import { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\n13: import type Database from 'better-sqlite3';\n14: \n15: // ───────────────────────────────────────────────────────────────\n16: // 2. INTERFACES\n17: \n18: // ───────────────────────────────────────────────────────────────\n19: interface FtsBm25Result {\n20:   id: number;\n21:   fts_score: number;\n22:   [key: string]: unknown;\n23: }\n24: \n25: interface FtsBm25Options {\n26:   limit?: number;\n27:   specFolder?: string;\n28:   includeArchived?: boolean;\n29: }\n30: \n31: type LexicalPath = 'fts5' | 'like' | 'unavailable';\n32: type FallbackState =\n33:   | 'ok'\n34:   | 'compile_probe_miss'\n35:   | 'missing_table'\n36:   | 'no_such_module_fts5'\n37:   | 'bm25_runtime_failure';\n38: \n39: interface LexicalCapabilitySnapshot {\n40:   lexicalPath: LexicalPath;\n41:   fallbackState: FallbackState;\n42: }\n43: \n44: let lastLexicalCapabilitySnapshot: LexicalCapabilitySnapshot | null = null;\n45: \n46: function cloneLexicalCapabilitySnapshot(\n47:   snapshot: LexicalCapabilitySnapshot | null\n48: ): LexicalCapabilitySnapshot | null {\n49:   return snapshot ? { ...snapshot } : null;\n50: }\n51: \n52: function setLastLexicalCapabilitySnapshot(snapshot: LexicalCapabilitySnapshot): void {\n53:   lastLexicalCapabilitySnapshot = { ...snapshot };\n54: }\n55: \n56: function getLastLexicalCapabilitySnapshot(): LexicalCapabilitySnapshot | null {\n57:   return cloneLexicalCapabilitySnapshot(lastLexicalCapabilitySnapshot);\n58: }\n59: \n60: function resetLastLexicalCapabilitySnapshot(): void {\n61:   lastLexicalCapabilitySnapshot = null;\n62: }\n63: \n64: function toErrorMessage(error: unknown): string {\n65:   return error instanceof Error ? error.message : String(error);\n66: }\n67: \n68: function readCompileOptionValue(row: unknown): string | null {\n69:   if (typeof row === 'string') {\n70:     return row;\n71:   }\n72:   if (!row || typeof row !== 'object') {\n73:     return null;\n74:   }\n75: \n76:   const record = row as Record<string, unknown>;\n77:   const direct = record.compile_options;\n78:   if (typeof direct === 'string') {\n79:     return direct;\n80:   }\n81: \n82:   const firstString = Object.values(record).find((value) => typeof value === 'string');\n83:   return typeof firstString === 'string' ? firstString : null;\n84: }\n85: \n86: function isNoSuchModuleFts5Error(error: unknown): boolean {\n87:   return toErrorMessage(error).toLowerCase().includes('no such module: fts5');\n88: }\n89: \n90: function isBm25RuntimeFailure(error: unknown): boolean {\n91:   const message = toErrorMessage(error).toLowerCase();\n92:   return message.includes('bm25');\n93: }\n94: \n95: function probeFts5Capability(db: Database.Database): LexicalCapabilitySnapshot {\n96:   try {\n97:     const compileRows = (db.prepare('PRAGMA compile_options') as Database.Statement).all() as unknown[];\n98:     const hasFts5CompileFlag = compileRows\n99:       .map(readCompileOptionValue)\n100:       .some((value) => typeof value === 'string' && value.toUpperCase().includes('ENABLE_FTS5'));\n101: \n102:     if (!hasFts5CompileFlag) {\n103:       return {\n104:         lexicalPath: 'unavailable',\n105:         fallbackState: 'compile_probe_miss',\n106:       };\n107:     }\n108:   } catch {\n109:     return {\n110:       lexicalPath: 'unavailable',\n111:       fallbackState: 'compile_probe_miss',\n112:     };\n113:   }\n114: \n115:   try {\n116:     const result = (db.prepare(\n117:       `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n118:     ) as Database.Statement).get() as { name: string } | undefined;\n119: \n120:     if (!result) {\n121:       return {\n122:         lexicalPath: 'unavailable',\n123:         fallbackState: 'missing_table',\n124:       };\n125:     }\n126:   } catch (error: unknown) {\n127:     if (isNoSuchModuleFts5Error(error)) {\n128:       return {\n129:         lexicalPath: 'unavailable',\n130:         fallbackState: 'no_such_module_fts5',\n131:       };\n132:     }\n133:     return {\n134:       lexicalPath: 'unavailable',\n135:       fallbackState: 'missing_table',\n136:     };\n137:   }\n138: \n139:   return {\n140:     lexicalPath: 'fts5',\n141:     fallbackState: 'ok',\n142:   };\n143: }\n144: \n145: // ───────────────────────────────────────────────────────────────\n146: // 3. CORE FUNCTION\n147: \n148: // ───────────────────────────────────────────────────────────────\n149: /**\n150:  * Execute a weighted BM25 FTS5 search against memory_fts.\n151:  *\n152:  * Uses SQLite FTS5's built-in bm25() ranking function with\n153:  * per-column weights instead of the default `rank` pseudo-column.\n154:  * This gives title matches 10x weight, trigger_phrases 5x, etc.\n155:  *\n156:  * @param db - SQLite database connection\n157:  * @param query - Raw search query (will be sanitized)\n158:  * @param options - Search options (limit, specFolder, includeArchived)\n159:  * @returns Array of results with BM25 scores (higher = better)\n160:  * @example\n161:  * ```ts\n162:  * const rows = fts5Bm25Search(db, 'memory search', { limit: 10 });\n163:  * ```\n164:  */\n165: function fts5Bm25Search(\n166:   db: Database.Database,\n167:   query: string,\n168:   options: FtsBm25Options = {}\n169: ): FtsBm25Result[] {\n170:   const { limit = 20, specFolder, includeArchived = false } = options;\n171:   // Include cold/deprecated-tier rows by default (or on explicit includeArchived) —\n172:   // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n173:   const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n174: \n175:   // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n176:   const sanitized = normalizeLexicalQueryTokens(query).fts;\n177: \n178:   if (!sanitized) {\n179:     setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n180:     return [];\n181:   }\n182: \n183:   const folderFilter = specFolder\n184:     ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n185:     : '';\n186:   const deprecatedTierFilter = includeCold\n187:     ? ''\n188:     : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n189: \n190:   const params: (string | number)[] = specFolder\n191:     ? [sanitized, specFolder, specFolderLikePattern(specFolder), limit]\n192:     : [sanitized, limit];\n193: \n194:   // Bm25() returns negative scores (lower = better), so we negate\n195:   // To produce positive scores where higher = better match.\n196:   const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n197:   const sql = `\n198:     SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n199:     FROM memory_fts\n200:     JOIN memory_index m ON m.id = memory_fts.rowid\n201:     WHERE memory_fts MATCH ?\n202:       ${folderFilter}\n203:       ${deprecatedTierFilter}\n204:     ORDER BY fts_score DESC\n205:     LIMIT ?\n206:   `;\n207: \n208:   const capability = probeFts5Capability(db);\n209:   setLastLexicalCapabilitySnapshot(capability);\n210:   if (capability.fallbackState !== 'ok') {\n211:     console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n212:     return [];\n213:   }\n214: \n215:   try {\n216:     const rows = (db.prepare(sql) as Database.Statement).all(\n217:       ...params\n218:     ) as Array<Record<string, unknown>>;\n219: \n220:     const normalizedRows = rows.map(row => ({\n221:       ...row,\n222:       id: row.id as number,\n223:       fts_score: (row.fts_score as number) || 0,\n224:     }));\n225:     setLastLexicalCapabilitySnapshot({\n226:       lexicalPath: 'fts5',\n227:       fallbackState: 'ok',\n228:     });\n229:     return normalizedRows;\n230:   } catch (error: unknown) {\n231:     const msg = error instanceof Error ? error.message : String(error);\n232:     const failureSnapshot: LexicalCapabilitySnapshot = isNoSuchModuleFts5Error(error)\n233:       ? {\n234:           lexicalPath: 'unavailable',\n235:           fallbackState: 'no_such_module_fts5',\n236:         }\n237:       : isBm25RuntimeFailure(error)\n238:         ? {\n239:             lexicalPath: 'unavailable',\n240:             fallbackState: 'bm25_runtime_failure',\n241:           }\n242:         : msg.toLowerCase().includes('no such table: memory_fts')\n243:           ? {\n244:               lexicalPath: 'unavailable',\n245:               fallbackState: 'missing_table',\n246:             }\n247:           : {\n248:               lexicalPath: 'unavailable',\n249:               fallbackState: 'bm25_runtime_failure',\n250:             };\n251:     setLastLexicalCapabilitySnapshot(failureSnapshot);\n252:     console.warn(`[sqlite-fts] BM25 FTS5 search failed: ${msg}`);\n253:     return [];\n254:   }\n255: }\n256: \n257: /**\n258:  * Check if the memory_fts FTS5 virtual table exists in the database.\n259:  *\n260:  * Used as a feature-detect before calling fts5Bm25Search, since FTS5\n261:  * may be absent on older SQLite builds or freshly-created databases.\n262:  *\n263:  * @param db - SQLite database connection to check\n264:  * @returns true if memory_fts exists and is queryable\n265:  * @example\n266:  * ```ts\n267:  * if (isFts5Available(db)) {\n268:  *   fts5Bm25Search(db, 'memory');\n269:  * }\n270:  * ```\n271:  */\n272: function isFts5Available(db: Database.Database): boolean {\n273:   return probeFts5Capability(db).fallbackState === 'ok';\n274: }\n275: \n276: // ───────────────────────────────────────────────────────────────\n277: // 4. EXPORTS\n278: \n279: // ───────────────────────────────────────────────────────────────\n280: export {\n281:   BM25_FTS5_WEIGHTS as FTS5_BM25_WEIGHTS,\n282:   fts5Bm25Search,\n283:   getLastLexicalCapabilitySnapshot,\n284:   isFts5Available,\n285:   probeFts5Capability,\n286:   resetLastLexicalCapabilitySnapshot,\n287:   setLastLexicalCapabilitySnapshot,\n288: };\n289: \n290: /**\n291:  * BM25 FTS result and option types exposed by the SQLite FTS module.\n292:  */\n293: export type {\n294:   FallbackState,\n295:   FtsBm25Result,\n296:   FtsBm25Options,\n297:   LexicalCapabilitySnapshot,\n298:   LexicalPath,\n299: };\n\n(End of file - total 299 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Sqlite Fts\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Semantic and lexical search (memory_search)\n// Weighted BM25 scoring for FTS5 full-text search.\n// Extracted from hybrid-search.ts ftsSearch() for independent\n// Testing and future delegation.\n\nimport { BM25_FTS5_WEIGHTS } from './bm25-index.js';\nimport { specFolderLikePattern } from './vector-index-types.js';\nimport { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\nimport { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\nimport type Database from 'better-sqlite3';\n\n// ───────────────────────────────────────────────────────────────\n// 2. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface FtsBm25Result {\n  id: number;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Sqlite Fts\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Semantic and lexical search (memory_search)\n// Weighted BM25 scoring for FTS5 full-text search.\n// Extracted from hybrid-search.ts ftsSearch() for independent\n// Testing and future delegation.\n\nimport { BM25_FTS5_WEIGHTS } from './bm25-index.js';\nimport { specFolderLikePattern } from './vector-index-types.js';\nimport { normalizeLexicalQueryTokens } from './lexical-normalizer.js';\nimport { isArchivedRetrievalIncludedByDefault } from './search-flags.js';\nimport type Database from 'better-sqlite3';\n\n// ───────────────────────────────────────────────────────────────\n// 2. INTERFACES\n\n// ───────────────────────────────────────────────────────────────\ninterface FtsBm25Result {\n  id: number;\n  fts_score: number;\n  [key: string]: unknown;\n}\n\ninterface FtsBm25Options {\n  limit?: number;\n  specFolder?: string;\n  includeArchived?: boolean;\n}\n\ntype LexicalPath = 'fts5' | 'like' | 'unavailable';\ntype FallbackState =\n  | 'ok'\n  | 'compile_probe_miss'\n  | 'missing_table'\n  | 'no_such_module_fts5'\n  | 'bm25_runtime_failure';\n\ninterface LexicalCapabilitySnapshot {\n  lexicalPath: LexicalPath;\n  fallbackState: FallbackState;\n}\n\nlet lastLexicalCapabilitySnapshot: LexicalCapabilitySnapshot | null = null;\n\nfunction cloneLexicalCapabilitySnapshot(\n  snapshot: LexicalCapabilitySnapshot | null\n): LexicalCapabilitySnapshot | null {\n  return snapshot ? { ...snapshot } : null;\n}\n\nfunction setLastLexicalCapabilitySnapshot(snapshot: LexicalCapabilitySnapshot): void {\n  lastLexicalCapabilitySnapshot = { ...snapshot };\n}\n\nfunction getLastLexicalCapabilitySnapshot(): LexicalCapabilitySnapshot | null {\n  return cloneLexicalCapabilitySnapshot(lastLexicalCapabilitySnapshot);\n}\n\nfunction resetLastLexicalCapabilitySnapshot(): void {\n  lastLexicalCapabilitySnapshot = null;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction readCompileOptionValue(row: unknown): string | null {\n  if (typeof row === 'string') {\n    return row;\n  }\n  if (!row || typeof row !== 'object') {\n    return null;\n  }\n\n  const record = row as Record<string, unknown>;\n  const direct = record.compile_options;\n  if (typeof direct === 'string') {\n    return direct;\n  }\n\n  const firstString = Object.values(record).find((value) => typeof value === 'string');\n  return typeof firstString === 'string' ? firstString : null;\n}\n\nfunction isNoSuchModuleFts5Error(error: unknown): boolean {\n  return toErrorMessage(error).toLowerCase().includes('no such module: fts5');\n}\n\nfunction isBm25RuntimeFailure(error: unknown): boolean {\n  const message = toErrorMessage(error).toLowerCase();\n  return message.includes('bm25');\n}\n\nfunction probeFts5Capability(db: Database.Database): LexicalCapabilitySnapshot {\n  try {\n    const compileRows = (db.prepare('PRAGMA compile_options') as Database.Statement).all() as unknown[];\n    const hasFts5CompileFlag = compileRows\n      .map(readCompileOptionValue)\n      .some((value) => typeof value === 'string' && value.toUpperCase().includes('ENABLE_FTS5'));\n\n    if (!hasFts5CompileFlag) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'compile_probe_miss',\n      };\n    }\n  } catch {\n    return {\n      lexicalPath: 'unavailable',\n      fallbackState: 'compile_probe_miss',\n    };\n  }\n\n  try {\n    const result = (db.prepare(\n      `SELECT name FROM sqlite_master WHERE type='table' AND name='memory_fts'`\n    ) as Database.Statement).get() as { name: string } | undefined;\n\n    if (!result) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'missing_table',\n      };\n    }\n  } catch (error: unknown) {\n    if (isNoSuchModuleFts5Error(error)) {\n      return {\n        lexicalPath: 'unavailable',\n        fallbackState: 'no_such_module_fts5',\n      };\n    }\n    return {\n      lexicalPath: 'unavailable',\n      fallbackState: 'missing_table',\n    };\n  }\n\n  return {\n    lexicalPath: 'fts5',\n    fallbackState: 'ok',\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 3. CORE FUNCTION\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Execute a weighted BM25 FTS5 search against memory_fts.\n *\n * Uses SQLite FTS5's built-in bm25() ranking function with\n * per-column weights instead of the default `rank` pseudo-column.\n * This gives title matches 10x weight, trigger_phrases 5x, etc.\n *\n * @param db - SQLite database connection\n * @param query - Raw search query (will be sanitized)\n * @param options - Search options (limit, specFolder, includeArchived)\n * @returns Array of results with BM25 scores (higher = better)\n * @example\n * ```ts\n * const rows = fts5Bm25Search(db, 'memory search', { limit: 10 });\n * ```\n */\nfunction fts5Bm25Search(\n  db: Database.Database,\n  query: string,\n  options: FtsBm25Options = {}\n): FtsBm25Result[] {\n  const { limit = 20, specFolder, includeArchived = false } = options;\n  // Include cold/deprecated-tier rows by default (or on explicit includeArchived) —\n  // FSRS retrievability ranks them below hot memories, so no hard wall is needed.\n  const includeCold = includeArchived || isArchivedRetrievalIncludedByDefault();\n\n  // Sanitize via shared tokenizer, then join quoted terms with OR for recall.\n  const sanitized = normalizeLexicalQueryTokens(query).fts;\n\n  if (!sanitized) {\n    setLastLexicalCapabilitySnapshot(probeFts5Capability(db));\n    return [];\n  }\n\n  const folderFilter = specFolder\n    ? \"AND (m.spec_folder = ? OR m.spec_folder LIKE ? ESCAPE '\\\\')\"\n    : '';\n  const deprecatedTierFilter = includeCold\n    ? ''\n    : \"AND (m.importance_tier IS NULL OR m.importance_tier != 'deprecated')\";\n\n  const params: (string | number)[] = specFolder\n    ? [sanitized, specFolder, specFolderLikePattern(specFolder), limit]\n    : [sanitized, limit];\n\n  // Bm25() returns negative scores (lower = better), so we negate\n  // To produce positive scores where higher = better match.\n  const [w0, w1, w2, w3] = BM25_FTS5_WEIGHTS;\n  const sql = `\n    SELECT m.*, -bm25(memory_fts, ${w0}, ${w1}, ${w2}, ${w3}) AS fts_score\n    FROM memory_fts\n    JOIN memory_index m ON m.id = memory_fts.rowid\n    WHERE memory_fts MATCH ?\n      ${folderFilter}\n      ${deprecatedTierFilter}\n    ORDER BY fts_score DESC\n    LIMIT ?\n  `;\n\n  const capability = probeFts5Capability(db);\n  setLastLexicalCapabilitySnapshot(capability);\n  if (capability.fallbackState !== 'ok') {\n    console.warn(`[sqlite-fts] FTS5 unavailable (${capability.fallbackState}); returning empty lexical lane results`);\n    return [];\n  }\n\n  try {\n    const rows = (db.prepare(sql) as Database.Statement).all(\n      ...params\n    ) as Array<Record<string, unknown>>;\n\n    const normalizedRows = rows.map(row => ({\n      ...row,\n      id: row.id as number,\n      fts_score: (row.fts_score as number) || 0,\n    }));\n    setLastLexicalCapabilitySnapshot({\n      lexicalPath: 'fts5',\n      fallbackState: 'ok',\n    });\n    return normalizedRows;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    const failureSnapshot: LexicalCapabilitySnapshot = isNoSuchModuleFts5Error(error)\n      ? {\n          lexicalPath: 'unavailable',\n          fallbackState: 'no_such_module_fts5',\n        }\n      : isBm25RuntimeFailure(error)\n        ? {\n            lexicalPath: 'unavailable',\n            fallbackState: 'bm25_runtime_failure',\n          }\n        : msg.toLowerCase().includes('no such table: memory_fts')\n          ? {\n              lexicalPath: 'unavailable',\n              fallbackState: 'missing_table',\n            }\n          : {\n              lexicalPath: 'unavailable',\n              fallbackState: 'bm25_runtime_failure',\n            };\n    setLastLexicalCapabilitySnapshot(failureSnapshot);\n    console.warn(`[sqlite-fts] BM25 FTS5 search failed: ${msg}`);\n    return [];\n  }\n}\n\n/**\n * Check if the memory_fts FTS5 virtual table exists in the database.\n *\n * Used as a feature-detect before calling fts5Bm25Search, since FTS5\n * may be absent on older SQLite builds or freshly-created databases.\n *\n * @param db - SQLite database connection to check\n * @returns true if memory_fts exists and is queryable\n * @example\n * ```ts\n * if (isFts5Available(db)) {\n *   fts5Bm25Search(db, 'memory');\n * }\n * ```\n */\nfunction isFts5Available(db: Database.Database): boolean {\n  return probeFts5Capability(db).fallbackState === 'ok';\n}\n\n// ───────────────────────────────────────────────────────────────\n// 4. EXPORTS\n\n// ───────────────────────────────────────────────────────────────\nexport {\n  BM25_FTS5_WEIGHTS as FTS5_BM25_WEIGHTS,\n  fts5Bm25Search,\n  getLastLexicalCapabilitySnapshot,\n  isFts5Available,\n  probeFts5Capability,\n  resetLastLexicalCapabilitySnapshot,\n  setLastLexicalCapabilitySnapshot,\n};\n\n/**\n * BM25 FTS result and option types exposed by the SQLite FTS module.\n */\nexport type {\n  FallbackState,\n  FtsBm25Result,\n  FtsBm25Options,\n  LexicalCapabilitySnapshot,\n  LexicalPath,\n};","lineStart":1,"lineEnd":299,"totalLines":299,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/sqlite-fts.ts","time":{"start":1781763793239,"end":1781763793246}},"metadata":{"openai":{"itemId":"fc_036c3a75fcdce96f016a338ed07df48191ac533fda496d9b16"}},"id":"prt_ed965e0dd001S068y4HCJzpIET","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed965a7a6001axABUKSXIuuHDU"}}
{"type":"tool_use","timestamp":1781763793282,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_BvnptwBqrgmWkLD9PUlHBKDl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-calibration.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-calibration.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Confidence Calibration\n3: // ───────────────────────────────────────────────────────────────\n4: // Maps a raw per-result confidence value (0–1) onto an empirical\n5: // P(relevant) using a monotonic calibration model fit from labeled\n6: // query→memory relevance judgements.\n7: //\n8: // STATUS: UNVALIDATED INFRASTRUCTURE. The fitting and apply math here\n9: // is exercised by tests, but no production-grade labeled set has been\n10: // collected yet. The starter labeled set shipped alongside this module\n11: // is a CORPUS-DERIVED PROXY (spec titles/keywords as queries, the spec's\n12: // own memory as the positive), NOT human-judged live `memory_search`\n13: // traffic. The real ~50–100 judged pairs from live traffic are the\n14: // documented follow-up before any model here is trusted in ranking.\n15: //\n16: // Because of that, the wiring in confidence-scoring.ts keeps this OFF by\n17: // default (SPECKIT_CONFIDENCE_CALIBRATION) and only applies a model when\n18: // one is explicitly provided. Default behavior is unchanged.\n19: \n20: import { readFileSync } from 'node:fs';\n21: \n22: // -- Types --\n23: \n24: /**\n25:  * One labeled relevance judgement: did `memoryId` satisfy `query`?\n26:  * `relevant` is the binary ground-truth label (1 = relevant, 0 = not).\n27:  */\n28: export interface LabeledPair {\n29:   query: string;\n30:   memoryId: number | string;\n31:   relevant: 0 | 1;\n32: }\n33: \n34: /**\n35:  * One fitting sample: the model maps a pre-calibration confidence value\n36:  * (`rawValue`, 0–1) onto the observed binary relevance label. Producing\n37:  * these from a LabeledPair[] requires running search to obtain the\n38:  * rawValue each query/memory pair scored — that join is the labeled-traffic\n39:  * follow-up, not something this module can synthesize.\n40:  */\n41: export interface CalibrationSample {\n42:   rawValue: number;\n43:   relevant: 0 | 1;\n44: }\n45: \n46: /**\n47:  * A fitted monotonic calibration curve. `points` are sorted by `x`\n48:  * (rawValue) with non-decreasing `y` (P(relevant)); applyCalibration\n49:  * interpolates between them. Kept as plain data so a model can be\n50:  * serialized to JSON and reloaded without re-fitting.\n51:  */\n52: export interface CalibrationModel {\n53:   method: 'isotonic';\n54:   points: Array<{ x: number; y: number }>;\n55:   /** Number of samples the model was fit from (provenance / sanity check). */\n56:   fittedFrom: number;\n57: }\n58: \n59: // -- Helpers --\n60: \n61: function clamp01(value: number): number {\n62:   if (!Number.isFinite(value)) return 0;\n63:   return Math.max(0, Math.min(1, value));\n64: }\n65: \n66: // -- Labeled-set loading --\n67: \n68: /**\n69:  * Validate and normalize a parsed labeled set into LabeledPair[].\n70:  * Rejects malformed entries rather than silently coercing them, so a\n71:  * bad labeled file fails loudly instead of fitting on garbage.\n72:  */\n73: export function loadLabeledSet(json: unknown): LabeledPair[] {\n74:   if (!Array.isArray(json)) {\n75:     throw new Error('labeled set must be a JSON array of {query, memoryId, relevant}');\n76:   }\n77:   return json.map((entry, i) => {\n78:     if (!entry || typeof entry !== 'object') {\n79:       throw new Error(`labeled set entry ${i} is not an object`);\n80:     }\n81:     const e = entry as Record<string, unknown>;\n82:     const query = e.query;\n83:     const memoryId = e.memoryId;\n84:     const relevant = e.relevant;\n85:     if (typeof query !== 'string' || query.trim().length === 0) {\n86:       throw new Error(`labeled set entry ${i} has an invalid query`);\n87:     }\n88:     if (typeof memoryId !== 'string' && typeof memoryId !== 'number') {\n89:       throw new Error(`labeled set entry ${i} has an invalid memoryId`);\n90:     }\n91:     if (relevant !== 0 && relevant !== 1) {\n92:       throw new Error(`labeled set entry ${i} relevant must be 0 or 1`);\n93:     }\n94:     return { query, memoryId, relevant };\n95:   });\n96: }\n97: \n98: /**\n99:  * Read and parse a CalibrationModel from a JSON file path. Returns null\n100:  * when the path is missing/unreadable or the contents are not a valid\n101:  * model, so a misconfigured path degrades to a no-op rather than throwing\n102:  * in the search hot path.\n103:  */\n104: export function loadCalibrationModel(path: string): CalibrationModel | null {\n105:   let raw: string;\n106:   try {\n107:     raw = readFileSync(path, 'utf8');\n108:   } catch {\n109:     return null;\n110:   }\n111:   let parsed: unknown;\n112:   try {\n113:     parsed = JSON.parse(raw);\n114:   } catch {\n115:     return null;\n116:   }\n117:   if (!parsed || typeof parsed !== 'object') return null;\n118:   const m = parsed as Record<string, unknown>;\n119:   if (m.method !== 'isotonic' || !Array.isArray(m.points)) return null;\n120:   const points: Array<{ x: number; y: number }> = [];\n121:   for (const p of m.points) {\n122:     if (!p || typeof p !== 'object') return null;\n123:     const x = (p as Record<string, unknown>).x;\n124:     const y = (p as Record<string, unknown>).y;\n125:     if (typeof x !== 'number' || typeof y !== 'number') return null;\n126:     points.push({ x, y });\n127:   }\n128:   if (points.length === 0) return null;\n129:   const fittedFrom = typeof m.fittedFrom === 'number' ? m.fittedFrom : points.length;\n130:   return { method: 'isotonic', points, fittedFrom };\n131: }\n132: \n133: // -- Fitting --\n134: \n135: /**\n136:  * Fit an isotonic (monotonic non-decreasing) calibration curve via the\n137:  * Pool Adjacent Violators algorithm (PAV). The result maps rawValue →\n138:  * P(relevant) and is guaranteed non-decreasing, so a higher raw confidence\n139:  * never calibrates to a lower probability.\n140:  *\n141:  * Each output point is a pooled block: x = mean rawValue of the block,\n142:  * y = empirical relevance rate of the block. Ties in rawValue are merged\n143:  * before pooling so the curve is well defined.\n144:  */\n145: export function fitCalibration(samples: CalibrationSample[]): CalibrationModel {\n146:   const clean = samples\n147:     .filter((s) => Number.isFinite(s.rawValue) && (s.relevant === 0 || s.relevant === 1))\n148:     .map((s) => ({ x: clamp01(s.rawValue), y: s.relevant as number }))\n149:     .sort((a, b) => a.x - b.x);\n150: \n151:   if (clean.length === 0) {\n152:     return { method: 'isotonic', points: [], fittedFrom: 0 };\n153:   }\n154: \n155:   // Each block tracks the pooled sum of x and y plus the sample count so a\n156:   // merge is O(1). PAV merges left while the previous block's mean y is greater\n157:   // than OR equal to the current block's mean y. The `>` case repairs a\n158:   // monotonicity violation; the `===` case collapses adjacent equal-mean blocks\n159:   // into one — pooling equal means leaves the mean (and therefore y) unchanged,\n160:   // so it is purely a serialization-size reduction with no effect on the fitted\n161:   // curve or its interpolation.\n162:   interface Block {\n163:     sumX: number;\n164:     sumY: number;\n165:     count: number;\n166:   }\n167:   const blocks: Block[] = [];\n168:   for (const { x, y } of clean) {\n169:     blocks.push({ sumX: x, sumY: y, count: 1 });\n170:     while (blocks.length >= 2) {\n171:       const curr = blocks[blocks.length - 1]!;\n172:       const prev = blocks[blocks.length - 2]!;\n173:       if (prev.sumY / prev.count < curr.sumY / curr.count) break;\n174:       prev.sumX += curr.sumX;\n175:       prev.sumY += curr.sumY;\n176:       prev.count += curr.count;\n177:       blocks.pop();\n178:     }\n179:   }\n180: \n181:   const points = blocks.map((b) => ({\n182:     x: b.sumX / b.count,\n183:     y: clamp01(b.sumY / b.count),\n184:   }));\n185: \n186:   return { method: 'isotonic', points, fittedFrom: clean.length };\n187: }\n188: \n189: // -- Apply --\n190: \n191: /**\n192:  * Map a raw confidence value through the fitted curve via piecewise-linear\n193:  * interpolation between pooled blocks. Values below the first / above the\n194:  * last block clamp to that block's probability. Output is bounded to 0–1\n195:  * and monotonic in `rawValue` (the points are non-decreasing in y).\n196:  *\n197:  * An empty model is the identity (returns the clamped rawValue), so an\n198:  * unfit or degenerate model never distorts confidence.\n199:  */\n200: export function applyCalibration(model: CalibrationModel, rawValue: number): number {\n201:   const x = clamp01(rawValue);\n202:   const pts = model.points;\n203:   if (pts.length === 0) return x;\n204:   if (x <= pts[0]!.x) return clamp01(pts[0]!.y);\n205:   const last = pts[pts.length - 1]!;\n206:   if (x >= last.x) return clamp01(last.y);\n207: \n208:   for (let i = 0; i < pts.length - 1; i++) {\n209:     const a = pts[i]!;\n210:     const b = pts[i + 1]!;\n211:     if (x >= a.x && x <= b.x) {\n212:       const span = b.x - a.x;\n213:       if (span <= 0) return clamp01(b.y);\n214:       const t = (x - a.x) / span;\n215:       return clamp01(a.y + t * (b.y - a.y));\n216:     }\n217:   }\n218:   return clamp01(last.y);\n219: }\n\n(End of file - total 219 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Calibration\n// ───────────────────────────────────────────────────────────────\n// Maps a raw per-result confidence value (0–1) onto an empirical\n// P(relevant) using a monotonic calibration model fit from labeled\n// query→memory relevance judgements.\n//\n// STATUS: UNVALIDATED INFRASTRUCTURE. The fitting and apply math here\n// is exercised by tests, but no production-grade labeled set has been\n// collected yet. The starter labeled set shipped alongside this module\n// is a CORPUS-DERIVED PROXY (spec titles/keywords as queries, the spec's\n// own memory as the positive), NOT human-judged live `memory_search`\n// traffic. The real ~50–100 judged pairs from live traffic are the\n// documented follow-up before any model here is trusted in ranking.\n//\n// Because of that, the wiring in confidence-scoring.ts keeps this OFF by\n// default (SPECKIT_CONFIDENCE_CALIBRATION) and only applies a model when\n// one is explicitly provided. Default behavior is unchanged.\n\nimport { readFileSync } from 'node:fs';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-calibration.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Calibration\n// ───────────────────────────────────────────────────────────────\n// Maps a raw per-result confidence value (0–1) onto an empirical\n// P(relevant) using a monotonic calibration model fit from labeled\n// query→memory relevance judgements.\n//\n// STATUS: UNVALIDATED INFRASTRUCTURE. The fitting and apply math here\n// is exercised by tests, but no production-grade labeled set has been\n// collected yet. The starter labeled set shipped alongside this module\n// is a CORPUS-DERIVED PROXY (spec titles/keywords as queries, the spec's\n// own memory as the positive), NOT human-judged live `memory_search`\n// traffic. The real ~50–100 judged pairs from live traffic are the\n// documented follow-up before any model here is trusted in ranking.\n//\n// Because of that, the wiring in confidence-scoring.ts keeps this OFF by\n// default (SPECKIT_CONFIDENCE_CALIBRATION) and only applies a model when\n// one is explicitly provided. Default behavior is unchanged.\n\nimport { readFileSync } from 'node:fs';\n\n// -- Types --\n\n/**\n * One labeled relevance judgement: did `memoryId` satisfy `query`?\n * `relevant` is the binary ground-truth label (1 = relevant, 0 = not).\n */\nexport interface LabeledPair {\n  query: string;\n  memoryId: number | string;\n  relevant: 0 | 1;\n}\n\n/**\n * One fitting sample: the model maps a pre-calibration confidence value\n * (`rawValue`, 0–1) onto the observed binary relevance label. Producing\n * these from a LabeledPair[] requires running search to obtain the\n * rawValue each query/memory pair scored — that join is the labeled-traffic\n * follow-up, not something this module can synthesize.\n */\nexport interface CalibrationSample {\n  rawValue: number;\n  relevant: 0 | 1;\n}\n\n/**\n * A fitted monotonic calibration curve. `points` are sorted by `x`\n * (rawValue) with non-decreasing `y` (P(relevant)); applyCalibration\n * interpolates between them. Kept as plain data so a model can be\n * serialized to JSON and reloaded without re-fitting.\n */\nexport interface CalibrationModel {\n  method: 'isotonic';\n  points: Array<{ x: number; y: number }>;\n  /** Number of samples the model was fit from (provenance / sanity check). */\n  fittedFrom: number;\n}\n\n// -- Helpers --\n\nfunction clamp01(value: number): number {\n  if (!Number.isFinite(value)) return 0;\n  return Math.max(0, Math.min(1, value));\n}\n\n// -- Labeled-set loading --\n\n/**\n * Validate and normalize a parsed labeled set into LabeledPair[].\n * Rejects malformed entries rather than silently coercing them, so a\n * bad labeled file fails loudly instead of fitting on garbage.\n */\nexport function loadLabeledSet(json: unknown): LabeledPair[] {\n  if (!Array.isArray(json)) {\n    throw new Error('labeled set must be a JSON array of {query, memoryId, relevant}');\n  }\n  return json.map((entry, i) => {\n    if (!entry || typeof entry !== 'object') {\n      throw new Error(`labeled set entry ${i} is not an object`);\n    }\n    const e = entry as Record<string, unknown>;\n    const query = e.query;\n    const memoryId = e.memoryId;\n    const relevant = e.relevant;\n    if (typeof query !== 'string' || query.trim().length === 0) {\n      throw new Error(`labeled set entry ${i} has an invalid query`);\n    }\n    if (typeof memoryId !== 'string' && typeof memoryId !== 'number') {\n      throw new Error(`labeled set entry ${i} has an invalid memoryId`);\n    }\n    if (relevant !== 0 && relevant !== 1) {\n      throw new Error(`labeled set entry ${i} relevant must be 0 or 1`);\n    }\n    return { query, memoryId, relevant };\n  });\n}\n\n/**\n * Read and parse a CalibrationModel from a JSON file path. Returns null\n * when the path is missing/unreadable or the contents are not a valid\n * model, so a misconfigured path degrades to a no-op rather than throwing\n * in the search hot path.\n */\nexport function loadCalibrationModel(path: string): CalibrationModel | null {\n  let raw: string;\n  try {\n    raw = readFileSync(path, 'utf8');\n  } catch {\n    return null;\n  }\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw);\n  } catch {\n    return null;\n  }\n  if (!parsed || typeof parsed !== 'object') return null;\n  const m = parsed as Record<string, unknown>;\n  if (m.method !== 'isotonic' || !Array.isArray(m.points)) return null;\n  const points: Array<{ x: number; y: number }> = [];\n  for (const p of m.points) {\n    if (!p || typeof p !== 'object') return null;\n    const x = (p as Record<string, unknown>).x;\n    const y = (p as Record<string, unknown>).y;\n    if (typeof x !== 'number' || typeof y !== 'number') return null;\n    points.push({ x, y });\n  }\n  if (points.length === 0) return null;\n  const fittedFrom = typeof m.fittedFrom === 'number' ? m.fittedFrom : points.length;\n  return { method: 'isotonic', points, fittedFrom };\n}\n\n// -- Fitting --\n\n/**\n * Fit an isotonic (monotonic non-decreasing) calibration curve via the\n * Pool Adjacent Violators algorithm (PAV). The result maps rawValue →\n * P(relevant) and is guaranteed non-decreasing, so a higher raw confidence\n * never calibrates to a lower probability.\n *\n * Each output point is a pooled block: x = mean rawValue of the block,\n * y = empirical relevance rate of the block. Ties in rawValue are merged\n * before pooling so the curve is well defined.\n */\nexport function fitCalibration(samples: CalibrationSample[]): CalibrationModel {\n  const clean = samples\n    .filter((s) => Number.isFinite(s.rawValue) && (s.relevant === 0 || s.relevant === 1))\n    .map((s) => ({ x: clamp01(s.rawValue), y: s.relevant as number }))\n    .sort((a, b) => a.x - b.x);\n\n  if (clean.length === 0) {\n    return { method: 'isotonic', points: [], fittedFrom: 0 };\n  }\n\n  // Each block tracks the pooled sum of x and y plus the sample count so a\n  // merge is O(1). PAV merges left while the previous block's mean y is greater\n  // than OR equal to the current block's mean y. The `>` case repairs a\n  // monotonicity violation; the `===` case collapses adjacent equal-mean blocks\n  // into one — pooling equal means leaves the mean (and therefore y) unchanged,\n  // so it is purely a serialization-size reduction with no effect on the fitted\n  // curve or its interpolation.\n  interface Block {\n    sumX: number;\n    sumY: number;\n    count: number;\n  }\n  const blocks: Block[] = [];\n  for (const { x, y } of clean) {\n    blocks.push({ sumX: x, sumY: y, count: 1 });\n    while (blocks.length >= 2) {\n      const curr = blocks[blocks.length - 1]!;\n      const prev = blocks[blocks.length - 2]!;\n      if (prev.sumY / prev.count < curr.sumY / curr.count) break;\n      prev.sumX += curr.sumX;\n      prev.sumY += curr.sumY;\n      prev.count += curr.count;\n      blocks.pop();\n    }\n  }\n\n  const points = blocks.map((b) => ({\n    x: b.sumX / b.count,\n    y: clamp01(b.sumY / b.count),\n  }));\n\n  return { method: 'isotonic', points, fittedFrom: clean.length };\n}\n\n// -- Apply --\n\n/**\n * Map a raw confidence value through the fitted curve via piecewise-linear\n * interpolation between pooled blocks. Values below the first / above the\n * last block clamp to that block's probability. Output is bounded to 0–1\n * and monotonic in `rawValue` (the points are non-decreasing in y).\n *\n * An empty model is the identity (returns the clamped rawValue), so an\n * unfit or degenerate model never distorts confidence.\n */\nexport function applyCalibration(model: CalibrationModel, rawValue: number): number {\n  const x = clamp01(rawValue);\n  const pts = model.points;\n  if (pts.length === 0) return x;\n  if (x <= pts[0]!.x) return clamp01(pts[0]!.y);\n  const last = pts[pts.length - 1]!;\n  if (x >= last.x) return clamp01(last.y);\n\n  for (let i = 0; i < pts.length - 1; i++) {\n    const a = pts[i]!;\n    const b = pts[i + 1]!;\n    if (x >= a.x && x <= b.x) {\n      const span = b.x - a.x;\n      if (span <= 0) return clamp01(b.y);\n      const t = (x - a.x) / span;\n      return clamp01(a.y + t * (b.y - a.y));\n    }\n  }\n  return clamp01(last.y);\n}","lineStart":1,"lineEnd":219,"totalLines":219,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-calibration.ts","time":{"start":1781763793277,"end":1781763793280}},"metadata":{"openai":{"itemId":"fc_036c3a75fcdce96f016a338ed07e248191a84009729f43d9ef"}},"id":"prt_ed965e15900119of1y0OvD5HpL","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed965a7a6001axABUKSXIuuHDU"}}
{"type":"tool_use","timestamp":1781763793451,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_jQlwF3GWkyslD58AhZYRmVmu","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","offset":1,"limit":1600},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Confidence Scoring\n3: // ───────────────────────────────────────────────────────────────\n4: // Per-result calibrated confidence scoring\n5: //\n6: // PURPOSE: Combine margin, multi-channel agreement,\n7: // and anchor density into a single calibrated confidence score per\n8: // result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n9: //\n10: // FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n11: //\n12: // OUTPUT SHAPE (per result):\n13: // {\n14: //   \"confidence\": {\n15: //     \"label\": \"high\" | \"medium\" | \"low\",\n16: //     \"value\": 0.78,\n17: //     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n18: //   },\n19: //   \"requestQuality\": {\n20: //     \"label\": \"good\" | \"weak\" | \"gap\"\n21: //   }\n22: // }\n23: //\n24: // IMPORTANT: This module only models ranking confidence for retrieval ordering.\n25: // It is not freshness authority and it is not a substitute for StructuralTrust.\n26: import { statSync } from 'node:fs';\n27: import { resolveEffectiveScore, resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\n28: import {\n29:   isAbsoluteRelevanceCalibrationEnabled,\n30:   isConfidenceCalibrationEnabled,\n31:   getConfidenceCalibrationModelPath,\n32: } from './search-flags.js';\n33: import { applyCalibration, loadCalibrationModel, type CalibrationModel } from './confidence-calibration.js';\n34: \n35: declare const rankingConfidenceBrand: unique symbol;\n36: \n37: // -- Constants --\n38: \n39: const HIGH_THRESHOLD = 0.7;\n40: const LOW_THRESHOLD = 0.4;\n41: \n42: // Weights for each active confidence factor. The former reranker weight (0.20)\n43: // was removed with the LLM reranker; its term was already inert (always 0), so\n44: // rawValue stays capped at 0.80 exactly as before — behavior-neutral. The 0.20\n45: // is intentionally NOT redistributed (that would change confidence scores).\n46: const WEIGHT_MARGIN = 0.35;\n47: const WEIGHT_CHANNEL_AGREEMENT = 0.30;\n48: const WEIGHT_ANCHOR_DENSITY = 0.15;\n49: \n50: // Blend of the heuristic signal (margin/channel/anchor) and the absolute\n51: // relevance prior into the final per-result value. Relevance is intentionally\n52: // weighted higher than the heuristics so the band is monotonic in relevance: a\n53: // strong-but-isolated cosine hit (single channel, no anchors, tail margin) must\n54: // not be capped at \"medium\" purely because the heuristic signals are weak.\n55: // These two must sum to 1.0.\n56: const WEIGHT_HEURISTIC = 0.45;\n57: const WEIGHT_SCORE_PRIOR = 0.55;\n58: \n59: // Guard the sum-to-1.0 invariant at module load: if either weight is retuned\n60: // without adjusting the other, the rebalanced value would no longer be a convex\n61: // blend and could exceed 1 before clamping (silently distorting the band). Fail\n62: // loudly instead. Tolerance absorbs float representation error (0.45 + 0.55).\n63: if (Math.abs(WEIGHT_HEURISTIC + WEIGHT_SCORE_PRIOR - 1.0) > 1e-9) {\n64:   throw new Error(\n65:     `confidence-scoring: WEIGHT_HEURISTIC (${WEIGHT_HEURISTIC}) + WEIGHT_SCORE_PRIOR (${WEIGHT_SCORE_PRIOR}) must sum to 1.0`,\n66:   );\n67: }\n68: \n69: // Margin thresholds (gap between top score and next score, 0–1 scale)\n70: const LARGE_MARGIN_THRESHOLD = 0.15;\n71: const SMALL_MARGIN_THRESHOLD = 0.05;\n72: \n73: // Channel count thresholds\n74: const STRONG_CHANNEL_AGREEMENT_MIN = 2;\n75: \n76: // Request-quality aggregation: a top hit at or above this absolute relevance\n77: // stands on its own, so a weak tail cannot drag the verdict below \"good\".\n78: const TOP_DOMINANT_THRESHOLD = 0.8;\n79: \n80: // Cap the quality-ratio denominator at the head of the ranking. Pulling deeper\n81: // for recall appends weaker tail results; counting them would mechanically\n82: // depress the ratio and penalize a query for retrieving more candidates.\n83: const QUALITY_RATIO_HEAD = 5;\n84: \n85: // -- Types --\n86: \n87: /** Confidence label for a single result. */\n88: export type ConfidenceLabel = 'high' | 'medium' | 'low';\n89: \n90: /**\n91:  * Branded ranking score for retrieval ordering only.\n92:  * Consumers must not reuse this as parser provenance, evidence status,\n93:  * freshness authority, or any other StructuralTrust axis.\n94:  */\n95: export type RankingConfidenceValue = number & {\n96:   readonly [rankingConfidenceBrand]: 'RankingConfidenceValue';\n97: };\n98: \n99: /** Quality label at the request level (across all results). */\n100: export type RequestQualityLabel = 'good' | 'weak' | 'gap';\n101: \n102: /** Which factors drove the confidence score upward. */\n103: export type ConfidenceDriver =\n104:   | 'large_margin'\n105:   | 'multi_channel_agreement'\n106:   | 'anchor_density';\n107: \n108: /** Per-result confidence payload. */\n109: export interface RankingConfidenceContract {\n110:   label: ConfidenceLabel;\n111:   value: RankingConfidenceValue;\n112:   drivers: ConfidenceDriver[];\n113:   structuralTrust?: never;\n114:   parserProvenance?: never;\n115:   evidenceStatus?: never;\n116:   freshnessAuthority?: never;\n117: }\n118: \n119: export interface ResultConfidence {\n120:   confidence: RankingConfidenceContract;\n121: }\n122: \n123: /** Request-level quality assessment (one per search call). */\n124: export interface RequestQualityAssessment {\n125:   requestQuality: {\n126:     label: RequestQualityLabel;\n127:   };\n128: }\n129: \n130: /**\n131:  * Minimal result shape needed for confidence computation.\n132:  * Uses `Record<string, unknown>` to stay compatible with both\n133:  * `RawSearchResult` and `PipelineRow` without importing either.\n134:  */\n135: export interface ScoredResult extends Record<string, unknown> {\n136:   id: number;\n137:   /** Composite score (0–1). */\n138:   score?: number;\n139:   /** RRF fusion score (0–1). */\n140:   rrfScore?: number;\n141:   /** Intent-adjusted score (0–1). */\n142:   intentAdjustedScore?: number;\n143:   /** Raw cosine similarity (0–100 scale from sqlite-vec). */\n144:   similarity?: number;\n145:   /** Score origin metadata for distinguishing real reranks from fallbacks. */\n146:   scoringMethod?: string;\n147:   /** Anchor metadata array populated by Stage 2. */\n148:   anchorMetadata?: Array<Record<string, unknown>>;\n149:   /** Source channels that contributed this result. */\n150:   sources?: string[];\n151:   /** Single source channel string (legacy). */\n152:   source?: string;\n153:   /** Trace metadata containing channel attribution. */\n154:   traceMetadata?: Record<string, unknown>;\n155: }\n156: \n157: // -- Internal helpers --\n158: \n159: function resolveScore(result: ScoredResult): number {\n160:   return resolveEffectiveScore(result as PipelineRow);\n161: }\n162: \n163: /**\n164:  * Absolute relevance used for confidence calibration and request-quality — keeps\n165:  * ordering on the RRF/effective score while reading an absolute 0–1 signal for\n166:  * \"how good is this\", so the 0.7/0.4 thresholds mean what they say. Reverts to the\n167:  * effective score when SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION is disabled.\n168:  */\n169: function resolveCalibrationScore(result: ScoredResult): number {\n170:   return isAbsoluteRelevanceCalibrationEnabled()\n171:     ? resolveAbsoluteRelevance(result as PipelineRow)\n172:     : resolveEffectiveScore(result as PipelineRow);\n173: }\n174: \n175: // Lazily-loaded calibration model, memoized so the search hot path reads the\n176: // file at most once per (path, mtime) pair. The mtime is part of the cache key\n177: // so editing the model in place re-reads it; without it a path-stable file\n178: // rewritten on disk would serve the stale fitted curve indefinitely.\n179: // `undefined` = not yet looked up; `null` = looked up and absent/invalid\n180: // (degrade to identity).\n181: let cachedCalibrationModel: CalibrationModel | null | undefined;\n182: let cachedCalibrationModelPath: string | undefined;\n183: let cachedCalibrationModelMtimeMs: number | undefined;\n184: \n185: /** Best-effort mtime; `undefined` when the path is unreadable (treated as a miss). */\n186: function calibrationModelMtimeMs(path: string): number | undefined {\n187:   try {\n188:     return statSync(path).mtimeMs;\n189:   } catch {\n190:     return undefined;\n191:   }\n192: }\n193: \n194: function resolveCalibrationModel(): CalibrationModel | null {\n195:   const path = getConfidenceCalibrationModelPath();\n196:   if (!path) return null;\n197:   const mtimeMs = calibrationModelMtimeMs(path);\n198:   if (\n199:     cachedCalibrationModel !== undefined &&\n200:     cachedCalibrationModelPath === path &&\n201:     cachedCalibrationModelMtimeMs === mtimeMs\n202:   ) {\n203:     return cachedCalibrationModel;\n204:   }\n205:   cachedCalibrationModelPath = path;\n206:   cachedCalibrationModelMtimeMs = mtimeMs;\n207:   cachedCalibrationModel = loadCalibrationModel(path);\n208:   return cachedCalibrationModel;\n209: }\n210: \n211: /**\n212:  * Map a rebalanced confidence value through the empirical calibration model\n213:  * when enabled. Default OFF and a no-op when no model is configured, so the\n214:  * returned value is identical to the rebalance-only path until a validated\n215:  * model is wired in.\n216:  */\n217: function maybeCalibrate(value: number): number {\n218:   if (!isConfidenceCalibrationEnabled()) return value;\n219:   const model = resolveCalibrationModel();\n220:   if (!model) return value;\n221:   return applyCalibration(model, value);\n222: }\n223: \n224: /**\n225:  * Count the number of unique channels that retrieved this result.\n226:  * Inspects `sources`, `source`, and traceMetadata.attribution.\n227:  */\n228: function countChannels(result: ScoredResult): number {\n229:   const channels = new Set<string>();\n230: \n231:   if (Array.isArray(result.sources)) {\n232:     for (const s of result.sources) {\n233:       if (typeof s === 'string' && s.trim().length > 0) channels.add(s.trim());\n234:     }\n235:   }\n236: \n237:   if (typeof result.source === 'string' && result.source.trim().length > 0) {\n238:     channels.add(result.source.trim());\n239:   }\n240: \n241:   // Check traceMetadata.attribution for richer channel data\n242:   const numericId = typeof result.id === 'number' ? result.id : null;\n243:   const attribution = result.traceMetadata?.attribution;\n244:   if (attribution && typeof attribution === 'object' && numericId !== null) {\n245:     for (const [channel, memoryIds] of Object.entries(attribution as Record<string, unknown>)) {\n246:       if (!Array.isArray(memoryIds)) continue;\n247:       const matched = memoryIds.some((mid) => {\n248:         const n = typeof mid === 'number' ? mid : typeof mid === 'string' ? Number(mid) : NaN;\n249:         return Number.isFinite(n) && n === numericId;\n250:       });\n251:       if (matched && typeof channel === 'string' && channel.trim().length > 0) {\n252:         channels.add(channel.trim());\n253:       }\n254:     }\n255:   }\n256: \n257:   return channels.size;\n258: }\n259: \n260: /**\n261:  * Count anchors present in this result's anchorMetadata array.\n262:  * A result with multiple named anchors is considered \"dense\" and\n263:  * more likely to be a high-quality, well-structured memory.\n264:  */\n265: function countAnchors(result: ScoredResult): number {\n266:   if (!Array.isArray(result.anchorMetadata)) return 0;\n267:   return result.anchorMetadata.length;\n268: }\n269: \n270: /**\n271:  * Compute the score margin between result[i] and result[i+1].\n272:  * Tail results have no successor, so they receive no synthetic margin boost.\n273:  */\n274: function computeMargin(score: number, nextScore: number | null): number {\n275:   if (nextScore === null) return 0;\n276:   const gap = score - nextScore;\n277:   return Math.max(0, gap);\n278: }\n279: \n280: /**\n281:  * Map raw confidence value to a coarse label.\n282:  */\n283: function toConfidenceLabel(value: number): ConfidenceLabel {\n284:   if (value >= HIGH_THRESHOLD) return 'high';\n285:   if (value >= LOW_THRESHOLD) return 'medium';\n286:   return 'low';\n287: }\n288: \n289: export function asRankingConfidenceValue(value: number): RankingConfidenceValue {\n290:   const clamped = Math.max(0, Math.min(1, value));\n291:   return (Math.round(clamped * 1000) / 1000) as RankingConfidenceValue;\n292: }\n293: \n294: // -- Public API --\n295: \n296: /**\n297:  * Compute per-result confidence for a ranked list of results.\n298:  *\n299:  * Each result receives a confidence object derived from:\n300:  *   - Score margin to the next result (35% weight)\n301:  *   - Number of channels that contributed this result (30%)\n302:  *   - Anchor density in anchorMetadata (15%)\n303:  *\n304:  * @param results - Ranked results (highest score first). Ordering is assumed.\n305:  * @returns Array of ResultConfidence objects, parallel to `results`.\n306:  */\n307: export function computeResultConfidence(results: ScoredResult[]): ResultConfidence[] {\n308:   if (!Array.isArray(results) || results.length === 0) return [];\n309: \n310:   const scores = results.map(resolveScore);\n311: \n312:   return results.map((result, i): ResultConfidence => {\n313:     const score = scores[i] ?? 0;\n314:     const nextScore = i + 1 < scores.length ? (scores[i + 1] ?? null) : null;\n315: \n316:     const margin = computeMargin(score, nextScore);\n317:     const channelCount = countChannels(result);\n318:     const anchorCount = countAnchors(result);\n319: \n320:     // Factor scores (each 0–1)\n321:     const marginFactor = margin >= LARGE_MARGIN_THRESHOLD\n322:       ? 1.0\n323:       : margin >= SMALL_MARGIN_THRESHOLD\n324:         ? margin / LARGE_MARGIN_THRESHOLD\n325:         : 0;\n326: \n327:     const channelFactor = channelCount >= STRONG_CHANNEL_AGREEMENT_MIN\n328:       ? 1.0\n329:       : channelCount === 1\n330:         ? 0.5\n331:         : 0;\n332: \n333:     // Anchor density: 1 anchor → 0.3, 2 → 0.6, 3+ → 1.0\n334:     const anchorFactor = Math.min(1, anchorCount * 0.33);\n335: \n336:     const rawValue =\n337:       WEIGHT_MARGIN * marginFactor +\n338:       WEIGHT_CHANNEL_AGREEMENT * channelFactor +\n339:       WEIGHT_ANCHOR_DENSITY * anchorFactor;\n340: \n341:     // Base score is a strong prior: if the score itself is very high, confidence\n342:     // should reflect that even when heuristic signals are weak. Use the absolute\n343:     // relevance (cosine) here, not the RRF ordering score — an RRF magnitude of\n344:     // ~0.03 would make this prior contribute ~0.01 and defeat its purpose.\n345:     // Relevance carries the larger weight so the band stays monotonic in it.\n346:     const scorePrior = resolveCalibrationScore(result) * WEIGHT_SCORE_PRIOR;\n347:     const heuristicValue = rawValue * WEIGHT_HEURISTIC;\n348:     const rebalancedValue = Math.max(0, Math.min(1, heuristicValue + scorePrior));\n349: \n350:     // Optional empirical calibration to P(relevant). Default OFF: only applied\n351:     // when the flag is on AND a fitted model is available, so production\n352:     // confidence is the rebalance-only value until a validated model exists.\n353:     const value = maybeCalibrate(rebalancedValue);\n354: \n355:     const drivers: ConfidenceDriver[] = [];\n356:     if (margin >= LARGE_MARGIN_THRESHOLD) drivers.push('large_margin');\n357:     if (channelCount >= STRONG_CHANNEL_AGREEMENT_MIN) drivers.push('multi_channel_agreement');\n358:     if (anchorCount >= 2) drivers.push('anchor_density');\n359: \n360:       return {\n361:         confidence: {\n362:           label: toConfidenceLabel(value),\n363:           value: asRankingConfidenceValue(value),\n364:           drivers,\n365:         },\n366:       };\n367:   });\n368: }\n369: \n370: /**\n371:  * Compute request-level quality assessment based on the overall result set.\n372:  *\n373:  * - \"good\":  a dominant top hit, or a healthy top score with confident head / clear margin\n374:  * - \"weak\":  results exist but signals are mixed or low\n375:  * - \"gap\":   no results, or all results have low confidence\n376:  *\n377:  * The \"good\" rule is top-dominant and margin-aware: a single strong, well-separated\n378:  * top hit is citable even when the tail is weak. Without this, a strong top result\n379:  * is dragged to \"weak\" by a weaker tail, and expanding recall (more tail candidates)\n380:  * mechanically lowers the quality ratio — penalizing the very recall that found the hit.\n381:  *\n382:  * @param results   - The scored results for the query.\n383:  * @param confidences - Parallel confidence array from `computeResultConfidence`.\n384:  */\n385: export function assessRequestQuality(\n386:   results: ScoredResult[],\n387:   confidences: ResultConfidence[],\n388: ): RequestQualityAssessment {\n389:   if (!Array.isArray(results) || results.length === 0) {\n390:     return { requestQuality: { label: 'gap' } };\n391:   }\n392: \n393:   // `results` and `confidences` are a parallel pair (confidences come from\n394:   // computeResultConfidence(results)). A length mismatch means the head slice\n395:   // below would pair results[i] with an unrelated confidence, so degrade to the\n396:   // conservative do-not-cite verdict rather than emit a quality label off\n397:   // misaligned data. Holds at every call site today — defensive only.\n398:   if (!Array.isArray(confidences) || confidences.length !== results.length) {\n399:     return { requestQuality: { label: 'gap' } };\n400:   }\n401: \n402:   // Absolute relevance, not the RRF ordering score: HIGH_THRESHOLD/LOW_THRESHOLD\n403:   // are calibrated for a 0–1 cosine scale, so an RRF-magnitude topScore (~0.03)\n404:   // would put \"good\" out of reach and collapse every query to weak/gap.\n405:   const topScore = resolveCalibrationScore(results[0]);\n406: \n407:   // Quality ratio over the head of the ranking only, so recall expansion does\n408:   // not depress it (see QUALITY_RATIO_HEAD).\n409:   const head = Math.min(confidences.length, QUALITY_RATIO_HEAD);\n410:   const highOrMediumCount = confidences\n411:     .slice(0, head)\n412:     .filter((c) => c.confidence.label === 'high' || c.confidence.label === 'medium')\n413:     .length;\n414:   const qualityRatio = head > 0 ? highOrMediumCount / head : 0;\n415: \n416:   // Margin between #1 and #2 on the same absolute scale as topScore. A clear gap\n417:   // to the runner-up marks a dominant top hit even when the tail is weak.\n418:   const topMargin = results.length > 1\n419:     ? computeMargin(topScore, resolveCalibrationScore(results[1]))\n420:     : 0;\n421: \n422:   // A sufficiently strong top hit is citable on its own, regardless of the tail.\n423:   if (topScore >= TOP_DOMINANT_THRESHOLD) {\n424:     return { requestQuality: { label: 'good' } };\n425:   }\n426:   // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n427:   // OR the top hit clearly dominates the runner-up.\n428:   if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n429:     return { requestQuality: { label: 'good' } };\n430:   }\n431:   // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n432:   // genuinely low-signal queries.\n433:   if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n434:     return { requestQuality: { label: 'weak' } };\n435:   }\n436:   return { requestQuality: { label: 'gap' } };\n437: }\n438: \n439: /**\n440:  * Check whether the per-result confidence feature flag is enabled.\n441:  * Default: ON (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n442:  */\n443: export { isResultConfidenceEnabled } from './search-flags.js';\n\n(End of file - total 443 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Scoring\n// ───────────────────────────────────────────────────────────────\n// Per-result calibrated confidence scoring\n//\n// PURPOSE: Combine margin, multi-channel agreement,\n// and anchor density into a single calibrated confidence score per\n// result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n//\n// FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE (per result):\n// {\n//   \"confidence\": {\n//     \"label\": \"high\" | \"medium\" | \"low\",\n//     \"value\": 0.78,\n//     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n//   },\n//   \"requestQuality\": {\n//     \"label\": \"good\" | \"weak\" | \"gap\"","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Confidence Scoring\n// ───────────────────────────────────────────────────────────────\n// Per-result calibrated confidence scoring\n//\n// PURPOSE: Combine margin, multi-channel agreement,\n// and anchor density into a single calibrated confidence score per\n// result. V1 uses heuristic scoring only — no LLM calls in the hot path.\n//\n// FEATURE FLAG: SPECKIT_RESULT_CONFIDENCE_V1 (default ON, graduated)\n//\n// OUTPUT SHAPE (per result):\n// {\n//   \"confidence\": {\n//     \"label\": \"high\" | \"medium\" | \"low\",\n//     \"value\": 0.78,\n//     \"drivers\": [\"large_margin\", \"multi_channel_agreement\"]\n//   },\n//   \"requestQuality\": {\n//     \"label\": \"good\" | \"weak\" | \"gap\"\n//   }\n// }\n//\n// IMPORTANT: This module only models ranking confidence for retrieval ordering.\n// It is not freshness authority and it is not a substitute for StructuralTrust.\nimport { statSync } from 'node:fs';\nimport { resolveEffectiveScore, resolveAbsoluteRelevance, type PipelineRow } from './pipeline/types.js';\nimport {\n  isAbsoluteRelevanceCalibrationEnabled,\n  isConfidenceCalibrationEnabled,\n  getConfidenceCalibrationModelPath,\n} from './search-flags.js';\nimport { applyCalibration, loadCalibrationModel, type CalibrationModel } from './confidence-calibration.js';\n\ndeclare const rankingConfidenceBrand: unique symbol;\n\n// -- Constants --\n\nconst HIGH_THRESHOLD = 0.7;\nconst LOW_THRESHOLD = 0.4;\n\n// Weights for each active confidence factor. The former reranker weight (0.20)\n// was removed with the LLM reranker; its term was already inert (always 0), so\n// rawValue stays capped at 0.80 exactly as before — behavior-neutral. The 0.20\n// is intentionally NOT redistributed (that would change confidence scores).\nconst WEIGHT_MARGIN = 0.35;\nconst WEIGHT_CHANNEL_AGREEMENT = 0.30;\nconst WEIGHT_ANCHOR_DENSITY = 0.15;\n\n// Blend of the heuristic signal (margin/channel/anchor) and the absolute\n// relevance prior into the final per-result value. Relevance is intentionally\n// weighted higher than the heuristics so the band is monotonic in relevance: a\n// strong-but-isolated cosine hit (single channel, no anchors, tail margin) must\n// not be capped at \"medium\" purely because the heuristic signals are weak.\n// These two must sum to 1.0.\nconst WEIGHT_HEURISTIC = 0.45;\nconst WEIGHT_SCORE_PRIOR = 0.55;\n\n// Guard the sum-to-1.0 invariant at module load: if either weight is retuned\n// without adjusting the other, the rebalanced value would no longer be a convex\n// blend and could exceed 1 before clamping (silently distorting the band). Fail\n// loudly instead. Tolerance absorbs float representation error (0.45 + 0.55).\nif (Math.abs(WEIGHT_HEURISTIC + WEIGHT_SCORE_PRIOR - 1.0) > 1e-9) {\n  throw new Error(\n    `confidence-scoring: WEIGHT_HEURISTIC (${WEIGHT_HEURISTIC}) + WEIGHT_SCORE_PRIOR (${WEIGHT_SCORE_PRIOR}) must sum to 1.0`,\n  );\n}\n\n// Margin thresholds (gap between top score and next score, 0–1 scale)\nconst LARGE_MARGIN_THRESHOLD = 0.15;\nconst SMALL_MARGIN_THRESHOLD = 0.05;\n\n// Channel count thresholds\nconst STRONG_CHANNEL_AGREEMENT_MIN = 2;\n\n// Request-quality aggregation: a top hit at or above this absolute relevance\n// stands on its own, so a weak tail cannot drag the verdict below \"good\".\nconst TOP_DOMINANT_THRESHOLD = 0.8;\n\n// Cap the quality-ratio denominator at the head of the ranking. Pulling deeper\n// for recall appends weaker tail results; counting them would mechanically\n// depress the ratio and penalize a query for retrieving more candidates.\nconst QUALITY_RATIO_HEAD = 5;\n\n// -- Types --\n\n/** Confidence label for a single result. */\nexport type ConfidenceLabel = 'high' | 'medium' | 'low';\n\n/**\n * Branded ranking score for retrieval ordering only.\n * Consumers must not reuse this as parser provenance, evidence status,\n * freshness authority, or any other StructuralTrust axis.\n */\nexport type RankingConfidenceValue = number & {\n  readonly [rankingConfidenceBrand]: 'RankingConfidenceValue';\n};\n\n/** Quality label at the request level (across all results). */\nexport type RequestQualityLabel = 'good' | 'weak' | 'gap';\n\n/** Which factors drove the confidence score upward. */\nexport type ConfidenceDriver =\n  | 'large_margin'\n  | 'multi_channel_agreement'\n  | 'anchor_density';\n\n/** Per-result confidence payload. */\nexport interface RankingConfidenceContract {\n  label: ConfidenceLabel;\n  value: RankingConfidenceValue;\n  drivers: ConfidenceDriver[];\n  structuralTrust?: never;\n  parserProvenance?: never;\n  evidenceStatus?: never;\n  freshnessAuthority?: never;\n}\n\nexport interface ResultConfidence {\n  confidence: RankingConfidenceContract;\n}\n\n/** Request-level quality assessment (one per search call). */\nexport interface RequestQualityAssessment {\n  requestQuality: {\n    label: RequestQualityLabel;\n  };\n}\n\n/**\n * Minimal result shape needed for confidence computation.\n * Uses `Record<string, unknown>` to stay compatible with both\n * `RawSearchResult` and `PipelineRow` without importing either.\n */\nexport interface ScoredResult extends Record<string, unknown> {\n  id: number;\n  /** Composite score (0–1). */\n  score?: number;\n  /** RRF fusion score (0–1). */\n  rrfScore?: number;\n  /** Intent-adjusted score (0–1). */\n  intentAdjustedScore?: number;\n  /** Raw cosine similarity (0–100 scale from sqlite-vec). */\n  similarity?: number;\n  /** Score origin metadata for distinguishing real reranks from fallbacks. */\n  scoringMethod?: string;\n  /** Anchor metadata array populated by Stage 2. */\n  anchorMetadata?: Array<Record<string, unknown>>;\n  /** Source channels that contributed this result. */\n  sources?: string[];\n  /** Single source channel string (legacy). */\n  source?: string;\n  /** Trace metadata containing channel attribution. */\n  traceMetadata?: Record<string, unknown>;\n}\n\n// -- Internal helpers --\n\nfunction resolveScore(result: ScoredResult): number {\n  return resolveEffectiveScore(result as PipelineRow);\n}\n\n/**\n * Absolute relevance used for confidence calibration and request-quality — keeps\n * ordering on the RRF/effective score while reading an absolute 0–1 signal for\n * \"how good is this\", so the 0.7/0.4 thresholds mean what they say. Reverts to the\n * effective score when SPECKIT_ABSOLUTE_RELEVANCE_CALIBRATION is disabled.\n */\nfunction resolveCalibrationScore(result: ScoredResult): number {\n  return isAbsoluteRelevanceCalibrationEnabled()\n    ? resolveAbsoluteRelevance(result as PipelineRow)\n    : resolveEffectiveScore(result as PipelineRow);\n}\n\n// Lazily-loaded calibration model, memoized so the search hot path reads the\n// file at most once per (path, mtime) pair. The mtime is part of the cache key\n// so editing the model in place re-reads it; without it a path-stable file\n// rewritten on disk would serve the stale fitted curve indefinitely.\n// `undefined` = not yet looked up; `null` = looked up and absent/invalid\n// (degrade to identity).\nlet cachedCalibrationModel: CalibrationModel | null | undefined;\nlet cachedCalibrationModelPath: string | undefined;\nlet cachedCalibrationModelMtimeMs: number | undefined;\n\n/** Best-effort mtime; `undefined` when the path is unreadable (treated as a miss). */\nfunction calibrationModelMtimeMs(path: string): number | undefined {\n  try {\n    return statSync(path).mtimeMs;\n  } catch {\n    return undefined;\n  }\n}\n\nfunction resolveCalibrationModel(): CalibrationModel | null {\n  const path = getConfidenceCalibrationModelPath();\n  if (!path) return null;\n  const mtimeMs = calibrationModelMtimeMs(path);\n  if (\n    cachedCalibrationModel !== undefined &&\n    cachedCalibrationModelPath === path &&\n    cachedCalibrationModelMtimeMs === mtimeMs\n  ) {\n    return cachedCalibrationModel;\n  }\n  cachedCalibrationModelPath = path;\n  cachedCalibrationModelMtimeMs = mtimeMs;\n  cachedCalibrationModel = loadCalibrationModel(path);\n  return cachedCalibrationModel;\n}\n\n/**\n * Map a rebalanced confidence value through the empirical calibration model\n * when enabled. Default OFF and a no-op when no model is configured, so the\n * returned value is identical to the rebalance-only path until a validated\n * model is wired in.\n */\nfunction maybeCalibrate(value: number): number {\n  if (!isConfidenceCalibrationEnabled()) return value;\n  const model = resolveCalibrationModel();\n  if (!model) return value;\n  return applyCalibration(model, value);\n}\n\n/**\n * Count the number of unique channels that retrieved this result.\n * Inspects `sources`, `source`, and traceMetadata.attribution.\n */\nfunction countChannels(result: ScoredResult): number {\n  const channels = new Set<string>();\n\n  if (Array.isArray(result.sources)) {\n    for (const s of result.sources) {\n      if (typeof s === 'string' && s.trim().length > 0) channels.add(s.trim());\n    }\n  }\n\n  if (typeof result.source === 'string' && result.source.trim().length > 0) {\n    channels.add(result.source.trim());\n  }\n\n  // Check traceMetadata.attribution for richer channel data\n  const numericId = typeof result.id === 'number' ? result.id : null;\n  const attribution = result.traceMetadata?.attribution;\n  if (attribution && typeof attribution === 'object' && numericId !== null) {\n    for (const [channel, memoryIds] of Object.entries(attribution as Record<string, unknown>)) {\n      if (!Array.isArray(memoryIds)) continue;\n      const matched = memoryIds.some((mid) => {\n        const n = typeof mid === 'number' ? mid : typeof mid === 'string' ? Number(mid) : NaN;\n        return Number.isFinite(n) && n === numericId;\n      });\n      if (matched && typeof channel === 'string' && channel.trim().length > 0) {\n        channels.add(channel.trim());\n      }\n    }\n  }\n\n  return channels.size;\n}\n\n/**\n * Count anchors present in this result's anchorMetadata array.\n * A result with multiple named anchors is considered \"dense\" and\n * more likely to be a high-quality, well-structured memory.\n */\nfunction countAnchors(result: ScoredResult): number {\n  if (!Array.isArray(result.anchorMetadata)) return 0;\n  return result.anchorMetadata.length;\n}\n\n/**\n * Compute the score margin between result[i] and result[i+1].\n * Tail results have no successor, so they receive no synthetic margin boost.\n */\nfunction computeMargin(score: number, nextScore: number | null): number {\n  if (nextScore === null) return 0;\n  const gap = score - nextScore;\n  return Math.max(0, gap);\n}\n\n/**\n * Map raw confidence value to a coarse label.\n */\nfunction toConfidenceLabel(value: number): ConfidenceLabel {\n  if (value >= HIGH_THRESHOLD) return 'high';\n  if (value >= LOW_THRESHOLD) return 'medium';\n  return 'low';\n}\n\nexport function asRankingConfidenceValue(value: number): RankingConfidenceValue {\n  const clamped = Math.max(0, Math.min(1, value));\n  return (Math.round(clamped * 1000) / 1000) as RankingConfidenceValue;\n}\n\n// -- Public API --\n\n/**\n * Compute per-result confidence for a ranked list of results.\n *\n * Each result receives a confidence object derived from:\n *   - Score margin to the next result (35% weight)\n *   - Number of channels that contributed this result (30%)\n *   - Anchor density in anchorMetadata (15%)\n *\n * @param results - Ranked results (highest score first). Ordering is assumed.\n * @returns Array of ResultConfidence objects, parallel to `results`.\n */\nexport function computeResultConfidence(results: ScoredResult[]): ResultConfidence[] {\n  if (!Array.isArray(results) || results.length === 0) return [];\n\n  const scores = results.map(resolveScore);\n\n  return results.map((result, i): ResultConfidence => {\n    const score = scores[i] ?? 0;\n    const nextScore = i + 1 < scores.length ? (scores[i + 1] ?? null) : null;\n\n    const margin = computeMargin(score, nextScore);\n    const channelCount = countChannels(result);\n    const anchorCount = countAnchors(result);\n\n    // Factor scores (each 0–1)\n    const marginFactor = margin >= LARGE_MARGIN_THRESHOLD\n      ? 1.0\n      : margin >= SMALL_MARGIN_THRESHOLD\n        ? margin / LARGE_MARGIN_THRESHOLD\n        : 0;\n\n    const channelFactor = channelCount >= STRONG_CHANNEL_AGREEMENT_MIN\n      ? 1.0\n      : channelCount === 1\n        ? 0.5\n        : 0;\n\n    // Anchor density: 1 anchor → 0.3, 2 → 0.6, 3+ → 1.0\n    const anchorFactor = Math.min(1, anchorCount * 0.33);\n\n    const rawValue =\n      WEIGHT_MARGIN * marginFactor +\n      WEIGHT_CHANNEL_AGREEMENT * channelFactor +\n      WEIGHT_ANCHOR_DENSITY * anchorFactor;\n\n    // Base score is a strong prior: if the score itself is very high, confidence\n    // should reflect that even when heuristic signals are weak. Use the absolute\n    // relevance (cosine) here, not the RRF ordering score — an RRF magnitude of\n    // ~0.03 would make this prior contribute ~0.01 and defeat its purpose.\n    // Relevance carries the larger weight so the band stays monotonic in it.\n    const scorePrior = resolveCalibrationScore(result) * WEIGHT_SCORE_PRIOR;\n    const heuristicValue = rawValue * WEIGHT_HEURISTIC;\n    const rebalancedValue = Math.max(0, Math.min(1, heuristicValue + scorePrior));\n\n    // Optional empirical calibration to P(relevant). Default OFF: only applied\n    // when the flag is on AND a fitted model is available, so production\n    // confidence is the rebalance-only value until a validated model exists.\n    const value = maybeCalibrate(rebalancedValue);\n\n    const drivers: ConfidenceDriver[] = [];\n    if (margin >= LARGE_MARGIN_THRESHOLD) drivers.push('large_margin');\n    if (channelCount >= STRONG_CHANNEL_AGREEMENT_MIN) drivers.push('multi_channel_agreement');\n    if (anchorCount >= 2) drivers.push('anchor_density');\n\n      return {\n        confidence: {\n          label: toConfidenceLabel(value),\n          value: asRankingConfidenceValue(value),\n          drivers,\n        },\n      };\n  });\n}\n\n/**\n * Compute request-level quality assessment based on the overall result set.\n *\n * - \"good\":  a dominant top hit, or a healthy top score with confident head / clear margin\n * - \"weak\":  results exist but signals are mixed or low\n * - \"gap\":   no results, or all results have low confidence\n *\n * The \"good\" rule is top-dominant and margin-aware: a single strong, well-separated\n * top hit is citable even when the tail is weak. Without this, a strong top result\n * is dragged to \"weak\" by a weaker tail, and expanding recall (more tail candidates)\n * mechanically lowers the quality ratio — penalizing the very recall that found the hit.\n *\n * @param results   - The scored results for the query.\n * @param confidences - Parallel confidence array from `computeResultConfidence`.\n */\nexport function assessRequestQuality(\n  results: ScoredResult[],\n  confidences: ResultConfidence[],\n): RequestQualityAssessment {\n  if (!Array.isArray(results) || results.length === 0) {\n    return { requestQuality: { label: 'gap' } };\n  }\n\n  // `results` and `confidences` are a parallel pair (confidences come from\n  // computeResultConfidence(results)). A length mismatch means the head slice\n  // below would pair results[i] with an unrelated confidence, so degrade to the\n  // conservative do-not-cite verdict rather than emit a quality label off\n  // misaligned data. Holds at every call site today — defensive only.\n  if (!Array.isArray(confidences) || confidences.length !== results.length) {\n    return { requestQuality: { label: 'gap' } };\n  }\n\n  // Absolute relevance, not the RRF ordering score: HIGH_THRESHOLD/LOW_THRESHOLD\n  // are calibrated for a 0–1 cosine scale, so an RRF-magnitude topScore (~0.03)\n  // would put \"good\" out of reach and collapse every query to weak/gap.\n  const topScore = resolveCalibrationScore(results[0]);\n\n  // Quality ratio over the head of the ranking only, so recall expansion does\n  // not depress it (see QUALITY_RATIO_HEAD).\n  const head = Math.min(confidences.length, QUALITY_RATIO_HEAD);\n  const highOrMediumCount = confidences\n    .slice(0, head)\n    .filter((c) => c.confidence.label === 'high' || c.confidence.label === 'medium')\n    .length;\n  const qualityRatio = head > 0 ? highOrMediumCount / head : 0;\n\n  // Margin between #1 and #2 on the same absolute scale as topScore. A clear gap\n  // to the runner-up marks a dominant top hit even when the tail is weak.\n  const topMargin = results.length > 1\n    ? computeMargin(topScore, resolveCalibrationScore(results[1]))\n    : 0;\n\n  // A sufficiently strong top hit is citable on its own, regardless of the tail.\n  if (topScore >= TOP_DOMINANT_THRESHOLD) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // Otherwise a healthy top hit reads \"good\" when the head is mostly confident\n  // OR the top hit clearly dominates the runner-up.\n  if (topScore >= HIGH_THRESHOLD && (qualityRatio >= 0.6 || topMargin >= LARGE_MARGIN_THRESHOLD)) {\n    return { requestQuality: { label: 'good' } };\n  }\n  // weak/gap thresholds unchanged — preserves the do-not-cite safety net for\n  // genuinely low-signal queries.\n  if (topScore >= LOW_THRESHOLD || qualityRatio >= 0.3) {\n    return { requestQuality: { label: 'weak' } };\n  }\n  return { requestQuality: { label: 'gap' } };\n}\n\n/**\n * Check whether the per-result confidence feature flag is enabled.\n * Default: ON (graduated). Set SPECKIT_RESULT_CONFIDENCE_V1=false to disable.\n */\nexport { isResultConfidenceEnabled } from './search-flags.js';","lineStart":1,"lineEnd":443,"totalLines":443,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/confidence-scoring.ts","time":{"start":1781763793440,"end":1781763793449}},"metadata":{"openai":{"itemId":"fc_036c3a75fcdce96f016a338ed07e2c8191bd0e2ebcbc486561"}},"id":"prt_ed965e192001Js8sQNsHYR1rw1","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed965a7a6001axABUKSXIuuHDU"}}
