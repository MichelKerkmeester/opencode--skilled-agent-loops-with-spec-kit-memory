/specs/sk-design/011-sk-design-styles-utilization/002-md-generator-upgrade/research/lineages/sol/iterations/iteration-001.md:16-18\"]}\n5: {\"type\":\"finding\",\"id\":\"I003-F4\",\"iteration\":3,\"question\":\"Q3\",\"summary\":\"Use a fail-closed generation, provenance, rights/use-label, and prompt-injection envelope; raw corpus text never reaches the writer.\",\"roughBuildCost\":\"1-2 engineer-days\",\"sources\":[\".opencode/specs/sk-design/011-sk-design-styles-utilization/001-research-utilization/research/lineages/sol/research.md:117-132\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/001-research-utilization/research/lineages/sol/research.md:174-185\",\".opencode/skills/sk-design/design-md-generator/backend/scripts/build-write-prompt.ts:116-126\"]}\n6: {\"type\":\"finding\",\"id\":\"I003-F5\",\"iteration\":3,\"question\":\"Q3\",\"summary\":\"Run target-value and source-overlap leakage checks before normal validation, with positive, negative, stale, rights, injection, mismatch, capability, copy, and false-positive fixtures.\",\"roughBuildCost\":\"3-5 engineer-days\",\"sources\":[\".opencode/skills/sk-design/design-md-generator/backend/scripts/build-write-prompt.ts:116-126\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/001-research-utilization/research/lineages/sol/research.md:174-191\",\".opencode/specs/sk-design/011-sk-design-styles-utilization/002-md-generator-upgrade/research/lineages/sol/iterations/iteration-002.md:25\"]}\n\n(End of file - total 6 lines)\n</content>","metadata":{"preview":"{\"type\":\"iteration\",\"iteration\":3,\"mode\":\"research\",\"target_agent\":\"deep-research\",\"agent_definition_loaded\":true,\"resolved_route\":\"Resolved route: mode=research target_agent=deep-research\",\"run\":3,\"status\":\"complete\",\"focus\":\"Define Q3 bounded STUDY selection, transformation, authority, provenance, anti-injection, leakage, and adversarial-fixture protocol at pre-WRITE\",\"findingsCount\":5,\"newInfoRatio\":1.0,\"n