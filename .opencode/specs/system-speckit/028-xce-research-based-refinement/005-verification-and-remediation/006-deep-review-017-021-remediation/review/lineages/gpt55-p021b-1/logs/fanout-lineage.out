86:     });\n287:     mocks.mockBatchUpdateMtimes.mockReturnValue({ updated: 0 });\n288:     mocks.mockListIndexedRecordIdsForDeletedPaths.mockReturnValue([]);\n289:     mocks.mockDeleteMemory.mockReturnValue(true);\n290:     mocks.mockGetDb.mockReturnValue({\n291:       prepare: vi.fn(() => ({ get: vi.fn(() => undefined), all: vi.fn(() => []) })),\n292:     });\n293:     mocks.mockRunPostMutationHooks.mockReturnValue({ latencyMs: 0 });\n294:     mocks.mockRequireDb.mockReturnValue({\n295:       prepare: vi.fn(() => ({ all: vi.fn(() => []), get: vi.fn(() => undefined) })),\n296:     });\n297:     mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'indexed', id: 1, specFolder: 'specs/test' });\n298:     mocks.mockProcessBatches.mockImplementation(\n299:       async (files: string[], worker: (file: string) => Promise<unknown>) => Promise.all(files.map(worker)),\n300:     );\n301:   });\n302: \n303:   it('background:true returns a queued jobId immediately without blocking on the scan', async () => {\n304:     const { gate, release } = createBatchGate();\n305:     mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n306:       await gate;\n307:       return Promise.all(files.map(worker));\n308:     });\n309: \n310:     const result = await scanHandler.handleMemoryIndexScan({\n311:       background: true,\n312:       includeConstitutional: false,\n313:       includeSpecDocs: true,\n314:       incremental: false,\n315:       force: false,\n316:     });\n317: \n318:     const { data } = parseEnvelope(result);\n319:     expect(data.background).toBe(true);\n320:     expect(data.state).toBe('queued');\n321:     expect(typeof data.jobId).toBe('string');\n322: \n323:     const jobId = data.jobId as string;\n324:     // The runner advances to 'running' but parks at the gated batch loop — the\n325:     // handler already returned, proving the call did not block on the scan.\n326:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'running');\n327:     expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n328: \n329:     release();\n330:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n331:     expect(mocks.mockIndexMemoryFile).toHaveBeenCalledTimes(1);\n332:   });\n333: \n334:   it('without background runs synchronously and never creates a job', async () => {\n335:     const result = await scanHandler.handleMemoryIndexScan({\n336:       includeConstitutional: false,\n337:       includeSpecDocs: true,\n338:       incremental: false,\n339:       force: false,\n340:     });\n341: \n342:     const { data } = parseEnvelope(result);\n343:     expect(data.status).toBe('complete');\n344:     expect(data.jobId).toBeUndefined();\n345:     expect(jobStore.createMaintenanceJob).not.toHaveBeenCalled();\n346:   });\n347: \n348:   it('memory_index_scan_status echoes the terminal result and returns E404 for unknown ids', async () => {\n349:     const started = await scanHandler.handleMemoryIndexScan({\n350:       background: true,\n351:       includeConstitutional: false,\n352:       includeSpecDocs: true,\n353:       incremental: false,\n354:       force: false,\n355:     });\n356:     const jobId = parseEnvelope(started).data.jobId as string;\n357:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n358: \n359:     const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n360:     const statusData = parseEnvelope(statusRes).data;\n361:     expect(statusData.state).toBe('complete');\n362:     const echoed = statusData.result as Record<string, unknown>;\n363:     expect(echoed.status).toBe('complete');\n364: \n365:     const missing = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId: 'job_missing' });\n366:     // The error envelope carries the code at the top level of the payload.\n367:     const missingPayload = JSON.parse(missing.content[0].text) as { code?: string };\n368:     expect(missingPayload.code).toBe('E404');\n369:   });\n370: \n371:   it('counts a cancelled file as neither failed nor success', async () => {\n372:     // A file whose worker returns 'cancelled' (operator-requested stop mid-batch)\n373:     // must not inflate the failure tally — the cancel is not a file error.\n374:     mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'cancelled' });\n375: \n376:     const result = await scanHandler.handleMemoryIndexScan({\n377:       includeConstitutional: false,\n378:       includeSpecDocs: true,\n379:       incremental: false,\n380:       force: false,\n381:     });\n382: \n383:     const { data } = parseEnvelope(result);\n384:     expect(data.failed).toBe(0);\n385:     expect(data.indexed).toBe(0);\n386:     expect(data.updated).toBe(0);\n387:   });\n388: \n389:   it('instruments the empty-files tail phases via timedPhase (onPhase markers)', async () => {\n390:     // No discoverable files routes through the empty-files branch; that branch must\n391:     // still fire onPhase for each tail maintenance phase so the busy marker refreshes\n392:     // and per-phase timing is emitted — symmetry with the main scan path.\n393:     mocks.mockFindSpecDocuments.mockReturnValue([]);\n394:     mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n395: \n396:     const started = await scanHandler.handleMemoryIndexScan({\n397:       background: true,\n398:       includeConstitutional: false,\n399:       includeSpecDocs: true,\n400:       incremental: false,\n401:       force: false,\n402:     });\n403:     const jobId = parseEnvelope(started).data.jobId as string;\n404:     await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n405: \n406:     const phases = jobStore.setJobPhase.mock.calls.map((call) => call[1]);\n407:     expect(phases).toContain('orphan-sweep');\n408:     expect(phases).toContain('enrichment-repair');\n409:     expect(phases).toContain('near-dup-repair');\n410:     expect(phases).toContain('trigger-backfill');\n411: \n412:     // The empty-files branch never enters the indexing loop.\n413:     expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n414:     const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n415:     const echoed = parseEnvelope(statusRes).data.result as Record<string, unknown>;\n416:     expect(echoed.status).toBe('complete');\n417:   });\n418: \n419:   it('cancel stops the runner at a phase boundary, releases the lease, and is idempotent', async () => {\n420:     const { gate, release } = createBatchGate();\n421:     mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n422:       await gate;\n423:       return Promise.all(files.map(worker));\n424:     });\n425: \n426:     const started = await scanHandler.handleMemoryIndexScan({\n427:       background: true,\n428:       includeConstitutional: false,\n429:       includeSpecDocs: true,\n430:       incremental: false,\n431:       force: false,\n432:     });\n433:     const jobId = parseEnvelope(started).data.jobId as string;\n434: \n435:     // Runner parks in the indexing phase, before any file work.\n436:     await waitFor(() => jobStore.jobs.get(jobId)?.phase === 'indexing');\n437: \n438:     const cancelRes = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n439:     expect(parseEnvelope(cancelRes).data.cancelRequested).toBe(true);\n\n(Showing lines 250-439 of 451. Use offset=440 to continue.)\n</content>","metadata":{"preview":"}\n\nfunction createBatchGate(): { gate: Promise<void>; release: () => void } {\n  let release = (): void => {};\n  const gate = new Promise<void>((resolve) => { release = resolve; });\n  return { gate, release };\n}\n\n// ──────────────────────────────────────────────────────────────\n// 5. TESTS\n// ──────────────────────────────────────────────────────────────\n\ndescribe('memory_index_scan background dispatch', () => {\n  beforeEach(() => {\n    vi.clearAllMocks();\n    jobStore.jobs.clear();\n\n    mocks.mockAcquireIndexScanLease.mockResolvedValue({\n      acquired: true,\n      reason: 'ok',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","text":"}\n\nfunction createBatchGate(): { gate: Promise<void>; release: () => void } {\n  let release = (): void => {};\n  const gate = new Promise<void>((resolve) => { release = resolve; });\n  return { gate, release };\n}\n\n// ──────────────────────────────────────────────────────────────\n// 5. TESTS\n// ──────────────────────────────────────────────────────────────\n\ndescribe('memory_index_scan background dispatch', () => {\n  beforeEach(() => {\n    vi.clearAllMocks();\n    jobStore.jobs.clear();\n\n    mocks.mockAcquireIndexScanLease.mockResolvedValue({\n      acquired: true,\n      reason: 'ok',\n      waitSeconds: 0,\n      lastIndexScan: 0,\n      scanStartedAt: 0,\n      leaseExpiryMs: 120000,\n      cooldownMs: 60000,\n    });\n    mocks.mockCompleteIndexScanLease.mockResolvedValue(undefined);\n    mocks.mockCheckDatabaseUpdated.mockResolvedValue(false);\n    mocks.mockFindSpecDocuments.mockReturnValue([TEST_FILE]);\n    mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n    mocks.mockFindGraphMetadataFiles.mockReturnValue([]);\n    mocks.mockCategorizeFilesForIndexing.mockReturnValue({\n      toIndex: [TEST_FILE],\n      toUpdate: [],\n      toSkip: [],\n      toDelete: [],\n    });\n    mocks.mockBatchUpdateMtimes.mockReturnValue({ updated: 0 });\n    mocks.mockListIndexedRecordIdsForDeletedPaths.mockReturnValue([]);\n    mocks.mockDeleteMemory.mockReturnValue(true);\n    mocks.mockGetDb.mockReturnValue({\n      prepare: vi.fn(() => ({ get: vi.fn(() => undefined), all: vi.fn(() => []) })),\n    });\n    mocks.mockRunPostMutationHooks.mockReturnValue({ latencyMs: 0 });\n    mocks.mockRequireDb.mockReturnValue({\n      prepare: vi.fn(() => ({ all: vi.fn(() => []), get: vi.fn(() => undefined) })),\n    });\n    mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'indexed', id: 1, specFolder: 'specs/test' });\n    mocks.mockProcessBatches.mockImplementation(\n      async (files: string[], worker: (file: string) => Promise<unknown>) => Promise.all(files.map(worker)),\n    );\n  });\n\n  it('background:true returns a queued jobId immediately without blocking on the scan', async () => {\n    const { gate, release } = createBatchGate();\n    mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n      await gate;\n      return Promise.all(files.map(worker));\n    });\n\n    const result = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.background).toBe(true);\n    expect(data.state).toBe('queued');\n    expect(typeof data.jobId).toBe('string');\n\n    const jobId = data.jobId as string;\n    // The runner advances to 'running' but parks at the gated batch loop — the\n    // handler already returned, proving the call did not block on the scan.\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'running');\n    expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n\n    release();\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n    expect(mocks.mockIndexMemoryFile).toHaveBeenCalledTimes(1);\n  });\n\n  it('without background runs synchronously and never creates a job', async () => {\n    const result = await scanHandler.handleMemoryIndexScan({\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.status).toBe('complete');\n    expect(data.jobId).toBeUndefined();\n    expect(jobStore.createMaintenanceJob).not.toHaveBeenCalled();\n  });\n\n  it('memory_index_scan_status echoes the terminal result and returns E404 for unknown ids', async () => {\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n\n    const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n    const statusData = parseEnvelope(statusRes).data;\n    expect(statusData.state).toBe('complete');\n    const echoed = statusData.result as Record<string, unknown>;\n    expect(echoed.status).toBe('complete');\n\n    const missing = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId: 'job_missing' });\n    // The error envelope carries the code at the top level of the payload.\n    const missingPayload = JSON.parse(missing.content[0].text) as { code?: string };\n    expect(missingPayload.code).toBe('E404');\n  });\n\n  it('counts a cancelled file as neither failed nor success', async () => {\n    // A file whose worker returns 'cancelled' (operator-requested stop mid-batch)\n    // must not inflate the failure tally — the cancel is not a file error.\n    mocks.mockIndexMemoryFile.mockResolvedValue({ status: 'cancelled' });\n\n    const result = await scanHandler.handleMemoryIndexScan({\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n\n    const { data } = parseEnvelope(result);\n    expect(data.failed).toBe(0);\n    expect(data.indexed).toBe(0);\n    expect(data.updated).toBe(0);\n  });\n\n  it('instruments the empty-files tail phases via timedPhase (onPhase markers)', async () => {\n    // No discoverable files routes through the empty-files branch; that branch must\n    // still fire onPhase for each tail maintenance phase so the busy marker refreshes\n    // and per-phase timing is emitted — symmetry with the main scan path.\n    mocks.mockFindSpecDocuments.mockReturnValue([]);\n    mocks.mockFindConstitutionalFiles.mockReturnValue([]);\n\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n    await waitFor(() => jobStore.jobs.get(jobId)?.state === 'complete');\n\n    const phases = jobStore.setJobPhase.mock.calls.map((call) => call[1]);\n    expect(phases).toContain('orphan-sweep');\n    expect(phases).toContain('enrichment-repair');\n    expect(phases).toContain('near-dup-repair');\n    expect(phases).toContain('trigger-backfill');\n\n    // The empty-files branch never enters the indexing loop.\n    expect(mocks.mockIndexMemoryFile).not.toHaveBeenCalled();\n    const statusRes = await scanJobHandlers.handleMemoryIndexScanStatus({ jobId });\n    const echoed = parseEnvelope(statusRes).data.result as Record<string, unknown>;\n    expect(echoed.status).toBe('complete');\n  });\n\n  it('cancel stops the runner at a phase boundary, releases the lease, and is idempotent', async () => {\n    const { gate, release } = createBatchGate();\n    mocks.mockProcessBatches.mockImplementation(async (files: string[], worker: (file: string) => Promise<unknown>) => {\n      await gate;\n      return Promise.all(files.map(worker));\n    });\n\n    const started = await scanHandler.handleMemoryIndexScan({\n      background: true,\n      includeConstitutional: false,\n      includeSpecDocs: true,\n      incremental: false,\n      force: false,\n    });\n    const jobId = parseEnvelope(started).data.jobId as string;\n\n    // Runner parks in the indexing phase, before any file work.\n    await waitFor(() => jobStore.jobs.get(jobId)?.phase === 'indexing');\n\n    const cancelRes = await scanJobHandlers.handleMemoryIndexScanCancel({ jobId });\n    expect(parseEnvelope(cancelRes).data.cancelRequested).toBe(true);","lineStart":250,"lineEnd":439,"totalLines":451,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/handler-memory-index-scan-jobs.vitest.ts","time":{"start":1781755689397,"end":1781755689404}},"metadata":{"openai":{"itemId":"fc_03587c3e99ec24fd016a336f29073c8191acdc1cacd0dcdd81"}},"id":"prt_ed8ea3851001S85KebSGs9CMHM","sessionID":"ses_12718501effeJJTfPZxos2yLxP","messageID":"msg_ed8ea2917001cG5t4MLvHNv0qf"}}
