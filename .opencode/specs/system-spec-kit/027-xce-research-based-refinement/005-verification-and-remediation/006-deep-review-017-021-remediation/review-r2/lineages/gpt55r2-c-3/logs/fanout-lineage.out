{"type":"tool_use","timestamp":1781762174936,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_V1pFsYJgcLP1y3Ho1m8tuexO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","offset":1,"limit":230},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Spec Folder Mutex\n3: // ───────────────────────────────────────────────────────────────\n4: // Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n5: \n6: import { createHash } from 'node:crypto';\n7: import fs from 'node:fs';\n8: import os from 'node:os';\n9: import path from 'node:path';\n10: \n11: // Feature catalog: Memory indexing (memory_save)\n12: // Feature catalog: Atomic-save parity and partial-indexing hints\n13: \n14: const SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\n15: const LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\n16: const LOCK_WAIT_MS = 25;\n17: const LOCK_TIMEOUT_MS = 30_000;\n18: const LOCK_STALE_MS = 5 * 60 * 1000;\n19: const LOCK_HEARTBEAT_MS = 60_000;\n20: \n21: type LockOwnerState = 'alive' | 'dead' | 'unknown';\n22: \n23: const lockHeartbeats = new Map<string, ReturnType<typeof setInterval>>();\n24: \n25: interface InterprocessLockHandle {\n26:   lockDir: string;\n27: }\n28: \n29: function sleep(ms: number): Promise<void> {\n30:   return new Promise((resolve) => setTimeout(resolve, ms));\n31: }\n32: \n33: function getLockDir(specFolder: string): string {\n34:   const digest = createHash('sha1').update(specFolder).digest('hex');\n35:   return path.join(LOCK_ROOT, digest);\n36: }\n37: \n38: function isExistingDirectoryError(error: unknown): boolean {\n39:   return Boolean(error && typeof error === 'object' && 'code' in error && (error as { code?: string }).code === 'EEXIST');\n40: }\n41: \n42: function getNodeErrorCode(error: unknown): string | null {\n43:   if (error && typeof error === 'object' && 'code' in error) {\n44:     const code = (error as { code?: unknown }).code;\n45:     return typeof code === 'string' ? code : null;\n46:   }\n47:   return null;\n48: }\n49: \n50: // Read back the lock owner pid and probe whether that process is still alive.\n51: // A live owner must never be reaped — that is the TOCTOU this mutex prevents.\n52: function getLockOwnerState(lockDir: string): LockOwnerState {\n53:   let ownerRaw: string;\n54:   try {\n55:     ownerRaw = fs.readFileSync(path.join(lockDir, 'owner.json'), 'utf8');\n56:   } catch {\n57:     return 'unknown';\n58:   }\n59: \n60:   let ownerPid: number;\n61:   try {\n62:     const parsed = JSON.parse(ownerRaw) as { pid?: unknown };\n63:     ownerPid = Number(parsed.pid);\n64:   } catch {\n65:     return 'unknown';\n66:   }\n67:   if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n68:     return 'unknown';\n69:   }\n70: \n71:   try {\n72:     process.kill(ownerPid, 0);\n73:     return 'alive';\n74:   } catch (error: unknown) {\n75:     const code = getNodeErrorCode(error);\n76:     if (code === 'ESRCH') {\n77:       return 'dead';\n78:     }\n79:     if (code === 'EPERM') {\n80:       return 'alive';\n81:     }\n82:     return 'unknown';\n83:   }\n84: }\n85: \n86: // A lock is reclaimable only when its owner is provably gone (dead), or when the\n87: // owner record is unreadable AND the dir has aged past the stale threshold.\n88: // An alive owner is never reclaimable, regardless of age.\n89: function isReclaimableLock(lockDir: string): boolean {\n90:   let ageMs: number;\n91:   try {\n92:     const stats = fs.statSync(lockDir);\n93:     ageMs = Date.now() - stats.mtimeMs;\n94:   } catch {\n95:     return false;\n96:   }\n97:   const ownerState = getLockOwnerState(lockDir);\n98:   return ownerState === 'dead' || (ownerState === 'unknown' && ageMs > LOCK_STALE_MS);\n99: }\n100: \n101: function stopHeartbeat(lockDir: string): void {\n102:   const heartbeat = lockHeartbeats.get(lockDir);\n103:   if (!heartbeat) {\n104:     return;\n105:   }\n106:   clearInterval(heartbeat);\n107:   lockHeartbeats.delete(lockDir);\n108: }\n109: \n110: // Refresh the lock dir mtime while fn() runs so a long-but-live save is never\n111: // mistaken for an abandoned lock by the stale-age fallback.\n112: function startHeartbeat(lockDir: string): void {\n113:   stopHeartbeat(lockDir);\n114:   const heartbeat = setInterval(() => {\n115:     try {\n116:       const now = new Date();\n117:       fs.utimesSync(lockDir, now, now);\n118:     } catch {\n119:       stopHeartbeat(lockDir);\n120:     }\n121:   }, LOCK_HEARTBEAT_MS);\n122:   const unref = (heartbeat as { unref?: () => void }).unref;\n123:   unref?.call(heartbeat);\n124:   lockHeartbeats.set(lockDir, heartbeat);\n125: }\n126: \n127: function createInterprocessLock(specFolder: string, lockDir: string): InterprocessLockHandle {\n128:   fs.mkdirSync(lockDir);\n129:   fs.writeFileSync(path.join(lockDir, 'owner.json'), JSON.stringify({\n130:     pid: process.pid,\n131:     specFolder,\n132:     acquiredAt: new Date().toISOString(),\n133:   }));\n134:   startHeartbeat(lockDir);\n135:   return { lockDir };\n136: }\n137: \n138: function releaseInterprocessLock(handle: InterprocessLockHandle): void {\n139:   stopHeartbeat(handle.lockDir);\n140:   try {\n141:     fs.rmSync(handle.lockDir, { recursive: true, force: true });\n142:   } catch (error: unknown) {\n143:     console.warn('[memory-save] failed to release interprocess spec-folder lock:', error);\n144:   }\n145: }\n146: \n147: async function acquireInterprocessLock(specFolder: string): Promise<InterprocessLockHandle> {\n148:   const lockDir = getLockDir(specFolder);\n149:   const deadline = Date.now() + LOCK_TIMEOUT_MS;\n150: \n151:   fs.mkdirSync(LOCK_ROOT, { recursive: true });\n152: \n153:   while (true) {\n154:     try {\n155:       return createInterprocessLock(specFolder, lockDir);\n156:     } catch (error: unknown) {\n157:       if (!isExistingDirectoryError(error)) {\n158:         throw error;\n159:       }\n160: \n161:       if (isReclaimableLock(lockDir)) {\n162:         fs.rmSync(lockDir, { recursive: true, force: true });\n163:         continue;\n164:       }\n165: \n166:       if (Date.now() >= deadline) {\n167:         throw new Error(`Timed out acquiring interprocess spec-folder lock for ${specFolder}`);\n168:       }\n169: \n170:       await sleep(LOCK_WAIT_MS);\n171:     }\n172:   }\n173: }\n174: \n175: async function withSpecFolderLock<T>(specFolder: string, fn: () => Promise<T>): Promise<T> {\n176:   const normalizedFolder = specFolder || '__global__';\n177:   const chain = (SPEC_FOLDER_LOCKS.get(normalizedFolder) ?? Promise.resolve())\n178:     .catch((error: unknown) => {\n179:       console.error('[memory-save] prior queued save failed:', error);\n180:     })\n181:     .then(async () => {\n182:       const interprocessLock = await acquireInterprocessLock(normalizedFolder);\n183:       try {\n184:         return await fn();\n185:       } finally {\n186:         releaseInterprocessLock(interprocessLock);\n187:       }\n188:     });\n189:   SPEC_FOLDER_LOCKS.set(normalizedFolder, chain);\n190:   try {\n191:     return await chain;\n192:   } finally {\n193:     if (SPEC_FOLDER_LOCKS.get(normalizedFolder) === chain) {\n194:       SPEC_FOLDER_LOCKS.delete(normalizedFolder);\n195:     }\n196:   }\n197: }\n198: \n199: export {\n200:   SPEC_FOLDER_LOCKS,\n201:   withSpecFolderLock,\n202:   // Exported for targeted lock-liveness tests; not part of the save flow API.\n203:   LOCK_STALE_MS,\n204:   LOCK_HEARTBEAT_MS,\n205:   getLockDir,\n206:   getLockOwnerState,\n207:   isReclaimableLock,\n208:   createInterprocessLock,\n209:   releaseInterprocessLock,\n210: };\n\n(End of file - total 210 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Spec Folder Mutex\n// ───────────────────────────────────────────────────────────────\n// Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n\nimport { createHash } from 'node:crypto';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport path from 'node:path';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\nconst SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\nconst LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\nconst LOCK_WAIT_MS = 25;\nconst LOCK_TIMEOUT_MS = 30_000;\nconst LOCK_STALE_MS = 5 * 60 * 1000;\nconst LOCK_HEARTBEAT_MS = 60_000;\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Spec Folder Mutex\n// ───────────────────────────────────────────────────────────────\n// Per-spec-folder save mutex to prevent concurrent indexing races (TOCTOU).\n\nimport { createHash } from 'node:crypto';\nimport fs from 'node:fs';\nimport os from 'node:os';\nimport path from 'node:path';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\nconst SPEC_FOLDER_LOCKS = new Map<string, Promise<unknown>>();\nconst LOCK_ROOT = path.join(os.tmpdir(), 'mk-spec-memory-save-locks');\nconst LOCK_WAIT_MS = 25;\nconst LOCK_TIMEOUT_MS = 30_000;\nconst LOCK_STALE_MS = 5 * 60 * 1000;\nconst LOCK_HEARTBEAT_MS = 60_000;\n\ntype LockOwnerState = 'alive' | 'dead' | 'unknown';\n\nconst lockHeartbeats = new Map<string, ReturnType<typeof setInterval>>();\n\ninterface InterprocessLockHandle {\n  lockDir: string;\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction getLockDir(specFolder: string): string {\n  const digest = createHash('sha1').update(specFolder).digest('hex');\n  return path.join(LOCK_ROOT, digest);\n}\n\nfunction isExistingDirectoryError(error: unknown): boolean {\n  return Boolean(error && typeof error === 'object' && 'code' in error && (error as { code?: string }).code === 'EEXIST');\n}\n\nfunction getNodeErrorCode(error: unknown): string | null {\n  if (error && typeof error === 'object' && 'code' in error) {\n    const code = (error as { code?: unknown }).code;\n    return typeof code === 'string' ? code : null;\n  }\n  return null;\n}\n\n// Read back the lock owner pid and probe whether that process is still alive.\n// A live owner must never be reaped — that is the TOCTOU this mutex prevents.\nfunction getLockOwnerState(lockDir: string): LockOwnerState {\n  let ownerRaw: string;\n  try {\n    ownerRaw = fs.readFileSync(path.join(lockDir, 'owner.json'), 'utf8');\n  } catch {\n    return 'unknown';\n  }\n\n  let ownerPid: number;\n  try {\n    const parsed = JSON.parse(ownerRaw) as { pid?: unknown };\n    ownerPid = Number(parsed.pid);\n  } catch {\n    return 'unknown';\n  }\n  if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n    return 'unknown';\n  }\n\n  try {\n    process.kill(ownerPid, 0);\n    return 'alive';\n  } catch (error: unknown) {\n    const code = getNodeErrorCode(error);\n    if (code === 'ESRCH') {\n      return 'dead';\n    }\n    if (code === 'EPERM') {\n      return 'alive';\n    }\n    return 'unknown';\n  }\n}\n\n// A lock is reclaimable only when its owner is provably gone (dead), or when the\n// owner record is unreadable AND the dir has aged past the stale threshold.\n// An alive owner is never reclaimable, regardless of age.\nfunction isReclaimableLock(lockDir: string): boolean {\n  let ageMs: number;\n  try {\n    const stats = fs.statSync(lockDir);\n    ageMs = Date.now() - stats.mtimeMs;\n  } catch {\n    return false;\n  }\n  const ownerState = getLockOwnerState(lockDir);\n  return ownerState === 'dead' || (ownerState === 'unknown' && ageMs > LOCK_STALE_MS);\n}\n\nfunction stopHeartbeat(lockDir: string): void {\n  const heartbeat = lockHeartbeats.get(lockDir);\n  if (!heartbeat) {\n    return;\n  }\n  clearInterval(heartbeat);\n  lockHeartbeats.delete(lockDir);\n}\n\n// Refresh the lock dir mtime while fn() runs so a long-but-live save is never\n// mistaken for an abandoned lock by the stale-age fallback.\nfunction startHeartbeat(lockDir: string): void {\n  stopHeartbeat(lockDir);\n  const heartbeat = setInterval(() => {\n    try {\n      const now = new Date();\n      fs.utimesSync(lockDir, now, now);\n    } catch {\n      stopHeartbeat(lockDir);\n    }\n  }, LOCK_HEARTBEAT_MS);\n  const unref = (heartbeat as { unref?: () => void }).unref;\n  unref?.call(heartbeat);\n  lockHeartbeats.set(lockDir, heartbeat);\n}\n\nfunction createInterprocessLock(specFolder: string, lockDir: string): InterprocessLockHandle {\n  fs.mkdirSync(lockDir);\n  fs.writeFileSync(path.join(lockDir, 'owner.json'), JSON.stringify({\n    pid: process.pid,\n    specFolder,\n    acquiredAt: new Date().toISOString(),\n  }));\n  startHeartbeat(lockDir);\n  return { lockDir };\n}\n\nfunction releaseInterprocessLock(handle: InterprocessLockHandle): void {\n  stopHeartbeat(handle.lockDir);\n  try {\n    fs.rmSync(handle.lockDir, { recursive: true, force: true });\n  } catch (error: unknown) {\n    console.warn('[memory-save] failed to release interprocess spec-folder lock:', error);\n  }\n}\n\nasync function acquireInterprocessLock(specFolder: string): Promise<InterprocessLockHandle> {\n  const lockDir = getLockDir(specFolder);\n  const deadline = Date.now() + LOCK_TIMEOUT_MS;\n\n  fs.mkdirSync(LOCK_ROOT, { recursive: true });\n\n  while (true) {\n    try {\n      return createInterprocessLock(specFolder, lockDir);\n    } catch (error: unknown) {\n      if (!isExistingDirectoryError(error)) {\n        throw error;\n      }\n\n      if (isReclaimableLock(lockDir)) {\n        fs.rmSync(lockDir, { recursive: true, force: true });\n        continue;\n      }\n\n      if (Date.now() >= deadline) {\n        throw new Error(`Timed out acquiring interprocess spec-folder lock for ${specFolder}`);\n      }\n\n      await sleep(LOCK_WAIT_MS);\n    }\n  }\n}\n\nasync function withSpecFolderLock<T>(specFolder: string, fn: () => Promise<T>): Promise<T> {\n  const normalizedFolder = specFolder || '__global__';\n  const chain = (SPEC_FOLDER_LOCKS.get(normalizedFolder) ?? Promise.resolve())\n    .catch((error: unknown) => {\n      console.error('[memory-save] prior queued save failed:', error);\n    })\n    .then(async () => {\n      const interprocessLock = await acquireInterprocessLock(normalizedFolder);\n      try {\n        return await fn();\n      } finally {\n        releaseInterprocessLock(interprocessLock);\n      }\n    });\n  SPEC_FOLDER_LOCKS.set(normalizedFolder, chain);\n  try {\n    return await chain;\n  } finally {\n    if (SPEC_FOLDER_LOCKS.get(normalizedFolder) === chain) {\n      SPEC_FOLDER_LOCKS.delete(normalizedFolder);\n    }\n  }\n}\n\nexport {\n  SPEC_FOLDER_LOCKS,\n  withSpecFolderLock,\n  // Exported for targeted lock-liveness tests; not part of the save flow API.\n  LOCK_STALE_MS,\n  LOCK_HEARTBEAT_MS,\n  getLockDir,\n  getLockOwnerState,\n  isReclaimableLock,\n  createInterprocessLock,\n  releaseInterprocessLock,\n};","lineStart":1,"lineEnd":210,"totalLines":210,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/spec-folder-mutex.ts","time":{"start":1781762174929,"end":1781762174935}},"metadata":{"openai":{"itemId":"fc_003bc1ea02355e63016a33887e8980819192092b22b42067c1"}},"id":"prt_ed94d2e69001W168ZOjm76HX15","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94d1462001W2ebwuvUQBVfQx"}}
