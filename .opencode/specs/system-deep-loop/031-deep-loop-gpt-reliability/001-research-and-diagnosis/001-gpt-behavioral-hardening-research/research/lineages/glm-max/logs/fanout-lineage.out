  \"allowedModes\": [\"new\", \"resume\", \"restart\"],\n    \"deferredModes\": [\"fork\", \"completed-continue\"],\n    \"generation\": 1,\n    \"continuedFromRun\": null,\n    \"fanout\": true,\n    \"siblingLabel\": \"gpt-fast-high\"\n  },\n  \"reducer\": {\n    \"enabled\": true,\n    \"version\": \"1.0\",\n    \"registryFile\": \"findings-registry.json\",\n    \"dashboardFile\": \"deep-research-dashboard.md\",\n    \"strategyFile\": \"deep-research-strategy.md\",\n    \"machineOwnedSections\": [\n      \"key-questions\",\n      \"answered-questions\",\n      \"what-worked\",\n      \"what-failed\",\n      \"exhausted-approaches\",\n      \"ruled-out-directions\",\n      \"next-focus\"\n    ],\n    \"lineageManaged\": true\n  },\n  \"capabilityMatrixPath\": \".opencode/skills/deep-loop-workflows/deep-research/assets/runtime_capabilities.json\",\n  \"capabilityMatrixDocPath\": \".opencode/skills/deep-loop-workflows/deep-research/references/guides/capability_matrix.md\",\n  \"runtimeCapabilityResolver\": \".opencode/skills/deep-loop-workflows/deep-research/scripts/runtime-capabilities.cjs\",\n  \"reducerScriptPath\": \".opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs\",\n  \"pauseSentinelPath\": \"research/.deep-research-pause\",\n  \"archiveRoot\": \"research_archive\",\n  \"migrationWindowDays\": 28,\n  \"resource_map_present\": false,\n  \"fileProtection\": {\n    \"deep-research-config.json\": \"immutable\",\n    \"deep-research-state.jsonl\": \"append-only\",\n    \"deep-research-strategy.md\": \"mutable\",\n    \"deep-research-dashboard.md\": \"auto-generated\",\n    \"findings-registry.json\": \"auto-generated\",\n    \"iteration-*.md\": \"write-once\",\n    \"research.md\": \"mutable\",\n    \"resource-map.md\": \"mutable\"\n  },\n  \"_optimizerManaged\": {\n    \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n    \"manifest