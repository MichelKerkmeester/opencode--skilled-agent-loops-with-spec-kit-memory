abled,\n43:   type ScoredResult,\n44:   type RequestQualityAssessment,\n45: } from '../lib/search/confidence-scoring.js';\n46: \n47: // Two-Tier Explainability\n48: import {\n49:   attachExplainabilityToResults,\n50:   isResultExplainEnabled,\n51:   type ExplainabilityOptions,\n52: } from '../lib/search/result-explainability.js';\n53: import {\n54:   buildWhyRankedTrace,\n55:   findInlineConflictWarnings,\n56:   type RetrievalConflictWarning,\n57:   type WhyRankedTrace,\n58: } from '../lib/observability/retrieval-observability.js';\n59: \n60: // Consolidated path validation from core/config.js (single source of truth)\n61: import { ALLOWED_BASE_PATHS } from '../core/config.js';\n62: \n63: // ────────────────────────────────────────────────────────────────\n64: // 1. TYPES \n65: \n66: // ────────────────────────────────────────────────────────────────\n67: \n68: /** Token metrics for anchor-filtered content */\n69: export interface AnchorTokenMetrics {\n70:   originalTokens: number;\n71:   returnedTokens: number;\n72:   savingsPercent: number;\n73:   anchorsRequested: number;\n74:   anchorsFound: number;\n75: }\n76: \n77: /** Raw search result from database/vector search */\n78: export interface RawSearchResult {\n79:   id: number | string;\n80:   spec_folder?: string;\n81:   file_path?: string;\n82:   specFolder?: string;\n83:   filePath?: string;\n84:   title?: string | null;\n85:   /** Raw vector cosine similarity (0-100 scale from sqlite-vec). */\n86:   similarity?: number;\n87:   /** Average similarity across multi-concept queries (0-100 scale). */\n88:   averageSimilarity?: number;\n89:   isConstitutional?: boolean;\n90:   importance_tier?: string;\n91:   triggerPhrases?: string | string[];\n92:   created_at?: string;\n93:   [key: string]: unknown;\n94: }\n95: \n96: /** Formatted search result */\n97: export interface FormattedSearchResult {\n98:   id: number;\n99:   specFolder: string;\n100:   filePath: string;\n101:   title: string | null;\n102:   /** Raw vector cosine similarity (0-100 scale from sqlite-vec), or averageSimilarity for multi-concept. */\n103:   similarity?: number;\n104:   isConstitutional: boolean;\n105:   importanceTier?: string;\n106:   triggerPhrases: string[];\n107:   createdAt?: string;\n108:   content?: string | null;\n109:   contentError?: string;\n110:   tokenMetrics?: AnchorTokenMetrics;\n111:   isChunk?: boolean;\n112:   parentId?: number | null;\n113:   chunkIndex?: number | null;\n114:   chunkLabel?: string | null;\n115:   chunkCount?: number | null;\n116:   contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n117: }\n118: \n119: export interface MemoryResultScores {\n120:   semantic: number | null;\n121:   lexical: number | null;\n122:   fusion: number | null;\n123:   intentAdjusted: number | null;\n124:   composite: number | null;\n125:   rerank: number | null;\n126:   attention: number | null;\n127: }\n128: \n129: export interface MemoryResultSource {\n130:   file: string | null;\n131:   anchorIds: string[];\n132:   anchorTypes: string[];\n133:   lastModified: string | null;\n134:   memoryState: string | null;\n135: }\n136: \n137: export interface MemoryResultTrace {\n138:   channelsUsed: string[];\n139:   pipelineStages: string[];\n140:   fallbackTier: number | null;\n\n(Showing lines 1-140 of 1169. Use offset=141 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Search Results Formatter\n// ────────────────────────────────────────────────────────────────\n\n// Node stdlib\nimport fs from 'fs';\n\n// Internal modules\nimport { estimateTokens } from './token-metrics.js';\n\n// Import path security utilities (migrated from shared/utils.js)\nimport { validateFilePath } from '../lib/utils/path-security.js';\nimport {\n  readSessionTransitionTrace,\n  type SessionTransitionTrace,\n} from '../lib/search/session-transition.js';\nimport { formatAgeString } from '../lib/utils/format-helpers.js';\n\n// Import memory parser for anchor extraction\nimport * as memoryParser from '../lib/parsing/memory-parser.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Search Results Formatter\n// ────────────────────────────────────────────────────────────────\n\n// Node stdlib\nimport fs from 'fs';\n\n// Internal modules\nimport { estimateTokens } from './token-metrics.js';\n\n// Import path security utilities (migrated from shared/utils.js)\nimport { validateFilePath } from '../lib/utils/path-security.js';\nimport {\n  readSessionTransitionTrace,\n  type SessionTransitionTrace,\n} from '../lib/search/session-transition.js';\nimport { formatAgeString } from '../lib/utils/format-helpers.js';\n\n// Import memory parser for anchor extraction\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport { requireDb } from '../utils/index.js';\n\n// Standardized Response Structure\nimport {\n  createMCPSuccessResponse,\n  createMCPEmptyResponse,\n  type MCPResponse,\n} from '../lib/response/envelope.js';\n\n// Empty/Weak Result Recovery UX\nimport {\n  buildRecoveryPayload,\n  shouldTriggerRecovery,\n  isEmptyResultRecoveryEnabled,\n  type RecoveryPayload,\n} from '../lib/search/recovery-payload.js';\n\n// Per-Result Calibrated Confidence\nimport {\n  computeResultConfidence,\n  assessRequestQuality,\n  isResultConfidenceEnabled,\n  type ScoredResult,\n  type RequestQualityAssessment,\n} from '../lib/search/confidence-scoring.js';\n\n// Two-Tier Explainability\nimport {\n  attachExplainabilityToResults,\n  isResultExplainEnabled,\n  type ExplainabilityOptions,\n} from '../lib/search/result-explainability.js';\nimport {\n  buildWhyRankedTrace,\n  findInlineConflictWarnings,\n  type RetrievalConflictWarning,\n  type WhyRankedTrace,\n} from '../lib/observability/retrieval-observability.js';\n\n// Consolidated path validation from core/config.js (single source of truth)\nimport { ALLOWED_BASE_PATHS } from '../core/config.js';\n\n// ────────────────────────────────────────────────────────────────\n// 1. TYPES \n\n// ────────────────────────────────────────────────────────────────\n\n/** Token metrics for anchor-filtered content */\nexport interface AnchorTokenMetrics {\n  originalTokens: number;\n  returnedTokens: number;\n  savingsPercent: number;\n  anchorsRequested: number;\n  anchorsFound: number;\n}\n\n/** Raw search result from database/vector search */\nexport interface RawSearchResult {\n  id: number | string;\n  spec_folder?: string;\n  file_path?: string;\n  specFolder?: string;\n  filePath?: string;\n  title?: string | null;\n  /** Raw vector cosine similarity (0-100 scale from sqlite-vec). */\n  similarity?: number;\n  /** Average similarity across multi-concept queries (0-100 scale). */\n  averageSimilarity?: number;\n  isConstitutional?: boolean;\n  importance_tier?: string;\n  triggerPhrases?: string | string[];\n  created_at?: string;\n  [key: string]: unknown;\n}\n\n/** Formatted search result */\nexport interface FormattedSearchResult {\n  id: number;\n  specFolder: string;\n  filePath: string;\n  title: string | null;\n  /** Raw vector cosine similarity (0-100 scale from sqlite-vec), or averageSimilarity for multi-concept. */\n  similarity?: number;\n  isConstitutional: boolean;\n  importanceTier?: string;\n  triggerPhrases: string[];\n  createdAt?: string;\n  content?: string | null;\n  contentError?: string;\n  tokenMetrics?: AnchorTokenMetrics;\n  isChunk?: boolean;\n  parentId?: number | null;\n  chunkIndex?: number | null;\n  chunkLabel?: string | null;\n  chunkCount?: number | null;\n  contentSource?: 'reassembled_chunks' | 'file_read_fallback';\n}\n\nexport interface MemoryResultScores {\n  semantic: number | null;\n  lexical: number | null;\n  fusion: number | null;\n  intentAdjusted: number | null;\n  composite: number | null;\n  rerank: number | null;\n  attention: number | null;\n}\n\nexport interface MemoryResultSource {\n  file: string | null;\n  anchorIds: string[];\n  anchorTypes: string[];\n  lastModified: string | null;\n  memoryState: string | null;\n}\n\nexport interface MemoryResultTrace {\n  channelsUsed: string[];\n  pipelineStages: string[];\n  fallbackTier: number | null;","lineStart":1,"lineEnd":140,"totalLines":1169,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts","time":{"start":1781764241192,"end":1781764241197}},"metadata":{"openai":{"itemId":"fc_0ef9904291217aa8016a339090f9ec819199a8ec3fd516f16e"}},"id":"prt_ed96cb71200160wIHN3dl5DpVF","sessionID":"ses_126974374fferlHj5CU2Guj68V","messageID":"msg_ed96c70bd001XdAPkqzC5UE2eG"}}
