/skills/system-skill-advisor/mcp_server/lib/scorer/aliases.ts:95-165\",\".opencode/skills/system-spec-kit/mcp_server/vitest.config.ts:15-22\",\".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json:7-18\",\".opencode/skills/deep-loop-runtime/references/integration_points.md:158-170\"],\"graphEvents\":[{\"type\":\"node\",\"id\":\"q-path-coupling\",\"kind\":\"QUESTION\",\"label\":\"Bidirectional path-coupling repair scope\"},{\"type\":\"node\",\"id\":\"f-002-executable-coupling\",\"kind\":\"FINDING\",\"label\":\"Executable path couplings span commands, doctor, agents, advisor, and tests\"},{\"type\":\"node\",\"id\":\"src-research-yaml-64\",\"kind\":\"SOURCE\",\"label\":\"deep_research_auto dual-root paths\"},{\"type\":\"node\",\"id\":\"src-advisor-2570\",\"kind\":\"SOURCE\",\"label\":\"advisor merged deep route projection\"},{\"type\":\"edge\",\"id\":\"e-002-answers-path\",\"source\":\"f-002-executable-coupling\",\"target\":\"q-path-coupling\",\"relation\":\"ANSWERS\"},{\"type\":\"edge\",\"id\":\"e-002-cites-yaml\",\"source\":\"f-002-executable-coupling\",\"target\":\"src-research-yaml-64\",\"relation\":\"CITES\"},{\"type\":\"edge\",\"id\":\"e-002-cites-advisor\",\"source\":\"f-002-executable-coupling\",\"target\":\"src-advisor-2570\",\"relation\":\"CITES\"}],\"timestamp\":\"2026-07-08T05:18:00Z\",\"durationMs\":620000,\"sessionId\":\"fanout-gpt55-fast-1-1783486518892-2qss01\",\"generation\":1,\"executor\":{\"kind\":\"cli-opencode\",\"model\":\"openai/gpt-5.5-fast\"}}\n","additions":1,"deletions":0},{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-1/deep-research-strategy.md","relativePath":".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-1/deep-research-strategy.md","type":"update","patch":"Index: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-1/deep-research-strategy.md\n===================================================================\n--- /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-1/deep-research-strategy.md\n+++ /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-1/deep-research-strategy.md\n@@ -7,9 +7,9 @@\n \n <!-- ANCHOR:key-questions -->\n ## 2. KEY QUESTIONS (remaining)\n - [x] Does the proposed `system-deep-loop` structural layout preserve the current workflow/runtime split without creating ambiguous ownership or broken relative paths?\n-- [ ] Which bidirectional path couplings between `deep-loop-workflows`, `deep-loop-runtime`, commands, agents, docs, tests, and scripts must be repaired mechanically during the merge?\n+- [x] Which bidirectional path couplings between `deep-loop-workflows`, `deep-loop-runtime`, commands, agents, docs, tests, and scripts must be repaired mechanically during the merge?\n - [ ] Which `system-spec-kit` tooling should be borrowed, wrapped, or left external instead of duplicated inside the merged deep-loop system?\n - [ ] What reference migration is required across commands, agents, READMEs, skill docs, feature catalogs, manual testing playbooks, specs, and advisor corpus entries?\n - [ ] Should `fallback-router.ts` be wired into real GLM-5.2 to MiMo-v2.5-Pro fallback now, or remain an offline/reference-only primitive for this phase?\n <!-- /ANCHOR:key-questions -->\n@@ -32,23 +32,26 @@\n \n <!-- ANCHOR:answered-questions -->\n ## 5. ANSWERED QUESTIONS\n - Structural layout: preserve `deep-loop-workflows` as public hub/mode packets and `deep-loop-runtime` as internal backend under a merged `system-deep-loop` root; do not flatten them (iteration 1, evidence: `.opencode/skills/deep-loop-workflows/SKILL.md:12`, `.opencode/skills/deep-loop-runtime/README.md:23-30`).\n+- Path coupling: rewrite command YAML and compiled contracts, doctor routes/assets, orchestrator/agent prompt contracts, advisor Python/TS/tests/metadata, system-spec-kit test/optimizer/docs, and runtime integration docs atomically with the move (iteration 2, evidence: `.opencode/commands/deep/assets/deep_research_auto.yaml:64-77`, `.opencode/commands/doctor/_routes.yaml:100-110`, `.opencode/skills/system-skill-advisor/mcp_server/scripts/skill_advisor.py:2570-2587`).\n <!-- /ANCHOR:answered-questions -->\n \n ---\n \n <!-- MACHINE-OWNED: START -->\n <!-- ANCHOR:what-worked -->\n ## 6. WHAT WORKED\n - Contract-first structural read: hub/runtime READMEs and SKILL contracts exposed the ownership seam before path inventory work (iteration 1).\n+- Exact old-root greps across scoped surfaces separated executable migration targets from lower-priority prose references (iteration 2).\n <!-- /ANCHOR:what-worked -->\n \n ---\n \n <!-- ANCHOR:what-failed -->\n ## 7. WHAT FAILED\n - Broad markdown globbing across `deep-loop-workflows` was noisy because catalogs/playbooks dominate the tree; targeted grep/read is needed next (iteration 1).\n+- Generated compiled contracts are not authoritative enough to repair references on their own; source YAML/advisor/test files must rewrite first, then contracts regenerate (iteration 2).\n <!-- /ANCHOR:what-failed -->\n \n ---\n \n@@ -61,22 +64,23 @@\n \n <!-- ANCHOR:ruled-out-directions -->\n ## 9. RULED OUT DIRECTIONS\n - Flattening runtime and workflow packets into one directory: contradicts the logic-free hub and backend-only runtime contracts (iteration 1, evidence: `.opencode/skills/deep-loop-workflows/SKILL.md:37-39`, `.opencode/skills/deep-loop-runtime/README.md:23-30`).\n+- Moving directories first and relying on generated contracts to catch up: generated contracts are outputs, while source YAML, advisor code, agents, and test configs carry old paths (iteration 2).\n <!-- /ANCHOR:ruled-out-directions -->\n \n ---\n \n <!-- ANCHOR:carried-forward-open-questions -->\n ## 10. CARRIED-FORWARD OPEN QUESTIONS\n-- Which exact path references must be rewritten atomically across commands, agents, docs, scripts, tests, and advisor surfaces?\n+- Which system-spec-kit tooling should remain borrowed/external instead of moving into `system-deep-loop`?\n <!-- /ANCHOR:carried-forward-open-questions -->\n \n ---\n \n <!-- ANCHOR:next-focus -->\n ## 11. NEXT FOCUS\n-Path-coupling inventory: enumerate concrete references to `.opencode/skills/deep-loop-runtime` and `.opencode/skills/deep-loop-workflows` across commands, agents, docs, scripts, tests, and advisor surfaces, then classify which must rewrite atomically for the merge.\n+System-spec-kit tooling borrow: identify which current shared pieces (`resolveArtifactRoot`, spec validation, memory/context save, resource-map extraction, optimizer/test discovery) should remain external contracts versus be moved, wrapped, or duplicated under the merged `system-deep-loop` root.\n <!-- /ANCHOR:next-focus -->\n <!-- MACHINE-OWNED: END -->\n \n ---\n","additions":7,"deletions":3},{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-1/deep-research-findings-registry.json","relativePath":".opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-1/deep-research-findings-registry.json","type":"update","patch":"Index: /Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-deep-loop/052-deep-loop-unification/001-reference-research/research/lineages/gpt55-fast-1/deep-research-findings-registry.json\n===================================================================\n--- /Users/mic