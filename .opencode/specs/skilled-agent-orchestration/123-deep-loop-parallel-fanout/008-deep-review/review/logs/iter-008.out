   447	export function getNode(ns: Namespace, id: string): CoverageNode | null {
   448	  if (!ns.sessionId) return null;
   449	  const d = getDb();
   450	  const row = prepareStatement(
   451	    'SELECT * FROM coverage_nodes WHERE spec_folder = ? AND loop_type = ? AND session_id = ? AND id = ?',
