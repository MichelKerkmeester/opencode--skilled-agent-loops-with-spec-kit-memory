Author: MichelKerkmeester <82775228+MichelKerkmeester@users.noreply.github.com>
Date:   Thu Jun 4 12:59:17 2026 +0200

    feat(mcp-server): bounded dryRun-default relation-inference backfill (026/021)
    
    Builds the real relation-inference backfill behind packet 019's honest stat: infers typed created_by='auto' causal edges from existing deterministic signals (spec-document chains + lineage predecessor links), default dryRun, bounded limit (<=2000), transactional, idempotent, and invalidates the entity-density cache after writes.
    
    Flips backfillJob.implemented to true with a callable command wired onto memory_causal_stats({ backfill }); no new MCP tool. Refreshes the causal README and tool-layer dispatch type.
    
    Co-Authored-By: Claude Opus 4.8 (1M context) <noreply@anthropic.com>

diff --git a/.opencode/skills/system-spec-kit/mcp_server/lib/causal/relation-coverage.ts b/.opencode/skills/system-spec-kit/mcp_server/lib/causal/relation-coverage.ts
index 440f507c77..990a9bdf19 100644
--- a/.opencode/skills/system-spec-kit/mcp_server/lib/causal/relation-coverage.ts
+++ b/.opencode/skills/system-spec-kit/mcp_server/lib/causal/relation-coverage.ts
@@ -24,9 +24,10 @@ interface RelationCoverageState {
   backfillJob: {
     name: string;
     scope: string;
-    // Honest signal: the autonomous relation-backfill is NOT wired. No command balances relations —
-    // 'supports' edges grow via post-insert enrichment on save (default-on); typed relations require
-    // explicit memory_causal_link. `implemented` stays false and `command` null until a real job exists.
+    // Honest signal: a bounded relation-inference backfill IS now wired. It infers typed edges from
+    // strong EXISTING signals only (spec-document chains + lineage predecessor links), all created_by
+    // 'auto' and subject to insertEdge's guards. `command` names the real callable entry point;
+    // `lastBackfillAt` is the latest auto-edge timestamp (null until the job has run at least once).
     implemented: boolean;
     command: string | null;
     lastBackfillAt: string | null;
@@ -46,7 +47,10 @@ const DEFAULT_RELATION_TARGETS: RelationCoverageTarget[] = [
   { relation: 'cited_by', minimumShare: 0, minimumCount: 0 },
 ];
 
