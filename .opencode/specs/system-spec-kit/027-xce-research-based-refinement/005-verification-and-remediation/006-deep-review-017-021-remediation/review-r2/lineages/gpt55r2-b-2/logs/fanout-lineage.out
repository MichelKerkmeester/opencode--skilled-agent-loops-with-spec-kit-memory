{"type":"tool_use","timestamp":1781761621734,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_KIKr1rkmoetmOQlo4nsZzRtG","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":330},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Delete\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* ───────────────────────────────────────────────────────────────\n34:    CORE LOGIC\n35: ──────────────────────────────────────────────────────────────── */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n181:     const deletedIds: number[] = [];\n182:     const hashById = new Map<number, MemoryHashSnapshot>();\n183: \n184:     if (database && 'prepare' in database) {\n185:       try {\n186:         const rows = database.prepare(`\n187:           SELECT id, content_hash, spec_folder, file_path\n188:           FROM memory_index\n189:           WHERE spec_folder = ?\n190:         `).all(specFolder as string) as MemoryHashSnapshot[];\n191: \n192:         for (const row of rows) {\n193:           hashById.set(row.id, row);\n194:         }\n195:       } catch (_err: unknown) {\n196:         // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n197:       }\n198:     }\n199: \n200:     if (memories.length > 0) {\n201:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n202:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n203:       try {\n204:         const checkpoint = checkpoints.createCheckpoint({\n205:           name: proposedCheckpointName,\n206:           specFolder,\n207:           metadata: {\n208:             reason: 'auto-checkpoint before bulk delete',\n209:             memoryCount: memories.length,\n210:           },\n211:         });\n212: \n213:         if (checkpoint) {\n214:           checkpointName = checkpoint.name;\n215:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n216:         } else {\n217:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n218:           checkpointName = null;\n219:         }\n220:       } catch (cpErr: unknown) {\n221:         const message = toErrorMessage(cpErr);\n222:         console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n223:         // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n224:         console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n225:         checkpointName = null;\n226:       }\n227:     }\n228: \n229:     // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n230:     causalEdges.init(database);\n231:     const bulkDeleteTx = database.transaction(() => {\n232:       for (const memory of memories) {\n233:         if (tombstoneMemory(database, memory.id)) {\n234:           // Record DELETE history after confirmed delete (no FK, history rows survive).\n235:           try {\n236:             const snapshot = hashById.get(memory.id);\n237:             recordHistory(\n238:               memory.id,\n239:               'DELETE',\n240:               snapshot?.file_path ?? null,\n241:               null,\n242:               'mcp:memory_delete',\n243:               snapshot?.spec_folder ?? null,\n244:             );\n245:           } catch (_histErr: unknown) {\n246:             // History recording is best-effort inside bulk delete\n247:           }\n248:           deletedCount++;\n249:           deletedIds.push(memory.id);\n250:           causalEdges.deleteEdgesForMemory(String(memory.id), {\n251:             reason: 'memory row mutation cleanup',\n252:             command: 'memory-crud-delete.handleMemoryDelete',\n253:             restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n254:           });\n255:         }\n256:       }\n257: \n258:       // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n259:       for (const deletedId of deletedIds) {\n260:         const snapshot = hashById.get(deletedId) ?? null;\n261:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n262:           mutationType: 'delete',\n263:           reason: 'memory_delete: bulk delete by spec folder',\n264:           priorHash: snapshot?.content_hash ?? null,\n265:           newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n266:           linkedMemoryIds: [deletedId],\n267:           decisionMeta: {\n268:             tool: 'memory_delete',\n269:             bulk: true,\n270:             specFolder,\n271:             checkpoint: checkpointName,\n272:             memoryId: deletedId,\n273:             filePath: snapshot?.file_path ?? null,\n274:           },\n275:           actor: 'mcp:memory_delete',\n276:         });\n277:         if (!ledgerRecorded) {\n278:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n279:         }\n280:       }\n281:     });\n282:     bulkDeleteTx();\n283:   }\n284: \n285:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n286:   if (deletedCount > 0) {\n287:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n288:     try {\n289:       postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n290:     } catch (hookError: unknown) {\n291:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n292:       postMutationHooks = {\n293:         latencyMs: 0, triggerCacheCleared: false,\n294:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n295:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n296:         errors: [msg],\n297:       };\n298:     }\n299:     postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n300:   }\n301: \n302:   const summary = deletedCount > 0\n303:     ? `Deleted ${deletedCount} memory(s)`\n304:     : 'No spec-doc records found to delete';\n305: \n306:   const hints: string[] = [];\n307:   if (checkpointName) {\n308:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n309:   }\n310:   if (deletedCount === 0) {\n311:     hints.push('Use memory_list() to find existing memories');\n312:   }\n313:   if (postMutationFeedback) {\n314:     hints.push(...postMutationFeedback.hints);\n315:   }\n316:   if (mutationLedgerWarning) {\n317:     hints.push(mutationLedgerWarning);\n318:   }\n319: \n320:   const data: Record<string, unknown> = { deleted: deletedCount };\n321:   if (checkpointName) {\n322:     data.checkpoint = checkpointName;\n323:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n324:   }\n325:   if (postMutationFeedback) {\n326:     data.postMutationHooks = postMutationFeedback.data;\n327:   }\n328:   if (mutationLedgerWarning) {\n329:     data.warning = mutationLedgerWarning;\n330:   }\n\n(Showing lines 1-330 of 344. Use offset=331 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper — wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {\n        const message = toErrorMessage(cpErr);\n        console.error(`[memory-delete] Failed to create checkpoint: ${message}`);\n        // Confirm is always true here (validated at function entry) — safe to proceed without checkpoint.\n        console.warn('[memory-delete] Proceeding without backup (user confirmed)');\n        checkpointName = null;\n      }\n    }\n\n    // Snapshot-then-delete is safe under single-process better-sqlite3; re-evaluate if multi-process support is added\n    causalEdges.init(database);\n    const bulkDeleteTx = database.transaction(() => {\n      for (const memory of memories) {\n        if (tombstoneMemory(database, memory.id)) {\n          // Record DELETE history after confirmed delete (no FK, history rows survive).\n          try {\n            const snapshot = hashById.get(memory.id);\n            recordHistory(\n              memory.id,\n              'DELETE',\n              snapshot?.file_path ?? null,\n              null,\n              'mcp:memory_delete',\n              snapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort inside bulk delete\n          }\n          deletedCount++;\n          deletedIds.push(memory.id);\n          causalEdges.deleteEdgesForMemory(String(memory.id), {\n            reason: 'memory row mutation cleanup',\n            command: 'memory-crud-delete.handleMemoryDelete',\n            restoreContext: { memoryId: memory.id, specFolder, checkpointName },\n          });\n        }\n      }\n\n      // Mutation ledger entries written inside bulk transaction for atomicity with deletes.\n      for (const deletedId of deletedIds) {\n        const snapshot = hashById.get(deletedId) ?? null;\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: bulk delete by spec folder',\n          priorHash: snapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`bulk-delete:${deletedId}:${Date.now()}`),\n          linkedMemoryIds: [deletedId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: true,\n            specFolder,\n            checkpoint: checkpointName,\n            memoryId: deletedId,\n            filePath: snapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    });\n    bulkDeleteTx();\n  }\n\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('delete', { specFolder, deletedCount });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('delete', postMutationHooks);\n  }\n\n  const summary = deletedCount > 0\n    ? `Deleted ${deletedCount} memory(s)`\n    : 'No spec-doc records found to delete';\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  }\n  if (deletedCount === 0) {\n    hints.push('Use memory_list() to find existing memories');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (mutationLedgerWarning) {\n    hints.push(mutationLedgerWarning);\n  }\n\n  const data: Record<string, unknown> = { deleted: deletedCount };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (mutationLedgerWarning) {\n    data.warning = mutationLedgerWarning;\n  }","lineStart":1,"lineEnd":330,"totalLines":344,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781761621718,"end":1781761621732}},"metadata":{"openai":{"itemId":"fc_094e195933770258016a3386554e7081919dc27f1f9602ea6c"}},"id":"prt_ed944bd4a001yL5SpZO4axmdKn","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed944881d001NxTUNY1NZ67WlU"}}
{"type":"step_finish","timestamp":1781761622004,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"id":"prt_ed944bff2001O6H4MnthuI1Gwf","reason":"tool-calls","snapshot":"b79c5a45504e83e9da14c533bac87dff3fe7b7b1","messageID":"msg_ed944881d001NxTUNY1NZ67WlU","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","type":"step-finish","tokens":{"total":184820,"input":2975,"output":63,"reasoning":22,"cache":{"write":0,"read":181760}},"cost":0}}
{"type":"step_start","timestamp":1781761624828,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"id":"prt_ed944cafa001p7vkvHg4WvFQ4x","messageID":"msg_ed944c0fd001P0gA41qJ4qY0MG","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","snapshot":"b79c5a45504e83e9da14c533bac87dff3fe7b7b1","type":"step-start"}}
{"type":"tool_use","timestamp":1781761630258,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_M0WAYycjBu9AqEmsJCcaq73J","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","offset":321,"limit":360},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts</path>\n<type>file</type>\n<content>\n321:       return null;\n322:     }\n323:   }\n324: \n325:   try {\n326:     const clampedStrength = clampStrength(effectiveStrength);\n327:     if (clampedStrength === null) {\n328:       console.warn('[causal-edges] insertEdge rejected non-finite strength');\n329:       setLastInsertEdgeOutcome({ status: 'skipped', reason: 'non-finite strength', edgeId: null });\n330:       return null;\n331:     }\n332: \n333:     // Wrap SELECT + UPSERT + logWeightChange in a transaction for atomicity\n334:     const rowId = database.transaction(() => {\n335:       if (isTemporalEdgesEnabled()) {\n336:         detectContradictions(\n337:           database,\n338:           Number.parseInt(sourceId, 10),\n339:           Number.parseInt(targetId, 10),\n340:           relation,\n341:         );\n342:       }\n343: \n344:       // Check if edge exists (for weight_history logging on conflict update).\n345:       // This SELECT is intentional: we need the old strength to decide whether\n346:       // To write a weight_history row after the upsert. The subsequent INSERT\n347:       // Uses last_insert_rowid() to avoid a second post-upsert SELECT.\n348:       const existing = (database.prepare(`\n349:         SELECT id, strength, evidence, created_by FROM causal_edges\n350:         WHERE source_id = ? AND target_id = ? AND relation = ?\n351:           AND COALESCE(source_anchor, '') = COALESCE(?, '')\n352:           AND COALESCE(target_anchor, '') = COALESCE(?, '')\n353:       `) as Database.Statement).get(\n354:         sourceId,\n355:         targetId,\n356:         relation,\n357:         anchors.sourceAnchor ?? null,\n358:         anchors.targetAnchor ?? null,\n359:       ) as { id: number; strength: number; evidence: string | null; created_by: string | null } | undefined;\n360: \n361:       // Manual/curated edges must never be overwritten by automatic writers:\n362:       // an auto upsert against a non-auto row is skipped so curated provenance\n363:       // and strength survive. Auto-to-auto updates remain allowed under caps.\n364:       if (existing && isAutoEdgeCreator(createdBy) && !isAutoEdgeCreator(existing.created_by ?? 'manual')) {\n365:         console.warn(\n366:           `[causal-edges] skipped manual edge ${existing.id} (created_by=${existing.created_by ?? 'manual'}); skipped overwrite by ${createdBy}`,\n367:         );\n368:         setLastInsertEdgeOutcome({ status: 'skipped', reason: 'skipped manual edge', edgeId: existing.id });\n369:         return 0;\n370:       }\n371: \n372:       const columns = new Set((database.prepare('PRAGMA table_info(causal_edges)').all() as Array<{ name: string }>)\n373:         .map((column) => column.name));\n374: \n375:       if (existing) {\n376:         const assignments = [\n377:           'strength = ?',\n378:           'evidence = COALESCE(?, evidence)',\n379:           'created_by = ?',\n380:         ];\n381:         const params: unknown[] = [clampedStrength, evidence, createdBy];\n382:         if (columns.has('confidence') && metadata.confidence !== undefined) {\n383:           assignments.push('confidence = ?');\n384:           params.push(metadata.confidence);\n385:         }\n386:         if (columns.has('extraction_method') && metadata.extractionMethod !== undefined) {\n387:           assignments.push('extraction_method = ?');\n388:           params.push(metadata.extractionMethod);\n389:         }\n390:         params.push(existing.id);\n391: \n392:         (database.prepare(`\n393:           UPDATE causal_edges\n394:           SET ${assignments.join(',\\n              ')}\n395:           WHERE id = ?\n396:         `) as Database.Statement).run(...params);\n397:         setLastInsertEdgeOutcome({ status: 'updated', reason: null, edgeId: existing.id });\n398:       } else {\n399:         if (!enforceRelationWindowCap(relation, database)) {\n400:           setLastInsertEdgeOutcome({ status: 'skipped', reason: 'relation cap exceeded', edgeId: null });\n401:           return 0;\n402:         }\n403: \n404:         const insertColumns = [\n405:           'source_id',\n406:           'target_id',\n407:           'source_anchor',\n408:           'target_anchor',\n409:           'relation',\n410:           'strength',\n411:           'evidence',\n412:           'created_by',\n413:         ];\n414:         const insertValues: unknown[] = [\n415:           sourceId,\n416:           targetId,\n417:           anchors.sourceAnchor ?? null,\n418:           anchors.targetAnchor ?? null,\n419:           relation,\n420:           clampedStrength,\n421:           evidence,\n422:           createdBy,\n423:         ];\n424:         if (columns.has('confidence') && metadata.confidence !== undefined) {\n425:           insertColumns.push('confidence');\n426:           insertValues.push(metadata.confidence);\n427:         }\n428:         if (columns.has('extraction_method') && metadata.extractionMethod !== undefined) {\n429:           insertColumns.push('extraction_method');\n430:           insertValues.push(metadata.extractionMethod);\n431:         }\n432: \n433:         (database.prepare(`\n434:           INSERT INTO causal_edges (\n435:             ${insertColumns.join(',\\n            ')}\n436:           )\n437:           VALUES (${insertColumns.map(() => '?').join(', ')})\n438:         `) as Database.Statement).run(...insertValues);\n439:       }\n440: \n441:       const row = (database.prepare(`\n442:         SELECT id FROM causal_edges\n443:         WHERE source_id = ? AND target_id = ? AND relation = ?\n444:           AND COALESCE(source_anchor, '') = COALESCE(?, '')\n445:           AND COALESCE(target_anchor, '') = COALESCE(?, '')\n446:       `) as Database.Statement).get(\n447:         sourceId,\n448:         targetId,\n449:         relation,\n450:         anchors.sourceAnchor ?? null,\n451:         anchors.targetAnchor ?? null,\n452:       ) as { id: number } | undefined;\n453:       const rowId = row ? row.id : 0;\n454:       if (!existing && rowId) {\n455:         setLastInsertEdgeOutcome({ status: 'inserted', reason: null, edgeId: rowId });\n456:       }\n457: \n458:       // Log weight change on conflict update\n459:       if (existing && rowId && isFiniteNumber(existing.strength) && existing.strength !== clampedStrength) {\n460:         logWeightChange(rowId, existing.strength, clampedStrength, createdBy, 'insert-upsert');\n461:       }\n462: \n463:       return rowId;\n464:     })();\n465: \n466:     if (shouldInvalidateCache) {\n467:       invalidateDegreeCache();\n468:     }\n469: \n470:     return rowId || null;\n471:   } catch (error: unknown) {\n472:     const msg = error instanceof Error ? error.message : String(error);\n473:     console.warn(`[causal-edges] insertEdge error: ${msg}`);\n474:     setLastInsertEdgeOutcome({ status: 'skipped', reason: msg, edgeId: null });\n475:     if (/SQLITE_BUSY|SQLITE_LOCKED|database is locked/i.test(msg)) {\n476:       throw error;\n477:     }\n478:     return null;\n479:   }\n480: }\n481: \n482: function insertEdgesBatch(\n483:   edges: Array<{\n484:     sourceId: string;\n485:     targetId: string;\n486:     relation: RelationType;\n487:     strength?: number;\n488:     evidence?: string | null;\n489:     createdBy?: string;\n490:     sourceAnchor?: string | null;\n491:     targetAnchor?: string | null;\n492:     confidence?: number;\n493:     extractionMethod?: string;\n494:   }>\n495: ): { inserted: number; failed: number; skippedManual: number } {\n496:   if (!db) return { inserted: 0, failed: edges.length, skippedManual: 0 };\n497: \n498:   let inserted = 0;\n499:   let failed = 0;\n500:   let skippedManual = 0;\n501: \n502:   const insertTx = db.transaction(() => {\n503:     for (const edge of edges) {\n504:       const id = insertEdge(\n505:         edge.sourceId,\n506:         edge.targetId,\n507:         edge.relation,\n508:         edge.strength ?? 1.0,\n509:         edge.evidence ?? null,\n510:         false,\n511:         edge.createdBy ?? 'manual',\n512:         {\n513:           sourceAnchor: edge.sourceAnchor ?? null,\n514:           targetAnchor: edge.targetAnchor ?? null,\n515:         },\n516:         {\n517:           confidence: edge.confidence,\n518:           extractionMethod: edge.extractionMethod,\n519:         },\n520:       );\n521:       if (id !== null) inserted++;\n522:       else {\n523:         failed++;\n524:         if (getLastInsertEdgeOutcome()?.reason === 'skipped manual edge') {\n525:           skippedManual++;\n526:         }\n527:       }\n528:     }\n529:   });\n530: \n531:   try {\n532:     insertTx();\n533:     if (inserted > 0) {\n534:       invalidateDegreeCache();\n535:     }\n536:   } catch (error: unknown) {\n537:     const msg = error instanceof Error ? error.message : String(error);\n538:     console.warn(`[causal-edges] insertEdgesBatch error: ${msg}`);\n539:   }\n540: \n541:   return { inserted, failed, skippedManual };\n542: }\n543: \n544: function bulkInsertEdges(edges: Array<Record<string, unknown>>): { inserted: number; failed: number } {\n545:   if (!db) return { inserted: 0, failed: edges.length };\n546: \n547:   const database = db;\n548:   let inserted = 0;\n549:   let failed = 0;\n550: \n551:   try {\n552:     const edgeColumns = (database.prepare('PRAGMA table_info(causal_edges)').all() as Array<{ name: string }>)\n553:       .map((column) => column.name)\n554:       .filter((name) => typeof name === 'string' && name.length > 0 && name !== 'id');\n555: \n556:     if (edgeColumns.length === 0) {\n557:       return { inserted: 0, failed: edges.length };\n558:     }\n559: \n560:     const insertEdgeStmt = database.prepare(`\n561:       INSERT OR IGNORE INTO causal_edges (${edgeColumns.join(', ')})\n562:       VALUES (${edgeColumns.map(() => '?').join(', ')})\n563:     `) as Database.Statement;\n564: \n565:     const insertTx = database.transaction(() => {\n566:       for (const edge of edges) {\n567:         if (!edge || typeof edge.source_id !== 'string' || typeof edge.target_id !== 'string') {\n568:           failed++;\n569:           continue;\n570:         }\n571:         if (typeof edge.relation !== 'string' || edge.relation.trim().length === 0) {\n572:           failed++;\n573:           continue;\n574:         }\n575:         if (edge.source_id === edge.target_id) {\n576:           failed++;\n577:           continue;\n578:         }\n579:         if (!enforceRelationWindowCap(edge.relation, database)) {\n580:           failed++;\n581:           continue;\n582:         }\n583: \n584:         const result = insertEdgeStmt.run(...edgeColumns.map((column) => edge[column] ?? null)) as { changes: number };\n585:         if (result.changes > 0) {\n586:           inserted++;\n587:         }\n588:       }\n589:     });\n590: \n591:     insertTx();\n592:     if (inserted > 0) {\n593:       invalidateDegreeCache();\n594:     }\n595:   } catch (error: unknown) {\n596:     const msg = error instanceof Error ? error.message : String(error);\n597:     console.warn(`[causal-edges] bulkInsertEdges error: ${msg}`);\n598:   }\n599: \n600:   return { inserted, failed };\n601: }\n602: \n603: function createEdgeQueryResult(\n604:   edges: CausalEdge[],\n605:   limit: number,\n606:   truncated: boolean,\n607: ): EdgeQueryResult {\n608:   const result = edges as EdgeQueryResult;\n609:   result.truncated = truncated;\n610:   result.limit = limit;\n611:   return result;\n612: }\n613: \n614: function getEdgesFrom(sourceId: string, limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n615:   if (!db) return createEdgeQueryResult([], limit, false);\n616: \n617:   try {\n618:     const rows = (db.prepare(`\n619:       SELECT * FROM causal_edges\n620:       WHERE source_id = ?\n621:       ORDER BY strength DESC\n622:       LIMIT ?\n623:     `) as Database.Statement).all(sourceId, limit + 1) as CausalEdgeRow[];\n624:     const truncated = rows.length > limit;\n625:     const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n626:     for (const edge of edges) {\n627:       try { touchEdgeAccess(edge.id); } catch (e: unknown) {\n628:         console.warn(`[causal-edges] touchEdgeAccess failed for edge ${edge.id}: ${e instanceof Error ? e.message : String(e)}`);\n629:       }\n630:     }\n631:     return createEdgeQueryResult(edges, limit, truncated);\n632:   } catch (error: unknown) {\n633:     const msg = error instanceof Error ? error.message : String(error);\n634:     console.warn(`[causal-edges] getEdgesFrom error: ${msg}`);\n635:     return createEdgeQueryResult([], limit, false);\n636:   }\n637: }\n638: \n639: function getEdgesTo(targetId: string, limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n640:   if (!db) return createEdgeQueryResult([], limit, false);\n641: \n642:   try {\n643:     const rows = (db.prepare(`\n644:       SELECT * FROM causal_edges\n645:       WHERE target_id = ?\n646:       ORDER BY strength DESC\n647:       LIMIT ?\n648:     `) as Database.Statement).all(targetId, limit + 1) as CausalEdgeRow[];\n649:     const truncated = rows.length > limit;\n650:     const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n651:     for (const edge of edges) {\n652:       try { touchEdgeAccess(edge.id); } catch (e: unknown) {\n653:         console.warn(`[causal-edges] touchEdgeAccess failed for edge ${edge.id}: ${e instanceof Error ? e.message : String(e)}`);\n654:       }\n655:     }\n656:     return createEdgeQueryResult(edges, limit, truncated);\n657:   } catch (error: unknown) {\n658:     const msg = error instanceof Error ? error.message : String(error);\n659:     console.warn(`[causal-edges] getEdgesTo error: ${msg}`);\n660:     return createEdgeQueryResult([], limit, false);\n661:   }\n662: }\n663: \n664: function getAllEdges(limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n665:   if (!db) return createEdgeQueryResult([], limit, false);\n666: \n667:   try {\n668:     const rows = (db.prepare(`\n669:       SELECT * FROM causal_edges\n670:       ORDER BY extracted_at DESC\n671:       LIMIT ?\n672:     `) as Database.Statement).all(limit + 1) as CausalEdgeRow[];\n673:     const truncated = rows.length > limit;\n674:     const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n675:     return createEdgeQueryResult(edges, limit, truncated);\n676:   } catch (error: unknown) {\n677:     const msg = error instanceof Error ? error.message : String(error);\n678:     console.warn(`[causal-edges] getAllEdges error: ${msg}`);\n679:     return createEdgeQueryResult([], limit, false);\n680:   }\n\n(Showing lines 321-680 of 1216. Use offset=681 to continue.)\n</content>","metadata":{"preview":"      return null;\n    }\n  }\n\n  try {\n    const clampedStrength = clampStrength(effectiveStrength);\n    if (clampedStrength === null) {\n      console.warn('[causal-edges] insertEdge rejected non-finite strength');\n      setLastInsertEdgeOutcome({ status: 'skipped', reason: 'non-finite strength', edgeId: null });\n      return null;\n    }\n\n    // Wrap SELECT + UPSERT + logWeightChange in a transaction for atomicity\n    const rowId = database.transaction(() => {\n      if (isTemporalEdgesEnabled()) {\n        detectContradictions(\n          database,\n          Number.parseInt(sourceId, 10),\n          Number.parseInt(targetId, 10),\n          relation,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","text":"      return null;\n    }\n  }\n\n  try {\n    const clampedStrength = clampStrength(effectiveStrength);\n    if (clampedStrength === null) {\n      console.warn('[causal-edges] insertEdge rejected non-finite strength');\n      setLastInsertEdgeOutcome({ status: 'skipped', reason: 'non-finite strength', edgeId: null });\n      return null;\n    }\n\n    // Wrap SELECT + UPSERT + logWeightChange in a transaction for atomicity\n    const rowId = database.transaction(() => {\n      if (isTemporalEdgesEnabled()) {\n        detectContradictions(\n          database,\n          Number.parseInt(sourceId, 10),\n          Number.parseInt(targetId, 10),\n          relation,\n        );\n      }\n\n      // Check if edge exists (for weight_history logging on conflict update).\n      // This SELECT is intentional: we need the old strength to decide whether\n      // To write a weight_history row after the upsert. The subsequent INSERT\n      // Uses last_insert_rowid() to avoid a second post-upsert SELECT.\n      const existing = (database.prepare(`\n        SELECT id, strength, evidence, created_by FROM causal_edges\n        WHERE source_id = ? AND target_id = ? AND relation = ?\n          AND COALESCE(source_anchor, '') = COALESCE(?, '')\n          AND COALESCE(target_anchor, '') = COALESCE(?, '')\n      `) as Database.Statement).get(\n        sourceId,\n        targetId,\n        relation,\n        anchors.sourceAnchor ?? null,\n        anchors.targetAnchor ?? null,\n      ) as { id: number; strength: number; evidence: string | null; created_by: string | null } | undefined;\n\n      // Manual/curated edges must never be overwritten by automatic writers:\n      // an auto upsert against a non-auto row is skipped so curated provenance\n      // and strength survive. Auto-to-auto updates remain allowed under caps.\n      if (existing && isAutoEdgeCreator(createdBy) && !isAutoEdgeCreator(existing.created_by ?? 'manual')) {\n        console.warn(\n          `[causal-edges] skipped manual edge ${existing.id} (created_by=${existing.created_by ?? 'manual'}); skipped overwrite by ${createdBy}`,\n        );\n        setLastInsertEdgeOutcome({ status: 'skipped', reason: 'skipped manual edge', edgeId: existing.id });\n        return 0;\n      }\n\n      const columns = new Set((database.prepare('PRAGMA table_info(causal_edges)').all() as Array<{ name: string }>)\n        .map((column) => column.name));\n\n      if (existing) {\n        const assignments = [\n          'strength = ?',\n          'evidence = COALESCE(?, evidence)',\n          'created_by = ?',\n        ];\n        const params: unknown[] = [clampedStrength, evidence, createdBy];\n        if (columns.has('confidence') && metadata.confidence !== undefined) {\n          assignments.push('confidence = ?');\n          params.push(metadata.confidence);\n        }\n        if (columns.has('extraction_method') && metadata.extractionMethod !== undefined) {\n          assignments.push('extraction_method = ?');\n          params.push(metadata.extractionMethod);\n        }\n        params.push(existing.id);\n\n        (database.prepare(`\n          UPDATE causal_edges\n          SET ${assignments.join(',\\n              ')}\n          WHERE id = ?\n        `) as Database.Statement).run(...params);\n        setLastInsertEdgeOutcome({ status: 'updated', reason: null, edgeId: existing.id });\n      } else {\n        if (!enforceRelationWindowCap(relation, database)) {\n          setLastInsertEdgeOutcome({ status: 'skipped', reason: 'relation cap exceeded', edgeId: null });\n          return 0;\n        }\n\n        const insertColumns = [\n          'source_id',\n          'target_id',\n          'source_anchor',\n          'target_anchor',\n          'relation',\n          'strength',\n          'evidence',\n          'created_by',\n        ];\n        const insertValues: unknown[] = [\n          sourceId,\n          targetId,\n          anchors.sourceAnchor ?? null,\n          anchors.targetAnchor ?? null,\n          relation,\n          clampedStrength,\n          evidence,\n          createdBy,\n        ];\n        if (columns.has('confidence') && metadata.confidence !== undefined) {\n          insertColumns.push('confidence');\n          insertValues.push(metadata.confidence);\n        }\n        if (columns.has('extraction_method') && metadata.extractionMethod !== undefined) {\n          insertColumns.push('extraction_method');\n          insertValues.push(metadata.extractionMethod);\n        }\n\n        (database.prepare(`\n          INSERT INTO causal_edges (\n            ${insertColumns.join(',\\n            ')}\n          )\n          VALUES (${insertColumns.map(() => '?').join(', ')})\n        `) as Database.Statement).run(...insertValues);\n      }\n\n      const row = (database.prepare(`\n        SELECT id FROM causal_edges\n        WHERE source_id = ? AND target_id = ? AND relation = ?\n          AND COALESCE(source_anchor, '') = COALESCE(?, '')\n          AND COALESCE(target_anchor, '') = COALESCE(?, '')\n      `) as Database.Statement).get(\n        sourceId,\n        targetId,\n        relation,\n        anchors.sourceAnchor ?? null,\n        anchors.targetAnchor ?? null,\n      ) as { id: number } | undefined;\n      const rowId = row ? row.id : 0;\n      if (!existing && rowId) {\n        setLastInsertEdgeOutcome({ status: 'inserted', reason: null, edgeId: rowId });\n      }\n\n      // Log weight change on conflict update\n      if (existing && rowId && isFiniteNumber(existing.strength) && existing.strength !== clampedStrength) {\n        logWeightChange(rowId, existing.strength, clampedStrength, createdBy, 'insert-upsert');\n      }\n\n      return rowId;\n    })();\n\n    if (shouldInvalidateCache) {\n      invalidateDegreeCache();\n    }\n\n    return rowId || null;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] insertEdge error: ${msg}`);\n    setLastInsertEdgeOutcome({ status: 'skipped', reason: msg, edgeId: null });\n    if (/SQLITE_BUSY|SQLITE_LOCKED|database is locked/i.test(msg)) {\n      throw error;\n    }\n    return null;\n  }\n}\n\nfunction insertEdgesBatch(\n  edges: Array<{\n    sourceId: string;\n    targetId: string;\n    relation: RelationType;\n    strength?: number;\n    evidence?: string | null;\n    createdBy?: string;\n    sourceAnchor?: string | null;\n    targetAnchor?: string | null;\n    confidence?: number;\n    extractionMethod?: string;\n  }>\n): { inserted: number; failed: number; skippedManual: number } {\n  if (!db) return { inserted: 0, failed: edges.length, skippedManual: 0 };\n\n  let inserted = 0;\n  let failed = 0;\n  let skippedManual = 0;\n\n  const insertTx = db.transaction(() => {\n    for (const edge of edges) {\n      const id = insertEdge(\n        edge.sourceId,\n        edge.targetId,\n        edge.relation,\n        edge.strength ?? 1.0,\n        edge.evidence ?? null,\n        false,\n        edge.createdBy ?? 'manual',\n        {\n          sourceAnchor: edge.sourceAnchor ?? null,\n          targetAnchor: edge.targetAnchor ?? null,\n        },\n        {\n          confidence: edge.confidence,\n          extractionMethod: edge.extractionMethod,\n        },\n      );\n      if (id !== null) inserted++;\n      else {\n        failed++;\n        if (getLastInsertEdgeOutcome()?.reason === 'skipped manual edge') {\n          skippedManual++;\n        }\n      }\n    }\n  });\n\n  try {\n    insertTx();\n    if (inserted > 0) {\n      invalidateDegreeCache();\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] insertEdgesBatch error: ${msg}`);\n  }\n\n  return { inserted, failed, skippedManual };\n}\n\nfunction bulkInsertEdges(edges: Array<Record<string, unknown>>): { inserted: number; failed: number } {\n  if (!db) return { inserted: 0, failed: edges.length };\n\n  const database = db;\n  let inserted = 0;\n  let failed = 0;\n\n  try {\n    const edgeColumns = (database.prepare('PRAGMA table_info(causal_edges)').all() as Array<{ name: string }>)\n      .map((column) => column.name)\n      .filter((name) => typeof name === 'string' && name.length > 0 && name !== 'id');\n\n    if (edgeColumns.length === 0) {\n      return { inserted: 0, failed: edges.length };\n    }\n\n    const insertEdgeStmt = database.prepare(`\n      INSERT OR IGNORE INTO causal_edges (${edgeColumns.join(', ')})\n      VALUES (${edgeColumns.map(() => '?').join(', ')})\n    `) as Database.Statement;\n\n    const insertTx = database.transaction(() => {\n      for (const edge of edges) {\n        if (!edge || typeof edge.source_id !== 'string' || typeof edge.target_id !== 'string') {\n          failed++;\n          continue;\n        }\n        if (typeof edge.relation !== 'string' || edge.relation.trim().length === 0) {\n          failed++;\n          continue;\n        }\n        if (edge.source_id === edge.target_id) {\n          failed++;\n          continue;\n        }\n        if (!enforceRelationWindowCap(edge.relation, database)) {\n          failed++;\n          continue;\n        }\n\n        const result = insertEdgeStmt.run(...edgeColumns.map((column) => edge[column] ?? null)) as { changes: number };\n        if (result.changes > 0) {\n          inserted++;\n        }\n      }\n    });\n\n    insertTx();\n    if (inserted > 0) {\n      invalidateDegreeCache();\n    }\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] bulkInsertEdges error: ${msg}`);\n  }\n\n  return { inserted, failed };\n}\n\nfunction createEdgeQueryResult(\n  edges: CausalEdge[],\n  limit: number,\n  truncated: boolean,\n): EdgeQueryResult {\n  const result = edges as EdgeQueryResult;\n  result.truncated = truncated;\n  result.limit = limit;\n  return result;\n}\n\nfunction getEdgesFrom(sourceId: string, limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n  if (!db) return createEdgeQueryResult([], limit, false);\n\n  try {\n    const rows = (db.prepare(`\n      SELECT * FROM causal_edges\n      WHERE source_id = ?\n      ORDER BY strength DESC\n      LIMIT ?\n    `) as Database.Statement).all(sourceId, limit + 1) as CausalEdgeRow[];\n    const truncated = rows.length > limit;\n    const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n    for (const edge of edges) {\n      try { touchEdgeAccess(edge.id); } catch (e: unknown) {\n        console.warn(`[causal-edges] touchEdgeAccess failed for edge ${edge.id}: ${e instanceof Error ? e.message : String(e)}`);\n      }\n    }\n    return createEdgeQueryResult(edges, limit, truncated);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getEdgesFrom error: ${msg}`);\n    return createEdgeQueryResult([], limit, false);\n  }\n}\n\nfunction getEdgesTo(targetId: string, limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n  if (!db) return createEdgeQueryResult([], limit, false);\n\n  try {\n    const rows = (db.prepare(`\n      SELECT * FROM causal_edges\n      WHERE target_id = ?\n      ORDER BY strength DESC\n      LIMIT ?\n    `) as Database.Statement).all(targetId, limit + 1) as CausalEdgeRow[];\n    const truncated = rows.length > limit;\n    const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n    for (const edge of edges) {\n      try { touchEdgeAccess(edge.id); } catch (e: unknown) {\n        console.warn(`[causal-edges] touchEdgeAccess failed for edge ${edge.id}: ${e instanceof Error ? e.message : String(e)}`);\n      }\n    }\n    return createEdgeQueryResult(edges, limit, truncated);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getEdgesTo error: ${msg}`);\n    return createEdgeQueryResult([], limit, false);\n  }\n}\n\nfunction getAllEdges(limit: number = MAX_EDGES_LIMIT): EdgeQueryResult {\n  if (!db) return createEdgeQueryResult([], limit, false);\n\n  try {\n    const rows = (db.prepare(`\n      SELECT * FROM causal_edges\n      ORDER BY extracted_at DESC\n      LIMIT ?\n    `) as Database.Statement).all(limit + 1) as CausalEdgeRow[];\n    const truncated = rows.length > limit;\n    const edges = (truncated ? rows.slice(0, limit) : rows).map(normalizeCausalEdgeRow);\n    return createEdgeQueryResult(edges, limit, truncated);\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[causal-edges] getAllEdges error: ${msg}`);\n    return createEdgeQueryResult([], limit, false);\n  }","lineStart":321,"lineEnd":680,"totalLines":1216,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","time":{"start":1781761630252,"end":1781761630256}},"metadata":{"openai":{"itemId":"fc_06a2dab5886ea655016a33865ddb50819195384db6c1f42dce"}},"id":"prt_ed944dea7001AS7qDJXNoZLB0S","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed944c0fd001P0gA41qJ4qY0MG"}}
