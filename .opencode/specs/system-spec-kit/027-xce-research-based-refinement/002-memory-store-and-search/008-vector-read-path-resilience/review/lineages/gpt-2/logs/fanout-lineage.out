2), makeEmbeddingBuffer(0.5));\n284: \n285:     const activeRows = db.prepare(`\n286:       SELECT rowid\n287:       FROM ${activeVectorSource('vec_memories')}\n288:       ORDER BY vec_distance_cosine(embedding, ?) ASC\n289:     `).all(makeEmbeddingBuffer(1)) as Array<{ rowid: number }>;\n290:     const legacyRows = db.prepare(`\n291:       SELECT rowid\n292:       FROM vec_memories\n293:       ORDER BY vec_distance_cosine(embedding, ?) ASC\n294:     `).all(makeEmbeddingBuffer(1)) as Array<{ rowid: number }>;\n295: \n296:     expect(activeRows.map((row) => row.rowid)).toEqual(legacyRows.map((row) => row.rowid));\n297: \n298:     detachActiveVectorShard(db);\n299:     db.close();\n300:   });\n301: \n302:   it('runs vector_search against active_vec.vec_memories', () => {\n303:     const profile = makeProfile();\n304:     const db = createSchemaBackedDb(tempDir, profile);\n305:     const id = index_memory({\n306:       specFolder: 'specs/demo',\n307:       filePath: 'search.md',\n308:       title: 'Searchable shard row',\n309:       triggerPhrases: ['active_vec'],\n310:       importanceWeight: 0.5,\n311:       embedding: makeEmbedding(),\n312:       contentText: 'query should join through active_vec vec_memories',\n313:     }, db);\n314: \n315:     const results = vector_search(makeEmbedding(), { limit: 5, includeConstitutional: false }, db);\n316: \n317:     expect(results.map((row) => row.id)).toContain(id);\n318:     detachActiveVectorShard(db);\n319:     db.close();\n320:   });\n321: \n322:   it('migrates a legacy single DB into canonical metadata and vector shard files', () => {\n323:     const profile = makeProfile();\n324:     const legacyPath = path.join(tempDir, `context-index__${profile.slug}.sqlite`);\n325:     const canonicalPath = profile.getCanonicalDatabasePath(tempDir);\n326:     const shardPath = profile.getVectorShardPath(tempDir);\n327:     createLegacySingleDb(legacyPath, profile);\n328: \n329:     migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n330: \n331:     expect(fs.existsSync(canonicalPath)).toBe(true);\n332:     expect(fs.existsSync(shardPath)).toBe(true);\n333:     expect(fs.existsSync(legacyPath)).toBe(false);\n334:     expect(fs.readdirSync(path.join(tempDir, 'migrations')).some((name) => name.endsWith('.sqlite.bak'))).toBe(true);\n335: \n336:     const canonical = new Database(canonicalPath);\n337:     canonical.exec(`ATTACH DATABASE '${shardPath.replace(/'/g, \"''\")}' AS ${ACTIVE_VECTOR_SCHEMA}`);\n338:     expect(tableExists(canonical, 'main', 'memory_index')).toBe(true);\n339:     expect(tableExists(canonical, 'main', 'embedding_cache')).toBe(false);\n340:     expect(tableExists(canonical, ACTIVE_VECTOR_SCHEMA, 'embedding_cache')).toBe(true);\n341:     expect(tableExists(canonical, ACTIVE_VECTOR_SCHEMA, 'vec_memories')).toBe(true);\n342:     canonical.close();\n343:   });\n344: \n345:   it('skips migration idempotently once canonical and shard exist', () => {\n346:     const profile = makeProfile();\n347:     const legacyPath = path.join(tempDir, `context-index__${profile.slug}.sqlite`);\n348:     const canonicalPath = profile.getCanonicalDatabasePath(tempDir);\n349:     const shardPath = profile.getVectorShardPath(tempDir);\n350:     createLegacySingleDb(legacyPath, profile);\n351: \n352:     migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n353:     expect(() => migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile)).not.toThrow();\n354:   });\n355: \n356:   it('refuses to attach a shard whose metadata does not match the active profile', () => {\n357:     const profile = makeProfile();\n358:     const db = openCanonical(tempDir, profile);\n359:     detachActiveVectorShard(db);\n360:     const shard = new Database(profile.getVectorShardPath(tempDir));\n361:     shard.prepare(\"UPDATE vec_metadata SET value = 'wrong-model' WHERE key = 'model'\").run();\n362:     shard.close();\n363: \n364:     expect(() => attachActiveVectorShard(db, profile)).toThrow(/metadata mismatch/i);\n365:     db.close();\n366:   });\n367: \n368:   it('keeps checkpoint state in canonical DB while snapshotting shard vectors through the alias', () => {\n369:     const profile = makeProfile();\n370:     const db = createSchemaBackedDb(tempDir, profile);\n371:     const id = index_memory({\n372:       specFolder: 'specs/demo',\n373:       filePath: 'checkpoint.md',\n374:       title: 'Checkpoint shard row',\n375:       triggerPhrases: ['checkpoint'],\n376:       importanceWeight: 0.5,\n377:       embedding: makeEmbedding(),\n378:       contentText: 'checkpoint tables remain canonical',\n379:     }, db);\n380: \n381:     checkpoints.init(db);\n382:     const checkpoint = checkpoints.createCheckpoint({ name: 'split-checkpoint', includeEmbeddings: true });\n383: \n384:     expect(tableExists(db, 'main', 'checkpoints')).toBe(true);\n385:     expect(checkpoint?.name).toBe('split-checkpoint');\n386:     expect(db.prepare('SELECT COUNT(*) AS count FROM checkpoints').get()).toMatchObject({ count: 1 });\n387:     expect(db.prepare(`SELECT COUNT(*) AS count FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).get(id))\n388:       .toMatchObject({ count: 1 });\n389: \n390:     detachActiveVectorShard(db);\n391:     db.close();\n392:   });\n393: });\n\n(End of file - total 393 lines)\n</content>","metadata":{"preview":"\n    clearCache(db);\n    detachActiveVectorShard(db);\n    db.close();\n  });\n\n  it('indexes vector mutations into active_vec.vec_memories only', () => {\n    const profile = makeProfile();\n    const db = createSchemaBackedDb(tempDir, profile);\n\n    const id = index_memory({\n      specFolder: 'specs/demo',\n      filePath: 'spec.md',\n      title: 'Shard write',\n      triggerPhrases: ['shard'],\n      importanceWeight: 0.5,\n      embedding: makeEmbedding(),\n      contentText: 'shard mutation writes land in the attached vector DB',\n    }, db);\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/canonical-vector-shard.vitest.ts","text":"\n    clearCache(db);\n    detachActiveVectorShard(db);\n    db.close();\n  });\n\n  it('indexes vector mutations into active_vec.vec_memories only', () => {\n    const profile = makeProfile();\n    const db = createSchemaBackedDb(tempDir, profile);\n\n    const id = index_memory({\n      specFolder: 'specs/demo',\n      filePath: 'spec.md',\n      title: 'Shard write',\n      triggerPhrases: ['shard'],\n      importanceWeight: 0.5,\n      embedding: makeEmbedding(),\n      contentText: 'shard mutation writes land in the attached vector DB',\n    }, db);\n\n    const shardCount = db.prepare(`SELECT COUNT(*) AS count FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`)\n      .get(id) as { count: number };\n    expect(shardCount.count).toBe(1);\n    expect(tableExists(db, 'main', 'vec_memories')).toBe(false);\n\n    detachActiveVectorShard(db);\n    db.close();\n  });\n\n  it('queries vectors through active_vec with the same row ordering as an unqualified legacy table', () => {\n    const db = openCanonical(tempDir);\n    const insert = db.prepare(`INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)`);\n    insert.run(BigInt(1), makeEmbeddingBuffer(1));\n    insert.run(BigInt(2), makeEmbeddingBuffer(0.5));\n\n    const activeRows = db.prepare(`\n      SELECT rowid\n      FROM ${activeVectorSource('vec_memories')}\n      ORDER BY vec_distance_cosine(embedding, ?) ASC\n    `).all(makeEmbeddingBuffer(1)) as Array<{ rowid: number }>;\n    const legacyRows = db.prepare(`\n      SELECT rowid\n      FROM vec_memories\n      ORDER BY vec_distance_cosine(embedding, ?) ASC\n    `).all(makeEmbeddingBuffer(1)) as Array<{ rowid: number }>;\n\n    expect(activeRows.map((row) => row.rowid)).toEqual(legacyRows.map((row) => row.rowid));\n\n    detachActiveVectorShard(db);\n    db.close();\n  });\n\n  it('runs vector_search against active_vec.vec_memories', () => {\n    const profile = makeProfile();\n    const db = createSchemaBackedDb(tempDir, profile);\n    const id = index_memory({\n      specFolder: 'specs/demo',\n      filePath: 'search.md',\n      title: 'Searchable shard row',\n      triggerPhrases: ['active_vec'],\n      importanceWeight: 0.5,\n      embedding: makeEmbedding(),\n      contentText: 'query should join through active_vec vec_memories',\n    }, db);\n\n    const results = vector_search(makeEmbedding(), { limit: 5, includeConstitutional: false }, db);\n\n    expect(results.map((row) => row.id)).toContain(id);\n    detachActiveVectorShard(db);\n    db.close();\n  });\n\n  it('migrates a legacy single DB into canonical metadata and vector shard files', () => {\n    const profile = makeProfile();\n    const legacyPath = path.join(tempDir, `context-index__${profile.slug}.sqlite`);\n    const canonicalPath = profile.getCanonicalDatabasePath(tempDir);\n    const shardPath = profile.getVectorShardPath(tempDir);\n    createLegacySingleDb(legacyPath, profile);\n\n    migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n\n    expect(fs.existsSync(canonicalPath)).toBe(true);\n    expect(fs.existsSync(shardPath)).toBe(true);\n    expect(fs.existsSync(legacyPath)).toBe(false);\n    expect(fs.readdirSync(path.join(tempDir, 'migrations')).some((name) => name.endsWith('.sqlite.bak'))).toBe(true);\n\n    const canonical = new Database(canonicalPath);\n    canonical.exec(`ATTACH DATABASE '${shardPath.replace(/'/g, \"''\")}' AS ${ACTIVE_VECTOR_SCHEMA}`);\n    expect(tableExists(canonical, 'main', 'memory_index')).toBe(true);\n    expect(tableExists(canonical, 'main', 'embedding_cache')).toBe(false);\n    expect(tableExists(canonical, ACTIVE_VECTOR_SCHEMA, 'embedding_cache')).toBe(true);\n    expect(tableExists(canonical, ACTIVE_VECTOR_SCHEMA, 'vec_memories')).toBe(true);\n    canonical.close();\n  });\n\n  it('skips migration idempotently once canonical and shard exist', () => {\n    const profile = makeProfile();\n    const legacyPath = path.join(tempDir, `context-index__${profile.slug}.sqlite`);\n    const canonicalPath = profile.getCanonicalDatabasePath(tempDir);\n    const shardPath = profile.getVectorShardPath(tempDir);\n    createLegacySingleDb(legacyPath, profile);\n\n    migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile);\n    expect(() => migrateLegacySingleDbToShardSync(legacyPath, canonicalPath, shardPath, profile)).not.toThrow();\n  });\n\n  it('refuses to attach a shard whose metadata does not match the active profile', () => {\n    const profile = makeProfile();\n    const db = openCanonical(tempDir, profile);\n    detachActiveVectorShard(db);\n    const shard = new Database(profile.getVectorShardPath(tempDir));\n    shard.prepare(\"UPDATE vec_metadata SET value = 'wrong-model' WHERE key = 'model'\").run();\n    shard.close();\n\n    expect(() => attachActiveVectorShard(db, profile)).toThrow(/metadata mismatch/i);\n    db.close();\n  });\n\n  it('keeps checkpoint state in canonical DB while snapshotting shard vectors through the alias', () => {\n    const profile = makeProfile();\n    const db = createSchemaBackedDb(tempDir, profile);\n    const id = index_memory({\n      specFolder: 'specs/demo',\n      filePath: 'checkpoint.md',\n      title: 'Checkpoint shard row',\n      triggerPhrases: ['checkpoint'],\n      importanceWeight: 0.5,\n      embedding: makeEmbedding(),\n      contentText: 'checkpoint tables remain canonical',\n    }, db);\n\n    checkpoints.init(db);\n    const checkpoint = checkpoints.createCheckpoint({ name: 'split-checkpoint', includeEmbeddings: true });\n\n    expect(tableExists(db, 'main', 'checkpoints')).toBe(true);\n    expect(checkpoint?.name).toBe('split-checkpoint');\n    expect(db.prepare('SELECT COUNT(*) AS count FROM checkpoints').get()).toMatchObject({ count: 1 });\n    expect(db.prepare(`SELECT COUNT(*) AS count FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).get(id))\n      .toMatchObject({ count: 1 });\n\n    detachActiveVectorShard(db);\n    db.close();\n  });\n});","lineStart":250,"lineEnd":393,"totalLines":393,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/canonical-vector-shard.vitest.ts","time":{"start":1781151319734,"end":1781151319742}},"metadata":{"openai":{"itemId":"fc_0d9d167ebf797419016a2a365798488191a58cd3ea920650fb"}},"id":"prt_eb4e44660001zf2SH46jDDZ0sL","sessionID":"ses_14b1d6f21ffeiA9vRmpnyEZ4DQ","messageID":"msg_eb4e41933001paZ6jKsv4GY7oN"}}
