{"type":"tool_use","timestamp":1780728417718,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_4wkF9RZGQ70Cl22sfUHjhlHW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","offset":1,"limit":140},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py</path>\n<type>file</type>\n<content>\n1: import asyncio\n2: import hashlib\n3: import json\n4: import logging\n5: import re\n6: import time\n7: import uuid\n8: from datetime import UTC, datetime, timedelta\n9: from typing import cast\n10: from uuid import UUID, uuid4\n11: \n12: from fastapi import HTTPException\n13: from sqlalchemy.exc import SQLAlchemyError\n14: from sqlalchemy.ext.asyncio import AsyncSession\n15: \n16: from core_api.clients.storage_client import get_storage_client\n17: from core_api.config import settings\n18: from core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\n19: from core_api.tasks import track_task\n20: \n21: try:\n22:     from openai import OpenAIError\n23: except ImportError:\n24: \n25:     class OpenAIError(Exception):\n26:         pass  # type: ignore[misc]\n27: \n28: \n29: try:\n30:     from google.api_core.exceptions import GoogleAPIError\n31: except ImportError:\n32: \n33:     class GoogleAPIError(Exception):\n34:         pass  # type: ignore[misc]\n35: \n36: \n37: from common.constants import VECTOR_DIM\n38: from common.embedding import get_embedding, get_embeddings_batch, get_query_embedding\n39: from common.events import publish_memory_embed_request, publish_memory_enrich_request\n40: from core_api.constants import (\n41:     BULK_EMBEDDING_TIMEOUT_SECONDS,\n42:     BULK_ENRICHMENT_CONCURRENCY,\n43:     BULK_ENRICHMENT_TOTAL_TIMEOUT_SECONDS,\n44:     CHUNKING_THRESHOLD_CHARS,\n45:     CRYSTALLIZER_SHORT_CONTENT_CHARS,\n46:     DEFAULT_MEMORY_WEIGHT,\n47:     DEFAULT_SEARCH_TOP_K,\n48:     EMBEDDING_CACHE_TTL,\n49:     FRESHNESS_DECAY_DAYS,\n50:     FRESHNESS_FLOOR,\n51:     FTS_BOOST_MAX_TOKENS,\n52:     FTS_BOOST_SPECIFICITY_RATIO,\n53:     FTS_WEIGHT,\n54:     FTS_WEIGHT_BOOSTED,\n55:     GRAPH_HOP_BOOST,\n56:     GRAPH_MAX_BOOSTED_MEMORIES,\n57:     GRAPH_MAX_HOPS,\n58:     MIN_SEARCH_SIMILARITY,\n59:     OPENAI_EMBEDDING_MODEL,\n60:     RECALL_BOOST_CAP,\n61:     RECALL_DECAY_WINDOW_DAYS,\n62:     SEARCH_OVERFETCH_FACTOR,\n63:     SIMILARITY_BLEND,\n64: )\n65: from core_api.schemas import (\n66:     BulkItemResult,\n67:     BulkMemoryCreate,\n68:     BulkMemoryResponse,\n69:     ContradictionInfo,\n70:     EntityLinkOut,\n71:     MemoryCreate,\n72:     MemoryOut,\n73:     MemoryUpdate,\n74: )\n75: from core_api.services.entity_extraction_worker import process_entity_extraction\n76: from core_api.services.entity_tokens import extract_entity_tokens\n77: from core_api.services.hooks import get_hooks\n78: from core_api.services.task_tracker import tracked_task\n79: \n80: logger = logging.getLogger(__name__)\n81: \n82: # Hardcoded pipeline flags. Intentionally not read from env/Settings: the legacy\n83: # write/search paths are deprecated and scheduled for removal. If an emergency\n84: # rollback is needed, flip these to False and ship a hotfix — do NOT re-introduce\n85: # env-level configuration, since that caused prior silent divergence between\n86: # deployments and the default code path.\n87: _USE_PIPELINE_WRITE = True\n88: _USE_PIPELINE_SEARCH = True\n89: \n90: \n91: def _content_hash(tenant_id: str, fleet_id: str | None, content: str) -> str:\n92:     return hashlib.sha256(f\"{tenant_id}:{fleet_id or ''}:{content}\".encode()).hexdigest()\n93: \n94: \n95: def _auto_chunk_request_id() -> str:\n96:     \"\"\"Mint a per-row attempt id for in-process bulk-insert callers\n97:     (auto-chunk, atomic-facts) that have no ``X-Bulk-Attempt-Id`` from\n98:     a client (CAURA-602). The ``auto-chunk:`` prefix keeps these rows\n99:     visually distinguishable in the partial unique index from\n100:     real client-side bulk attempts (``f\"{X-Bulk-Attempt-Id}:{idx}\"``).\n101:     \"\"\"\n102:     return f\"auto-chunk:{uuid4()}\"\n103: \n104: \n105: async def _find_semantic_duplicate(\n106:     db: AsyncSession,\n107:     tenant_id: str,\n108:     fleet_id: str | None,\n109:     embedding: list[float],\n110:     exclude_id: UUID | None = None,\n111:     visibility: str | None = None,\n112:     min_similarity: float | None = None,\n113: ) -> dict | None:\n114:     \"\"\"Find a near-duplicate memory via cosine similarity.\n115: \n116:     Returns the closest match above the threshold (or ``None``). The\n117:     returned dict carries a ``similarity`` field — added in A1 #16 so\n118:     two-tier callers can dispatch by score.\n119: \n120:     ``min_similarity`` defaults to ``SEMANTIC_DEDUP_THRESHOLD`` (0.95)\n121:     via the storage layer for back-compat. A1 #16's\n122:     ``CheckSemanticDuplicate`` pipeline step passes\n123:     ``SEMANTIC_DEDUP_JUDGE_THRESHOLD`` to surface the judge band.\n124:     \"\"\"\n125:     sc = get_storage_client()\n126:     payload: dict = {\n127:         \"tenant_id\": tenant_id,\n128:         \"fleet_id\": fleet_id,\n129:         \"embedding\": embedding,\n130:         \"exclude_id\": str(exclude_id) if exclude_id else None,\n131:         \"visibility\": visibility,\n132:     }\n133:     if min_similarity is not None:\n134:         payload[\"min_similarity\"] = min_similarity\n135:     return await sc.find_semantic_duplicate(payload)\n136: \n137: \n138: def _dict_to_memory_out(\n139:     mem: dict,\n140:     entity_links: list[EntityLinkOut] | None = None,\n\n(Showing lines 1-140 of 3230. Use offset=141 to continue.)\n</content>","metadata":{"preview":"import asyncio\nimport hashlib\nimport json\nimport logging\nimport re\nimport time\nimport uuid\nfrom datetime import UTC, datetime, timedelta\nfrom typing import cast\nfrom uuid import UUID, uuid4\n\nfrom fastapi import HTTPException\nfrom sqlalchemy.exc import SQLAlchemyError\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings\nfrom core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\nfrom core_api.tasks import track_task\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"import asyncio\nimport hashlib\nimport json\nimport logging\nimport re\nimport time\nimport uuid\nfrom datetime import UTC, datetime, timedelta\nfrom typing import cast\nfrom uuid import UUID, uuid4\n\nfrom fastapi import HTTPException\nfrom sqlalchemy.exc import SQLAlchemyError\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.config import settings\nfrom core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\nfrom core_api.tasks import track_task\n\ntry:\n    from openai import OpenAIError\nexcept ImportError:\n\n    class OpenAIError(Exception):\n        pass  # type: ignore[misc]\n\n\ntry:\n    from google.api_core.exceptions import GoogleAPIError\nexcept ImportError:\n\n    class GoogleAPIError(Exception):\n        pass  # type: ignore[misc]\n\n\nfrom common.constants import VECTOR_DIM\nfrom common.embedding import get_embedding, get_embeddings_batch, get_query_embedding\nfrom common.events import publish_memory_embed_request, publish_memory_enrich_request\nfrom core_api.constants import (\n    BULK_EMBEDDING_TIMEOUT_SECONDS,\n    BULK_ENRICHMENT_CONCURRENCY,\n    BULK_ENRICHMENT_TOTAL_TIMEOUT_SECONDS,\n    CHUNKING_THRESHOLD_CHARS,\n    CRYSTALLIZER_SHORT_CONTENT_CHARS,\n    DEFAULT_MEMORY_WEIGHT,\n    DEFAULT_SEARCH_TOP_K,\n    EMBEDDING_CACHE_TTL,\n    FRESHNESS_DECAY_DAYS,\n    FRESHNESS_FLOOR,\n    FTS_BOOST_MAX_TOKENS,\n    FTS_BOOST_SPECIFICITY_RATIO,\n    FTS_WEIGHT,\n    FTS_WEIGHT_BOOSTED,\n    GRAPH_HOP_BOOST,\n    GRAPH_MAX_BOOSTED_MEMORIES,\n    GRAPH_MAX_HOPS,\n    MIN_SEARCH_SIMILARITY,\n    OPENAI_EMBEDDING_MODEL,\n    RECALL_BOOST_CAP,\n    RECALL_DECAY_WINDOW_DAYS,\n    SEARCH_OVERFETCH_FACTOR,\n    SIMILARITY_BLEND,\n)\nfrom core_api.schemas import (\n    BulkItemResult,\n    BulkMemoryCreate,\n    BulkMemoryResponse,\n    ContradictionInfo,\n    EntityLinkOut,\n    MemoryCreate,\n    MemoryOut,\n    MemoryUpdate,\n)\nfrom core_api.services.entity_extraction_worker import process_entity_extraction\nfrom core_api.services.entity_tokens import extract_entity_tokens\nfrom core_api.services.hooks import get_hooks\nfrom core_api.services.task_tracker import tracked_task\n\nlogger = logging.getLogger(__name__)\n\n# Hardcoded pipeline flags. Intentionally not read from env/Settings: the legacy\n# write/search paths are deprecated and scheduled for removal. If an emergency\n# rollback is needed, flip these to False and ship a hotfix — do NOT re-introduce\n# env-level configuration, since that caused prior silent divergence between\n# deployments and the default code path.\n_USE_PIPELINE_WRITE = True\n_USE_PIPELINE_SEARCH = True\n\n\ndef _content_hash(tenant_id: str, fleet_id: str | None, content: str) -> str:\n    return hashlib.sha256(f\"{tenant_id}:{fleet_id or ''}:{content}\".encode()).hexdigest()\n\n\ndef _auto_chunk_request_id() -> str:\n    \"\"\"Mint a per-row attempt id for in-process bulk-insert callers\n    (auto-chunk, atomic-facts) that have no ``X-Bulk-Attempt-Id`` from\n    a client (CAURA-602). The ``auto-chunk:`` prefix keeps these rows\n    visually distinguishable in the partial unique index from\n    real client-side bulk attempts (``f\"{X-Bulk-Attempt-Id}:{idx}\"``).\n    \"\"\"\n    return f\"auto-chunk:{uuid4()}\"\n\n\nasync def _find_semantic_duplicate(\n    db: AsyncSession,\n    tenant_id: str,\n    fleet_id: str | None,\n    embedding: list[float],\n    exclude_id: UUID | None = None,\n    visibility: str | None = None,\n    min_similarity: float | None = None,\n) -> dict | None:\n    \"\"\"Find a near-duplicate memory via cosine similarity.\n\n    Returns the closest match above the threshold (or ``None``). The\n    returned dict carries a ``similarity`` field — added in A1 #16 so\n    two-tier callers can dispatch by score.\n\n    ``min_similarity`` defaults to ``SEMANTIC_DEDUP_THRESHOLD`` (0.95)\n    via the storage layer for back-compat. A1 #16's\n    ``CheckSemanticDuplicate`` pipeline step passes\n    ``SEMANTIC_DEDUP_JUDGE_THRESHOLD`` to surface the judge band.\n    \"\"\"\n    sc = get_storage_client()\n    payload: dict = {\n        \"tenant_id\": tenant_id,\n        \"fleet_id\": fleet_id,\n        \"embedding\": embedding,\n        \"exclude_id\": str(exclude_id) if exclude_id else None,\n        \"visibility\": visibility,\n    }\n    if min_similarity is not None:\n        payload[\"min_similarity\"] = min_similarity\n    return await sc.find_semantic_duplicate(payload)\n\n\ndef _dict_to_memory_out(\n    mem: dict,\n    entity_links: list[EntityLinkOut] | None = None,","lineStart":1,"lineEnd":140,"totalLines":3230,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780728417711,"end":1780728417718}},"metadata":{"openai":{"itemId":"fc_0a235a28143a62e8016a23c2619a588191b48b7c31291a0417"}},"id":"prt_e9baf4d89001PM33swDyWM8npf","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baf27a3001gboGwYUe0Ast5m"}}
{"type":"tool_use","timestamp":1780728417734,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_E6LQwkuo72uwuIQBXXzGxJy5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","offset":3220,"limit":25},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py</path>\n<type>file</type>\n<content>\n3220:         )\n3221: \n3222:     # Increment recall_count and update last_recalled_at for returned memories\n3223:     _hooks = get_hooks()\n3224:     if memory_ids and _hooks.on_recall:\n3225:         try:\n3226:             await _hooks.on_recall(db, memory_ids)\n3227:         except Exception:\n3228:             logger.debug(\"Recall tracking hook failed (non-critical)\", exc_info=True)\n3229: \n3230:     return results\n\n(End of file - total 3230 lines)\n</content>","metadata":{"preview":"        )\n\n    # Increment recall_count and update last_recalled_at for returned memories\n    _hooks = get_hooks()\n    if memory_ids and _hooks.on_recall:\n        try:\n            await _hooks.on_recall(db, memory_ids)\n        except Exception:\n            logger.debug(\"Recall tracking hook failed (non-critical)\", exc_info=True)\n\n    return results","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"        )\n\n    # Increment recall_count and update last_recalled_at for returned memories\n    _hooks = get_hooks()\n    if memory_ids and _hooks.on_recall:\n        try:\n            await _hooks.on_recall(db, memory_ids)\n        except Exception:\n            logger.debug(\"Recall tracking hook failed (non-critical)\", exc_info=True)\n\n    return results","lineStart":3220,"lineEnd":3230,"totalLines":3230,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780728417726,"end":1780728417733}},"metadata":{"openai":{"itemId":"fc_0a235a28143a62e8016a23c2619a6c8191a7c4b81b8f8c39c3"}},"id":"prt_e9baf4db0001B9X6WFUjj1RV8k","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baf27a3001gboGwYUe0Ast5m"}}
{"type":"tool_use","timestamp":1780728417755,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_AqROHFTLbvRV2WeitXxuuDaI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py</path>\n<type>file</type>\n<content>\n1: \"\"\"ParallelEmbedAndEntityBoost — concurrent embedding + entity/graph boost via asyncio.gather.\n2: \n3: Uses the storage client for entity FTS and graph expansion instead of direct\n4: repository calls.\n5: \"\"\"\n6: \n7: from __future__ import annotations\n8: \n9: import asyncio\n10: import logging\n11: import time\n12: from uuid import UUID\n13: \n14: from fastapi import HTTPException\n15: \n16: from core_api.clients.storage_client import get_storage_client\n17: from core_api.constants import (\n18:     GRAPH_HOP_BOOST,\n19:     GRAPH_MAX_BOOSTED_MEMORIES,\n20:     RECALL_BOOST_CAP,\n21: )\n22: from core_api.pipeline.context import PipelineContext\n23: from core_api.pipeline.step import StepOutcome, StepResult\n24: from core_api.services.entity_tokens import extract_entity_tokens\n25: from core_api.services.memory_service import _get_or_cache_embedding\n26: \n27: logger = logging.getLogger(__name__)\n28: \n29: # Overall wall-clock budget for the embedding + entity-boost step. Embedding\n30: # uses the full budget; entity boost runs in parallel and gets whatever\n31: # remains after the embedding resolves (clamped below by\n32: # ``_MIN_ENTITY_BUDGET_S`` so a near-instant embedding still gives the\n33: # in-flight entity task a moment to finish).\n34: _OVERALL_TIMEOUT_S = 15.0\n35: _MIN_ENTITY_BUDGET_S = 0.1\n36: \n37: \n38: async def _entity_boost_via_storage(\n39:     query: str,\n40:     tenant_id: str,\n41:     fleet_ids: list[str] | None,\n42:     graph_expand: bool,\n43:     graph_max_hops: int,\n44:     use_union: bool = False,\n45:     precomputed_hops: dict[UUID, tuple[int, float]] | None = None,\n46: ) -> tuple[set[UUID], dict[UUID, float]]:\n47:     \"\"\"Entity FTS → graph expansion → link collection via storage client.\n48: \n49:     Returns (boosted_memory_ids, memory_boost_factor).\n50:     \"\"\"\n51:     sc = get_storage_client()\n52:     boosted_memory_ids: set[UUID] = set()\n53:     memory_boost_factor: dict[UUID, float] = {}\n54: \n55:     try:\n56:         if precomputed_hops is not None:\n57:             entity_hops = precomputed_hops\n58:             matched_entity_ids = [eid for eid, (hop, _w) in entity_hops.items() if hop == 0]\n59:         else:\n60:             tokens = extract_entity_tokens(query)\n61:             if not tokens:\n62:                 return boosted_memory_ids, memory_boost_factor\n63: \n64:             fts_data: dict = {\"tokens\": tokens, \"tenant_id\": tenant_id}\n65:             if fleet_ids:\n66:                 fts_data[\"fleet_ids\"] = fleet_ids\n67:             matched_id_strs = await sc.fts_search_entities(fts_data)\n68:             matched_entity_ids = [UUID(eid) for eid in matched_id_strs]\n69: \n70:             if not matched_entity_ids:\n71:                 return boosted_memory_ids, memory_boost_factor\n72: \n73:             # Graph expansion\n74:             if graph_expand and graph_max_hops > 0:\n75:                 expand_data = {\n76:                     \"seed_entity_ids\": [str(eid) for eid in matched_entity_ids],\n77:                     \"tenant_id\": tenant_id,\n78:                     \"fleet_id\": fleet_ids[0] if fleet_ids and len(fleet_ids) == 1 else None,\n79:                     \"max_hops\": graph_max_hops,\n80:                     \"use_union\": use_union,\n81:                 }\n82:                 raw_hops = await sc.expand_graph(expand_data)\n83:                 entity_hops = {\n84:                     UUID(eid_str): (hop_weight[\"hop\"], hop_weight[\"weight\"])\n85:                     for eid_str, hop_weight in raw_hops.items()\n86:                 }\n87:             else:\n88:                 entity_hops = dict.fromkeys(matched_entity_ids, (0, 1.0))\n89: \n90:         if matched_entity_ids:\n91:             all_entity_ids = list(entity_hops.keys())\n92:             raw_links = await sc.get_memory_ids_by_entity_ids(\n93:                 [str(eid) for eid in all_entity_ids],\n94:             )\n95: \n96:             # Sort by hop order (closest entities first).\n97:             all_links = sorted(\n98:                 raw_links,\n99:                 key=lambda row: entity_hops.get(UUID(row[\"entity_id\"]), (999, 0.0))[0],\n100:             )\n101: \n102:             for link in all_links:\n103:                 mem_id_str, ent_id_str = link[\"memory_id\"], link[\"entity_id\"]\n104:                 mem_id = UUID(mem_id_str)\n105:                 ent_id = UUID(ent_id_str)\n106:                 if ent_id not in entity_hops:\n107:                     continue\n108:                 hop, rel_weight = entity_hops[ent_id]\n109:                 hop_boost = GRAPH_HOP_BOOST.get(hop, GRAPH_HOP_BOOST[max(GRAPH_HOP_BOOST)])\n110:                 boost = hop_boost * rel_weight\n111:                 if mem_id not in memory_boost_factor or boost > memory_boost_factor[mem_id]:\n112:                     memory_boost_factor[mem_id] = boost\n113:                 if len(memory_boost_factor) >= GRAPH_MAX_BOOSTED_MEMORIES:\n114:                     break\n115: \n116:             # Multi-entity boost\n117:             if len(matched_entity_ids) > 1:\n118:                 memory_entity_count: dict[UUID, int] = {}\n119:                 matched_set = set(matched_entity_ids)\n120:                 for link in all_links:\n121:                     mem_id = UUID(link[\"memory_id\"])\n122:                     ent_id = UUID(link[\"entity_id\"])\n123:                     if ent_id in matched_set:\n124:                         memory_entity_count[mem_id] = memory_entity_count.get(mem_id, 0) + 1\n125:                 for mem_id in memory_boost_factor:\n126:                     count = memory_entity_count.get(mem_id, 0)\n127:                     if count > 1 and memory_boost_factor[mem_id] > 1.0:\n128:                         extra = min(count - 1, 4) * 0.10\n129:                         memory_boost_factor[mem_id] = min(\n130:                             memory_boost_factor[mem_id] * (1.0 + extra),\n131:                             RECALL_BOOST_CAP,\n132:                         )\n133: \n134:             boosted_memory_ids = set(memory_boost_factor.keys())\n135:     except Exception:\n136:         logger.exception(\"Entity/graph boost lookup failed (falling back to pure vector search)\")\n137: \n138:     return boosted_memory_ids, memory_boost_factor\n139: \n140: \n141: class ParallelEmbedAndEntityBoost:\n142:     @property\n143:     def name(self) -> str:\n144:         return \"parallel_embed_entity_boost\"\n145: \n146:     async def execute(self, ctx: PipelineContext) -> StepResult | None:\n147:         plan = ctx.data.get(\"retrieval_plan\")\n148:         if plan and plan.skip_embedding:\n149:             return StepResult(outcome=StepOutcome.SKIPPED)\n150: \n151:         data = ctx.data\n152:         sp = data[\"search_params\"]\n153: \n154:         emb_task = asyncio.ensure_future(\n155:             _get_or_cache_embedding(data[\"query\"], data[\"tenant_id\"], data[\"tenant_config\"])\n156:         )\n157:         ent_task = asyncio.ensure_future(\n158:             _entity_boost_via_storage(\n159:                 data[\"query\"],\n160:                 data[\"tenant_id\"],\n161:                 data.get(\"fleet_ids\"),\n162:                 data.get(\"graph_expand\", True),\n163:                 sp[\"graph_max_hops\"],\n164:                 use_union=True,\n165:                 precomputed_hops=data.pop(\"_classified_entity_hops\", None),\n166:             )\n167:         )\n168:         # D7 — split the prior shared ``gather`` timeout into per-task budgets.\n169:         # Embedding is the critical path: a missing vector means the search\n170:         # can't run, so a timeout there still raises 504. Entity boost is a\n171:         # supplementary signal — a slow lookup should NOT cancel a completed\n172:         # embedding; degrade to vector-only search and log instead. Total\n173:         # budget stays at ``_OVERALL_TIMEOUT_S`` so a slow entity task can't\n174:         # double the step's wall-clock budget.\n175:         t0 = time.perf_counter()\n176:         try:\n177:             embedding = await asyncio.wait_for(emb_task, timeout=_OVERALL_TIMEOUT_S)\n178:         except TimeoutError:\n179:             ent_task.cancel()\n180:             raise HTTPException(status_code=504, detail=\"Search embedding timed out\")\n181:         except ValueError as exc:\n182:             ent_task.cancel()\n183:             raise HTTPException(status_code=503, detail=str(exc))\n184:         except BaseException:\n185:             ent_task.cancel()\n186:             raise\n187: \n188:         # ent_task has been running in parallel with emb_task since the\n189:         # ``ensure_future`` calls above, so the remaining-budget wait_for\n190:         # below is usually trivial — the task is already done. The guard\n191:         # only fires when entity_boost outlasts the embedding.\n192:         remaining = max(_MIN_ENTITY_BUDGET_S, _OVERALL_TIMEOUT_S - (time.perf_counter() - t0))\n193:         try:\n194:             boosted_memory_ids, memory_boost_factor = await asyncio.wait_for(ent_task, timeout=remaining)\n195:         except TimeoutError:\n196:             logger.warning(\n197:                 \"entity_boost timed out after %.2fs remaining budget; continuing with vector-only search\",\n198:                 remaining,\n199:             )\n200:             boosted_memory_ids, memory_boost_factor = set(), {}\n201:         except BaseException as exc:\n202:             # ``_entity_boost_via_storage`` swallows most exceptions internally\n203:             # and returns ``(set(), {})``; anything that escapes is unexpected\n204:             # but still non-fatal for the search — fall back to vector-only.\n205:             logger.warning(\n206:                 \"entity_boost raised after embedding ready; continuing with vector-only search: %r\",\n207:                 exc,\n208:             )\n209:             boosted_memory_ids, memory_boost_factor = set(), {}\n210: \n211:         data[\"embedding\"] = embedding\n212:         data[\"boosted_memory_ids\"] = boosted_memory_ids\n213:         data[\"memory_boost_factor\"] = memory_boost_factor\n214:         return None\n\n(End of file - total 214 lines)\n</content>","metadata":{"preview":"\"\"\"ParallelEmbedAndEntityBoost — concurrent embedding + entity/graph boost via asyncio.gather.\n\nUses the storage client for entity FTS and graph expansion instead of direct\nrepository calls.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nimport time\nfrom uuid import UUID\n\nfrom fastapi import HTTPException\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.constants import (\n    GRAPH_HOP_BOOST,\n    GRAPH_MAX_BOOSTED_MEMORIES,\n    RECALL_BOOST_CAP,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py","text":"\"\"\"ParallelEmbedAndEntityBoost — concurrent embedding + entity/graph boost via asyncio.gather.\n\nUses the storage client for entity FTS and graph expansion instead of direct\nrepository calls.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport asyncio\nimport logging\nimport time\nfrom uuid import UUID\n\nfrom fastapi import HTTPException\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.constants import (\n    GRAPH_HOP_BOOST,\n    GRAPH_MAX_BOOSTED_MEMORIES,\n    RECALL_BOOST_CAP,\n)\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepOutcome, StepResult\nfrom core_api.services.entity_tokens import extract_entity_tokens\nfrom core_api.services.memory_service import _get_or_cache_embedding\n\nlogger = logging.getLogger(__name__)\n\n# Overall wall-clock budget for the embedding + entity-boost step. Embedding\n# uses the full budget; entity boost runs in parallel and gets whatever\n# remains after the embedding resolves (clamped below by\n# ``_MIN_ENTITY_BUDGET_S`` so a near-instant embedding still gives the\n# in-flight entity task a moment to finish).\n_OVERALL_TIMEOUT_S = 15.0\n_MIN_ENTITY_BUDGET_S = 0.1\n\n\nasync def _entity_boost_via_storage(\n    query: str,\n    tenant_id: str,\n    fleet_ids: list[str] | None,\n    graph_expand: bool,\n    graph_max_hops: int,\n    use_union: bool = False,\n    precomputed_hops: dict[UUID, tuple[int, float]] | None = None,\n) -> tuple[set[UUID], dict[UUID, float]]:\n    \"\"\"Entity FTS → graph expansion → link collection via storage client.\n\n    Returns (boosted_memory_ids, memory_boost_factor).\n    \"\"\"\n    sc = get_storage_client()\n    boosted_memory_ids: set[UUID] = set()\n    memory_boost_factor: dict[UUID, float] = {}\n\n    try:\n        if precomputed_hops is not None:\n            entity_hops = precomputed_hops\n            matched_entity_ids = [eid for eid, (hop, _w) in entity_hops.items() if hop == 0]\n        else:\n            tokens = extract_entity_tokens(query)\n            if not tokens:\n                return boosted_memory_ids, memory_boost_factor\n\n            fts_data: dict = {\"tokens\": tokens, \"tenant_id\": tenant_id}\n            if fleet_ids:\n                fts_data[\"fleet_ids\"] = fleet_ids\n            matched_id_strs = await sc.fts_search_entities(fts_data)\n            matched_entity_ids = [UUID(eid) for eid in matched_id_strs]\n\n            if not matched_entity_ids:\n                return boosted_memory_ids, memory_boost_factor\n\n            # Graph expansion\n            if graph_expand and graph_max_hops > 0:\n                expand_data = {\n                    \"seed_entity_ids\": [str(eid) for eid in matched_entity_ids],\n                    \"tenant_id\": tenant_id,\n                    \"fleet_id\": fleet_ids[0] if fleet_ids and len(fleet_ids) == 1 else None,\n                    \"max_hops\": graph_max_hops,\n                    \"use_union\": use_union,\n                }\n                raw_hops = await sc.expand_graph(expand_data)\n                entity_hops = {\n                    UUID(eid_str): (hop_weight[\"hop\"], hop_weight[\"weight\"])\n                    for eid_str, hop_weight in raw_hops.items()\n                }\n            else:\n                entity_hops = dict.fromkeys(matched_entity_ids, (0, 1.0))\n\n        if matched_entity_ids:\n            all_entity_ids = list(entity_hops.keys())\n            raw_links = await sc.get_memory_ids_by_entity_ids(\n                [str(eid) for eid in all_entity_ids],\n            )\n\n            # Sort by hop order (closest entities first).\n            all_links = sorted(\n                raw_links,\n                key=lambda row: entity_hops.get(UUID(row[\"entity_id\"]), (999, 0.0))[0],\n            )\n\n            for link in all_links:\n                mem_id_str, ent_id_str = link[\"memory_id\"], link[\"entity_id\"]\n                mem_id = UUID(mem_id_str)\n                ent_id = UUID(ent_id_str)\n                if ent_id not in entity_hops:\n                    continue\n                hop, rel_weight = entity_hops[ent_id]\n                hop_boost = GRAPH_HOP_BOOST.get(hop, GRAPH_HOP_BOOST[max(GRAPH_HOP_BOOST)])\n                boost = hop_boost * rel_weight\n                if mem_id not in memory_boost_factor or boost > memory_boost_factor[mem_id]:\n                    memory_boost_factor[mem_id] = boost\n                if len(memory_boost_factor) >= GRAPH_MAX_BOOSTED_MEMORIES:\n                    break\n\n            # Multi-entity boost\n            if len(matched_entity_ids) > 1:\n                memory_entity_count: dict[UUID, int] = {}\n                matched_set = set(matched_entity_ids)\n                for link in all_links:\n                    mem_id = UUID(link[\"memory_id\"])\n                    ent_id = UUID(link[\"entity_id\"])\n                    if ent_id in matched_set:\n                        memory_entity_count[mem_id] = memory_entity_count.get(mem_id, 0) + 1\n                for mem_id in memory_boost_factor:\n                    count = memory_entity_count.get(mem_id, 0)\n                    if count > 1 and memory_boost_factor[mem_id] > 1.0:\n                        extra = min(count - 1, 4) * 0.10\n                        memory_boost_factor[mem_id] = min(\n                            memory_boost_factor[mem_id] * (1.0 + extra),\n                            RECALL_BOOST_CAP,\n                        )\n\n            boosted_memory_ids = set(memory_boost_factor.keys())\n    except Exception:\n        logger.exception(\"Entity/graph boost lookup failed (falling back to pure vector search)\")\n\n    return boosted_memory_ids, memory_boost_factor\n\n\nclass ParallelEmbedAndEntityBoost:\n    @property\n    def name(self) -> str:\n        return \"parallel_embed_entity_boost\"\n\n    async def execute(self, ctx: PipelineContext) -> StepResult | None:\n        plan = ctx.data.get(\"retrieval_plan\")\n        if plan and plan.skip_embedding:\n            return StepResult(outcome=StepOutcome.SKIPPED)\n\n        data = ctx.data\n        sp = data[\"search_params\"]\n\n        emb_task = asyncio.ensure_future(\n            _get_or_cache_embedding(data[\"query\"], data[\"tenant_id\"], data[\"tenant_config\"])\n        )\n        ent_task = asyncio.ensure_future(\n            _entity_boost_via_storage(\n                data[\"query\"],\n                data[\"tenant_id\"],\n                data.get(\"fleet_ids\"),\n                data.get(\"graph_expand\", True),\n                sp[\"graph_max_hops\"],\n                use_union=True,\n                precomputed_hops=data.pop(\"_classified_entity_hops\", None),\n            )\n        )\n        # D7 — split the prior shared ``gather`` timeout into per-task budgets.\n        # Embedding is the critical path: a missing vector means the search\n        # can't run, so a timeout there still raises 504. Entity boost is a\n        # supplementary signal — a slow lookup should NOT cancel a completed\n        # embedding; degrade to vector-only search and log instead. Total\n        # budget stays at ``_OVERALL_TIMEOUT_S`` so a slow entity task can't\n        # double the step's wall-clock budget.\n        t0 = time.perf_counter()\n        try:\n            embedding = await asyncio.wait_for(emb_task, timeout=_OVERALL_TIMEOUT_S)\n        except TimeoutError:\n            ent_task.cancel()\n            raise HTTPException(status_code=504, detail=\"Search embedding timed out\")\n        except ValueError as exc:\n            ent_task.cancel()\n            raise HTTPException(status_code=503, detail=str(exc))\n        except BaseException:\n            ent_task.cancel()\n            raise\n\n        # ent_task has been running in parallel with emb_task since the\n        # ``ensure_future`` calls above, so the remaining-budget wait_for\n        # below is usually trivial — the task is already done. The guard\n        # only fires when entity_boost outlasts the embedding.\n        remaining = max(_MIN_ENTITY_BUDGET_S, _OVERALL_TIMEOUT_S - (time.perf_counter() - t0))\n        try:\n            boosted_memory_ids, memory_boost_factor = await asyncio.wait_for(ent_task, timeout=remaining)\n        except TimeoutError:\n            logger.warning(\n                \"entity_boost timed out after %.2fs remaining budget; continuing with vector-only search\",\n                remaining,\n            )\n            boosted_memory_ids, memory_boost_factor = set(), {}\n        except BaseException as exc:\n            # ``_entity_boost_via_storage`` swallows most exceptions internally\n            # and returns ``(set(), {})``; anything that escapes is unexpected\n            # but still non-fatal for the search — fall back to vector-only.\n            logger.warning(\n                \"entity_boost raised after embedding ready; continuing with vector-only search: %r\",\n                exc,\n            )\n            boosted_memory_ids, memory_boost_factor = set(), {}\n\n        data[\"embedding\"] = embedding\n        data[\"boosted_memory_ids\"] = boosted_memory_ids\n        data[\"memory_boost_factor\"] = memory_boost_factor\n        return None","lineStart":1,"lineEnd":214,"totalLines":214,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/parallel_embed_entity_boost.py","time":{"start":1780728417750,"end":1780728417754}},"metadata":{"openai":{"itemId":"fc_0a235a28143a62e8016a23c2619a8081919fd15094492fe6a1"}},"id":"prt_e9baf4dc700162YZijstMtJJXu","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baf27a3001gboGwYUe0Ast5m"}}
{"type":"tool_use","timestamp":1780728417778,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_yuY9atFhAvJ159qpx3fp33xw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/execute_scored_search.py","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/execute_scored_search.py</path>\n<type>file</type>\n<content>\n1: \"\"\"ExecuteScoredSearch — delegate scored search to the storage client.\n2: \n3: All scoring expressions, filters, and CTE logic are handled server-side\n4: by core-storage-api.  This step builds the request payload and maps the\n5: response dicts back to SimpleNamespace rows for downstream steps.\n6: \"\"\"\n7: \n8: from __future__ import annotations\n9: \n10: import logging\n11: from collections import OrderedDict\n12: from types import SimpleNamespace\n13: \n14: from core_api.clients.storage_client import get_storage_client\n15: from core_api.constants import SEARCH_OVERFETCH_FACTOR\n16: from core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\n17: from core_api.pipeline.context import PipelineContext\n18: from core_api.pipeline.step import StepOutcome, StepResult\n19: from core_api.schemas import EntityLinkOut\n20: \n21: logger = logging.getLogger(__name__)\n22: \n23: _ALLOWED_OVERRIDES = frozenset({\"freshness_decay_days\", \"freshness_floor\", \"top_k\"})\n24: \n25: \n26: class ExecuteScoredSearch:\n27:     @property\n28:     def name(self) -> str:\n29:         return \"execute_scored_search\"\n30: \n31:     async def execute(self, ctx: PipelineContext) -> StepResult | None:\n32:         plan = ctx.data.get(\"retrieval_plan\")\n33:         if plan and plan.skip_scored_search:\n34:             return StepResult(outcome=StepOutcome.SKIPPED)\n35: \n36:         data = ctx.data\n37:         sp = data[\"search_params\"]\n38: \n39:         # Apply per-strategy overrides (e.g., TEMPORAL tightens freshness_decay_days).\n40:         if plan and plan.search_param_overrides:\n41:             unknown = plan.search_param_overrides.keys() - _ALLOWED_OVERRIDES\n42:             if unknown:\n43:                 raise ValueError(f\"Unexpected search_param_overrides keys: {unknown}\")\n44:             sp = {**sp, **plan.search_param_overrides}\n45: \n46:         embedding = data[\"embedding\"]\n47:         temporal_window = data[\"temporal_window\"]\n48:         boosted_memory_ids = data[\"boosted_memory_ids\"]\n49:         memory_boost_factor = data[\"memory_boost_factor\"]\n50:         recall_boost_enabled = data.get(\"recall_boost_enabled\", True)\n51: \n52:         # Diagnostic mode: widen the search to capture all candidates.\n53:         diagnostic = data.get(\"diagnostic\", False)\n54:         top_k = sp[\"top_k\"]\n55:         if diagnostic:\n56:             data[\"diagnostic_original_top_k\"] = top_k\n57:             top_k = max(top_k, 50)\n58:         else:\n59:             # Overfetch so PostFilterResults has headroom to drop low-vec_sim rows\n60:             # without starving the final result set. Final trim happens in PostFilterResults.\n61:             data[\"final_top_k\"] = top_k\n62:             top_k = top_k * SEARCH_OVERFETCH_FACTOR\n63: \n64:         # Build the request payload for the storage client.\n65:         search_data: dict = {\n66:             \"tenant_id\": data[\"tenant_id\"],\n67:             \"query\": data[\"query\"],\n68:             \"embedding\": embedding,\n69:             \"search_params\": sp,\n70:             \"top_k\": top_k,\n71:             \"recall_boost_enabled\": recall_boost_enabled,\n72:         }\n73: \n74:         # Cross-tenant read widening: when the caller's AuthContext is\n75:         # authorised to read from more than its home tenant, pass the\n76:         # full set through to the storage-api so it widens the WHERE\n77:         # predicate. Absent / single-element list stays single-tenant\n78:         # (storage-api falls back to ``Memory.tenant_id == tenant_id``).\n79:         readable = data.get(\"readable_tenant_ids\")\n80:         if readable and len(readable) > 1:\n81:             search_data[\"readable_tenant_ids\"] = readable\n82: \n83:         if temporal_window is not None:\n84:             search_data[\"temporal_window_seconds\"] = int(temporal_window.total_seconds())\n85: \n86:         if boosted_memory_ids:\n87:             search_data[\"boosted_memory_ids\"] = [str(mid) for mid in boosted_memory_ids]\n88:             search_data[\"memory_boost_factor\"] = {\n89:                 str(mid): factor for mid, factor in memory_boost_factor.items()\n90:             }\n91: \n92:         fleet_ids = data.get(\"fleet_ids\")\n93:         if fleet_ids:\n94:             search_data[\"fleet_ids\"] = fleet_ids\n95:         if data.get(\"filter_agent_id\"):\n96:             search_data[\"filter_agent_id\"] = data[\"filter_agent_id\"]\n97:         if data.get(\"caller_agent_id\"):\n98:             search_data[\"caller_agent_id\"] = data[\"caller_agent_id\"]\n99:         if data.get(\"memory_type_filter\"):\n100:             search_data[\"memory_type_filter\"] = data[\"memory_type_filter\"]\n101:         if data.get(\"status_filter\"):\n102:             search_data[\"status_filter\"] = data[\"status_filter\"]\n103:         if data.get(\"valid_at\"):\n104:             search_data[\"valid_at\"] = str(data[\"valid_at\"])\n105: \n106:         date_range = data.get(\"date_range_filter\")\n107:         if date_range:\n108:             search_data[\"date_range_start\"] = date_range[\"start_date\"]\n109:             search_data[\"date_range_end\"] = date_range[\"end_date\"]\n110:             logger.info(\n111:                 \"execute_scored_search: applying date_range %s → %s\",\n112:                 date_range[\"start_date\"],\n113:                 date_range[\"end_date\"],\n114:             )\n115: \n116:         # Per-tenant storage bulkhead (CAURA-602 follow-up). The pipeline\n117:         # search path is the active path (``_USE_PIPELINE_SEARCH=True``);\n118:         # without this slot, the legacy-path bulkhead in\n119:         # ``memory_service._search_memories_legacy`` was applied to dead\n120:         # code only. ``data[\"tenant_id\"]`` is set upstream by\n121:         # ``_search_memories_pipeline`` before this step runs.\n122:         #\n123:         # C10: if ``classify_query`` already entered + released the same\n124:         # slot for ``load_memories_by_ids`` (entity-lookup short-circuit\n125:         # that fell through), it sets ``_storage_slot_acquired=True`` on\n126:         # ctx.data. Don't re-charge — one logical search counts once\n127:         # against the per-tenant storage_search bucket.\n128:         sc = get_storage_client()\n129:         if data.get(\"_storage_slot_acquired\"):\n130:             rows = await sc.scored_search(search_data)\n131:         else:\n132:             async with per_tenant_storage_slot(\"storage_search\", data[\"tenant_id\"]):\n133:                 rows = await sc.scored_search(search_data)\n134: \n135:         # Map response dicts to SimpleNamespace rows expected by downstream steps.\n136:         grouped: OrderedDict[str, SimpleNamespace] = OrderedDict()\n137:         for row in rows:\n138:             mid = row[\"id\"]\n139:             if mid not in grouped:\n140:                 grouped[mid] = SimpleNamespace(\n141:                     Memory=SimpleNamespace(\n142:                         **{\n143:                             k: v\n144:                             for k, v in row.items()\n145:                             if k\n146:                             not in (\n147:                                 \"score\",\n148:                                 \"similarity\",\n149:                                 \"vec_sim\",\n150:                                 \"fts_score\",\n151:                                 \"freshness\",\n152:                                 \"entity_boost\",\n153:                                 \"recall_boost\",\n154:                                 \"temporal_boost\",\n155:                                 \"status_penalty\",\n156:                                 \"entity_links\",\n157:                                 \"has_embedding\",\n158:                             )\n159:                         }\n160:                     ),\n161:                     score=row.get(\"score\"),\n162:                     similarity=row.get(\"similarity\"),\n163:                     vec_sim=row.get(\"vec_sim\"),\n164:                     fts_score=row.get(\"fts_score\"),\n165:                     freshness=row.get(\"freshness\"),\n166:                     entity_boost=row.get(\"entity_boost\"),\n167:                     recall_boost=row.get(\"recall_boost\"),\n168:                     temporal_boost=row.get(\"temporal_boost\"),\n169:                     status_penalty=row.get(\"status_penalty\"),\n170:                     has_embedding=row.get(\"has_embedding\", True),\n171:                     entity_links=[],\n172:                 )\n173:             # Entity links may be inline in the row or as a nested list.\n174:             for link in row.get(\"entity_links\", []):\n175:                 grouped[mid].entity_links.append(\n176:                     EntityLinkOut(\n177:                         entity_id=link[\"entity_id\"],\n178:                         role=link.get(\"role\"),\n179:                     )\n180:                 )\n181: \n182:         data[\"raw_rows\"] = list(grouped.values())\n183:         return None\n\n(End of file - total 183 lines)\n</content>","metadata":{"preview":"\"\"\"ExecuteScoredSearch — delegate scored search to the storage client.\n\nAll scoring expressions, filters, and CTE logic are handled server-side\nby core-storage-api.  This step builds the request payload and maps the\nresponse dicts back to SimpleNamespace rows for downstream steps.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom collections import OrderedDict\nfrom types import SimpleNamespace\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.constants import SEARCH_OVERFETCH_FACTOR\nfrom core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepOutcome, StepResult\nfrom core_api.schemas import EntityLinkOut\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/execute_scored_search.py","text":"\"\"\"ExecuteScoredSearch — delegate scored search to the storage client.\n\nAll scoring expressions, filters, and CTE logic are handled server-side\nby core-storage-api.  This step builds the request payload and maps the\nresponse dicts back to SimpleNamespace rows for downstream steps.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom collections import OrderedDict\nfrom types import SimpleNamespace\n\nfrom core_api.clients.storage_client import get_storage_client\nfrom core_api.constants import SEARCH_OVERFETCH_FACTOR\nfrom core_api.middleware.per_tenant_concurrency import per_tenant_storage_slot\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepOutcome, StepResult\nfrom core_api.schemas import EntityLinkOut\n\nlogger = logging.getLogger(__name__)\n\n_ALLOWED_OVERRIDES = frozenset({\"freshness_decay_days\", \"freshness_floor\", \"top_k\"})\n\n\nclass ExecuteScoredSearch:\n    @property\n    def name(self) -> str:\n        return \"execute_scored_search\"\n\n    async def execute(self, ctx: PipelineContext) -> StepResult | None:\n        plan = ctx.data.get(\"retrieval_plan\")\n        if plan and plan.skip_scored_search:\n            return StepResult(outcome=StepOutcome.SKIPPED)\n\n        data = ctx.data\n        sp = data[\"search_params\"]\n\n        # Apply per-strategy overrides (e.g., TEMPORAL tightens freshness_decay_days).\n        if plan and plan.search_param_overrides:\n            unknown = plan.search_param_overrides.keys() - _ALLOWED_OVERRIDES\n            if unknown:\n                raise ValueError(f\"Unexpected search_param_overrides keys: {unknown}\")\n            sp = {**sp, **plan.search_param_overrides}\n\n        embedding = data[\"embedding\"]\n        temporal_window = data[\"temporal_window\"]\n        boosted_memory_ids = data[\"boosted_memory_ids\"]\n        memory_boost_factor = data[\"memory_boost_factor\"]\n        recall_boost_enabled = data.get(\"recall_boost_enabled\", True)\n\n        # Diagnostic mode: widen the search to capture all candidates.\n        diagnostic = data.get(\"diagnostic\", False)\n        top_k = sp[\"top_k\"]\n        if diagnostic:\n            data[\"diagnostic_original_top_k\"] = top_k\n            top_k = max(top_k, 50)\n        else:\n            # Overfetch so PostFilterResults has headroom to drop low-vec_sim rows\n            # without starving the final result set. Final trim happens in PostFilterResults.\n            data[\"final_top_k\"] = top_k\n            top_k = top_k * SEARCH_OVERFETCH_FACTOR\n\n        # Build the request payload for the storage client.\n        search_data: dict = {\n            \"tenant_id\": data[\"tenant_id\"],\n            \"query\": data[\"query\"],\n            \"embedding\": embedding,\n            \"search_params\": sp,\n            \"top_k\": top_k,\n            \"recall_boost_enabled\": recall_boost_enabled,\n        }\n\n        # Cross-tenant read widening: when the caller's AuthContext is\n        # authorised to read from more than its home tenant, pass the\n        # full set through to the storage-api so it widens the WHERE\n        # predicate. Absent / single-element list stays single-tenant\n        # (storage-api falls back to ``Memory.tenant_id == tenant_id``).\n        readable = data.get(\"readable_tenant_ids\")\n        if readable and len(readable) > 1:\n            search_data[\"readable_tenant_ids\"] = readable\n\n        if temporal_window is not None:\n            search_data[\"temporal_window_seconds\"] = int(temporal_window.total_seconds())\n\n        if boosted_memory_ids:\n            search_data[\"boosted_memory_ids\"] = [str(mid) for mid in boosted_memory_ids]\n            search_data[\"memory_boost_factor\"] = {\n                str(mid): factor for mid, factor in memory_boost_factor.items()\n            }\n\n        fleet_ids = data.get(\"fleet_ids\")\n        if fleet_ids:\n            search_data[\"fleet_ids\"] = fleet_ids\n        if data.get(\"filter_agent_id\"):\n            search_data[\"filter_agent_id\"] = data[\"filter_agent_id\"]\n        if data.get(\"caller_agent_id\"):\n            search_data[\"caller_agent_id\"] = data[\"caller_agent_id\"]\n        if data.get(\"memory_type_filter\"):\n            search_data[\"memory_type_filter\"] = data[\"memory_type_filter\"]\n        if data.get(\"status_filter\"):\n            search_data[\"status_filter\"] = data[\"status_filter\"]\n        if data.get(\"valid_at\"):\n            search_data[\"valid_at\"] = str(data[\"valid_at\"])\n\n        date_range = data.get(\"date_range_filter\")\n        if date_range:\n            search_data[\"date_range_start\"] = date_range[\"start_date\"]\n            search_data[\"date_range_end\"] = date_range[\"end_date\"]\n            logger.info(\n                \"execute_scored_search: applying date_range %s → %s\",\n                date_range[\"start_date\"],\n                date_range[\"end_date\"],\n            )\n\n        # Per-tenant storage bulkhead (CAURA-602 follow-up). The pipeline\n        # search path is the active path (``_USE_PIPELINE_SEARCH=True``);\n        # without this slot, the legacy-path bulkhead in\n        # ``memory_service._search_memories_legacy`` was applied to dead\n        # code only. ``data[\"tenant_id\"]`` is set upstream by\n        # ``_search_memories_pipeline`` before this step runs.\n        #\n        # C10: if ``classify_query`` already entered + released the same\n        # slot for ``load_memories_by_ids`` (entity-lookup short-circuit\n        # that fell through), it sets ``_storage_slot_acquired=True`` on\n        # ctx.data. Don't re-charge — one logical search counts once\n        # against the per-tenant storage_search bucket.\n        sc = get_storage_client()\n        if data.get(\"_storage_slot_acquired\"):\n            rows = await sc.scored_search(search_data)\n        else:\n            async with per_tenant_storage_slot(\"storage_search\", data[\"tenant_id\"]):\n                rows = await sc.scored_search(search_data)\n\n        # Map response dicts to SimpleNamespace rows expected by downstream steps.\n        grouped: OrderedDict[str, SimpleNamespace] = OrderedDict()\n        for row in rows:\n            mid = row[\"id\"]\n            if mid not in grouped:\n                grouped[mid] = SimpleNamespace(\n                    Memory=SimpleNamespace(\n                        **{\n                            k: v\n                            for k, v in row.items()\n                            if k\n                            not in (\n                                \"score\",\n                                \"similarity\",\n                                \"vec_sim\",\n                                \"fts_score\",\n                                \"freshness\",\n                                \"entity_boost\",\n                                \"recall_boost\",\n                                \"temporal_boost\",\n                                \"status_penalty\",\n                                \"entity_links\",\n                                \"has_embedding\",\n                            )\n                        }\n                    ),\n                    score=row.get(\"score\"),\n                    similarity=row.get(\"similarity\"),\n                    vec_sim=row.get(\"vec_sim\"),\n                    fts_score=row.get(\"fts_score\"),\n                    freshness=row.get(\"freshness\"),\n                    entity_boost=row.get(\"entity_boost\"),\n                    recall_boost=row.get(\"recall_boost\"),\n                    temporal_boost=row.get(\"temporal_boost\"),\n                    status_penalty=row.get(\"status_penalty\"),\n                    has_embedding=row.get(\"has_embedding\", True),\n                    entity_links=[],\n                )\n            # Entity links may be inline in the row or as a nested list.\n            for link in row.get(\"entity_links\", []):\n                grouped[mid].entity_links.append(\n                    EntityLinkOut(\n                        entity_id=link[\"entity_id\"],\n                        role=link.get(\"role\"),\n                    )\n                )\n\n        data[\"raw_rows\"] = list(grouped.values())\n        return None","lineStart":1,"lineEnd":183,"totalLines":183,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/execute_scored_search.py","time":{"start":1780728417770,"end":1780728417776}},"metadata":{"openai":{"itemId":"fc_0a235a28143a62e8016a23c2619a8c8191b6374ee8e55c9faf"}},"id":"prt_e9baf4de9001kOq57wwuvT7YeC","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baf27a3001gboGwYUe0Ast5m"}}
{"type":"tool_use","timestamp":1780728417778,"sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","part":{"type":"tool","tool":"read","callID":"call_40T25MzHUO0r7qpH86ETjCbi","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/post_filter_results.py","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/post_filter_results.py</path>\n<type>file</type>\n<content>\n1: \"\"\"PostFilterResults — filter raw rows by min_similarity gate on vec_sim.\"\"\"\n2: \n3: from __future__ import annotations\n4: \n5: from core_api.pipeline.context import PipelineContext\n6: from core_api.pipeline.step import StepOutcome, StepResult\n7: from core_api.pipeline.steps.search.retrieval_types import RetrievalStrategy\n8: \n9: \n10: class PostFilterResults:\n11:     @property\n12:     def name(self) -> str:\n13:         return \"post_filter_results\"\n14: \n15:     async def execute(self, ctx: PipelineContext) -> StepResult | None:\n16:         plan = ctx.data.get(\"retrieval_plan\")\n17:         if plan and plan.strategy == RetrievalStrategy.ENTITY_LOOKUP:\n18:             return StepResult(outcome=StepOutcome.SKIPPED)\n19: \n20:         min_similarity = ctx.data[\"search_params\"][\"min_similarity\"]\n21:         # NULL-embedding rows reach this point only when storage admitted them\n22:         # via the FTS half of `embedding IS NOT NULL OR search_vector @@ query`\n23:         # (relaxed in CAURA-594 so writes deferred via EMBED_REQUESTED stay\n24:         # searchable during the embed-pending window). Storage coerces their\n25:         # missing cosine to a 0.0 sentinel and emits `has_embedding=False` to\n26:         # disambiguate that from a real orthogonal match — trust that flag\n27:         # here and bypass the vec_sim threshold for FTS-only rows. Without\n28:         # this, the entire FTS-fallback contract is silently broken for any\n29:         # row whose embedding hasn't been PATCHed yet by core-worker.\n30:         filtered = [\n31:             row\n32:             for row in ctx.data[\"raw_rows\"]\n33:             if (not getattr(row, \"has_embedding\", True))\n34:             or row.vec_sim is None\n35:             or float(row.vec_sim) >= min_similarity\n36:         ]\n37:         # Trim to the user-requested top_k (storage returned top_k * overfetch_factor)\n38:         final_top_k = ctx.data.get(\"final_top_k\")\n39:         if final_top_k is not None:\n40:             filtered = filtered[:final_top_k]\n41:         ctx.data[\"filtered_rows\"] = filtered\n42:         return None\n\n(End of file - total 42 lines)\n</content>","metadata":{"preview":"\"\"\"PostFilterResults — filter raw rows by min_similarity gate on vec_sim.\"\"\"\n\nfrom __future__ import annotations\n\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepOutcome, StepResult\nfrom core_api.pipeline.steps.search.retrieval_types import RetrievalStrategy\n\n\nclass PostFilterResults:\n    @property\n    def name(self) -> str:\n        return \"post_filter_results\"\n\n    async def execute(self, ctx: PipelineContext) -> StepResult | None:\n        plan = ctx.data.get(\"retrieval_plan\")\n        if plan and plan.strategy == RetrievalStrategy.ENTITY_LOOKUP:\n            return StepResult(outcome=StepOutcome.SKIPPED)\n\n        min_similarity = ctx.data[\"search_params\"][\"min_similarity\"]","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/post_filter_results.py","text":"\"\"\"PostFilterResults — filter raw rows by min_similarity gate on vec_sim.\"\"\"\n\nfrom __future__ import annotations\n\nfrom core_api.pipeline.context import PipelineContext\nfrom core_api.pipeline.step import StepOutcome, StepResult\nfrom core_api.pipeline.steps.search.retrieval_types import RetrievalStrategy\n\n\nclass PostFilterResults:\n    @property\n    def name(self) -> str:\n        return \"post_filter_results\"\n\n    async def execute(self, ctx: PipelineContext) -> StepResult | None:\n        plan = ctx.data.get(\"retrieval_plan\")\n        if plan and plan.strategy == RetrievalStrategy.ENTITY_LOOKUP:\n            return StepResult(outcome=StepOutcome.SKIPPED)\n\n        min_similarity = ctx.data[\"search_params\"][\"min_similarity\"]\n        # NULL-embedding rows reach this point only when storage admitted them\n        # via the FTS half of `embedding IS NOT NULL OR search_vector @@ query`\n        # (relaxed in CAURA-594 so writes deferred via EMBED_REQUESTED stay\n        # searchable during the embed-pending window). Storage coerces their\n        # missing cosine to a 0.0 sentinel and emits `has_embedding=False` to\n        # disambiguate that from a real orthogonal match — trust that flag\n        # here and bypass the vec_sim threshold for FTS-only rows. Without\n        # this, the entire FTS-fallback contract is silently broken for any\n        # row whose embedding hasn't been PATCHed yet by core-worker.\n        filtered = [\n            row\n            for row in ctx.data[\"raw_rows\"]\n            if (not getattr(row, \"has_embedding\", True))\n            or row.vec_sim is None\n            or float(row.vec_sim) >= min_similarity\n        ]\n        # Trim to the user-requested top_k (storage returned top_k * overfetch_factor)\n        final_top_k = ctx.data.get(\"final_top_k\")\n        if final_top_k is not None:\n            filtered = filtered[:final_top_k]\n        ctx.data[\"filtered_rows\"] = filtered\n        return None","lineStart":1,"lineEnd":42,"totalLines":42,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/pipeline/steps/search/post_filter_results.py","time":{"start":1780728417772,"end":1780728417777}},"metadata":{"openai":{"itemId":"fc_0a235a28143a62e8016a23c2619a9c81918c2f34323c426351"}},"id":"prt_e9baf4deb001Ym0FLV4Vqb1InA","sessionID":"ses_164517a7fffebWJvAeGhtkjUIj","messageID":"msg_e9baf27a3001gboGwYUe0Ast5m"}}
