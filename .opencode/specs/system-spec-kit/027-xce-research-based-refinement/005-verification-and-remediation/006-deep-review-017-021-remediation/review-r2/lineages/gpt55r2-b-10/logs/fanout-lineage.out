,\n3892:         specFolder: prepared.parsed.specFolder,\n3893:         persistedContent: prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent\n3894:           ? prepared.qualityLoopResult.fixedContent\n3895:           : currentContent,\n3896:       } as const;\n3897:     },\n3898:     prepareLocked: async ({ ready, params: currentParams }) => {\n3899:       if (!isCanonicalAtomicPrepared(ready.prepared)) {\n3900:         return ready;\n3901:       }\n3902: \n3903:       // Rebuild the canonical merge while the spec-folder lock is held so\n3904:       // concurrent routed saves always merge against the latest on-disk doc.\n3905:       const canonicalPrepared = await buildCanonicalAtomicPreparedSave(currentParams, database);\n3906:       if (canonicalPrepared.status !== 'ready') {\n3907:         return canonicalPrepared;\n3908:       }\n3909: \n3910:       return {\n3911:         status: 'ready',\n3912:         prepared: canonicalPrepared.prepared,\n3913:         specFolder: canonicalPrepared.prepared.preparedMemory.parsed.specFolder,\n3914:         persistedContent: canonicalPrepared.persistedContent,\n3915:         persistedFilePath: canonicalPrepared.persistedFilePath,\n3916:       } as const;\n3917:     },\n3918:     indexPrepared: ({ ready, params: currentParams, force }) => {\n3919:       const effectiveFilePath = ready.persistedFilePath ?? currentParams.file_path;\n3920:       const routedPrepared = isCanonicalAtomicPrepared(ready.prepared)\n3921:         ? ready.prepared\n3922:         : null;\n3923: \n3924:       if (routedPrepared) {\n3925:         const validationResult = validateCanonicalPreparedSave(routedPrepared);\n3926:         if (!validationResult.ok) {\n3927:           return validationResult.rejection;\n3928:         }\n3929: \n3930:         return processPreparedMemory(routedPrepared.preparedMemory, effectiveFilePath, {\n3931:           force,\n3932:           asyncEmbedding: true,\n3933:           plannerMode: currentPara