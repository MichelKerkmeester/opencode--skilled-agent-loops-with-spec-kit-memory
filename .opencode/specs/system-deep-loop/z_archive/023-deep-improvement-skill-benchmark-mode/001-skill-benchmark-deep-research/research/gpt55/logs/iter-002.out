sers/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/deltas/iter-001.jsonl\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/iterations/iteration-001.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/prompts/iter-001.txt\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/deep-research-strategy.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/deep-research-config.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/.deep-research.lock\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/findings-registry.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/004-validation-and-docs/graph-metadata.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/003-skill-benchmark-mode/graph-metadata.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/002-skill-rename-deep-improvement/graph-metadata.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/graph-metadata.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/graph-metadata.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/004-validation-and-docs/description.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/003-skill-benchmark-mode/description.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/002-skill-rename-deep-improvement/description.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/description.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/description.json\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/004-validation-and-docs/spec.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/003-skill-benchmark-mode/spec.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/002-skill-rename-deep-improvement/spec.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/spec.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/spec.md\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/context-index.md","metadata":{"count":30,"truncated":false},"title":"","time":{"start":1780128167507,"end":1780128167576}},"id":"prt_e77e835c9001uC7ygg37EOR8e3","sessionID":"ses_18818249cffeInllmWUcVkPFl1","messageID":"msg_e77e81716001324o9XN5wDusSp"}}
.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/minimax/logs/iter-001.out:15:{"type":"tool_use","timestamp":1780128174585,"sessionID":"ses_18818249cffeInllmWUcVkPFl1","part":{"type":"tool","tool":"read","callID":"call_function_uq6cuwlcg0ve_1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/spec.md"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/spec.md</path>\n<type>file</type>\n<content>\n1: ---\n2: title: \"Feature Specification: deep-improvement — skill-benchmark mode + rename\"\n3: description: \"Phase parent: rename deep-agent-improvement to deep-improvement and add Lane C (skill-benchmark) measuring a skill's real-world routing, unprompted reference/asset discovery, efficiency, and usefulness; multi-model deep research (001) informs rename (002), Lane C build (003), and validation/docs (004).\"\n4: trigger_phrases:\n5:   - \"122-deep-improvement-skill-benchmark-mode\"\n6:   - \"skill-benchmark mode\"\n7:   - \"deep-improvement skill rename\"\n8: importance_tier: \"important\"\n9: contextType: \"implementation\"\n10: _memory:\n11:   continuity:\n12:     packet_pointer: \"skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode\"\n13:     last_updated_at: \"2026-05-30T00:00:00Z\"\n14:     last_updated_by: \"claude-opus\"\n15:     recent_action: \"Authored parent spec + 4-phase structure\"\n16:     next_safe_action: \"Run multi-model deep research in 001-skill-benchmark-deep-research\"\n17:     blockers: []\n18:     completion_pct: 10\n19:     open_questions: []\n20:     answered_questions: []\n21: ---\n22: <!-- SPECKIT_TEMPLATE_SOURCE: spec-core | v2.2 -->\n23: <!-- SPECKIT_LEVEL: 3 -->\n24: <!-- CONTENT DISCIPLINE: PHASE PARENT — root purpose + sub-phase control + what needs done; no migration narrative (see context-index.md); heavy docs live in children. -->\n25: \n26: # Spec 122 — deep-improvement: skill-benchmark mode + skill rename\n27: \n28: **Track:** skilled-agent-orchestration\n29: **Type:** Phase parent (sub-phase control file)\n30: **Status:** In progress — Phase 001 (deep research) active\n31: **Level:** 3 (architecture-affecting; multi-phase)\n32: \n33: ---\n34: \n35: ## 1. Purpose\n36: \n37: Evolve the `deep-agent-improvement` skill into a broader **`deep-improvement`** evaluation skill and add a third evaluation lane that benchmarks *skills themselves*.\n38: \n39: Two coupled changes:\n40: \n41: 1. **Rename `deep-agent-improvement` → `deep-improvement`.** The skill no longer only improves agent `.md` files. It already carries Lane A (agent-improvement) and Lane B (model-benchmark), and this packet adds Lane C (skill-benchmark). The `-agent-` infix in the name is now too narrow and miscommunicates scope.\n42: \n43: 2. **Add Lane C — skill-benchmark mode.** A new evaluation lane that measures whether a *skill* is actually well-structured, well-routed, efficient, and useful **in practice** — i.e. how real AI agents discover and use it in situ — and emits actionable findings that a follow-up packet can remediate.\n44: \n45: This is the phase-parent control file. Heavy per-phase docs (`plan.md`, `tasks.md`, `checklist.md`, `implementation-summary.md`, `decision-record.md`) live in the sub-phases where the work happens. Migration notes for the placeholder→real phase restructure live in `context-index.md`, not here.\n46: \n47: ---\n48: \n49: ## 2. Background / current state\n50: \n51: `deep-agent-improvement` (evaluator-first bounded improvement) currently ships:\n52: \n53: - **Lane A — agent-improvement** (`/deep:start-agent-improvement-loop`): proposal-first loop over a bounded agent `.md`, dynamic-mode 5-dimension scoring, guarded promotion/rollback.\n54: - **Lane B — model-benchmark** (`/deep:start-model-benchmark-loop`): benchmark a model or prompt framework against repeatable fixtures; pattern or 5-dim scoring; deterministic or graded runs. Built across packet **121** (`121-deep-agent-improvement-benchmark-mode`).\n55: - **Three pluggable seams** shared by all lanes: candidate-source, dispatcher, scorer. Entry: `scripts/shared/loop-host.cjs --mode=<lane>`. References/assets/scripts are organized by lane (`agent-improvement/`, `model-benchmark/`, `shared/`).\n56: - Shared runtime via the `deep-loop-runtime` peer skill (executor config, prompt-pack, validation, atomic state, coverage-graph, Bayesian scoring, fallback routing).\n57: \n58: Lane C is the natural third lane: same loop shape, same three seams, a new fixture/dispatcher/scorer triple scoped to *skills*.\n59: \n60: ---\n61: \n62: ## 3. Problem statement\n63: \n64: Skills are validated today in two ways, and both miss a critical failure class:\n65: \n66: - **`sk-doc` / `validate.sh`** check *document shape* (sections present, frontmatter valid, README/package conformance).\n67: - **Manual testing playbooks** (shipped inside many skills) check the *behavior the skill docs describe* — i.e. \"does the workflow do what the doc says when followed.\"\n68: \n69: Neither answers the question that actually determines a skill's real-world value:\n70: \n71: > When an AI is dropped into a realistic situation that *should* trigger this skill, does it (a) get routed to the skill at the right moment, (b) find and load the *correct, useful* references/assets **without being told which file to open**, and (c) reach a good outcome efficiently — or does the skill's structure/routing create bottlenecks that make AIs miss it, mis-route, over-load context, or fail to find the asset they needed?\n72: \n73: This is a **structure / routing / efficiency / usefulness** benchmark of the skill *as it is actually consumed*, not of the logic it describes. It is distinct from manual playbooks and from doc-shape validation. Its output must be **diagnostic and remediable** — ranked bottlenecks with concrete recommendations.\n74: \n75: ---\n76: \n77: ## 4. Goals\n78: \n79: - **G1.** Rename `deep-agent-improvement` → `deep-improvement` across every surface (skill dir, `SKILL.md`, commands, agent + runtime mirrors, skill-advisor graph, `descriptions.json`, and all cross-references) with zero dangling references and a green skill-advisor rebuild.\n80: - **G2.** Define Lane C (\"skill-benchmark\") precisely: what it measures, the fixture (scenario) schema, the unprompted-dispatch capture method, the scoring dimensions, and the remediation-report format.\n81: - **G3.** Implement Lane C as a third lane reusing the candidate/dispatcher/scorer seams and `loop-host.cjs --mode=skill-benchmark`, with a `/deep:start-skill-benchmark-loop` command.\n82: - **G4.** Produce a **Skill Benchmark Report** that ranks bottlenecks and gives actionable remediation a follow-up packet can act on.\n83: - **G5.** Keep Lane A and Lane B byte-identical when no `--mode=skill-benchmark` flag is set (no regression to existing lanes).\n84: - **G6.** Update all docs (two-lane → three-lane), README, advisor metadata, and run the standard hardening/deep-review gate.\n85: \n86: ### Non-Goals\n87: \n88: - **NG1.** Actually *remediating* the skills that Lane C flags (Lane C is diagnostic; remediation is separate, optionally via Lane A).\n89: - **NG2.** Replacing `sk-doc` doc-shape validation or the existing manual testing playbooks — Lane C is complementary, not a replacement.\n90: - **NG3.** Re-architecting the shared `deep-loop-runtime` (consume it; do not redesign it).\n91: - **NG4.** Renaming the per-lane command verbs unnecessarily (e.g. `/deep:start-agent-improvement-loop` stays — it still improves *agents*); only the **skill name** must change. Command/agent naming decisions are recorded explicitly in Phase 002.\n92: \n93: ---\n94: \n95: ## 5. Scope\n96: \n97: **In scope:** the `deep-improvement` skill (post-rename), its commands/agent/mirrors, advisor metadata, and the new Lane C surface (references/assets/scripts under a `skill-benchmark/` domain), plus the deep-research that informs the design.\n98: \n99: **Out of scope:** changes to skills *other than* as benchmark *targets* of Lane C; changes to `deep-loop-runtime` internals; changes to `deep-review`/`deep-research` workflows beyond consuming them.\n100: \n101: **Frozen scope note:** per the Four Laws, scope defined here is frozen for the implementation phases. New ideas surfaced by research are recorded as follow-ups, not silently absorbed.\n102: \n103: ---\n104: \n105: ## 6. Sub-phase control\n106: \n107: This packet decomposes into the following ordered phases. Each child owns its own canonical docs.\n108: \n109: | Phase | Folder | Purpose | Depends on |\n110: | ----- | ------ | ------- | ---------- |\n111: | **001** | `001-skill-benchmark-deep-research/` | 20-iteration deep-research loop investigating Lane C design (what to measure, how to capture unprompted routing/discovery, scoring, remediation) **and** the rename impact map. Multi-model: 5× MiniMax-2.7, 5× DeepSeek-v4-pro, 5× GPT-5.5 (xhigh, fast), 5× Opus-4.8 native. | — |\n112: | **002** | `002-skill-rename-deep-improvement/` | Rename `deep-agent-improvement` → `deep-improvement` across all surfaces; advisor rebuild; no dangling refs. | 001 (impact map) |\n113: | **003** | `003-skill-benchmark-mode/` | Design + build Lane C in the renamed skill: scenario fixtures, unprompted dispatcher, routing/discovery/efficiency/usefulness scorer, report, `/deep:start-skill-benchmark-loop`. | 001, 002 |\n114: | **004** | `004-validation-and-docs/` | Three-lane doc updates, README, advisor metadata, hardening/deep-review gate, end-to-end validation. | 002, 003 |\n115: \n116: Resume policy: on a phase parent, follow `graph-metadata.json.derived.last_active_child_id`; if absent/stale, list children with statuses and pick.\n117: \n118: ---\n119: \n120: ## 7. Lane C — requirements (to be confirmed/refined by Phase 001 research)\n121: \n122: Working hypothesis for what Lane C measures. Phase 001 deep research validates, corrects, and operationalizes these; Phase 003 implements the converged design.\n123: \n124: - **R1 — Routing/activation accuracy.** Given a realistic prompt that *should* activate the target skill at a specific intent, does the skill-advisor + the skill's smart router select the right skill and the right intent/resource set? Measure precision/recall over a scenario suite (including near-miss negatives that should *not* activate).\n125: - **R2 — Unprompted reference/asset discovery.** For scenarios whose correct handling *requires* a specific reference/asset, does the agent autonomously load the right file via the router **without** being told the path? Measure discovery precision/recall and the count of irrelevant loads.\n126: - **R3 — Efficiency / bottlenecks.** Tool-calls and token cost to reach the needed resource; over-loading (too much context), under-loading (missing needed refs), ambiguous routing keys, fallback misfires, dead-ends.\n127: - **R4 — Usefulness (ablation).** Does the skill materially improve the scenario outcome vs a skill-off baseline? (skill-on vs skill-off delta.)\n128: - **R5 — Structural connectivity.** Orphan references/assets (present but never routable), router keys that never fire for any real scenario, missing triggers for real scenario classes, broken/over-broad routing.\n129: - **R6 — Actionable output.** A ranked **Skill Benchmark Report**: per-dimension scores + ranked bottlenecks + concrete remediations (add trigger X, intent Y never fires for class Z, reference A orphaned, scenario class B needs asset C surfaced).\n130: \n131: ### Architecture fit (working hypothesis)\n132: \n133: - **Fixtures** = a scenario set per target skill: realistic prompt + expected activation + expected resource(s) + correct-outcome rubric, including negatives.\n134: - **Dispatcher** = run each scenario against an executor in a *hint-free* harness, capturing the resource-load trace and tool trace (what it opened, in what order, how many calls).\n135: - **Scorer** = compare actual vs expected across R1–R5 → skill-benchmark dimensions; emit R6 report. Reuses the deterministic-checks + pluggable-grader shape of the Lane B 5-dim scorer.\n136: - **Mode** = `loop-host.cjs --mode=skill-benchmark`; every state record carries `mode: skill-benchmark`; reports carry a `scoringMethod`.\n137: - **Promotion** = Lane C is **advisory/diagnostic** by default (emits a report; does not mutate the target skill). Optional hand-off: feed findings into Lane A to actually improve a `SKILL.md`.\n138: \n139: ---\n140: \n141: ## 8. Success criteria\n142: \n143: - **SC1.** Phase 001 deep-research loop completes (convergence or max iterations) with all state files consistent, `research/research.md` synthesized, and the multi-model split executed (5/5/5/5 across MiniMax-2.7 / DeepSeek-v4-pro / GPT-5.5-xhigh-fast / Opus-4.8-native).\n144: - **SC2.** Rename (Phase 002) leaves zero dangling `deep-agent-improvement` references where `deep-improvement` is intended; skill-advisor rebuild + validate are green; Lane A/B commands still run.\n145: - **SC3.** Lane C (Phase 003) runs end-to-end on at least one real target skill and emits a Skill Benchmark Report with ranked, actionable bottlenecks; Lane A/B behavior is unchanged when the mode flag is absent.\n146: - **SC4.** Docs/README/advisor reflect three lanes; hardening/deep-review gate passes (Phase 004).\n147: - **SC5.** `validate.sh <packet> --strict` is green at parent and per active child.\n148: \n149: ---\n150: \n151: ## 9. Risks\n152: \n153: - **Rename blast radius.** `deep-agent-improvement` is referenced by commands, the agent + 3 runtime mirrors, the advisor graph, `descriptions.json`, the sentinel `sk-prompt-models`, and root docs. Mitigation: Phase 001 produces an exhaustive impact map before Phase 002 touches anything.\n154: - **Lane C measurement validity.** \"Did the AI find the right asset unprompted\" must be measured without leaking the answer into the prompt. Mitigation: hint-free dispatch harness + held-out expected-resource keys; this is a primary research question.\n155: - **Non-determinism.** AI routing varies run-to-run. Mitigation: repeatability runs + report variance, mirroring Lane B's stability evidence.\n156: - **Scope creep into remediation.** Easy to drift from \"diagnose\" to \"fix\". Mitigation: NG1 freezes Lane C as diagnostic.\n157: \n158: ---\n159: \n160: ## 10. References\n161: \n162: - Skill under change: `.opencode/skills/deep-agent-improvement/SKILL.md` (→ `deep-improvement`).\n163: - Sibling packet (Lane B, template): `.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/`.\n164: - Deep-research contract: `.opencode/skills/deep-research/SKILL.md`; command `.opencode/commands/deep/start-research-loop.md`.\n165: - Shared runtime: `.opencode/skills/deep-loop-runtime/SKILL.md`.\n166: - Doc/validation: `.opencode/skills/sk-doc/`, `system-spec-kit` validate.\n167: \n168: ---\n169: \n170: ## 11. Open questions (for Phase 001 research)\n171: \n172: - OQ1. Exact scoring dimensions + weights for Lane C (R1–R5) and how to normalize across skills of different shapes.\n173: - OQ2. How to build a credible *hint-free* dispatch harness that still captures the resource-load trace.\n174: - OQ3. Whether activation accuracy should be measured against the skill-advisor, the in-`SKILL.md` smart router, or both as separate sub-scores.\n175: - OQ4. Scenario authoring: hand-authored vs generated-from-the-skill's-own-triggers (and how to avoid circularity).\n176: - OQ5. The exact rename surface list + safe ordering (advisor graph + mirrors + descriptions).\n177: - OQ6. Whether `/deep:start-skill-benchmark-loop` should reuse the model-benchmark command scaffold or get its own.\n\n(End of file - total 177 lines)\n</content>","metadata":{"preview":"---\ntitle: \"Feature Specification: deep-improvement — skill-benchmark mode + rename\"\ndescription: \"Phase parent: rename deep-agent-improvement to deep-improvement and add Lane C (skill-benchmark) measuring a skill's real-world routing, unprompted reference/asset discovery, efficiency, and usefulness; multi-model deep research (001) informs rename (002), Lane C build (003), and validation/docs (004).\"\ntrigger_phrases:\n  - \"122-deep-improvement-skill-benchmark-mode\"\n  - \"skill-benchmark mode\"\n  - \"deep-improvement skill rename\"\nimportance_tier: \"important\"\ncontextType: \"implementation\"\n_memory:\n  continuity:\n    packet_pointer: \"skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode\"\n    last_updated_at: \"2026-05-30T00:00:00Z\"\n    last_updated_by: \"claude-opus\"\n    recent_action: \"Authored parent spec + 4-phase structure\"\n    next_safe_action: \"Run multi-model deep research in 001-skill-benchmark-deep-research\"\n    blockers: []\n    completion_pct: 10\n    open_questions: []\n    answered_questions: []","truncated":false,"loaded":[]},"title":".opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/spec.md","time":{"start":1780128174579,"end":1780128174584}},"id":"prt_e77e8519a001tzM32WLJC6t0Zb","sessionID":"ses_18818249cffeInllmWUcVkPFl1","messageID":"msg_e77e8390f001cmfTlwe5oWz4bn"}}
.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/minimax/logs/iter-001.out:20:{"type":"tool_use","timestamp":1780128182321,"sessionID":"ses_18818249cffeInllmWUcVkPFl1","part":{"type":"tool","tool":"grep","callID":"call_function_d9o8ac6jmgq3_2","state":{"status":"completed","input":{"path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research","pattern":"skill.*benchmark|router.*test|routing.*accuracy|unprompted.*discovery|tool.*selection"},"output":"Found 80 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/122-deep-improvement-skill-benchmark-mode/001-skill-benchmark-deep-research/research/minimax/logs/iter-001.out:\n  Line 4: {\"type\":\"tool_use\",\"timestamp\":1780128158678,\"sessionID\":\"ses_18818249cffeInllmWUcVkPFl1\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_function_r6hfuyah5s92_1\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-agent-improvement/SKILL.md\"},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-agent-improvement/SKILL.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: name: deep-agent-improvement\\n3: description: \\\"Evaluator-first bounded agent improvement: 5-dim scoring, dynamic profiling, packet-local candidates, guarded promotion.\\\"\\n4: allowed-tools: [Read, Write, Edit, Bash, Glob, Grep]\\n5: version: 1.9.0.0\\n6: triggers:\\n7:   - deep-agent-improvement\\n8:   - agent improvement loop\\n9:   - bounded agent improvement\\n10:   - 5-dimension scoring\\n11:   - integration scanner\\n12:   - dynamic profiling\\n13:   - model-benchmark mode\\n14:   - benchmark a model or prompt framework\\n15: ---\\n16: \\n17: <!-- Keywords: deep-agent-improvement, deep-agent-improvement, agent-improvement, benchmark-harness, score-candidate, promote-candidate, rollback-candidate -->\\n18: \\n19: # Recursive Agent: Evaluator-First Improvement Orchestrator\\n20: \\n21: Evaluator-first workflow for testing whether a bounded agent surface can be improved without immediately mutating the source of truth. It combines packet-local candidates, deterministic scoring, repeatable benchmarks, and explicit promotion or rollback gates.\\n22: \\n23: ---\\n24: \\n25: ## 1. WHEN TO USE\\n26: \\n27: ### Two Co-Equal Lanes\\n28: \\n29: This skill supports two co-equal use-case lanes that share the same candidate, dispatcher, and scorer seams:\\n30: \\n31: | Lane | Pick when | Command |\\n32: | --- | --- | --- |\\n33: | **Lane A: Agent-Improvement** | You want to improve a bounded agent `.md` file | `/deep:start-agent-improvement-loop` |\\n34: | **Lane B: Model-Benchmark** | You want to be...\n  Line 5: {\"type\":\"tool_use\",\"timestamp\":1780128158681,\"sessionID\":\"ses_18818249cffeInllmWUcVkPFl1\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_function_r6hfuyah5s92_2\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/SKILL.md\"},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-doc/SKILL.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: name: sk-doc\\n3: description: \\\"Markdown and OpenCode component specialist: doc quality, content optimization, component scaffolds, install guides, playbooks.\\\"\\n4: allowed-tools: [Bash, Edit, Glob, Grep, Read, Task, Write]\\n5: version: 1.5.0.0\\n6: ---\\n7: \\n8: <!-- Keywords: sk-doc, markdown-quality, skill-creation, document-validation, ascii-flowchart, llms-txt, content-optimization, extract-structure -->\\n9: \\n10: # Documentation Creation Specialist - Unified Markdown & Component Management\\n11: \\n12: Unified specialist providing: (1) Document quality pipeline with structure enforcement and content optimization, (2) OpenCode component creation (skills, agents, commands) with scaffolding, validation and packaging, (3) ASCII flowchart creation for visualizing workflows, (4) Install guide creation for setup documentation and (5) Feature catalog and manual testing playbook creation for inventory and validation packages.\\n13: \\n14: **Core Principle**: Structure first, then content, then quality.\\n15: \\n16: **Architecture**: Scripts handle deterministic parsing/metrics. AI handles quality judgment and recommendations.\\n17: \\n18: ## 1. WHEN TO USE\\n19: \\n20: ### Use Case: Document Quality Management\\n21: \\n22: Enforce markdown structure, optimize content for AI assistants, validate quality through script-assisted AI analysis.\\n23: \\n24: **README Creation** - Use `readme_template.md` + `readme_creation.md` when:\\n25: - Creating new README for any folder or project\\n26: - User requests \\\"create a RE...\n  Line 6: {\"type\":\"tool_use\",\"timestamp\":1780128158895,\"sessionID\":\"ses_18818249cffeInllmWUcVkPFl1\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_function_r6hfuyah5s92_3\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/SKILL.md\"},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/SKILL.md</path>\\n<type>file</type>\\n<content>\\n1: ---\\n2: name: system-skill-advisor\\n3: description: Routes non-trivial requests to matching skills through standalone MCP metadata and stable advisor tool ids.\\n4: allowed-tools: [Read, Write, Edit, Bash, Glob, Grep]\\n5: version: 0.1.0\\n6: trigger_phrases:\\n7:   - \\\"skill advisor\\\"\\n8:   - \\\"gate 2 routing\\\"\\n9:   - \\\"advisor_recommend\\\"\\n10:   - \\\"advisor_status\\\"\\n11:   - \\\"which skill should handle this\\\"\\n12:   - \\\"route this request to a skill\\\"\\n13:   - \\\"system skill advisor\\\"\\n14: keywords:\\n15:   - skill-routing\\n16:   - gate-2\\n17:   - advisor-mcp\\n18:   - legacy-tool-bridge\\n19:   - skill-graph\\n20:   - semantic-lane\\n21: intent_signals:\\n22:   - \\\"Gate 2 skill routing\\\"\\n23:   - \\\"advisor_recommend native MCP routing\\\"\\n24:   - \\\"advisor_status freshness check\\\"\\n25:   - \\\"which skill should handle this request\\\"\\n26:   - \\\"run the skill advisor hook\\\"\\n27: ---\\n28: \\n29: <!-- Keywords: system-skill-advisor, skill-advisor, advisor_recommend, advisor_status, advisor_rebuild, advisor_validate, skill_graph_scan, skill_graph_query, skill_graph_status, skill_graph_validate, skill_graph_propagate_enhances, cross-skill-edges, gate-2-routing, standalone-mcp, legacy-tool-bridge, skill-graph -->\\n30: \\n31: # System Skill Advisor\\n32: \\n33: <!-- sk-doc-template: skill_md -->\\n34: \\n35: Routes non-trivial user requests to the right skill through the standalone Skill Advisor MCP package.\\n36: \\n37: ---\\n38: \\n39: ## 1. WHEN TO USE\\n40: \\n41: Use this skill when the work is a...\n  Line 7: {\"type\":\"tool_use\",\"timestamp\":1780128159017,\"sessionID\":\"ses_18818249cffeInllmWUcVkPFl1\",\"part\":{\"type\":\"tool\",\"tool\":\"glob\",\"callID\":\"call_function_r6hfuyah5s92_4\",\"state\":{\"status\":\"completed\",\"input\":{\"pattern\":\".opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/**\"},\"output\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/context-index.md\\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/skilled-agent-orchestration/121-deep-agent-improvement-benchmark-mode/timeline.md\\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Pub