    93	function dispatchArgs(model, dir, variant) {
    94	  const args = ['run', '--model', model];
    95	  // No explicit --agent: on this opencode build `general` is classified as a
    96	  // subagent (warns + falls back), and MiniMax rejects --agent outright. The
    97	  // default primary agent loads skills fine for a routing-analysis dispatch.
    98	  // Reasoning effort (provider-specific, e.g. high/max). Forwarded for all
    99	  // models, including MiniMax-M3 which accepts --variant and would otherwise
   100	  // silently lose its reasoning-effort setting.
   101	  if (variant) args.push('--variant', variant);
   102	  args.push('--format', 'json', '--dir', dir);
   103	  return args;
   104	}
   105	
   106	/**
   107	 * Run one `opencode run` dispatch via spawnSync and capture its streams.
   108	 *
   109	 * @param {Object} args - Dispatch inputs.
   110	 * @param {string} args.prompt - Prompt to send to the model.
   111	 * @param {string} args.dir - Working directory / project dir for the run.
   112	 * @param {string} args.model - Model id to dispatch.
   113	 * @param {string} args.variant - Reasoning-effort variant.
   114	 * @param {Object} [args.extraEnv] - Extra environment variables to inject.
   115	 * @returns {{ status:number, stdout:string, stderr:string, timedOut:boolean }}
   116	 */
   117	function runDispatch({ prompt, dir, model, variant, extraEnv }) {
   118	  model = model || DEFAULT_MODEL;
   119	  const res = spawnSync(OPENCODE_BIN, [...dispatchArgs(model, dir, variant), prompt], {
   120	    cwd: dir,
   121	    stdio: ['ignore', 'pipe', 'pipe'], // closed stdin == the mandatory </dev/null
   122	    encoding: 'utf8',
   123	    timeout: DISPATCH_TIMEOUT_MS,
   124	    maxBuffer: 32 * 1024 * 1024,
   125	    env: { ...process.env, AI_SESSION_CHILD: '1', ...(extraEnv || {}) },
   126	  });
   127	  return { status: res.status, stdout: res.stdout || '', stderr: res.stderr || '', timedOut: res.signal === 'SIGTERM' };
   128	}
