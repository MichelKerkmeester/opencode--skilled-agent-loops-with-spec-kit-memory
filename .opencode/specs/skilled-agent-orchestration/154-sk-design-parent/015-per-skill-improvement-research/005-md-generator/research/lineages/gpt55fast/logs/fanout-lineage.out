 \"design tokens from url\",\n113:       \"create design reference\",\n114:       \"design-to-markdown\",\n115:       \"extract design tokens\"\n116:     ],\n117:     \"key_topics\": [\n118:       \"sk-design\",\n119:       \"mode-registry\",\n120:       \"workflowMode\",\n121:       \"backendKind\",\n122:       \"reference-base\",\n123:       \"interface-mode\",\n124:       \"foundations-mode\",\n125:       \"motion-mode\",\n126:       \"audit-mode\",\n127:       \"md-generator-mode\",\n128:       \"shared-design-reference-base\",\n129:       \"anti-slop\",\n130:       \"design-token-vocabulary\",\n131:       \"cognitive-laws\"\n132:     ],\n133:     \"key_files\": [\n134:       \".opencode/skills/sk-design/SKILL.md\",\n135:       \".opencode/skills/sk-design/mode-registry.json\"\n136:     ],\n137:     \"entities\": [\n138:       {\n139:         \"name\": \"sk-design\",\n140:         \"kind\": \"skill\",\n141:         \"path\": \".opencode/skills/sk-design/SKILL.md\",\n142:         \"source\": \"derived\"\n143:       },\n144:       {\n145:         \"name\": \"mode-registry\",\n146:         \"kind\": \"config\",\n147:         \"path\": \".opencode/skills/sk-design/mode-registry.json\",\n148:         \"source\": \"derived\"\n149:       }\n150:     ],\n151:     \"causal_summary\": \"sk-design is the single public design skill that routes a request to one of five design modes (interface, foundations, motion, audit, md-generator) by workflowMode through mode-registry.json over a shared design reference base. The four doc-guidance modes cite the shared reference base (anti-slop principles, cognitive laws, design-token vocabulary) for consistent vocabulary, while md-generator runs its own Playwright CSS-extraction backend (backendKind discriminates the two). The hub holds no per-mode design logic; every mode keeps its own judgment, examples, and verification in its packet, and all five route by hub membership so the advisor sees exactly one design identity.\",\n152:     \