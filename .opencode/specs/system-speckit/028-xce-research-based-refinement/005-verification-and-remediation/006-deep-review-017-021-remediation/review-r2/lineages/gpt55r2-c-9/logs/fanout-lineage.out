c } from 'node:fs';\nimport net from 'node:net';\nimport { createRequire } from 'node:module';\nimport path from 'node:path';\nimport { StringDecoder } from 'node:string_decoder';\nimport { fileURLToPath } from 'node:url';\n\nimport {\n  TOOL_DEFINITIONS,\n  type ToolDefinition,\n  ToolSchemaValidationError,\n  validateToolArgs,\n} from './tool-schemas.js';\n\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst DEFAULT_TIMEOUT_MS = 30_000;\nconst DEFAULT_SOCKET_DIR = '/tmp/mk-spec-memory';\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst RESERVED_COMMANDS = new Set(['list-tools', 'completion']);\n\nconst EXIT_SUCCESS = 0;\nconst EXIT_RUNTIME = 1;\nconst EXIT_USAGE = 64;\nconst EXIT_PROTOCOL = 69;\nconst EXIT_RETRYABLE = 75;\n\ntype OutputFormat = 'json' | 'text' | 'jsonl';\ntype ToolListMode = 'full' | 'compact' | 'names-only';\ntype CompletionShell = 'bash' | 'zsh';\n\ninterface ParsedCommand {\n  readonly command: string;\n  readonly format: OutputFormat;\n  readonly timeoutMs: number;\n  readonly sessionId?: string;\n  readonly warmOnly: boolean;\n  readonly toolListMode: ToolListMode;\n  readonly completionShell?: CompletionShell;\n  readonly args: Record<string, unknown>;\n  readonly help: boolean;\n  readonly version: boolean;\n}\n\ninterface CliIo {\n  readonly stdout: Pick<NodeJS.WriteStream, 'write'>;\n  readonly stderr: Pick<NodeJS.WriteStream, 'write'>;\n}\n\ninterface RepoPaths {\n  readonly opencodeDir: string;\n  readonly repoRoot: string;\n  readonly launcherPath: string;\n  readonly bridgePath: string;\n  readonly dbDir: string;\n  readonly packageJsonPath: string;\n}\n\ninterface BridgeProbeResult {\n  readonly status: string;\n  readonly reason?: string;\n}\n\ninterface BridgeModule {\n  readonly getIpcSocketPath: (serviceName: string, options?: { dbDir?: string }) => string;\n  readonly probeDaemon: (socketPath: string, options?: { timeoutMs?: number; deepProbe?: boolean }) => Promise<BridgeProbeResult>;\n  readonly toConnectionOptions: (socketPath: string) => string | net.NetConnectOpts;\n}\n\ninterface JsonRpcResponse {\n  readonly jsonrpc?: string;\n  readonly id?: unknown;\n  readonly result?: unknown;\n  readonly error?: {\n    readonly code?: number;\n    readonly message?: string;\n    readonly data?: unknown;\n  };\n}\n\ninterface InitializeResult {\n  readonly protocolVersion?: string;\n}\n\ninterface ToolResult {\n  readonly content?: Array<{ readonly type?: string; readonly text?: string }>;\n  readonly isError?: boolean;\n}\n\nclass CliUsageError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliUsageError';\n  }\n}\n\nclass CliRetryableError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliRetryableError';\n  }\n}\n\nclass CliProtocolError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliProtocolError';\n  }\n}\n\nclass JsonRpcError extends Error {\n  public readonly code?: number;\n  public readonly data?: unknown;\n\n  constructor(error: NonNullable<JsonRpcResponse['error']>) {\n    super(error.message ?? 'JSON-RPC request failed');\n    this.name = 'JsonRpcError';\n    this.code = error.code;\n    this.data = error.data;\n  }\n}\n\n// Awaits drain when the kernel pipe buffer is full: a fire-and-forget\n// write followed by process.exit() truncates large payloads at the pipe\n// buffer boundary (observed as exactly 64KB on darwin). Streams without\n// emitter methods (test fakes) resolve immediately.\nasync function writeLine(stream: Pick<NodeJS.WriteStream, 'write'>, value: string): Promise<void> {\n  const flushed = stream.write(`${value}\\n`);\n  if (flushed) return;\n  const drainable = stream as Pick<NodeJS.WriteStream, 'write'> & Partial<Pick<NodeJS.WriteStream, 'once' | 'off'>>;\n  if (typeof drainable.once !== 'function') return;\n  await new Promise<void>((resolve) => {\n    const settle = (): void => {\n      drainable.off?.('drain', settle);\n      drainable.off?.('error', settle);\n      drainable.off?.('close', settle);\n      resolve();\n    };\n    drainable.once?.('drain', settle);\n    drainable.once?.('error', settle);\n    drainable.once?.('close', settle);\n  });\n}\n\nfunction currentModulePath(): string {\n  return fileURLToPath(import.meta.url);\n}\n\nfunction findRepoPaths(startFile = currentModulePath()): RepoPaths {\n  let current = path.dirname(startFile);\n\n  while (true) {\n    const directOpencodeDir = path.basename(current) === '.opencode' ? current : path.join(current, '.opencode');\n    const launcherPath = path.join(directOpencodeDir, 'bin', 'mk-spec-memory-launcher.cjs');\n    const bridgePath = path.join(directOpencodeDir, 'bin', 'lib', 'launcher-ipc-bridge.cjs');\n    if (existsSync(launcherPath) && existsSync(bridgePath)) {\n      const repoRoot = path.dirname(directOpencodeDir);\n      return {\n        opencodeDir: directOpencodeDir,\n        repoRoot,\n        launcherPath,\n        bridgePath,\n        dbDir: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'),\n        packageJsonPath: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'package.json'),\n      };\n    }\n\n    const parent = path.dirname(current);\n    if (parent === current) {\n      throw new CliProtocolError('Unable to locate .opencode/bin launcher assets from CLI path');\n    }\n    current = parent;\n  }\n}\n\nfunction loadBridge(paths: RepoPaths): BridgeModule {\n  const require = createRequire(import.meta.url);\n  return require(paths.bridgePath) as BridgeModule;\n}\n\nfunction readCliVersion(paths: RepoPaths): string {\n  const require = createRequire(import.meta.url);\n  const pkg = require(paths.packageJsonPath) as { version?: unknown };\n  return typeof pkg.version === 'string' ? pkg.version : '0.0.0';\n}\n\nfunction toKebabCommand(name: string): string {\n  return name.replace(/_/g, '-');\n}\n\nfunction toCamelCommand(name: string): string {\n  return name.replace(/_([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandAliases(name: string): string[] {\n  return Array.from(new Set([name, toKebabCommand(name), toCamelCommand(name)]));\n}\n\nfunction usageText(command?: string): string {\n  const tool = command ? getToolDefinition(command) : null;\n  if (tool) {\n    return `spec-memory ${tool.name}\n\nDescription:\n  ${tool.description}\n\nAliases:\n  ${commandAliases(tool.name).join(', ')}\n\nInput schema:\n${JSON.stringify(tool.inputSchema, null, 2)}`;\n  }\n\n  return `spec-memory - daemon-backed CLI for mk-spec-memory\n\nUsage:\n  spec-memory list-tools [--format json|text|jsonl] [--compact|--names-only]\n  spec-memory completion bash|zsh\n  spec-memory <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--session-id ID] [--warm-only]\n  spec-memory <tool_name> --param value [--another-param value]\n\nExamples:\n  spec-memory list-tools --format text\n  spec-memory list-tools --compact\n  spec-memory completion zsh\n  spec-memory memory_stats --format json\n  spec-memory memory_search --query \"gold query battery\" --limit 3\n  spec-memory memory_context --json '{\"input\":\"resume\", \"mode\":\"resume\"}'\n\nExit codes:\n  0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error\n\nExit 69 recovery:\n  - Missing or stale dist entrypoint: run npm run build --workspace=@spec-kit/mcp-server.\n    - Backend protocol version changed: rebuild the CLI and daemon from the same checkout, then update any pinned client.\n    - Socket path or daemon config mismatch: check SPECKIT_IPC_SOCKET_DIR, socket length, and daemon config before retrying.`;\n}\n\nfunction parseCompletionShell(raw: string): CompletionShell {\n  if (raw === 'bash' || raw === 'zsh') return raw;\n  throw new CliUsageError('completion shell must be one of: bash, zsh');\n}\n\nfunction normalizeName(value: string): string {\n  return value.replace(/[-_]/g, '').toLowerCase();\n}\n\nfunction toCamelCaseFlag(value: string): string {\n  return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandMap(): Map<string, ToolDefinition> {","lineStart":1,"lineEnd":260,"totalLines":1084,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","time":{"start":1781764118963,"end":1781764118967}},"metadata":{"openai":{"itemId":"fc_0b9f88f8add1abb6016a339016b55c8191bb9e2024203bb28c"}},"id":"prt_ed96ad9a5001CONj9JmKTg6Kfp","sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","messageID":"msg_ed96aa383001roOIL3jU7NQtqc"}}
{"type":"tool_use","timestamp":1781764119044,"sessionID":"ses_1269aaa39ffe90UiGOknaKBwn5","part":{"type":"tool","tool":"read","callID":"call_xT0Lmv6gxFPbZFHnBV9yPi7z","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","offset":260,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts</path>\n<type>file</type>\n<content>\n260: function commandMap(): Map<string, ToolDefinition> {\n261:   const map = new Map<string, ToolDefinition>();\n262:   for (const tool of TOOL_DEFINITIONS) {\n263:     for (const alias of commandAliases(tool.name)) {\n264:       const existing = map.get(alias);\n265:       if (existing && existing.name !== tool.name) {\n266:         throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n267:       }\n268:       map.set(alias, tool);\n269:     }\n270:   }\n271:   return map;\n272: }\n273: \n274: function getToolDefinition(command: string): ToolDefinition | null {\n275:   return commandMap().get(command) ?? null;\n276: }\n277: \n278: function inputPropertyNames(tool: ToolDefinition): string[] {\n279:   const schema = tool.inputSchema;\n280:   const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n281:     ? (schema as { readonly properties?: unknown }).properties\n282:     : null;\n283:   if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n284:   return Object.keys(properties);\n285: }\n286: \n287: function resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n288:   const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n289:   if (exact) return exact;\n290: \n291:   const normalized = normalizeName(rawFlag);\n292:   const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n293:   if (matched) return matched;\n294: \n295:   return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n296: }\n297: \n298: function parseValue(raw: string): unknown {\n299:   const trimmed = raw.trim();\n300:   if (trimmed === 'true') return true;\n301:   if (trimmed === 'false') return false;\n302:   if (trimmed === 'null') return null;\n303:   if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n304:     try {\n305:       return JSON.parse(trimmed) as unknown;\n306:     } catch (error: unknown) {\n307:       const message = error instanceof Error ? error.message : String(error);\n308:       throw new CliUsageError(`Invalid JSON value: ${message}`);\n309:     }\n310:   }\n311:   return raw;\n312: }\n313: \n314: function parsePositiveInteger(raw: string, flagName: string): number {\n315:   if (!/^\\d+$/.test(raw)) {\n316:     throw new CliUsageError(`${flagName} must be a positive integer`);\n317:   }\n318:   const value = Number.parseInt(raw, 10);\n319:   if (!Number.isFinite(value) || value <= 0) {\n320:     throw new CliUsageError(`${flagName} must be a positive integer`);\n321:   }\n322:   return value;\n323: }\n324: \n325: function parseFormat(raw: string): OutputFormat {\n326:   if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n327:   throw new CliUsageError('--format must be one of: json, text, jsonl');\n328: }\n329: \n330: function parseInlineBoolean(raw: string, flagName: string): boolean {\n331:   if (raw === 'true' || raw === '1') return true;\n332:   if (raw === 'false' || raw === '0') return false;\n333:   throw new CliUsageError(`${flagName} must be true or false`);\n334: }\n335: \n336: function readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n337:   const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n338:   if (inline) return { value: inline[1], nextIndex: index + 1 };\n339:   const value = tokens[index + 1];\n340:   if (value === undefined) {\n341:     throw new CliUsageError(`${flagName} requires a value`);\n342:   }\n343:   return { value, nextIndex: index + 2 };\n344: }\n345: \n346: function parseJsonObject(raw: string): Record<string, unknown> {\n347:   let parsed: unknown;\n348:   try {\n349:     parsed = JSON.parse(raw) as unknown;\n350:   } catch (error: unknown) {\n351:     const message = error instanceof Error ? error.message : String(error);\n352:     throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n353:   }\n354:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n355:     throw new CliUsageError('--json must be a JSON object');\n356:   }\n357:   return parsed as Record<string, unknown>;\n358: }\n359: \n360: function envFlagEnabled(name: string): boolean {\n361:   const raw = process.env[name];\n362:   if (raw === undefined || raw === null) return false;\n363:   return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n364: }\n365: \n366: function defaultWarmOnly(): boolean {\n367:   return envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_WARM_ONLY')\n368:     || envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME')\n369:     || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n370:     || envFlagEnabled('OPENCODE_PROMPT_TIME')\n371:     || envFlagEnabled('CODEX_PROMPT_TIME')\n372:     || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n373: }\n374: \n375: export function parseCliArgs(argv: string[]): ParsedCommand {\n376:   const command = argv[0];\n377:   const warmOnlyDefault = defaultWarmOnly();\n378:   if (!command || command === '--help' || command === '-h') {\n379:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n380:   }\n381:   if (command === '--version' || command === '-v') {\n382:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n383:   }\n384: \n385:   let format: OutputFormat = 'json';\n386:   let timeoutMs = DEFAULT_TIMEOUT_MS;\n387:   let sessionId: string | undefined;\n388:   let warmOnly = warmOnlyDefault;\n389:   let toolListMode: ToolListMode = 'full';\n390:   let completionShell: CompletionShell | undefined;\n391:   let jsonPayload: Record<string, unknown> | null = null;\n392:   const tool = getToolDefinition(command);\n393:   const parsedArgs: Record<string, unknown> = {};\n394:   const tokens = argv.slice(1);\n395:   let index = 0;\n396: \n397:   while (index < tokens.length) {\n398:     const token = tokens[index];\n399:     if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n400:       completionShell = parseCompletionShell(token);\n401:       index += 1;\n402:       continue;\n403:     }\n404:     if (!token.startsWith('--')) {\n405:       throw new CliUsageError(`Unexpected positional argument: ${token}`);\n406:     }\n407:     const rawFlag = token.slice(2).split('=', 1)[0];\n408:     const option = `--${rawFlag}`;\n409: \n410:     if (rawFlag === 'help' || rawFlag === 'h') {\n411:       return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n412:     }\n413:     if (rawFlag === 'format') {\n414:       const read = readOptionValue(tokens, index, option);\n415:       format = parseFormat(read.value);\n416:       index = read.nextIndex;\n417:       continue;\n418:     }\n419:     if (rawFlag === 'timeout-ms') {\n420:       const read = readOptionValue(tokens, index, option);\n421:       timeoutMs = parsePositiveInteger(read.value, option);\n422:       index = read.nextIndex;\n423:       continue;\n424:     }\n425:     if (rawFlag === 'session-id') {\n426:       const read = readOptionValue(tokens, index, option);\n427:       sessionId = read.value;\n428:       index = read.nextIndex;\n429:       continue;\n430:     }\n431:     if (rawFlag === 'warm-only') {\n432:       const inline = token.match(/^--[^=]+=(.*)$/);\n433:       warmOnly = inline ? parseInlineBoolean(inline[1], option) : true;\n434:       index += 1;\n435:       continue;\n436:     }\n437:     if (rawFlag === 'no-warm-only') {\n438:       warmOnly = false;\n439:       index += 1;\n440:       continue;\n441:     }\n442:     if (rawFlag === 'compact') {\n443:       toolListMode = 'compact';\n444:       index += 1;\n445:       continue;\n446:     }\n447:     if (rawFlag === 'names-only') {\n448:       toolListMode = 'names-only';\n449:       index += 1;\n450:       continue;\n451:     }\n452:     if (rawFlag === 'json') {\n453:       const read = readOptionValue(tokens, index, option);\n454:       jsonPayload = parseJsonObject(read.value);\n455:       index = read.nextIndex;\n456:       continue;\n457:     }\n458: \n459:     if (!tool) {\n460:       throw new CliUsageError(`Unknown command: ${command}`);\n461:     }\n462: \n463:     const propertyName = resolvePropertyName(rawFlag, tool);\n464:     const inline = token.match(/^--[^=]+=(.*)$/);\n465:     if (inline) {\n466:       parsedArgs[propertyName] = parseValue(inline[1]);\n467:       index += 1;\n468:       continue;\n469:     }\n470: \n471:     const next = tokens[index + 1];\n472:     if (next === undefined || next.startsWith('--')) {\n473:       parsedArgs[propertyName] = true;\n474:       index += 1;\n475:       continue;\n476:     }\n477:     parsedArgs[propertyName] = parseValue(next);\n478:     index += 2;\n479:   }\n480: \n481:   if (jsonPayload && Object.keys(parsedArgs).length > 0) {\n482:     throw new CliUsageError('--json cannot be combined with per-parameter flags');\n483:   }\n484: \n485:   return {\n486:     command,\n487:     format,\n488:     timeoutMs,\n489:     sessionId,\n490:     warmOnly,\n491:     toolListMode,\n492:     completionShell,\n493:     