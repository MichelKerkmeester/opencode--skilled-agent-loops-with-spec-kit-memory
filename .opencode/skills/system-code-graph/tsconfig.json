{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "verbatimModuleSyntax": true,
    "rootDir": "./mcp_server",
    "outDir": "./mcp_server/dist",
    "tsBuildInfoFile": "./mcp_server/dist/tsconfig.tsbuildinfo",
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "include": [
    "mcp_server/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "mcp_server/dist",
    "mcp_server/tests/**/*.ts",
    "mcp_server/stress_test/**/*.ts",
    "mcp_server/**/__tests__/**/*.ts",
    "**/*.test.ts",
    "**/*.vitest.ts",
    "**/*.test-d.ts"
  ]
}
