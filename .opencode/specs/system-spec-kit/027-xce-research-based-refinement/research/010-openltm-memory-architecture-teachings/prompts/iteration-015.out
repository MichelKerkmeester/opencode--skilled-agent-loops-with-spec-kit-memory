 }\n49: \n50: export interface Config {\n51:   ltm: LtmConfig;\n52:   server: ServerConfig;\n53:   sync: SyncConfig;\n54:   embeddings: EmbeddingsConfig;\n55: }\n56: \n57: // ── Defaults ───────────────────────────────────────────────────────────────────\n58: \n59: const DEFAULT_EMBEDDINGS: EmbeddingsConfig = {\n60:   provider: \"disabled\",\n61:   confidenceThreshold: 0.6,\n62: };\n63: \n64: const DEFAULTS: Config = {\n65:   ltm: {\n66:     dbPath: getDbPath(),\n67:     decayEnabled: true,\n68:     injectTopN: 15,\n69:     autoRelate: true,\n70:     graphReasoning: false,\n71:     evaluateSessionLlm: false,\n72:     semanticFallback: true,\n73:     gitLearnEnabled: false,\n74:     gitLearnMinDiffChars: 200,\n75:     gitLearnFileFilter: [],\n76:     gitLearnIgnorePatterns: [],\n77:     autoRecall: true,\n78:   },\n79:   server: {\n80:     apiPort: 7331,\n81:     uiPort: 7332,\n82:   },\n83:   sync: {\n84:     enabled: false,\n85:     provider: null,\n86:   },\n87:   embeddings: DEFAULT_EMBEDDINGS,\n88: };\n89: \n90: // ── Validation ──────────────────────────────────────────────────────────────\n91: \n92: function validateConfig(raw: Record<string, unknown>): { valid: boolean; errors: string[] } {\n93:   const errors: string[] = [];\n94:   if (raw && typeof raw === \"object\") {\n95:     const ltm = raw[\"ltm\"] as Record<string, unknown> | undefined;\n96:     if (ltm) {\n97:       if (\"decayEnabled\" in ltm && typeof ltm[\"decayEnabled\"] !== \"boolean\") errors.push(\"ltm.decayEnabled: must be boolean\");\n98:       if (\"injectTopN\" in ltm && typeof ltm[\"injectTopN\"] !== \"number\") errors.push(\"ltm.injectTopN: must be number\");\n99:       if (\"autoRecall\" in ltm && typeof ltm[\"autoRecall\"] !== \"boolean\") errors.push(\"ltm.autoRecall: must be boolean\");\n100:       if (\"graphReasoning\" in ltm && typeof ltm[\"graphReasoning\"] !== \"boolean\") errors.push(\"ltm.graphReasoning: must be boolean\");\n101:       if (\"autoRelate\" in ltm && typeof ltm[\"autoRelate\"] !== \"boolean\") errors.push(\"ltm.autoRelate: must be boolean\");\n102:     }\n103:   }\n104:   return { valid: errors.length === 0, errors };\n105: }\n106: \n107: // ── Loader ─────────────────────────────────────────────────────────────────────\n108: \n109: export function readConfigSync(): Partial<Config> {\n110:   const configPath = getConfigPath();\n111:   if (!existsSync(configPath)) return {};\n112:   try { return JSON.parse(readFileSync(configPath, \"utf8\")) as Partial<Config>; } \n113:   catch { return {}; }\n114: }\n115: \n116: export async function loadConfig(): Promise<Config> {\n117:   const configPath = getConfigPath();\n118:   if (!existsSync(configPath)) return { ...DEFAULTS, embeddings: { ...DEFAULT_EMBEDDINGS } };\n119: \n120:   let raw: Record<string, unknown>;\n121:   try { raw = JSON.parse(await Bun.file(configPath).text()) as Record<string, unknown>; }\n122:   catch { return { ...DEFAULTS, embeddings: { ...DEFAULT_EMBEDDINGS } }; }\n123: \n124:   const { valid, errors } = validateConfig(raw);\n125:   if (!valid) process.stderr.write(`[config] Validation: ${errors.join(\", \")}\\n`);\n126: \n127:   const ltm = (raw[\"ltm\"] ?? {}) as Partial<LtmConfig>;\n128:   const server = (raw[\"server\"] ?? {}) as Partial<ServerConfig>;\n129:   const sync = (raw[\"sync\"] ?? {}) as Partial<SyncConfig>;\n130:   const emb = (raw[\"embeddings\"] ?? {}) as Partial<EmbeddingsConfig>;\n131: \n132:   // Resolve apiKey from env when not set in config\n133:   const resolvedApiKey = emb.apiKey\n134:     ?? (emb.provider === \"gemini\" ? process.env[\"GEMINI_API_KEY\"] : undefined)\n135:     ?? (emb.provider === \"openai\" ? process.env[\"OPENAI_API_KEY\"] : undefined)\n136:     ?? (emb.provider === \"ollama\" ? process.env[\"OLLAMA_API_KEY\"] : undefined);\n137: \n138:   return {\n139:     ltm: {\n140:       dbPath: ltm.dbPath ?? DEFAULTS.ltm.dbPath,\n141:       decayEnabled: ltm.decayEnabled ?? DEFAULTS.ltm.decayEnabled,\n142:       injectTopN: ltm.injectTopN ?? DEFAULTS.ltm.injectTopN,\n143:       autoRelate: ltm.autoRelate ?? DEFAULTS.ltm.autoRelate,\n144:       graphReasoning: ltm.graphReasoning ?? DEFAULTS.ltm.graphReasoning,\n145:       evaluateSessionLlm: ltm.evaluateSessionLlm ?? DEFAULTS.ltm.evaluateSessionLlm,\n146:       semanticFallback: ltm.semanticFallback ?? DEFAULTS.ltm.semanticFallback,\n147:       gitLearnEnabled: ltm.gitLearnEnabled ?? DEFAULTS.ltm.gitLearnEnabled,\n148:       gitLearnMinDiffChars: ltm.gitLearnMinDiffChars ?? DEFAULTS.ltm.gitLearnMinDiffChars,\n149:       gitLearnFileFilter: ltm.gitLearnFileFilter ?? DEFAULTS.ltm.gitLearnFileFilter,\n150:       gitLearnIgnorePatterns: ltm.gitLearnIgnorePatterns ?? DEFAULTS.ltm.gitLearnIgnorePatterns,\n151:       autoRecall: ltm.autoRecall ?? DEFAULTS.ltm.autoRecall,\n152:     },\n153:     server: { apiPort: server.apiPort ?? DEFAULTS.server.apiPort, uiPort: server.uiPort ?? DEFAULTS.server.uiPort },\n154:     sync: { enabled: sync.enabled ?? DEFAULTS.sync.enabled, provider: sync.provider ?? DEFAULTS.sync.provider },\n155:     embeddings: {\n156:       provider: emb.provider ?? DEFAULT_EMBEDDINGS.provider,\n157:       apiKey: resolvedApiKey,\n158:       model: emb.model,\n159:       baseUrl: emb.baseUrl,\n160:       confidenceThreshold: emb.confidenceThreshold ?? DEFAULT_EMBEDDINGS.confidenceThreshold,\n161:     },\n162:   };\n163: }\n\n(End of file - total 163 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\n/**\n * config.ts — Loader and validator for ~/.claude/config.json\n */\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { existsSync, readFileSync } from \"fs\";\nimport { getDbPath } from \"./paths.js\";\n\n// Lazy-computed config path\nfunction getConfigPath(): string {\n  return join(homedir(), \".claude\", \"config.json\");\n}\n\n// ── Types ─────────────────────────────────────────────────────────────────────\n\nexport interface EmbeddingsConfig {\n  provider: \"gemini\" | \"openai\" | \"ollama\" | \"disabled\";\n  apiKey?: string;\n  model?: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/src/config.ts","text":"#!/usr/bin/env bun\n/**\n * config.ts — Loader and validator for ~/.claude/config.json\n */\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport { existsSync, readFileSync } from \"fs\";\nimport { getDbPath } from \"./paths.js\";\n\n// Lazy-computed config path\nfunction getConfigPath(): string {\n  return join(homedir(), \".claude\", \"config.json\");\n}\n\n// ── Types ─────────────────────────────────────────────────────────────────────\n\nexport interface EmbeddingsConfig {\n  provider: \"gemini\" | \"openai\" | \"ollama\" | \"disabled\";\n  apiKey?: string;\n  model?: string;\n  baseUrl?: string;\n  confidenceThreshold: number;\n}\n\nexport interface LtmConfig {\n  dbPath: string;\n  decayEnabled: boolean;\n  injectTopN: number;\n  autoRelate: boolean;\n  graphReasoning: boolean;\n  evaluateSessionLlm: boolean;\n  semanticFallback: boolean;\n  gitLearnEnabled: boolean;\n  gitLearnMinDiffChars: number;\n  gitLearnFileFilter: string[];\n  gitLearnIgnorePatterns: string[];\n  autoRecall: boolean;\n}\n\nexport interface ServerConfig {\n  apiPort: number;\n  uiPort: number;\n}\n\nexport interface SyncConfig {\n  enabled: boolean;\n  provider: \"s3\" | \"r2\" | null;\n}\n\nexport interface Config {\n  ltm: LtmConfig;\n  server: ServerConfig;\n  sync: SyncConfig;\n  embeddings: EmbeddingsConfig;\n}\n\n// ── Defaults ───────────────────────────────────────────────────────────────────\n\nconst DEFAULT_EMBEDDINGS: EmbeddingsConfig = {\n  provider: \"disabled\",\n  confidenceThreshold: 0.6,\n};\n\nconst DEFAULTS: Config = {\n  ltm: {\n    dbPath: getDbPath(),\n    decayEnabled: true,\n    injectTopN: 15,\n    autoRelate: true,\n    graphReasoning: false,\n    evaluateSessionLlm: false,\n    semanticFallback: true,\n    gitLearnEnabled: false,\n    gitLearnMinDiffChars: 200,\n    gitLearnFileFilter: [],\n    gitLearnIgnorePatterns: [],\n    autoRecall: true,\n  },\n  server: {\n    apiPort: 7331,\n    uiPort: 7332,\n  },\n  sync: {\n    enabled: false,\n    provider: null,\n  },\n  embeddings: DEFAULT_EMBEDDINGS,\n};\n\n// ── Validation ──────────────────────────────────────────────────────────────\n\nfunction validateConfig(raw: Record<string, unknown>): { valid: boolean; errors: string[] } {\n  const errors: string[] = [];\n  if (raw && typeof raw === \"object\") {\n    const ltm = raw[\"ltm\"] as Record<string, unknown> | undefined;\n    if (ltm) {\n      if (\"decayEnabled\" in ltm && typeof ltm[\"decayEnabled\"] !== \"boolean\") errors.push(\"ltm.decayEnabled: must be boolean\");\n      if (\"injectTopN\" in ltm && typeof ltm[\"injectTopN\"] !== \"number\") errors.push(\"ltm.injectTopN: must be number\");\n      if (\"autoRecall\" in ltm && typeof ltm[\"autoRecall\"] !== \"boolean\") errors.push(\"ltm.autoRecall: must be boolean\");\n      if (\"graphReasoning\" in ltm && typeof ltm[\"graphReasoning\"] !== \"boolean\") errors.push(\"ltm.graphReasoning: must be boolean\");\n      if (\"autoRelate\" in ltm && typeof ltm[\"autoRelate\"] !== \"boolean\") errors.push(\"ltm.autoRelate: must be boolean\");\n    }\n  }\n  return { valid: errors.length === 0, errors };\n}\n\n// ── Loader ─────────────────────────────────────────────────────────────────────\n\nexport function readConfigSync(): Partial<Config> {\n  const configPath = getConfigPath();\n  if (!existsSync(configPath)) return {};\n  try { return JSON.parse(readFileSync(configPath, \"utf8\")) as Partial<Config>; } \n  catch { return {}; }\n}\n\nexport async function loadConfig(): Promise<Config> {\n  const configPath = getConfigPath();\n  if (!existsSync(configPath)) return { ...DEFAULTS, embeddings: { ...DEFAULT_EMBEDDINGS } };\n\n  let raw: Record<string, unknown>;\n  try { raw = JSON.parse(await Bun.file(configPath).text()) as Record<string, unknown>; }\n  catch { return { ...DEFAULTS, embeddings: { ...DEFAULT_EMBEDDINGS } }; }\n\n  const { valid, errors } = validateConfig(raw);\n  if (!valid) process.stderr.write(`[config] Validation: ${errors.join(\", \")}\\n`);\n\n  const ltm = (raw[\"ltm\"] ?? {}) as Partial<LtmConfig>;\n  const server = (raw[\"server\"] ?? {}) as Partial<ServerConfig>;\n  const sync = (raw[\"sync\"] ?? {}) as Partial<SyncConfig>;\n  const emb = (raw[\"embeddings\"] ?? {}) as Partial<EmbeddingsConfig>;\n\n  // Resolve apiKey from env when not set in config\n  const resolvedApiKey = emb.apiKey\n    ?? (emb.provider === \"gemini\" ? process.env[\"GEMINI_API_KEY\"] : undefined)\n    ?? (emb.provider === \"openai\" ? process.env[\"OPENAI_API_KEY\"] : undefined)\n    ?? (emb.provider === \"ollama\" ? process.env[\"OLLAMA_API_KEY\"] : undefined);\n\n  return {\n    ltm: {\n      dbPath: ltm.dbPath ?? DEFAULTS.ltm.dbPath,\n      decayEnabled: ltm.decayEnabled ?? DEFAULTS.ltm.decayEnabled,\n      injectTopN: ltm.injectTopN ?? DEFAULTS.ltm.injectTopN,\n      autoRelate: ltm.autoRelate ?? DEFAULTS.ltm.autoRelate,\n      graphReasoning: ltm.graphReasoning ?? DEFAULTS.ltm.graphReasoning,\n      evaluateSessionLlm: ltm.evaluateSessionLlm ?? DEFAULTS.ltm.evaluateSessionLlm,\n      semanticFallback: ltm.semanticFallback ?? DEFAULTS.ltm.semanticFallback,\n      gitLearnEnabled: ltm.gitLearnEnabled ?? DEFAULTS.ltm.gitLearnEnabled,\n      gitLearnMinDiffChars: ltm.gitLearnMinDiffChars ?? DEFAULTS.ltm.gitLearnMinDiffChars,\n      gitLearnFileFilter: ltm.gitLearnFileFilter ?? DEFAULTS.ltm.gitLearnFileFilter,\n      gitLearnIgnorePatterns: ltm.gitLearnIgnorePatterns ?? DEFAULTS.ltm.gitLearnIgnorePatterns,\n      autoRecall: ltm.autoRecall ?? DEFAULTS.ltm.autoRecall,\n    },\n    server: { apiPort: server.apiPort ?? DEFAULTS.server.apiPort, uiPort: server.uiPort ?? DEFAULTS.server.uiPort },\n    sync: { enabled: sync.enabled ?? DEFAULTS.sync.enabled, provider: sync.provider ?? DEFAULTS.sync.provider },\n    embeddings: {\n      provider: emb.provider ?? DEFAULT_EMBEDDINGS.provider,\n      apiKey: resolvedApiKey,\n      model: emb.model,\n      baseUrl: emb.baseUrl,\n      confidenceThreshold: emb.confidenceThreshold ?? DEFAULT_EMBEDDINGS.confidenceThreshold,\n    },\n  };\n}","lineStart":1,"lineEnd":163,"totalLines":163,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/src/config.ts","time":{"start":1780929688581,"end":1780929688589}},"metadata":{"openai":{"itemId":"fc_0f95d4e412be0502016a26d4987e2081918c92e256573ed481"}},"id":"prt_ea7ae73eb001e9fn9v4bZQGtiL","sessionID":"ses_15852ff63ffejJtpJJJcia0535","messageID":"msg_ea7ae5350001WvO9w6bRemI030"}}
