     2	// MODULE: Advisor Scorer Benchmark
     3	// ───────────────────────────────────────────────────────────────
     4	
     5	import { performance } from 'node:perf_hooks';
     6	import { existsSync } from 'node:fs';
     7	import { resolve } from 'node:path';
     8	import { fileURLToPath } from 'node:url';
     9	import { dirname } from 'node:path';
    10	
    11	import { scoreAdvisorPrompt } from '../lib/scorer/fusion.js';
    12	import { loadAdvisorProjection } from '../lib/scorer/projection.js';
    13	import { findAdvisorWorkspaceRoot } from '../lib/utils/workspace-root.js';
    14	
    15	const CACHE_HIT_P95_GATE_MS = 50;
    16	const UNCACHED_P95_GATE_MS = 60;
    17	
    18	function percentile(values: readonly number[], pct: number): number {
    19	  const sorted = [...values].sort((left, right) => left - right);
    20	  const index = Math.min(sorted.length - 1, Math.ceil(sorted.length * pct) - 1);
    21	  return Number((sorted[index] ?? 0).toFixed(3));
    22	}
    23	
    24	function workspaceRoot(): string {
    25	  const start = dirname(fileURLToPath(import.meta.url));
    26	  const sentinel = '.opencode/skills/system-spec-kit/SKILL.md';
    27	  const candidate = findAdvisorWorkspaceRoot(start, { maxDepth: 12, sentinel });
    28	  return existsSync(resolve(candidate, sentinel))
    29	    ? candidate
    30	    : resolve(start, '..', '..', '..');
    31	}
    32	
    33	function runSeries(count: number, fn: () => void): number[] {
    34	  const durations: number[] = [];
    35	  for (let index = 0; index < count; index += 1) {
    36	    const started = performance.now();
    37	    fn();
    38	    durations.push(performance.now() - started);
    39	  }
    40	  return durations;
    41	}
    42	
    43	export function runScorerBench(root = workspaceRoot()): {
    44	  readonly cacheHitP95Ms: number;
    45	  readonly uncachedP95Ms: number;
    46	  readonly passed: boolean;
    47	} {
    48	  const prompt = 'Implement a Vitest for gate-3-classifier.ts and run targeted tests.';
    49	  const projection = loadAdvisorProjection(root);
    50	  const cacheHit = runSeries(150, () => {
    51	    scoreAdvisorPrompt(prompt, { workspaceRoot: root, projection });
    52	  });
    53	  const uncached = runSeries(75, () => {
    54	    scoreAdvisorPrompt(`${prompt} ${Math.random().toString(16).slice(2)}`, { workspaceRoot: root });
    55	  });
    56	  const cacheHitP95Ms = percentile(cacheHit, 0.95);
    57	  const uncachedP95Ms = percentile(uncached, 0.95);
    58	  return {
    59	    cacheHitP95Ms,
    60	    uncachedP95Ms,
    61	    passed: cacheHitP95Ms <= CACHE_HIT_P95_GATE_MS && uncachedP95Ms <= UNCACHED_P95_GATE_MS,
    62	  };
    63	}
    64	
    65	const invoked = process.argv[1] ? resolve(process.argv[1]) === fileURLToPath(import.meta.url) : false;
    66	if (invoked) {
    67	  const report = runScorerBench();
    68	  console.log(`advisor-scorer-bench ${JSON.stringify(report)}`);
    69	  if (!report.passed) {
    70	    process.exitCode = 1;
    71	  }
    72	}

