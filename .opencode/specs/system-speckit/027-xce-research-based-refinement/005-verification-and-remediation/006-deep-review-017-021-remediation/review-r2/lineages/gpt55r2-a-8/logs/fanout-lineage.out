{"type":"text","timestamp":1781763854338,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"id":"prt_ed966bdd80017CH35KAtPQHrtE","messageID":"msg_ed96693ac001prVrpSijTbxJQl","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","type":"text","text":"Confirmed one security-class finding: Stage 2’s retrieval-rescue path can reintroduce unscoped rows after Stage 1 applies tenant/user/agent filtering. I’m checking adjacent fallback paths for the same scope-loss pattern before writing the iteration artifacts.","time":{"start":1781763849688,"end":1781763854336},"metadata":{"openai":{"itemId":"msg_0b65030751c38a88016a338f09a978819183e32eb69177ed3b","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1781763854414,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_aNUbl1zeC7SxWnNDTWa8Djd4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","offset":1155,"limit":75},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts</path>\n<type>file</type>\n<content>\n1155:     const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n1156:     let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n1157: \n1158:     // Community search fallback — inject community members on weak results\n1159:     let communityFallbackApplied = false;\n1160:     const shouldRunCommunitySearch = (\n1161:       isDualRetrievalEnabled() &&\n1162:       isCommunitySearchFallbackEnabled() &&\n1163:       effectiveQuery.length > 0 &&\n1164:       (retrievalLevel === 'global' || retrievalLevel === 'auto')\n1165:     );\n1166:     if (shouldRunCommunitySearch) {\n1167:       const isWeakResult = resultsForFormatting.length === 0 ||\n1168:         (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n1169:       if (isWeakResult) {\n1170:         try {\n1171:           const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n1172:           if (communityResults.totalMemberIds.length > 0) {\n1173:             // Fetch the actual memory rows for community member IDs\n1174:             const memberIds = communityResults.totalMemberIds.slice(0, 20);\n1175:             const placeholders = memberIds.map(() => '?').join(', ');\n1176:             const db = requireDb();\n1177:             const rawMemberRows = db.prepare(`\n1178:               SELECT id, title, similarity, content, file_path, anchor_id, document_type,\n1179:                      importance_tier, context_type, quality_score, created_at,\n1180:                      tenant_id, user_id, agent_id\n1181:               FROM memory_index\n1182:               WHERE id IN (${placeholders})\n1183:             `).all(...memberIds) as Array<Record<string, unknown> & { id: number }>;\n1184: \n1185:             // Apply governed retrieval scope to the community fallback so it cannot\n1186:             // bypass the tenant/user/agent boundary the canonical pipeline enforces.\n1187:             // sessionId is deliberately excluded — it is a dedup/continuity key, not\n1188:             // a row-access boundary. Unscoped (single-user) callers are unaffected.\n1189:             const hasGovernanceScope = Boolean(\n1190:               normalizedScope.tenantId || normalizedScope.userId || normalizedScope.agentId,\n1191:             );\n1192:             const memberRows = hasGovernanceScope\n1193:               ? filterRowsByScope(rawMemberRows, {\n1194:                   tenantId: normalizedScope.tenantId,\n1195:                   userId: normalizedScope.userId,\n1196:                   agentId: normalizedScope.agentId,\n1197:                 })\n1198:               : rawMemberRows;\n1199: \n1200:             if (memberRows.length > 0) {\n1201:               // Calibrate score from community match quality, bounded below pipeline threshold\n1202:               const communityScoreScale = 0.02; // aligns with pipeline's minimum quality floor\n1203:               const avgMatchScore = communityResults.results.length > 0\n1204:                 ? communityResults.results.reduce((sum, r) => sum + r.matchScore, 0) / communityResults.results.length\n1205:                 : 0.5;\n1206:               const calibratedScore = Math.max(0.001, avgMatchScore * communityScoreScale);\n1207:               // Mark community-sourced results and assign calibrated score\n1208:               const communityRows = memberRows.map((row) => ({\n1209:                 ...row,\n1210:                 similarity: typeof row.similarity === 'number' ? row.similarity : 0.5,\n1211:                 score: calibratedScore,\n1212:                 _communityFallback: true,\n1213:               }));\n1214:               // Merge: append community results not already in pipeline results\n1215:               const existingIds = new Set(resultsForFormatting.map((r) => (r as Record<string, unknown>).id as number));\n1216:               const newRows = communityRows.filter((r) => !existingIds.has(r.id));\n1217:               if (newRows.length > 0) {\n1218:                 resultsForFormatting = [...resultsForFormatting, ...newRows as unknown as SessionAwareResult[]];\n1219:                 communityFallbackApplied = true;\n1220:               }\n1221:             }\n1222:           }\n1223:         } catch (err: unknown) {\n1224:           const msg = err instanceof Error ? err.message : String(err);\n1225:           console.warn(`[memory-search] Community search fallback failed (fail-open): ${msg}`);\n1226:         }\n1227:       }\n1228:     }\n1229: \n\n(Showing lines 1155-1229 of 1788. Use offset=1230 to continue.)\n</content>","metadata":{"preview":"    const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n    let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n\n    // Community search fallback — inject community members on weak results\n    let communityFallbackApplied = false;\n    const shouldRunCommunitySearch = (\n      isDualRetrievalEnabled() &&\n      isCommunitySearchFallbackEnabled() &&\n      effectiveQuery.length > 0 &&\n      (retrievalLevel === 'global' || retrievalLevel === 'auto')\n    );\n    if (shouldRunCommunitySearch) {\n      const isWeakResult = resultsForFormatting.length === 0 ||\n        (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n      if (isWeakResult) {\n        try {\n          const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n          if (communityResults.totalMemberIds.length > 0) {\n            // Fetch the actual memory rows for community member IDs\n            const memberIds = communityResults.totalMemberIds.slice(0, 20);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"    const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n    let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n\n    // Community search fallback — inject community members on weak results\n    let communityFallbackApplied = false;\n    const shouldRunCommunitySearch = (\n      isDualRetrievalEnabled() &&\n      isCommunitySearchFallbackEnabled() &&\n      effectiveQuery.length > 0 &&\n      (retrievalLevel === 'global' || retrievalLevel === 'auto')\n    );\n    if (shouldRunCommunitySearch) {\n      const isWeakResult = resultsForFormatting.length === 0 ||\n        (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n      if (isWeakResult) {\n        try {\n          const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n          if (communityResults.totalMemberIds.length > 0) {\n            // Fetch the actual memory rows for community member IDs\n            const memberIds = communityResults.totalMemberIds.slice(0, 20);\n            const placeholders = memberIds.map(() => '?').join(', ');\n            const db = requireDb();\n            const rawMemberRows = db.prepare(`\n              SELECT id, title, similarity, content, file_path, anchor_id, document_type,\n                     importance_tier, context_type, quality_score, created_at,\n                     tenant_id, user_id, agent_id\n              FROM memory_index\n              WHERE id IN (${placeholders})\n            `).all(...memberIds) as Array<Record<string, unknown> & { id: number }>;\n\n            // Apply governed retrieval scope to the community fallback so it cannot\n            // bypass the tenant/user/agent boundary the canonical pipeline enforces.\n            // sessionId is deliberately excluded — it is a dedup/continuity key, not\n            // a row-access boundary. Unscoped (single-user) callers are unaffected.\n            const hasGovernanceScope = Boolean(\n              normalizedScope.tenantId || normalizedScope.userId || normalizedScope.agentId,\n            );\n            const memberRows = hasGovernanceScope\n              ? filterRowsByScope(rawMemberRows, {\n                  tenantId: normalizedScope.tenantId,\n                  userId: normalizedScope.userId,\n                  agentId: normalizedScope.agentId,\n                })\n              : rawMemberRows;\n\n            if (memberRows.length > 0) {\n              // Calibrate score from community match quality, bounded below pipeline threshold\n              const communityScoreScale = 0.02; // aligns with pipeline's minimum quality floor\n              const avgMatchScore = communityResults.results.length > 0\n                ? communityResults.results.reduce((sum, r) => sum + r.matchScore, 0) / communityResults.results.length\n                : 0.5;\n              const calibratedScore = Math.max(0.001, avgMatchScore * communityScoreScale);\n              // Mark community-sourced results and assign calibrated score\n              const communityRows = memberRows.map((row) => ({\n                ...row,\n                similarity: typeof row.similarity === 'number' ? row.similarity : 0.5,\n                score: calibratedScore,\n                _communityFallback: true,\n              }));\n              // Merge: append community results not already in pipeline results\n              const existingIds = new Set(resultsForFormatting.map((r) => (r as Record<string, unknown>).id as number));\n              const newRows = communityRows.filter((r) => !existingIds.has(r.id));\n              if (newRows.length > 0) {\n                resultsForFormatting = [...resultsForFormatting, ...newRows as unknown as SessionAwareResult[]];\n                communityFallbackApplied = true;\n              }\n            }\n          }\n        } catch (err: unknown) {\n          const msg = err instanceof Error ? err.message : String(err);\n          console.warn(`[memory-search] Community search fallback failed (fail-open): ${msg}`);\n        }\n      }\n    }\n","lineStart":1155,"lineEnd":1229,"totalLines":1788,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781763854407,"end":1781763854413}},"metadata":{"openai":{"itemId":"fc_0b65030751c38a88016a338f0e49b0819181328cb284bf278e"}},"id":"prt_ed966d00f001UPqLgN9oZ55Dc1","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96693ac001prVrpSijTbxJQl"}}
{"type":"tool_use","timestamp":1781763854448,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_8b2LouWenrmBCQOCumDBkDU1","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/community-search.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/community-search.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Community Search\n3: // ───────────────────────────────────────────────────────────────\n4: // Community-level search as fallback channel.\n5: //\n6: // When primary search returns weak or zero results, this module\n7: // searches community summaries by keyword matching and returns\n8: // matching community member IDs for injection into the pipeline.\n9: //\n10: // FEATURE FLAG: SPECKIT_COMMUNITY_SEARCH_FALLBACK (default ON, graduated)\n11: \n12: import type Database from 'better-sqlite3';\n13: \n14: import { isCommunitySearchFallbackEnabled, isCommunitySummariesEnabled } from './search-flags.js';\n15: \n16: // -- Types --\n17: \n18: export interface CommunitySearchResult {\n19:   communityId: number;\n20:   summary: string;\n21:   memberIds: number[];\n22:   memberCount: number;\n23:   matchScore: number;\n24: }\n25: \n26: export interface CommunitySearchOutput {\n27:   results: CommunitySearchResult[];\n28:   totalMemberIds: number[];\n29:   source: 'community_fallback';\n30: }\n31: \n32: // -- Internal helpers --\n33: \n34: function tableExists(db: Database.Database, tableName: string): boolean {\n35:   const row = db.prepare(`\n36:     SELECT name FROM sqlite_master\n37:     WHERE type = 'table' AND name = ?\n38:   `).get(tableName) as { name?: string } | undefined;\n39:   return row?.name === tableName;\n40: }\n41: \n42: function parseMemberIds(memberIdsJson: string): number[] {\n43:   try {\n44:     const parsed = JSON.parse(memberIdsJson) as unknown;\n45:     if (!Array.isArray(parsed)) return [];\n46:     return parsed\n47:       .map((v) => Number(v))\n48:       .filter((v) => Number.isFinite(v));\n49:   } catch (error: unknown) {\n50:     const message = error instanceof Error ? error.message : String(error);\n51:     console.warn(`[community-search] parseMemberIds failed (fail-open): ${message}`);\n52:     return [];\n53:   }\n54: }\n55: \n56: /**\n57:  * Score a community summary against query terms.\n58:  * Returns 0-1 based on fraction of query terms found in the summary.\n59:  */\n60: function scoreSummary(summary: string, queryTerms: string[]): number {\n61:   if (queryTerms.length === 0) return 0;\n62:   const lowerSummary = summary.toLowerCase();\n63:   let matches = 0;\n64:   for (const term of queryTerms) {\n65:     if (lowerSummary.includes(term)) matches++;\n66:   }\n67:   return matches / queryTerms.length;\n68: }\n69: \n70: /**\n71:  * Extract meaningful search terms from a query string.\n72:  * Filters out common stop words.\n73:  */\n74: function extractQueryTerms(query: string): string[] {\n75:   const stopWords = new Set([\n76:     'a', 'an', 'the', 'in', 'on', 'at', 'to', 'for', 'of', 'with',\n77:     'by', 'from', 'and', 'or', 'not', 'is', 'are', 'was', 'were',\n78:     'be', 'been', 'has', 'have', 'had', 'do', 'does', 'did', 'will',\n79:     'would', 'could', 'should', 'may', 'might', 'can', 'this', 'that',\n80:     'it', 'its', 'my', 'your', 'our', 'their', 'all', 'any', 'some',\n81:   ]);\n82:   return query\n83:     .toLowerCase()\n84:     .split(/\\s+/)\n85:     .filter((w) => w.length > 1 && !stopWords.has(w));\n86: }\n87: \n88: // -- Public API --\n89: \n90: /**\n91:  * Search community summaries by keyword matching.\n92:  *\n93:  * Returns communities whose summaries match the query terms, sorted by match\n94:  * score. Used as a fallback channel when primary search returns weak results.\n95:  *\n96:  * @param query - The search query string\n97:  * @param db - SQLite database instance\n98:  * @param limit - Maximum communities to return (default 5)\n99:  * @returns Community search results with member IDs for pipeline injection\n100:  */\n101: export function searchCommunities(\n102:   query: string,\n103:   db: Database.Database,\n104:   limit: number = 5,\n105: ): CommunitySearchOutput {\n106:   const emptyOutput: CommunitySearchOutput = {\n107:     results: [],\n108:     totalMemberIds: [],\n109:     source: 'community_fallback',\n110:   };\n111: \n112:   if (!isCommunitySearchFallbackEnabled() || !isCommunitySummariesEnabled()) {\n113:     return emptyOutput;\n114:   }\n115: \n116:   try {\n117:     if (!tableExists(db, 'community_summaries')) {\n118:       return emptyOutput;\n119:     }\n120: \n121:     const queryTerms = extractQueryTerms(query);\n122:     if (queryTerms.length === 0) return emptyOutput;\n123: \n124:     const rows = db.prepare(`\n125:       SELECT community_id, summary, member_ids, member_count\n126:       FROM community_summaries\n127:       ORDER BY community_id ASC\n128:     `).all() as Array<{\n129:       community_id: number;\n130:       summary: string;\n131:       member_ids: string;\n132:       member_count: number;\n133:     }>;\n134: \n135:     if (rows.length === 0) return emptyOutput;\n136: \n137:     // Score and rank communities by query-term match\n138:     const scored: CommunitySearchResult[] = [];\n139:     for (const row of rows) {\n140:       const matchScore = scoreSummary(row.summary, queryTerms);\n141:       if (matchScore > 0) {\n142:         scored.push({\n143:           communityId: row.community_id,\n144:           summary: row.summary,\n145:           memberIds: parseMemberIds(row.member_ids),\n146:           memberCount: row.member_count,\n147:           matchScore,\n148:         });\n149:       }\n150:     }\n151: \n152:     // Sort by match score descending, then by member count descending\n153:     scored.sort((a, b) => {\n154:       if (b.matchScore !== a.matchScore) return b.matchScore - a.matchScore;\n155:       return b.memberCount - a.memberCount;\n156:     });\n157: \n158:     const topResults = scored.slice(0, limit);\n159: \n160:     // Collect unique member IDs across all matched communities\n161:     const memberIdSet = new Set<number>();\n162:     for (const r of topResults) {\n163:       for (const id of r.memberIds) {\n164:         memberIdSet.add(id);\n165:       }\n166:     }\n167: \n168:     return {\n169:       results: topResults,\n170:       totalMemberIds: Array.from(memberIdSet),\n171:       source: 'community_fallback',\n172:     };\n173:   } catch (error: unknown) {\n174:     const message = error instanceof Error ? error.message : String(error);\n175:     console.warn(`[community-search] searchCommunities failed (fail-open): ${message}`);\n176:     return emptyOutput;\n177:   }\n178: }\n\n(End of file - total 178 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Community Search\n// ───────────────────────────────────────────────────────────────\n// Community-level search as fallback channel.\n//\n// When primary search returns weak or zero results, this module\n// searches community summaries by keyword matching and returns\n// matching community member IDs for injection into the pipeline.\n//\n// FEATURE FLAG: SPECKIT_COMMUNITY_SEARCH_FALLBACK (default ON, graduated)\n\nimport type Database from 'better-sqlite3';\n\nimport { isCommunitySearchFallbackEnabled, isCommunitySummariesEnabled } from './search-flags.js';\n\n// -- Types --\n\nexport interface CommunitySearchResult {\n  communityId: number;\n  summary: string;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/community-search.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Community Search\n// ───────────────────────────────────────────────────────────────\n// Community-level search as fallback channel.\n//\n// When primary search returns weak or zero results, this module\n// searches community summaries by keyword matching and returns\n// matching community member IDs for injection into the pipeline.\n//\n// FEATURE FLAG: SPECKIT_COMMUNITY_SEARCH_FALLBACK (default ON, graduated)\n\nimport type Database from 'better-sqlite3';\n\nimport { isCommunitySearchFallbackEnabled, isCommunitySummariesEnabled } from './search-flags.js';\n\n// -- Types --\n\nexport interface CommunitySearchResult {\n  communityId: number;\n  summary: string;\n  memberIds: number[];\n  memberCount: number;\n  matchScore: number;\n}\n\nexport interface CommunitySearchOutput {\n  results: CommunitySearchResult[];\n  totalMemberIds: number[];\n  source: 'community_fallback';\n}\n\n// -- Internal helpers --\n\nfunction tableExists(db: Database.Database, tableName: string): boolean {\n  const row = db.prepare(`\n    SELECT name FROM sqlite_master\n    WHERE type = 'table' AND name = ?\n  `).get(tableName) as { name?: string } | undefined;\n  return row?.name === tableName;\n}\n\nfunction parseMemberIds(memberIdsJson: string): number[] {\n  try {\n    const parsed = JSON.parse(memberIdsJson) as unknown;\n    if (!Array.isArray(parsed)) return [];\n    return parsed\n      .map((v) => Number(v))\n      .filter((v) => Number.isFinite(v));\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[community-search] parseMemberIds failed (fail-open): ${message}`);\n    return [];\n  }\n}\n\n/**\n * Score a community summary against query terms.\n * Returns 0-1 based on fraction of query terms found in the summary.\n */\nfunction scoreSummary(summary: string, queryTerms: string[]): number {\n  if (queryTerms.length === 0) return 0;\n  const lowerSummary = summary.toLowerCase();\n  let matches = 0;\n  for (const term of queryTerms) {\n    if (lowerSummary.includes(term)) matches++;\n  }\n  return matches / queryTerms.length;\n}\n\n/**\n * Extract meaningful search terms from a query string.\n * Filters out common stop words.\n */\nfunction extractQueryTerms(query: string): string[] {\n  const stopWords = new Set([\n    'a', 'an', 'the', 'in', 'on', 'at', 'to', 'for', 'of', 'with',\n    'by', 'from', 'and', 'or', 'not', 'is', 'are', 'was', 'were',\n    'be', 'been', 'has', 'have', 'had', 'do', 'does', 'did', 'will',\n    'would', 'could', 'should', 'may', 'might', 'can', 'this', 'that',\n    'it', 'its', 'my', 'your', 'our', 'their', 'all', 'any', 'some',\n  ]);\n  return query\n    .toLowerCase()\n    .split(/\\s+/)\n    .filter((w) => w.length > 1 && !stopWords.has(w));\n}\n\n// -- Public API --\n\n/**\n * Search community summaries by keyword matching.\n *\n * Returns communities whose summaries match the query terms, sorted by match\n * score. Used as a fallback channel when primary search returns weak results.\n *\n * @param query - The search query string\n * @param db - SQLite database instance\n * @param limit - Maximum communities to return (default 5)\n * @returns Community search results with member IDs for pipeline injection\n */\nexport function searchCommunities(\n  query: string,\n  db: Database.Database,\n  limit: number = 5,\n): CommunitySearchOutput {\n  const emptyOutput: CommunitySearchOutput = {\n    results: [],\n    totalMemberIds: [],\n    source: 'community_fallback',\n  };\n\n  if (!isCommunitySearchFallbackEnabled() || !isCommunitySummariesEnabled()) {\n    return emptyOutput;\n  }\n\n  try {\n    if (!tableExists(db, 'community_summaries')) {\n      return emptyOutput;\n    }\n\n    const queryTerms = extractQueryTerms(query);\n    if (queryTerms.length === 0) return emptyOutput;\n\n    const rows = db.prepare(`\n      SELECT community_id, summary, member_ids, member_count\n      FROM community_summaries\n      ORDER BY community_id ASC\n    `).all() as Array<{\n      community_id: number;\n      summary: string;\n      member_ids: string;\n      member_count: number;\n    }>;\n\n    if (rows.length === 0) return emptyOutput;\n\n    // Score and rank communities by query-term match\n    const scored: CommunitySearchResult[] = [];\n    for (const row of rows) {\n      const matchScore = scoreSummary(row.summary, queryTerms);\n      if (matchScore > 0) {\n        scored.push({\n          communityId: row.community_id,\n          summary: row.summary,\n          memberIds: parseMemberIds(row.member_ids),\n          memberCount: row.member_count,\n          matchScore,\n        });\n      }\n    }\n\n    // Sort by match score descending, then by member count descending\n    scored.sort((a, b) => {\n      if (b.matchScore !== a.matchScore) return b.matchScore - a.matchScore;\n      return b.memberCount - a.memberCount;\n    });\n\n    const topResults = scored.slice(0, limit);\n\n    // Collect unique member IDs across all matched communities\n    const memberIdSet = new Set<number>();\n    for (const r of topResults) {\n      for (const id of r.memberIds) {\n        memberIdSet.add(id);\n      }\n    }\n\n    return {\n      results: topResults,\n      totalMemberIds: Array.from(memberIdSet),\n      source: 'community_fallback',\n    };\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    console.warn(`[community-search] searchCommunities failed (fail-open): ${message}`);\n    return emptyOutput;\n  }\n}","lineStart":1,"lineEnd":178,"totalLines":178,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/community-search.ts","time":{"start":1781763854439,"end":1781763854446}},"metadata":{"openai":{"itemId":"fc_0b65030751c38a88016a338f0e49c0819193b4130e37af17f6"}},"id":"prt_ed966d05a00112H0bFvlGCt5vZ","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96693ac001prVrpSijTbxJQl"}}
{"type":"tool_use","timestamp":1781763854457,"sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","part":{"type":"tool","tool":"read","callID":"call_QYY7PrSzlJycmHXl3NC4oAwo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/scope-governance.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/scope-governance.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Scope Governance\n3: // ───────────────────────────────────────────────────────────────\n4: // Hierarchical scope filtering, governed ingest validation,\n5: // provenance normalization, and governance audit persistence.\n6: import { ensureGovernanceTables } from '../search/vector-index-schema.js';\n7: \n8: import type Database from 'better-sqlite3';\n9: \n10: // Feature catalog: Hierarchical scope governance, governed ingest, retention, and audit\n11: \n12: /**\n13:  * Default TTL for ephemeral memories when the caller doesn't supply an explicit deleteAfter.\n14:  * 24h is conservative: short enough to clean up active test fixtures, long\n15:  * enough to survive a typical autonomous workflow.\n16:  */\n17: export const DEFAULT_EPHEMERAL_TTL_MS = 24 * 60 * 60 * 1000;\n18: \n19: /**\n20:  * Retention modes applied during governed ingest.\n21:  */\n22: export type RetentionPolicy = 'keep' | 'ephemeral';\n23: \n24: /**\n25:  * Request scope used to enforce tenancy, actor, and session boundaries.\n26:  */\n27: export interface ScopeContext {\n28:   tenantId?: string;\n29:   userId?: string;\n30:   agentId?: string;\n31:   sessionId?: string;\n32: }\n33: \n34: /**\n35:  * Governed-ingest fields required to persist scope and retention metadata.\n36:  */\n37: export interface GovernedIngestInput extends ScopeContext {\n38:   provenanceSource?: string;\n39:   provenanceActor?: string;\n40:   governedAt?: string;\n41:   retentionPolicy?: RetentionPolicy;\n42:   deleteAfter?: string;\n43: }\n44: \n45: /**\n46:  * Result of governed-ingest validation and field normalization.\n47:  */\n48: // Simplified normalized type — previously a complex intersection.\n49: export interface GovernanceNormalized {\n50:   tenantId?: string | null;\n51:   userId?: string | null;\n52:   agentId?: string | null;\n53:   sessionId?: string | null;\n54:   provenanceSource: string | null;\n55:   provenanceActor: string | null;\n56:   governedAt: string;\n57:   retentionPolicy: RetentionPolicy;\n58:   deleteAfter: string | null;\n59: }\n60: \n61: export interface GovernanceDecision {\n62:   allowed: boolean;\n63:   normalized: GovernanceNormalized;\n64:   reason?: string;\n65:   issues: string[];\n66: }\n67: \n68: /**\n69:  * Audit payload written for allow, deny, delete, and conflict events.\n70:  */\n71: export interface GovernanceAuditEntry extends ScopeContext {\n72:   action: string;\n73:   decision: 'allow' | 'deny' | 'delete' | 'conflict';\n74:   memoryId?: number | null;\n75:   logicalKey?: string | null;\n76:   reason?: string | null;\n77:   metadata?: Record<string, unknown> | null;\n78: }\n79: \n80: /**\n81:  * Filters used to review governance audit history.\n82:  */\n83: export interface GovernanceAuditReviewFilters extends ScopeContext {\n84:   action?: string;\n85:   decision?: GovernanceAuditEntry['decision'];\n86:   limit?: number;\n87:   allowUnscoped?: boolean;\n88: }\n89: \n90: /**\n91:  * Parsed governance audit row returned for review workflows.\n92:  */\n93: export interface GovernanceAuditReviewRow extends ScopeContext {\n94:   id: number;\n95:   action: string;\n96:   decision: GovernanceAuditEntry['decision'];\n97:   memoryId: number | null;\n98:   logicalKey: string | null;\n99:   reason: string | null;\n100:   metadata: Record<string, unknown> | null;\n101:   createdAt: string;\n102: }\n103: \n104: /**\n105:  * Aggregate view of governance audit activity for a filtered review.\n106:  */\n107: export interface GovernanceAuditReviewSummary {\n108:   totalMatching: number;\n109:   returnedRows: number;\n110:   byAction: Record<string, number>;\n111:   byDecision: Partial<Record<GovernanceAuditEntry['decision'], number>>;\n112:   latestCreatedAt: string | null;\n113: }\n114: \n115: /**\n116:  * Combined governance audit review rows and summary.\n117:  */\n118: export interface GovernanceAuditReviewResult {\n119:   rows: GovernanceAuditReviewRow[];\n120:   summary: GovernanceAuditReviewSummary;\n121: }\n122: \n123: export const GOVERNANCE_AUDIT_ACTIONS = {\n124:   TIER_DOWNGRADE_NON_CONSTITUTIONAL_PATH: 'tier_downgrade_non_constitutional_path',\n125:   TIER_DOWNGRADE_NON_CONSTITUTIONAL_PATH_CLEANUP: 'tier_downgrade_non_constitutional_path_cleanup',\n126:   CHECKPOINT_RESTORE_EXCLUDED_PATH_REJECTED: 'checkpoint_restore_excluded_path_rejected',\n127: } as const;\n128: \n129: export type GovernanceAuditAction =\n130:   typeof GOVERNANCE_AUDIT_ACTIONS[keyof typeof GOVERNANCE_AUDIT_ACTIONS];\n131: \n132: export interface TierDowngradeAuditParams extends ScopeContext {\n133:   action?: GovernanceAuditAction;\n134:   memoryId?: number | null;\n135:   logicalKey?: string | null;\n136:   requestedTier?: string | null;\n137:   previousTier?: string | null;\n138:   nextTier: string;\n139:   source: string;\n140:   reason?: string | null;\n141:   filePath?: string | null;\n142:   canonicalFilePath?: string | null;\n143:   metadata?: Record<string, unknown> | null;\n144: }\n145: \n146: /**\n147:  * Options used when benchmarking scope-filter behavior.\n148:  */\n149: export interface ScopeFilterBenchmarkOptions {\n150:   iterations?: number;\n151: }\n152: \n153: /**\n154:  * Benchmark result for a scope filter predicate.\n155:  */\n156: export interface ScopeFilterBenchmarkResult {\n157:   iterations: number;\n158:   totalRows: number;\n159:   matchedRows: number;\n160:   filteredRows: number;\n161:   elapsedMs: number;\n162:   averageMsPerIteration: number;\n163: }\n164: \n165: function normalizeId(value: unknown): string | undefined {\n166:   if (typeof value !== 'string') return undefined;\n167:   const trimmed = value.trim();\n168:   return trimmed.length > 0 ? trimmed : undefined;\n169: }\n170: \n171: /**\n172:  * Canonical single-string scope normalizer.\n173:  *\n174:  * Returns `string | null` to preserve the historical semantics of four local\n175:  * copies collapsed here (reconsolidation-bridge, lineage-state, save/types,\n176:  * preflight). Callers that perform null-specific narrowing (e.g. `=== null`,\n177:  * `!== null`) continue to work unchanged. `normalizeScopeContext` above uses\n178:  * `string | undefined` for structural scope objects; this helper is the\n179:  * single-field companion used when callers need a null-valued placeholder.\n180:  *\n181:  * @param value - Arbitrary input (string, null, undefined, other).\n182:  * @returns Trimmed non-empty string, or `null` for blank/non-string input.\n183:  */\n184: export function normalizeScopeValue(value: unknown): string | null {\n185:   if (typeof value !== 'string') return null;\n186:   const trimmed = value.trim();\n187:   return trimmed.length > 0 ? trimmed : null;\n188: }\n189: \n190: export function buildGovernanceLogicalKey(\n191:   specFolder: string | null | undefined,\n192:   resolvedPath: string | null | undefined,\n193:   anchorId: string | null | undefined,\n194: ): string | null {\n195:   if (!specFolder || !resolvedPath) {\n196:     return null;\n197:   }\n198: \n199:   const normalizedAnchor = anchorId && anchorId.trim().length > 0 ? anchorId : '_';\n200:   return `${specFolder}::${resolvedPath}::${normalizedAnchor}`;\n201: }\n202: \n203: function normalizeIsoTimestamp(value: unknown): string | undefined {\n204:   if (typeof value !== 'string' || value.trim().length === 0) return undefined;\n205:   const date = new Date(value);\n206:   if (Number.isNaN(date.getTime())) return undefined;\n207:   return date.toISOString();\n208: }\n209: \n210: /**\n211:  * Trim and normalize optional scope identifiers before enforcement.\n212:  *\n213:  * @param input - Scope values supplied by the caller.\n214:  * @returns Scope with blank identifiers removed.\n215:  */\n216: export function normalizeScopeContext(input: ScopeContext): ScopeContext {\n217:   return {\n218:     tenantId: normalizeId(input.tenantId),\n219:     userId: normalizeId(input.userId),\n220:     agentId: normalizeId(input.agentId),\n221:     sessionId: normalizeId(input.sessionId),\n222:   };\n223: }\n224: \n225: /**\n226:  * Determine whether an ingest request must pass governed-ingest validation.\n227:  * All ingest mutation surfaces should call `validateGovernedIngest` with their\n228:  * available metadata before writes or job enqueue. When any scope,\n229:  * provenance, governed timestamp, or retention field is present,\n230:  * `provenanceActor` is mandatory so audit rows can identify the caller.\n231:  *\n232:  * @param input - Candidate ingest metadata.\n233:  * @returns `true` when governance or scope metadata requires enforcement.\n234:  */\n235: export function requiresGovernedIngest(input: GovernedIngestInput): boolean {\n236:   const scope = normalizeScopeContext(input);\n237:   return Object.values(scope).some((value) => typeof value === 'string')\n238:     || typeof input.provenanceSource === 'string'\n239:     || typeof input.provenanceActor === 'string'\n240:     || typeof input.governedAt === 'string'\n241:     || (input.retentionPolicy !== 'ephemeral' && typeof input.deleteAfter === 'string');\n242: }\n243: \n244: /**\n245:  * Validate governed-ingest metadata and return normalized persistence fields.\n246:  *\n247:  * @param input - Candidate ingest metadata.\n248:  * @returns Validation result with normalized scope, provenance, and retention data.\n249:  */\n250: export function validateGovernedIngest(input: GovernedIngestInput): GovernanceDecision {\n251:   const scope = normalizeScopeContext(input);\n252:   const issues: string[] = [];\n253:   const governedAt = normalizeIsoTimestamp(input.governedAt) ?? new Date().toISOString();\n254:   const deleteAfter = normalizeIsoTimestamp(input.deleteAfter) ?? null;\n255:   const retentionPolicy: RetentionPolicy = input.retentionPolicy === 'ephemeral'\n256:     ? input.retentionPolicy\n257:     : 'keep';\n258:   const provenanceSource = normalizeId(input.provenanceSource) ?? '';\n259:   const provenanceActor = normalizeId(input.provenanceActor) ?? '';\n260: \n261:   if (!requiresGovernedIngest(input)) {\n262:     const computedDeleteAfter = deleteAfter ?? (\n263:       retentionPolicy === 'ephemeral'\n264:         ? new Date(Date.now() + DEFAULT_EPHEMERAL_TTL_MS).toISOString()\n265:         : null\n266:     );\n267:     // Return null instead of empty string for optional scope fields\n268:     // when governance is not required, to avoid persisting false-y placeholders.\n269:     return {\n270:       allowed: true,\n271:       normalized: {\n272:         tenantId: scope.tenantId || null,\n273:         userId: scope.userId || null,\n274:         agentId: scope.agentId || null,\n275:         sessionId: scope.sessionId || null,\n276:         provenanceSource: provenanceSource || null,\n277:         provenanceActor: provenanceActor || null,\n278:         governedAt,\n279:         retentionPolicy,\n280:         deleteAfter: computedDeleteAfter,\n281:       },\n282:       issues,\n283:     };\n284:   }\n285: \n286:   if (!scope.tenantId) issues.push('tenantId is required for governed ingest');\n287:   if (!scope.sessionId) issues.push('sessionId is required for governed ingest');\n288:   if (!scope.userId && !scope.agentId) issues.push('userId or agentId is required for governed ingest');\n289:   if (!provenanceSource) issues.push('provenanceSource is required for governed ingest');\n290:   if (!provenanceActor) issues.push('provenanceActor is required for governed ingest');\n291:   if (deleteAfter && new Date(deleteAfter).getTime() <= new Date(governedAt).getTime()) {\n292:     issues.push('deleteAfter must be later than governedAt');\n293:   }\n294:   // Require valid future deleteAfter for ephemeral retention policy\n295:   // The memory retention sweep enforces this field via memory_index.delete_after;\n296:   // keep ephemeral rows paired with a concrete timestamp for auditability.\n297:   if (retentionPolicy === 'ephemeral' && !deleteAfter) {\n298:     issues.push('deleteAfter is required for ephemeral retention policy');\n299:   }\n300: \n301:   return {\n302:     allowed: issues.length === 0,\n303:     reason: issues[0],\n304:     issues,\n305:     normalized: {\n306:       tenantId: scope.tenantId ?? '',\n307:       userId: scope.userId,\n308:       agentId: scope.agentId,\n309:       sessionId: scope.sessionId ?? '',\n310:       provenanceSource,\n311:       provenanceActor,\n312:       governedAt,\n313:       retentionPolicy,\n314:       deleteAfter,\n315:     },\n316:   };\n317: }\n318: \n319: /**\n320:  * Map a governance decision into memory-index column values.\n321:  *\n322:  * @param decision - Normalized governance decision from ingest validation.\n323:  * @returns Column/value pairs used after memory insertion.\n324:  */\n325: export function buildGovernancePostInsertFields(decision: GovernanceDecision): Record<string, unknown> {\n326:   return {\n327:     tenant_id: decision.normalized.tenantId || null,\n328:     user_id: decision.normalized.userId ?? null,\n329:     agent_id: decision.normalized.agentId ?? null,\n330:     session_id: decision.normalized.sessionId || null,\n331:     provenance_source: decision.normalized.provenanceSource || null,\n332:     provenance_actor: decision.normalized.provenanceActor || null,\n333:     governed_at: decision.normalized.governedAt,\n334:     retention_policy: decision.normalized.retentionPolicy,\n335:     // Consumed by memory_retention_sweep and the scheduled retention interval.\n336:     delete_after: decision.normalized.deleteAfter,\n337:     governance_metadata: JSON.stringify({\n338:       tenantId: decision.normalized.tenantId || null,\n339:       userId: decision.normalized.userId ?? null,\n340:       agentId: decision.normalized.agentId ?? null,\n341:       sessionId: decision.normalized.sessionId || null,\n342:       provenanceSource: decision.normalized.provenanceSource || null,\n343:       provenanceActor: decision.normalized.provenanceActor || null,\n344:       governedAt: decision.normalized.governedAt,\n345:       retentionPolicy: decision.normalized.retentionPolicy,\n346:       deleteAfter: decision.normalized.deleteAfter,\n347:     }),\n348:   };\n349: }\n350: \n351: /**\n352:  * Ensure governance audit tables exist before writes.\n353:  *\n354:  * @param database - Database connection that stores governance state.\n355:  */\n356: export function ensureGovernanceRuntime(database: Database.Database): void {\n357:   ensureGovernanceTables(database);\n358: }\n359: \n360: /**\n361:  * Persist a governance audit entry for enforcement decisions and lifecycle events.\n362:  *\n363:  * @param database - Database connection that stores governance state.\n364:  * @param entry - Audit payload to persist.\n365:  */\n366: export function recordGovernanceAudit(database: Database.Database, entry: GovernanceAuditEntry): void {\n367:   ensureGovernanceRuntime(database);\n368:   const scope = normalizeScopeContext(entry);\n369:   database.prepare(`\n370:     INSERT INTO governance_audit (\n371:       action, decision, memory_id, logical_key, tenant_id, user_id, agent_id, session_id,\n372:       reason, metadata\n373:     ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n374:   `).run(\n375:     entry.action,\n376:     entry.decision,\n377:     entry.memoryId ?? null,\n378:     entry.logicalKey ?? null,\n379:     scope.tenantId ?? null,\n380:     scope.userId ?? null,\n381:     scope.agentId ?? null,\n382:     scope.sessionId ?? null,\n383:     entry.reason ?? null,\n384:     entry.metadata ? JSON.stringify(entry.metadata) : null,\n385:   );\n386: }\n387: \n388: \n389: export function recordTierDowngradeAudit(\n390:   database: Database.Database,\n391:   params: TierDowngradeAuditParams,\n392: ): void {\n393:   const metadata: Record<string, unknown> = {\n394:     source: params.source,\n395:     appliedTier: params.nextTier,\n396:   };\n397: \n398:   if (params.requestedTier !== undefined) {\n399:     metadata.requestedTier = params.requestedTier;\n400:   }\n401:   if (params.previousTier !== undefined) {\n402:     metadata.previousTier = params.previousTier;\n403:   }\n404:   if (params.filePath !== undefined) {\n405:     metadata.filePath = params.filePath;\n406:   }\n407:   if (params.canonicalFilePath !== undefined) {\n408:     metadata.canonicalFilePath = params.canonicalFilePath;\n409:   }\n410:   if (params.metadata) {\n411:     Object.assign(metadata, params.metadata);\n412:   }\n413: \n414:   recordGovernanceAudit(database, {\n415:     action: params.action ?? GOVERNANCE_AUDIT_ACTIONS.TIER_DOWNGRADE_NON_CONSTITUTIONAL_PATH,\n416:     decision: 'conflict',\n417:     tenantId: params.tenantId,\n418:     userId: params.userId,\n419:     agentId: params.agentId,\n420:     sessionId: params.sessionId,\n421:     memoryId: params.memoryId ?? null,\n422:     logicalKey: params.logicalKey ?? null,\n423:     reason: params.reason ?? 'non_constitutional_path',\n424:     metadata,\n425:   });\n426: }\n427: \n428: function matchesExactScope(rowValue: unknown, requestedValue?: string): boolean {\n429:   if (!requestedValue) return true;\n430:   return typeof rowValue === 'string' && rowValue === requestedValue;\n431: }\n432: \n433: /**\n434:  * Determine whether a scope includes at least one concrete constraint.\n435:  *\n436:  * @param scope - Scope to inspect for tenant, actor, or session bounds.\n437:  * @returns `true` when the scope constrains access to at least one boundary.\n438:  */\n439: export function hasScopeConstraints(scope: ScopeContext): boolean {\n440:   return Boolean(\n441:     scope.tenantId\n442:     || scope.userId\n443:     || scope.agentId\n444:     || scope.sessionId,\n445:   );\n446: }\n447: \n448: function parseAuditMetadata(value: unknown): Record<string, unknown> | null {\n449:   if (typeof value !== 'string' || value.trim().length === 0) {\n450:     return null;\n451:   }\n452: \n453:   try {\n454:     const parsed = JSON.parse(value) as unknown;\n455:     if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) {\n456:       return parsed as Record<string, unknown>;\n457:     }\n458:   } catch (error: unknown) {\n459:     if (error instanceof Error) {\n460:       return null;\n461:     }\n462:     return null;\n463:   }\n464: \n465:   return null;\n466: }\n467: \n468: function buildGovernanceAuditWhereClause(filters: GovernanceAuditReviewFilters): { whereSql: string; params: unknown[] } {\n469:   const normalized = normalizeScopeContext(filters);\n470:   const clauses: string[] = [];\n471:   const params: unknown[] = [];\n472: \n473:   if (filters.action) {\n474:     clauses.push('action = ?');\n475:     params.push(filters.action);\n476:   }\n477:   if (filters.decision) {\n478:     clauses.push('decision = ?');\n479:     params.push(filters.decision);\n480:   }\n481:   if (normalized.tenantId) {\n482:     clauses.push('tenant_id = ?');\n483:     params.push(normalized.tenantId);\n484:   }\n485:   if (normalized.userId) {\n486:     clauses.push('user_id = ?');\n487:     params.push(normalized.userId);\n488:   }\n489:   if (normalized.agentId) {\n490:     clauses.push('agent_id = ?');\n491:     params.push(normalized.agentId);\n492:   }\n493:   if (normalized.sessionId) {\n494:     clauses.push('session_id = ?');\n495:     params.push(normalized.sessionId);\n496:   }\n497:   return {\n498:     whereSql: clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '',\n499:     params,\n500:   };\n501: }\n502: \n503: function hasGovernanceAuditFilters(filters: GovernanceAuditReviewFilters): boolean {\n504:   const normalized = normalizeScopeContext(filters);\n505:   return Boolean(\n506:     filters.action\n507:     || filters.decision\n508:     || normalized.tenantId\n509:     || normalized.userId\n510:     || normalized.agentId\n511:     || normalized.sessionId\n512:   );\n513: }\n514: \n515: /**\n516:  * Build a reusable row predicate for scope filtering without re-normalizing each row scan.\n517:  *\n518:  * @param scope - Requested scope used for filtering.\n519:  * @returns Predicate that returns `true` when a row remains visible.\n520:  */\n521: export function createScopeFilterPredicate<T extends Record<string, unknown>>(\n522:   scope: ScopeContext,\n523: ): (row: T) => boolean {\n524:   const normalized = normalizeScopeContext(scope);\n525:   if (!hasScopeConstraints(normalized)) {\n526:     return () => false;\n527:   }\n528: \n529:   return (row: T) => {\n530:     return matchesExactScope(row.tenant_id, normalized.tenantId)\n531:       && matchesExactScope(row.user_id, normalized.userId)\n532:       && matchesExactScope(row.agent_id, normalized.agentId)\n533:       && matchesExactScope(row.session_id, normalized.sessionId);\n534:   };\n535: }\n536: \n537: /**\n538:  * Review governance audit rows and aggregate counts for a filtered governance window.\n539:  *\n540:  * @param database - Database connection that stores governance state.\n541:  * @param filters - Optional audit filters and row limit.\n542:  * @returns Review rows plus aggregate counts for the matching audit window.\n543:  */\n544: export function reviewGovernanceAudit(\n545:   database: Database.Database,\n546:   filters: GovernanceAuditReviewFilters = {},\n547: ): GovernanceAuditReviewResult {\n548:   ensureGovernanceRuntime(database);\n549:   const allowUnscoped = filters.allowUnscoped === true;\n550:   // Security: audit enumeration requires explicit scope filters or admin override\n551:   if (!allowUnscoped && !hasGovernanceAuditFilters(filters)) {\n552:     console.warn('[scope-governance] Unscoped governance audit enumeration blocked; explicit filters or allowUnscoped=true required.');\n553:     return {\n554:       rows: [],\n555:       summary: {\n556:         totalMatching: 0,\n557:         returnedRows: 0,\n558:         byAction: {},\n559:         byDecision: {},\n560:         latestCreatedAt: null,\n561:       },\n562:     };\n563:   }\n564:   const { whereSql, params } = buildGovernanceAuditWhereClause(filters);\n565:   const limit = Number.isInteger(filters.limit) && (filters.limit ?? 0) > 0\n566:     ? Math.trunc(filters.limit as number)\n567:     : 50;\n568: \n569:   const rows = database.prepare(`\n570:     SELECT\n571:       id,\n572:       action,\n573:       decision,\n574:       memory_id,\n575:       logical_key,\n576:       tenant_id,\n577:       user_id,\n578:       agent_id,\n579:       session_id,\n580:       reason,\n581:       metadata,\n582:       created_at\n583:     FROM governance_audit\n584:     ${whereSql}\n585:     ORDER BY id DESC\n586:     LIMIT ?\n587:   `).all(...params, limit) as Array<{\n588:     id: number;\n589:     action: string;\n590:     decision: GovernanceAuditEntry['decision'];\n591:     memory_id: number | null;\n592:     logical_key: string | null;\n593:     tenant_id: string | null;\n594:     user_id: string | null;\n595:     agent_id: string | null;\n596:     session_id: string | null;\n597:     reason: string | null;\n598:     metadata: string | null;\n599:     created_at: string;\n600:   }>;\n601: \n602:   const summaryRow = database.prepare(`\n603:     SELECT\n604:       COUNT(*) AS total_matching,\n605:       MAX(created_at) AS latest_created_at\n606:     FROM governance_audit\n607:     ${whereSql}\n608:   `).get(...params) as {\n609:     total_matching: number;\n610:     latest_created_at: string | null;\n611:   };\n612:   const aggregateRows = database.prepare(`\n613:     SELECT\n614:       'action' AS aggregate_kind,\n615:       action AS aggregate_key,\n616:       COUNT(*) AS aggregate_count\n617:     FROM governance_audit\n618:     ${whereSql}\n619:     GROUP BY action\n620:     UNION ALL\n621:     SELECT\n622:       'decision' AS aggregate_kind,\n623:       decision AS aggregate_key,\n624:       COUNT(*) AS aggregate_count\n625:     FROM governance_audit\n626:     ${whereSql}\n627:     GROUP BY decision\n628:   `).all(...params, ...params) as Array<{\n629:     aggregate_kind: 'action' | 'decision';\n630:     aggregate_key: string;\n631:     aggregate_count: number;\n632:   }>;\n633: \n634:   const totalMatching = summaryRow.total_matching;\n635:   const byActionRows = aggregateRows.filter((row) => row.aggregate_kind === 'action');\n636:   const byDecisionRows = aggregateRows.filter((row) => row.aggregate_kind === 'decision');\n637: \n638:   return {\n639:     rows: rows.map((row) => ({\n640:       id: row.id,\n641:       action: row.action,\n642:       decision: row.decision,\n643:       memoryId: row.memory_id,\n644:       logicalKey: row.logical_key,\n645:       tenantId: row.tenant_id ?? undefined,\n646:       userId: row.user_id ?? undefined,\n647:       agentId: row.agent_id ?? undefined,\n648:       sessionId: row.session_id ?? undefined,\n649:       reason: row.reason,\n650:       metadata: parseAuditMetadata(row.metadata),\n651:       createdAt: row.created_at,\n652:     })),\n653:     summary: {\n654:       totalMatching,\n655:       returnedRows: rows.length,\n656:       byAction: Object.fromEntries(byActionRows.map((row) => [row.aggregate_key, row.aggregate_count])),\n657:       byDecision: Object.fromEntries(byDecisionRows.map((row) => [row.aggregate_key as GovernanceAuditEntry['decision'], row.aggregate_count])),\n658:       latestCreatedAt: summaryRow.latest_created_at,\n659:     },\n660:   };\n661: }\n662: \n663: /**\n664:  * Benchmark scope filtering with a reusable predicate for rollout and safety checks.\n665:  *\n666:  * @param rows - Candidate rows that include governance scope columns.\n667:  * @param scope - Requested scope used for filtering.\n668:  * @param options - Optional iteration count.\n669:  * @returns Timing and match counts for the benchmark run.\n670:  */\n671: export function benchmarkScopeFilter<T extends Record<string, unknown>>(\n672:   rows: T[],\n673:   scope: ScopeContext,\n674:   options: ScopeFilterBenchmarkOptions = {},\n675: ): ScopeFilterBenchmarkResult {\n676:   const iterations = Number.isInteger(options.iterations) && (options.iterations ?? 0) > 0\n677:     ? Math.trunc(options.iterations as number)\n678:     : 1;\n679:   const predicate = createScopeFilterPredicate(scope);\n680:   let matchedRows = 0;\n681:   const startedAt = process.hrtime.bigint();\n682: \n683:   for (let iteration = 0; iteration < iterations; iteration += 1) {\n684:     matchedRows = 0;\n685:     for (const row of rows) {\n686:       if (predicate(row)) {\n687:         matchedRows += 1;\n688:       }\n689:     }\n690:   }\n691: \n692:   const elapsedMs = Number(process.hrtime.bigint() - startedAt) / 1_000_000;\n693:   return {\n694:     iterations,\n695:     totalRows: rows.length,\n696:     matchedRows,\n697:     filteredRows: rows.length - matchedRows,\n698:     elapsedMs,\n699:     averageMsPerIteration: elapsedMs / iterations,\n700:   };\n701: }\n702: \n703: /**\n704:  * Filter result rows to the tenant, actor, and session scope in force.\n705:  *\n706:  * @param rows - Candidate rows that include governance scope columns.\n707:  * @param scope - Requested scope used for filtering.\n708:  * @returns Rows that remain visible after governance filtering.\n709:  */\n710: export function filterRowsByScope<T extends Record<string, unknown>>(rows: T[], scope: ScopeContext): T[] {\n711:   return rows.filter(createScopeFilterPredicate(scope));\n712: }\n\n(End of file - total 712 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Scope Governance\n// ───────────────────────────────────────────────────────────────\n// Hierarchical scope filtering, governed ingest validation,\n// provenance normalization, and governance audit persistence.\nimport { ensureGovernanceTables } from '../search/vector-index-schema.js';\n\nimport type Database from 'better-sqlite3';\n\n// Feature catalog: Hierarchical scope governance, governed ingest, retention, and audit\n\n/**\n * Default TTL for ephemeral memories when the caller doesn't supply an explicit deleteAfter.\n * 24h is conservative: short enough to clean up active test fixtures, long\n * enough to survive a typical autonomous workflow.\n */\nexport const DEFAULT_EPHEMERAL_TTL_MS = 24 * 60 * 60 * 1000;\n\n/**\n * Retention modes applied during governed ingest.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/scope-governance.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Scope Governance\n// ───────────────────────────────────────────────────────────────\n// Hierarchical scope filtering, governed ingest validation,\n// provenance normalization, and governance audit persistence.\nimport { ensureGovernanceTables } from '../search/vector-index-schema.js';\n\nimport type Database from 'better-sqlite3';\n\n// Feature catalog: Hierarchical scope governance, governed ingest, retention, and audit\n\n/**\n * Default TTL for ephemeral memories when the caller doesn't supply an explicit deleteAfter.\n * 24h is conservative: short enough to clean up active test fixtures, long\n * enough to survive a typical autonomous workflow.\n */\nexport const DEFAULT_EPHEMERAL_TTL_MS = 24 * 60 * 60 * 1000;\n\n/**\n * Retention modes applied during governed ingest.\n */\nexport type RetentionPolicy = 'keep' | 'ephemeral';\n\n/**\n * Request scope used to enforce tenancy, actor, and session boundaries.\n */\nexport interface ScopeContext {\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n}\n\n/**\n * Governed-ingest fields required to persist scope and retention metadata.\n */\nexport interface GovernedIngestInput extends ScopeContext {\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: RetentionPolicy;\n  deleteAfter?: string;\n}\n\n/**\n * Result of governed-ingest validation and field normalization.\n */\n// Simplified normalized type — previously a complex intersection.\nexport interface GovernanceNormalized {\n  tenantId?: string | null;\n  userId?: string | null;\n  agentId?: string | null;\n  sessionId?: string | null;\n  provenanceSource: string | null;\n  provenanceActor: string | null;\n  governedAt: string;\n  retentionPolicy: RetentionPolicy;\n  deleteAfter: string | null;\n}\n\nexport interface GovernanceDecision {\n  allowed: boolean;\n  normalized: GovernanceNormalized;\n  reason?: string;\n  issues: string[];\n}\n\n/**\n * Audit payload written for allow, deny, delete, and conflict events.\n */\nexport interface GovernanceAuditEntry extends ScopeContext {\n  action: string;\n  decision: 'allow' | 'deny' | 'delete' | 'conflict';\n  memoryId?: number | null;\n  logicalKey?: string | null;\n  reason?: string | null;\n  metadata?: Record<string, unknown> | null;\n}\n\n/**\n * Filters used to review governance audit history.\n */\nexport interface GovernanceAuditReviewFilters extends ScopeContext {\n  action?: string;\n  decision?: GovernanceAuditEntry['decision'];\n  limit?: number;\n  allowUnscoped?: boolean;\n}\n\n/**\n * Parsed governance audit row returned for review workflows.\n */\nexport interface GovernanceAuditReviewRow extends ScopeContext {\n  id: number;\n  action: string;\n  decision: GovernanceAuditEntry['decision'];\n  memoryId: number | null;\n  logicalKey: string | null;\n  reason: string | null;\n  metadata: Record<string, unknown> | null;\n  createdAt: string;\n}\n\n/**\n * Aggregate view of governance audit activity for a filtered review.\n */\nexport interface GovernanceAuditReviewSummary {\n  totalMatching: number;\n  returnedRows: number;\n  byAction: Record<string, number>;\n  byDecision: Partial<Record<GovernanceAuditEntry['decision'], number>>;\n  latestCreatedAt: string | null;\n}\n\n/**\n * Combined governance audit review rows and summary.\n */\nexport interface GovernanceAuditReviewResult {\n  rows: GovernanceAuditReviewRow[];\n  summary: GovernanceAuditReviewSummary;\n}\n\nexport const GOVERNANCE_AUDIT_ACTIONS = {\n  TIER_DOWNGRADE_NON_CONSTITUTIONAL_PATH: 'tier_downgrade_non_constitutional_path',\n  TIER_DOWNGRADE_NON_CONSTITUTIONAL_PATH_CLEANUP: 'tier_downgrade_non_constitutional_path_cleanup',\n  CHECKPOINT_RESTORE_EXCLUDED_PATH_REJECTED: 'checkpoint_restore_excluded_path_rejected',\n} as const;\n\nexport type GovernanceAuditAction =\n  typeof GOVERNANCE_AUDIT_ACTIONS[keyof typeof GOVERNANCE_AUDIT_ACTIONS];\n\nexport interface TierDowngradeAuditParams extends ScopeContext {\n  action?: GovernanceAuditAction;\n  memoryId?: number | null;\n  logicalKey?: string | null;\n  requestedTier?: string | null;\n  previousTier?: string | null;\n  nextTier: string;\n  source: string;\n  reason?: string | null;\n  filePath?: string | null;\n  canonicalFilePath?: string | null;\n  metadata?: Record<string, unknown> | null;\n}\n\n/**\n * Options used when benchmarking scope-filter behavior.\n */\nexport interface ScopeFilterBenchmarkOptions {\n  iterations?: number;\n}\n\n/**\n * Benchmark result for a scope filter predicate.\n */\nexport interface ScopeFilterBenchmarkResult {\n  iterations: number;\n  totalRows: number;\n  matchedRows: number;\n  filteredRows: number;\n  elapsedMs: number;\n  averageMsPerIteration: number;\n}\n\nfunction normalizeId(value: unknown): string | undefined {\n  if (typeof value !== 'string') return undefined;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : undefined;\n}\n\n/**\n * Canonical single-string scope normalizer.\n *\n * Returns `string | null` to preserve the historical semantics of four local\n * copies collapsed here (reconsolidation-bridge, lineage-state, save/types,\n * preflight). Callers that perform null-specific narrowing (e.g. `=== null`,\n * `!== null`) continue to work unchanged. `normalizeScopeContext` above uses\n * `string | undefined` for structural scope objects; this helper is the\n * single-field companion used when callers need a null-valued placeholder.\n *\n * @param value - Arbitrary input (string, null, undefined, other).\n * @returns Trimmed non-empty string, or `null` for blank/non-string input.\n */\nexport function normalizeScopeValue(value: unknown): string | null {\n  if (typeof value !== 'string') return null;\n  const trimmed = value.trim();\n  return trimmed.length > 0 ? trimmed : null;\n}\n\nexport function buildGovernanceLogicalKey(\n  specFolder: string | null | undefined,\n  resolvedPath: string | null | undefined,\n  anchorId: string | null | undefined,\n): string | null {\n  if (!specFolder || !resolvedPath) {\n    return null;\n  }\n\n  const normalizedAnchor = anchorId && anchorId.trim().length > 0 ? anchorId : '_';\n  return `${specFolder}::${resolvedPath}::${normalizedAnchor}`;\n}\n\nfunction normalizeIsoTimestamp(value: unknown): string | undefined {\n  if (typeof value !== 'string' || value.trim().length === 0) return undefined;\n  const date = new Date(value);\n  if (Number.isNaN(date.getTime())) return undefined;\n  return date.toISOString();\n}\n\n/**\n * Trim and normalize optional scope identifiers before enforcement.\n *\n * @param input - Scope values supplied by the caller.\n * @returns Scope with blank identifiers removed.\n */\nexport function normalizeScopeContext(input: ScopeContext): ScopeContext {\n  return {\n    tenantId: normalizeId(input.tenantId),\n    userId: normalizeId(input.userId),\n    agentId: normalizeId(input.agentId),\n    sessionId: normalizeId(input.sessionId),\n  };\n}\n\n/**\n * Determine whether an ingest request must pass governed-ingest validation.\n * All ingest mutation surfaces should call `validateGovernedIngest` with their\n * available metadata before writes or job enqueue. When any scope,\n * provenance, governed timestamp, or retention field is present,\n * `provenanceActor` is mandatory so audit rows can identify the caller.\n *\n * @param input - Candidate ingest metadata.\n * @returns `true` when governance or scope metadata requires enforcement.\n */\nexport function requiresGovernedIngest(input: GovernedIngestInput): boolean {\n  const scope = normalizeScopeContext(input);\n  return Object.values(scope).some((value) => typeof value === 'string')\n    || typeof input.provenanceSource === 'string'\n    || typeof input.provenanceActor === 'string'\n    || typeof input.governedAt === 'string'\n    || (input.retentionPolicy !== 'ephemeral' && typeof input.deleteAfter === 'string');\n}\n\n/**\n * Validate governed-ingest metadata and return normalized persistence fields.\n *\n * @param input - Candidate ingest metadata.\n * @returns Validation result with normalized scope, provenance, and retention data.\n */\nexport function validateGovernedIngest(input: GovernedIngestInput): GovernanceDecision {\n  const scope = normalizeScopeContext(input);\n  const issues: string[] = [];\n  const governedAt = normalizeIsoTimestamp(input.governedAt) ?? new Date().toISOString();\n  const deleteAfter = normalizeIsoTimestamp(input.deleteAfter) ?? null;\n  const retentionPolicy: RetentionPolicy = input.retentionPolicy === 'ephemeral'\n    ? input.retentionPolicy\n    : 'keep';\n  const provenanceSource = normalizeId(input.provenanceSource) ?? '';\n  const provenanceActor = normalizeId(input.provenanceActor) ?? '';\n\n  if (!requiresGovernedIngest(input)) {\n    const computedDeleteAfter = deleteAfter ?? (\n      retentionPolicy === 'ephemeral'\n        ? new Date(Date.now() + DEFAULT_EPHEMERAL_TTL_MS).toISOString()\n        : null\n    );\n    // Return null instead of empty string for optional scope fields\n    // when governance is not required, to avoid persisting false-y placeholders.\n    return {\n      allowed: true,\n      normalized: {\n        tenantId: scope.tenantId || null,\n        userId: scope.userId || null,\n        agentId: scope.agentId || null,\n        sessionId: scope.sessionId || null,\n        provenanceSource: provenanceSource || null,\n        provenanceActor: provenanceActor || null,\n        governedAt,\n        retentionPolicy,\n        deleteAfter: computedDeleteAfter,\n      },\n      issues,\n    };\n  }\n\n  if (!scope.tenantId) issues.push('tenantId is required for governed ingest');\n  if (!scope.sessionId) issues.push('sessionId is required for governed ingest');\n  if (!scope.userId && !scope.agentId) issues.push('userId or agentId is required for governed ingest');\n  if (!provenanceSource) issues.push('provenanceSource is required for governed ingest');\n  if (!provenanceActor) issues.push('provenanceActor is required for governed ingest');\n  if (deleteAfter && new Date(deleteAfter).getTime() <= new Date(governedAt).getTime()) {\n    issues.push('deleteAfter must be later than governedAt');\n  }\n  // Require valid future deleteAfter for ephemeral retention policy\n  // The memory retention sweep enforces this field via memory_index.delete_after;\n  // keep ephemeral rows paired with a concrete timestamp for auditability.\n  if (retentionPolicy === 'ephemeral' && !deleteAfter) {\n    issues.push('deleteAfter is required for ephemeral retention policy');\n  }\n\n  return {\n    allowed: issues.length === 0,\n    reason: issues[0],\n    issues,\n    normalized: {\n      tenantId: scope.tenantId ?? '',\n      userId: scope.userId,\n      agentId: scope.agentId,\n      sessionId: scope.sessionId ?? '',\n      provenanceSource,\n      provenanceActor,\n      governedAt,\n      retentionPolicy,\n      deleteAfter,\n    },\n  };\n}\n\n/**\n * Map a governance decision into memory-index column values.\n *\n * @param decision - Normalized governance decision from ingest validation.\n * @returns Column/value pairs used after memory insertion.\n */\nexport function buildGovernancePostInsertFields(decision: GovernanceDecision): Record<string, unknown> {\n  return {\n    tenant_id: decision.normalized.tenantId || null,\n    user_id: decision.normalized.userId ?? null,\n    agent_id: decision.normalized.agentId ?? null,\n    session_id: decision.normalized.sessionId || null,\n    provenance_source: decision.normalized.provenanceSource || null,\n    provenance_actor: decision.normalized.provenanceActor || null,\n    governed_at: decision.normalized.governedAt,\n    retention_policy: decision.normalized.retentionPolicy,\n    // Consumed by memory_retention_sweep and the scheduled retention interval.\n    delete_after: decision.normalized.deleteAfter,\n    governance_metadata: JSON.stringify({\n      tenantId: decision.normalized.tenantId || null,\n      userId: decision.normalized.userId ?? null,\n      agentId: decision.normalized.agentId ?? null,\n      sessionId: decision.normalized.sessionId || null,\n      provenanceSource: decision.normalized.provenanceSource || null,\n      provenanceActor: decision.normalized.provenanceActor || null,\n      governedAt: decision.normalized.governedAt,\n      retentionPolicy: decision.normalized.retentionPolicy,\n      deleteAfter: decision.normalized.deleteAfter,\n    }),\n  };\n}\n\n/**\n * Ensure governance audit tables exist before writes.\n *\n * @param database - Database connection that stores governance state.\n */\nexport function ensureGovernanceRuntime(database: Database.Database): void {\n  ensureGovernanceTables(database);\n}\n\n/**\n * Persist a governance audit entry for enforcement decisions and lifecycle events.\n *\n * @param database - Database connection that stores governance state.\n * @param entry - Audit payload to persist.\n */\nexport function recordGovernanceAudit(database: Database.Database, entry: GovernanceAuditEntry): void {\n  ensureGovernanceRuntime(database);\n  const scope = normalizeScopeContext(entry);\n  database.prepare(`\n    INSERT INTO governance_audit (\n      action, decision, memory_id, logical_key, tenant_id, user_id, agent_id, session_id,\n      reason, metadata\n    ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n  `).run(\n    entry.action,\n    entry.decision,\n    entry.memoryId ?? null,\n    entry.logicalKey ?? null,\n    scope.tenantId ?? null,\n    scope.userId ?? null,\n    scope.agentId ?? null,\n    scope.sessionId ?? null,\n    entry.reason ?? null,\n    entry.metadata ? JSON.stringify(entry.metadata) : null,\n  );\n}\n\n\nexport function recordTierDowngradeAudit(\n  database: Database.Database,\n  params: TierDowngradeAuditParams,\n): void {\n  const metadata: Record<string, unknown> = {\n    source: params.source,\n    appliedTier: params.nextTier,\n  };\n\n  if (params.requestedTier !== undefined) {\n    metadata.requestedTier = params.requestedTier;\n  }\n  if (params.previousTier !== undefined) {\n    metadata.previousTier = params.previousTier;\n  }\n  if (params.filePath !== undefined) {\n    metadata.filePath = params.filePath;\n  }\n  if (params.canonicalFilePath !== undefined) {\n    metadata.canonicalFilePath = params.canonicalFilePath;\n  }\n  if (params.metadata) {\n    Object.assign(metadata, params.metadata);\n  }\n\n  recordGovernanceAudit(database, {\n    action: params.action ?? GOVERNANCE_AUDIT_ACTIONS.TIER_DOWNGRADE_NON_CONSTITUTIONAL_PATH,\n    decision: 'conflict',\n    tenantId: params.tenantId,\n    userId: params.userId,\n    agentId: params.agentId,\n    sessionId: params.sessionId,\n    memoryId: params.memoryId ?? null,\n    logicalKey: params.logicalKey ?? null,\n    reason: params.reason ?? 'non_constitutional_path',\n    metadata,\n  });\n}\n\nfunction matchesExactScope(rowValue: unknown, requestedValue?: string): boolean {\n  if (!requestedValue) return true;\n  return typeof rowValue === 'string' && rowValue === requestedValue;\n}\n\n/**\n * Determine whether a scope includes at least one concrete constraint.\n *\n * @param scope - Scope to inspect for tenant, actor, or session bounds.\n * @returns `true` when the scope constrains access to at least one boundary.\n */\nexport function hasScopeConstraints(scope: ScopeContext): boolean {\n  return Boolean(\n    scope.tenantId\n    || scope.userId\n    || scope.agentId\n    || scope.sessionId,\n  );\n}\n\nfunction parseAuditMetadata(value: unknown): Record<string, unknown> | null {\n  if (typeof value !== 'string' || value.trim().length === 0) {\n    return null;\n  }\n\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) {\n      return parsed as Record<string, unknown>;\n    }\n  } catch (error: unknown) {\n    if (error instanceof Error) {\n      return null;\n    }\n    return null;\n  }\n\n  return null;\n}\n\nfunction buildGovernanceAuditWhereClause(filters: GovernanceAuditReviewFilters): { whereSql: string; params: unknown[] } {\n  const normalized = normalizeScopeContext(filters);\n  const clauses: string[] = [];\n  const params: unknown[] = [];\n\n  if (filters.action) {\n    clauses.push('action = ?');\n    params.push(filters.action);\n  }\n  if (filters.decision) {\n    clauses.push('decision = ?');\n    params.push(filters.decision);\n  }\n  if (normalized.tenantId) {\n    clauses.push('tenant_id = ?');\n    params.push(normalized.tenantId);\n  }\n  if (normalized.userId) {\n    clauses.push('user_id = ?');\n    params.push(normalized.userId);\n  }\n  if (normalized.agentId) {\n    clauses.push('agent_id = ?');\n    params.push(normalized.agentId);\n  }\n  if (normalized.sessionId) {\n    clauses.push('session_id = ?');\n    params.push(normalized.sessionId);\n  }\n  return {\n    whereSql: clauses.length > 0 ? `WHERE ${clauses.join(' AND ')}` : '',\n    params,\n  };\n}\n\nfunction hasGovernanceAuditFilters(filters: GovernanceAuditReviewFilters): boolean {\n  const normalized = normalizeScopeContext(filters);\n  return Boolean(\n    filters.action\n    || filters.decision\n    || normalized.tenantId\n    || normalized.userId\n    || normalized.agentId\n    || normalized.sessionId\n  );\n}\n\n/**\n * Build a reusable row predicate for scope filtering without re-normalizing each row scan.\n *\n * @param scope - Requested scope used for filtering.\n * @returns Predicate that returns `true` when a row remains visible.\n */\nexport function createScopeFilterPredicate<T extends Record<string, unknown>>(\n  scope: ScopeContext,\n): (row: T) => boolean {\n  const normalized = normalizeScopeContext(scope);\n  if (!hasScopeConstraints(normalized)) {\n    return () => false;\n  }\n\n  return (row: T) => {\n    return matchesExactScope(row.tenant_id, normalized.tenantId)\n      && matchesExactScope(row.user_id, normalized.userId)\n      && matchesExactScope(row.agent_id, normalized.agentId)\n      && matchesExactScope(row.session_id, normalized.sessionId);\n  };\n}\n\n/**\n * Review governance audit rows and aggregate counts for a filtered governance window.\n *\n * @param database - Database connection that stores governance state.\n * @param filters - Optional audit filters and row limit.\n * @returns Review rows plus aggregate counts for the matching audit window.\n */\nexport function reviewGovernanceAudit(\n  database: Database.Database,\n  filters: GovernanceAuditReviewFilters = {},\n): GovernanceAuditReviewResult {\n  ensureGovernanceRuntime(database);\n  const allowUnscoped = filters.allowUnscoped === true;\n  // Security: audit enumeration requires explicit scope filters or admin override\n  if (!allowUnscoped && !hasGovernanceAuditFilters(filters)) {\n    console.warn('[scope-governance] Unscoped governance audit enumeration blocked; explicit filters or allowUnscoped=true required.');\n    return {\n      rows: [],\n      summary: {\n        totalMatching: 0,\n        returnedRows: 0,\n        byAction: {},\n        byDecision: {},\n        latestCreatedAt: null,\n      },\n    };\n  }\n  const { whereSql, params } = buildGovernanceAuditWhereClause(filters);\n  const limit = Number.isInteger(filters.limit) && (filters.limit ?? 0) > 0\n    ? Math.trunc(filters.limit as number)\n    : 50;\n\n  const rows = database.prepare(`\n    SELECT\n      id,\n      action,\n      decision,\n      memory_id,\n      logical_key,\n      tenant_id,\n      user_id,\n      agent_id,\n      session_id,\n      reason,\n      metadata,\n      created_at\n    FROM governance_audit\n    ${whereSql}\n    ORDER BY id DESC\n    LIMIT ?\n  `).all(...params, limit) as Array<{\n    id: number;\n    action: string;\n    decision: GovernanceAuditEntry['decision'];\n    memory_id: number | null;\n    logical_key: string | null;\n    tenant_id: string | null;\n    user_id: string | null;\n    agent_id: string | null;\n    session_id: string | null;\n    reason: string | null;\n    metadata: string | null;\n    created_at: string;\n  }>;\n\n  const summaryRow = database.prepare(`\n    SELECT\n      COUNT(*) AS total_matching,\n      MAX(created_at) AS latest_created_at\n    FROM governance_audit\n    ${whereSql}\n  `).get(...params) as {\n    total_matching: number;\n    latest_created_at: string | null;\n  };\n  const aggregateRows = database.prepare(`\n    SELECT\n      'action' AS aggregate_kind,\n      action AS aggregate_key,\n      COUNT(*) AS aggregate_count\n    FROM governance_audit\n    ${whereSql}\n    GROUP BY action\n    UNION ALL\n    SELECT\n      'decision' AS aggregate_kind,\n      decision AS aggregate_key,\n      COUNT(*) AS aggregate_count\n    FROM governance_audit\n    ${whereSql}\n    GROUP BY decision\n  `).all(...params, ...params) as Array<{\n    aggregate_kind: 'action' | 'decision';\n    aggregate_key: string;\n    aggregate_count: number;\n  }>;\n\n  const totalMatching = summaryRow.total_matching;\n  const byActionRows = aggregateRows.filter((row) => row.aggregate_kind === 'action');\n  const byDecisionRows = aggregateRows.filter((row) => row.aggregate_kind === 'decision');\n\n  return {\n    rows: rows.map((row) => ({\n      id: row.id,\n      action: row.action,\n      decision: row.decision,\n      memoryId: row.memory_id,\n      logicalKey: row.logical_key,\n      tenantId: row.tenant_id ?? undefined,\n      userId: row.user_id ?? undefined,\n      agentId: row.agent_id ?? undefined,\n      sessionId: row.session_id ?? undefined,\n      reason: row.reason,\n      metadata: parseAuditMetadata(row.metadata),\n      createdAt: row.created_at,\n    })),\n    summary: {\n      totalMatching,\n      returnedRows: rows.length,\n      byAction: Object.fromEntries(byActionRows.map((row) => [row.aggregate_key, row.aggregate_count])),\n      byDecision: Object.fromEntries(byDecisionRows.map((row) => [row.aggregate_key as GovernanceAuditEntry['decision'], row.aggregate_count])),\n      latestCreatedAt: summaryRow.latest_created_at,\n    },\n  };\n}\n\n/**\n * Benchmark scope filtering with a reusable predicate for rollout and safety checks.\n *\n * @param rows - Candidate rows that include governance scope columns.\n * @param scope - Requested scope used for filtering.\n * @param options - Optional iteration count.\n * @returns Timing and match counts for the benchmark run.\n */\nexport function benchmarkScopeFilter<T extends Record<string, unknown>>(\n  rows: T[],\n  scope: ScopeContext,\n  options: ScopeFilterBenchmarkOptions = {},\n): ScopeFilterBenchmarkResult {\n  const iterations = Number.isInteger(options.iterations) && (options.iterations ?? 0) > 0\n    ? Math.trunc(options.iterations as number)\n    : 1;\n  const predicate = createScopeFilterPredicate(scope);\n  let matchedRows = 0;\n  const startedAt = process.hrtime.bigint();\n\n  for (let iteration = 0; iteration < iterations; iteration += 1) {\n    matchedRows = 0;\n    for (const row of rows) {\n      if (predicate(row)) {\n        matchedRows += 1;\n      }\n    }\n  }\n\n  const elapsedMs = Number(process.hrtime.bigint() - startedAt) / 1_000_000;\n  return {\n    iterations,\n    totalRows: rows.length,\n    matchedRows,\n    filteredRows: rows.length - matchedRows,\n    elapsedMs,\n    averageMsPerIteration: elapsedMs / iterations,\n  };\n}\n\n/**\n * Filter result rows to the tenant, actor, and session scope in force.\n *\n * @param rows - Candidate rows that include governance scope columns.\n * @param scope - Requested scope used for filtering.\n * @returns Rows that remain visible after governance filtering.\n */\nexport function filterRowsByScope<T extends Record<string, unknown>>(rows: T[], scope: ScopeContext): T[] {\n  return rows.filter(createScopeFilterPredicate(scope));\n}","lineStart":1,"lineEnd":712,"totalLines":712,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/governance/scope-governance.ts","time":{"start":1781763854452,"end":1781763854456}},"metadata":{"openai":{"itemId":"fc_0b65030751c38a88016a338f0e49dc8191a1bccddbd794e281"}},"id":"prt_ed966d068001ZTGBIuG2nxONlQ","sessionID":"ses_1269bed27ffeaBceEWnTAdPS3b","messageID":"msg_ed96693ac001prVrpSijTbxJQl"}}
