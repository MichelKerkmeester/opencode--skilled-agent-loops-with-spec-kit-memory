ete\",\"focus\":\"traceability-maintainability\",\"dimensions\":[\"traceability\",\"maintainability\"],\"filesReviewed\":[\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/spec.md\",\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/graph-metadata.json\",\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/001-advisor-observability/implementation-summary.md\",\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/005-advisor-feedback-calibration/implementation-summary.md\",\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/009-codegraph-bm25-symbol-resolver/implementation-summary.md\",\".opencode/skills/system-code-graph/mcp_server/handlers/query.ts\"],\"findingsCount\":2,\"findingsSummary\":{\"P0\":0,\"P1\":2,\"P2\":1},\"findingsNew\":{\"P0\":0,\"P1\":1,\"P2\":1},\"findingsRefined\":{\"P0\":0,\"P1\":0,\"P2\":0},\"findingRefs\":[\"F001\",\"F003\"],\"findingDetails\":[{\"findingId\":\"F001\",\"severity\":\"P1\",\"category\":\"traceability\",\"status\":\"active\",\"dimension\":\"traceability\",\"title\":\"Phase parent still advertises scaffold-only planned state after child phases report implementation and verification\",\"file\":\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/spec.md\",\"line\":71,\"evidence\":[\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/spec.md:51\",\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/spec.md:71\",\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/spec.md:87\",\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/graph-metadata.json:43-46\",\".opencode/specs/skilled-agent-orchestration/145-xce-feature-adoption-advisor-codegraph/005-advisor-feedback-calibration