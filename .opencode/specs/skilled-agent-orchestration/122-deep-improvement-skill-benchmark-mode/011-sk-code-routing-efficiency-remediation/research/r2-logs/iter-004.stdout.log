.\n203:   const coverage = { routing: 0, advisor: 0, browser: 0, routedOut: 0, scored: 0 };\n204:   for (const r of rows) {\n205:     const k = r.classKind || 'routing';\n206:     if (coverage[k] !== undefined) coverage[k] += 1;\n207:     if (r.routedOut) coverage.routedOut += 1;\n208:     else if (typeof r.modeAScore === 'number') coverage.scored += 1;\n209:   }\n210:   // Funnel attrition: count first-failing-stage occurrences (scored rows only).\n211:   const funnel = {};\n212:   for (const r of rows) {\n213:     if (r.routedOut) continue;\n214:     const stage = r.firstFailingStage || 'passed';\n215:     funnel[stage] = (funnel[stage] || 0) + 1;\n216:   }\n217:   const headlineBottleneck = Object.entries(funnel)\n218:     .filter(([k]) => k !== 'passed')\n219:     .sort((a, b) => b[1] - a[1])[0] || null;\n220: \n221:   const d5 = connectivity.score;\n222:   const aggregateScore = avg((r) => r.modeAScore);\n223:   // D1-inter is scored only when advisor probes ran; avg() returns null if no row\n224:   // carried a numeric D1-inter score, so the dimension self-reports its coverage.\n225:   const d1interAvg = avg((r) => (r.dims && r.dims.d1inter && typeof r.dims.d1inter.score === 'number'\n226:     ? Math.round(r.dims.d1inter.score * 100) : null));\n227:   const gateFailed = connectivity.gateFailed;\n228:   let verdict;\n229:   if (gateFailed) verdict = 'BLOCKED-BY-STRUCTURE';\n230:   else if (aggregateScore == null) verdict = 'NO-SCENARIOS';\n231:   else if (aggregateScore >= 80) verdict = 'PASS';\n232:   else if (aggregateScore >= 50) verdict = 'CONDITIONAL';\n233:   else verdict = 'FAIL';\n234: \n235:   // Bottlenecks: D5 findings + any scenario stage failures, ranked by severity.\n236:   const bottlenecks = [...connectivity.findings];\n237:   if (headlineBottleneck) {\n238:     bottlenecks.unshift({\n239:       class: 'funnel_attrition', severity: 'P1', stage: headlineBottleneck[0],\n240:       detail: `${headlineBottleneck[1]} scenario(s) first fail at stage '${headlineBottleneck[0]}'`,\n241:     });\n242:   }\n243: \n244:   return {\n245:     schemaVersion: 'skill-benchmark-report.v1',\n246:     status: 'skill-benchmark-complete',\n247:     mode: 'skill-benchmark',\n248:     scoringMethod: (traceMode || 'router') === 'live' ? 'mode-b-live' : 'mode-a-router-replay',\n249:     traceMode: traceMode || 'router',\n250:     targetSkill: { id: skillId, root: skillRoot },\n251:     verdict,\n252:     aggregateScore,\n253:     gate: { d5Score: d5, gateFailed, reason: gateFailed ? 'D5 structural hard-gate failure' : null },\n254:     dimensionScores: {\n255:       D1inter: d1interAvg === null\n256:         ? { points: WEIGHTS.d1inter, score: null, status: 'unscored-mode-a' }\n257:         : { points: WEIGHTS.d1inter, score: d1interAvg },\n258:       D1intra: { points: WEIGHTS.d1intra, score: avg((r) => (r.dims && r.dims.d1intra ? Math.round(r.dims.d1intra.score * 100) : null)) },\n259:       D2: { points: WEIGHTS.d2, score: avg((r) => (r.dims && r.dims.d2 ? Math.round(r.dims.d2.score * 100) : null)) },\n260:       D3: { points: WEIGHTS.d3, score: avg((r) => (r.dims && r.dims.d3 ? Math.round(r.dims.d3.score * 100) : null)) },\n261:       D4: { points: WEIGHTS.d4, score: null, status: 'unscored-mode-a' },\n262:       D5: { points: WEIGHTS.d5, score: d5, hardGate: true },\n263:     },\n264:     unscoredDimensions: d1interAvg === null ? ['D1inter', 'D4'] : ['D4'],\n265:     funnel,\n266:     headlineBottleneck: headlineBottleneck ? headlineBottleneck[0] : null,\n267:     bottlenecks,\n268:     coverage,\n269:     divergence: divergence || [],\n270:     lintFindings: lintFindings || [],\n271:     scenarioRows: rows,\n272:     runQuality: {\n273:       scenarioCount: rows.length,\n274:       traceMode: traceMode || 'router',\n275:       note: 'Mode A is the deterministic CI gate; D1-inter (advisor) + D4 (ablation) need live mode.',\n276:     },\n277:   };\n278: }\n279: \n280: module.exports = { scoreScenario, aggregate, computeDivergence, WEIGHTS };\n\n(End of file - total 280 lines)\n</content>","metadata":{"preview":"  const lRefs = new Set((liveObserved && liveObserved.observedResources) || []);\n  const onlyRouter = [...rRefs].filter((r) => !lRefs.has(r));\n  const onlyLive = [...lRefs].filter((r) => !rRefs.has(r));\n  const rSurface = routerObserved && routerObserved.observedSurface;\n  const lSurface = liveObserved && liveObserved.observedSurface;\n  const surfaceAgree = (rSurface && lSurface) ? (rSurface === lSurface) : null;\n  const delta = onlyRouter.length + onlyLive.length;\n  const severity = delta === 0 && surfaceAgree !== false ? 'none' : (delta > 4 || surfaceAgree === false ? 'high' : 'low');\n  return { scenarioId, resourceDelta: { onlyRouter, onlyLive }, surfaceAgree, severity };\n}\n\n/**\n * Aggregate scenario rows + the D5 connectivity result into a report object.\n */\nfunction aggregate({ skillId, skillRoot, scenarioRows, connectivity, traceMode, lintFindings, divergence }) {\n  const rows = scenarioRows.filter(Boolean);\n  const avg = (sel) => {\n    const vals = rows.map(sel).filter((v) => typeof v === 'number');\n    return vals.length ? Math.round(vals.reduce((a, b) => a + b, 0) / vals.length) : null;\n  };","truncated":false,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/score-skill-benchmark.cjs","time":{"start":1780372761489,"end":1780372761508}},"metadata":{"openai":{"itemId":"fc_052c63f5e113434f016a1e551955388191864b7beeccc57986"}},"id":"prt_e867c6b8e0013iqQBIdMC0N2L9","sessionID":"ses_17985835dffe8as3Ygnwtbh8Aj","messageID":"msg_e867c437200153N8624JlScMKy"}}
