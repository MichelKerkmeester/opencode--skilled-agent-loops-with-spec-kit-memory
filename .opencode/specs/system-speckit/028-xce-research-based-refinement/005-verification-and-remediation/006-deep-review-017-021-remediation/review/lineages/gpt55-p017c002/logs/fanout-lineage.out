{"type":"tool_use","timestamp":1781757310717,"sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","part":{"type":"tool","tool":"read","callID":"call_p9CYDnXvdYJNRDJiNTzPSuYl","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts","offset":780,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts</path>\n<type>file</type>\n<content>\n780: // ────────────────────────────────────────────────────────────────\n781: \n782: export async function formatSearchResults(\n783:   results: RawSearchResult[] | null,\n784:   searchType: string,\n785:   include_content: boolean = false,\n786:   anchors: string[] | null = null,\n787:   parserOverride: MemoryParserLike | null = null,\n788:   startTime: number | null = null,\n789:   extraData: Record<string, unknown> = {},\n790:   includeTrace: boolean = false,\n791:   query: string | null = null,\n792:   specFolder: string | null = null\n793: ): Promise<MCPResponse> {\n794:   const startMs = startTime || Date.now();\n795:   const includeContent = include_content;\n796:   const safeExtraData: Record<string, unknown> = { ...(extraData ?? {}) };\n797:   if (!includeTrace) {\n798:     delete safeExtraData.retrievalTrace;\n799:     delete safeExtraData.sessionTransition;\n800:   }\n801: \n802:   if (!results || results.length === 0) {\n803:     // Attach recovery payload when flag is enabled\n804:     let recoveryPayload: RecoveryPayload | null = null;\n805:     const requestQualityData = isResultConfidenceEnabled()\n806:       ? assessRequestQuality([], [])\n807:       : null;\n808:     if (isEmptyResultRecoveryEnabled()) {\n809:       recoveryPayload = buildRecoveryPayload({\n810:         query,\n811:         hasSpecFolderFilter: specFolder !== null && specFolder.length > 0,\n812:         resultCount: 0,\n813:       });\n814:     }\n815:     const responsePolicy = deriveResponsePolicy(requestQualityData, recoveryPayload);\n816:     const citationPolicy = deriveCitationPolicy(requestQualityData);\n817: \n818:     // Use standardized empty response envelope\n819:     return createMCPEmptyResponse({\n820:       tool: 'memory_search',\n821:       summary: 'No matching memories found',\n822:       data: {\n823:         searchType: searchType,\n824:         constitutionalCount: 0,\n825:         ...(requestQualityData ?? {}),\n826:         // Preserve caller metadata, but keep trace-only fields opt-in.\n827:         ...safeExtraData,\n828:         // Attach recovery payload (additive, only when flag enabled)\n829:         ...(recoveryPayload !== null ? { recovery: recoveryPayload } : {}),\n830:         citationPolicy,\n831:         ...(responsePolicy !== null ? { responsePolicy } : {}),\n832:       },\n833:       hints: [\n834:         'Try broadening your search query',\n835:         'Use memory_list() to browse available memories',\n836:         'Check if specFolder filter is too restrictive'\n837:       ],\n838:       startTime: startMs\n839:     });\n840:   }\n841: \n842:   // Count constitutional results\n843:   const constitutionalCount = results.filter(rawResult => rawResult.isConstitutional).length;\n844:   const trustBadgeFetch = fetchTrustBadgeSnapshots(results);\n845: \n846:   const formatted: MemoryResultEnvelope[] = await Promise.all(results.map(async (rawResult: RawSearchResult, index: number) => {\n847:     const resultId = toNullableNumber(rawResult.id);\n848:     const formattedResult: MemoryResultEnvelope = {\n849:       id: typeof rawResult.id === 'number' ? rawResult.id : Number.parseInt(rawResult.id, 10),\n850:       specFolder: rawResult.spec_folder ?? String(rawResult.specFolder ?? ''),\n851:       filePath: rawResult.file_path ?? String(rawResult.filePath ?? ''),\n852:       title: rawResult.title ?? null,\n853:       similarity: rawResult.similarity ?? rawResult.averageSimilarity,\n854:       isConstitutional: rawResult.isConstitutional || false,\n855:       importanceTier: rawResult.importance_tier,\n856:       // Use typed validator instead of safeJsonParse cast.\n857:       triggerPhrases: parseTriggerPhrases(rawResult.triggerPhrases),\n858:       createdAt: rawResult.created_at,\n859:       isChunk: rawResult.isChunk === true,\n860:       parentId: toNullableNumber(rawResult.parentId ?? rawResult.parent_id),\n861:       chunkIndex: toNullableNumber(rawResult.chunkIndex ?? rawResult.chunk_index),\n862:       chunkLabel: (typeof rawResult.chunkLabel === 'string'\n863:         ? rawResult.chunkLabel\n864:         : (typeof rawResult.chunk_label === 'string' ? rawResult.chunk_label : null)),\n865:       chunkCount: toNullableNumber(rawResult.chunkCount ?? rawResult.chunk_count),\n866:       contentSource: (rawResult.contentSource === 'reassembled_chunks' || rawResult.contentSource === 'file_read_fallback')\n867:         ? rawResult.contentSource\n868:         : undefined,\n869:     };\n870: \n871:     // Explicit `trustBadges` payloads are\n872:     // sanitized per-field (allowlisted age strings, clamped\n873:     // confidence, type-checked booleans). The\n874:     // sanitized partial is merged onto the derived snapshot\n875:     // per-field so callers can override specific fields without\n876:     // wholesale-replacing the badge.\n877:     const explicitTrustBadgePartial = normalizeExplicitTrustBadges(rawResult.trustBadges);\n878:     const derivedTrustBadges = toTrustBadges(\n879:       resultId !== null ? (trustBadgeFetch.snapshots.get(resultId) ?? null) : null\n880:     );\n881:     formattedResult.trustBadges = mergeTrustBadges(explicitTrustBadgePartial, derivedTrustBadges);\n882: \n883:     if (includeTrace) {\n884:       const anchorsInfo = extractAnchorDetails(rawResult);\n885:       formattedResult.scores = {\n886:         semantic: toNullableNumber(rawResult.similarity ?? rawResult.averageSimilarity),\n887:         lexical: toNullableNumber(rawResult.fts_score ?? rawResult.bm25_score ?? (rawResult.sourceScores as Record<string, number> | undefined)?.keyword ?? (rawResult.sourceScores as Record<string, number> | undefined)?.fts ?? (rawResult.sourceScores as Record<string, number> | undefined)?.bm25),\n888:         fusion: toNullableNumber(rawResult.rrfScore),\n889:         intentAdjusted: toNullableNumber(rawResult.intentAdjustedScore),\n890:         composite: resolveCompositeScore(rawResult),\n891:         rerank: toNullableNumber(rawResult.rerankerScore),\n892:         attention: toNullableNumber(rawResult.attentionScore),\n893:       };\n894:       formattedResult.source = {\n895:         file: typeof rawResult.file_path === 'string' ? rawResult.file_path : null,\n896:         anchorIds: anchorsInfo.anchorIds,\n897:         anchorTypes: anchorsInfo.anchorTypes,\n898:         lastModified: typeof rawResult.updated_at === 'string'\n899:           ? rawResult.updated_at\n900:           : (typeof rawResult.created_at === 'string' ? rawResult.created_at : null),\n901:         memoryState: typeof rawResult.memoryState === 'string' ? rawResult.memoryState : null,\n902:       };\n903:       formattedResult.trace = extractTrace(rawResult, extraData);\n904:       formattedResult.why_ranked = buildWhyRankedTrace(rawResult, index + 1);\n905:       // stamp the badge-derivation observability\n906:       // fields onto the trace so operators can distinguish\n907:       // explicit-vs-derived without inspecting logs.\n908:       formattedResult.trace.trustBadgeDerivation = {\n909:         attempted: trustBadgeFetch.attempted,\n910:         derivedCount: trustBadgeFetch.derivedCount,\n911:         failureReason: trustBadgeFetch.failureReason,\n912:       };\n913:     }\n914: \n915:     // Phase C: Include graphEvidence provenance when present on the pipeline row.\n916:     // The field is populated by Stage 2 when SPECKIT_RESULT_PROVENANCE is enabled.\n917:     if (rawResult.graphEvidence && typeof rawResult.graphEvidence === 'object') {\n918:       const evidence = rawResult.graphEvidence as Record<string, unknown>;\n919:       formattedResult.graphEvidence = {\n920:         edges: Array.isArray(evidence.edges)\n921:           ? (evidence.edges as Array<Record<string, unknown>>).map((e) => ({\n922:               sourceId: typeof e.sourceId === 'number' ? e.sourceId : 0,\n923:               targetId: typeof e.targetId === 'number' ? e.targetId : 0,\n924:               relation: typeof e.relation === 'string' ? e.relation : 'unknown',\n925:               strength: typeof e.strength === 'number' ? e.strength : 1.0,\n926:             }))\n927:           : [],\n928:         communities: Array.isArray(evidence.communities)\n929:           ? (evidence.communities as Array<Record<string, unknown>>).map((c) => ({\n930:               communityId: typeof c.communityId === 'number' ? c.communityId : 0,\n931:               ...(typeof c.summary === 'string' ? { summary: c.summary } : {}),\n932:             }))\n933:           : [],\n934:         boostFactors: Array.isArray(evidence.boostFactors)\n935:           ? (evidence.boostFactors as Array<Record<string, unknown>>).map((b) => ({\n936:               type: typeof b.type === 'string' ? b.type : 'unknown',\n937:               delta: typeof b.delta === 'number' ? b.delta : 0,\n938:             }))\n939:           : [],\n940:       };\n941:     }\n942: \n943:     // Include file content if requested.\n944:     // Prefer precomputed chunk reassembly from memory-search to avoid disk reads.\n945:     if (includeContent) {\n946:       try {\n947:         let content: string | null = null;\n948: \n949:         if (typeof rawResult.precomputedContent === 'string' && rawResult.precomputedContent.length > 0) {\n950:           content = rawResult.precomputedContent;\n951:           if (!formattedResult.contentSource) {\n952:             formattedResult.contentSource = 'reassembled_chunks';\n953:           }\n954:         } else if (rawResult.file_path) {\n955:           // SEC-002: Validate DB-stored file paths before reading (CWE-22 defense-in-depth)\n956:           const validatedPath = validateFilePathLocal(rawResult.file_path);\n957:           content = await fs.promises.readFile(validatedPath, 'utf-8');\n958:           if (!formattedResult.contentSource) {\n959:             formattedResult.contentSource = 'file_read_fallback';\n960:           }\n961:         } else {\n962:           formattedResult.content = null;\n963:           formattedResult.contentError = 'File not found';\n964:           return formattedResult;\n965:         }\n966: \n967:         // Anchor System Implementation\n968:         const parser: MemoryParserLike = parserOverride || memoryParser;\n969:         if (anchors && Array.isArray(anchors) && anchors.length > 0 && parser && typeof content === 'string') {\n970:           // Capture original tokens BEFORE any content reassignment\n971:           const originalTokens = estimateTokens(content);\n972: \n973:           const extracted = parser.extractAnchors(content);\n974:           const filteredParts: string[] = [];\n975:           let foundCount = 0;\n976: \n977:           for (const anchorId of anchors) {\n978:             // Prefix matching: try exact match first, then fall back to\n979:             // Prefix match for composite anchor IDs (e.g. 'summary' matches\n980:             // 'summary-session-1770903150838-...'). Prefers shortest match to\n981:             // Select the most specific key when multiple keys share a prefix.\n982:             const matchingKey = extracted[anchorId] !== undefined\n983:               ? anchorId\n984:               : Object.keys(extracted)\n985:                   .filter(key => key.startsWith(anchorId + '-'))\n986:                   .sort((a, b) => a.length - b.length)[0] ?? undefined;\n987: \n988:             if (matchingKey !== undefined) {\n989:               filteredParts.push(`<!-- ANCHOR:${matchingKey} -->\\n${extracted[matchingKey]}\\n<!-- /ANCHOR:${matchingKey} -->`);\n990:               foundCount++;\n991:             }\n992:           }\n993: \n994:           if (filteredParts.length > 0) {\n995:             // Warn about missing anchors in partial match\n996:             // Use same prefix-matching logic for consistency\n997:             const missingAnchors = anchors.filter(a => {\n998:               if (extracted[a] !== undefined) return false;\n999:               return !Object.keys(extracted).some(key => key.startsWith(a + '-'));\n1000:             });\n1001:             if (missingAnchors.length > 0) {\n1002:               filteredParts.push(`<!-- WARNING: Requested anchors not found: ${missingAnchors.join(', ')} -->`);\n1003:             }\n1004: \n1005:             content = filteredParts.join('\\n\\n');\n1006:             const newTokens = estimateTokens(content);\n1007:             const savings = Math.round((1 - newTokens / Math.max(originalTokens, 1)) * 100);\n1008: \n1009:             formattedResult.tokenMetrics = {\n1010:               originalTokens: originalTokens,\n1011:               returnedTokens: newTokens,\n1012:               savingsPercent: savings,\n1013:               anchorsRequested: anchors.length,\n1014:               anchorsFound: foundCount\n1015:             };\n1016:           } else {\n1017:             // No anchors found - return warning; the warning string itself\n1018:             // consumes tokens that budget accounting must account for.\n1019:             content = `<!-- WARNING: Requested anchors not found: ${anchors.join(', ')} -->`;\n1020:             const newTokens = estimateTokens(content);\n1021:             const savings = Math.round((1 - newTokens / Math.max(originalTokens, 1)) * 100);\n1022:             formattedResult.tokenMetrics = {\n1023:               originalTokens: originalTokens,\n1024:               returnedTokens: newTokens,\n1025:               savingsPercent: savings,\n1026:               anchorsRequested: anchors.length,\n1027:               anchorsFound: 0\n1028:             };\n1029:           }\n1030:         }\n1031: \n1032:         formattedResult.content = content;\n1033:       } catch (err: unknown) {\n1034:         formattedResult.content = null;\n1035:         const message = err instanceof Error ? err.message : String(err);\n1036:         // Sanitize error messages to prevent information leakage\n1037:         formattedResult.contentError = message.includes('Access denied')\n1038:           ? 'Security: Access denied'\n1039:           : message.includes('ENOENT')\n1040:             ? 'File not found'\n1041:             : 'Failed to read file';\n1042:       }\n1043:     }\n1044: \n1045:     return formattedResult;\n1046:   }));\n1047: \n1048:   // Compute per-result confidence when flag is enabled (additive, no side-effects)\n1049:   const confidenceEnabled = isResultConfidenceEnabled();\n1050:   let confidenceData: ReturnType<typeof computeResultConfidence> | null = null;\n1051:   let requestQualityData: ReturnType<typeof assessRequestQuality> | null = null;\n1052:   if (confidenceEnabled) {\n1053:     // Cast to ScoredResult — RawSearchResult extends Record<string,unknown> and has the same shape\n1054:     const scoredResults = results as unknown as ScoredResult[];\n1055:     confidenceData = computeResultConfidence(scoredResults);\n1056:     requestQualityData = assessRequestQuality(scoredResults, confidenceData);\n1057:   }\n1058: \n1059:   // Compute recovery payload for weak/partial results when flag is enabled\n1060:   let recoveryPayload: RecoveryPayload | null = null;\n1061:   if (isEmptyResultRecoveryEnabled() && formatted.length > 0) {\n1062:     // Compute average confidence for recovery decision\n1063:     let avgConfidence: number | undefined;\n1064:     if (confidenceData && confidenceData.length > 0) {\n1065:       const sum = confidenceData.reduce((acc, c) => acc + c.confidence.value, 0);\n1066:       avgConfidence = sum / confidenceData.length;\n1067:     }\n1068: \n1069:     const recoveryCtx = {\n1070:       query,\n1071:       hasSpecFolderFilter: specFolder !== null && specFolder.length > 0,\n1072:       evidenceGap: Boolean(safeExtraData?.evidenceGap),\n1073:       resultCount: formatted.length,\n1074:       avgConfidence,\n1075:     };\n1076: \n1077:     if (shouldTriggerRecovery(recoveryCtx)) {\n1078:       recoveryPayload = buildRecoveryPayload(recoveryCtx);\n1079:     }\n1080:   }\n1081: \n1082:   // Build summary based on result characteristics\n1083:   const summary = constitutionalCount > 0\n1084:     ? `Found ${formatted.length} memories (${constitutionalCount} constitutional)`\n1085:     : `Found ${formatted.length} memories`;\n1086: \n1087:   // Build hints based on context\n1088:   const hints: string[] = [];\n1089:   if (includeContent && anchors && anchors.length > 0) {\n1090:     hints.push('Anchor filtering applied for token efficiency');\n1091:   }\n1092:   if (!includeContent && formatted.length > 0) {\n1093:     hints.push('Use includeContent: true to embed file contents in results');\n1094:   }\n1095:   if (formatted.some(r => r.contentError)) {\n1096:     hints.push('Some files could not be read - check file paths');\n1097:   }\n1098: \n1099:   const explainOptions: ExplainabilityOptions = {\n1100:     debugEnabled: process.env.SPECKIT_RESULT_EXPLAIN_DEBUG?.toLowerCase().trim() === 'true',\n1101:   };\n1102:   const explainedRawResults = isResultExplainEnabled()\n1103:     ? attachExplainabilityToResults(\n1104:         results.map(toExplainabilityRow),\n1105:         explainOptions\n1106:       )\n1107:     : null;\n1108: \n1109:   // Merge per-result confidence into the formatted result array (additive)\n1110:   const resultsWithConfidence: Array<Record<string, unknown>> = formatted.map(\n1111:     (r, i): Record<string, unknown> => {\n1112:       const explainedWhy = explainedRawResults?.[i]?.why;\n1113:       const base = explainedWhy\n1114:         ? { ...(r as unknown as Record<string, unknown>), why: explainedWhy }\n1115:         : r as unknown as Record<string, unknown>;\n1116:       if (!confidenceData) return base;\n1117:       const conf = confidenceData[i];\n1118:       if (!conf) return base;\n1119:       return { ...base, ...conf };\n1120:     }\n1121:   );\n1122: \n1123:   const responsePolicy = deriveResponsePolicy(requestQualityData, recoveryPayload);\n1124:   const citationPolicy = deriveCitationPolicy(requestQualityData);\n1125:   const inlineWarnings: RetrievalConflictWarning[] = includeTrace\n1126:     ? findInlineConflictWarnings(results, requireDb)\n1127:     : [];\n1128: \n1129:   // Use standardized success response envelope\n1130:   const responseData: Record<string, unknown> = {\n1131:     searchType: searchType,\n1132:     count: formatted.length,\n1133:     constitutionalCount: constitutionalCount,\n1134:     results: resultsWithConfidence,\n1135:     // Request-level quality assessment (additive)\n1136:     ...(requestQualityData !== null ? requestQualityData : {}),\n1137:     // Recovery payload for weak/partial results (additive)\n1138:     ...(recoveryPayload !== null ? { recovery: recoveryPayload } : {}),\n1139:     citationPolicy,\n1140:     ...(inlineWarnings.length > 0 ? { inlineWarnings, retrievalWarnings: inlineWarnings } : {}),\n1141:     ...(responsePolicy !== null ? { responsePolicy } : {}),\n1142:   };\n1143:   // Preserve caller metadata, but keep trace-only fields opt-in.\n1144:   // Spread extraData first, then re-assert canonical keys to prevent overwrites.\n1145:   if (Object.keys(safeExtraData).length > 0) {\n1146:     const {\n1147:       searchType: _s,\n1148:       count: _c,\n1149:       constitutionalCount: _cc,\n1150:       results: _r,\n1151:       citationPolicy: _cp,\n1152:       responsePolicy: _rp,\n1153:       ...safeExtra\n1154:     } = safeExtraData as Record<string, unknown>;\n1155:     Object.assign(responseData, safeExtra);\n1156:   }\n1157: \n1158:   return createMCPSuccessResponse({\n1159:     tool: 'memory_search',\n\n(Showing lines 780-1159 of 1169. Use offset=1160 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n\nexport async function formatSearchResults(\n  results: RawSearchResult[] | null,\n  searchType: string,\n  include_content: boolean = false,\n  anchors: string[] | null = null,\n  parserOverride: MemoryParserLike | null = null,\n  startTime: number | null = null,\n  extraData: Record<string, unknown> = {},\n  includeTrace: boolean = false,\n  query: string | null = null,\n  specFolder: string | null = null\n): Promise<MCPResponse> {\n  const startMs = startTime || Date.now();\n  const includeContent = include_content;\n  const safeExtraData: Record<string, unknown> = { ...(extraData ?? {}) };\n  if (!includeTrace) {\n    delete safeExtraData.retrievalTrace;\n    delete safeExtraData.sessionTransition;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts","text":"// ────────────────────────────────────────────────────────────────\n\nexport async function formatSearchResults(\n  results: RawSearchResult[] | null,\n  searchType: string,\n  include_content: boolean = false,\n  anchors: string[] | null = null,\n  parserOverride: MemoryParserLike | null = null,\n  startTime: number | null = null,\n  extraData: Record<string, unknown> = {},\n  includeTrace: boolean = false,\n  query: string | null = null,\n  specFolder: string | null = null\n): Promise<MCPResponse> {\n  const startMs = startTime || Date.now();\n  const includeContent = include_content;\n  const safeExtraData: Record<string, unknown> = { ...(extraData ?? {}) };\n  if (!includeTrace) {\n    delete safeExtraData.retrievalTrace;\n    delete safeExtraData.sessionTransition;\n  }\n\n  if (!results || results.length === 0) {\n    // Attach recovery payload when flag is enabled\n    let recoveryPayload: RecoveryPayload | null = null;\n    const requestQualityData = isResultConfidenceEnabled()\n      ? assessRequestQuality([], [])\n      : null;\n    if (isEmptyResultRecoveryEnabled()) {\n      recoveryPayload = buildRecoveryPayload({\n        query,\n        hasSpecFolderFilter: specFolder !== null && specFolder.length > 0,\n        resultCount: 0,\n      });\n    }\n    const responsePolicy = deriveResponsePolicy(requestQualityData, recoveryPayload);\n    const citationPolicy = deriveCitationPolicy(requestQualityData);\n\n    // Use standardized empty response envelope\n    return createMCPEmptyResponse({\n      tool: 'memory_search',\n      summary: 'No matching memories found',\n      data: {\n        searchType: searchType,\n        constitutionalCount: 0,\n        ...(requestQualityData ?? {}),\n        // Preserve caller metadata, but keep trace-only fields opt-in.\n        ...safeExtraData,\n        // Attach recovery payload (additive, only when flag enabled)\n        ...(recoveryPayload !== null ? { recovery: recoveryPayload } : {}),\n        citationPolicy,\n        ...(responsePolicy !== null ? { responsePolicy } : {}),\n      },\n      hints: [\n        'Try broadening your search query',\n        'Use memory_list() to browse available memories',\n        'Check if specFolder filter is too restrictive'\n      ],\n      startTime: startMs\n    });\n  }\n\n  // Count constitutional results\n  const constitutionalCount = results.filter(rawResult => rawResult.isConstitutional).length;\n  const trustBadgeFetch = fetchTrustBadgeSnapshots(results);\n\n  const formatted: MemoryResultEnvelope[] = await Promise.all(results.map(async (rawResult: RawSearchResult, index: number) => {\n    const resultId = toNullableNumber(rawResult.id);\n    const formattedResult: MemoryResultEnvelope = {\n      id: typeof rawResult.id === 'number' ? rawResult.id : Number.parseInt(rawResult.id, 10),\n      specFolder: rawResult.spec_folder ?? String(rawResult.specFolder ?? ''),\n      filePath: rawResult.file_path ?? String(rawResult.filePath ?? ''),\n      title: rawResult.title ?? null,\n      similarity: rawResult.similarity ?? rawResult.averageSimilarity,\n      isConstitutional: rawResult.isConstitutional || false,\n      importanceTier: rawResult.importance_tier,\n      // Use typed validator instead of safeJsonParse cast.\n      triggerPhrases: parseTriggerPhrases(rawResult.triggerPhrases),\n      createdAt: rawResult.created_at,\n      isChunk: rawResult.isChunk === true,\n      parentId: toNullableNumber(rawResult.parentId ?? rawResult.parent_id),\n      chunkIndex: toNullableNumber(rawResult.chunkIndex ?? rawResult.chunk_index),\n      chunkLabel: (typeof rawResult.chunkLabel === 'string'\n        ? rawResult.chunkLabel\n        : (typeof rawResult.chunk_label === 'string' ? rawResult.chunk_label : null)),\n      chunkCount: toNullableNumber(rawResult.chunkCount ?? rawResult.chunk_count),\n      contentSource: (rawResult.contentSource === 'reassembled_chunks' || rawResult.contentSource === 'file_read_fallback')\n        ? rawResult.contentSource\n        : undefined,\n    };\n\n    // Explicit `trustBadges` payloads are\n    // sanitized per-field (allowlisted age strings, clamped\n    // confidence, type-checked booleans). The\n    // sanitized partial is merged onto the derived snapshot\n    // per-field so callers can override specific fields without\n    // wholesale-replacing the badge.\n    const explicitTrustBadgePartial = normalizeExplicitTrustBadges(rawResult.trustBadges);\n    const derivedTrustBadges = toTrustBadges(\n      resultId !== null ? (trustBadgeFetch.snapshots.get(resultId) ?? null) : null\n    );\n    formattedResult.trustBadges = mergeTrustBadges(explicitTrustBadgePartial, derivedTrustBadges);\n\n    if (includeTrace) {\n      const anchorsInfo = extractAnchorDetails(rawResult);\n      formattedResult.scores = {\n        semantic: toNullableNumber(rawResult.similarity ?? rawResult.averageSimilarity),\n        lexical: toNullableNumber(rawResult.fts_score ?? rawResult.bm25_score ?? (rawResult.sourceScores as Record<string, number> | undefined)?.keyword ?? (rawResult.sourceScores as Record<string, number> | undefined)?.fts ?? (rawResult.sourceScores as Record<string, number> | undefined)?.bm25),\n        fusion: toNullableNumber(rawResult.rrfScore),\n        intentAdjusted: toNullableNumber(rawResult.intentAdjustedScore),\n        composite: resolveCompositeScore(rawResult),\n        rerank: toNullableNumber(rawResult.rerankerScore),\n        attention: toNullableNumber(rawResult.attentionScore),\n      };\n      formattedResult.source = {\n        file: typeof rawResult.file_path === 'string' ? rawResult.file_path : null,\n        anchorIds: anchorsInfo.anchorIds,\n        anchorTypes: anchorsInfo.anchorTypes,\n        lastModified: typeof rawResult.updated_at === 'string'\n          ? rawResult.updated_at\n          : (typeof rawResult.created_at === 'string' ? rawResult.created_at : null),\n        memoryState: typeof rawResult.memoryState === 'string' ? rawResult.memoryState : null,\n      };\n      formattedResult.trace = extractTrace(rawResult, extraData);\n      formattedResult.why_ranked = buildWhyRankedTrace(rawResult, index + 1);\n      // stamp the badge-derivation observability\n      // fields onto the trace so operators can distinguish\n      // explicit-vs-derived without inspecting logs.\n      formattedResult.trace.trustBadgeDerivation = {\n        attempted: trustBadgeFetch.attempted,\n        derivedCount: trustBadgeFetch.derivedCount,\n        failureReason: trustBadgeFetch.failureReason,\n      };\n    }\n\n    // Phase C: Include graphEvidence provenance when present on the pipeline row.\n    // The field is populated by Stage 2 when SPECKIT_RESULT_PROVENANCE is enabled.\n    if (rawResult.graphEvidence && typeof rawResult.graphEvidence === 'object') {\n      const evidence = rawResult.graphEvidence as Record<string, unknown>;\n      formattedResult.graphEvidence = {\n        edges: Array.isArray(evidence.edges)\n          ? (evidence.edges as Array<Record<string, unknown>>).map((e) => ({\n              sourceId: typeof e.sourceId === 'number' ? e.sourceId : 0,\n              targetId: typeof e.targetId === 'number' ? e.targetId : 0,\n              relation: typeof e.relation === 'string' ? e.relation : 'unknown',\n              strength: typeof e.strength === 'number' ? e.strength : 1.0,\n            }))\n          : [],\n        communities: Array.isArray(evidence.communities)\n          ? (evidence.communities as Array<Record<string, unknown>>).map((c) => ({\n              communityId: typeof c.communityId === 'number' ? c.communityId : 0,\n              ...(typeof c.summary === 'string' ? { summary: c.summary } : {}),\n            }))\n          : [],\n        boostFactors: Array.isArray(evidence.boostFactors)\n          ? (evidence.boostFactors as Array<Record<string, unknown>>).map((b) => ({\n              type: typeof b.type === 'string' ? b.type : 'unknown',\n              delta: typeof b.delta === 'number' ? b.delta : 0,\n            }))\n          : [],\n      };\n    }\n\n    // Include file content if requested.\n    // Prefer precomputed chunk reassembly from memory-search to avoid disk reads.\n    if (includeContent) {\n      try {\n        let content: string | null = null;\n\n        if (typeof rawResult.precomputedContent === 'string' && rawResult.precomputedContent.length > 0) {\n          content = rawResult.precomputedContent;\n          if (!formattedResult.contentSource) {\n            formattedResult.contentSource = 'reassembled_chunks';\n          }\n        } else if (rawResult.file_path) {\n          // SEC-002: Validate DB-stored file paths before reading (CWE-22 defense-in-depth)\n          const validatedPath = validateFilePathLocal(rawResult.file_path);\n          content = await fs.promises.readFile(validatedPath, 'utf-8');\n          if (!formattedResult.contentSource) {\n            formattedResult.contentSource = 'file_read_fallback';\n          }\n        } else {\n          formattedResult.content = null;\n          formattedResult.contentError = 'File not found';\n          return formattedResult;\n        }\n\n        // Anchor System Implementation\n        const parser: MemoryParserLike = parserOverride || memoryParser;\n        if (anchors && Array.isArray(anchors) && anchors.length > 0 && parser && typeof content === 'string') {\n          // Capture original tokens BEFORE any content reassignment\n          const originalTokens = estimateTokens(content);\n\n          const extracted = parser.extractAnchors(content);\n          const filteredParts: string[] = [];\n          let foundCount = 0;\n\n          for (const anchorId of anchors) {\n            // Prefix matching: try exact match first, then fall back to\n            // Prefix match for composite anchor IDs (e.g. 'summary' matches\n            // 'summary-session-1770903150838-...'). Prefers shortest match to\n            // Select the most specific key when multiple keys share a prefix.\n            const matchingKey = extracted[anchorId] !== undefined\n              ? anchorId\n              : Object.keys(extracted)\n                  .filter(key => key.startsWith(anchorId + '-'))\n                  .sort((a, b) => a.length - b.length)[0] ?? undefined;\n\n            if (matchingKey !== undefined) {\n              filteredParts.push(`<!-- ANCHOR:${matchingKey} -->\\n${extracted[matchingKey]}\\n<!-- /ANCHOR:${matchingKey} -->`);\n              foundCount++;\n            }\n          }\n\n          if (filteredParts.length > 0) {\n            // Warn about missing anchors in partial match\n            // Use same prefix-matching logic for consistency\n            const missingAnchors = anchors.filter(a => {\n              if (extracted[a] !== undefined) return false;\n              return !Object.keys(extracted).some(key => key.startsWith(a + '-'));\n            });\n            if (missingAnchors.length > 0) {\n              filteredParts.push(`<!-- WARNING: Requested anchors not found: ${missingAnchors.join(', ')} -->`);\n            }\n\n            content = filteredParts.join('\\n\\n');\n            const newTokens = estimateTokens(content);\n            const savings = Math.round((1 - newTokens / Math.max(originalTokens, 1)) * 100);\n\n            formattedResult.tokenMetrics = {\n              originalTokens: originalTokens,\n              returnedTokens: newTokens,\n              savingsPercent: savings,\n              anchorsRequested: anchors.length,\n              anchorsFound: foundCount\n            };\n          } else {\n            // No anchors found - return warning; the warning string itself\n            // consumes tokens that budget accounting must account for.\n            content = `<!-- WARNING: Requested anchors not found: ${anchors.join(', ')} -->`;\n            const newTokens = estimateTokens(content);\n            const savings = Math.round((1 - newTokens / Math.max(originalTokens, 1)) * 100);\n            formattedResult.tokenMetrics = {\n              originalTokens: originalTokens,\n              returnedTokens: newTokens,\n              savingsPercent: savings,\n              anchorsRequested: anchors.length,\n              anchorsFound: 0\n            };\n          }\n        }\n\n        formattedResult.content = content;\n      } catch (err: unknown) {\n        formattedResult.content = null;\n        const message = err instanceof Error ? err.message : String(err);\n        // Sanitize error messages to prevent information leakage\n        formattedResult.contentError = message.includes('Access denied')\n          ? 'Security: Access denied'\n          : message.includes('ENOENT')\n            ? 'File not found'\n            : 'Failed to read file';\n      }\n    }\n\n    return formattedResult;\n  }));\n\n  // Compute per-result confidence when flag is enabled (additive, no side-effects)\n  const confidenceEnabled = isResultConfidenceEnabled();\n  let confidenceData: ReturnType<typeof computeResultConfidence> | null = null;\n  let requestQualityData: ReturnType<typeof assessRequestQuality> | null = null;\n  if (confidenceEnabled) {\n    // Cast to ScoredResult — RawSearchResult extends Record<string,unknown> and has the same shape\n    const scoredResults = results as unknown as ScoredResult[];\n    confidenceData = computeResultConfidence(scoredResults);\n    requestQualityData = assessRequestQuality(scoredResults, confidenceData);\n  }\n\n  // Compute recovery payload for weak/partial results when flag is enabled\n  let recoveryPayload: RecoveryPayload | null = null;\n  if (isEmptyResultRecoveryEnabled() && formatted.length > 0) {\n    // Compute average confidence for recovery decision\n    let avgConfidence: number | undefined;\n    if (confidenceData && confidenceData.length > 0) {\n      const sum = confidenceData.reduce((acc, c) => acc + c.confidence.value, 0);\n      avgConfidence = sum / confidenceData.length;\n    }\n\n    const recoveryCtx = {\n      query,\n      hasSpecFolderFilter: specFolder !== null && specFolder.length > 0,\n      evidenceGap: Boolean(safeExtraData?.evidenceGap),\n      resultCount: formatted.length,\n      avgConfidence,\n    };\n\n    if (shouldTriggerRecovery(recoveryCtx)) {\n      recoveryPayload = buildRecoveryPayload(recoveryCtx);\n    }\n  }\n\n  // Build summary based on result characteristics\n  const summary = constitutionalCount > 0\n    ? `Found ${formatted.length} memories (${constitutionalCount} constitutional)`\n    : `Found ${formatted.length} memories`;\n\n  // Build hints based on context\n  const hints: string[] = [];\n  if (includeContent && anchors && anchors.length > 0) {\n    hints.push('Anchor filtering applied for token efficiency');\n  }\n  if (!includeContent && formatted.length > 0) {\n    hints.push('Use includeContent: true to embed file contents in results');\n  }\n  if (formatted.some(r => r.contentError)) {\n    hints.push('Some files could not be read - check file paths');\n  }\n\n  const explainOptions: ExplainabilityOptions = {\n    debugEnabled: process.env.SPECKIT_RESULT_EXPLAIN_DEBUG?.toLowerCase().trim() === 'true',\n  };\n  const explainedRawResults = isResultExplainEnabled()\n    ? attachExplainabilityToResults(\n        results.map(toExplainabilityRow),\n        explainOptions\n      )\n    : null;\n\n  // Merge per-result confidence into the formatted result array (additive)\n  const resultsWithConfidence: Array<Record<string, unknown>> = formatted.map(\n    (r, i): Record<string, unknown> => {\n      const explainedWhy = explainedRawResults?.[i]?.why;\n      const base = explainedWhy\n        ? { ...(r as unknown as Record<string, unknown>), why: explainedWhy }\n        : r as unknown as Record<string, unknown>;\n      if (!confidenceData) return base;\n      const conf = confidenceData[i];\n      if (!conf) return base;\n      return { ...base, ...conf };\n    }\n  );\n\n  const responsePolicy = deriveResponsePolicy(requestQualityData, recoveryPayload);\n  const citationPolicy = deriveCitationPolicy(requestQualityData);\n  const inlineWarnings: RetrievalConflictWarning[] = includeTrace\n    ? findInlineConflictWarnings(results, requireDb)\n    : [];\n\n  // Use standardized success response envelope\n  const responseData: Record<string, unknown> = {\n    searchType: searchType,\n    count: formatted.length,\n    constitutionalCount: constitutionalCount,\n    results: resultsWithConfidence,\n    // Request-level quality assessment (additive)\n    ...(requestQualityData !== null ? requestQualityData : {}),\n    // Recovery payload for weak/partial results (additive)\n    ...(recoveryPayload !== null ? { recovery: recoveryPayload } : {}),\n    citationPolicy,\n    ...(inlineWarnings.length > 0 ? { inlineWarnings, retrievalWarnings: inlineWarnings } : {}),\n    ...(responsePolicy !== null ? { responsePolicy } : {}),\n  };\n  // Preserve caller metadata, but keep trace-only fields opt-in.\n  // Spread extraData first, then re-assert canonical keys to prevent overwrites.\n  if (Object.keys(safeExtraData).length > 0) {\n    const {\n      searchType: _s,\n      count: _c,\n      constitutionalCount: _cc,\n      results: _r,\n      citationPolicy: _cp,\n      responsePolicy: _rp,\n      ...safeExtra\n    } = safeExtraData as Record<string, unknown>;\n    Object.assign(responseData, safeExtra);\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_search',","lineStart":780,"lineEnd":1159,"totalLines":1169,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/formatters/search-results.ts","time":{"start":1781757310693,"end":1781757310713}},"metadata":{"openai":{"itemId":"fc_0485c49dd84de4a6016a33757e8b688191801c1e7beced00a7"}},"id":"prt_ed902f6e2001F0WxHXG3xTcxFA","sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","messageID":"msg_ed902bf0d001NloBDIAYHYdFhL"}}
{"type":"tool_use","timestamp":1781757310717,"sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","part":{"type":"tool","tool":"read","callID":"call_bZBAVlpT9BBfFFMjClOs3J5H","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/d5-confidence-scoring.vitest.ts","offset":302,"limit":60},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/d5-confidence-scoring.vitest.ts</path>\n<type>file</type>\n<content>\n302: // -- assessRequestQuality --\n303: \n304: describe('assessRequestQuality()', () => {\n305:   it('returns \"gap\" when results array is empty', () => {\n306:     const { requestQuality } = assessRequestQuality([], []);\n307:     expect(requestQuality.label).toBe('gap');\n308:   });\n309: \n310:   it('returns \"good\" when most results are high/medium confidence and top score is high', () => {\n311:     const results: ScoredResult[] = [\n312:       { id: 1, score: 0.95, sources: ['semantic', 'lexical'] },\n313:       { id: 2, score: 0.85, sources: ['semantic', 'lexical'] },\n314:       { id: 3, score: 0.8, sources: ['semantic', 'lexical'] },\n315:     ];\n316:     const confidences = computeResultConfidence(results);\n317:     const { requestQuality } = assessRequestQuality(results, confidences);\n318:     expect(requestQuality.label).toBe('good');\n319:   });\n320: \n321:   it('returns \"gap\" when all results have low confidence', () => {\n322:     const results = makeResults([0.05, 0.03, 0.01]);\n323:     const confidences = computeResultConfidence(results);\n324:     const { requestQuality } = assessRequestQuality(results, confidences);\n325:     expect(requestQuality.label).toBe('gap');\n326:   });\n327: \n328:   it('returns \"weak\" for results with mediocre scores and mixed confidence', () => {\n329:     const results = makeResults([0.45, 0.4, 0.35]);\n330:     const confidences = computeResultConfidence(results);\n331:     const { requestQuality } = assessRequestQuality(results, confidences);\n332:     // Scores around 0.4–0.45 → should be \"weak\" (not gap, not good)\n333:     expect(['weak', 'good']).toContain(requestQuality.label);\n334:   });\n335: \n336:   it('requestQuality.label is one of the valid literals', () => {\n337:     const validLabels = ['good', 'weak', 'gap'];\n338:     const results = makeResults([0.6, 0.3]);\n339:     const confidences = computeResultConfidence(results);\n340:     const { requestQuality } = assessRequestQuality(results, confidences);\n341:     expect(validLabels).toContain(requestQuality.label);\n342:   });\n343: \n344:   it('always returns an object with requestQuality.label', () => {\n345:     const results = makeResults([0.9]);\n346:     const confidences = computeResultConfidence(results);\n347:     const assessment = assessRequestQuality(results, confidences);\n348:     expect(assessment).toHaveProperty('requestQuality');\n349:     expect(assessment.requestQuality).toHaveProperty('label');\n350:     expect(typeof assessment.requestQuality.label).toBe('string');\n351:   });\n352: });\n\n(End of file - total 352 lines)\n</content>","metadata":{"preview":"// -- assessRequestQuality --\n\ndescribe('assessRequestQuality()', () => {\n  it('returns \"gap\" when results array is empty', () => {\n    const { requestQuality } = assessRequestQuality([], []);\n    expect(requestQuality.label).toBe('gap');\n  });\n\n  it('returns \"good\" when most results are high/medium confidence and top score is high', () => {\n    const results: ScoredResult[] = [\n      { id: 1, score: 0.95, sources: ['semantic', 'lexical'] },\n      { id: 2, score: 0.85, sources: ['semantic', 'lexical'] },\n      { id: 3, score: 0.8, sources: ['semantic', 'lexical'] },\n    ];\n    const confidences = computeResultConfidence(results);\n    const { requestQuality } = assessRequestQuality(results, confidences);\n    expect(requestQuality.label).toBe('good');\n  });\n\n  it('returns \"gap\" when all results have low confidence', () => {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/d5-confidence-scoring.vitest.ts","text":"// -- assessRequestQuality --\n\ndescribe('assessRequestQuality()', () => {\n  it('returns \"gap\" when results array is empty', () => {\n    const { requestQuality } = assessRequestQuality([], []);\n    expect(requestQuality.label).toBe('gap');\n  });\n\n  it('returns \"good\" when most results are high/medium confidence and top score is high', () => {\n    const results: ScoredResult[] = [\n      { id: 1, score: 0.95, sources: ['semantic', 'lexical'] },\n      { id: 2, score: 0.85, sources: ['semantic', 'lexical'] },\n      { id: 3, score: 0.8, sources: ['semantic', 'lexical'] },\n    ];\n    const confidences = computeResultConfidence(results);\n    const { requestQuality } = assessRequestQuality(results, confidences);\n    expect(requestQuality.label).toBe('good');\n  });\n\n  it('returns \"gap\" when all results have low confidence', () => {\n    const results = makeResults([0.05, 0.03, 0.01]);\n    const confidences = computeResultConfidence(results);\n    const { requestQuality } = assessRequestQuality(results, confidences);\n    expect(requestQuality.label).toBe('gap');\n  });\n\n  it('returns \"weak\" for results with mediocre scores and mixed confidence', () => {\n    const results = makeResults([0.45, 0.4, 0.35]);\n    const confidences = computeResultConfidence(results);\n    const { requestQuality } = assessRequestQuality(results, confidences);\n    // Scores around 0.4–0.45 → should be \"weak\" (not gap, not good)\n    expect(['weak', 'good']).toContain(requestQuality.label);\n  });\n\n  it('requestQuality.label is one of the valid literals', () => {\n    const validLabels = ['good', 'weak', 'gap'];\n    const results = makeResults([0.6, 0.3]);\n    const confidences = computeResultConfidence(results);\n    const { requestQuality } = assessRequestQuality(results, confidences);\n    expect(validLabels).toContain(requestQuality.label);\n  });\n\n  it('always returns an object with requestQuality.label', () => {\n    const results = makeResults([0.9]);\n    const confidences = computeResultConfidence(results);\n    const assessment = assessRequestQuality(results, confidences);\n    expect(assessment).toHaveProperty('requestQuality');\n    expect(assessment.requestQuality).toHaveProperty('label');\n    expect(typeof assessment.requestQuality.label).toBe('string');\n  });\n});","lineStart":302,"lineEnd":352,"totalLines":352,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/d5-confidence-scoring.vitest.ts","time":{"start":1781757310701,"end":1781757310715}},"metadata":{"openai":{"itemId":"fc_0485c49dd84de4a6016a33757e8b708191918ad8bd627abe96"}},"id":"prt_ed902f6e6001oPX8H2kOZ1I73R","sessionID":"ses_126fe9c3cffeLctNH34nBe7kVb","messageID":"msg_ed902bf0d001NloBDIAYHYdFhL"}}
