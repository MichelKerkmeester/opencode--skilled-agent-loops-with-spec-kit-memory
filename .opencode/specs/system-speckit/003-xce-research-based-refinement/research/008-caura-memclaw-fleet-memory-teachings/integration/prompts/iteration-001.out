,\n        parsed.content,\n      );\n      if (verifiedMatch === false) {\n        console.warn(`[memory-save] Hash match for memory #${duplicateByHash.id} failed secondary content verification; continuing save`);\n        return null;\n      }\n      console.error(`[memory-save] T054: Duplicate content detected (hash match id=${duplicateByHash.id}), skipping embedding`);\n      return {\n        status: 'duplicate',\n        id: duplicateByHash.id,\n        specFolder: parsed.specFolder,\n        title: parsed.title ?? duplicateByHash.title ?? '',\n        triggerPhrases: parsed.triggerPhrases,\n        contextType: parsed.contextType,\n        importanceTier: parsed.importanceTier,\n        warnings,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/dedup.ts","text":"    if (duplicateByHash) {\n      const verifiedMatch = verifyStoredContentMatch(\n        duplicateByHash.content_text,\n        duplicateByHash.file_path,\n        parsed.content,\n      );\n      if (verifiedMatch === false) {\n        console.warn(`[memory-save] Hash match for memory #${duplicateByHash.id} failed secondary content verification; continuing save`);\n        return null;\n      }\n      console.error(`[memory-save] T054: Duplicate content detected (hash match id=${duplicateByHash.id}), skipping embedding`);\n      return {\n        status: 'duplicate',\n        id: duplicateByHash.id,\n        specFolder: parsed.specFolder,\n        title: parsed.title ?? duplicateByHash.title ?? '',\n        triggerPhrases: parsed.triggerPhrases,\n        contextType: parsed.contextType,\n        importanceTier: parsed.importanceTier,\n        warnings,\n        message: `Duplicate content detected: identical to existing memory #${duplicateByHash.id} (${duplicateByHash.file_path}). Skipping embedding generation.`,\n      };\n    }\n  }\n\n  return null;\n}","lineStart":330,"lineEnd":356,"totalLines":356,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/dedup.ts","time":{"start":1780738312496,"end":1780738312512}},"metadata":{"openai":{"itemId":"fc_0d13bffc736b6061016a23e908491081919dff93bc9529c0b8"}},"id":"prt_e9c46490a001Qnt84TnWR7mYH9","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c4620d1001Np54i4Id3LJzQR"}}
{"type":"tool_use","timestamp":1780738312529,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_kOsdC11QZeYHjjSlibV5SGjb","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":2340,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n2340:             qualityScore: routedParsed.qualityScore,\n2341:             qualityFlags: routedParsed.qualityFlags,\n2342:             rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n2343:             message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n2344:             qualityGate: {\n2345:               pass: false,\n2346:               reasons: qualityGateResult.reasons,\n2347:               layers: qualityGateResult.layers,\n2348:             },\n2349:           };\n2350:         }\n2351: \n2352:         if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n2353:           console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2354:         }\n2355: \n2356:         if (qualityGateResult.wouldReject) {\n2357:           console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n2358:         }\n2359:       } catch (qgErr: unknown) {\n2360:         const message = qgErr instanceof Error ? qgErr.message : String(qgErr);\n2361:         console.warn(`[memory-save] TM-04: Quality gate error (proceeding with save): ${message}`);\n2362:         // Quality gate errors must not block saves\n2363:       }\n2364:     }\n2365: \n2366:     const duplicatePrecheck = checkContentHashDedup(\n2367:       database,\n2368:       routedParsed,\n2369:       force,\n2370:       validation.warnings,\n2371:       samePathDedupExclusion,\n2372:       scope,\n2373:     );\n2374:     if (duplicatePrecheck) {\n2375:       await repairReplayEnrichmentIfNeeded(database, duplicatePrecheck.id, routedParsed);\n2376:       return duplicatePrecheck;\n2377:     }\n2378: \n2379:     persistPendingEmbeddingCacheWrite(database, pendingCacheWrite, routedFilePath);\n2380: \n2381:     // PE GATING\n2382:     const peResult = evaluateAndApplyPeDecision(\n2383:       database, routedParsed, embedding, force, validation.warnings, embeddingStatus, routedFilePath, scope,\n2384:     );\n2385:     if (peResult.earlyReturn) return peResult.earlyReturn;\n2386: \n2387:     let reconResult: Awaited<ReturnType<typeof runReconsolidationIfEnabled>> = {\n2388:       earlyReturn: null,\n2389:       warnings: [],\n2390:       saveTimeReconsolidation: {\n2391:         status: 'skipped',\n2392:         persistedState: { kind: 'create' },\n2393:       },\n2394:     };\n2395: \n2396:     // Complete async reconsolidation planning before chunking or\n2397:     // taking the SQLite writer lock, so chunked saves do not bypass the gate\n2398:     // and BEGIN IMMEDIATE only covers synchronous DB mutation work.\n2399:     reconResult = await runReconsolidationIfEnabled(\n2400:       database,\n2401:       routedParsed,\n2402:       routedFilePath,\n2403:       force,\n2404:       embedding,\n2405:       scope,\n2406:       { plannerMode },\n2407:     );\n2408:     if (reconResult.earlyReturn) return reconResult.earlyReturn;\n2409:     if (reconResult.saveTimeReconsolidation.status === 'failed') {\n2410:       return buildSaveTimeReconsolidationFailureResult({\n2411:         parsed: routedParsed,\n2412:         validation,\n2413:         reconWarnings: reconResult.warnings,\n2414:         failure: {\n2415:           status: 'failed',\n2416:           reason: reconResult.saveTimeReconsolidation.reason ?? 'conflict_failed',\n2417:           ...(reconResult.saveTimeReconsolidation.warnings\n2418:             ? { warnings: reconResult.saveTimeReconsolidation.warnings }\n2419:             : {}),\n2420:           ...(reconResult.saveTimeReconsolidation.persistedState\n2421:             ? { persistedState: reconResult.saveTimeReconsolidation.persistedState }\n2422:             : {}),\n2423:         },\n2424:       });\n2425:     }\n2426: \n2427:     if (shouldChunkContent) {\n2428:       console.error(`[memory-save] File exceeds chunking threshold (${routedParsed.content.length} chars), using chunked indexing`);\n2429:       const chunkedInsertTracker = createChunkedInsertTracker();\n2430:       const chunkedResult = await indexChunkedMemoryFile(routedFilePath, routedParsed, {\n2431:         force,\n2432:         scope,\n2433:         applyPostInsertMetadata: (db, memoryId, fields) => {\n2434:           applyPostInsertMetadata(db, memoryId, fields);\n2435:           trackChunkedInsert(chunkedInsertTracker, memoryId, fields as Record<string, unknown>);\n2436:         },\n2437:       });\n2438: \n2439:       if (\n2440:         peResult.supersededId != null\n2441:         && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n2442:       ) {\n2443:         try {\n2444:           const finalizeChunkedPeTx = database.transaction(() => {\n2445:             if (chunkedResult.id > 0) {\n2446:               recordCrossPathPeSupersedes(\n2447:                 database,\n2448:                 chunkedResult.id,\n2449:                 peResult.supersededId,\n2450:                 samePathExisting?.id ?? null,\n2451:                 peResult.decision.reason,\n2452:               );\n2453:             }\n2454:             if (peResult.supersededId != null && !markMemorySuperseded(peResult.supersededId)) {\n2455:               throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n2456:             }\n2457:           });\n2458:           finalizeChunkedPeTx.immediate();\n2459:         } catch (supersedeErr: unknown) {\n2460:           const cleanup = rollbackCreatedChunkTree(database, chunkedInsertTracker);\n2461:           const cleanupSuffix = cleanup.cleaned\n2462:             ? ' Rolled back the newly created chunk tree.'\n2463:             : cleanup.attempted && cleanup.error\n2464:               ? ` Cleanup failed: ${cleanup.error}`\n2465:               : '';\n2466:           return {\n2467:             ...chunkedResult,\n2468:             status: 'error',\n2469:             error: `Failed to mark predecessor ${peResult.supersededId} as superseded after chunked indexing: ${getAtomicSaveErrorMessage(supersedeErr)}`,\n\n(Showing lines 2340-2469 of 3763. Use offset=2470 to continue.)\n</content>","metadata":{"preview":"            qualityScore: routedParsed.qualityScore,\n            qualityFlags: routedParsed.qualityFlags,\n            rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            qualityGate: {\n              pass: false,\n              reasons: qualityGateResult.reasons,\n              layers: qualityGateResult.layers,\n            },\n          };\n        }\n\n        if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n          console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n\n        if (qualityGateResult.wouldReject) {\n          console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n      } catch (qgErr: unknown) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"            qualityScore: routedParsed.qualityScore,\n            qualityFlags: routedParsed.qualityFlags,\n            rejectionReason: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            message: `Quality gate rejected: ${qualityGateResult.reasons.join('; ')}`,\n            qualityGate: {\n              pass: false,\n              reasons: qualityGateResult.reasons,\n              layers: qualityGateResult.layers,\n            },\n          };\n        }\n\n        if (!qualityGateResult.pass && qualityGateMode === 'warn-only') {\n          console.warn(`[memory-save] TM-04: Quality gate warn-only (spec doc) for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n\n        if (qualityGateResult.wouldReject) {\n          console.warn(`[memory-save] TM-04: Quality gate WARN-ONLY for ${path.basename(routedFilePath)}: ${qualityGateResult.reasons.join('; ')}`);\n        }\n      } catch (qgErr: unknown) {\n        const message = qgErr instanceof Error ? qgErr.message : String(qgErr);\n        console.warn(`[memory-save] TM-04: Quality gate error (proceeding with save): ${message}`);\n        // Quality gate errors must not block saves\n      }\n    }\n\n    const duplicatePrecheck = checkContentHashDedup(\n      database,\n      routedParsed,\n      force,\n      validation.warnings,\n      samePathDedupExclusion,\n      scope,\n    );\n    if (duplicatePrecheck) {\n      await repairReplayEnrichmentIfNeeded(database, duplicatePrecheck.id, routedParsed);\n      return duplicatePrecheck;\n    }\n\n    persistPendingEmbeddingCacheWrite(database, pendingCacheWrite, routedFilePath);\n\n    // PE GATING\n    const peResult = evaluateAndApplyPeDecision(\n      database, routedParsed, embedding, force, validation.warnings, embeddingStatus, routedFilePath, scope,\n    );\n    if (peResult.earlyReturn) return peResult.earlyReturn;\n\n    let reconResult: Awaited<ReturnType<typeof runReconsolidationIfEnabled>> = {\n      earlyReturn: null,\n      warnings: [],\n      saveTimeReconsolidation: {\n        status: 'skipped',\n        persistedState: { kind: 'create' },\n      },\n    };\n\n    // Complete async reconsolidation planning before chunking or\n    // taking the SQLite writer lock, so chunked saves do not bypass the gate\n    // and BEGIN IMMEDIATE only covers synchronous DB mutation work.\n    reconResult = await runReconsolidationIfEnabled(\n      database,\n      routedParsed,\n      routedFilePath,\n      force,\n      embedding,\n      scope,\n      { plannerMode },\n    );\n    if (reconResult.earlyReturn) return reconResult.earlyReturn;\n    if (reconResult.saveTimeReconsolidation.status === 'failed') {\n      return buildSaveTimeReconsolidationFailureResult({\n        parsed: routedParsed,\n        validation,\n        reconWarnings: reconResult.warnings,\n        failure: {\n          status: 'failed',\n          reason: reconResult.saveTimeReconsolidation.reason ?? 'conflict_failed',\n          ...(reconResult.saveTimeReconsolidation.warnings\n            ? { warnings: reconResult.saveTimeReconsolidation.warnings }\n            : {}),\n          ...(reconResult.saveTimeReconsolidation.persistedState\n            ? { persistedState: reconResult.saveTimeReconsolidation.persistedState }\n            : {}),\n        },\n      });\n    }\n\n    if (shouldChunkContent) {\n      console.error(`[memory-save] File exceeds chunking threshold (${routedParsed.content.length} chars), using chunked indexing`);\n      const chunkedInsertTracker = createChunkedInsertTracker();\n      const chunkedResult = await indexChunkedMemoryFile(routedFilePath, routedParsed, {\n        force,\n        scope,\n        applyPostInsertMetadata: (db, memoryId, fields) => {\n          applyPostInsertMetadata(db, memoryId, fields);\n          trackChunkedInsert(chunkedInsertTracker, memoryId, fields as Record<string, unknown>);\n        },\n      });\n\n      if (\n        peResult.supersededId != null\n        && (chunkedResult.status === 'indexed' || chunkedResult.status === 'updated')\n      ) {\n        try {\n          const finalizeChunkedPeTx = database.transaction(() => {\n            if (chunkedResult.id > 0) {\n              recordCrossPathPeSupersedes(\n                database,\n                chunkedResult.id,\n                peResult.supersededId,\n                samePathExisting?.id ?? null,\n                peResult.decision.reason,\n              );\n            }\n            if (peResult.supersededId != null && !markMemorySuperseded(peResult.supersededId)) {\n              throw new Error(`Failed to mark predecessor ${peResult.supersededId} as superseded`);\n            }\n          });\n          finalizeChunkedPeTx.immediate();\n        } catch (supersedeErr: unknown) {\n          const cleanup = rollbackCreatedChunkTree(database, chunkedInsertTracker);\n          const cleanupSuffix = cleanup.cleaned\n            ? ' Rolled back the newly created chunk tree.'\n            : cleanup.attempted && cleanup.error\n              ? ` Cleanup failed: ${cleanup.error}`\n              : '';\n          return {\n            ...chunkedResult,\n            status: 'error',\n            error: `Failed to mark predecessor ${peResult.supersededId} as superseded after chunked indexing: ${getAtomicSaveErrorMessage(supersedeErr)}`,","lineStart":2340,"lineEnd":2469,"totalLines":3763,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1780738312516,"end":1780738312528}},"metadata":{"openai":{"itemId":"fc_0d13bffc736b6061016a23e9084a84819182904fe173bcd2ab"}},"id":"prt_e9c46493a001CvLxpntfDU9tIV","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c4620d1001Np54i4Id3LJzQR"}}
{"type":"tool_use","timestamp":1780738312532,"sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","part":{"type":"tool","tool":"read","callID":"call_G2NbxxF22Lz2Ijs8IAuPDLX2","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":2901,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n2901: /** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\n2902: async function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n2903:   // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n2904:   // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n2905:   // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n2906:   // carries a code (e.g. preflight.PreflightError) keeps it.\n2907:   const requestId = randomUUID();\n2908:   try {\n2909:     return await handleMemorySaveInner(args, requestId);\n2910:   } catch (error: unknown) {\n2911:     if (error instanceof VRuleUnavailableError) {\n2912:       return createMCPErrorResponse({\n2913:         tool: 'memory_save',\n2914:         error: error.message,\n2915:         code: 'E_RUNTIME',\n2916:         details: { requestId },\n2917:         recovery: {\n2918:           hint: 'Build the Spec Kit scripts workspace and retry the save.',\n2919:           actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n2920:           severity: 'warning',\n2921:         },\n2922:       });\n2923:     }\n2924:     const message = error instanceof Error ? error.message : String(error);\n2925:     const existingCode = (error as { code?: string }).code;\n2926:     const code = typeof existingCode === 'string' && existingCode.length > 0\n2927:       ? existingCode\n2928:       : classifySaveErrorCode(message);\n2929:     return createMCPErrorResponse({\n2930:       tool: 'memory_save',\n2931:       error: message,\n2932:       code,\n2933:       details: { requestId, ...extractSaveErrorDetails(message) },\n2934:       recovery: {\n2935:         hint: 'Inspect the error message for the specific failure; transient DB locks are usually retryable.',\n2936:         actions: ['Resolve the reported cause', 'Retry memory_save'],\n2937:         severity: 'warning',\n2938:       },\n2939:     });\n2940:   }\n2941: }\n2942: \n2943: async function handleMemorySaveInner(args: SaveArgs, requestId: string): Promise<MCPResponse> {\n2944:   await ensureMemoryRuntimeInitialized('handler:memory_save');\n2945: \n2946:   // Fail fast with a clear message when the target file does not exist, before any\n2947:   // path/db processing flattens it into the generic \"unexpected error\" (E081). The\n2948:   // caller-supplied path is safe to echo back.\n2949:   if (typeof args.filePath === 'string' && args.filePath.length > 0) {\n2950:     const probePath = path.isAbsolute(args.filePath)\n2951:       ? args.filePath\n2952:       : path.resolve(process.cwd(), args.filePath);\n2953:     if (!fs.existsSync(probePath)) {\n2954:       return createMCPErrorResponse({\n2955:         tool: 'memory_save',\n2956:         error: `File not found: ${probePath}`,\n2957:         code: 'E089',\n2958:         details: { requestId, filePath: probePath },\n2959:         recovery: {\n2960:           hint: 'Create the file before indexing it; for a new spec folder, generate description.json and graph-metadata.json first.',\n2961:           actions: ['Verify the path exists', 'Scaffold the spec folder metadata before saving its docs'],\n2962:           severity: 'warning',\n2963:         },\n2964:       });\n2965:     }\n2966:   }\n2967: \n2968:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n2969: \n2970:   if (restoreBarrier) {\n2971:     return createMCPErrorResponse({\n2972:       tool: 'memory_save',\n2973:       error: restoreBarrier.message,\n2974:       code: restoreBarrier.code,\n2975:       details: {\n2976:         requestId,\n2977:       },\n2978:       recovery: {\n2979:         hint: 'Retry memory_save after checkpoint_restore maintenance completes.',\n2980:         actions: ['Wait for the restore to finish', 'Retry the save request'],\n2981:         severity: 'warning',\n2982:       },\n2983:     });\n2984:   }\n2985: \n2986:   const {\n2987:     filePath: file_path,\n2988:     force = false,\n2989:     dryRun = false,\n2990:     plannerMode: requestedPlannerMode,\n2991:     skipPreflight = false,\n2992:     asyncEmbedding = false,\n2993:     routeAs,\n2994:     mergeModeHint,\n2995:     targetAnchorId,\n2996:     tenantId,\n2997:     userId,\n2998:     agentId,\n2999:     sessionId,\n3000:     provenanceSource,\n3001:     provenanceActor,\n3002:     governedAt,\n3003:     retentionPolicy,\n3004:     deleteAfter,\n3005:   } = args;\n3006:   const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n3007:   const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n3008: \n3009:   // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n3010:   // Return a classified validation error instead of a bare throw, which the dispatcher would\n3011:   // otherwise flatten into the generic \"unexpected error\" (E081).\n3012:   if (!file_path || typeof file_path !== 'string') {\n3013:     return createMCPErrorResponse({\n3014:       tool: 'memory_save',\n3015:       error: 'filePath is required and must be a string',\n3016:       code: 'E089',\n3017:       details: { requestId },\n3018:       recovery: {\n3019:         hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n3020:         actions: ['Provide a non-empty filePath string', 'Retry memory_save'],\n3021:         severity: 'warning',\n3022:       },\n3023:     });\n3024:   }\n3025: \n3026:   await checkDatabaseUpdated();\n3027: \n3028:   const validatedPath: string = validateFilePathLocal(file_path);\n3029:   const canonicalValidatedPath = resolveCanonicalPath(validatedPath);\n3030:   const database = requireDb();\n\n(Showing lines 2901-3030 of 3763. Use offset=3031 to continue.)\n</content>","metadata":{"preview":"/** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\nasync function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n  // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n  // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n  // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n  // carries a code (e.g. preflight.PreflightError) keeps it.\n  const requestId = randomUUID();\n  try {\n    return await handleMemorySaveInner(args, requestId);\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"/** Handle memory_save tool - validates, indexes, and persists a memory file to the database */\nasync function handleMemorySave(args: SaveArgs): Promise<MCPResponse> {\n  // Top-level classify-catch: any throw that escapes the inner handler (pre-index path/DB\n  // validation, governance runtime setup, etc.) is mapped to a specific code instead of the\n  // generic E081 catch-all the dispatcher would otherwise apply. A thrown error that already\n  // carries a code (e.g. preflight.PreflightError) keeps it.\n  const requestId = randomUUID();\n  try {\n    return await handleMemorySaveInner(args, requestId);\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n    const message = error instanceof Error ? error.message : String(error);\n    const existingCode = (error as { code?: string }).code;\n    const code = typeof existingCode === 'string' && existingCode.length > 0\n      ? existingCode\n      : classifySaveErrorCode(message);\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: message,\n      code,\n      details: { requestId, ...extractSaveErrorDetails(message) },\n      recovery: {\n        hint: 'Inspect the error message for the specific failure; transient DB locks are usually retryable.',\n        actions: ['Resolve the reported cause', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n}\n\nasync function handleMemorySaveInner(args: SaveArgs, requestId: string): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_save');\n\n  // Fail fast with a clear message when the target file does not exist, before any\n  // path/db processing flattens it into the generic \"unexpected error\" (E081). The\n  // caller-supplied path is safe to echo back.\n  if (typeof args.filePath === 'string' && args.filePath.length > 0) {\n    const probePath = path.isAbsolute(args.filePath)\n      ? args.filePath\n      : path.resolve(process.cwd(), args.filePath);\n    if (!fs.existsSync(probePath)) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: `File not found: ${probePath}`,\n        code: 'E089',\n        details: { requestId, filePath: probePath },\n        recovery: {\n          hint: 'Create the file before indexing it; for a new spec folder, generate description.json and graph-metadata.json first.',\n          actions: ['Verify the path exists', 'Scaffold the spec folder metadata before saving its docs'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        requestId,\n      },\n      recovery: {\n        hint: 'Retry memory_save after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the save request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    filePath: file_path,\n    force = false,\n    dryRun = false,\n    plannerMode: requestedPlannerMode,\n    skipPreflight = false,\n    asyncEmbedding = false,\n    routeAs,\n    mergeModeHint,\n    targetAnchorId,\n    tenantId,\n    userId,\n    agentId,\n    sessionId,\n    provenanceSource,\n    provenanceActor,\n    governedAt,\n    retentionPolicy,\n    deleteAfter,\n  } = args;\n  const plannerMode = requestedPlannerMode ?? resolveSavePlannerMode();\n  const shouldPlanCanonicalSave = !dryRun && plannerMode !== 'full-auto' && Boolean(routeAs || mergeModeHint || targetAnchorId);\n\n  // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation).\n  // Return a classified validation error instead of a bare throw, which the dispatcher would\n  // otherwise flatten into the generic \"unexpected error\" (E081).\n  if (!file_path || typeof file_path !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: 'filePath is required and must be a string',\n      code: 'E089',\n      details: { requestId },\n      recovery: {\n        hint: 'Pass an absolute path to a canonical spec document or constitutional memory.',\n        actions: ['Provide a non-empty filePath string', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const validatedPath: string = validateFilePathLocal(file_path);\n  const canonicalValidatedPath = resolveCanonicalPath(validatedPath);\n  const database = requireDb();","lineStart":2901,"lineEnd":3030,"totalLines":3763,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1780738312519,"end":1780738312531}},"metadata":{"openai":{"itemId":"fc_0d13bffc736b6061016a23e9084a9881918933e34418dbda90"}},"id":"prt_e9c464945001YG61FmJK8cA2ZK","sessionID":"ses_163bcc508ffey1OIiwa9Lcz6qq","messageID":"msg_e9c4620d1001Np54i4Id3LJzQR"}}
