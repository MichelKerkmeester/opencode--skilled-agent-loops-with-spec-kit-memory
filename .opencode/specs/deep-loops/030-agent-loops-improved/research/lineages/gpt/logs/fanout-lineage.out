older}`,\n852:     `--max-iterations=${maxIterations}`,\n853:     `--convergence=${convergenceThreshold}`,\n854:     `--stop-policy=${stopPolicy}`,\n855:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n856:     '--lineage-mode=auto',\n857:   ];\n858:   if (loopType === 'research' && options.researchTopic) {\n859:     args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n860:   }\n861: \n862:   return [\n863:     args.join(' '),\n864:     '',\n865:     'PRE-BOUND SETUP ANSWERS:',\n866:     `review_target: ${specFolder}`,\n867:     'review_target_type: spec-folder',\n868:     'review_dimensions: all',\n869:     `spec_folder: ${specFolder}`,\n870:     'execution_mode: AUTONOMOUS',\n871:     'lineage_mode: auto',\n872:     `maxIterations: ${maxIterations}`,\n873:     `convergenceThreshold: ${convergenceThreshold}`,\n874:     `stop_policy: ${stopPolicy}`,\n875:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n876:   ].join('\\n');\n877: }\n878: \n879: /**\n880:  * Compute a generous timeout for a full lineage loop run.\n881:  * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n882:  * We double it for safety and cap at 4 hours.\n883:  */\n884: function computeLineageTimeoutMs(lineage) {\n885:   const iters = lineage.iterations || 12;\n886:   const perIterSecs = lineage.timeoutSeconds || 900;\n887:   return Math.min(iters * perIterSecs * 2 * 1000, 4 * 60 * 60 * 1000);\n888: }\n889: \n890: function normalizeProgressHeartbeatMs(seconds) {\n891:   const value = Number(seconds);\n892:   if (!Number.isFinite(value) || value <= 0) return 0;\n893:   return Math.max(1, Math.floor(value * 1000));\n894: }\n895: \n896: function slotDurationMsFromHrtime(hrStart) {\n897:   const [seconds, nanoseconds] = process.hrtime(hrStart);\n898:   return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n899: }\n900: \n901: function computeSkippedCount(slotDurationMs, intervalMs) {\n902:   const elapsed = Number(slotDurationMs);\n903:   const interval = Number(intervalMs);\n904:   if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n905:     return 0;\n906:   }\n907:   return Math.max(0, Math.floor(elapsed / interval) - 1);\n908: }\n909: \n910: function buildSlotAccounting(hrStart, intervalMs) {\n911:   const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n912:   return {\n913:     slotDurationMs,\n914:     skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n915:   };\n916: }\n917: \n918: function decorateSlotAccountingEvent(event, accountingByLabel) {\n919:   if (!event || typeof event.label !== 'string') return event;\n920:   if (event.event !== 'completed' && event.event !== 'failed') return event;\n921: \n922:   const accounting = accountingByLabel.get(event.label);\n923:   if (!accounting) return event;\n924:   return {\n925:     ...event,\n926:     skippedCount: accounting.skippedCount,\n927:     slotDurationMs: accounting.slotDurationMs,\n928:   };\n929: }\n930: \n931: function startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges }) {\n932:   if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n933:     return () => {};\n934:   }\n935:   const startedAtMs = Date.now();\n936:   const timer = setInterval(() => {\n937:     appendFanoutStatusLedger(ledgerPath, {\n938:       event: 'progress',\n939:       label,\n\n(Showing lines 820-939 of 1515. Use offset=940 to continue.)\n</content>","metadata":{"preview":"          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are a ${agentName} agent running a fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","text":"          `spec_folder: ${specFolder}`,\n          `execution_mode: AUTONOMOUS`,\n          `lineage_mode: auto`,\n          ``,\n        ]\n      : [];\n  return [\n    `You are a ${agentName} agent running a fan-out lineage.`,\n    ...detachedIntro,\n    ``,\n    `Read ${skillFile} and execute the ${loopType} loop with these parameters:`,\n    ...params,\n    ...setupBindings,\n    `The step_resolve_artifact_root step will bind artifact_dir to ${lineageDir} via the`,\n    `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n    `command; bind artifact_dir directly to the override value.`,\n    ``,\n    `Run phase_init, phase_main_loop (${stopClause}), and phase_synthesis.`,\n    `Write all outputs to ${lineageDir}. Do not touch any path outside ${lineageDir}.`,\n    ``,\n    `When complete, output a single line: FANOUT_LINEAGE_COMPLETE:${lineage.label}`,\n  ].join('\\n');\n}\n\nfunction buildNativeCommandInput(loopType, specFolder, lineageDir, lineage, options = {}) {\n  const maxIterations = lineage.iterations || 12;\n  const convergenceThreshold = options.convergenceThreshold ?? 0.1;\n  const stopPolicy = options.stopPolicy || 'convergence';\n  const args = [\n    ':auto',\n    JSON.stringify(specFolder),\n    `--spec-folder=${specFolder}`,\n    `--max-iterations=${maxIterations}`,\n    `--convergence=${convergenceThreshold}`,\n    `--stop-policy=${stopPolicy}`,\n    `--fanout-lineage-artifact-dir=${lineageDir}`,\n    '--lineage-mode=auto',\n  ];\n  if (loopType === 'research' && options.researchTopic) {\n    args.push(`--research-topic=${JSON.stringify(options.researchTopic)}`);\n  }\n\n  return [\n    args.join(' '),\n    '',\n    'PRE-BOUND SETUP ANSWERS:',\n    `review_target: ${specFolder}`,\n    'review_target_type: spec-folder',\n    'review_dimensions: all',\n    `spec_folder: ${specFolder}`,\n    'execution_mode: AUTONOMOUS',\n    'lineage_mode: auto',\n    `maxIterations: ${maxIterations}`,\n    `convergenceThreshold: ${convergenceThreshold}`,\n    `stop_policy: ${stopPolicy}`,\n    `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n  ].join('\\n');\n}\n\n/**\n * Compute a generous timeout for a full lineage loop run.\n * A single iteration is timeoutSeconds; a full loop is up to iterations * timeoutSeconds.\n * We double it for safety and cap at 4 hours.\n */\nfunction computeLineageTimeoutMs(lineage) {\n  const iters = lineage.iterations || 12;\n  const perIterSecs = lineage.timeoutSeconds || 900;\n  return Math.min(iters * perIterSecs * 2 * 1000, 4 * 60 * 60 * 1000);\n}\n\nfunction normalizeProgressHeartbeatMs(seconds) {\n  const value = Number(seconds);\n  if (!Number.isFinite(value) || value <= 0) return 0;\n  return Math.max(1, Math.floor(value * 1000));\n}\n\nfunction slotDurationMsFromHrtime(hrStart) {\n  const [seconds, nanoseconds] = process.hrtime(hrStart);\n  return Math.max(0, (seconds * 1000) + (nanoseconds / 1e6));\n}\n\nfunction computeSkippedCount(slotDurationMs, intervalMs) {\n  const elapsed = Number(slotDurationMs);\n  const interval = Number(intervalMs);\n  if (!Number.isFinite(elapsed) || !Number.isFinite(interval) || interval <= 0) {\n    return 0;\n  }\n  return Math.max(0, Math.floor(elapsed / interval) - 1);\n}\n\nfunction buildSlotAccounting(hrStart, intervalMs) {\n  const slotDurationMs = slotDurationMsFromHrtime(hrStart);\n  return {\n    slotDurationMs,\n    skippedCount: computeSkippedCount(slotDurationMs, intervalMs),\n  };\n}\n\nfunction decorateSlotAccountingEvent(event, accountingByLabel) {\n  if (!event || typeof event.label !== 'string') return event;\n  if (event.event !== 'completed' && event.event !== 'failed') return event;\n\n  const accounting = accountingByLabel.get(event.label);\n  if (!accounting) return event;\n  return {\n    ...event,\n    skippedCount: accounting.skippedCount,\n    slotDurationMs: accounting.slotDurationMs,\n  };\n}\n\nfunction startLineageProgressHeartbeat({ cadenceMs, label, ledgerPath, getGauges }) {\n  if (!Number.isFinite(cadenceMs) || cadenceMs <= 0) {\n    return () => {};\n  }\n  const startedAtMs = Date.now();\n  const timer = setInterval(() => {\n    appendFanoutStatusLedger(ledgerPath, {\n      event: 'progress',\n      label,","lineStart":820,"lineEnd":939,"totalLines":1515,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-run.cjs","time":{"start":1782890309897,"end":1782890309903}},"metadata":{"openai":{"itemId":"fc_0a447f0dd7206b07016a44bf45bc548191b23f2eec2366c049"}},"id":"prt_f1c8b2902001BM55GiNyhY45C6","sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","messageID":"msg_f1c8acb300018FxBTTIOGkECyZ"}}
{"type":"tool_use","timestamp":1782890309921,"sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","part":{"type":"tool","tool":"read","callID":"call_hiLRyDLAdyBgABECCLiUXUtO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs","offset":430,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs</path>\n<type>file</type>\n<content>\n430:   const existingRank = SEVERITY_RANK[existing.severity] ?? 0;\n431:   if (incomingRank > existingRank) {\n432:     Object.assign(existing, {\n433:       ...finding,\n434:       _lineages: mergeLineageLabels(existing, finding, label),\n435:     });\n436:     return;\n437:   }\n438:   addLineage(existing, label);\n439: }\n440: \n441: function flattenFindingBuckets(findingById, idKey, sortKeys) {\n442:   const records = [];\n443:   for (const [baseId, bucket] of findingById) {\n444:     const variants = sortByContentThenId(bucket, sortKeys);\n445:     if (variants.length === 1) {\n446:       records.push(variants[0]);\n447:       continue;\n448:     }\n449:     records.push(...attachConflictMarkers(\n450:       variants.map((variant) => conflictSafeRecord(variant, baseId, idKey)),\n451:       baseId,\n452:       idKey,\n453:     ));\n454:   }\n455:   return sortByContentThenId(records, sortKeys);\n456: }\n457: \n458: // ─────────────────────────────────────────────────────────────────────────────\n459: // 2b. SCHEMA NORMALIZATION\n460: // ─────────────────────────────────────────────────────────────────────────────\n461: \n462: /**\n463:  * Normalize a registry object so that the canonical findings key is populated,\n464:  * tolerating known aliases (e.g. `findings` → `keyFindings` for research,\n465:  * `findings` → `openFindings` for review).\n466:  *\n467:  * Returns { registry, warnings } where warnings is an array of structured\n468:  * schema_mismatch events for every alias hit or unusable-registry skip.\n469:  *\n470:  * @param {object|null} registry\n471:  * @param {{ canonicalKey: string, aliases: Record<string, string>, lineage: string }} opts\n472:  * @returns {{ registry: object|null, warnings: object[] }}\n473:  */\n474: function normalizeRegistrySchema(registry, { canonicalKey, aliases, lineage }) {\n475:   if (!registry) return { registry, warnings: [] };\n476:   const warnings = [];\n477: \n478:   // If canonical key is already present and an array, nothing to do.\n479:   if (Array.isArray(registry[canonicalKey])) {\n480:     return { registry, warnings };\n481:   }\n482: \n483:   // Try each alias in priority order.\n484:   for (const [aliasKey, targetKey] of Object.entries(aliases)) {\n485:     if (Array.isArray(registry[aliasKey])) {\n486:       // Alias found — coerce to canonical key.\n487:       registry[targetKey] = registry[aliasKey];\n488:       warnings.push({\n489:         type: 'schema_mismatch',\n490:         severity: 'warn',\n491:         lineage,\n492:         message: `Registry uses non-canonical key \"${aliasKey}\" instead of \"${targetKey}\"; coerced ${registry[aliasKey].length} entries.`,\n493:         aliasKey,\n494:         canonicalKey: targetKey,\n495:         coercedCount: registry[aliasKey].length,\n496:       });\n497:       return { registry, warnings };\n498:     }\n499:   }\n500: \n501:   // No usable findings array found — registry will be skipped.\n502:   // We cannot count entries that don't exist, but report the skip.\n503:   warnings.push({\n504:     type: 'schema_mismatch',\n505:     severity: 'warn',\n506:     lineage,\n507:     message: `Registry has no usable \"${canonicalKey}\" array (checked aliases: ${Object.keys(aliases).join(', ')}); lineage findings will be skipped.`,\n508:     aliasKey: null,\n509:     canonicalKey,\n510:     coercedCount: 0,\n511:   });\n512: \n513:   return { registry, warnings };\n514: }\n515: \n516: // ─────────────────────────────────────────────────────────────────────────────\n517: // 3. RESEARCH MERGE\n518: // ─────────────────────────────────────────────────────────────────────────────\n519: \n520: /**\n521:  * Merge research findings registries from all lineages.\n522:  * Deduplicates by findingId; cross-model attribution via lineage labels.\n523:  * Returns the merged registry object.\n524:  */\n525: function mergeResearchRegistries(lineageData, options = {}) {\n526:   const mergeOptions = resolveMergeOptions(options);\n527:   const findingById = mergeOptions.enableNearDuplicateDedup ? createFindingBucketIndex() : new Map();\n528:   const schemaWarnings = [];\n529: \n530:   for (const { label, registry: rawRegistry } of lineageData) {\n531:     const { registry, warnings } = normalizeRegistrySchema(rawRegistry, {\n532:       canonicalKey: 'keyFindings',\n533:       aliases: { findings: 'keyFindings' },\n534:       lineage: label,\n535:     });\n536:     for (const w of warnings) {\n537:       schemaWarnings.push(w);\n538:       process.stderr.write(JSON.stringify(w) + '\\n');\n539:     }\n540:     if (!registry || !Array.isArray(registry.keyFindings)) continue;\n541:     for (const finding of registry.keyFindings) {\n542:       const id = finding.id || finding.title;\n543:       if (!id) continue;\n544:       if (mergeOptions.enableNearDuplicateDedup) {\n545:         addResearchFinding(getFindingBucket(findingById, id, finding, true).records, finding, label, mergeOptions);\n546:       } else {\n547:         if (!findingById.has(id)) findingById.set(id, []);\n548:         addResearchFinding(findingById.get(id), finding, label, mergeOptions);\n549:       }\n550:     }\n551:   }\n552: \n553:   const mergedFindings = mergeOptions.enableNearDuplicateDedup\n554:     ? flattenFindingBucketIndex(findingById, 'id', ['id', 'title'])\n555:     : flattenFindingBuckets(findingById, 'id', ['id', 'title']);\n556:   const openQuestionsById = new Map();\n557:   const resolvedQuestionsById = new Map();\n558:   const ruledOutById = new Map();\n559: \n560:   for (const { label, registry } of lineageData) {\n561:     if (!registry) continue;\n562:     for (const q of registry.openQuestions ?? []) {\n563:       const id = q.id || q.question || q.text;\n564:       if (!id) continue;\n565:       if (!openQuestionsById.has(id)) openQuestionsById.set(id, { ...q, _lineages: [label] });\n566:       else {\n567:         const existing = openQuestionsById.get(id);\n568:         addLineage(existing, label);\n569:       }\n570:     }\n571:     // Resolved questions are produced per-lineage by the research reducer but\n572:     // were previously dropped here, under-reporting answered coverage in the\n573:     // merged registry. Collect them with the same id/_lineages discipline.\n574:     for (const q of registry.resolvedQuestions ?? []) {\n575:       const id = q.id || q.question || q.text;\n576:       if (!id) continue;\n577:       if (!resolvedQuestionsById.has(id)) resolvedQuestionsById.set(id, { ...q, _lineages: [label] });\n578:       else {\n579:         const existing = resolvedQuestionsById.get(id);\n580:         addLineage(existing, label);\n581:       }\n582:     }\n583:     for (const d of registry.ruledOutDirections ?? []) {\n584:       const id = d.id || d.direction;\n585:       if (!id) continue;\n586:       if (!ruledOutById.has(id)) ruledOutById.set(id, { ...d, _lineages: [label] });\n587:     }\n588:   }\n589: \n\n(Showing lines 430-589 of 902. Use offset=590 to continue.)\n</content>","metadata":{"preview":"  const existingRank = SEVERITY_RANK[existing.severity] ?? 0;\n  if (incomingRank > existingRank) {\n    Object.assign(existing, {\n      ...finding,\n      _lineages: mergeLineageLabels(existing, finding, label),\n    });\n    return;\n  }\n  addLineage(existing, label);\n}\n\nfunction flattenFindingBuckets(findingById, idKey, sortKeys) {\n  const records = [];\n  for (const [baseId, bucket] of findingById) {\n    const variants = sortByContentThenId(bucket, sortKeys);\n    if (variants.length === 1) {\n      records.push(variants[0]);\n      continue;\n    }\n    records.push(...attachConflictMarkers(","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs","text":"  const existingRank = SEVERITY_RANK[existing.severity] ?? 0;\n  if (incomingRank > existingRank) {\n    Object.assign(existing, {\n      ...finding,\n      _lineages: mergeLineageLabels(existing, finding, label),\n    });\n    return;\n  }\n  addLineage(existing, label);\n}\n\nfunction flattenFindingBuckets(findingById, idKey, sortKeys) {\n  const records = [];\n  for (const [baseId, bucket] of findingById) {\n    const variants = sortByContentThenId(bucket, sortKeys);\n    if (variants.length === 1) {\n      records.push(variants[0]);\n      continue;\n    }\n    records.push(...attachConflictMarkers(\n      variants.map((variant) => conflictSafeRecord(variant, baseId, idKey)),\n      baseId,\n      idKey,\n    ));\n  }\n  return sortByContentThenId(records, sortKeys);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2b. SCHEMA NORMALIZATION\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Normalize a registry object so that the canonical findings key is populated,\n * tolerating known aliases (e.g. `findings` → `keyFindings` for research,\n * `findings` → `openFindings` for review).\n *\n * Returns { registry, warnings } where warnings is an array of structured\n * schema_mismatch events for every alias hit or unusable-registry skip.\n *\n * @param {object|null} registry\n * @param {{ canonicalKey: string, aliases: Record<string, string>, lineage: string }} opts\n * @returns {{ registry: object|null, warnings: object[] }}\n */\nfunction normalizeRegistrySchema(registry, { canonicalKey, aliases, lineage }) {\n  if (!registry) return { registry, warnings: [] };\n  const warnings = [];\n\n  // If canonical key is already present and an array, nothing to do.\n  if (Array.isArray(registry[canonicalKey])) {\n    return { registry, warnings };\n  }\n\n  // Try each alias in priority order.\n  for (const [aliasKey, targetKey] of Object.entries(aliases)) {\n    if (Array.isArray(registry[aliasKey])) {\n      // Alias found — coerce to canonical key.\n      registry[targetKey] = registry[aliasKey];\n      warnings.push({\n        type: 'schema_mismatch',\n        severity: 'warn',\n        lineage,\n        message: `Registry uses non-canonical key \"${aliasKey}\" instead of \"${targetKey}\"; coerced ${registry[aliasKey].length} entries.`,\n        aliasKey,\n        canonicalKey: targetKey,\n        coercedCount: registry[aliasKey].length,\n      });\n      return { registry, warnings };\n    }\n  }\n\n  // No usable findings array found — registry will be skipped.\n  // We cannot count entries that don't exist, but report the skip.\n  warnings.push({\n    type: 'schema_mismatch',\n    severity: 'warn',\n    lineage,\n    message: `Registry has no usable \"${canonicalKey}\" array (checked aliases: ${Object.keys(aliases).join(', ')}); lineage findings will be skipped.`,\n    aliasKey: null,\n    canonicalKey,\n    coercedCount: 0,\n  });\n\n  return { registry, warnings };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. RESEARCH MERGE\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Merge research findings registries from all lineages.\n * Deduplicates by findingId; cross-model attribution via lineage labels.\n * Returns the merged registry object.\n */\nfunction mergeResearchRegistries(lineageData, options = {}) {\n  const mergeOptions = resolveMergeOptions(options);\n  const findingById = mergeOptions.enableNearDuplicateDedup ? createFindingBucketIndex() : new Map();\n  const schemaWarnings = [];\n\n  for (const { label, registry: rawRegistry } of lineageData) {\n    const { registry, warnings } = normalizeRegistrySchema(rawRegistry, {\n      canonicalKey: 'keyFindings',\n      aliases: { findings: 'keyFindings' },\n      lineage: label,\n    });\n    for (const w of warnings) {\n      schemaWarnings.push(w);\n      process.stderr.write(JSON.stringify(w) + '\\n');\n    }\n    if (!registry || !Array.isArray(registry.keyFindings)) continue;\n    for (const finding of registry.keyFindings) {\n      const id = finding.id || finding.title;\n      if (!id) continue;\n      if (mergeOptions.enableNearDuplicateDedup) {\n        addResearchFinding(getFindingBucket(findingById, id, finding, true).records, finding, label, mergeOptions);\n      } else {\n        if (!findingById.has(id)) findingById.set(id, []);\n        addResearchFinding(findingById.get(id), finding, label, mergeOptions);\n      }\n    }\n  }\n\n  const mergedFindings = mergeOptions.enableNearDuplicateDedup\n    ? flattenFindingBucketIndex(findingById, 'id', ['id', 'title'])\n    : flattenFindingBuckets(findingById, 'id', ['id', 'title']);\n  const openQuestionsById = new Map();\n  const resolvedQuestionsById = new Map();\n  const ruledOutById = new Map();\n\n  for (const { label, registry } of lineageData) {\n    if (!registry) continue;\n    for (const q of registry.openQuestions ?? []) {\n      const id = q.id || q.question || q.text;\n      if (!id) continue;\n      if (!openQuestionsById.has(id)) openQuestionsById.set(id, { ...q, _lineages: [label] });\n      else {\n        const existing = openQuestionsById.get(id);\n        addLineage(existing, label);\n      }\n    }\n    // Resolved questions are produced per-lineage by the research reducer but\n    // were previously dropped here, under-reporting answered coverage in the\n    // merged registry. Collect them with the same id/_lineages discipline.\n    for (const q of registry.resolvedQuestions ?? []) {\n      const id = q.id || q.question || q.text;\n      if (!id) continue;\n      if (!resolvedQuestionsById.has(id)) resolvedQuestionsById.set(id, { ...q, _lineages: [label] });\n      else {\n        const existing = resolvedQuestionsById.get(id);\n        addLineage(existing, label);\n      }\n    }\n    for (const d of registry.ruledOutDirections ?? []) {\n      const id = d.id || d.direction;\n      if (!id) continue;\n      if (!ruledOutById.has(id)) ruledOutById.set(id, { ...d, _lineages: [label] });\n    }\n  }\n","lineStart":430,"lineEnd":589,"totalLines":902,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-merge.cjs","time":{"start":1782890309905,"end":1782890309920}},"metadata":{"openai":{"itemId":"fc_0a447f0dd7206b07016a44bf45bc608191b037fc9f24837e55"}},"id":"prt_f1c8b290b001pOfohnGOHXP0GF","sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","messageID":"msg_f1c8acb300018FxBTTIOGkECyZ"}}
{"type":"tool_use","timestamp":1782890309923,"sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","part":{"type":"tool","tool":"read","callID":"call_zTMW3CxPzozc3GfVPixubpqA","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-salvage.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-salvage.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep-Loop Runtime — Fan-Out Lineage Salvage                              ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ Recovers missing iteration files from captured subprocess stdout when    ║\n5: // ║ a CLI executor fails to write outputs (sandbox write restrictions, etc). ║\n6: // ╚══════════════════════════════════════════════════════════════════════════╝\n7: \n8: 'use strict';\n9: \n10: const fs = require('node:fs');\n11: const path = require('node:path');\n12: \n13: if (process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n14:   require('tsx/cjs');\n15: }\n16: \n17: const { mergeJsonlUnderLock } = require('../lib/deep-loop/jsonl-repair.ts');\n18: \n19: const STATE_LOG_BY_LOOP_TYPE = {\n20:   research: 'deep-research-state.jsonl',\n21:   review: 'deep-review-state.jsonl',\n22: };\n23: \n24: /**\n25:  * Parse opencode --format json text parts from subprocess stdout.\n26:  * Opencode emits JSONL lines of {type:\"text\",part:{text:\"...\"}}.\n27:  * Concatenates all text parts; falls back to raw stdout for other executors.\n28:  *\n29:  * @param {string|null} stdout - Combined subprocess stdout.\n30:  * @returns {string|null} Recovered text, or null if nothing substantive.\n31:  */\n32: function extractTextFromOpencodeJson(stdout) {\n33:   if (!stdout || typeof stdout !== 'string') return null;\n34: \n35:   const textParts = [];\n36:   for (const line of stdout.split('\\n')) {\n37:     const trimmed = line.trim();\n38:     if (!trimmed.startsWith('{')) continue;\n39:     try {\n40:       const parsed = JSON.parse(trimmed);\n41:       if (\n42:         parsed &&\n43:         parsed.type === 'text' &&\n44:         parsed.part &&\n45:         typeof parsed.part.text === 'string'\n46:       ) {\n47:         textParts.push(parsed.part.text);\n48:       }\n49:     } catch {\n50:       // non-JSON line — skip\n51:     }\n52:   }\n53: \n54:   if (textParts.length > 0) return textParts.join('').slice(0, 50_000);\n55: \n56:   const raw = stdout.trim();\n57:   return raw.length > 50 ? raw.slice(0, 50_000) : null;\n58: }\n59: \n60: /**\n61:  * After a lineage subprocess exits, recover any missing or empty iteration\n62:  * files from the saved stdout (write-failure salvage path).\n63:  *\n64:  * For each iteration recorded in the state log that lacks its .md file:\n65:  *   - If recoverable text is available: write it and append a\n66:  *     salvaged_from_stdout event to the state log.\n67:  *   - Otherwise: write a failed-marker placeholder so downstream steps\n68:  *     see a file and can apply their own stuck-recovery logic.\n69:  *\n70:  * @param {string} lineageDir - Absolute path to the lineage artifact dir.\n71:  * @param {'research'|'review'} loopType - Loop type for state log naming.\n72:  * @param {string} savedStdout - Captured subprocess stdout.\n73:  * @returns {{ salvaged: number, failed: number }}\n74:  */\n75: function runSalvageSweep(lineageDir, loopType, savedStdout) {\n76:   const stateLogName = STATE_LOG_BY_LOOP_TYPE[loopType];\n77:   if (!stateLogName) return { salvaged: 0, failed: 0 };\n78: \n79:   const stateLogPath = path.join(lineageDir, stateLogName);\n80:   const iterDir = path.join(lineageDir, 'iterations');\n81: \n82:   if (!fs.existsSync(stateLogPath)) return { salvaged: 0, failed: 0 };\n83: \n84:   // Discover which iterations completed by scanning the state log.\n85:   const iterationNumbers = new Set();\n86:   let stateContent;\n87:   try {\n88:     stateContent = fs.readFileSync(stateLogPath, 'utf8');\n89:   } catch {\n90:     return { salvaged: 0, failed: 0 };\n91:   }\n92: \n93:   for (const line of stateContent.trim().split('\\n')) {\n94:     if (!line.trim()) continue;\n95:     try {\n96:       const record = JSON.parse(line);\n97:       if (record && record.type === 'iteration' && typeof record.iteration === 'number') {\n98:         iterationNumbers.add(record.iteration);\n99:       }\n100:     } catch {\n101:       // malformed JSONL — skip\n102:     }\n103:   }\n104: \n105:   if (iterationNumbers.size === 0) return { salvaged: 0, failed: 0 };\n106: \n107:   let salvaged = 0;\n108:   let failed = 0;\n109:   const recoveredText = extractTextFromOpencodeJson(savedStdout);\n110: \n111:   for (const iterNum of iterationNumbers) {\n112:     const iterFile = path.join(iterDir, `iteration-${iterNum}.md`);\n113: \n114:     // Skip iterations that already have a non-empty file.\n115:     if (fs.existsSync(iterFile)) {\n116:       try {\n117:         if (fs.statSync(iterFile).size > 0) continue;\n118:       } catch {\n119:         // stat failed — treat as missing\n120:       }\n121:     }\n122: \n123:     fs.mkdirSync(iterDir, { recursive: true });\n124: \n125:     if (recoveredText) {\n126:       fs.writeFileSync(iterFile, recoveredText, 'utf8');\n127:       const eventRecord = {\n128:         type: 'event',\n129:         event: 'salvaged_from_stdout',\n130:         iteration: iterNum,\n131:         id: 'salvaged_from_stdout',\n132:         source: 'fanout_lineage_stdout',\n133:         bytes_recovered: recoveredText.length,\n134:       };\n135:       mergeJsonlUnderLock(stateLogPath, [eventRecord]);\n136:       salvaged += 1;\n137:     } else {\n138:       fs.writeFileSync(\n139:         iterFile,\n140:         `<!-- fanout_salvage_failed: iteration ${iterNum} content not recoverable from subprocess stdout -->\\n`,\n141:         'utf8',\n142:       );\n143:       failed += 1;\n144:     }\n145:   }\n146: \n147:   return { salvaged, failed };\n148: }\n149: \n150: module.exports = { runSalvageSweep, extractTextFromOpencodeJson };\n\n(End of file - total 150 lines)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out Lineage Salvage                              ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Recovers missing iteration files from captured subprocess stdout when    ║\n// ║ a CLI executor fails to write outputs (sandbox write restrictions, etc). ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nif (process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n  require('tsx/cjs');\n}\n\nconst { mergeJsonlUnderLock } = require('../lib/deep-loop/jsonl-repair.ts');\n\nconst STATE_LOG_BY_LOOP_TYPE = {\n  research: 'deep-research-state.jsonl',","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-salvage.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out Lineage Salvage                              ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Recovers missing iteration files from captured subprocess stdout when    ║\n// ║ a CLI executor fails to write outputs (sandbox write restrictions, etc). ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\nconst fs = require('node:fs');\nconst path = require('node:path');\n\nif (process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n  require('tsx/cjs');\n}\n\nconst { mergeJsonlUnderLock } = require('../lib/deep-loop/jsonl-repair.ts');\n\nconst STATE_LOG_BY_LOOP_TYPE = {\n  research: 'deep-research-state.jsonl',\n  review: 'deep-review-state.jsonl',\n};\n\n/**\n * Parse opencode --format json text parts from subprocess stdout.\n * Opencode emits JSONL lines of {type:\"text\",part:{text:\"...\"}}.\n * Concatenates all text parts; falls back to raw stdout for other executors.\n *\n * @param {string|null} stdout - Combined subprocess stdout.\n * @returns {string|null} Recovered text, or null if nothing substantive.\n */\nfunction extractTextFromOpencodeJson(stdout) {\n  if (!stdout || typeof stdout !== 'string') return null;\n\n  const textParts = [];\n  for (const line of stdout.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed.startsWith('{')) continue;\n    try {\n      const parsed = JSON.parse(trimmed);\n      if (\n        parsed &&\n        parsed.type === 'text' &&\n        parsed.part &&\n        typeof parsed.part.text === 'string'\n      ) {\n        textParts.push(parsed.part.text);\n      }\n    } catch {\n      // non-JSON line — skip\n    }\n  }\n\n  if (textParts.length > 0) return textParts.join('').slice(0, 50_000);\n\n  const raw = stdout.trim();\n  return raw.length > 50 ? raw.slice(0, 50_000) : null;\n}\n\n/**\n * After a lineage subprocess exits, recover any missing or empty iteration\n * files from the saved stdout (write-failure salvage path).\n *\n * For each iteration recorded in the state log that lacks its .md file:\n *   - If recoverable text is available: write it and append a\n *     salvaged_from_stdout event to the state log.\n *   - Otherwise: write a failed-marker placeholder so downstream steps\n *     see a file and can apply their own stuck-recovery logic.\n *\n * @param {string} lineageDir - Absolute path to the lineage artifact dir.\n * @param {'research'|'review'} loopType - Loop type for state log naming.\n * @param {string} savedStdout - Captured subprocess stdout.\n * @returns {{ salvaged: number, failed: number }}\n */\nfunction runSalvageSweep(lineageDir, loopType, savedStdout) {\n  const stateLogName = STATE_LOG_BY_LOOP_TYPE[loopType];\n  if (!stateLogName) return { salvaged: 0, failed: 0 };\n\n  const stateLogPath = path.join(lineageDir, stateLogName);\n  const iterDir = path.join(lineageDir, 'iterations');\n\n  if (!fs.existsSync(stateLogPath)) return { salvaged: 0, failed: 0 };\n\n  // Discover which iterations completed by scanning the state log.\n  const iterationNumbers = new Set();\n  let stateContent;\n  try {\n    stateContent = fs.readFileSync(stateLogPath, 'utf8');\n  } catch {\n    return { salvaged: 0, failed: 0 };\n  }\n\n  for (const line of stateContent.trim().split('\\n')) {\n    if (!line.trim()) continue;\n    try {\n      const record = JSON.parse(line);\n      if (record && record.type === 'iteration' && typeof record.iteration === 'number') {\n        iterationNumbers.add(record.iteration);\n      }\n    } catch {\n      // malformed JSONL — skip\n    }\n  }\n\n  if (iterationNumbers.size === 0) return { salvaged: 0, failed: 0 };\n\n  let salvaged = 0;\n  let failed = 0;\n  const recoveredText = extractTextFromOpencodeJson(savedStdout);\n\n  for (const iterNum of iterationNumbers) {\n    const iterFile = path.join(iterDir, `iteration-${iterNum}.md`);\n\n    // Skip iterations that already have a non-empty file.\n    if (fs.existsSync(iterFile)) {\n      try {\n        if (fs.statSync(iterFile).size > 0) continue;\n      } catch {\n        // stat failed — treat as missing\n      }\n    }\n\n    fs.mkdirSync(iterDir, { recursive: true });\n\n    if (recoveredText) {\n      fs.writeFileSync(iterFile, recoveredText, 'utf8');\n      const eventRecord = {\n        type: 'event',\n        event: 'salvaged_from_stdout',\n        iteration: iterNum,\n        id: 'salvaged_from_stdout',\n        source: 'fanout_lineage_stdout',\n        bytes_recovered: recoveredText.length,\n      };\n      mergeJsonlUnderLock(stateLogPath, [eventRecord]);\n      salvaged += 1;\n    } else {\n      fs.writeFileSync(\n        iterFile,\n        `<!-- fanout_salvage_failed: iteration ${iterNum} content not recoverable from subprocess stdout -->\\n`,\n        'utf8',\n      );\n      failed += 1;\n    }\n  }\n\n  return { salvaged, failed };\n}\n\nmodule.exports = { runSalvageSweep, extractTextFromOpencodeJson };","lineStart":1,"lineEnd":150,"totalLines":150,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-salvage.cjs","time":{"start":1782890309914,"end":1782890309922}},"metadata":{"openai":{"itemId":"fc_0a447f0dd7206b07016a44bf45bc6c8191ab662806e6fba47d"}},"id":"prt_f1c8b29170011y0ArrjQPsG57z","sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","messageID":"msg_f1c8acb300018FxBTTIOGkECyZ"}}
{"type":"tool_use","timestamp":1782890309988,"sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","part":{"type":"tool","tool":"read","callID":"call_NtpvTP3ir5cg4eMDpyvgepQj","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs</path>\n<type>file</type>\n<content>\n1: // ╔══════════════════════════════════════════════════════════════════════════╗\n2: // ║ Deep-Loop Runtime — Fan-Out Worker Pool                                   ║\n3: // ╠══════════════════════════════════════════════════════════════════════════╣\n4: // ║ Concurrency-capped fan-out primitive for the opt-in multi-executor        ║\n5: // ║ (\"fan-out\") layer above the single-executor deep-loop. Generalizes the    ║\n6: // ║ council parallel dispatcher (lib/council/multi-seat-dispatch.cjs) by      ║\n7: // ║ adding a concurrency cap so N executor lineages run with at most K in      ║\n8: // ║ flight, plus a status-ledger writer following the proven                  ║\n9: // ║ orchestration-status.log ledger pattern.                                   ║\n10: // ║                                                                           ║\n11: // ║ Design: pure pool primitive (worker is INJECTED) + ledger helpers, fully  ║\n12: // ║ unit-tested. The real spawn worker and the CLI entry that wires it        ║\n13: // ║ (arg parse, JSON-out, exit codes) live in fanout-run.cjs.                ║\n14: // ╚══════════════════════════════════════════════════════════════════════════╝\n15: \n16: 'use strict';\n17: \n18: // ─────────────────────────────────────────────────────────────────────────────\n19: // 1. IMPORTS\n20: // ─────────────────────────────────────────────────────────────────────────────\n21: \n22: const fs = require('node:fs');\n23: const path = require('node:path');\n24: const { classifyLineageFailure } = require('./lib/cli-guards.cjs');\n25: \n26: // ─────────────────────────────────────────────────────────────────────────────\n27: // 2. CONSTANTS\n28: // ─────────────────────────────────────────────────────────────────────────────\n29: \n30: const LAG_CEILING_ACTION_ABORT_REQUEUE = 'abort-requeue';\n31: const WAVE_ASSIGNMENT_MODEL = 'wave';\n32: const WAVE_PLANNER_STATUS_DORMANT = 'dormant';\n33: const WAVE_PLANNER_DORMANT_MESSAGE = 'wave planner is dormant until conflict-safety substrate is available';\n34: \n35: // ─────────────────────────────────────────────────────────────────────────────\n36: // 3. HELPERS\n37: // ─────────────────────────────────────────────────────────────────────────────\n38: \n39: function isRecord(value) {\n40:   return value !== null && typeof value === 'object' && !Array.isArray(value);\n41: }\n42: \n43: function normalizeTimestamp(value) {\n44:   if (value instanceof Date) {\n45:     return value.toISOString();\n46:   }\n47:   if (typeof value === 'string' && value.trim() !== '') {\n48:     return value;\n49:   }\n50:   return new Date().toISOString();\n51: }\n52: \n53: function normalizeConcurrency(value) {\n54:   const n = Number(value);\n55:   if (!Number.isFinite(n) || n < 1) {\n56:     return 1;\n57:   }\n58:   return Math.floor(n);\n59: }\n60: \n61: function labelFor(item, index) {\n62:   if (isRecord(item) && typeof item.label === 'string' && item.label.trim() !== '') {\n63:     return item.label;\n64:   }\n65:   return `item-${index}`;\n66: }\n67: \n68: function buildPoolGauges({ total, settled, pending, failed, oldestPendingLagMs }) {\n69:   const gauges = {\n70:     lag: Math.max(0, total - settled),\n71:     pending: Math.max(0, pending),\n72:     failed: Math.max(0, failed),\n73:   };\n74:   if (Number.isFinite(oldestPendingLagMs)) {\n75:     gauges.oldest_pending_lag_ms = Math.max(0, Math.floor(oldestPendingLagMs));\n76:   }\n77:   return gauges;\n78: }\n79: \n80: function normalizeMaxRetries(value) {\n81:   if (value === undefined || value === null) {\n82:     return 0;\n83:   }\n84:   const n = Number(value);\n85:   if (!Number.isFinite(n) || n < 0) {\n86:     return 0;\n87:   }\n88:   return Math.floor(n);\n89: }\n90: \n91: function normalizeNonNegativeDuration(value) {\n92:   if (value === undefined || value === null) {\n93:     return 0;\n94:   }\n95:   const n = Number(value);\n96:   if (!Number.isFinite(n) || n < 0) {\n97:     return 0;\n98:   }\n99:   return Math.floor(n);\n100: }\n101: \n102: function normalizeLagCeilingAction(value) {\n103:   if (value === undefined || value === null || value === '') {\n104:     return null;\n105:   }\n106:   const action = String(value).trim();\n107:   if (action !== LAG_CEILING_ACTION_ABORT_REQUEUE) {\n108:     throw new TypeError('lagCeilingAction must be \"abort-requeue\" when set');\n109:   }\n110:   return action;\n111: }\n112: \n113: function normalizeRetryCountMap(value) {\n114:   const counts = new Map();\n115:   if (!isRecord(value)) {\n116:     return counts;\n117:   }\n118:   for (const [label, count] of Object.entries(value)) {\n119:     const n = Number(count);\n120:     if (typeof label === 'string' && label && Number.isFinite(n) && n > 0) {\n121:       counts.set(label, Math.floor(n));\n122:     }\n123:   }\n124:   return counts;\n125: }\n126: \n127: function buildFailureClassRollup(results) {\n128:   const rollup = {\n129:     timeout: 0,\n130:     exit: 0,\n131:     salvage_miss: 0,\n132:   };\n133:   for (const result of results) {\n134:     if (!result || result.status !== 'rejected') {\n135:       continue;\n136:     }\n137:     const failureClass = result.error && typeof result.error.failure_class === 'string'\n138:       ? result.error.failure_class\n139:       : 'exit';\n140:     if (Object.prototype.hasOwnProperty.call(rollup, failureClass)) {\n141:       rollup[failureClass] += 1;\n142:     }\n143:   }\n144:   return rollup;\n145: }\n146: \n147: function normalizeError(error) {\n148:   const classification = classifyLineageFailure(error);\n149:   return {\n150:     name: error && error.name ? String(error.name) : 'Error',\n151:     message: error && error.message ? String(error.message) : String(error),\n152:     ...classification,\n153:   };\n154: }\n155: \n156: function buildLagCeilingTimeoutError({ label, lagMs, lagCeilingMs }) {\n157:   const error = new Error(\n158:     `lineage ${label} exceeded lag ceiling ${lagCeilingMs}ms after ${Math.max(0, Math.floor(lagMs))}ms without pool progress`,\n159:   );\n160:   error.name = 'AbortError';\n161:   error.timedOut = true;\n162:   error.exitCode = null;\n163:   return error;\n164: }\n165: \n166: function throwDormantWavePlannerError() {\n167:   throw new Error(WAVE_PLANNER_DORMANT_MESSAGE);\n168: }\n169: \n170: /**\n171:  * Create the dormant wave-planner contract for future dependency-aware dispatch.\n172:  *\n173:  * The methods name the future planning phases without routing production traffic\n174:  * through them. Runtime dispatch stays on `runCappedPool` until conflict safety\n175:  * can make overlapping write domains unrepresentable.\n176:  *\n177:  * @returns {Object} Dormant planner interface.\n178:  */\n179: function createWavePlannerInterface() {\n180:   return Object.freeze({\n181:     assignmentModel: WAVE_ASSIGNMENT_MODEL,\n182:     status: WAVE_PLANNER_STATUS_DORMANT,\n183:     selectEligibleAssignments: throwDormantWavePlannerError,\n184:     packDisjointGroups: throwDormantWavePlannerError,\n185:     capConcurrentGroups: throwDormantWavePlannerError,\n186:     planWave: throwDormantWavePlannerError,\n187:   });\n188: }\n189: \n190: function readLedgerRecords(ledgerPath) {\n191:   if (!ledgerPath || !fs.existsSync(ledgerPath)) {\n192:     return [];\n193:   }\n194: \n195:   let content;\n196:   try {\n197:     content = fs.readFileSync(ledgerPath, 'utf8');\n198:   } catch {\n199:     return [];\n200:   }\n201: \n202:   const records = [];\n203:   for (const line of content.split('\\n')) {\n204:     const trimmed = line.trim();\n205:     if (!trimmed) {\n206:       continue;\n207:     }\n208:     try {\n209:       const parsed = JSON.parse(trimmed);\n210:       if (isRecord(parsed)) {\n211:         records.push(parsed);\n212:       }\n213:     } catch {\n214:       // A malformed status row cannot safely create retry credit.\n215:     }\n216:   }\n217:   return records;\n218: }\n219: \n220: function readRetryCountsFromLedger(ledgerPath) {\n221:   const counts = {};\n222:   for (const record of readLedgerRecords(ledgerPath)) {\n223:     if (record.event !== 'retry_scheduled' || typeof record.label !== 'string') {\n224:       continue;\n225:     }\n226:     counts[record.label] = (counts[record.label] || 0) + 1;\n227:   }\n228:   return counts;\n229: }\n230: \n231: function detectOrphanedLineages(records) {\n232:   const open = new Map();\n233:   for (const record of records) {\n234:     if (!isRecord(record) || typeof record.label !== 'string' || !record.label) {\n235:       continue;\n236:     }\n237:     if (record.event === 'started') {\n238:       open.set(record.label, record);\n239:     } else if (\n240:       record.event === 'completed'\n241:       || record.event === 'failed'\n242:       || record.event === 'orphan_requeued'\n243:     ) {\n244:       open.delete(record.label);\n245:     }\n246:   }\n247:   return Array.from(open.values()).map((record) => ({\n248:     label: record.label,\n249:     index: Number.isFinite(Number(record.index)) ? Number(record.index) : null,\n250:     started_at_iso: typeof record.at === 'string' ? record.at : null,\n251:   }));\n252: }\n253: \n254: function markOrphanedLineages(ledgerPath, options = {}) {\n255:   const orphans = detectOrphanedLineages(readLedgerRecords(ledgerPath));\n256:   if (!orphans.length) {\n257:     return [];\n258:   }\n259:   const now = typeof options.now === 'function' ? options.now : () => new Date();\n260:   for (const orphan of orphans) {\n\n(Showing lines 1-260 of 767. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out Worker Pool                                   ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Concurrency-capped fan-out primitive for the opt-in multi-executor        ║\n// ║ (\"fan-out\") layer above the single-executor deep-loop. Generalizes the    ║\n// ║ council parallel dispatcher (lib/council/multi-seat-dispatch.cjs) by      ║\n// ║ adding a concurrency cap so N executor lineages run with at most K in      ║\n// ║ flight, plus a status-ledger writer following the proven                  ║\n// ║ orchestration-status.log ledger pattern.                                   ║\n// ║                                                                           ║\n// ║ Design: pure pool primitive (worker is INJECTED) + ledger helpers, fully  ║\n// ║ unit-tested. The real spawn worker and the CLI entry that wires it        ║\n// ║ (arg parse, JSON-out, exit codes) live in fanout-run.cjs.                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","text":"// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Fan-Out Worker Pool                                   ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Concurrency-capped fan-out primitive for the opt-in multi-executor        ║\n// ║ (\"fan-out\") layer above the single-executor deep-loop. Generalizes the    ║\n// ║ council parallel dispatcher (lib/council/multi-seat-dispatch.cjs) by      ║\n// ║ adding a concurrency cap so N executor lineages run with at most K in      ║\n// ║ flight, plus a status-ledger writer following the proven                  ║\n// ║ orchestration-status.log ledger pattern.                                   ║\n// ║                                                                           ║\n// ║ Design: pure pool primitive (worker is INJECTED) + ledger helpers, fully  ║\n// ║ unit-tested. The real spawn worker and the CLI entry that wires it        ║\n// ║ (arg parse, JSON-out, exit codes) live in fanout-run.cjs.                ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { classifyLineageFailure } = require('./lib/cli-guards.cjs');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst LAG_CEILING_ACTION_ABORT_REQUEUE = 'abort-requeue';\nconst WAVE_ASSIGNMENT_MODEL = 'wave';\nconst WAVE_PLANNER_STATUS_DORMANT = 'dormant';\nconst WAVE_PLANNER_DORMANT_MESSAGE = 'wave planner is dormant until conflict-safety substrate is available';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction isRecord(value) {\n  return value !== null && typeof value === 'object' && !Array.isArray(value);\n}\n\nfunction normalizeTimestamp(value) {\n  if (value instanceof Date) {\n    return value.toISOString();\n  }\n  if (typeof value === 'string' && value.trim() !== '') {\n    return value;\n  }\n  return new Date().toISOString();\n}\n\nfunction normalizeConcurrency(value) {\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 1) {\n    return 1;\n  }\n  return Math.floor(n);\n}\n\nfunction labelFor(item, index) {\n  if (isRecord(item) && typeof item.label === 'string' && item.label.trim() !== '') {\n    return item.label;\n  }\n  return `item-${index}`;\n}\n\nfunction buildPoolGauges({ total, settled, pending, failed, oldestPendingLagMs }) {\n  const gauges = {\n    lag: Math.max(0, total - settled),\n    pending: Math.max(0, pending),\n    failed: Math.max(0, failed),\n  };\n  if (Number.isFinite(oldestPendingLagMs)) {\n    gauges.oldest_pending_lag_ms = Math.max(0, Math.floor(oldestPendingLagMs));\n  }\n  return gauges;\n}\n\nfunction normalizeMaxRetries(value) {\n  if (value === undefined || value === null) {\n    return 0;\n  }\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) {\n    return 0;\n  }\n  return Math.floor(n);\n}\n\nfunction normalizeNonNegativeDuration(value) {\n  if (value === undefined || value === null) {\n    return 0;\n  }\n  const n = Number(value);\n  if (!Number.isFinite(n) || n < 0) {\n    return 0;\n  }\n  return Math.floor(n);\n}\n\nfunction normalizeLagCeilingAction(value) {\n  if (value === undefined || value === null || value === '') {\n    return null;\n  }\n  const action = String(value).trim();\n  if (action !== LAG_CEILING_ACTION_ABORT_REQUEUE) {\n    throw new TypeError('lagCeilingAction must be \"abort-requeue\" when set');\n  }\n  return action;\n}\n\nfunction normalizeRetryCountMap(value) {\n  const counts = new Map();\n  if (!isRecord(value)) {\n    return counts;\n  }\n  for (const [label, count] of Object.entries(value)) {\n    const n = Number(count);\n    if (typeof label === 'string' && label && Number.isFinite(n) && n > 0) {\n      counts.set(label, Math.floor(n));\n    }\n  }\n  return counts;\n}\n\nfunction buildFailureClassRollup(results) {\n  const rollup = {\n    timeout: 0,\n    exit: 0,\n    salvage_miss: 0,\n  };\n  for (const result of results) {\n    if (!result || result.status !== 'rejected') {\n      continue;\n    }\n    const failureClass = result.error && typeof result.error.failure_class === 'string'\n      ? result.error.failure_class\n      : 'exit';\n    if (Object.prototype.hasOwnProperty.call(rollup, failureClass)) {\n      rollup[failureClass] += 1;\n    }\n  }\n  return rollup;\n}\n\nfunction normalizeError(error) {\n  const classification = classifyLineageFailure(error);\n  return {\n    name: error && error.name ? String(error.name) : 'Error',\n    message: error && error.message ? String(error.message) : String(error),\n    ...classification,\n  };\n}\n\nfunction buildLagCeilingTimeoutError({ label, lagMs, lagCeilingMs }) {\n  const error = new Error(\n    `lineage ${label} exceeded lag ceiling ${lagCeilingMs}ms after ${Math.max(0, Math.floor(lagMs))}ms without pool progress`,\n  );\n  error.name = 'AbortError';\n  error.timedOut = true;\n  error.exitCode = null;\n  return error;\n}\n\nfunction throwDormantWavePlannerError() {\n  throw new Error(WAVE_PLANNER_DORMANT_MESSAGE);\n}\n\n/**\n * Create the dormant wave-planner contract for future dependency-aware dispatch.\n *\n * The methods name the future planning phases without routing production traffic\n * through them. Runtime dispatch stays on `runCappedPool` until conflict safety\n * can make overlapping write domains unrepresentable.\n *\n * @returns {Object} Dormant planner interface.\n */\nfunction createWavePlannerInterface() {\n  return Object.freeze({\n    assignmentModel: WAVE_ASSIGNMENT_MODEL,\n    status: WAVE_PLANNER_STATUS_DORMANT,\n    selectEligibleAssignments: throwDormantWavePlannerError,\n    packDisjointGroups: throwDormantWavePlannerError,\n    capConcurrentGroups: throwDormantWavePlannerError,\n    planWave: throwDormantWavePlannerError,\n  });\n}\n\nfunction readLedgerRecords(ledgerPath) {\n  if (!ledgerPath || !fs.existsSync(ledgerPath)) {\n    return [];\n  }\n\n  let content;\n  try {\n    content = fs.readFileSync(ledgerPath, 'utf8');\n  } catch {\n    return [];\n  }\n\n  const records = [];\n  for (const line of content.split('\\n')) {\n    const trimmed = line.trim();\n    if (!trimmed) {\n      continue;\n    }\n    try {\n      const parsed = JSON.parse(trimmed);\n      if (isRecord(parsed)) {\n        records.push(parsed);\n      }\n    } catch {\n      // A malformed status row cannot safely create retry credit.\n    }\n  }\n  return records;\n}\n\nfunction readRetryCountsFromLedger(ledgerPath) {\n  const counts = {};\n  for (const record of readLedgerRecords(ledgerPath)) {\n    if (record.event !== 'retry_scheduled' || typeof record.label !== 'string') {\n      continue;\n    }\n    counts[record.label] = (counts[record.label] || 0) + 1;\n  }\n  return counts;\n}\n\nfunction detectOrphanedLineages(records) {\n  const open = new Map();\n  for (const record of records) {\n    if (!isRecord(record) || typeof record.label !== 'string' || !record.label) {\n      continue;\n    }\n    if (record.event === 'started') {\n      open.set(record.label, record);\n    } else if (\n      record.event === 'completed'\n      || record.event === 'failed'\n      || record.event === 'orphan_requeued'\n    ) {\n      open.delete(record.label);\n    }\n  }\n  return Array.from(open.values()).map((record) => ({\n    label: record.label,\n    index: Number.isFinite(Number(record.index)) ? Number(record.index) : null,\n    started_at_iso: typeof record.at === 'string' ? record.at : null,\n  }));\n}\n\nfunction markOrphanedLineages(ledgerPath, options = {}) {\n  const orphans = detectOrphanedLineages(readLedgerRecords(ledgerPath));\n  if (!orphans.length) {\n    return [];\n  }\n  const now = typeof options.now === 'function' ? options.now : () => new Date();\n  for (const orphan of orphans) {","lineStart":1,"lineEnd":260,"totalLines":767,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/scripts/fanout-pool.cjs","time":{"start":1782890309978,"end":1782890309986}},"metadata":{"openai":{"itemId":"fc_0a447f0dd7206b07016a44bf45bc7481919eee291c9f198fca"}},"id":"prt_f1c8b291c0016214wPdqgZB3gR","sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","messageID":"msg_f1c8acb300018FxBTTIOGkECyZ"}}
{"type":"tool_use","timestamp":1782890310052,"sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","part":{"type":"tool","tool":"read","callID":"call_OtPE9unB2XrC0tueA5GF3FHh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: \n3: // ╔══════════════════════════════════════════════════════════════════════════╗\n4: // ║ Deep-Loop Runtime — Loop-Lock CLI Adapter                               ║\n5: // ╠══════════════════════════════════════════════════════════════════════════╣\n6: // ║ Thin CLI front door over lib/deep-loop/loop-lock.ts so non-TS callers    ║\n7: // ║ (command YAML, shells, other runtimes) share one locking contract        ║\n8: // ║ instead of drifting per mode. Every subcommand is a direct pass-through  ║\n9: // ║ to the library; the adapter adds only argv parsing and JSON framing.     ║\n10: // ║                                                                          ║\n11: // ║ Subcommands:                                                             ║\n12: // ║   acquire --lock-path P --packet-id X [--ttl-ms N] [--runtime-kind K]    ║\n13: // ║           [--owner-pid PID]                                              ║\n14: // ║   status  --lock-path P                                                  ║\n15: // ║   refresh --lock-path P --owner-pid PID                                  ║\n16: // ║   release --lock-path P --owner-pid PID                                  ║\n17: // ║ Output: one JSON object on stdout.                                       ║\n18: // ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n19: // ║                                                                          ║\n20: // ║ deep_research / deep_review / deep_ai-council YAMLs call THIS adapter.    ║\n21: // ║ Sanctioned exception to the \"one contract\" claim: deep-context keeps a    ║\n22: // ║ separate host-facing wrapper                                             ║\n23: // ║ (deep-loop-workflows/deep-context/scripts/loop-lock.cjs) with a          ║\n24: // ║ different CLI surface (--lock/--packet/--owner), a longer default TTL     ║\n25: // ║ (1h vs 5min), and in-process require() loading, because the host-driven   ║\n26: // ║ context loop has no single long-lived heartbeat process. Both wrap the    ║\n27: // ║ same lib/deep-loop/loop-lock.ts; keep the two header notes in sync.       ║\n28: // ╚══════════════════════════════════════════════════════════════════════════╝\n29: \n30: 'use strict';\n31: \n32: // ─────────────────────────────────────────────────────────────────────────────\n33: // 1. IMPORTS\n34: // ─────────────────────────────────────────────────────────────────────────────\n35: \n36: const fs = require('node:fs');\n37: const path = require('node:path');\n38: const { spawnSync } = require('node:child_process');\n39: \n40: // ─────────────────────────────────────────────────────────────────────────────\n41: // 2. CONSTANTS\n42: // ─────────────────────────────────────────────────────────────────────────────\n43: \n44: const TSX_LOADER = require.resolve('tsx');\n45: \n46: // ─────────────────────────────────────────────────────────────────────────────\n47: // 3. TSX BOOTSTRAP\n48: // ─────────────────────────────────────────────────────────────────────────────\n49: \n50: // loop-lock.ts is a TypeScript ESM module; re-exec under the tsx loader once so\n51: // the dynamic import below resolves it. Mirrors convergence.cjs.\n52: if (process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n53:   const child = spawnSync(\n54:     process.execPath,\n55:     ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n56:     {\n57:       cwd: process.cwd(),\n58:       env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n59:       encoding: 'utf8',\n60:     },\n61:   );\n62:   if (child.stdout) process.stdout.write(child.stdout);\n63:   if (child.stderr) process.stderr.write(child.stderr);\n64:   process.exit(child.status === null ? 1 : child.status);\n65: }\n66: \n67: // ─────────────────────────────────────────────────────────────────────────────\n68: // 4. HELPERS\n69: // ─────────────────────────────────────────────────────────────────────────────\n70: \n71: function inputError(message) {\n72:   const err = new Error(message);\n73:   err.code = 'INPUT_VALIDATION';\n74:   return err;\n75: }\n76: \n77: function parseFlags(argv) {\n78:   const flags = {};\n79:   for (let i = 0; i < argv.length; i += 1) {\n80:     const token = argv[i];\n81:     if (!token.startsWith('--')) {\n82:       throw inputError(`Unexpected positional argument: ${token}`);\n83:     }\n84:     const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n85:     const next = argv[i + 1];\n86:     if (next === undefined || next.startsWith('--')) {\n87:       flags[key] = true;\n88:     } else {\n89:       flags[key] = next;\n90:       i += 1;\n91:     }\n92:   }\n93:   return flags;\n94: }\n95: \n96: function requireString(flags, key) {\n97:   const value = flags[key];\n98:   if (typeof value !== 'string' || !value) {\n99:     throw inputError(`--${key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`)} is required`);\n100:   }\n101:   return value;\n102: }\n103: \n104: function resolveOwnerPid(flags) {\n105:   if (flags.ownerPid === undefined) {\n106:     return process.pid;\n107:   }\n108:   const pid = Number(flags.ownerPid);\n109:   if (!Number.isInteger(pid) || pid <= 0) {\n110:     throw inputError('--owner-pid must be a positive integer');\n111:   }\n112:   return pid;\n113: }\n114: \n115: function jsonOut(payload) {\n116:   process.stdout.write(`${JSON.stringify(payload)}\\n`);\n117: }\n118: \n119: // Map the snake_case on-disk lock record to the camelCase LoopLockData shape so\n120: // status can run it through the same staleness check the library uses.\n121: function readDiskLock(lockPath) {\n122:   let raw;\n123:   try {\n124:     raw = JSON.parse(fs.readFileSync(lockPath, 'utf8'));\n125:   } catch {\n126:     return null;\n127:   }\n128:   if (!raw || typeof raw !== 'object' || Array.isArray(raw)) {\n129:     return null;\n130:   }\n131:   return {\n132:     ownerPid: raw.owner_pid,\n133:     startedAtIso: raw.started_at_iso,\n134:     ttlMs: raw.ttl_ms,\n135:     lastHeartbeatIso: raw.last_heartbeat_iso,\n136:     packetId: raw.packet_id,\n137:     runtimeKind: raw.runtime_kind,\n138:   };\n139: }\n140: \n141: // ─────────────────────────────────────────────────────────────────────────────\n142: // 5. CORE LOGIC\n143: // ─────────────────────────────────────────────────────────────────────────────\n144: \n145: async function main() {\n146:   const argv = process.argv.slice(2);\n147:   const subcommand = argv[0];\n148:   if (!subcommand || subcommand.startsWith('--')) {\n149:     throw inputError('A subcommand is required: acquire | status | refresh | release');\n150:   }\n151:   const flags = parseFlags(argv.slice(1));\n152: \n153:   const lib = await import('../lib/deep-loop/loop-lock.ts');\n154: \n155:   if (subcommand === 'acquire') {\n156:     const lockPath = requireString(flags, 'lockPath');\n157:     const packetId = requireString(flags, 'packetId');\n158:     const ttlMs = flags.ttlMs === undefined ? 300000 : Number(flags.ttlMs);\n159:     if (!Number.isFinite(ttlMs) || ttlMs < 0) {\n160:       throw inputError('--ttl-ms must be a non-negative number');\n161:     }\n162:     const runtimeKind = typeof flags.runtimeKind === 'string' && flags.runtimeKind\n163:       ? flags.runtimeKind\n164:       : 'main';\n165:     const ownerPid = resolveOwnerPid(flags);\n166:     const now = new Date().toISOString();\n167:     const result = lib.acquireLoopLock(lockPath, {\n168:       ownerPid,\n169:       startedAtIso: now,\n170:       ttlMs,\n171:       lastHeartbeatIso: now,\n172:       packetId,\n173:       runtimeKind,\n174:     });\n175:     jsonOut({ command: 'acquire', ...result });\n176:     return;\n177:   }\n178: \n179:   if (subcommand === 'status') {\n180:     const lockPath = requireString(flags, 'lockPath');\n181:     const holder = fs.existsSync(lockPath) ? readDiskLock(lockPath) : null;\n182:     if (!holder) {\n183:       jsonOut({ command: 'status', exists: false, stale: false, alive: false, holder: null });\n184:       return;\n185:     }\n186:     const stale = lib.isStaleLoopLock(holder);\n187:     const alive = lib.processAlive(holder.ownerPid);\n188:     jsonOut({ command: 'status', exists: true, held: !stale, stale, alive, holder });\n189:     return;\n190:   }\n191: \n192:   if (subcommand === 'refresh') {\n193:     const lockPath = requireString(flags, 'lockPath');\n194:     const ownerPid = resolveOwnerPid(flags);\n195:     const refreshed = lib.refreshLoopLock(lockPath, ownerPid);\n196:     jsonOut({ command: 'refresh', refreshed });\n197:     return;\n198:   }\n199: \n200:   if (subcommand === 'release') {\n201:     const lockPath = requireString(flags, 'lockPath');\n202:     const ownerPid = resolveOwnerPid(flags);\n203:     const released = lib.releaseLoopLock(lockPath, ownerPid);\n204:     jsonOut({ command: 'release', released });\n205:     return;\n206:   }\n207: \n208:   throw inputError(`Unknown subcommand \"${subcommand}\": expected acquire | status | refresh | release`);\n209: }\n210: \n211: main().catch((err) => {\n212:   const code = err && err.code === 'INPUT_VALIDATION' ? 3 : 1;\n213:   jsonOut({\n214:     status: 'error',\n215:     error: err instanceof Error ? err.message : String(err),\n216:     code: err && err.code ? err.code : 'SCRIPT_ERROR',\n217:   });\n218:   process.exit(code);\n219: });\n\n(End of file - total 219 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Loop-Lock CLI Adapter                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Thin CLI front door over lib/deep-loop/loop-lock.ts so non-TS callers    ║\n// ║ (command YAML, shells, other runtimes) share one locking contract        ║\n// ║ instead of drifting per mode. Every subcommand is a direct pass-through  ║\n// ║ to the library; the adapter adds only argv parsing and JSON framing.     ║\n// ║                                                                          ║\n// ║ Subcommands:                                                             ║\n// ║   acquire --lock-path P --packet-id X [--ttl-ms N] [--runtime-kind K]    ║\n// ║           [--owner-pid PID]                                              ║\n// ║   status  --lock-path P                                                  ║\n// ║   refresh --lock-path P --owner-pid PID                                  ║\n// ║   release --lock-path P --owner-pid PID                                  ║\n// ║ Output: one JSON object on stdout.                                       ║\n// ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n// ║                                                                          ║\n// ║ deep_research / deep_review / deep_ai-council YAMLs call THIS adapter.    ║","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs","text":"#!/usr/bin/env node\n\n// ╔══════════════════════════════════════════════════════════════════════════╗\n// ║ Deep-Loop Runtime — Loop-Lock CLI Adapter                               ║\n// ╠══════════════════════════════════════════════════════════════════════════╣\n// ║ Thin CLI front door over lib/deep-loop/loop-lock.ts so non-TS callers    ║\n// ║ (command YAML, shells, other runtimes) share one locking contract        ║\n// ║ instead of drifting per mode. Every subcommand is a direct pass-through  ║\n// ║ to the library; the adapter adds only argv parsing and JSON framing.     ║\n// ║                                                                          ║\n// ║ Subcommands:                                                             ║\n// ║   acquire --lock-path P --packet-id X [--ttl-ms N] [--runtime-kind K]    ║\n// ║           [--owner-pid PID]                                              ║\n// ║   status  --lock-path P                                                  ║\n// ║   refresh --lock-path P --owner-pid PID                                  ║\n// ║   release --lock-path P --owner-pid PID                                  ║\n// ║ Output: one JSON object on stdout.                                       ║\n// ║ Exit:   0=ok, 1=script error, 3=input validation error.                 ║\n// ║                                                                          ║\n// ║ deep_research / deep_review / deep_ai-council YAMLs call THIS adapter.    ║\n// ║ Sanctioned exception to the \"one contract\" claim: deep-context keeps a    ║\n// ║ separate host-facing wrapper                                             ║\n// ║ (deep-loop-workflows/deep-context/scripts/loop-lock.cjs) with a          ║\n// ║ different CLI surface (--lock/--packet/--owner), a longer default TTL     ║\n// ║ (1h vs 5min), and in-process require() loading, because the host-driven   ║\n// ║ context loop has no single long-lived heartbeat process. Both wrap the    ║\n// ║ same lib/deep-loop/loop-lock.ts; keep the two header notes in sync.       ║\n// ╚══════════════════════════════════════════════════════════════════════════╝\n\n'use strict';\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 1. IMPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst fs = require('node:fs');\nconst path = require('node:path');\nconst { spawnSync } = require('node:child_process');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 2. CONSTANTS\n// ─────────────────────────────────────────────────────────────────────────────\n\nconst TSX_LOADER = require.resolve('tsx');\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 3. TSX BOOTSTRAP\n// ─────────────────────────────────────────────────────────────────────────────\n\n// loop-lock.ts is a TypeScript ESM module; re-exec under the tsx loader once so\n// the dynamic import below resolves it. Mirrors convergence.cjs.\nif (process.env.DEEP_LOOP_TSX_LOADED !== '1') {\n  const child = spawnSync(\n    process.execPath,\n    ['--import', TSX_LOADER, __filename, ...process.argv.slice(2)],\n    {\n      cwd: process.cwd(),\n      env: { ...process.env, DEEP_LOOP_TSX_LOADED: '1' },\n      encoding: 'utf8',\n    },\n  );\n  if (child.stdout) process.stdout.write(child.stdout);\n  if (child.stderr) process.stderr.write(child.stderr);\n  process.exit(child.status === null ? 1 : child.status);\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 4. HELPERS\n// ─────────────────────────────────────────────────────────────────────────────\n\nfunction inputError(message) {\n  const err = new Error(message);\n  err.code = 'INPUT_VALIDATION';\n  return err;\n}\n\nfunction parseFlags(argv) {\n  const flags = {};\n  for (let i = 0; i < argv.length; i += 1) {\n    const token = argv[i];\n    if (!token.startsWith('--')) {\n      throw inputError(`Unexpected positional argument: ${token}`);\n    }\n    const key = token.slice(2).replace(/-([a-z])/g, (_, c) => c.toUpperCase());\n    const next = argv[i + 1];\n    if (next === undefined || next.startsWith('--')) {\n      flags[key] = true;\n    } else {\n      flags[key] = next;\n      i += 1;\n    }\n  }\n  return flags;\n}\n\nfunction requireString(flags, key) {\n  const value = flags[key];\n  if (typeof value !== 'string' || !value) {\n    throw inputError(`--${key.replace(/[A-Z]/g, (c) => `-${c.toLowerCase()}`)} is required`);\n  }\n  return value;\n}\n\nfunction resolveOwnerPid(flags) {\n  if (flags.ownerPid === undefined) {\n    return process.pid;\n  }\n  const pid = Number(flags.ownerPid);\n  if (!Number.isInteger(pid) || pid <= 0) {\n    throw inputError('--owner-pid must be a positive integer');\n  }\n  return pid;\n}\n\nfunction jsonOut(payload) {\n  process.stdout.write(`${JSON.stringify(payload)}\\n`);\n}\n\n// Map the snake_case on-disk lock record to the camelCase LoopLockData shape so\n// status can run it through the same staleness check the library uses.\nfunction readDiskLock(lockPath) {\n  let raw;\n  try {\n    raw = JSON.parse(fs.readFileSync(lockPath, 'utf8'));\n  } catch {\n    return null;\n  }\n  if (!raw || typeof raw !== 'object' || Array.isArray(raw)) {\n    return null;\n  }\n  return {\n    ownerPid: raw.owner_pid,\n    startedAtIso: raw.started_at_iso,\n    ttlMs: raw.ttl_ms,\n    lastHeartbeatIso: raw.last_heartbeat_iso,\n    packetId: raw.packet_id,\n    runtimeKind: raw.runtime_kind,\n  };\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. CORE LOGIC\n// ─────────────────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const argv = process.argv.slice(2);\n  const subcommand = argv[0];\n  if (!subcommand || subcommand.startsWith('--')) {\n    throw inputError('A subcommand is required: acquire | status | refresh | release');\n  }\n  const flags = parseFlags(argv.slice(1));\n\n  const lib = await import('../lib/deep-loop/loop-lock.ts');\n\n  if (subcommand === 'acquire') {\n    const lockPath = requireString(flags, 'lockPath');\n    const packetId = requireString(flags, 'packetId');\n    const ttlMs = flags.ttlMs === undefined ? 300000 : Number(flags.ttlMs);\n    if (!Number.isFinite(ttlMs) || ttlMs < 0) {\n      throw inputError('--ttl-ms must be a non-negative number');\n    }\n    const runtimeKind = typeof flags.runtimeKind === 'string' && flags.runtimeKind\n      ? flags.runtimeKind\n      : 'main';\n    const ownerPid = resolveOwnerPid(flags);\n    const now = new Date().toISOString();\n    const result = lib.acquireLoopLock(lockPath, {\n      ownerPid,\n      startedAtIso: now,\n      ttlMs,\n      lastHeartbeatIso: now,\n      packetId,\n      runtimeKind,\n    });\n    jsonOut({ command: 'acquire', ...result });\n    return;\n  }\n\n  if (subcommand === 'status') {\n    const lockPath = requireString(flags, 'lockPath');\n    const holder = fs.existsSync(lockPath) ? readDiskLock(lockPath) : null;\n    if (!holder) {\n      jsonOut({ command: 'status', exists: false, stale: false, alive: false, holder: null });\n      return;\n    }\n    const stale = lib.isStaleLoopLock(holder);\n    const alive = lib.processAlive(holder.ownerPid);\n    jsonOut({ command: 'status', exists: true, held: !stale, stale, alive, holder });\n    return;\n  }\n\n  if (subcommand === 'refresh') {\n    const lockPath = requireString(flags, 'lockPath');\n    const ownerPid = resolveOwnerPid(flags);\n    const refreshed = lib.refreshLoopLock(lockPath, ownerPid);\n    jsonOut({ command: 'refresh', refreshed });\n    return;\n  }\n\n  if (subcommand === 'release') {\n    const lockPath = requireString(flags, 'lockPath');\n    const ownerPid = resolveOwnerPid(flags);\n    const released = lib.releaseLoopLock(lockPath, ownerPid);\n    jsonOut({ command: 'release', released });\n    return;\n  }\n\n  throw inputError(`Unknown subcommand \"${subcommand}\": expected acquire | status | refresh | release`);\n}\n\nmain().catch((err) => {\n  const code = err && err.code === 'INPUT_VALIDATION' ? 3 : 1;\n  jsonOut({\n    status: 'error',\n    error: err instanceof Error ? err.message : String(err),\n    code: err && err.code ? err.code : 'SCRIPT_ERROR',\n  });\n  process.exit(code);\n});","lineStart":1,"lineEnd":219,"totalLines":219,"truncated":false}},"title":".opencode/skills/deep-loop-runtime/scripts/loop-lock.cjs","time":{"start":1782890310044,"end":1782890310050}},"metadata":{"openai":{"itemId":"fc_0a447f0dd7206b07016a44bf45bc7c8191b3890c19799b2dd1"}},"id":"prt_f1c8b295b001wnSsAqobt9rCpa","sessionID":"ses_0e3774f05ffeAQ2wPKEyNPUx36","messageID":"msg_f1c8acb300018FxBTTIOGkECyZ"}}
