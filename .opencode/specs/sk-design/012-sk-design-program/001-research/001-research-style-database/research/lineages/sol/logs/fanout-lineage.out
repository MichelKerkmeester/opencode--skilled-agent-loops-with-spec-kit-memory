ype\":\"finding\",\"id\":\"I007-F7\",\"iteration\":7,\"summary\":\"Any future graph is a rebuildable generation-stamped projection with graph-down fallback, never an authority.\",\"sources\":[\".opencode/skills/system-deep-loop/runtime/lib/council/council-graph-db.ts:3-4\",\".opencode/skills/system-deep-loop/runtime/lib/council/council-graph-db.ts:690-705\"]}\n{\"type\":\"finding\",\"id\":\"I007-F8\",\"iteration\":7,\"summary\":\"Graph promotion requires a measured variable-depth workload, SQLite SLO failure, relevance lift, identity-quality readiness, and projection operations.\",\"sources\":[\".opencode/skills/system-deep-loop/runtime/lib/coverage-graph/coverage-graph-query.ts:644-805\",\".opencode/skills/system-deep-loop/runtime/lib/coverage-graph/coverage-graph-signals.ts:513-547\"]}","lineStart":1,"lineEnd":9,"totalLines":9,"truncated":false}},"title":".opencode/specs/sk-design/012-style-database-and-interface-commands/001-research-style-database/research/lineages/sol/deltas/iter-007.jsonl","time":{"start":1784447122133,"end":1784447122137}},"metadata":{"openai":{"itemId":"fc_0605df8c7dafe349016a5c8091f2e88191a40e5746202fe44d"}},"id":"prt_f79563a8b001X6tLRIYEWOAKKL","sessionID":"ses_086d7cfc0ffe217XO92sKCjWRm","messageID":"msg_f79561e990013aueidIUr8osr5"}}
