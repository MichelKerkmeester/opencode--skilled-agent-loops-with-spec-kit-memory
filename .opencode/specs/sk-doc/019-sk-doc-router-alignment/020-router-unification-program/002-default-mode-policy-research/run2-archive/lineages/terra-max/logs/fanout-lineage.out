ent] [--create-missing-anchors] [--emit-resource-map]\\n',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/scripts/compile-command-contracts.cjs:\n  Line 312:         'config.fanout_lineage_artifact_dir',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/tests/unit/lineage-timestamp-window.vitest.ts:\n  Line 118:       '--base-artifact-dir',\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/scripts/fanout-run.cjs:\n  Line 7: // ║         --base-artifact-dir).                                            ║\n\n  Line 1003:  * with config.fanout_lineage_artifact_dir overriding step_resolve_artifact_root.\n\n  Line 1034:     `  config.fanout_lineage_artifact_dir: ${lineageDir}`,\n\n  Line 1078:     `config.fanout_lineage_artifact_dir override — do NOT run the resolveArtifactRoot node`,\n\n  Line 1101:     `--fanout-lineage-artifact-dir=${lineageDir}`,\n\n  Line 1122:     `config.fanout_lineage_artifact_dir: ${lineageDir}`,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-merge.vitest.ts:\n  Line 786:       '--artifact-dir', baseDir,\n\n  Line 817:     execSync(`node \"${fanoutMergeScript}\" --loop-type review --artifact-dir \"${baseDir}\"`, { encoding: 'utf8' });\n\n  Line 851:     execSync(`node \"${fanoutMergeScript}\" --loop-type research --artifact-dir \"${baseDir}\" --enable-near-duplicate-dedup`, { encoding: 'utf8' });\n\n  Line 871:       '--artifact-dir', baseDir,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0063-skilled-router-collapse/.opencode/skills/system-deep-loop/runtime/tests/unit/fanout-run.vit