PATH = dbPath;\n88:     process.env.MEMORY_ALLOWED_PATHS = tempDir;\n89:     process.env.EMBEDDER_REINDEX_BATCH_SIZE = '50';\n90:     resetDegradedVectorObservabilityForTest();\n91:     embedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n92:     vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n93:   });\n94: \n95:   afterEach(() => {\n96:     vi.restoreAllMocks();\n97:     closeDb();\n98:     resetDegradedVectorObservabilityForTest();\n99:     if (originalMemoryDbPath === undefined) delete process.env.MEMORY_DB_PATH;\n100:     else process.env.MEMORY_DB_PATH = originalMemoryDbPath;\n101:     if (originalAllowedPaths === undefined) delete process.env.MEMORY_ALLOWED_PATHS;\n102:     else process.env.MEMORY_ALLOWED_PATHS = originalAllowedPaths;\n103:     if (originalBatchSize === undefined) delete process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n104:     else process.env.EMBEDDER_REINDEX_BATCH_SIZE = originalBatchSize;\n105:     fs.rmSync(tempDir, { recursive: true, force: true });\n106:   });\n107: \n108:   it('detects, quarantines, rebuilds, and returns healthy after a corrupted copied shard', async () => {\n109:     const db = initializeDb(dbPath);\n110:     const activeProfile = profile();\n111:     setActiveEmbedder(db, TEST_MODEL, TEST_DIM, TEST_BACKEND);\n112:     attachActiveVectorShard(db, activeProfile);\n113:     const now = new Date().toISOString();\n114:     db.prepare(`\n115:       INSERT INTO memory_index (spec_folder, file_path, title, content_text, embedding_status, created_at, updated_at, trigger_phrases)\n116:       VALUES (?, ?, ?, ?, 'pending', ?, ?, '[]'), (?, ?, ?, ?, 'pending', ?, ?, '[]')\n117:     `).run(\n118:       'specs/tmp', 'a.md', 'A', 'alpha', now, now,\n119:       'specs/tmp', 'b.md', 'B', 'beta', now, now,\n120:     );\n121: \n122:     const shardPath = activeProfile.getVectorShardPath(tempDir);\n123:     expect(shardPath.startsWith(tempDir)).toBe(true);\n124:     expect(shardPath).not.toContain('/mcp_server/database/');\n125:     detachActiveVectorShard(db);\n126: \n127:     const fixtureShardPath = path.join(tempDir, 'fixture-shard.sqlite');\n128:     fs.copyFileSync(shardPath, fixtureShardPath);\n129:     fs.copyFileSync(fixtureShardPath, shardPath);\n130:     fs.writeFileSync(shardPath, Buffer.from('not a sqlite database'));\n131: \n132:     let releaseEmbedding: (() => void) | null = null;\n133:     embedImpl = async (texts) => {\n134:       await new Promise<void>((resolve) => {\n135:         releaseEmbedding = resolve;\n136:       });\n137:       return texts.map(() => Float32Array.from([2, 2, 2, 2]));\n138:     };\n139: \n140:     attachActiveVectorShard(db, activeProfile);\n141:     await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'rebuilding', 'repair job to start');\n142: \n143:     const rebuildingHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n144:     const rebuildingDegradation = rebuildingHealth.recallDegradation as Record<string, unknown>;\n145:     expect((rebuildingDegradation.degradedVector as Record<string, unknown>).state).toBe('rebuilding');\n146:     expect(rebuildingDegradation.degraded).toBe(true);\n147:     expect(fs.readdirSync(path.dirname(shardPath)).some((name) => name.includes('.quarantined-'))).toBe(true);\n148: \n149:     releaseEmbedding?.();\n150:     await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'healthy', 'repair job to complete');\n151: \n152:     const finalHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n153:     const finalDegradation = finalHealth.recallDegradation as Record<string, unknown>;\n154:     const degradedVector = finalDegradation.degradedVector as Record<string, unknown>;\n155:     expect(degradedVector.state).toBe('healthy');\n156:     expect(degradedVector.detections).toBe(1);\n157:     expect(degradedVector.quarantines).toBe(1);\n158:     expect(degradedVector.rebuildsStarted).toBe(1);\n159:     expect(degradedVector.rebuildsCompleted).toBe(1);\n160:     expect(vectorIds(shardPath)).toEqual([1, 2]);\n161:   });\n162: });\n\n(End of file - total 162 lines)\n</content>","metadata":{"preview":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport Database from 'better-sqlite3';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nconst TEST_DIM = 4;\nconst TEST_MODEL = 'test-vector-repair-embedder';\nconst TEST_BACKEND = 'sentence-transformers' as const;\n\ntype EmbedImpl = (texts: string[]) => Promise<Float32Array[]> | Float32Array[];\nlet embedImpl: EmbedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n\nvi.mock('../lib/embedders/registry.js', () => ({\n  getManifest: (name: string) => (\n    name === TEST_MODEL ? { name: TEST_MODEL, backend: TEST_BACKEND, dim: TEST_DIM } : null\n  ),\n}));","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts","text":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport Database from 'better-sqlite3';\nimport { afterEach, beforeEach, describe, expect, it, vi } from 'vitest';\n\nconst TEST_DIM = 4;\nconst TEST_MODEL = 'test-vector-repair-embedder';\nconst TEST_BACKEND = 'sentence-transformers' as const;\n\ntype EmbedImpl = (texts: string[]) => Promise<Float32Array[]> | Float32Array[];\nlet embedImpl: EmbedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n\nvi.mock('../lib/embedders/registry.js', () => ({\n  getManifest: (name: string) => (\n    name === TEST_MODEL ? { name: TEST_MODEL, backend: TEST_BACKEND, dim: TEST_DIM } : null\n  ),\n}));\n\nvi.mock('../lib/embedders/execution-router.js', () => ({\n  getEmbedderAdapter: () => ({\n    embed: async (texts: string[]) => embedImpl(texts),\n  }),\n  teardownEmbedderAfterSwap: async () => {},\n}));\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport * as core from '../core/index.js';\nimport { handleMemoryHealth } from '../handlers/memory-crud-health.js';\nimport {\n  attachActiveVectorShard,\n  closeDb,\n  detachActiveVectorShard,\n  initializeDb,\n} from '../lib/search/vector-index-store.js';\nimport {\n  getDegradedVectorObservabilitySnapshot,\n  resetDegradedVectorObservabilityForTest,\n} from '../lib/observability/retrieval-observability.js';\n\nfunction parseResponse(response: { content: Array<{ text: string }> }): Record<string, unknown> {\n  return JSON.parse(response.content[0]?.text ?? '{}') as Record<string, unknown>;\n}\n\nasync function waitUntil(predicate: () => boolean, label: string): Promise<void> {\n  const deadline = Date.now() + 2000;\n  while (Date.now() < deadline) {\n    if (predicate()) return;\n    await new Promise<void>((resolve) => setImmediate(resolve));\n  }\n  throw new Error(`Timed out waiting for ${label}`);\n}\n\nfunction profile(): EmbeddingProfile {\n  return new EmbeddingProfile({\n    provider: TEST_BACKEND,\n    model: TEST_MODEL,\n    dim: TEST_DIM,\n    dtype: null,\n    baseUrl: null,\n  });\n}\n\nfunction vectorIds(shardPath: string): number[] {\n  const shard = new Database(shardPath, { readonly: true });\n  try {\n    return (shard.prepare(`SELECT id FROM vec_${TEST_DIM} ORDER BY id ASC`).all() as Array<{ id: number }>)\n      .map((row) => row.id);\n  } finally {\n    shard.close();\n  }\n}\n\ndescribe('vector shard read-path resilience', () => {\n  const originalMemoryDbPath = process.env.MEMORY_DB_PATH;\n  const originalAllowedPaths = process.env.MEMORY_ALLOWED_PATHS;\n  const originalBatchSize = process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n  let tempDir: string;\n  let dbPath: string;\n\n  beforeEach(() => {\n    tempDir = fs.mkdtempSync(path.join(os.tmpdir(), `vector-shard-resilience-${randomUUID().slice(0, 8)}-`));\n    dbPath = path.join(tempDir, 'context-index.sqlite');\n    process.env.MEMORY_DB_PATH = dbPath;\n    process.env.MEMORY_ALLOWED_PATHS = tempDir;\n    process.env.EMBEDDER_REINDEX_BATCH_SIZE = '50';\n    resetDegradedVectorObservabilityForTest();\n    embedImpl = (texts) => texts.map(() => Float32Array.from([1, 1, 1, 1]));\n    vi.spyOn(core, 'checkDatabaseUpdated').mockResolvedValue(false);\n  });\n\n  afterEach(() => {\n    vi.restoreAllMocks();\n    closeDb();\n    resetDegradedVectorObservabilityForTest();\n    if (originalMemoryDbPath === undefined) delete process.env.MEMORY_DB_PATH;\n    else process.env.MEMORY_DB_PATH = originalMemoryDbPath;\n    if (originalAllowedPaths === undefined) delete process.env.MEMORY_ALLOWED_PATHS;\n    else process.env.MEMORY_ALLOWED_PATHS = originalAllowedPaths;\n    if (originalBatchSize === undefined) delete process.env.EMBEDDER_REINDEX_BATCH_SIZE;\n    else process.env.EMBEDDER_REINDEX_BATCH_SIZE = originalBatchSize;\n    fs.rmSync(tempDir, { recursive: true, force: true });\n  });\n\n  it('detects, quarantines, rebuilds, and returns healthy after a corrupted copied shard', async () => {\n    const db = initializeDb(dbPath);\n    const activeProfile = profile();\n    setActiveEmbedder(db, TEST_MODEL, TEST_DIM, TEST_BACKEND);\n    attachActiveVectorShard(db, activeProfile);\n    const now = new Date().toISOString();\n    db.prepare(`\n      INSERT INTO memory_index (spec_folder, file_path, title, content_text, embedding_status, created_at, updated_at, trigger_phrases)\n      VALUES (?, ?, ?, ?, 'pending', ?, ?, '[]'), (?, ?, ?, ?, 'pending', ?, ?, '[]')\n    `).run(\n      'specs/tmp', 'a.md', 'A', 'alpha', now, now,\n      'specs/tmp', 'b.md', 'B', 'beta', now, now,\n    );\n\n    const shardPath = activeProfile.getVectorShardPath(tempDir);\n    expect(shardPath.startsWith(tempDir)).toBe(true);\n    expect(shardPath).not.toContain('/mcp_server/database/');\n    detachActiveVectorShard(db);\n\n    const fixtureShardPath = path.join(tempDir, 'fixture-shard.sqlite');\n    fs.copyFileSync(shardPath, fixtureShardPath);\n    fs.copyFileSync(fixtureShardPath, shardPath);\n    fs.writeFileSync(shardPath, Buffer.from('not a sqlite database'));\n\n    let releaseEmbedding: (() => void) | null = null;\n    embedImpl = async (texts) => {\n      await new Promise<void>((resolve) => {\n        releaseEmbedding = resolve;\n      });\n      return texts.map(() => Float32Array.from([2, 2, 2, 2]));\n    };\n\n    attachActiveVectorShard(db, activeProfile);\n    await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'rebuilding', 'repair job to start');\n\n    const rebuildingHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n    const rebuildingDegradation = rebuildingHealth.recallDegradation as Record<string, unknown>;\n    expect((rebuildingDegradation.degradedVector as Record<string, unknown>).state).toBe('rebuilding');\n    expect(rebuildingDegradation.degraded).toBe(true);\n    expect(fs.readdirSync(path.dirname(shardPath)).some((name) => name.includes('.quarantined-'))).toBe(true);\n\n    releaseEmbedding?.();\n    await waitUntil(() => getDegradedVectorObservabilitySnapshot().state === 'healthy', 'repair job to complete');\n\n    const finalHealth = parseResponse(await handleMemoryHealth({})).data as Record<string, unknown>;\n    const finalDegradation = finalHealth.recallDegradation as Record<string, unknown>;\n    const degradedVector = finalDegradation.degradedVector as Record<string, unknown>;\n    expect(degradedVector.state).toBe('healthy');\n    expect(degradedVector.detections).toBe(1);\n    expect(degradedVector.quarantines).toBe(1);\n    expect(degradedVector.rebuildsStarted).toBe(1);\n    expect(degradedVector.rebuildsCompleted).toBe(1);\n    expect(vectorIds(shardPath)).toEqual([1, 2]);\n  });\n});","lineStart":1,"lineEnd":162,"totalLines":162,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-shard-read-path-resilience.vitest.ts","time":{"start":1781151304347,"end":1781151304350}},"metadata":{"openai":{"itemId":"fc_0057ee78801644c8016a2a36483bd48191b7a8e38bf972d3e8"}},"id":"prt_eb4e40a9a001boEiNWeNEgHopM","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3e7f1001Uvxcy5l1gLFGBH"}}
{"type":"tool_use","timestamp":1781151304388,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_I0kDT8tfEcOEQFimlO6zmK4l","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts</path>\n<type>file</type>\n<content>\n1: import Database from 'better-sqlite3';\n2: import * as sqliteVec from 'sqlite-vec';\n3: import { afterEach, describe, expect, it, vi } from 'vitest';\n4: \n5: import { setActiveEmbedder } from '../lib/embedders/schema.js';\n6: import { __testables } from '../lib/search/vector-index-store.js';\n7: \n8: function makeMemoryDb(): Database.Database {\n9:   const db = new Database(':memory:');\n10:   sqliteVec.load(db);\n11:   db.exec(`\n12:     CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n13:     CREATE TABLE vec_metadata (key TEXT PRIMARY KEY, value TEXT NOT NULL);\n14:   `);\n15:   return db;\n16: }\n17: \n18: describe('vector dimension source precedence', () => {\n19:   afterEach(() => {\n20:     vi.restoreAllMocks();\n21:   });\n22: \n23:   it('uses the active embedder profile before vec_memories schema text', () => {\n24:     const db = makeMemoryDb();\n25:     try {\n26:       setActiveEmbedder(db, 'profile-model', 4, 'ollama');\n27:       db.exec(`CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[8])`);\n28: \n29:       const result = __testables.get_existing_embedding_dimension(db);\n30: \n31:       expect(result).toMatchObject({\n32:         existing_db: true,\n33:         stored_dim: 4,\n34:         source: 'active_embedder_profile',\n35:       });\n36:     } finally {\n37:       db.close();\n38:     }\n39:   });\n40: \n41:   it('demotes vec_memories schema parsing to a warning-only last resort', () => {\n42:     const db = new Database(':memory:');\n43:     sqliteVec.load(db);\n44:     const warn = vi.spyOn(console, 'warn').mockImplementation(() => {});\n45:     try {\n46:       db.exec(`\n47:         CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n48:         CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[6]);\n49:       `);\n50: \n51:       const result = __testables.get_existing_embedding_dimension(db, { allowProfileFallback: false });\n52: \n53:       expect(result).toMatchObject({\n54:         existing_db: true,\n55:         stored_dim: 6,\n56:         source: 'vec_memories',\n57:       });\n58:       expect(warn).toHaveBeenCalledWith(expect.stringContaining('Falling back to vec_memories schema text'));\n59:     } finally {\n60:       db.close();\n61:     }\n62:   });\n63: \n64:   it('reports absent schema without inventing a stored dimension', () => {\n65:     const db = new Database(':memory:');\n66:     try {\n67:       const result = __testables.get_existing_embedding_dimension(db);\n68: \n69:       expect(result).toMatchObject({\n70:         existing_db: false,\n71:         stored_dim: null,\n72:         source: null,\n73:       });\n74:     } finally {\n75:       db.close();\n76:     }\n77:   });\n78: });\n\n(End of file - total 78 lines)\n</content>","metadata":{"preview":"import Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { __testables } from '../lib/search/vector-index-store.js';\n\nfunction makeMemoryDb(): Database.Database {\n  const db = new Database(':memory:');\n  sqliteVec.load(db);\n  db.exec(`\n    CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n    CREATE TABLE vec_metadata (key TEXT PRIMARY KEY, value TEXT NOT NULL);\n  `);\n  return db;\n}\n\ndescribe('vector dimension source precedence', () => {\n  afterEach(() => {\n    vi.restoreAllMocks();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts","text":"import Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, describe, expect, it, vi } from 'vitest';\n\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { __testables } from '../lib/search/vector-index-store.js';\n\nfunction makeMemoryDb(): Database.Database {\n  const db = new Database(':memory:');\n  sqliteVec.load(db);\n  db.exec(`\n    CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n    CREATE TABLE vec_metadata (key TEXT PRIMARY KEY, value TEXT NOT NULL);\n  `);\n  return db;\n}\n\ndescribe('vector dimension source precedence', () => {\n  afterEach(() => {\n    vi.restoreAllMocks();\n  });\n\n  it('uses the active embedder profile before vec_memories schema text', () => {\n    const db = makeMemoryDb();\n    try {\n      setActiveEmbedder(db, 'profile-model', 4, 'ollama');\n      db.exec(`CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[8])`);\n\n      const result = __testables.get_existing_embedding_dimension(db);\n\n      expect(result).toMatchObject({\n        existing_db: true,\n        stored_dim: 4,\n        source: 'active_embedder_profile',\n      });\n    } finally {\n      db.close();\n    }\n  });\n\n  it('demotes vec_memories schema parsing to a warning-only last resort', () => {\n    const db = new Database(':memory:');\n    sqliteVec.load(db);\n    const warn = vi.spyOn(console, 'warn').mockImplementation(() => {});\n    try {\n      db.exec(`\n        CREATE TABLE memory_index (id INTEGER PRIMARY KEY);\n        CREATE VIRTUAL TABLE vec_memories USING vec0(embedding FLOAT[6]);\n      `);\n\n      const result = __testables.get_existing_embedding_dimension(db, { allowProfileFallback: false });\n\n      expect(result).toMatchObject({\n        existing_db: true,\n        stored_dim: 6,\n        source: 'vec_memories',\n      });\n      expect(warn).toHaveBeenCalledWith(expect.stringContaining('Falling back to vec_memories schema text'));\n    } finally {\n      db.close();\n    }\n  });\n\n  it('reports absent schema without inventing a stored dimension', () => {\n    const db = new Database(':memory:');\n    try {\n      const result = __testables.get_existing_embedding_dimension(db);\n\n      expect(result).toMatchObject({\n        existing_db: false,\n        stored_dim: null,\n        source: null,\n      });\n    } finally {\n      db.close();\n    }\n  });\n});","lineStart":1,"lineEnd":78,"totalLines":78,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-dimension-source.vitest.ts","time":{"start":1781151304384,"end":1781151304387}},"metadata":{"openai":{"itemId":"fc_0057ee78801644c8016a2a36483be08191903e817fb7efe364"}},"id":"prt_eb4e40a9c001jRoNpkz3Ky05Ya","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3e7f1001Uvxcy5l1gLFGBH"}}
{"type":"tool_use","timestamp":1781151304391,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_f9RyeIE4ju5nNGEIPXlqYO6I","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts</path>\n<type>file</type>\n<content>\n1: import * as fs from 'node:fs';\n2: import * as os from 'node:os';\n3: import * as path from 'node:path';\n4: \n5: import Database from 'better-sqlite3';\n6: import * as sqliteVec from 'sqlite-vec';\n7: import { afterEach, beforeEach, describe, expect, it } from 'vitest';\n8: \n9: import { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\n10: import { setActiveEmbedder } from '../lib/embedders/schema.js';\n11: import { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\n12: import {\n13:   benchmarkKnnQueryShapes,\n14:   shouldAdoptMatchQueryShape,\n15: } from '../lib/search/vector-index-queries.js';\n16: \n17: const DIM = 4;\n18: \n19: function embedding(value: number): Float32Array {\n20:   return Float32Array.from([value, value / 2, value / 3, value / 4]);\n21: }\n22: \n23: function embeddingBuffer(value: number): Buffer {\n24:   const vector = embedding(value);\n25:   return Buffer.from(vector.buffer, vector.byteOffset, vector.byteLength);\n26: }\n27: \n28: describe('vector KNN query-shape benchmark', () => {\n29:   let tempDir: string;\n30:   let db: Database.Database;\n31:   let profile: EmbeddingProfile;\n32: \n33:   beforeEach(() => {\n34:     tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-knn-benchmark-'));\n35:     db = new Database(path.join(tempDir, 'context-index.sqlite'));\n36:     sqliteVec.load(db);\n37:     profile = new EmbeddingProfile({ provider: 'ollama', model: 'knn-benchmark-model', dim: DIM, dtype: null, baseUrl: null });\n38:     setActiveEmbedder(db, profile.model, profile.dim, 'ollama');\n39:     attachActiveVectorShard(db, profile);\n40:     db.exec(`\n41:       CREATE TABLE memory_index (\n42:         id INTEGER PRIMARY KEY,\n43:         spec_folder TEXT,\n44:         file_path TEXT,\n45:         importance_tier TEXT DEFAULT 'normal',\n46:         importance_weight REAL DEFAULT 0.5,\n47:         embedding_status TEXT DEFAULT 'success',\n48:         expires_at TEXT,\n49:         is_pinned INTEGER DEFAULT 0,\n50:         last_review TEXT,\n51:         review_count INTEGER DEFAULT 0,\n52:         stability REAL,\n53:         updated_at TEXT DEFAULT (datetime('now'))\n54:       );\n55:       CREATE VIEW active_memory_projection AS SELECT id AS active_memory_id FROM memory_index;\n56:     `);\n57:     const memoryInsert = db.prepare(`\n58:       INSERT INTO memory_index (id, spec_folder, file_path, embedding_status)\n59:       VALUES (?, 'specs/knn', ?, 'success')\n60:     `);\n61:     const vecInsert = db.prepare(`INSERT INTO active_vec.vec_${DIM} (id, vec) VALUES (?, ?)`);\n62:     const knnInsert = db.prepare('INSERT INTO active_vec.vec_memories (rowid, embedding) VALUES (?, ?)');\n63:     const writeRows = db.transaction(() => {\n64:       for (let i = 1; i <= 32; i += 1) {\n65:         memoryInsert.run(i, `doc-${i}.md`);\n66:         vecInsert.run(i, embeddingBuffer(i));\n67:         knnInsert.run(BigInt(i), embeddingBuffer(i));\n68:       }\n69:     });\n70:     writeRows();\n71:   });\n72: \n73:   afterEach(() => {\n74:     try { detachActiveVectorShard(db); } catch { /* best-effort */ }\n75:     try { db.close(); } catch { /* best-effort */ }\n76:     fs.rmSync(tempDir, { recursive: true, force: true });\n77:   });\n78: \n79:   it('records scalar JOIN vs vec0 MATCH timings and gates adoption at >20 percent', () => {\n80:     const result = benchmarkKnnQueryShapes(embedding(1), { iterations: 2, limit: 8 }, db);\n81: \n82:     console.info(\n83:       `KNN query-shape benchmark: corpus=${result.corpusSize} scalar_ms=${result.scalarJoinAverageMs.toFixed(4)} ` +\n84:       `match_ms=${result.matchAverageMs?.toFixed(4) ?? 'n/a'} decision=${result.decision}`,\n85:     );\n86:     expect(result.corpusSize).toBe(32);\n87:     expect(result.scalarJoinAverageMs).toBeGreaterThanOrEqual(0);\n88:     expect(result.decision).toBe(\n89:       result.matchSupported && (result.matchImprovementPct ?? 0) > 20 ? 'adopt_match' : 'keep_scalar_join',\n90:     );\n91:     expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20 })).toBe(false);\n92:     expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20.1 })).toBe(true);\n93:   });\n94: });\n\n(End of file - total 94 lines)\n</content>","metadata":{"preview":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\nimport {\n  benchmarkKnnQueryShapes,\n  shouldAdoptMatchQueryShape,\n} from '../lib/search/vector-index-queries.js';\n\nconst DIM = 4;\n\nfunction embedding(value: number): Float32Array {\n  return Float32Array.from([value, value / 2, value / 3, value / 4]);","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","text":"import * as fs from 'node:fs';\nimport * as os from 'node:os';\nimport * as path from 'node:path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\nimport { afterEach, beforeEach, describe, expect, it } from 'vitest';\n\nimport { EmbeddingProfile } from '@spec-kit/shared/embeddings/profile';\nimport { setActiveEmbedder } from '../lib/embedders/schema.js';\nimport { attachActiveVectorShard, detachActiveVectorShard } from '../lib/search/vector-index-store.js';\nimport {\n  benchmarkKnnQueryShapes,\n  shouldAdoptMatchQueryShape,\n} from '../lib/search/vector-index-queries.js';\n\nconst DIM = 4;\n\nfunction embedding(value: number): Float32Array {\n  return Float32Array.from([value, value / 2, value / 3, value / 4]);\n}\n\nfunction embeddingBuffer(value: number): Buffer {\n  const vector = embedding(value);\n  return Buffer.from(vector.buffer, vector.byteOffset, vector.byteLength);\n}\n\ndescribe('vector KNN query-shape benchmark', () => {\n  let tempDir: string;\n  let db: Database.Database;\n  let profile: EmbeddingProfile;\n\n  beforeEach(() => {\n    tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'vector-knn-benchmark-'));\n    db = new Database(path.join(tempDir, 'context-index.sqlite'));\n    sqliteVec.load(db);\n    profile = new EmbeddingProfile({ provider: 'ollama', model: 'knn-benchmark-model', dim: DIM, dtype: null, baseUrl: null });\n    setActiveEmbedder(db, profile.model, profile.dim, 'ollama');\n    attachActiveVectorShard(db, profile);\n    db.exec(`\n      CREATE TABLE memory_index (\n        id INTEGER PRIMARY KEY,\n        spec_folder TEXT,\n        file_path TEXT,\n        importance_tier TEXT DEFAULT 'normal',\n        importance_weight REAL DEFAULT 0.5,\n        embedding_status TEXT DEFAULT 'success',\n        expires_at TEXT,\n        is_pinned INTEGER DEFAULT 0,\n        last_review TEXT,\n        review_count INTEGER DEFAULT 0,\n        stability REAL,\n        updated_at TEXT DEFAULT (datetime('now'))\n      );\n      CREATE VIEW active_memory_projection AS SELECT id AS active_memory_id FROM memory_index;\n    `);\n    const memoryInsert = db.prepare(`\n      INSERT INTO memory_index (id, spec_folder, file_path, embedding_status)\n      VALUES (?, 'specs/knn', ?, 'success')\n    `);\n    const vecInsert = db.prepare(`INSERT INTO active_vec.vec_${DIM} (id, vec) VALUES (?, ?)`);\n    const knnInsert = db.prepare('INSERT INTO active_vec.vec_memories (rowid, embedding) VALUES (?, ?)');\n    const writeRows = db.transaction(() => {\n      for (let i = 1; i <= 32; i += 1) {\n        memoryInsert.run(i, `doc-${i}.md`);\n        vecInsert.run(i, embeddingBuffer(i));\n        knnInsert.run(BigInt(i), embeddingBuffer(i));\n      }\n    });\n    writeRows();\n  });\n\n  afterEach(() => {\n    try { detachActiveVectorShard(db); } catch { /* best-effort */ }\n    try { db.close(); } catch { /* best-effort */ }\n    fs.rmSync(tempDir, { recursive: true, force: true });\n  });\n\n  it('records scalar JOIN vs vec0 MATCH timings and gates adoption at >20 percent', () => {\n    const result = benchmarkKnnQueryShapes(embedding(1), { iterations: 2, limit: 8 }, db);\n\n    console.info(\n      `KNN query-shape benchmark: corpus=${result.corpusSize} scalar_ms=${result.scalarJoinAverageMs.toFixed(4)} ` +\n      `match_ms=${result.matchAverageMs?.toFixed(4) ?? 'n/a'} decision=${result.decision}`,\n    );\n    expect(result.corpusSize).toBe(32);\n    expect(result.scalarJoinAverageMs).toBeGreaterThanOrEqual(0);\n    expect(result.decision).toBe(\n      result.matchSupported && (result.matchImprovementPct ?? 0) > 20 ? 'adopt_match' : 'keep_scalar_join',\n    );\n    expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20 })).toBe(false);\n    expect(shouldAdoptMatchQueryShape({ matchSupported: true, matchImprovementPct: 20.1 })).toBe(true);\n  });\n});","lineStart":1,"lineEnd":94,"totalLines":94,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/tests/vector-knn-query-shape-benchmark.vitest.ts","time":{"start":1781151304388,"end":1781151304390}},"metadata":{"openai":{"itemId":"fc_0057ee78801644c8016a2a36483be8819180c704582119aaa3"}},"id":"prt_eb4e40ac1001vBzCkeCbWlIgkW","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e3e7f1001Uvxcy5l1gLFGBH"}}
{"type":"step_finish","timestamp":1781151304709,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"id":"prt_eb4e40c03001tubG9t9DSk2JHQ","reason":"tool-calls","snapshot":"bd0cc31ea69de12f342f1b80b2c1fed28d0b4f38","messageID":"msg_eb4e3e7f1001Uvxcy5l1gLFGBH","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","type":"step-finish","tokens":{"total":110851,"input":14265,"output":313,"reasoning":17,"cache":{"write":0,"read":96256}},"cost":0}}
{"type":"step_start","timestamp":1781151306232,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"id":"prt_eb4e411f7001Jzocb8nVCRzCL2","messageID":"msg_eb4e40ce0001fJ9Y1NCFW3dWj8","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","snapshot":"bd0cc31ea69de12f342f1b80b2c1fed28d0b4f38","type":"step-start"}}
{"type":"tool_use","timestamp":1781151311863,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"read","callID":"call_n22ULlcyhUKh10TsIG0CuraB","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","offset":394,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts</path>\n<type>file</type>\n<content>\n394:            m.importance_weight * POWER(\n395:              1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n396:              -0.5\n397:            )\n398:          ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n399:        END`\n400:     : 'm.importance_weight';\n401: \n402:   let constitutional_results: MemoryRow[] = [];\n403: \n404:   if (includeConstitutional && tier !== 'constitutional') {\n405:     constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n406:   }\n407: \n408:   const where_clauses = ['m.embedding_status = \\'success\\''];\n409:   const params: unknown[] = [query_buffer];\n410: \n411:   where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n412: \n413:   if (tier === 'deprecated') {\n414:     where_clauses.push('m.importance_tier = ?');\n415:     params.push('deprecated');\n416:   } else if (tier === 'constitutional') {\n417:     where_clauses.push('m.importance_tier = ?');\n418:     params.push('constitutional');\n419:   } else if (tier) {\n420:     where_clauses.push('m.importance_tier = ?');\n421:     params.push(tier);\n422:   } else {\n423:     where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n424:   }\n425: \n426:   appendSpecFolderScope(where_clauses, params, specFolder);\n427: \n428:   if (contextType) {\n429:     where_clauses.push('m.context_type = ?');\n430:     params.push(contextType);\n431:   }\n432: \n433:   // If constitutional results already satisfy limit, return them directly.\n434:   if (constitutional_results.length >= limit) {\n435:     return constitutional_results.slice(0, limit);\n436:   }\n437:   const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n438:   params.push(max_distance, adjusted_limit);\n439: \n440:   const sql = `\n441:     SELECT sub.*,\n442:            ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n443:     FROM (\n444:       SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n445:              ${decay_expr} as effective_importance\n446:       FROM memory_index m\n447:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n448:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n449:       WHERE ${where_clauses.join(' AND ')}\n450:     ) sub\n451:     WHERE sub.distance <= ?\n452:     ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n453:     LIMIT ?\n454:   `;\n455: \n456:   const rows = database.prepare(sql).all(...params);\n457: \n458:   const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n459:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n460:     row.isConstitutional = row.importance_tier === 'constitutional';\n461:     return row;\n462:   });\n463: \n464:   return [...constitutional_results, ...regular_results];\n465: }\n466: \n467: /**\n468:  * Gets constitutional memories for prompt assembly.\n469:  * @param options - Retrieval options.\n470:  * @returns The constitutional memory rows.\n471:  */\n472: export function get_constitutional_memories_public(\n473:   options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n474:   database: Database.Database = initialize_db(),\n475: ): MemoryRow[] {\n476:   const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n477: \n478:   let results = get_constitutional_memories(database, specFolder, includeArchived);\n479: \n480:   const TOKENS_PER_MEMORY = 100;\n481:   const max_count = Math.floor(maxTokens / TOKENS_PER_MEMORY);\n482:   if (results.length > max_count) {\n483:     results = results.slice(0, max_count);\n484:   }\n485: \n486:   return results;\n487: }\n488: \n489: /**\n490:  * Searches indexed memories with multiple concept embeddings.\n491:  * @param concept_embeddings - The concept embeddings to search with.\n492:  * @param options - Search options.\n493:  * @returns The matching memory rows.\n494:  * @throws {VectorIndexError} When concept count or embedding dimensions are invalid, or when store initialization fails.\n495:  * @example\n496:  * ```ts\n497:  * const rows = multi_concept_search([embA, embB], { limit: 8, specFolder: 'specs/001-demo' });\n498:  * ```\n499:  */\n500: export function multi_concept_search(\n501:   concept_embeddings: EmbeddingInput[],\n502:   options: { limit?: number; specFolder?: string | null; minSimilarity?: number } = {}\n503: ): MemoryRow[] {\n504:   const sqlite_vec = get_sqlite_vec_available();\n505:   if (!sqlite_vec) {\n506:     console.warn('[vector-index] Multi-concept search unavailable - sqlite-vec not loaded');\n507:     return [];\n508:   }\n509: \n510:   const database = initialize_db();\n511: \n512:   const concepts = concept_embeddings;\n513:   if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n514:     throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n515:   }\n516: \n517:   const vectorSource = getActiveVectorSourceForQuery(database);\n518:   for (const emb of concepts) {\n519:     if (!emb || emb.length !== vectorSource.dim) {\n520:       throw new VectorIndexError(\n521:         `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n522:         VectorIndexErrorCode.QUERY_FAILED,\n523:       );\n524:     }\n525:   }\n526: \n527:   const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n528: \n529:   const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n530:   const max_distance = 2 * (1 - minSimilarity / 100);\n531: \n532:   const distance_expressions = concept_buffers.map((_, i) =>\n533:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n534:   ).join(', ');\n535: \n536:   const distance_filters = concept_buffers.map((_, _i) =>\n537:     `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n538:   ).join(' AND ');\n539: \n540:   const folder_filter = specFolder ? 'AND (m.spec_folder = ? OR m.spec_folder LIKE ?)' : '';\n541:   const similarity_select = concept_buffers.map((_, i) =>\n542:     `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n543:   ).join(', ');\n544: \n545:   const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n546: \n547:   const sql = `\n548:     SELECT\n549:       sub.*,\n550:       ${similarity_select},\n551:       (${avg_distance_expr}) / ${concepts.length} as avg_distance\n552:     FROM (\n553:       SELECT\n554:         m.*,\n555:         ${distance_expressions}\n556:       FROM memory_index m\n557:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n558:       JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n559:       WHERE m.embedding_status = 'success'\n560:         AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n561:         ${folder_filter}\n562:         AND ${distance_filters}\n563:     ) sub\n564:     ORDER BY avg_distance ASC\n565:     LIMIT ?\n566:   `;\n567: \n568:   const params = [\n569:     ...concept_buffers,\n570:     ...(specFolder ? [specFolder, `${specFolder}/%`] : []),\n571:     ...concept_buffers.flatMap(b => [b, max_distance]),\n572:     limit\n573:   ];\n574: \n575:   const rows = database.prepare(sql).all(...params);\n576: \n577:   return (rows as MemoryRow[]).map((row: MemoryRow) => {\n578:     row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n579:     row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n580:     row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n581:     row.isConstitutional = row.importance_tier === 'constitutional';\n582:     return row;\n583:   });\n584: }\n585: \n586: /* ───────────────────────────────────────────────────────────────\n587:    CONTENT EXTRACTION HELPERS\n588: ----------------------------------------------------------------*/\n589: \n590: /**\n591:  * Extracts a display title from indexed content.\n592:  * @param content - The content to inspect.\n593:  * @param filename - The optional source filename.\n594:  * @returns The extracted title.\n595:  */\n596: export function extract_title(content: unknown, filename?: string): string {\n597:   if (!content || typeof content !== 'string') {\n598:     return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n599:   }\n600: \n601:   const h1_match = content.match(/^#\\s+(.+)$/m);\n602:   if (h1_match && h1_match[1]) {\n603:     return h1_match[1].trim();\n604:   }\n605: \n606:   const h2_match = content.match(/^##\\s+(.+)$/m);\n607:   if (h2_match && h2_match[1]) {\n608:     return h2_match[1].trim();\n609:   }\n610: \n611:   const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n612:   if (yaml_match && yaml_match[1]) {\n613:     return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');\n\n(Showing lines 394-613 of 1706. Use offset=614 to continue.)\n</content>","metadata":{"preview":"           m.importance_weight * POWER(\n             1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n             -0.5\n           )\n         ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n       END`\n    : 'm.importance_weight';\n\n  let constitutional_results: MemoryRow[] = [];\n\n  if (includeConstitutional && tier !== 'constitutional') {\n    constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n  }\n\n  const where_clauses = ['m.embedding_status = \\'success\\''];\n  const params: unknown[] = [query_buffer];\n\n  where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n\n  if (tier === 'deprecated') {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","text":"           m.importance_weight * POWER(\n             1.0 + (19.0/81.0) * (julianday('now') - julianday(m.last_review)) / COALESCE(NULLIF(m.stability, 0), 1.0),\n             -0.5\n           )\n         ELSE m.importance_weight * POWER(0.5, (julianday('now') - julianday(m.updated_at)) / COALESCE(NULLIF(m.decay_half_life_days, 0), 90.0))\n       END`\n    : 'm.importance_weight';\n\n  let constitutional_results: MemoryRow[] = [];\n\n  if (includeConstitutional && tier !== 'constitutional') {\n    constitutional_results = get_constitutional_memories(database, specFolder, includeArchived);\n  }\n\n  const where_clauses = ['m.embedding_status = \\'success\\''];\n  const params: unknown[] = [query_buffer];\n\n  where_clauses.push('(m.expires_at IS NULL OR m.expires_at > datetime(\\'now\\'))');\n\n  if (tier === 'deprecated') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('deprecated');\n  } else if (tier === 'constitutional') {\n    where_clauses.push('m.importance_tier = ?');\n    params.push('constitutional');\n  } else if (tier) {\n    where_clauses.push('m.importance_tier = ?');\n    params.push(tier);\n  } else {\n    where_clauses.push('(m.importance_tier IS NULL OR m.importance_tier NOT IN (\\'deprecated\\', \\'constitutional\\'))');\n  }\n\n  appendSpecFolderScope(where_clauses, params, specFolder);\n\n  if (contextType) {\n    where_clauses.push('m.context_type = ?');\n    params.push(contextType);\n  }\n\n  // If constitutional results already satisfy limit, return them directly.\n  if (constitutional_results.length >= limit) {\n    return constitutional_results.slice(0, limit);\n  }\n  const adjusted_limit = Math.max(1, limit - constitutional_results.length);\n  params.push(max_distance, adjusted_limit);\n\n  const sql = `\n    SELECT sub.*,\n           ROUND((1 - sub.distance / 2) * 100, 2) as similarity\n    FROM (\n      SELECT m.*, vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as distance,\n             ${decay_expr} as effective_importance\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE ${where_clauses.join(' AND ')}\n    ) sub\n    WHERE sub.distance <= ?\n    ORDER BY (sub.distance - (sub.effective_importance * 0.1)) ASC\n    LIMIT ?\n  `;\n\n  const rows = database.prepare(sql).all(...params);\n\n  const regular_results = (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n\n  return [...constitutional_results, ...regular_results];\n}\n\n/**\n * Gets constitutional memories for prompt assembly.\n * @param options - Retrieval options.\n * @returns The constitutional memory rows.\n */\nexport function get_constitutional_memories_public(\n  options: { specFolder?: string | null; maxTokens?: number; includeArchived?: boolean } = {},\n  database: Database.Database = initialize_db(),\n): MemoryRow[] {\n  const { specFolder = null, maxTokens = 2000, includeArchived = false } = options;\n\n  let results = get_constitutional_memories(database, specFolder, includeArchived);\n\n  const TOKENS_PER_MEMORY = 100;\n  const max_count = Math.floor(maxTokens / TOKENS_PER_MEMORY);\n  if (results.length > max_count) {\n    results = results.slice(0, max_count);\n  }\n\n  return results;\n}\n\n/**\n * Searches indexed memories with multiple concept embeddings.\n * @param concept_embeddings - The concept embeddings to search with.\n * @param options - Search options.\n * @returns The matching memory rows.\n * @throws {VectorIndexError} When concept count or embedding dimensions are invalid, or when store initialization fails.\n * @example\n * ```ts\n * const rows = multi_concept_search([embA, embB], { limit: 8, specFolder: 'specs/001-demo' });\n * ```\n */\nexport function multi_concept_search(\n  concept_embeddings: EmbeddingInput[],\n  options: { limit?: number; specFolder?: string | null; minSimilarity?: number } = {}\n): MemoryRow[] {\n  const sqlite_vec = get_sqlite_vec_available();\n  if (!sqlite_vec) {\n    console.warn('[vector-index] Multi-concept search unavailable - sqlite-vec not loaded');\n    return [];\n  }\n\n  const database = initialize_db();\n\n  const concepts = concept_embeddings;\n  if (!Array.isArray(concepts) || concepts.length < 2 || concepts.length > 5) {\n    throw new VectorIndexError('Multi-concept search requires 2-5 concepts', VectorIndexErrorCode.QUERY_FAILED);\n  }\n\n  const vectorSource = getActiveVectorSourceForQuery(database);\n  for (const emb of concepts) {\n    if (!emb || emb.length !== vectorSource.dim) {\n      throw new VectorIndexError(\n        `Invalid embedding dimension: expected ${vectorSource.dim}, got ${emb?.length}`,\n        VectorIndexErrorCode.QUERY_FAILED,\n      );\n    }\n  }\n\n  const { limit = 10, specFolder = null, minSimilarity = 50 } = options;\n\n  const concept_buffers = concepts.map(c => to_embedding_buffer(c));\n  const max_distance = 2 * (1 - minSimilarity / 100);\n\n  const distance_expressions = concept_buffers.map((_, i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) as dist_${i}`\n  ).join(', ');\n\n  const distance_filters = concept_buffers.map((_, _i) =>\n    `vec_distance_cosine(v.${vectorSource.embeddingColumn}, ?) <= ?`\n  ).join(' AND ');\n\n  const folder_filter = specFolder ? 'AND (m.spec_folder = ? OR m.spec_folder LIKE ?)' : '';\n  const similarity_select = concept_buffers.map((_, i) =>\n    `ROUND((1 - sub.dist_${i} / 2) * 100, 2) as similarity_${i}`\n  ).join(', ');\n\n  const avg_distance_expr = concept_buffers.map((_, i) => `sub.dist_${i}`).join(' + ');\n\n  const sql = `\n    SELECT\n      sub.*,\n      ${similarity_select},\n      (${avg_distance_expr}) / ${concepts.length} as avg_distance\n    FROM (\n      SELECT\n        m.*,\n        ${distance_expressions}\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      JOIN ${vectorSource.tableName} v ON m.id = v.${vectorSource.idColumn}\n      WHERE m.embedding_status = 'success'\n        AND (m.expires_at IS NULL OR m.expires_at > datetime('now'))\n        ${folder_filter}\n        AND ${distance_filters}\n    ) sub\n    ORDER BY avg_distance ASC\n    LIMIT ?\n  `;\n\n  const params = [\n    ...concept_buffers,\n    ...(specFolder ? [specFolder, `${specFolder}/%`] : []),\n    ...concept_buffers.flatMap(b => [b, max_distance]),\n    limit\n  ];\n\n  const rows = database.prepare(sql).all(...params);\n\n  return (rows as MemoryRow[]).map((row: MemoryRow) => {\n    row.trigger_phrases = parse_trigger_phrases(row.trigger_phrases);\n    row.concept_similarities = concept_buffers.map((_, i) => Number(row[`similarity_${i}`] ?? 0));\n    row.avg_similarity = (row.concept_similarities as number[]).reduce((a, b) => a + b, 0) / concepts.length;\n    row.isConstitutional = row.importance_tier === 'constitutional';\n    return row;\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   CONTENT EXTRACTION HELPERS\n----------------------------------------------------------------*/\n\n/**\n * Extracts a display title from indexed content.\n * @param content - The content to inspect.\n * @param filename - The optional source filename.\n * @returns The extracted title.\n */\nexport function extract_title(content: unknown, filename?: string): string {\n  if (!content || typeof content !== 'string') {\n    return filename ? path.basename(filename, path.extname(filename)) : 'Untitled';\n  }\n\n  const h1_match = content.match(/^#\\s+(.+)$/m);\n  if (h1_match && h1_match[1]) {\n    return h1_match[1].trim();\n  }\n\n  const h2_match = content.match(/^##\\s+(.+)$/m);\n  if (h2_match && h2_match[1]) {\n    return h2_match[1].trim();\n  }\n\n  const yaml_match = content.match(/^---[\\s\\S]*?^title:\\s*(.+)$/m);\n  if (yaml_match && yaml_match[1]) {\n    return yaml_match[1].trim().replace(/^[\"']|[\"']$/g, '');","lineStart":394,"lineEnd":613,"totalLines":1706,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts","time":{"start":1781151311847,"end":1781151311861}},"metadata":{"openai":{"itemId":"fc_0f1322bf3766cfbb016a2a364f819c81918ebb4312dec273a7"}},"id":"prt_eb4e426a1001K6Amwa2ENGC483","sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","messageID":"msg_eb4e40ce0001fJ9Y1NCFW3dWj8"}}
