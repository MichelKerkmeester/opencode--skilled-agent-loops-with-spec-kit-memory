   212	  const score = headingScore + patternScore + cleanScore;
   213	  const failureModes = [];
   214	  if (missingHeadings.length > 0) {
   215	    failureModes.push('missing-headings');
   216	  }
   217	  if (missingPatterns.length > 0) {
   218	    failureModes.push('missing-required-patterns');
   219	  }
   220	  if (forbiddenMatches.length > 0) {
   221	    failureModes.push('forbidden-patterns');
   222	  }
