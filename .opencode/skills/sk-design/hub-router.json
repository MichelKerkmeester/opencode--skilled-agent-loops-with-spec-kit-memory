{
  "skill": "sk-design",
  "version": "1.2.0.0",
  "routerPolicy": {
    "defaultMode": "interface",
    "ambiguityDelta": 1,
    "tieBreak": ["interface", "foundations", "motion", "audit", "md-generator"],
    "outcomes": {
      "single": "one dominant design axis routes to one mode",
      "orderedBundle": "clearly separate design axes route to an ordered mode list",
      "defer": "unclear or contradictory design intent asks for disambiguation"
    },
    "defaultResource": [
      "shared/anti_slop_principles.md",
      "shared/cognitive_laws.md",
      "shared/design_token_vocabulary.md",
      "references/design_proof_token.md"
    ],
    "bundleRules": [
      {
        "name": "ui-build-bundle",
        "whenAll": ["interface", "foundations"],
        "outcome": "orderedBundle"
      }
    ]
  },
  "routerSignals": {
    "interface": {
      "weight": 4,
      "classes": [
        "interface-aliases",
        "interface-taste",
        "interface-build",
        "hub-identity"
      ],
      "resources": ["design-interface/SKILL.md"]
    },
    "foundations": {
      "weight": 4,
      "classes": [
        "foundations-aliases",
        "foundations-color",
        "foundations-type",
        "foundations-layout",
        "foundations-tokens",
        "hub-identity"
      ],
      "resources": ["design-foundations/SKILL.md"]
    },
    "motion": {
      "weight": 4,
      "classes": [
        "motion-aliases",
        "motion-temporal",
        "motion-runtime",
        "motion-feel",
        "hub-identity"
      ],
      "resources": ["design-motion/SKILL.md"]
    },
    "audit": {
      "weight": 4,
      "classes": [
        "audit-aliases",
        "audit-quality",
        "audit-transform-question",
        "audit-accessibility",
        "audit-hardening",
        "hub-identity"
      ],
      "resources": ["design-audit/SKILL.md"]
    },
    "md-generator": {
      "weight": 4,
      "classes": [
        "md-generator-aliases",
        "md-generator-extraction",
        "md-generator-artifacts",
        "md-generator-validation",
        "hub-identity"
      ],
      "resources": ["design-md-generator/SKILL.md"]
    }
  },
