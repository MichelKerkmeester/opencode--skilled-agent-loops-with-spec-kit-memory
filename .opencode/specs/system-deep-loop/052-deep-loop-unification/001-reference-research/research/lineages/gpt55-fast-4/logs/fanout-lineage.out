{"type":"tool_use","timestamp":1783486764356,"sessionID":"ses_0bfeb66afffetpkX52bffjbY3h","part":{"type":"tool","tool":"read","callID":"call_t0y4B96ZhAFvvGPjdZYmSoLJ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/aliases.ts","offset":1,"limit":240},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/aliases.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Advisor Skill Alias Groups\n3: // ───────────────────────────────────────────────────────────────\n4: \n5: const BASE_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = Object.freeze({\n6:   'create:agent': ['command-create-agent', '/create:agent', 'create:agent'],\n7:   'create:manual-testing-playbook': [\n8:     'command-create-manual-testing-playbook',\n9:     '/create:manual-testing-playbook',\n10:     'create:manual-testing-playbook',\n11:   ],\n12:   'memory:save': ['command-memory-save', '/memory:save', 'memory:save'],\n13:   'deep-model-benchmark': [\n14:     'command-spec-kit-deep-model-benchmark',\n15:     '/deep:start-model-benchmark-loop',\n16:     'deep-model-benchmark',\n17:     'sk-deep-model-benchmark',\n18:   ],\n19: });\n20: \n21: // BEGIN GENERATED DEEP ROUTING PROJECTION\n22: /** Hash of the generated deep-loop routing projection embedded below. */\n23: export const DEEP_ROUTING_PROJECTION_HASH = 'sha256:5c22ac993d9fb60ec1efcd4688cdf0452eb000ccb8108d581911155e5e9a7d02';\n24: \n25: const GENERATED_DEEP_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = Object.freeze({\n26:   'deep-ai-council': [\n27:     '@deep-ai-council',\n28:     'deep-ai-council',\n29:     'deep ai council',\n30:     'ai council',\n31:     'planning council',\n32:     'council deliberation',\n33:     'multi-ai-council',\n34:   ],\n35:   'deep-improvement': [\n36:     'command-spec-kit-deep-agent-improvement',\n37:     '/deep:start-agent-improvement-loop',\n38:     'deep-agent-improvement',\n39:     'sk-deep-agent-improvement',\n40:   ],\n41:   'deep-research': [\n42:     'command-spec-kit-deep-research',\n43:     '/deep:start-research-loop',\n44:     'spec_kit:deep-research',\n45:     'deep-research',\n46:     'sk-deep-research',\n47:   ],\n48:   'deep-review': [\n49:     'command-spec-kit-deep-review',\n50:     '/deep:start-review-loop',\n51:     'spec_kit:deep-review',\n52:     'deep-review',\n53:     'sk-deep-review',\n54:   ],\n55: });\n56: \n57: export const DEEP_MODE_BY_CANONICAL: Readonly<Record<string, string>> = Object.freeze({\n58:   'deep-ai-council': 'ai-council',\n59:   'deep-improvement': 'agent-improvement',\n60:   'deep-research': 'research',\n61:   'deep-review': 'review',\n62: });\n63: // END GENERATED DEEP ROUTING PROJECTION\n64: \n65: const RAW_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = Object.freeze({\n66:   ...BASE_ALIAS_GROUPS,\n67:   ...GENERATED_DEEP_ALIAS_GROUPS,\n68: });\n69: \n70: export const SKILL_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = RAW_ALIAS_GROUPS;\n71: \n72: const ALIAS_TO_CANONICAL = new Map<string, string>(\n73:   Object.entries(RAW_ALIAS_GROUPS).flatMap(([canonical, aliases]) => [\n74:     [canonical, canonical] as const,\n75:     ...aliases.map((alias) => [alias, canonical] as const),\n76:   ]),\n77: );\n78: \n79: export function canonicalSkillId(skillId: string): string {\n80:   return ALIAS_TO_CANONICAL.get(skillId) ?? skillId;\n81: }\n82: \n83: export function skillMatchesAlias(actual: string, expected: string): boolean {\n84:   return canonicalSkillId(actual) === canonicalSkillId(expected);\n85: }\n86: \n87: export function skillInAliasSet(actual: string, expected: readonly string[]): boolean {\n88:   return expected.some((candidate) => skillMatchesAlias(actual, candidate));\n89: }\n90: \n91: // ───────────────────────────────────────────────────────────────\n92: // MODULE: Merged Deep-Loop Identity + Mode Layer\n93: // ───────────────────────────────────────────────────────────────\n94: //\n95: // The active legacy deep-loop modes (deep-research, deep-review,\n96: // deep-ai-council, deep-improvement) are folded into one public skill,\n97: // deep-loop-workflows, discriminated by workflowMode (see\n98: // deep-loop-workflows/mode-registry.json). canonicalSkillId above is\n99: // deliberately UNCHANGED: an alias still resolves to its mode-level legacy id\n100: // (e.g. 'spec_kit:deep-review' -> 'deep-review') so existing callers and the\n101: // alias contract keep working. This layer adds the SECOND projection — legacy\n102: // mode-level id -> (merged skill, workflowMode) — that routers use to land on\n103: // deep-loop-workflows with the right mode once the old skill nodes leave the\n104: // graph.\n105: //\n106: // The removed standalone context route is intentionally absent from\n107: // DEEP_MODE_BY_CANONICAL and no longer appears in active registry routing.\n108: // Use @context for retrieval and research/review bounded snapshots for loops.\n109: export const MERGED_DEEP_SKILL_ID = 'deep-loop-workflows';\n110: \n111: const ALIAS_TO_MODE = new Map<string, string>(\n112:   Object.entries(RAW_ALIAS_GROUPS).flatMap(([canonical, aliases]) => {\n113:     const mode = DEEP_MODE_BY_CANONICAL[canonical];\n114:     if (!mode) return [];\n115:     return [\n116:       [canonical, mode] as const,\n117:       ...aliases.map((alias) => [alias, mode] as const),\n118:     ];\n119:   }),\n120: );\n121: \n122: const PROMPT_ALIAS_ENTRIES = Array.from(ALIAS_TO_MODE.entries())\n123:   .sort((left, right) => right[0].length - left[0].length || left[0].localeCompare(right[0]));\n124: \n125: function escapeRegExp(value: string): string {\n126:   return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n127: }\n128: \n129: function promptContainsAlias(promptLower: string, alias: string): boolean {\n130:   const normalized = alias.toLowerCase();\n131:   if (!normalized) return false;\n132:   if (/^[a-z0-9][a-z0-9 -]*[a-z0-9]$/u.test(normalized)) {\n133:     return new RegExp(`(^|[^a-z0-9])${escapeRegExp(normalized)}([^a-z0-9]|$)`, 'u').test(promptLower);\n134:   }\n135:   return promptLower.includes(normalized);\n136: }\n137: \n138: /**\n139:  * Resolve any deep-loop alias (or mode-level legacy id) to its workflowMode, or\n140:  * null when the id is not a folded deep-loop mode.\n141:  */\n142: export function modeForAlias(skillId: string): string | null {\n143:   return ALIAS_TO_MODE.get(skillId) ?? ALIAS_TO_MODE.get(canonicalSkillId(skillId)) ?? null;\n144: }\n145: \n146: /**\n147:  * Resolve a deep-loop workflowMode when a prompt directly names a generated\n148:  * alias. Returns null for broad merged-skill prompts that require hub routing.\n149:  */\n150: export function modeForPromptAlias(prompt: string): string | null {\n151:   const promptLower = prompt.toLowerCase();\n152:   for (const [alias, mode] of PROMPT_ALIAS_ENTRIES) {\n153:     if (promptContainsAlias(promptLower, alias)) return mode;\n154:   }\n155:   return null;\n156: }\n157: \n158: /**\n159:  * Resolve any deep-loop alias to the merged skill id (deep-loop-workflows) when\n160:  * it names a folded mode, else fall back to the plain canonical id. Non-deep\n161:  * skills are returned unchanged.\n162:  */\n163: export function mergedSkillForAlias(skillId: string): string {\n164:   return modeForAlias(skillId) !== null ? MERGED_DEEP_SKILL_ID : canonicalSkillId(skillId);\n165: }\n\n(End of file - total 165 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Skill Alias Groups\n// ───────────────────────────────────────────────────────────────\n\nconst BASE_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = Object.freeze({\n  'create:agent': ['command-create-agent', '/create:agent', 'create:agent'],\n  'create:manual-testing-playbook': [\n    'command-create-manual-testing-playbook',\n    '/create:manual-testing-playbook',\n    'create:manual-testing-playbook',\n  ],\n  'memory:save': ['command-memory-save', '/memory:save', 'memory:save'],\n  'deep-model-benchmark': [\n    'command-spec-kit-deep-model-benchmark',\n    '/deep:start-model-benchmark-loop',\n    'deep-model-benchmark',\n    'sk-deep-model-benchmark',\n  ],\n});\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-skill-advisor/mcp_server/lib/scorer/aliases.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Advisor Skill Alias Groups\n// ───────────────────────────────────────────────────────────────\n\nconst BASE_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = Object.freeze({\n  'create:agent': ['command-create-agent', '/create:agent', 'create:agent'],\n  'create:manual-testing-playbook': [\n    'command-create-manual-testing-playbook',\n    '/create:manual-testing-playbook',\n    'create:manual-testing-playbook',\n  ],\n  'memory:save': ['command-memory-save', '/memory:save', 'memory:save'],\n  'deep-model-benchmark': [\n    'command-spec-kit-deep-model-benchmark',\n    '/deep:start-model-benchmark-loop',\n    'deep-model-benchmark',\n    'sk-deep-model-benchmark',\n  ],\n});\n\n// BEGIN GENERATED DEEP ROUTING PROJECTION\n/** Hash of the generated deep-loop routing projection embedded below. */\nexport const DEEP_ROUTING_PROJECTION_HASH = 'sha256:5c22ac993d9fb60ec1efcd4688cdf0452eb000ccb8108d581911155e5e9a7d02';\n\nconst GENERATED_DEEP_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = Object.freeze({\n  'deep-ai-council': [\n    '@deep-ai-council',\n    'deep-ai-council',\n    'deep ai council',\n    'ai council',\n    'planning council',\n    'council deliberation',\n    'multi-ai-council',\n  ],\n  'deep-improvement': [\n    'command-spec-kit-deep-agent-improvement',\n    '/deep:start-agent-improvement-loop',\n    'deep-agent-improvement',\n    'sk-deep-agent-improvement',\n  ],\n  'deep-research': [\n    'command-spec-kit-deep-research',\n    '/deep:start-research-loop',\n    'spec_kit:deep-research',\n    'deep-research',\n    'sk-deep-research',\n  ],\n  'deep-review': [\n    'command-spec-kit-deep-review',\n    '/deep:start-review-loop',\n    'spec_kit:deep-review',\n    'deep-review',\n    'sk-deep-review',\n  ],\n});\n\nexport const DEEP_MODE_BY_CANONICAL: Readonly<Record<string, string>> = Object.freeze({\n  'deep-ai-council': 'ai-council',\n  'deep-improvement': 'agent-improvement',\n  'deep-research': 'research',\n  'deep-review': 'review',\n});\n// END GENERATED DEEP ROUTING PROJECTION\n\nconst RAW_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = Object.freeze({\n  ...BASE_ALIAS_GROUPS,\n  ...GENERATED_DEEP_ALIAS_GROUPS,\n});\n\nexport const SKILL_ALIAS_GROUPS: Readonly<Record<string, readonly string[]>> = RAW_ALIAS_GROUPS;\n\nconst ALIAS_TO_CANONICAL = new Map<string, string>(\n  Object.entries(RAW_ALIAS_GROUPS).flatMap(([canonical, aliases]) => [\n    [canonical, canonical] as const,\n    ...aliases.map((alias) => [alias, canonical] as const),\n  ]),\n);\n\nexport function canonicalSkillId(skillId: string): string {\n  return ALIAS_TO_CANONICAL.get(skillId) ?? skillId;\n}\n\nexport function skillMatchesAlias(actual: string, expected: string): boolean {\n  return canonicalSkillId(actual) === canonicalSkillId(expected);\n}\n\nexport function skillInAliasSet(actual: string, expected: readonly string[]): boolean {\n  return expected.some((candidate) => skillMatchesAlias(actual, candidate));\n}\n\n// ───────────────────────────────────────────────────────────────\n// MODULE: Merged Deep-Loop Identity + Mode Layer\n// ───────────────────────────────────────────────────────────────\n//\n// The active legacy deep-loop modes (deep-research, deep-review,\n// deep-ai-council, deep-improvement) are folded into one public skill,\n// deep-loop-workflows, discriminated by workflowMode (see\n// deep-loop-workflows/mode-registry.json). canonicalSkillId above is\n// deliberately UNCHANGED: an alias still resolves to its mode-level legacy id\n// (e.g. 'spec_kit:deep-review' -> 'deep-review') so existing callers and the\n// alias contract keep working. This layer adds the SECOND projection — legacy\n// mode-level id -> (merged skill, workflowMode) — that routers use to land on\n// deep-loop-workflows with the right mode once the old skill nodes leave the\n// graph.\n//\n// The removed standalone context route is intentionally absent from\n// DEEP_MODE_BY_CANONICAL and no longer appears in active registry routing.\n// Use @context for retrieval and research/review bounded snapshots for loops.\nexport const MERGED_DEEP_SKILL_ID = 'deep-loop-workflows';\n\nconst ALIAS_TO_MODE = new Map<string, string>(\n  Object.entries(RAW_ALIAS_GROUPS).flatMap(([canonical, aliases]) => {\n    const mode = DEEP_MODE_BY_CANONICAL[canonical];\n    if (!mode) return [];\n    return [\n      [canonical, mode] as const,\n      ...aliases.map((alias) => [alias, mode] as const),\n    ];\n  }),\n);\n\nconst PROMPT_ALIAS_ENTRIES = Array.from(ALIAS_TO_MODE.entries())\n  .sort((left, right) => right[0].length - left[0].length || left[0].localeCompare(right[0]));\n\nfunction escapeRegExp(value: string): string {\n  return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\nfunction promptContainsAlias(promptLower: string, alias: string): boolean {\n  const normalized = alias.toLowerCase();\n  if (!normalized) return false;\n  if (/^[a-z0-9][a-z0-9 -]*[a-z0-9]$/u.test(normalized)) {\n    return new RegExp(`(^|[^a-z0-9])${escapeRegExp(normalized)}([^a-z0-9]|$)`, 'u').test(promptLower);\n  }\n  return promptLower.includes(normalized);\n}\n\n/**\n * Resolve any deep-loop alias (or mode-level legacy id) to its workflowMode, or\n * null when the id is not a folded deep-loop mode.\n */\nexport function modeForAlias(skillId: string): string | null {\n  return ALIAS_TO_MODE.get(skillId) ?? ALIAS_TO_MODE.get(canonicalSkillId(skillId)) ?? null;\n}\n\n/**\n * Resolve a deep-loop workflowMode when a prompt directly names a generated\n * alias. Returns null for broad merged-skill prompts that require hub routing.\n */\nexport function modeForPromptAlias(prompt: string): string | null {\n  const promptLower = prompt.toLowerCase();\n  for (const [alias, mode] of PROMPT_ALIAS_ENTRIES) {\n    if (promptContainsAlias(promptLower, alias)) return mode;\n  }\n  return null;\n}\n\n/**\n * Resolve any deep-loop alias to the merged skill id (deep-loop-workflows) when\n * it names a folded mode, else fall back to the plain canonical id. Non-deep\n * skills are returned unchanged.\n */\nexport function mergedSkillForAlias(skillId: string): string {\n  return modeForAlias(skillId) !== null ? MERGED_DEEP_SKILL_ID : canonicalSkillId(skillId);\n}","lineStart":1,"lineEnd":165,"totalLines":165,"truncated":false}},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/aliases.ts","time":{"start":1783486764352,"end":1783486764355}},"metadata":{"openai":{"itemId":"fc_01e9cf9e4c73634a016a4dd92b5d7c8191afec3659d6398d1a"}},"id":"prt_f401851610012aJ1YRG703chzn","sessionID":"ses_0bfeb66afffetpkX52bffjbY3h","messageID":"msg_f40184804001vFAVwUh0ONhzzN"}}
