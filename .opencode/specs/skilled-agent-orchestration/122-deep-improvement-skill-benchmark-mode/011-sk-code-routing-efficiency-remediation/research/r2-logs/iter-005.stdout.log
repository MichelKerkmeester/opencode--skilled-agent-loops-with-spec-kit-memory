{"type":"tool_use","timestamp":1780373033237,"sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","part":{"type":"tool","tool":"read","callID":"call_amZ1PxboNVFAPmfhuJP8PE2R","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/live-executor.cjs","offset":1,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-improvement/scripts/skill-benchmark/live-executor.cjs</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: 'use strict';\n3: \n4: /**\n5:  * live-executor.cjs — Mode B live executor (cli-opencode).\n6:  *\n7:  * Runs a playbook routing/advisor scenario through a real `opencode run` and\n8:  * reads back what actually happened, normalized into the observed-result shape\n9:  * the scorer consumes. Validated against the live event schema (see the Phase 0\n10:  * spike): NDJSON events of shape { type, timestamp, sessionID, part }, where\n11:  *   - tool_use:  part.tool (e.g. \"skill\",\"read\",\"glob\",\"grep\",\"bash\"),\n12:  *                part.state.input, part.state.output\n13:  *   - text:      part.text  (the model's final answer)\n14:  *\n15:  * KEY observability fact: opencode emits no startup \"resources loaded\" manifest.\n16:  * So we run scenarios as routing-ANALYSIS prompts — the model STATES its routing\n17:  * in a fenced JSON block, which we grade against gold. tool_use events\n18:  * corroborate (a `skill` call with input.name === skillId is hard activation\n19:  * evidence; read/glob/grep on the skill's tree is observed discovery).\n20:  *\n21:  * Self-contained dispatch (does not reuse dispatch-model.cjs): MiniMax models\n22:  * reject `--agent`, which that helper hardcodes, and we need `--format json`.\n23:  * Model + binary come from env so no machine-specific id is baked in.\n24:  */\n25: \n26: const fs = require('fs');\n27: const path = require('path');\n28: const { spawnSync } = require('child_process');\n29: \n30: const DEFAULT_MODEL = process.env.SKILL_BENCH_OPENCODE_MODEL || 'opencode-go/deepseek-v4-pro';\n31: const DEFAULT_VARIANT = process.env.SKILL_BENCH_OPENCODE_VARIANT || 'high';\n32: const OPENCODE_BIN = process.env.OPENCODE_BIN || 'opencode';\n33: const DISPATCH_TIMEOUT_MS = Number(process.env.SKILL_BENCH_DISPATCH_TIMEOUT_MS || 360000);\n34: \n35: // Wrap the scenario prompt as a routing-ANALYSIS task with a strict output\n36: // contract. CS-* scenarios are already analysis-shaped; SD/LS/RD/SA get the\n37: // reframe. The contract forces one fenced json block the parser can read.\n38: function buildLiveDispatchPrompt(scenario) {\n39:   const base = scenario.prompt || '';\n40:   return [\n41:     'You are analyzing skill routing only - do NOT edit files.',\n42:     `Task: ${base}`,\n43:     '',\n44:     'Using the project code skill, determine: (1) the detected SURFACE '\n45:       + '(WEBFLOW / OPENCODE / UNKNOWN), (2) the OPENCODE sub-language if any, '\n46:       + '(3) the exact reference/asset file paths you would load (relative to the '\n47:       + 'skill root, e.g. references/... and assets/...), (4) the agent you would '\n48:       + 'dispatch, or \"none\".',\n49:     'Then emit ONLY a fenced ```json code block, nothing after it:',\n50:     '{\"surface\": \"...\", \"subLanguage\": \"...\", \"resources\": [\"references/...\"], '\n51:       + '\"assets\": [\"assets/...\"], \"agent\": \"none\", \"disambiguation\": false}',\n52:   ].join('\\n');\n53: }\n54: \n55: function dispatchArgs(model, dir, variant) {\n56:   const args = ['run', '--model', model];\n57:   // No explicit --agent: on this opencode build `general` is classified as a\n58:   // subagent (warns + falls back), and MiniMax rejects --agent outright. The\n59:   // default primary agent loads skills fine for a routing-analysis dispatch.\n60:   // Reasoning effort (provider-specific, e.g. high/max). MiniMax highspeed\n61:   // ignores variants; skip it there to avoid a rejected flag.\n62:   if (variant && !/minimax/i.test(model)) args.push('--variant', variant);\n63:   args.push('--format', 'json', '--dir', dir);\n64:   return args;\n65: }\n66: \n67: function runDispatch({ prompt, dir, model, variant, extraEnv }) {\n68:   const res = spawnSync(OPENCODE_BIN, [...dispatchArgs(model, dir, variant), prompt], {\n69:     cwd: dir,\n70:     stdio: ['ignore', 'pipe', 'pipe'], // closed stdin == the mandatory </dev/null\n71:     encoding: 'utf8',\n72:     timeout: DISPATCH_TIMEOUT_MS,\n73:     maxBuffer: 32 * 1024 * 1024,\n74:     env: { ...process.env, AI_SESSION_CHILD: '1', ...(extraEnv || {}) },\n75:   });\n76:   return { status: res.status, stdout: res.stdout || '', stderr: res.stderr || '', timedOut: res.signal === 'SIGTERM' };\n77: }\n78: \n79: function parseEvents(stdout) {\n80:   const events = [];\n\n(Showing lines 1-80 of 204. Use offset=81 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n'use strict';\n\n/**\n * live-executor.cjs — Mode B live executor (cli-opencode).\n *\n * Runs a playbook routing/advisor scenario through a real `opencode run` and\n * reads back what actually happened, normalized into the observed-result shape\n * the scorer consumes. Validated against the live event schema (see the Phase 0\n * spike): NDJSON events of shape { type, timestamp, sessionID, part }, where\n *   - tool_use:  part.tool (e.g. \"skill\",\"read\",\"glob\",\"grep\",\"bash\"),\n *                part.state.input, part.state.output\n *   - text:      part.text  (the model's final answer)\n *\n * KEY observability fact: opencode emits no startup \"resources loaded\" manifest.\n * So we run scenarios as routing-ANALYSIS prompts — the model STATES its routing\n * in a fenced JSON block, which we grade against gold. tool_use events\n * corroborate (a `skill` call with input.name === skillId is hard activation\n * evidence; read/glob/grep on the skill's tree is observed discovery).\n *","truncated":true,"loaded":[]},"title":".opencode/skills/deep-improvement/scripts/skill-benchmark/live-executor.cjs","time":{"start":1780373033231,"end":1780373033236}},"metadata":{"openai":{"itemId":"fc_0f93b8f73c6d7bcb016a1e562918508191b076652d4664e9c4"}},"id":"prt_e868090fe001aZHbxmQQxAqUoS","sessionID":"ses_179821a7fffeliBzI3TOZnRjZf","messageID":"msg_e867f9af9001277CAGnUVp8u3h"}}
