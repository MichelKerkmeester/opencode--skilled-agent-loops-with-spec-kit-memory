 \"runtimeLoopType\",\n106:       \"backendKind\",\n107:       \"research-mode\",\n108:       \"review-mode\",\n109:       \"ai-council-mode\",\n110:       \"improvement-mode\",\n111:       \"agent-improvement\",\n112:       \"model-benchmark\",\n113:       \"skill-benchmark\",\n114:       \"non-dev-ai-system-refine\"\n115:     ],\n116:     \"key_files\": [\n117:       \".opencode/skills/deep-loop-workflows/SKILL.md\",\n118:       \".opencode/skills/deep-loop-workflows/mode-registry.json\",\n119:       \".opencode/skills/deep-loop-workflows/deep-research/SKILL.md\",\n120:       \".opencode/skills/deep-loop-workflows/deep-review/SKILL.md\",\n121:       \".opencode/skills/deep-loop-workflows/deep-ai-council/SKILL.md\",\n122:       \".opencode/skills/deep-loop-workflows/deep-improvement/SKILL.md\",\n123:       \".opencode/skills/deep-loop-workflows/shared/synthesis/resource-map.cjs\"\n124:     ],\n125:     \"entities\": [\n126:       {\n127:         \"name\": \"deep-loop-workflows\",\n128:         \"kind\": \"skill\",\n129:         \"path\": \".opencode/skills/deep-loop-workflows/SKILL.md\",\n130:         \"source\": \"derived\"\n131:       },\n132:       {\n133:         \"name\": \"mode-registry\",\n134:         \"kind\": \"config\",\n135:         \"path\": \".opencode/skills/deep-loop-workflows/mode-registry.json\",\n136:         \"source\": \"derived\"\n137:       },\n138:       {\n139:         \"name\": \"deep-loop-runtime\",\n140:         \"kind\": \"skill\",\n141:         \"path\": \".opencode/skills/deep-loop-runtime/SKILL.md\",\n142:         \"source\": \"derived\"\n143:       }\n144:     ],\n145:     \"causal_summary\": \"deep-loop-workflows is the single public skill that merges active deep-loop persona modes (deep-research, deep-review, deep-ai-council, deep-improvement) into one advisor identity with active mode packets, routed by workflowMode through mode-registry.json over the frozen MCP-free deep-loop-runtime backend. @context owns one-shot retrieval while research and review carry bounded context snapshots. Per-mode convergence, state, artifacts, and tool-permission contracts are preserved unflattened; the three-tier discriminator (workflowMode / runtimeLoopType / backendKind) keeps graph-backed modes and improvement-host/external-adapter modes distinct.\",\n146:     \"source_docs\": [\n147:       \"SKILL.md\",\n148:       \"README.md\",\n149:       \"mode-registry.json\",\n150:       \"deep-research/SKILL.md\",\n151:       \"deep-review/SKILL.md\",\n152:       \"deep-ai-council/SKILL.md\",\n153:       \"deep-improvement/SKILL.md\"\n154:     ],\n155:     \"created_at\": \"2026-06-15T00:00:00Z\",\n156:     \"last_updated_at\": \"2026-07-08T03:29:41Z\"\n157:   }\n158: }\n\n(End of file - total 158 lines)\n</content>","metadata":{"preview":"{\n  \"schema_version\": 2,\n  \"skill_id\": \"deep-loop-workflows\",\n  \"family\": \"deep-loop\",\n  \"category\": \"workflow\",\n  \"importance_tier\": \"important\",\n  \"edges\": {\n    \"depends_on\": [\n      {\n        \"target\": \"deep-loop-runtime\",\n        \"weight\": 0.8,\n        \"context\": \"consumes the frozen MCP-free backend (executor, coverage-graph, scoring, fan-out, council primitives, promoted plumbing) for every mode\"\n      },\n      {\n        \"target\": \"system-spec-kit\",\n        \"weight\": 0.6,\n        \"context\": \"spec-folder workflow, artifact-root topology, and command YAML consumers\"\n      }\n    ],\n    \"enhances\": [","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/graph-metadata.json","text":"{\n  \"schema_version\": 2,\n  \"skill_id\": \"deep-loop-workflows\",\n  \"family\": \"deep-loop\",\n  \"category\": \"workflow\",\n  \"importance_tier\": \"important\",\n  \"edges\": {\n    \"depends_on\": [\n      {\n        \"target\": \"deep-loop-runtime\",\n        \"weight\": 0.8,\n        \"context\": \"consumes the frozen MCP-free backend (executor, coverage-graph, scoring, fan-out, council primitives, promoted plumbing) for every mode\"\n      },\n      {\n        \"target\": \"system-spec-kit\",\n        \"weight\": 0.6,\n        \"context\": \"spec-folder workflow, artifact-root topology, and command YAML consumers\"\n      }\n    ],\n    \"enhances\": [\n      {\n        \"target\": \"system-spec-kit\",\n        \"weight\": 0.6,\n        \"context\": \"research and review modes provide bounded context outputs for spec-kit planning and implementation workflows\"\n      }\n    ],\n    \"siblings\": [\n      {\n        \"target\": \"deep-loop-runtime\",\n        \"weight\": 0.7,\n        \"context\": \"the backend peer in the deep-loop family\"\n      },\n      {\n        \"target\": \"sk-prompt\",\n        \"weight\": 0.4,\n        \"context\": \"improvement utility peer\"\n      }\n    ],\n    \"conflicts_with\": [],\n    \"prerequisite_for\": []\n  },\n  \"manual\": {\n    \"depends_on\": [\"deep-loop-runtime\"],\n    \"related_to\": [\"system-spec-kit\", \"system-code-graph\", \"system-skill-advisor\"]\n  },\n  \"domains\": [\n    \"deep-loop\",\n    \"workflow\",\n    \"research\",\n    \"review-loop\",\n    \"ai-council\",\n    \"agent-improvement\",\n    \"convergence\",\n    \"coverage-graph\",\n    \"mode-registry\"\n  ],\n  \"intent_signals\": [\n    \"deep loop workflow\",\n    \"deep-research\",\n    \"deep-review\",\n    \"deep-ai-council\",\n    \"deep-improvement\",\n    \"research loop\",\n    \"iterative review loop\",\n    \"deep-review wave\",\n    \"release readiness\",\n    \"ai council deliberation\",\n    \"agent improvement benchmark\"\n  ],\n  \"derived\": {\n    \"trigger_phrases\": [\n      \"deep-loop-workflows\",\n      \"deep loop workflows\",\n      \"deep research\",\n      \"research loop\",\n      \"iterative investigation workflow\",\n      \"deep-research\",\n      \"autoresearch\",\n      \"deep review\",\n      \"review loop\",\n      \"iterative review loop\",\n      \"severity weighted findings\",\n      \"deep-review\",\n      \"convergence review\",\n      \"deep-review wave\",\n      \"release readiness\",\n      \"deep-ai-council\",\n      \"ai council deliberation\",\n      \"multi-seat planning council\",\n      \"council convergence\",\n      \"improve agent\",\n      \"evaluate agent\",\n      \"score agent candidate\",\n      \"deep-improvement\",\n      \"agent-improvement\",\n      \"model benchmark\",\n      \"benchmark a model or prompt framework\",\n      \"skill benchmark\",\n      \"non-dev ai system\"\n    ],\n    \"key_topics\": [\n      \"deep-loop-workflows\",\n      \"mode-registry\",\n      \"workflowMode\",\n      \"runtimeLoopType\",\n      \"backendKind\",\n      \"research-mode\",\n      \"review-mode\",\n      \"ai-council-mode\",\n      \"improvement-mode\",\n      \"agent-improvement\",\n      \"model-benchmark\",\n      \"skill-benchmark\",\n      \"non-dev-ai-system-refine\"\n    ],\n    \"key_files\": [\n      \".opencode/skills/deep-loop-workflows/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/mode-registry.json\",\n      \".opencode/skills/deep-loop-workflows/deep-research/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/deep-review/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/deep-ai-council/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/deep-improvement/SKILL.md\",\n      \".opencode/skills/deep-loop-workflows/shared/synthesis/resource-map.cjs\"\n    ],\n    \"entities\": [\n      {\n        \"name\": \"deep-loop-workflows\",\n        \"kind\": \"skill\",\n        \"path\": \".opencode/skills/deep-loop-workflows/SKILL.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"mode-registry\",\n        \"kind\": \"config\",\n        \"path\": \".opencode/skills/deep-loop-workflows/mode-registry.json\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"deep-loop-runtime\",\n        \"kind\": \"skill\",\n        \"path\": \".opencode/skills/deep-loop-runtime/SKILL.md\",\n        \"source\": \"derived\"\n      }\n    ],\n    \"causal_summary\": \"deep-loop-workflows is the single public skill that merges active deep-loop persona modes (deep-research, deep-review, deep-ai-council, deep-improvement) into one advisor identity with active mode packets, routed by workflowMode through mode-registry.json over the frozen MCP-free deep-loop-runtime backend. @context owns one-shot retrieval while research and review carry bounded context snapshots. Per-mode convergence, state, artifacts, and tool-permission contracts are preserved unflattened; the three-tier discriminator (workflowMode / runtimeLoopType / backendKind) keeps graph-backed modes and improvement-host/external-adapter modes distinct.\",\n    \"source_docs\": [\n      \"SKILL.md\",\n      \"README.md\",\n      \"mode-registry.json\",\n      \"deep-research/SKILL.md\",\n      \"deep-review/SKILL.md\",\n      \"deep-ai-council/SKILL.md\",\n      \"deep-improvement/SKILL.md\"\n    ],\n    \"created_at\": \"2026-06-15T00:00:00Z\",\n    \"last_updated_at\": \"2026-07-08T03:29:41Z\"\n  }\n}","lineStart":1,"lineEnd":158,"totalLines":158,"truncated":false}},"title":".opencode/skills/deep-loop-workflows/graph-metadata.json","time":{"start":1783486697032,"end":1783486697038}},"metadata":{"openai":{"itemId":"fc_02a69f2f33d65f64016a4dd8e8d3308191921d1af579483262"}},"id":"prt_f40174e45001LrkkYlHD3wdfz5","sessionID":"ses_0bfeb66afffetpkX52bffjbY3h","messageID":"msg_f40171502001rTwww93LgMlEDe"}}
