{"type":"tool_use","timestamp":1780925328247,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"type":"tool","tool":"read","callID":"call_QHE1xd4ckQcG5Usz6uVQ3aWF","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","offset":1,"limit":80},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Store\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // SEARCH: VECTOR INDEX\n6: // TypeScript port of the vector index implementation.\n7: // DECAY STRATEGY: Search-time temporal decay uses an\n8: // FSRS-preferred strategy. Memories with FSRS review data (last_review\n9: // IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n10: // R(t) = (1 + 0.2346 * t / S)^(-0.5)\n11: // Memories without review data fall back to half-life exponential:\n12: // Weight * 0.5^(days / half_life_days)\n13: // This ensures backward compatibility while aligning reviewed\n14: // Memories with the canonical FSRS algorithm.\n15: \n16: import * as fs from 'fs';\n17: import * as os from 'os';\n18: import * as path from 'path';\n19: \n20: import Database from 'better-sqlite3';\n21: import * as sqliteVec from 'sqlite-vec';\n22: \n23: import { getEmbeddingDimension } from '@spec-kit/shared/embeddings';\n24: import {\n25:   EmbeddingProfile,\n26: } from '@spec-kit/shared/embeddings/profile';\n27: import { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings/factory';\n28: \n29: import { resolveDatabasePaths, SERVER_DIR } from '../../core/config.js';\n30: import { IVectorStore } from '../interfaces/vector-store.js';\n31: import { computeInterferenceScoresBatch } from '../scoring/interference-scoring.js';\n32: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\n33: import { validateFilePath } from '../utils/path-security.js';\n34: import {\n35:   get_error_code,\n36:   get_error_message,\n37:   parse_trigger_phrases,\n38:   VectorIndexError,\n39:   VectorIndexErrorCode,\n40: } from './vector-index-types.js';\n41: import {\n42:   create_schema,\n43:   ensure_schema_version,\n44: } from './vector-index-schema.js';\n45: import { migrateLegacySingleDbToShardSync } from './db-shard-migration.js';\n46: import type {\n47:   EmbeddingInput,\n48:   EnrichedSearchResult,\n49:   IndexMemoryParams,\n50:   MemoryRow,\n51:   VectorSearchOptions,\n52: } from './vector-index-types.js';\n53: \n54: type SearchWeightsConfig = {\n55:   maxTriggersPerMemory?: number;\n56:   smartRanking?: {\n57:     recencyWeight?: number;\n58:     accessWeight?: number;\n59:     relevanceWeight?: number;\n60:   };\n61: };\n62: \n63: type RestoreJournalPhase = 'swap-pending' | 'swap-done';\n64: \n65: type RestoreJournalFile = {\n66:   formatVersion: 1;\n67:   phase: RestoreJournalPhase;\n68:   createdAt: string;\n69:   checkpointName: string;\n70:   liveMainPath: string;\n71:   backupMainPath: string;\n72:   snapshotMainPath: string;\n73:   liveShardPath: string | null;\n74:   backupShardPath: string | null;\n75:   snapshotVecPath: string | null;\n76:   shouldRestoreVec: boolean;\n77:   liveShardPreexisted: boolean;\n78: };\n79: \n80: type InitializeDbOptions = {\n\n(Showing lines 1-80 of 2042. Use offset=81 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Store\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// SEARCH: VECTOR INDEX\n// TypeScript port of the vector index implementation.\n// DECAY STRATEGY: Search-time temporal decay uses an\n// FSRS-preferred strategy. Memories with FSRS review data (last_review\n// IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n// R(t) = (1 + 0.2346 * t / S)^(-0.5)\n// Memories without review data fall back to half-life exponential:\n// Weight * 0.5^(days / half_life_days)\n// This ensures backward compatibility while aligning reviewed\n// Memories with the canonical FSRS algorithm.\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Store\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// SEARCH: VECTOR INDEX\n// TypeScript port of the vector index implementation.\n// DECAY STRATEGY: Search-time temporal decay uses an\n// FSRS-preferred strategy. Memories with FSRS review data (last_review\n// IS NOT NULL, review_count > 0) use the FSRS v4 power-law formula:\n// R(t) = (1 + 0.2346 * t / S)^(-0.5)\n// Memories without review data fall back to half-life exponential:\n// Weight * 0.5^(days / half_life_days)\n// This ensures backward compatibility while aligning reviewed\n// Memories with the canonical FSRS algorithm.\n\nimport * as fs from 'fs';\nimport * as os from 'os';\nimport * as path from 'path';\n\nimport Database from 'better-sqlite3';\nimport * as sqliteVec from 'sqlite-vec';\n\nimport { getEmbeddingDimension } from '@spec-kit/shared/embeddings';\nimport {\n  EmbeddingProfile,\n} from '@spec-kit/shared/embeddings/profile';\nimport { getStartupEmbeddingProfile } from '@spec-kit/shared/embeddings/factory';\n\nimport { resolveDatabasePaths, SERVER_DIR } from '../../core/config.js';\nimport { IVectorStore } from '../interfaces/vector-store.js';\nimport { computeInterferenceScoresBatch } from '../scoring/interference-scoring.js';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder } from '../embedders/schema.js';\nimport { validateFilePath } from '../utils/path-security.js';\nimport {\n  get_error_code,\n  get_error_message,\n  parse_trigger_phrases,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  create_schema,\n  ensure_schema_version,\n} from './vector-index-schema.js';\nimport { migrateLegacySingleDbToShardSync } from './db-shard-migration.js';\nimport type {\n  EmbeddingInput,\n  EnrichedSearchResult,\n  IndexMemoryParams,\n  MemoryRow,\n  VectorSearchOptions,\n} from './vector-index-types.js';\n\ntype SearchWeightsConfig = {\n  maxTriggersPerMemory?: number;\n  smartRanking?: {\n    recencyWeight?: number;\n    accessWeight?: number;\n    relevanceWeight?: number;\n  };\n};\n\ntype RestoreJournalPhase = 'swap-pending' | 'swap-done';\n\ntype RestoreJournalFile = {\n  formatVersion: 1;\n  phase: RestoreJournalPhase;\n  createdAt: string;\n  checkpointName: string;\n  liveMainPath: string;\n  backupMainPath: string;\n  snapshotMainPath: string;\n  liveShardPath: string | null;\n  backupShardPath: string | null;\n  snapshotVecPath: string | null;\n  shouldRestoreVec: boolean;\n  liveShardPreexisted: boolean;\n};\n\ntype InitializeDbOptions = {","lineStart":1,"lineEnd":80,"totalLines":2042,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","time":{"start":1780925328234,"end":1780925328246}},"metadata":{"openai":{"itemId":"fc_0752ecbcaf7741ea016a26c38ff3d08191a8dfbccffb876b96"}},"id":"prt_ea76beaca001Wf9cpmokOlit3G","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76bc38f001t8Qxft3dTEc5w7"}}
{"type":"tool_use","timestamp":1780925328391,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"type":"tool","tool":"glob","callID":"call_iM9eqez8KUY16CNoEsmf3OIr","state":{"status":"completed","input":{"pattern":"**/fsrs-scheduler.ts","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server"},"output":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/cognitive/fsrs-scheduler.ts","metadata":{"count":1,"truncated":false},"title":".opencode/skills/system-spec-kit/mcp_server","time":{"start":1780925328376,"end":1780925328390}},"metadata":{"openai":{"itemId":"fc_0752ecbcaf7741ea016a26c38ff3ec8191af1be30bf24ff9ae"}},"id":"prt_ea76beba0001rFAUyucK6f5sQB","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76bc38f001t8Qxft3dTEc5w7"}}
{"type":"tool_use","timestamp":1780925328439,"sessionID":"ses_158954ad3ffeepM4JX05JFyErC","part":{"type":"tool","tool":"read","callID":"call_YE0X318cXexKuZdzmSkVpT01","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-triggers.ts","offset":120,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-triggers.ts</path>\n<type>file</type>\n<content>\n120:    2b. CONSTANTS\n121: ──────────────────────────────────────────────────────────────── */\n122: \n123: /** Per-turn decay rate for attention scoring. */\n124: const TURN_DECAY_RATE = 0.98;\n125: const validateTieredFilePath = createFilePathValidator(ALLOWED_BASE_PATHS, validateFilePath);\n126: \n127: /* ───────────────────────────────────────────────────────────────\n128:    2c. HELPER FUNCTIONS\n129: ──────────────────────────────────────────────────────────────── */\n130: \n131: /** Fetch full memory records required for FSRS tier classification. */\n132: function fetchMemoryRecords(memoryIds: number[]): Map<number, TierInput> {\n133:   const records = new Map<number, TierInput>();\n134:   if (memoryIds.length === 0) return records;\n135: \n136:   const db = attentionDecay.getDb();\n137:   if (!db) return records;\n138: \n139:   try {\n140:     const stmt = db.prepare(\n141:       'SELECT * FROM memory_index WHERE id = ?'\n142:     );\n143:     for (const id of memoryIds) {\n144:       const row = stmt.get(id) as TierInput | undefined;\n145:       if (row) {\n146:         records.set(row.id as number, row);\n147:       }\n148:     }\n149:   } catch (err: unknown) {\n150:     const message = toErrorMessage(err);\n151:     console.warn('[memory_match_triggers] Failed to fetch memory records:', message);\n152:   }\n153: \n154:   return records;\n155: }\n156: \n157: /** Result shape returned by getTieredContent */\n158: interface TieredContentResult {\n159:   /** Truncated content for MCP output (full for HOT, 150-char summary for WARM, empty for COLD) */\n160:   content: string;\n161:   /**\n162:    * Token count of the complete file before any truncation. Populated for WARM entries\n163:    * so calculateTokenMetrics can use the real file size as the hypothetical baseline\n164:    * rather than scaling up the summary window with a fixed multiplier.\n165:    */\n166:   fullContentTokens: number;\n167: }\n168: \n169: /** Get tiered content for a memory based on its tier state (HOT=full, WARM=summary, COLD=excluded) */\n170: async function getTieredContent(\n171:   memoryInfo: { filePath: string; title: string | null; triggerPhrases: string[] },\n172:   tier: string\n173: ): Promise<TieredContentResult> {\n174:   if (tier === 'COLD' || tier === 'DORMANT' || tier === 'ARCHIVED') return { content: '', fullContentTokens: 0 };\n175:   try {\n176:     const fs = await import('fs');\n177:     const validatedPath = validateTieredFilePath(memoryInfo.filePath);\n178:     const canonicalPath = validateTieredFilePath(fs.realpathSync(validatedPath));\n179:     const content = fs.readFileSync(canonicalPath, 'utf-8');\n180:     if (tier === 'HOT') return { content, fullContentTokens: estimateTokens(content) };\n181:     // WARM tier: capture full token count before truncating to summary window\n182:     const fullContentTokens = estimateTokens(content);\n183:     const summary = content.substring(0, 150) + (content.length > 150 ? '...' : '');\n184:     return { content: summary, fullContentTokens };\n185:   } catch (_error: unknown) {\n186:     console.warn('[memory-triggers] getTieredContent failed', {\n187:       filePath: memoryInfo.filePath, // server-side only; safe to log\n188:       tier,\n189:       error: _error instanceof Error ? _error.message : String(_error),\n190:     });\n191:     return { content: '', fullContentTokens: 0 };\n192:   }\n193: }\n194: \n195: /* ───────────────────────────────────────────────────────────────\n196:    3. MATCH TRIGGERS HANDLER\n197: ──────────────────────────────────────────────────────────────── */\n198: \n199: /** Handle memory_match_triggers tool - matches prompt against trigger phrases with cognitive decay */\n200: async function handleMemoryMatchTriggers(args: TriggerArgs): Promise<MCPResponse> {\n201:   await ensureMemoryRuntimeInitialized('handler:memory_match_triggers');\n202:   const {\n203:     prompt,\n204:     limit: rawLimit = 3,\n205:     session_id: rawSessionId,\n206:     turnNumber: rawTurnNumber = 1,\n207:     include_cognitive: includeCognitive = true\n208:   } = args;\n209: \n210:   // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation)\n211:   if (!prompt || typeof prompt !== 'string') {\n212:     return createMCPErrorResponse({\n213:       tool: 'memory_match_triggers',\n214:       error: 'prompt is required and must be a string',\n215:       code: 'E_VALIDATION',\n216:       details: { parameter: 'prompt' },\n217:       recovery: {\n218:         hint: 'Provide a non-empty string for the prompt parameter'\n219:       }\n220:     });\n221:   }\n222: \n223:   // SECURITY: Validate caller-supplied sessionId through server-side session\n224:   // manager to prevent IDOR. Callers cannot read/write working memory for\n225:   // arbitrary sessions — only server-minted or previously tracked sessions.\n226:   let sessionId: string | undefined = rawSessionId;\n227:   if (rawSessionId) {\n228:     const trustedSession = sessionManager.resolveTrustedSession(rawSessionId, {\n229:       tenantId: args.tenantId,\n230:       userId: args.userId,\n231:       agentId: args.agentId,\n232:     });\n233:     if (trustedSession.error) {\n234:       console.warn(`[memory_match_triggers] SECURITY: Rejected untrusted sessionId \"${rawSessionId}\" — ${trustedSession.error}`);\n235:       return createMCPErrorResponse({\n236:         tool: 'memory_match_triggers',\n237:         error: trustedSession.error,\n238:         code: 'E_SESSION_SCOPE',\n239:         details: { requestedSessionId: rawSessionId },\n240:         recovery: {\n241:           hint: 'Omit session_id to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.',\n242:         },\n243:       });\n244:     }\n245:     sessionId = trustedSession.effectiveSessionId;\n246:   }\n247: \n248:   const limit = (typeof rawLimit === 'number' && Number.isFinite(rawLimit) && rawLimit > 0)\n249:     ? Math.min(Math.floor(rawLimit), 50)\n250:     : 3;\n251:   const turnNumber = (typeof rawTurnNumber === 'number' && Number.isFinite(rawTurnNumber) && rawTurnNumber >= 0)\n252:     ? Math.floor(rawTurnNumber)\n253:     : 1;\n254: \n255:   await checkDatabaseUpdated();\n256: \n257:   const startTime = Date.now();\n258: \n259:   // Eval logger — capture trigger query at entry (fail-safe)\n260:   let _evalQueryId = 0;\n261:   let _evalRunId = 0;\n262:   try {\n263:     const evalEntry = logSearchQuery({\n264:       query: prompt,\n265:       intent: 'trigger_match',\n266:       specFolder: null,\n267:     });\n268:     _evalQueryId = evalEntry.queryId;\n269:     _evalRunId = evalEntry.evalRunId;\n270:   } catch (_error: unknown) { /* eval logging must never break triggers handler */ }\n271: \n272:   const logFinalTriggerEval = (memoryIds: number[], latencyMs: number): void => {\n273:     try {\n274:       if (_evalRunId && _evalQueryId) {\n275:         logFinalResult({\n276:           evalRunId: _evalRunId,\n277:           queryId: _evalQueryId,\n278:           resultMemoryIds: memoryIds,\n279:           scores: memoryIds.map(() => 1.0), // trigger matches are binary\n280:           fusionMethod: 'trigger',\n281:           latencyMs,\n282:         });\n283:       }\n284:     } catch (_error: unknown) {\n285:       /* eval logging must never break triggers handler */\n286:     }\n287:   };\n288: \n289:   const useCognitive = includeCognitive &&\n290:     sessionId &&\n291:     workingMemory.isEnabled() &&\n292:     attentionDecay.getDb();\n293: \n294:   let decayStats: DecayStats | null = null;\n295:   if (useCognitive) {\n296:     try {\n297:       decayStats = { decayedCount: workingMemory.batchUpdateScores(sessionId as string) };\n298:     } catch (err: unknown) {\n299:       const message = toErrorMessage(err);\n300:       console.warn('[memory_match_triggers] Decay failed:', message);\n301:     }\n302:   }\n303: \n304:   const triggerMatchResult = triggerMatcher.matchTriggerPhrasesWithStats(prompt, limit * 2);\n305:   let results: TriggerMatch[] = triggerMatchResult.matches;\n306: \n307:   // C2 FIX: Post-filter by scope to prevent cross-tenant trigger leaks\n308:   const { specFolder, tenantId, userId, agentId } = args;\n309:   if (specFolder || tenantId || userId || agentId) {\n310:     try {\n311:       const database = initialize_db();\n312:       const memoryIds = results.map(r => r.memoryId);\n313:       if (memoryIds.length > 0) {\n314:         const placeholders = memoryIds.map(() => '?').join(',');\n315:         const scopeRows = database.prepare(`\n316:           SELECT id, spec_folder, tenant_id, user_id, agent_id\n317:           FROM memory_index WHERE id IN (${placeholders})\n318:         `).all(...memoryIds) as Array<{\n319:           id: number;\n320:           spec_folder?: string;\n321:           tenant_id?: string;\n322:           user_id?: string;\n323:           agent_id?: string;\n324:         }>;\n325:         const scopeMap = new Map(scopeRows.map(r => [r.id, r]));\n326:         results = results.filter(match => {\n327:           const row = scopeMap.get(match.memoryId);\n328:           if (!row) return false;\n329:           // H2 FIX: Require exact scope match — rows with NULL scope are excluded\n330:           // when the caller specifies a scope, not silently passed through.\n331:           if (specFolder && row.spec_folder !== specFolder) return false;\n332:           if (tenantId && row.tenant_id !== tenantId) return false;\n333:           if (userId && row.user_id !== userId) return false;\n334:           if (agentId && row.agent_id !== agentId) return false;\n335:           return true;\n336:         });\n337:       }\n338:     } catch (scopeErr: unknown) {\n339:       console.error('[memory_match_triggers] Scope filtering failed, returning empty results (fail-closed):', toErrorMessage(scopeErr));\n340:       results = [];\n341:     }\n342:   }\n343:   const detectedSignals = Array.isArray(triggerMatchResult.stats?.signals)\n344:     ? triggerMatchResult.stats.signals\n345:     : [];\n346:   const degradedTriggerMatching = triggerMatchResult.stats?.degraded ?? null;\n347: \n348:   if (!results || results.length === 0) {\n349:     const noMatchResponse = createMCPEmptyResponse({\n350:       tool: 'memory_match_triggers',\n351:       summary: 'No matching trigger phrases found',\n352:       data: {\n353:         matchType: useCognitive ? 'trigger-phrase-cognitive' : 'trigger-phrase',\n354:         degradedMatching: degradedTriggerMatching,\n355:         cognitive: useCognitive ? {\n356:           enabled: true,\n357:           sessionId,\n358:           turnNumber: turnNumber,\n359:           decayApplied: decayStats ? decayStats.decayedCount : 0\n360:         } : null\n361:       },\n362:       hints: [\n363:         'Ensure memories have trigger phrases defined',\n364:         'Try a different prompt or check memory content',\n365:         ...(degradedTriggerMatching ? ['Trigger matching ran in degraded mode; inspect server logs for skipped trigger sources'] : []),\n366:       ],\n367:       startTime: startTime\n368:     });\n369: \n370:     logFinalTriggerEval([], Date.now() - startTime);\n371:     return noMatchResponse;\n372:   }\n373: \n374:   let formattedResults: FormattedResult[];\n375:   let cognitiveStats: CognitiveStats | null = null;\n376: \n377:   if (useCognitive) {\n378:     // Activate matched memories.\n379:     const activatedMemories: number[] = [];\n380:     for (const match of results) {\n381:       try {\n382:         attentionDecay.activateMemory(match.memoryId);\n383:         // Persist max attention boost for matched memories.\n384:         workingMemory.setAttentionScore(sessionId as string, match.memoryId, 1.0);\n385:         activatedMemories.push(match.memoryId);\n386:       } catch (err: unknown) {\n387:         const message = toErrorMessage(err);\n388:         console.warn(`[memory_match_triggers] Failed to activate memory ${match.memoryId}:`, message);\n389:       }\n390:     }\n391: \n392:     // Step 4: CO-ACTIVATE\n393:     const coActivatedMemories: CoActivatedMemory[] = [];\n394:     if (coActivation.isEnabled()) {\n395:       for (const memoryId of activatedMemories) {\n396:         try {\n397:           const boosted: CoActivatedMemory[] | null = coActivation.spreadActivation([memoryId])\n398:             .map(r => ({ memoryId: r.id }));\n399:           if (boosted && Array.isArray(boosted)) {\n400:             coActivatedMemories.push(...boosted);\n401:           }\n402:         } catch (err: unknown) {\n403:           const message = toErrorMessage(err);\n404:           console.warn(`[memory_match_triggers] Co-activation failed for ${memoryId}:`, message);\n405:         }\n406:       }\n407:     }\n408: \n409:     const matchedIds = results.map((m: TriggerMatch) => m.memoryId);\n410:     const fullRecords = fetchMemoryRecords(matchedIds);\n411: \n412:     const sessionMemories: WorkingMemoryEntry[] = workingMemory.getSessionMemories(sessionId as string)\n413:       .map(wm => ({ memoryId: (wm.id as number) || 0, attentionScore: (wm.attention_score as number) || 1.0 }));\n414: \n415:     const turnDecayFactor = turnNumber > 1\n416:       ? Math.pow(TURN_DECAY_RATE, turnNumber - 1)\n417:       : 1.0;\n418: \n419:     const enrichedResults: EnrichedTriggerMatch[] = results.map((match: TriggerMatch) => {\n420:       const fullRecord = fullRecords.get(match.memoryId);\n421:       const wmEntry = sessionMemories.find(wm => wm.memoryId === match.memoryId);\n422: \n423:       let attentionScore: number;\n424:       let tier: string;\n425: \n426:       if (fullRecord) {\n427:         const classification = tierClassifier.classifyTier(fullRecord);\n428:         let effectiveRetrievability = classification.retrievability;\n429: \n430:         if (wmEntry) {\n431:           // WM already applies its own decay — skip turnDecayFactor to avoid double-decay.\n432:           effectiveRetrievability = Math.min(effectiveRetrievability, wmEntry.attentionScore);\n433:         } else {\n434:           effectiveRetrievability *= turnDecayFactor;\n435:         }\n436: \n437:         attentionScore = effectiveRetrievability;\n438:         tier = tierClassifier.classifyState(effectiveRetrievability);\n439:       } else {\n440:         // When no FSRS record, use WM score directly (already session-decayed) or apply turn decay\n441:         const baseScore = wmEntry ? wmEntry.attentionScore : 1.0;\n442:         attentionScore = wmEntry ? baseScore : baseScore * turnDecayFactor;\n443:         tier = tierClassifier.classifyState(attentionScore);\n444:       }\n445: \n446:       // Clamp to [0,1] — retrievability * decay or wmEntry scores\n447:       // Can drift outside the valid range due to floating-point arithmetic.\n448:       attentionScore = Math.max(0, Math.min(1, attentionScore));\n449: \n450:       return {\n451:         ...match,\n452:         attentionScore: attentionScore,\n453:         tier,\n454:         coActivated: coActivatedMemories.some(ca => ca.memoryId === match.memoryId)\n455:       };\n456:     });\n457: \n458:     const tieredResults = tierClassifier.filterAndLimitByState(enrichedResults, null, limit);\n459: \n460:     // Resolve tiered content for each result. getTieredContent returns the display\n461:     // content (truncated for WARM) plus a pre-truncation token count used only for\n462:     // savings% calculation — the latter is never forwarded to MCP output.\n463:     const tieredContent = await Promise.all(tieredResults.map(async (r: EnrichedTriggerMatch) =>\n464:       getTieredContent({ filePath: r.filePath, title: r.title, triggerPhrases: r.matchedPhrases }, r.tier)\n465:     ));\n466: \n467:     formattedResults = tieredResults.map((r: EnrichedTriggerMatch, i: number) => ({\n468:       memoryId: r.memoryId,\n469:       specFolder: r.specFolder,\n470:       filePath: r.filePath,\n471:       title: r.title,\n472:       matchedPhrases: r.matchedPhrases,\n473:       importanceWeight: r.importanceWeight,\n474:       tier: r.tier,\n475:       attentionScore: r.attentionScore,\n476:       content: tieredContent[i].content,\n477:       coActivated: r.coActivated || false\n478:     }));\n479: \n480:     // Metrics-only view: pairs each result with its pre-truncation token count so\n481:     // calculateTokenMetrics can compute accurate savings% for WARM entries.\n482:     const metricsResults = tieredResults.map((r: EnrichedTriggerMatch, i: number) => ({\n483:       tier: r.tier,\n484:       content: tieredContent[i].content,\n485:       fullContentTokens: tieredContent[i].fullContentTokens,\n486:     }));\n487: \n488:     cognitiveStats = {\n489:       enabled: true,\n490:       sessionId: sessionId!,\n491:       turnNumber: turnNumber,\n492:       decayApplied: decayStats ? decayStats.decayedCount : 0,\n493:       memoriesActivated: activatedMemories.length,\n494:       coActivations: coActivatedMemories.length,\n495:       tierDistribution: tierClassifier.getStateStats(enrichedResults),\n496:       tokenMetrics: calculateTokenMetrics(results, metricsResults)\n497:     };\n498: \n499:   } else {\n\n(Showing lines 120-499 of 587. Use offset=500 to continue.)\n</content>","metadata":{"preview":"   2b. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\n/** Per-turn decay rate for attention scoring. */\nconst TURN_DECAY_RATE = 0.98;\nconst validateTieredFilePath = createFilePathValidator(ALLOWED_BASE_PATHS, validateFilePath);\n\n/* ───────────────────────────────────────────────────────────────\n   2c. HELPER FUNCTIONS\n──────────────────────────────────────────────────────────────── */\n\n/** Fetch full memory records required for FSRS tier classification. */\nfunction fetchMemoryRecords(memoryIds: number[]): Map<number, TierInput> {\n  const records = new Map<number, TierInput>();\n  if (memoryIds.length === 0) return records;\n\n  const db = attentionDecay.getDb();\n  if (!db) return records;\n\n  try {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-triggers.ts","text":"   2b. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\n/** Per-turn decay rate for attention scoring. */\nconst TURN_DECAY_RATE = 0.98;\nconst validateTieredFilePath = createFilePathValidator(ALLOWED_BASE_PATHS, validateFilePath);\n\n/* ───────────────────────────────────────────────────────────────\n   2c. HELPER FUNCTIONS\n──────────────────────────────────────────────────────────────── */\n\n/** Fetch full memory records required for FSRS tier classification. */\nfunction fetchMemoryRecords(memoryIds: number[]): Map<number, TierInput> {\n  const records = new Map<number, TierInput>();\n  if (memoryIds.length === 0) return records;\n\n  const db = attentionDecay.getDb();\n  if (!db) return records;\n\n  try {\n    const stmt = db.prepare(\n      'SELECT * FROM memory_index WHERE id = ?'\n    );\n    for (const id of memoryIds) {\n      const row = stmt.get(id) as TierInput | undefined;\n      if (row) {\n        records.set(row.id as number, row);\n      }\n    }\n  } catch (err: unknown) {\n    const message = toErrorMessage(err);\n    console.warn('[memory_match_triggers] Failed to fetch memory records:', message);\n  }\n\n  return records;\n}\n\n/** Result shape returned by getTieredContent */\ninterface TieredContentResult {\n  /** Truncated content for MCP output (full for HOT, 150-char summary for WARM, empty for COLD) */\n  content: string;\n  /**\n   * Token count of the complete file before any truncation. Populated for WARM entries\n   * so calculateTokenMetrics can use the real file size as the hypothetical baseline\n   * rather than scaling up the summary window with a fixed multiplier.\n   */\n  fullContentTokens: number;\n}\n\n/** Get tiered content for a memory based on its tier state (HOT=full, WARM=summary, COLD=excluded) */\nasync function getTieredContent(\n  memoryInfo: { filePath: string; title: string | null; triggerPhrases: string[] },\n  tier: string\n): Promise<TieredContentResult> {\n  if (tier === 'COLD' || tier === 'DORMANT' || tier === 'ARCHIVED') return { content: '', fullContentTokens: 0 };\n  try {\n    const fs = await import('fs');\n    const validatedPath = validateTieredFilePath(memoryInfo.filePath);\n    const canonicalPath = validateTieredFilePath(fs.realpathSync(validatedPath));\n    const content = fs.readFileSync(canonicalPath, 'utf-8');\n    if (tier === 'HOT') return { content, fullContentTokens: estimateTokens(content) };\n    // WARM tier: capture full token count before truncating to summary window\n    const fullContentTokens = estimateTokens(content);\n    const summary = content.substring(0, 150) + (content.length > 150 ? '...' : '');\n    return { content: summary, fullContentTokens };\n  } catch (_error: unknown) {\n    console.warn('[memory-triggers] getTieredContent failed', {\n      filePath: memoryInfo.filePath, // server-side only; safe to log\n      tier,\n      error: _error instanceof Error ? _error.message : String(_error),\n    });\n    return { content: '', fullContentTokens: 0 };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MATCH TRIGGERS HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_match_triggers tool - matches prompt against trigger phrases with cognitive decay */\nasync function handleMemoryMatchTriggers(args: TriggerArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_match_triggers');\n  const {\n    prompt,\n    limit: rawLimit = 3,\n    session_id: rawSessionId,\n    turnNumber: rawTurnNumber = 1,\n    include_cognitive: includeCognitive = true\n  } = args;\n\n  // Validate inputs before any I/O (checkDatabaseUpdated is deferred until after validation)\n  if (!prompt || typeof prompt !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_match_triggers',\n      error: 'prompt is required and must be a string',\n      code: 'E_VALIDATION',\n      details: { parameter: 'prompt' },\n      recovery: {\n        hint: 'Provide a non-empty string for the prompt parameter'\n      }\n    });\n  }\n\n  // SECURITY: Validate caller-supplied sessionId through server-side session\n  // manager to prevent IDOR. Callers cannot read/write working memory for\n  // arbitrary sessions — only server-minted or previously tracked sessions.\n  let sessionId: string | undefined = rawSessionId;\n  if (rawSessionId) {\n    const trustedSession = sessionManager.resolveTrustedSession(rawSessionId, {\n      tenantId: args.tenantId,\n      userId: args.userId,\n      agentId: args.agentId,\n    });\n    if (trustedSession.error) {\n      console.warn(`[memory_match_triggers] SECURITY: Rejected untrusted sessionId \"${rawSessionId}\" — ${trustedSession.error}`);\n      return createMCPErrorResponse({\n        tool: 'memory_match_triggers',\n        error: trustedSession.error,\n        code: 'E_SESSION_SCOPE',\n        details: { requestedSessionId: rawSessionId },\n        recovery: {\n          hint: 'Omit session_id to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.',\n        },\n      });\n    }\n    sessionId = trustedSession.effectiveSessionId;\n  }\n\n  const limit = (typeof rawLimit === 'number' && Number.isFinite(rawLimit) && rawLimit > 0)\n    ? Math.min(Math.floor(rawLimit), 50)\n    : 3;\n  const turnNumber = (typeof rawTurnNumber === 'number' && Number.isFinite(rawTurnNumber) && rawTurnNumber >= 0)\n    ? Math.floor(rawTurnNumber)\n    : 1;\n\n  await checkDatabaseUpdated();\n\n  const startTime = Date.now();\n\n  // Eval logger — capture trigger query at entry (fail-safe)\n  let _evalQueryId = 0;\n  let _evalRunId = 0;\n  try {\n    const evalEntry = logSearchQuery({\n      query: prompt,\n      intent: 'trigger_match',\n      specFolder: null,\n    });\n    _evalQueryId = evalEntry.queryId;\n    _evalRunId = evalEntry.evalRunId;\n  } catch (_error: unknown) { /* eval logging must never break triggers handler */ }\n\n  const logFinalTriggerEval = (memoryIds: number[], latencyMs: number): void => {\n    try {\n      if (_evalRunId && _evalQueryId) {\n        logFinalResult({\n          evalRunId: _evalRunId,\n          queryId: _evalQueryId,\n          resultMemoryIds: memoryIds,\n          scores: memoryIds.map(() => 1.0), // trigger matches are binary\n          fusionMethod: 'trigger',\n          latencyMs,\n        });\n      }\n    } catch (_error: unknown) {\n      /* eval logging must never break triggers handler */\n    }\n  };\n\n  const useCognitive = includeCognitive &&\n    sessionId &&\n    workingMemory.isEnabled() &&\n    attentionDecay.getDb();\n\n  let decayStats: DecayStats | null = null;\n  if (useCognitive) {\n    try {\n      decayStats = { decayedCount: workingMemory.batchUpdateScores(sessionId as string) };\n    } catch (err: unknown) {\n      const message = toErrorMessage(err);\n      console.warn('[memory_match_triggers] Decay failed:', message);\n    }\n  }\n\n  const triggerMatchResult = triggerMatcher.matchTriggerPhrasesWithStats(prompt, limit * 2);\n  let results: TriggerMatch[] = triggerMatchResult.matches;\n\n  // C2 FIX: Post-filter by scope to prevent cross-tenant trigger leaks\n  const { specFolder, tenantId, userId, agentId } = args;\n  if (specFolder || tenantId || userId || agentId) {\n    try {\n      const database = initialize_db();\n      const memoryIds = results.map(r => r.memoryId);\n      if (memoryIds.length > 0) {\n        const placeholders = memoryIds.map(() => '?').join(',');\n        const scopeRows = database.prepare(`\n          SELECT id, spec_folder, tenant_id, user_id, agent_id\n          FROM memory_index WHERE id IN (${placeholders})\n        `).all(...memoryIds) as Array<{\n          id: number;\n          spec_folder?: string;\n          tenant_id?: string;\n          user_id?: string;\n          agent_id?: string;\n        }>;\n        const scopeMap = new Map(scopeRows.map(r => [r.id, r]));\n        results = results.filter(match => {\n          const row = scopeMap.get(match.memoryId);\n          if (!row) return false;\n          // H2 FIX: Require exact scope match — rows with NULL scope are excluded\n          // when the caller specifies a scope, not silently passed through.\n          if (specFolder && row.spec_folder !== specFolder) return false;\n          if (tenantId && row.tenant_id !== tenantId) return false;\n          if (userId && row.user_id !== userId) return false;\n          if (agentId && row.agent_id !== agentId) return false;\n          return true;\n        });\n      }\n    } catch (scopeErr: unknown) {\n      console.error('[memory_match_triggers] Scope filtering failed, returning empty results (fail-closed):', toErrorMessage(scopeErr));\n      results = [];\n    }\n  }\n  const detectedSignals = Array.isArray(triggerMatchResult.stats?.signals)\n    ? triggerMatchResult.stats.signals\n    : [];\n  const degradedTriggerMatching = triggerMatchResult.stats?.degraded ?? null;\n\n  if (!results || results.length === 0) {\n    const noMatchResponse = createMCPEmptyResponse({\n      tool: 'memory_match_triggers',\n      summary: 'No matching trigger phrases found',\n      data: {\n        matchType: useCognitive ? 'trigger-phrase-cognitive' : 'trigger-phrase',\n        degradedMatching: degradedTriggerMatching,\n        cognitive: useCognitive ? {\n          enabled: true,\n          sessionId,\n          turnNumber: turnNumber,\n          decayApplied: decayStats ? decayStats.decayedCount : 0\n        } : null\n      },\n      hints: [\n        'Ensure memories have trigger phrases defined',\n        'Try a different prompt or check memory content',\n        ...(degradedTriggerMatching ? ['Trigger matching ran in degraded mode; inspect server logs for skipped trigger sources'] : []),\n      ],\n      startTime: startTime\n    });\n\n    logFinalTriggerEval([], Date.now() - startTime);\n    return noMatchResponse;\n  }\n\n  let formattedResults: FormattedResult[];\n  let cognitiveStats: CognitiveStats | null = null;\n\n  if (useCognitive) {\n    // Activate matched memories.\n    const activatedMemories: number[] = [];\n    for (const match of results) {\n      try {\n        attentionDecay.activateMemory(match.memoryId);\n        // Persist max attention boost for matched memories.\n        workingMemory.setAttentionScore(sessionId as string, match.memoryId, 1.0);\n        activatedMemories.push(match.memoryId);\n      } catch (err: unknown) {\n        const message = toErrorMessage(err);\n        console.warn(`[memory_match_triggers] Failed to activate memory ${match.memoryId}:`, message);\n      }\n    }\n\n    // Step 4: CO-ACTIVATE\n    const coActivatedMemories: CoActivatedMemory[] = [];\n    if (coActivation.isEnabled()) {\n      for (const memoryId of activatedMemories) {\n        try {\n          const boosted: CoActivatedMemory[] | null = coActivation.spreadActivation([memoryId])\n            .map(r => ({ memoryId: r.id }));\n          if (boosted && Array.isArray(boosted)) {\n            coActivatedMemories.push(...boosted);\n          }\n        } catch (err: unknown) {\n          const message = toErrorMessage(err);\n          console.warn(`[memory_match_triggers] Co-activation failed for ${memoryId}:`, message);\n        }\n      }\n    }\n\n    const matchedIds = results.map((m: TriggerMatch) => m.memoryId);\n    const fullRecords = fetchMemoryRecords(matchedIds);\n\n    const sessionMemories: WorkingMemoryEntry[] = workingMemory.getSessionMemories(sessionId as string)\n      .map(wm => ({ memoryId: (wm.id as number) || 0, attentionScore: (wm.attention_score as number) || 1.0 }));\n\n    const turnDecayFactor = turnNumber > 1\n      ? Math.pow(TURN_DECAY_RATE, turnNumber - 1)\n      : 1.0;\n\n    const enrichedResults: EnrichedTriggerMatch[] = results.map((match: TriggerMatch) => {\n      const fullRecord = fullRecords.get(match.memoryId);\n      const wmEntry = sessionMemories.find(wm => wm.memoryId === match.memoryId);\n\n      let attentionScore: number;\n      let tier: string;\n\n      if (fullRecord) {\n        const classification = tierClassifier.classifyTier(fullRecord);\n        let effectiveRetrievability = classification.retrievability;\n\n        if (wmEntry) {\n          // WM already applies its own decay — skip turnDecayFactor to avoid double-decay.\n          effectiveRetrievability = Math.min(effectiveRetrievability, wmEntry.attentionScore);\n        } else {\n          effectiveRetrievability *= turnDecayFactor;\n        }\n\n        attentionScore = effectiveRetrievability;\n        tier = tierClassifier.classifyState(effectiveRetrievability);\n      } else {\n        // When no FSRS record, use WM score directly (already session-decayed) or apply turn decay\n        const baseScore = wmEntry ? wmEntry.attentionScore : 1.0;\n        attentionScore = wmEntry ? baseScore : baseScore * turnDecayFactor;\n        tier = tierClassifier.classifyState(attentionScore);\n      }\n\n      // Clamp to [0,1] — retrievability * decay or wmEntry scores\n      // Can drift outside the valid range due to floating-point arithmetic.\n      attentionScore = Math.max(0, Math.min(1, attentionScore));\n\n      return {\n        ...match,\n        attentionScore: attentionScore,\n        tier,\n        coActivated: coActivatedMemories.some(ca => ca.memoryId === match.memoryId)\n      };\n    });\n\n    const tieredResults = tierClassifier.filterAndLimitByState(enrichedResults, null, limit);\n\n    // Resolve tiered content for each result. getTieredContent returns the display\n    // content (truncated for WARM) plus a pre-truncation token count used only for\n    // savings% calculation — the latter is never forwarded to MCP output.\n    const tieredContent = await Promise.all(tieredResults.map(async (r: EnrichedTriggerMatch) =>\n      getTieredContent({ filePath: r.filePath, title: r.title, triggerPhrases: r.matchedPhrases }, r.tier)\n    ));\n\n    formattedResults = tieredResults.map((r: EnrichedTriggerMatch, i: number) => ({\n      memoryId: r.memoryId,\n      specFolder: r.specFolder,\n      filePath: r.filePath,\n      title: r.title,\n      matchedPhrases: r.matchedPhrases,\n      importanceWeight: r.importanceWeight,\n      tier: r.tier,\n      attentionScore: r.attentionScore,\n      content: tieredContent[i].content,\n      coActivated: r.coActivated || false\n    }));\n\n    // Metrics-only view: pairs each result with its pre-truncation token count so\n    // calculateTokenMetrics can compute accurate savings% for WARM entries.\n    const metricsResults = tieredResults.map((r: EnrichedTriggerMatch, i: number) => ({\n      tier: r.tier,\n      content: tieredContent[i].content,\n      fullContentTokens: tieredContent[i].fullContentTokens,\n    }));\n\n    cognitiveStats = {\n      enabled: true,\n      sessionId: sessionId!,\n      turnNumber: turnNumber,\n      decayApplied: decayStats ? decayStats.decayedCount : 0,\n      memoriesActivated: activatedMemories.length,\n      coActivations: coActivatedMemories.length,\n      tierDistribution: tierClassifier.getStateStats(enrichedResults),\n      tokenMetrics: calculateTokenMetrics(results, metricsResults)\n    };\n\n  } else {","lineStart":120,"lineEnd":499,"totalLines":587,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-triggers.ts","time":{"start":1780925328428,"end":1780925328438}},"metadata":{"openai":{"itemId":"fc_0752ecbcaf7741ea016a26c38ff3f88191b83efcf8d48f4835"}},"id":"prt_ea76bebf9001Z6sCZvFvRBcc5p","sessionID":"ses_158954ad3ffeepM4JX05JFyErC","messageID":"msg_ea76bc38f001t8Qxft3dTEc5w7"}}
