{"type":"tool_use","timestamp":1780738243314,"sessionID":"ses_163bcc50affeyxhkrz48ouVc7l","part":{"type":"tool","tool":"read","callID":"call_VcvGGARH3Bc9h3XqFSYAIPjy","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","offset":3100,"limit":700},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts</path>\n<type>file</type>\n<content>\n3100:       metadata: { issues: governanceDecision.issues },\n3101:     });\n3102:     // Surface the governance rejection with its own code + issue list instead of a bare\n3103:     // throw that the dispatcher would report as the generic E081 \"unexpected error\".\n3104:     return createMCPErrorResponse({\n3105:       tool: 'memory_save',\n3106:       error: `Governed ingest rejected: ${governanceDecision.issues.join('; ')}`,\n3107:       code: 'E085',\n3108:       details: { requestId, issues: governanceDecision.issues },\n3109:       recovery: {\n3110:         hint: 'Supply the required governed-ingest provenance/scope fields and retry.',\n3111:         actions: ['Provide the missing tenant/provenance/actor metadata', 'Retry memory_save'],\n3112:         severity: 'warning',\n3113:       },\n3114:     });\n3115:   }\n3116: \n3117:   // Shared dry-run response builder — both the skipPreflight and post-preflight\n3118:   // dry-run branches delegate here to prevent near-duplicate envelope drift.\n3119:   async function buildDryRunResponse(\n3120:     preparedDryRun: PreparedParsedMemory,\n3121:     parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n3122:     preflightValidation: {\n3123:       skipped: boolean;\n3124:       errors: preflight.PreflightIssue[];\n3125:       warnings: preflight.PreflightResult['warnings'];\n3126:       details: Record<string, unknown>;\n3127:       wouldPass: boolean;\n3128:     },\n3129:   ) {\n3130:     const templateContractPass = preparedDryRun.templateContract.valid\n3131:       || shouldBypassTemplateContract(\n3132:         preparedDryRun.sourceClassification,\n3133:         preparedDryRun.sufficiencyResult,\n3134:         preparedDryRun.templateContract,\n3135:         preparedDryRun.specDocHealth,\n3136:         preparedDryRun.parsed.documentType,\n3137:       );\n3138:     const bypassMode = shouldBypassTemplateContract(\n3139:       preparedDryRun.sourceClassification,\n3140:       preparedDryRun.sufficiencyResult,\n3141:       preparedDryRun.templateContract,\n3142:       preparedDryRun.specDocHealth,\n3143:       preparedDryRun.parsed.documentType,\n3144:     );\n3145:     const { createMCPSuccessResponse } = await import('../lib/response/envelope.js');\n3146:     const dryRunSummary = !preflightValidation.wouldPass\n3147:       ? `Pre-flight validation failed: ${preflightValidation.errors.length} error(s)`\n3148:       : bypassMode\n3149:         ? 'Dry-run would pass in manual-fallback mode with deferred indexing.'\n3150:         : buildDryRunSummary(\n3151:             preparedDryRun.sufficiencyResult,\n3152:             preparedDryRun.qualityLoopResult,\n3153:             preparedDryRun.templateContract,\n3154:           );\n3155: \n3156:     const wouldPass = preflightValidation.wouldPass\n3157:       && preparedDryRun.validation.valid\n3158:       && preparedDryRun.qualityLoopResult.rejected !== true\n3159:       && templateContractPass\n3160:       && preparedDryRun.sufficiencyResult.pass;\n3161: \n3162:     const hints: string[] = !preflightValidation.wouldPass\n3163:       ? ['Fix validation errors before saving', 'Use skipPreflight: true to bypass validation']\n3164:       : templateContractPass && preparedDryRun.sufficiencyResult.pass\n3165:         ? [\n3166:             'Dry-run complete - no changes made',\n3167:             ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n3168:             ...(bypassMode\n3169:               ? ['Manual-fallback mode would bypass the strict memory template contract for this save']\n3170:               : []),\n3171:           ]\n3172:         : [\n3173:             'Dry-run complete - no changes made',\n3174:             ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n3175:             ...(!preparedDryRun.templateContract.valid\n3176:               ? ['Rendered content must match the memory template contract before indexing']\n3177:               : []),\n3178:             'Not enough context was available to save a durable memory',\n3179:             ...(!preflightValidation.skipped\n3180:               ? ['Add concrete file, tool, decision, blocker, next action, or outcome evidence and retry']\n3181:               : []),\n3182:           ];\n3183: \n3184:     return createMCPSuccessResponse({\n3185:       tool: 'memory_save',\n3186:       summary: dryRunSummary,\n3187:       data: {\n3188:         status: 'dry_run',\n3189:         would_pass: wouldPass,\n3190:         file_path: validatedPath,\n3191:         spec_folder: parsed.specFolder,\n3192:         title: parsed.title,\n3193:         validation: preflightValidation.skipped\n3194:           ? { skipped: true, errors: [], warnings: [], details: { skipped: true } }\n3195:           : { errors: preflightValidation.errors, warnings: preflightValidation.warnings, details: preflightValidation.details },\n3196:         qualityLoop: {\n3197:           passed: preparedDryRun.qualityLoopResult.passed,\n3198:           rejected: preparedDryRun.qualityLoopResult.rejected,\n3199:           fixes: preparedDryRun.qualityLoopResult.fixes,\n3200:           rejectionReason: preparedDryRun.qualityLoopResult.rejectionReason,\n3201:         },\n3202:         templateContract: preparedDryRun.templateContract,\n3203:         sufficiency: preparedDryRun.sufficiencyResult,\n3204:         specDocHealth: preparedDryRun.specDocHealth,\n3205:         rejectionCode: preparedDryRun.sufficiencyResult.pass ? undefined : MEMORY_SUFFICIENCY_REJECTION_CODE,\n3206:         message: dryRunSummary,\n3207:       },\n3208:       hints,\n3209:     });\n3210:   }\n3211: \n3212:   // DryRun must remain non-mutating even when preflight is explicitly skipped.\n3213:   if (dryRun && skipPreflight) {\n3214:     const parsedForDryRun = memoryParser.parseMemoryFile(validatedPath);\n3215:     const preparedDryRun = prepareParsedMemoryForIndexing(parsedForDryRun, database, {\n3216:       emitEvalMetrics: false,\n3217:       qualityLoopMode: 'advisory',\n3218:     });\n3219:     return buildDryRunResponse(preparedDryRun, parsedForDryRun, {\n3220:       skipped: true, errors: [], warnings: [], details: {}, wouldPass: true,\n3221:     });\n3222:   }\n3223: \n3224:   const saveScope: MemoryScopeMatch = {\n3225:     tenantId: governanceDecision.normalized.tenantId,\n3226:     userId: governanceDecision.normalized.userId ?? null,\n3227:     agentId: governanceDecision.normalized.agentId ?? null,\n3228:     sessionId: governanceDecision.normalized.sessionId,\n3229:   };\n3230: \n3231:   // PRE-FLIGHT VALIDATION\n3232:   let parsedForPreflight: ReturnType<typeof memoryParser.parseMemoryFile> | null = null;\n3233:   if (!skipPreflight) {\n3234:     parsedForPreflight = memoryParser.parseMemoryFile(validatedPath);\n3235: \n3236:     const preflightResult = preflight.runPreflight(\n3237:       {\n3238:         content: parsedForPreflight.content,\n3239:         file_path: validatedPath,\n3240:         spec_folder: parsedForPreflight.specFolder,\n3241:         database: database,\n3242:         find_similar: findSimilarMemories as Parameters<typeof preflight.runPreflight>[0]['find_similar'],\n3243:         tenantId: saveScope.tenantId ?? undefined,\n3244:         userId: saveScope.userId ?? undefined,\n3245:         agentId: saveScope.agentId ?? undefined,\n3246:       },\n3247:       {\n3248:         dry_run: dryRun,\n3249:         check_anchors: true,\n3250:         check_duplicates: !force,\n3251:         check_similar: false,\n3252:         check_tokens: true,\n3253:         check_size: true,\n3254:         strict_anchors: false,\n3255:       }\n3256:     );\n3257: \n3258:     if (dryRun) {\n3259:       let preparedDryRun: PreparedParsedMemory;\n3260:       try {\n3261:         preparedDryRun = prepareParsedMemoryForIndexing(parsedForPreflight, database, {\n3262:           emitEvalMetrics: false,\n3263:           qualityLoopMode: 'advisory',\n3264:         });\n3265:       } catch (error: unknown) {\n3266:         if (error instanceof VRuleUnavailableError) {\n3267:           return createMCPErrorResponse({\n3268:             tool: 'memory_save',\n3269:             error: error.message,\n3270:             code: 'E_RUNTIME',\n3271:             details: { requestId },\n3272:             recovery: {\n3273:               hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3274:               actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3275:               severity: 'warning',\n3276:             },\n3277:           });\n3278:         }\n3279:         // Classify dry-run preparation failures so even validation-only runs surface the\n3280:         // specific cause instead of the generic E081 catch-all at the dispatcher.\n3281:         const dryRunErrorMessage = error instanceof Error ? error.message : String(error);\n3282:         return createMCPErrorResponse({\n3283:           tool: 'memory_save',\n3284:           error: dryRunErrorMessage,\n3285:           code: classifySaveErrorCode(dryRunErrorMessage),\n3286:           details: { requestId, ...extractSaveErrorDetails(dryRunErrorMessage) },\n3287:           recovery: {\n3288:             hint: 'Inspect the error message for the specific dry-run preparation failure.',\n3289:             actions: ['Resolve the reported cause', 'Retry memory_save'],\n3290:             severity: 'warning',\n3291:           },\n3292:         });\n3293:       }\n3294:       return buildDryRunResponse(preparedDryRun, parsedForPreflight, {\n3295:         skipped: false,\n3296:         errors: preflightResult.errors,\n3297:         warnings: preflightResult.warnings,\n3298:         details: preflightResult.details,\n3299:         wouldPass: preflightResult.dry_run_would_pass ?? preflightResult.pass,\n3300:       });\n3301:     }\n3302: \n3303:     if (!preflightResult.pass) {\n3304:       if (shouldPlanCanonicalSave) {\n3305:         return buildPlannerResponse({\n3306:           planner: {\n3307:             filePath: validatedPath,\n3308:             specFolder: parsedForPreflight.specFolder,\n3309:             title: parsedForPreflight.title ?? path.basename(validatedPath),\n3310:             status: 'blocked',\n3311:             message: 'Planner found blocker(s) during pre-flight validation.',\n3312:             plannerMode: 'plan-only',\n3313:             routeTarget: serializePlannerRouteTarget({\n3314:               routeCategory: routeAs ?? 'drop',\n3315:               targetDocPath: validatedPath,\n3316:               targetAnchorId: targetAnchorId ?? null,\n3317:               mergeMode: mergeModeHint,\n3318:             }),\n3319:             proposedEdits: [],\n3320:             blockers: preflightResult.errors.map((entry: string | { message: string; code?: string }) =>\n3321:               serializePlannerBlocker(buildPlannerBlocker({\n3322:                 code: typeof entry === 'string' ? 'PREFLIGHT_BLOCKER' : (entry.code ?? 'PREFLIGHT_BLOCKER'),\n3323:                 message: typeof entry === 'string' ? entry : entry.message,\n3324:                 routeCategory: routeAs ?? undefined,\n3325:                 targetDocPath: validatedPath,\n3326:                 targetAnchorId: targetAnchorId ?? null,\n3327:               }))\n3328:             ),\n3329:             advisories: preflightResult.warnings.map((entry: string | { message: string }) =>\n3330:               serializePlannerAdvisory(buildPlannerAdvisory({\n3331:                 code: 'PREFLIGHT_WARNING',\n3332:                 message: typeof entry === 'string' ? entry : entry.message,\n3333:                 routeCategory: routeAs ?? undefined,\n3334:                 targetDocPath: validatedPath,\n3335:                 targetAnchorId: targetAnchorId ?? null,\n3336:               }))\n3337:             ),\n3338:             followUpActions: [\n3339:               serializePlannerFollowUpAction({\n3340:                 action: 'apply',\n3341:                 title: 'Retry with full-auto after fixing pre-flight blockers',\n3342:                 description: 'Fix the reported blockers, then request explicit full-auto mode.',\n3343:                 args: {\n3344:                   filePath: validatedPath,\n3345:                   plannerMode: 'full-auto',\n3346:                   ...(routeAs ? { routeAs } : {}),\n3347:                   ...(mergeModeHint ? { mergeModeHint } : {}),\n3348:                   ...(targetAnchorId ? { targetAnchorId } : {}),\n3349:                 },\n3350:               }),\n3351:             ],\n3352:           },\n3353:         });\n3354:       }\n3355: \n3356:       const errorMessages = preflightResult.errors.map((e: string | { message: string }) =>\n3357:         typeof e === 'string' ? e : e.message\n3358:       ).join('; ');\n3359: \n3360:       // Use the actual error code from the\n3361:       // First validation error instead of hardcoding ANCHOR_FORMAT_INVALID.\n3362:       const firstError = preflightResult.errors[0];\n3363:       const errorCode = (typeof firstError === 'object' && firstError?.code)\n3364:         ? firstError.code\n3365:         : preflight.PreflightErrorCodes.ANCHOR_FORMAT_INVALID;\n3366:       throw new preflight.PreflightError(\n3367:         errorCode,\n3368:         `Pre-flight validation failed: ${errorMessages}`,\n3369:         {\n3370:           errors: preflightResult.errors,\n3371:           warnings: preflightResult.warnings,\n3372:           recoverable: true,\n3373:           suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n3374:         }\n3375:       );\n3376:     }\n3377: \n3378:     if (preflightResult.warnings.length > 0) {\n3379:       console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n3380:       preflightResult.warnings.forEach((w: string | { message: string }) => {\n3381:         const msg = typeof w === 'string' ? w : w.message;\n3382:         console.warn(`[preflight]   - ${msg}`);\n3383:       });\n3384:     }\n3385:   }\n3386: \n3387:   if (shouldPlanCanonicalSave) {\n3388:     const plannerResult = await atomicSaveMemory({\n3389:       file_path: validatedPath,\n3390:       content: fs.readFileSync(validatedPath, 'utf8'),\n3391:       plannerMode,\n3392:       ...(routeAs ? { routeAs } : {}),\n3393:       ...(mergeModeHint ? { mergeModeHint } : {}),\n3394:       ...(targetAnchorId ? { targetAnchorId } : {}),\n3395:     }, { force });\n3396: \n3397:     return buildPlannerResponse({\n3398:       planner: {\n3399:         filePath: validatedPath,\n3400:         specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n3401:         title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n3402:         status: plannerResult.status === 'blocked' ? 'blocked' : 'planned',\n3403:         message: plannerResult.message ?? 'Planner prepared a non-mutating canonical save plan.',\n3404:         plannerMode: 'plan-only',\n3405:         routeTarget: plannerResult.routeTarget ?? serializePlannerRouteTarget({\n3406:           routeCategory: routeAs ?? 'drop',\n3407:           targetDocPath: plannerResult.targetDocPath ?? validatedPath,\n3408:           targetAnchorId: plannerResult.targetAnchorId ?? targetAnchorId ?? null,\n3409:           mergeMode: plannerResult.mergeMode ?? mergeModeHint,\n3410:         }),\n3411:         proposedEdits: plannerResult.proposedEdits ?? [],\n3412:         blockers: plannerResult.blockers ?? [],\n3413:         advisories: plannerResult.advisories ?? [],\n3414:         followUpActions: plannerResult.followUpActions ?? [],\n3415:       },\n3416:     });\n3417:   }\n3418: \n3419:   let result: IndexResult;\n3420:   try {\n3421:     result = await indexMemoryFile(validatedPath, {\n3422:       force,\n3423:       parsedOverride: parsedForPreflight,\n3424:       asyncEmbedding,\n3425:       plannerMode,\n3426:       scope: saveScope,\n3427:       routing: buildRoutedSaveOptions(validatedPath, routeAs, mergeModeHint, targetAnchorId),\n3428:     });\n3429:   } catch (error: unknown) {\n3430:     if (error instanceof VRuleUnavailableError) {\n3431:       return createMCPErrorResponse({\n3432:         tool: 'memory_save',\n3433:         error: error.message,\n3434:         code: 'E_RUNTIME',\n3435:         details: { requestId },\n3436:         recovery: {\n3437:           hint: 'Build the Spec Kit scripts workspace and retry the save.',\n3438:           actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n3439:           severity: 'warning',\n3440:         },\n3441:       });\n3442:     }\n3443:     // Classify deep save/index failures (sqlite busy, embedding, db error, etc.) so the\n3444:     // response code points at the actual failure mode instead of the generic E081 catch-all.\n3445:     const indexErrorMessage = error instanceof Error ? error.message : String(error);\n3446:     return createMCPErrorResponse({\n3447:       tool: 'memory_save',\n3448:       error: indexErrorMessage,\n3449:       code: classifySaveErrorCode(indexErrorMessage),\n3450:       details: { requestId, ...extractSaveErrorDetails(indexErrorMessage) },\n3451:       recovery: {\n3452:         hint: 'Inspect the error message for the specific failure; transient DB/embedding issues are usually retryable.',\n3453:         actions: ['Resolve the reported cause', 'Retry memory_save'],\n3454:         severity: 'warning',\n3455:       },\n3456:     });\n3457:   }\n3458: \n3459:   if (typeof result.id === 'number' && result.id > 0 && result.status !== 'unchanged' && result.status !== 'duplicate') {\n3460:     // B13 + H5 FIX: Wrap governance metadata in a transaction with rollback on failure.\n3461:     // If governance application fails, delete the orphaned memory row to prevent\n3462:     // persisted rows without tenant/session/retention metadata.\n3463:     const applyGovernanceTx = database.transaction(() => {\n3464:       applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n3465:       recordGovernanceAudit(database, {\n3466:         action: 'memory_save',\n3467:         decision: 'allow',\n3468:         memoryId: result.id,\n3469:         tenantId,\n3470:         userId,\n3471:         agentId,\n3472:         sessionId,\n3473:         reason: 'governed_ingest',\n3474:         metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n3475:       });\n3476:     });\n3477:     try {\n3478:       applyGovernanceTx();\n3479:     } catch (govErr: unknown) {\n3480:       // C2 FIX: Use full delete helper to clean up ALL ancillary records\n3481:       // (vec_memories, BM25 index, causal edges, projections, etc.)\n3482:       // not just memory_index, to prevent orphaned search phantoms.\n3483:       const govErrorMessage = govErr instanceof Error ? govErr.message : String(govErr);\n3484:       console.error('[memory-save] Governance metadata failed, removing orphaned memory:', govErrorMessage);\n3485:       try { delete_memory_from_database(database, result.id); } catch (_: unknown) { /* best-effort cleanup */ }\n3486:       // The orphan rollback above already ran; return a classified error (sqlite-busy / db\n3487:       // failures map to E087/E088) instead of a bare throw the dispatcher would surface as the\n3488:       // generic E081 catch-all.\n3489:       return createMCPErrorResponse({\n3490:         tool: 'memory_save',\n3491:         error: govErrorMessage,\n3492:         code: classifySaveErrorCode(govErrorMessage),\n3493:         details: { requestId, ...extractSaveErrorDetails(govErrorMessage) },\n3494:         recovery: {\n3495:           hint: 'The memory was rolled back after a post-insert metadata write failed; transient DB locks are retryable.',\n3496:           actions: ['Resolve the reported cause', 'Retry memory_save'],\n3497:           severity: 'warning',\n3498:         },\n3499:       });\n3500:     }\n3501:   }\n3502: \n3503:   return buildSaveResponse({ result, filePath: file_path, asyncEmbedding, requestId });\n3504: }\n3505: \n3506: /* --- 10. ATOMIC MEMORY SAVE --- */\n3507: \n3508: /**\n3509:  * Save memory content to disk with retry + rollback guarded indexing.\n3510:  *\n3511:  * The file write promotes a pending file while holding the per-spec-folder\n3512:  * mutex so concurrent saves cannot overwrite each other between disk\n3513:  * promotion and indexing. If indexing later fails, the original file content\n3514:  * is restored before the error is returned and before the lock is released.\n3515:  */\n3516: async function atomicSaveMemory(params: AtomicSaveParams, options: AtomicSaveOptions = {}): Promise<AtomicSaveResult> {\n3517:   const { file_path, routeAs, mergeModeHint, targetAnchorId } = params;\n3518:   const database = requireDb();\n3519:   const routing = buildRoutedSaveOptions(file_path, routeAs, mergeModeHint, targetAnchorId);\n3520:   const plannerMode = params.plannerMode ?? resolveSavePlannerMode();\n3521: \n3522:   if (shouldUseCanonicalRouting(params) && plannerMode !== 'full-auto') {\n3523:     const canonicalPrepared = await buildCanonicalAtomicPreparedSave(params, database);\n3524:     if (canonicalPrepared.status !== 'ready') {\n3525:       return buildAtomicPlannerAbortResult(params, canonicalPrepared.result);\n3526:     }\n3527: \n3528:     return buildAtomicPlannerReadyResult(\n3529:       params,\n3530:       canonicalPrepared.prepared,\n3531:       validateCanonicalPreparedSave(canonicalPrepared.prepared),\n3532:       options,\n3533:     );\n3534:   }\n3535: \n3536:   return atomicIndexMemory<PreparedParsedMemory | CanonicalAtomicPrepared>(params, options, {\n3537:     prepare: async (currentParams, _context) => {\n3538:       if (shouldUseCanonicalRouting(currentParams)) {\n3539:         const canonicalPrepared = await buildCanonicalAtomicPreparedSave(currentParams, database);\n3540:         if (canonicalPrepared.status !== 'ready') {\n3541:           return canonicalPrepared;\n3542:         }\n3543: \n3544:         return {\n3545:           status: 'ready',\n3546:           prepared: canonicalPrepared.prepared,\n3547:           specFolder: canonicalPrepared.prepared.preparedMemory.parsed.specFolder,\n3548:           persistedContent: canonicalPrepared.persistedContent,\n3549:           persistedFilePath: canonicalPrepared.persistedFilePath,\n3550:         } as const;\n3551:       }\n3552: \n3553:       const { file_path: currentFilePath, content: currentContent } = currentParams;\n3554:       const prepared = prepareParsedMemoryForIndexing(\n3555:         memoryParser.parseMemoryContent(currentFilePath, currentContent),\n3556:         database,\n3557:         {\n3558:           qualityLoopMode: currentParams.plannerMode === 'full-auto' ? 'full-auto' : 'advisory',\n3559:         },\n3560:       );\n3561: \n3562:       if (!prepared.validation.valid) {\n3563:         return {\n3564:           status: 'abort',\n3565:           result: {\n3566:             success: false,\n3567:             filePath: currentFilePath,\n3568:             status: 'error',\n3569:             summary: 'Atomic save preflight failed',\n3570:             message: 'Parsed content failed validation before atomic save',\n3571:             error: `Validation failed: ${prepared.validation.errors.join(', ')}`,\n3572:           },\n3573:         } as const;\n3574:       }\n3575: \n3576:       if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n3577:         console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(currentFilePath)} before pending-file promotion`);\n3578:       }\n3579: \n3580:       return {\n3581:         status: 'ready',\n3582:         prepared,\n3583:         specFolder: prepared.parsed.specFolder,\n3584:         persistedContent: prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent\n3585:           ? prepared.qualityLoopResult.fixedContent\n3586:           : currentContent,\n3587:       } as const;\n3588:     },\n3589:     prepareLocked: async ({ ready, params: currentParams }) => {\n3590:       if (!isCanonicalAtomicPrepared(ready.prepared)) {\n3591:         return ready;\n3592:       }\n3593: \n3594:       // Rebuild the canonical merge while the spec-folder lock is held so\n3595:       // concurrent routed saves always merge against the latest on-disk doc.\n3596:       const canonicalPrepared = await buildCanonicalAtomicPreparedSave(currentParams, database);\n3597:       if (canonicalPrepared.status !== 'ready') {\n3598:         return canonicalPrepared;\n3599:       }\n3600: \n3601:       return {\n3602:         status: 'ready',\n3603:         prepared: canonicalPrepared.prepared,\n3604:         specFolder: canonicalPrepared.prepared.preparedMemory.parsed.specFolder,\n3605:         persistedContent: canonicalPrepared.persistedContent,\n3606:         persistedFilePath: canonicalPrepared.persistedFilePath,\n3607:       } as const;\n3608:     },\n3609:     indexPrepared: ({ ready, params: currentParams, force }) => {\n3610:       const effectiveFilePath = ready.persistedFilePath ?? currentParams.file_path;\n3611:       const routedPrepared = isCanonicalAtomicPrepared(ready.prepared)\n3612:         ? ready.prepared\n3613:         : null;\n3614: \n3615:       if (routedPrepared) {\n3616:         const validationResult = validateCanonicalPreparedSave(routedPrepared);\n3617:         if (!validationResult.ok) {\n3618:           return validationResult.rejection;\n3619:         }\n3620: \n3621:         return processPreparedMemory(routedPrepared.preparedMemory, effectiveFilePath, {\n3622:           force,\n3623:           asyncEmbedding: true,\n3624:           plannerMode: currentParams.plannerMode,\n3625:           persistQualityLoopContent: false,\n3626:           specFolderLockAlreadyHeld: true,\n3627:           qualityGateMode: 'warn-only',\n3628:           routing: routedPrepared.routing,\n3629:         }).then((result) => {\n3630:           for (const warning of validationResult.warnings) {\n3631:             appendResultWarning(result, warning);\n3632:           }\n3633:           return result;\n3634:         });\n3635:       }\n3636: \n3637:       return processPreparedMemory(ready.prepared as PreparedParsedMemory, currentParams.file_path, {\n3638:         force,\n3639:         asyncEmbedding: true,\n3640:         plannerMode: currentParams.plannerMode,\n3641:         persistQualityLoopContent: false,\n3642:         specFolderLockAlreadyHeld: true,\n3643:         routing: buildRoutedSaveOptions(currentParams.file_path, currentParams.routeAs, currentParams.mergeModeHint, currentParams.targetAnchorId),\n3644:       });\n3645:     },\n3646:     getPendingPath: (currentFilePath) => `${transactionManager.getPendingPath(currentFilePath)}.${randomUUID().slice(0, 8)}`,\n3647:     withSpecFolderLock,\n3648:     captureOriginalState: captureAtomicSaveOriginalState,\n3649:     restoreOriginalState: restoreAtomicSaveOriginalState,\n3650:     cleanupPendingFile: cleanupAtomicSavePendingFile,\n3651:     writePendingFile: (pendingPath, persistedContent) => {\n3652:       fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n3653:       fs.writeFileSync(pendingPath, persistedContent, 'utf-8');\n3654:     },\n3655:     promotePendingFile: (pendingPath, currentFilePath) => {\n3656:       fs.mkdirSync(path.dirname(currentFilePath), { recursive: true });\n3657:       fs.renameSync(pendingPath, currentFilePath);\n3658:     },\n3659:     mapSuccessResult: (indexResult, context) => {\n3660:       const effectiveFilePath = context.ready.persistedFilePath ?? file_path;\n3661:       const routedRouteCategory = indexResult.routeCategory ?? routing?.routeAs;\n3662:       const routedMergeMode = indexResult.mergeMode ?? routing?.mergeModeHint;\n3663:       const routedTargetDocPath = indexResult.targetDocPath ?? effectiveFilePath;\n3664: \n3665:       if (indexResult.status !== 'unchanged' && indexResult.status !== 'duplicate' && indexResult.id > 0) {\n3666:         applyPostInsertMetadata(database, indexResult.id, {});\n3667:       }\n3668: \n3669:       const shouldEmitPostMutationFeedback = indexResult.status !== 'duplicate' && indexResult.status !== 'unchanged';\n3670:       let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n3671:       if (shouldEmitPostMutationFeedback) {\n3672:         let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n3673:         try {\n3674:           postMutationHooks = runPostMutationHooks('atomic-save', {\n3675:             filePath: routedTargetDocPath,\n3676:             specFolder: indexResult.specFolder,\n3677:             memoryId: indexResult.id,\n3678:           });\n3679:         } catch (hookError: unknown) {\n3680:           const msg = hookError instanceof Error ? hookError.message : String(hookError);\n3681:           postMutationHooks = {\n3682:             latencyMs: 0, triggerCacheCleared: false,\n3683:             constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n3684:             graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n3685:             errors: [msg],\n3686:           };\n3687:         }\n3688:         postMutationFeedback = buildMutationHookFeedback('atomic-save', postMutationHooks);\n3689:       }\n3690: \n3691:       const message = indexResult.message ?? (\n3692:         indexResult.status === 'duplicate'\n3693:           ? 'Memory skipped (duplicate content)'\n3694:           : `Memory ${indexResult.status} successfully`\n3695:       );\n3696:       const hints: string[] = [];\n3697: \n3698:       if (indexResult.embeddingStatus === 'pending') {\n3699:         hints.push('Memory will be fully indexed when embedding provider becomes available');\n3700:       }\n3701:       if (indexResult.embeddingStatus === 'partial') {\n3702:         hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n3703:       }\n3704:       if (postMutationFeedback) {\n3705:         hints.push(...postMutationFeedback.hints);\n3706:       } else if (indexResult.status === 'duplicate') {\n3707:         hints.push('Duplicate content matched an existing indexed memory, so caches were left unchanged');\n3708:       }\n3709: \n3710:       return {\n3711:         success: true,\n3712:         filePath: routedTargetDocPath,\n3713:         status: indexResult.status,\n3714:         id: indexResult.id,\n3715:         specFolder: indexResult.specFolder,\n3716:         title: indexResult.title,\n3717:         summary: message,\n3718:         message,\n3719:         embeddingStatus: indexResult.embeddingStatus,\n3720:         ...(routedRouteCategory ? { routeCategory: routedRouteCategory } : {}),\n3721:         ...(routedMergeMode ? { mergeMode: routedMergeMode } : {}),\n3722:         ...(routedTargetDocPath ? { targetDocPath: routedTargetDocPath } : {}),\n3723:         ...(indexResult.targetAnchorId ? { targetAnchorId: indexResult.targetAnchorId } : {}),\n3724:         ...(postMutationFeedback ? { postMutationHooks: postMutationFeedback.data } : {}),\n3725:         ...(hints.length > 0 ? { hints } : {}),\n3726:       };\n3727:     },\n3728:   });\n3729: }\n3730: \n3731: /** Return transaction manager metrics for atomicity monitoring */\n3732: function getAtomicityMetrics(): Record<string, unknown> {\n3733:   return transactionManager.getMetrics();\n3734: }\n3735: \n3736: /* --- 12. EXPORTS --- */\n3737: \n3738: export {\n3739:   // Primary exports (defined in this module)\n3740:   indexMemoryFile,\n3741:   indexMemoryFileFromScan,\n3742:   indexChunkedMemoryFile,\n3743:   handleMemorySave,\n3744:   atomicSaveMemory,\n3745:   getAtomicityMetrics,\n3746: };\n3747: \n3748: // Backward-compatible aliases (snake_case) — only for symbols defined in this module\n3749: const index_memory_file = indexMemoryFile;\n3750: const index_memory_file_from_scan = indexMemoryFileFromScan;\n3751: const index_chunked_memory_file = indexChunkedMemoryFile;\n3752: const handle_memory_save = handleMemorySave;\n3753: const atomic_save_memory = atomicSaveMemory;\n3754: const get_atomicity_metrics = getAtomicityMetrics;\n3755: \n3756: export {\n3757:   index_memory_file,\n3758:   index_memory_file_from_scan,\n3759:   index_chunked_memory_file,\n3760:   handle_memory_save,\n3761:   atomic_save_memory,\n3762:   get_atomicity_metrics,\n3763: };\n\n(End of file - total 3763 lines)\n</content>","metadata":{"preview":"      metadata: { issues: governanceDecision.issues },\n    });\n    // Surface the governance rejection with its own code + issue list instead of a bare\n    // throw that the dispatcher would report as the generic E081 \"unexpected error\".\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: `Governed ingest rejected: ${governanceDecision.issues.join('; ')}`,\n      code: 'E085',\n      details: { requestId, issues: governanceDecision.issues },\n      recovery: {\n        hint: 'Supply the required governed-ingest provenance/scope fields and retry.',\n        actions: ['Provide the missing tenant/provenance/actor metadata', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  // Shared dry-run response builder — both the skipPreflight and post-preflight\n  // dry-run branches delegate here to prevent near-duplicate envelope drift.\n  async function buildDryRunResponse(","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","text":"      metadata: { issues: governanceDecision.issues },\n    });\n    // Surface the governance rejection with its own code + issue list instead of a bare\n    // throw that the dispatcher would report as the generic E081 \"unexpected error\".\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: `Governed ingest rejected: ${governanceDecision.issues.join('; ')}`,\n      code: 'E085',\n      details: { requestId, issues: governanceDecision.issues },\n      recovery: {\n        hint: 'Supply the required governed-ingest provenance/scope fields and retry.',\n        actions: ['Provide the missing tenant/provenance/actor metadata', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  // Shared dry-run response builder — both the skipPreflight and post-preflight\n  // dry-run branches delegate here to prevent near-duplicate envelope drift.\n  async function buildDryRunResponse(\n    preparedDryRun: PreparedParsedMemory,\n    parsed: ReturnType<typeof memoryParser.parseMemoryFile>,\n    preflightValidation: {\n      skipped: boolean;\n      errors: preflight.PreflightIssue[];\n      warnings: preflight.PreflightResult['warnings'];\n      details: Record<string, unknown>;\n      wouldPass: boolean;\n    },\n  ) {\n    const templateContractPass = preparedDryRun.templateContract.valid\n      || shouldBypassTemplateContract(\n        preparedDryRun.sourceClassification,\n        preparedDryRun.sufficiencyResult,\n        preparedDryRun.templateContract,\n        preparedDryRun.specDocHealth,\n        preparedDryRun.parsed.documentType,\n      );\n    const bypassMode = shouldBypassTemplateContract(\n      preparedDryRun.sourceClassification,\n      preparedDryRun.sufficiencyResult,\n      preparedDryRun.templateContract,\n      preparedDryRun.specDocHealth,\n      preparedDryRun.parsed.documentType,\n    );\n    const { createMCPSuccessResponse } = await import('../lib/response/envelope.js');\n    const dryRunSummary = !preflightValidation.wouldPass\n      ? `Pre-flight validation failed: ${preflightValidation.errors.length} error(s)`\n      : bypassMode\n        ? 'Dry-run would pass in manual-fallback mode with deferred indexing.'\n        : buildDryRunSummary(\n            preparedDryRun.sufficiencyResult,\n            preparedDryRun.qualityLoopResult,\n            preparedDryRun.templateContract,\n          );\n\n    const wouldPass = preflightValidation.wouldPass\n      && preparedDryRun.validation.valid\n      && preparedDryRun.qualityLoopResult.rejected !== true\n      && templateContractPass\n      && preparedDryRun.sufficiencyResult.pass;\n\n    const hints: string[] = !preflightValidation.wouldPass\n      ? ['Fix validation errors before saving', 'Use skipPreflight: true to bypass validation']\n      : templateContractPass && preparedDryRun.sufficiencyResult.pass\n        ? [\n            'Dry-run complete - no changes made',\n            ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n            ...(bypassMode\n              ? ['Manual-fallback mode would bypass the strict memory template contract for this save']\n              : []),\n          ]\n        : [\n            'Dry-run complete - no changes made',\n            ...(preflightValidation.skipped ? ['Pre-flight checks were skipped because skipPreflight=true'] : []),\n            ...(!preparedDryRun.templateContract.valid\n              ? ['Rendered content must match the memory template contract before indexing']\n              : []),\n            'Not enough context was available to save a durable memory',\n            ...(!preflightValidation.skipped\n              ? ['Add concrete file, tool, decision, blocker, next action, or outcome evidence and retry']\n              : []),\n          ];\n\n    return createMCPSuccessResponse({\n      tool: 'memory_save',\n      summary: dryRunSummary,\n      data: {\n        status: 'dry_run',\n        would_pass: wouldPass,\n        file_path: validatedPath,\n        spec_folder: parsed.specFolder,\n        title: parsed.title,\n        validation: preflightValidation.skipped\n          ? { skipped: true, errors: [], warnings: [], details: { skipped: true } }\n          : { errors: preflightValidation.errors, warnings: preflightValidation.warnings, details: preflightValidation.details },\n        qualityLoop: {\n          passed: preparedDryRun.qualityLoopResult.passed,\n          rejected: preparedDryRun.qualityLoopResult.rejected,\n          fixes: preparedDryRun.qualityLoopResult.fixes,\n          rejectionReason: preparedDryRun.qualityLoopResult.rejectionReason,\n        },\n        templateContract: preparedDryRun.templateContract,\n        sufficiency: preparedDryRun.sufficiencyResult,\n        specDocHealth: preparedDryRun.specDocHealth,\n        rejectionCode: preparedDryRun.sufficiencyResult.pass ? undefined : MEMORY_SUFFICIENCY_REJECTION_CODE,\n        message: dryRunSummary,\n      },\n      hints,\n    });\n  }\n\n  // DryRun must remain non-mutating even when preflight is explicitly skipped.\n  if (dryRun && skipPreflight) {\n    const parsedForDryRun = memoryParser.parseMemoryFile(validatedPath);\n    const preparedDryRun = prepareParsedMemoryForIndexing(parsedForDryRun, database, {\n      emitEvalMetrics: false,\n      qualityLoopMode: 'advisory',\n    });\n    return buildDryRunResponse(preparedDryRun, parsedForDryRun, {\n      skipped: true, errors: [], warnings: [], details: {}, wouldPass: true,\n    });\n  }\n\n  const saveScope: MemoryScopeMatch = {\n    tenantId: governanceDecision.normalized.tenantId,\n    userId: governanceDecision.normalized.userId ?? null,\n    agentId: governanceDecision.normalized.agentId ?? null,\n    sessionId: governanceDecision.normalized.sessionId,\n  };\n\n  // PRE-FLIGHT VALIDATION\n  let parsedForPreflight: ReturnType<typeof memoryParser.parseMemoryFile> | null = null;\n  if (!skipPreflight) {\n    parsedForPreflight = memoryParser.parseMemoryFile(validatedPath);\n\n    const preflightResult = preflight.runPreflight(\n      {\n        content: parsedForPreflight.content,\n        file_path: validatedPath,\n        spec_folder: parsedForPreflight.specFolder,\n        database: database,\n        find_similar: findSimilarMemories as Parameters<typeof preflight.runPreflight>[0]['find_similar'],\n        tenantId: saveScope.tenantId ?? undefined,\n        userId: saveScope.userId ?? undefined,\n        agentId: saveScope.agentId ?? undefined,\n      },\n      {\n        dry_run: dryRun,\n        check_anchors: true,\n        check_duplicates: !force,\n        check_similar: false,\n        check_tokens: true,\n        check_size: true,\n        strict_anchors: false,\n      }\n    );\n\n    if (dryRun) {\n      let preparedDryRun: PreparedParsedMemory;\n      try {\n        preparedDryRun = prepareParsedMemoryForIndexing(parsedForPreflight, database, {\n          emitEvalMetrics: false,\n          qualityLoopMode: 'advisory',\n        });\n      } catch (error: unknown) {\n        if (error instanceof VRuleUnavailableError) {\n          return createMCPErrorResponse({\n            tool: 'memory_save',\n            error: error.message,\n            code: 'E_RUNTIME',\n            details: { requestId },\n            recovery: {\n              hint: 'Build the Spec Kit scripts workspace and retry the save.',\n              actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n              severity: 'warning',\n            },\n          });\n        }\n        // Classify dry-run preparation failures so even validation-only runs surface the\n        // specific cause instead of the generic E081 catch-all at the dispatcher.\n        const dryRunErrorMessage = error instanceof Error ? error.message : String(error);\n        return createMCPErrorResponse({\n          tool: 'memory_save',\n          error: dryRunErrorMessage,\n          code: classifySaveErrorCode(dryRunErrorMessage),\n          details: { requestId, ...extractSaveErrorDetails(dryRunErrorMessage) },\n          recovery: {\n            hint: 'Inspect the error message for the specific dry-run preparation failure.',\n            actions: ['Resolve the reported cause', 'Retry memory_save'],\n            severity: 'warning',\n          },\n        });\n      }\n      return buildDryRunResponse(preparedDryRun, parsedForPreflight, {\n        skipped: false,\n        errors: preflightResult.errors,\n        warnings: preflightResult.warnings,\n        details: preflightResult.details,\n        wouldPass: preflightResult.dry_run_would_pass ?? preflightResult.pass,\n      });\n    }\n\n    if (!preflightResult.pass) {\n      if (shouldPlanCanonicalSave) {\n        return buildPlannerResponse({\n          planner: {\n            filePath: validatedPath,\n            specFolder: parsedForPreflight.specFolder,\n            title: parsedForPreflight.title ?? path.basename(validatedPath),\n            status: 'blocked',\n            message: 'Planner found blocker(s) during pre-flight validation.',\n            plannerMode: 'plan-only',\n            routeTarget: serializePlannerRouteTarget({\n              routeCategory: routeAs ?? 'drop',\n              targetDocPath: validatedPath,\n              targetAnchorId: targetAnchorId ?? null,\n              mergeMode: mergeModeHint,\n            }),\n            proposedEdits: [],\n            blockers: preflightResult.errors.map((entry: string | { message: string; code?: string }) =>\n              serializePlannerBlocker(buildPlannerBlocker({\n                code: typeof entry === 'string' ? 'PREFLIGHT_BLOCKER' : (entry.code ?? 'PREFLIGHT_BLOCKER'),\n                message: typeof entry === 'string' ? entry : entry.message,\n                routeCategory: routeAs ?? undefined,\n                targetDocPath: validatedPath,\n                targetAnchorId: targetAnchorId ?? null,\n              }))\n            ),\n            advisories: preflightResult.warnings.map((entry: string | { message: string }) =>\n              serializePlannerAdvisory(buildPlannerAdvisory({\n                code: 'PREFLIGHT_WARNING',\n                message: typeof entry === 'string' ? entry : entry.message,\n                routeCategory: routeAs ?? undefined,\n                targetDocPath: validatedPath,\n                targetAnchorId: targetAnchorId ?? null,\n              }))\n            ),\n            followUpActions: [\n              serializePlannerFollowUpAction({\n                action: 'apply',\n                title: 'Retry with full-auto after fixing pre-flight blockers',\n                description: 'Fix the reported blockers, then request explicit full-auto mode.',\n                args: {\n                  filePath: validatedPath,\n                  plannerMode: 'full-auto',\n                  ...(routeAs ? { routeAs } : {}),\n                  ...(mergeModeHint ? { mergeModeHint } : {}),\n                  ...(targetAnchorId ? { targetAnchorId } : {}),\n                },\n              }),\n            ],\n          },\n        });\n      }\n\n      const errorMessages = preflightResult.errors.map((e: string | { message: string }) =>\n        typeof e === 'string' ? e : e.message\n      ).join('; ');\n\n      // Use the actual error code from the\n      // First validation error instead of hardcoding ANCHOR_FORMAT_INVALID.\n      const firstError = preflightResult.errors[0];\n      const errorCode = (typeof firstError === 'object' && firstError?.code)\n        ? firstError.code\n        : preflight.PreflightErrorCodes.ANCHOR_FORMAT_INVALID;\n      throw new preflight.PreflightError(\n        errorCode,\n        `Pre-flight validation failed: ${errorMessages}`,\n        {\n          errors: preflightResult.errors,\n          warnings: preflightResult.warnings,\n          recoverable: true,\n          suggestion: 'Fix the validation errors and retry, or use skipPreflight=true to bypass',\n        }\n      );\n    }\n\n    if (preflightResult.warnings.length > 0) {\n      console.warn(`[preflight] ${validatedPath}: ${preflightResult.warnings.length} warning(s)`);\n      preflightResult.warnings.forEach((w: string | { message: string }) => {\n        const msg = typeof w === 'string' ? w : w.message;\n        console.warn(`[preflight]   - ${msg}`);\n      });\n    }\n  }\n\n  if (shouldPlanCanonicalSave) {\n    const plannerResult = await atomicSaveMemory({\n      file_path: validatedPath,\n      content: fs.readFileSync(validatedPath, 'utf8'),\n      plannerMode,\n      ...(routeAs ? { routeAs } : {}),\n      ...(mergeModeHint ? { mergeModeHint } : {}),\n      ...(targetAnchorId ? { targetAnchorId } : {}),\n    }, { force });\n\n    return buildPlannerResponse({\n      planner: {\n        filePath: validatedPath,\n        specFolder: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).specFolder,\n        title: (parsedForPreflight ?? memoryParser.parseMemoryFile(validatedPath)).title ?? path.basename(validatedPath),\n        status: plannerResult.status === 'blocked' ? 'blocked' : 'planned',\n        message: plannerResult.message ?? 'Planner prepared a non-mutating canonical save plan.',\n        plannerMode: 'plan-only',\n        routeTarget: plannerResult.routeTarget ?? serializePlannerRouteTarget({\n          routeCategory: routeAs ?? 'drop',\n          targetDocPath: plannerResult.targetDocPath ?? validatedPath,\n          targetAnchorId: plannerResult.targetAnchorId ?? targetAnchorId ?? null,\n          mergeMode: plannerResult.mergeMode ?? mergeModeHint,\n        }),\n        proposedEdits: plannerResult.proposedEdits ?? [],\n        blockers: plannerResult.blockers ?? [],\n        advisories: plannerResult.advisories ?? [],\n        followUpActions: plannerResult.followUpActions ?? [],\n      },\n    });\n  }\n\n  let result: IndexResult;\n  try {\n    result = await indexMemoryFile(validatedPath, {\n      force,\n      parsedOverride: parsedForPreflight,\n      asyncEmbedding,\n      plannerMode,\n      scope: saveScope,\n      routing: buildRoutedSaveOptions(validatedPath, routeAs, mergeModeHint, targetAnchorId),\n    });\n  } catch (error: unknown) {\n    if (error instanceof VRuleUnavailableError) {\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: error.message,\n        code: 'E_RUNTIME',\n        details: { requestId },\n        recovery: {\n          hint: 'Build the Spec Kit scripts workspace and retry the save.',\n          actions: ['Run npm run build --workspace=@spec-kit/scripts', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n    // Classify deep save/index failures (sqlite busy, embedding, db error, etc.) so the\n    // response code points at the actual failure mode instead of the generic E081 catch-all.\n    const indexErrorMessage = error instanceof Error ? error.message : String(error);\n    return createMCPErrorResponse({\n      tool: 'memory_save',\n      error: indexErrorMessage,\n      code: classifySaveErrorCode(indexErrorMessage),\n      details: { requestId, ...extractSaveErrorDetails(indexErrorMessage) },\n      recovery: {\n        hint: 'Inspect the error message for the specific failure; transient DB/embedding issues are usually retryable.',\n        actions: ['Resolve the reported cause', 'Retry memory_save'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (typeof result.id === 'number' && result.id > 0 && result.status !== 'unchanged' && result.status !== 'duplicate') {\n    // B13 + H5 FIX: Wrap governance metadata in a transaction with rollback on failure.\n    // If governance application fails, delete the orphaned memory row to prevent\n    // persisted rows without tenant/session/retention metadata.\n    const applyGovernanceTx = database.transaction(() => {\n      applyPostInsertMetadata(database, result.id, buildGovernancePostInsertFields(governanceDecision));\n      recordGovernanceAudit(database, {\n        action: 'memory_save',\n        decision: 'allow',\n        memoryId: result.id,\n        tenantId,\n        userId,\n        agentId,\n        sessionId,\n        reason: 'governed_ingest',\n        metadata: { filePath: validatedPath, retentionPolicy: governanceDecision.normalized.retentionPolicy },\n      });\n    });\n    try {\n      applyGovernanceTx();\n    } catch (govErr: unknown) {\n      // C2 FIX: Use full delete helper to clean up ALL ancillary records\n      // (vec_memories, BM25 index, causal edges, projections, etc.)\n      // not just memory_index, to prevent orphaned search phantoms.\n      const govErrorMessage = govErr instanceof Error ? govErr.message : String(govErr);\n      console.error('[memory-save] Governance metadata failed, removing orphaned memory:', govErrorMessage);\n      try { delete_memory_from_database(database, result.id); } catch (_: unknown) { /* best-effort cleanup */ }\n      // The orphan rollback above already ran; return a classified error (sqlite-busy / db\n      // failures map to E087/E088) instead of a bare throw the dispatcher would surface as the\n      // generic E081 catch-all.\n      return createMCPErrorResponse({\n        tool: 'memory_save',\n        error: govErrorMessage,\n        code: classifySaveErrorCode(govErrorMessage),\n        details: { requestId, ...extractSaveErrorDetails(govErrorMessage) },\n        recovery: {\n          hint: 'The memory was rolled back after a post-insert metadata write failed; transient DB locks are retryable.',\n          actions: ['Resolve the reported cause', 'Retry memory_save'],\n          severity: 'warning',\n        },\n      });\n    }\n  }\n\n  return buildSaveResponse({ result, filePath: file_path, asyncEmbedding, requestId });\n}\n\n/* --- 10. ATOMIC MEMORY SAVE --- */\n\n/**\n * Save memory content to disk with retry + rollback guarded indexing.\n *\n * The file write promotes a pending file while holding the per-spec-folder\n * mutex so concurrent saves cannot overwrite each other between disk\n * promotion and indexing. If indexing later fails, the original file content\n * is restored before the error is returned and before the lock is released.\n */\nasync function atomicSaveMemory(params: AtomicSaveParams, options: AtomicSaveOptions = {}): Promise<AtomicSaveResult> {\n  const { file_path, routeAs, mergeModeHint, targetAnchorId } = params;\n  const database = requireDb();\n  const routing = buildRoutedSaveOptions(file_path, routeAs, mergeModeHint, targetAnchorId);\n  const plannerMode = params.plannerMode ?? resolveSavePlannerMode();\n\n  if (shouldUseCanonicalRouting(params) && plannerMode !== 'full-auto') {\n    const canonicalPrepared = await buildCanonicalAtomicPreparedSave(params, database);\n    if (canonicalPrepared.status !== 'ready') {\n      return buildAtomicPlannerAbortResult(params, canonicalPrepared.result);\n    }\n\n    return buildAtomicPlannerReadyResult(\n      params,\n      canonicalPrepared.prepared,\n      validateCanonicalPreparedSave(canonicalPrepared.prepared),\n      options,\n    );\n  }\n\n  return atomicIndexMemory<PreparedParsedMemory | CanonicalAtomicPrepared>(params, options, {\n    prepare: async (currentParams, _context) => {\n      if (shouldUseCanonicalRouting(currentParams)) {\n        const canonicalPrepared = await buildCanonicalAtomicPreparedSave(currentParams, database);\n        if (canonicalPrepared.status !== 'ready') {\n          return canonicalPrepared;\n        }\n\n        return {\n          status: 'ready',\n          prepared: canonicalPrepared.prepared,\n          specFolder: canonicalPrepared.prepared.preparedMemory.parsed.specFolder,\n          persistedContent: canonicalPrepared.persistedContent,\n          persistedFilePath: canonicalPrepared.persistedFilePath,\n        } as const;\n      }\n\n      const { file_path: currentFilePath, content: currentContent } = currentParams;\n      const prepared = prepareParsedMemoryForIndexing(\n        memoryParser.parseMemoryContent(currentFilePath, currentContent),\n        database,\n        {\n          qualityLoopMode: currentParams.plannerMode === 'full-auto' ? 'full-auto' : 'advisory',\n        },\n      );\n\n      if (!prepared.validation.valid) {\n        return {\n          status: 'abort',\n          result: {\n            success: false,\n            filePath: currentFilePath,\n            status: 'error',\n            summary: 'Atomic save preflight failed',\n            message: 'Parsed content failed validation before atomic save',\n            error: `Validation failed: ${prepared.validation.errors.join(', ')}`,\n          },\n        } as const;\n      }\n\n      if (prepared.qualityLoopResult.fixes.length > 0 && prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent) {\n        console.error(`[memory-save] Quality loop applied ${prepared.qualityLoopResult.fixes.length} auto-fix(es) for ${path.basename(currentFilePath)} before pending-file promotion`);\n      }\n\n      return {\n        status: 'ready',\n        prepared,\n        specFolder: prepared.parsed.specFolder,\n        persistedContent: prepared.qualityLoopResult.passed && prepared.qualityLoopResult.fixedContent\n          ? prepared.qualityLoopResult.fixedContent\n          : currentContent,\n      } as const;\n    },\n    prepareLocked: async ({ ready, params: currentParams }) => {\n      if (!isCanonicalAtomicPrepared(ready.prepared)) {\n        return ready;\n      }\n\n      // Rebuild the canonical merge while the spec-folder lock is held so\n      // concurrent routed saves always merge against the latest on-disk doc.\n      const canonicalPrepared = await buildCanonicalAtomicPreparedSave(currentParams, database);\n      if (canonicalPrepared.status !== 'ready') {\n        return canonicalPrepared;\n      }\n\n      return {\n        status: 'ready',\n        prepared: canonicalPrepared.prepared,\n        specFolder: canonicalPrepared.prepared.preparedMemory.parsed.specFolder,\n        persistedContent: canonicalPrepared.persistedContent,\n        persistedFilePath: canonicalPrepared.persistedFilePath,\n      } as const;\n    },\n    indexPrepared: ({ ready, params: currentParams, force }) => {\n      const effectiveFilePath = ready.persistedFilePath ?? currentParams.file_path;\n      const routedPrepared = isCanonicalAtomicPrepared(ready.prepared)\n        ? ready.prepared\n        : null;\n\n      if (routedPrepared) {\n        const validationResult = validateCanonicalPreparedSave(routedPrepared);\n        if (!validationResult.ok) {\n          return validationResult.rejection;\n        }\n\n        return processPreparedMemory(routedPrepared.preparedMemory, effectiveFilePath, {\n          force,\n          asyncEmbedding: true,\n          plannerMode: currentParams.plannerMode,\n          persistQualityLoopContent: false,\n          specFolderLockAlreadyHeld: true,\n          qualityGateMode: 'warn-only',\n          routing: routedPrepared.routing,\n        }).then((result) => {\n          for (const warning of validationResult.warnings) {\n            appendResultWarning(result, warning);\n          }\n          return result;\n        });\n      }\n\n      return processPreparedMemory(ready.prepared as PreparedParsedMemory, currentParams.file_path, {\n        force,\n        asyncEmbedding: true,\n        plannerMode: currentParams.plannerMode,\n        persistQualityLoopContent: false,\n        specFolderLockAlreadyHeld: true,\n        routing: buildRoutedSaveOptions(currentParams.file_path, currentParams.routeAs, currentParams.mergeModeHint, currentParams.targetAnchorId),\n      });\n    },\n    getPendingPath: (currentFilePath) => `${transactionManager.getPendingPath(currentFilePath)}.${randomUUID().slice(0, 8)}`,\n    withSpecFolderLock,\n    captureOriginalState: captureAtomicSaveOriginalState,\n    restoreOriginalState: restoreAtomicSaveOriginalState,\n    cleanupPendingFile: cleanupAtomicSavePendingFile,\n    writePendingFile: (pendingPath, persistedContent) => {\n      fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n      fs.writeFileSync(pendingPath, persistedContent, 'utf-8');\n    },\n    promotePendingFile: (pendingPath, currentFilePath) => {\n      fs.mkdirSync(path.dirname(currentFilePath), { recursive: true });\n      fs.renameSync(pendingPath, currentFilePath);\n    },\n    mapSuccessResult: (indexResult, context) => {\n      const effectiveFilePath = context.ready.persistedFilePath ?? file_path;\n      const routedRouteCategory = indexResult.routeCategory ?? routing?.routeAs;\n      const routedMergeMode = indexResult.mergeMode ?? routing?.mergeModeHint;\n      const routedTargetDocPath = indexResult.targetDocPath ?? effectiveFilePath;\n\n      if (indexResult.status !== 'unchanged' && indexResult.status !== 'duplicate' && indexResult.id > 0) {\n        applyPostInsertMetadata(database, indexResult.id, {});\n      }\n\n      const shouldEmitPostMutationFeedback = indexResult.status !== 'duplicate' && indexResult.status !== 'unchanged';\n      let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n      if (shouldEmitPostMutationFeedback) {\n        let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n        try {\n          postMutationHooks = runPostMutationHooks('atomic-save', {\n            filePath: routedTargetDocPath,\n            specFolder: indexResult.specFolder,\n            memoryId: indexResult.id,\n          });\n        } catch (hookError: unknown) {\n          const msg = hookError instanceof Error ? hookError.message : String(hookError);\n          postMutationHooks = {\n            latencyMs: 0, triggerCacheCleared: false,\n            constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n            graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n            errors: [msg],\n          };\n        }\n        postMutationFeedback = buildMutationHookFeedback('atomic-save', postMutationHooks);\n      }\n\n      const message = indexResult.message ?? (\n        indexResult.status === 'duplicate'\n          ? 'Memory skipped (duplicate content)'\n          : `Memory ${indexResult.status} successfully`\n      );\n      const hints: string[] = [];\n\n      if (indexResult.embeddingStatus === 'pending') {\n        hints.push('Memory will be fully indexed when embedding provider becomes available');\n      }\n      if (indexResult.embeddingStatus === 'partial') {\n        hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n      }\n      if (postMutationFeedback) {\n        hints.push(...postMutationFeedback.hints);\n      } else if (indexResult.status === 'duplicate') {\n        hints.push('Duplicate content matched an existing indexed memory, so caches were left unchanged');\n      }\n\n      return {\n        success: true,\n        filePath: routedTargetDocPath,\n        status: indexResult.status,\n        id: indexResult.id,\n        specFolder: indexResult.specFolder,\n        title: indexResult.title,\n        summary: message,\n        message,\n        embeddingStatus: indexResult.embeddingStatus,\n        ...(routedRouteCategory ? { routeCategory: routedRouteCategory } : {}),\n        ...(routedMergeMode ? { mergeMode: routedMergeMode } : {}),\n        ...(routedTargetDocPath ? { targetDocPath: routedTargetDocPath } : {}),\n        ...(indexResult.targetAnchorId ? { targetAnchorId: indexResult.targetAnchorId } : {}),\n        ...(postMutationFeedback ? { postMutationHooks: postMutationFeedback.data } : {}),\n        ...(hints.length > 0 ? { hints } : {}),\n      };\n    },\n  });\n}\n\n/** Return transaction manager metrics for atomicity monitoring */\nfunction getAtomicityMetrics(): Record<string, unknown> {\n  return transactionManager.getMetrics();\n}\n\n/* --- 12. EXPORTS --- */\n\nexport {\n  // Primary exports (defined in this module)\n  indexMemoryFile,\n  indexMemoryFileFromScan,\n  indexChunkedMemoryFile,\n  handleMemorySave,\n  atomicSaveMemory,\n  getAtomicityMetrics,\n};\n\n// Backward-compatible aliases (snake_case) — only for symbols defined in this module\nconst index_memory_file = indexMemoryFile;\nconst index_memory_file_from_scan = indexMemoryFileFromScan;\nconst index_chunked_memory_file = indexChunkedMemoryFile;\nconst handle_memory_save = handleMemorySave;\nconst atomic_save_memory = atomicSaveMemory;\nconst get_atomicity_metrics = getAtomicityMetrics;\n\nexport {\n  index_memory_file,\n  index_memory_file_from_scan,\n  index_chunked_memory_file,\n  handle_memory_save,\n  atomic_save_memory,\n  get_atomicity_metrics,\n};","lineStart":3100,"lineEnd":3763,"totalLines":3763,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts","time":{"start":1780738243304,"end":1780738243313}},"metadata":{"openai":{"itemId":"fc_0b9fab94dfdca3ed016a23e8c33b4481919bb175364fdafd54"}},"id":"prt_e9c453ab7001kqpHRDnemZZAPS","sessionID":"ses_163bcc50affeyxhkrz48ouVc7l","messageID":"msg_e9c451128001EFz7vHt0oGj4YX"}}
