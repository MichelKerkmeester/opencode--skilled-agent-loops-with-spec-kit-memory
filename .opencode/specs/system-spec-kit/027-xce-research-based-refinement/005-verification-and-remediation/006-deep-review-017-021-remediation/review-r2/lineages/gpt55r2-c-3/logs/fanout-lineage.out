{"type":"tool_use","timestamp":1781762026148,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_JiY0S5VWyzH9iOzlvjH1JWUQ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","offset":1,"limit":420},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ---------------------------------------------------------------\n3: // MODULE: Spec Memory CLI\n4: // ---------------------------------------------------------------\n5: // Daemon-backed command line client for the mk-spec-memory tool\n6: // surface. The CLI is intentionally IPC-only: all persistence remains\n7: // owned by the already-running context server daemon.\n8: \n9: import { spawn } from 'node:child_process';\n10: import { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\n11: import net from 'node:net';\n12: import { createRequire } from 'node:module';\n13: import path from 'node:path';\n14: import { StringDecoder } from 'node:string_decoder';\n15: import { fileURLToPath } from 'node:url';\n16: \n17: import {\n18:   TOOL_DEFINITIONS,\n19:   type ToolDefinition,\n20:   ToolSchemaValidationError,\n21:   validateToolArgs,\n22: } from './tool-schemas.js';\n23: \n24: const JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\n25: const DEFAULT_TIMEOUT_MS = 30_000;\n26: const DEFAULT_SOCKET_DIR = '/tmp/mk-spec-memory';\n27: const SOCKET_FILE_NAME = 'daemon-ipc.sock';\n28: const RESERVED_COMMANDS = new Set(['list-tools', 'completion']);\n29: \n30: const EXIT_SUCCESS = 0;\n31: const EXIT_RUNTIME = 1;\n32: const EXIT_USAGE = 64;\n33: const EXIT_PROTOCOL = 69;\n34: const EXIT_RETRYABLE = 75;\n35: \n36: type OutputFormat = 'json' | 'text' | 'jsonl';\n37: type ToolListMode = 'full' | 'compact' | 'names-only';\n38: type CompletionShell = 'bash' | 'zsh';\n39: \n40: interface ParsedCommand {\n41:   readonly command: string;\n42:   readonly format: OutputFormat;\n43:   readonly timeoutMs: number;\n44:   readonly sessionId?: string;\n45:   readonly warmOnly: boolean;\n46:   readonly toolListMode: ToolListMode;\n47:   readonly completionShell?: CompletionShell;\n48:   readonly args: Record<string, unknown>;\n49:   readonly help: boolean;\n50:   readonly version: boolean;\n51: }\n52: \n53: interface CliIo {\n54:   readonly stdout: Pick<NodeJS.WriteStream, 'write'>;\n55:   readonly stderr: Pick<NodeJS.WriteStream, 'write'>;\n56: }\n57: \n58: interface RepoPaths {\n59:   readonly opencodeDir: string;\n60:   readonly repoRoot: string;\n61:   readonly launcherPath: string;\n62:   readonly bridgePath: string;\n63:   readonly dbDir: string;\n64:   readonly packageJsonPath: string;\n65: }\n66: \n67: interface BridgeProbeResult {\n68:   readonly status: string;\n69:   readonly reason?: string;\n70: }\n71: \n72: interface BridgeModule {\n73:   readonly getIpcSocketPath: (serviceName: string, options?: { dbDir?: string }) => string;\n74:   readonly probeDaemon: (socketPath: string, options?: { timeoutMs?: number; deepProbe?: boolean }) => Promise<BridgeProbeResult>;\n75:   readonly toConnectionOptions: (socketPath: string) => string | net.NetConnectOpts;\n76: }\n77: \n78: interface JsonRpcResponse {\n79:   readonly jsonrpc?: string;\n80:   readonly id?: unknown;\n81:   readonly result?: unknown;\n82:   readonly error?: {\n83:     readonly code?: number;\n84:     readonly message?: string;\n85:     readonly data?: unknown;\n86:   };\n87: }\n88: \n89: interface InitializeResult {\n90:   readonly protocolVersion?: string;\n91: }\n92: \n93: interface ToolResult {\n94:   readonly content?: Array<{ readonly type?: string; readonly text?: string }>;\n95:   readonly isError?: boolean;\n96: }\n97: \n98: class CliUsageError extends Error {\n99:   constructor(message: string) {\n100:     super(message);\n101:     this.name = 'CliUsageError';\n102:   }\n103: }\n104: \n105: class CliRetryableError extends Error {\n106:   constructor(message: string) {\n107:     super(message);\n108:     this.name = 'CliRetryableError';\n109:   }\n110: }\n111: \n112: class CliProtocolError extends Error {\n113:   constructor(message: string) {\n114:     super(message);\n115:     this.name = 'CliProtocolError';\n116:   }\n117: }\n118: \n119: class JsonRpcError extends Error {\n120:   public readonly code?: number;\n121:   public readonly data?: unknown;\n122: \n123:   constructor(error: NonNullable<JsonRpcResponse['error']>) {\n124:     super(error.message ?? 'JSON-RPC request failed');\n125:     this.name = 'JsonRpcError';\n126:     this.code = error.code;\n127:     this.data = error.data;\n128:   }\n129: }\n130: \n131: // Awaits drain when the kernel pipe buffer is full: a fire-and-forget\n132: // write followed by process.exit() truncates large payloads at the pipe\n133: // buffer boundary (observed as exactly 64KB on darwin). Streams without\n134: // emitter methods (test fakes) resolve immediately.\n135: async function writeLine(stream: Pick<NodeJS.WriteStream, 'write'>, value: string): Promise<void> {\n136:   const flushed = stream.write(`${value}\\n`);\n137:   if (flushed) return;\n138:   const drainable = stream as Pick<NodeJS.WriteStream, 'write'> & Partial<Pick<NodeJS.WriteStream, 'once' | 'off'>>;\n139:   if (typeof drainable.once !== 'function') return;\n140:   await new Promise<void>((resolve) => {\n141:     const settle = (): void => {\n142:       drainable.off?.('drain', settle);\n143:       drainable.off?.('error', settle);\n144:       drainable.off?.('close', settle);\n145:       resolve();\n146:     };\n147:     drainable.once?.('drain', settle);\n148:     drainable.once?.('error', settle);\n149:     drainable.once?.('close', settle);\n150:   });\n151: }\n152: \n153: function currentModulePath(): string {\n154:   return fileURLToPath(import.meta.url);\n155: }\n156: \n157: function findRepoPaths(startFile = currentModulePath()): RepoPaths {\n158:   let current = path.dirname(startFile);\n159: \n160:   while (true) {\n161:     const directOpencodeDir = path.basename(current) === '.opencode' ? current : path.join(current, '.opencode');\n162:     const launcherPath = path.join(directOpencodeDir, 'bin', 'mk-spec-memory-launcher.cjs');\n163:     const bridgePath = path.join(directOpencodeDir, 'bin', 'lib', 'launcher-ipc-bridge.cjs');\n164:     if (existsSync(launcherPath) && existsSync(bridgePath)) {\n165:       const repoRoot = path.dirname(directOpencodeDir);\n166:       return {\n167:         opencodeDir: directOpencodeDir,\n168:         repoRoot,\n169:         launcherPath,\n170:         bridgePath,\n171:         dbDir: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'),\n172:         packageJsonPath: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'package.json'),\n173:       };\n174:     }\n175: \n176:     const parent = path.dirname(current);\n177:     if (parent === current) {\n178:       throw new CliProtocolError('Unable to locate .opencode/bin launcher assets from CLI path');\n179:     }\n180:     current = parent;\n181:   }\n182: }\n183: \n184: function loadBridge(paths: RepoPaths): BridgeModule {\n185:   const require = createRequire(import.meta.url);\n186:   return require(paths.bridgePath) as BridgeModule;\n187: }\n188: \n189: function readCliVersion(paths: RepoPaths): string {\n190:   const require = createRequire(import.meta.url);\n191:   const pkg = require(paths.packageJsonPath) as { version?: unknown };\n192:   return typeof pkg.version === 'string' ? pkg.version : '0.0.0';\n193: }\n194: \n195: function toKebabCommand(name: string): string {\n196:   return name.replace(/_/g, '-');\n197: }\n198: \n199: function toCamelCommand(name: string): string {\n200:   return name.replace(/_([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n201: }\n202: \n203: function commandAliases(name: string): string[] {\n204:   return Array.from(new Set([name, toKebabCommand(name), toCamelCommand(name)]));\n205: }\n206: \n207: function usageText(command?: string): string {\n208:   const tool = command ? getToolDefinition(command) : null;\n209:   if (tool) {\n210:     return `spec-memory ${tool.name}\n211: \n212: Description:\n213:   ${tool.description}\n214: \n215: Aliases:\n216:   ${commandAliases(tool.name).join(', ')}\n217: \n218: Input schema:\n219: ${JSON.stringify(tool.inputSchema, null, 2)}`;\n220:   }\n221: \n222:   return `spec-memory - daemon-backed CLI for mk-spec-memory\n223: \n224: Usage:\n225:   spec-memory list-tools [--format json|text|jsonl] [--compact|--names-only]\n226:   spec-memory completion bash|zsh\n227:   spec-memory <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--session-id ID] [--warm-only]\n228:   spec-memory <tool_name> --param value [--another-param value]\n229: \n230: Examples:\n231:   spec-memory list-tools --format text\n232:   spec-memory list-tools --compact\n233:   spec-memory completion zsh\n234:   spec-memory memory_stats --format json\n235:   spec-memory memory_search --query \"gold query battery\" --limit 3\n236:   spec-memory memory_context --json '{\"input\":\"resume\", \"mode\":\"resume\"}'\n237: \n238: Exit codes:\n239:   0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error\n240: \n241: Exit 69 recovery:\n242:   - Missing or stale dist entrypoint: run npm run build --workspace=@spec-kit/mcp-server.\n243:     - Backend protocol version changed: rebuild the CLI and daemon from the same checkout, then update any pinned client.\n244:     - Socket path or daemon config mismatch: check SPECKIT_IPC_SOCKET_DIR, socket length, and daemon config before retrying.`;\n245: }\n246: \n247: function parseCompletionShell(raw: string): CompletionShell {\n248:   if (raw === 'bash' || raw === 'zsh') return raw;\n249:   throw new CliUsageError('completion shell must be one of: bash, zsh');\n250: }\n251: \n252: function normalizeName(value: string): string {\n253:   return value.replace(/[-_]/g, '').toLowerCase();\n254: }\n255: \n256: function toCamelCaseFlag(value: string): string {\n257:   return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n258: }\n259: \n260: function commandMap(): Map<string, ToolDefinition> {\n261:   const map = new Map<string, ToolDefinition>();\n262:   for (const tool of TOOL_DEFINITIONS) {\n263:     for (const alias of commandAliases(tool.name)) {\n264:       const existing = map.get(alias);\n265:       if (existing && existing.name !== tool.name) {\n266:         throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n267:       }\n268:       map.set(alias, tool);\n269:     }\n270:   }\n271:   return map;\n272: }\n273: \n274: function getToolDefinition(command: string): ToolDefinition | null {\n275:   return commandMap().get(command) ?? null;\n276: }\n277: \n278: function inputPropertyNames(tool: ToolDefinition): string[] {\n279:   const schema = tool.inputSchema;\n280:   const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n281:     ? (schema as { readonly properties?: unknown }).properties\n282:     : null;\n283:   if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n284:   return Object.keys(properties);\n285: }\n286: \n287: function resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n288:   const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n289:   if (exact) return exact;\n290: \n291:   const normalized = normalizeName(rawFlag);\n292:   const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n293:   if (matched) return matched;\n294: \n295:   return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n296: }\n297: \n298: function parseValue(raw: string): unknown {\n299:   const trimmed = raw.trim();\n300:   if (trimmed === 'true') return true;\n301:   if (trimmed === 'false') return false;\n302:   if (trimmed === 'null') return null;\n303:   if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n304:     try {\n305:       return JSON.parse(trimmed) as unknown;\n306:     } catch (error: unknown) {\n307:       const message = error instanceof Error ? error.message : String(error);\n308:       throw new CliUsageError(`Invalid JSON value: ${message}`);\n309:     }\n310:   }\n311:   return raw;\n312: }\n313: \n314: function parsePositiveInteger(raw: string, flagName: string): number {\n315:   if (!/^\\d+$/.test(raw)) {\n316:     throw new CliUsageError(`${flagName} must be a positive integer`);\n317:   }\n318:   const value = Number.parseInt(raw, 10);\n319:   if (!Number.isFinite(value) || value <= 0) {\n320:     throw new CliUsageError(`${flagName} must be a positive integer`);\n321:   }\n322:   return value;\n323: }\n324: \n325: function parseFormat(raw: string): OutputFormat {\n326:   if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n327:   throw new CliUsageError('--format must be one of: json, text, jsonl');\n328: }\n329: \n330: function parseInlineBoolean(raw: string, flagName: string): boolean {\n331:   if (raw === 'true' || raw === '1') return true;\n332:   if (raw === 'false' || raw === '0') return false;\n333:   throw new CliUsageError(`${flagName} must be true or false`);\n334: }\n335: \n336: function readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n337:   const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n338:   if (inline) return { value: inline[1], nextIndex: index + 1 };\n339:   const value = tokens[index + 1];\n340:   if (value === undefined) {\n341:     throw new CliUsageError(`${flagName} requires a value`);\n342:   }\n343:   return { value, nextIndex: index + 2 };\n344: }\n345: \n346: function parseJsonObject(raw: string): Record<string, unknown> {\n347:   let parsed: unknown;\n348:   try {\n349:     parsed = JSON.parse(raw) as unknown;\n350:   } catch (error: unknown) {\n351:     const message = error instanceof Error ? error.message : String(error);\n352:     throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n353:   }\n354:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n355:     throw new CliUsageError('--json must be a JSON object');\n356:   }\n357:   return parsed as Record<string, unknown>;\n358: }\n359: \n360: function envFlagEnabled(name: string): boolean {\n361:   const raw = process.env[name];\n362:   if (raw === undefined || raw === null) return false;\n363:   return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n364: }\n365: \n366: function defaultWarmOnly(): boolean {\n367:   return envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_WARM_ONLY')\n368:     || envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME')\n369:     || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n370:     || envFlagEnabled('OPENCODE_PROMPT_TIME')\n371:     || envFlagEnabled('CODEX_PROMPT_TIME')\n372:     || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n373: }\n374: \n375: export function parseCliArgs(argv: string[]): ParsedCommand {\n376:   const command = argv[0];\n377:   const warmOnlyDefault = defaultWarmOnly();\n378:   if (!command || command === '--help' || command === '-h') {\n379:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n380:   }\n381:   if (command === '--version' || command === '-v') {\n382:     return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n383:   }\n384: \n385:   let format: OutputFormat = 'json';\n386:   let timeoutMs = DEFAULT_TIMEOUT_MS;\n387:   let sessionId: string | undefined;\n388:   let warmOnly = warmOnlyDefault;\n389:   let toolListMode: ToolListMode = 'full';\n390:   let completionShell: CompletionShell | undefined;\n391:   let jsonPayload: Record<string, unknown> | null = null;\n392:   const tool = getToolDefinition(command);\n393:   const parsedArgs: Record<string, unknown> = {};\n394:   const tokens = argv.slice(1);\n395:   let index = 0;\n396: \n397:   while (index < tokens.length) {\n398:     const token = tokens[index];\n399:     if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n400:       completionShell = parseCompletionShell(token);\n401:       index += 1;\n402:       continue;\n403:     }\n404:     if (!token.startsWith('--')) {\n405:       throw new CliUsageError(`Unexpected positional argument: ${token}`);\n406:     }\n407:     const rawFlag = token.slice(2).split('=', 1)[0];\n408:     const option = `--${rawFlag}`;\n409: \n410:     if (rawFlag === 'help' || rawFlag === 'h') {\n411:       return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n412:     }\n413:     if (rawFlag === 'format') {\n414:       const read = readOptionValue(tokens, index, option);\n415:       format = parseFormat(read.value);\n416:       index = read.nextIndex;\n417:       continue;\n418:     }\n419:     if (rawFlag === 'timeout-ms') {\n420:       const read = readOptionValue(tokens, index, option);\n\n(Showing lines 1-420 of 1084. Use offset=421 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ---------------------------------------------------------------\n// MODULE: Spec Memory CLI\n// ---------------------------------------------------------------\n// Daemon-backed command line client for the mk-spec-memory tool\n// surface. The CLI is intentionally IPC-only: all persistence remains\n// owned by the already-running context server daemon.\n\nimport { spawn } from 'node:child_process';\nimport { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\nimport net from 'node:net';\nimport { createRequire } from 'node:module';\nimport path from 'node:path';\nimport { StringDecoder } from 'node:string_decoder';\nimport { fileURLToPath } from 'node:url';\n\nimport {\n  TOOL_DEFINITIONS,\n  type ToolDefinition,\n  ToolSchemaValidationError,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","text":"#!/usr/bin/env node\n// ---------------------------------------------------------------\n// MODULE: Spec Memory CLI\n// ---------------------------------------------------------------\n// Daemon-backed command line client for the mk-spec-memory tool\n// surface. The CLI is intentionally IPC-only: all persistence remains\n// owned by the already-running context server daemon.\n\nimport { spawn } from 'node:child_process';\nimport { existsSync, lstatSync, mkdirSync, statSync } from 'node:fs';\nimport net from 'node:net';\nimport { createRequire } from 'node:module';\nimport path from 'node:path';\nimport { StringDecoder } from 'node:string_decoder';\nimport { fileURLToPath } from 'node:url';\n\nimport {\n  TOOL_DEFINITIONS,\n  type ToolDefinition,\n  ToolSchemaValidationError,\n  validateToolArgs,\n} from './tool-schemas.js';\n\nconst JSON_RPC_PROTOCOL_VERSION = '2025-06-18';\nconst DEFAULT_TIMEOUT_MS = 30_000;\nconst DEFAULT_SOCKET_DIR = '/tmp/mk-spec-memory';\nconst SOCKET_FILE_NAME = 'daemon-ipc.sock';\nconst RESERVED_COMMANDS = new Set(['list-tools', 'completion']);\n\nconst EXIT_SUCCESS = 0;\nconst EXIT_RUNTIME = 1;\nconst EXIT_USAGE = 64;\nconst EXIT_PROTOCOL = 69;\nconst EXIT_RETRYABLE = 75;\n\ntype OutputFormat = 'json' | 'text' | 'jsonl';\ntype ToolListMode = 'full' | 'compact' | 'names-only';\ntype CompletionShell = 'bash' | 'zsh';\n\ninterface ParsedCommand {\n  readonly command: string;\n  readonly format: OutputFormat;\n  readonly timeoutMs: number;\n  readonly sessionId?: string;\n  readonly warmOnly: boolean;\n  readonly toolListMode: ToolListMode;\n  readonly completionShell?: CompletionShell;\n  readonly args: Record<string, unknown>;\n  readonly help: boolean;\n  readonly version: boolean;\n}\n\ninterface CliIo {\n  readonly stdout: Pick<NodeJS.WriteStream, 'write'>;\n  readonly stderr: Pick<NodeJS.WriteStream, 'write'>;\n}\n\ninterface RepoPaths {\n  readonly opencodeDir: string;\n  readonly repoRoot: string;\n  readonly launcherPath: string;\n  readonly bridgePath: string;\n  readonly dbDir: string;\n  readonly packageJsonPath: string;\n}\n\ninterface BridgeProbeResult {\n  readonly status: string;\n  readonly reason?: string;\n}\n\ninterface BridgeModule {\n  readonly getIpcSocketPath: (serviceName: string, options?: { dbDir?: string }) => string;\n  readonly probeDaemon: (socketPath: string, options?: { timeoutMs?: number; deepProbe?: boolean }) => Promise<BridgeProbeResult>;\n  readonly toConnectionOptions: (socketPath: string) => string | net.NetConnectOpts;\n}\n\ninterface JsonRpcResponse {\n  readonly jsonrpc?: string;\n  readonly id?: unknown;\n  readonly result?: unknown;\n  readonly error?: {\n    readonly code?: number;\n    readonly message?: string;\n    readonly data?: unknown;\n  };\n}\n\ninterface InitializeResult {\n  readonly protocolVersion?: string;\n}\n\ninterface ToolResult {\n  readonly content?: Array<{ readonly type?: string; readonly text?: string }>;\n  readonly isError?: boolean;\n}\n\nclass CliUsageError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliUsageError';\n  }\n}\n\nclass CliRetryableError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliRetryableError';\n  }\n}\n\nclass CliProtocolError extends Error {\n  constructor(message: string) {\n    super(message);\n    this.name = 'CliProtocolError';\n  }\n}\n\nclass JsonRpcError extends Error {\n  public readonly code?: number;\n  public readonly data?: unknown;\n\n  constructor(error: NonNullable<JsonRpcResponse['error']>) {\n    super(error.message ?? 'JSON-RPC request failed');\n    this.name = 'JsonRpcError';\n    this.code = error.code;\n    this.data = error.data;\n  }\n}\n\n// Awaits drain when the kernel pipe buffer is full: a fire-and-forget\n// write followed by process.exit() truncates large payloads at the pipe\n// buffer boundary (observed as exactly 64KB on darwin). Streams without\n// emitter methods (test fakes) resolve immediately.\nasync function writeLine(stream: Pick<NodeJS.WriteStream, 'write'>, value: string): Promise<void> {\n  const flushed = stream.write(`${value}\\n`);\n  if (flushed) return;\n  const drainable = stream as Pick<NodeJS.WriteStream, 'write'> & Partial<Pick<NodeJS.WriteStream, 'once' | 'off'>>;\n  if (typeof drainable.once !== 'function') return;\n  await new Promise<void>((resolve) => {\n    const settle = (): void => {\n      drainable.off?.('drain', settle);\n      drainable.off?.('error', settle);\n      drainable.off?.('close', settle);\n      resolve();\n    };\n    drainable.once?.('drain', settle);\n    drainable.once?.('error', settle);\n    drainable.once?.('close', settle);\n  });\n}\n\nfunction currentModulePath(): string {\n  return fileURLToPath(import.meta.url);\n}\n\nfunction findRepoPaths(startFile = currentModulePath()): RepoPaths {\n  let current = path.dirname(startFile);\n\n  while (true) {\n    const directOpencodeDir = path.basename(current) === '.opencode' ? current : path.join(current, '.opencode');\n    const launcherPath = path.join(directOpencodeDir, 'bin', 'mk-spec-memory-launcher.cjs');\n    const bridgePath = path.join(directOpencodeDir, 'bin', 'lib', 'launcher-ipc-bridge.cjs');\n    if (existsSync(launcherPath) && existsSync(bridgePath)) {\n      const repoRoot = path.dirname(directOpencodeDir);\n      return {\n        opencodeDir: directOpencodeDir,\n        repoRoot,\n        launcherPath,\n        bridgePath,\n        dbDir: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'database'),\n        packageJsonPath: path.join(directOpencodeDir, 'skills', 'system-spec-kit', 'mcp_server', 'package.json'),\n      };\n    }\n\n    const parent = path.dirname(current);\n    if (parent === current) {\n      throw new CliProtocolError('Unable to locate .opencode/bin launcher assets from CLI path');\n    }\n    current = parent;\n  }\n}\n\nfunction loadBridge(paths: RepoPaths): BridgeModule {\n  const require = createRequire(import.meta.url);\n  return require(paths.bridgePath) as BridgeModule;\n}\n\nfunction readCliVersion(paths: RepoPaths): string {\n  const require = createRequire(import.meta.url);\n  const pkg = require(paths.packageJsonPath) as { version?: unknown };\n  return typeof pkg.version === 'string' ? pkg.version : '0.0.0';\n}\n\nfunction toKebabCommand(name: string): string {\n  return name.replace(/_/g, '-');\n}\n\nfunction toCamelCommand(name: string): string {\n  return name.replace(/_([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandAliases(name: string): string[] {\n  return Array.from(new Set([name, toKebabCommand(name), toCamelCommand(name)]));\n}\n\nfunction usageText(command?: string): string {\n  const tool = command ? getToolDefinition(command) : null;\n  if (tool) {\n    return `spec-memory ${tool.name}\n\nDescription:\n  ${tool.description}\n\nAliases:\n  ${commandAliases(tool.name).join(', ')}\n\nInput schema:\n${JSON.stringify(tool.inputSchema, null, 2)}`;\n  }\n\n  return `spec-memory - daemon-backed CLI for mk-spec-memory\n\nUsage:\n  spec-memory list-tools [--format json|text|jsonl] [--compact|--names-only]\n  spec-memory completion bash|zsh\n  spec-memory <tool_name> [--json '{...}'] [--format json|text|jsonl] [--timeout-ms N] [--session-id ID] [--warm-only]\n  spec-memory <tool_name> --param value [--another-param value]\n\nExamples:\n  spec-memory list-tools --format text\n  spec-memory list-tools --compact\n  spec-memory completion zsh\n  spec-memory memory_stats --format json\n  spec-memory memory_search --query \"gold query battery\" --limit 3\n  spec-memory memory_context --json '{\"input\":\"resume\", \"mode\":\"resume\"}'\n\nExit codes:\n  0 success, 1 runtime error, 64 usage/schema error, 69 protocol mismatch, 75 retryable daemon error\n\nExit 69 recovery:\n  - Missing or stale dist entrypoint: run npm run build --workspace=@spec-kit/mcp-server.\n    - Backend protocol version changed: rebuild the CLI and daemon from the same checkout, then update any pinned client.\n    - Socket path or daemon config mismatch: check SPECKIT_IPC_SOCKET_DIR, socket length, and daemon config before retrying.`;\n}\n\nfunction parseCompletionShell(raw: string): CompletionShell {\n  if (raw === 'bash' || raw === 'zsh') return raw;\n  throw new CliUsageError('completion shell must be one of: bash, zsh');\n}\n\nfunction normalizeName(value: string): string {\n  return value.replace(/[-_]/g, '').toLowerCase();\n}\n\nfunction toCamelCaseFlag(value: string): string {\n  return value.replace(/-([a-z0-9])/g, (_match, char: string) => char.toUpperCase());\n}\n\nfunction commandMap(): Map<string, ToolDefinition> {\n  const map = new Map<string, ToolDefinition>();\n  for (const tool of TOOL_DEFINITIONS) {\n    for (const alias of commandAliases(tool.name)) {\n      const existing = map.get(alias);\n      if (existing && existing.name !== tool.name) {\n        throw new CliProtocolError(`Command alias collision: ${alias} maps to ${existing.name} and ${tool.name}`);\n      }\n      map.set(alias, tool);\n    }\n  }\n  return map;\n}\n\nfunction getToolDefinition(command: string): ToolDefinition | null {\n  return commandMap().get(command) ?? null;\n}\n\nfunction inputPropertyNames(tool: ToolDefinition): string[] {\n  const schema = tool.inputSchema;\n  const properties = typeof schema === 'object' && schema !== null && !Array.isArray(schema)\n    ? (schema as { readonly properties?: unknown }).properties\n    : null;\n  if (!properties || typeof properties !== 'object' || Array.isArray(properties)) return [];\n  return Object.keys(properties);\n}\n\nfunction resolvePropertyName(rawFlag: string, tool: ToolDefinition): string {\n  const exact = inputPropertyNames(tool).find((name) => name === rawFlag);\n  if (exact) return exact;\n\n  const normalized = normalizeName(rawFlag);\n  const matched = inputPropertyNames(tool).find((name) => normalizeName(name) === normalized);\n  if (matched) return matched;\n\n  return rawFlag.includes('-') ? toCamelCaseFlag(rawFlag) : rawFlag;\n}\n\nfunction parseValue(raw: string): unknown {\n  const trimmed = raw.trim();\n  if (trimmed === 'true') return true;\n  if (trimmed === 'false') return false;\n  if (trimmed === 'null') return null;\n  if ((trimmed.startsWith('{') && trimmed.endsWith('}')) || (trimmed.startsWith('[') && trimmed.endsWith(']'))) {\n    try {\n      return JSON.parse(trimmed) as unknown;\n    } catch (error: unknown) {\n      const message = error instanceof Error ? error.message : String(error);\n      throw new CliUsageError(`Invalid JSON value: ${message}`);\n    }\n  }\n  return raw;\n}\n\nfunction parsePositiveInteger(raw: string, flagName: string): number {\n  if (!/^\\d+$/.test(raw)) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  const value = Number.parseInt(raw, 10);\n  if (!Number.isFinite(value) || value <= 0) {\n    throw new CliUsageError(`${flagName} must be a positive integer`);\n  }\n  return value;\n}\n\nfunction parseFormat(raw: string): OutputFormat {\n  if (raw === 'json' || raw === 'text' || raw === 'jsonl') return raw;\n  throw new CliUsageError('--format must be one of: json, text, jsonl');\n}\n\nfunction parseInlineBoolean(raw: string, flagName: string): boolean {\n  if (raw === 'true' || raw === '1') return true;\n  if (raw === 'false' || raw === '0') return false;\n  throw new CliUsageError(`${flagName} must be true or false`);\n}\n\nfunction readOptionValue(tokens: string[], index: number, flagName: string): { readonly value: string; readonly nextIndex: number } {\n  const inline = tokens[index].match(/^--[^=]+=(.*)$/);\n  if (inline) return { value: inline[1], nextIndex: index + 1 };\n  const value = tokens[index + 1];\n  if (value === undefined) {\n    throw new CliUsageError(`${flagName} requires a value`);\n  }\n  return { value, nextIndex: index + 2 };\n}\n\nfunction parseJsonObject(raw: string): Record<string, unknown> {\n  let parsed: unknown;\n  try {\n    parsed = JSON.parse(raw) as unknown;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    throw new CliUsageError(`--json must be a valid JSON object: ${message}`);\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {\n    throw new CliUsageError('--json must be a JSON object');\n  }\n  return parsed as Record<string, unknown>;\n}\n\nfunction envFlagEnabled(name: string): boolean {\n  const raw = process.env[name];\n  if (raw === undefined || raw === null) return false;\n  return ['1', 'true', 'yes', 'on'].includes(raw.trim().toLowerCase());\n}\n\nfunction defaultWarmOnly(): boolean {\n  return envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_WARM_ONLY')\n    || envFlagEnabled('SPECKIT_SPEC_MEMORY_CLI_PROMPT_TIME')\n    || envFlagEnabled('SPECKIT_CLI_PROMPT_TIME')\n    || envFlagEnabled('OPENCODE_PROMPT_TIME')\n    || envFlagEnabled('CODEX_PROMPT_TIME')\n    || envFlagEnabled('CLAUDE_CODE_PROMPT_TIME');\n}\n\nexport function parseCliArgs(argv: string[]): ParsedCommand {\n  const command = argv[0];\n  const warmOnlyDefault = defaultWarmOnly();\n  if (!command || command === '--help' || command === '-h') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: true, version: false };\n  }\n  if (command === '--version' || command === '-v') {\n    return { command: '', format: 'text', timeoutMs: DEFAULT_TIMEOUT_MS, warmOnly: warmOnlyDefault, toolListMode: 'full', args: {}, help: false, version: true };\n  }\n\n  let format: OutputFormat = 'json';\n  let timeoutMs = DEFAULT_TIMEOUT_MS;\n  let sessionId: string | undefined;\n  let warmOnly = warmOnlyDefault;\n  let toolListMode: ToolListMode = 'full';\n  let completionShell: CompletionShell | undefined;\n  let jsonPayload: Record<string, unknown> | null = null;\n  const tool = getToolDefinition(command);\n  const parsedArgs: Record<string, unknown> = {};\n  const tokens = argv.slice(1);\n  let index = 0;\n\n  while (index < tokens.length) {\n    const token = tokens[index];\n    if (command === 'completion' && completionShell === undefined && !token.startsWith('--')) {\n      completionShell = parseCompletionShell(token);\n      index += 1;\n      continue;\n    }\n    if (!token.startsWith('--')) {\n      throw new CliUsageError(`Unexpected positional argument: ${token}`);\n    }\n    const rawFlag = token.slice(2).split('=', 1)[0];\n    const option = `--${rawFlag}`;\n\n    if (rawFlag === 'help' || rawFlag === 'h') {\n      return { command, format: 'text', timeoutMs, sessionId, warmOnly, toolListMode, completionShell, args: {}, help: true, version: false };\n    }\n    if (rawFlag === 'format') {\n      const read = readOptionValue(tokens, index, option);\n      format = parseFormat(read.value);\n      index = read.nextIndex;\n      continue;\n    }\n    if (rawFlag === 'timeout-ms') {\n      const read = readOptionValue(tokens, index, option);","lineStart":1,"lineEnd":420,"totalLines":1084,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/spec-memory-cli.ts","time":{"start":1781762026142,"end":1781762026147}},"metadata":{"openai":{"itemId":"fc_005a99258a413e36016a3387ea17648191bc6e016b8c80583a"}},"id":"prt_ed94aea91001UxahzJJULSxBt4","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94ab900001in5bFnJvP5kvTn"}}
{"type":"tool_use","timestamp":1781762026207,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_GzX2lDlyh3EOdUv5zyQSl9zz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Tool Schemas\n3: // ───────────────────────────────────────────────────────────────\n4: // All MCP tool definitions (names, descriptions, input schemas).\n5: // Extracted from context-server.ts for maintainability.\n6: import {\n7:   MAX_INGEST_PATHS,\n8:   MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n9: } from './schemas/tool-input-schemas.js';\n10: \n11: /**\n12:  * Re-export schema validation helpers used by the MCP tool entry points.\n13:  */\n14: export {\n15:   ToolSchemaValidationError,\n16:   formatZodError,\n17:   getToolSchema,\n18:   validateToolArgs,\n19:   getSchema,\n20: } from './schemas/tool-input-schemas.js';\n21: \n22: // ───────────────────────────────────────────────────────────────\n23: // 1. TYPES\n24: \n25: // ───────────────────────────────────────────────────────────────\n26: /**\n27:  * Normalized definition for a single MCP tool and its JSON schema.\n28:  */\n29: export interface ToolDefinition {\n30:   name: string;\n31:   description: string;\n32:   inputSchema: Record<string, unknown>;\n33:   outputSchema?: Record<string, unknown>;\n34: }\n35: \n36: export type ToolOwnershipStability = 'stable' | 'deprecated';\n37: \n38: export interface ToolOwnershipEntry {\n39:   name: string;\n40:   owner: string;\n41:   stability: ToolOwnershipStability;\n42:   level: string;\n43:   category: string;\n44: }\n45: \n46: export interface ToolOwnershipMap {\n47:   schemaVersion: 1;\n48:   generatedFrom: 'TOOL_DEFINITIONS';\n49:   tools: ToolOwnershipEntry[];\n50: }\n51: \n52: export interface ToolOwnershipDriftReport {\n53:   ok: boolean;\n54:   missingFromCommitted: string[];\n55:   extraInCommitted: string[];\n56:   changed: Array<{\n57:     name: string;\n58:     field: keyof Omit<ToolOwnershipEntry, 'name'>;\n59:     expected: string;\n60:     actual: string;\n61:   }>;\n62:   expectedMap: ToolOwnershipMap;\n63: }\n64: \n65: const TOOL_OWNER_BY_CATEGORY: Record<string, string> = Object.freeze({\n66:   Orchestration: 'memory-orchestration',\n67:   Core: 'memory-core',\n68:   Discovery: 'memory-discovery',\n69:   Mutation: 'memory-mutation',\n70:   Lifecycle: 'memory-lifecycle',\n71:   Analysis: 'memory-analysis',\n72:   Maintenance: 'memory-maintenance',\n73: });\n74: \n75: function readToolContract(definition: ToolDefinition): { level: string; category: string } {\n76:   const match = /^\\[([^:\\]]+):([^\\]]+)\\]/.exec(definition.description);\n77:   if (!match) {\n78:     return { level: 'unclassified', category: 'unclassified' };\n79:   }\n80:   return {\n81:     level: match[1] ?? 'unclassified',\n82:     category: match[2] ?? 'unclassified',\n83:   };\n84: }\n85: \n86: function deriveToolOwnershipEntry(definition: ToolDefinition): ToolOwnershipEntry {\n87:   const contract = readToolContract(definition);\n88:   return {\n89:     name: definition.name,\n90:     owner: TOOL_OWNER_BY_CATEGORY[contract.category] ?? 'memory-unclassified',\n91:     stability: /^\\[deprecated\\]/i.test(definition.description) ? 'deprecated' : 'stable',\n92:     level: contract.level,\n93:     category: contract.category,\n94:   };\n95: }\n96: \n97: function normalizeToolOwnershipMap(map: ToolOwnershipMap): ToolOwnershipMap {\n98:   return {\n99:     schemaVersion: 1,\n100:     generatedFrom: 'TOOL_DEFINITIONS',\n101:     tools: [...map.tools].sort((a, b) => a.name.localeCompare(b.name)),\n102:   };\n103: }\n104: \n105: function isToolOwnershipEntry(value: unknown): value is ToolOwnershipEntry {\n106:   if (!value || typeof value !== 'object' || Array.isArray(value)) return false;\n107:   const record = value as Record<string, unknown>;\n108:   return (\n109:     typeof record.name === 'string' &&\n110:     typeof record.owner === 'string' &&\n111:     (record.stability === 'stable' || record.stability === 'deprecated') &&\n112:     typeof record.level === 'string' &&\n113:     typeof record.category === 'string'\n114:   );\n115: }\n116: \n117: function parseToolOwnershipMap(value: unknown): ToolOwnershipMap | null {\n118:   let parsed: unknown;\n119:   try {\n120:     parsed = typeof value === 'string' ? JSON.parse(value) as unknown : value;\n121:   } catch (_error: unknown) {\n122:     return null;\n123:   }\n124:   if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;\n125:   const record = parsed as Record<string, unknown>;\n126:   if (record.schemaVersion !== 1 || record.generatedFrom !== 'TOOL_DEFINITIONS') return null;\n127:   if (!Array.isArray(record.tools) || !record.tools.every(isToolOwnershipEntry)) return null;\n128:   return normalizeToolOwnershipMap({\n129:     schemaVersion: 1,\n130:     generatedFrom: 'TOOL_DEFINITIONS',\n131:     tools: record.tools,\n132:   });\n133: }\n134: \n135: /** Derive the deterministic tool ownership map from live tool definitions. */\n136: export function deriveToolOwnershipMap(\n137:   toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n138: ): ToolOwnershipMap {\n139:   return normalizeToolOwnershipMap({\n140:     schemaVersion: 1,\n141:     generatedFrom: 'TOOL_DEFINITIONS',\n142:     tools: toolDefinitions.map(deriveToolOwnershipEntry),\n143:   });\n144: }\n145: \n146: /** Serialize a derived ownership map for byte-identical generated output. */\n147: export function serializeToolOwnershipMap(map: ToolOwnershipMap = deriveToolOwnershipMap()): string {\n148:   return `${JSON.stringify(normalizeToolOwnershipMap(map), null, 2)}\\n`;\n149: }\n150: \n151: /** Compare a committed ownership map with a fresh derivation. */\n152: export function lintToolOwnershipMapDrift(\n153:   committedMap: unknown,\n154:   toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n155: ): ToolOwnershipDriftReport {\n156:   const expectedMap = deriveToolOwnershipMap(toolDefinitions);\n157:   const parsed = parseToolOwnershipMap(committedMap);\n158:   if (!parsed) {\n159:     return {\n160:       ok: false,\n161:       missingFromCommitted: expectedMap.tools.map((tool) => tool.name),\n162:       extraInCommitted: [],\n163:       changed: [],\n164:       expectedMap,\n165:     };\n166:   }\n167: \n168:   const expectedByName = new Map(expectedMap.tools.map((tool) => [tool.name, tool]));\n169:   const actualByName = new Map(parsed.tools.map((tool) => [tool.name, tool]));\n170:   const missingFromCommitted = expectedMap.tools\n171:     .filter((tool) => !actualByName.has(tool.name))\n172:     .map((tool) => tool.name);\n173:   const extraInCommitted = parsed.tools\n174:     .filter((tool) => !expectedByName.has(tool.name))\n175:     .map((tool) => tool.name);\n176:   const changed: ToolOwnershipDriftReport['changed'] = [];\n177:   const fields: Array<keyof Omit<ToolOwnershipEntry, 'name'>> = ['owner', 'stability', 'level', 'category'];\n178: \n179:   for (const expected of expectedMap.tools) {\n180:     const actual = actualByName.get(expected.name);\n181:     if (!actual) continue;\n182:     for (const field of fields) {\n183:       if (expected[field] !== actual[field]) {\n184:         changed.push({\n185:           name: expected.name,\n186:           field,\n187:           expected: expected[field],\n188:           actual: actual[field],\n189:         });\n190:       }\n191:     }\n192:   }\n193: \n194:   return {\n195:     ok: missingFromCommitted.length === 0 && extraInCommitted.length === 0 && changed.length === 0,\n196:     missingFromCommitted,\n197:     extraInCommitted,\n198:     changed,\n199:     expectedMap,\n200:   };\n201: }\n202: \n203: // ───────────────────────────────────────────────────────────────\n204: // 2. TOOL DEFINITIONS\n205: \n206: // ───────────────────────────────────────────────────────────────\n207: // L1 Orchestration - Unified entry point (Token Budget: 3500)\n208: const memoryContext: ToolDefinition = {\n209:   name: 'memory_context',\n210:   description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n211:   inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n212: };\n213: \n214: // L2: Core - Primary operations (Token Budget: 3500)\n215: const memorySearch: ToolDefinition = {\n216:   name: 'memory_search',\n217:   description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n218:   inputSchema: {\n219:     type: 'object',\n220:     additionalProperties: false,\n\n(Showing lines 1-220 of 955. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Tool Schemas\n// ───────────────────────────────────────────────────────────────\n// All MCP tool definitions (names, descriptions, input schemas).\n// Extracted from context-server.ts for maintainability.\nimport {\n  MAX_INGEST_PATHS,\n  MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS,\n} from './schemas/tool-input-schemas.js';\n\n/**\n * Re-export schema validation helpers used by the MCP tool entry points.\n */\nexport {\n  ToolSchemaValidationError,\n  formatZodError,\n  getToolSchema,\n  validateToolArgs,\n  getSchema,\n} from './schemas/tool-input-schemas.js';\n\n// ───────────────────────────────────────────────────────────────\n// 1. TYPES\n\n// ───────────────────────────────────────────────────────────────\n/**\n * Normalized definition for a single MCP tool and its JSON schema.\n */\nexport interface ToolDefinition {\n  name: string;\n  description: string;\n  inputSchema: Record<string, unknown>;\n  outputSchema?: Record<string, unknown>;\n}\n\nexport type ToolOwnershipStability = 'stable' | 'deprecated';\n\nexport interface ToolOwnershipEntry {\n  name: string;\n  owner: string;\n  stability: ToolOwnershipStability;\n  level: string;\n  category: string;\n}\n\nexport interface ToolOwnershipMap {\n  schemaVersion: 1;\n  generatedFrom: 'TOOL_DEFINITIONS';\n  tools: ToolOwnershipEntry[];\n}\n\nexport interface ToolOwnershipDriftReport {\n  ok: boolean;\n  missingFromCommitted: string[];\n  extraInCommitted: string[];\n  changed: Array<{\n    name: string;\n    field: keyof Omit<ToolOwnershipEntry, 'name'>;\n    expected: string;\n    actual: string;\n  }>;\n  expectedMap: ToolOwnershipMap;\n}\n\nconst TOOL_OWNER_BY_CATEGORY: Record<string, string> = Object.freeze({\n  Orchestration: 'memory-orchestration',\n  Core: 'memory-core',\n  Discovery: 'memory-discovery',\n  Mutation: 'memory-mutation',\n  Lifecycle: 'memory-lifecycle',\n  Analysis: 'memory-analysis',\n  Maintenance: 'memory-maintenance',\n});\n\nfunction readToolContract(definition: ToolDefinition): { level: string; category: string } {\n  const match = /^\\[([^:\\]]+):([^\\]]+)\\]/.exec(definition.description);\n  if (!match) {\n    return { level: 'unclassified', category: 'unclassified' };\n  }\n  return {\n    level: match[1] ?? 'unclassified',\n    category: match[2] ?? 'unclassified',\n  };\n}\n\nfunction deriveToolOwnershipEntry(definition: ToolDefinition): ToolOwnershipEntry {\n  const contract = readToolContract(definition);\n  return {\n    name: definition.name,\n    owner: TOOL_OWNER_BY_CATEGORY[contract.category] ?? 'memory-unclassified',\n    stability: /^\\[deprecated\\]/i.test(definition.description) ? 'deprecated' : 'stable',\n    level: contract.level,\n    category: contract.category,\n  };\n}\n\nfunction normalizeToolOwnershipMap(map: ToolOwnershipMap): ToolOwnershipMap {\n  return {\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: [...map.tools].sort((a, b) => a.name.localeCompare(b.name)),\n  };\n}\n\nfunction isToolOwnershipEntry(value: unknown): value is ToolOwnershipEntry {\n  if (!value || typeof value !== 'object' || Array.isArray(value)) return false;\n  const record = value as Record<string, unknown>;\n  return (\n    typeof record.name === 'string' &&\n    typeof record.owner === 'string' &&\n    (record.stability === 'stable' || record.stability === 'deprecated') &&\n    typeof record.level === 'string' &&\n    typeof record.category === 'string'\n  );\n}\n\nfunction parseToolOwnershipMap(value: unknown): ToolOwnershipMap | null {\n  let parsed: unknown;\n  try {\n    parsed = typeof value === 'string' ? JSON.parse(value) as unknown : value;\n  } catch (_error: unknown) {\n    return null;\n  }\n  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;\n  const record = parsed as Record<string, unknown>;\n  if (record.schemaVersion !== 1 || record.generatedFrom !== 'TOOL_DEFINITIONS') return null;\n  if (!Array.isArray(record.tools) || !record.tools.every(isToolOwnershipEntry)) return null;\n  return normalizeToolOwnershipMap({\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: record.tools,\n  });\n}\n\n/** Derive the deterministic tool ownership map from live tool definitions. */\nexport function deriveToolOwnershipMap(\n  toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n): ToolOwnershipMap {\n  return normalizeToolOwnershipMap({\n    schemaVersion: 1,\n    generatedFrom: 'TOOL_DEFINITIONS',\n    tools: toolDefinitions.map(deriveToolOwnershipEntry),\n  });\n}\n\n/** Serialize a derived ownership map for byte-identical generated output. */\nexport function serializeToolOwnershipMap(map: ToolOwnershipMap = deriveToolOwnershipMap()): string {\n  return `${JSON.stringify(normalizeToolOwnershipMap(map), null, 2)}\\n`;\n}\n\n/** Compare a committed ownership map with a fresh derivation. */\nexport function lintToolOwnershipMapDrift(\n  committedMap: unknown,\n  toolDefinitions: readonly ToolDefinition[] = TOOL_DEFINITIONS,\n): ToolOwnershipDriftReport {\n  const expectedMap = deriveToolOwnershipMap(toolDefinitions);\n  const parsed = parseToolOwnershipMap(committedMap);\n  if (!parsed) {\n    return {\n      ok: false,\n      missingFromCommitted: expectedMap.tools.map((tool) => tool.name),\n      extraInCommitted: [],\n      changed: [],\n      expectedMap,\n    };\n  }\n\n  const expectedByName = new Map(expectedMap.tools.map((tool) => [tool.name, tool]));\n  const actualByName = new Map(parsed.tools.map((tool) => [tool.name, tool]));\n  const missingFromCommitted = expectedMap.tools\n    .filter((tool) => !actualByName.has(tool.name))\n    .map((tool) => tool.name);\n  const extraInCommitted = parsed.tools\n    .filter((tool) => !expectedByName.has(tool.name))\n    .map((tool) => tool.name);\n  const changed: ToolOwnershipDriftReport['changed'] = [];\n  const fields: Array<keyof Omit<ToolOwnershipEntry, 'name'>> = ['owner', 'stability', 'level', 'category'];\n\n  for (const expected of expectedMap.tools) {\n    const actual = actualByName.get(expected.name);\n    if (!actual) continue;\n    for (const field of fields) {\n      if (expected[field] !== actual[field]) {\n        changed.push({\n          name: expected.name,\n          field,\n          expected: expected[field],\n          actual: actual[field],\n        });\n      }\n    }\n  }\n\n  return {\n    ok: missingFromCommitted.length === 0 && extraInCommitted.length === 0 && changed.length === 0,\n    missingFromCommitted,\n    extraInCommitted,\n    changed,\n    expectedMap,\n  };\n}\n\n// ───────────────────────────────────────────────────────────────\n// 2. TOOL DEFINITIONS\n\n// ───────────────────────────────────────────────────────────────\n// L1 Orchestration - Unified entry point (Token Budget: 3500)\nconst memoryContext: ToolDefinition = {\n  name: 'memory_context',\n  description: '[L1:Orchestration] Unified entry point for context retrieval with intent-aware routing. START HERE for most context-retrieval operations across indexed spec docs and constitutional rules. For session recovery, use mode: \\'resume\\' with profile: \\'resume\\'. Automatically detects task intent (add_feature, fix_bug, refactor, security_audit, understand, find_spec, find_decision) and routes to optimal retrieval strategy. Modes: auto (default), quick (trigger-based), deep (comprehensive), focused (intent-optimized), resume (session recovery). Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: { type: 'object', additionalProperties: false, properties: { input: { type: 'string', minLength: 1, description: 'The query, prompt, or context description (required)' }, mode: { type: 'string', enum: ['auto', 'quick', 'deep', 'focused', 'resume'], default: 'auto', description: 'Context retrieval mode: auto (detect intent), quick (fast triggers), deep (comprehensive search), focused (intent-optimized), resume (session recovery)' }, intent: { type: 'string', enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'], description: 'Explicit task intent. If not provided and mode=auto, intent is auto-detected from input.' }, specFolder: { type: 'string', description: 'Limit context to specific spec folder' }, tenantId: { type: 'string', description: 'Tenant boundary for governed retrieval when memory_context routes to memory_search.' }, userId: { type: 'string', description: 'User boundary for governed retrieval when memory_context routes to memory_search.' }, agentId: { type: 'string', description: 'Agent boundary for governed retrieval when memory_context routes to memory_search.' }, limit: { type: 'number', minimum: 1, maximum: 100, description: 'Maximum results (mode-specific defaults apply)' }, sessionId: { type: 'string', description: 'Optional server-issued session identifier for working-memory continuity. When provided, it must match an existing server-managed session or the call is rejected. Omit it to let the server generate a new session for this request.' }, enableDedup: { type: 'boolean', default: true, description: 'Enable session deduplication' }, includeContent: { type: 'boolean', default: false, description: 'Include full file content in results' }, includeTrace: { type: 'boolean', default: false, description: 'Include provenance-rich trace data (scores, source, trace) in results when underlying memory_search is called' }, tokenUsage: { type: 'number', minimum: 0.0, maximum: 1.0, description... (line truncated to 2000 chars)\n};\n\n// L2: Core - Primary operations (Token Budget: 3500)\nconst memorySearch: ToolDefinition = {\n  name: 'memory_search',\n  description: '[L2:Core] Search indexed spec-doc continuity semantically using vector similarity. Returns ranked results with similarity scores. Constitutional tier rules are ALWAYS included at the top of results (~2000 tokens max), regardless of query. Requires query (string), concepts (array of 2-5 strings), or cursor (string) for continuation pagination. Supports intent-aware retrieval (REQ-006) with task-specific weight adjustments. When implicit feedback logging is enabled, searches also emit shadow-only feedback signals such as search_shown and, for includeContent runs, result_cited. Token Budget: 3500. For code search, use mcp__mk_code_index__code_graph_query for structural code queries (callers, imports) and Grep for exact text or token searches.',\n  inputSchema: {\n    type: 'object',\n    additionalProperties: false,","lineStart":1,"lineEnd":220,"totalLines":955,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","time":{"start":1781762026203,"end":1781762026206}},"metadata":{"openai":{"itemId":"fc_005a99258a413e36016a3387ea1778819198a9aa0fab2cf8ad"}},"id":"prt_ed94aeaa0001pZDEvFjRxdWRuf","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94ab900001in5bFnJvP5kvTn"}}
{"type":"tool_use","timestamp":1781762026234,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_mIKfWhUkbnaZbAvc68ry7bH0","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Embeddings\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // PROVIDERS: EMBEDDINGS\n6: // Re-export from shared/ (canonical source)\n7: // Includes multi-provider support, task-specific functions, dynamic dimensions\n8: // MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n9: // Explicit named exports required for auditability.\n10: export {\n11:   generateEmbedding,\n12:   generateEmbeddingWithTimeout,\n13:   generateBatchEmbeddings,\n14:   generateDocumentEmbedding,\n15:   generateQueryEmbedding,\n16:   generateClusteringEmbedding,\n17:   buildWeightedDocumentText,\n18:   semanticChunk,\n19:   getEmbeddingDimension,\n20:   getModelName,\n21:   isModelLoaded,\n22:   getModelLoadTime,\n23:   getCurrentDevice,\n24:   getOptimalDevice,\n25:   getTaskPrefix,\n26:   preWarmModel,\n27:   getEmbeddingProfile,\n28:   getEmbeddingProfileAsync,\n29:   getProviderMetadata,\n30:   clearEmbeddingCache,\n31:   getEmbeddingCacheStats,\n32:   isProviderInitialized,\n33:   invalidateProviderSingleton,\n34:   shouldEagerWarmup,\n35:   getLazyLoadingStats,\n36:   validateApiKey,\n37:   VALIDATION_TIMEOUT_MS,\n38:   EMBEDDING_DIM,\n39:   EMBEDDING_TIMEOUT,\n40:   MAX_TEXT_LENGTH,\n41:   MODEL_NAME,\n42:   DEFAULT_MODEL_NAME,\n43:   TASK_PREFIX,\n44:   BATCH_DELAY_MS,\n45:   BATCH_RATE_LIMIT_DELAY,\n46:   RESERVED_OVERVIEW,\n47:   RESERVED_OUTCOME,\n48:   MIN_SECTION_LENGTH,\n49:   __embeddingCircuitTestables,\n50: } from '@spec-kit/shared/embeddings';\n\n(End of file - total 50 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embeddings\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// PROVIDERS: EMBEDDINGS\n// Re-export from shared/ (canonical source)\n// Includes multi-provider support, task-specific functions, dynamic dimensions\n// MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n// Explicit named exports required for auditability.\nexport {\n  generateEmbedding,\n  generateEmbeddingWithTimeout,\n  generateBatchEmbeddings,\n  generateDocumentEmbedding,\n  generateQueryEmbedding,\n  generateClusteringEmbedding,\n  buildWeightedDocumentText,\n  semanticChunk,\n  getEmbeddingDimension,\n  getModelName,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Embeddings\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// PROVIDERS: EMBEDDINGS\n// Re-export from shared/ (canonical source)\n// Includes multi-provider support, task-specific functions, dynamic dimensions\n// MAINTENANCE: Keep exports in sync with @spec-kit/shared/embeddings.\n// Explicit named exports required for auditability.\nexport {\n  generateEmbedding,\n  generateEmbeddingWithTimeout,\n  generateBatchEmbeddings,\n  generateDocumentEmbedding,\n  generateQueryEmbedding,\n  generateClusteringEmbedding,\n  buildWeightedDocumentText,\n  semanticChunk,\n  getEmbeddingDimension,\n  getModelName,\n  isModelLoaded,\n  getModelLoadTime,\n  getCurrentDevice,\n  getOptimalDevice,\n  getTaskPrefix,\n  preWarmModel,\n  getEmbeddingProfile,\n  getEmbeddingProfileAsync,\n  getProviderMetadata,\n  clearEmbeddingCache,\n  getEmbeddingCacheStats,\n  isProviderInitialized,\n  invalidateProviderSingleton,\n  shouldEagerWarmup,\n  getLazyLoadingStats,\n  validateApiKey,\n  VALIDATION_TIMEOUT_MS,\n  EMBEDDING_DIM,\n  EMBEDDING_TIMEOUT,\n  MAX_TEXT_LENGTH,\n  MODEL_NAME,\n  DEFAULT_MODEL_NAME,\n  TASK_PREFIX,\n  BATCH_DELAY_MS,\n  BATCH_RATE_LIMIT_DELAY,\n  RESERVED_OVERVIEW,\n  RESERVED_OUTCOME,\n  MIN_SECTION_LENGTH,\n  __embeddingCircuitTestables,\n} from '@spec-kit/shared/embeddings';","lineStart":1,"lineEnd":50,"totalLines":50,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/embeddings.ts","time":{"start":1781762026219,"end":1781762026230}},"metadata":{"openai":{"itemId":"fc_005a99258a413e36016a3387ea17808191b921f6171fd66796"}},"id":"prt_ed94aeae4001gBtHBdI86I1Xzw","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94ab900001in5bFnJvP5kvTn"}}
{"type":"tool_use","timestamp":1781762026234,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_N0TMkjGeTpqsphSRQdh0Zra4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","offset":280,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts</path>\n<type>file</type>\n<content>\n280:   if (failure.sanitized) {\n281:     console.error(context, {\n282:       sanitized: {\n283:         code: failure.code,\n284:         provider: failure.provider,\n285:         errorType: failure.errorType,\n286:       },\n287:       redacted: true,\n288:     });\n289:   }\n290: \n291:   return failure.publicMessage;\n292: }\n293: \n294: function claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n295:   const db = vectorIndex.getDb();\n296:   const previousStatus = getRetryStatus(memory);\n297:   if (!db || previousStatus === null) {\n298:     return { claimed: false, previousStatus };\n299:   }\n300: \n301:   const now = new Date().toISOString();\n302:   const retryCount = getRetryCountValue(memory);\n303:   const lastRetryAt = getLastRetryAtValue(memory);\n304:   // Concurrency: atomic claim prevents double-processing of retry jobs\n305:   const result = previousStatus === 'pending'\n306:     ? db.prepare(`\n307:         UPDATE memory_index\n308:         SET embedding_status = 'retry',\n309:             last_retry_at = ?,\n310:             updated_at = ?\n311:         WHERE id = ?\n312:           AND embedding_status = 'pending'\n313:           AND retry_count = ?\n314:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n315:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n316:     : db.prepare(`\n317:         UPDATE memory_index\n318:         SET last_retry_at = ?,\n319:             updated_at = ?\n320:         WHERE id = ?\n321:           AND embedding_status = 'retry'\n322:           AND retry_count = ?\n323:           AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n324:       `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n325: \n326:   return {\n327:     claimed: result.changes > 0,\n328:     previousStatus,\n329:   };\n330: }\n331: \n332: /* ───────────────────────────────────────────────────────────────\n333:    2. CONFIGURATION\n334: ──────────────────────────────────────────────────────────────── */\n335: \n336: // Backoff delays in milliseconds (1min, 5min, 15min)\n337: const BACKOFF_DELAYS: number[] = [\n338:   60 * 1000,\n339:   5 * 60 * 1000,\n340:   15 * 60 * 1000,\n341: ];\n342: \n343: const MAX_RETRIES = 3;\n344: const MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n345: const MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n346: \n347: // 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n348: // applies to a long-lived daemon without depending on the exact restart sequence. The\n349: // module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\n350: function getMaxRetryQueuePending(): number {\n351:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n352: }\n353: \n354: function getMaxRetryQueueAgeMs(): number {\n355:   return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n356: }\n357: \n358: // Background retry job configuration\n359: // Env-overrideable\n360: //   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)\n361: //   SPECKIT_RETRY_BATCH_SIZE  — items processed per batch (default 5)\n362: //   SPECKIT_RETRY_ENABLED     — set to \"false\" to disable the background loop entirely (default enabled)\n363: const BACKGROUND_JOB_CONFIG: BackgroundJobConfig = {\n364:   intervalMs: parseInt(process.env.SPECKIT_RETRY_INTERVAL_MS || String(5 * 60 * 1000), 10),\n365:   batchSize: parseInt(process.env.SPECKIT_RETRY_BATCH_SIZE || '5', 10),\n366:   enabled: (process.env.SPECKIT_RETRY_ENABLED ?? 'true') !== 'false',\n367: };\n368: \n369: // Background job state\n370: let backgroundJobInterval: ReturnType<typeof setInterval> | null = null;\n371: let backgroundJobRunning = false;\n372: let shutdownRequested = false;\n373: let retryAbortController: AbortController | null = null;\n374: \n375: // In-memory retry telemetry (never persisted to DB — read by getEmbeddingRetryStats)\n376: let lastBackgroundRunAt: string | null = null;\n377: let totalRetryAttempts = 0;\n378: const retryHealthSnapshot: EmbeddingRetryStats = {\n379:   pending: 0,\n380:   failed: 0,\n381:   retryAttempts: 0,\n382:   circuitBreakerOpen: false,\n383:   lastRun: null,\n384:   queueDepth: 0,\n385: };\n386: \n387: // circuit breaker — prevents the background retry job from\n388: // Hammering the embedding API when the provider is entirely down. After\n389: // PROVIDER_FAILURE_THRESHOLD consecutive failures across any items, the\n390: // Circuit opens for PROVIDER_COOLDOWN_MS, causing retryEmbedding to skip\n391: // The API call and return a transient error instead.\n392: const PROVIDER_FAILURE_THRESHOLD = 5;\n393: const PROVIDER_COOLDOWN_MS = 120_000; // 2 minutes\n394: const CIRCUIT_TRANSITION_WINDOW_MS = 10 * 60 * 1000; // 10 minutes\n395: const FLAPPING_THRESHOLD = 2;\n396: const circuitTransitions: number[] = [];\n397: \n398: let providerFailures = 0;\n399: let providerCircuitOpenedAt: number | null = null;\n400: \n401: function parsePositiveIntEnv(name: string, fallback: number): number {\n402:   const raw = process.env[name];\n403:   if (!raw) return fallback;\n404: \n405:   const parsed = Number.parseInt(raw, 10);\n406:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n407: }\n408: \n409: function recordCircuitTransition(): void {\n410:   const now = Date.now();\n411:   circuitTransitions.push(now);\n412:   while (circuitTransitions.length > 0 && circuitTransitions[0] < now - CIRCUIT_TRANSITION_WINDOW_MS) {\n413:     circuitTransitions.shift();\n414:   }\n415: }\n416: \n417: function getCircuitFlapState(): { flapping: boolean; transitionsInLast10Min: number } {\n418:   const now = Date.now();\n419:   const recent = circuitTransitions.filter(t => t >= now - CIRCUIT_TRANSITION_WINDOW_MS);\n420:   return { flapping: recent.length > FLAPPING_THRESHOLD, transitionsInLast10Min: recent.length };\n421: }\n422: \n423: function isProviderCircuitOpen(): boolean {\n424:   if (providerCircuitOpenedAt === null) return false;\n425:   if (Date.now() - providerCircuitOpenedAt >= PROVIDER_COOLDOWN_MS) {\n426:     providerCircuitOpenedAt = null;\n427:     providerFailures = 0;\n428:     recordCircuitTransition();\n429:     return false;\n430:   }\n431:   return true;\n432: }\n433: \n434: function recordProviderSuccess(): void {\n435:   providerFailures = 0;\n436:   providerCircuitOpenedAt = null;\n437:   retryHealthSnapshot.circuitBreakerOpen = false;\n438: }\n439: \n440: function recordProviderFailure(): void {\n441:   providerFailures++;\n442:   if (providerFailures >= PROVIDER_FAILURE_THRESHOLD && providerCircuitOpenedAt === null) {\n443:     providerCircuitOpenedAt = Date.now();\n444:     recordCircuitTransition();\n445:     console.warn(`[retry-manager] Embedding provider circuit breaker OPEN after ${providerFailures} consecutive failures. Cooldown: ${PROVIDER_COOLDOWN_MS}ms`);\n446:   }\n447:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n448: }\n449: \n450: function applyRetryHealthTransition(previousStatus: string | null | undefined, nextStatus: string): void {\n451:   if (previousStatus === 'pending') {\n452:     retryHealthSnapshot.pending = Math.max(0, retryHealthSnapshot.pending - 1);\n453:   }\n454: \n455:   if (previousStatus === 'pending' || previousStatus === 'retry') {\n456:     retryHealthSnapshot.queueDepth = Math.max(0, retryHealthSnapshot.queueDepth - 1);\n457:   }\n458: \n459:   if (nextStatus === 'pending') {\n460:     retryHealthSnapshot.pending++;\n461:     retryHealthSnapshot.queueDepth++;\n462:   }\n463: \n464:   if (nextStatus === 'retry') {\n465:     retryHealthSnapshot.queueDepth++;\n466:   }\n467: \n468:   if (previousStatus === 'failed') {\n469:     retryHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n470:   }\n471: \n472:   if (nextStatus === 'failed') {\n473:     retryHealthSnapshot.failed++;\n474:   }\n475: }\n476: \n477: function refreshRetryHealthSnapshot(stats: RetryStats): void {\n478:   retryHealthSnapshot.pending = stats.pending;\n479:   retryHealthSnapshot.failed = stats.failed;\n480:   retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n481:   retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n482:   retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n483:   retryHealthSnapshot.queueDepth = stats.queue_size;\n484: }\n485: \n486: function enforceRetryRetentionLimits(\n487:   maxPending = getMaxRetryQueuePending(),\n488:   maxAgeMs = getMaxRetryQueueAgeMs(),\n489:   now: Date = new Date(),\n490: ): { expired: number; overflow: number } {\n491:   const db = vectorIndex.getDb();\n492:   if (!db) return { expired: 0, overflow: 0 };\n493: \n494:   const nowIso = now.toISOString();\n495:   const oldestAllowedIso = new Date(now.getTime() - maxAgeMs).toISOString();\n496:   // Retention is non-destructive for never-attempted clean `pending` rows.\n497:   // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n498:   // subject to max-age expiry and pending-cap overflow; clean `pending` work waits to be\n499:   // embedded instead of being parked as `failed` before the drain can claim it.\n\n(Showing lines 280-499 of 1141. Use offset=500 to continue.)\n</content>","metadata":{"preview":"  if (failure.sanitized) {\n    console.error(context, {\n      sanitized: {\n        code: failure.code,\n        provider: failure.provider,\n        errorType: failure.errorType,\n      },\n      redacted: true,\n    });\n  }\n\n  return failure.publicMessage;\n}\n\nfunction claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n  const db = vectorIndex.getDb();\n  const previousStatus = getRetryStatus(memory);\n  if (!db || previousStatus === null) {\n    return { claimed: false, previousStatus };\n  }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"  if (failure.sanitized) {\n    console.error(context, {\n      sanitized: {\n        code: failure.code,\n        provider: failure.provider,\n        errorType: failure.errorType,\n      },\n      redacted: true,\n    });\n  }\n\n  return failure.publicMessage;\n}\n\nfunction claimRetryCandidate(memory: RetryMemoryRow): RetryClaimResult {\n  const db = vectorIndex.getDb();\n  const previousStatus = getRetryStatus(memory);\n  if (!db || previousStatus === null) {\n    return { claimed: false, previousStatus };\n  }\n\n  const now = new Date().toISOString();\n  const retryCount = getRetryCountValue(memory);\n  const lastRetryAt = getLastRetryAtValue(memory);\n  // Concurrency: atomic claim prevents double-processing of retry jobs\n  const result = previousStatus === 'pending'\n    ? db.prepare(`\n        UPDATE memory_index\n        SET embedding_status = 'retry',\n            last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'pending'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt)\n    : db.prepare(`\n        UPDATE memory_index\n        SET last_retry_at = ?,\n            updated_at = ?\n        WHERE id = ?\n          AND embedding_status = 'retry'\n          AND retry_count = ?\n          AND ((? IS NULL AND last_retry_at IS NULL) OR last_retry_at = ?)\n      `).run(now, now, memory.id, retryCount, lastRetryAt, lastRetryAt);\n\n  return {\n    claimed: result.changes > 0,\n    previousStatus,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\n// Backoff delays in milliseconds (1min, 5min, 15min)\nconst BACKOFF_DELAYS: number[] = [\n  60 * 1000,\n  5 * 60 * 1000,\n  15 * 60 * 1000,\n];\n\nconst MAX_RETRIES = 3;\nconst MAX_RETRY_QUEUE_PENDING = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\nconst MAX_RETRY_QUEUE_AGE_MS = parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n\n// 005-003: Read retry-retention limits at call-time so tuned env (SPECKIT_RETRY_QUEUE_MAX_*)\n// applies to a long-lived daemon without depending on the exact restart sequence. The\n// module-load constants above remain the boot-time snapshot exported for diagnostics/tests.\nfunction getMaxRetryQueuePending(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_PENDING', 1_000);\n}\n\nfunction getMaxRetryQueueAgeMs(): number {\n  return parsePositiveIntEnv('SPECKIT_RETRY_QUEUE_MAX_AGE_MS', 24 * 60 * 60 * 1000);\n}\n\n// Background retry job configuration\n// Env-overrideable\n//   SPECKIT_RETRY_INTERVAL_MS — interval between background batches (default 300000 = 5 min)\n//   SPECKIT_RETRY_BATCH_SIZE  — items processed per batch (default 5)\n//   SPECKIT_RETRY_ENABLED     — set to \"false\" to disable the background loop entirely (default enabled)\nconst BACKGROUND_JOB_CONFIG: BackgroundJobConfig = {\n  intervalMs: parseInt(process.env.SPECKIT_RETRY_INTERVAL_MS || String(5 * 60 * 1000), 10),\n  batchSize: parseInt(process.env.SPECKIT_RETRY_BATCH_SIZE || '5', 10),\n  enabled: (process.env.SPECKIT_RETRY_ENABLED ?? 'true') !== 'false',\n};\n\n// Background job state\nlet backgroundJobInterval: ReturnType<typeof setInterval> | null = null;\nlet backgroundJobRunning = false;\nlet shutdownRequested = false;\nlet retryAbortController: AbortController | null = null;\n\n// In-memory retry telemetry (never persisted to DB — read by getEmbeddingRetryStats)\nlet lastBackgroundRunAt: string | null = null;\nlet totalRetryAttempts = 0;\nconst retryHealthSnapshot: EmbeddingRetryStats = {\n  pending: 0,\n  failed: 0,\n  retryAttempts: 0,\n  circuitBreakerOpen: false,\n  lastRun: null,\n  queueDepth: 0,\n};\n\n// circuit breaker — prevents the background retry job from\n// Hammering the embedding API when the provider is entirely down. After\n// PROVIDER_FAILURE_THRESHOLD consecutive failures across any items, the\n// Circuit opens for PROVIDER_COOLDOWN_MS, causing retryEmbedding to skip\n// The API call and return a transient error instead.\nconst PROVIDER_FAILURE_THRESHOLD = 5;\nconst PROVIDER_COOLDOWN_MS = 120_000; // 2 minutes\nconst CIRCUIT_TRANSITION_WINDOW_MS = 10 * 60 * 1000; // 10 minutes\nconst FLAPPING_THRESHOLD = 2;\nconst circuitTransitions: number[] = [];\n\nlet providerFailures = 0;\nlet providerCircuitOpenedAt: number | null = null;\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction recordCircuitTransition(): void {\n  const now = Date.now();\n  circuitTransitions.push(now);\n  while (circuitTransitions.length > 0 && circuitTransitions[0] < now - CIRCUIT_TRANSITION_WINDOW_MS) {\n    circuitTransitions.shift();\n  }\n}\n\nfunction getCircuitFlapState(): { flapping: boolean; transitionsInLast10Min: number } {\n  const now = Date.now();\n  const recent = circuitTransitions.filter(t => t >= now - CIRCUIT_TRANSITION_WINDOW_MS);\n  return { flapping: recent.length > FLAPPING_THRESHOLD, transitionsInLast10Min: recent.length };\n}\n\nfunction isProviderCircuitOpen(): boolean {\n  if (providerCircuitOpenedAt === null) return false;\n  if (Date.now() - providerCircuitOpenedAt >= PROVIDER_COOLDOWN_MS) {\n    providerCircuitOpenedAt = null;\n    providerFailures = 0;\n    recordCircuitTransition();\n    return false;\n  }\n  return true;\n}\n\nfunction recordProviderSuccess(): void {\n  providerFailures = 0;\n  providerCircuitOpenedAt = null;\n  retryHealthSnapshot.circuitBreakerOpen = false;\n}\n\nfunction recordProviderFailure(): void {\n  providerFailures++;\n  if (providerFailures >= PROVIDER_FAILURE_THRESHOLD && providerCircuitOpenedAt === null) {\n    providerCircuitOpenedAt = Date.now();\n    recordCircuitTransition();\n    console.warn(`[retry-manager] Embedding provider circuit breaker OPEN after ${providerFailures} consecutive failures. Cooldown: ${PROVIDER_COOLDOWN_MS}ms`);\n  }\n  retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n}\n\nfunction applyRetryHealthTransition(previousStatus: string | null | undefined, nextStatus: string): void {\n  if (previousStatus === 'pending') {\n    retryHealthSnapshot.pending = Math.max(0, retryHealthSnapshot.pending - 1);\n  }\n\n  if (previousStatus === 'pending' || previousStatus === 'retry') {\n    retryHealthSnapshot.queueDepth = Math.max(0, retryHealthSnapshot.queueDepth - 1);\n  }\n\n  if (nextStatus === 'pending') {\n    retryHealthSnapshot.pending++;\n    retryHealthSnapshot.queueDepth++;\n  }\n\n  if (nextStatus === 'retry') {\n    retryHealthSnapshot.queueDepth++;\n  }\n\n  if (previousStatus === 'failed') {\n    retryHealthSnapshot.failed = Math.max(0, retryHealthSnapshot.failed - 1);\n  }\n\n  if (nextStatus === 'failed') {\n    retryHealthSnapshot.failed++;\n  }\n}\n\nfunction refreshRetryHealthSnapshot(stats: RetryStats): void {\n  retryHealthSnapshot.pending = stats.pending;\n  retryHealthSnapshot.failed = stats.failed;\n  retryHealthSnapshot.retryAttempts = totalRetryAttempts;\n  retryHealthSnapshot.circuitBreakerOpen = isProviderCircuitOpen();\n  retryHealthSnapshot.lastRun = lastBackgroundRunAt;\n  retryHealthSnapshot.queueDepth = stats.queue_size;\n}\n\nfunction enforceRetryRetentionLimits(\n  maxPending = getMaxRetryQueuePending(),\n  maxAgeMs = getMaxRetryQueueAgeMs(),\n  now: Date = new Date(),\n): { expired: number; overflow: number } {\n  const db = vectorIndex.getDb();\n  if (!db) return { expired: 0, overflow: 0 };\n\n  const nowIso = now.toISOString();\n  const oldestAllowedIso = new Date(now.getTime() - maxAgeMs).toISOString();\n  // Retention is non-destructive for never-attempted clean `pending` rows.\n  // Only rows that have actually been attempted (status='retry' OR retry_count>0) are\n  // subject to max-age expiry and pending-cap overflow; clean `pending` work waits to be\n  // embedded instead of being parked as `failed` before the drain can claim it.","lineStart":280,"lineEnd":499,"totalLines":1141,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781762026223,"end":1781762026231}},"metadata":{"openai":{"itemId":"fc_005a99258a413e36016a3387ea17848191b0f6cb99cd5172ce"}},"id":"prt_ed94aeaee001DyX9eVNGBO6Qwv","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94ab900001in5bFnJvP5kvTn"}}
{"type":"tool_use","timestamp":1781762026242,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_q6POl6UERz1TMommyRF0J9ts","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","offset":128,"limit":160},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts</path>\n<type>file</type>\n<content>\n128: /** Handle memory_ingest_start tool — begins batch ingestion of spec documents from disk.\n129:  * @param args - Ingest arguments (paths, scope, options)\n130:  * @returns MCP response with job ID and forecast\n131:  */\n132: async function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n133:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n134:   await checkDatabaseUpdated();\n135:   const governedIngest = requiresGovernedIngest(args);\n136:   const governanceDecision = validateGovernedIngest(args);\n137:   if (!governanceDecision.allowed) {\n138:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n139:   }\n140: \n141:   let paths = Array.isArray(args.paths)\n142:     ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n143:     : [];\n144: \n145:   if (paths.length === 0) {\n146:     throw new Error('paths must be a non-empty array of file paths');\n147:   }\n148: \n149:   if (paths.length > MAX_INGEST_PATHS) {\n150:     throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n151:   }\n152: \n153:   const overlengthPaths = paths\n154:     .filter((entry) => entry.length > MAX_PATH_LENGTH)\n155:     .map((entry) => ({\n156:       filePath: toPublicPathLabel(entry),\n157:       reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n158:     }));\n159:   const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n160:   if (withinLength.length !== paths.length) {\n161:     console.warn(\n162:       `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n163:     );\n164:   }\n165:   paths = withinLength;\n166: \n167:   if (paths.length === 0) {\n168:     throw new Error('paths must be a non-empty array of file paths');\n169:   }\n170: \n171:   const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n172:   const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n173:     ? path.resolve(process.cwd(), configuredMemoryRoot)\n174:     : path.resolve(path.dirname(DATABASE_PATH));\n175:   const allowedBasePaths = Array.from(\n176:     new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n177:   );\n178: \n179:   const normalizedPaths: string[] = [];\n180:   const invalidPaths: Array<{ input: string; reason: string }> = [];\n181: \n182:   for (const inputPath of paths) {\n183:     const trimmedPath = inputPath.trim();\n184: \n185:     if (hasTraversalSegment(trimmedPath)) {\n186:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n187:       continue;\n188:     }\n189: \n190:     const resolvedPath = path.resolve(trimmedPath);\n191: \n192:     const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n193:     if (hasTraversalAfterResolve) {\n194:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n195:       continue;\n196:     }\n197: \n198:     // Resolve symlinks so traversal checks apply to canonical targets.\n199:     let realPath: string;\n200:     try {\n201:       realPath = fs.realpathSync(resolvedPath);\n202:     } catch {\n203:       // Fall back to resolvedPath during pre-validation when target does not yet exist.\n204:       realPath = resolvedPath;\n205:     }\n206: \n207:     const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n208:       realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n209:     ));\n210:     if (!isWithinAllowedBase) {\n211:       invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n212:       continue;\n213:     }\n214: \n215:     normalizedPaths.push(realPath);\n216:   }\n217: \n218:   if (invalidPaths.length > 0) {\n219:     return createMCPErrorResponse({\n220:       tool: 'memory_ingest_start',\n221:       error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n222:       code: 'E_VALIDATION',\n223:       details: {\n224:         allowedBasePathCount: allowedBasePaths.length,\n225:         allowedPathPolicy: 'configured-memory-roots',\n226:         rejectedCount: invalidPaths.length,\n227:       },\n228:       recovery: {\n229:         hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n230:         actions: ['Use absolute paths rooted in the configured memory base path'],\n231:         severity: 'warning',\n232:       },\n233:     });\n234:   }\n235: \n236:   const deduplicatedPaths: string[] = [];\n237:   const seenPaths = new Set<string>();\n238:   let duplicatePathCount = 0;\n239: \n240:   for (const normalizedPath of normalizedPaths) {\n241:     if (seenPaths.has(normalizedPath)) {\n242:       duplicatePathCount++;\n243:       continue;\n244:     }\n245: \n246:     seenPaths.add(normalizedPath);\n247:     deduplicatedPaths.push(normalizedPath);\n248:   }\n249: \n250:   paths = deduplicatedPaths;\n251: \n252:   const jobId = createJobId();\n253:   const job = await createIngestJob({\n254:     id: jobId,\n255:     paths,\n256:     specFolder: args.specFolder,\n257:     governance: governedIngest ? governanceDecision : null,\n258:   });\n259: \n260:   enqueueIngestJob(job.id);\n261: \n262:   return createMCPSuccessResponse({\n263:     tool: 'memory_ingest_start',\n264:     summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n265:     data: {\n266:       jobId: job.id,\n267:       state: job.state,\n268:       filesTotal: job.filesTotal,\n269:       acceptedPathCount: paths.length,\n270:       rejectedPathCount: overlengthPaths.length,\n271:       ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n272:       ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n273:     },\n274:     hints: [\n275:       'Use memory_ingest_status with jobId to poll progress',\n276:       'Use memory_ingest_cancel with jobId to stop processing',\n277:       ...(duplicatePathCount > 0\n278:         ? ['Duplicate input paths were deduplicated before queueing']\n279:         : []),\n280:       ...(overlengthPaths.length > 0\n281:         ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n282:         : []),\n283:     ],\n284:   });\n285: }\n286: \n287: async function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {\n\n(Showing lines 128-287 of 375. Use offset=288 to continue.)\n</content>","metadata":{"preview":"/** Handle memory_ingest_start tool — begins batch ingestion of spec documents from disk.\n * @param args - Ingest arguments (paths, scope, options)\n * @returns MCP response with job ID and forecast\n */\nasync function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n  await checkDatabaseUpdated();\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  let paths = Array.isArray(args.paths)\n    ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n    : [];\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","text":"/** Handle memory_ingest_start tool — begins batch ingestion of spec documents from disk.\n * @param args - Ingest arguments (paths, scope, options)\n * @returns MCP response with job ID and forecast\n */\nasync function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n  await checkDatabaseUpdated();\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  let paths = Array.isArray(args.paths)\n    ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n    : [];\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  if (paths.length > MAX_INGEST_PATHS) {\n    throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n  }\n\n  const overlengthPaths = paths\n    .filter((entry) => entry.length > MAX_PATH_LENGTH)\n    .map((entry) => ({\n      filePath: toPublicPathLabel(entry),\n      reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n    }));\n  const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n  if (withinLength.length !== paths.length) {\n    console.warn(\n      `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n    );\n  }\n  paths = withinLength;\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n  const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n    ? path.resolve(process.cwd(), configuredMemoryRoot)\n    : path.resolve(path.dirname(DATABASE_PATH));\n  const allowedBasePaths = Array.from(\n    new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n  );\n\n  const normalizedPaths: string[] = [];\n  const invalidPaths: Array<{ input: string; reason: string }> = [];\n\n  for (const inputPath of paths) {\n    const trimmedPath = inputPath.trim();\n\n    if (hasTraversalSegment(trimmedPath)) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    const resolvedPath = path.resolve(trimmedPath);\n\n    const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n    if (hasTraversalAfterResolve) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    // Resolve symlinks so traversal checks apply to canonical targets.\n    let realPath: string;\n    try {\n      realPath = fs.realpathSync(resolvedPath);\n    } catch {\n      // Fall back to resolvedPath during pre-validation when target does not yet exist.\n      realPath = resolvedPath;\n    }\n\n    const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n      realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n    ));\n    if (!isWithinAllowedBase) {\n      invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n      continue;\n    }\n\n    normalizedPaths.push(realPath);\n  }\n\n  if (invalidPaths.length > 0) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_start',\n      error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n      code: 'E_VALIDATION',\n      details: {\n        allowedBasePathCount: allowedBasePaths.length,\n        allowedPathPolicy: 'configured-memory-roots',\n        rejectedCount: invalidPaths.length,\n      },\n      recovery: {\n        hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n        actions: ['Use absolute paths rooted in the configured memory base path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const deduplicatedPaths: string[] = [];\n  const seenPaths = new Set<string>();\n  let duplicatePathCount = 0;\n\n  for (const normalizedPath of normalizedPaths) {\n    if (seenPaths.has(normalizedPath)) {\n      duplicatePathCount++;\n      continue;\n    }\n\n    seenPaths.add(normalizedPath);\n    deduplicatedPaths.push(normalizedPath);\n  }\n\n  paths = deduplicatedPaths;\n\n  const jobId = createJobId();\n  const job = await createIngestJob({\n    id: jobId,\n    paths,\n    specFolder: args.specFolder,\n    governance: governedIngest ? governanceDecision : null,\n  });\n\n  enqueueIngestJob(job.id);\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_start',\n    summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n    data: {\n      jobId: job.id,\n      state: job.state,\n      filesTotal: job.filesTotal,\n      acceptedPathCount: paths.length,\n      rejectedPathCount: overlengthPaths.length,\n      ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n      ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n    },\n    hints: [\n      'Use memory_ingest_status with jobId to poll progress',\n      'Use memory_ingest_cancel with jobId to stop processing',\n      ...(duplicatePathCount > 0\n        ? ['Duplicate input paths were deduplicated before queueing']\n        : []),\n      ...(overlengthPaths.length > 0\n        ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n        : []),\n    ],\n  });\n}\n\nasync function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {","lineStart":128,"lineEnd":287,"totalLines":375,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","time":{"start":1781762026233,"end":1781762026241}},"metadata":{"openai":{"itemId":"fc_005a99258a413e36016a3387ea178c8191b4a6211f979af095"}},"id":"prt_ed94aeaf0001G7NMtmy9g9tQGb","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94ab900001in5bFnJvP5kvTn"}}
{"type":"tool_use","timestamp":1781762026244,"sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","part":{"type":"tool","tool":"read","callID":"call_bhWqJlVT2aceipHQ83XfURuP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Crud Delete\n3: // ────────────────────────────────────────────────────────────────\n4: \n5: /* ───────────────────────────────────────────────────────────────\n6:    IMPORTS\n7: ──────────────────────────────────────────────────────────────── */\n8: \n9: import { checkDatabaseUpdated } from '../core/index.js';\n10: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n11: import * as vectorIndex from '../lib/search/vector-index.js';\n12: import * as checkpoints from '../lib/storage/checkpoints.js';\n13: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n14: import * as causalEdges from '../lib/storage/causal-edges.js';\n15: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n16: import { toErrorMessage } from '../utils/index.js';\n17: \n18: import { recordHistory } from '../lib/storage/history.js';\n19: import { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: import { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n23: \n24: import type { MCPResponse } from './types.js';\n25: import type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n26: \n27: // Feature catalog: Single and folder delete (memory_delete)\n28: // Feature catalog: Validation feedback (memory_validate)\n29: // Feature catalog: Transaction wrappers on mutation handlers\n30: // Feature catalog: Per-memory history log\n31: \n32: \n33: /* ───────────────────────────────────────────────────────────────\n34:    CORE LOGIC\n35: ──────────────────────────────────────────────────────────────── */\n36: \n37: function parseMemoryId(rawId: number | string): number {\n38:   const numericId = typeof rawId === 'string'\n39:     ? Number.parseInt(rawId.trim(), 10)\n40:     : rawId;\n41: \n42:   if (\n43:     typeof numericId !== 'number' ||\n44:     !Number.isSafeInteger(numericId) ||\n45:     numericId <= 0 ||\n46:     (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n47:   ) {\n48:     throw new Error('Invalid memory ID: must be a positive integer');\n49:   }\n50: \n51:   return numericId;\n52: }\n53: \n54: function createDatabaseUnavailableDeleteResponse(): MCPResponse {\n55:   return createMCPErrorResponse({\n56:     tool: 'memory_delete',\n57:     error: 'Delete aborted: database unavailable',\n58:     code: 'E_DB_UNAVAILABLE',\n59:     details: { deleted: 0 },\n60:     recovery: {\n61:       hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n62:       actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n63:       severity: 'error',\n64:     },\n65:   });\n66: }\n67: \n68: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n69:   if (!database || !('prepare' in database)) return false;\n70:   try {\n71:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n72:     return columns.some((column) => column.name === 'deleted_at');\n73:   } catch {\n74:     return false;\n75:   }\n76: }\n77: \n78: function isSoftDeleteTombstonesEnabled(): boolean {\n79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n80: }\n81: \n82: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n83:   if (!isSoftDeleteTombstonesEnabled()) {\n84:     return vectorIndex.deleteMemory(memoryId, database);\n85:   }\n86: \n87:   if (!hasDeletedAtColumn(database)) {\n88:     return vectorIndex.deleteMemory(memoryId, database);\n89:   }\n90: \n91:   const deletedAt = new Date().toISOString();\n92:   const result = database.prepare(`\n93:     UPDATE memory_index\n94:     SET deleted_at = COALESCE(deleted_at, ?),\n95:         updated_at = datetime('now')\n96:     WHERE id = ?\n97:   `).run(deletedAt, memoryId);\n98:   return result.changes > 0;\n99: }\n100: \n101: /** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\n102: async function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n103:   await ensureMemoryRuntimeInitialized('handler:memory_delete');\n104:   await checkDatabaseUpdated();\n105: \n106:   const { id, specFolder, confirm } = args;\n107:   if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n108:   if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n109:   if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n110: \n111:   let numericId: number | null = null;\n112:   if (id !== undefined && id !== null) {\n113:     numericId = parseMemoryId(id);\n114:   }\n115: \n116:   let deletedCount = 0;\n117:   let checkpointName: string | null = null;\n118:   let mutationLedgerWarning: string | null = null;\n119:   const database = vectorIndex.getDb();\n120: \n121:   if (!database) {\n122:     // Unified DB-unavailable contract for single and bulk delete paths.\n123:     return createDatabaseUnavailableDeleteResponse();\n124:   }\n125: \n126:   if (numericId !== null) {\n127:     const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n128: \n129:     // transaction wrapper — wraps single-delete path (memory delete, causal edge\n130:     // Cleanup, ledger append) in a transaction for atomicity on error.\n131:     database.transaction(() => {\n132:       deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n133: \n134:       if (deletedCount > 0) {\n135:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n136:         // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n137:         try {\n138:           recordHistory(\n139:             numericId,\n140:             'DELETE',\n141:             singleSnapshot?.file_path ?? null,\n142:             null,\n143:             'mcp:memory_delete',\n144:             singleSnapshot?.spec_folder ?? null,\n145:           );\n146:         } catch (_histErr: unknown) {\n147:           // History recording is best-effort\n148:         }\n149: \n150:         causalEdges.init(database);\n151:         causalEdges.deleteEdgesForMemory(String(numericId), {\n152:           reason: 'memory row mutation cleanup',\n153:           command: 'memory-crud-delete.handleMemoryDelete',\n154:           restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n155:         });\n156:         // Use db-specific invalidation instead of the no-op global version\n157:         clearDegreeCacheForDb(database);\n158: \n159:         const ledgerRecorded = appendMutationLedgerSafe(database, {\n160:           mutationType: 'delete',\n161:           reason: 'memory_delete: single memory delete',\n162:           priorHash: singleSnapshot?.content_hash ?? null,\n163:           newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n164:           linkedMemoryIds: [numericId],\n165:           decisionMeta: {\n166:             tool: 'memory_delete',\n167:             bulk: false,\n168:             memoryId: numericId,\n169:             specFolder: singleSnapshot?.spec_folder ?? null,\n170:             filePath: singleSnapshot?.file_path ?? null,\n171:           },\n172:           actor: 'mcp:memory_delete',\n173:         });\n174:         if (!ledgerRecorded) {\n175:           mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n176:         }\n177:       }\n178:     })();\n179:   } else {\n180:     const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n181:     const deletedIds: number[] = [];\n182:     const hashById = new Map<number, MemoryHashSnapshot>();\n183: \n184:     if (database && 'prepare' in database) {\n185:       try {\n186:         const rows = database.prepare(`\n187:           SELECT id, content_hash, spec_folder, file_path\n188:           FROM memory_index\n189:           WHERE spec_folder = ?\n190:         `).all(specFolder as string) as MemoryHashSnapshot[];\n191: \n192:         for (const row of rows) {\n193:           hashById.set(row.id, row);\n194:         }\n195:       } catch (_err: unknown) {\n196:         // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n197:       }\n198:     }\n199: \n200:     if (memories.length > 0) {\n201:       const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n202:       const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n203:       try {\n204:         const checkpoint = checkpoints.createCheckpoint({\n205:           name: proposedCheckpointName,\n206:           specFolder,\n207:           metadata: {\n208:             reason: 'auto-checkpoint before bulk delete',\n209:             memoryCount: memories.length,\n210:           },\n211:         });\n212: \n213:         if (checkpoint) {\n214:           checkpointName = checkpoint.name;\n215:           console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n216:         } else {\n217:           console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n218:           checkpointName = null;\n219:         }\n220:       } catch (cpErr: unknown) {\n\n(Showing lines 1-220 of 344. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Crud Delete\n// ────────────────────────────────────────────────────────────────\n\n/* ───────────────────────────────────────────────────────────────\n   IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { appendMutationLedgerSafe, getMemoryHashSnapshot } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\nimport { clearDegreeCacheForDb } from '../lib/search/graph-search-fn.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { DeleteArgs, MemoryHashSnapshot } from './memory-crud-types.js';\n\n// Feature catalog: Single and folder delete (memory_delete)\n// Feature catalog: Validation feedback (memory_validate)\n// Feature catalog: Transaction wrappers on mutation handlers\n// Feature catalog: Per-memory history log\n\n\n/* ───────────────────────────────────────────────────────────────\n   CORE LOGIC\n──────────────────────────────────────────────────────────────── */\n\nfunction parseMemoryId(rawId: number | string): number {\n  const numericId = typeof rawId === 'string'\n    ? Number.parseInt(rawId.trim(), 10)\n    : rawId;\n\n  if (\n    typeof numericId !== 'number' ||\n    !Number.isSafeInteger(numericId) ||\n    numericId <= 0 ||\n    (typeof rawId === 'string' && !/^\\d+$/.test(rawId.trim()))\n  ) {\n    throw new Error('Invalid memory ID: must be a positive integer');\n  }\n\n  return numericId;\n}\n\nfunction createDatabaseUnavailableDeleteResponse(): MCPResponse {\n  return createMCPErrorResponse({\n    tool: 'memory_delete',\n    error: 'Delete aborted: database unavailable',\n    code: 'E_DB_UNAVAILABLE',\n    details: { deleted: 0 },\n    recovery: {\n      hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database',\n      actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n      severity: 'error',\n    },\n  });\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/** Handle memory_delete tool -- deletes a single memory by ID or bulk-deletes by spec folder. */\nasync function handleMemoryDelete(args: DeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_delete');\n  await checkDatabaseUpdated();\n\n  const { id, specFolder, confirm } = args;\n  if (!id && !specFolder) throw new Error('Either id or specFolder is required');\n  if (specFolder !== undefined && typeof specFolder !== 'string') throw new Error('specFolder must be a string');\n  if (confirm !== true) throw new Error('memory_delete requires confirm: true');\n\n  let numericId: number | null = null;\n  if (id !== undefined && id !== null) {\n    numericId = parseMemoryId(id);\n  }\n\n  let deletedCount = 0;\n  let checkpointName: string | null = null;\n  let mutationLedgerWarning: string | null = null;\n  const database = vectorIndex.getDb();\n\n  if (!database) {\n    // Unified DB-unavailable contract for single and bulk delete paths.\n    return createDatabaseUnavailableDeleteResponse();\n  }\n\n  if (numericId !== null) {\n    const singleSnapshot = getMemoryHashSnapshot(database, numericId);\n\n    // transaction wrapper — wraps single-delete path (memory delete, causal edge\n    // Cleanup, ledger append) in a transaction for atomicity on error.\n    database.transaction(() => {\n      deletedCount = tombstoneMemory(database, numericId) ? 1 : 0;\n\n      if (deletedCount > 0) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        // Placed after deleteMemory to avoid false audit rows for non-existent IDs.\n        try {\n          recordHistory(\n            numericId,\n            'DELETE',\n            singleSnapshot?.file_path ?? null,\n            null,\n            'mcp:memory_delete',\n            singleSnapshot?.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort\n        }\n\n        causalEdges.init(database);\n        causalEdges.deleteEdgesForMemory(String(numericId), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-crud-delete.handleMemoryDelete',\n          restoreContext: { memoryId: numericId, specFolder: singleSnapshot?.spec_folder ?? null },\n        });\n        // Use db-specific invalidation instead of the no-op global version\n        clearDegreeCacheForDb(database);\n\n        const ledgerRecorded = appendMutationLedgerSafe(database, {\n          mutationType: 'delete',\n          reason: 'memory_delete: single memory delete',\n          priorHash: singleSnapshot?.content_hash ?? null,\n          newHash: mutationLedger.computeHash(`delete:${numericId}:${Date.now()}`),\n          linkedMemoryIds: [numericId],\n          decisionMeta: {\n            tool: 'memory_delete',\n            bulk: false,\n            memoryId: numericId,\n            specFolder: singleSnapshot?.spec_folder ?? null,\n            filePath: singleSnapshot?.file_path ?? null,\n          },\n          actor: 'mcp:memory_delete',\n        });\n        if (!ledgerRecorded) {\n          mutationLedgerWarning = 'Mutation ledger append failed; audit trail may be incomplete.';\n        }\n      }\n    })();\n  } else {\n    const memories: { id: number }[] = vectorIndex.getMemoriesByFolder(specFolder as string);\n    const deletedIds: number[] = [];\n    const hashById = new Map<number, MemoryHashSnapshot>();\n\n    if (database && 'prepare' in database) {\n      try {\n        const rows = database.prepare(`\n          SELECT id, content_hash, spec_folder, file_path\n          FROM memory_index\n          WHERE spec_folder = ?\n        `).all(specFolder as string) as MemoryHashSnapshot[];\n\n        for (const row of rows) {\n          hashById.set(row.id, row);\n        }\n      } catch (_err: unknown) {\n        // Non-fatal — bulk delete proceeds without per-memory hash snapshots; ledger entries will lack prior hashes.\n      }\n    }\n\n    if (memories.length > 0) {\n      const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n      const proposedCheckpointName = `pre-cleanup-${timestamp}`;\n      try {\n        const checkpoint = checkpoints.createCheckpoint({\n          name: proposedCheckpointName,\n          specFolder,\n          metadata: {\n            reason: 'auto-checkpoint before bulk delete',\n            memoryCount: memories.length,\n          },\n        });\n\n        if (checkpoint) {\n          checkpointName = checkpoint.name;\n          console.error(`[memory-delete] Created checkpoint: ${checkpointName}`);\n        } else {\n          console.warn('[memory-delete] Checkpoint creation returned no checkpoint; proceeding without rollback.');\n          checkpointName = null;\n        }\n      } catch (cpErr: unknown) {","lineStart":1,"lineEnd":220,"totalLines":344,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts","time":{"start":1781762026240,"end":1781762026243}},"metadata":{"openai":{"itemId":"fc_005a99258a413e36016a3387ea17908191803ffbec56713ab2"}},"id":"prt_ed94aeaff0014gNvt4rFvTnMsa","sessionID":"ses_126b6d851ffe9oibwmWKJDkEOY","messageID":"msg_ed94ab900001in5bFnJvP5kvTn"}}
