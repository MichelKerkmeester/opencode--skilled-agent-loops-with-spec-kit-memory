    39	  excludeGlobs: readonly string[];
    40	  excludedAgentGlobs: readonly string[];
    41	  excludedCommandGlobs: readonly string[];
    42	  excludedSpecGlobs: readonly string[];
    43	  excludedPluginGlobs: readonly string[];
    44	}
    45	
    46	export interface ResolveIndexScopePolicyInput {
    47	  includeSkills?: boolean | string[];
    48	  includeAgents?: boolean;
    49	  includeCommands?: boolean;
    50	  includeSpecs?: boolean;
    51	  includePlugins?: boolean;
    52	  includeGlobs?: readonly string[];
    53	  excludeGlobs?: readonly string[];
    54	  env?: Record<string, string | undefined>;
    55	}
    56	
    57	const SKILL_NAME_PATTERN = /^sk-[a-z0-9-]+$/;
    58	
    59	function isEnabledEnvValue(value: string | undefined): boolean {
    60	  return value?.trim().toLowerCase() === 'true';
    61	}
    62	
    63	function isIndexScopePolicySource(value: string | null | undefined): value is IndexScopePolicySource {
    64	  return value === 'default' || value === 'env' || value === 'scan-argument';
    65	}
    66	
    67	function hasPerCallScopeOverride(input: ResolveIndexScopePolicyInput): boolean {
    68	  return input.includeSkills !== undefined
    69	    || input.includeAgents !== undefined
    70	    || input.includeCommands !== undefined
    71	    || input.includeSpecs !== undefined
    72	    || input.includePlugins !== undefined
    73	    || input.includeGlobs !== undefined
    74	    || input.excludeGlobs !== undefined;
    75	}
    76	
    77	function normalizeSkillList(values: readonly string[]): string[] {
    78	  return [...new Set(values.map(value => value.trim()).filter(value => SKILL_NAME_PATTERN.test(value)))].sort();
    79	}
