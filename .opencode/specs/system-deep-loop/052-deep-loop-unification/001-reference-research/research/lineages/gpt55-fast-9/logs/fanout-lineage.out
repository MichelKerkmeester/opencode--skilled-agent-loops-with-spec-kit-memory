{"type":"tool_use","timestamp":1783488786116,"sessionID":"ses_0bfcc9e59ffevWtcj5ONdHm47k","part":{"type":"tool","tool":"read","callID":"call_Kf7zARTzfK1KgEgPlpSNj3j3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","offset":1,"limit":190},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────────\n2: // MODULE: Deep-Loop Fallback Router\n3: // ───────────────────────────────────────────────────────────────────\n4: \n5: // ───────────────────────────────────────────────────────────────────\n6: // 1. TYPE DEFINITIONS\n7: // ───────────────────────────────────────────────────────────────────\n8: \n9: export type FallbackAction = 'fallback' | 'fail-fast';\n10: \n11: /** Executor result category used by typed fallback route selection. */\n12: export type FallbackRouteOutcome = 'success' | 'failure';\n13: \n14: /** Failure classes that can select a targeted fallback route. */\n15: export type FallbackFailureKind =\n16:   | 'timeout'\n17:   | 'auth-failure'\n18:   | 'quota-exceeded'\n19:   | 'executor-error'\n20:   | (string & {});\n21: \n22: /** Per-failure target map for typed fallback routes. */\n23: export interface FallbackFailureTargets {\n24:   readonly default?: string;\n25:   readonly [failureKind: string]: string | undefined;\n26: }\n27: \n28: /** Fallback decision returned to dispatch callers. */\n29: export type FallbackRoute = {\n30:   readonly action: FallbackAction;\n31:   readonly target?: string;\n32:   readonly reason: string;\n33:   readonly failureKind?: FallbackFailureKind;\n34:   readonly routeGroupId?: string;\n35:   readonly hopIndex?: number;\n36: };\n37: \n38: /** Runtime context attached to a routed fallback decision. */\n39: export interface FallbackRouteContext {\n40:   readonly outcome?: FallbackRouteOutcome;\n41:   readonly failureKind?: FallbackFailureKind;\n42:   readonly routeGroupId?: string;\n43:   readonly hopIndex?: number;\n44: }\n45: \n46: /** Model routing profile used by fallback graph resolution. */\n47: export type ModelProfile = {\n48:   readonly id: string;\n49:   readonly quota_pool: string;\n50:   readonly fallback_target: string | null;\n51:   readonly failureKind?: FallbackFailureKind;\n52:   readonly onSuccessTarget?: string | null;\n53:   readonly onFailureTarget?: string | FallbackFailureTargets | null;\n54:   readonly routeScope?: string;\n55: };\n56: \n57: /** Registry of model profiles available to the fallback router. */\n58: export type ModelRegistry = {\n59:   readonly models: readonly ModelProfile[];\n60: };\n61: \n62: /** Configuration for validating fallback graph edges before dispatch. */\n63: export interface FallbackGraphValidationOptions {\n64:   readonly maxHops?: number;\n65: }\n66: \n67: /** Validated router that binds a registry after graph preflight. */\n68: export interface FallbackRouter {\n69:   resolve(\n70:     failedModelId: string,\n71:     approvedModelIds?: readonly string[],\n72:     context?: FallbackRouteContext,\n73:   ): FallbackRoute;\n74: }\n75: \n76: type TargetKind = 'legacy' | 'success' | 'failure';\n77: \n78: interface TargetSelection {\n79:   readonly target: string | null;\n80:   readonly kind: TargetKind;\n81:   readonly failureKind?: FallbackFailureKind;\n82: }\n83: \n84: interface FallbackEdge {\n85:   readonly source: ModelProfile;\n86:   readonly targetId: string;\n87:   readonly kind: TargetKind;\n88:   readonly failureKind?: string;\n89: }\n90: \n91: const DEFAULT_MAX_HOPS = 1;\n92: \n93: // ───────────────────────────────────────────────────────────────────\n94: // 2. HELPERS\n95: // ───────────────────────────────────────────────────────────────────\n96: \n97: function findModel(registry: ModelRegistry, modelId: string): ModelProfile | undefined {\n98:   return registry.models.find((model) => model.id === modelId);\n99: }\n100: \n101: function isFailureTargets(\n102:   value: string | FallbackFailureTargets | null | undefined,\n103: ): value is FallbackFailureTargets {\n104:   return typeof value === 'object' && value !== null;\n105: }\n106: \n107: function selectFailureTarget(\n108:   failedModel: ModelProfile,\n109:   failureKind: FallbackFailureKind | undefined,\n110: ): TargetSelection {\n111:   const configuredTarget = failedModel.onFailureTarget;\n112:   const effectiveFailureKind = failureKind ?? failedModel.failureKind;\n113: \n114:   if (typeof configuredTarget === 'string') {\n115:     return { target: configuredTarget, kind: 'failure', failureKind: effectiveFailureKind };\n116:   }\n117: \n118:   if (isFailureTargets(configuredTarget)) {\n119:     const mappedTarget =\n120:       effectiveFailureKind === undefined\n121:         ? configuredTarget.default ?? null\n122:         : configuredTarget[effectiveFailureKind] ?? configuredTarget.default ?? null;\n123: \n124:     return {\n125:       target: mappedTarget,\n126:       kind: 'failure',\n127:       failureKind: effectiveFailureKind,\n128:     };\n129:   }\n130: \n131:   return {\n132:     target: failedModel.fallback_target,\n133:     kind: 'legacy',\n134:     failureKind: effectiveFailureKind,\n135:   };\n136: }\n137: \n138: function selectTarget(failedModel: ModelProfile, context: FallbackRouteContext | undefined): TargetSelection {\n139:   if (context?.outcome === 'success' && failedModel.onSuccessTarget !== undefined) {\n140:     return {\n141:       target: failedModel.onSuccessTarget,\n142:       kind: 'success',\n143:       failureKind: context.failureKind ?? failedModel.failureKind,\n144:     };\n145:   }\n146: \n147:   return selectFailureTarget(failedModel, context?.failureKind);\n148: }\n149: \n150: function createTrace(\n151:   failedModelId: string,\n152:   context: FallbackRouteContext | undefined,\n153: ): Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined {\n154:   if (context === undefined) return undefined;\n155: \n156:   return {\n157:     routeGroupId: context.routeGroupId ?? `${failedModelId}:${context.failureKind ?? context.outcome ?? 'fallback'}`,\n158:     hopIndex: context.hopIndex ?? 0,\n159:   };\n160: }\n161: \n162: function withRouteMetadata(\n163:   route: FallbackRoute,\n164:   trace: Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined,\n165:   failureKind: FallbackFailureKind | undefined,\n166: ): FallbackRoute {\n167:   if (trace === undefined && failureKind === undefined) return route;\n168: \n169:   return {\n170:     ...route,\n171:     ...(failureKind === undefined ? {} : { failureKind }),\n172:     ...trace,\n173:   };\n174: }\n175: \n176: function describeTargetKind(selection: TargetSelection): string {\n177:   if (selection.kind === 'success') return 'success target';\n178:   if (selection.kind === 'failure') return 'failure target';\n179:   return 'fallback';\n180: }\n181: \n182: function collectTargets(profile: ModelProfile): readonly FallbackEdge[] {\n183:   const edges: FallbackEdge[] = [];\n184: \n185:   if (profile.fallback_target !== null) {\n186:     edges.push({ source: profile, targetId: profile.fallback_target, kind: 'legacy' });\n187:   }\n188: \n189:   if (profile.onSuccessTarget !== undefined && profile.onSuccessTarget !== null) {\n190:     edges.push({ source: profile, targetId: profile.onSuccessTarget, kind: 'success' });\n\n(Showing lines 1-190 of 431. Use offset=191 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Fallback Router\n// ───────────────────────────────────────────────────────────────────\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport type FallbackAction = 'fallback' | 'fail-fast';\n\n/** Executor result category used by typed fallback route selection. */\nexport type FallbackRouteOutcome = 'success' | 'failure';\n\n/** Failure classes that can select a targeted fallback route. */\nexport type FallbackFailureKind =\n  | 'timeout'\n  | 'auth-failure'\n  | 'quota-exceeded'\n  | 'executor-error'\n  | (string & {});","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","text":"// ───────────────────────────────────────────────────────────────────\n// MODULE: Deep-Loop Fallback Router\n// ───────────────────────────────────────────────────────────────────\n\n// ───────────────────────────────────────────────────────────────────\n// 1. TYPE DEFINITIONS\n// ───────────────────────────────────────────────────────────────────\n\nexport type FallbackAction = 'fallback' | 'fail-fast';\n\n/** Executor result category used by typed fallback route selection. */\nexport type FallbackRouteOutcome = 'success' | 'failure';\n\n/** Failure classes that can select a targeted fallback route. */\nexport type FallbackFailureKind =\n  | 'timeout'\n  | 'auth-failure'\n  | 'quota-exceeded'\n  | 'executor-error'\n  | (string & {});\n\n/** Per-failure target map for typed fallback routes. */\nexport interface FallbackFailureTargets {\n  readonly default?: string;\n  readonly [failureKind: string]: string | undefined;\n}\n\n/** Fallback decision returned to dispatch callers. */\nexport type FallbackRoute = {\n  readonly action: FallbackAction;\n  readonly target?: string;\n  readonly reason: string;\n  readonly failureKind?: FallbackFailureKind;\n  readonly routeGroupId?: string;\n  readonly hopIndex?: number;\n};\n\n/** Runtime context attached to a routed fallback decision. */\nexport interface FallbackRouteContext {\n  readonly outcome?: FallbackRouteOutcome;\n  readonly failureKind?: FallbackFailureKind;\n  readonly routeGroupId?: string;\n  readonly hopIndex?: number;\n}\n\n/** Model routing profile used by fallback graph resolution. */\nexport type ModelProfile = {\n  readonly id: string;\n  readonly quota_pool: string;\n  readonly fallback_target: string | null;\n  readonly failureKind?: FallbackFailureKind;\n  readonly onSuccessTarget?: string | null;\n  readonly onFailureTarget?: string | FallbackFailureTargets | null;\n  readonly routeScope?: string;\n};\n\n/** Registry of model profiles available to the fallback router. */\nexport type ModelRegistry = {\n  readonly models: readonly ModelProfile[];\n};\n\n/** Configuration for validating fallback graph edges before dispatch. */\nexport interface FallbackGraphValidationOptions {\n  readonly maxHops?: number;\n}\n\n/** Validated router that binds a registry after graph preflight. */\nexport interface FallbackRouter {\n  resolve(\n    failedModelId: string,\n    approvedModelIds?: readonly string[],\n    context?: FallbackRouteContext,\n  ): FallbackRoute;\n}\n\ntype TargetKind = 'legacy' | 'success' | 'failure';\n\ninterface TargetSelection {\n  readonly target: string | null;\n  readonly kind: TargetKind;\n  readonly failureKind?: FallbackFailureKind;\n}\n\ninterface FallbackEdge {\n  readonly source: ModelProfile;\n  readonly targetId: string;\n  readonly kind: TargetKind;\n  readonly failureKind?: string;\n}\n\nconst DEFAULT_MAX_HOPS = 1;\n\n// ───────────────────────────────────────────────────────────────────\n// 2. HELPERS\n// ───────────────────────────────────────────────────────────────────\n\nfunction findModel(registry: ModelRegistry, modelId: string): ModelProfile | undefined {\n  return registry.models.find((model) => model.id === modelId);\n}\n\nfunction isFailureTargets(\n  value: string | FallbackFailureTargets | null | undefined,\n): value is FallbackFailureTargets {\n  return typeof value === 'object' && value !== null;\n}\n\nfunction selectFailureTarget(\n  failedModel: ModelProfile,\n  failureKind: FallbackFailureKind | undefined,\n): TargetSelection {\n  const configuredTarget = failedModel.onFailureTarget;\n  const effectiveFailureKind = failureKind ?? failedModel.failureKind;\n\n  if (typeof configuredTarget === 'string') {\n    return { target: configuredTarget, kind: 'failure', failureKind: effectiveFailureKind };\n  }\n\n  if (isFailureTargets(configuredTarget)) {\n    const mappedTarget =\n      effectiveFailureKind === undefined\n        ? configuredTarget.default ?? null\n        : configuredTarget[effectiveFailureKind] ?? configuredTarget.default ?? null;\n\n    return {\n      target: mappedTarget,\n      kind: 'failure',\n      failureKind: effectiveFailureKind,\n    };\n  }\n\n  return {\n    target: failedModel.fallback_target,\n    kind: 'legacy',\n    failureKind: effectiveFailureKind,\n  };\n}\n\nfunction selectTarget(failedModel: ModelProfile, context: FallbackRouteContext | undefined): TargetSelection {\n  if (context?.outcome === 'success' && failedModel.onSuccessTarget !== undefined) {\n    return {\n      target: failedModel.onSuccessTarget,\n      kind: 'success',\n      failureKind: context.failureKind ?? failedModel.failureKind,\n    };\n  }\n\n  return selectFailureTarget(failedModel, context?.failureKind);\n}\n\nfunction createTrace(\n  failedModelId: string,\n  context: FallbackRouteContext | undefined,\n): Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined {\n  if (context === undefined) return undefined;\n\n  return {\n    routeGroupId: context.routeGroupId ?? `${failedModelId}:${context.failureKind ?? context.outcome ?? 'fallback'}`,\n    hopIndex: context.hopIndex ?? 0,\n  };\n}\n\nfunction withRouteMetadata(\n  route: FallbackRoute,\n  trace: Pick<FallbackRoute, 'routeGroupId' | 'hopIndex'> | undefined,\n  failureKind: FallbackFailureKind | undefined,\n): FallbackRoute {\n  if (trace === undefined && failureKind === undefined) return route;\n\n  return {\n    ...route,\n    ...(failureKind === undefined ? {} : { failureKind }),\n    ...trace,\n  };\n}\n\nfunction describeTargetKind(selection: TargetSelection): string {\n  if (selection.kind === 'success') return 'success target';\n  if (selection.kind === 'failure') return 'failure target';\n  return 'fallback';\n}\n\nfunction collectTargets(profile: ModelProfile): readonly FallbackEdge[] {\n  const edges: FallbackEdge[] = [];\n\n  if (profile.fallback_target !== null) {\n    edges.push({ source: profile, targetId: profile.fallback_target, kind: 'legacy' });\n  }\n\n  if (profile.onSuccessTarget !== undefined && profile.onSuccessTarget !== null) {\n    edges.push({ source: profile, targetId: profile.onSuccessTarget, kind: 'success' });","lineStart":1,"lineEnd":190,"totalLines":431,"truncated":true}},"title":".opencode/skills/deep-loop-runtime/lib/deep-loop/fallback-router.ts","time":{"start":1783488786112,"end":1783488786115}},"metadata":{"openai":{"itemId":"fc_0c1200d43c53d268016a4de112136c8191b8689d18bea81260"}},"id":"prt_f40372ebc00101DiwrwLHeE4f5","sessionID":"ses_0bfcc9e59ffevWtcj5ONdHm47k","messageID":"msg_f40370c24001k5dvmKtKJqLMfu"}}
