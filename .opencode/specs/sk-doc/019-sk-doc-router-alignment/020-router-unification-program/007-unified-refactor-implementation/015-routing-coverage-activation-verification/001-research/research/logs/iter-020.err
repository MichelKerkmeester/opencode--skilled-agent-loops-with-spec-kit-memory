   640	      tokenCap: maxTokens,
   641	      retryable: metadata.retryable ?? true,
   642	      exitCode: metadata.exitCode ?? ADVISOR_CLI_RETRYABLE_EXIT,
   643	      subprocessInvoked,
   644	      ...metadata,
   645	    },
   646	  });
