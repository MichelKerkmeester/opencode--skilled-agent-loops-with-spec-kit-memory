: /** Failure classes that can select a targeted fallback route. */\n\n  Line 22: /** Per-failure target map for typed fallback routes. */\n\n  Line 38: /** Runtime context attached to a routed fallback decision. */\n\n  Line 46: /** Model routing profile used by fallback graph resolution. */\n\n  Line 50:   readonly fallback_target: string | null;\n\n  Line 57: /** Registry of model profiles available to the fallback router. */\n\n  Line 59:   readonly models: readonly ModelProfile[];\n\n  Line 62: /** Configuration for validating fallback graph edges before dispatch. */\n\n  Line 97: function findModel(registry: ModelRegistry, modelId: string): ModelProfile | undefined {\n\n  Line 98:   return registry.models.find((model) => model.id === modelId);\n\n  Line 132:     target: failedModel.fallback_target,\n\n  Line 157:     routeGroupId: context.routeGroupId ?? `${failedModelId}:${context.failureKind ?? context.outcome ?? 'fallback'}`,\n\n  Line 179:   return 'fallback';\n\n  Line 185:   if (profile.fallback_target !== null) {\n\n  Line 186:     edges.push({ source: profile, targetId: profile.fallback_target, kind: 'legacy' });\n\n  Line 212:   return registry.models.flatMap((profile) => collectTargets(profile));\n\n  Line 218:       throw new Error(`fallback graph references missing ${edge.kind} target ${edge.targetId} from ${edge.source.id}`);\n\n  Line 230:       throw new Error(`fallback graph cross-scope route rejected from ${edge.source.id} to ${target.id}`);\n\n  Line 244:   function visit(modelId: string, path: readonly string[]): void {\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"fallback|GLM|glm|MiMo|mimo|fallback-router|fallbackRouter|retry|model","time":{"start":1783487874150,"end":1783487874163}},"metadata":{"openai":{"itemId":"fc_0107759b0c9b86e6016a4ddd81fc3c81918bcedbaaca5a8156"}},"id":"prt_f4029440a0014oWITn6ngKs66O","sessionID":"ses_0bfeb66caffeOOxX7Bbz2N0h6m","messa