{"type":"tool_use","timestamp":1782887474220,"sessionID":"ses_0e3a7cbd6ffex3B3McvCZaMchj","part":{"type":"tool","tool":"read","callID":"call_f75f1312e37c4485bf429bf3","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","offset":2655,"limit":66},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs</path>\n<type>file</type>\n<content>\n2655: }\n2656: \n2657: // ─────────────────────────────────────────────────────────────────────────────\n2658: // 5. CLI ENTRY POINT\n2659: // ─────────────────────────────────────────────────────────────────────────────\n2660: \n2661: if (require.main === module) {\n2662:   const args = process.argv.slice(2);\n2663:   const lenient = args.includes('--lenient');\n2664:   const emitResourceMapOutput = args.includes('--emit-resource-map');\n2665:   const requireExistingState = args.includes('--require-existing-state');\n2666:   const positional = args.filter((arg) => !arg.startsWith('--'));\n2667:   const specFolder = positional[0];\n2668: \n2669:   if (!specFolder) {\n2670:     process.stderr.write(\n2671:       'Usage: node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs <spec-folder> [--lenient] [--emit-resource-map]\\n',\n2672:     );\n2673:     process.exit(1);\n2674:   }\n2675: \n2676:   try {\n2677:     const result = reduceResearchState(specFolder, {\n2678:       write: true,\n2679:       lenient,\n2680:       emitResourceMap: emitResourceMapOutput,\n2681:       requireExistingState,\n2682:     });\n2683:     process.stdout.write(\n2684:       `${JSON.stringify(\n2685:         {\n2686:           registryPath: result.registryPath,\n2687:           dashboardPath: result.dashboardPath,\n2688:           strategyPath: result.strategyPath,\n2689:           iterationsCompleted: result.registry.metrics.iterationsCompleted,\n2690:           corruptionCount: result.corruptionWarnings.length,\n2691:           resourceMapPath: emitResourceMapOutput ? result.resourceMapPath : null,\n2692:           resourceMapSkipped: emitResourceMapOutput ? result.resourceMapSkipped : null,\n2693:           resourceMapSkipReason: emitResourceMapOutput ? result.resourceMapSkipReason : null,\n2694:         },\n2695:         null,\n2696:         2,\n2697:       )}\\n`,\n2698:     );\n2699:     // Fail-closed exit semantics matching deep-review.\n2700:     if (result.hasCorruption && !lenient) {\n2701:       process.exit(2);\n2702:     }\n2703:   } catch (error) {\n2704:     if (error && error.code === 'STATE_RECOVERY_REFUSED') {\n2705:       process.stderr.write(`${error.message}\\n`);\n2706:       process.exit(2);\n2707:     }\n2708:     if (error && error.code === 'STATE_CORRUPTION') {\n2709:       process.stderr.write(`${error.message}\\n`);\n2710:       process.exit(2);\n2711:     }\n2712:     process.stderr.write(`[deep-research] reducer failed: ${error instanceof Error ? error.message : String(error)}\\n`);\n2713:     process.exit(3);\n2714:   }\n2715: }\n2716: \n2717: // ─────────────────────────────────────────────────────────────────────────────\n2718: // 6. EXPORTS\n2719: // ─────────────────────────────────────────────────────────────────────────────\n2720: \n\n(Showing lines 2655-2720 of 2737. Use offset=2721 to continue.)\n</content>","metadata":{"preview":"}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. CLI ENTRY POINT\n// ─────────────────────────────────────────────────────────────────────────────\n\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const lenient = args.includes('--lenient');\n  const emitResourceMapOutput = args.includes('--emit-resource-map');\n  const requireExistingState = args.includes('--require-existing-state');\n  const positional = args.filter((arg) => !arg.startsWith('--'));\n  const specFolder = positional[0];\n\n  if (!specFolder) {\n    process.stderr.write(\n      'Usage: node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs <spec-folder> [--lenient] [--emit-resource-map]\\n',\n    );\n    process.exit(1);\n  }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","text":"}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. CLI ENTRY POINT\n// ─────────────────────────────────────────────────────────────────────────────\n\nif (require.main === module) {\n  const args = process.argv.slice(2);\n  const lenient = args.includes('--lenient');\n  const emitResourceMapOutput = args.includes('--emit-resource-map');\n  const requireExistingState = args.includes('--require-existing-state');\n  const positional = args.filter((arg) => !arg.startsWith('--'));\n  const specFolder = positional[0];\n\n  if (!specFolder) {\n    process.stderr.write(\n      'Usage: node .opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs <spec-folder> [--lenient] [--emit-resource-map]\\n',\n    );\n    process.exit(1);\n  }\n\n  try {\n    const result = reduceResearchState(specFolder, {\n      write: true,\n      lenient,\n      emitResourceMap: emitResourceMapOutput,\n      requireExistingState,\n    });\n    process.stdout.write(\n      `${JSON.stringify(\n        {\n          registryPath: result.registryPath,\n          dashboardPath: result.dashboardPath,\n          strategyPath: result.strategyPath,\n          iterationsCompleted: result.registry.metrics.iterationsCompleted,\n          corruptionCount: result.corruptionWarnings.length,\n          resourceMapPath: emitResourceMapOutput ? result.resourceMapPath : null,\n          resourceMapSkipped: emitResourceMapOutput ? result.resourceMapSkipped : null,\n          resourceMapSkipReason: emitResourceMapOutput ? result.resourceMapSkipReason : null,\n        },\n        null,\n        2,\n      )}\\n`,\n    );\n    // Fail-closed exit semantics matching deep-review.\n    if (result.hasCorruption && !lenient) {\n      process.exit(2);\n    }\n  } catch (error) {\n    if (error && error.code === 'STATE_RECOVERY_REFUSED') {\n      process.stderr.write(`${error.message}\\n`);\n      process.exit(2);\n    }\n    if (error && error.code === 'STATE_CORRUPTION') {\n      process.stderr.write(`${error.message}\\n`);\n      process.exit(2);\n    }\n    process.stderr.write(`[deep-research] reducer failed: ${error instanceof Error ? error.message : String(error)}\\n`);\n    process.exit(3);\n  }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 6. EXPORTS\n// ─────────────────────────────────────────────────────────────────────────────\n","lineStart":2655,"lineEnd":2720,"totalLines":2737,"truncated":true}},"title":".opencode/skills/deep-loop-workflows/deep-research/scripts/reduce-state.cjs","time":{"start":1782887474214,"end":1782887474218}},"id":"prt_f1c5fe425001KNLOZADOcDTbJ0","sessionID":"ses_0e3a7cbd6ffex3B3McvCZaMchj","messageID":"msg_f1c5fce7c001q7ZOBA8Lk73xxM"}}
