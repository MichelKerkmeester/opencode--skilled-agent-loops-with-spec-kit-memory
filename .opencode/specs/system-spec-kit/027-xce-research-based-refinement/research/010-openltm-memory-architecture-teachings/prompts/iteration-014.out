 = {},\n403: ): Buffer | null {\n404:   const profileKey = normalizeProfileKey(options.profileKey);\n405:   const inputKind = normalizeInputKind(options.inputKind);\n406:   const hasScopedLookup = options.profileKey !== undefined || options.inputKind !== undefined;\n407:   const row = hasScopedLookup\n408:     ? (db.prepare(\n409:       `SELECT rowid, embedding\n410:        FROM ${cacheTable(db)}\n411:        WHERE content_hash = ?\n412:          AND profile_key = ?\n413:          AND input_kind = ?\n414:          AND model_id = ?\n415:          AND dimensions = ?`,\n416:     ) as Database.Statement).get(contentHash, profileKey, inputKind, modelId, dimensions) as\n417:       | { rowid: number; embedding: Buffer }\n418:       | undefined\n419:     : (db.prepare(\n420:       `SELECT rowid, embedding\n421:        FROM ${cacheTable(db)}\n422:        WHERE content_hash = ?\n423:          AND model_id = ?\n424:          AND dimensions = ?\n425:        ORDER BY\n426:          CASE WHEN profile_key = '' AND input_kind = 'document' THEN 0 ELSE 1 END,\n427:          last_used_at DESC\n428:        LIMIT 1`,\n429:     ) as Database.Statement).get(contentHash, modelId, dimensions) as\n430:       | { rowid: number; embedding: Buffer }\n431:       | undefined;\n432: \n433:   if (!row) {\n434:     cacheMisses += 1;\n435:     return null;\n436:   }\n437: \n438:   cacheHits += 1;\n439: \n440:   // Update last_used_at on cache hit\n441:   (db.prepare(\n442:     `UPDATE ${cacheTable(db)} SET last_used_at = datetime('now') WHERE rowid = ?`,\n443:   ) as Database.Statement).run(row.rowid);\n444: \n445:   return row.embedding;\n446: }\n447: \n448: /* --- 5. CACHE STORE --- */\n449: \n450: /**\n451:  * Store an embedding in the cache.\n452:  * Uses INSERT OR REPLACE so duplicate (content_hash, model_id, dimensions)\n453:  * rows are overwritten with the latest embedding, while allowing multiple\n454:  * dimension variants to coexist for the same content/model pair.\n455:  *\n456:  * NOTE: The count-then-delete below is a non-transactional read-then-update\n457:  * pattern. Under concurrent writers the cache may briefly exceed\n458:  * MAX_CACHE_ENTRIES, but this is acceptable for a performance cache — the\n459:  * next store call will trim the overshoot.\n460:  *\n461:  * @param db - better-sqlite3 database instance\n462:  * @param contentHash - SHA-256 hex digest of the content\n463:  * @param modelId - Embedding model identifier\n464:  * @param embedding - Raw embedding buffer\n465:  * @param dimensions - Number of embedding dimensions\n466:  */\n467: function storeEmbedding(\n468:   db: Database.Database,\n469:   contentHash: string,\n470:   modelId: string,\n471:   embedding: Buffer,\n472:   dimensions: number,\n473:   options: EmbeddingCacheKeyOptions = {},\n474: ): void {\n475:   const profileKey = normalizeProfileKey(options.profileKey);\n476:   const inputKind = normalizeInputKind(options.inputKind);\n477: \n478:   (db.prepare(\n479:     `INSERT INTO ${cacheTable(db)}\n480:        (content_hash, profile_key, input_kind, model_id, embedding, dimensions, last_used_at)\n481:      VALUES (?, ?, ?, ?, ?, ?, datetime('now'))\n482:      ON CONFLICT(content_hash, profile_key, input_kind, model_id, dimensions)\n483:      DO UPDATE SET\n484:        embedding = excluded.embedding,\n485:        last_used_at = datetime('now')`,\n486:   ) as Database.Statement).run(contentHash, profileKey, inputKind, modelId, embedding, dimensions);\n487: \n488:   evictIfOverBudget(db);\n489: }\n490: \n491: /* --- 6. LRU EVICTION --- */\n492: \n493: /**\n494:  * Evict rows until byte and secondary entry budgets are satisfied.\n495:  *\n496:  * @param db - better-sqlite3 database instance\n497:  * @returns Number of evicted rows\n498:  */\n499: function evictIfOverBudget(db: Database.Database): number {\n500:   const budgets = getCacheBudgetConfig();\n501:   let deleted = 0;\n502: \n503:   deleted += evictLruUntilUnderBudget(db, '1 = 1', [], budgets.maxBytes);\n504: \n505:   const profileRows = (db.prepare(`\n506:     SELECT profile_key, COALESCE(SUM(${BYTE_ESTIMATE_SQL}), 0) AS bytes\n507:     FROM ${cacheTable(db)}\n508:     GROUP BY profile_key\n509:     HAVING COALESCE(SUM(${BYTE_ESTIMATE_SQL}), 0) > ?\n510:   `) as Database.Statement).all(budgets.profileMaxBytes) as Array<{ profile_key: string; bytes: number }>;\n511:   for (const row of profileRows) {\n512:     deleted += evictLruUntilUnderBudget(\n513:       db,\n514:       'profile_key = ?',\n515:       [row.profile_key],\n516:       budgets.profileMaxBytes,\n517:     );\n518:   }\n519: \n520:   deleted += evictLruUntilUnderBudget(\n521:     db,\n522:     \"input_kind = 'query'\",\n523:     [],\n524:     budgets.queryMaxBytes,\n525:   );\n526:   deleted += evictProfileEntryOverflow(db, budgets.maxEntriesPerProfile);\n527: \n528:   if (deleted > 0) {\n529:     shrinkSqliteMemory(db);\n530:   }\n531: \n532:   return deleted;\n533: }\n534: \n535: /**\n536:  * Evict cache entries whose last_used_at is older than maxAgeDays.\n537:  *\n538:  * @param db - better-sqlite3 database instance\n539:  * @param maxAgeDays - Maximum age in days before eviction\n540:  * @returns Number of evicted entries\n541:  */\n542: function evictOldEntries(db: Database.Database, maxAgeDays: number): number {\n543:   const result = (db.prepare(\n544:     `DELETE FROM ${cacheTable(db)}\n545:      WHERE last_used_at < datetime('now', ? || ' days')`,\n546:   ) as Database.Statement).run(`-${maxAgeDays}`);\n547: \n548:   return (result as { changes: number }).changes;\n549: }\n550: \n551: /* --- 7. STATISTICS --- */\n552: \n553: /**\n554:  * Return runtime hit/miss statistics for the embedding cache.\n555:  *\n556:  * @returns Cache hit/miss counters and derived hit rate\n557:  */\n558: function getCacheStats(): EmbeddingCacheHitStats;\n559: \n560: /**\n561:  * Return aggregate statistics about the embedding cache.\n562:  *\n563:  * @param db - better-sqlite3 database instance\n564:  * @returns Cache statistics including total entries, size, oldest/newest timestamps\n565:  */\n566: function getCacheStats(db: Database.Database): EmbeddingCacheStats;\n567: function getCacheStats(db?: Database.Database): EmbeddingCacheStats | EmbeddingCacheHitStats {\n568:   if (!db) {\n569:     const totalLookups = cacheHits + cacheMisses;\n570: \n571:     return {\n572:       hits: cacheHits,\n573:       misses: cacheMisses,\n574:       hitRate: totalLookups > 0 ? cacheHits / totalLookups : 0,\n575:     };\n576:   }\n577: \n578:   const row = (db.prepare(`\n579:     SELECT\n\n(Showing lines 360-579 of 748. Use offset=580 to continue.)\n</content>","metadata":{"preview":"\n  return deleted;\n}\n\nfunction shrinkSqliteMemory(db: Database.Database): void {\n  try {\n    db.pragma('shrink_memory');\n  } catch {\n    // Cache eviction must not fail the write path on older/test SQLite bindings.\n  }\n}\n\n/* --- 3. TABLE INITIALIZATION --- */\n\n/**\n * Create the embedding_cache table if it does not exist.\n * Idempotent — safe to call on every startup.\n *\n * @param db - better-sqlite3 database instance\n */","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/cache/embedding-cache.ts","text":"\n  return deleted;\n}\n\nfunction shrinkSqliteMemory(db: Database.Database): void {\n  try {\n    db.pragma('shrink_memory');\n  } catch {\n    // Cache eviction must not fail the write path on older/test SQLite bindings.\n  }\n}\n\n/* --- 3. TABLE INITIALIZATION --- */\n\n/**\n * Create the embedding_cache table if it does not exist.\n * Idempotent — safe to call on every startup.\n *\n * @param db - better-sqlite3 database instance\n */\nfunction initEmbeddingCache(db: Database.Database): void {\n  migrateEmbeddingCacheSchema(db);\n}\n\n/* --- 4. CACHE LOOKUP --- */\n\n/**\n * Look up a cached embedding by content hash, model ID, and embedding dimension.\n * On hit: updates last_used_at and returns the embedding Buffer.\n * On miss: returns null.\n *\n * @param db - better-sqlite3 database instance\n * @param contentHash - SHA-256 hex digest of the content\n * @param modelId - Embedding model identifier\n * @param dimensions - Expected embedding dimensions for this lookup\n * @returns Embedding buffer on cache hit, null on miss\n */\nfunction lookupEmbedding(\n  db: Database.Database,\n  contentHash: string,\n  modelId: string,\n  dimensions: number,\n  options: EmbeddingCacheKeyOptions = {},\n): Buffer | null {\n  const profileKey = normalizeProfileKey(options.profileKey);\n  const inputKind = normalizeInputKind(options.inputKind);\n  const hasScopedLookup = options.profileKey !== undefined || options.inputKind !== undefined;\n  const row = hasScopedLookup\n    ? (db.prepare(\n      `SELECT rowid, embedding\n       FROM ${cacheTable(db)}\n       WHERE content_hash = ?\n         AND profile_key = ?\n         AND input_kind = ?\n         AND model_id = ?\n         AND dimensions = ?`,\n    ) as Database.Statement).get(contentHash, profileKey, inputKind, modelId, dimensions) as\n      | { rowid: number; embedding: Buffer }\n      | undefined\n    : (db.prepare(\n      `SELECT rowid, embedding\n       FROM ${cacheTable(db)}\n       WHERE content_hash = ?\n         AND model_id = ?\n         AND dimensions = ?\n       ORDER BY\n         CASE WHEN profile_key = '' AND input_kind = 'document' THEN 0 ELSE 1 END,\n         last_used_at DESC\n       LIMIT 1`,\n    ) as Database.Statement).get(contentHash, modelId, dimensions) as\n      | { rowid: number; embedding: Buffer }\n      | undefined;\n\n  if (!row) {\n    cacheMisses += 1;\n    return null;\n  }\n\n  cacheHits += 1;\n\n  // Update last_used_at on cache hit\n  (db.prepare(\n    `UPDATE ${cacheTable(db)} SET last_used_at = datetime('now') WHERE rowid = ?`,\n  ) as Database.Statement).run(row.rowid);\n\n  return row.embedding;\n}\n\n/* --- 5. CACHE STORE --- */\n\n/**\n * Store an embedding in the cache.\n * Uses INSERT OR REPLACE so duplicate (content_hash, model_id, dimensions)\n * rows are overwritten with the latest embedding, while allowing multiple\n * dimension variants to coexist for the same content/model pair.\n *\n * NOTE: The count-then-delete below is a non-transactional read-then-update\n * pattern. Under concurrent writers the cache may briefly exceed\n * MAX_CACHE_ENTRIES, but this is acceptable for a performance cache — the\n * next store call will trim the overshoot.\n *\n * @param db - better-sqlite3 database instance\n * @param contentHash - SHA-256 hex digest of the content\n * @param modelId - Embedding model identifier\n * @param embedding - Raw embedding buffer\n * @param dimensions - Number of embedding dimensions\n */\nfunction storeEmbedding(\n  db: Database.Database,\n  contentHash: string,\n  modelId: string,\n  embedding: Buffer,\n  dimensions: number,\n  options: EmbeddingCacheKeyOptions = {},\n): void {\n  const profileKey = normalizeProfileKey(options.profileKey);\n  const inputKind = normalizeInputKind(options.inputKind);\n\n  (db.prepare(\n    `INSERT INTO ${cacheTable(db)}\n       (content_hash, profile_key, input_kind, model_id, embedding, dimensions, last_used_at)\n     VALUES (?, ?, ?, ?, ?, ?, datetime('now'))\n     ON CONFLICT(content_hash, profile_key, input_kind, model_id, dimensions)\n     DO UPDATE SET\n       embedding = excluded.embedding,\n       last_used_at = datetime('now')`,\n  ) as Database.Statement).run(contentHash, profileKey, inputKind, modelId, embedding, dimensions);\n\n  evictIfOverBudget(db);\n}\n\n/* --- 6. LRU EVICTION --- */\n\n/**\n * Evict rows until byte and secondary entry budgets are satisfied.\n *\n * @param db - better-sqlite3 database instance\n * @returns Number of evicted rows\n */\nfunction evictIfOverBudget(db: Database.Database): number {\n  const budgets = getCacheBudgetConfig();\n  let deleted = 0;\n\n  deleted += evictLruUntilUnderBudget(db, '1 = 1', [], budgets.maxBytes);\n\n  const profileRows = (db.prepare(`\n    SELECT profile_key, COALESCE(SUM(${BYTE_ESTIMATE_SQL}), 0) AS bytes\n    FROM ${cacheTable(db)}\n    GROUP BY profile_key\n    HAVING COALESCE(SUM(${BYTE_ESTIMATE_SQL}), 0) > ?\n  `) as Database.Statement).all(budgets.profileMaxBytes) as Array<{ profile_key: string; bytes: number }>;\n  for (const row of profileRows) {\n    deleted += evictLruUntilUnderBudget(\n      db,\n      'profile_key = ?',\n      [row.profile_key],\n      budgets.profileMaxBytes,\n    );\n  }\n\n  deleted += evictLruUntilUnderBudget(\n    db,\n    \"input_kind = 'query'\",\n    [],\n    budgets.queryMaxBytes,\n  );\n  deleted += evictProfileEntryOverflow(db, budgets.maxEntriesPerProfile);\n\n  if (deleted > 0) {\n    shrinkSqliteMemory(db);\n  }\n\n  return deleted;\n}\n\n/**\n * Evict cache entries whose last_used_at is older than maxAgeDays.\n *\n * @param db - better-sqlite3 database instance\n * @param maxAgeDays - Maximum age in days before eviction\n * @returns Number of evicted entries\n */\nfunction evictOldEntries(db: Database.Database, maxAgeDays: number): number {\n  const result = (db.prepare(\n    `DELETE FROM ${cacheTable(db)}\n     WHERE last_used_at < datetime('now', ? || ' days')`,\n  ) as Database.Statement).run(`-${maxAgeDays}`);\n\n  return (result as { changes: number }).changes;\n}\n\n/* --- 7. STATISTICS --- */\n\n/**\n * Return runtime hit/miss statistics for the embedding cache.\n *\n * @returns Cache hit/miss counters and derived hit rate\n */\nfunction getCacheStats(): EmbeddingCacheHitStats;\n\n/**\n * Return aggregate statistics about the embedding cache.\n *\n * @param db - better-sqlite3 database instance\n * @returns Cache statistics including total entries, size, oldest/newest timestamps\n */\nfunction getCacheStats(db: Database.Database): EmbeddingCacheStats;\nfunction getCacheStats(db?: Database.Database): EmbeddingCacheStats | EmbeddingCacheHitStats {\n  if (!db) {\n    const totalLookups = cacheHits + cacheMisses;\n\n    return {\n      hits: cacheHits,\n      misses: cacheMisses,\n      hitRate: totalLookups > 0 ? cacheHits / totalLookups : 0,\n    };\n  }\n\n  const row = (db.prepare(`\n    SELECT","lineStart":360,"lineEnd":579,"totalLines":748,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/cache/embedding-cache.ts","time":{"start":1780929456787,"end":1780929456797}},"metadata":{"openai":{"itemId":"fc_0b5a17f61061e107016a26d3af9a8081908cc073ae3593cc71"}},"id":"prt_ea7aae64c001IByzaplkRBpqZv","sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","messageID":"msg_ea7aadac7001AYYnEAywIKvuq5"}}
