.opencode/skills/cli-external-orchestration/manual-testing-playbook/plugins-and-hooks/cli-dispatch-audit-trail.md:111:ls "$SCRATCH_DIR4/.opencode/logs/cli-dispatch-audit.log" 2>&1 || echo "no log file created"
