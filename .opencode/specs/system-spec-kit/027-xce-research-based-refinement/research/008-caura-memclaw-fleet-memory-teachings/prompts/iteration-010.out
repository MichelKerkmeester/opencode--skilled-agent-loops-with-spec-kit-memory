t__.py","agent_service.py","audit_queue.py","audit_service.py","contradiction_detector.py","crystallizer_service.py","dedup_identifier_filter.py","dedup_judge.py","doc_indexing.py","entity_extraction_worker.py","entity_extraction.py","entity_service.py","entity_tokens.py","evolve_service.py","hooks.py","ingest_chunking.py","ingest_service.py","insights_service.py","lifecycle_audit.py","memory_enrichment.py","memory_service.py","memory_stats.py","organization_settings.py","payment/","recall_service.py","stm_service.py","subject_preflight.py","task_tracker.py","tenants.py","trust_service.py","usage_service.py"],"offset":1,"totalEntries":31,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services","time":{"start":1780728395440,"end":1780728395448}},"metadata":{"openai":{"itemId":"fc_07567b249853a56d016a23c24b5b6c8191ae1eab0d2fb4d9e4"}},"id":"prt_e9baef6ae0011BxdE2fDIF0xiZ","sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","messageID":"msg_e9baec97f0018f9o7iHv6tdd19"}}
