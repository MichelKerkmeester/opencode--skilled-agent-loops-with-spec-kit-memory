   283	async function probeNativeAdvisor(input, dependencies = {}) {
   284	  const env = dependencies.env ?? process.env;
   285	  if (env[DISABLED_ENV] === '1') {
   286	    return {
   287	      available: false,
   288	      freshness: 'unavailable',
   289	      generation: 0,
   290	      reason: 'ADVISOR_DISABLED',
   291	    };
