from '../lib/runtime/memory-runtime-guard.js';\n17: import { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\n18: import {\n19:   runTriggerEmbeddingBackfill,\n20:   type TriggerEmbeddingBackfillResult,\n21: } from '../lib/search/trigger-embedding-backfill.js';\n22: \n23: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n24:    2. LIB MODULE IMPORTS\n25: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n26: \n27: import { recordHistory } from '../lib/storage/history.js';\n28: import * as checkpoints from '../lib/storage/checkpoints.js';\n29: import * as memoryParser from '../lib/parsing/memory-parser.js';\n30: import * as embeddings from '../lib/providers/embeddings.js';\n31: import * as incrementalIndex from '../lib/storage/incremental-index.js';\n32: import * as causalEdges from '../lib/storage/causal-edges.js';\n33: import * as vectorIndex from '../lib/search/vector-index.js';\n34: import { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\n35: import { runPostMutationHooks } from './mutation-hooks.js';\n36: import { createStatediffAction } from '../lib/storage/statediff.js';\n37: import { repairIncompleteMarkers } from './save/enrichment-state.js';\n38: import { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\n39: import { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\n40: import {\n41:   findConstitutionalFiles,\n42:   findGraphMetadataFiles,\n43:   findSpecDocuments,\n44:   detectSpecLevel,\n45:   type DiscoveryCapExceeded,\n46:   type DiscoveryFileList,\n47: } from './memory-index-discovery.js';\n48: import {\n49:   EMPTY_ALIAS_CONFLICT_SUMMARY,\n50:   createDefaultDivergenceReconcileSummary,\n51:   detectAliasConflictsFromIndex,\n52:   summarizeAliasConflicts,\n53:   runDivergenceReconcileHooks,\n54:   type AliasConflictSummary,\n55:   type DivergenceReconcileSummary,\n56: } from './memory-index-alias.js';\n57: \n58: // Standardized response structure\n59: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n60: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n61: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n62: import {\n63:   createJobId,\n64:   createMaintenanceJob,\n65:   setJobState,\n66:   setJobPhase,\n67:   setJobProgress,\n68:   appendJobError,\n69:   completeJob,\n70:   isCancelRequestedFast,\n71: } from '../lib/ops/job-store.js';\n72: \n73: // Shared handler types\n74: import type { MCPResponse, EmbeddingProfile } from './types.js';\n75: import type { StatediffAction } from '../lib/storage/statediff.js';\n76: \n77: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n78: // Feature catalog: Async ingestion job lifecycle\n79: \n80: \n81: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n82:    4. TYPES\n83: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n84: \n85: interface IndexResult {\n86:   status: string;\n87:   id?: number;\n88:   specFolder?: string;\n89:   title?: string | null;\n90:   error?: string;\n91:   errorDetail?: string;\n92:   [key: string]: unknown;\n93: }\n94: \n95: /** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\n96: function isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n97:   return (\n98:     typeof result === 'object' &&\n99:     result !== null &&\n100:     typeof (result as { status?: unknown }).status === 'string' &&\n101:     !('retries_failed' in result)\n102:   );\n103: }\n104: \n105: function emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n106:   return { maxNodes: false, depth: false, gitignoreSize: false };\n107: }\n108: \n109: function mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n110:   return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n111:     maxNodes: merged.maxNodes || cap?.maxNodes === true,\n112:     depth: merged.depth || cap?.depth === true,\n113:     gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n114:   }), emptyDiscoveryCapExceeded());\n115: }\n116: \n117: function discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n118:   const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n119:   return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n120: }\n121: \n122: function discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n123:   return (files as Partial<DiscoveryFileList>).capExceeded;\n124: }\n125: \n126: /** Individual file result from a memory index scan. */\n127: interface ScanFileEntry {\n128:   file: string;\n129:   filePath?: string;\n130:   status?: string;\n131:   specFolder?: string;\n132:   id?: number;\n133:   isConstitutional?: boolean;\n134:   error?: string;\n135:   errorDetail?: string;\n136: }\n137: \n138: interface CheckpointRepairReport {\n139:   sentinelPresent: boolean;\n140:   attempted: boolean;\n141:   completed: number;\n142:   failed: number;\n143:   skipped: number;\n144:   cleared: boolean;\n145:   error: string | null;\n146: }\n147: \n148: interface ScanResults {\n149:   scanned: number;\n150:   indexed: number;\n151:   updated: number;\n152:   unchanged: number;\n153:   failed: number;\n154:   deferred: number;\n155:   skipped_mtime: number;\n156:   mtimeUpdates: number;\n157:   staleDeleted: number;\n158:   staleDeleteFailed: number;\n159:   postInsertEnrichmentRepaired: number;\n160:   nearDuplicateRepaired: number;\n161:   orphanSwept: number;\n162:   orphanSweepFailed: number;\n163:   orphanSweepScanned: number;\n164:   orphanSweepNextCursor: number | null;\n165:   moveReconciled?: number;\n166:   files: ScanFileEntry[];\n167:   constitutional: {\n168:     found: number;\n169:     indexed: number;\n170:     alreadyIndexed: number;\n171:   };\n172:   incremental: {\n173:     enabled: boolean;\n174:     fast_path_skips: number;\n175:     mtime_changed: number;\n176:     metadataPromoter: {\n177:       processed: number;\n178:       resolved: number;\n179:       inserted: number;\n180:       skippedManual: number;\n181:       staleTombstoned: number;\n182:       staleDeleted: number;\n183:       warnings: number;\n184:     };\n185:   };\n186:   dedup: {\n187:     inputTotal: number;\n188:     uniqueTotal: number;\n189:     duplicatesSkipped: number;\n190:   };\n191:   aliasConflicts: AliasConflictSummary;\n192:   divergenceReconcile: DivergenceReconcileSummary;\n193:   checkpointRepair: CheckpointRepairReport;\n194:   triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n195:   warnings: string[];\n196:   capExceeded: DiscoveryCapExceeded;\n197: }\n198: \n199: interface CategorizedFiles {\n200:   toIndex: string[];\n201:   toUpdate: string[];\n202:   toSkip: string[];\n203:   toDelete: string[];\n204: }\n205: \n206: interface ScanKeyOptions {\n207:   spec_folder: string | null;\n208:   force: boolean;\n209:   incremental: boolean;\n210:   include_constitutional: boolean;\n211:   include_spec_docs: boolean;\n212: }\n213: \n214: interface RecordDeleteResult {\n215:   deleted: number;\n216:   failed: number;\n217:   actions: StatediffAction[];\n218: }\n219: \n220: interface OrphanSweepDeleteResult {\n221:   swept: number;\n222:   failed: number;\n223:   scannedRows: number;\n224:   nextCursor: number | null;\n225:   actions: StatediffAction[];\n226: }\n227: \n228: interface OrphanSweepCandidates {\n229:   swept: number;\n230:   nextCursor: number | null;\n231:   scannedRows: number;\n232:   orphanRecordIds?: number[];\n233: }\n234: \n235: const ORPHAN_SWEEP_LIMIT = 200;\n236: \n237: // Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n238: // breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n239: // launcher spawns a second daemon. Sampling timer drift distinguishes a true\n240: // event-loop block from a phase that is merely slow but yields вҖ” the two need\n241: // different fixes (chunk-and-yield vs launcher-side probe tolerance).\n242: const LOOP_LAG_SAMPLE_MS = 250;\n243: const LOOP_LAG_WARN_MS = 1000;\n244: \n245: function emptyCheckpointRepairReport(): CheckpointRepairReport {\n246:   return {\n247:     sentinelPresent: false,\n248:     attempted: false,\n249:     completed: 0,\n250:     failed: 0,\n251:     skipped: 0,\n252:     cleared: false,\n253:     error: null,\n254:   };\n255: }\n256: \n257: function runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n258:   try {\n259:     const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n260:       source: 'memory_index_scan',\n261:       actor: 'mcp:memory_index_scan',\n262:     });\n263:     return {\n264:       sentinelPresent: repair.sentinelPresent,\n265:       attempted: repair.attempted,\n266:       completed: repair.summary?.completed.length ?? 0,\n267:       failed: repair.summary?.failed.length ?? 0,\n268:       skipped: repair.summary?.skipped.length ?? 0,\n269:       cleared: repair.cleared,\n270:       error: repair.error,\n271:     };\n272:   } catch (error: unknown) {\n273:     return {\n274:       ...emptyCheckpointRepairReport(),\n275:       sentinelPresent: true,\n276:       attempted: true,\n277:       error: toErrorMessage(error),\n278:     };\n279:   }\n280: }\n281: \n282: function createScanKey(options: ScanKeyOptions): string {\n283:   const normalized = {\n284:     spec_folder: options.spec_folder ?? null,\n285:     force: !!options.force,\n286:     incremental: !!options.incremental,\n287:     include_constitutional: !!options.include_constitutional,\n288:     include_spec_docs: !!options.include_spec_docs,\n289:   };\n290: \n291:   return createHash('sha256')\n292:     .update(JSON.stringify(normalized))\n293:     .digest('hex')\n294:     .slice(0, 16);\n295: }\n296: \n297: interface ScanArgs {\n298:   specFolder?: string | null;\n299:   force?: boolean;\n300:   includeConstitutional?: boolean;\n301:   includeSpecDocs?: boolean;\n302:   incremental?: boolean;\n303:   // Opt-in: run the scan as a background job and return a jobId immediately.\n304:   background?: boolean;\n305:   tenantId?: string;\n306:   userId?: string;\n307:   agentId?: string;\n308:   sessionId?: string;\n309:   provenanceSource?: string;\n310:   provenanceActor?: string;\n311:   governedAt?: string;\n312:   retentionPolicy?: 'keep' | 'ephemeral';\n313:   deleteAfter?: string;\n314: }\n315: \n316: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n317:    5. SHARED INDEXING LOGIC\n318: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n319: \n320: import { indexMemoryFile } from './memory-save.js';\n321: import type { GovernanceDecision } from '../lib/governance/scope-governance.js';\n322: import type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n323: \n324: /** Index a single memory file, delegating to the shared indexMemoryFile logic */\n325: async function indexSingleFile(\n326:   filePath: string,\n327:   force: boolean = false,\n328:   options?: {\n329:     qualityGateMode?: 'enforce' | 'warn-only';\n330:     fromScan?: boolean;\n331:     asyncEmbedding?: boolean;\n332:     governance?: GovernanceDecision;\n333:     provenance?: WriteProvenanceContext;\n334:   },\n335: ): Promise<IndexResult> {\n336:   return indexMemoryFile(filePath, {\n337:     force,\n338:     qualityGateMode: options?.qualityGateMode,\n339:     fromScan: options?.fromScan,\n340:     asyncEmbedding: options?.asyncEmbedding,\n341:     governance: options?.governance,\n342:     provenance: options?.provenance,\n343:   });\n344: }\n345: \n346: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n347:    6. MEMORY INDEX SCAN HANDLER\n348: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n349: \n350: // Hooks let a background runner observe cancellation and report phase/progress.\n351: // On the synchronous path every hook is undefined, so behavior is identical.\n352: interface ScanRunContext {\n353:   isCancelled?: () => boolean;\n354:   onPhase?: (phase: string) => void;\n355:   onProgress?: (progress: { processed: number; total: number }) => void;\n356: }\n357: \n358: // Pull the envelope.data field back out of an MCP response so status can echo it.\n359: function extractEnvelopeData(response: MCPResponse): unknown {\n360:   try {\n361:     const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n362:     if (typeof text !== 'string') return null;\n363:     const parsed = JSON.parse(text) as { data?: unknown };\n364:     return parsed?.data ?? null;\n365:   } catch (_error: unknown) {\n366:     return null;\n367:   }\n368: }\n369: \n370: // Persisted payload for debugging: scan shape only, no governance identifiers.\n371: function redactScanArgs(args: ScanArgs): Record<string, unknown> {\n372:   return {\n373:     specFolder: args.specFolder ?? null,\n374:     force: !!args.force,\n375:     includeConstitutional: args.includeConstitutional !== false,\n376:     includeSpecDocs: args.includeSpecDocs !== false,\n377:     incremental: args.incremental !== false,\n378:     background: true,\n379:   };\n380: }\n381: \n382: function cancelledScanEnvelope(scanKey: string): MCPResponse {\n383:   return createMCPSuccessResponse({\n384:     tool: 'memory_index_scan',\n385:     summary: 'Index scan cancelled before completion',\n386:     data: { status: 'cancelled', cancelled: true, scanKey },\n387:     hints: ['The scan was cancelled via memory_index_scan_cancel'],\n388:   });\n389: }\n390: \n391: /** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\n392: async function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n393:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n394:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n395:   if (restoreBarrier) {\n396:     recordMaintenanceRun('memory_index_scan', { status: 'error' });\n397:     return createMCPErrorResponse({\n398:       tool: 'memory_index_scan',\n399:       error: restoreBarrier.message,\n400:       code: restoreBarrier.code,\n401:       recovery: {\n402:         hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n403:         actions: ['Wait for the restore to finish', 'Retry the index scan'],\n404:         severity: 'warning',\n405:       },\n406:     });\n407:   }\n408: \n409:   const {\n410:     specFolder: spec_folder = null,\n411:     force = false,\n412:     includeConstitutional: include_constitutional = true,\n413:     includeSpecDocs: include_spec_docs = true,\n414:     incremental = true\n415:   } = args;\n416:   const scanKey = createScanKey({\n417:     spec_folder,\n418:     force,\n419:     incremental,\n420:     include_constitutional,\n421:     include_spec_docs,\n422:   });\n423:   const governedIngest = requiresGovernedIngest(args);\n424:   const governanceDecision = validateGovernedIngest(args);\n425:   if (!governanceDecision.allowed) {\n426:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n427:   }\n428: \n429:   // Pre-flight dimension check\n430:   try {\n431:     const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n432:     if (profile) {\n433:       console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n434:     }\n435:   } catch (dimCheckError: unknown) {\n436:     const message = toErrorMessage(dimCheckError);\n437:     console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n438:   }\n439: \n440:   await checkDatabaseUpdated();\n441: \n442:   // Atomic scan lease check.\n443:   // Reserve scan_started_at up front to avoid check-then-set race windows.\n444:   const now = Date.now();\n445:   const lease = await acquireIndexScanLease({\n446:     now,\n447:     cooldownMs: INDEX_SCAN_COOLDOWN,\n448:   });\n449:   if (!lease.acquired) {\n450:     let message: string;\n451:     if (lease.reason === 'lease_active') {\n452:       message = 'A scan is already in progress; this call coalesced onto it.';\n453:     } else if (lease.reason === 'contention') {\n454:       message = 'The index DB is briefly locked by another writer; retry shortly.';\n455:     } else {\n456:       message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n457:     }\n458:     recordMaintenanceRun('memory_index_scan', {\n459:       status: 'coalesced',\n460:       counts: { waitSeconds: lease.waitSeconds },\n461:       staleCandidates: 0,\n462:     });\n463:     return createMCPSuccessResponse({\n464:       tool: 'memory_index_scan',\n465:       summary: message,\n466:       data: {\n467:         success: true,\n468:         coalesced: true,\n469:         status: 'coalesced',\n470:         reason: lease.reason,\n471:         scanKey,\n472:         waitSeconds: lease.waitSeconds,\n473:         nextPollAfterMs: lease.waitSeconds * 1000,\n474:         message,\n475:       },\n476:       hints: [message],\n477:     });\n478:   }\n479: \n480:   let scanLeaseReleased = false;\n481:   const releaseScanLease = async (): Promise<void> => {\n482:     if (scanLeaseReleased) return;\n483:     scanLeaseReleased = true;\n484:     await completeIndexScanLease(Date.now());\n485:   };\n486: \n487:   const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n488: \n489:   // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n490:   // processBatches() runs all batches sequentially and may exceed the lease expiry\n491:   // window (each batch waits on embedding/API latency). Without a periodic refresh\n492:   // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n493:   // launch a second parallel scan. Refresh well inside the expiry window (a third of\n494:   // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n495:   // from holding the event loop open at shutdown; finally clears it before release.\n496:   const leaseExpiryMs = lease.leaseExpiryMs;\n497:   const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n498:   let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n499: \n500:   // Background scans pass an onPhase hook; the synchronous foreground path does not.\n501:   // Gate diagnostics on it so the synchronous path's behavior stays identical.\n502:   const instrument = typeof ctx.onPhase === 'function';\n503:   let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n504:   let maxLoopLagMs = 0;\n505: \n506:   try {\n507:   leaseHeartbeat = setInterval(() => {\n508:     refreshScanLease();\n509:   }, leaseHeartbeatMs);\n510:   leaseHeartbeat.unref?.();\n511: \n512:   if (instrument) {\n513:     let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n514:     loopLagTimer = setInterval(() => {\n515:       const sampledAt = Date.now();\n516:       const lag = sampledAt - loopLagExpectedAt;\n517:       loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n518:       if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n519:       if (lag > LOOP_LAG_WARN_MS) {\n520:         // A late sample means the loop was blocked since the prior tick; logged\n521:         // adjacent to the phase=... line of whatever phase just ran, so the daemon\n522:         // log timeline fingers the blocking phase.\n523:         console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n524:       }\n525:     }, LOOP_LAG_SAMPLE_MS);\n526:     loopLagTimer.unref?.();\n527:   }\n528: \n529:   if (ctx.isCancelled?.()) {\n530:     await releaseScanLease();\n531:     return cancelledScanEnvelope(scanKey);\n532:   }\n533:   ctx.onPhase?.('discovering');\n534: \n535:   const workspacePath: string = DEFAULT_BASE_PATH;\n536: \n537:   const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n538:   const specDocFiles = include_spec_docs\n539:     ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n540:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n541:   const graphMetadataFiles = include_spec_docs\n542:     ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n543:     : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n544:   const walkerWarnings = [\n545:     ...discoveryWarnings(specDocFiles),\n546:     ...discoveryWarnings(graphMetadataFiles),\n547:   ];\n548:   const walkerCapExceeded = mergeDiscoveryCapExceeded(\n549:     discoveryCaps(specDocFiles),\n550:     discoveryCaps(graphMetadataFiles),\n551:   );\n552: \n553:   const canonicalKeyCache = new Map<string, string>();\n554:   const getCachedKey = (filePath: string): string => {\n555:     const cached = canonicalKeyCache.get(filePath);\n556:     if (cached) {\n557:       return cached;\n558:     }\n559: \n560:     const canonicalKey = getCanonicalPathKey(filePath);\n561:     canonicalKeyCache.set(filePath, canonicalKey);\n562:     return canonicalKey;\n563:   };\n564: \n565:   const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n566:   const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n567:   const seenCanonicalFiles = new Set<string>();\n568:   const files: string[] = [];\n569: \n570:   for (const filePath of mergedFiles) {\n571:     const canonicalKey = getCachedKey(filePath);\n572:     if (seenCanonicalFiles.has(canonicalKey)) {\n573:       continue;\n574:     }\n575:     seenCanonicalFiles.add(canonicalKey);\n576:     files.push(filePath);\n577:   }\n578: \n579:   const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n580:   if (dedupDuplicatesSkipped > 0) {\n581:     console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n582:   }\n583: \n584:   const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n585:     if (recordIds.length === 0) {\n586:       return { deleted: 0, failed: 0, actions: [] };\n587:     }\n588: \n589:     let deleted = 0;\n590:     let failed = 0;\n591:     const actions: StatediffAction[] = [];\n592: \n593:     for (const staleRecordId of recordIds) {\n594:       try {\n595:         const database = vectorIndex.getDb();\n596:         const staleSnapshot = database?.prepare(\n597:           'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n598:         ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n599: \n600:         if (database) {\n601:           causalEdges.init(database);\n602:           causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n603:             reason: 'memory_index stale record cleanup',\n604:             command: 'memory-index.deleteIndexedRecordIds',\n605:             restoreContext: {\n606:               memoryId: staleRecordId,\n607:               specFolder: staleSnapshot?.spec_folder ?? null,\n608:               filePath: staleSnapshot?.file_path ?? null,\n609:             },\n610:           });\n611:         }\n612: \n613:         if (vectorIndex.deleteMemory(staleRecordId)) {\n614:           deleted++;\n615:           actions.push(createStatediffAction('delete', {\n616:             target: 'memory_index',\n617:             key: String(staleRecordId),\n618:             sourceOperation: 'scan',\n619:             oldStateHash: null,\n620:             newStateHash: null,\n621:             metadata: {\n622:               filePath: staleSnapshot?.file_path ?? null,\n623:               specFolder: staleSnapshot?.spec_folder ?? null,\n624:             },\n625:           }));\n626:           // Record DELETE history only after confirmed deletion.\n627:           try {\n628:             recordHistory(\n629:               staleRecordId,\n630:               'DELETE',\n631:               staleSnapshot?.file_path ?? null,\n632:               null,\n633:               'mcp:memory_index_scan',\n634:               staleSnapshot?.spec_folder ?? null,\n635:             );\n636:           } catch (_histErr: unknown) {\n637:             // History recording is best-effort\n638:           }\n639:         } else {\n640:           failed++;\n641:         }\n642:       } catch (_error: unknown) {\n643:         failed++;\n644:       }\n645:     }\n646: \n647:     return { deleted, failed, actions };\n648:   };\n649: \n650:   const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n651:     if (paths.length === 0) {\n652:       return { deleted: 0, failed: 0, actions: [] };\n653:     }\n654: \n655:     return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n656:   };\n657: \n658:   const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n659:     if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n660:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n661:     }\n662: \n663:     const sweepOrphanIndexRows = (incrementalIndex as {\n664:       sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n665:     }).sweepOrphanIndexRows;\n666: \n667:     if (typeof sweepOrphanIndexRows !== 'function') {\n668:       return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n669:     }\n670: \n671:     const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n672:     const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n673:     return {\n674:       swept: deleteResult.deleted,\n675:       failed: deleteResult.failed,\n676:       scannedRows: sweep.scannedRows,\n677:       nextCursor: sweep.nextCursor,\n678:       actions: deleteResult.actions,\n679:     };\n680:   };\n681: \n682:   const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n683:     try {\n684:       runPostMutationHooks('scan', { ...context, statediffActions: actions });\n685:     } catch (error: unknown) {\n686:       console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n687:     }\n688:   };\n689: \n690:   const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n691:     result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n692:   );\n693: \n694:   const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n695:     target: 'memory_index',\n696:     key: 'trigger-embedding-backfill',\n697:     sourceOperation: 'scan',\n698:     metadata: {\n699:       readyRows: result.readyRows,\n700:       failedRows: result.failedRows,\n701:       pendingRows: result.pendingRows,\n702:     },\n703:   });\n704: \n705:   const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n706:     if (actions.length === 0) {\n707:       return;\n708:     }\n709:     results.aliasConflicts = detectAliasConflictsFromIndex();\n710:     results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n711:   };\n712: \n713:   const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n714:     try {\n715:       const repairResult = await repairIncompleteMarkers(\n716:         { database: requireDb(), plannerMode: 'full-auto' },\n717:         { limit: BATCH_SIZE },\n718:       );\n719:       if (repairResult.failed > 0) {\n720:         console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n721:       }\n722:       return repairResult.repaired;\n723:     } catch (error: unknown) {\n724:       console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n725:       return 0;\n726:     }\n727:   };\n728: \n729:   const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n730:     if (!isMemoryIdempotencyEnabled()) {\n731:       return 0;\n732:     }\n733:     try {\n734:       const database = requireDb();\n735:       const rows = database.prepare(`\n736:         SELECT id, spec_folder, title, content_text, content_hash,\n737:                tenant_id, user_id, agent_id, session_id\n738:         FROM memory_index\n739:         WHERE parent_id IS NULL\n740:           AND embedding_status = 'success'\n741:           AND content_text IS NOT NULL\n742:           AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n743:         ORDER BY id ASC\n744:         LIMIT ?\n745:       `).all(BATCH_SIZE) as Array<{\n746:         id: number;\n747:         spec_folder: string;\n748:         title: string | null;\n749:         content_text: string;\n750:         content_hash: string | null;\n751:         tenant_id: string | null;\n752:         user_id: string | null;\n753:         agent_id: string | null;\n754:         session_id: string | null;\n755:       }>;\n756:       let repaired = 0;\n757:       for (const row of rows) {\n758:         try {\n759:           const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n760:           const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n761:           recordNearDuplicateCheck({\n762:             database,\n763:             memoryId: row.id,\n764:             specFolder: row.spec_folder,\n765:             contentHash: row.content_hash,\n766:             embedding,\n767:             scope: {\n768:               tenantId: row.tenant_id,\n769:               userId: row.user_id,\n770:               agentId: row.agent_id,\n771:               sessionId: row.session_id,\n772:             },\n773:           });\n774:           repaired++;\n775:         } catch (error: unknown) {\n776:           console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n777:         }\n778:       }\n779:       return repaired;\n780:     } catch (error: unknown) {\n781:       console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n782:       return 0;\n783:     }\n784:   };\n785: \n786:   // Time each un-yielded tail phase: because these phases do not yield, their\n787:   // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n788:   // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n789:   // onPhase, which refreshes the busy marker вҖ” giving each phase a full TTL ahead.\n790:   const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n791:     ctx.onPhase?.(phase);\n792:     if (!instrument) {\n793:       return await fn();\n794:     }\n795:     const startedAt = Date.now();\n796:     try {\n797:       return await fn();\n798:     } finally {\n799:       console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n800:     }\n801:   };\n802: \n803:   if (files.length === 0) {\n804:     let staleDeleted = 0;\n805:     let staleDeleteFailed = 0;\n806:     const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n807:     const postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n808:     const nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n809: \n810:     if (incremental && !force) {\n811:       const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n812:       const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n813:       staleDeleted = staleDeleteResult.deleted;\n814:       staleDeleteFailed = staleDeleteResult.failed;\n815:       if (staleDeleted > 0) {\n816:         runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n817:       }\n818:     }\n819: \n820:     const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n821:       runTriggerEmbeddingBackfill(requireDb(), {\n822:         isCancelled: () => ctx.isCancelled?.() ?? false,\n823:       }));\n824: \n825:     if (orphanSweepResult.swept > 0) {\n826:       runScanInvalidationHooks({\n827:         orphanSwept: orphanSweepResult.swept,\n828:         orphanSweepFailed: orphanSweepResult.failed,\n829:         operation: 'orphan-sweep',\n830:       }, orphanSweepResult.actions);\n831:     }\n832:     if (postInsertEnrichmentRepaired > 0) {\n833:       runScanInvalidationHooks({\n834:         postInsertEnrichmentRepaired,\n835:         operation: 'post-insert-enrichment-repair',\n836:       }, [createStatediffAction('upsert', {\n837:         target: 'graph_edge',\n838:         key: 'post-insert-enrichment-repair',\n839:         sourceOperation: 'scan',\n840:         metadata: { postInsertEnrichmentRepaired },\n841:       })]);\n842:     }\n843:     if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n844:       runScanInvalidationHooks({\n845:         triggerEmbeddingBackfill,\n846:         operation: 'trigger-embedding-backfill',\n847:       }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n848:     }\n849: \n850:     recordMaintenanceRun('memory_index_scan', {\n851:       status: 'success',\n852:       counts: {\n853:         scanned: 0,\n854:         indexed: 0,\n855:         updated: 0,\n856:         unchanged: 0,\n857:         failed: 0,\n858:         staleDeleted,\n859:         staleDeleteFailed,\n860:         orphanSwept: orphanSweepResult.swept,\n861:       },\n862:       staleCandidates: staleDeleted + staleDeleteFailed,\n863:     });\n864:     await releaseScanLease();\n865:     return createMCPSuccessResponse({\n866:       tool: 'memory_index_scan',\n867:       summary: 'No memory files found',\n868:       data: {\n869:         status: 'complete',\n870:         scanKey,\n871:         scanned: 0,\n872:         indexed: 0,\n873:         updated: 0,\n874:         unchanged: 0,\n875:         failed: 0,\n876:         staleDeleted,\n877:         staleDeleteFailed,\n878:         postInsertEnrichmentRepaired,\n879:         nearDuplicateRepaired,\n880:         triggerEmbeddingBackfill,\n881:         orphanSwept: orphanSweepResult.swept,\n882:         orphanSweepFailed: orphanSweepResult.failed,\n883:         orphanSweepScanned: orphanSweepResult.scannedRows,\n884:         orphanSweepNextCursor: orphanSweepResult.nextCursor,\n885:         checkpointRepair,\n886:         warnings: walkerWarnings,\n887:         capExceeded: walkerCapExceeded,\n888:       },\n889:       hints: [\n890:         ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n891:         ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n892:         ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n893:         ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n894:         ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n895:         ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n896:         ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n897:         ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n898:         ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n899:         ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n900:         'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n901:         'Constitutional files go in .opencode/skills/*/constitutional/'\n902:       ]\n903:     });\n904:   }\n905: \n906:   const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n907: \n908:   const results: ScanResults = {\n909:     scanned: files.length,\n910:     indexed: 0,\n911:     updated: 0,\n912:     unchanged: 0,\n913:     failed: 0,\n914:     deferred: 0,\n915:     skipped_mtime: 0,\n916:     mtimeUpdates: 0,\n917:     staleDeleted: 0,\n918:     staleDeleteFailed: 0,\n919:     postInsertEnrichmentRepaired: 0,\n920:     nearDuplicateRepaired: 0,\n921:     orphanSwept: 0,\n922:     orphanSweepFailed: 0,\n923:     orphanSweepScanned: 0,\n924:     orphanSweepNextCursor: null,\n925:     files: [],\n926:     constitutional: {\n927:       found: constitutionalFiles.length,\n928:       indexed: 0,\n929:       alreadyIndexed: 0\n930:     },\n931:     incremental: {\n932:       enabled: incremental && !force,\n933:       fast_path_skips: 0,\n934:       mtime_changed: 0,\n935:       metadataPromoter: {\n936:         processed: 0,\n937:         resolved: 0,\n938:         inserted: 0,\n939:         skippedManual: 0,\n940:         staleTombstoned: 0,\n941:         staleDeleted: 0,\n942:         warnings: 0,\n943:       }\n944:     },\n945:     dedup: {\n946:       inputTotal: mergedFiles.length,\n947:       uniqueTotal: files.length,\n948:       duplicatesSkipped: dedupDuplicatesSkipped,\n949:     },\n950:     aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n951:     divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n952:     checkpointRepair,\n953:     warnings: walkerWarnings,\n954:     capExceeded: walkerCapExceeded,\n955:   };\n956:   const scanAppliedActions: StatediffAction[] = [];\n957: \n958:   let filesToIndex: string[] = files;\n959:   let filesToDelete: string[] = [];\n960: \n961:   if (incremental && !force) {\n962:     const startCategorize = Date.now();\n963:     const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n964: \n965:     filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n966:     filesToDelete = categorized.toDelete;\n967: \n968:     results.unchanged = categorized.toSkip.length;\n969:     results.skipped_mtime = categorized.toSkip.length;\n970:     results.incremental.fast_path_skips = categorized.toSkip.length;\n971:     results.incremental.mtime_changed = categorized.toUpdate.length;\n972: \n973:     for (const unchangedPath of categorized.toSkip) {\n974:       if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n975:         results.constitutional.alreadyIndexed++;\n976:       }\n977:     }\n978: \n979:     const categorizeTime = Date.now() - startCategorize;\n980:     console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n981:     console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n982:   }\n983: \n984:   // Attempt move reconciliation before full delete+reindex cycle.\n985:   // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n986:   // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n987:   // stored-document_type cross-checks; the matched row is updated in place.\n988:   if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n989:     const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n990:     if (moveResult.reconciled.length > 0) {\n991:       results.moveReconciled = moveResult.reconciled.length;\n992:       filesToDelete = moveResult.filteredToDelete;\n993:       filesToIndex = moveResult.filteredToIndex;\n994:       console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n995:     }\n996:   }\n997: \n998:   const plannedScanActions = [\n999:     ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n1000:       target: 'memory_index',\n1001:       key: getCachedKey(filePath),\n1002:       sourceOperation: 'scan',\n1003:       metadata: { filePath },\n1004:     })),\n1005:     ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n1006:       target: 'memory_index',\n1007:       key: getCachedKey(filePath),\n1008:       sourceOperation: 'scan',\n1009:       metadata: { filePath },\n1010:     })),\n1011:   ];\n1012:   if (plannedScanActions.length > 0) {\n1013:     console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n1014:   }\n1015: \n1016:   // Track successfully indexed files for post-indexing mtime update.\n1017:   // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n1018:   // Failed files keep their old mtime so shouldReindex() returns 'modified'\n1019:   // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n1020:   // Before indexing would cause silent data loss вҖ” a failed file would be\n1021:   // Marked \"already indexed\" and permanently skipped.\n1022:   const successfullyIndexedFiles: string[] = [];\n1023:   const scanBatchSize = BATCH_SIZE;\n1024: \n1025:   ctx.onPhase?.('indexing');\n1026:   ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n1027: \n1028:   if (filesToIndex.length > 0) {\n1029:     let processedInScan = 0;\n1030:     const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n1031:       // Cancellation is checked between files (mirrors ingest). A cancelled file is\n1032:       // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n1033:       if (ctx.isCancelled?.()) {\n1034:         return { status: 'cancelled' } as IndexResult;\n1035:       }\n1036:       const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n1037:       // Constitutional markdown is policy text, not evidence-bearing memory.\n1038:       // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n1039:       // strict sufficiency gate would always reject it. Treat constitutional files like\n1040:       // spec docs and pass them through warn-only mode so they index against the same\n1041:       // pipeline without the document-evidence requirements.\n1042:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1043:       // During force reindex, use warn-only for all files вҖ” the goal is to index\n1044:       // everything that has valid frontmatter, not to enforce template contracts on\n1045:       // older files created before current templates were established.\n1046:       const useWarnOnly = force || isSpecDoc || isConstitutional;\n1047:       const indexResult = await indexSingleFile(filePath, force, {\n1048:         ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n1049:         fromScan: true,\n1050:         asyncEmbedding: true,\n1051:         governance: governedIngest ? governanceDecision : undefined,\n1052:       });\n1053:       processedInScan += 1;\n1054:       ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n1055:       return indexResult;\n1056:     }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n1057: \n1058:     for (let i = 0; i < batchResults.length; i++) {\n1059:       const result = batchResults[i];\n1060:       const filePath = filesToIndex[i];\n1061:       const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n1062: \n1063:       if (result.error) {\n1064:         results.failed++;\n1065:         results.files.push({\n1066:           file: path.basename(filePath),\n1067:           filePath,\n1068:           status: 'failed',\n1069:           error: result.error,\n1070:           errorDetail: result.errorDetail\n1071:         });\n1072:       } else if (isIndexResult(result)) {\n1073:         const isSuccessfulStatus =\n1074:           result.status === 'success' ||\n1075:           result.status === 'indexed' ||\n1076:           result.status === 'updated' ||\n1077:           result.status === 'unchanged' ||\n1078:           result.status === 'reinforced' ||\n1079:           result.status === 'duplicate' ||\n1080:           result.status === 'deferred';\n1081:         // A cancelled file was never indexed and was never going to be: counting it\n1082:         // as a failure would attribute an operator-requested stop to a file error.\n1083:         // It is neither success nor failure, so it falls through both tallies.\n1084:         if (!isSuccessfulStatus && result.status !== 'cancelled') {\n1085:           results.failed++;\n1086:         }\n1087: \n1088:         if (result.status === 'indexed') {\n1089:           results.indexed++;\n1090:           successfullyIndexedFiles.push(filePath);\n1091:           scanAppliedActions.push(createStatediffAction('insert', {\n1092:             target: 'memory_index',\n1093:             key: String(result.id ?? getCachedKey(filePath)),\n1094:             sourceOperation: 'scan',\n1095:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1096:           }));\n1097:         } else if (result.status === 'updated') {\n1098:           results.updated++;\n1099:           successfullyIndexedFiles.push(filePath);\n1100:           scanAppliedActions.push(createStatediffAction('upsert', {\n1101:             target: 'memory_index',\n1102:             key: String(result.id ?? getCachedKey(filePath)),\n1103:             sourceOperation: 'scan',\n1104:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1105:           }));\n1106:         } else if (result.status === 'unchanged') {\n1107:           results.unchanged++;\n1108:           successfullyIndexedFiles.push(filePath);\n1109:         } else if (result.status === 'reinforced') {\n1110:           results.updated++;\n1111:           successfullyIndexedFiles.push(filePath);\n1112:           scanAppliedActions.push(createStatediffAction('upsert', {\n1113:             target: 'memory_index',\n1114:             key: String(result.id ?? getCachedKey(filePath)),\n1115:             sourceOperation: 'scan',\n1116:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1117:           }));\n1118:         } else if (result.status === 'duplicate') {\n1119:           results.unchanged++;\n1120:           successfullyIndexedFiles.push(filePath);\n1121:         } else if (result.status === 'deferred') {\n1122:           results.indexed++;\n1123:           results.deferred++;\n1124:           successfullyIndexedFiles.push(filePath);\n1125:           scanAppliedActions.push(createStatediffAction('insert', {\n1126:             target: 'memory_index',\n1127:             key: String(result.id ?? getCachedKey(filePath)),\n1128:             sourceOperation: 'scan',\n1129:             metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n1130:           }));\n1131:         }\n1132: \n1133:         if (isConstitutional) {\n1134:           if (result.status === 'indexed') {\n1135:             results.constitutional.indexed++;\n1136:           } else if (result.status === 'unchanged') {\n1137:             results.constitutional.alreadyIndexed++;\n1138:           }\n1139:         }\n1140: \n1141:         if (result.status !== 'unchanged') {\n1142:           const rejectionDetail = !isSuccessfulStatus\n1143:             ? {\n1144:                 ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n1145:                   ? { rejectionCode: result.rejectionCode }\n1146:                   : {}),\n1147:                 ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n1148:                   ? { rejectionReason: result.rejectionReason }\n1149:                   : (typeof result.message === 'string' && result.message.length > 0\n1150:                     ? { rejectionReason: result.message }\n1151:                     : {})),\n1152:                 ...(typeof result.error === 'string' && result.error.length > 0\n1153:                   ? { error: result.error }\n1154:                   : {}),\n1155:               }\n1156:             : {};\n1157: \n1158:           results.files.push({\n1159:             file: path.basename(filePath),\n1160:             filePath,\n1161:             specFolder: result.specFolder,\n1162:             status: result.status,\n1163:             id: result.id,\n1164:             isConstitutional,\n1165:             ...rejectionDetail,\n1166:           });\n1167:         }\n1168:       } else {\n1169:         results.failed++;\n1170:         results.files.push({\n1171:           file: path.basename(filePath),\n1172:           filePath,\n1173:           status: 'failed',\n1174:           error: 'Unexpected batch result shape',\n1175:           errorDetail: JSON.stringify(result),\n1176:         });\n1177:       }\n1178:     }\n1179:   }\n1180: \n1181:   // Update mtimes ONLY for successfully indexed files, not before indexing.\n1182:   // Failed files keep their old mtime so they are retried on next scan.\n1183:   // This is the ONLY place where scan-triggered mtime updates occur.\n1184:   // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n1185:   // Which rolls back atomically on failure вҖ” a complementary safety mechanism.\n1186:   if (successfullyIndexedFiles.length > 0) {\n1187:     const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n1188:     results.mtimeUpdates = mtimeUpdateResult.updated;\n1189:   }\n1190: \n1191:   if (include_spec_docs) {\n1192:     const database = requireDb();\n1193:     let promoterYieldCount = 0;\n1194:     for (const fileResult of results.files) {\n1195:       // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n1196:       // that is the whole corpus, so without a periodic macrotask yield the event\n1197:       // loop is starved for the duration and no IPC (status, cancel, health,\n1198:       // search) can be serviced. Yield and re-check cancellation between rows; the\n1199:       // yield lands between self-contained promoteMetadataEdges transactions, never\n1200:       // inside one, so atomicity on the shared connection is preserved.\n1201:       if (++promoterYieldCount % 200 === 0) {\n1202:         if (ctx.isCancelled?.()) {\n1203:           return cancelledScanEnvelope(scanKey);\n1204:         }\n1205:         await new Promise<void>((resolve) => setImmediate(resolve));\n1206:       }\n1207:       if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n1208:         continue;\n1209:       }\n1210:       try {\n1211:         const promotion = promoteMetadataEdges(database, {\n1212:           memoryId: fileResult.id,\n1213:           filePath: fileResult.filePath,\n1214:         });\n1215:         results.incremental.metadataPromoter.processed += promotion.processed;\n1216:         results.incremental.metadataPromoter.resolved += promotion.resolved;\n1217:         results.incremental.metadataPromoter.inserted += promotion.inserted;\n1218:         results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n1219:         results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n1220:         results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n1221:         results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n1222:         for (const warning of promotion.warnings) {\n1223:           results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n1224:         }\n1225:       } catch (error: unknown) {\n1226:         results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n1227:       }\n1228:     }\n1229:   }\n1230: \n1231:   if (ctx.isCancelled?.()) {\n1232:     return cancelledScanEnvelope(scanKey);\n1233:   }\n1234:   ctx.onPhase?.('post-processing');\n1235: \n1236:   if (filesToDelete.length > 0) {\n1237:     if (results.failed === 0) {\n1238:       const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n1239:       results.staleDeleted = staleDeleteResult.deleted;\n1240:       results.staleDeleteFailed = staleDeleteResult.failed;\n1241:       scanAppliedActions.push(...staleDeleteResult.actions);\n1242:     } else {\n1243:       console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n1244:     }\n1245:   }\n1246: \n1247:   const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n1248:   results.orphanSwept = orphanSweepResult.swept;\n1249:   results.orphanSweepFailed = orphanSweepResult.failed;\n1250:   results.orphanSweepScanned = orphanSweepResult.scannedRows;\n1251:   results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n1252:   scanAppliedActions.push(...orphanSweepResult.actions);\n1253: \n1254:   results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n1255:   if (results.postInsertEnrichmentRepaired > 0) {\n1256:     scanAppliedActions.push(createStatediffAction('upsert', {\n1257:       target: 'graph_edge',\n1258:       key: 'post-insert-enrichment-repair',\n1259:       sourceOperation: 'scan',\n1260:       metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n1261:     }));\n1262:   }\n1263: \n1264:   results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n1265:     runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n1266:   if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n1267:     scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n1268:   }\n1269:   results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n1270: \n1271:   // Create causal chains between spec folder documents.\n1272:   // Includes deferred indexing outcomes and incremental single-file updates.\n1273:   if (include_spec_docs) {\n1274:     try {\n1275:       // Determine which spec folders had spec document changes in this scan.\n1276:       // We use parsed document type (not basename) to avoid false positives\n1277:       // From memory/plan.md or similar filenames.\n1278:       const affectedSpecFolders = new Set<string>();\n1279:       for (const fileResult of results.files) {\n1280:         if (!fileResult.specFolder || fileResult.status === 'failed') {\n1281:           continue;\n1282:         }\n1283: \n1284:         if (!fileResult.filePath) {\n1285:           continue;\n1286:         }\n1287: \n1288:         const docType = memoryParser.extractDocumentType(fileResult.filePath);\n1289:         if (\n1290:           docType !== 'memory' &&\n1291:           docType !== 'constitutional'\n1292:         ) {\n1293:           affectedSpecFolders.add(fileResult.specFolder);\n1294:         }\n1295:       }\n1296: \n1297:       if (affectedSpecFolders.size > 0) {\n1298:         const database = requireDb();\n1299:         const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n1300:         initCausalEdges(database);\n1301: \n1302:         // Build full per-folder document map from DB (not just this scan's files).\n1303:         const selectDocIds = database.prepare(`\n1304:           SELECT document_type, MAX(id) AS id\n1305:           FROM memory_index\n1306:           WHERE spec_folder = ?\n1307:             AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n1308:           GROUP BY document_type\n1309:         `);\n1310: \n1311:         let chainsCreated = 0;\n1312:         let foldersProcessed = 0;\n1313:         let chainYieldCount = 0;\n1314: \n1315:         for (const folder of affectedSpecFolders) {\n\n(Output capped at 50 KB. Showing lines 1-1315. Use offset=1316 to continue.)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Index\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. CORE AND UTILS IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Index\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport path from 'path';\nimport { createHash } from 'node:crypto';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. CORE AND UTILS IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { INDEX_SCAN_COOLDOWN, DEFAULT_BASE_PATH, BATCH_SIZE } from '../core/config.js';\nimport { beginMaintenance } from '../lib/storage/maintenance-marker.js';\nimport { acquireIndexScanLease, completeIndexScanLease, refreshScanLease } from '../core/db-state.js';\nimport { processBatches, requireDb, toErrorMessage, type RetryErrorResult } from '../utils/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport { getCanonicalPathKey } from '../lib/utils/canonical-path.js';\nimport {\n  runTriggerEmbeddingBackfill,\n  type TriggerEmbeddingBackfillResult,\n} from '../lib/search/trigger-embedding-backfill.js';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. LIB MODULE IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as memoryParser from '../lib/parsing/memory-parser.js';\nimport * as embeddings from '../lib/providers/embeddings.js';\nimport * as incrementalIndex from '../lib/storage/incremental-index.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { promoteMetadataEdges } from '../lib/causal/frontmatter-promoter.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { repairIncompleteMarkers } from './save/enrichment-state.js';\nimport { isMemoryIdempotencyEnabled } from '../lib/storage/idempotency-receipts.js';\nimport { recordNearDuplicateCheck } from '../lib/storage/near-duplicate.js';\nimport {\n  findConstitutionalFiles,\n  findGraphMetadataFiles,\n  findSpecDocuments,\n  detectSpecLevel,\n  type DiscoveryCapExceeded,\n  type DiscoveryFileList,\n} from './memory-index-discovery.js';\nimport {\n  EMPTY_ALIAS_CONFLICT_SUMMARY,\n  createDefaultDivergenceReconcileSummary,\n  detectAliasConflictsFromIndex,\n  summarizeAliasConflicts,\n  runDivergenceReconcileHooks,\n  type AliasConflictSummary,\n  type DivergenceReconcileSummary,\n} from './memory-index-alias.js';\n\n// Standardized response structure\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\nimport {\n  createJobId,\n  createMaintenanceJob,\n  setJobState,\n  setJobPhase,\n  setJobProgress,\n  appendJobError,\n  completeJob,\n  isCancelRequestedFast,\n} from '../lib/ops/job-store.js';\n\n// Shared handler types\nimport type { MCPResponse, EmbeddingProfile } from './types.js';\nimport type { StatediffAction } from '../lib/storage/statediff.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n// Feature catalog: Async ingestion job lifecycle\n\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\ninterface IndexResult {\n  status: string;\n  id?: number;\n  specFolder?: string;\n  title?: string | null;\n  error?: string;\n  errorDetail?: string;\n  [key: string]: unknown;\n}\n\n/** Type guard: distinguishes IndexResult from RetryErrorResult via the 'status' property */\nfunction isIndexResult(result: IndexResult | RetryErrorResult): result is IndexResult {\n  return (\n    typeof result === 'object' &&\n    result !== null &&\n    typeof (result as { status?: unknown }).status === 'string' &&\n    !('retries_failed' in result)\n  );\n}\n\nfunction emptyDiscoveryCapExceeded(): DiscoveryCapExceeded {\n  return { maxNodes: false, depth: false, gitignoreSize: false };\n}\n\nfunction mergeDiscoveryCapExceeded(...caps: Array<DiscoveryCapExceeded | undefined>): DiscoveryCapExceeded {\n  return caps.reduce<DiscoveryCapExceeded>((merged, cap) => ({\n    maxNodes: merged.maxNodes || cap?.maxNodes === true,\n    depth: merged.depth || cap?.depth === true,\n    gitignoreSize: merged.gitignoreSize || cap?.gitignoreSize === true,\n  }), emptyDiscoveryCapExceeded());\n}\n\nfunction discoveryWarnings(files: string[] | DiscoveryFileList): string[] {\n  const maybeWarnings = (files as Partial<DiscoveryFileList>).warnings;\n  return Array.isArray(maybeWarnings) ? maybeWarnings : [];\n}\n\nfunction discoveryCaps(files: string[] | DiscoveryFileList): DiscoveryCapExceeded | undefined {\n  return (files as Partial<DiscoveryFileList>).capExceeded;\n}\n\n/** Individual file result from a memory index scan. */\ninterface ScanFileEntry {\n  file: string;\n  filePath?: string;\n  status?: string;\n  specFolder?: string;\n  id?: number;\n  isConstitutional?: boolean;\n  error?: string;\n  errorDetail?: string;\n}\n\ninterface CheckpointRepairReport {\n  sentinelPresent: boolean;\n  attempted: boolean;\n  completed: number;\n  failed: number;\n  skipped: number;\n  cleared: boolean;\n  error: string | null;\n}\n\ninterface ScanResults {\n  scanned: number;\n  indexed: number;\n  updated: number;\n  unchanged: number;\n  failed: number;\n  deferred: number;\n  skipped_mtime: number;\n  mtimeUpdates: number;\n  staleDeleted: number;\n  staleDeleteFailed: number;\n  postInsertEnrichmentRepaired: number;\n  nearDuplicateRepaired: number;\n  orphanSwept: number;\n  orphanSweepFailed: number;\n  orphanSweepScanned: number;\n  orphanSweepNextCursor: number | null;\n  moveReconciled?: number;\n  files: ScanFileEntry[];\n  constitutional: {\n    found: number;\n    indexed: number;\n    alreadyIndexed: number;\n  };\n  incremental: {\n    enabled: boolean;\n    fast_path_skips: number;\n    mtime_changed: number;\n    metadataPromoter: {\n      processed: number;\n      resolved: number;\n      inserted: number;\n      skippedManual: number;\n      staleTombstoned: number;\n      staleDeleted: number;\n      warnings: number;\n    };\n  };\n  dedup: {\n    inputTotal: number;\n    uniqueTotal: number;\n    duplicatesSkipped: number;\n  };\n  aliasConflicts: AliasConflictSummary;\n  divergenceReconcile: DivergenceReconcileSummary;\n  checkpointRepair: CheckpointRepairReport;\n  triggerEmbeddingBackfill?: TriggerEmbeddingBackfillResult;\n  warnings: string[];\n  capExceeded: DiscoveryCapExceeded;\n}\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface ScanKeyOptions {\n  spec_folder: string | null;\n  force: boolean;\n  incremental: boolean;\n  include_constitutional: boolean;\n  include_spec_docs: boolean;\n}\n\ninterface RecordDeleteResult {\n  deleted: number;\n  failed: number;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepDeleteResult {\n  swept: number;\n  failed: number;\n  scannedRows: number;\n  nextCursor: number | null;\n  actions: StatediffAction[];\n}\n\ninterface OrphanSweepCandidates {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds?: number[];\n}\n\nconst ORPHAN_SWEEP_LIMIT = 200;\n\n// Scan responsiveness diagnostics. A blocked event loop is the failure mode that\n// breaks daemon re-election: it cannot answer a competing launcher's probe, so the\n// launcher spawns a second daemon. Sampling timer drift distinguishes a true\n// event-loop block from a phase that is merely slow but yields вҖ” the two need\n// different fixes (chunk-and-yield vs launcher-side probe tolerance).\nconst LOOP_LAG_SAMPLE_MS = 250;\nconst LOOP_LAG_WARN_MS = 1000;\n\nfunction emptyCheckpointRepairReport(): CheckpointRepairReport {\n  return {\n    sentinelPresent: false,\n    attempted: false,\n    completed: 0,\n    failed: 0,\n    skipped: 0,\n    cleared: false,\n    error: null,\n  };\n}\n\nfunction runCheckpointNeedsRebuildRepairForScan(): CheckpointRepairReport {\n  try {\n    const repair = checkpoints.repairNeedsRebuildSentinel(requireDb(), {\n      source: 'memory_index_scan',\n      actor: 'mcp:memory_index_scan',\n    });\n    return {\n      sentinelPresent: repair.sentinelPresent,\n      attempted: repair.attempted,\n      completed: repair.summary?.completed.length ?? 0,\n      failed: repair.summary?.failed.length ?? 0,\n      skipped: repair.summary?.skipped.length ?? 0,\n      cleared: repair.cleared,\n      error: repair.error,\n    };\n  } catch (error: unknown) {\n    return {\n      ...emptyCheckpointRepairReport(),\n      sentinelPresent: true,\n      attempted: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction createScanKey(options: ScanKeyOptions): string {\n  const normalized = {\n    spec_folder: options.spec_folder ?? null,\n    force: !!options.force,\n    incremental: !!options.incremental,\n    include_constitutional: !!options.include_constitutional,\n    include_spec_docs: !!options.include_spec_docs,\n  };\n\n  return createHash('sha256')\n    .update(JSON.stringify(normalized))\n    .digest('hex')\n    .slice(0, 16);\n}\n\ninterface ScanArgs {\n  specFolder?: string | null;\n  force?: boolean;\n  includeConstitutional?: boolean;\n  includeSpecDocs?: boolean;\n  incremental?: boolean;\n  // Opt-in: run the scan as a background job and return a jobId immediately.\n  background?: boolean;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. SHARED INDEXING LOGIC\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { indexMemoryFile } from './memory-save.js';\nimport type { GovernanceDecision } from '../lib/governance/scope-governance.js';\nimport type { WriteProvenanceContext } from '../lib/storage/write-provenance.js';\n\n/** Index a single memory file, delegating to the shared indexMemoryFile logic */\nasync function indexSingleFile(\n  filePath: string,\n  force: boolean = false,\n  options?: {\n    qualityGateMode?: 'enforce' | 'warn-only';\n    fromScan?: boolean;\n    asyncEmbedding?: boolean;\n    governance?: GovernanceDecision;\n    provenance?: WriteProvenanceContext;\n  },\n): Promise<IndexResult> {\n  return indexMemoryFile(filePath, {\n    force,\n    qualityGateMode: options?.qualityGateMode,\n    fromScan: options?.fromScan,\n    asyncEmbedding: options?.asyncEmbedding,\n    governance: options?.governance,\n    provenance: options?.provenance,\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. MEMORY INDEX SCAN HANDLER\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n// Hooks let a background runner observe cancellation and report phase/progress.\n// On the synchronous path every hook is undefined, so behavior is identical.\ninterface ScanRunContext {\n  isCancelled?: () => boolean;\n  onPhase?: (phase: string) => void;\n  onProgress?: (progress: { processed: number; total: number }) => void;\n}\n\n// Pull the envelope.data field back out of an MCP response so status can echo it.\nfunction extractEnvelopeData(response: MCPResponse): unknown {\n  try {\n    const text = (response as { content?: Array<{ text?: string }> })?.content?.[0]?.text;\n    if (typeof text !== 'string') return null;\n    const parsed = JSON.parse(text) as { data?: unknown };\n    return parsed?.data ?? null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\n// Persisted payload for debugging: scan shape only, no governance identifiers.\nfunction redactScanArgs(args: ScanArgs): Record<string, unknown> {\n  return {\n    specFolder: args.specFolder ?? null,\n    force: !!args.force,\n    includeConstitutional: args.includeConstitutional !== false,\n    includeSpecDocs: args.includeSpecDocs !== false,\n    incremental: args.incremental !== false,\n    background: true,\n  };\n}\n\nfunction cancelledScanEnvelope(scanKey: string): MCPResponse {\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: 'Index scan cancelled before completion',\n    data: { status: 'cancelled', cancelled: true, scanKey },\n    hints: ['The scan was cancelled via memory_index_scan_cancel'],\n  });\n}\n\n/** Run the full memory_index_scan operation. Hooks are no-ops on the synchronous path. */\nasync function runIndexScan(args: ScanArgs, ctx: ScanRunContext = {}): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    recordMaintenanceRun('memory_index_scan', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      recovery: {\n        hint: 'Retry memory_index_scan after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the index scan'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const {\n    specFolder: spec_folder = null,\n    force = false,\n    includeConstitutional: include_constitutional = true,\n    includeSpecDocs: include_spec_docs = true,\n    incremental = true\n  } = args;\n  const scanKey = createScanKey({\n    spec_folder,\n    force,\n    incremental,\n    include_constitutional,\n    include_spec_docs,\n  });\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  // Pre-flight dimension check\n  try {\n    const profile: EmbeddingProfile | null = embeddings.getEmbeddingProfile();\n    if (profile) {\n      console.error(`[memory_index_scan] Using embedding provider: ${profile.provider}, model: ${profile.model}, dimension: ${profile.dim}`);\n    }\n  } catch (dimCheckError: unknown) {\n    const message = toErrorMessage(dimCheckError);\n    console.warn('[memory_index_scan] Could not verify embedding dimension:', message);\n  }\n\n  await checkDatabaseUpdated();\n\n  // Atomic scan lease check.\n  // Reserve scan_started_at up front to avoid check-then-set race windows.\n  const now = Date.now();\n  const lease = await acquireIndexScanLease({\n    now,\n    cooldownMs: INDEX_SCAN_COOLDOWN,\n  });\n  if (!lease.acquired) {\n    let message: string;\n    if (lease.reason === 'lease_active') {\n      message = 'A scan is already in progress; this call coalesced onto it.';\n    } else if (lease.reason === 'contention') {\n      message = 'The index DB is briefly locked by another writer; retry shortly.';\n    } else {\n      message = 'A scan recently completed; this call coalesced onto the recent scan window.';\n    }\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'coalesced',\n      counts: { waitSeconds: lease.waitSeconds },\n      staleCandidates: 0,\n    });\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: message,\n      data: {\n        success: true,\n        coalesced: true,\n        status: 'coalesced',\n        reason: lease.reason,\n        scanKey,\n        waitSeconds: lease.waitSeconds,\n        nextPollAfterMs: lease.waitSeconds * 1000,\n        message,\n      },\n      hints: [message],\n    });\n  }\n\n  let scanLeaseReleased = false;\n  const releaseScanLease = async (): Promise<void> => {\n    if (scanLeaseReleased) return;\n    scanLeaseReleased = true;\n    await completeIndexScanLease(Date.now());\n  };\n\n  const checkpointRepair = runCheckpointNeedsRebuildRepairForScan();\n\n  // Keep the scan lease alive for the full duration of a long, multi-batch scan.\n  // processBatches() runs all batches sequentially and may exceed the lease expiry\n  // window (each batch waits on embedding/API latency). Without a periodic refresh\n  // the lease can expire mid-scan, letting a concurrent caller treat it as stale and\n  // launch a second parallel scan. Refresh well inside the expiry window (a third of\n  // it) so a single missed beat never lets the lease lapse. .unref() keeps the timer\n  // from holding the event loop open at shutdown; finally clears it before release.\n  const leaseExpiryMs = lease.leaseExpiryMs;\n  const leaseHeartbeatMs = Math.max(10000, Math.floor(leaseExpiryMs / 3));\n  let leaseHeartbeat: ReturnType<typeof setInterval> | null = null;\n\n  // Background scans pass an onPhase hook; the synchronous foreground path does not.\n  // Gate diagnostics on it so the synchronous path's behavior stays identical.\n  const instrument = typeof ctx.onPhase === 'function';\n  let loopLagTimer: ReturnType<typeof setInterval> | null = null;\n  let maxLoopLagMs = 0;\n\n  try {\n  leaseHeartbeat = setInterval(() => {\n    refreshScanLease();\n  }, leaseHeartbeatMs);\n  leaseHeartbeat.unref?.();\n\n  if (instrument) {\n    let loopLagExpectedAt = Date.now() + LOOP_LAG_SAMPLE_MS;\n    loopLagTimer = setInterval(() => {\n      const sampledAt = Date.now();\n      const lag = sampledAt - loopLagExpectedAt;\n      loopLagExpectedAt = sampledAt + LOOP_LAG_SAMPLE_MS;\n      if (lag > maxLoopLagMs) maxLoopLagMs = lag;\n      if (lag > LOOP_LAG_WARN_MS) {\n        // A late sample means the loop was blocked since the prior tick; logged\n        // adjacent to the phase=... line of whatever phase just ran, so the daemon\n        // log timeline fingers the blocking phase.\n        console.error(`[memory-index-scan] event-loop blocked ~${lag}ms between samples`);\n      }\n    }, LOOP_LAG_SAMPLE_MS);\n    loopLagTimer.unref?.();\n  }\n\n  if (ctx.isCancelled?.()) {\n    await releaseScanLease();\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('discovering');\n\n  const workspacePath: string = DEFAULT_BASE_PATH;\n\n  const constitutionalFiles: string[] = include_constitutional ? findConstitutionalFiles(workspacePath) : [];\n  const specDocFiles = include_spec_docs\n    ? findSpecDocuments(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const graphMetadataFiles = include_spec_docs\n    ? findGraphMetadataFiles(workspacePath, { specFolder: spec_folder })\n    : Object.assign([], { warnings: [], capExceeded: emptyDiscoveryCapExceeded() }) as DiscoveryFileList;\n  const walkerWarnings = [\n    ...discoveryWarnings(specDocFiles),\n    ...discoveryWarnings(graphMetadataFiles),\n  ];\n  const walkerCapExceeded = mergeDiscoveryCapExceeded(\n    discoveryCaps(specDocFiles),\n    discoveryCaps(graphMetadataFiles),\n  );\n\n  const canonicalKeyCache = new Map<string, string>();\n  const getCachedKey = (filePath: string): string => {\n    const cached = canonicalKeyCache.get(filePath);\n    if (cached) {\n      return cached;\n    }\n\n    const canonicalKey = getCanonicalPathKey(filePath);\n    canonicalKeyCache.set(filePath, canonicalKey);\n    return canonicalKey;\n  };\n\n  const mergedFiles = [...constitutionalFiles, ...specDocFiles, ...graphMetadataFiles];\n  const specDocKeySet = new Set(specDocFiles.map((f) => getCachedKey(f)));\n  const seenCanonicalFiles = new Set<string>();\n  const files: string[] = [];\n\n  for (const filePath of mergedFiles) {\n    const canonicalKey = getCachedKey(filePath);\n    if (seenCanonicalFiles.has(canonicalKey)) {\n      continue;\n    }\n    seenCanonicalFiles.add(canonicalKey);\n    files.push(filePath);\n  }\n\n  const dedupDuplicatesSkipped = mergedFiles.length - files.length;\n  if (dedupDuplicatesSkipped > 0) {\n    console.error(`[memory-index-scan] Canonical dedup skipped ${dedupDuplicatesSkipped} alias path(s) (${mergedFiles.length} -> ${files.length})`);\n  }\n\n  const deleteIndexedRecordIds = (recordIds: number[]): RecordDeleteResult => {\n    if (recordIds.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    let deleted = 0;\n    let failed = 0;\n    const actions: StatediffAction[] = [];\n\n    for (const staleRecordId of recordIds) {\n      try {\n        const database = vectorIndex.getDb();\n        const staleSnapshot = database?.prepare(\n          'SELECT spec_folder, file_path FROM memory_index WHERE id = ?'\n        ).get(staleRecordId) as { spec_folder?: string | null; file_path?: string | null } | undefined;\n\n        if (database) {\n          causalEdges.init(database);\n          causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n            reason: 'memory_index stale record cleanup',\n            command: 'memory-index.deleteIndexedRecordIds',\n            restoreContext: {\n              memoryId: staleRecordId,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n              filePath: staleSnapshot?.file_path ?? null,\n            },\n          });\n        }\n\n        if (vectorIndex.deleteMemory(staleRecordId)) {\n          deleted++;\n          actions.push(createStatediffAction('delete', {\n            target: 'memory_index',\n            key: String(staleRecordId),\n            sourceOperation: 'scan',\n            oldStateHash: null,\n            newStateHash: null,\n            metadata: {\n              filePath: staleSnapshot?.file_path ?? null,\n              specFolder: staleSnapshot?.spec_folder ?? null,\n            },\n          }));\n          // Record DELETE history only after confirmed deletion.\n          try {\n            recordHistory(\n              staleRecordId,\n              'DELETE',\n              staleSnapshot?.file_path ?? null,\n              null,\n              'mcp:memory_index_scan',\n              staleSnapshot?.spec_folder ?? null,\n            );\n          } catch (_histErr: unknown) {\n            // History recording is best-effort\n          }\n        } else {\n          failed++;\n        }\n      } catch (_error: unknown) {\n        failed++;\n      }\n    }\n\n    return { deleted, failed, actions };\n  };\n\n  const deleteStaleIndexedRecords = (paths: string[]): RecordDeleteResult => {\n    if (paths.length === 0) {\n      return { deleted: 0, failed: 0, actions: [] };\n    }\n\n    return deleteIndexedRecordIds(incrementalIndex.listIndexedRecordIdsForDeletedPaths(paths));\n  };\n\n  const runGlobalOrphanSweep = (): OrphanSweepDeleteResult => {\n    if (!('sweepOrphanIndexRows' in incrementalIndex)) {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweepOrphanIndexRows = (incrementalIndex as {\n      sweepOrphanIndexRows?: (options?: { limit?: number; cursor?: number }) => OrphanSweepCandidates;\n    }).sweepOrphanIndexRows;\n\n    if (typeof sweepOrphanIndexRows !== 'function') {\n      return { swept: 0, failed: 0, scannedRows: 0, nextCursor: null, actions: [] };\n    }\n\n    const sweep = sweepOrphanIndexRows({ limit: ORPHAN_SWEEP_LIMIT });\n    const deleteResult = deleteIndexedRecordIds(sweep.orphanRecordIds ?? []);\n    return {\n      swept: deleteResult.deleted,\n      failed: deleteResult.failed,\n      scannedRows: sweep.scannedRows,\n      nextCursor: sweep.nextCursor,\n      actions: deleteResult.actions,\n    };\n  };\n\n  const runScanInvalidationHooks = (context: Record<string, unknown>, actions: readonly StatediffAction[]): void => {\n    try {\n      runPostMutationHooks('scan', { ...context, statediffActions: actions });\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-mutation invalidation failed:', toErrorMessage(error));\n    }\n  };\n\n  const triggerBackfillChangedRows = (result: TriggerEmbeddingBackfillResult): boolean => (\n    result.readyRows > 0 || result.failedRows > 0 || result.pendingRows > 0\n  );\n\n  const createTriggerBackfillAction = (result: TriggerEmbeddingBackfillResult): StatediffAction => createStatediffAction('upsert', {\n    target: 'memory_index',\n    key: 'trigger-embedding-backfill',\n    sourceOperation: 'scan',\n    metadata: {\n      readyRows: result.readyRows,\n      failedRows: result.failedRows,\n      pendingRows: result.pendingRows,\n    },\n  });\n\n  const runScanHygieneSubscribers = (actions: readonly StatediffAction[]): void => {\n    if (actions.length === 0) {\n      return;\n    }\n    results.aliasConflicts = detectAliasConflictsFromIndex();\n    results.divergenceReconcile = runDivergenceReconcileHooks(results.aliasConflicts);\n  };\n\n  const runPostInsertEnrichmentRepairBackfill = async (): Promise<number> => {\n    try {\n      const repairResult = await repairIncompleteMarkers(\n        { database: requireDb(), plannerMode: 'full-auto' },\n        { limit: BATCH_SIZE },\n      );\n      if (repairResult.failed > 0) {\n        console.warn(`[memory-index-scan] Post-insert enrichment repair left ${repairResult.failed} failed marker(s)`);\n      }\n      return repairResult.repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Post-insert enrichment repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  const runNearDuplicateRepairBackfill = async (): Promise<number> => {\n    if (!isMemoryIdempotencyEnabled()) {\n      return 0;\n    }\n    try {\n      const database = requireDb();\n      const rows = database.prepare(`\n        SELECT id, spec_folder, title, content_text, content_hash,\n               tenant_id, user_id, agent_id, session_id\n        FROM memory_index\n        WHERE parent_id IS NULL\n          AND embedding_status = 'success'\n          AND content_text IS NOT NULL\n          AND (last_dedup_checked_at IS NULL OR updated_at > last_dedup_checked_at)\n        ORDER BY id ASC\n        LIMIT ?\n      `).all(BATCH_SIZE) as Array<{\n        id: number;\n        spec_folder: string;\n        title: string | null;\n        content_text: string;\n        content_hash: string | null;\n        tenant_id: string | null;\n        user_id: string | null;\n        agent_id: string | null;\n        session_id: string | null;\n      }>;\n      let repaired = 0;\n      for (const row of rows) {\n        try {\n          const embeddingInput = row.title ? `${row.title}\\n\\n${row.content_text}` : row.content_text;\n          const embedding = await embeddings.generateDocumentEmbedding(embeddingInput);\n          recordNearDuplicateCheck({\n            database,\n            memoryId: row.id,\n            specFolder: row.spec_folder,\n            contentHash: row.content_hash,\n            embedding,\n            scope: {\n              tenantId: row.tenant_id,\n              userId: row.user_id,\n              agentId: row.agent_id,\n              sessionId: row.session_id,\n            },\n          });\n          repaired++;\n        } catch (error: unknown) {\n          console.warn(`[memory-index-scan] Near-duplicate repair skipped for memory ${row.id}: ${toErrorMessage(error)}`);\n        }\n      }\n      return repaired;\n    } catch (error: unknown) {\n      console.warn('[memory-index-scan] Near-duplicate repair skipped:', toErrorMessage(error));\n      return 0;\n    }\n  };\n\n  // Time each un-yielded tail phase: because these phases do not yield, their\n  // wall-clock equals their event-loop-block duration, so this pinpoints a blocking\n  // phase when read alongside the event-loop lag sampler. Entering a phase also fires\n  // onPhase, which refreshes the busy marker вҖ” giving each phase a full TTL ahead.\n  const timedPhase = async <T>(phase: string, fn: () => Promise<T> | T): Promise<T> => {\n    ctx.onPhase?.(phase);\n    if (!instrument) {\n      return await fn();\n    }\n    const startedAt = Date.now();\n    try {\n      return await fn();\n    } finally {\n      console.error(`[memory-index-scan] phase=${phase} ms=${Date.now() - startedAt}`);\n    }\n  };\n\n  if (files.length === 0) {\n    let staleDeleted = 0;\n    let staleDeleteFailed = 0;\n    const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n    const postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n    const nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n    if (incremental && !force) {\n      const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing([]);\n      const staleDeleteResult = deleteStaleIndexedRecords(categorized.toDelete);\n      staleDeleted = staleDeleteResult.deleted;\n      staleDeleteFailed = staleDeleteResult.failed;\n      if (staleDeleted > 0) {\n        runScanInvalidationHooks({ staleDeleted, staleDeleteFailed, operation: 'stale-delete' }, staleDeleteResult.actions);\n      }\n    }\n\n    const triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n      runTriggerEmbeddingBackfill(requireDb(), {\n        isCancelled: () => ctx.isCancelled?.() ?? false,\n      }));\n\n    if (orphanSweepResult.swept > 0) {\n      runScanInvalidationHooks({\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        operation: 'orphan-sweep',\n      }, orphanSweepResult.actions);\n    }\n    if (postInsertEnrichmentRepaired > 0) {\n      runScanInvalidationHooks({\n        postInsertEnrichmentRepaired,\n        operation: 'post-insert-enrichment-repair',\n      }, [createStatediffAction('upsert', {\n        target: 'graph_edge',\n        key: 'post-insert-enrichment-repair',\n        sourceOperation: 'scan',\n        metadata: { postInsertEnrichmentRepaired },\n      })]);\n    }\n    if (triggerBackfillChangedRows(triggerEmbeddingBackfill)) {\n      runScanInvalidationHooks({\n        triggerEmbeddingBackfill,\n        operation: 'trigger-embedding-backfill',\n      }, [createTriggerBackfillAction(triggerEmbeddingBackfill)]);\n    }\n\n    recordMaintenanceRun('memory_index_scan', {\n      status: 'success',\n      counts: {\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        orphanSwept: orphanSweepResult.swept,\n      },\n      staleCandidates: staleDeleted + staleDeleteFailed,\n    });\n    await releaseScanLease();\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan',\n      summary: 'No memory files found',\n      data: {\n        status: 'complete',\n        scanKey,\n        scanned: 0,\n        indexed: 0,\n        updated: 0,\n        unchanged: 0,\n        failed: 0,\n        staleDeleted,\n        staleDeleteFailed,\n        postInsertEnrichmentRepaired,\n        nearDuplicateRepaired,\n        triggerEmbeddingBackfill,\n        orphanSwept: orphanSweepResult.swept,\n        orphanSweepFailed: orphanSweepResult.failed,\n        orphanSweepScanned: orphanSweepResult.scannedRows,\n        orphanSweepNextCursor: orphanSweepResult.nextCursor,\n        checkpointRepair,\n        warnings: walkerWarnings,\n        capExceeded: walkerCapExceeded,\n      },\n      hints: [\n        ...(staleDeleted > 0 ? [`Removed ${staleDeleted} stale index record(s) for deleted files`] : []),\n        ...(postInsertEnrichmentRepaired > 0 ? [`Repaired ${postInsertEnrichmentRepaired} incomplete post-insert enrichment marker(s)`] : []),\n        ...(nearDuplicateRepaired > 0 ? [`Repaired ${nearDuplicateRepaired} near-duplicate marker(s)`] : []),\n        ...(triggerEmbeddingBackfill.readyRows > 0 ? [`Backfilled ${triggerEmbeddingBackfill.readyRows} trigger embedding row(s)`] : []),\n        ...(triggerEmbeddingBackfill.failedRows > 0 ? [`${triggerEmbeddingBackfill.failedRows} trigger embedding row(s) failed backfill`] : []),\n        ...(orphanSweepResult.swept > 0 ? [`Swept ${orphanSweepResult.swept} orphan index record(s)`] : []),\n        ...(orphanSweepResult.failed > 0 ? [`${orphanSweepResult.failed} orphan index record(s) could not be removed`] : []),\n        ...(checkpointRepair.cleared ? [`Cleared checkpoint derived rebuild sentinel after repairing ${checkpointRepair.completed} step(s)`] : []),\n        ...(checkpointRepair.attempted && !checkpointRepair.cleared ? ['Checkpoint derived rebuild repair did not complete; sentinel retained'] : []),\n        ...(checkpointRepair.error ? [`Checkpoint derived rebuild repair error: ${checkpointRepair.error}`] : []),\n        'Indexable files are canonical spec documents under specs/**/ (spec.md, plan.md, decision-record.md, implementation-summary.md, handover.md, etc.)',\n        'Constitutional files go in .opencode/skills/*/constitutional/'\n      ]\n    });\n  }\n\n  const constitutionalSet = new Set(constitutionalFiles.map((filePath) => getCachedKey(filePath)));\n\n  const results: ScanResults = {\n    scanned: files.length,\n    indexed: 0,\n    updated: 0,\n    unchanged: 0,\n    failed: 0,\n    deferred: 0,\n    skipped_mtime: 0,\n    mtimeUpdates: 0,\n    staleDeleted: 0,\n    staleDeleteFailed: 0,\n    postInsertEnrichmentRepaired: 0,\n    nearDuplicateRepaired: 0,\n    orphanSwept: 0,\n    orphanSweepFailed: 0,\n    orphanSweepScanned: 0,\n    orphanSweepNextCursor: null,\n    files: [],\n    constitutional: {\n      found: constitutionalFiles.length,\n      indexed: 0,\n      alreadyIndexed: 0\n    },\n    incremental: {\n      enabled: incremental && !force,\n      fast_path_skips: 0,\n      mtime_changed: 0,\n      metadataPromoter: {\n        processed: 0,\n        resolved: 0,\n        inserted: 0,\n        skippedManual: 0,\n        staleTombstoned: 0,\n        staleDeleted: 0,\n        warnings: 0,\n      }\n    },\n    dedup: {\n      inputTotal: mergedFiles.length,\n      uniqueTotal: files.length,\n      duplicatesSkipped: dedupDuplicatesSkipped,\n    },\n    aliasConflicts: { ...EMPTY_ALIAS_CONFLICT_SUMMARY },\n    divergenceReconcile: createDefaultDivergenceReconcileSummary(),\n    checkpointRepair,\n    warnings: walkerWarnings,\n    capExceeded: walkerCapExceeded,\n  };\n  const scanAppliedActions: StatediffAction[] = [];\n\n  let filesToIndex: string[] = files;\n  let filesToDelete: string[] = [];\n\n  if (incremental && !force) {\n    const startCategorize = Date.now();\n    const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n\n    filesToIndex = [...categorized.toIndex, ...categorized.toUpdate];\n    filesToDelete = categorized.toDelete;\n\n    results.unchanged = categorized.toSkip.length;\n    results.skipped_mtime = categorized.toSkip.length;\n    results.incremental.fast_path_skips = categorized.toSkip.length;\n    results.incremental.mtime_changed = categorized.toUpdate.length;\n\n    for (const unchangedPath of categorized.toSkip) {\n      if (constitutionalSet.has(getCachedKey(unchangedPath))) {\n        results.constitutional.alreadyIndexed++;\n      }\n    }\n\n    const categorizeTime = Date.now() - startCategorize;\n    console.error(`[memory-index-scan] Incremental mode: ${filesToIndex.length}/${files.length} files need indexing (categorized in ${categorizeTime}ms)`);\n    console.error(`[memory-index-scan] Fast-path skips: ${results.incremental.fast_path_skips}, Mtime changed: ${results.incremental.mtime_changed}`);\n  }\n\n  // Attempt move reconciliation before full delete+reindex cycle.\n  // Pairs a vanished path with a new path by grandparent dir + basename (a sibling folder\n  // rename), gated by the new folder still carrying a packet_id and by DB uniqueness +\n  // stored-document_type cross-checks; the matched row is updated in place.\n  if (filesToDelete.length > 0 && filesToIndex.length > 0) {\n    const moveResult = incrementalIndex.reconcileMoves(filesToDelete, filesToIndex);\n    if (moveResult.reconciled.length > 0) {\n      results.moveReconciled = moveResult.reconciled.length;\n      filesToDelete = moveResult.filteredToDelete;\n      filesToIndex = moveResult.filteredToIndex;\n      console.error(`[memory-index-scan] Move reconciled ${moveResult.reconciled.length} path(s) in place`);\n    }\n  }\n\n  const plannedScanActions = [\n    ...filesToIndex.map((filePath) => createStatediffAction('upsert', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n    ...filesToDelete.map((filePath) => createStatediffAction('delete', {\n      target: 'memory_index',\n      key: getCachedKey(filePath),\n      sourceOperation: 'scan',\n      metadata: { filePath },\n    })),\n  ];\n  if (plannedScanActions.length > 0) {\n    console.error(`[memory-index-scan] Statediff plan: ${plannedScanActions.length} action(s) before scan writes`);\n  }\n\n  // Track successfully indexed files for post-indexing mtime update.\n  // SAFETY INVARIANT: mtime markers are updated ONLY after indexing succeeds.\n  // Failed files keep their old mtime so shouldReindex() returns 'modified'\n  // Or 'new' on the next scan, ensuring automatic retry. Moving this update\n  // Before indexing would cause silent data loss вҖ” a failed file would be\n  // Marked \"already indexed\" and permanently skipped.\n  const successfullyIndexedFiles: string[] = [];\n  const scanBatchSize = BATCH_SIZE;\n\n  ctx.onPhase?.('indexing');\n  ctx.onProgress?.({ processed: 0, total: filesToIndex.length });\n\n  if (filesToIndex.length > 0) {\n    let processedInScan = 0;\n    const batchResults = await processBatches(filesToIndex, async (filePath: string) => {\n      // Cancellation is checked between files (mirrors ingest). A cancelled file is\n      // returned as a no-op so its mtime is never bumped, preserving retry on re-run.\n      if (ctx.isCancelled?.()) {\n        return { status: 'cancelled' } as IndexResult;\n      }\n      const isSpecDoc = specDocKeySet.has(getCachedKey(filePath));\n      // Constitutional markdown is policy text, not evidence-bearing memory.\n      // It does not carry primary-evidence sections or ANCHOR tags by design, so the\n      // strict sufficiency gate would always reject it. Treat constitutional files like\n      // spec docs and pass them through warn-only mode so they index against the same\n      // pipeline without the document-evidence requirements.\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n      // During force reindex, use warn-only for all files вҖ” the goal is to index\n      // everything that has valid frontmatter, not to enforce template contracts on\n      // older files created before current templates were established.\n      const useWarnOnly = force || isSpecDoc || isConstitutional;\n      const indexResult = await indexSingleFile(filePath, force, {\n        ...(useWarnOnly ? { qualityGateMode: 'warn-only' as const } : {}),\n        fromScan: true,\n        asyncEmbedding: true,\n        governance: governedIngest ? governanceDecision : undefined,\n      });\n      processedInScan += 1;\n      ctx.onProgress?.({ processed: processedInScan, total: filesToIndex.length });\n      return indexResult;\n    }, scanBatchSize, undefined, { shouldAbort: () => ctx.isCancelled?.() ?? false });\n\n    for (let i = 0; i < batchResults.length; i++) {\n      const result = batchResults[i];\n      const filePath = filesToIndex[i];\n      const isConstitutional = constitutionalSet.has(getCachedKey(filePath));\n\n      if (result.error) {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: result.error,\n          errorDetail: result.errorDetail\n        });\n      } else if (isIndexResult(result)) {\n        const isSuccessfulStatus =\n          result.status === 'success' ||\n          result.status === 'indexed' ||\n          result.status === 'updated' ||\n          result.status === 'unchanged' ||\n          result.status === 'reinforced' ||\n          result.status === 'duplicate' ||\n          result.status === 'deferred';\n        // A cancelled file was never indexed and was never going to be: counting it\n        // as a failure would attribute an operator-requested stop to a file error.\n        // It is neither success nor failure, so it falls through both tallies.\n        if (!isSuccessfulStatus && result.status !== 'cancelled') {\n          results.failed++;\n        }\n\n        if (result.status === 'indexed') {\n          results.indexed++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'updated') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'unchanged') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'reinforced') {\n          results.updated++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('upsert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        } else if (result.status === 'duplicate') {\n          results.unchanged++;\n          successfullyIndexedFiles.push(filePath);\n        } else if (result.status === 'deferred') {\n          results.indexed++;\n          results.deferred++;\n          successfullyIndexedFiles.push(filePath);\n          scanAppliedActions.push(createStatediffAction('insert', {\n            target: 'memory_index',\n            key: String(result.id ?? getCachedKey(filePath)),\n            sourceOperation: 'scan',\n            metadata: { filePath, specFolder: result.specFolder ?? null, status: result.status },\n          }));\n        }\n\n        if (isConstitutional) {\n          if (result.status === 'indexed') {\n            results.constitutional.indexed++;\n          } else if (result.status === 'unchanged') {\n            results.constitutional.alreadyIndexed++;\n          }\n        }\n\n        if (result.status !== 'unchanged') {\n          const rejectionDetail = !isSuccessfulStatus\n            ? {\n                ...(typeof result.rejectionCode === 'string' && result.rejectionCode.length > 0\n                  ? { rejectionCode: result.rejectionCode }\n                  : {}),\n                ...(typeof result.rejectionReason === 'string' && result.rejectionReason.length > 0\n                  ? { rejectionReason: result.rejectionReason }\n                  : (typeof result.message === 'string' && result.message.length > 0\n                    ? { rejectionReason: result.message }\n                    : {})),\n                ...(typeof result.error === 'string' && result.error.length > 0\n                  ? { error: result.error }\n                  : {}),\n              }\n            : {};\n\n          results.files.push({\n            file: path.basename(filePath),\n            filePath,\n            specFolder: result.specFolder,\n            status: result.status,\n            id: result.id,\n            isConstitutional,\n            ...rejectionDetail,\n          });\n        }\n      } else {\n        results.failed++;\n        results.files.push({\n          file: path.basename(filePath),\n          filePath,\n          status: 'failed',\n          error: 'Unexpected batch result shape',\n          errorDetail: JSON.stringify(result),\n        });\n      }\n    }\n  }\n\n  // Update mtimes ONLY for successfully indexed files, not before indexing.\n  // Failed files keep their old mtime so they are retried on next scan.\n  // This is the ONLY place where scan-triggered mtime updates occur.\n  // See also: indexMemoryFile() sets file_mtime_ms within its DB transaction,\n  // Which rolls back atomically on failure вҖ” a complementary safety mechanism.\n  if (successfullyIndexedFiles.length > 0) {\n    const mtimeUpdateResult = incrementalIndex.batchUpdateMtimes(successfullyIndexedFiles);\n    results.mtimeUpdates = mtimeUpdateResult.updated;\n  }\n\n  if (include_spec_docs) {\n    const database = requireDb();\n    let promoterYieldCount = 0;\n    for (const fileResult of results.files) {\n      // This sweep is synchronous SQLite over EVERY indexed row. On a force scan\n      // that is the whole corpus, so without a periodic macrotask yield the event\n      // loop is starved for the duration and no IPC (status, cancel, health,\n      // search) can be serviced. Yield and re-check cancellation between rows; the\n      // yield lands between self-contained promoteMetadataEdges transactions, never\n      // inside one, so atomicity on the shared connection is preserved.\n      if (++promoterYieldCount % 200 === 0) {\n        if (ctx.isCancelled?.()) {\n          return cancelledScanEnvelope(scanKey);\n        }\n        await new Promise<void>((resolve) => setImmediate(resolve));\n      }\n      if (!fileResult.id || !fileResult.filePath || fileResult.status === 'failed') {\n        continue;\n      }\n      try {\n        const promotion = promoteMetadataEdges(database, {\n          memoryId: fileResult.id,\n          filePath: fileResult.filePath,\n        });\n        results.incremental.metadataPromoter.processed += promotion.processed;\n        results.incremental.metadataPromoter.resolved += promotion.resolved;\n        results.incremental.metadataPromoter.inserted += promotion.inserted;\n        results.incremental.metadataPromoter.skippedManual += promotion.skippedManual;\n        results.incremental.metadataPromoter.staleTombstoned += promotion.staleTombstoned;\n        results.incremental.metadataPromoter.staleDeleted += promotion.staleDeleted;\n        results.incremental.metadataPromoter.warnings += promotion.warnings.length;\n        for (const warning of promotion.warnings) {\n          results.warnings.push(`Metadata edge promoter: ${warning.field} ${warning.reference}: ${warning.message}`);\n        }\n      } catch (error: unknown) {\n        results.warnings.push(`Metadata edge promoter failed for ${fileResult.filePath}: ${toErrorMessage(error)}`);\n      }\n    }\n  }\n\n  if (ctx.isCancelled?.()) {\n    return cancelledScanEnvelope(scanKey);\n  }\n  ctx.onPhase?.('post-processing');\n\n  if (filesToDelete.length > 0) {\n    if (results.failed === 0) {\n      const staleDeleteResult = deleteStaleIndexedRecords(filesToDelete);\n      results.staleDeleted = staleDeleteResult.deleted;\n      results.staleDeleteFailed = staleDeleteResult.failed;\n      scanAppliedActions.push(...staleDeleteResult.actions);\n    } else {\n      console.warn('[memory-index-scan] Deferring stale cleanup because one or more replacement files failed to index');\n    }\n  }\n\n  const orphanSweepResult = await timedPhase('orphan-sweep', () => runGlobalOrphanSweep());\n  results.orphanSwept = orphanSweepResult.swept;\n  results.orphanSweepFailed = orphanSweepResult.failed;\n  results.orphanSweepScanned = orphanSweepResult.scannedRows;\n  results.orphanSweepNextCursor = orphanSweepResult.nextCursor;\n  scanAppliedActions.push(...orphanSweepResult.actions);\n\n  results.postInsertEnrichmentRepaired = await timedPhase('enrichment-repair', () => runPostInsertEnrichmentRepairBackfill());\n  if (results.postInsertEnrichmentRepaired > 0) {\n    scanAppliedActions.push(createStatediffAction('upsert', {\n      target: 'graph_edge',\n      key: 'post-insert-enrichment-repair',\n      sourceOperation: 'scan',\n      metadata: { postInsertEnrichmentRepaired: results.postInsertEnrichmentRepaired },\n    }));\n  }\n\n  results.triggerEmbeddingBackfill = await timedPhase('trigger-backfill', () =>\n    runTriggerEmbeddingBackfill(requireDb(), { isCancelled: () => ctx.isCancelled?.() ?? false }));\n  if (triggerBackfillChangedRows(results.triggerEmbeddingBackfill)) {\n    scanAppliedActions.push(createTriggerBackfillAction(results.triggerEmbeddingBackfill));\n  }\n  results.nearDuplicateRepaired = await timedPhase('near-dup-repair', () => runNearDuplicateRepairBackfill());\n\n  // Create causal chains between spec folder documents.\n  // Includes deferred indexing outcomes and incremental single-file updates.\n  if (include_spec_docs) {\n    try {\n      // Determine which spec folders had spec document changes in this scan.\n      // We use parsed document type (not basename) to avoid false positives\n      // From memory/plan.md or similar filenames.\n      const affectedSpecFolders = new Set<string>();\n      for (const fileResult of results.files) {\n        if (!fileResult.specFolder || fileResult.status === 'failed') {\n          continue;\n        }\n\n        if (!fileResult.filePath) {\n          continue;\n        }\n\n        const docType = memoryParser.extractDocumentType(fileResult.filePath);\n        if (\n          docType !== 'memory' &&\n          docType !== 'constitutional'\n        ) {\n          affectedSpecFolders.add(fileResult.specFolder);\n        }\n      }\n\n      if (affectedSpecFolders.size > 0) {\n        const database = requireDb();\n        const { createSpecDocumentChain, init: initCausalEdges } = await import('../lib/storage/causal-edges.js');\n        initCausalEdges(database);\n\n        // Build full per-folder document map from DB (not just this scan's files).\n        const selectDocIds = database.prepare(`\n          SELECT document_type, MAX(id) AS id\n          FROM memory_index\n          WHERE spec_folder = ?\n            AND document_type IN ('spec', 'plan', 'tasks', 'checklist', 'decision_record', 'implementation_summary', 'research', 'handover', 'graph_metadata')\n          GROUP BY document_type\n        `);\n\n        let chainsCreated = 0;\n        let foldersProcessed = 0;\n        let chainYieldCount = 0;\n\n        for (const folder of affectedSpecFolders) {","lineStart":1,"lineEnd":1315,"totalLines":1316,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781764217297,"end":1781764217306}},"metadata":{"openai":{"itemId":"fc_029fb0d52577e901016a3390792c50819198a2332027942d26"}},"id":"prt_ed96c5996001JXdWIMy2qFH1S6","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c1eea001tzvVVbCyA2kr7i"}}
{"type":"tool_use","timestamp":1781764217334,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_7mvptagjFiuWKXzOdZ0sGyMr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Index Scan Job Handlers\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Status/cancel surface for background memory_index_scan jobs backed\n5: // by the kind-agnostic maintenance job store.\n6: \n7: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n8:    1. IMPORTS\n9: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n10: \n11: import { checkDatabaseUpdated } from '../core/index.js';\n12: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n13: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n14: import {\n15:   getMaintenanceJob,\n16:   requestCancel,\n17:   isTerminalJobState,\n18:   type MaintenanceJob,\n19: } from '../lib/ops/job-store.js';\n20: \n21: import type { MCPResponse } from './types.js';\n22: \n23: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n24: \n25: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n26:    2. TYPES\n27: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n28: \n29: interface MemoryIndexScanStatusArgs {\n30:   jobId: string;\n31: }\n32: \n33: interface MemoryIndexScanCancelArgs {\n34:   jobId: string;\n35: }\n36: \n37: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n38:    3. HELPERS\n39: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n40: \n41: function progressPercent(job: MaintenanceJob): number {\n42:   if (job.progressTotal <= 0) return 0;\n43:   const raw = Math.round((job.progressProcessed / job.progressTotal) * 100);\n44:   return Math.max(0, Math.min(100, raw));\n45: }\n46: \n47: function mapScanJobForResponse(job: MaintenanceJob): Record<string, unknown> {\n48:   return {\n49:     jobId: job.id,\n50:     kind: job.kind,\n51:     state: job.state,\n52:     phase: job.phase,\n53:     progress: { processed: job.progressProcessed, total: job.progressTotal },\n54:     progressPercent: progressPercent(job),\n55:     cancelRequested: job.cancelRequested,\n56:     errors: job.errors,\n57:     result: job.result,\n58:     createdAt: job.createdAt,\n59:     updatedAt: job.updatedAt,\n60:   };\n61: }\n62: \n63: // Scan job tools own only index_scan jobs; an ingest jobId is not addressable here.\n64: function getScanJob(jobId: string): MaintenanceJob | null {\n65:   const job = getMaintenanceJob(jobId);\n66:   if (!job || job.kind !== 'index_scan') return null;\n67:   return job;\n68: }\n69: \n70: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n71:    4. HANDLERS\n72: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n73: \n74: async function handleMemoryIndexScanStatus(args: MemoryIndexScanStatusArgs): Promise<MCPResponse> {\n75:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan_status');\n76:   await checkDatabaseUpdated();\n77: \n78:   if (!args.jobId || typeof args.jobId !== 'string') {\n79:     throw new Error('jobId is required and must be a string');\n80:   }\n81: \n82:   const job = getScanJob(args.jobId);\n83:   if (!job) {\n84:     return createMCPErrorResponse({\n85:       tool: 'memory_index_scan_status',\n86:       error: `Index scan job not found: ${args.jobId}`,\n87:       code: 'E404',\n88:       details: { jobId: args.jobId },\n89:       recovery: {\n90:         hint: 'Verify the jobId and retry.',\n91:         actions: ['Call memory_index_scan with background:true to create a new background scan job'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   return createMCPSuccessResponse({\n98:     tool: 'memory_index_scan_status',\n99:     summary: `Index scan job ${job.id}: ${job.state}${job.phase ? ` (${job.phase})` : ''}`,\n100:     data: mapScanJobForResponse(job),\n101:   });\n102: }\n103: \n104: async function handleMemoryIndexScanCancel(args: MemoryIndexScanCancelArgs): Promise<MCPResponse> {\n105:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan_cancel');\n106:   await checkDatabaseUpdated();\n107: \n108:   if (!args.jobId || typeof args.jobId !== 'string') {\n109:     throw new Error('jobId is required and must be a string');\n110:   }\n111: \n112:   const job = getScanJob(args.jobId);\n113:   if (!job) {\n114:     return createMCPErrorResponse({\n115:       tool: 'memory_index_scan_cancel',\n116:       error: `Index scan job not found: ${args.jobId}`,\n117:       code: 'E404',\n118:       details: { jobId: args.jobId },\n119:       recovery: {\n120:         hint: 'Verify the jobId and retry.',\n121:         actions: ['Call memory_index_scan_status with a known jobId'],\n122:         severity: 'warning',\n123:       },\n124:     });\n125:   }\n126: \n127:   if (isTerminalJobState(job.state)) {\n128:     return createMCPSuccessResponse({\n129:       tool: 'memory_index_scan_cancel',\n130:       summary: `Index scan job ${job.id} is already terminal (${job.state})`,\n131:       data: mapScanJobForResponse(job),\n132:     });\n133:   }\n134: \n135:   await requestCancel(args.jobId);\n136:   const updated = getScanJob(args.jobId) ?? job;\n137: \n138:   return createMCPSuccessResponse({\n139:     tool: 'memory_index_scan_cancel',\n140:     summary: `Cancellation requested for index scan job ${updated.id}`,\n141:     data: mapScanJobForResponse(updated),\n142:   });\n143: }\n144: \n145: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n146:    5. EXPORTS\n147: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n148: \n149: const handle_memory_index_scan_status = handleMemoryIndexScanStatus;\n150: const handle_memory_index_scan_cancel = handleMemoryIndexScanCancel;\n151: \n152: export {\n153:   handleMemoryIndexScanStatus,\n154:   handleMemoryIndexScanCancel,\n155:   mapScanJobForResponse,\n156:   handle_memory_index_scan_status,\n157:   handle_memory_index_scan_cancel,\n158: };\n\n(End of file - total 158 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Index Scan Job Handlers\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Status/cancel surface for background memory_index_scan jobs backed\n// by the kind-agnostic maintenance job store.\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  getMaintenanceJob,\n  requestCancel,\n  isTerminalJobState,\n  type MaintenanceJob,\n} from '../lib/ops/job-store.js';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Index Scan Job Handlers\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Status/cancel surface for background memory_index_scan jobs backed\n// by the kind-agnostic maintenance job store.\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  getMaintenanceJob,\n  requestCancel,\n  isTerminalJobState,\n  type MaintenanceJob,\n} from '../lib/ops/job-store.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\ninterface MemoryIndexScanStatusArgs {\n  jobId: string;\n}\n\ninterface MemoryIndexScanCancelArgs {\n  jobId: string;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. HELPERS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction progressPercent(job: MaintenanceJob): number {\n  if (job.progressTotal <= 0) return 0;\n  const raw = Math.round((job.progressProcessed / job.progressTotal) * 100);\n  return Math.max(0, Math.min(100, raw));\n}\n\nfunction mapScanJobForResponse(job: MaintenanceJob): Record<string, unknown> {\n  return {\n    jobId: job.id,\n    kind: job.kind,\n    state: job.state,\n    phase: job.phase,\n    progress: { processed: job.progressProcessed, total: job.progressTotal },\n    progressPercent: progressPercent(job),\n    cancelRequested: job.cancelRequested,\n    errors: job.errors,\n    result: job.result,\n    createdAt: job.createdAt,\n    updatedAt: job.updatedAt,\n  };\n}\n\n// Scan job tools own only index_scan jobs; an ingest jobId is not addressable here.\nfunction getScanJob(jobId: string): MaintenanceJob | null {\n  const job = getMaintenanceJob(jobId);\n  if (!job || job.kind !== 'index_scan') return null;\n  return job;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. HANDLERS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nasync function handleMemoryIndexScanStatus(args: MemoryIndexScanStatusArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan_status');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getScanJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan_status',\n      error: `Index scan job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_index_scan with background:true to create a new background scan job'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan_status',\n    summary: `Index scan job ${job.id}: ${job.state}${job.phase ? ` (${job.phase})` : ''}`,\n    data: mapScanJobForResponse(job),\n  });\n}\n\nasync function handleMemoryIndexScanCancel(args: MemoryIndexScanCancelArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan_cancel');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getScanJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan_cancel',\n      error: `Index scan job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_index_scan_status with a known jobId'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (isTerminalJobState(job.state)) {\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan_cancel',\n      summary: `Index scan job ${job.id} is already terminal (${job.state})`,\n      data: mapScanJobForResponse(job),\n    });\n  }\n\n  await requestCancel(args.jobId);\n  const updated = getScanJob(args.jobId) ?? job;\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan_cancel',\n    summary: `Cancellation requested for index scan job ${updated.id}`,\n    data: mapScanJobForResponse(updated),\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. EXPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nconst handle_memory_index_scan_status = handleMemoryIndexScanStatus;\nconst handle_memory_index_scan_cancel = handleMemoryIndexScanCancel;\n\nexport {\n  handleMemoryIndexScanStatus,\n  handleMemoryIndexScanCancel,\n  mapScanJobForResponse,\n  handle_memory_index_scan_status,\n  handle_memory_index_scan_cancel,\n};","lineStart":1,"lineEnd":158,"totalLines":158,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","time":{"start":1781764217330,"end":1781764217333}},"metadata":{"openai":{"itemId":"fc_029fb0d52577e901016a3390792c688191bb192b14d367912e"}},"id":"prt_ed96c59d3001OSpbJW4TBIRNOy","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c1eea001tzvVVbCyA2kr7i"}}
{"type":"tool_use","timestamp":1781764217342,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_ZQiVR5sl0EOz09w0uvpEfrvj","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Ingest Handlers\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: \n5: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n6:    1. IMPORTS\n7: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n8: \n9: import fs from 'node:fs';\n10: import path from 'node:path';\n11: \n12: import { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\n13: import { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\n14: import { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\n15: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n16: import {\n17:   createIngestJob,\n18:   enqueueIngestJob,\n19:   getIngestJob,\n20:   cancelIngestJob,\n21:   getIngestProgressPercent,\n22:   getIngestForecast,\n23:   type IngestJob,\n24: } from '../lib/ops/job-queue.js';\n25: import * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\n26: import { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\n27: import { createJobId } from '../lib/ops/job-store.js';\n28: \n29: import type { MCPResponse } from './types.js';\n30: \n31: // Feature catalog: Async ingestion job lifecycle\n32: // Feature catalog: Workspace scanning and indexing (memory_index_scan)\n33: \n34: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n35:    2. TYPES\n36: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n37: \n38: interface MemoryIngestStartArgs {\n39:   paths: string[];\n40:   specFolder?: string;\n41:   tenantId?: string;\n42:   userId?: string;\n43:   agentId?: string;\n44:   sessionId?: string;\n45:   provenanceSource?: string;\n46:   provenanceActor?: string;\n47:   governedAt?: string;\n48:   retentionPolicy?: 'keep' | 'ephemeral';\n49:   deleteAfter?: string;\n50: }\n51: \n52: interface MemoryIngestStatusArgs {\n53:   jobId: string;\n54: }\n55: \n56: interface MemoryIngestCancelArgs {\n57:   jobId: string;\n58: }\n59: \n60: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n61:    3. CONSTANTS\n62: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n63: \n64: const MAX_PATH_LENGTH = 500;\n65: \n66: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n67:    4. HELPERS\n68: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n69: \n70: function hasTraversalSegment(inputPath: string): boolean {\n71:   return inputPath.split(/[\\\\/]+/).includes('..');\n72: }\n73: \n74: function toPublicPathLabel(filePath: string): string {\n75:   return filePath === '__job__' ? filePath : path.basename(filePath || '');\n76: }\n77: \n78: function mapJobForResponse(job: IngestJob): Record<string, unknown> {\n79:   let forecast: Record<string, unknown>;\n80:   try {\n81:     forecast = getIngestForecast(job) as unknown as Record<string, unknown>;\n82:   } catch (error: unknown) {\n83:     const message = error instanceof Error ? error.message : String(error);\n84:     forecast = {\n85:       etaSeconds: null,\n86:       etaConfidence: null,\n87:       failureRisk: null,\n88:       riskSignals: [],\n89:       caveat: `Forecast unavailable: ${message}`,\n90:     };\n91:   }\n92: \n93:   let telemetryPayload: Record<string, unknown> | undefined;\n94:   if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n95:     const telemetry = retrievalTelemetry.createTelemetry();\n96:     retrievalTelemetry.recordLifecycleForecastDiagnostics(telemetry, forecast, {\n97:       state: job.state,\n98:       progress: getIngestProgressPercent(job),\n99:       filesProcessed: job.filesProcessed,\n100:       filesTotal: job.filesTotal,\n101:     });\n102:     telemetryPayload = retrievalTelemetry.toJSON(telemetry);\n103:   }\n104: \n105:   return {\n106:     jobId: job.id,\n107:     state: job.state,\n108:     specFolder: job.specFolder,\n109:     paths: job.paths.map((entry) => toPublicPathLabel(entry)),\n110:     filesTotal: job.filesTotal,\n111:     filesProcessed: job.filesProcessed,\n112:     progress: getIngestProgressPercent(job),\n113:     errors: job.errors.map((entry) => ({\n114:       ...entry,\n115:       filePath: toPublicPathLabel(entry.filePath),\n116:     })),\n117:     createdAt: job.createdAt,\n118:     updatedAt: job.updatedAt,\n119:     forecast: forecast as unknown as Record<string, unknown>,\n120:     ...(telemetryPayload ? { _telemetry: telemetryPayload } : {}),\n121:   };\n122: }\n123: \n124: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n125:    5. HANDLERS\n126: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n127: \n128: /** Handle memory_ingest_start tool вҖ” begins batch ingestion of spec documents from disk.\n129:  * @param args - Ingest arguments (paths, scope, options)\n130:  * @returns MCP response with job ID and forecast\n131:  */\n132: async function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n133:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n134:   await checkDatabaseUpdated();\n135:   const governedIngest = requiresGovernedIngest(args);\n136:   const governanceDecision = validateGovernedIngest(args);\n137:   if (!governanceDecision.allowed) {\n138:     throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n139:   }\n140: \n141:   let paths = Array.isArray(args.paths)\n142:     ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n143:     : [];\n144: \n145:   if (paths.length === 0) {\n146:     throw new Error('paths must be a non-empty array of file paths');\n147:   }\n148: \n149:   if (paths.length > MAX_INGEST_PATHS) {\n150:     throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n151:   }\n152: \n153:   const overlengthPaths = paths\n154:     .filter((entry) => entry.length > MAX_PATH_LENGTH)\n155:     .map((entry) => ({\n156:       filePath: toPublicPathLabel(entry),\n157:       reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n158:     }));\n159:   const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n160:   if (withinLength.length !== paths.length) {\n161:     console.warn(\n162:       `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n163:     );\n164:   }\n165:   paths = withinLength;\n166: \n167:   if (paths.length === 0) {\n168:     throw new Error('paths must be a non-empty array of file paths');\n169:   }\n170: \n171:   const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n172:   const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n173:     ? path.resolve(process.cwd(), configuredMemoryRoot)\n174:     : path.resolve(path.dirname(DATABASE_PATH));\n175:   const allowedBasePaths = Array.from(\n176:     new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n177:   );\n178: \n179:   const normalizedPaths: string[] = [];\n180:   const invalidPaths: Array<{ input: string; reason: string }> = [];\n181: \n182:   for (const inputPath of paths) {\n183:     const trimmedPath = inputPath.trim();\n184: \n185:     if (hasTraversalSegment(trimmedPath)) {\n186:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n187:       continue;\n188:     }\n189: \n190:     const resolvedPath = path.resolve(trimmedPath);\n191: \n192:     const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n193:     if (hasTraversalAfterResolve) {\n194:       invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n195:       continue;\n196:     }\n197: \n198:     // Resolve symlinks so traversal checks apply to canonical targets.\n199:     let realPath: string;\n200:     try {\n201:       realPath = fs.realpathSync(resolvedPath);\n202:     } catch {\n203:       // Fall back to resolvedPath during pre-validation when target does not yet exist.\n204:       realPath = resolvedPath;\n205:     }\n206: \n207:     const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n208:       realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n209:     ));\n210:     if (!isWithinAllowedBase) {\n211:       invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n212:       continue;\n213:     }\n214: \n215:     normalizedPaths.push(realPath);\n216:   }\n217: \n218:   if (invalidPaths.length > 0) {\n219:     return createMCPErrorResponse({\n220:       tool: 'memory_ingest_start',\n221:       error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n222:       code: 'E_VALIDATION',\n223:       details: {\n224:         allowedBasePathCount: allowedBasePaths.length,\n225:         allowedPathPolicy: 'configured-memory-roots',\n226:         rejectedCount: invalidPaths.length,\n227:       },\n228:       recovery: {\n229:         hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n230:         actions: ['Use absolute paths rooted in the configured memory base path'],\n231:         severity: 'warning',\n232:       },\n233:     });\n234:   }\n235: \n236:   const deduplicatedPaths: string[] = [];\n237:   const seenPaths = new Set<string>();\n238:   let duplicatePathCount = 0;\n239: \n240:   for (const normalizedPath of normalizedPaths) {\n241:     if (seenPaths.has(normalizedPath)) {\n242:       duplicatePathCount++;\n243:       continue;\n244:     }\n245: \n246:     seenPaths.add(normalizedPath);\n247:     deduplicatedPaths.push(normalizedPath);\n248:   }\n249: \n250:   paths = deduplicatedPaths;\n251: \n252:   const jobId = createJobId();\n253:   const job = await createIngestJob({\n254:     id: jobId,\n255:     paths,\n256:     specFolder: args.specFolder,\n257:     governance: governedIngest ? governanceDecision : null,\n258:   });\n259: \n260:   enqueueIngestJob(job.id);\n261: \n262:   return createMCPSuccessResponse({\n263:     tool: 'memory_ingest_start',\n264:     summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n265:     data: {\n266:       jobId: job.id,\n267:       state: job.state,\n268:       filesTotal: job.filesTotal,\n269:       acceptedPathCount: paths.length,\n270:       rejectedPathCount: overlengthPaths.length,\n271:       ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n272:       ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n273:     },\n274:     hints: [\n275:       'Use memory_ingest_status with jobId to poll progress',\n276:       'Use memory_ingest_cancel with jobId to stop processing',\n277:       ...(duplicatePathCount > 0\n278:         ? ['Duplicate input paths were deduplicated before queueing']\n279:         : []),\n280:       ...(overlengthPaths.length > 0\n281:         ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n282:         : []),\n283:     ],\n284:   });\n285: }\n286: \n287: async function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {\n288:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_status');\n289:   await checkDatabaseUpdated();\n290: \n291:   if (!args.jobId || typeof args.jobId !== 'string') {\n292:     throw new Error('jobId is required and must be a string');\n293:   }\n294: \n295:   const job = getIngestJob(args.jobId);\n296:   if (!job) {\n297:     return createMCPErrorResponse({\n298:       tool: 'memory_ingest_status',\n299:       error: `Ingest job not found: ${args.jobId}`,\n300:       code: 'E404',\n301:       details: { jobId: args.jobId },\n302:       recovery: {\n303:         hint: 'Verify the jobId and retry.',\n304:         actions: ['Call memory_ingest_start to create a new ingest job'],\n305:         severity: 'warning',\n306:       },\n307:     });\n308:   }\n309: \n310:   return createMCPSuccessResponse({\n311:     tool: 'memory_ingest_status',\n312:     summary: `Ingest job ${job.id}: ${job.state} (${job.filesProcessed}/${job.filesTotal})`,\n313:     data: mapJobForResponse(job),\n314:   });\n315: }\n316: \n317: async function handleMemoryIngestCancel(args: MemoryIngestCancelArgs): Promise<MCPResponse> {\n318:   await ensureMemoryRuntimeInitialized('handler:memory_ingest_cancel');\n319:   await checkDatabaseUpdated();\n320: \n321:   if (!args.jobId || typeof args.jobId !== 'string') {\n322:     throw new Error('jobId is required and must be a string');\n323:   }\n324: \n325:   const job = getIngestJob(args.jobId);\n326:   if (!job) {\n327:     return createMCPErrorResponse({\n328:       tool: 'memory_ingest_cancel',\n329:       error: `Ingest job not found: ${args.jobId}`,\n330:       code: 'E404',\n331:       details: { jobId: args.jobId },\n332:       recovery: {\n333:         hint: 'Verify the jobId and retry.',\n334:         actions: ['Call memory_ingest_status with a known jobId'],\n335:         severity: 'warning',\n336:       },\n337:     });\n338:   }\n339: \n340:   if (job.state === 'complete' || job.state === 'failed' || job.state === 'cancelled') {\n341:     return createMCPSuccessResponse({\n342:       tool: 'memory_ingest_cancel',\n343:       summary: `Ingest job ${job.id} is already terminal (${job.state})`,\n344:       data: mapJobForResponse(job),\n345:     });\n346:   }\n347: \n348:   const cancelled = await cancelIngestJob(args.jobId);\n349:   const summary = cancelled.state === 'cancelled'\n350:     ? `Cancelled ingest job ${cancelled.id}`\n351:     : `Ingest job ${cancelled.id} is already terminal (${cancelled.state})`;\n352: \n353:   return createMCPSuccessResponse({\n354:     tool: 'memory_ingest_cancel',\n355:     summary,\n356:     data: mapJobForResponse(cancelled),\n357:   });\n358: }\n359: \n360: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n361:    6. EXPORTS\n362: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n363: \n364: const handle_memory_ingest_start = handleMemoryIngestStart;\n365: const handle_memory_ingest_status = handleMemoryIngestStatus;\n366: const handle_memory_ingest_cancel = handleMemoryIngestCancel;\n367: \n368: export {\n369:   handleMemoryIngestStart,\n370:   handleMemoryIngestStatus,\n371:   handleMemoryIngestCancel,\n372:   handle_memory_ingest_start,\n373:   handle_memory_ingest_status,\n374:   handle_memory_ingest_cancel,\n375: };\n\n(End of file - total 375 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Ingest Handlers\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\n\nimport { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\nimport { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  createIngestJob,\n  enqueueIngestJob,\n  getIngestJob,\n  cancelIngestJob,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Ingest Handlers\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\n\nimport { ALLOWED_BASE_PATHS, DATABASE_PATH, checkDatabaseUpdated } from '../core/index.js';\nimport { MAX_INGEST_PATHS } from '../schemas/tool-input-schemas.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  createIngestJob,\n  enqueueIngestJob,\n  getIngestJob,\n  cancelIngestJob,\n  getIngestProgressPercent,\n  getIngestForecast,\n  type IngestJob,\n} from '../lib/ops/job-queue.js';\nimport * as retrievalTelemetry from '../lib/telemetry/retrieval-telemetry.js';\nimport { requiresGovernedIngest, validateGovernedIngest } from '../lib/governance/scope-governance.js';\nimport { createJobId } from '../lib/ops/job-store.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Async ingestion job lifecycle\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\ninterface MemoryIngestStartArgs {\n  paths: string[];\n  specFolder?: string;\n  tenantId?: string;\n  userId?: string;\n  agentId?: string;\n  sessionId?: string;\n  provenanceSource?: string;\n  provenanceActor?: string;\n  governedAt?: string;\n  retentionPolicy?: 'keep' | 'ephemeral';\n  deleteAfter?: string;\n}\n\ninterface MemoryIngestStatusArgs {\n  jobId: string;\n}\n\ninterface MemoryIngestCancelArgs {\n  jobId: string;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. CONSTANTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nconst MAX_PATH_LENGTH = 500;\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. HELPERS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction hasTraversalSegment(inputPath: string): boolean {\n  return inputPath.split(/[\\\\/]+/).includes('..');\n}\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction mapJobForResponse(job: IngestJob): Record<string, unknown> {\n  let forecast: Record<string, unknown>;\n  try {\n    forecast = getIngestForecast(job) as unknown as Record<string, unknown>;\n  } catch (error: unknown) {\n    const message = error instanceof Error ? error.message : String(error);\n    forecast = {\n      etaSeconds: null,\n      etaConfidence: null,\n      failureRisk: null,\n      riskSignals: [],\n      caveat: `Forecast unavailable: ${message}`,\n    };\n  }\n\n  let telemetryPayload: Record<string, unknown> | undefined;\n  if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n    const telemetry = retrievalTelemetry.createTelemetry();\n    retrievalTelemetry.recordLifecycleForecastDiagnostics(telemetry, forecast, {\n      state: job.state,\n      progress: getIngestProgressPercent(job),\n      filesProcessed: job.filesProcessed,\n      filesTotal: job.filesTotal,\n    });\n    telemetryPayload = retrievalTelemetry.toJSON(telemetry);\n  }\n\n  return {\n    jobId: job.id,\n    state: job.state,\n    specFolder: job.specFolder,\n    paths: job.paths.map((entry) => toPublicPathLabel(entry)),\n    filesTotal: job.filesTotal,\n    filesProcessed: job.filesProcessed,\n    progress: getIngestProgressPercent(job),\n    errors: job.errors.map((entry) => ({\n      ...entry,\n      filePath: toPublicPathLabel(entry.filePath),\n    })),\n    createdAt: job.createdAt,\n    updatedAt: job.updatedAt,\n    forecast: forecast as unknown as Record<string, unknown>,\n    ...(telemetryPayload ? { _telemetry: telemetryPayload } : {}),\n  };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. HANDLERS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n/** Handle memory_ingest_start tool вҖ” begins batch ingestion of spec documents from disk.\n * @param args - Ingest arguments (paths, scope, options)\n * @returns MCP response with job ID and forecast\n */\nasync function handleMemoryIngestStart(args: MemoryIngestStartArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_start');\n  await checkDatabaseUpdated();\n  const governedIngest = requiresGovernedIngest(args);\n  const governanceDecision = validateGovernedIngest(args);\n  if (!governanceDecision.allowed) {\n    throw new Error(`Governed ingest rejected: ${governanceDecision.issues.join('; ')}`);\n  }\n\n  let paths = Array.isArray(args.paths)\n    ? args.paths.filter((entry): entry is string => typeof entry === 'string' && entry.trim().length > 0)\n    : [];\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  if (paths.length > MAX_INGEST_PATHS) {\n    throw new Error(`paths exceeds maximum of ${MAX_INGEST_PATHS}`);\n  }\n\n  const overlengthPaths = paths\n    .filter((entry) => entry.length > MAX_PATH_LENGTH)\n    .map((entry) => ({\n      filePath: toPublicPathLabel(entry),\n      reason: `path exceeds ${MAX_PATH_LENGTH} characters`,\n    }));\n  const withinLength = paths.filter((entry) => entry.length <= MAX_PATH_LENGTH);\n  if (withinLength.length !== paths.length) {\n    console.warn(\n      `[memory-ingest] Dropped ${paths.length - withinLength.length} path(s) longer than ${MAX_PATH_LENGTH} characters`,\n    );\n  }\n  paths = withinLength;\n\n  if (paths.length === 0) {\n    throw new Error('paths must be a non-empty array of file paths');\n  }\n\n  const configuredMemoryRoot = process.env.MEMORY_BASE_PATH;\n  const derivedAllowedBasePath = configuredMemoryRoot && configuredMemoryRoot.trim().length > 0\n    ? path.resolve(process.cwd(), configuredMemoryRoot)\n    : path.resolve(path.dirname(DATABASE_PATH));\n  const allowedBasePaths = Array.from(\n    new Set([derivedAllowedBasePath, ...ALLOWED_BASE_PATHS].map((basePath) => path.resolve(basePath))),\n  );\n\n  const normalizedPaths: string[] = [];\n  const invalidPaths: Array<{ input: string; reason: string }> = [];\n\n  for (const inputPath of paths) {\n    const trimmedPath = inputPath.trim();\n\n    if (hasTraversalSegment(trimmedPath)) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    const resolvedPath = path.resolve(trimmedPath);\n\n    const hasTraversalAfterResolve = resolvedPath.split(path.sep).includes('..');\n    if (hasTraversalAfterResolve) {\n      invalidPaths.push({ input: inputPath, reason: 'contains path traversal segments (..)' });\n      continue;\n    }\n\n    // Resolve symlinks so traversal checks apply to canonical targets.\n    let realPath: string;\n    try {\n      realPath = fs.realpathSync(resolvedPath);\n    } catch {\n      // Fall back to resolvedPath during pre-validation when target does not yet exist.\n      realPath = resolvedPath;\n    }\n\n    const isWithinAllowedBase = allowedBasePaths.some((basePath) => (\n      realPath === basePath || realPath.startsWith(`${basePath}${path.sep}`)\n    ));\n    if (!isWithinAllowedBase) {\n      invalidPaths.push({ input: inputPath, reason: 'is outside allowed memory roots' });\n      continue;\n    }\n\n    normalizedPaths.push(realPath);\n  }\n\n  if (invalidPaths.length > 0) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_start',\n      error: `Invalid path(s) rejected: ${invalidPaths.map((entry) => `\"${entry.input}\" (${entry.reason})`).join(', ')}`,\n      code: 'E_VALIDATION',\n      details: {\n        allowedBasePathCount: allowedBasePaths.length,\n        allowedPathPolicy: 'configured-memory-roots',\n        rejectedCount: invalidPaths.length,\n      },\n      recovery: {\n        hint: 'Provide file paths under an allowed memory base directory and remove traversal segments.',\n        actions: ['Use absolute paths rooted in the configured memory base path'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  const deduplicatedPaths: string[] = [];\n  const seenPaths = new Set<string>();\n  let duplicatePathCount = 0;\n\n  for (const normalizedPath of normalizedPaths) {\n    if (seenPaths.has(normalizedPath)) {\n      duplicatePathCount++;\n      continue;\n    }\n\n    seenPaths.add(normalizedPath);\n    deduplicatedPaths.push(normalizedPath);\n  }\n\n  paths = deduplicatedPaths;\n\n  const jobId = createJobId();\n  const job = await createIngestJob({\n    id: jobId,\n    paths,\n    specFolder: args.specFolder,\n    governance: governedIngest ? governanceDecision : null,\n  });\n\n  enqueueIngestJob(job.id);\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_start',\n    summary: `Queued ingest job ${job.id} (${job.filesTotal} file(s))`,\n    data: {\n      jobId: job.id,\n      state: job.state,\n      filesTotal: job.filesTotal,\n      acceptedPathCount: paths.length,\n      rejectedPathCount: overlengthPaths.length,\n      ...(duplicatePathCount > 0 ? { duplicatePathCount } : {}),\n      ...(overlengthPaths.length > 0 ? { rejectedPaths: overlengthPaths } : {}),\n    },\n    hints: [\n      'Use memory_ingest_status with jobId to poll progress',\n      'Use memory_ingest_cancel with jobId to stop processing',\n      ...(duplicatePathCount > 0\n        ? ['Duplicate input paths were deduplicated before queueing']\n        : []),\n      ...(overlengthPaths.length > 0\n        ? ['Some input paths were rejected before queueing; inspect rejectedPaths for details']\n        : []),\n    ],\n  });\n}\n\nasync function handleMemoryIngestStatus(args: MemoryIngestStatusArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_status');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getIngestJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_status',\n      error: `Ingest job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_ingest_start to create a new ingest job'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_status',\n    summary: `Ingest job ${job.id}: ${job.state} (${job.filesProcessed}/${job.filesTotal})`,\n    data: mapJobForResponse(job),\n  });\n}\n\nasync function handleMemoryIngestCancel(args: MemoryIngestCancelArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_ingest_cancel');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getIngestJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_ingest_cancel',\n      error: `Ingest job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_ingest_status with a known jobId'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (job.state === 'complete' || job.state === 'failed' || job.state === 'cancelled') {\n    return createMCPSuccessResponse({\n      tool: 'memory_ingest_cancel',\n      summary: `Ingest job ${job.id} is already terminal (${job.state})`,\n      data: mapJobForResponse(job),\n    });\n  }\n\n  const cancelled = await cancelIngestJob(args.jobId);\n  const summary = cancelled.state === 'cancelled'\n    ? `Cancelled ingest job ${cancelled.id}`\n    : `Ingest job ${cancelled.id} is already terminal (${cancelled.state})`;\n\n  return createMCPSuccessResponse({\n    tool: 'memory_ingest_cancel',\n    summary,\n    data: mapJobForResponse(cancelled),\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. EXPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nconst handle_memory_ingest_start = handleMemoryIngestStart;\nconst handle_memory_ingest_status = handleMemoryIngestStatus;\nconst handle_memory_ingest_cancel = handleMemoryIngestCancel;\n\nexport {\n  handleMemoryIngestStart,\n  handleMemoryIngestStatus,\n  handleMemoryIngestCancel,\n  handle_memory_ingest_start,\n  handle_memory_ingest_status,\n  handle_memory_ingest_cancel,\n};","lineStart":1,"lineEnd":375,"totalLines":375,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-ingest.ts","time":{"start":1781764217336,"end":1781764217342}},"metadata":{"openai":{"itemId":"fc_029fb0d52577e901016a3390792c708191987b34d674d2bc8c"}},"id":"prt_ed96c59f30016GaCVcnsUYdxiz","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c1eea001tzvVVbCyA2kr7i"}}
{"type":"tool_use","timestamp":1781764217344,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_0Mud1jO5cNwaYA6IPM3xw33v","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Maintenance Job Store\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Kind-agnostic persisted job lifecycle: jobId, state record, progress\n5: // counters, error capture+truncation, cancel flag, and crash-recovery\n6: // reset. Shared lifecycle/registry across long-running maintenance jobs.\n7: \n8: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n9:    1. IMPORTS\n10: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n11: \n12: import { randomBytes } from 'node:crypto';\n13: \n14: import { requireDb, toErrorMessage } from '../../utils/index.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n18:    2. TYPES\n19: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n20: \n21: export type MaintenanceJobKind = 'ingest' | 'index_scan';\n22: \n23: export type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n24: \n25: export interface JobError {\n26:   source: string;\n27:   message: string;\n28:   timestamp: string;\n29: }\n30: \n31: export interface MaintenanceJob {\n32:   id: string;\n33:   kind: MaintenanceJobKind;\n34:   state: JobLifecycleState;\n35:   phase: string | null;\n36:   progressTotal: number;\n37:   progressProcessed: number;\n38:   cancelRequested: boolean;\n39:   errors: JobError[];\n40:   result: unknown | null;\n41:   payload: unknown | null;\n42:   createdAt: string;\n43:   updatedAt: string;\n44: }\n45: \n46: interface MaintenanceJobRow {\n47:   id: string;\n48:   kind: string;\n49:   state: string;\n50:   phase: string | null;\n51:   progress_total: number;\n52:   progress_processed: number;\n53:   cancel_requested: number;\n54:   errors_json: string;\n55:   result_json: string | null;\n56:   payload_json: string | null;\n57:   created_at: string;\n58:   updated_at: string;\n59: }\n60: \n61: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n62:    3. CONSTANTS\n63: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n64: \n65: export const MAX_STORED_ERRORS = 50;\n66: \n67: const TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n68: \n69: // In-process mirror of cancel_requested. A running job polls this from a hot loop\n70: // to decide whether to stop, avoiding a DB SELECT on the single shared connection\n71: // every check. The cancel request runs in this same process, so the Set is\n72: // authoritative for an in-flight run; the durable column still backs status\n73: // responses and crash recovery. Entries are cleared when a job reaches a terminal\n74: // state so the Set cannot grow without bound across many jobs.\n75: const cancelledJobIds = new Set<string>();\n76: \n77: const ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n78:   queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n79:   running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n80:   complete: new Set<JobLifecycleState>([]),\n81:   failed: new Set<JobLifecycleState>([]),\n82:   cancelled: new Set<JobLifecycleState>([]),\n83: };\n84: \n85: // URL-safe 12-char identifier without a UUID dependency.\n86: const NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n87: \n88: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n89:    4. HELPERS\n90: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n91: \n92: function nowIso(): string {\n93:   return new Date().toISOString();\n94: }\n95: \n96: function isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n97:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n98: }\n99: \n100: function parseJson<T>(value: string | null | undefined, fallback: T): T {\n101:   if (value === null || value === undefined) return fallback;\n102:   try {\n103:     return JSON.parse(value) as T;\n104:   } catch (_error: unknown) {\n105:     return fallback;\n106:   }\n107: }\n108: \n109: function parseJobErrors(value: string | null | undefined): JobError[] {\n110:   const parsed = parseJson<unknown>(value, []);\n111:   return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n112: }\n113: \n114: function mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n115:   if (!row) return null;\n116:   return {\n117:     id: row.id,\n118:     kind: row.kind as MaintenanceJobKind,\n119:     state: row.state as JobLifecycleState,\n120:     phase: row.phase,\n121:     progressTotal: row.progress_total,\n122:     progressProcessed: row.progress_processed,\n123:     cancelRequested: row.cancel_requested === 1,\n124:     errors: parseJobErrors(row.errors_json),\n125:     result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n126:     payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n127:     createdAt: row.created_at,\n128:     updatedAt: row.updated_at,\n129:   };\n130: }\n131: \n132: const SELECT_COLUMNS =\n133:   'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n134: \n135: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n136:    5. SCHEMA\n137: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n138: \n139: export function ensureMaintenanceJobsTable(): void {\n140:   const db = requireDb();\n141:   db.exec(`\n142:     CREATE TABLE IF NOT EXISTS maintenance_jobs (\n143:       id TEXT PRIMARY KEY,\n144:       kind TEXT NOT NULL,\n145:       state TEXT NOT NULL,\n146:       phase TEXT,\n147:       progress_total INTEGER NOT NULL DEFAULT 0,\n148:       progress_processed INTEGER NOT NULL DEFAULT 0,\n149:       cancel_requested INTEGER NOT NULL DEFAULT 0,\n150:       errors_json TEXT NOT NULL DEFAULT '[]',\n151:       result_json TEXT,\n152:       payload_json TEXT,\n153:       created_at TEXT NOT NULL,\n154:       updated_at TEXT NOT NULL\n155:     )\n156:   `);\n157:   db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n158: }\n159: \n160: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n161:    6. IDENTIFIERS\n162: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n163: \n164: export function createJobId(): string {\n165:   const bytes = randomBytes(12);\n166:   let id = '';\n167:   for (let i = 0; i < 12; i++) {\n168:     id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n169:   }\n170:   return `job_${id}`;\n171: }\n172: \n173: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n174:    7. LIFECYCLE\n175: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n176: \n177: export async function createMaintenanceJob(args: {\n178:   id: string;\n179:   kind: MaintenanceJobKind;\n180:   payload?: unknown;\n181: }): Promise<MaintenanceJob> {\n182:   const db = requireDb();\n183:   const timestamp = nowIso();\n184:   const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n185: \n186:   await withBusyRetry(() =>\n187:     db.prepare(`\n188:       INSERT INTO maintenance_jobs (\n189:         id, kind, state, phase, progress_total, progress_processed,\n190:         cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n191:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n192:     `).run(\n193:       args.id,\n194:       args.kind,\n195:       'queued',\n196:       null,\n197:       0,\n198:       0,\n199:       0,\n200:       '[]',\n201:       null,\n202:       payloadJson,\n203:       timestamp,\n204:       timestamp,\n205:     )\n206:   );\n207: \n208:   return {\n209:     id: args.id,\n210:     kind: args.kind,\n211:     state: 'queued',\n212:     phase: null,\n213:     progressTotal: 0,\n214:     progressProcessed: 0,\n215:     cancelRequested: false,\n216:     errors: [],\n217:     result: null,\n218:     payload: args.payload ?? null,\n219:     createdAt: timestamp,\n220:     updatedAt: timestamp,\n221:   };\n222: }\n223: \n224: export function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n225:   const db = requireDb();\n226:   const row = db.prepare(`\n227:     SELECT ${SELECT_COLUMNS}\n228:     FROM maintenance_jobs\n229:     WHERE id = ?\n230:   `).get(jobId) as MaintenanceJobRow | undefined;\n231:   return mapRowToJob(row);\n232: }\n233: \n234: export async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n235:   const db = requireDb();\n236:   const current = getMaintenanceJob(jobId);\n237:   if (!current) {\n238:     throw new Error(`Maintenance job not found: ${jobId}`);\n239:   }\n240: \n241:   if (current.state === nextState) {\n242:     return current;\n243:   }\n244: \n245:   if (!isTransitionAllowed(current.state, nextState)) {\n246:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n247:   }\n248: \n249:   const updatedAt = nowIso();\n250:   const result = await withBusyRetry(() =>\n251:     db.prepare(`\n252:       UPDATE maintenance_jobs\n253:       SET state = ?, updated_at = ?\n254:       WHERE id = ? AND state = ?\n255:     `).run(nextState, updatedAt, jobId, current.state)\n256:   );\n257: \n258:   if ((result as { changes: number }).changes === 0) {\n259:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n260:   }\n261: \n262:   // Every terminal transition must release the in-process cancel mirror, not just\n263:   // completeJob/resetRunningJobsForKind. A cancel-then-fail-while-running race\n264:   // routes through setJobState('failed'); without this the job-id would leak,\n265:   // contradicting the cancelledJobIds bounded-growth guarantee.\n266:   if (isTerminalJobState(nextState)) {\n267:     cancelledJobIds.delete(jobId);\n268:   }\n269: \n270:   return { ...current, state: nextState, updatedAt };\n271: }\n272: \n273: export async function setJobPhase(jobId: string, phase: string): Promise<void> {\n274:   const db = requireDb();\n275:   await withBusyRetry(() =>\n276:     db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n277:       .run(phase, nowIso(), jobId)\n278:   );\n279: }\n280: \n281: export async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n282:   const db = requireDb();\n283:   const processed = Math.max(0, Math.trunc(progress.processed));\n284:   const total = Math.max(0, Math.trunc(progress.total));\n285:   await withBusyRetry(() =>\n286:     db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n287:       .run(processed, total, nowIso(), jobId)\n288:   );\n289: }\n290: \n291: export async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n292:   const db = requireDb();\n293:   const current = getMaintenanceJob(jobId);\n294:   if (!current) {\n295:     throw new Error(`Maintenance job not found: ${jobId}`);\n296:   }\n297: \n298:   let errors: JobError[] = [\n299:     ...current.errors,\n300:     { source, message: toErrorMessage(error), timestamp: nowIso() },\n301:   ];\n302: \n303:   if (errors.length > MAX_STORED_ERRORS) {\n304:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n305:     const trimmedCount = errors.length - tailLength;\n306:     const truncationNotice: JobError = {\n307:       source: '__job__',\n308:       message: `error log truncated (${trimmedCount} older entries removed)`,\n309:       timestamp: nowIso(),\n310:     };\n311:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n312:     errors = [truncationNotice, ...truncatedTail];\n313:   }\n314: \n315:   const updatedAt = nowIso();\n316:   await withBusyRetry(() =>\n317:     db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n318:       .run(JSON.stringify(errors), updatedAt, jobId)\n319:   );\n320: \n321:   return { ...current, errors, updatedAt };\n322: }\n323: \n324: export async function requestCancel(jobId: string): Promise<void> {\n325:   // Set the in-process flag first so a running loop observes the cancel even if the\n326:   // durable write contends on the shared connection.\n327:   cancelledJobIds.add(jobId);\n328:   const db = requireDb();\n329:   await withBusyRetry(() =>\n330:     db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n331:       .run(nowIso(), jobId)\n332:   );\n333: }\n334: \n335: // Synchronous so the runner can poll it inline at batch/phase boundaries.\n336: export function isCancelRequested(jobId: string): boolean {\n337:   const db = requireDb();\n338:   const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n339:     .get(jobId) as { cancel_requested?: number } | undefined;\n340:   return !!row && row.cancel_requested === 1;\n341: }\n342: \n343: // Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n344: // mirror, so it is safe to call thousands of times during a scan without touching\n345: // the shared SQLite connection. Use isCancelRequested when durability across the\n346: // in-memory boundary matters (status responses, post-restart).\n347: export function isCancelRequestedFast(jobId: string): boolean {\n348:   return cancelledJobIds.has(jobId);\n349: }\n350: \n351: export async function completeJob(\n352:   jobId: string,\n353:   options: { state: JobLifecycleState; result?: unknown },\n354: ): Promise<MaintenanceJob> {\n355:   const db = requireDb();\n356:   const current = getMaintenanceJob(jobId);\n357:   if (!current) {\n358:     throw new Error(`Maintenance job not found: ${jobId}`);\n359:   }\n360: \n361:   if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n362:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n363:   }\n364: \n365:   const updatedAt = nowIso();\n366:   const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n367:   const completion = await withBusyRetry(() =>\n368:     db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n369:       .run(options.state, resultJson, updatedAt, jobId, current.state)\n370:   );\n371:   if (completion.changes === 0) {\n372:     // The row moved out from under the read-then-check; refuse to clobber a state\n373:     // another writer set rather than overwriting it from a stale read.\n374:     throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n375:   }\n376: \n377:   cancelledJobIds.delete(jobId);\n378:   return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n379: }\n380: \n381: // Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n382: // re-run fresh, so they are reset to 'failed' rather than re-enqueued.\n383: export function resetRunningJobsForKind(\n384:   kind: MaintenanceJobKind,\n385:   // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n386:   // target keeps a caller from persisting an illegal transition past the guard.\n387:   options: { to: 'failed' | 'cancelled' },\n388: ): string[] {\n389:   const db = requireDb();\n390:   const rows = db.prepare(`\n391:     SELECT id FROM maintenance_jobs\n392:     WHERE kind = ? AND state IN ('queued', 'running')\n393:   `).all(kind) as Array<{ id: string }>;\n394: \n395:   if (rows.length === 0) return [];\n396: \n397:   withBusyRetrySync(() =>\n398:     db.prepare(`\n399:       UPDATE maintenance_jobs\n400:       SET state = ?, updated_at = ?\n401:       WHERE kind = ? AND state IN ('queued', 'running')\n402:     `).run(options.to, nowIso(), kind)\n403:   );\n404: \n405:   for (const row of rows) {\n406:     cancelledJobIds.delete(row.id);\n407:   }\n408:   return rows.map((r) => r.id);\n409: }\n410: \n411: export function isTerminalJobState(state: JobLifecycleState): boolean {\n412:   return TERMINAL_STATES.has(state);\n413: }\n\n(End of file - total 413 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Maintenance Job Store\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Maintenance Job Store\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport type MaintenanceJobKind = 'ingest' | 'index_scan';\n\nexport type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n\nexport interface JobError {\n  source: string;\n  message: string;\n  timestamp: string;\n}\n\nexport interface MaintenanceJob {\n  id: string;\n  kind: MaintenanceJobKind;\n  state: JobLifecycleState;\n  phase: string | null;\n  progressTotal: number;\n  progressProcessed: number;\n  cancelRequested: boolean;\n  errors: JobError[];\n  result: unknown | null;\n  payload: unknown | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\ninterface MaintenanceJobRow {\n  id: string;\n  kind: string;\n  state: string;\n  phase: string | null;\n  progress_total: number;\n  progress_processed: number;\n  cancel_requested: number;\n  errors_json: string;\n  result_json: string | null;\n  payload_json: string | null;\n  created_at: string;\n  updated_at: string;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. CONSTANTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport const MAX_STORED_ERRORS = 50;\n\nconst TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n\n// In-process mirror of cancel_requested. A running job polls this from a hot loop\n// to decide whether to stop, avoiding a DB SELECT on the single shared connection\n// every check. The cancel request runs in this same process, so the Set is\n// authoritative for an in-flight run; the durable column still backs status\n// responses and crash recovery. Entries are cleared when a job reaches a terminal\n// state so the Set cannot grow without bound across many jobs.\nconst cancelledJobIds = new Set<string>();\n\nconst ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n  queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n  running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n  complete: new Set<JobLifecycleState>([]),\n  failed: new Set<JobLifecycleState>([]),\n  cancelled: new Set<JobLifecycleState>([]),\n};\n\n// URL-safe 12-char identifier without a UUID dependency.\nconst NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. HELPERS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\nfunction parseJson<T>(value: string | null | undefined, fallback: T): T {\n  if (value === null || value === undefined) return fallback;\n  try {\n    return JSON.parse(value) as T;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseJobErrors(value: string | null | undefined): JobError[] {\n  const parsed = parseJson<unknown>(value, []);\n  return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n}\n\nfunction mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    kind: row.kind as MaintenanceJobKind,\n    state: row.state as JobLifecycleState,\n    phase: row.phase,\n    progressTotal: row.progress_total,\n    progressProcessed: row.progress_processed,\n    cancelRequested: row.cancel_requested === 1,\n    errors: parseJobErrors(row.errors_json),\n    result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n    payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nconst SELECT_COLUMNS =\n  'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. SCHEMA\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport function ensureMaintenanceJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS maintenance_jobs (\n      id TEXT PRIMARY KEY,\n      kind TEXT NOT NULL,\n      state TEXT NOT NULL,\n      phase TEXT,\n      progress_total INTEGER NOT NULL DEFAULT 0,\n      progress_processed INTEGER NOT NULL DEFAULT 0,\n      cancel_requested INTEGER NOT NULL DEFAULT 0,\n      errors_json TEXT NOT NULL DEFAULT '[]',\n      result_json TEXT,\n      payload_json TEXT,\n      created_at TEXT NOT NULL,\n      updated_at TEXT NOT NULL\n    )\n  `);\n  db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. IDENTIFIERS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport function createJobId(): string {\n  const bytes = randomBytes(12);\n  let id = '';\n  for (let i = 0; i < 12; i++) {\n    id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n  }\n  return `job_${id}`;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   7. LIFECYCLE\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport async function createMaintenanceJob(args: {\n  id: string;\n  kind: MaintenanceJobKind;\n  payload?: unknown;\n}): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO maintenance_jobs (\n        id, kind, state, phase, progress_total, progress_processed,\n        cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      args.kind,\n      'queued',\n      null,\n      0,\n      0,\n      0,\n      '[]',\n      null,\n      payloadJson,\n      timestamp,\n      timestamp,\n    )\n  );\n\n  return {\n    id: args.id,\n    kind: args.kind,\n    state: 'queued',\n    phase: null,\n    progressTotal: 0,\n    progressProcessed: 0,\n    cancelRequested: false,\n    errors: [],\n    result: null,\n    payload: args.payload ?? null,\n    createdAt: timestamp,\n    updatedAt: timestamp,\n  };\n}\n\nexport function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n  const db = requireDb();\n  const row = db.prepare(`\n    SELECT ${SELECT_COLUMNS}\n    FROM maintenance_jobs\n    WHERE id = ?\n  `).get(jobId) as MaintenanceJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nexport async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  // Every terminal transition must release the in-process cancel mirror, not just\n  // completeJob/resetRunningJobsForKind. A cancel-then-fail-while-running race\n  // routes through setJobState('failed'); without this the job-id would leak,\n  // contradicting the cancelledJobIds bounded-growth guarantee.\n  if (isTerminalJobState(nextState)) {\n    cancelledJobIds.delete(jobId);\n  }\n\n  return { ...current, state: nextState, updatedAt };\n}\n\nexport async function setJobPhase(jobId: string, phase: string): Promise<void> {\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n      .run(phase, nowIso(), jobId)\n  );\n}\n\nexport async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n  const db = requireDb();\n  const processed = Math.max(0, Math.trunc(progress.processed));\n  const total = Math.max(0, Math.trunc(progress.total));\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n      .run(processed, total, nowIso(), jobId)\n  );\n}\n\nexport async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  let errors: JobError[] = [\n    ...current.errors,\n    { source, message: toErrorMessage(error), timestamp: nowIso() },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: JobError = {\n      source: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n      .run(JSON.stringify(errors), updatedAt, jobId)\n  );\n\n  return { ...current, errors, updatedAt };\n}\n\nexport async function requestCancel(jobId: string): Promise<void> {\n  // Set the in-process flag first so a running loop observes the cancel even if the\n  // durable write contends on the shared connection.\n  cancelledJobIds.add(jobId);\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET cancel_requested = 1, updated_at = ? WHERE id = ?`)\n      .run(nowIso(), jobId)\n  );\n}\n\n// Synchronous so the runner can poll it inline at batch/phase boundaries.\nexport function isCancelRequested(jobId: string): boolean {\n  const db = requireDb();\n  const row = db.prepare(`SELECT cancel_requested FROM maintenance_jobs WHERE id = ?`)\n    .get(jobId) as { cancel_requested?: number } | undefined;\n  return !!row && row.cancel_requested === 1;\n}\n\n// Allocation- and IO-free cancel check for hot loops. Reads only the in-process\n// mirror, so it is safe to call thousands of times during a scan without touching\n// the shared SQLite connection. Use isCancelRequested when durability across the\n// in-memory boundary matters (status responses, post-restart).\nexport function isCancelRequestedFast(jobId: string): boolean {\n  return cancelledJobIds.has(jobId);\n}\n\nexport async function completeJob(\n  jobId: string,\n  options: { state: JobLifecycleState; result?: unknown },\n): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state !== options.state && !isTransitionAllowed(current.state, options.state)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${options.state}`);\n  }\n\n  const updatedAt = nowIso();\n  const resultJson = options.result === undefined ? null : JSON.stringify(options.result);\n  const completion = await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET state = ?, result_json = ?, updated_at = ? WHERE id = ? AND state = ?`)\n      .run(options.state, resultJson, updatedAt, jobId, current.state)\n  );\n  if (completion.changes === 0) {\n    // The row moved out from under the read-then-check; refuse to clobber a state\n    // another writer set rather than overwriting it from a stale read.\n    throw new Error(`Maintenance job state changed concurrently: ${jobId}`);\n  }\n\n  cancelledJobIds.delete(jobId);\n  return { ...current, state: options.state, result: options.result ?? null, updatedAt };\n}\n\n// Crash recovery: mark interrupted jobs of a kind terminal on boot. Index scans\n// re-run fresh, so they are reset to 'failed' rather than re-enqueued.\nexport function resetRunningJobsForKind(\n  kind: MaintenanceJobKind,\n  // Crash recovery only moves interrupted jobs to a terminal state. Restricting the\n  // target keeps a caller from persisting an illegal transition past the guard.\n  options: { to: 'failed' | 'cancelled' },\n): string[] {\n  const db = requireDb();\n  const rows = db.prepare(`\n    SELECT id FROM maintenance_jobs\n    WHERE kind = ? AND state IN ('queued', 'running')\n  `).all(kind) as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE kind = ? AND state IN ('queued', 'running')\n    `).run(options.to, nowIso(), kind)\n  );\n\n  for (const row of rows) {\n    cancelledJobIds.delete(row.id);\n  }\n  return rows.map((r) => r.id);\n}\n\nexport function isTerminalJobState(state: JobLifecycleState): boolean {\n  return TERMINAL_STATES.has(state);\n}","lineStart":1,"lineEnd":413,"totalLines":413,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","time":{"start":1781764217339,"end":1781764217343}},"metadata":{"openai":{"itemId":"fc_029fb0d52577e901016a3390792c78819198cfb61f95f5e39f"}},"id":"prt_ed96c59f9001t10TcZPxixqpsS","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c1eea001tzvVVbCyA2kr7i"}}
{"type":"tool_use","timestamp":1781764217354,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_tKR1THMW1H7g4Dflp2fPAYUO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Retention Sweep Handler\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: import { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n11: \n12: import type { MCPResponse } from './types.js';\n13: import type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n14: \n15: /** Handle the memory_retention_sweep MCP tool request. */\n16: async function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n17:   await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n18:   await checkDatabaseUpdated();\n19: \n20:   const database = vectorIndex.getDb();\n21:   if (!database) {\n22:     recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n23:     return createMCPErrorResponse({\n24:       tool: 'memory_retention_sweep',\n25:       error: 'Retention sweep aborted: database unavailable',\n26:       code: 'E_DB_UNAVAILABLE',\n27:       details: {\n28:         dryRun: args?.dryRun === true,\n29:       },\n30:       recovery: {\n31:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n32:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n33:         severity: 'error',\n34:       },\n35:     });\n36:   }\n37: \n38:   try {\n39:     const result = runMemoryRetentionSweep(database, {\n40:       dryRun: args?.dryRun === true,\n41:       feedbackRetention: args?.feedbackRetention,\n42:     });\n43:     const protectedSuffix = result.protectedCount > 0\n44:       ? `; protected ${result.protectedCount} high-tier/pinned row(s)`\n45:       : '';\n46:     const summary = result.dryRun\n47:       ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted${protectedSuffix}`\n48:       : `Swept ${result.swept} expired memory row(s); retained ${result.retained}${protectedSuffix}`;\n49: \n50:     const hints: string[] = [];\n51:     if (result.ledgerRecorded === false) {\n52:       hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n53:     }\n54:     if (result.dryRun && result.candidates.length > 0) {\n55:       hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n56:     }\n57:     recordMaintenanceRun('memory_retention_sweep', {\n58:       status: 'success',\n59:       counts: {\n60:         swept: result.swept,\n61:         retained: result.retained,\n62:         candidates: result.candidates.length,\n63:         protectedCount: result.protectedCount,\n64:       },\n65:       staleCandidates: result.candidates.length,\n66:     });\n67: \n68:     return createMCPSuccessResponse({\n69:       tool: 'memory_retention_sweep',\n70:       summary,\n71:       data: {\n72:         swept: result.swept,\n73:         retained: result.retained,\n74:         dryRun: result.dryRun,\n75:         durationMs: result.durationMs,\n76:         candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n77:           id: candidate.id,\n78:           deleteAfter: candidate.deleteAfter,\n79:           specFolder: candidate.specFolder,\n80:           filePath: candidate.filePath,\n81:         })),\n82:         deletedIds: result.deletedIds,\n83:         protectedCount: result.protectedCount,\n84:         protectedIds: result.protectedIds,\n85:         ledgerRecorded: result.ledgerRecorded,\n86:         ...(result.feedbackRetention ? {\n87:           feedbackRetention: {\n88:             mode: result.feedbackRetention.mode,\n89:             activeGatePassed: result.feedbackRetention.activeGatePassed,\n90:             activeBlocked: result.feedbackRetention.activeBlocked,\n91:             auditCount: result.feedbackRetention.auditCount,\n92:             protectedCount: result.feedbackRetention.protectedIds.length,\n93:             extendedCount: result.feedbackRetention.extendedIds.length,\n94:             deletedCount: result.feedbackRetention.deletedIds.length,\n95:           },\n96:           extendedIds: result.feedbackRetention.extendedIds,\n97:         } : {}),\n98:       },\n99:       hints,\n100:     });\n101:   } catch (error: unknown) {\n102:     recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n103:     return createMCPErrorResponse({\n104:       tool: 'memory_retention_sweep',\n105:       error: `Retention sweep failed: ${toErrorMessage(error)}`,\n106:       code: 'E_RETENTION_SWEEP_FAILED',\n107:       details: {\n108:         dryRun: args?.dryRun === true,\n109:       },\n110:       recovery: {\n111:         hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n112:         actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n113:         severity: 'error',\n114:       },\n115:     });\n116:   }\n117: }\n118: \n119: export { handleMemoryRetentionSweep };\n\n(End of file - total 119 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Retention Sweep Handler\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Retention Sweep Handler\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\nimport { recordMaintenanceRun } from '../lib/observability/retrieval-observability.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: 'Retention sweep aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  try {\n    const result = runMemoryRetentionSweep(database, {\n      dryRun: args?.dryRun === true,\n      feedbackRetention: args?.feedbackRetention,\n    });\n    const protectedSuffix = result.protectedCount > 0\n      ? `; protected ${result.protectedCount} high-tier/pinned row(s)`\n      : '';\n    const summary = result.dryRun\n      ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted${protectedSuffix}`\n      : `Swept ${result.swept} expired memory row(s); retained ${result.retained}${protectedSuffix}`;\n\n    const hints: string[] = [];\n    if (result.ledgerRecorded === false) {\n      hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n    }\n    if (result.dryRun && result.candidates.length > 0) {\n      hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n    }\n    recordMaintenanceRun('memory_retention_sweep', {\n      status: 'success',\n      counts: {\n        swept: result.swept,\n        retained: result.retained,\n        candidates: result.candidates.length,\n        protectedCount: result.protectedCount,\n      },\n      staleCandidates: result.candidates.length,\n    });\n\n    return createMCPSuccessResponse({\n      tool: 'memory_retention_sweep',\n      summary,\n      data: {\n        swept: result.swept,\n        retained: result.retained,\n        dryRun: result.dryRun,\n        durationMs: result.durationMs,\n        candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n          id: candidate.id,\n          deleteAfter: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        })),\n        deletedIds: result.deletedIds,\n        protectedCount: result.protectedCount,\n        protectedIds: result.protectedIds,\n        ledgerRecorded: result.ledgerRecorded,\n        ...(result.feedbackRetention ? {\n          feedbackRetention: {\n            mode: result.feedbackRetention.mode,\n            activeGatePassed: result.feedbackRetention.activeGatePassed,\n            activeBlocked: result.feedbackRetention.activeBlocked,\n            auditCount: result.feedbackRetention.auditCount,\n            protectedCount: result.feedbackRetention.protectedIds.length,\n            extendedCount: result.feedbackRetention.extendedIds.length,\n            deletedCount: result.feedbackRetention.deletedIds.length,\n          },\n          extendedIds: result.feedbackRetention.extendedIds,\n        } : {}),\n      },\n      hints,\n    });\n  } catch (error: unknown) {\n    recordMaintenanceRun('memory_retention_sweep', { status: 'error' });\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: `Retention sweep failed: ${toErrorMessage(error)}`,\n      code: 'E_RETENTION_SWEEP_FAILED',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n        actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryRetentionSweep };","lineStart":1,"lineEnd":119,"totalLines":119,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","time":{"start":1781764217350,"end":1781764217353}},"metadata":{"openai":{"itemId":"fc_029fb0d52577e901016a3390792c888191a67b739a166a49d5"}},"id":"prt_ed96c5a05001oKhTNik90I80sz","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c1eea001tzvVVbCyA2kr7i"}}
{"type":"tool_use","timestamp":1781764217359,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_8sLbxjmzl4x5eZtMRlgPLkES","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Job Queue\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // True sequential worker, meaningful state transitions,\n5: // Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n6: // Crash recovery with re-enqueue, and original-path progress tracking.\n7: \n8: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n9:    1. IMPORTS\n10: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n11: \n12: import path from 'node:path';\n13: import { requireDb, toErrorMessage } from '../../utils/index.js';\n14: import type { GovernanceDecision } from '../governance/scope-governance.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: // Feature catalog: Async ingestion job lifecycle\n18: \n19: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n20:    2. TYPES\n21: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n22: \n23: /**\n24:  * Defines the IngestJobState type.\n25:  */\n26: export type IngestJobState =\n27:   | 'queued'\n28:   | 'parsing'\n29:   | 'embedding'\n30:   | 'indexing'\n31:   | 'complete'\n32:   | 'failed'\n33:   | 'cancelled';\n34: \n35: /**\n36:  * Describes the IngestJobError shape.\n37:  */\n38: export interface IngestJobError {\n39:   filePath: string;\n40:   message: string;\n41:   timestamp: string;\n42: }\n43: \n44: /**\n45:  * Describes the IngestJob shape.\n46:  */\n47: export interface IngestJob {\n48:   id: string;\n49:   state: IngestJobState;\n50:   specFolder: string | null;\n51:   paths: string[];\n52:   filesTotal: number;\n53:   filesProcessed: number;\n54:   errors: IngestJobError[];\n55:   createdAt: string;\n56:   updatedAt: string;\n57:   // Validated governance decision captured at enqueue time so the worker\n58:   // re-indexes each path under the same provenance/retention/scope the\n59:   // synchronous save path applies. Null for ungoverned jobs (the default).\n60:   governance: GovernanceDecision | null;\n61: }\n62: \n63: export interface IngestJobForecast {\n64:   etaSeconds: number | null;\n65:   etaConfidence: number | null;\n66:   failureRisk: number | null;\n67:   riskSignals: string[];\n68:   caveat: string | null;\n69: }\n70: \n71: interface IngestJobRow {\n72:   id: string;\n73:   state: IngestJobState;\n74:   spec_folder: string | null;\n75:   paths_json: string;\n76:   files_total: number;\n77:   files_processed: number;\n78:   errors_json: string;\n79:   created_at: string;\n80:   updated_at: string;\n81:   governance_json?: string | null;\n82: }\n83: \n84: interface JobQueueConfig {\n85:   processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n86: }\n87: \n88: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n89:    3. CONSTANTS\n90: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n91: \n92: const ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\n93: const TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n94: \n95: const ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n96:   queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n97:   parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n98:   embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n99:   indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n100:   complete: new Set<IngestJobState>([]),\n101:   failed: new Set<IngestJobState>([]),\n102:   cancelled: new Set<IngestJobState>([]),\n103: };\n104: \n105: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n106:    5. STATE MANAGEMENT\n107: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n108: \n109: // True sequential queue вҖ” only one job processes at a time.\n110: const pendingQueue: string[] = [];\n111: let workerActive = false;\n112: // Drain fence. Once set, the worker stops draining and refuses to touch the\n113: // database. This prevents the worker from reopening a connection that shutdown\n114: // has already checkpointed and closed, which would otherwise re-dirty the WAL\n115: // and the unclean-shutdown marker at rest.\n116: let shuttingDown = false;\n117: let processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\n118: const MAX_STORED_ERRORS = 50;\n119: const MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n120: \n121: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n122:    4. HELPERS\n123: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n124: \n125: function toPublicPathLabel(filePath: string): string {\n126:   return filePath === '__job__' ? filePath : path.basename(filePath || '');\n127: }\n128: \n129: function sleep(ms: number): Promise<void> {\n130:   return new Promise((resolve) => setTimeout(resolve, ms));\n131: }\n132: \n133: function parsePositiveIntEnv(name: string, fallback: number): number {\n134:   const raw = process.env[name];\n135:   if (!raw) return fallback;\n136: \n137:   const parsed = Number.parseInt(raw, 10);\n138:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n139: }\n140: \n141: function parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n142:   if (!value) return fallback;\n143:   try {\n144:     const parsed = JSON.parse(value) as unknown;\n145:     return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n146:   } catch (_error: unknown) {\n147:     return fallback;\n148:   }\n149: }\n150: \n151: function parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n152:   if (!value) return null;\n153:   try {\n154:     const parsed = JSON.parse(value) as unknown;\n155:     if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n156:       return parsed as GovernanceDecision;\n157:     }\n158:     return null;\n159:   } catch (_error: unknown) {\n160:     return null;\n161:   }\n162: }\n163: \n164: function mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n165:   if (!row) return null;\n166:   return {\n167:     id: row.id,\n168:     state: row.state,\n169:     specFolder: row.spec_folder,\n170:     paths: parseJsonArray<string>(row.paths_json, []),\n171:     filesTotal: row.files_total,\n172:     filesProcessed: row.files_processed,\n173:     errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n174:     createdAt: row.created_at,\n175:     updatedAt: row.updated_at,\n176:     governance: parseGovernanceJson(row.governance_json),\n177:   };\n178: }\n179: \n180: function nowIso(): string {\n181:   return new Date().toISOString();\n182: }\n183: \n184: function isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n185:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n186: }\n187: \n188: // DB accessor for the worker path. While shutting down it refuses to acquire a\n189: // connection so the worker can never travel the requireDb -> getDb -> reopen\n190: // path after shutdown has closed the database. The throw is caught by the\n191: // worker's surrounding error handling and the drain unwinds cleanly.\n192: function acquireWorkerDb(): ReturnType<typeof requireDb> {\n193:   if (shuttingDown) {\n194:     throw new Error('Ingest worker is shutting down; database access refused');\n195:   }\n196:   return requireDb();\n197: }\n198: \n199: function ensureIngestJobsTable(): void {\n200:   const db = requireDb();\n201:   db.exec(`\n202:     CREATE TABLE IF NOT EXISTS ingest_jobs (\n203:       id TEXT PRIMARY KEY,\n204:       state TEXT,\n205:       spec_folder TEXT,\n206:       paths_json TEXT,\n207:       files_total INTEGER,\n208:       files_processed INTEGER,\n209:       errors_json TEXT,\n210:       created_at TEXT,\n211:       updated_at TEXT,\n212:       governance_json TEXT\n213:     )\n214:   `);\n215:   // Backward-compatible migration: add the nullable governance column to tables\n216:   // created before governed ingest existed. In-flight jobs simply carry a null\n217:   // governance and remain ungoverned, exactly as before.\n218:   const columns = db.prepare(`PRAGMA table_info(ingest_jobs)`).all() as Array<{ name: string }>;\n219:   if (!columns.some((column) => column.name === 'governance_json')) {\n220:     db.exec(`ALTER TABLE ingest_jobs ADD COLUMN governance_json TEXT`);\n221:   }\n222: }\n223: \n224: // Restart interrupted jobs from the beginning on process startup.\n225: // Indexing is idempotent, and replaying the original path list avoids\n226: // Mismatches when path accessibility changes between runs.\n227: function resetIncompleteJobsToQueued(): string[] {\n228:   const db = requireDb();\n229:   // Collect IDs of jobs that will be reset so we can re-enqueue them.\n230:   const rows = db.prepare(`\n231:     SELECT id FROM ingest_jobs\n232:     WHERE state NOT IN ('complete', 'failed', 'cancelled')\n233:   `).all() as Array<{ id: string }>;\n234: \n235:   if (rows.length === 0) return [];\n236: \n237:   withBusyRetrySync(() =>\n238:     db.prepare(`\n239:       UPDATE ingest_jobs\n240:       SET\n241:         state = 'queued',\n242:         files_processed = 0,\n243:         errors_json = '[]',\n244:         updated_at = ?\n245:       WHERE state NOT IN ('complete', 'failed', 'cancelled')\n246:     `).run(nowIso())\n247:   );\n248: \n249:   return rows.map((r) => r.id);\n250: }\n251: \n252: async function createIngestJob(args: {\n253:   id: string;\n254:   paths: string[];\n255:   specFolder?: string;\n256:   governance?: GovernanceDecision | null;\n257: }): Promise<IngestJob> {\n258:   const db = requireDb();\n259:   const timestamp = nowIso();\n260:   const normalizedPaths = args.paths.map((entry) => String(entry).trim()).filter((entry) => entry.length > 0);\n261: \n262:   if (normalizedPaths.length === 0) {\n263:     throw new Error('paths must include at least one file path');\n264:   }\n265: \n266:   const governance = args.governance ?? null;\n267:   const governanceJson = governance ? JSON.stringify(governance) : null;\n268: \n269:   await withBusyRetry(() =>\n270:     db.prepare(`\n271:       INSERT INTO ingest_jobs (\n272:         id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n273:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n274:     `).run(\n275:       args.id,\n276:       'queued',\n277:       args.specFolder ?? null,\n278:       JSON.stringify(normalizedPaths),\n279:       normalizedPaths.length,\n280:       0,\n281:       JSON.stringify([]),\n282:       timestamp,\n283:       timestamp,\n284:       governanceJson,\n285:     )\n286:   );\n287: \n288:   return {\n289:     id: args.id,\n290:     state: 'queued',\n291:     specFolder: args.specFolder ?? null,\n292:     paths: normalizedPaths,\n293:     filesTotal: normalizedPaths.length,\n294:     filesProcessed: 0,\n295:     errors: [],\n296:     createdAt: timestamp,\n297:     updatedAt: timestamp,\n298:     governance,\n299:   };\n300: }\n301: \n302: function getIngestJob(jobId: string): IngestJob | null {\n303:   const db = acquireWorkerDb();\n304:   const row = db.prepare(`\n305:     SELECT id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n306:     FROM ingest_jobs\n307:     WHERE id = ?\n308:   `).get(jobId) as IngestJobRow | undefined;\n309:   return mapRowToJob(row);\n310: }\n311: \n312: async function setIngestJobState(jobId: string, nextState: IngestJobState): Promise<IngestJob> {\n313:   const db = acquireWorkerDb();\n314:   const current = getIngestJob(jobId);\n315:   if (!current) {\n316:     throw new Error(`Ingest job not found: ${jobId}`);\n317:   }\n318: \n319:   if (current.state === nextState) {\n320:     return current;\n321:   }\n322: \n323:   if (!isTransitionAllowed(current.state, nextState)) {\n324:     throw new Error(`Invalid ingest job state transition: ${current.state} -> ${nextState}`);\n325:   }\n326: \n327:   const updatedAt = nowIso();\n328:   const result = await withBusyRetry(() =>\n329:     db.prepare(`\n330:       UPDATE ingest_jobs\n331:       SET state = ?, updated_at = ?\n332:       WHERE id = ? AND state = ?\n333:     `).run(nextState, updatedAt, jobId, current.state)\n334:   );\n335: \n336:   if ((result as { changes: number }).changes === 0) {\n337:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n338:   }\n339: \n340:   return {\n341:     ...current,\n342:     state: nextState,\n343:     updatedAt,\n344:   };\n345: }\n346: \n347: async function incrementProcessed(jobId: string): Promise<IngestJob> {\n348:   const db = acquireWorkerDb();\n349:   const updatedAt = nowIso();\n350:   await withBusyRetry(() =>\n351:     db.prepare(`\n352:       UPDATE ingest_jobs\n353:       SET files_processed = files_processed + 1, updated_at = ?\n354:       WHERE id = ?\n355:     `).run(updatedAt, jobId)\n356:   );\n357: \n358:   const updated = getIngestJob(jobId);\n359:   if (!updated) {\n360:     throw new Error(`Ingest job not found after progress update: ${jobId}`);\n361:   }\n362:   return updated;\n363: }\n364: \n365: async function appendIngestError(jobId: string, filePath: string, error: unknown): Promise<IngestJob> {\n366:   const db = acquireWorkerDb();\n367:   const current = getIngestJob(jobId);\n368:   if (!current) {\n369:     throw new Error(`Ingest job not found: ${jobId}`);\n370:   }\n371: \n372:   let errors = [\n373:     ...current.errors,\n374:     {\n375:       filePath: toPublicPathLabel(filePath),\n376:       message: toErrorMessage(error),\n377:       timestamp: nowIso(),\n378:     },\n379:   ];\n380: \n381:   if (errors.length > MAX_STORED_ERRORS) {\n382:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n383:     const trimmedCount = errors.length - tailLength;\n384:     const truncationNotice: IngestJobError = {\n385:       filePath: '__job__',\n386:       message: `error log truncated (${trimmedCount} older entries removed)`,\n387:       timestamp: nowIso(),\n388:     };\n389:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n390:     errors = [truncationNotice, ...truncatedTail];\n391:   }\n392: \n393:   const updatedAt = nowIso();\n394:   await withBusyRetry(() =>\n395:     db.prepare(`\n396:       UPDATE ingest_jobs\n397:       SET errors_json = ?, updated_at = ?\n398:       WHERE id = ?\n399:     `).run(JSON.stringify(errors), updatedAt, jobId)\n400:   );\n401: \n402:   return {\n403:     ...current,\n404:     errors,\n405:     updatedAt,\n406:   };\n407: }\n408: \n409: async function cancelIngestJob(jobId: string): Promise<IngestJob> {\n410:   const MAX_CANCEL_RETRIES = 3;\n411: \n412:   for (let attempt = 0; attempt < MAX_CANCEL_RETRIES; attempt += 1) {\n413:     const current = getIngestJob(jobId);\n414:     if (!current) {\n415:       throw new Error(`Ingest job not found: ${jobId}`);\n416:     }\n417:     if (TERMINAL_STATES.has(current.state)) {\n418:       return current;\n419:     }\n420: \n421:     try {\n422:       return await setIngestJobState(jobId, 'cancelled');\n423:     } catch (error: unknown) {\n424:       const message = toErrorMessage(error);\n425:       if (message.startsWith('State transition conflict:')) {\n426:         continue;\n427:       }\n428: \n429:       if (message.startsWith('Invalid ingest job state transition:')) {\n430:         const latest = getIngestJob(jobId);\n431:         if (latest && TERMINAL_STATES.has(latest.state)) {\n432:           return latest;\n433:         }\n434:         continue;\n435:       }\n436: \n437:       throw error;\n438:     }\n439:   }\n440: \n441:   const latest = getIngestJob(jobId);\n442:   if (!latest) {\n443:     throw new Error(`Ingest job not found: ${jobId}`);\n444:   }\n445:   if (TERMINAL_STATES.has(latest.state)) {\n446:     return latest;\n447:   }\n448: \n449:   return setIngestJobState(jobId, 'cancelled');\n450: }\n451: \n452: /**\n453:  * Provides the getIngestProgressPercent helper.\n454:  */\n455: export function getIngestProgressPercent(job: Pick<IngestJob, 'filesProcessed' | 'filesTotal'>): number {\n456:   if (job.filesTotal <= 0) return 0;\n457:   const raw = Math.round((job.filesProcessed / job.filesTotal) * 100);\n458:   return Math.max(0, Math.min(100, raw));\n459: }\n460: \n461: function parseIsoTimestamp(timestamp: string): number | null {\n462:   if (typeof timestamp !== 'string' || timestamp.trim().length === 0) {\n463:     return null;\n464:   }\n465: \n466:   const parsed = Date.parse(timestamp);\n467:   return Number.isFinite(parsed) ? parsed : null;\n468: }\n469: \n470: function clampUnitInterval(value: number): number {\n471:   if (!Number.isFinite(value)) return 0;\n472:   return Math.max(0, Math.min(1, value));\n473: }\n474: \n475: export function getIngestForecast(\n476:   job: Pick<IngestJob, 'state' | 'filesProcessed' | 'filesTotal' | 'errors' | 'createdAt' | 'updatedAt'>,\n477: ): IngestJobForecast {\n478:   const filesTotal = Math.max(0, job.filesTotal || 0);\n479:   const filesProcessed = Math.max(0, job.filesProcessed || 0);\n480:   const remaining = Math.max(0, filesTotal - filesProcessed);\n481:   const errorCount = Array.isArray(job.errors) ? job.errors.length : 0;\n482:   const errorRatio = filesTotal > 0 ? errorCount / filesTotal : 0;\n483:   const progressRatio = filesTotal > 0 ? filesProcessed / filesTotal : 0;\n484:   const riskSignals: string[] = [];\n485: \n486:   if (job.state === 'failed') {\n487:     return {\n488:       etaSeconds: 0,\n489:       etaConfidence: 1,\n490:       failureRisk: 1,\n491:       riskSignals: ['terminal_failed'],\n492:       caveat: null,\n493:     };\n494:   }\n495: \n496:   if (job.state === 'complete') {\n497:     return {\n498:       etaSeconds: 0,\n499:       etaConfidence: 1,\n500:       failureRisk: clampUnitInterval(errorRatio * 0.5),\n501:       riskSignals: errorCount > 0 ? ['completed_with_file_errors'] : [],\n502:       caveat: null,\n503:     };\n504:   }\n505: \n506:   if (job.state === 'cancelled') {\n507:     return {\n508:       etaSeconds: 0,\n509:       etaConfidence: 1,\n510:       failureRisk: 0,\n511:       riskSignals: ['terminal_cancelled'],\n512:       caveat: 'Forecast is advisory only because the job is no longer progressing.',\n513:     };\n514:   }\n515: \n516:   if (filesTotal <= 0) {\n517:     return {\n518:       etaSeconds: null,\n519:       etaConfidence: null,\n520:       failureRisk: null,\n521:       riskSignals,\n522:       caveat: 'Forecast unavailable because the queue has no file-count baseline yet.',\n523:     };\n524:   }\n525: \n526:   if (errorCount > 0) {\n527:     riskSignals.push('file_errors_seen');\n528:   }\n529:   if (job.state === 'queued') {\n530:     riskSignals.push('queued_not_started');\n531:   }\n532: \n533:   const createdAtMs = parseIsoTimestamp(job.createdAt);\n534:   const updatedAtMs = parseIsoTimestamp(job.updatedAt);\n535:   const elapsedSeconds = createdAtMs !== null && updatedAtMs !== null && updatedAtMs >= createdAtMs\n536:     ? Math.max(0, (updatedAtMs - createdAtMs) / 1000)\n537:     : 0;\n538: \n539:   let etaSeconds: number | null = null;\n540:   let etaConfidence: number | null = null;\n541:   let caveat: string | null = null;\n542: \n543:   if (filesProcessed <= 0 || elapsedSeconds < 1) {\n544:     caveat = 'Forecast is low-confidence until at least one file has been processed.';\n545:   } else {\n546:     const throughput = filesProcessed / elapsedSeconds;\n547:     if (throughput > 0) {\n548:       etaSeconds = Math.max(0, Math.round(remaining / throughput));\n549:       etaConfidence = clampUnitInterval(0.35 + (progressRatio * 0.45) - (errorRatio * 0.25));\n550:       if (etaConfidence < 0.4) {\n551:         caveat = 'Forecast is low-confidence because queue history is still sparse or noisy.';\n552:       }\n553:     } else {\n554:       caveat = 'Forecast unavailable because throughput could not be derived from queue history.';\n555:     }\n556:   }\n557: \n558:   if (progressRatio <= 0 && job.state !== 'queued') {\n559:     riskSignals.push('active_without_progress');\n560:   }\n561:   if (errorRatio >= 0.5 && errorCount > 0) {\n562:     riskSignals.push('high_error_ratio');\n563:   }\n564: \n565:   const stateRisk = job.state === 'indexing' ? 0.15 : (job.state === 'embedding' ? 0.1 : 0.05);\n566:   const failureRisk = clampUnitInterval((errorRatio * 0.7) + stateRisk + (progressRatio === 0 ? 0.05 : 0));\n567: \n568:   return {\n569:     etaSeconds,\n570:     etaConfidence,\n571:     failureRisk,\n572:     riskSignals,\n573:     caveat,\n574:   };\n575: }\n576: \n577: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n578:    6. WORKER\n579: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n580: \n581: // Real state machine вҖ” states now correspond to actual work phases.\n582: // Progress is tracked against the original submitted path list so terminal\n583: // Accounting stays stable even when some files are inaccessible.\n584: async function processQueuedJob(jobId: string): Promise<void> {\n585:   if (!processFileFn) {\n586:     throw new Error('Ingest queue not initialized: processFile handler is missing');\n587:   }\n588: \n589:   let job = getIngestJob(jobId);\n590:   if (!job || TERMINAL_STATES.has(job.state)) {\n591:     return;\n592:   }\n593: \n594:   // Step 1: Parsing вҖ” validate all paths exist and are readable.\n595:   job = await setIngestJobState(jobId, 'parsing');\n596:   if (TERMINAL_STATES.has(job.state)) return;\n597: \n598:   const { access } = await import('fs/promises');\n599: \n600:   // Step 2: Embedding вҖ” placeholder for batch embedding pre-processing.\n601:   // Transition is meaningful: it signals readiness for indexing after validation.\n602:   const latest1 = getIngestJob(jobId);\n603:   if (!latest1 || TERMINAL_STATES.has(latest1.state)) return;\n604:   job = await setIngestJobState(jobId, 'embedding');\n605:   if (TERMINAL_STATES.has(job.state)) return;\n606: \n607:   // Step 3: Indexing вҖ” process only validated paths (not original paths).\n608:   const latest2 = getIngestJob(jobId);\n609:   if (!latest2 || TERMINAL_STATES.has(latest2.state)) return;\n610:   job = await setIngestJobState(jobId, 'indexing');\n611: \n612:   // Resume from filesProcessed against the original submitted path order.\n613:   let currentIndex = job.filesProcessed;\n614:   // Track actual failure count independently of the truncated errors array.\n615:   // The errors array is capped at MAX_STORED_ERRORS, so using errors.length for\n616:   // Terminal state decisions would misclassify all-fail jobs with >50 files as \"complete\".\n617:   let failCount = 0;\n618: \n619:   while (currentIndex < job.paths.length) {\n620:     // Stop touching the DB the moment shutdown begins. The job stays in an\n621:     // active state and boot crash-recovery re-enqueues it on the next start.\n622:     if (shuttingDown) return;\n623:     const current = getIngestJob(jobId);\n624:     if (!current) return;\n625:     if (current.state === 'cancelled') return;\n626: \n627:     const nextPath = current.paths[currentIndex];\n628:     if (!nextPath) {\n629:       break;\n630:     }\n631: \n632:     // Continue on file error instead of aborting the entire job.\n633:     try {\n634:       await access(nextPath);\n635:       await processFileFn(nextPath, current.governance);\n636:     } catch (error: unknown) {\n637:       const normalizedError = error instanceof Error\n638:         && 'code' in error\n639:         && typeof error.code === 'string'\n640:         && error.code === 'ENOENT'\n641:         ? new Error('File not accessible')\n642:         : error;\n643:       await appendIngestError(jobId, nextPath, normalizedError);\n644:       failCount += 1;\n645:       console.warn(`[job-queue] File error (continuing): ${toPublicPathLabel(nextPath)} вҖ” ${toErrorMessage(normalizedError)}`);\n646:     }\n647: \n648:     job = await incrementProcessed(jobId);\n649:     currentIndex = job.filesProcessed;\n650:   }\n651: \n652:   // Determine terminal state: complete if no errors, failed if all files errored.\n653:   const done = getIngestJob(jobId);\n654:   if (!done) return;\n655:   if (done.state === 'cancelled') return;\n656: \n657:   if (failCount > 0 && failCount >= done.filesTotal) {\n658:     // All files failed вҖ” mark as failed.\n659:     await setIngestJobState(jobId, 'failed');\n660:   } else {\n661:     // Partial or full success вҖ” mark as complete (errors are preserved in record).\n662:     await setIngestJobState(jobId, 'complete');\n663:   }\n664: }\n665: \n666: // True sequential worker вҖ” processes one job at a time.\n667: // Multiple enqueueIngestJob calls add to pendingQueue; a single worker drains it.\n668: async function drainQueue(): Promise<void> {\n669:   if (workerActive) return;\n670:   workerActive = true;\n671: \n672:   try {\n673:     while (pendingQueue.length > 0) {\n674:       // Halt draining once shutdown begins so no new job opens the DB.\n675:       if (shuttingDown) break;\n676:       // PendingQueue.length > 0 in the loop condition guarantees shift() returns a job id\n677:       const jobId = pendingQueue.shift()!;\n678:       try {\n679:         await processQueuedJob(jobId);\n680:       } catch (error: unknown) {\n681:         try {\n682:           await appendIngestError(jobId, '__job__', error);\n683:           const current = getIngestJob(jobId);\n684:           if (current && ACTIVE_STATES.has(current.state)) {\n685:             await setIngestJobState(jobId, 'failed');\n686:           }\n687:         } catch (_error: unknown) {\n688:           // Non-fatal: queue guard to avoid unhandled rejection loops.\n689:         }\n690:       }\n691: \n692:       // Brief yield between jobs to avoid starving the event loop.\n693:       await sleep(10);\n694:     }\n695:   } finally {\n696:     workerActive = false;\n697:   }\n698: }\n699: \n700: function enqueueIngestJob(jobId: string): void {\n701:   // Never admit work or respawn the worker once shutdown has begun.\n702:   if (shuttingDown) {\n703:     return;\n704:   }\n705:   // Prevent duplicate enqueue of the same job.\n706:   if (pendingQueue.includes(jobId)) {\n707:     return;\n708:   }\n709: \n710:   pendingQueue.push(jobId);\n711:   while (pendingQueue.length > MAX_PENDING_INGEST_JOBS) {\n712:     const evictedJobId = pendingQueue.shift();\n713:     if (!evictedJobId) break;\n714:     void appendIngestError(\n715:       evictedJobId,\n716:       '__job__',\n717:       new Error(`Pending ingest queue exceeded cap ${MAX_PENDING_INGEST_JOBS}; oldest job aborted`),\n718:     )\n719:       .then(() => cancelIngestJob(evictedJobId))\n720:       .catch((error: unknown) => {\n721:         console.warn(`[job-queue] Failed to cancel overflow job ${evictedJobId}: ${toErrorMessage(error)}`);\n722:       });\n723:   }\n724: \n725:   // Start worker if not already running (fire-and-forget).\n726:   if (!workerActive) {\n727:     setImmediate(() => {\n728:       void drainQueue().catch((error: unknown) => {\n729:         console.error(`[job-queue] Worker error: ${toErrorMessage(error)}`);\n730:       });\n731:     });\n732:   }\n733: }\n734: \n735: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n736:    7. INITIALIZATION\n737: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n738: \n739: function initIngestJobQueue(config: JobQueueConfig): { resetCount: number } {\n740:   processFileFn = config.processFile;\n741:   ensureIngestJobsTable();\n742: \n743:   // Crash recovery: reset incomplete jobs to 'queued' AND re-enqueue them\n744:   // So they actually get processed by the worker.\n745:   const resetJobIds = resetIncompleteJobsToQueued();\n746:   for (const jobId of resetJobIds) {\n747:     enqueueIngestJob(jobId);\n748:   }\n749: \n750:   return { resetCount: resetJobIds.length };\n751: }\n752: \n753: // Default ceiling for how long stopWorker waits for the active drain to settle.\n754: // The worker yields between files and between jobs, so it observes the fence\n755: // quickly; the bound only guards against a wedged in-flight processFile call.\n756: const STOP_WORKER_DRAIN_DEADLINE_MS = 2_000;\n757: \n758: // Fence the ingest worker for shutdown: refuse new work, drop the pending\n759: // queue, and wait (bounded) for any in-flight drain to unwind before the\n760: // database is closed. Must run before closeDb() so the worker cannot reopen a\n761: // closed connection. Idempotent and safe to call when the worker is idle.\n762: async function stopWorker(options: { drainDeadlineMs?: number } = {}): Promise<void> {\n763:   shuttingDown = true;\n764:   pendingQueue.length = 0;\n765: \n766:   if (!workerActive) return;\n767: \n768:   const deadline = Date.now()\n769:     + (Number.isFinite(options.drainDeadlineMs) && (options.drainDeadlineMs as number) > 0\n770:       ? (options.drainDeadlineMs as number)\n771:       : STOP_WORKER_DRAIN_DEADLINE_MS);\n772: \n773:   while (workerActive && Date.now() < deadline) {\n774:     await sleep(10);\n775:   }\n776: }\n777: \n778: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n779:    8. EXPORTS\n780: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n781: \n782: export {\n783:   initIngestJobQueue,\n784:   stopWorker,\n785:   createIngestJob,\n786:   getIngestJob,\n787:   cancelIngestJob,\n788:   enqueueIngestJob,\n789:   resetIncompleteJobsToQueued,\n790:   MAX_PENDING_INGEST_JOBS,\n791: };\n\n(End of file - total 791 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Job Queue\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. TYPES","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Job Queue\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// True sequential worker, meaningful state transitions,\n// Continue-on-error for bulk ingestion, SQLITE_BUSY async retry on DB writes,\n// Crash recovery with re-enqueue, and original-path progress tracking.\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. IMPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nimport path from 'node:path';\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport type { GovernanceDecision } from '../governance/scope-governance.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n// Feature catalog: Async ingestion job lifecycle\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   2. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n/**\n * Defines the IngestJobState type.\n */\nexport type IngestJobState =\n  | 'queued'\n  | 'parsing'\n  | 'embedding'\n  | 'indexing'\n  | 'complete'\n  | 'failed'\n  | 'cancelled';\n\n/**\n * Describes the IngestJobError shape.\n */\nexport interface IngestJobError {\n  filePath: string;\n  message: string;\n  timestamp: string;\n}\n\n/**\n * Describes the IngestJob shape.\n */\nexport interface IngestJob {\n  id: string;\n  state: IngestJobState;\n  specFolder: string | null;\n  paths: string[];\n  filesTotal: number;\n  filesProcessed: number;\n  errors: IngestJobError[];\n  createdAt: string;\n  updatedAt: string;\n  // Validated governance decision captured at enqueue time so the worker\n  // re-indexes each path under the same provenance/retention/scope the\n  // synchronous save path applies. Null for ungoverned jobs (the default).\n  governance: GovernanceDecision | null;\n}\n\nexport interface IngestJobForecast {\n  etaSeconds: number | null;\n  etaConfidence: number | null;\n  failureRisk: number | null;\n  riskSignals: string[];\n  caveat: string | null;\n}\n\ninterface IngestJobRow {\n  id: string;\n  state: IngestJobState;\n  spec_folder: string | null;\n  paths_json: string;\n  files_total: number;\n  files_processed: number;\n  errors_json: string;\n  created_at: string;\n  updated_at: string;\n  governance_json?: string | null;\n}\n\ninterface JobQueueConfig {\n  processFile: (filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. CONSTANTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nconst ACTIVE_STATES = new Set<IngestJobState>(['queued', 'parsing', 'embedding', 'indexing']);\nconst TERMINAL_STATES = new Set<IngestJobState>(['complete', 'failed', 'cancelled']);\n\nconst ALLOWED_TRANSITIONS: Record<IngestJobState, Set<IngestJobState>> = {\n  queued: new Set<IngestJobState>(['parsing', 'cancelled', 'failed']),\n  parsing: new Set<IngestJobState>(['embedding', 'cancelled', 'failed']),\n  embedding: new Set<IngestJobState>(['indexing', 'cancelled', 'failed']),\n  indexing: new Set<IngestJobState>(['complete', 'cancelled', 'failed']),\n  complete: new Set<IngestJobState>([]),\n  failed: new Set<IngestJobState>([]),\n  cancelled: new Set<IngestJobState>([]),\n};\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   5. STATE MANAGEMENT\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n// True sequential queue вҖ” only one job processes at a time.\nconst pendingQueue: string[] = [];\nlet workerActive = false;\n// Drain fence. Once set, the worker stops draining and refuses to touch the\n// database. This prevents the worker from reopening a connection that shutdown\n// has already checkpointed and closed, which would otherwise re-dirty the WAL\n// and the unclean-shutdown marker at rest.\nlet shuttingDown = false;\nlet processFileFn: ((filePath: string, governance?: GovernanceDecision | null) => Promise<unknown>) | null = null;\nconst MAX_STORED_ERRORS = 50;\nconst MAX_PENDING_INGEST_JOBS = parsePositiveIntEnv('SPECKIT_INGEST_QUEUE_MAX_PENDING', 1_000);\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   4. HELPERS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction toPublicPathLabel(filePath: string): string {\n  return filePath === '__job__' ? filePath : path.basename(filePath || '');\n}\n\nfunction sleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction parsePositiveIntEnv(name: string, fallback: number): number {\n  const raw = process.env[name];\n  if (!raw) return fallback;\n\n  const parsed = Number.parseInt(raw, 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction parseJsonArray<T>(value: string | null | undefined, fallback: T[]): T[] {\n  if (!value) return fallback;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    return Array.isArray(parsed) ? (parsed as T[]) : fallback;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseGovernanceJson(value: string | null | undefined): GovernanceDecision | null {\n  if (!value) return null;\n  try {\n    const parsed = JSON.parse(value) as unknown;\n    if (parsed && typeof parsed === 'object' && 'normalized' in (parsed as Record<string, unknown>)) {\n      return parsed as GovernanceDecision;\n    }\n    return null;\n  } catch (_error: unknown) {\n    return null;\n  }\n}\n\nfunction mapRowToJob(row: IngestJobRow | undefined): IngestJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    state: row.state,\n    specFolder: row.spec_folder,\n    paths: parseJsonArray<string>(row.paths_json, []),\n    filesTotal: row.files_total,\n    filesProcessed: row.files_processed,\n    errors: parseJsonArray<IngestJobError>(row.errors_json, []),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n    governance: parseGovernanceJson(row.governance_json),\n  };\n}\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: IngestJobState, to: IngestJobState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\n// DB accessor for the worker path. While shutting down it refuses to acquire a\n// connection so the worker can never travel the requireDb -> getDb -> reopen\n// path after shutdown has closed the database. The throw is caught by the\n// worker's surrounding error handling and the drain unwinds cleanly.\nfunction acquireWorkerDb(): ReturnType<typeof requireDb> {\n  if (shuttingDown) {\n    throw new Error('Ingest worker is shutting down; database access refused');\n  }\n  return requireDb();\n}\n\nfunction ensureIngestJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS ingest_jobs (\n      id TEXT PRIMARY KEY,\n      state TEXT,\n      spec_folder TEXT,\n      paths_json TEXT,\n      files_total INTEGER,\n      files_processed INTEGER,\n      errors_json TEXT,\n      created_at TEXT,\n      updated_at TEXT,\n      governance_json TEXT\n    )\n  `);\n  // Backward-compatible migration: add the nullable governance column to tables\n  // created before governed ingest existed. In-flight jobs simply carry a null\n  // governance and remain ungoverned, exactly as before.\n  const columns = db.prepare(`PRAGMA table_info(ingest_jobs)`).all() as Array<{ name: string }>;\n  if (!columns.some((column) => column.name === 'governance_json')) {\n    db.exec(`ALTER TABLE ingest_jobs ADD COLUMN governance_json TEXT`);\n  }\n}\n\n// Restart interrupted jobs from the beginning on process startup.\n// Indexing is idempotent, and replaying the original path list avoids\n// Mismatches when path accessibility changes between runs.\nfunction resetIncompleteJobsToQueued(): string[] {\n  const db = requireDb();\n  // Collect IDs of jobs that will be reset so we can re-enqueue them.\n  const rows = db.prepare(`\n    SELECT id FROM ingest_jobs\n    WHERE state NOT IN ('complete', 'failed', 'cancelled')\n  `).all() as Array<{ id: string }>;\n\n  if (rows.length === 0) return [];\n\n  withBusyRetrySync(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET\n        state = 'queued',\n        files_processed = 0,\n        errors_json = '[]',\n        updated_at = ?\n      WHERE state NOT IN ('complete', 'failed', 'cancelled')\n    `).run(nowIso())\n  );\n\n  return rows.map((r) => r.id);\n}\n\nasync function createIngestJob(args: {\n  id: string;\n  paths: string[];\n  specFolder?: string;\n  governance?: GovernanceDecision | null;\n}): Promise<IngestJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const normalizedPaths = args.paths.map((entry) => String(entry).trim()).filter((entry) => entry.length > 0);\n\n  if (normalizedPaths.length === 0) {\n    throw new Error('paths must include at least one file path');\n  }\n\n  const governance = args.governance ?? null;\n  const governanceJson = governance ? JSON.stringify(governance) : null;\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO ingest_jobs (\n        id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      'queued',\n      args.specFolder ?? null,\n      JSON.stringify(normalizedPaths),\n      normalizedPaths.length,\n      0,\n      JSON.stringify([]),\n      timestamp,\n      timestamp,\n      governanceJson,\n    )\n  );\n\n  return {\n    id: args.id,\n    state: 'queued',\n    specFolder: args.specFolder ?? null,\n    paths: normalizedPaths,\n    filesTotal: normalizedPaths.length,\n    filesProcessed: 0,\n    errors: [],\n    createdAt: timestamp,\n    updatedAt: timestamp,\n    governance,\n  };\n}\n\nfunction getIngestJob(jobId: string): IngestJob | null {\n  const db = acquireWorkerDb();\n  const row = db.prepare(`\n    SELECT id, state, spec_folder, paths_json, files_total, files_processed, errors_json, created_at, updated_at, governance_json\n    FROM ingest_jobs\n    WHERE id = ?\n  `).get(jobId) as IngestJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nasync function setIngestJobState(jobId: string, nextState: IngestJobState): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const current = getIngestJob(jobId);\n  if (!current) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid ingest job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  return {\n    ...current,\n    state: nextState,\n    updatedAt,\n  };\n}\n\nasync function incrementProcessed(jobId: string): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET files_processed = files_processed + 1, updated_at = ?\n      WHERE id = ?\n    `).run(updatedAt, jobId)\n  );\n\n  const updated = getIngestJob(jobId);\n  if (!updated) {\n    throw new Error(`Ingest job not found after progress update: ${jobId}`);\n  }\n  return updated;\n}\n\nasync function appendIngestError(jobId: string, filePath: string, error: unknown): Promise<IngestJob> {\n  const db = acquireWorkerDb();\n  const current = getIngestJob(jobId);\n  if (!current) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n\n  let errors = [\n    ...current.errors,\n    {\n      filePath: toPublicPathLabel(filePath),\n      message: toErrorMessage(error),\n      timestamp: nowIso(),\n    },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: IngestJobError = {\n      filePath: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE ingest_jobs\n      SET errors_json = ?, updated_at = ?\n      WHERE id = ?\n    `).run(JSON.stringify(errors), updatedAt, jobId)\n  );\n\n  return {\n    ...current,\n    errors,\n    updatedAt,\n  };\n}\n\nasync function cancelIngestJob(jobId: string): Promise<IngestJob> {\n  const MAX_CANCEL_RETRIES = 3;\n\n  for (let attempt = 0; attempt < MAX_CANCEL_RETRIES; attempt += 1) {\n    const current = getIngestJob(jobId);\n    if (!current) {\n      throw new Error(`Ingest job not found: ${jobId}`);\n    }\n    if (TERMINAL_STATES.has(current.state)) {\n      return current;\n    }\n\n    try {\n      return await setIngestJobState(jobId, 'cancelled');\n    } catch (error: unknown) {\n      const message = toErrorMessage(error);\n      if (message.startsWith('State transition conflict:')) {\n        continue;\n      }\n\n      if (message.startsWith('Invalid ingest job state transition:')) {\n        const latest = getIngestJob(jobId);\n        if (latest && TERMINAL_STATES.has(latest.state)) {\n          return latest;\n        }\n        continue;\n      }\n\n      throw error;\n    }\n  }\n\n  const latest = getIngestJob(jobId);\n  if (!latest) {\n    throw new Error(`Ingest job not found: ${jobId}`);\n  }\n  if (TERMINAL_STATES.has(latest.state)) {\n    return latest;\n  }\n\n  return setIngestJobState(jobId, 'cancelled');\n}\n\n/**\n * Provides the getIngestProgressPercent helper.\n */\nexport function getIngestProgressPercent(job: Pick<IngestJob, 'filesProcessed' | 'filesTotal'>): number {\n  if (job.filesTotal <= 0) return 0;\n  const raw = Math.round((job.filesProcessed / job.filesTotal) * 100);\n  return Math.max(0, Math.min(100, raw));\n}\n\nfunction parseIsoTimestamp(timestamp: string): number | null {\n  if (typeof timestamp !== 'string' || timestamp.trim().length === 0) {\n    return null;\n  }\n\n  const parsed = Date.parse(timestamp);\n  return Number.isFinite(parsed) ? parsed : null;\n}\n\nfunction clampUnitInterval(value: number): number {\n  if (!Number.isFinite(value)) return 0;\n  return Math.max(0, Math.min(1, value));\n}\n\nexport function getIngestForecast(\n  job: Pick<IngestJob, 'state' | 'filesProcessed' | 'filesTotal' | 'errors' | 'createdAt' | 'updatedAt'>,\n): IngestJobForecast {\n  const filesTotal = Math.max(0, job.filesTotal || 0);\n  const filesProcessed = Math.max(0, job.filesProcessed || 0);\n  const remaining = Math.max(0, filesTotal - filesProcessed);\n  const errorCount = Array.isArray(job.errors) ? job.errors.length : 0;\n  const errorRatio = filesTotal > 0 ? errorCount / filesTotal : 0;\n  const progressRatio = filesTotal > 0 ? filesProcessed / filesTotal : 0;\n  const riskSignals: string[] = [];\n\n  if (job.state === 'failed') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: 1,\n      riskSignals: ['terminal_failed'],\n      caveat: null,\n    };\n  }\n\n  if (job.state === 'complete') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: clampUnitInterval(errorRatio * 0.5),\n      riskSignals: errorCount > 0 ? ['completed_with_file_errors'] : [],\n      caveat: null,\n    };\n  }\n\n  if (job.state === 'cancelled') {\n    return {\n      etaSeconds: 0,\n      etaConfidence: 1,\n      failureRisk: 0,\n      riskSignals: ['terminal_cancelled'],\n      caveat: 'Forecast is advisory only because the job is no longer progressing.',\n    };\n  }\n\n  if (filesTotal <= 0) {\n    return {\n      etaSeconds: null,\n      etaConfidence: null,\n      failureRisk: null,\n      riskSignals,\n      caveat: 'Forecast unavailable because the queue has no file-count baseline yet.',\n    };\n  }\n\n  if (errorCount > 0) {\n    riskSignals.push('file_errors_seen');\n  }\n  if (job.state === 'queued') {\n    riskSignals.push('queued_not_started');\n  }\n\n  const createdAtMs = parseIsoTimestamp(job.createdAt);\n  const updatedAtMs = parseIsoTimestamp(job.updatedAt);\n  const elapsedSeconds = createdAtMs !== null && updatedAtMs !== null && updatedAtMs >= createdAtMs\n    ? Math.max(0, (updatedAtMs - createdAtMs) / 1000)\n    : 0;\n\n  let etaSeconds: number | null = null;\n  let etaConfidence: number | null = null;\n  let caveat: string | null = null;\n\n  if (filesProcessed <= 0 || elapsedSeconds < 1) {\n    caveat = 'Forecast is low-confidence until at least one file has been processed.';\n  } else {\n    const throughput = filesProcessed / elapsedSeconds;\n    if (throughput > 0) {\n      etaSeconds = Math.max(0, Math.round(remaining / throughput));\n      etaConfidence = clampUnitInterval(0.35 + (progressRatio * 0.45) - (errorRatio * 0.25));\n      if (etaConfidence < 0.4) {\n        caveat = 'Forecast is low-confidence because queue history is still sparse or noisy.';\n      }\n    } else {\n      caveat = 'Forecast unavailable because throughput could not be derived from queue history.';\n    }\n  }\n\n  if (progressRatio <= 0 && job.state !== 'queued') {\n    riskSignals.push('active_without_progress');\n  }\n  if (errorRatio >= 0.5 && errorCount > 0) {\n    riskSignals.push('high_error_ratio');\n  }\n\n  const stateRisk = job.state === 'indexing' ? 0.15 : (job.state === 'embedding' ? 0.1 : 0.05);\n  const failureRisk = clampUnitInterval((errorRatio * 0.7) + stateRisk + (progressRatio === 0 ? 0.05 : 0));\n\n  return {\n    etaSeconds,\n    etaConfidence,\n    failureRisk,\n    riskSignals,\n    caveat,\n  };\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   6. WORKER\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\n// Real state machine вҖ” states now correspond to actual work phases.\n// Progress is tracked against the original submitted path list so terminal\n// Accounting stays stable even when some files are inaccessible.\nasync function processQueuedJob(jobId: string): Promise<void> {\n  if (!processFileFn) {\n    throw new Error('Ingest queue not initialized: processFile handler is missing');\n  }\n\n  let job = getIngestJob(jobId);\n  if (!job || TERMINAL_STATES.has(job.state)) {\n    return;\n  }\n\n  // Step 1: Parsing вҖ” validate all paths exist and are readable.\n  job = await setIngestJobState(jobId, 'parsing');\n  if (TERMINAL_STATES.has(job.state)) return;\n\n  const { access } = await import('fs/promises');\n\n  // Step 2: Embedding вҖ” placeholder for batch embedding pre-processing.\n  // Transition is meaningful: it signals readiness for indexing after validation.\n  const latest1 = getIngestJob(jobId);\n  if (!latest1 || TERMINAL_STATES.has(latest1.state)) return;\n  job = await setIngestJobState(jobId, 'embedding');\n  if (TERMINAL_STATES.has(job.state)) return;\n\n  // Step 3: Indexing вҖ” process only validated paths (not original paths).\n  const latest2 = getIngestJob(jobId);\n  if (!latest2 || TERMINAL_STATES.has(latest2.state)) return;\n  job = await setIngestJobState(jobId, 'indexing');\n\n  // Resume from filesProcessed against the original submitted path order.\n  let currentIndex = job.filesProcessed;\n  // Track actual failure count independently of the truncated errors array.\n  // The errors array is capped at MAX_STORED_ERRORS, so using errors.length for\n  // Terminal state decisions would misclassify all-fail jobs with >50 files as \"complete\".\n  let failCount = 0;\n\n  while (currentIndex < job.paths.length) {\n    // Stop touching the DB the moment shutdown begins. The job stays in an\n    // active state and boot crash-recovery re-enqueues it on the next start.\n    if (shuttingDown) return;\n    const current = getIngestJob(jobId);\n    if (!current) return;\n    if (current.state === 'cancelled') return;\n\n    const nextPath = current.paths[currentIndex];\n    if (!nextPath) {\n      break;\n    }\n\n    // Continue on file error instead of aborting the entire job.\n    try {\n      await access(nextPath);\n      await processFileFn(nextPath, current.governance);\n    } catch (error: unknown) {\n      const normalizedError = error instanceof Error\n        && 'code' in error\n        && typeof error.code === 'string'\n        && error.code === 'ENOENT'\n        ? new Error('File not accessible')\n        : error;\n      await appendIngestError(jobId, nextPath, normalizedError);\n      failCount += 1;\n      console.warn(`[job-queue] File error (continuing): ${toPublicPathLabel(nextPath)} вҖ” ${toErrorMessage(normalizedError)}`);\n    }\n\n    job = await incrementProcessed(jobId);\n    currentIndex = job.filesProcessed;\n  }\n\n  // Determine terminal state: complete if no errors, failed if all files errored.\n  const done = getIngestJob(jobId);\n  if (!done) return;\n  if (done.state === 'cancelled') return;\n\n  if (failCount > 0 && failCount >= done.filesTotal) {\n    // All files failed вҖ” mark as failed.\n    await setIngestJobState(jobId, 'failed');\n  } else {\n    // Partial or full success вҖ” mark as complete (errors are preserved in record).\n    await setIngestJobState(jobId, 'complete');\n  }\n}\n\n// True sequential worker вҖ” processes one job at a time.\n// Multiple enqueueIngestJob calls add to pendingQueue; a single worker drains it.\nasync function drainQueue(): Promise<void> {\n  if (workerActive) return;\n  workerActive = true;\n\n  try {\n    while (pendingQueue.length > 0) {\n      // Halt draining once shutdown begins so no new job opens the DB.\n      if (shuttingDown) break;\n      // PendingQueue.length > 0 in the loop condition guarantees shift() returns a job id\n      const jobId = pendingQueue.shift()!;\n      try {\n        await processQueuedJob(jobId);\n      } catch (error: unknown) {\n        try {\n          await appendIngestError(jobId, '__job__', error);\n          const current = getIngestJob(jobId);\n          if (current && ACTIVE_STATES.has(current.state)) {\n            await setIngestJobState(jobId, 'failed');\n          }\n        } catch (_error: unknown) {\n          // Non-fatal: queue guard to avoid unhandled rejection loops.\n        }\n      }\n\n      // Brief yield between jobs to avoid starving the event loop.\n      await sleep(10);\n    }\n  } finally {\n    workerActive = false;\n  }\n}\n\nfunction enqueueIngestJob(jobId: string): void {\n  // Never admit work or respawn the worker once shutdown has begun.\n  if (shuttingDown) {\n    return;\n  }\n  // Prevent duplicate enqueue of the same job.\n  if (pendingQueue.includes(jobId)) {\n    return;\n  }\n\n  pendingQueue.push(jobId);\n  while (pendingQueue.length > MAX_PENDING_INGEST_JOBS) {\n    const evictedJobId = pendingQueue.shift();\n    if (!evictedJobId) break;\n    void appendIngestError(\n      evictedJobId,\n      '__job__',\n      new Error(`Pending ingest queue exceeded cap ${MAX_PENDING_INGEST_JOBS}; oldest job aborted`),\n    )\n      .then(() => cancelIngestJob(evictedJobId))\n      .catch((error: unknown) => {\n        console.warn(`[job-queue] Failed to cancel overflow job ${evictedJobId}: ${toErrorMessage(error)}`);\n      });\n  }\n\n  // Start worker if not already running (fire-and-forget).\n  if (!workerActive) {\n    setImmediate(() => {\n      void drainQueue().catch((error: unknown) => {\n        console.error(`[job-queue] Worker error: ${toErrorMessage(error)}`);\n      });\n    });\n  }\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   7. INITIALIZATION\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nfunction initIngestJobQueue(config: JobQueueConfig): { resetCount: number } {\n  processFileFn = config.processFile;\n  ensureIngestJobsTable();\n\n  // Crash recovery: reset incomplete jobs to 'queued' AND re-enqueue them\n  // So they actually get processed by the worker.\n  const resetJobIds = resetIncompleteJobsToQueued();\n  for (const jobId of resetJobIds) {\n    enqueueIngestJob(jobId);\n  }\n\n  return { resetCount: resetJobIds.length };\n}\n\n// Default ceiling for how long stopWorker waits for the active drain to settle.\n// The worker yields between files and between jobs, so it observes the fence\n// quickly; the bound only guards against a wedged in-flight processFile call.\nconst STOP_WORKER_DRAIN_DEADLINE_MS = 2_000;\n\n// Fence the ingest worker for shutdown: refuse new work, drop the pending\n// queue, and wait (bounded) for any in-flight drain to unwind before the\n// database is closed. Must run before closeDb() so the worker cannot reopen a\n// closed connection. Idempotent and safe to call when the worker is idle.\nasync function stopWorker(options: { drainDeadlineMs?: number } = {}): Promise<void> {\n  shuttingDown = true;\n  pendingQueue.length = 0;\n\n  if (!workerActive) return;\n\n  const deadline = Date.now()\n    + (Number.isFinite(options.drainDeadlineMs) && (options.drainDeadlineMs as number) > 0\n      ? (options.drainDeadlineMs as number)\n      : STOP_WORKER_DRAIN_DEADLINE_MS);\n\n  while (workerActive && Date.now() < deadline) {\n    await sleep(10);\n  }\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   8. EXPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport {\n  initIngestJobQueue,\n  stopWorker,\n  createIngestJob,\n  getIngestJob,\n  cancelIngestJob,\n  enqueueIngestJob,\n  resetIncompleteJobsToQueued,\n  MAX_PENDING_INGEST_JOBS,\n};","lineStart":1,"lineEnd":791,"totalLines":791,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-queue.ts","time":{"start":1781764217348,"end":1781764217355}},"metadata":{"openai":{"itemId":"fc_029fb0d52577e901016a3390792c808191a8c304b88b73cfc4"}},"id":"prt_ed96c59fc001mPJ9NTnlZAEceP","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c1eea001tzvVVbCyA2kr7i"}}
{"type":"tool_use","timestamp":1781764217361,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_2YXnB29Wb93RcaYcMYwslEej","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","offset":1,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Memory Bulk Delete\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: // Tier-based bulk deletion of memories with safety gates.\n5: // Eliminates the need for direct DB scripts when cleaning up\n6: // Deprecated/temporary memories at scale.\n7: import { checkDatabaseUpdated } from '../core/index.js';\n8: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n9: import * as vectorIndex from '../lib/search/vector-index.js';\n10: import * as checkpoints from '../lib/storage/checkpoints.js';\n11: import * as mutationLedger from '../lib/storage/mutation-ledger.js';\n12: import * as causalEdges from '../lib/storage/causal-edges.js';\n13: import { createStatediffAction } from '../lib/storage/statediff.js';\n14: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n15: import { toErrorMessage } from '../utils/index.js';\n16: \n17: import { recordHistory } from '../lib/storage/history.js';\n18: import { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\n19: import { appendMutationLedgerSafe } from './memory-crud-utils.js';\n20: import { runPostMutationHooks } from './mutation-hooks.js';\n21: import { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n22: \n23: import type { MCPResponse } from './types.js';\n24: \n25: // Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n26: // Feature catalog: Per-memory history log\n27: \n28: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n29:    1. TYPES\n30: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n31: \n32: interface BulkDeleteArgs {\n33:   tier: string;\n34:   specFolder?: string;\n35:   confirm: boolean;\n36:   olderThanDays?: number;\n37:   skipCheckpoint?: boolean;\n38: }\n39: \n40: function hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n41:   if (!database || !('prepare' in database)) return false;\n42:   try {\n43:     const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n44:     return columns.some((column) => column.name === 'deleted_at');\n45:   } catch {\n46:     return false;\n47:   }\n48: }\n49: \n50: function isSoftDeleteTombstonesEnabled(): boolean {\n51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n52: }\n53: \n54: function tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n55:   if (!isSoftDeleteTombstonesEnabled()) {\n56:     return vectorIndex.deleteMemory(memoryId, database);\n57:   }\n58: \n59:   if (!hasDeletedAtColumn(database)) {\n60:     return vectorIndex.deleteMemory(memoryId, database);\n61:   }\n62: \n63:   const deletedAt = new Date().toISOString();\n64:   const result = database.prepare(`\n65:     UPDATE memory_index\n66:     SET deleted_at = COALESCE(deleted_at, ?),\n67:         updated_at = datetime('now')\n68:     WHERE id = ?\n69:   `).run(deletedAt, memoryId);\n70:   return result.changes > 0;\n71: }\n72: \n73: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n74:     2. HANDLER\n75: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n76: \n77: async function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n78:   await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n79:   const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n80:   if (restoreBarrier) {\n81:     return createMCPErrorResponse({\n82:       tool: 'memory_bulk_delete',\n83:       error: restoreBarrier.message,\n84:       code: restoreBarrier.code,\n85:       details: {\n86:         tier: args.tier ?? null,\n87:         specFolder: args.specFolder ?? null,\n88:       },\n89:       recovery: {\n90:         hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n91:         actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   await checkDatabaseUpdated();\n98: \n99:   const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n100: \n101:   // Validation\n102:   if (!tier || typeof tier !== 'string') {\n103:     throw new Error('tier is required and must be a string');\n104:   }\n105: \n106:   const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n107:   if (!validTiers.includes(tier)) {\n108:     throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n109:   }\n110: \n111:   if (!confirm) {\n112:     throw new Error('Bulk delete requires confirm: true as a safety gate');\n113:   }\n114: \n115:   // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n116:   if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n117:     throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n118:   }\n119: \n120:   if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n121:     throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n122:   }\n123: \n124:   if (\n125:     olderThanDays !== undefined\n126:     && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n127:   ) {\n128:     throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n129:   }\n130: \n131:   const database = vectorIndex.getDb();\n132:   if (!database) {\n133:     return createMCPErrorResponse({\n134:       tool: 'memory_bulk_delete',\n135:       error: 'Memory bulk delete aborted: database unavailable',\n136:       code: 'E_DB_UNAVAILABLE',\n137:       details: {\n138:         tier,\n139:         specFolder: specFolder || null,\n140:         olderThanDays: olderThanDays || null,\n141:       },\n142:       recovery: {\n143:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n144:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n145:         severity: 'error',\n146:       },\n147:     });\n148:   }\n149: \n150:   // Build query to count affected memories\n151:   let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n152:   const countParams: unknown[] = [tier];\n153: \n154:   if (specFolder) {\n155:     countSql += ' AND spec_folder = ?';\n156:     countParams.push(specFolder);\n157:   }\n158: \n159:   if (olderThanDays !== undefined) {\n160:     countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n161:     countParams.push(olderThanDays);\n162:   }\n163: \n164:   const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n165:   const affectedCount = countResult.count;\n166: \n167:   if (affectedCount === 0) {\n168:     return createMCPSuccessResponse({\n169:       tool: 'memory_bulk_delete',\n170:       summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n171:       data: { deleted: 0, tier, specFolder: specFolder || null },\n172:       hints: ['Use memory_list() to browse existing memories'],\n173:     });\n174:   }\n175: \n176:   // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n177:   let checkpointName: string | null = null;\n178:   if (!skipCheckpoint) {\n179:     const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n180:     const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n181: \n182:     try {\n183:       const checkpoint = checkpoints.createCheckpoint({\n184:         name: proposedCheckpointName,\n185:         specFolder,\n186:         metadata: {\n187:           reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n188:           tier,\n189:           affectedCount,\n190:           olderThanDays: olderThanDays || null,\n191:         },\n192:       });\n193: \n194:       if (!checkpoint) {\n195:         const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n196:         if (tier === 'constitutional' || tier === 'critical') {\n197:           throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n198:         }\n199:         console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n200:       } else {\n201:         checkpointName = checkpoint.name;\n202:         console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n203:       }\n204:     } catch (cpErr: unknown) {\n205:       const message = toErrorMessage(cpErr);\n206:       console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n207:       // High-safety tiers require a valid checkpoint.\n208:       if (tier === 'constitutional' || tier === 'critical') {\n209:         throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n210:       }\n211:       // Lower tiers can proceed with explicit no-rollback notice.\n212:       checkpointName = null;\n213:     }\n214:   } else {\n215:     console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n216:   }\n217: \n218:   // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n219:   let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n220:   const selectParams: unknown[] = [tier];\n221: \n222:   if (specFolder) {\n223:     selectSql += ' AND spec_folder = ?';\n224:     selectParams.push(specFolder);\n225:   }\n226: \n227:   if (olderThanDays !== undefined) {\n228:     selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n229:     selectParams.push(olderThanDays);\n230:   }\n231: \n232:   const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n233:     id: number;\n234:     content_hash: string | null;\n235:     file_path: string | null;\n236:     spec_folder: string | null;\n237:   }>;\n238: \n239:   // Perform deletion in a transaction\n240:   let deletedCount = 0;\n241:   const deletedIds: number[] = [];\n242: \n243:   causalEdges.init(database);\n244: \n245:   const bulkDeleteTx = database.transaction(() => {\n246:     for (const memory of memoriesToDelete) {\n247:       if (tombstoneMemory(database, memory.id)) {\n248:         // Record DELETE history after confirmed delete (no FK, history rows survive).\n249:         try {\n250:           recordHistory(\n251:             memory.id,\n252:             'DELETE',\n253:             memory.file_path ?? null,\n254:             null,\n255:             'mcp:memory_bulk_delete',\n256:             memory.spec_folder ?? null,\n257:           );\n258:         } catch (_histErr: unknown) {\n259:           // History recording is best-effort inside bulk delete\n260:         }\n261:         deletedCount++;\n262:         deletedIds.push(memory.id);\n263: \n264:         // Clean up causal edges\n265:         // Propagate edge-cleanup errors to fail the transaction.\n266:         // Previously errors were caught and logged, leaving orphan causal edges\n267:         // When memory rows were successfully deleted but edge cleanup failed.\n268:         causalEdges.deleteEdgesForMemory(String(memory.id), {\n269:           reason: 'memory row mutation cleanup',\n270:           command: 'memory-bulk-delete.handleMemoryBulkDelete',\n271:           restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n272:         });\n273:       }\n274:     }\n275:   });\n276: \n277:   bulkDeleteTx();\n278: \n279:   // Record in mutation ledger (single entry for bulk operation)\n280:   const ledgerRecorded = appendMutationLedgerSafe(database, {\n281:     mutationType: 'delete',\n282:     reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n283:     priorHash: null,\n284:     newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n285:     linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n286:     decisionMeta: {\n287:       tool: 'memory_bulk_delete',\n288:       tier,\n289:       specFolder: specFolder || null,\n290:       olderThanDays: olderThanDays || null,\n291:       totalDeleted: deletedCount,\n292:       checkpoint: checkpointName,\n293:       skipCheckpoint,\n294:     },\n295:     actor: 'mcp:memory_bulk_delete',\n296:   });\n297: \n298:   // Invalidate caches\n299:   let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n300:   if (deletedCount > 0) {\n301:     let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n302:     try {\n303:       postMutationHooks = runPostMutationHooks('bulk-delete', {\n304:         specFolder,\n305:         tier,\n306:         deletedCount,\n307:         statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n308:           target: 'memory_index',\n309:           key: String(id),\n310:           sourceOperation: 'bulk-delete',\n311:           metadata: { tier, specFolder: specFolder ?? null },\n312:         })),\n313:       });\n314:     } catch (hookError: unknown) {\n315:       const msg = hookError instanceof Error ? hookError.message : String(hookError);\n316:       postMutationHooks = {\n317:         latencyMs: 0, triggerCacheCleared: false,\n318:         constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n319:         graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n320:         errors: [msg],\n321:       };\n322:     }\n323:     postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n324:   }\n325: \n326:   const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n327: \n328:   const hints: string[] = [];\n329:   if (checkpointName) {\n330:     hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n331:   } else if (skipCheckpoint) {\n332:     hints.push('Checkpoint skipped: restore is not available for this operation');\n333:   }\n334:   if (postMutationFeedback) {\n335:     hints.push(...postMutationFeedback.hints);\n336:   }\n337:   if (!ledgerRecorded) {\n338:     hints.push('Mutation ledger append failed; audit trail may be incomplete.');\n339:   }\n340:   hints.push(`Run memory_index_scan({ force: true }) to re-index if needed`);\n341: \n342:   const data: Record<string, unknown> = {\n343:     deleted: deletedCount,\n344:     tier,\n345:     specFolder: specFolder || null,\n346:     olderThanDays: olderThanDays || null,\n347:     skipCheckpoint,\n348:   };\n349:   if (checkpointName) {\n350:     data.checkpoint = checkpointName;\n351:     data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n352:   }\n353:   if (postMutationFeedback) {\n354:     data.postMutationHooks = postMutationFeedback.data;\n355:   }\n356:   if (!ledgerRecorded) {\n357:     data.warning = 'Mutation ledger append failed; audit trail may be incomplete.';\n358:   }\n359: \n360:   return createMCPSuccessResponse({\n361:     tool: 'memory_bulk_delete',\n362:     summary,\n363:     data,\n364:     hints,\n365:   });\n366: }\n367: \n368: /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n369:    3. EXPORTS\n370: в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n371: \n372: export { handleMemoryBulkDelete };\n\n(End of file - total 372 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Bulk Delete\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Memory Bulk Delete\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// Tier-based bulk deletion of memories with safety gates.\n// Eliminates the need for direct DB scripts when cleaning up\n// Deprecated/temporary memories at scale.\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport * as checkpoints from '../lib/storage/checkpoints.js';\nimport * as mutationLedger from '../lib/storage/mutation-ledger.js';\nimport * as causalEdges from '../lib/storage/causal-edges.js';\nimport { createStatediffAction } from '../lib/storage/statediff.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport { recordHistory } from '../lib/storage/history.js';\nimport { MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS } from '../schemas/tool-input-schemas.js';\nimport { appendMutationLedgerSafe } from './memory-crud-utils.js';\nimport { runPostMutationHooks } from './mutation-hooks.js';\nimport { buildMutationHookFeedback } from '../hooks/mutation-feedback.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Tier-based bulk deletion (memory_bulk_delete)\n// Feature catalog: Per-memory history log\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   1. TYPES\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\ninterface BulkDeleteArgs {\n  tier: string;\n  specFolder?: string;\n  confirm: boolean;\n  olderThanDays?: number;\n  skipCheckpoint?: boolean;\n}\n\nfunction hasDeletedAtColumn(database: ReturnType<typeof vectorIndex.getDb>): boolean {\n  if (!database || !('prepare' in database)) return false;\n  try {\n    const columns = database.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>;\n    return columns.some((column) => column.name === 'deleted_at');\n  } catch {\n    return false;\n  }\n}\n\nfunction isSoftDeleteTombstonesEnabled(): boolean {\n  return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n}\n\nfunction tombstoneMemory(database: NonNullable<ReturnType<typeof vectorIndex.getDb>>, memoryId: number): boolean {\n  if (!isSoftDeleteTombstonesEnabled()) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  if (!hasDeletedAtColumn(database)) {\n    return vectorIndex.deleteMemory(memoryId, database);\n  }\n\n  const deletedAt = new Date().toISOString();\n  const result = database.prepare(`\n    UPDATE memory_index\n    SET deleted_at = COALESCE(deleted_at, ?),\n        updated_at = datetime('now')\n    WHERE id = ?\n  `).run(deletedAt, memoryId);\n  return result.changes > 0;\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    2. HANDLER\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nasync function handleMemoryBulkDelete(args: BulkDeleteArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_bulk_delete');\n  const restoreBarrier = checkpoints.getRestoreBarrierStatus();\n  if (restoreBarrier) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: restoreBarrier.message,\n      code: restoreBarrier.code,\n      details: {\n        tier: args.tier ?? null,\n        specFolder: args.specFolder ?? null,\n      },\n      recovery: {\n        hint: 'Retry memory_bulk_delete after checkpoint_restore maintenance completes.',\n        actions: ['Wait for the restore to finish', 'Retry the bulk delete request'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  await checkDatabaseUpdated();\n\n  const { tier, specFolder, confirm, olderThanDays, skipCheckpoint = false } = args;\n\n  // Validation\n  if (!tier || typeof tier !== 'string') {\n    throw new Error('tier is required and must be a string');\n  }\n\n  const validTiers = ['constitutional', 'critical', 'important', 'normal', 'temporary', 'deprecated'];\n  if (!validTiers.includes(tier)) {\n    throw new Error(`Invalid tier: \"${tier}\". Must be one of: ${validTiers.join(', ')}`);\n  }\n\n  if (!confirm) {\n    throw new Error('Bulk delete requires confirm: true as a safety gate');\n  }\n\n  // Safety: refuse to bulk-delete constitutional or critical tiers without explicit specFolder scope\n  if ((tier === 'constitutional' || tier === 'critical') && !specFolder) {\n    throw new Error(`Bulk delete of \"${tier}\" tier requires specFolder scope for safety. Use memory_delete for individual deletions.`);\n  }\n\n  if ((tier === 'constitutional' || tier === 'critical') && skipCheckpoint) {\n    throw new Error(`skipCheckpoint is not allowed for \"${tier}\" tier. Checkpoint is mandatory for high-safety tiers.`);\n  }\n\n  if (\n    olderThanDays !== undefined\n    && (!Number.isInteger(olderThanDays) || olderThanDays < MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS)\n  ) {\n    throw new Error(`olderThanDays must be an integer >= ${MEMORY_BULK_DELETE_MIN_OLDER_THAN_DAYS} when provided`);\n  }\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_bulk_delete',\n      error: 'Memory bulk delete aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        tier,\n        specFolder: specFolder || null,\n        olderThanDays: olderThanDays || null,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Build query to count affected memories\n  let countSql = 'SELECT COUNT(*) as count FROM memory_index WHERE importance_tier = ?';\n  const countParams: unknown[] = [tier];\n\n  if (specFolder) {\n    countSql += ' AND spec_folder = ?';\n    countParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    countSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    countParams.push(olderThanDays);\n  }\n\n  const countResult = database.prepare(countSql).get(...countParams) as { count: number };\n  const affectedCount = countResult.count;\n\n  if (affectedCount === 0) {\n    return createMCPSuccessResponse({\n      tool: 'memory_bulk_delete',\n      summary: `No spec-doc records found with tier=\"${tier}\"${specFolder ? ` in folder \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`,\n      data: { deleted: 0, tier, specFolder: specFolder || null },\n      hints: ['Use memory_list() to browse existing memories'],\n    });\n  }\n\n  // Create auto-checkpoint before bulk deletion (unless explicitly skipped)\n  let checkpointName: string | null = null;\n  if (!skipCheckpoint) {\n    const timestamp = new Date().toISOString().replace(/[:.]/g, '-').slice(0, 19);\n    const proposedCheckpointName = `pre-bulk-delete-${tier}-${timestamp}`;\n\n    try {\n      const checkpoint = checkpoints.createCheckpoint({\n        name: proposedCheckpointName,\n        specFolder,\n        metadata: {\n          reason: `auto-checkpoint before bulk delete of ${affectedCount} \"${tier}\" spec-doc records`,\n          tier,\n          affectedCount,\n          olderThanDays: olderThanDays || null,\n        },\n      });\n\n      if (!checkpoint) {\n        const checkpointError = `Checkpoint creation failed before deleting ${tier} memories`;\n        if (tier === 'constitutional' || tier === 'critical') {\n          throw new Error(`${checkpointError}. Aborting high-safety bulk delete.`);\n        }\n        console.warn(`[memory-bulk-delete] ${checkpointError}. Proceeding without rollback.`);\n      } else {\n        checkpointName = checkpoint.name;\n        console.error(`[memory-bulk-delete] Created checkpoint: ${checkpointName}`);\n      }\n    } catch (cpErr: unknown) {\n      const message = toErrorMessage(cpErr);\n      console.error(`[memory-bulk-delete] Failed to create checkpoint: ${message}`);\n      // High-safety tiers require a valid checkpoint.\n      if (tier === 'constitutional' || tier === 'critical') {\n        throw new Error(`Failed to create mandatory checkpoint for \"${tier}\" tier: ${message}`);\n      }\n      // Lower tiers can proceed with explicit no-rollback notice.\n      checkpointName = null;\n    }\n  } else {\n    console.error('[memory-bulk-delete] Checkpoint creation skipped by caller (skipCheckpoint=true)');\n  }\n\n  // Fetch IDs for deletion (needed for causal edge cleanup and ledger)\n  let selectSql = 'SELECT id, content_hash, file_path, spec_folder FROM memory_index WHERE importance_tier = ?';\n  const selectParams: unknown[] = [tier];\n\n  if (specFolder) {\n    selectSql += ' AND spec_folder = ?';\n    selectParams.push(specFolder);\n  }\n\n  if (olderThanDays !== undefined) {\n    selectSql += ` AND created_at < datetime('now', '-' || ? || ' days')`;\n    selectParams.push(olderThanDays);\n  }\n\n  const memoriesToDelete = database.prepare(selectSql).all(...selectParams) as Array<{\n    id: number;\n    content_hash: string | null;\n    file_path: string | null;\n    spec_folder: string | null;\n  }>;\n\n  // Perform deletion in a transaction\n  let deletedCount = 0;\n  const deletedIds: number[] = [];\n\n  causalEdges.init(database);\n\n  const bulkDeleteTx = database.transaction(() => {\n    for (const memory of memoriesToDelete) {\n      if (tombstoneMemory(database, memory.id)) {\n        // Record DELETE history after confirmed delete (no FK, history rows survive).\n        try {\n          recordHistory(\n            memory.id,\n            'DELETE',\n            memory.file_path ?? null,\n            null,\n            'mcp:memory_bulk_delete',\n            memory.spec_folder ?? null,\n          );\n        } catch (_histErr: unknown) {\n          // History recording is best-effort inside bulk delete\n        }\n        deletedCount++;\n        deletedIds.push(memory.id);\n\n        // Clean up causal edges\n        // Propagate edge-cleanup errors to fail the transaction.\n        // Previously errors were caught and logged, leaving orphan causal edges\n        // When memory rows were successfully deleted but edge cleanup failed.\n        causalEdges.deleteEdgesForMemory(String(memory.id), {\n          reason: 'memory row mutation cleanup',\n          command: 'memory-bulk-delete.handleMemoryBulkDelete',\n          restoreContext: { memoryId: memory.id, tier, specFolder: memory.spec_folder, checkpointName },\n        });\n      }\n    }\n  });\n\n  bulkDeleteTx();\n\n  // Record in mutation ledger (single entry for bulk operation)\n  const ledgerRecorded = appendMutationLedgerSafe(database, {\n    mutationType: 'delete',\n    reason: `memory_bulk_delete: deleted ${deletedCount} memories with tier=\"${tier}\"`,\n    priorHash: null,\n    newHash: mutationLedger.computeHash(`bulk-delete-tier:${tier}:${deletedCount}:${Date.now()}`),\n    linkedMemoryIds: deletedIds.slice(0, 50), // Cap at 50 to avoid bloating ledger\n    decisionMeta: {\n      tool: 'memory_bulk_delete',\n      tier,\n      specFolder: specFolder || null,\n      olderThanDays: olderThanDays || null,\n      totalDeleted: deletedCount,\n      checkpoint: checkpointName,\n      skipCheckpoint,\n    },\n    actor: 'mcp:memory_bulk_delete',\n  });\n\n  // Invalidate caches\n  let postMutationFeedback: ReturnType<typeof buildMutationHookFeedback> | null = null;\n  if (deletedCount > 0) {\n    let postMutationHooks: import('./mutation-hooks.js').MutationHookResult;\n    try {\n      postMutationHooks = runPostMutationHooks('bulk-delete', {\n        specFolder,\n        tier,\n        deletedCount,\n        statediffActions: deletedIds.map((id) => createStatediffAction('delete', {\n          target: 'memory_index',\n          key: String(id),\n          sourceOperation: 'bulk-delete',\n          metadata: { tier, specFolder: specFolder ?? null },\n        })),\n      });\n    } catch (hookError: unknown) {\n      const msg = hookError instanceof Error ? hookError.message : String(hookError);\n      postMutationHooks = {\n        latencyMs: 0, triggerCacheCleared: false,\n        constitutionalCacheCleared: false, toolCacheInvalidated: 0,\n        graphSignalsCacheCleared: false, coactivationCacheCleared: false,\n        errors: [msg],\n      };\n    }\n    postMutationFeedback = buildMutationHookFeedback('bulk-delete', postMutationHooks);\n  }\n\n  const summary = `Deleted ${deletedCount} \"${tier}\" spec-doc record(s)${specFolder ? ` from \"${specFolder}\"` : ''}${olderThanDays ? ` older than ${olderThanDays} days` : ''}`;\n\n  const hints: string[] = [];\n  if (checkpointName) {\n    hints.push(`Restore with: checkpoint_restore({ name: \"${checkpointName}\" })`);\n  } else if (skipCheckpoint) {\n    hints.push('Checkpoint skipped: restore is not available for this operation');\n  }\n  if (postMutationFeedback) {\n    hints.push(...postMutationFeedback.hints);\n  }\n  if (!ledgerRecorded) {\n    hints.push('Mutation ledger append failed; audit trail may be incomplete.');\n  }\n  hints.push(`Run memory_index_scan({ force: true }) to re-index if needed`);\n\n  const data: Record<string, unknown> = {\n    deleted: deletedCount,\n    tier,\n    specFolder: specFolder || null,\n    olderThanDays: olderThanDays || null,\n    skipCheckpoint,\n  };\n  if (checkpointName) {\n    data.checkpoint = checkpointName;\n    data.restoreCommand = `checkpoint_restore({ name: \"${checkpointName}\" })`;\n  }\n  if (postMutationFeedback) {\n    data.postMutationHooks = postMutationFeedback.data;\n  }\n  if (!ledgerRecorded) {\n    data.warning = 'Mutation ledger append failed; audit trail may be incomplete.';\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_bulk_delete',\n    summary,\n    data,\n    hints,\n  });\n}\n\n/* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   3. EXPORTS\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */\n\nexport { handleMemoryBulkDelete };","lineStart":1,"lineEnd":372,"totalLines":372,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts","time":{"start":1781764217356,"end":1781764217360}},"metadata":{"openai":{"itemId":"fc_029fb0d52577e901016a3390792c908191806a5da8fc02dbba"}},"id":"prt_ed96c5a06001xHr5dU97uGDXp5","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c1eea001tzvVVbCyA2kr7i"}}
{"type":"tool_use","timestamp":1781764217362,"sessionID":"ses_126960be2ffewGSaH1Z0io46OH","part":{"type":"tool","tool":"read","callID":"call_ZbysHEouJ1dqJJ5avvUlmri4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","offset":1,"limit":1400},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts</path>\n<type>file</type>\n<content>\n1: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n2: // MODULE: Atomic Index Memory\n3: // в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n4: \n5: import fs from 'node:fs';\n6: import path from 'node:path';\n7: import { randomUUID } from 'node:crypto';\n8: \n9: import * as transactionManager from '../../lib/storage/transaction-manager.js';\n10: \n11: import type {\n12:   AtomicSaveOptions,\n13:   AtomicSaveParams,\n14:   AtomicSaveResult,\n15:   IndexResult,\n16: } from './types.js';\n17: import { withSpecFolderLock } from './spec-folder-mutex.js';\n18: \n19: // Feature catalog: Memory indexing (memory_save)\n20: // Feature catalog: Atomic-save parity and partial-indexing hints\n21: \n22: interface AtomicIndexOriginalState {\n23:   existed: boolean;\n24:   content: string | null;\n25: }\n26: \n27: interface AtomicIndexPendingCleanupResult {\n28:   cleaned: boolean;\n29:   existed: boolean;\n30:   error?: string;\n31: }\n32: \n33: interface AtomicIndexRestoreResult {\n34:   restored: boolean;\n35:   error?: string;\n36: }\n37: \n38: export interface AtomicIndexReady<TPrepared = unknown> {\n39:   status: 'ready';\n40:   prepared: TPrepared;\n41:   specFolder: string;\n42:   persistedContent?: string;\n43:   persistedFilePath?: string;\n44: }\n45: \n46: export interface AtomicIndexTerminal {\n47:   status: 'abort' | 'rejected';\n48:   result: AtomicSaveResult;\n49: }\n50: \n51: export type AtomicIndexPreparation<TPrepared = unknown> =\n52:   | AtomicIndexReady<TPrepared>\n53:   | AtomicIndexTerminal;\n54: \n55: export interface AtomicIndexAttemptContext {\n56:   attempt: number;\n57:   force: boolean;\n58: }\n59: \n60: export interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n61:   params: AtomicSaveParams;\n62:   ready: AtomicIndexReady<TPrepared>;\n63:   specFolderLockAlreadyHeld: true;\n64: }\n65: \n66: export interface AtomicIndexDependencies<TPrepared = unknown> {\n67:   prepare: (\n68:     params: AtomicSaveParams,\n69:     context: AtomicIndexAttemptContext,\n70:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n71:   prepareLocked?: (\n72:     context: AtomicIndexLockedContext<TPrepared>,\n73:   ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n74:   indexPrepared: (\n75:     context: AtomicIndexLockedContext<TPrepared>,\n76:   ) => Promise<IndexResult> | IndexResult;\n77:   mapSuccessResult?: (\n78:     indexResult: IndexResult,\n79:     context: AtomicIndexLockedContext<TPrepared>,\n80:   ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n81:   maxIndexAttempts?: number;\n82:   getPendingPath?: (filePath: string) => string;\n83:   withSpecFolderLock?: typeof withSpecFolderLock;\n84:   captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n85:   restoreOriginalState?: (\n86:     filePath: string,\n87:     originalState: AtomicIndexOriginalState,\n88:   ) => AtomicIndexRestoreResult;\n89:   cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n90:   writePendingFile?: (pendingPath: string, content: string) => void;\n91:   promotePendingFile?: (pendingPath: string, filePath: string) => void;\n92: }\n93: \n94: function toErrorMessage(error: unknown): string {\n95:   return error instanceof Error ? error.message : String(error);\n96: }\n97: \n98: function deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n99:   const existed = fs.existsSync(filePath);\n100:   if (!existed) {\n101:     return { deleted: false, existed: false };\n102:   }\n103: \n104:   try {\n105:     fs.unlinkSync(filePath);\n106:     return { deleted: true, existed: true };\n107:   } catch (error: unknown) {\n108:     return {\n109:       deleted: false,\n110:       existed: true,\n111:       error: toErrorMessage(error),\n112:     };\n113:   }\n114: }\n115: \n116: function captureOriginalState(filePath: string): AtomicIndexOriginalState {\n117:   if (!fs.existsSync(filePath)) {\n118:     return { existed: false, content: null };\n119:   }\n120: \n121:   return {\n122:     existed: true,\n123:     content: fs.readFileSync(filePath, 'utf-8'),\n124:   };\n125: }\n126: \n127: function restoreOriginalState(\n128:   filePath: string,\n129:   originalState: AtomicIndexOriginalState,\n130: ): AtomicIndexRestoreResult {\n131:   try {\n132:     if (!originalState.existed) {\n133:       const deleteResult = deleteFileIfPresent(filePath);\n134:       if (!deleteResult.existed || deleteResult.deleted) {\n135:         return { restored: true };\n136:       }\n137:       return {\n138:         restored: false,\n139:         error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n140:       };\n141:     }\n142: \n143:     if (typeof originalState.content !== 'string') {\n144:       return { restored: false, error: 'Original file content is unavailable for rollback' };\n145:     }\n146: \n147:     fs.mkdirSync(path.dirname(filePath), { recursive: true });\n148:     fs.writeFileSync(filePath, originalState.content, 'utf-8');\n149:     return { restored: true };\n150:   } catch (error: unknown) {\n151:     return {\n152:       restored: false,\n153:       error: toErrorMessage(error),\n154:     };\n155:   }\n156: }\n157: \n158: function cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n159:   const deleteResult = deleteFileIfPresent(pendingPath);\n160:   if (!deleteResult.existed || deleteResult.deleted) {\n161:     return {\n162:       cleaned: true,\n163:       existed: deleteResult.existed,\n164:     };\n165:   }\n166:   return {\n167:     cleaned: false,\n168:     existed: deleteResult.existed,\n169:     error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n170:   };\n171: }\n172: \n173: function writePendingFile(pendingPath: string, content: string): void {\n174:   fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n175:   fs.writeFileSync(pendingPath, content, 'utf-8');\n176: }\n177: \n178: function promotePendingFile(pendingPath: string, filePath: string): void {\n179:   fs.mkdirSync(path.dirname(filePath), { recursive: true });\n180:   fs.renameSync(pendingPath, filePath);\n181: }\n182: \n183: function defaultPendingPath(filePath: string): string {\n184:   const basePendingPath = transactionManager.getPendingPath(filePath);\n185:   return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n186: }\n187: \n188: function buildRejectedResult(\n189:   filePath: string,\n190:   indexResult: IndexResult,\n191:   rollbackSucceeded: boolean,\n192:   errorMetadata: Record<string, string> | null,\n193: ): AtomicSaveResult {\n194:   return {\n195:     success: false,\n196:     filePath,\n197:     status: 'rejected',\n198:     id: indexResult.id,\n199:     specFolder: indexResult.specFolder,\n200:     title: indexResult.title,\n201:     summary: rollbackSucceeded\n202:       ? 'Atomic index rejected before file promotion'\n203:       : 'Atomic index rejected but pending file cleanup failed',\n204:     message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n205:     embeddingStatus: indexResult.embeddingStatus,\n206:     hints: [\n207:       rollbackSucceeded\n208:         ? 'Pending file was removed because the save was rejected before promotion'\n209:         : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n210:     ],\n211:     ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n212:     ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n213:   };\n214: }\n215: \n216: function buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n217:   const message = indexResult.message ?? (\n218:     indexResult.status === 'duplicate'\n219:       ? 'Memory skipped (duplicate content)'\n220:       : `Memory ${indexResult.status} successfully`\n221:   );\n222: \n223:   const hints: string[] = [];\n224:   if (indexResult.embeddingStatus === 'pending') {\n225:     hints.push('Memory will be fully indexed when embedding provider becomes available');\n226:   }\n227:   if (indexResult.embeddingStatus === 'partial') {\n228:     hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n229:   }\n230: \n231:   const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n232: \n233:   return {\n234:     success: true,\n235:     filePath,\n236:     status: indexResult.status,\n237:     id: indexResult.id,\n238:     specFolder: indexResult.specFolder,\n239:     title: indexResult.title,\n240:     summary: message,\n241:     message,\n242:     embeddingStatus: indexResult.embeddingStatus,\n243:     ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n244:       ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n245:       : {}),\n246:     ...(hints.length > 0 ? { hints } : {}),\n247:   };\n248: }\n249: \n250: function buildRetryFailureResult(\n251:   filePath: string,\n252:   indexError: Error | null,\n253:   rollbackSucceeded: boolean,\n254:   errorMetadata: Record<string, string> | null,\n255: ): AtomicSaveResult {\n256:   const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n257:   const finalErrorMetadata = errorMetadata ?? {};\n258: \n259:   return {\n260:     success: false,\n261:     filePath,\n262:     status: 'error',\n263:     summary: rollbackSucceeded\n264:       ? 'Atomic index failed after retry and restored original file state'\n265:       : 'Atomic index failed after retry and rollback was incomplete',\n266:     message: indexError?.message ?? 'Indexing failed after retry',\n267:     hints: [\n268:       rollbackSucceeded\n269:         ? 'Original file content was preserved or restored because indexing failed before completion'\n270:         : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n271:       'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n272:     ],\n273:     error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n274:     ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n275:   };\n276: }\n277: \n278: export async function atomicIndexMemory<TPrepared = unknown>(\n279:   params: AtomicSaveParams,\n280:   options: AtomicSaveOptions = {},\n281:   dependencies: AtomicIndexDependencies<TPrepared>,\n282: ): Promise<AtomicSaveResult> {\n283:   const { file_path, content } = params;\n284:   const { force = false } = options;\n285: \n286:   const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n287: \n288:   let indexResult: IndexResult | null = null;\n289:   let indexError: Error | null = null;\n290:   let restoredOriginalAfterFailure = false;\n291:   let anyPromotionAttempted = false;\n292:   let errorMetadata: Record<string, string> | null = null;\n293:   let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n294:   let lastEffectiveFilePath = file_path;\n295:   let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n296: \n297:   const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n298:     if (!entry) {\n299:       return;\n300:     }\n301:     errorMetadata = {\n302:       ...(errorMetadata ?? {}),\n303:       ...entry,\n304:     };\n305:   };\n306: \n307:   for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n308:     let promotedToFinalPath = false;\n309:     let handledFailureWhileLocked = false;\n310:     let rollbackSucceededAfterRejectedSave = false;\n311:     let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n312: \n313:     try {\n314:       const prepared = await dependencies.prepare(params, { attempt, force });\n315:       if (prepared.status !== 'ready') {\n316:         return prepared.result;\n317:       }\n318: \n319:       const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n320:       const lockedResult = await runWithLock(prepared.specFolder, async () => {\n321:         let effectiveFilePath = lastEffectiveFilePath;\n322:         let pendingPath = lastPendingPath;\n323:         let originalState: AtomicIndexOriginalState | null = null;\n324:         try {\n325:           let ready = prepared;\n326:           lockedContext = {\n327:             attempt,\n328:             force,\n329:             params,\n330:             ready,\n331:             specFolderLockAlreadyHeld: true,\n332:           };\n333: \n334:           if (dependencies.prepareLocked) {\n335:             const preparedLocked = await dependencies.prepareLocked(lockedContext);\n336:             if (preparedLocked.status !== 'ready') {\n337:               return {\n338:                 kind: 'terminal',\n339:                 result: preparedLocked.result,\n340:               } as const;\n341:             }\n342: \n343:             ready = preparedLocked;\n344:             lockedContext = {\n345:               attempt,\n346:               force,\n347:               params,\n348:               ready,\n349:               specFolderLockAlreadyHeld: true,\n350:             };\n351:           }\n352: \n353:           effectiveFilePath = ready.persistedFilePath ?? file_path;\n354:           const persistedContent = ready.persistedContent ?? content;\n355:           pendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(effectiveFilePath);\n356:           originalState = (dependencies.captureOriginalState ?? captureOriginalState)(effectiveFilePath);\n357:           lastEffectiveFilePath = effectiveFilePath;\n358:           lastPendingPath = pendingPath;\n359: \n360:           (dependencies.writePendingFile ?? writePendingFile)(pendingPath, persistedContent);\n361: \n362:           const lockedIndexResult = await dependencies.indexPrepared(lockedContext);\n363: \n364:           if (lockedIndexResult.status === 'rejected') {\n365:             handledFailureWhileLocked = true;\n366:             const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n367:             rollbackSucceededAfterRejectedSave = pendingCleanupResult.cleaned;\n368:             if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n369:               mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n370:             }\n371:             return {\n372:               kind: 'indexed',\n373:               indexResult: lockedIndexResult,\n374:               context: lockedContext,\n375:             } as const;\n376:           }\n377: \n378:           (dependencies.promotePendingFile ?? promotePendingFile)(pendingPath, effectiveFilePath);\n379:           promotedToFinalPath = true;\n380:           anyPromotionAttempted = true;\n381: \n382:           return {\n383:             kind: 'indexed',\n384:             indexResult: lockedIndexResult,\n385:             context: lockedContext,\n386:           } as const;\n387:         } catch (lockedError: unknown) {\n388:           handledFailureWhileLocked = true;\n389:           const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n390:           if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n391:             mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n392:           }\n393: \n394:           if (promotedToFinalPath) {\n395:             const rollbackResult = (dependencies.restoreOriginalState ?? restoreOriginalState)(\n396:               effectiveFilePath,\n397:               originalState ?? captureOriginalState(effectiveFilePath),\n398:             );\n399:             restoredOriginalAfterFailure = rollbackResult.restored;\n400:             if (!rollbackResult.restored && rollbackResult.error) {\n401:               mergeErrorMetadata({ rollbackError: rollbackResult.error });\n402:             }\n403:             if (!restoredOriginalAfterFailure) {\n404:               const message = toErrorMessage(lockedError);\n405:               throw new Error(`Original file rollback failed after promote-before-index path: ${message}`);\n406:             }\n407:           }\n408: \n409:           throw lockedError;\n410:         }\n411:       });\n412: \n413:       if (lockedResult.kind === 'terminal') {\n414:         return lockedResult.result;\n415:       }\n416: \n417:       indexResult = lockedResult.indexResult;\n418: \n419:       if (indexResult.status === 'error') {\n420:         throw new Error(indexResult.message ?? indexResult.error ?? 'atomicIndexMemory indexPrepared returned status=error');\n421:       }\n422: \n423:       if (indexResult.status === 'rejected') {\n424:         return buildRejectedResult(lastEffectiveFilePath, indexResult, rollbackSucceededAfterRejectedSave, errorMetadata);\n425:       }\n426: \n427:       successfulLockedContext = lockedResult.context;\n428:       indexError = null;\n429:       break;\n430:     } catch (error: unknown) {\n431:       if (!handledFailureWhileLocked) {\n432:         const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(lastPendingPath);\n433:         if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n434:           mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n435:         }\n436:       }\n437:       indexError = error instanceof Error ? error : new Error(toErrorMessage(error));\n438:       if (attempt === maxIndexAttempts) {\n439:         break;\n440:       }\n441:     }\n442:   }\n443: \n444:   if (!indexResult || indexError) {\n445:     return buildRetryFailureResult(\n446:       lastEffectiveFilePath,\n447:       indexError,\n448:       anyPromotionAttempted ? restoredOriginalAfterFailure : true,\n449:       errorMetadata,\n450:     );\n451:   }\n452: \n453:   if (dependencies.mapSuccessResult && successfulLockedContext) {\n454:     return await dependencies.mapSuccessResult(indexResult, successfulLockedContext);\n455:   }\n456: \n457:   return buildSuccessResult(successfulLockedContext?.ready.persistedFilePath ?? file_path, indexResult);\n458: }\n459: \n460: const atomic_index_memory = atomicIndexMemory;\n461: \n462: export { atomic_index_memory };\n\n(End of file - total 462 lines)\n</content>","metadata":{"preview":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Atomic Index Memory\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","text":"// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n// MODULE: Atomic Index Memory\n// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { randomUUID } from 'node:crypto';\n\nimport * as transactionManager from '../../lib/storage/transaction-manager.js';\n\nimport type {\n  AtomicSaveOptions,\n  AtomicSaveParams,\n  AtomicSaveResult,\n  IndexResult,\n} from './types.js';\nimport { withSpecFolderLock } from './spec-folder-mutex.js';\n\n// Feature catalog: Memory indexing (memory_save)\n// Feature catalog: Atomic-save parity and partial-indexing hints\n\ninterface AtomicIndexOriginalState {\n  existed: boolean;\n  content: string | null;\n}\n\ninterface AtomicIndexPendingCleanupResult {\n  cleaned: boolean;\n  existed: boolean;\n  error?: string;\n}\n\ninterface AtomicIndexRestoreResult {\n  restored: boolean;\n  error?: string;\n}\n\nexport interface AtomicIndexReady<TPrepared = unknown> {\n  status: 'ready';\n  prepared: TPrepared;\n  specFolder: string;\n  persistedContent?: string;\n  persistedFilePath?: string;\n}\n\nexport interface AtomicIndexTerminal {\n  status: 'abort' | 'rejected';\n  result: AtomicSaveResult;\n}\n\nexport type AtomicIndexPreparation<TPrepared = unknown> =\n  | AtomicIndexReady<TPrepared>\n  | AtomicIndexTerminal;\n\nexport interface AtomicIndexAttemptContext {\n  attempt: number;\n  force: boolean;\n}\n\nexport interface AtomicIndexLockedContext<TPrepared = unknown> extends AtomicIndexAttemptContext {\n  params: AtomicSaveParams;\n  ready: AtomicIndexReady<TPrepared>;\n  specFolderLockAlreadyHeld: true;\n}\n\nexport interface AtomicIndexDependencies<TPrepared = unknown> {\n  prepare: (\n    params: AtomicSaveParams,\n    context: AtomicIndexAttemptContext,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  prepareLocked?: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicIndexPreparation<TPrepared>> | AtomicIndexPreparation<TPrepared>;\n  indexPrepared: (\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<IndexResult> | IndexResult;\n  mapSuccessResult?: (\n    indexResult: IndexResult,\n    context: AtomicIndexLockedContext<TPrepared>,\n  ) => Promise<AtomicSaveResult> | AtomicSaveResult;\n  maxIndexAttempts?: number;\n  getPendingPath?: (filePath: string) => string;\n  withSpecFolderLock?: typeof withSpecFolderLock;\n  captureOriginalState?: (filePath: string) => AtomicIndexOriginalState;\n  restoreOriginalState?: (\n    filePath: string,\n    originalState: AtomicIndexOriginalState,\n  ) => AtomicIndexRestoreResult;\n  cleanupPendingFile?: (pendingPath: string) => AtomicIndexPendingCleanupResult;\n  writePendingFile?: (pendingPath: string, content: string) => void;\n  promotePendingFile?: (pendingPath: string, filePath: string) => void;\n}\n\nfunction toErrorMessage(error: unknown): string {\n  return error instanceof Error ? error.message : String(error);\n}\n\nfunction deleteFileIfPresent(filePath: string): { deleted: boolean; existed: boolean; error?: string } {\n  const existed = fs.existsSync(filePath);\n  if (!existed) {\n    return { deleted: false, existed: false };\n  }\n\n  try {\n    fs.unlinkSync(filePath);\n    return { deleted: true, existed: true };\n  } catch (error: unknown) {\n    return {\n      deleted: false,\n      existed: true,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction captureOriginalState(filePath: string): AtomicIndexOriginalState {\n  if (!fs.existsSync(filePath)) {\n    return { existed: false, content: null };\n  }\n\n  return {\n    existed: true,\n    content: fs.readFileSync(filePath, 'utf-8'),\n  };\n}\n\nfunction restoreOriginalState(\n  filePath: string,\n  originalState: AtomicIndexOriginalState,\n): AtomicIndexRestoreResult {\n  try {\n    if (!originalState.existed) {\n      const deleteResult = deleteFileIfPresent(filePath);\n      if (!deleteResult.existed || deleteResult.deleted) {\n        return { restored: true };\n      }\n      return {\n        restored: false,\n        error: deleteResult.error ?? `Failed to remove promoted file at ${filePath}`,\n      };\n    }\n\n    if (typeof originalState.content !== 'string') {\n      return { restored: false, error: 'Original file content is unavailable for rollback' };\n    }\n\n    fs.mkdirSync(path.dirname(filePath), { recursive: true });\n    fs.writeFileSync(filePath, originalState.content, 'utf-8');\n    return { restored: true };\n  } catch (error: unknown) {\n    return {\n      restored: false,\n      error: toErrorMessage(error),\n    };\n  }\n}\n\nfunction cleanupPendingFile(pendingPath: string): AtomicIndexPendingCleanupResult {\n  const deleteResult = deleteFileIfPresent(pendingPath);\n  if (!deleteResult.existed || deleteResult.deleted) {\n    return {\n      cleaned: true,\n      existed: deleteResult.existed,\n    };\n  }\n  return {\n    cleaned: false,\n    existed: deleteResult.existed,\n    error: deleteResult.error ?? `Failed to remove pending file at ${pendingPath}`,\n  };\n}\n\nfunction writePendingFile(pendingPath: string, content: string): void {\n  fs.mkdirSync(path.dirname(pendingPath), { recursive: true });\n  fs.writeFileSync(pendingPath, content, 'utf-8');\n}\n\nfunction promotePendingFile(pendingPath: string, filePath: string): void {\n  fs.mkdirSync(path.dirname(filePath), { recursive: true });\n  fs.renameSync(pendingPath, filePath);\n}\n\nfunction defaultPendingPath(filePath: string): string {\n  const basePendingPath = transactionManager.getPendingPath(filePath);\n  return `${basePendingPath}.${randomUUID().slice(0, 8)}`;\n}\n\nfunction buildRejectedResult(\n  filePath: string,\n  indexResult: IndexResult,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  return {\n    success: false,\n    filePath,\n    status: 'rejected',\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: rollbackSucceeded\n      ? 'Atomic index rejected before file promotion'\n      : 'Atomic index rejected but pending file cleanup failed',\n    message: indexResult.message ?? indexResult.rejectionReason ?? 'Memory save rejected',\n    embeddingStatus: indexResult.embeddingStatus,\n    hints: [\n      rollbackSucceeded\n        ? 'Pending file was removed because the save was rejected before promotion'\n        : 'Pending file cleanup failed after rejection; manual cleanup may be required',\n    ],\n    ...(rollbackSucceeded ? {} : { error: 'Pending file cleanup failed after rejected save' }),\n    ...(rollbackSucceeded || !errorMetadata ? {} : { errorMetadata }),\n  };\n}\n\nfunction buildSuccessResult(filePath: string, indexResult: IndexResult): AtomicSaveResult {\n  const message = indexResult.message ?? (\n    indexResult.status === 'duplicate'\n      ? 'Memory skipped (duplicate content)'\n      : `Memory ${indexResult.status} successfully`\n  );\n\n  const hints: string[] = [];\n  if (indexResult.embeddingStatus === 'pending') {\n    hints.push('Memory will be fully indexed when embedding provider becomes available');\n  }\n  if (indexResult.embeddingStatus === 'partial') {\n    hints.push('Large file indexed via chunking: parent record + individual chunk records with embeddings');\n  }\n\n  const maybePostMutationHooks = (indexResult as Record<string, unknown>).postMutationHooks;\n\n  return {\n    success: true,\n    filePath,\n    status: indexResult.status,\n    id: indexResult.id,\n    specFolder: indexResult.specFolder,\n    title: indexResult.title,\n    summary: message,\n    message,\n    embeddingStatus: indexResult.embeddingStatus,\n    ...(maybePostMutationHooks && typeof maybePostMutationHooks === 'object'\n      ? { postMutationHooks: maybePostMutationHooks as AtomicSaveResult['postMutationHooks'] }\n      : {}),\n    ...(hints.length > 0 ? { hints } : {}),\n  };\n}\n\nfunction buildRetryFailureResult(\n  filePath: string,\n  indexError: Error | null,\n  rollbackSucceeded: boolean,\n  errorMetadata: Record<string, string> | null,\n): AtomicSaveResult {\n  const rollbackError = errorMetadata?.rollbackError ? ` (rollback error: ${errorMetadata.rollbackError})` : '';\n  const finalErrorMetadata = errorMetadata ?? {};\n\n  return {\n    success: false,\n    filePath,\n    status: 'error',\n    summary: rollbackSucceeded\n      ? 'Atomic index failed after retry and restored original file state'\n      : 'Atomic index failed after retry and rollback was incomplete',\n    message: indexError?.message ?? 'Indexing failed after retry',\n    hints: [\n      rollbackSucceeded\n        ? 'Original file content was preserved or restored because indexing failed before completion'\n        : 'Pending file cleanup failed after indexing error; manual cleanup may be required',\n      'Retry memory_save({ filePath, force: true }) once dependencies are healthy',\n    ],\n    error: `Indexing failed after retry${rollbackError}: ${indexError?.message ?? 'unknown'}`,\n    ...(Object.keys(finalErrorMetadata).length > 0 ? { errorMetadata: finalErrorMetadata } : {}),\n  };\n}\n\nexport async function atomicIndexMemory<TPrepared = unknown>(\n  params: AtomicSaveParams,\n  options: AtomicSaveOptions = {},\n  dependencies: AtomicIndexDependencies<TPrepared>,\n): Promise<AtomicSaveResult> {\n  const { file_path, content } = params;\n  const { force = false } = options;\n\n  const maxIndexAttempts = dependencies.maxIndexAttempts ?? 2;\n\n  let indexResult: IndexResult | null = null;\n  let indexError: Error | null = null;\n  let restoredOriginalAfterFailure = false;\n  let anyPromotionAttempted = false;\n  let errorMetadata: Record<string, string> | null = null;\n  let successfulLockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n  let lastEffectiveFilePath = file_path;\n  let lastPendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(file_path);\n\n  const mergeErrorMetadata = (entry: Record<string, string> | null): void => {\n    if (!entry) {\n      return;\n    }\n    errorMetadata = {\n      ...(errorMetadata ?? {}),\n      ...entry,\n    };\n  };\n\n  for (let attempt = 1; attempt <= maxIndexAttempts; attempt += 1) {\n    let promotedToFinalPath = false;\n    let handledFailureWhileLocked = false;\n    let rollbackSucceededAfterRejectedSave = false;\n    let lockedContext: AtomicIndexLockedContext<TPrepared> | null = null;\n\n    try {\n      const prepared = await dependencies.prepare(params, { attempt, force });\n      if (prepared.status !== 'ready') {\n        return prepared.result;\n      }\n\n      const runWithLock = dependencies.withSpecFolderLock ?? withSpecFolderLock;\n      const lockedResult = await runWithLock(prepared.specFolder, async () => {\n        let effectiveFilePath = lastEffectiveFilePath;\n        let pendingPath = lastPendingPath;\n        let originalState: AtomicIndexOriginalState | null = null;\n        try {\n          let ready = prepared;\n          lockedContext = {\n            attempt,\n            force,\n            params,\n            ready,\n            specFolderLockAlreadyHeld: true,\n          };\n\n          if (dependencies.prepareLocked) {\n            const preparedLocked = await dependencies.prepareLocked(lockedContext);\n            if (preparedLocked.status !== 'ready') {\n              return {\n                kind: 'terminal',\n                result: preparedLocked.result,\n              } as const;\n            }\n\n            ready = preparedLocked;\n            lockedContext = {\n              attempt,\n              force,\n              params,\n              ready,\n              specFolderLockAlreadyHeld: true,\n            };\n          }\n\n          effectiveFilePath = ready.persistedFilePath ?? file_path;\n          const persistedContent = ready.persistedContent ?? content;\n          pendingPath = (dependencies.getPendingPath ?? defaultPendingPath)(effectiveFilePath);\n          originalState = (dependencies.captureOriginalState ?? captureOriginalState)(effectiveFilePath);\n          lastEffectiveFilePath = effectiveFilePath;\n          lastPendingPath = pendingPath;\n\n          (dependencies.writePendingFile ?? writePendingFile)(pendingPath, persistedContent);\n\n          const lockedIndexResult = await dependencies.indexPrepared(lockedContext);\n\n          if (lockedIndexResult.status === 'rejected') {\n            handledFailureWhileLocked = true;\n            const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n            rollbackSucceededAfterRejectedSave = pendingCleanupResult.cleaned;\n            if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n              mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n            }\n            return {\n              kind: 'indexed',\n              indexResult: lockedIndexResult,\n              context: lockedContext,\n            } as const;\n          }\n\n          (dependencies.promotePendingFile ?? promotePendingFile)(pendingPath, effectiveFilePath);\n          promotedToFinalPath = true;\n          anyPromotionAttempted = true;\n\n          return {\n            kind: 'indexed',\n            indexResult: lockedIndexResult,\n            context: lockedContext,\n          } as const;\n        } catch (lockedError: unknown) {\n          handledFailureWhileLocked = true;\n          const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(pendingPath);\n          if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n            mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n          }\n\n          if (promotedToFinalPath) {\n            const rollbackResult = (dependencies.restoreOriginalState ?? restoreOriginalState)(\n              effectiveFilePath,\n              originalState ?? captureOriginalState(effectiveFilePath),\n            );\n            restoredOriginalAfterFailure = rollbackResult.restored;\n            if (!rollbackResult.restored && rollbackResult.error) {\n              mergeErrorMetadata({ rollbackError: rollbackResult.error });\n            }\n            if (!restoredOriginalAfterFailure) {\n              const message = toErrorMessage(lockedError);\n              throw new Error(`Original file rollback failed after promote-before-index path: ${message}`);\n            }\n          }\n\n          throw lockedError;\n        }\n      });\n\n      if (lockedResult.kind === 'terminal') {\n        return lockedResult.result;\n      }\n\n      indexResult = lockedResult.indexResult;\n\n      if (indexResult.status === 'error') {\n        throw new Error(indexResult.message ?? indexResult.error ?? 'atomicIndexMemory indexPrepared returned status=error');\n      }\n\n      if (indexResult.status === 'rejected') {\n        return buildRejectedResult(lastEffectiveFilePath, indexResult, rollbackSucceededAfterRejectedSave, errorMetadata);\n      }\n\n      successfulLockedContext = lockedResult.context;\n      indexError = null;\n      break;\n    } catch (error: unknown) {\n      if (!handledFailureWhileLocked) {\n        const pendingCleanupResult = (dependencies.cleanupPendingFile ?? cleanupPendingFile)(lastPendingPath);\n        if (!pendingCleanupResult.cleaned && pendingCleanupResult.error) {\n          mergeErrorMetadata({ pendingCleanupError: pendingCleanupResult.error });\n        }\n      }\n      indexError = error instanceof Error ? error : new Error(toErrorMessage(error));\n      if (attempt === maxIndexAttempts) {\n        break;\n      }\n    }\n  }\n\n  if (!indexResult || indexError) {\n    return buildRetryFailureResult(\n      lastEffectiveFilePath,\n      indexError,\n      anyPromotionAttempted ? restoredOriginalAfterFailure : true,\n      errorMetadata,\n    );\n  }\n\n  if (dependencies.mapSuccessResult && successfulLockedContext) {\n    return await dependencies.mapSuccessResult(indexResult, successfulLockedContext);\n  }\n\n  return buildSuccessResult(successfulLockedContext?.ready.persistedFilePath ?? file_path, indexResult);\n}\n\nconst atomic_index_memory = atomicIndexMemory;\n\nexport { atomic_index_memory };","lineStart":1,"lineEnd":462,"totalLines":462,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/save/atomic-index-memory.ts","time":{"start":1781764217358,"end":1781764217362}},"metadata":{"openai":{"itemId":"fc_029fb0d52577e901016a3390792c948191a00d728606e25e71"}},"id":"prt_ed96c5a0d001Hui9ftZjR1REpn","sessionID":"ses_126960be2ffewGSaH1Z0io46OH","messageID":"msg_ed96c1eea001tzvVVbCyA2kr7i"}}
