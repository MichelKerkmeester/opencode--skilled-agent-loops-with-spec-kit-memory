{"type":"tool_use","timestamp":1782750768409,"sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","part":{"type":"tool","tool":"read","callID":"call_6327fc59e24f45d385cee0be","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/proof_check.py"},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/proof_check.py</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env python3\n2: \"\"\"Deterministic proof-of-application gate for sk-design context-loading.\n3: \n4: The benchmark showed the contract changes behaviour when handed to a delegate,\n5: but nothing makes the orchestrator's own path *prove* it. This is that gate: a\n6: build/delivery/CI step runs it on the filled proof-of-application card (or the\n7: notes file that embeds it) and it exits non-zero unless every required proof\n8: field is present and the verdict reads READY. A calculator for \"is the contract\n9: actually applied\", not a vibe check.\n10: \n11: Usage:\n12:   proof_check.py notes.md\n13:   proof_check.py --json notes.md\n14:   proof_check.py --require-cards notes.md   # also require both card sections\n15:   proof_check.py --require-source-proof notes.md\n16:   proof_check.py --require-application-witness notes.md\n17:   proof_check.py --require-decision-rationale notes.md\n18:   proof_check.py --require-observation-triad notes.md\n19: \n20: Required proof fields (matched case-insensitively, tolerant of formatting):\n21:   REGISTER / DIALS, CONTRAST PAIRS, INTERFACE PREFLIGHT, AUDIT EVIDENCE,\n22:   plus a READY verdict.\n23: Exit: 0 = complete + READY; 1 = missing field or NOT READY; 2 = usage error.\n24: \"\"\"\n25: import hashlib\n26: import json\n27: from pathlib import Path\n28: import re\n29: import sys\n30: from typing import Optional\n31: \n32: # label -> regexes that satisfy it (any match counts)\n33: PROOF_FIELDS = {\n34:     \"REGISTER / DIALS\": [r\"\\bregister\\b.*\\bdials?\\b\", r\"\\bregister\\s*/\\s*dials\\b\", r\"\\bVARIANCE\\b.*\\bDENSITY\\b\"],\n35:     \"CONTRAST PAIRS\": [r\"\\bcontrast[\\s-]*pairs?\\b\", r\"\\bcontrast[\\s-]*pair\\s+inventory\\b\"],\n36:     \"INTERFACE PREFLIGHT\": [r\"\\binterface\\s+pre-?flight\\b\", r\"\\bpre-?flight\\b.*\\b(pass|fail|ship)\\b\"],\n37:     \"AUDIT EVIDENCE\": [r\"\\baudit\\s+evidence\\b\", r\"\\bevidence\\s+labels?\\b\", r\"\\bconfirmed\\b.*\\binferred\\b.*\\bnot[\\s-]*assessed\\b\"],\n38: }\n39: CARD_SECTIONS = {\n40:     \"Context Loaded card\": [r\"context[\\s-]*loaded\\s+card\"],\n41:     \"Proof Of Application card\": [r\"proof[\\s-]*of[\\s-]*application\\s+card\"],\n42: }\n43: # Verdict detection is checkbox-aware: a card lists both \"[x] READY\" and\n44: # \"[ ] NOT READY\" as options, so match only the CHECKED/asserted form, never the\n45: # bare unchecked label.\n46: READY = re.compile(r\"(?:\\[x\\]|\\*\\*|verdict[:\\s*]+|result[:\\s*]+)\\s*READY\\b\", re.I)\n47: NOT_READY = re.compile(r\"(?:\\[x\\]|\\*\\*)\\s*NOT[\\s-]*READY\\b\", re.I)\n48: SOURCE_PROOF_HEADING = re.compile(r\"^#{1,6}\\s+.*SOURCE\\s+PROOF.*$\", re.I)\n49: APPLICATION_WITNESS_HEADING = re.compile(r\"^#{1,6}\\s+.*APPLICATION\\s+WITNESS.*$\", re.I)\n50: DECISION_RATIONALE_HEADING = re.compile(r\"^#{1,6}\\s+.*DECISION\\s+RATIONALE.*$\", re.I)\n51: MARKDOWN_HEADING = re.compile(r\"^#{1,6}\\s+\")\n52: SHA256 = re.compile(r\"^(?:sha256:)?([0-9a-f]{64})$\", re.I)\n53: APPLICATION_CLASSIFICATIONS = (\"not-loaded\", \"loaded-inert\", \"loaded-determinative\")\n54: DECISION_RATIONALE_FIELDS = (\n55:     \"decision\",\n56:     \"optionsConsidered[]\",\n57:     \"evidenceSources[]\",\n58:     \"tradeoffs[]\",\n59:     \"validationPlan\",\n60:     \"sourceProofs[]\",\n61: )\n62: OBSERVATION_TRIAD_FIELDS = (\"Observation\", \"Problem\", \"Fix\")\n63: FINDING_HEADING = re.compile(r\"^#{1,6}\\s+P[0-3]\\s*[-:]\\s+\\S.*$\", re.I)\n64: \n65: \n66: def _present(text: str, patterns) -> bool:\n67:     return any(re.search(p, text, re.I | re.S) for p in patterns)\n68: \n69: \n70: def _clean_cell(value: str) -> str:\n71:     value = value.strip()\n72:     if len(value) >= 2 and value[0] == \"`\" and value[-1] == \"`\":\n73:         value = value[1:-1].strip()\n74:     return value\n75: \n76: \n77: def _is_placeholder(value: str) -> bool:\n78:     cleaned = _clean_cell(value)\n79:     return not cleaned or bool(re.fullmatch(r\"(?:sha256:)?_+\", cleaned))\n80: \n81: \n82: def _split_table_row(line: str) -> list[str]:\n83:     line = line.strip()\n84:     if not line.startswith(\"|\") or not line.endswith(\"|\"):\n85:         return []\n86:     return [cell.strip() for cell in line.strip(\"|\").split(\"|\")]\n87: \n88: \n89: def _is_separator_row(cells: list[str]) -> bool:\n90:     return bool(cells) and all(re.fullmatch(r\":?-{3,}:?\", cell.strip()) for cell in cells)\n91: \n92: \n93: def _find_source_proof_rows(text: str) -> list[dict]:\n94:     lines = text.splitlines()\n95:     start = None\n96:     for i, line in enumerate(lines):\n97:         if SOURCE_PROOF_HEADING.search(line):\n98:             start = i + 1\n99:             break\n100:     if start is None:\n101:         return []\n102: \n103:     rows = []\n104:     in_table = False\n105:     for line in lines[start:]:\n106:         if MARKDOWN_HEADING.match(line):\n107:             break\n108:         cells = _split_table_row(line)\n109:         if not cells:\n110:             if in_table:\n111:                 break\n112:             continue\n113:         if len(cells) != 4:\n114:             continue\n115:         normalized = [_clean_cell(cell).lower() for cell in cells]\n116:         if normalized == [\"path\", \"sha256\", \"anchor\", \"echo\"] or _is_separator_row(cells):\n117:             in_table = True\n118:             continue\n119:         in_table = True\n120:         if all(_is_placeholder(cell) for cell in cells):\n121:             continue\n122:         rows.append({\n123:             \"path\": _clean_cell(cells[0]),\n124:             \"sha256\": _clean_cell(cells[1]),\n125:             \"anchor\": _clean_cell(cells[2]),\n126:             \"echo\": _clean_cell(cells[3]),\n127:         })\n128:     return rows\n129: \n130: \n131: def _application_classification(value: str) -> Optional[str]:\n132:     for classification in APPLICATION_CLASSIFICATIONS:\n133:         pattern = r\"\\[[xX]\\]\\s*\" + re.escape(classification) + r\"\\b\"\n134:         if re.search(pattern, value, re.I):\n135:             return classification\n136:     return None\n137: \n138: \n139: def _find_application_witness_rows(text: str) -> list[dict]:\n140:     lines = text.splitlines()\n141:     start = None\n142:     for i, line in enumerate(lines):\n143:         if APPLICATION_WITNESS_HEADING.search(line):\n144:             start = i + 1\n145:             break\n146:     if start is None:\n147:         return []\n148: \n149:     rows = []\n150:     in_table = False\n151:     for line in lines[start:]:\n152:         if MARKDOWN_HEADING.match(line):\n153:             break\n154:         cells = _split_table_row(line)\n155:         if not cells:\n156:             if in_table:\n157:                 break\n158:             continue\n159:         if len(cells) != 4:\n160:             continue\n161:         normalized = [_clean_cell(cell).lower() for cell in cells]\n162:         if normalized == [\"output choice\", \"loaded rule source\", \"classification\", \"counterfactual\"] or _is_separator_row(cells):\n163:             in_table = True\n164:             continue\n165:         in_table = True\n166:         classification = _application_classification(cells[2])\n167:         if (\n168:             _is_placeholder(cells[0])\n169:             and _is_placeholder(cells[1])\n170:             and classification is None\n171:             and _is_placeholder(cells[3])\n172:         ):\n173:             continue\n174:         rows.append({\n175:             \"output_choice\": _clean_cell(cells[0]),\n176:             \"loaded_rule_source\": _clean_cell(cells[1]),\n177:             \"classification\": classification,\n178:             \"counterfactual\": _clean_cell(cells[3]),\n179:         })\n180:     return rows\n181: \n182: \n183: def _decision_rationale_canonical_field(value: str) -> Optional[str]:\n184:     normalized = re.sub(r\"\\s+\", \"\", _clean_cell(value).rstrip(\":\")).lower()\n185:     for field in DECISION_RATIONALE_FIELDS:\n186:         if normalized == field.lower():\n187:             return field\n188:     return None\n189: \n190: \n191: def _find_decision_rationale_rows(text: str) -> list[dict]:\n192:     lines = text.splitlines()\n193:     start = None\n194:     for i, line in enumerate(lines):\n195:         if DECISION_RATIONALE_HEADING.search(line):\n196:             start = i + 1\n197:             break\n198:     if start is None:\n199:         return []\n200: \n201:     rows = []\n202:     in_table = False\n203:     for line in lines[start:]:\n204:         if MARKDOWN_HEADING.match(line):\n205:             break\n206:         cells = _split_table_row(line)\n207:         if not cells:\n208:             if in_table:\n209:                 break\n210:             continue\n211:         if len(cells) != 2:\n212:             continue\n213:         normalized = [_clean_cell(cell).lower() for cell in cells]\n214:         if normalized == [\"field\", \"value\"] or _is_separator_row(cells):\n215:             in_table = True\n216:             continue\n217:         in_table = True\n218:         if _is_placeholder(cells[0]) and _is_placeholder(cells[1]):\n219:             continue\n220:         rows.append({\n221:             \"field\": _clean_cell(cells[0]),\n222:             \"value\": _clean_cell(cells[1]),\n223:         })\n224:     return rows\n225: \n226: \n227: def _observation_triad_value(line: str, field: str) -> Optional[str]:\n228:     pattern = re.compile(\n229:         r\"^\\s*(?:[-*+]\\s*)?(?:\\*\\*)?\"\n230:         + re.escape(field)\n231:         + r\"(?:\\*\\*)?\\s*:\\s*(?:\\*\\*)?\\s*(.*?)\\s*(?:\\*\\*)?\\s*$\",\n232:         re.I,\n233:     )\n234:     match = pattern.match(line)\n235:     if not match:\n236:         return None\n237:     return _clean_cell(match.group(1))\n238: \n239: \n240: def _is_observation_triad_placeholder(value: str) -> bool:\n241:     cleaned = _clean_cell(value)\n242:     if _is_placeholder(cleaned):\n243:         return True\n244:     return bool(re.fullmatch(r\"(?:<[^>]*>|\\.{3}|tbd|todo|n/?a)\", cleaned, re.I))\n245: \n246: \n247: def _find_observation_triad_blocks(text: str) -> list[dict]:\n248:     lines = text.splitlines()\n249:     blocks = []\n250:     current = None\n251: \n252:     for line in lines:\n253:         if FINDING_HEADING.match(line):\n254:             if current is not None:\n255:                 blocks.append(current)\n256:             current = {\"heading\": line.strip(\"# \").strip(), \"lines\": []}\n257:             continue\n258:         if current is not None and MARKDOWN_HEADING.match(line):\n259:             blocks.append(current)\n260:             current = None\n261:             continue\n262:         if current is not None:\n263:             current[\"lines\"].append(line)\n264: \n265:     if current is not None:\n266:         blocks.append(current)\n267:     return blocks\n268: \n269: \n270: def _repo_root(card_path: Optional[str]) -> Path:\n271:     start = Path(card_path).resolve().parent if card_path else Path.cwd().resolve()\n272:     for candidate in (start, *start.parents):\n273:         if (candidate / \".opencode\").exists() or (candidate / \".git\").exists():\n274:             return candidate\n275:     return Path.cwd().resolve()\n276: \n277: \n278: def _validate_source_proof(text: str, card_path: Optional[str]) -> dict:\n279:     rows = _find_source_proof_rows(text)\n280:     result = {\n281:         \"rows\": len(rows),\n282:         \"items\": [],\n283:         \"missing\": [],\n284:         \"ok\": True,\n285:     }\n286:     if not rows:\n287:         result[\"missing\"].append(\"source-proof rows missing\")\n288:         result[\"ok\"] = False\n289:         return result\n290: \n291:     root = _repo_root(card_path)\n292:     for row in rows:\n293:         item = {\"path\": row[\"path\"], \"ok\": False, \"errors\": []}\n294:         if _is_placeholder(row[\"path\"]):\n295:             item[\"errors\"].append(\"source path missing\")\n296:         if _is_placeholder(row[\"anchor\"]):\n297:             item[\"errors\"].append(\"anchor missing\")\n298:         if _is_placeholder(row[\"echo\"]):\n299:             item[\"errors\"].append(\"anchor echo absent/forged\")\n300: \n301:         digest_match = SHA256.match(row[\"sha256\"])\n302:         if not digest_match:\n303:             item[\"errors\"].append(\"digest malformed\")\n304: \n305:         raw = None\n306:         if not item[\"errors\"] or digest_match:\n307:             try:\n308:                 with open(root / row[\"path\"], \"rb\") as fh:\n309:                     raw = fh.read()\n310:             except OSError:\n311:                 item[\"errors\"].append(\"source file unreadable\")\n312: \n313:         if raw is not None and digest_match:\n314:             actual = hashlib.sha256(raw).hexdigest()\n315:             if actual != digest_match.group(1).lower():\n316:                 item[\"errors\"].append(\"digest mismatch\")\n317: \n318:         if raw is not None and not _is_placeholder(row[\"echo\"]):\n319:             try:\n320:                 source_text = raw.decode(\"utf-8\")\n321:             except UnicodeDecodeError:\n322:                 source_text = raw.decode(\"utf-8\", errors=\"replace\")\n323:             if row[\"echo\"] not in source_text:\n324:                 item[\"errors\"].append(\"anchor echo absent/forged\")\n325: \n326:         item[\"ok\"] = not item[\"errors\"]\n327:         result[\"items\"].append(item)\n328:         if item[\"errors\"]:\n329:             result[\"missing\"].extend(f\"{row['path']}: {error}\" for error in item[\"errors\"])\n330: \n331:     result[\"ok\"] = not result[\"missing\"]\n332:     return result\n333: \n334: \n335: def _validate_application_witness(text: str) -> dict:\n336:     rows = _find_application_witness_rows(text)\n337:     result = {\n338:         \"rows\": len(rows),\n339:         \"items\": [],\n340:         \"missing\": [],\n341:         \"ok\": True,\n342:     }\n343:     if not rows:\n344:         result[\"missing\"].append(\"application-witness rows missing\")\n345:         result[\"ok\"] = False\n346:         return result\n347: \n348:     has_determinative = False\n349:     has_well_formed_determinative = False\n350:     for row in rows:\n351:         item = {\n352:             \"output_choice\": row[\"output_choice\"],\n353:             \"loaded_rule_source\": row[\"loaded_rule_source\"],\n354:             \"classification\": row[\"classification\"],\n355:             \"ok\": True,\n356:             \"errors\": [],\n357:         }\n358:         if row[\"classification\"] == \"loaded-determinative\":\n359:             has_determinative = True\n360:             if _is_placeholder(row[\"output_choice\"]):\n361:                 item[\"errors\"].append(\"output choice missing\")\n362:             if _is_placeholder(row[\"loaded_rule_source\"]):\n363:                 item[\"errors\"].append(\"loaded rule source missing\")\n364:             if not item[\"errors\"]:\n365:                 has_well_formed_determinative = True\n366:         item[\"ok\"] = not item[\"errors\"]\n367:         result[\"items\"].append(item)\n368:         if item[\"errors\"] and \"witness not well-formed\" not in result[\"missing\"]:\n369:             result[\"missing\"].append(\"witness not well-formed\")\n370: \n371:     if not has_determinative:\n372:         result[\"missing\"].append(\"no loaded-determinative witness\")\n373: \n374:     result[\"ok\"] = not result[\"missing\"] and has_well_formed_determinative\n375:     return result\n376: \n377: \n378: def _validate_decision_rationale(text: str) -> dict:\n379:     rows = _find_decision_rationale_rows(text)\n380:     result = {\n381:         \"rows\": len(rows),\n382:         \"items\": [],\n383:         \"missing\": [],\n384:         \"ok\": True,\n385:     }\n386:     if not rows:\n387:         result[\"missing\"].append(\"decision-rationale rows missing\")\n388:         result[\"ok\"] = False\n389:         return result\n390: \n391:     values_by_field = {}\n392:     for row in rows:\n393:         canonical = _decision_rationale_canonical_field(row[\"field\"])\n394:         item = {\n395:             \"field\": row[\"field\"],\n396:             \"canonical_field\": canonical,\n397:             \"ok\": True,\n398:             \"errors\": [],\n399:         }\n400:         if canonical is not None:\n401:             if _is_placeholder(row[\"value\"]):\n402:                 item[\"errors\"].append(\"value missing\")\n403:             current = values_by_field.get(canonical)\n404:             if current is None or _is_placeholder(current):\n405:                 values_by_field[canonical] = row[\"value\"]\n406:         item[\"ok\"] = not item[\"errors\"]\n407:         result[\"items\"].append(item)\n408: \n409:     for field in DECISION_RATIONALE_FIELDS:\n410:         value = values_by_field.get(field)\n411:         if value is None:\n412:             result[\"missing\"].append(f\"decision-rationale field missing: {field}\")\n413:         elif _is_placeholder(value):\n414:             result[\"missing\"].append(f\"decision-rationale field placeholder: {field}\")\n415: \n416:     result[\"ok\"] = not result[\"missing\"]\n417:     return result\n418: \n419: \n420: def _validate_observation_triad(text: str) -> dict:\n421:     rows = _find_observation_triad_blocks(text)\n422:     result = {\n423:         \"rows\": len(rows),\n424:         \"items\": [],\n425:         \"missing\": [],\n426:         \"ok\": True,\n427:     }\n428:     if not rows:\n429:         result[\"missing\"].append(\"observation-triad findings missing\")\n430:         result[\"ok\"] = False\n431:         return result\n432: \n433:     for row in rows:\n434:         values = {}\n435:         for line in row[\"lines\"]:\n436:             for field in OBSERVATION_TRIAD_FIELDS:\n437:                 value = _observation_triad_value(line, field)\n438:                 if value is not None and field not in values:\n439:                     values[field] = value\n440: \n441:         item = {\n442:             \"heading\": row[\"heading\"],\n443:             \"ok\": True,\n444:             \"errors\": [],\n445:         }\n446:         for field in OBSERVATION_TRIAD_FIELDS:\n447:             value = values.get(field)\n448:             if value is None:\n449:                 item[\"errors\"].append(f\"{field} missing\")\n450:             elif _is_observation_triad_placeholder(value):\n451:                 item[\"errors\"].append(f\"{field} placeholder\")\n452: \n453:         item[\"ok\"] = not item[\"errors\"]\n454:         result[\"items\"].append(item)\n455:         result[\"missing\"].extend(f\"{row['heading']}: {error}\" for error in item[\"errors\"])\n456: \n457:     result[\"ok\"] = not result[\"missing\"]\n458:     return result\n459: \n460: \n461: def check(\n462:     text: str,\n463:     require_cards: bool,\n464:     require_source_proof: bool = False,\n465:     source_path: Optional[str] = None,\n466:     require_application_witness: bool = False,\n467:     require_decision_rationale: bool = False,\n468:     require_observation_triad: bool = False,\n469: ) -> dict:\n470:     fields = {label: _present(text, pats) for label, pats in PROOF_FIELDS.items()}\n471:     cards = {label: _present(text, pats) for label, pats in CARD_SECTIONS.items()} if require_cards else {}\n472:     not_ready = bool(NOT_READY.search(text))\n473:     ready = bool(READY.search(text)) and not not_ready\n474:     missing = [k for k, v in fields.items() if not v] + [k for k, v in cards.items() if not v]\n475:     source_proof = _validate_source_proof(text, source_path) if require_source_proof else None\n476:     if source_proof:\n477:         missing.extend(source_proof[\"missing\"])\n478:     application_witness = _validate_application_witness(text) if require_application_witness else None\n479:     if application_witness:\n480:         missing.extend(application_witness[\"missing\"])\n481:     decision_rationale = _validate_decision_rationale(text) if require_decision_rationale else None\n482:     if decision_rationale:\n483:         missing.extend(decision_rationale[\"missing\"])\n484:     observation_triad = _validate_observation_triad(text) if require_observation_triad else None\n485:     if observation_triad:\n486:         missing.extend(observation_triad[\"missing\"])\n487:     ok = not missing and ready\n488:     result = {\n489:         \"fields\": fields,\n490:         \"cards\": cards,\n491:         \"ready\": ready,\n492:         \"not_ready_flag\": not_ready,\n493:         \"missing\": missing,\n494:         \"ok\": ok,\n495:     }\n496:     if source_proof:\n497:         result[\"source_proof\"] = source_proof\n498:     if application_witness:\n499:         result[\"application_witness\"] = application_witness\n500:     if decision_rationale:\n501:         result[\"decision_rationale\"] = decision_rationale\n502:     if observation_triad:\n503:         result[\"observation_triad\"] = observation_triad\n504:     return result\n505: \n506: \n507: def main(argv) -> int:\n508:     as_json = \"--json\" in argv\n509:     require_cards = \"--require-cards\" in argv\n510:     require_source_proof = \"--require-source-proof\" in argv\n511:     require_application_witness = \"--require-application-witness\" in argv\n512:     require_decision_rationale = \"--require-decision-rationale\" in argv\n513:     require_observation_triad = \"--require-observation-triad\" in argv\n514:     paths = [a for a in argv if not a.startswith(\"--\")]\n515:     if len(paths) != 1:\n516:         sys.stderr.write(\"usage: proof_check.py [--json] [--require-cards] [--require-source-proof] [--require-application-witness] [--require-decision-rationale] [--require-observation-triad] <proof-card-or-notes.md>\\n\")\n517:         return 2\n518:     try:\n519:         with open(paths[0], \"r\", encoding=\"utf-8\") as fh:\n520:             text = fh.read()\n521:     except OSError as e:\n522:         sys.stderr.write(f\"cannot read {paths[0]}: {e}\\n\")\n523:         return 2\n524: \n525:     r = check(\n526:         text,\n527:         require_cards,\n528:         require_source_proof,\n529:         paths[0],\n530:         require_application_witness,\n531:         require_decision_rationale,\n532:         require_observation_triad,\n533:     )\n534:     if as_json:\n535:         print(json.dumps({\"file\": paths[0], **r}, indent=2))\n536:     else:\n537:         print(f\"Proof-of-application gate — {paths[0]}\")\n538:         for label, ok in {**r[\"fields\"], **r[\"cards\"]}.items():\n539:             print(f\"  [{'x' if ok else ' '}] {label}\")\n540:         if require_source_proof:\n541:             source_ok = r[\"source_proof\"][\"ok\"]\n542:             print(f\"  [{'x' if source_ok else ' '}] SOURCE PROOF\")\n543:         if require_application_witness:\n544:             witness_ok = r[\"application_witness\"][\"ok\"]\n545:             print(f\"  [{'x' if witness_ok else ' '}] APPLICATION WITNESS\")\n546:         if require_decision_rationale:\n547:             rationale_ok = r[\"decision_rationale\"][\"ok\"]\n548:             print(f\"  [{'x' if rationale_ok else ' '}] DECISION RATIONALE\")\n549:         if require_observation_triad:\n550:             triad_ok = r[\"observation_triad\"][\"ok\"]\n551:             print(f\"  [{'x' if triad_ok else ' '}] OBSERVATION TRIAD\")\n552:         print(f\"  verdict READY: {'yes' if r['ready'] else 'no'}\"\n553:               + (\" (NOT READY found)\" if r[\"not_ready_flag\"] else \"\"))\n554:         if r[\"ok\"]:\n555:             print(\"PASS — contract applied; all proof fields present and READY.\")\n556:         else:\n557:             gaps = \", \".join(r[\"missing\"]) or \"verdict not READY\"\n558:             print(f\"FAIL — {gaps}. Do not claim ready/accessible/release until complete.\")\n559:     return 0 if r[\"ok\"] else 1\n560: \n561: \n562: if __name__ == \"__main__\":\n563:     raise SystemExit(main(sys.argv[1:]))\n\n(End of file - total 563 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env python3\n\"\"\"Deterministic proof-of-application gate for sk-design context-loading.\n\nThe benchmark showed the contract changes behaviour when handed to a delegate,\nbut nothing makes the orchestrator's own path *prove* it. This is that gate: a\nbuild/delivery/CI step runs it on the filled proof-of-application card (or the\nnotes file that embeds it) and it exits non-zero unless every required proof\nfield is present and the verdict reads READY. A calculator for \"is the contract\nactually applied\", not a vibe check.\n\nUsage:\n  proof_check.py notes.md\n  proof_check.py --json notes.md\n  proof_check.py --require-cards notes.md   # also require both card sections\n  proof_check.py --require-source-proof notes.md\n  proof_check.py --require-application-witness notes.md\n  proof_check.py --require-decision-rationale notes.md\n  proof_check.py --require-observation-triad notes.md\n\nRequired proof fields (matched case-insensitively, tolerant of formatting):","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-design/shared/scripts/proof_check.py","text":"#!/usr/bin/env python3\n\"\"\"Deterministic proof-of-application gate for sk-design context-loading.\n\nThe benchmark showed the contract changes behaviour when handed to a delegate,\nbut nothing makes the orchestrator's own path *prove* it. This is that gate: a\nbuild/delivery/CI step runs it on the filled proof-of-application card (or the\nnotes file that embeds it) and it exits non-zero unless every required proof\nfield is present and the verdict reads READY. A calculator for \"is the contract\nactually applied\", not a vibe check.\n\nUsage:\n  proof_check.py notes.md\n  proof_check.py --json notes.md\n  proof_check.py --require-cards notes.md   # also require both card sections\n  proof_check.py --require-source-proof notes.md\n  proof_check.py --require-application-witness notes.md\n  proof_check.py --require-decision-rationale notes.md\n  proof_check.py --require-observation-triad notes.md\n\nRequired proof fields (matched case-insensitively, tolerant of formatting):\n  REGISTER / DIALS, CONTRAST PAIRS, INTERFACE PREFLIGHT, AUDIT EVIDENCE,\n  plus a READY verdict.\nExit: 0 = complete + READY; 1 = missing field or NOT READY; 2 = usage error.\n\"\"\"\nimport hashlib\nimport json\nfrom pathlib import Path\nimport re\nimport sys\nfrom typing import Optional\n\n# label -> regexes that satisfy it (any match counts)\nPROOF_FIELDS = {\n    \"REGISTER / DIALS\": [r\"\\bregister\\b.*\\bdials?\\b\", r\"\\bregister\\s*/\\s*dials\\b\", r\"\\bVARIANCE\\b.*\\bDENSITY\\b\"],\n    \"CONTRAST PAIRS\": [r\"\\bcontrast[\\s-]*pairs?\\b\", r\"\\bcontrast[\\s-]*pair\\s+inventory\\b\"],\n    \"INTERFACE PREFLIGHT\": [r\"\\binterface\\s+pre-?flight\\b\", r\"\\bpre-?flight\\b.*\\b(pass|fail|ship)\\b\"],\n    \"AUDIT EVIDENCE\": [r\"\\baudit\\s+evidence\\b\", r\"\\bevidence\\s+labels?\\b\", r\"\\bconfirmed\\b.*\\binferred\\b.*\\bnot[\\s-]*assessed\\b\"],\n}\nCARD_SECTIONS = {\n    \"Context Loaded card\": [r\"context[\\s-]*loaded\\s+card\"],\n    \"Proof Of Application card\": [r\"proof[\\s-]*of[\\s-]*application\\s+card\"],\n}\n# Verdict detection is checkbox-aware: a card lists both \"[x] READY\" and\n# \"[ ] NOT READY\" as options, so match only the CHECKED/asserted form, never the\n# bare unchecked label.\nREADY = re.compile(r\"(?:\\[x\\]|\\*\\*|verdict[:\\s*]+|result[:\\s*]+)\\s*READY\\b\", re.I)\nNOT_READY = re.compile(r\"(?:\\[x\\]|\\*\\*)\\s*NOT[\\s-]*READY\\b\", re.I)\nSOURCE_PROOF_HEADING = re.compile(r\"^#{1,6}\\s+.*SOURCE\\s+PROOF.*$\", re.I)\nAPPLICATION_WITNESS_HEADING = re.compile(r\"^#{1,6}\\s+.*APPLICATION\\s+WITNESS.*$\", re.I)\nDECISION_RATIONALE_HEADING = re.compile(r\"^#{1,6}\\s+.*DECISION\\s+RATIONALE.*$\", re.I)\nMARKDOWN_HEADING = re.compile(r\"^#{1,6}\\s+\")\nSHA256 = re.compile(r\"^(?:sha256:)?([0-9a-f]{64})$\", re.I)\nAPPLICATION_CLASSIFICATIONS = (\"not-loaded\", \"loaded-inert\", \"loaded-determinative\")\nDECISION_RATIONALE_FIELDS = (\n    \"decision\",\n    \"optionsConsidered[]\",\n    \"evidenceSources[]\",\n    \"tradeoffs[]\",\n    \"validationPlan\",\n    \"sourceProofs[]\",\n)\nOBSERVATION_TRIAD_FIELDS = (\"Observation\", \"Problem\", \"Fix\")\nFINDING_HEADING = re.compile(r\"^#{1,6}\\s+P[0-3]\\s*[-:]\\s+\\S.*$\", re.I)\n\n\ndef _present(text: str, patterns) -> bool:\n    return any(re.search(p, text, re.I | re.S) for p in patterns)\n\n\ndef _clean_cell(value: str) -> str:\n    value = value.strip()\n    if len(value) >= 2 and value[0] == \"`\" and value[-1] == \"`\":\n        value = value[1:-1].strip()\n    return value\n\n\ndef _is_placeholder(value: str) -> bool:\n    cleaned = _clean_cell(value)\n    return not cleaned or bool(re.fullmatch(r\"(?:sha256:)?_+\", cleaned))\n\n\ndef _split_table_row(line: str) -> list[str]:\n    line = line.strip()\n    if not line.startswith(\"|\") or not line.endswith(\"|\"):\n        return []\n    return [cell.strip() for cell in line.strip(\"|\").split(\"|\")]\n\n\ndef _is_separator_row(cells: list[str]) -> bool:\n    return bool(cells) and all(re.fullmatch(r\":?-{3,}:?\", cell.strip()) for cell in cells)\n\n\ndef _find_source_proof_rows(text: str) -> list[dict]:\n    lines = text.splitlines()\n    start = None\n    for i, line in enumerate(lines):\n        if SOURCE_PROOF_HEADING.search(line):\n            start = i + 1\n            break\n    if start is None:\n        return []\n\n    rows = []\n    in_table = False\n    for line in lines[start:]:\n        if MARKDOWN_HEADING.match(line):\n            break\n        cells = _split_table_row(line)\n        if not cells:\n            if in_table:\n                break\n            continue\n        if len(cells) != 4:\n            continue\n        normalized = [_clean_cell(cell).lower() for cell in cells]\n        if normalized == [\"path\", \"sha256\", \"anchor\", \"echo\"] or _is_separator_row(cells):\n            in_table = True\n            continue\n        in_table = True\n        if all(_is_placeholder(cell) for cell in cells):\n            continue\n        rows.append({\n            \"path\": _clean_cell(cells[0]),\n            \"sha256\": _clean_cell(cells[1]),\n            \"anchor\": _clean_cell(cells[2]),\n            \"echo\": _clean_cell(cells[3]),\n        })\n    return rows\n\n\ndef _application_classification(value: str) -> Optional[str]:\n    for classification in APPLICATION_CLASSIFICATIONS:\n        pattern = r\"\\[[xX]\\]\\s*\" + re.escape(classification) + r\"\\b\"\n        if re.search(pattern, value, re.I):\n            return classification\n    return None\n\n\ndef _find_application_witness_rows(text: str) -> list[dict]:\n    lines = text.splitlines()\n    start = None\n    for i, line in enumerate(lines):\n        if APPLICATION_WITNESS_HEADING.search(line):\n            start = i + 1\n            break\n    if start is None:\n        return []\n\n    rows = []\n    in_table = False\n    for line in lines[start:]:\n        if MARKDOWN_HEADING.match(line):\n            break\n        cells = _split_table_row(line)\n        if not cells:\n            if in_table:\n                break\n            continue\n        if len(cells) != 4:\n            continue\n        normalized = [_clean_cell(cell).lower() for cell in cells]\n        if normalized == [\"output choice\", \"loaded rule source\", \"classification\", \"counterfactual\"] or _is_separator_row(cells):\n            in_table = True\n            continue\n        in_table = True\n        classification = _application_classification(cells[2])\n        if (\n            _is_placeholder(cells[0])\n            and _is_placeholder(cells[1])\n            and classification is None\n            and _is_placeholder(cells[3])\n        ):\n            continue\n        rows.append({\n            \"output_choice\": _clean_cell(cells[0]),\n            \"loaded_rule_source\": _clean_cell(cells[1]),\n            \"classification\": classification,\n            \"counterfactual\": _clean_cell(cells[3]),\n        })\n    return rows\n\n\ndef _decision_rationale_canonical_field(value: str) -> Optional[str]:\n    normalized = re.sub(r\"\\s+\", \"\", _clean_cell(value).rstrip(\":\")).lower()\n    for field in DECISION_RATIONALE_FIELDS:\n        if normalized == field.lower():\n            return field\n    return None\n\n\ndef _find_decision_rationale_rows(text: str) -> list[dict]:\n    lines = text.splitlines()\n    start = None\n    for i, line in enumerate(lines):\n        if DECISION_RATIONALE_HEADING.search(line):\n            start = i + 1\n            break\n    if start is None:\n        return []\n\n    rows = []\n    in_table = False\n    for line in lines[start:]:\n        if MARKDOWN_HEADING.match(line):\n            break\n        cells = _split_table_row(line)\n        if not cells:\n            if in_table:\n                break\n            continue\n        if len(cells) != 2:\n            continue\n        normalized = [_clean_cell(cell).lower() for cell in cells]\n        if normalized == [\"field\", \"value\"] or _is_separator_row(cells):\n            in_table = True\n            continue\n        in_table = True\n        if _is_placeholder(cells[0]) and _is_placeholder(cells[1]):\n            continue\n        rows.append({\n            \"field\": _clean_cell(cells[0]),\n            \"value\": _clean_cell(cells[1]),\n        })\n    return rows\n\n\ndef _observation_triad_value(line: str, field: str) -> Optional[str]:\n    pattern = re.compile(\n        r\"^\\s*(?:[-*+]\\s*)?(?:\\*\\*)?\"\n        + re.escape(field)\n        + r\"(?:\\*\\*)?\\s*:\\s*(?:\\*\\*)?\\s*(.*?)\\s*(?:\\*\\*)?\\s*$\",\n        re.I,\n    )\n    match = pattern.match(line)\n    if not match:\n        return None\n    return _clean_cell(match.group(1))\n\n\ndef _is_observation_triad_placeholder(value: str) -> bool:\n    cleaned = _clean_cell(value)\n    if _is_placeholder(cleaned):\n        return True\n    return bool(re.fullmatch(r\"(?:<[^>]*>|\\.{3}|tbd|todo|n/?a)\", cleaned, re.I))\n\n\ndef _find_observation_triad_blocks(text: str) -> list[dict]:\n    lines = text.splitlines()\n    blocks = []\n    current = None\n\n    for line in lines:\n        if FINDING_HEADING.match(line):\n            if current is not None:\n                blocks.append(current)\n            current = {\"heading\": line.strip(\"# \").strip(), \"lines\": []}\n            continue\n        if current is not None and MARKDOWN_HEADING.match(line):\n            blocks.append(current)\n            current = None\n            continue\n        if current is not None:\n            current[\"lines\"].append(line)\n\n    if current is not None:\n        blocks.append(current)\n    return blocks\n\n\ndef _repo_root(card_path: Optional[str]) -> Path:\n    start = Path(card_path).resolve().parent if card_path else Path.cwd().resolve()\n    for candidate in (start, *start.parents):\n        if (candidate / \".opencode\").exists() or (candidate / \".git\").exists():\n            return candidate\n    return Path.cwd().resolve()\n\n\ndef _validate_source_proof(text: str, card_path: Optional[str]) -> dict:\n    rows = _find_source_proof_rows(text)\n    result = {\n        \"rows\": len(rows),\n        \"items\": [],\n        \"missing\": [],\n        \"ok\": True,\n    }\n    if not rows:\n        result[\"missing\"].append(\"source-proof rows missing\")\n        result[\"ok\"] = False\n        return result\n\n    root = _repo_root(card_path)\n    for row in rows:\n        item = {\"path\": row[\"path\"], \"ok\": False, \"errors\": []}\n        if _is_placeholder(row[\"path\"]):\n            item[\"errors\"].append(\"source path missing\")\n        if _is_placeholder(row[\"anchor\"]):\n            item[\"errors\"].append(\"anchor missing\")\n        if _is_placeholder(row[\"echo\"]):\n            item[\"errors\"].append(\"anchor echo absent/forged\")\n\n        digest_match = SHA256.match(row[\"sha256\"])\n        if not digest_match:\n            item[\"errors\"].append(\"digest malformed\")\n\n        raw = None\n        if not item[\"errors\"] or digest_match:\n            try:\n                with open(root / row[\"path\"], \"rb\") as fh:\n                    raw = fh.read()\n            except OSError:\n                item[\"errors\"].append(\"source file unreadable\")\n\n        if raw is not None and digest_match:\n            actual = hashlib.sha256(raw).hexdigest()\n            if actual != digest_match.group(1).lower():\n                item[\"errors\"].append(\"digest mismatch\")\n\n        if raw is not None and not _is_placeholder(row[\"echo\"]):\n            try:\n                source_text = raw.decode(\"utf-8\")\n            except UnicodeDecodeError:\n                source_text = raw.decode(\"utf-8\", errors=\"replace\")\n            if row[\"echo\"] not in source_text:\n                item[\"errors\"].append(\"anchor echo absent/forged\")\n\n        item[\"ok\"] = not item[\"errors\"]\n        result[\"items\"].append(item)\n        if item[\"errors\"]:\n            result[\"missing\"].extend(f\"{row['path']}: {error}\" for error in item[\"errors\"])\n\n    result[\"ok\"] = not result[\"missing\"]\n    return result\n\n\ndef _validate_application_witness(text: str) -> dict:\n    rows = _find_application_witness_rows(text)\n    result = {\n        \"rows\": len(rows),\n        \"items\": [],\n        \"missing\": [],\n        \"ok\": True,\n    }\n    if not rows:\n        result[\"missing\"].append(\"application-witness rows missing\")\n        result[\"ok\"] = False\n        return result\n\n    has_determinative = False\n    has_well_formed_determinative = False\n    for row in rows:\n        item = {\n            \"output_choice\": row[\"output_choice\"],\n            \"loaded_rule_source\": row[\"loaded_rule_source\"],\n            \"classification\": row[\"classification\"],\n            \"ok\": True,\n            \"errors\": [],\n        }\n        if row[\"classification\"] == \"loaded-determinative\":\n            has_determinative = True\n            if _is_placeholder(row[\"output_choice\"]):\n                item[\"errors\"].append(\"output choice missing\")\n            if _is_placeholder(row[\"loaded_rule_source\"]):\n                item[\"errors\"].append(\"loaded rule source missing\")\n            if not item[\"errors\"]:\n                has_well_formed_determinative = True\n        item[\"ok\"] = not item[\"errors\"]\n        result[\"items\"].append(item)\n        if item[\"errors\"] and \"witness not well-formed\" not in result[\"missing\"]:\n            result[\"missing\"].append(\"witness not well-formed\")\n\n    if not has_determinative:\n        result[\"missing\"].append(\"no loaded-determinative witness\")\n\n    result[\"ok\"] = not result[\"missing\"] and has_well_formed_determinative\n    return result\n\n\ndef _validate_decision_rationale(text: str) -> dict:\n    rows = _find_decision_rationale_rows(text)\n    result = {\n        \"rows\": len(rows),\n        \"items\": [],\n        \"missing\": [],\n        \"ok\": True,\n    }\n    if not rows:\n        result[\"missing\"].append(\"decision-rationale rows missing\")\n        result[\"ok\"] = False\n        return result\n\n    values_by_field = {}\n    for row in rows:\n        canonical = _decision_rationale_canonical_field(row[\"field\"])\n        item = {\n            \"field\": row[\"field\"],\n            \"canonical_field\": canonical,\n            \"ok\": True,\n            \"errors\": [],\n        }\n        if canonical is not None:\n            if _is_placeholder(row[\"value\"]):\n                item[\"errors\"].append(\"value missing\")\n            current = values_by_field.get(canonical)\n            if current is None or _is_placeholder(current):\n                values_by_field[canonical] = row[\"value\"]\n        item[\"ok\"] = not item[\"errors\"]\n        result[\"items\"].append(item)\n\n    for field in DECISION_RATIONALE_FIELDS:\n        value = values_by_field.get(field)\n        if value is None:\n            result[\"missing\"].append(f\"decision-rationale field missing: {field}\")\n        elif _is_placeholder(value):\n            result[\"missing\"].append(f\"decision-rationale field placeholder: {field}\")\n\n    result[\"ok\"] = not result[\"missing\"]\n    return result\n\n\ndef _validate_observation_triad(text: str) -> dict:\n    rows = _find_observation_triad_blocks(text)\n    result = {\n        \"rows\": len(rows),\n        \"items\": [],\n        \"missing\": [],\n        \"ok\": True,\n    }\n    if not rows:\n        result[\"missing\"].append(\"observation-triad findings missing\")\n        result[\"ok\"] = False\n        return result\n\n    for row in rows:\n        values = {}\n        for line in row[\"lines\"]:\n            for field in OBSERVATION_TRIAD_FIELDS:\n                value = _observation_triad_value(line, field)\n                if value is not None and field not in values:\n                    values[field] = value\n\n        item = {\n            \"heading\": row[\"heading\"],\n            \"ok\": True,\n            \"errors\": [],\n        }\n        for field in OBSERVATION_TRIAD_FIELDS:\n            value = values.get(field)\n            if value is None:\n                item[\"errors\"].append(f\"{field} missing\")\n            elif _is_observation_triad_placeholder(value):\n                item[\"errors\"].append(f\"{field} placeholder\")\n\n        item[\"ok\"] = not item[\"errors\"]\n        result[\"items\"].append(item)\n        result[\"missing\"].extend(f\"{row['heading']}: {error}\" for error in item[\"errors\"])\n\n    result[\"ok\"] = not result[\"missing\"]\n    return result\n\n\ndef check(\n    text: str,\n    require_cards: bool,\n    require_source_proof: bool = False,\n    source_path: Optional[str] = None,\n    require_application_witness: bool = False,\n    require_decision_rationale: bool = False,\n    require_observation_triad: bool = False,\n) -> dict:\n    fields = {label: _present(text, pats) for label, pats in PROOF_FIELDS.items()}\n    cards = {label: _present(text, pats) for label, pats in CARD_SECTIONS.items()} if require_cards else {}\n    not_ready = bool(NOT_READY.search(text))\n    ready = bool(READY.search(text)) and not not_ready\n    missing = [k for k, v in fields.items() if not v] + [k for k, v in cards.items() if not v]\n    source_proof = _validate_source_proof(text, source_path) if require_source_proof else None\n    if source_proof:\n        missing.extend(source_proof[\"missing\"])\n    application_witness = _validate_application_witness(text) if require_application_witness else None\n    if application_witness:\n        missing.extend(application_witness[\"missing\"])\n    decision_rationale = _validate_decision_rationale(text) if require_decision_rationale else None\n    if decision_rationale:\n        missing.extend(decision_rationale[\"missing\"])\n    observation_triad = _validate_observation_triad(text) if require_observation_triad else None\n    if observation_triad:\n        missing.extend(observation_triad[\"missing\"])\n    ok = not missing and ready\n    result = {\n        \"fields\": fields,\n        \"cards\": cards,\n        \"ready\": ready,\n        \"not_ready_flag\": not_ready,\n        \"missing\": missing,\n        \"ok\": ok,\n    }\n    if source_proof:\n        result[\"source_proof\"] = source_proof\n    if application_witness:\n        result[\"application_witness\"] = application_witness\n    if decision_rationale:\n        result[\"decision_rationale\"] = decision_rationale\n    if observation_triad:\n        result[\"observation_triad\"] = observation_triad\n    return result\n\n\ndef main(argv) -> int:\n    as_json = \"--json\" in argv\n    require_cards = \"--require-cards\" in argv\n    require_source_proof = \"--require-source-proof\" in argv\n    require_application_witness = \"--require-application-witness\" in argv\n    require_decision_rationale = \"--require-decision-rationale\" in argv\n    require_observation_triad = \"--require-observation-triad\" in argv\n    paths = [a for a in argv if not a.startswith(\"--\")]\n    if len(paths) != 1:\n        sys.stderr.write(\"usage: proof_check.py [--json] [--require-cards] [--require-source-proof] [--require-application-witness] [--require-decision-rationale] [--require-observation-triad] <proof-card-or-notes.md>\\n\")\n        return 2\n    try:\n        with open(paths[0], \"r\", encoding=\"utf-8\") as fh:\n            text = fh.read()\n    except OSError as e:\n        sys.stderr.write(f\"cannot read {paths[0]}: {e}\\n\")\n        return 2\n\n    r = check(\n        text,\n        require_cards,\n        require_source_proof,\n        paths[0],\n        require_application_witness,\n        require_decision_rationale,\n        require_observation_triad,\n    )\n    if as_json:\n        print(json.dumps({\"file\": paths[0], **r}, indent=2))\n    else:\n        print(f\"Proof-of-application gate — {paths[0]}\")\n        for label, ok in {**r[\"fields\"], **r[\"cards\"]}.items():\n            print(f\"  [{'x' if ok else ' '}] {label}\")\n        if require_source_proof:\n            source_ok = r[\"source_proof\"][\"ok\"]\n            print(f\"  [{'x' if source_ok else ' '}] SOURCE PROOF\")\n        if require_application_witness:\n            witness_ok = r[\"application_witness\"][\"ok\"]\n            print(f\"  [{'x' if witness_ok else ' '}] APPLICATION WITNESS\")\n        if require_decision_rationale:\n            rationale_ok = r[\"decision_rationale\"][\"ok\"]\n            print(f\"  [{'x' if rationale_ok else ' '}] DECISION RATIONALE\")\n        if require_observation_triad:\n            triad_ok = r[\"observation_triad\"][\"ok\"]\n            print(f\"  [{'x' if triad_ok else ' '}] OBSERVATION TRIAD\")\n        print(f\"  verdict READY: {'yes' if r['ready'] else 'no'}\"\n              + (\" (NOT READY found)\" if r[\"not_ready_flag\"] else \"\"))\n        if r[\"ok\"]:\n            print(\"PASS — contract applied; all proof fields present and READY.\")\n        else:\n            gaps = \", \".join(r[\"missing\"]) or \"verdict not READY\"\n            print(f\"FAIL — {gaps}. Do not claim ready/accessible/release until complete.\")\n    return 0 if r[\"ok\"] else 1\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main(sys.argv[1:]))","lineStart":1,"lineEnd":563,"totalLines":563,"truncated":false}},"title":".opencode/skills/sk-design/shared/scripts/proof_check.py","time":{"start":1782750768400,"end":1782750768407}},"id":"prt_f1439ed0d001zcZqg56uR4zCqO","sessionID":"ses_0ebcbd824ffeY6bdd3Qgc3G0aZ","messageID":"msg_f1439b9dc001Fxg5Er3V5pUak9"}}
