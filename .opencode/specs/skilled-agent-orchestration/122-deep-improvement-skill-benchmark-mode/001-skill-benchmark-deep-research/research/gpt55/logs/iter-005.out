   183	        command: "node -e \"const fs=require('node:fs'); const stability=require('./.opencode/skills/deep-agent-improvement/scripts/agent-improvement/benchmark-stability.cjs'); const score=JSON.parse(fs.readFileSync('{score_output_path}','utf8')); const result=stability.measureStability([score],{minReplayCount:3,warningThreshold:0.95}); fs.mkdirSync('{spec_folder}/improvement/benchmark-outputs',{recursive:true}); fs.writeFileSync('{spec_folder}/improvement/benchmark-outputs/iteration-{iteration}-repeatability.json',JSON.stringify(result,null,2)+'\\n');\""
