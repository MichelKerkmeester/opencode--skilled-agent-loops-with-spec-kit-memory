      "$description": "Midnight Wine — Primary action buttons, announcement banner, footer — a warm near-black maroon that reads as ink rather than red, anchoring the palette without screaming"
    },
    "royal-violet": {
      "$value": "#714cb6",
      "$type": "color",
      "$description": "Royal Violet — Violet text accent for links, tags, and emphasized short phrases. Do not promote it to the primary CTA color"
