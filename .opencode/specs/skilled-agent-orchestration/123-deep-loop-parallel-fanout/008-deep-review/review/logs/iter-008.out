   669	  const result = prepareStatement(`
   670	    INSERT INTO coverage_snapshots (
   671	      spec_folder, loop_type, session_id, iteration, metrics, node_count, edge_count
   672	    )
   673	    VALUES (?, ?, ?, ?, ?, ?, ?)
   674	    ON CONFLICT(spec_folder, loop_type, session_id, iteration) DO UPDATE SET
