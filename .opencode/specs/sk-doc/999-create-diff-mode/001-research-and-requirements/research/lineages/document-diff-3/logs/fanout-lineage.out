\": [\n50:       \"key-questions\",\n51:       \"answered-questions\",\n52:       \"what-worked\",\n53:       \"what-failed\",\n54:       \"exhausted-approaches\",\n55:       \"ruled-out-directions\",\n56:       \"divergence-frontier\",\n57:       \"next-focus\"\n58:     ]\n59:   },\n60:   \"capabilityMatrixPath\": \".opencode/skills/system-deep-loop/deep-research/assets/runtime_capabilities.json\",\n61:   \"capabilityMatrixDocPath\": \".opencode/skills/system-deep-loop/deep-research/references/guides/capability_matrix.md\",\n62:   \"runtimeCapabilityResolver\": \".opencode/skills/system-deep-loop/deep-research/scripts/runtime-capabilities.cjs\",\n63:   \"reducerScriptPath\": \".opencode/skills/system-deep-loop/deep-research/scripts/reduce-state.cjs\",\n64:   \"pauseSentinelPath\": \"research/.deep-research-pause\",\n65:   \"archiveRoot\": \"research_archive\",\n66:   \"migrationWindowDays\": 28,\n67:   \"fileProtection\": {\n68:     \"deep-research-config.json\": \"immutable\",\n69:     \"deep-research-state.jsonl\": \"append-only\",\n70:     \"deep-research-strategy.md\": \"mutable\",\n71:     \"deep-research-dashboard.md\": \"auto-generated\",\n72:     \"findings-registry.json\": \"auto-generated\",\n73:     \"iteration-*.md\": \"write-once\",\n74:     \"research/research.md\": \"mutable\"\n75:   },\n76:   \"_optimizerManaged\": {\n77:     \"description\": \"Fields managed by the offline loop optimizer (042.004). See optimizer-manifest.json for the canonical tunable/locked field registry.\",\n78:     \"manifestPath\": \".opencode/skills/system-spec-kit/scripts/optimizer/optimizer-manifest.json\",\n79:     \"tunableFields\": [\"convergenceThreshold\", \"stuckThreshold\", \"maxIterations\"],\n80:     \"lockedFields\": [\"lineage\", \"reducer\", \"fileProtection\", \"sessionId\", \"status\", \"antiConvergence.convergenceMode\", \"antiConvergence.stopPolicy\"],\n81:     \"promotionMode\": \"advisory-only\"\n82:   }\n83: }\n\n(End of file - total 83 lines)\n</content>