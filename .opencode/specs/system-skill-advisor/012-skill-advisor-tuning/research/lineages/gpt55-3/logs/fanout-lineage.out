and palette\",\n      \"color palette\",\n      \"font pairing\",\n      \"ux quality checklist\",\n      \"give me N design variations\",\n      \"oklch palette\",\n      \"color token system\",\n      \"dark mode palette\",\n      \"typography scale\",\n      \"spacing system\",\n      \"responsive layout\",\n      \"animate this\",\n      \"micro-interactions\",\n      \"AnimatePresence\",\n      \"exit animation\",\n      \"reduced motion\",\n      \"morphing icons\",\n      \"motion performance\",\n      \"ui critique\",\n      \"accessibility audit\",\n      \"performance audit\",\n      \"anti-slop detection\",\n      \"production hardening\",\n      \"design quality score\",\n      \"P0 P1 design findings\",\n      \"extract design system\",\n      \"generate design.md\",\n      \"capture website css\",\n      \"design tokens from url\",\n      \"create design reference\",\n      \"design-to-markdown\",\n      \"extract design tokens\"\n    ],\n    \"key_topics\": [\n      \"sk-design\",\n      \"mode-registry\",\n      \"workflowMode\",\n      \"backendKind\",\n      \"reference-base\",\n      \"interface-mode\",\n      \"foundations-mode\",\n      \"motion-mode\",\n      \"audit-mode\",\n      \"md-generator-mode\",\n      \"shared-design-reference-base\",\n      \"anti-slop\",\n      \"design-token-vocabulary\",\n      \"cognitive-laws\"\n    ],\n    \"key_files\": [\n      \".opencode/skills/sk-design/SKILL.md\",\n      \".opencode/skills/sk-design/mode-registry.json\"\n    ],\n    \"entities\": [\n      {\n        \"name\": \"sk-design\",\n        \"kind\": \"skill\",\n        \"path\": \".opencode/skills/sk-design/SKILL.md\",\n        \"source\": \"derived\"\n      },\n      {\n        \"name\": \"mode-registry\",\n        \"kind\": \"config\",\n        \"path\": \".opencode/skills/sk-design/mode-registry.json\",\n        \"source\": \"derived\"\n      }\n    ],\n    \"causal_summary\": \"sk-design is the single public design skill that routes a request to one of five design modes (interface, foundations, motion, audit, md-generator) or one nested transport packet (design-mcp-open-design) by workflowMode through mode-registry.json. The five design modes share packetKind:\\\"workflow\\\"; design-mcp-open-design is the sole packetKind:\\\"transport\\\" entry, driving the external Open Design app's od CLI and stdio MCP server without performing design judgment itself. The four doc-guidance modes cite the shared reference base (anti-slop principles, cognitive laws, design-token vocabulary) for consistent vocabulary, md-generator runs its own Playwright CSS-extraction backend, and design-mcp-open-design runs an od-cli-transport backend (backendKind discriminates all three). The hub holds no per-mode design logic; every mode keeps its own judgment, examples, and verification in its packet, and all six route by hub membership so the advisor sees exactly one design identity.\",\n    \"source_docs\": [\n      \"SKILL.md\",\n      \"mode-registry.json\"\n    ],\n    \"created_at\": \"2026-06-25T00:00:00Z\",\n    \"last_updated_at\": \"2026-06-26T00:00:00Z\"\n  }\n}","lineStart":1,"lineEnd":165,"totalLines":165,"truncated":false}},"title":".opencode/skills/sk-design/graph-metadata.json","time":{"start":1783437204165,"end":1783437204170}},"metadata":{"openai":{"itemId":"fc_01433b4e1c6a40b2016a4d1793f1988191b21df1e76a65419d"}},"id":"prt_f3d241ac30016KUAOmy8CWVQFT","sessionID":"ses_0c2dd1dfcffeawJ3GCJmwMFkLa","messageID":"msg_f3d23ed9f0012KwRthplxOVxFx"}}
