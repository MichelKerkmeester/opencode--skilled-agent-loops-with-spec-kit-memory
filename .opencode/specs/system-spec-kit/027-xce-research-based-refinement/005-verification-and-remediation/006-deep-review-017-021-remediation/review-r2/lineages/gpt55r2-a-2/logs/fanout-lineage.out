backState})`\n      );\n    }\n\n    const extraData: Record<string, unknown> = {\n      stateStats: pipelineResult.annotations.stateStats,\n      featureFlags: {\n        ...pipelineResult.annotations.featureFlags,\n      },","lineStart":1238,"lineEnd":1285,"totalLines":1788,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781761495519,"end":1781761495523}},"metadata":{"openai":{"itemId":"fc_02e42b6c79a69d1a016a3385d741f08191b4cbf32eee2d41ca"}},"id":"prt_ed942d181001FJ2JqCC2JWXM96","sessionID":"ses_126bff007ffe0iB3rytmAD0l1k","messageID":"msg_ed942adb6001q9CA7jR3qrF5Ut"}}
