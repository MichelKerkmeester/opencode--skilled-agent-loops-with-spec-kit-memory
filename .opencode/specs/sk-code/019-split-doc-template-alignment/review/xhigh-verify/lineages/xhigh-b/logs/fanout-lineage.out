scripts/README.md:1-27\",\".opencode/skills/sk-doc/create-skill/assets/skill/skill_asset_template.md:125-175\",\".opencode/specs/sk-code/019-split-doc-template-alignment/spec.md:44-83\",\".opencode/specs/sk-code/019-split-doc-template-alignment/checklist.md:23-95\",\".opencode/specs/sk-code/019-split-doc-template-alignment/implementation-summary.md:60-84\"],\"findingsCount\":5,\"findingsSummary\":{\"P0\":0,\"P1\":4,\"P2\":1},\"findingsNew\":{\"P0\":0,\"P1\":0,\"P2\":1},\"findingDetails\":[{\"id\":\"F001\",\"severity\":\"P1\",\"finalSeverity\":\"P1\",\"category\":\"correctness\",\"file\":\".opencode/skills/sk-code/code-opencode/references/rust/style_guide/interop_errors_and_parity.md:13-19\",\"title\":\"Rust interop reference places OVERVIEW after substantive content\",\"claim\":\"The required OVERVIEW wrapper appears after substantive Rust guidance instead of before it.\",\"findingClass\":\"instance-only\",\"scopeProof\":\"Full 163-file ordering audit found exactly one instance.\",\"affectedSurfaceHints\":[\"code-opencode Rust reference\",\"create-skill reference template\",\"packet R3\"],\"content_hash\":\"7233e90b9f7706f97a94774b04eab38d7aa75091f083f683f8e8cfb20a292c81\",\"disposition\":\"active\",\"status\":\"active\"},{\"id\":\"F002\",\"severity\":\"P1\",\"finalSeverity\":\"P1\",\"category\":\"correctness\",\"file\":\".opencode/skills/sk-code/code-webflow/references/implementation/third_party_integrations/overview_hls_and_lenis.md:14-23\",\"title\":\"Third-party integration Purpose still duplicates its intro\",\"claim\":\"The Purpose paragraph repeats the H1 intro core sentence rather than adding distinct detail.\",\"findingClass\":\"class-of-bug\",\"scopeProof\":\"Semantic containment scan across all 163 targets found one remaining instance.\",\"affectedSurfaceHints\":[\"code-webflow third-party integration reference\",\"create-skill reference template\",\"post-review remediation\"],\"content_hash\":\"eae5f4e27b57b1f9e480dc2efee56c51b4d8290e9124cdb4ea4621ad730f