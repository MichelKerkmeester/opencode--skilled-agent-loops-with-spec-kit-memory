(incremental && !force) {\n\n  Line 667:     const categorized: CategorizedFiles = incrementalIndex.categorizeFilesForIndexing(files);\n\n\n(Results truncated: showing 100 of 816 matches (716 hidden). Consider using a more specific path or pattern.)","metadata":{"matches":816,"truncated":true},"title":"memory_index_scan|indexSpecDocs|scan.*spec|content_hash|mtime|incremental","time":{"start":1780929371736,"end":1780929371778}},"metadata":{"openai":{"itemId":"fc_0a834c98fcaf21a2016a26d35b64908191913d0a06fff13804"}},"id":"prt_ea7a99e4e001DxSqfpCwkr0fKU","sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","messageID":"msg_ea7a96f460013WQEcrdiSkgFKq"}}
{"type":"tool_use","timestamp":1780929371847,"sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","part":{"type":"tool","tool":"read","callID":"call_X8TTvOFbHjpYP37TrZCsORg8","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Embedding Reconcile Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: \n11: import type { MCPResponse } from './types.js';\n12: import type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n13: \n14: /** Handle the memory_embedding_reconcile MCP tool request. */\n15: async function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n16:   await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n17:   await checkDatabaseUpdated();\n18: \n19:   const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';\n20: \n21:   const database = vectorIndex.getDb();\n22:   if (!database) {\n23:     return createMCPErrorResponse({\n24:       tool: 'memory_embedding_reconcile',\n25:       error: 'Embedding reconcile aborted: database unavailable',\n26:       code: 'E_DB_UNAVAILABLE',\n27:       details: { mode },\n28:       recovery: {\n29:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n30:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n31:         severity: 'error',\n32:       },\n33:     });\n34:   }\n35: \n36:   // Best-effort: guarantee the active shard is attached as active_vec. The\n37:   // reconcile verifies it and fails closed if it is still unavailable.\n38:   // Attach (or re-point) the canonical active shard as active_vec. This is the\n39:   // path authority: it detaches any wrong/stale shard and attaches the shard\n40:   // resolved from the active embedder profile. For apply, a failed attach is\n41:   // FATAL — proceeding could mutate rows against a stale same-profile shard\n42:   // (the metadata-only guard can't tell two same-profile shard files apart).\n43:   try {\n44:     vectorIndex.attachActiveVectorShardForActiveProfile(database);\n45:   } catch (attachErr: unknown) {\n46:     if (mode === 'apply') {\n47:       return createMCPErrorResponse({\n48:         tool: 'memory_embedding_reconcile',\n49:         error: `Embedding reconcile aborted: could not attach the active vector shard (${toErrorMessage(attachErr)})`,\n50:         code: 'E_ACTIVE_SHARD_UNVERIFIED',\n51:         details: { mode },\n52:         recovery: {\n53:           hint: 'Ensure the active embedder shard exists and the daemon is healthy, then retry; restart the MCP server if it persists.',\n54:           actions: ['Run embedder_status()', 'Run memory_health()'],\n55:           severity: 'error',\n56:         },\n57:       });\n58:     }\n59:     // dry-run: non-fatal; verifyActiveShard reports activeShardVerified=false.\n60:   }\n61: \n62:   try {\n63:     const result = runMemoryEmbeddingReconcile(database, args ?? {});\n64:     const stale = result.buckets.vector_present_status_stale.count;\n65:     const missing = result.buckets.missing_active_vector_retry_eligible.count;\n66: \n67:     const coverageReset = result.applied?.successCoverageReset ?? 0;\n68:     const summary = result.mode === 'apply'\n69:       ? `Reconciled ${result.applied?.reconciledToSuccess ?? 0} vector-present row(s) to success; reset ${result.applied?.resetToRetry ?? 0} missing-vector row(s) to retry${coverageReset ? `; repaired ${coverageReset} success-coverage row(s) to retry` : ''}`\n70:       : `Dry-run: ${stale} vector-present stale row(s), ${missing} missing-vector retry-eligible; no rows mutated`;\n71: \n72:     const hints: string[] = [];\n73:     if (!result.safety.activeShardVerified) {\n74:       hints.push(`Active shard not verified (${result.safety.reason ?? 'unknown'}); no rows were counted or mutated.`);\n75:     } else if (result.mode === 'dry-run' && stale > 0) {\n76:       hints.push('Run memory_embedding_reconcile({ mode: \"apply\" }) to converge embedding_status to success.');\n77:     }\n78: \n79:     return createMCPSuccessResponse({\n80:       tool: 'memory_embedding_reconcile',\n81:       summary,\n82:       data: result,\n83:       hints,\n84:     });\n85:   } catch (error: unknown) {\n86:     if (error instanceof ActiveShardGuardError) {\n87:       return createMCPErrorResponse({\n88:         tool: 'memory_embedding_reconcile',\n89:         error: error.message,\n90:         code: error.code,\n91:         details: { mode },\n92:         recovery: {\n93:           hint: 'Ensure the active embedder shard is attached and matches the active pointer; restart the MCP server if needed.',\n94:           actions: ['Run embedder_status()', 'Run memory_health()'],\n95:           severity: 'error',\n96:         },\n97:       });\n98:     }\n99:     return createMCPErrorResponse({\n100:       tool: 'memory_embedding_reconcile',\n101:       error: `Embedding reconcile failed: ${toErrorMessage(error)}`,\n102:       code: 'E_EMBEDDING_RECONCILE_FAILED',\n103:       details: { mode },\n104:       recovery: {\n105:         hint: 'Inspect memory_index and the active vector shard state, then retry in dry-run.',\n106:         actions: ['Run memory_health()', 'Retry memory_embedding_reconcile({ mode: \"dry-run\" })'],\n107:         severity: 'error',\n108:       },\n109:     });\n110:   }\n111: }\n112: \n113: export { handleMemoryEmbeddingReconcile };\n\n(End of file - total 113 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Embedding Reconcile Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n\n/** Handle the memory_embedding_reconcile MCP tool request. */\nasync function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n  await checkDatabaseUpdated();\n\n  const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Embedding Reconcile Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryEmbeddingReconcile, ActiveShardGuardError } from '../lib/embedders/embedding-reconcile.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { EmbeddingReconcileArgs } from '../lib/embedders/embedding-reconcile.js';\n\n/** Handle the memory_embedding_reconcile MCP tool request. */\nasync function handleMemoryEmbeddingReconcile(args: EmbeddingReconcileArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_embedding_reconcile');\n  await checkDatabaseUpdated();\n\n  const mode = args?.mode === 'apply' ? 'apply' : 'dry-run';\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_embedding_reconcile',\n      error: 'Embedding reconcile aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: { mode },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  // Best-effort: guarantee the active shard is attached as active_vec. The\n  // reconcile verifies it and fails closed if it is still unavailable.\n  // Attach (or re-point) the canonical active shard as active_vec. This is the\n  // path authority: it detaches any wrong/stale shard and attaches the shard\n  // resolved from the active embedder profile. For apply, a failed attach is\n  // FATAL — proceeding could mutate rows against a stale same-profile shard\n  // (the metadata-only guard can't tell two same-profile shard files apart).\n  try {\n    vectorIndex.attachActiveVectorShardForActiveProfile(database);\n  } catch (attachErr: unknown) {\n    if (mode === 'apply') {\n      return createMCPErrorResponse({\n        tool: 'memory_embedding_reconcile',\n        error: `Embedding reconcile aborted: could not attach the active vector shard (${toErrorMessage(attachErr)})`,\n        code: 'E_ACTIVE_SHARD_UNVERIFIED',\n        details: { mode },\n        recovery: {\n          hint: 'Ensure the active embedder shard exists and the daemon is healthy, then retry; restart the MCP server if it persists.',\n          actions: ['Run embedder_status()', 'Run memory_health()'],\n          severity: 'error',\n        },\n      });\n    }\n    // dry-run: non-fatal; verifyActiveShard reports activeShardVerified=false.\n  }\n\n  try {\n    const result = runMemoryEmbeddingReconcile(database, args ?? {});\n    const stale = result.buckets.vector_present_status_stale.count;\n    const missing = result.buckets.missing_active_vector_retry_eligible.count;\n\n    const coverageReset = result.applied?.successCoverageReset ?? 0;\n    const summary = result.mode === 'apply'\n      ? `Reconciled ${result.applied?.reconciledToSuccess ?? 0} vector-present row(s) to success; reset ${result.applied?.resetToRetry ?? 0} missing-vector row(s) to retry${coverageReset ? `; repaired ${coverageReset} success-coverage row(s) to retry` : ''}`\n      : `Dry-run: ${stale} vector-present stale row(s), ${missing} missing-vector retry-eligible; no rows mutated`;\n\n    const hints: string[] = [];\n    if (!result.safety.activeShardVerified) {\n      hints.push(`Active shard not verified (${result.safety.reason ?? 'unknown'}); no rows were counted or mutated.`);\n    } else if (result.mode === 'dry-run' && stale > 0) {\n      hints.push('Run memory_embedding_reconcile({ mode: \"apply\" }) to converge embedding_status to success.');\n    }\n\n    return createMCPSuccessResponse({\n      tool: 'memory_embedding_reconcile',\n      summary,\n      data: result,\n      hints,\n    });\n  } catch (error: unknown) {\n    if (error instanceof ActiveShardGuardError) {\n      return createMCPErrorResponse({\n        tool: 'memory_embedding_reconcile',\n        error: error.message,\n        code: error.code,\n        details: { mode },\n        recovery: {\n          hint: 'Ensure the active embedder shard is attached and matches the active pointer; restart the MCP server if needed.',\n          actions: ['Run embedder_status()', 'Run memory_health()'],\n          severity: 'error',\n        },\n      });\n    }\n    return createMCPErrorResponse({\n      tool: 'memory_embedding_reconcile',\n      error: `Embedding reconcile failed: ${toErrorMessage(error)}`,\n      code: 'E_EMBEDDING_RECONCILE_FAILED',\n      details: { mode },\n      recovery: {\n        hint: 'Inspect memory_index and the active vector shard state, then retry in dry-run.',\n        actions: ['Run memory_health()', 'Retry memory_embedding_reconcile({ mode: \"dry-run\" })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryEmbeddingReconcile };","lineStart":1,"lineEnd":113,"totalLines":113,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-embedding-reconcile.ts","time":{"start":1780929371835,"end":1780929371844}},"metadata":{"openai":{"itemId":"fc_0a834c98fcaf21a2016a26d35b64ac81918c972333183584d5"}},"id":"prt_ea7a99eb7001PHgBw4YBOii9eK","sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","messageID":"msg_ea7a96f460013WQEcrdiSkgFKq"}}
{"type":"tool_use","timestamp":1780929371858,"sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","part":{"type":"tool","tool":"read","callID":"call_xunxBMkrFNxBLAdqlHWZ6VjP","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/embedding-reconcile.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/embedding-reconcile.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Embedding Reconcile\n3: // ────────────────────────────────────────────────────────────────\n4: // One-time/idempotent maintenance that converges memory_index.embedding_status\n5: // with active vector coverage. A row that already has both active vector\n6: // surfaces (vec_memories_rowids + vec_<dim>) must not stay failed/pending/retry.\n7: //\n8: // Safety model: dry-run is the default. The active shard is resolved from\n9: // runtime metadata only (never a caller-supplied path) and verified against the\n10: // main active-embedder pointer before any read or mutation; requireActiveShard\n11: // fails closed on mismatch.\n12: \n13: import type Database from 'better-sqlite3';\n14: \n15: /** Maintenance modes. */\n16: export type EmbeddingReconcileMode = 'dry-run' | 'apply';\n17: \n18: /** Arguments for memory_embedding_reconcile. Dry-run defaults across the board. */\n19: export interface EmbeddingReconcileArgs {\n20:   mode?: EmbeddingReconcileMode;\n21:   /**\n22:    * Reserved / no-op. The active shard is ALWAYS resolved and verified from\n23:    * runtime metadata; this flag has no runtime effect and is retained only for\n24:    * contract stability.\n25:    */\n26:   activeOnly?: boolean;\n27:   /** Reset genuinely missing-vector retention failures to retry-eligible (default true). */\n28:   resetMissing?: boolean;\n29:   /** Which missing-vector failures may be reset. Only retention failures by default. */\n30:   missingFailureScope?: 'retry-retention';\n31:   /** Masked-duplicate failed rows are reconciled to success, never pruned, here. */\n32:   maskedFailedPolicy?: 'reconcile';\n33:   /** Non-retention provider failures are reported, not mutated, by default. */\n34:   providerFailurePolicy?: 'report-only';\n35:   /** Fail closed when the active shard cannot be verified (default true). */\n36:   requireActiveShard?: boolean;\n37:   /**\n38:    * Also reset `success` rows that are MISSING an active vector\n39:    * surface back to `retry` so the retry-manager re-embeds them. Default false;\n40:    * the count is always reported under `coverage` regardless.\n41:    */\n42:   repairSuccessCoverage?: boolean;\n43: }\n44: \n45: export interface ReconcileActiveEmbedder {\n46:   provider: string | null;\n47:   name: string | null;\n48:   dim: number | null;\n49:   shard: string | null;\n50: }\n51: \n52: export interface ReconcileSafety {\n53:   activeShardVerified: boolean;\n54:   vectorPresenceSource: string;\n55:   dimensionTableChecked: string | null;\n56:   /** Present only when verification failed — explains why. */\n57:   reason?: string;\n58: }\n59: \n60: export interface ReconcileStatusSplit {\n61:   failed: number;\n62:   pending: number;\n63:   retry: number;\n64: }\n65: \n66: export interface ReconcileBuckets {\n67:   vector_present_status_stale: { count: number; byStatus: ReconcileStatusSplit };\n68:   missing_active_vector_retry_eligible: { count: number };\n69:   missing_active_vector_provider_failure: { count: number };\n70:   failed_masked_by_newer_latest_path_anchor_row: {\n71:     count: number;\n72:     overlapsBucket: string;\n73:     policy: string;\n74:   };\n75: }\n76: \n77: export interface ReconcilePlannedMutation {\n78:   name: string;\n79:   rows: number;\n80: }\n81: \n82: export interface ReconcileApplied {\n83:   reconciledToSuccess: number;\n84:   resetToRetry: number;\n85:   /** Success rows missing a vector that were reset to retry for re-embedding. */\n86:   successCoverageReset?: number;\n87: }\n88: \n89: /** Success-rows-missing-active-vector coverage diagnostic. */\n90: export interface ReconcileCoverage {\n91:   successMissingActiveVector: number;\n92: }\n93: \n94: export interface EmbeddingReconcileResult {\n95:   mode: EmbeddingReconcileMode;\n96:   activeEmbedder: ReconcileActiveEmbedder;\n97:   safety: ReconcileSafety;\n98:   buckets: ReconcileBuckets;\n99:   plannedMutations: ReconcilePlannedMutation[];\n100:   applied?: ReconcileApplied;\n101:   /** Success-coverage diagnostic; present once the active shard is verified. */\n102:   coverage?: ReconcileCoverage;\n103:   durationMs: number;\n104: }\n105: \n106: /** Raised when requireActiveShard is set but the active shard cannot be verified. */\n107: export class ActiveShardGuardError extends Error {\n108:   readonly code = 'E_ACTIVE_SHARD_UNVERIFIED';\n109:   constructor(reason: string) {\n110:     super(`Active vector shard could not be verified: ${reason}`);\n111:     this.name = 'ActiveShardGuardError';\n112:   }\n113: }\n114: \n115: const ACTIVE_SCHEMA = 'active_vec';\n116: const EMPTY_SPLIT: ReconcileStatusSplit = { failed: 0, pending: 0, retry: 0 };\n117: \n118: function hasTable(database: Database.Database, schema: string, table: string): boolean {\n119:   const row = database\n120:     .prepare(`SELECT 1 AS present FROM ${schema}.sqlite_master WHERE type = 'table' AND name = ? LIMIT 1`)\n121:     .get(table) as { present?: number } | undefined;\n122:   return row?.present === 1;\n123: }\n124: \n125: function metadataMap(database: Database.Database, schema: string): Map<string, string> {\n126:   const map = new Map<string, string>();\n127:   if (!hasTable(database, schema, 'vec_metadata')) {\n128:     return map;\n129:   }\n130:   const rows = database.prepare(`SELECT key, value FROM ${schema}.vec_metadata`).all() as Array<{ key: string; value: string }>;\n131:   for (const row of rows) {\n132:     map.set(row.key, row.value);\n133:   }\n134:   return map;\n135: }\n136: \n137: function readActiveEmbedder(database: Database.Database): { name: string | null; dim: number | null; provider: string | null } {\n138:   const meta = metadataMap(database, 'main');\n139:   const name = meta.get('active_embedder_name') ?? null;\n140:   const rawDim = meta.get('active_embedder_dim');\n141:   const dim = rawDim != null && /^[0-9]+$/.test(rawDim) ? Number.parseInt(rawDim, 10) : null;\n142:   const rawProvider = meta.get('active_embedder_provider');\n143:   const provider = rawProvider != null && rawProvider.trim().length > 0 ? rawProvider : null;\n144:   return { name, dim, provider };\n145: }\n146: \n147: function attachedActiveVecPath(database: Database.Database): string | null {\n148:   const rows = database.pragma('database_list') as Array<{ seq: number; name: string; file: string }>;\n149:   const entry = rows.find((row) => row.name === ACTIVE_SCHEMA);\n150:   return entry ? (entry.file || null) : null;\n151: }\n152: \n153: interface ShardVerification {\n154:   verified: boolean;\n155:   reason?: string;\n156:   dimTable: string | null;\n157:   shardPath: string | null;\n158: }\n159: \n160: /**\n161:  * Verify the attached active_vec shard matches the runtime active-embedder\n162:  * pointer (name + dim + provider) and exposes the expected dimension table.\n163:  */\n164: function verifyActiveShard(\n165:   database: Database.Database,\n166:   active: { name: string | null; dim: number | null; provider: string | null },\n167: ): ShardVerification {\n168:   const shardPath = attachedActiveVecPath(database);\n169:   if (!shardPath) {\n170:     return { verified: false, reason: 'active_vec shard not attached', dimTable: null, shardPath: null };\n171:   }\n172:   if (active.name == null || active.dim == null) {\n173:     return { verified: false, reason: 'main active-embedder pointer incomplete', dimTable: null, shardPath };\n174:   }\n175: \n176:   const shard = metadataMap(database, ACTIVE_SCHEMA);\n177:   const shardName = shard.get('model') ?? shard.get('embedding_model') ?? null;\n178:   const rawShardDim = shard.get('dim') ?? shard.get('embedding_dim') ?? null;\n179:   const shardDim = rawShardDim != null && /^[0-9]+$/.test(rawShardDim) ? Number.parseInt(rawShardDim, 10) : null;\n180:   const shardProvider = shard.get('provider') ?? null;\n181: \n182:   if (shardName !== active.name) {\n183:     return { verified: false, reason: `shard model '${shardName}' != active '${active.name}'`, dimTable: null, shardPath };\n184:   }\n185:   if (shardDim !== active.dim) {\n186:     return { verified: false, reason: `shard dim ${shardDim} != active ${active.dim}`, dimTable: null, shardPath };\n187:   }\n188:   if (active.provider != null && shardProvider != null && active.provider !== shardProvider) {\n189:     return { verified: false, reason: `shard provider '${shardProvider}' != active '${active.provider}'`, dimTable: null, shardPath };\n190:   }\n191: \n192:   const dimTable = `vec_${active.dim}`;\n193:   if (!hasTable(database, ACTIVE_SCHEMA, dimTable) || !hasTable(database, ACTIVE_SCHEMA, 'vec_memories_rowids')) {\n194:     return { verified: false, reason: `active shard missing ${dimTable}/vec_memories_rowids`, dimTable: null, shardPath };\n195:   }\n196:   return { verified: true, dimTable, shardPath };\n197: }\n198: \n199: function emptyBuckets(): ReconcileBuckets {\n200:   return {\n201:     vector_present_status_stale: { count: 0, byStatus: { ...EMPTY_SPLIT } },\n202:     missing_active_vector_retry_eligible: { count: 0 },\n203:     missing_active_vector_provider_failure: { count: 0 },\n204:     failed_masked_by_newer_latest_path_anchor_row: { count: 0, overlapsBucket: 'vector_present_status_stale', policy: 'reconcile' },\n205:   };\n206: }\n207: \n208: /**\n209:  * Count the four dry-run buckets. `dimTable` is a validated `vec_<int>` name\n210:  * (interpolated only after the dim is confirmed to be a positive integer and\n211:  * the table exists), so interpolation here is safe.\n212:  */\n213: function computeBuckets(database: Database.Database, dimTable: string): ReconcileBuckets {\n214:   const presentPredicate = `\n215:     EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = m.id)\n216:     AND EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = m.id)`;\n217:   const missingPredicate = `\n218:     NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = m.id)\n219:     OR NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = m.id)`;\n220: \n221:   const staleRows = database.prepare(`\n222:     SELECT m.embedding_status AS status, COUNT(*) AS n\n223:     FROM memory_index m\n224:     WHERE m.embedding_status IN ('failed', 'pending', 'retry')\n225:       AND (${presentPredicate})\n226:     GROUP BY m.embedding_status\n227:   `).all() as Array<{ status: string; n: number }>;\n228: \n229:   const byStatus: ReconcileStatusSplit = { ...EMPTY_SPLIT };\n230:   for (const row of staleRows) {\n231:     if (row.status === 'failed') byStatus.failed = row.n;\n232:     else if (row.status === 'pending') byStatus.pending = row.n;\n233:     else if (row.status === 'retry') byStatus.retry = row.n;\n234:   }\n235:   const staleCount = byStatus.failed + byStatus.pending + byStatus.retry;\n236: \n237:   // Only genuinely-parked retention FAILURES missing a vector need reset to\n238:   // retry. Already-pending/retry rows are queued for the daemon and are left\n239:   // alone — counting them would overstate plannedMutations and break\n240:   // idempotency (a second apply would clobber their retry_count). \"Missing\" =\n241:   // either surface absent (OR), keeping this complementary with the\n242:   // vector-present update (which requires BOTH surfaces). Matches the apply\n243:   // UPDATE exactly so plannedMutations is accurate and a re-run is a no-op.\n244:   const retryEligible = (database.prepare(`\n245:     SELECT COUNT(*) AS n FROM memory_index m\n246:     WHERE m.embedding_status = 'failed'\n247:       AND m.failure_reason LIKE 'Retry retention%'\n248:       AND (${missingPredicate})\n249:   `).get() as { n: number }).n;\n250: \n251:   const providerFailure = (database.prepare(`\n252:     SELECT COUNT(*) AS n FROM memory_index m\n253:     WHERE m.embedding_status = 'failed'\n254:       AND (${missingPredicate})\n255:       AND (m.failure_reason IS NULL OR m.failure_reason NOT LIKE 'Retry retention%')\n256:   `).get() as { n: number }).n;\n257: \n258:   const masked = (database.prepare(`\n259:     WITH latest AS (\n260:       SELECT COALESCE(canonical_file_path, file_path) AS canonical_path,\n\n(Showing lines 1-260 of 449. Use offset=261 to continue.)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Embedding Reconcile\n// ────────────────────────────────────────────────────────────────\n// One-time/idempotent maintenance that converges memory_index.embedding_status\n// with active vector coverage. A row that already has both active vector\n// surfaces (vec_memories_rowids + vec_<dim>) must not stay failed/pending/retry.\n//\n// Safety model: dry-run is the default. The active shard is resolved from\n// runtime metadata only (never a caller-supplied path) and verified against the\n// main active-embedder pointer before any read or mutation; requireActiveShard\n// fails closed on mismatch.\n\nimport type Database from 'better-sqlite3';\n\n/** Maintenance modes. */\nexport type EmbeddingReconcileMode = 'dry-run' | 'apply';\n\n/** Arguments for memory_embedding_reconcile. Dry-run defaults across the board. */\nexport interface EmbeddingReconcileArgs {\n  mode?: EmbeddingReconcileMode;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/embedders/embedding-reconcile.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Embedding Reconcile\n// ────────────────────────────────────────────────────────────────\n// One-time/idempotent maintenance that converges memory_index.embedding_status\n// with active vector coverage. A row that already has both active vector\n// surfaces (vec_memories_rowids + vec_<dim>) must not stay failed/pending/retry.\n//\n// Safety model: dry-run is the default. The active shard is resolved from\n// runtime metadata only (never a caller-supplied path) and verified against the\n// main active-embedder pointer before any read or mutation; requireActiveShard\n// fails closed on mismatch.\n\nimport type Database from 'better-sqlite3';\n\n/** Maintenance modes. */\nexport type EmbeddingReconcileMode = 'dry-run' | 'apply';\n\n/** Arguments for memory_embedding_reconcile. Dry-run defaults across the board. */\nexport interface EmbeddingReconcileArgs {\n  mode?: EmbeddingReconcileMode;\n  /**\n   * Reserved / no-op. The active shard is ALWAYS resolved and verified from\n   * runtime metadata; this flag has no runtime effect and is retained only for\n   * contract stability.\n   */\n  activeOnly?: boolean;\n  /** Reset genuinely missing-vector retention failures to retry-eligible (default true). */\n  resetMissing?: boolean;\n  /** Which missing-vector failures may be reset. Only retention failures by default. */\n  missingFailureScope?: 'retry-retention';\n  /** Masked-duplicate failed rows are reconciled to success, never pruned, here. */\n  maskedFailedPolicy?: 'reconcile';\n  /** Non-retention provider failures are reported, not mutated, by default. */\n  providerFailurePolicy?: 'report-only';\n  /** Fail closed when the active shard cannot be verified (default true). */\n  requireActiveShard?: boolean;\n  /**\n   * Also reset `success` rows that are MISSING an active vector\n   * surface back to `retry` so the retry-manager re-embeds them. Default false;\n   * the count is always reported under `coverage` regardless.\n   */\n  repairSuccessCoverage?: boolean;\n}\n\nexport interface ReconcileActiveEmbedder {\n  provider: string | null;\n  name: string | null;\n  dim: number | null;\n  shard: string | null;\n}\n\nexport interface ReconcileSafety {\n  activeShardVerified: boolean;\n  vectorPresenceSource: string;\n  dimensionTableChecked: string | null;\n  /** Present only when verification failed — explains why. */\n  reason?: string;\n}\n\nexport interface ReconcileStatusSplit {\n  failed: number;\n  pending: number;\n  retry: number;\n}\n\nexport interface ReconcileBuckets {\n  vector_present_status_stale: { count: number; byStatus: ReconcileStatusSplit };\n  missing_active_vector_retry_eligible: { count: number };\n  missing_active_vector_provider_failure: { count: number };\n  failed_masked_by_newer_latest_path_anchor_row: {\n    count: number;\n    overlapsBucket: string;\n    policy: string;\n  };\n}\n\nexport interface ReconcilePlannedMutation {\n  name: string;\n  rows: number;\n}\n\nexport interface ReconcileApplied {\n  reconciledToSuccess: number;\n  resetToRetry: number;\n  /** Success rows missing a vector that were reset to retry for re-embedding. */\n  successCoverageReset?: number;\n}\n\n/** Success-rows-missing-active-vector coverage diagnostic. */\nexport interface ReconcileCoverage {\n  successMissingActiveVector: number;\n}\n\nexport interface EmbeddingReconcileResult {\n  mode: EmbeddingReconcileMode;\n  activeEmbedder: ReconcileActiveEmbedder;\n  safety: ReconcileSafety;\n  buckets: ReconcileBuckets;\n  plannedMutations: ReconcilePlannedMutation[];\n  applied?: ReconcileApplied;\n  /** Success-coverage diagnostic; present once the active shard is verified. */\n  coverage?: ReconcileCoverage;\n  durationMs: number;\n}\n\n/** Raised when requireActiveShard is set but the active shard cannot be verified. */\nexport class ActiveShardGuardError extends Error {\n  readonly code = 'E_ACTIVE_SHARD_UNVERIFIED';\n  constructor(reason: string) {\n    super(`Active vector shard could not be verified: ${reason}`);\n    this.name = 'ActiveShardGuardError';\n  }\n}\n\nconst ACTIVE_SCHEMA = 'active_vec';\nconst EMPTY_SPLIT: ReconcileStatusSplit = { failed: 0, pending: 0, retry: 0 };\n\nfunction hasTable(database: Database.Database, schema: string, table: string): boolean {\n  const row = database\n    .prepare(`SELECT 1 AS present FROM ${schema}.sqlite_master WHERE type = 'table' AND name = ? LIMIT 1`)\n    .get(table) as { present?: number } | undefined;\n  return row?.present === 1;\n}\n\nfunction metadataMap(database: Database.Database, schema: string): Map<string, string> {\n  const map = new Map<string, string>();\n  if (!hasTable(database, schema, 'vec_metadata')) {\n    return map;\n  }\n  const rows = database.prepare(`SELECT key, value FROM ${schema}.vec_metadata`).all() as Array<{ key: string; value: string }>;\n  for (const row of rows) {\n    map.set(row.key, row.value);\n  }\n  return map;\n}\n\nfunction readActiveEmbedder(database: Database.Database): { name: string | null; dim: number | null; provider: string | null } {\n  const meta = metadataMap(database, 'main');\n  const name = meta.get('active_embedder_name') ?? null;\n  const rawDim = meta.get('active_embedder_dim');\n  const dim = rawDim != null && /^[0-9]+$/.test(rawDim) ? Number.parseInt(rawDim, 10) : null;\n  const rawProvider = meta.get('active_embedder_provider');\n  const provider = rawProvider != null && rawProvider.trim().length > 0 ? rawProvider : null;\n  return { name, dim, provider };\n}\n\nfunction attachedActiveVecPath(database: Database.Database): string | null {\n  const rows = database.pragma('database_list') as Array<{ seq: number; name: string; file: string }>;\n  const entry = rows.find((row) => row.name === ACTIVE_SCHEMA);\n  return entry ? (entry.file || null) : null;\n}\n\ninterface ShardVerification {\n  verified: boolean;\n  reason?: string;\n  dimTable: string | null;\n  shardPath: string | null;\n}\n\n/**\n * Verify the attached active_vec shard matches the runtime active-embedder\n * pointer (name + dim + provider) and exposes the expected dimension table.\n */\nfunction verifyActiveShard(\n  database: Database.Database,\n  active: { name: string | null; dim: number | null; provider: string | null },\n): ShardVerification {\n  const shardPath = attachedActiveVecPath(database);\n  if (!shardPath) {\n    return { verified: false, reason: 'active_vec shard not attached', dimTable: null, shardPath: null };\n  }\n  if (active.name == null || active.dim == null) {\n    return { verified: false, reason: 'main active-embedder pointer incomplete', dimTable: null, shardPath };\n  }\n\n  const shard = metadataMap(database, ACTIVE_SCHEMA);\n  const shardName = shard.get('model') ?? shard.get('embedding_model') ?? null;\n  const rawShardDim = shard.get('dim') ?? shard.get('embedding_dim') ?? null;\n  const shardDim = rawShardDim != null && /^[0-9]+$/.test(rawShardDim) ? Number.parseInt(rawShardDim, 10) : null;\n  const shardProvider = shard.get('provider') ?? null;\n\n  if (shardName !== active.name) {\n    return { verified: false, reason: `shard model '${shardName}' != active '${active.name}'`, dimTable: null, shardPath };\n  }\n  if (shardDim !== active.dim) {\n    return { verified: false, reason: `shard dim ${shardDim} != active ${active.dim}`, dimTable: null, shardPath };\n  }\n  if (active.provider != null && shardProvider != null && active.provider !== shardProvider) {\n    return { verified: false, reason: `shard provider '${shardProvider}' != active '${active.provider}'`, dimTable: null, shardPath };\n  }\n\n  const dimTable = `vec_${active.dim}`;\n  if (!hasTable(database, ACTIVE_SCHEMA, dimTable) || !hasTable(database, ACTIVE_SCHEMA, 'vec_memories_rowids')) {\n    return { verified: false, reason: `active shard missing ${dimTable}/vec_memories_rowids`, dimTable: null, shardPath };\n  }\n  return { verified: true, dimTable, shardPath };\n}\n\nfunction emptyBuckets(): ReconcileBuckets {\n  return {\n    vector_present_status_stale: { count: 0, byStatus: { ...EMPTY_SPLIT } },\n    missing_active_vector_retry_eligible: { count: 0 },\n    missing_active_vector_provider_failure: { count: 0 },\n    failed_masked_by_newer_latest_path_anchor_row: { count: 0, overlapsBucket: 'vector_present_status_stale', policy: 'reconcile' },\n  };\n}\n\n/**\n * Count the four dry-run buckets. `dimTable` is a validated `vec_<int>` name\n * (interpolated only after the dim is confirmed to be a positive integer and\n * the table exists), so interpolation here is safe.\n */\nfunction computeBuckets(database: Database.Database, dimTable: string): ReconcileBuckets {\n  const presentPredicate = `\n    EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = m.id)\n    AND EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = m.id)`;\n  const missingPredicate = `\n    NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.vec_memories_rowids r WHERE r.rowid = m.id)\n    OR NOT EXISTS (SELECT 1 FROM ${ACTIVE_SCHEMA}.${dimTable} v WHERE v.id = m.id)`;\n\n  const staleRows = database.prepare(`\n    SELECT m.embedding_status AS status, COUNT(*) AS n\n    FROM memory_index m\n    WHERE m.embedding_status IN ('failed', 'pending', 'retry')\n      AND (${presentPredicate})\n    GROUP BY m.embedding_status\n  `).all() as Array<{ status: string; n: number }>;\n\n  const byStatus: ReconcileStatusSplit = { ...EMPTY_SPLIT };\n  for (const row of staleRows) {\n    if (row.status === 'failed') byStatus.failed = row.n;\n    else if (row.status === 'pending') byStatus.pending = row.n;\n    else if (row.status === 'retry') byStatus.retry = row.n;\n  }\n  const staleCount = byStatus.failed + byStatus.pending + byStatus.retry;\n\n  // Only genuinely-parked retention FAILURES missing a vector need reset to\n  // retry. Already-pending/retry rows are queued for the daemon and are left\n  // alone — counting them would overstate plannedMutations and break\n  // idempotency (a second apply would clobber their retry_count). \"Missing\" =\n  // either surface absent (OR), keeping this complementary with the\n  // vector-present update (which requires BOTH surfaces). Matches the apply\n  // UPDATE exactly so plannedMutations is accurate and a re-run is a no-op.\n  const retryEligible = (database.prepare(`\n    SELECT COUNT(*) AS n FROM memory_index m\n    WHERE m.embedding_status = 'failed'\n      AND m.failure_reason LIKE 'Retry retention%'\n      AND (${missingPredicate})\n  `).get() as { n: number }).n;\n\n  const providerFailure = (database.prepare(`\n    SELECT COUNT(*) AS n FROM memory_index m\n    WHERE m.embedding_status = 'failed'\n      AND (${missingPredicate})\n      AND (m.failure_reason IS NULL OR m.failure_reason NOT LIKE 'Retry retention%')\n  `).get() as { n: number }).n;\n\n  const masked = (database.prepare(`\n    WITH latest AS (\n      SELECT COALESCE(canonical_file_path, file_path) AS canonical_path,","lineStart":1,"lineEnd":260,"totalLines":449,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/embedders/embedding-reconcile.ts","time":{"start":1780929371838,"end":1780929371854}},"metadata":{"openai":{"itemId":"fc_0a834c98fcaf21a2016a26d35b64b48191bf48d15331d233db"}},"id":"prt_ea7a99ebc001n60GbaRFRZ4Iiu","sessionID":"ses_15858491bffeXJMuegc5mX6JyJ","messageID":"msg_ea7a96f460013WQEcrdiSkgFKq"}}
