ap.\n    expect(__testing.classifyFrame(toolCallFrame(1, 'memory_save'))).toBe(true);\n  });\n});","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-recycle-transparency-stress.vitest.ts","text":"\n  it('classifies the replay partition the same way the proxy does (read vs unsafe)', () => {\n    for (const tool of READ_TOOLS) {\n      expect(__testing.classifyFrame(toolCallFrame(1, tool)), `${tool} should be replayable`).toBe(true);\n    }\n    for (const tool of WRITE_TOOLS) {\n      expect(__testing.classifyFrame(toolCallFrame(1, tool)), `${tool} should NOT be replayable`).toBe(false);\n    }\n    // memory_save is replayable by design (primary-row dedup), proving the\n    // recycle path keeps the canonical save flowing through a backend swap.\n    expect(__testing.classifyFrame(toolCallFrame(1, 'memory_save'))).toBe(true);\n  });\n});","lineStart":176,"lineEnd":188,"totalLines":188,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/stress_test/durability/daemon-recycle-transparency-stress.vitest.ts","time":{"start":1781763218098,"end":1781763218100}},"metadata":{"openai":{"itemId":"fc_03a14b1c6d665a2c016a338c91f50c8191ae328ce62e4df18f"}},"id":"prt_ed95d1aa6001dT8eyEr1ABSh62","sessionID":"ses_126a7351cffe2yu58i7OdmNdV8","messageID":"msg_ed95cdefb001PX4aV39FNjTzn9"}}
