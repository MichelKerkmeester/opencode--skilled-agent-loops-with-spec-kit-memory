memory_id = mi.id\n\n  Line 465:       memory_id: number;\n\n  Line 483:       if (!sets.memoryIdSet.has(row.memory_id)) {\n\n  Line 484:         sets.memoryIdSet.add(row.memory_id);\n\n  Line 485:         entry.memoryIds.push(row.memory_id);\n\n  Line 533:       `SELECT entity_text FROM memory_entities WHERE memory_id = ?`,\n\n  Line 649:       SELECT me.memory_id, me.entity_text, mi.spec_folder\n\n  Line 651:       JOIN memory_index mi ON me.memory_id = mi.id\n\n  Line 652:       WHERE me.memory_id != ?\n\n  Line 668:       entry.memoryIds.add(row.memory_id);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/chunk-reassembly.ts:\n  Line 20:   parent_id?: number | null;\n\n  Line 79:  * 1. Deduplicates by parent_id (keeps only the first/best-scoring chunk per parent)\n\n  Line 111:     const parentId = parseNullableInt(row.parent_id ?? (row as Record<string, unknown>).parentId);\n\n  Line 158:       SELECT parent_id, chunk_index, chunk_label, content_text\n\n  Line 160:       WHERE parent_id IN (${placeholders})\n\n  Line 161:       ORDER BY parent_id ASC, chunk_index ASC\n\n  Line 163:       parent_id: number;\n\n  Line 176:       const list = byParent.get(row.parent_id);\n\n  Line 180:         byParent.set(row.parent_id, [row]);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-queries.ts:\n  Line 159:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n\n  Line 166:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n\n  Line 197:         JOIN active_memory_projection p ON p.active_memory_id = m.id\n\n  Line 280:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n\n  Line 312:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n\n  Line 453:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n\n  Line 563:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n\n  Line 873:     JOIN active_memory_projection p ON p.active_memory_id = m.id\n\n  Line 1281:  * @param memory_id - The memory identifier.\n\n  Line 1284: export function get_related_memories(memory_id: number): MemoryRow[] {\n\n  Line 1290:     `).get(memory_id) as { related_memories?: string | null } | undefined;\n\n  Line 1309:     console.warn(`[vector-index] Failed to get related memories for ${memory_id}: ${get_error_message(error)}`);\n\n  Line 1450:  * @param memory_id - The memory identifier.\n\n  Line 1454: export function get_memory_preview(memory_id: number, max_lines = 50): { id: number; specFolder: string; filePath: string; title: string; createdAt: string | undefined; lastAccessedAt: number | undefined; accessCount: number; confidence: number; ageString: string; lastAccessString: string; content: string } | null {\n\n  Line 1461:     `).get(memory_id) as MemoryRow | undefined;\n\n  Line 1486:       memoryId: memory_id,\n\n  Line 1558:     const delete_stmt = database.prepare(`DELETE FROM ${source.tableName} WHERE ${source.idColumn} = ?`);\n\n  Line 1658:         SELECT id, parent_id, chunk_index, chunk_label, spec_folder\n\n  Line 1660:         WHERE parent_id IS NOT NULL\n\n  Line 1663:             WHERE parent.id = memory_index.parent_id\n\n  Line 1664:               AND parent.parent_id IS NULL\n\n  Line 1666:       `).all() as Array<{ id: number; parent_id: number; chunk_index: number; chunk_label: string | null; spec_folder: string | null }>;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts:\n  Line 83:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n\n  Line 95:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n\n  Line 98:     database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n\n  Lin