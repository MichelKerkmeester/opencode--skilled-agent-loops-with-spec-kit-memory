;\n41: }\n42: \n43: export interface SymbolBm25SearchOptions {\n44:   readonly fieldWeights?: Partial<SymbolBm25FieldWeights>;\n45:   readonly limit?: number;\n46: }\n47: \n48: export interface SymbolBm25Candidate {\n49:   readonly symbolId: string;\n50:   readonly fqName: string | null;\n51:   readonly name: string | null;\n52:   readonly kind: string | null;\n53:   readonly filePath: string | null;\n54:   readonly startLine: number | null;\n55:   readonly score: number;\n56:   readonly rawScore: number;\n57:   readonly evidence: readonly string[];\n58:   readonly disambiguationOnly: true;\n59: }\n60: \n61: export interface SymbolBm25FootprintStats {\n62:   readonly documentCount: number;\n63:   readonly termCount: number;\n64:   readonly postingCount: number;\n65:   readonly typedArrayBytes: number;\n66:   readonly mutablePostingCount: number;\n67: }\n68: \n69: interface FieldTermFrequency {\n70:   total: number;\n71:   fields: Record<SymbolBm25FieldName, number>;\n72: }\n73: \n74: interface PackedSymbolDocument extends SymbolBm25Document {\n75:   numericId: number;\n76:   length: number;\n77: }\n78: \n79: interface PackedPostingMutable {\n80:   docIds: number[];\n81:   nameTfs: number[];\n82:   fqNameTfs: number[];\n83:   signatureTfs: number[];\n84:   docstringTfs: number[];\n85:   filePathTfs: number[];\n86: }\n87: \n88: interface PackedPostingList {\n89:   docIds: Uint32Array;\n90:   nameTfs: Uint32Array;\n91:   fqNameTfs: Uint32Array;\n92:   signatureTfs: Uint32Array;\n93:   docstringTfs: Uint32Array;\n94:   filePathTfs: Uint32Array;\n95: }\n96: \n97: function emptyFieldFrequency(): FieldTermFrequency {\n98:   return {\n99:     total: 0,\n100:     fields: {\n101:       name: 0,\n102:       fqName: 0,\n103:       signature: 0,\n104:       docstring: 0,\n105:       filePath: 0,\n106:     },\n107:   };\n108: }\n109: \n110: function resolveFieldWeights(overrides: Partial<SymbolBm25FieldWeights> = {}): SymbolBm25FieldWeights {\n111:   return {\n112:     name: overrides.name ?? SYMBOL_BM25_FIELD_WEIGHTS.name,\n113:     fqName: overrides.fqName ?? SYMBOL_BM25_FIELD_WEIGHTS.fqName,\n114:     signature: overrides.signature ?? SYMBOL_BM25_FIELD_WEIGHTS.signature,\n115:     docstring: overrides.docstring ?? SYMBOL_BM25_FIELD_WEIGHTS.docstring,\n116:     filePath: overrides.filePath ?? SYMBOL_BM25_FIELD_WEIGHTS.filePath,\n117:   };\n118: }\n119: \n120: export function isCodeGraphBm25SymbolResolverEnabled(env: NodeJS.ProcessEnv = process.env): boolean {\n121:   const value = env[CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV]?.trim().toLowerCase();\n122:   return value ? ENABLED_VALUES.has(value) : false;\n123: }\n124: \n125: function splitIdentifier(value: string): string[] {\n126:   return value\n127:     .replace(/([a-z0-9])([A-Z])/g, '$1 $2')\n128:     .replace(/([A-Z]+)([A-Z][a-z])/g, '$1 $2')\n129:     .toLowerCase()\n130:     .split(/[^a-z0-9]+/)\n131:     .filter((token) => token.length >= 2);\n132: }\n133: \n134: function trigrams(token: string): string[] {\n135:   if (token.length < 4) return [];\n136:   const grams: string[] = [];\n137:   for (let index = 0; index <= token.length - 3; index += 1) {\n138:     grams.push(`tri:${token.slice(index, index + 3)}`);\n139:   }\n140:   return grams;\n141: }\n142: \n143: function tokenize(value: string | null | undefined): string[] {\n144:   if (!value) return [];\n145:   const baseTokens = splitIdentifier(value);\n146:   return baseTokens.flatMap((token) => [token, ...trigrams(token)]);\n147: }\n148: \n149: function documentFields(document: SymbolBm25Document): Record<SymbolBm25FieldName, readonly string[]> {\n150:   return {\n151:     name: [document.name ?? ''],\n152:     fqName: [document.fqName ?? ''],\n153:     signature: [document.signature ?? ''],\n154:     docstring: [document.docstring ?? ''],\n155:     filePath: [document.filePath ?? ''],\n156:   };\n157: }\n158: \n159: function fieldTermFrequencies(document: SymbolBm25Document): Map<string, FieldTermFrequency> {\n160:   const frequencies = new Map<string, FieldTermFrequency>();\n161:   for (const fieldName of SYMBOL_BM25_FIELD_NAMES) {\n162:     for (const value of documentFields(document)[fieldName]) {\n163:       for (const token of tokenize(value)) {\n164:         let frequency = frequencies.get(token);\n165:         if (!frequency) {\n166:           frequency = emptyFieldFrequency();\n167:           frequencies.set(token, frequency);\n168:         }\n169:         frequency.total += 1;\n170:         frequency.fields[fieldName] += 1;\n171:       }\n172:     }\n173:   }\n174:   return frequencies;\n175: }\n176: \n177: function weightedFrequency(\n178:   postings: PackedPostingList,\n179:   index: number,\n180:   weights: SymbolBm25FieldWeights,\n181: ): number {\n182:   return postings.nameTfs[index] * weights.name\n183:     + postings.fqNameTfs[index] * weights.fqName\n184:     + postings.signatureTfs[index] * weights.signature\n185:     + postings.docstringTfs[index] * weights.docstring\n186:     + postings.filePathTfs[index] * weights.filePath;\n187: }\n188: \n189: function topWeightedFields(\n190:   postings: PackedPostingList,\n191:   index: number,\n192:   weights: SymbolBm25FieldWeights,\n193: ): SymbolBm25FieldName[] {\n194:   return [\n195:     { field: 'name' as const, value: postings.nameTfs[index] * weights.name },\n196:     { field: 'fqName' as const, value: postings.fqNameTfs[index] * weights.fqName },\n197:     { field: 'signature' as const, value: postings.signatureTfs[index] * weights.signature },\n198:     { field: 'filePath' as const, value: postings.filePathTfs[index] * weights.filePath },\n199:     { field: 'docstring' as const, value: postings.docstringTfs[index] * weights.docstring },\n200:   ]\n201:     .filter((entry) => entry.value > 0)\n202:     .sort((left, right) => right.value - left.value)\n203:     .map((entry) => entry.field)\n204:     .slice(0, 3);\n205: }\n206: \n207: export class SymbolPackedBm25Index {\n208:   private readonly symbolIds: string[] = [];\n209:   private readonly symbolNumbersById = new Map<string, number>();\n210:   private readonly documents = new Map<string, PackedSymbolDocument>();\n211:   private readonly documentFreq = new Map<string, number>();\n212:   private readonly mutablePostings = new Map<string, PackedPostingMutable>();\n213:   private readonly packedPostings = new Map<string, PackedPostingList>();\n214:   private totalDocumentLength = 0;\n215: \n216:   constructor(documents: readonly SymbolBm25Document[] = []) {\n217:     for (const document of documents) {\n218:       this.addDocument(document);\n219:     }\n220:     this.finalize();\n221:   }\n222: \n223:   addDocument(document: SymbolBm25Document): void {\n224:     const frequencies = fieldTermFrequencies(document);\n225:     const length = Array.from(frequencies.values()).reduce((total, frequency) => total + frequency.total, 0);\n226:     if (length === 0) return;\n227: \n228:     const numericId = this.nextNumericId(document.symbolId);\n229:     this.documents.set(document.symbolId, { ...document, numericId, length });\n230:     this.totalDocumentLength += length;\n231: \n232:     for (const term of [...frequencies.keys()].sort()) {\n233:       const frequency = frequencies.get(term);\n234:       if (!frequency) continue;\n235:       this.documentFreq.set(term, (this.documentFreq.get(term) ?? 0) + 1);\n236:       const postings = this.ensureMutablePostings(term);\n237:       postings.docIds.push(numericId);\n238:       postings.nameTfs.push(frequency.fields.name);\n239:       postings.fqNameTfs.push(frequency.fields.fqName);\n240:       postings.signatureTfs.push(frequency.fields.signature);\n241:       postings.docstringTfs.push(frequency.fields.docstring);\n242:       postings.filePathTfs.push(frequency.fields.filePath);\n243:     }\n244:   }\n245: \n246:   finalize(): void {\n247:     for (const [term, postings] of this.mutablePostings.entries()) {\n248:       const order = postings.docIds.map((docId, index) => ({ docId, index }))\n249:         .sort((left, right) => left.docId - right.docId);\n250:       this.packedPostings.set(term, {\n251:         docIds: Uint32Array.from(order.map((entry) => entry.docId)),\n252:         nameTfs: Uint32Array.from(order.map((entry) => postings.nameTfs[entry.index])),\n253:         fqNameTfs: Uint32Array.from(order.map((entry) => postings.fqNameTfs[entry.index])),\n254:         signatureTfs: Uint32Array.from(order.map((entry) => postings.signatureTfs[entry.index])),\n255:         docstringTfs: Uint32Array.from(order.map((entry) => postings.docstringTfs[entry.index])),\n256:         filePathTfs: Uint32Array.from(order.map((entry) => postings.filePathTfs[entry.index])),\n257:       });\n258:     }\n259:     this.mutablePostings.clear();\n260:   }\n261: \n262:   search(query: string, options: SymbolBm25SearchOptions = {}): SymbolBm25Candidate[] {\n263:     const queryTerms = [...new Set(tokenize(query))];\n264:     if (queryTerms.length === 0 || this.documents.size === 0) return [];\n265: \n266:     const weights = resolveFieldWeights(options.fieldWeights);\n267:     const scores = new Map<number, { rawScore: number; evidence: string[] }>();\n268:     const averageLength = Math.max(this.totalDocumentLength / this.documents.size, 1);\n269: \n270:     for (const term of queryTerms) {\n271:       const postings = this.packedPostings.get(term);\n272:       if (!postings) continue;\n273:       const idf = this.idf(term);\n274:       for (let index = 0; index < postings.docIds.length; index += 1) {\n275:         const numericId = postings.docIds[index];\n276:         const symbolId = this.symbolIds[numericId];\n277:         const document = symbolId ? this.documents.get(symbolId) : undefined;\n278:         if (!document) continue;\n279:         const weightedTf = weightedFrequency(postings, index, weights);\n280:         if (weightedTf <= 0) continue;\n281: \n282:         const termScore = idf * ((weightedTf * (BM25_K1 + 1))\n283:           / (weightedTf + BM25_K1 * (1 - BM25_B + BM25_B * (document.length / averageLength))));\n284:         const existing = scores.get(numericId) ?? { rawScore: 0, evidence: [] };\n285:         existing.rawScore += termScore;\n286:         if (existing.evidence.length < 6) {\n287:           existing.evidence.push(`bm25:${term}`);\n288:           for (const field of topWeightedFields(postings, index, weights)) {\n289:             if (existing.evidence.length >= 6) break;\n290:             existing.evidence.push(`field:${field}`);\n291:           }\n292:         }\n293:         scores.set(numericId, existing);\n294:       }\n295:     }\n296: \n297:     const matches = [...scores.entries()]\n298:       .flatMap(([numericId, result]) => {\n299:         const symbolId = this.symbolIds[numericId];\n300:         const document = symbolId ? this.documents.get(symbolId) : undefined;\n301:         if (!document) return [];\n302:         return [{\n303:           symbolId: document.symbolId,\n304:           fqName: document.fqName,\n305:           name: document.name,\n306:           kind: document.kind,\n307:           filePath: document.filePath,\n308:           startLine: document.startLine,\n309:           rawScore: Number(result.rawScore.toFixed(6)),\n310:           score: Number((result.rawScore / (result.rawScore + 4)).toFixed(6)),\n311:           evidence: result.evidence,\n312:           disambiguationOnly: true,\n313:         } satisfies SymbolBm25Candidate];\n314:       })\n315:       .filter((match) => match.score > 0);\n316: \n317:     return matches\n318:       .sort((left, right) => right.score - left.score\n319:         || (left.filePath ?? '').localeCompare(right.filePath ?? '')\n320:         || (left.startLine ?? Number.MAX_SAFE_INTEGER) - (right.startLine ?? Number.MAX_SAFE_INTEGER)\n321:         || left.symbolId.localeCompare(right.symbolId))\n322:       .slice(0, options.limit ?? DEFAULT_LIMIT);\n323:   }\n324: \n325:   getFootprintStats(): SymbolBm25FootprintStats {\n326:     let postingCount = 0;\n327:     let typedArrayBytes = 0;\n328:     for (const postings of this.packedPostings.values()) {\n329:       postingCount += postings.docIds.length;\n330:       typedArrayBytes += postings.docIds.byteLength\n331:         + postings.nameTfs.byteLength\n332:         + postings.fqNameTfs.byteLength\n333:         + postings.signatureTfs.byteLength\n334:         + postings.docstringTfs.byteLength\n335:         + postings.filePathTfs.byteLength;\n336:     }\n337:     return {\n338:       documentCount: this.documents.size,\n339:       termCount: this.packedPostings.size,\n340:       postingCount,\n\n(Showing lines 1-340 of 382. Use offset=341 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph Symbol BM25 Resolver\n// ───────────────────────────────────────────────────────────────\n// Optional, fallback-only symbol candidate scoring over indexed symbol fields.\n\nexport const CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV = 'SPECKIT_CODE_GRAPH_BM25_SYMBOL_RESOLVER';\n\nconst BM25_K1 = 1.2;\nconst BM25_B = 0.75;\nconst DEFAULT_LIMIT = 5;\nconst ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n\nconst SYMBOL_BM25_FIELD_NAMES = [\n  'name',\n  'fqName',\n  'signature',\n  'docstring',\n  'filePath',\n] as const;\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/lib/symbol-bm25-resolver.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Code Graph Symbol BM25 Resolver\n// ───────────────────────────────────────────────────────────────\n// Optional, fallback-only symbol candidate scoring over indexed symbol fields.\n\nexport const CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV = 'SPECKIT_CODE_GRAPH_BM25_SYMBOL_RESOLVER';\n\nconst BM25_K1 = 1.2;\nconst BM25_B = 0.75;\nconst DEFAULT_LIMIT = 5;\nconst ENABLED_VALUES = new Set(['1', 'true', 'yes', 'on', 'experimental', 'fallback']);\n\nconst SYMBOL_BM25_FIELD_NAMES = [\n  'name',\n  'fqName',\n  'signature',\n  'docstring',\n  'filePath',\n] as const;\n\nexport type SymbolBm25FieldName = typeof SYMBOL_BM25_FIELD_NAMES[number];\nexport type SymbolBm25FieldWeights = Record<SymbolBm25FieldName, number>;\n\nexport const SYMBOL_BM25_FIELD_WEIGHTS: SymbolBm25FieldWeights = {\n  name: 4.0,\n  fqName: 3.2,\n  signature: 2.0,\n  filePath: 1.2,\n  docstring: 0.7,\n};\n\nexport interface SymbolBm25Document {\n  readonly symbolId: string;\n  readonly fqName: string | null;\n  readonly name: string | null;\n  readonly kind: string | null;\n  readonly filePath: string | null;\n  readonly startLine: number | null;\n  readonly signature: string | null;\n  readonly docstring: string | null;\n}\n\nexport interface SymbolBm25SearchOptions {\n  readonly fieldWeights?: Partial<SymbolBm25FieldWeights>;\n  readonly limit?: number;\n}\n\nexport interface SymbolBm25Candidate {\n  readonly symbolId: string;\n  readonly fqName: string | null;\n  readonly name: string | null;\n  readonly kind: string | null;\n  readonly filePath: string | null;\n  readonly startLine: number | null;\n  readonly score: number;\n  readonly rawScore: number;\n  readonly evidence: readonly string[];\n  readonly disambiguationOnly: true;\n}\n\nexport interface SymbolBm25FootprintStats {\n  readonly documentCount: number;\n  readonly termCount: number;\n  readonly postingCount: number;\n  readonly typedArrayBytes: number;\n  readonly mutablePostingCount: number;\n}\n\ninterface FieldTermFrequency {\n  total: number;\n  fields: Record<SymbolBm25FieldName, number>;\n}\n\ninterface PackedSymbolDocument extends SymbolBm25Document {\n  numericId: number;\n  length: number;\n}\n\ninterface PackedPostingMutable {\n  docIds: number[];\n  nameTfs: number[];\n  fqNameTfs: number[];\n  signatureTfs: number[];\n  docstringTfs: number[];\n  filePathTfs: number[];\n}\n\ninterface PackedPostingList {\n  docIds: Uint32Array;\n  nameTfs: Uint32Array;\n  fqNameTfs: Uint32Array;\n  signatureTfs: Uint32Array;\n  docstringTfs: Uint32Array;\n  filePathTfs: Uint32Array;\n}\n\nfunction emptyFieldFrequency(): FieldTermFrequency {\n  return {\n    total: 0,\n    fields: {\n      name: 0,\n      fqName: 0,\n      signature: 0,\n      docstring: 0,\n      filePath: 0,\n    },\n  };\n}\n\nfunction resolveFieldWeights(overrides: Partial<SymbolBm25FieldWeights> = {}): SymbolBm25FieldWeights {\n  return {\n    name: overrides.name ?? SYMBOL_BM25_FIELD_WEIGHTS.name,\n    fqName: overrides.fqName ?? SYMBOL_BM25_FIELD_WEIGHTS.fqName,\n    signature: overrides.signature ?? SYMBOL_BM25_FIELD_WEIGHTS.signature,\n    docstring: overrides.docstring ?? SYMBOL_BM25_FIELD_WEIGHTS.docstring,\n    filePath: overrides.filePath ?? SYMBOL_BM25_FIELD_WEIGHTS.filePath,\n  };\n}\n\nexport function isCodeGraphBm25SymbolResolverEnabled(env: NodeJS.ProcessEnv = process.env): boolean {\n  const value = env[CODE_GRAPH_BM25_SYMBOL_RESOLVER_ENV]?.trim().toLowerCase();\n  return value ? ENABLED_VALUES.has(value) : false;\n}\n\nfunction splitIdentifier(value: string): string[] {\n  return value\n    .replace(/([a-z0-9])([A-Z])/g, '$1 $2')\n    .replace(/([A-Z]+)([A-Z][a-z])/g, '$1 $2')\n    .toLowerCase()\n    .split(/[^a-z0-9]+/)\n    .filter((token) => token.length >= 2);\n}\n\nfunction trigrams(token: string): string[] {\n  if (token.length < 4) return [];\n  const grams: string[] = [];\n  for (let index = 0; index <= token.length - 3; index += 1) {\n    grams.push(`tri:${token.slice(index, index + 3)}`);\n  }\n  return grams;\n}\n\nfunction tokenize(value: string | null | undefined): string[] {\n  if (!value) return [];\n  const baseTokens = splitIdentifier(value);\n  return baseTokens.flatMap((token) => [token, ...trigrams(token)]);\n}\n\nfunction documentFields(document: SymbolBm25Document): Record<SymbolBm25FieldName, readonly string[]> {\n  return {\n    name: [document.name ?? ''],\n    fqName: [document.fqName ?? ''],\n    signature: [document.signature ?? ''],\n    docstring: [document.docstring ?? ''],\n    filePath: [document.filePath ?? ''],\n  };\n}\n\nfunction fieldTermFrequencies(document: SymbolBm25Document): Map<string, FieldTermFrequency> {\n  const frequencies = new Map<string, FieldTermFrequency>();\n  for (const fieldName of SYMBOL_BM25_FIELD_NAMES) {\n    for (const value of documentFields(document)[fieldName]) {\n      for (const token of tokenize(value)) {\n        let frequency = frequencies.get(token);\n        if (!frequency) {\n          frequency = emptyFieldFrequency();\n          frequencies.set(token, frequency);\n        }\n        frequency.total += 1;\n        frequency.fields[fieldName] += 1;\n      }\n    }\n  }\n  return frequencies;\n}\n\nfunction weightedFrequency(\n  postings: PackedPostingList,\n  index: number,\n  weights: SymbolBm25FieldWeights,\n): number {\n  return postings.nameTfs[index] * weights.name\n    + postings.fqNameTfs[index] * weights.fqName\n    + postings.signatureTfs[index] * weights.signature\n    + postings.docstringTfs[index] * weights.docstring\n    + postings.filePathTfs[index] * weights.filePath;\n}\n\nfunction topWeightedFields(\n  postings: PackedPostingList,\n  index: number,\n  weights: SymbolBm25FieldWeights,\n): SymbolBm25FieldName[] {\n  return [\n    { field: 'name' as const, value: postings.nameTfs[index] * weights.name },\n    { field: 'fqName' as const, value: postings.fqNameTfs[index] * weights.fqName },\n    { field: 'signature' as const, value: postings.signatureTfs[index] * weights.signature },\n    { field: 'filePath' as const, value: postings.filePathTfs[index] * weights.filePath },\n    { field: 'docstring' as const, value: postings.docstringTfs[index] * weights.docstring },\n  ]\n    .filter((entry) => entry.value > 0)\n    .sort((left, right) => right.value - left.value)\n    .map((entry) => entry.field)\n    .slice(0, 3);\n}\n\nexport class SymbolPackedBm25Index {\n  private readonly symbolIds: string[] = [];\n  private readonly symbolNumbersById = new Map<string, number>();\n  private readonly documents = new Map<string, PackedSymbolDocument>();\n  private readonly documentFreq = new Map<string, number>();\n  private readonly mutablePostings = new Map<string, PackedPostingMutable>();\n  private readonly packedPostings = new Map<string, PackedPostingList>();\n  private totalDocumentLength = 0;\n\n  constructor(documents: readonly SymbolBm25Document[] = []) {\n    for (const document of documents) {\n      this.addDocument(document);\n    }\n    this.finalize();\n  }\n\n  addDocument(document: SymbolBm25Document): void {\n    const frequencies = fieldTermFrequencies(document);\n    const length = Array.from(frequencies.values()).reduce((total, frequency) => total + frequency.total, 0);\n    if (length === 0) return;\n\n    const numericId = this.nextNumericId(document.symbolId);\n    this.documents.set(document.symbolId, { ...document, numericId, length });\n    this.totalDocumentLength += length;\n\n    for (const term of [...frequencies.keys()].sort()) {\n      const frequency = frequencies.get(term);\n      if (!frequency) continue;\n      this.documentFreq.set(term, (this.documentFreq.get(term) ?? 0) + 1);\n      const postings = this.ensureMutablePostings(term);\n      postings.docIds.push(numericId);\n      postings.nameTfs.push(frequency.fields.name);\n      postings.fqNameTfs.push(frequency.fields.fqName);\n      postings.signatureTfs.push(frequency.fields.signature);\n      postings.docstringTfs.push(frequency.fields.docstring);\n      postings.filePathTfs.push(frequency.fields.filePath);\n    }\n  }\n\n  finalize(): void {\n    for (const [term, postings] of this.mutablePostings.entries()) {\n      const order = postings.docIds.map((docId, index) => ({ docId, index }))\n        .sort((left, right) => left.docId - right.docId);\n      this.packedPostings.set(term, {\n        docIds: Uint32Array.from(order.map((entry) => entry.docId)),\n        nameTfs: Uint32Array.from(order.map((entry) => postings.nameTfs[entry.index])),\n        fqNameTfs: Uint32Array.from(order.map((entry) => postings.fqNameTfs[entry.index])),\n        signatureTfs: Uint32Array.from(order.map((entry) => postings.signatureTfs[entry.index])),\n        docstringTfs: Uint32Array.from(order.map((entry) => postings.docstringTfs[entry.index])),\n        filePathTfs: Uint32Array.from(order.map((entry) => postings.filePathTfs[entry.index])),\n      });\n    }\n    this.mutablePostings.clear();\n  }\n\n  search(query: string, options: SymbolBm25SearchOptions = {}): SymbolBm25Candidate[] {\n    const queryTerms = [...new Set(tokenize(query))];\n    if (queryTerms.length === 0 || this.documents.size === 0) return [];\n\n    const weights = resolveFieldWeights(options.fieldWeights);\n    const scores = new Map<number, { rawScore: number; evidence: string[] }>();\n    const averageLength = Math.max(this.totalDocumentLength / this.documents.size, 1);\n\n    for (const term of queryTerms) {\n      const postings = this.packedPostings.get(term);\n      if (!postings) continue;\n      const idf = this.idf(term);\n      for (let index = 0; index < postings.docIds.length; index += 1) {\n        const numericId = postings.docIds[index];\n        const symbolId = this.symbolIds[numericId];\n        const document = symbolId ? this.documents.get(symbolId) : undefined;\n        if (!document) continue;\n        const weightedTf = weightedFrequency(postings, index, weights);\n        if (weightedTf <= 0) continue;\n\n        const termScore = idf * ((weightedTf * (BM25_K1 + 1))\n          / (weightedTf + BM25_K1 * (1 - BM25_B + BM25_B * (document.length / averageLength))));\n        const existing = scores.get(numericId) ?? { rawScore: 0, evidence: [] };\n        existing.rawScore += termScore;\n        if (existing.evidence.length < 6) {\n          existing.evidence.push(`bm25:${term}`);\n          for (const field of topWeightedFields(postings, index, weights)) {\n            if (existing.evidence.length >= 6) break;\n            existing.evidence.push(`field:${field}`);\n          }\n        }\n        scores.set(numericId, existing);\n      }\n    }\n\n    const matches = [...scores.entries()]\n      .flatMap(([numericId, result]) => {\n        const symbolId = this.symbolIds[numericId];\n        const document = symbolId ? this.documents.get(symbolId) : undefined;\n        if (!document) return [];\n        return [{\n          symbolId: document.symbolId,\n          fqName: document.fqName,\n          name: document.name,\n          kind: document.kind,\n          filePath: document.filePath,\n          startLine: document.startLine,\n          rawScore: Number(result.rawScore.toFixed(6)),\n          score: Number((result.rawScore / (result.rawScore + 4)).toFixed(6)),\n          evidence: result.evidence,\n          disambiguationOnly: true,\n        } satisfies SymbolBm25Candidate];\n      })\n      .filter((match) => match.score > 0);\n\n    return matches\n      .sort((left, right) => right.score - left.score\n        || (left.filePath ?? '').localeCompare(right.filePath ?? '')\n        || (left.startLine ?? Number.MAX_SAFE_INTEGER) - (right.startLine ?? Number.MAX_SAFE_INTEGER)\n        || left.symbolId.localeCompare(right.symbolId))\n      .slice(0, options.limit ?? DEFAULT_LIMIT);\n  }\n\n  getFootprintStats(): SymbolBm25FootprintStats {\n    let postingCount = 0;\n    let typedArrayBytes = 0;\n    for (const postings of this.packedPostings.values()) {\n      postingCount += postings.docIds.length;\n      typedArrayBytes += postings.docIds.byteLength\n        + postings.nameTfs.byteLength\n        + postings.fqNameTfs.byteLength\n        + postings.signatureTfs.byteLength\n        + postings.docstringTfs.byteLength\n        + postings.filePathTfs.byteLength;\n    }\n    return {\n      documentCount: this.documents.size,\n      termCount: this.packedPostings.size,\n      postingCount,","lineStart":1,"lineEnd":340,"totalLines":382,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/lib/symbol-bm25-resolver.ts","time":{"start":1781128791424,"end":1781128791428}},"metadata":{"openai":{"itemId":"fc_02edcf03c0b9c56d016a29de574c988191a6efb96a5d50c2aa"}},"id":"prt_eb38c857f001t3EtCnGUVKusv2","sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","messageID":"msg_eb38c58ec001EvkU1mZu1DUHyY"}}
