   334	export function scoreAdvisorPrompt(prompt: string, options: AdvisorScoringOptions): AdvisorScoringResult {
   335	  const projection = options.projection ?? loadAdvisorProjection(options.workspaceRoot);
   336	  const weights = effectiveScorerWeights(options.laneWeightsOverride);
   337	  const disabled = new Set(options.disabledLanes ?? []);
   338	  const affordances = normalize(options.affordances ?? []);
   339	  const laneScores = buildLaneScores(prompt, projection, disabled, affordances);
   340	  const laneScoreIndexes = Object.fromEntries(
   341	    SCORER_LANES.map((lane) => [lane, buildLaneMatchIndex(laneScores[lane])]),
   342	  ) as Record<ScorerLane, LaneMatchIndex>;
   343	  const liveTotal = SCORER_LANES
   344	    .filter((lane) => !disabled.has(lane))
   345	    .reduce((total, lane) => isLiveScorerLane(lane) ? total + weights[lane] : total, 0) || liveWeightTotal();
   346	  if (isSpeckitMetricsEnabled() && liveTotal > 0) {
   347	    for (const lane of SCORER_LANES) {
   348	      if (!isLiveScorerLane(lane) || disabled.has(lane)) continue;
   349	      speckitMetrics.setGauge('spec_kit.scorer.fusion_live_weight_share', weights[lane] / liveTotal, { lane });
   350	    }
   351	  }
   352	  const promptLower = prompt.toLowerCase();
   353	  const readOnlyExplainer = isReadOnlyExplainer(promptLower);
   354	  const hasTaskIntent = TASK_INTENT.test(promptLower);
   355	  const recommendations: AdvisorScoredRecommendation[] = [];

