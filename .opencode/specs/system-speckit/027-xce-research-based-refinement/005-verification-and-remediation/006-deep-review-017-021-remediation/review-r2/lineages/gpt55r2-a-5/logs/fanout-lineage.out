{"type":"tool_use","timestamp":1781762535741,"sessionID":"ses_126affd45ffeTNBTsc65PNhoaD","part":{"type":"tool","tool":"read","callID":"call_6I7951gVS4sYypGQjyN9JqVn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts","offset":240,"limit":115},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts</path>\n<type>file</type>\n<content>\n240:       limit: { type: 'number', default: 10, minimum: 1, maximum: 100, description: 'Maximum number of results to return (1-100)' },\n241:       sessionId: {\n242:         type: 'string',\n243:         description: 'Session identifier for working memory and session deduplication (REQ-001). When provided with enableDedup=true, prevents duplicate spec-doc records from being returned in the same session (~50% token savings on follow-up queries).'\n244:       },\n245:       enableDedup: {\n246:         type: 'boolean',\n247:         default: true,\n248:         description: 'Enable session deduplication (REQ-001). When true and sessionId provided, filters out already-sent spec-doc records.'\n249:       },\n250:       tier: { type: 'string', description: 'Filter by importance tier (constitutional, critical, important, normal, temporary, deprecated)' },\n251:       contextType: { type: 'string', description: 'Filter by context type (decision, implementation, research, etc.)' },\n252:       useDecay: { type: 'boolean', default: true, description: 'Apply temporal decay scoring to results' },\n253:       includeContiguity: { type: 'boolean', default: false, description: 'Include adjacent/contiguous spec-doc records (from the same packet, neighboring sections) in results' },\n254:       includeConstitutional: {\n255:         type: 'boolean',\n256:         default: true,\n257:         description: 'Include constitutional tier rules at top of results (default: true)'\n258:       },\n259:       enableSessionBoost: {\n260:         type: 'boolean',\n261:         description: 'Enable session-based score boost from working_memory attention signals. Defaults to SPECKIT_SESSION_BOOST env flag.'\n262:       },\n263:       enableCausalBoost: {\n264:         type: 'boolean',\n265:         description: 'Enable causal-neighbor boost (2-hop traversal on causal_edges). Defaults to SPECKIT_CAUSAL_BOOST env flag.'\n266:       },\n267:       includeContent: {\n268:         type: 'boolean',\n269:         default: false,\n270:         description: 'Include full file content in results. When true, each result includes a \"content\" field with the spec-doc file contents. This embeds load logic directly in search, eliminating the need for separate load calls. When implicit feedback logging is enabled, includeContent searches also emit shadow-only result_cited events for returned spec-doc records.'\n271:       },\n272:       anchors: {\n273:         type: 'array',\n274:         items: { type: 'string' },\n275:         description: 'Specific anchor IDs to extract from content. If provided, returned content will be filtered to only these sections. Requires includeContent: true.'\n276:       },\n277:       profile: {\n278:         type: 'string',\n279:         enum: ['quick', 'research', 'resume', 'debug'],\n280:         description: 'Optional response profile formatter. Returns a reduced or mode-aware response shape when profile formatting is enabled.'\n281:       },\n282:       min_quality_score: {\n283:         type: 'number',\n284:         minimum: 0,\n285:         maximum: 1,\n286:         description: 'Minimum quality score threshold (0.0-1.0). Results with lower quality_score are filtered out.'\n287:       },\n288:       minQualityScore: {\n289:         type: 'number',\n290:         minimum: 0,\n291:         maximum: 1,\n292:         description: 'Deprecated alias for min_quality_score. Prefer snake_case parameter name.'\n293:       },\n294:       bypassCache: {\n295:         type: 'boolean',\n296:         default: false,\n297:         description: 'Skip the tool cache and force a fresh search. Useful when underlying data has changed since last cached result.'\n298:       },\n299:       rerank: {\n300:         type: 'boolean',\n301:         default: true,\n302:         description: 'Enable Stage-3 MMR diversity reranking (reduces near-duplicate results) plus MPAB chunk collapse. Default true.'\n303:       },\n304:       applyLengthPenalty: {\n305:         type: 'boolean',\n306:         default: true,\n307:         description: 'Apply length-based penalty during reranking. Penalizes very long spec-doc records to favor concise, focused results. Only effective when rerank is true.'\n308:       },\n309:       applyStateLimits: {\n310:         type: 'boolean',\n311:         default: false,\n312:         description: 'Apply per-tier quantity limits to results. When true, enforces maximum counts per state tier to balance result diversity.'\n313:       },\n314:       minState: {\n315:         type: 'string',\n316:         enum: ['HOT', 'WARM', 'COLD', 'DORMANT', 'ARCHIVED'],\n317:         default: 'WARM',\n318:         description: 'Minimum spec-doc record state to include in results. Records below this state are filtered out. Order: HOT > WARM > COLD > DORMANT > ARCHIVED.'\n319:       },\n320:       intent: {\n321:         type: 'string',\n322:         enum: ['add_feature', 'fix_bug', 'refactor', 'security_audit', 'understand', 'find_spec', 'find_decision'],\n323:         description: 'Task intent for weight adjustments (REQ-006). Explicitly set query intent to optimize scoring for specific tasks.'\n324:       },\n325:       autoDetectIntent: {\n326:         type: 'boolean',\n327:         default: true,\n328:         description: 'Auto-detect intent from query if not explicitly specified. When true, classifies query to apply task-specific scoring weights.'\n329:       },\n330:    