   320	 * Render a prompt-safe advisor brief from recommendation data.
   321	 *
   322	 * @param {object} result - Advisor result payload.
   323	 * @param {object} [options={}] - Rendering options and threshold config.
   324	 * @returns {string|null} Compact advisor brief, or null when unavailable.
   325	 */
   326	function renderAdvisorBrief(result, options = {}) {
   327	  if (result.status !== 'ok') return null;
   328	  if (result.freshness !== 'live' && result.freshness !== 'stale') return null;
   329	
   330	  const tokenCap = Math.min(Math.max(1, positiveInt(result.metrics?.tokenCap ?? options.tokenCap, 80)), 120);
   331	  const thresholdConfig = options.thresholdConfig ?? {};
   332	  const recommendations = Array.isArray(result.recommendations)
   333	    ? result.recommendations.filter((recommendation) => (
   334	      recommendation.passes_threshold === true
   335	      || (
   336	        recommendation.confidence >= (thresholdConfig.confidenceThreshold ?? DEFAULT_CONFIDENCE_THRESHOLD)
   337	        && (
   338	          thresholdConfig.confidenceOnly === true
   339	          || recommendation.uncertainty <= (thresholdConfig.uncertaintyThreshold ?? DEFAULT_UNCERTAINTY_THRESHOLD)
   340	        )
   341	      )
   342	    ))
   343	    : [];
   344	  const top = recommendations[0];
   345	  const second = recommendations[1];
   346	  if (!top) return null;
   347	
   348	  const topLabel = sanitizeLabel(result.sharedPayload?.metadata?.skillLabel ?? top.skill);
   349	  if (!topLabel) return null;
   350	  if (tokenCap > 80 && second && hasPrecomputedAmbiguity(result, recommendations)) {
   351	    const secondLabel = sanitizeLabel(second.skill);
   352	    if (!secondLabel) return null;
   353	    const text = `Advisor: ${result.freshness}; ambiguous: ${topLabel} ${formatScore(top.confidence)}/${formatScore(top.uncertainty)} vs ${secondLabel} ${formatScore(second.confidence)}/${formatScore(second.uncertainty)} pass.`;
   354	    const charCap = Math.min(tokenCap, 120) * 4;
   355	    const brief = text.length <= charCap ? text : `${text.slice(0, Math.max(1, charCap - 3)).trimEnd()}...`;
   356	    return brief + HYGIENE_DIRECTIVE + GOVERNOR_DIRECTIVE;
   357	  }
   358	  const text = `Advisor: ${result.freshness}; use ${topLabel} ${formatScore(top.confidence)}/${formatScore(top.uncertainty)} pass.`;
   359	  const charCap = Math.min(tokenCap, 80) * 4;
   360	  const brief = text.length <= charCap ? text : `${text.slice(0, Math.max(1, charCap - 3)).trimEnd()}...`;
   361	  return brief + HYGIENE_DIRECTIVE + GOVERNOR_DIRECTIVE;
   362	}
