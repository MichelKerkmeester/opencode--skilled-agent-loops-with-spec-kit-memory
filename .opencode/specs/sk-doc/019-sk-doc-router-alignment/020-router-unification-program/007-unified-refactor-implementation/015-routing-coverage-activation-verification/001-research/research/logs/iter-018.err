   274	 * @param {Object} [opts] - Parse options.
   275	 * @param {string} [opts.skillId] - Skill id used to detect activation/reads.
   276	 * @param {boolean} [opts.requireRouteDeclaration] - Mark route-gold misses.
   277	 * @returns observed-result consumed by score-skill-benchmark.scoreScenario
   278	 */
   279	function parseLiveResult(stdout, { skillId, requireRouteDeclaration = false } = {}) {
   280	  const events = parseEvents(stdout);
   281	  const toolCalls = [];
   282	  let activated = false;
   283	  const observedReads = [];
   284	  const textParts = [];
   285	
   286	  for (const e of events) {
   287	    const p = e && e.part;
   288	    if (e && e.type === 'text' && p && typeof p.text === 'string') textParts.push(p.text);
   289	    if (e && e.type === 'tool_use' && p && p.tool) {
   290	      const input = (p.state && p.state.input) || {};
   291	      toolCalls.push({ tool: p.tool, input });
   292	      if (p.tool === 'skill' && skillId && input.name === skillId) activated = true;
   293	      if (/^(read|glob|grep|bash)$/i.test(p.tool)) {
   294	        const blob = JSON.stringify(input);
   295	        if (skillId && blob.includes(skillId)) {
   296	          const m = blob.match(/(?:code-[a-z]+|references|assets)\/[A-Za-z0-9_./*-]+/g);
   297	          if (m) observedReads.push(...m);
