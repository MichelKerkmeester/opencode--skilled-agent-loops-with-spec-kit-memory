 failure: ${reason} (sources=${sourceFiles.length})`,\n1551:       );\n1552:       try {\n1553:         if (isSpeckitMetricsEnabled()) {\n1554:           speckitMetrics.incrementCounter(\n1555:             'spec_kit.graph.blast_radius_failure_total',\n1556:             { code: 'compute_error' },\n1557:           );\n1558:         }\n1559:       } catch (_metricErr: unknown) {\n1560:         // Best-effort: never let metric emission failures mask the original\n1561:         // Compute error.\n1562:       }\n1563:       blastRadius = {\n1564:         sourceFiles,\n1565:         nodes: sourceFiles.map((filePath) => ({ filePath, depth: 0, isSeed: true })),\n1566:         affectedFiles: [],\n1567:         depthGroups,\n1568:         riskLevel: classifyBlastRadiusRisk(depthGroups, ambiguityCandidates),\n1569:         minConfidence,\n1570:         ambiguityCandidates,\n1571:         hotFileBreadcrumbs: [],\n1572:         failureFallback: {\n1573:           reason,\n1574:           code: 'compute_error',\n1575:           partialResult: buildPartialBlastRadiusResult(sourceFiles, [], [], depthGroups),\n1576:         } satisfies BlastRadiusFailureFallback,\n1577:       };\n1578:     }\n1579:     return {\n1580:       content: [{\n1581:         type: 'text',\n1582:         text: JSON.stringify({\n1583:           status: 'ok',\n1584:           data: buildGraphQueryPayload({\n1585:             operation,\n1586:             sourceFiles: blastRadius.sourceFiles,\n1587:             nodes: blastRadius.nodes,\n1588:             multiFileUnion: args.unionMode === 'multi' && blastRadius.sourceFiles.length > 1,\n1589:             unionMode: args.unionMode ?? 'single',\n1590:             maxDepth: Math.max(0, effectiveDepth),\n1591:             affectedFiles: blastRadius.affectedFiles,\n1592:             depthGroups: blastRadius.depthGroups,\n1593:             riskLevel: blastRadius.riskLevel,\n1594:             minConfidence: blastRadius.minConfidence,\n1595:             ambiguityCandidates: blastRadius.ambiguityCandidates,\n1596:             ...(blastRadius.failureFallback ? { failureFallback: blastRadius.failureFallback } : {}),\n1597:             // Propagate the depth-completeness signal so callers can tell the\n1598:             // BFS stopped at `maxDepth` with dependents still unexplored,\n1599:             // distinct from the count-based `failureFallback` overflow.\n1600:             ...('depthTruncated' in blastRadius && blastRadius.depthTruncated\n1601:               ? { depthTruncated: true }\n1602:               : {}),\n1603:             hotFileBreadcrumbs: blastRadius.hotFileBreadcrumbs,\n1604:           }, readiness, 'code_graph_query blast_radius payload'),\n1605:         }, null, 2),\n1606:       }],\n1607:     };\n1608:   }\n1609: \n1610:   if (!isSupportedRelationshipOperation(operation)) {\n1611:     return buildUnknownOperationResponse(operation);\n1612:   }\n1613: \n1614:   const relationshipFilePath = resolveRelationshipFilePath(subject);\n1615:   if (relationshipFilePath) {\n1616:     const symbols = queryRelationshipFileSymbols(relationshipFilePath);\n1617:     const { result, edgeEnrichment } = graphDb.getDb().transaction(() => relationshipFilePayload({\n1618:       operation,\n1619:       filePath: relationshipFilePath,\n1620:       symbols,\n1621:       edgeType: requestedEdgeType,\n1622:       limit,\n1623:     }))();\n1624: \n1625:     return {\n1626:       content: [{\n1627:         type: 'text',\n1628:         text: JSON.stringify({\n1629:           status: 'ok',\n1630:           data: buildGraphQueryPayload(\n1631:             result,\n1632:             readiness,\n1633:             `code_graph_query ${operation} file-path payload`,\n1634:             edgeEnrichment,\n1635:           ),\n1636:         }, null, 2),\n1637:       }],\n1638:     };\n1639:   }\n1640: \n1641:   const resolvedSubject = resolveSubject(subject, operation, requestedEdgeType);\n1642:   const symbolId = resolvedSubject.symbolId;\n1643:   if (!symbolId) {\n1644:     return {\n1645:       content: [{\n1646:         type: 'text',\n1647:         text: JSON.stringify(buildUnresolvedSubjectError(subject, resolvedSubject.suggestions ?? [])),\n1648:       }],\n1649:     };\n1650:   }\n1651: \n1652:   // If includeTransitive, use BFS traversal instead of 1-hop\n1653:   if (args.includeTransitive) {\n1654:     const direction = operation.endsWith('from') ? 'from' : 'to';\n1655:     // Wrap the BFS multi-SELECT traversal in a snapshot-stable read\n1656:     // transaction so a concurrent index pass cannot shift the result set\n1657:     // between the per-depth queries. better-sqlite3 transactions in WAL mode\n1658:     // observe a consistent snapshot for the lifetime of the transaction.\n1659:     const transitive = graphDb.getDb().transaction(() => transitiveTraversal(\n1660:       symbolId,\n1661:       requestedEdgeType ?? 'CALLS',\n1662:       direction,\n1663:       maxDepth,\n1664:       limit,\n1665:       operation,\n1666:     ))();\n1667:     const warnings = mergeWarnings(resolvedSubject.warnings, transitive.warnings);\n1668:     return {\n1669:       content: [{\n1670:         type: 'text',\n1671:         text: JSON.stringify({\n1672:           status: 'ok',\n1673:           data: buildGraphQueryPayload({\n1674:             operation,\n1675:             symbolId,\n1676:             ...(resolvedSubject.selectedCandidate ? { selectedCandidate: resolvedSubject.selectedCandidate } : {}),\n1677:             edgeType: requestedEdgeType,\n1678:             transitive: true,\n1679:             maxDepth,\n1680:             ...(warnings ? { warnings } : {}),\n1681:             nodes: transitive.nodes,\n1682:           }, readiness, `code_graph_query ${operation} payload`),\n1683:         }, null, 2),\n1684:       }],\n1685:     };\n1686:   }\n1687: \n1688:   let result;\n1689:   switch (operation) {\n1690:     // 4 near-duplicate switch branches collapsed via the shared\n1691:     // `mapOutboundRelationshipEdge` / `mapInboundRelationshipEdge` helpers.\n1692:     // Variation surface: (1) direction (outbound / inbound), (2) whether the\n1693:     // start line is included (calls_*) or omitted (imports_*).\n1694:     case 'calls_from':\n1695:     case 'imports_from': {\n1696:       const includeLine = operation === 'calls_from';\n1697:       // Snapshot-stable read transaction. queryEdgesFrom issues the edge\n1698:       // lookup AND a per-edge node lookup; wrapping in a transaction\n1699:       // ensures both observe a consistent snapshot under concurrent writers.\n1700:       const edges = graphDb.getDb().transaction(\n1701:         () => graphDb.queryEdgesFrom(symbolId, requestedEdgeType),\n1702:       )();\n1703:       const { resolvedEntries, warnings } = excludeDanglingEdges(\n1704:         edges,\n1705:         limit,\n1706:         operation,\n1707:         'target',\n1708:         (entry: OutboundEdgeEntry) => entry.targetNode != null,\n1709:         (entry: OutboundEdgeEntry) => entry.edge.targetId,\n1710:       );\n1711:       result = {\n1712:         operation,\n1713:         symbolId,\n1714:         ...(resolvedSubject.selectedCandidate ? { selectedCandidate: resolvedSubject.selectedCandidate } : {}),\n1715:         edgeType: requestedEdgeType,\n1716:         edges: resolvedEntries.map((entry) => mapOutboundRelationshipEdge(entry, { includeLine })),\n1717:         ...(warnings ? { warnings } : {}),\n1718:         hotFileBreadcrumbs: buildHotFileBreadcrumbs(extractOutboundFilePaths(resolvedEntries)),\n1719:       };\n1720:       break;\n1721:     }\n1722:     case 'calls_to':\n1723:     case 'imports_to': {\n1724:       const includeLine = operation === 'calls_to';\n1725:       // Snapshot-stable read transaction (see calls_from above).\n1726:       const edges = graphDb.getDb().transaction(\n1727:         () => graphDb.queryEdgesTo(symbolId, requestedEdgeType),\n1728:       )();\n1729:       const { resolvedEntries, warnings } = excludeDanglingEdges(\n1730:         edges,\n1731:         limit,\n1732:         operation,\n1733:         'source',\n1734:         (entry: InboundEdgeEntry) => entry.sourceNode != null,\n1735:         (entry: InboundEdgeEntry) => entry.edge.sourceId,\n1736:       );\n1737:       result = {\n1738:         operation,\n1739:         symbolId,\n1740:         ...(resolvedSubject.selectedCandidate ? { selectedCandidate: resolvedSubject.selectedCandidate } : {}),\n1741:         edgeType: requestedEdgeType,\n1742:         edges: resolvedEntries.map((entry) => mapInboundRelationshipEdge(entry, { includeLine })),\n1743:         ...(warnings ? { warnings } : {}),\n1744:         hotFileBreadcrumbs: buildHotFileBreadcrumbs(extractInboundFilePaths(resolvedEntries)),\n1745:       };\n1746:       break;\n1747:     }\n1748:     default:\n1749:       return buildUnknownOperationResponse(operation);\n1750:   }\n1751: \n1752:   const warnings = mergeWarnings(resolvedSubject.warnings, result.warnings);\n1753: \n1754:   return {\n1755:     content: [{\n1756:       type: 'text',\n1757:       text: JSON.stringify({\n1758:         status: 'ok',\n1759:         data: buildGraphQueryPayload({\n1760:           ...result,\n1761:           ...(warnings ? { warnings } : {}),\n1762:         }, readiness, `code_graph_query ${operation} payload`, summarizeWeakestGraphEdgeEnrichment(result.edges)),\n1763:       }, null, 2),\n1764:     }],\n1765:   };\n1766: }\n\n(End of file - total 1766 lines)\n</content>","metadata":{"preview":"              minConfidence,\n              ambiguityCandidates: [],\n              failureFallback: {\n                reason: `Could not resolve blast-radius sources: ${rawSubjects.join(', ')}`,\n                code: 'empty_source',\n                partialResult: buildPartialBlastRadiusResult(sourceFiles, [], [], depthGroups),\n              } satisfies BlastRadiusFailureFallback,\n            }, readiness, 'code_graph_query blast_radius empty-source payload'),\n          }, null, 2),\n        }],\n      };\n    }\n\n    let blastRadius;\n    try {\n      blastRadius = graphDb.getDb().transaction(() => computeBlastRadius(\n        sourceFiles,\n        effectiveDepth,\n        limit,\n        minConfidence,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/handlers/query.ts","text":"              minConfidence,\n              ambiguityCandidates: [],\n              failureFallback: {\n                reason: `Could not resolve blast-radius sources: ${rawSubjects.join(', ')}`,\n                code: 'empty_source',\n                partialResult: buildPartialBlastRadiusResult(sourceFiles, [], [], depthGroups),\n              } satisfies BlastRadiusFailureFallback,\n            }, readiness, 'code_graph_query blast_radius empty-source payload'),\n          }, null, 2),\n        }],\n      };\n    }\n\n    let blastRadius;\n    try {\n      blastRadius = graphDb.getDb().transaction(() => computeBlastRadius(\n        sourceFiles,\n        effectiveDepth,\n        limit,\n        minConfidence,\n        ambiguityCandidates,\n        args.includeTrace === true,\n      ))();\n    } catch (error) {\n      const depthGroups = buildDepthGroups([], effectiveDepth);\n      const reason = error instanceof Error ? error.message : String(error);\n      // Surface a stable `code` and emit a warning log + metric so operators\n      // can distinguish a genuine compute / DB failure from a\n      // legitimately empty blast radius (which has no failureFallback).\n      console.warn(\n        `[code-graph-query] blast_radius compute failure: ${reason} (sources=${sourceFiles.length})`,\n      );\n      try {\n        if (isSpeckitMetricsEnabled()) {\n          speckitMetrics.incrementCounter(\n            'spec_kit.graph.blast_radius_failure_total',\n            { code: 'compute_error' },\n          );\n        }\n      } catch (_metricErr: unknown) {\n        // Best-effort: never let metric emission failures mask the original\n        // Compute error.\n      }\n      blastRadius = {\n        sourceFiles,\n        nodes: sourceFiles.map((filePath) => ({ filePath, depth: 0, isSeed: true })),\n        affectedFiles: [],\n        depthGroups,\n        riskLevel: classifyBlastRadiusRisk(depthGroups, ambiguityCandidates),\n        minConfidence,\n        ambiguityCandidates,\n        hotFileBreadcrumbs: [],\n        failureFallback: {\n          reason,\n          code: 'compute_error',\n          partialResult: buildPartialBlastRadiusResult(sourceFiles, [], [], depthGroups),\n        } satisfies BlastRadiusFailureFallback,\n      };\n    }\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify({\n          status: 'ok',\n          data: buildGraphQueryPayload({\n            operation,\n            sourceFiles: blastRadius.sourceFiles,\n            nodes: blastRadius.nodes,\n            multiFileUnion: args.unionMode === 'multi' && blastRadius.sourceFiles.length > 1,\n            unionMode: args.unionMode ?? 'single',\n            maxDepth: Math.max(0, effectiveDepth),\n            affectedFiles: blastRadius.affectedFiles,\n            depthGroups: blastRadius.depthGroups,\n            riskLevel: blastRadius.riskLevel,\n            minConfidence: blastRadius.minConfidence,\n            ambiguityCandidates: blastRadius.ambiguityCandidates,\n            ...(blastRadius.failureFallback ? { failureFallback: blastRadius.failureFallback } : {}),\n            // Propagate the depth-completeness signal so callers can tell the\n            // BFS stopped at `maxDepth` with dependents still unexplored,\n            // distinct from the count-based `failureFallback` overflow.\n            ...('depthTruncated' in blastRadius && blastRadius.depthTruncated\n              ? { depthTruncated: true }\n              : {}),\n            hotFileBreadcrumbs: blastRadius.hotFileBreadcrumbs,\n          }, readiness, 'code_graph_query blast_radius payload'),\n        }, null, 2),\n      }],\n    };\n  }\n\n  if (!isSupportedRelationshipOperation(operation)) {\n    return buildUnknownOperationResponse(operation);\n  }\n\n  const relationshipFilePath = resolveRelationshipFilePath(subject);\n  if (relationshipFilePath) {\n    const symbols = queryRelationshipFileSymbols(relationshipFilePath);\n    const { result, edgeEnrichment } = graphDb.getDb().transaction(() => relationshipFilePayload({\n      operation,\n      filePath: relationshipFilePath,\n      symbols,\n      edgeType: requestedEdgeType,\n      limit,\n    }))();\n\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify({\n          status: 'ok',\n          data: buildGraphQueryPayload(\n            result,\n            readiness,\n            `code_graph_query ${operation} file-path payload`,\n            edgeEnrichment,\n          ),\n        }, null, 2),\n      }],\n    };\n  }\n\n  const resolvedSubject = resolveSubject(subject, operation, requestedEdgeType);\n  const symbolId = resolvedSubject.symbolId;\n  if (!symbolId) {\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify(buildUnresolvedSubjectError(subject, resolvedSubject.suggestions ?? [])),\n      }],\n    };\n  }\n\n  // If includeTransitive, use BFS traversal instead of 1-hop\n  if (args.includeTransitive) {\n    const direction = operation.endsWith('from') ? 'from' : 'to';\n    // Wrap the BFS multi-SELECT traversal in a snapshot-stable read\n    // transaction so a concurrent index pass cannot shift the result set\n    // between the per-depth queries. better-sqlite3 transactions in WAL mode\n    // observe a consistent snapshot for the lifetime of the transaction.\n    const transitive = graphDb.getDb().transaction(() => transitiveTraversal(\n      symbolId,\n      requestedEdgeType ?? 'CALLS',\n      direction,\n      maxDepth,\n      limit,\n      operation,\n    ))();\n    const warnings = mergeWarnings(resolvedSubject.warnings, transitive.warnings);\n    return {\n      content: [{\n        type: 'text',\n        text: JSON.stringify({\n          status: 'ok',\n          data: buildGraphQueryPayload({\n            operation,\n            symbolId,\n            ...(resolvedSubject.selectedCandidate ? { selectedCandidate: resolvedSubject.selectedCandidate } : {}),\n            edgeType: requestedEdgeType,\n            transitive: true,\n            maxDepth,\n            ...(warnings ? { warnings } : {}),\n            nodes: transitive.nodes,\n          }, readiness, `code_graph_query ${operation} payload`),\n        }, null, 2),\n      }],\n    };\n  }\n\n  let result;\n  switch (operation) {\n    // 4 near-duplicate switch branches collapsed via the shared\n    // `mapOutboundRelationshipEdge` / `mapInboundRelationshipEdge` helpers.\n    // Variation surface: (1) direction (outbound / inbound), (2) whether the\n    // start line is included (calls_*) or omitted (imports_*).\n    case 'calls_from':\n    case 'imports_from': {\n      const includeLine = operation === 'calls_from';\n      // Snapshot-stable read transaction. queryEdgesFrom issues the edge\n      // lookup AND a per-edge node lookup; wrapping in a transaction\n      // ensures both observe a consistent snapshot under concurrent writers.\n      const edges = graphDb.getDb().transaction(\n        () => graphDb.queryEdgesFrom(symbolId, requestedEdgeType),\n      )();\n      const { resolvedEntries, warnings } = excludeDanglingEdges(\n        edges,\n        limit,\n        operation,\n        'target',\n        (entry: OutboundEdgeEntry) => entry.targetNode != null,\n        (entry: OutboundEdgeEntry) => entry.edge.targetId,\n      );\n      result = {\n        operation,\n        symbolId,\n        ...(resolvedSubject.selectedCandidate ? { selectedCandidate: resolvedSubject.selectedCandidate } : {}),\n        edgeType: requestedEdgeType,\n        edges: resolvedEntries.map((entry) => mapOutboundRelationshipEdge(entry, { includeLine })),\n        ...(warnings ? { warnings } : {}),\n        hotFileBreadcrumbs: buildHotFileBreadcrumbs(extractOutboundFilePaths(resolvedEntries)),\n      };\n      break;\n    }\n    case 'calls_to':\n    case 'imports_to': {\n      const includeLine = operation === 'calls_to';\n      // Snapshot-stable read transaction (see calls_from above).\n      const edges = graphDb.getDb().transaction(\n        () => graphDb.queryEdgesTo(symbolId, requestedEdgeType),\n      )();\n      const { resolvedEntries, warnings } = excludeDanglingEdges(\n        edges,\n        limit,\n        operation,\n        'source',\n        (entry: InboundEdgeEntry) => entry.sourceNode != null,\n        (entry: InboundEdgeEntry) => entry.edge.sourceId,\n      );\n      result = {\n        operation,\n        symbolId,\n        ...(resolvedSubject.selectedCandidate ? { selectedCandidate: resolvedSubject.selectedCandidate } : {}),\n        edgeType: requestedEdgeType,\n        edges: resolvedEntries.map((entry) => mapInboundRelationshipEdge(entry, { includeLine })),\n        ...(warnings ? { warnings } : {}),\n        hotFileBreadcrumbs: buildHotFileBreadcrumbs(extractInboundFilePaths(resolvedEntries)),\n      };\n      break;\n    }\n    default:\n      return buildUnknownOperationResponse(operation);\n  }\n\n  const warnings = mergeWarnings(resolvedSubject.warnings, result.warnings);\n\n  return {\n    content: [{\n      type: 'text',\n      text: JSON.stringify({\n        status: 'ok',\n        data: buildGraphQueryPayload({\n          ...result,\n          ...(warnings ? { warnings } : {}),\n        }, readiness, `code_graph_query ${operation} payload`, summarizeWeakestGraphEdgeEnrichment(result.edges)),\n      }, null, 2),\n    }],\n  };\n}","lineStart":1520,"lineEnd":1766,"totalLines":1766,"truncated":false}},"title":".opencode/skills/system-code-graph/mcp_server/handlers/query.ts","time":{"start":1781129284238,"end":1781129284242}},"metadata":