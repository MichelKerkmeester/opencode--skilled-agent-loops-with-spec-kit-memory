enhanced_search,\n124:   cachedSearch,\n125:   clearSearchCache,\n126:   learnFromSelection,\n127:   linkRelatedOnSave,\n128:   recordAccess,\n129:   enhancedSearch,\n130:   getCacheKey,\n131: } from './vector-index-aliases.js';\n132: \n133: // Re-export store items that aren't re-exported by other modules\n134: export {\n135:   initializeDb,\n136:   initialize_db,\n137:   checkpointAllWal,\n138:   closeDb,\n139:   close_db,\n140:   getDb,\n141:   get_db,\n142:   tryGetDb,\n143:   try_get_db,\n144:   getDbPath,\n145:   get_db_path,\n146:   clearConstitutionalCache,\n147:   validateFilePath,\n148:   isVectorSearchAvailable,\n149:   getConfirmedEmbeddingDimension,\n150:   getEmbeddingDim,\n151:   validateEmbeddingDimension,\n152:   EMBEDDING_DIM,\n153:   DEFAULT_DB_PATH,\n154:   search_weights,\n155:   safe_read_file_async,\n156:   safe_parse_json,\n157:   validate_file_path_local,\n158:   get_embedding_dim,\n159:   get_confirmed_embedding_dimension,\n160:   validate_embedding_dimension,\n161:   is_vector_search_available,\n162:   clear_constitutional_cache,\n163:   get_constitutional_memories,\n164:   init_prepared_statements,\n165:   clear_prepared_statements,\n166:   refresh_interference_scores_for_folder,\n167:   sqlite_vec_available,\n168:   activeVectorSource,\n169:   getActiveVectorSource,\n170:   attachActiveVectorShard,\n171:   detachActiveVectorShard,\n172:   attachActiveVectorShardForActiveProfile,\n173: } from './vector-index-store.js';\n174: \n175: // Snake_case aliases for store exports used by legacy callers\n176: export {\n177:   isVectorSearchAvailable as is_vector_search_available_alias,\n178: } from './vector-index-store.js';\n\n(End of file - total 178 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Backward-compatible export surface across split modules.\n\nexport {\n  BetterSqliteVectorStore,\n  BetterSqliteVectorStore as SQLiteVectorStore,\n} from '../storage/ports/vector-store.js';\nexport {\n  MAX_TRIGGERS_PER_MEMORY,\n  to_embedding_buffer,\n  parse_trigger_phrases,\n  get_error_message,\n  get_error_code,\n} from './vector-index-types.js';\nexport type {\n  MemoryIndexRow,\n  MemoryScopeParams,","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Backward-compatible export surface across split modules.\n\nexport {\n  BetterSqliteVectorStore,\n  BetterSqliteVectorStore as SQLiteVectorStore,\n} from '../storage/ports/vector-store.js';\nexport {\n  MAX_TRIGGERS_PER_MEMORY,\n  to_embedding_buffer,\n  parse_trigger_phrases,\n  get_error_message,\n  get_error_code,\n} from './vector-index-types.js';\nexport type {\n  MemoryIndexRow,\n  MemoryScopeParams,\n  IndexMemoryParams,\n  UpdateMemoryParams,\n  VectorSearchOptions,\n  EnrichedSearchResult,\n} from './vector-index-types.js';\nexport {\n  SCHEMA_VERSION,\n  run_migrations,\n  ensure_schema_version,\n  migrate_confidence_columns,\n  ensure_canonical_file_path_support,\n  migrate_constitutional_tier,\n  create_common_indexes,\n  ensureCompanionTables,\n  create_schema,\n  ensureSchemaVersion,\n  runMigrations,\n  createSchema,\n  createCommonIndexes,\n  migrateConfidenceColumns,\n  ensureCanonicalFilePathSupport,\n  migrateConstitutionalTier,\n} from './vector-index-schema.js';\nexport {\n  index_memory,\n  index_memory_deferred,\n  update_memory,\n  delete_memory,\n  delete_memory_by_path,\n  delete_memories,\n  update_embedding_status,\n  update_confidence,\n  indexMemory,\n  indexMemoryDeferred,\n  updateMemory,\n  deleteMemory,\n  deleteMemoryByPath,\n  deleteMemories,\n  updateEmbeddingStatus,\n  updateConfidence,\n} from './vector-index-mutations.js';\nexport {\n  get_memory,\n  get_memories_by_folder,\n  get_memory_count,\n  get_status_counts,\n  get_stats,\n  vector_search,\n  get_constitutional_memories_public,\n  multi_concept_search,\n  extract_title,\n  extract_snippet,\n  extract_tags,\n  extract_date,\n  generate_query_embedding,\n  keyword_search,\n  vector_search_enriched,\n  multi_concept_search_enriched,\n  multi_concept_keyword_search,\n  parse_quoted_terms,\n  apply_smart_ranking,\n  apply_diversity,\n  get_related_memories,\n  get_usage_stats,\n  find_cleanup_candidates,\n  get_memory_preview,\n  verify_integrity,\n  getMemory,\n  getMemoriesByFolder,\n  getMemoryCount,\n  getStatusCounts,\n  getStats,\n  vectorSearch,\n  getConstitutionalMemories,\n  multiConceptSearch,\n  extractTitle,\n  extractSnippet,\n  extractTags,\n  extractDate,\n  generateQueryEmbedding,\n  keywordSearch,\n  vectorSearchEnriched,\n  multiConceptSearchEnriched,\n  multiConceptKeywordSearch,\n  parseQuotedTerms,\n  applySmartRanking,\n  applyDiversity,\n  getRelatedMemories,\n  getUsageStats,\n  findCleanupCandidates,\n  getMemoryPreview,\n  verifyIntegrity,\n} from './vector-index-queries.js';\nexport {\n  LRUCache,\n  get_query_cache,\n  get_cache_key,\n  cached_search,\n  clear_search_cache,\n  learn_from_selection,\n  link_related_on_save,\n  record_access,\n  enhanced_search,\n  cachedSearch,\n  clearSearchCache,\n  learnFromSelection,\n  linkRelatedOnSave,\n  recordAccess,\n  enhancedSearch,\n  getCacheKey,\n} from './vector-index-aliases.js';\n\n// Re-export store items that aren't re-exported by other modules\nexport {\n  initializeDb,\n  initialize_db,\n  checkpointAllWal,\n  closeDb,\n  close_db,\n  getDb,\n  get_db,\n  tryGetDb,\n  try_get_db,\n  getDbPath,\n  get_db_path,\n  clearConstitutionalCache,\n  validateFilePath,\n  isVectorSearchAvailable,\n  getConfirmedEmbeddingDimension,\n  getEmbeddingDim,\n  validateEmbeddingDimension,\n  EMBEDDING_DIM,\n  DEFAULT_DB_PATH,\n  search_weights,\n  safe_read_file_async,\n  safe_parse_json,\n  validate_file_path_local,\n  get_embedding_dim,\n  get_confirmed_embedding_dimension,\n  validate_embedding_dimension,\n  is_vector_search_available,\n  clear_constitutional_cache,\n  get_constitutional_memories,\n  init_prepared_statements,\n  clear_prepared_statements,\n  refresh_interference_scores_for_folder,\n  sqlite_vec_available,\n  activeVectorSource,\n  getActiveVectorSource,\n  attachActiveVectorShard,\n  detachActiveVectorShard,\n  attachActiveVectorShardForActiveProfile,\n} from './vector-index-store.js';\n\n// Snake_case aliases for store exports used by legacy callers\nexport {\n  isVectorSearchAvailable as is_vector_search_available_alias,\n} from './vector-index-store.js';","lineStart":1,"lineEnd":178,"totalLines":178,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index.ts","time":{"start":1781762693884,"end":1781762693889}},"metadata":{"openai":{"itemId":"fc_071c84d92e422b80016a338a84fd288191b942056deb612a82"}},"id":"prt_ed9551a48001D877Ra9JBjRJSR","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed954d95e001dqM6EwcitRzirn"}}
{"type":"tool_use","timestamp":1781762694124,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"read","callID":"call_kJAT87oVZgwBBfdquWTJaoYf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Vector Index Mutations\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Hybrid search pipeline\n5: // Split from vector-index-store.ts — contains ALL mutation functions:\n6: // Index, update, delete, and status/confidence updates.\n7: \n8: import * as embeddingsProvider from '../providers/embeddings.js';\n9: import {\n10:   buildGovernanceLogicalKey,\n11:   normalizeScopeValue,\n12:   recordTierDowngradeAudit,\n13: } from '../governance/scope-governance.js';\n14: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n15: import { recordHistory } from '../storage/history.js';\n16: import { buildMemoryLogicalKey } from '../storage/lineage-state.js';\n17: import { getCanonicalPathKey } from '../utils/canonical-path.js';\n18: import { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\n19: import { createLogger } from '../utils/logger.js';\n20: import { deleteByContentHash } from '../cache/embedding-cache.js';\n21: import { clearDegreeCacheForDb } from './graph-search-fn.js';\n22: import { sweepCausalEdges } from '../causal/sweep.js';\n23: import { bumpCausalEdgesGeneration } from '../storage/causal-generation.js';\n24: import * as bm25Index from './bm25-index.js';\n25: import {\n26:   clear_search_cache,\n27: } from './vector-index-aliases.js';\n28: import { invalidateEntityDensityCache } from './entity-density.js';\n29: import {\n30:   get_error_message,\n31:   to_embedding_buffer,\n32:   VectorIndexError,\n33:   VectorIndexErrorCode,\n34: } from './vector-index-types.js';\n35: import {\n36:   clear_constitutional_cache,\n37:   get_embedding_dim,\n38:   initialize_db,\n39:   init_prepared_statements,\n40:   refresh_interference_scores_for_folder,\n41:   sqlite_vec_available as get_sqlite_vec_available,\n42:   activeVectorSource,\n43: } from './vector-index-store.js';\n44: import { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder, vecTableNameForDim } from '../embedders/schema.js';\n45: import type {\n46:   IndexMemoryParams as SharedIndexMemoryParams,\n47:   MemoryScopeParams,\n48:   UpdateMemoryParams as SharedUpdateMemoryParams,\n49: } from './vector-index-types.js';\n50: import type Database from 'better-sqlite3';\n51: \n52: const logger = createLogger('VectorIndex');\n53: \n54: function isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n55:   const message = get_error_message(error).toLowerCase();\n56:   return message.includes('no such table') && message.includes('vec_memories');\n57: }\n58: \n59: function activeVectorTableExists(database: Database.Database, tableName: string): boolean {\n60:   try {\n61:     const row = database.prepare(`\n62:       SELECT 1 AS found\n63:       FROM ${activeVectorSource('sqlite_master')}\n64:       WHERE type = 'table' AND name = ?\n65:       LIMIT 1\n66:     `).get(tableName) as { found?: number } | undefined;\n67:     return row?.found === 1;\n68:   } catch (_error: unknown) {\n69:     return false;\n70:   }\n71: }\n72: \n73: function activeDimVectorSource(database: Database.Database): string | null {\n74:   const active = getActiveEmbedder(database);\n75:   if (active.name === DEFAULT_ACTIVE_EMBEDDER.name) {\n76:     return null;\n77:   }\n78:   const tableName = vecTableNameForDim(active.dim);\n79:   return activeVectorTableExists(database, tableName) ? activeVectorSource(tableName) : null;\n80: }\n81: \n82: function writeActiveVectorPayload(database: Database.Database, id: bigint, embeddingBuffer: Buffer): void {\n83:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n84:   database.prepare(`\n85:     INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)\n86:   `).run(id, embeddingBuffer);\n87: \n88:   const dimSource = activeDimVectorSource(database);\n89:   if (dimSource) {\n90:     database.prepare(`INSERT OR REPLACE INTO ${dimSource} (id, vec) VALUES (?, ?)`).run(id, embeddingBuffer);\n91:   }\n92: }\n93: \n94: function deleteActiveVectorPayload(database: Database.Database, id: bigint): void {\n95:   database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n96:   const dimSource = activeDimVectorSource(database);\n97:   if (dimSource) {\n98:     database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n99:   }\n100: }\n101: \n102: function invalidateGraphCaches(database: Database.Database): void {\n103:   // Bump the generation FIRST so every cache key that includes it (e.g.\n104:   // memory_search with causal boost) goes stale before the per-db caches clear;\n105:   // without this, memory-delete sweeps served stale causal-boosted search results.\n106:   bumpCausalEdgesGeneration();\n107: \n108:   try {\n109:     clearDegreeCacheForDb(database);\n110:   } catch (_error: unknown) {\n111:     // Degree cache invalidation is best-effort for legacy mutation paths.\n112:   }\n113: \n114:   try {\n115:     clearGraphSignalsCache();\n116:   } catch (_error: unknown) {\n117:     // Graph signal cache invalidation is best-effort for legacy mutation paths.\n118:   }\n119: }\n120: \n121: function tryRecordTierDowngradeAudit(\n122:   database: Database.Database,\n123:   params: {\n124:     memoryId: number;\n125:     specFolder: string | null | undefined;\n126:     anchorId: string | null | undefined;\n127:     filePath: string | null | undefined;\n128:     canonicalFilePath: string | null | undefined;\n129:     requestedTier?: string | null | undefined;\n130:     previousTier?: string | null | undefined;\n131:     nextTier: string;\n132:     source: string;\n133:   },\n134: ): void {\n135:   try {\n136:     recordTierDowngradeAudit(database, {\n137:       memoryId: params.memoryId,\n138:       logicalKey: buildGovernanceLogicalKey(\n139:         params.specFolder,\n140:         params.canonicalFilePath || params.filePath,\n141:         params.anchorId,\n142:       ),\n143:       requestedTier: params.requestedTier ?? undefined,\n144:       previousTier: params.previousTier ?? undefined,\n145:       nextTier: params.nextTier,\n146:       source: params.source,\n147:       filePath: params.filePath ?? null,\n148:       canonicalFilePath: params.canonicalFilePath ?? null,\n149:     });\n150:   } catch (error: unknown) {\n151:     logger.warn('Failed to record governance audit for tier downgrade', {\n152:       memoryId: params.memoryId,\n153:       source: params.source,\n154:       message: get_error_message(error),\n155:     });\n156:   }\n157: }\n158: \n159: function deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n160:   const ancillaryTables = [\n161:     'DELETE FROM degree_snapshots WHERE memory_id = ?',\n162:     'DELETE FROM community_assignments WHERE memory_id = ?',\n163:     'DELETE FROM memory_summaries WHERE memory_id = ?',\n164:     'DELETE FROM memory_entities WHERE memory_id = ?',\n165:     'DELETE FROM memory_lineage WHERE memory_id = ?',\n166:   ];\n167: \n168:   for (const sql of ancillaryTables) {\n169:     try {\n170:       const paramCount = (sql.match(/\\?/g) || []).length;\n171:       if (paramCount === 2) {\n172:         database.prepare(sql).run(id, id);\n173:       } else {\n174:         database.prepare(sql).run(id);\n175:       }\n176:     } catch (_error: unknown) {\n177:       // Best-effort for legacy databases that may not have these tables yet.\n178:     }\n179:   }\n180: \n181:   // Clean active_memory_projection rows referencing this memory.\n182:   try {\n183:     database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n184:   } catch (_error: unknown) {\n185:     // Best-effort for legacy databases that may not have projection tables yet.\n186:   }\n187: \n188:   try {\n189:     const result = sweepCausalEdges(database, {\n190:       memoryIds: [id, String(id)],\n191:       reason: 'memory row mutation cleanup',\n192:       command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n193:       restoreContext: { memoryId: id },\n194:       invalidateCaches: false,\n195:     });\n196:     if (result.deleted > 0) {\n197:       invalidateGraphCaches(database);\n198:     }\n199:   } catch (error: unknown) {\n200:     // Tolerate only legacy databases that predate the causal-edge tables. Scope\n201:     // the match to those table names so an unrelated missing-table error still\n202:     // propagates and rolls back the surrounding delete instead of committing a\n203:     // hard delete without its tombstone audit row.\n204:     const message = error instanceof Error ? error.message : String(error);\n205:     if (!/no such table:\\s*causal_edge/i.test(message)) {\n206:       throw error;\n207:     }\n208:   }\n209: }\n210: \n211: function upsert_active_projection(\n212:   database: ReturnType<typeof initialize_db>,\n213:   specFolder: string,\n214:   canonicalFilePath: string,\n215:   anchorId: string | null,\n216:   memoryId: number,\n217:   updatedAt: string,\n218:   scope: NormalizedMemoryScope,\n219: ): void {\n220:   const logicalKey = buildMemoryLogicalKey({\n221:     specFolder,\n222:     filePath: canonicalFilePath,\n223:     canonicalFilePath,\n224:     anchorId,\n225:     ...scope,\n226:   });\n227:   // Evict any stale projection row that maps a *different* logical_key to the\n228:   // same active_memory_id — prevents UNIQUE constraint violation on re-index\n229:   // when the logical_key changes (e.g. anchor or path normalization drift).\n230:   database.prepare(\n231:     'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n232:   ).run(memoryId, logicalKey);\n233:   database.prepare(`\n234:     INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n235:     VALUES (?, ?, ?, ?)\n236:     ON CONFLICT(logical_key) DO UPDATE SET\n237:       root_memory_id = excluded.root_memory_id,\n238:       active_memory_id = excluded.active_memory_id,\n239:       updated_at = excluded.updated_at\n240:   `).run(logicalKey, memoryId, memoryId, updatedAt);\n241: }\n242: \n243: // These mutation-local extensions are intentional until the shared query/store\n244: // contract adopts appendOnly and canonicalFilePath semantics.\n245: type IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n246:   readonly appendOnly?: boolean;\n247: };\n248: type IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n249:   readonly failureReason?: string | null;\n250: };\n251: type UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n252:   readonly canonicalFilePath?: string;\n253:   // Set when the row's document now lives at a new on-disk location, so a\n254:   // moved file repoints its existing row instead of leaving a stale path.\n255:   readonly filePath?: string;\n256: };\n257: \n258: type NormalizedMemoryScope = {\n259:   tenant_id: string | null;\n260:   user_id: string | null;\n261:   agent_id: string | null;\n262:   session_id: string | null;\n263: };\n264: \n265: function normalizeMemoryScope(scope?: MemoryScopeParams): NormalizedMemoryScope {\n266:   return {\n267:     tenant_id: normalizeScopeValue(scope?.tenantId),\n268:     user_id: normalizeScopeValue(scope?.userId),\n269:     agent_id: normalizeScopeValue(scope?.agentId),\n270:     session_id: normalizeScopeValue(scope?.sessionId),\n271:   };\n272: }\n273: \n274: /**\n275:  * Indexes a memory with an embedding payload.\n276:  * @param params - The memory values to index.\n277:  * @returns The indexed memory identifier.\n278:  * @throws {VectorIndexError} When embedding validation fails or the mutation cannot be applied.\n279:  * @example\n280:  * ```ts\n281:  * const id = index_memory({\n282:  *   specFolder: 'specs/001-demo',\n283:  *   filePath: 'spec.md',\n284:  *   embedding,\n285:  * });\n286:  * ```\n287:  */\n288: export function index_memory(\n289:   params: IndexMemoryParams,\n290:   database: Database.Database = initialize_db(),\n291: ): number {\n292:   const {\n293:     specFolder,\n294:     filePath,\n295:     parentId = null,\n296:     anchorId = null,\n297:     title = null,\n298:     triggerPhrases = [],\n299:     importanceWeight = 0.5,\n300:     embedding,\n301:     encodingIntent,\n302:     documentType = 'memory',\n303:     specLevel = null,\n304:     contentText = null,\n305:     qualityScore = 0,\n306:     qualityFlags = [],\n307:     appendOnly = false,\n308:   } = params;\n309:   const scope = normalizeMemoryScope(params.scope);\n310: \n311:   if (!embedding) {\n312:     throw new VectorIndexError('Embedding is required', VectorIndexErrorCode.EMBEDDING_VALIDATION);\n313:   }\n314: \n315:   const expected_dim = get_embedding_dim();\n316:   if (embedding.length !== expected_dim) {\n317:     console.warn(`[vector-index] Embedding dimension mismatch: expected ${expected_dim}, got ${embedding.length}`);\n318:     throw new VectorIndexError(\n319:       `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n320:       VectorIndexErrorCode.EMBEDDING_VALIDATION,\n321:     );\n322:   }\n323: \n324:   const now = new Date().toISOString();\n325:   const triggers_json = JSON.stringify(triggerPhrases);\n326:   const embedding_buffer = to_embedding_buffer(embedding);\n327:   const canonicalFilePath = getCanonicalPathKey(filePath);\n328: \n329:   const stmts = init_prepared_statements(database);\n330:   const existing = appendOnly\n331:     ? null\n332:     : stmts.get_by_folder_and_path.get(\n333:         specFolder,\n334:         canonicalFilePath,\n335:         filePath,\n336:         canonicalFilePath,\n337:         filePath,\n338:         anchorId,\n339:         scope.tenant_id,\n340:         scope.user_id,\n341:         scope.agent_id,\n342:         scope.session_id,\n343:       );\n344: \n345:   if (existing && !appendOnly) {\n346:     return update_memory({\n347:       id: existing.id,\n348:       title: title ?? undefined,\n349:       triggerPhrases,\n350:       importanceWeight,\n351:       embedding,\n352:       encodingIntent,\n353:       documentType,\n354:       specLevel,\n355:       contentText,\n356:       qualityScore,\n357:       qualityFlags,\n358:       canonicalFilePath,\n359:       filePath,\n360:     }, database);\n361:   }\n362: \n363:   const sqlite_vec = get_sqlite_vec_available();\n364: \n365:   const index_memory_tx = database.transaction(() => {\n366:     const embedding_status = sqlite_vec ? 'success' : 'pending';\n367: \n368:     const result = database.prepare(`\n369:       INSERT INTO memory_index (\n370:         spec_folder, file_path, canonical_file_path, anchor_id, title, trigger_phrases,\n371:         importance_weight, created_at, updated_at, embedding_model,\n372:         embedding_generated_at, embedding_status, encoding_intent, document_type, spec_level,\n373:         content_text, quality_score, quality_flags, parent_id,\n374:         tenant_id, user_id, agent_id, session_id\n375:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n376:     `).run(\n377:       specFolder, filePath, canonicalFilePath, anchorId, title, triggers_json,\n378:       importanceWeight, now, now, embeddingsProvider.getModelName(), now, embedding_status,\n379:       encodingIntent ?? 'document', documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), parentId,\n380:       scope.tenant_id, scope.user_id, scope.agent_id, scope.session_id\n381:     );\n382: \n383:     const row_id = BigInt(result.lastInsertRowid);\n384:     const metadata_id = Number(row_id);\n385: \n386:     upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, metadata_id, now, scope);\n387: \n388:     if (sqlite_vec) {\n389:       writeActiveVectorPayload(database, row_id, embedding_buffer);\n390:     }\n391: \n392:     refresh_interference_scores_for_folder(database, specFolder);\n393:     clear_search_cache();\n394: \n395:     return metadata_id;\n396:   });\n397: \n398:   return index_memory_tx();\n399: }\n400: \n401: // Deferred indexing - entry searchable via BM25/FTS5 only\n402: /**\n403:  * Indexes a memory record without storing an embedding yet.\n404:  * @param params - The deferred memory values to index.\n405:  * @returns The indexed memory identifier.\n406:  */\n407: export function index_memory_deferred(\n408:   params: IndexMemoryDeferredParams,\n409:   database: Database.Database = initialize_db(),\n410: ): number {\n411:   const {\n412:     specFolder,\n413:     filePath,\n414:     parentId = null,\n415:     anchorId = null,\n416:     title = null,\n417:     triggerPhrases = [],\n418:     importanceWeight = 0.5,\n419:     failureReason = null,\n420:     encodingIntent,\n421:     documentType = 'memory',\n422:     specLevel = null,\n423:     contentText = null,\n424:     qualityScore = 0,\n425:     qualityFlags = [],\n426:     appendOnly = false,\n427:   } = params;\n428:   const scope = normalizeMemoryScope(params.scope);\n429: \n430:   const now = new Date().toISOString();\n431:   const triggers_json = JSON.stringify(triggerPhrases);\n432:   const canonicalFilePath = getCanonicalPathKey(filePath);\n433: \n434:   const stmts = init_prepared_statements(database);\n435:   const existing = appendOnly\n436:     ? null\n437:     : stmts.get_by_folder_and_path.get(\n438:         specFolder,\n439:         canonicalFilePath,\n440:         filePath,\n441:         canonicalFilePath,\n442:         filePath,\n443:         anchorId,\n444:         scope.tenant_id,\n445:         scope.user_id,\n446:         scope.agent_id,\n447:         scope.session_id,\n448:       );\n449: \n450:   const index_memory_deferred_tx = database.transaction(() => {\n451:     if (existing && !appendOnly) {\n452:       database.prepare(`\n453:         UPDATE memory_index\n454:         SET title = ?,\n455:             trigger_phrases = ?,\n456:             importance_weight = ?,\n457:             file_path = ?,\n458:             canonical_file_path = ?,\n459:             embedding_status = 'pending',\n460:             failure_reason = ?,\n461:             updated_at = ?,\n462:             encoding_intent = COALESCE(?, encoding_intent),\n463:             document_type = ?,\n464:             spec_level = ?,\n465:             content_text = ?,\n466:             quality_score = ?,\n467:             quality_flags = ?,\n468:             retry_count = 0,\n469:             last_retry_at = NULL\n470:         WHERE id = ?\n471:       `).run(title, triggers_json, importanceWeight, filePath, canonicalFilePath, failureReason, now, encodingIntent, documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), existing.id);\n472:       upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, existing.id, now, scope);\n473:       refresh_interference_scores_for_folder(database, specFolder);\n474:       return existing.id;\n475:     }\n476: \n477:     const result = database.prepare(`\n478:       INSERT INTO memory_index (\n479:         spec_folder, file_path, canonical_file_path, anchor_id, title, trigger_phrases,\n480:         importance_weight, created_at, updated_at, embedding_status,\n481:         failure_reason, retry_count, encoding_intent, document_type, spec_level,\n482:         content_text, quality_score, quality_flags, parent_id,\n483:         tenant_id, user_id, agent_id, session_id\n484:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?, 0, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n485:     `).run(\n486:       specFolder, filePath, canonicalFilePath, anchorId, title, triggers_json,\n487:       importanceWeight, now, now, failureReason, encodingIntent ?? 'document', documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), parentId,\n488:       scope.tenant_id, scope.user_id, scope.agent_id, scope.session_id\n489:     );\n490: \n491:     const row_id = BigInt(result.lastInsertRowid);\n492:     upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, Number(row_id), now, scope);\n493:     refresh_interference_scores_for_folder(database, specFolder);\n494:     logger.info(`Deferred indexing: Memory ${Number(row_id)} saved without embedding (BM25/FTS5 searchable)`);\n495: \n496:     return Number(row_id);\n497:   });\n498: \n499:   return index_memory_deferred_tx();\n500: }\n501: \n502: /**\n503:  * Updates stored memory metadata and embeddings.\n504:  * @param params - The memory values to update.\n505:  * @returns The updated memory identifier.\n506:  * @throws {VectorIndexError} When embedding validation fails or the mutation transaction cannot complete.\n507:  * @example\n508:  * ```ts\n509:  * const id = update_memory({ id: 42, title: 'Updated title', embedding });\n510:  * ```\n511:  */\n512: export function update_memory(\n513:   params: UpdateMemoryParams,\n514:   database: Database.Database = initialize_db(),\n515: ): number {\n516:   const {\n517:     id,\n518:     title,\n519:     triggerPhrases,\n520:     importanceWeight,\n521:     importanceTier,\n522:     embedding,\n523:     canonicalFilePath,\n524:     filePath,\n525:     encodingIntent,\n526:     documentType,\n527:     specLevel,\n528:     contentText,\n529:     qualityScore,\n530:     qualityFlags,\n531:   } = params;\n532: \n533:   const now = new Date().toISOString();\n534: \n535:   const update_memory_tx = database.transaction(() => {\n536:     const existingRow = database.prepare(`\n537:       SELECT spec_folder, anchor_id, canonical_file_path, file_path, importance_tier,\n538:              tenant_id, user_id, agent_id, session_id\n539:       FROM memory_index\n540:       WHERE id = ?\n541:     `).get(id) as {\n542:       spec_folder: string | null;\n543:       anchor_id: string | null;\n544:       canonical_file_path: string | null;\n545:       file_path: string | null;\n546:       importance_tier: string | null;\n547:       tenant_id: string | null;\n548:       user_id: string | null;\n549:       agent_id: string | null;\n550:       session_id: string | null;\n551:     } | undefined;\n552:     const updates = ['updated_at = ?'];\n553:     const values: unknown[] = [now];\n554: \n555:     if (title !== undefined) {\n556:       updates.push('title = ?');\n557:       values.push(title);\n558:     }\n559:     if (triggerPhrases !== undefined) {\n560:       updates.push('trigger_phrases = ?');\n561:       values.push(JSON.stringify(triggerPhrases));\n562:     }\n563:     if (importanceWeight !== undefined) {\n564:       updates.push('importance_weight = ?');\n565:       values.push(importanceWeight);\n566:     }\n567:     if (importanceTier !== undefined) {\n568:       let nextImportanceTier = importanceTier;\n569:       const previousTier = existingRow?.importance_tier ?? null;\n570:       if (\n571:         existingRow\n572:       ) {\n573:         const guardPath = existingRow.canonical_file_path || existingRow.file_path;\n574:         const hasNonConstitutionalPath = guardPath && !isIndexableConstitutionalMemoryPath(guardPath);\n575:         if (hasNonConstitutionalPath && importanceTier === 'constitutional') {\n576:           // Non-constitutional paths cannot be promoted to constitutional tier.\n577:           nextImportanceTier = 'important';\n578:         }\n579:         if (\n580:           hasNonConstitutionalPath\n581:           && (\n582:             importanceTier === 'constitutional'\n583:             || (previousTier === 'constitutional' && nextImportanceTier !== 'constitutional')\n584:           )\n585:         ) {\n586:           tryRecordTierDowngradeAudit(database, {\n587:             memoryId: id,\n588:             specFolder: existingRow.spec_folder,\n589:             anchorId: existingRow.anchor_id,\n590:             filePath: existingRow.file_path,\n591:             canonicalFilePath: existingRow.canonical_file_path,\n592:             requestedTier: importanceTier,\n593:             previousTier,\n594:             nextTier: nextImportanceTier,\n595:             source: 'update_memory',\n596:           });\n597:         }\n598:       }\n599:       updates.push('importance_tier = ?');\n600:       values.push(nextImportanceTier);\n601:       clear_constitutional_cache();\n602:     }\n603:     if (canonicalFilePath !== undefined) {\n604:       updates.push('canonical_file_path = ?');\n605:       values.push(canonicalFilePath);\n606:     }\n607:     if (filePath !== undefined) {\n608:       updates.push('file_path = ?');\n609:       values.push(filePath);\n610:     }\n611:     if (encodingIntent !== undefined) {\n612:       updates.push('encoding_intent = ?');\n613:       values.push(encodingIntent);\n614:     }\n615:     if (documentType !== undefined) {\n616:       updates.push('document_type = ?');\n617:       values.push(documentType);\n618:     }\n619:     if (specLevel !== undefined) {\n620:       updates.push('spec_level = ?');\n621:       values.push(specLevel);\n622:     }\n623:     if (contentText !== undefined) {\n624:       updates.push('content_text = ?');\n625:       values.push(contentText);\n626:     }\n627:     if (qualityScore !== undefined) {\n628:       updates.push('quality_score = ?');\n629:       values.push(qualityScore);\n630:     }\n631:     if (qualityFlags !== undefined) {\n632:       updates.push('quality_flags = ?');\n633:       values.push(JSON.stringify(qualityFlags));\n634:     }\n635:     if (embedding) {\n636:       updates.push('embedding_model = ?');\n637:       updates.push('embedding_generated_at = ?');\n638:       updates.push('embedding_status = ?');\n639:       values.push(embeddingsProvider.getModelName(), now, 'pending');\n640:     }\n641: \n642:     values.push(id);\n643: \n644:     const updateResult = database.prepare(`\n645:       UPDATE memory_index SET ${updates.join(', ')} WHERE id = ?\n646:     `).run(...values);\n647: \n648:     // Return early if the target row no longer exists.\n649:     if (updateResult.changes === 0) {\n650:       return id;\n651:     }\n652: \n653:     const sqlite_vec = get_sqlite_vec_available();\n654:     if (embedding && sqlite_vec) {\n655:       const expected_dim = get_embedding_dim();\n656:       if (embedding.length !== expected_dim) {\n657:         console.warn(`[vector-index] Embedding dimension mismatch in update: expected ${expected_dim}, got ${embedding.length}`);\n658:         throw new VectorIndexError(\n659:           `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n660:           VectorIndexErrorCode.EMBEDDING_VALIDATION,\n661:         );\n662:       }\n663: \n664:       const embedding_buffer = to_embedding_buffer(embedding);\n665:       writeActiveVectorPayload(database, BigInt(id), embedding_buffer);\n666:       database.prepare('UPDATE memory_index SET embedding_status = ? WHERE id = ?').run('success', id);\n667:     }\n668: \n669:     if (existingRow?.spec_folder) {\n670:       const projectionPath = canonicalFilePath\n671:         ?? existingRow.canonical_file_path\n672:         ?? getCanonicalPathKey(existingRow.file_path ?? '');\n673:       upsert_active_projection(database, existingRow.spec_folder, projectionPath, existingRow.anchor_id ?? null, id, now, {\n674:         tenant_id: existingRow.tenant_id,\n675:         user_id: existingRow.user_id,\n676:         agent_id: existingRow.agent_id,\n677:         session_id: existingRow.session_id,\n678:       });\n679:     }\n680: \n681:     if (existingRow?.spec_folder) {\n682:       refresh_interference_scores_for_folder(database, existingRow.spec_folder);\n683:     }\n684:     clear_search_cache();\n685: \n686:     return id;\n687:   });\n688: \n689:   return update_memory_tx();\n690: }\n691: \n692: /**\n693:  * Deletes a memory and its related index records.\n694:  * @param id - The memory identifier.\n695:  * @returns True when a memory was deleted.\n696:  * @throws {VectorIndexError} Propagates mutation or store initialization failures from the delete pipeline.\n697:  * @example\n698:  * ```ts\n699:  * const deleted = delete_memory(42);\n700:  * ```\n701:  */\n702: export function delete_memory(id: number, database: Database.Database = initialize_db()): boolean {\n703:   return delete_memory_from_database(database, id);\n704: }\n705: \n706: /**\n707:  * Deletes a memory and related index records using the provided database handle.\n708:  * @param database - The database containing the target memory.\n709:  * @param id - The memory identifier.\n710:  * @returns True when a memory was deleted.\n711:  * @throws {VectorIndexError} Propagates mutation failures encountered while deleting the memory.\n712:  * @example\n713:  * ```ts\n714:  * const deleted = delete_memory_from_database(database, 42);\n715:  * ```\n716:  */\n717: export function delete_memory_from_database(database: Database.Database, id: number): boolean {\n718:   const sqlite_vec = get_sqlite_vec_available();\n719: \n720:   const delete_memory_tx = database.transaction(() => {\n721:     // Memory_history rows are intentionally preserved after deletion\n722:     // So DELETE audit events recorded by handlers persist as audit trail.\n723:     const row = database.prepare('SELECT content_hash FROM memory_index WHERE id = ?').get(id) as\n724:       | { content_hash: string | null }\n725:       | undefined;\n726: \n727:     if (sqlite_vec) {\n728:       try {\n729:         deleteActiveVectorPayload(database, BigInt(id));\n730:       } catch (e: unknown) {\n731:         if (!isExpectedMissingVecMemoriesTable(e)) {\n732:           throw new VectorIndexError(\n733:             `Vector deletion failed for memory ${id}: ${get_error_message(e)}`,\n734:             VectorIndexErrorCode.MUTATION_FAILED,\n735:           );\n736:         }\n737:       }\n738:     }\n739: \n740:     // Clean ancillary records so deletes do not leave graph residue behind.\n741:     deleteAncillaryMemoryRows(database, id);\n742: \n743:     if (row?.content_hash) {\n744:       // Governed retention delete semantics include derived embedding-cache rows.\n745:       try {\n746:         deleteByContentHash(database, row.content_hash);\n747:       } catch (_error: unknown) {\n748:         // Legacy or test databases may not have embedding_cache yet.\n749:       }\n750:     }\n751: \n752:     const result = database.prepare('DELETE FROM memory_index WHERE id = ?').run(id);\n753: \n754:     clear_search_cache();\n755:     clear_constitutional_cache();\n756: \n757:     return result.changes > 0;\n758:   });\n759: \n760:   // Remove the BM25 document only after the source row is deleted.\n761:   const deleted = delete_memory_tx();\n762:   if (deleted) {\n763:     // Invalidate entity-density cache so deleted memory's tokens are not routed\n764:     // to the graph channel beyond the 60s TTL window. Best-effort: non-fatal.\n765:     try {\n766:       invalidateEntityDensityCache();\n767:     } catch (_error: unknown) {\n768:       // Cache invalidation is best-effort; do not mask a successful delete.\n769:     }\n770:   }\n771:   if (deleted) {\n772:     try {\n773:       if (bm25Index.isBm25Enabled()) {\n774:         bm25Index.getIndex().removeDocument(String(id));\n775:       }\n776:     } catch (_error: unknown) {\n777:       // BEST-EFFORT BM25 CLEANUP MUST NOT MASK A SUCCESSFUL PRIMARY DELETE.\n778:     }\n779:   }\n780:   return deleted;\n781: }\n782: \n783: /**\n784:  * Deletes the latest memory for a file path and optional anchor.\n785:  * @param spec_folder - The owning spec folder.\n786:  * @param file_path - The file path to delete.\n787:  * @param anchor_id - The optional anchor identifier.\n788:  * @returns True when a memory was deleted.\n789:  * @throws {VectorIndexError} Propagates delete failures from the underlying mutation helpers.\n790:  * @example\n791:  * ```ts\n792:  * const deleted = delete_memory_by_path('specs/001-demo', 'spec.md');\n793:  * ```\n794:  */\n795: export function delete_memory_by_path(\n796:   spec_folder: string,\n797:   file_path: string,\n798:   anchor_id: string | null = null,\n799:   database: Database.Database = initialize_db(),\n800: ): boolean {\n801:   const canonicalPath = getCanonicalPathKey(file_path);\n802: \n803:   const row = database.prepare(`\n804:     SELECT id, spec_folder FROM memory_index\n805:     WHERE spec_folder = ?\n806:       AND (canonical_file_path = ? OR file_path = ?)\n807:       AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))\n808:     ORDER BY id DESC\n809:     LIMIT 1\n810:   `).get(spec_folder, canonicalPath, file_path, anchor_id, anchor_id) as { id: number; spec_folder?: string | null } | undefined;\n811: \n812:   if (row) {\n813:     const deleted = delete_memory_from_database(database, row.id);\n814:     if (deleted) {\n815:       // Self-record DELETE history only after the delete succeeded.\n816:       try {\n817:         recordHistory(row.id, 'DELETE', file_path ?? null, null, 'mcp:delete_by_path', row.spec_folder ?? spec_folder);\n818:       } catch (_histErr: unknown) {\n819:         // BEST-EFFORT HISTORY WRITES MUST NOT MASK A SUCCESSFUL DELETE.\n820:       }\n821:     }\n822:     return deleted;\n823:   }\n824:   return false;\n825: }\n826: \n827: /**\n828:  * Deletes multiple memories in a single transaction.\n829:  * @param memory_ids - The memory identifiers to delete.\n830:  * @returns Counts for deleted and failed items.\n831:  * @throws {VectorIndexError} When one or more deletes fail and the transaction is rolled back.\n832:  * @example\n833:  * ```ts\n834:  * const outcome = delete_memories([1, 2, 3]);\n835:  * ```\n836:  */\n837: export function delete_memories(\n838:   memory_ids: number[],\n839:   database: Database.Database = initialize_db(),\n840: ): { deleted: number; failed: number } {\n841:   if (!memory_ids || memory_ids.length === 0) {\n842:     return { deleted: 0, failed: 0 };\n843:   }\n844:   const sqlite_vec = get_sqlite_vec_available();\n845:   let deleted = 0;\n846:   let failed = 0;\n847:   const deletedIds: number[] = [];\n848: \n849:   const specFolderById = new Map<number, string | null>();\n850:   for (const id of memory_ids) {\n851:     if (!Number.isInteger(id) || id <= 0) {\n852:       continue;\n853:     }\n854:     try {\n855:       const row = database.prepare('SELECT spec_folder FROM memory_index WHERE id = ?').get(id) as { spec_folder?: string | null } | undefined;\n856:       specFolderById.set(id, row?.spec_folder ?? null);\n857:     } catch (_error: unknown) {\n858:       specFolderById.set(id, null);\n859:     }\n860:   }\n861: \n862:   const delete_transaction = database.transaction(() => {\n863:     let transactionDeleted = 0;\n864:     let transactionFailed = 0;\n865:     const failed_ids: number[] = [];\n866: \n867:     for (const id of memory_ids) {\n868:       try {\n869:         if (sqlite_vec) {\n870:           try {\n871:             deleteActiveVectorPayload(database, BigInt(id));\n872:           } catch (vec_error: unknown) {\n873:             console.warn(`[VectorIndex] Failed to delete vector for memory ${id}: ${get_error_message(vec_error)}`);\n874:           }\n875:         }\n876: \n877:         deleteAncillaryMemoryRows(database, id);\n878:         const result = database.prepare('DELETE FROM memory_index WHERE id = ?').run(id);\n879:         if (result.changes > 0) {\n880:           // Memory_history rows are intentionally preserved after deletion\n881:           // So DELETE audit events recorded here persist as audit trail.\n882:           try {\n883:             recordHistory(id, 'DELETE', null, null, 'mcp:delete_memories', specFolderById.get(id) ?? null);\n884:           } catch (_histErr: unknown) {\n885:             // BEST-EFFORT HISTORY WRITES MUST NOT MASK A SUCCESSFUL DELETE.\n886:           }\n887:           transactionDeleted++;\n888:           deletedIds.push(id);\n889:         } else {\n890:           transactionFailed++;\n891:           failed_ids.push(id);\n892:         }\n893:       } catch (e: unknown) {\n894:         console.warn(`[vector-index] Failed to delete memory ${id}: ${get_error_message(e)}`);\n895:         transactionFailed++;\n896:         failed_ids.push(id);\n897:       }\n898:     }\n899: \n900:     if (failed_ids.length > 0) {\n901:       throw new VectorIndexError(\n902:         `Failed to delete memories: ${failed_ids.join(', ')}. Transaction rolled back.`,\n903:         VectorIndexErrorCode.MUTATION_FAILED,\n904:       );\n905:     }\n906: \n907:     return {\n908:       deleted: transactionDeleted,\n909:       failed: transactionFailed,\n910:     };\n911:   });\n912: \n913:   try {\n914:     const outcome = delete_transaction();\n915:     deleted = outcome.deleted;\n916:     failed = outcome.failed;\n917:     if (deleted > 0) {\n918:       clear_constitutional_cache();\n919:       clear_search_cache();\n920:       // Invalidate entity-density cache so deleted memories' tokens are evicted\n921:       // immediately rather than persisting for up to the 60s TTL. Best-effort.\n922:       try {\n923:         invalidateEntityDensityCache();\n924:       } catch (_error: unknown) {\n925:         // Cache invalidation is best-effort; do not mask a successful delete.\n926:       }\n927:       try {\n928:         if (bm25Index.isBm25Enabled()) {\n929:           const bm25 = bm25Index.getIndex();\n930:           for (const id of deletedIds) {\n931:             bm25.removeDocument(String(id));\n932:           }\n933:         }\n934:       } catch (_error: unknown) {\n935:         // BM25 cleanup is best-effort for bulk deletes as well.\n936:       }\n937:     }\n938:   } catch (e: unknown) {\n939:     console.warn(`[vector-index] delete_memories transaction error: ${get_error_message(e)}`);\n940:     deleted = 0;\n941:     failed = memory_ids.length;\n942:   }\n943: \n944:   return { deleted, failed };\n945: }\n946: \n947: // Valid statuses: 'pending', 'success', 'failed', 'retry', 'partial'\n948: /**\n949:  * Updates the embedding status for a memory.\n950:  * @param id - The memory identifier.\n951:  * @param status - The new embedding status.\n952:  * @returns True when the status was updated.\n953:  */\n954: export function update_embedding_status(\n955:   id: number,\n956:   status: string,\n957:   database: Database.Database = initialize_db(),\n958: ): boolean {\n959:   const valid_statuses = ['pending', 'success', 'failed', 'retry', 'partial'];\n960:   if (!valid_statuses.includes(status)) {\n961:     console.warn(`[vector-index] Invalid embedding status: ${status}`);\n962:     return false;\n963:   }\n964: \n965:   try {\n966:     const result = database.prepare(`\n967:       UPDATE memory_index\n968:       SET embedding_status = ?, updated_at = datetime('now')\n969:       WHERE id = ?\n970:     `).run(status, id);\n971: \n972:     return result.changes > 0;\n973:   } catch (error: unknown) {\n974:     console.warn(`[vector-index] Failed to update embedding status for ${id}: ${get_error_message(error)}`);\n975:     return false;\n976:   }\n977: }\n978: \n979: /**\n980:  * Updates the confidence value for a memory.\n981:  * @param memory_id - The memory identifier.\n982:  * @param confidence - The confidence value to store.\n983:  * @returns True when the confidence was updated.\n984:  */\n985: export function update_confidence(\n986:   memory_id: number,\n987:   confidence: number,\n988:   database: Database.Database = initialize_db(),\n989: ): boolean {\n990:   if (typeof confidence !== 'number' || confidence < 0 || confidence > 1) {\n991:     console.warn(`[vector-index] Invalid confidence value: ${confidence}`);\n992:     return false;\n993:   }\n994: \n995:   try {\n996:     const result = database.prepare(`\n997:       UPDATE memory_index\n998:       SET confidence = ?\n999:       WHERE id = ?\n1000:     `).run(confidence, memory_id);\n1001: \n1002:     return result.changes > 0;\n1003:   } catch (error: unknown) {\n1004:     console.warn(`[vector-index] Failed to update confidence for ${memory_id}: ${get_error_message(error)}`);\n1005:     return false;\n1006:   }\n1007: }\n1008: \n1009: // Exported so the store-port clear() can resolve and purge the active per-dim\n1010: // vector shard, mirroring the per-record delete path.\n1011: export { activeDimVectorSource };\n1012: \n1013: // CamelCase aliases\n1014: export { index_memory as indexMemory };\n1015: export { index_memory_deferred as indexMemoryDeferred };\n1016: export { update_memory as updateMemory };\n1017: export { delete_memory as deleteMemory };\n1018: export { delete_memory_by_path as deleteMemoryByPath };\n1019: export { delete_memories as deleteMemories };\n1020: export { update_embedding_status as updateEmbeddingStatus };\n1021: export { update_confidence as updateConfidence };\n\n(End of file - total 1021 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Mutations\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Vector Index Mutations\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Hybrid search pipeline\n// Split from vector-index-store.ts — contains ALL mutation functions:\n// Index, update, delete, and status/confidence updates.\n\nimport * as embeddingsProvider from '../providers/embeddings.js';\nimport {\n  buildGovernanceLogicalKey,\n  normalizeScopeValue,\n  recordTierDowngradeAudit,\n} from '../governance/scope-governance.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { recordHistory } from '../storage/history.js';\nimport { buildMemoryLogicalKey } from '../storage/lineage-state.js';\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { isIndexableConstitutionalMemoryPath } from '../utils/index-scope.js';\nimport { createLogger } from '../utils/logger.js';\nimport { deleteByContentHash } from '../cache/embedding-cache.js';\nimport { clearDegreeCacheForDb } from './graph-search-fn.js';\nimport { sweepCausalEdges } from '../causal/sweep.js';\nimport { bumpCausalEdgesGeneration } from '../storage/causal-generation.js';\nimport * as bm25Index from './bm25-index.js';\nimport {\n  clear_search_cache,\n} from './vector-index-aliases.js';\nimport { invalidateEntityDensityCache } from './entity-density.js';\nimport {\n  get_error_message,\n  to_embedding_buffer,\n  VectorIndexError,\n  VectorIndexErrorCode,\n} from './vector-index-types.js';\nimport {\n  clear_constitutional_cache,\n  get_embedding_dim,\n  initialize_db,\n  init_prepared_statements,\n  refresh_interference_scores_for_folder,\n  sqlite_vec_available as get_sqlite_vec_available,\n  activeVectorSource,\n} from './vector-index-store.js';\nimport { DEFAULT_ACTIVE_EMBEDDER, getActiveEmbedder, vecTableNameForDim } from '../embedders/schema.js';\nimport type {\n  IndexMemoryParams as SharedIndexMemoryParams,\n  MemoryScopeParams,\n  UpdateMemoryParams as SharedUpdateMemoryParams,\n} from './vector-index-types.js';\nimport type Database from 'better-sqlite3';\n\nconst logger = createLogger('VectorIndex');\n\nfunction isExpectedMissingVecMemoriesTable(error: unknown): boolean {\n  const message = get_error_message(error).toLowerCase();\n  return message.includes('no such table') && message.includes('vec_memories');\n}\n\nfunction activeVectorTableExists(database: Database.Database, tableName: string): boolean {\n  try {\n    const row = database.prepare(`\n      SELECT 1 AS found\n      FROM ${activeVectorSource('sqlite_master')}\n      WHERE type = 'table' AND name = ?\n      LIMIT 1\n    `).get(tableName) as { found?: number } | undefined;\n    return row?.found === 1;\n  } catch (_error: unknown) {\n    return false;\n  }\n}\n\nfunction activeDimVectorSource(database: Database.Database): string | null {\n  const active = getActiveEmbedder(database);\n  if (active.name === DEFAULT_ACTIVE_EMBEDDER.name) {\n    return null;\n  }\n  const tableName = vecTableNameForDim(active.dim);\n  return activeVectorTableExists(database, tableName) ? activeVectorSource(tableName) : null;\n}\n\nfunction writeActiveVectorPayload(database: Database.Database, id: bigint, embeddingBuffer: Buffer): void {\n  database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n  database.prepare(`\n    INSERT INTO ${activeVectorSource('vec_memories')} (rowid, embedding) VALUES (?, ?)\n  `).run(id, embeddingBuffer);\n\n  const dimSource = activeDimVectorSource(database);\n  if (dimSource) {\n    database.prepare(`INSERT OR REPLACE INTO ${dimSource} (id, vec) VALUES (?, ?)`).run(id, embeddingBuffer);\n  }\n}\n\nfunction deleteActiveVectorPayload(database: Database.Database, id: bigint): void {\n  database.prepare(`DELETE FROM ${activeVectorSource('vec_memories')} WHERE rowid = ?`).run(id);\n  const dimSource = activeDimVectorSource(database);\n  if (dimSource) {\n    database.prepare(`DELETE FROM ${dimSource} WHERE id = ?`).run(id);\n  }\n}\n\nfunction invalidateGraphCaches(database: Database.Database): void {\n  // Bump the generation FIRST so every cache key that includes it (e.g.\n  // memory_search with causal boost) goes stale before the per-db caches clear;\n  // without this, memory-delete sweeps served stale causal-boosted search results.\n  bumpCausalEdgesGeneration();\n\n  try {\n    clearDegreeCacheForDb(database);\n  } catch (_error: unknown) {\n    // Degree cache invalidation is best-effort for legacy mutation paths.\n  }\n\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signal cache invalidation is best-effort for legacy mutation paths.\n  }\n}\n\nfunction tryRecordTierDowngradeAudit(\n  database: Database.Database,\n  params: {\n    memoryId: number;\n    specFolder: string | null | undefined;\n    anchorId: string | null | undefined;\n    filePath: string | null | undefined;\n    canonicalFilePath: string | null | undefined;\n    requestedTier?: string | null | undefined;\n    previousTier?: string | null | undefined;\n    nextTier: string;\n    source: string;\n  },\n): void {\n  try {\n    recordTierDowngradeAudit(database, {\n      memoryId: params.memoryId,\n      logicalKey: buildGovernanceLogicalKey(\n        params.specFolder,\n        params.canonicalFilePath || params.filePath,\n        params.anchorId,\n      ),\n      requestedTier: params.requestedTier ?? undefined,\n      previousTier: params.previousTier ?? undefined,\n      nextTier: params.nextTier,\n      source: params.source,\n      filePath: params.filePath ?? null,\n      canonicalFilePath: params.canonicalFilePath ?? null,\n    });\n  } catch (error: unknown) {\n    logger.warn('Failed to record governance audit for tier downgrade', {\n      memoryId: params.memoryId,\n      source: params.source,\n      message: get_error_message(error),\n    });\n  }\n}\n\nfunction deleteAncillaryMemoryRows(database: Database.Database, id: number): void {\n  const ancillaryTables = [\n    'DELETE FROM degree_snapshots WHERE memory_id = ?',\n    'DELETE FROM community_assignments WHERE memory_id = ?',\n    'DELETE FROM memory_summaries WHERE memory_id = ?',\n    'DELETE FROM memory_entities WHERE memory_id = ?',\n    'DELETE FROM memory_lineage WHERE memory_id = ?',\n  ];\n\n  for (const sql of ancillaryTables) {\n    try {\n      const paramCount = (sql.match(/\\?/g) || []).length;\n      if (paramCount === 2) {\n        database.prepare(sql).run(id, id);\n      } else {\n        database.prepare(sql).run(id);\n      }\n    } catch (_error: unknown) {\n      // Best-effort for legacy databases that may not have these tables yet.\n    }\n  }\n\n  // Clean active_memory_projection rows referencing this memory.\n  try {\n    database.prepare('DELETE FROM active_memory_projection WHERE active_memory_id = ?').run(id);\n  } catch (_error: unknown) {\n    // Best-effort for legacy databases that may not have projection tables yet.\n  }\n\n  try {\n    const result = sweepCausalEdges(database, {\n      memoryIds: [id, String(id)],\n      reason: 'memory row mutation cleanup',\n      command: 'vector-index-mutations.deleteAncillaryMemoryRows',\n      restoreContext: { memoryId: id },\n      invalidateCaches: false,\n    });\n    if (result.deleted > 0) {\n      invalidateGraphCaches(database);\n    }\n  } catch (error: unknown) {\n    // Tolerate only legacy databases that predate the causal-edge tables. Scope\n    // the match to those table names so an unrelated missing-table error still\n    // propagates and rolls back the surrounding delete instead of committing a\n    // hard delete without its tombstone audit row.\n    const message = error instanceof Error ? error.message : String(error);\n    if (!/no such table:\\s*causal_edge/i.test(message)) {\n      throw error;\n    }\n  }\n}\n\nfunction upsert_active_projection(\n  database: ReturnType<typeof initialize_db>,\n  specFolder: string,\n  canonicalFilePath: string,\n  anchorId: string | null,\n  memoryId: number,\n  updatedAt: string,\n  scope: NormalizedMemoryScope,\n): void {\n  const logicalKey = buildMemoryLogicalKey({\n    specFolder,\n    filePath: canonicalFilePath,\n    canonicalFilePath,\n    anchorId,\n    ...scope,\n  });\n  // Evict any stale projection row that maps a *different* logical_key to the\n  // same active_memory_id — prevents UNIQUE constraint violation on re-index\n  // when the logical_key changes (e.g. anchor or path normalization drift).\n  database.prepare(\n    'DELETE FROM active_memory_projection WHERE active_memory_id = ? AND logical_key != ?',\n  ).run(memoryId, logicalKey);\n  database.prepare(`\n    INSERT INTO active_memory_projection (logical_key, root_memory_id, active_memory_id, updated_at)\n    VALUES (?, ?, ?, ?)\n    ON CONFLICT(logical_key) DO UPDATE SET\n      root_memory_id = excluded.root_memory_id,\n      active_memory_id = excluded.active_memory_id,\n      updated_at = excluded.updated_at\n  `).run(logicalKey, memoryId, memoryId, updatedAt);\n}\n\n// These mutation-local extensions are intentional until the shared query/store\n// contract adopts appendOnly and canonicalFilePath semantics.\ntype IndexMemoryParams = Readonly<SharedIndexMemoryParams> & {\n  readonly appendOnly?: boolean;\n};\ntype IndexMemoryDeferredParams = Omit<IndexMemoryParams, 'embedding'> & {\n  readonly failureReason?: string | null;\n};\ntype UpdateMemoryParams = Readonly<SharedUpdateMemoryParams> & {\n  readonly canonicalFilePath?: string;\n  // Set when the row's document now lives at a new on-disk location, so a\n  // moved file repoints its existing row instead of leaving a stale path.\n  readonly filePath?: string;\n};\n\ntype NormalizedMemoryScope = {\n  tenant_id: string | null;\n  user_id: string | null;\n  agent_id: string | null;\n  session_id: string | null;\n};\n\nfunction normalizeMemoryScope(scope?: MemoryScopeParams): NormalizedMemoryScope {\n  return {\n    tenant_id: normalizeScopeValue(scope?.tenantId),\n    user_id: normalizeScopeValue(scope?.userId),\n    agent_id: normalizeScopeValue(scope?.agentId),\n    session_id: normalizeScopeValue(scope?.sessionId),\n  };\n}\n\n/**\n * Indexes a memory with an embedding payload.\n * @param params - The memory values to index.\n * @returns The indexed memory identifier.\n * @throws {VectorIndexError} When embedding validation fails or the mutation cannot be applied.\n * @example\n * ```ts\n * const id = index_memory({\n *   specFolder: 'specs/001-demo',\n *   filePath: 'spec.md',\n *   embedding,\n * });\n * ```\n */\nexport function index_memory(\n  params: IndexMemoryParams,\n  database: Database.Database = initialize_db(),\n): number {\n  const {\n    specFolder,\n    filePath,\n    parentId = null,\n    anchorId = null,\n    title = null,\n    triggerPhrases = [],\n    importanceWeight = 0.5,\n    embedding,\n    encodingIntent,\n    documentType = 'memory',\n    specLevel = null,\n    contentText = null,\n    qualityScore = 0,\n    qualityFlags = [],\n    appendOnly = false,\n  } = params;\n  const scope = normalizeMemoryScope(params.scope);\n\n  if (!embedding) {\n    throw new VectorIndexError('Embedding is required', VectorIndexErrorCode.EMBEDDING_VALIDATION);\n  }\n\n  const expected_dim = get_embedding_dim();\n  if (embedding.length !== expected_dim) {\n    console.warn(`[vector-index] Embedding dimension mismatch: expected ${expected_dim}, got ${embedding.length}`);\n    throw new VectorIndexError(\n      `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n      VectorIndexErrorCode.EMBEDDING_VALIDATION,\n    );\n  }\n\n  const now = new Date().toISOString();\n  const triggers_json = JSON.stringify(triggerPhrases);\n  const embedding_buffer = to_embedding_buffer(embedding);\n  const canonicalFilePath = getCanonicalPathKey(filePath);\n\n  const stmts = init_prepared_statements(database);\n  const existing = appendOnly\n    ? null\n    : stmts.get_by_folder_and_path.get(\n        specFolder,\n        canonicalFilePath,\n        filePath,\n        canonicalFilePath,\n        filePath,\n        anchorId,\n        scope.tenant_id,\n        scope.user_id,\n        scope.agent_id,\n        scope.session_id,\n      );\n\n  if (existing && !appendOnly) {\n    return update_memory({\n      id: existing.id,\n      title: title ?? undefined,\n      triggerPhrases,\n      importanceWeight,\n      embedding,\n      encodingIntent,\n      documentType,\n      specLevel,\n      contentText,\n      qualityScore,\n      qualityFlags,\n      canonicalFilePath,\n      filePath,\n    }, database);\n  }\n\n  const sqlite_vec = get_sqlite_vec_available();\n\n  const index_memory_tx = database.transaction(() => {\n    const embedding_status = sqlite_vec ? 'success' : 'pending';\n\n    const result = database.prepare(`\n      INSERT INTO memory_index (\n        spec_folder, file_path, canonical_file_path, anchor_id, title, trigger_phrases,\n        importance_weight, created_at, updated_at, embedding_model,\n        embedding_generated_at, embedding_status, encoding_intent, document_type, spec_level,\n        content_text, quality_score, quality_flags, parent_id,\n        tenant_id, user_id, agent_id, session_id\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      specFolder, filePath, canonicalFilePath, anchorId, title, triggers_json,\n      importanceWeight, now, now, embeddingsProvider.getModelName(), now, embedding_status,\n      encodingIntent ?? 'document', documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), parentId,\n      scope.tenant_id, scope.user_id, scope.agent_id, scope.session_id\n    );\n\n    const row_id = BigInt(result.lastInsertRowid);\n    const metadata_id = Number(row_id);\n\n    upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, metadata_id, now, scope);\n\n    if (sqlite_vec) {\n      writeActiveVectorPayload(database, row_id, embedding_buffer);\n    }\n\n    refresh_interference_scores_for_folder(database, specFolder);\n    clear_search_cache();\n\n    return metadata_id;\n  });\n\n  return index_memory_tx();\n}\n\n// Deferred indexing - entry searchable via BM25/FTS5 only\n/**\n * Indexes a memory record without storing an embedding yet.\n * @param params - The deferred memory values to index.\n * @returns The indexed memory identifier.\n */\nexport function index_memory_deferred(\n  params: IndexMemoryDeferredParams,\n  database: Database.Database = initialize_db(),\n): number {\n  const {\n    specFolder,\n    filePath,\n    parentId = null,\n    anchorId = null,\n    title = null,\n    triggerPhrases = [],\n    importanceWeight = 0.5,\n    failureReason = null,\n    encodingIntent,\n    documentType = 'memory',\n    specLevel = null,\n    contentText = null,\n    qualityScore = 0,\n    qualityFlags = [],\n    appendOnly = false,\n  } = params;\n  const scope = normalizeMemoryScope(params.scope);\n\n  const now = new Date().toISOString();\n  const triggers_json = JSON.stringify(triggerPhrases);\n  const canonicalFilePath = getCanonicalPathKey(filePath);\n\n  const stmts = init_prepared_statements(database);\n  const existing = appendOnly\n    ? null\n    : stmts.get_by_folder_and_path.get(\n        specFolder,\n        canonicalFilePath,\n        filePath,\n        canonicalFilePath,\n        filePath,\n        anchorId,\n        scope.tenant_id,\n        scope.user_id,\n        scope.agent_id,\n        scope.session_id,\n      );\n\n  const index_memory_deferred_tx = database.transaction(() => {\n    if (existing && !appendOnly) {\n      database.prepare(`\n        UPDATE memory_index\n        SET title = ?,\n            trigger_phrases = ?,\n            importance_weight = ?,\n            file_path = ?,\n            canonical_file_path = ?,\n            embedding_status = 'pending',\n            failure_reason = ?,\n            updated_at = ?,\n            encoding_intent = COALESCE(?, encoding_intent),\n            document_type = ?,\n            spec_level = ?,\n            content_text = ?,\n            quality_score = ?,\n            quality_flags = ?,\n            retry_count = 0,\n            last_retry_at = NULL\n        WHERE id = ?\n      `).run(title, triggers_json, importanceWeight, filePath, canonicalFilePath, failureReason, now, encodingIntent, documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), existing.id);\n      upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, existing.id, now, scope);\n      refresh_interference_scores_for_folder(database, specFolder);\n      return existing.id;\n    }\n\n    const result = database.prepare(`\n      INSERT INTO memory_index (\n        spec_folder, file_path, canonical_file_path, anchor_id, title, trigger_phrases,\n        importance_weight, created_at, updated_at, embedding_status,\n        failure_reason, retry_count, encoding_intent, document_type, spec_level,\n        content_text, quality_score, quality_flags, parent_id,\n        tenant_id, user_id, agent_id, session_id\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, 'pending', ?, 0, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      specFolder, filePath, canonicalFilePath, anchorId, title, triggers_json,\n      importanceWeight, now, now, failureReason, encodingIntent ?? 'document', documentType, specLevel, contentText, qualityScore, JSON.stringify(qualityFlags), parentId,\n      scope.tenant_id, scope.user_id, scope.agent_id, scope.session_id\n    );\n\n    const row_id = BigInt(result.lastInsertRowid);\n    upsert_active_projection(database, specFolder, canonicalFilePath, anchorId, Number(row_id), now, scope);\n    refresh_interference_scores_for_folder(database, specFolder);\n    logger.info(`Deferred indexing: Memory ${Number(row_id)} saved without embedding (BM25/FTS5 searchable)`);\n\n    return Number(row_id);\n  });\n\n  return index_memory_deferred_tx();\n}\n\n/**\n * Updates stored memory metadata and embeddings.\n * @param params - The memory values to update.\n * @returns The updated memory identifier.\n * @throws {VectorIndexError} When embedding validation fails or the mutation transaction cannot complete.\n * @example\n * ```ts\n * const id = update_memory({ id: 42, title: 'Updated title', embedding });\n * ```\n */\nexport function update_memory(\n  params: UpdateMemoryParams,\n  database: Database.Database = initialize_db(),\n): number {\n  const {\n    id,\n    title,\n    triggerPhrases,\n    importanceWeight,\n    importanceTier,\n    embedding,\n    canonicalFilePath,\n    filePath,\n    encodingIntent,\n    documentType,\n    specLevel,\n    contentText,\n    qualityScore,\n    qualityFlags,\n  } = params;\n\n  const now = new Date().toISOString();\n\n  const update_memory_tx = database.transaction(() => {\n    const existingRow = database.prepare(`\n      SELECT spec_folder, anchor_id, canonical_file_path, file_path, importance_tier,\n             tenant_id, user_id, agent_id, session_id\n      FROM memory_index\n      WHERE id = ?\n    `).get(id) as {\n      spec_folder: string | null;\n      anchor_id: string | null;\n      canonical_file_path: string | null;\n      file_path: string | null;\n      importance_tier: string | null;\n      tenant_id: string | null;\n      user_id: string | null;\n      agent_id: string | null;\n      session_id: string | null;\n    } | undefined;\n    const updates = ['updated_at = ?'];\n    const values: unknown[] = [now];\n\n    if (title !== undefined) {\n      updates.push('title = ?');\n      values.push(title);\n    }\n    if (triggerPhrases !== undefined) {\n      updates.push('trigger_phrases = ?');\n      values.push(JSON.stringify(triggerPhrases));\n    }\n    if (importanceWeight !== undefined) {\n      updates.push('importance_weight = ?');\n      values.push(importanceWeight);\n    }\n    if (importanceTier !== undefined) {\n      let nextImportanceTier = importanceTier;\n      const previousTier = existingRow?.importance_tier ?? null;\n      if (\n        existingRow\n      ) {\n        const guardPath = existingRow.canonical_file_path || existingRow.file_path;\n        const hasNonConstitutionalPath = guardPath && !isIndexableConstitutionalMemoryPath(guardPath);\n        if (hasNonConstitutionalPath && importanceTier === 'constitutional') {\n          // Non-constitutional paths cannot be promoted to constitutional tier.\n          nextImportanceTier = 'important';\n        }\n        if (\n          hasNonConstitutionalPath\n          && (\n            importanceTier === 'constitutional'\n            || (previousTier === 'constitutional' && nextImportanceTier !== 'constitutional')\n          )\n        ) {\n          tryRecordTierDowngradeAudit(database, {\n            memoryId: id,\n            specFolder: existingRow.spec_folder,\n            anchorId: existingRow.anchor_id,\n            filePath: existingRow.file_path,\n            canonicalFilePath: existingRow.canonical_file_path,\n            requestedTier: importanceTier,\n            previousTier,\n            nextTier: nextImportanceTier,\n            source: 'update_memory',\n          });\n        }\n      }\n      updates.push('importance_tier = ?');\n      values.push(nextImportanceTier);\n      clear_constitutional_cache();\n    }\n    if (canonicalFilePath !== undefined) {\n      updates.push('canonical_file_path = ?');\n      values.push(canonicalFilePath);\n    }\n    if (filePath !== undefined) {\n      updates.push('file_path = ?');\n      values.push(filePath);\n    }\n    if (encodingIntent !== undefined) {\n      updates.push('encoding_intent = ?');\n      values.push(encodingIntent);\n    }\n    if (documentType !== undefined) {\n      updates.push('document_type = ?');\n      values.push(documentType);\n    }\n    if (specLevel !== undefined) {\n      updates.push('spec_level = ?');\n      values.push(specLevel);\n    }\n    if (contentText !== undefined) {\n      updates.push('content_text = ?');\n      values.push(contentText);\n    }\n    if (qualityScore !== undefined) {\n      updates.push('quality_score = ?');\n      values.push(qualityScore);\n    }\n    if (qualityFlags !== undefined) {\n      updates.push('quality_flags = ?');\n      values.push(JSON.stringify(qualityFlags));\n    }\n    if (embedding) {\n      updates.push('embedding_model = ?');\n      updates.push('embedding_generated_at = ?');\n      updates.push('embedding_status = ?');\n      values.push(embeddingsProvider.getModelName(), now, 'pending');\n    }\n\n    values.push(id);\n\n    const updateResult = database.prepare(`\n      UPDATE memory_index SET ${updates.join(', ')} WHERE id = ?\n    `).run(...values);\n\n    // Return early if the target row no longer exists.\n    if (updateResult.changes === 0) {\n      return id;\n    }\n\n    const sqlite_vec = get_sqlite_vec_available();\n    if (embedding && sqlite_vec) {\n      const expected_dim = get_embedding_dim();\n      if (embedding.length !== expected_dim) {\n        console.warn(`[vector-index] Embedding dimension mismatch in update: expected ${expected_dim}, got ${embedding.length}`);\n        throw new VectorIndexError(\n          `Embedding must be ${expected_dim} dimensions, got ${embedding.length}`,\n          VectorIndexErrorCode.EMBEDDING_VALIDATION,\n        );\n      }\n\n      const embedding_buffer = to_embedding_buffer(embedding);\n      writeActiveVectorPayload(database, BigInt(id), embedding_buffer);\n      database.prepare('UPDATE memory_index SET embedding_status = ? WHERE id = ?').run('success', id);\n    }\n\n    if (existingRow?.spec_folder) {\n      const projectionPath = canonicalFilePath\n        ?? existingRow.canonical_file_path\n        ?? getCanonicalPathKey(existingRow.file_path ?? '');\n      upsert_active_projection(database, existingRow.spec_folder, projectionPath, existingRow.anchor_id ?? null, id, now, {\n        tenant_id: existingRow.tenant_id,\n        user_id: existingRow.user_id,\n        agent_id: existingRow.agent_id,\n        session_id: existingRow.session_id,\n      });\n    }\n\n    if (existingRow?.spec_folder) {\n      refresh_interference_scores_for_folder(database, existingRow.spec_folder);\n    }\n    clear_search_cache();\n\n    return id;\n  });\n\n  return update_memory_tx();\n}\n\n/**\n * Deletes a memory and its related index records.\n * @param id - The memory identifier.\n * @returns True when a memory was deleted.\n * @throws {VectorIndexError} Propagates mutation or store initialization failures from the delete pipeline.\n * @example\n * ```ts\n * const deleted = delete_memory(42);\n * ```\n */\nexport function delete_memory(id: number, database: Database.Database = initialize_db()): boolean {\n  return delete_memory_from_database(database, id);\n}\n\n/**\n * Deletes a memory and related index records using the provided database handle.\n * @param database - The database containing the target memory.\n * @param id - The memory identifier.\n * @returns True when a memory was deleted.\n * @throws {VectorIndexError} Propagates mutation failures encountered while deleting the memory.\n * @example\n * ```ts\n * const deleted = delete_memory_from_database(database, 42);\n * ```\n */\nexport function delete_memory_from_database(database: Database.Database, id: number): boolean {\n  const sqlite_vec = get_sqlite_vec_available();\n\n  const delete_memory_tx = database.transaction(() => {\n    // Memory_history rows are intentionally preserved after deletion\n    // So DELETE audit events recorded by handlers persist as audit trail.\n    const row = database.prepare('SELECT content_hash FROM memory_index WHERE id = ?').get(id) as\n      | { content_hash: string | null }\n      | undefined;\n\n    if (sqlite_vec) {\n      try {\n        deleteActiveVectorPayload(database, BigInt(id));\n      } catch (e: unknown) {\n        if (!isExpectedMissingVecMemoriesTable(e)) {\n          throw new VectorIndexError(\n            `Vector deletion failed for memory ${id}: ${get_error_message(e)}`,\n            VectorIndexErrorCode.MUTATION_FAILED,\n          );\n        }\n      }\n    }\n\n    // Clean ancillary records so deletes do not leave graph residue behind.\n    deleteAncillaryMemoryRows(database, id);\n\n    if (row?.content_hash) {\n      // Governed retention delete semantics include derived embedding-cache rows.\n      try {\n        deleteByContentHash(database, row.content_hash);\n      } catch (_error: unknown) {\n        // Legacy or test databases may not have embedding_cache yet.\n      }\n    }\n\n    const result = database.prepare('DELETE FROM memory_index WHERE id = ?').run(id);\n\n    clear_search_cache();\n    clear_constitutional_cache();\n\n    return result.changes > 0;\n  });\n\n  // Remove the BM25 document only after the source row is deleted.\n  const deleted = delete_memory_tx();\n  if (deleted) {\n    // Invalidate entity-density cache so deleted memory's tokens are not routed\n    // to the graph channel beyond the 60s TTL window. Best-effort: non-fatal.\n    try {\n      invalidateEntityDensityCache();\n    } catch (_error: unknown) {\n      // Cache invalidation is best-effort; do not mask a successful delete.\n    }\n  }\n  if (deleted) {\n    try {\n      if (bm25Index.isBm25Enabled()) {\n        bm25Index.getIndex().removeDocument(String(id));\n      }\n    } catch (_error: unknown) {\n      // BEST-EFFORT BM25 CLEANUP MUST NOT MASK A SUCCESSFUL PRIMARY DELETE.\n    }\n  }\n  return deleted;\n}\n\n/**\n * Deletes the latest memory for a file path and optional anchor.\n * @param spec_folder - The owning spec folder.\n * @param file_path - The file path to delete.\n * @param anchor_id - The optional anchor identifier.\n * @returns True when a memory was deleted.\n * @throws {VectorIndexError} Propagates delete failures from the underlying mutation helpers.\n * @example\n * ```ts\n * const deleted = delete_memory_by_path('specs/001-demo', 'spec.md');\n * ```\n */\nexport function delete_memory_by_path(\n  spec_folder: string,\n  file_path: string,\n  anchor_id: string | null = null,\n  database: Database.Database = initialize_db(),\n): boolean {\n  const canonicalPath = getCanonicalPathKey(file_path);\n\n  const row = database.prepare(`\n    SELECT id, spec_folder FROM memory_index\n    WHERE spec_folder = ?\n      AND (canonical_file_path = ? OR file_path = ?)\n      AND (anchor_id = ? OR (anchor_id IS NULL AND ? IS NULL))\n    ORDER BY id DESC\n    LIMIT 1\n  `).get(spec_folder, canonicalPath, file_path, anchor_id, anchor_id) as { id: number; spec_folder?: string | null } | undefined;\n\n  if (row) {\n    const deleted = delete_memory_from_database(database, row.id);\n    if (deleted) {\n      // Self-record DELETE history only after the delete succeeded.\n      try {\n        recordHistory(row.id, 'DELETE', file_path ?? null, null, 'mcp:delete_by_path', row.spec_folder ?? spec_folder);\n      } catch (_histErr: unknown) {\n        // BEST-EFFORT HISTORY WRITES MUST NOT MASK A SUCCESSFUL DELETE.\n      }\n    }\n    return deleted;\n  }\n  return false;\n}\n\n/**\n * Deletes multiple memories in a single transaction.\n * @param memory_ids - The memory identifiers to delete.\n * @returns Counts for deleted and failed items.\n * @throws {VectorIndexError} When one or more deletes fail and the transaction is rolled back.\n * @example\n * ```ts\n * const outcome = delete_memories([1, 2, 3]);\n * ```\n */\nexport function delete_memories(\n  memory_ids: number[],\n  database: Database.Database = initialize_db(),\n): { deleted: number; failed: number } {\n  if (!memory_ids || memory_ids.length === 0) {\n    return { deleted: 0, failed: 0 };\n  }\n  const sqlite_vec = get_sqlite_vec_available();\n  let deleted = 0;\n  let failed = 0;\n  const deletedIds: number[] = [];\n\n  const specFolderById = new Map<number, string | null>();\n  for (const id of memory_ids) {\n    if (!Number.isInteger(id) || id <= 0) {\n      continue;\n    }\n    try {\n      const row = database.prepare('SELECT spec_folder FROM memory_index WHERE id = ?').get(id) as { spec_folder?: string | null } | undefined;\n      specFolderById.set(id, row?.spec_folder ?? null);\n    } catch (_error: unknown) {\n      specFolderById.set(id, null);\n    }\n  }\n\n  const delete_transaction = database.transaction(() => {\n    let transactionDeleted = 0;\n    let transactionFailed = 0;\n    const failed_ids: number[] = [];\n\n    for (const id of memory_ids) {\n      try {\n        if (sqlite_vec) {\n          try {\n            deleteActiveVectorPayload(database, BigInt(id));\n          } catch (vec_error: unknown) {\n            console.warn(`[VectorIndex] Failed to delete vector for memory ${id}: ${get_error_message(vec_error)}`);\n          }\n        }\n\n        deleteAncillaryMemoryRows(database, id);\n        const result = database.prepare('DELETE FROM memory_index WHERE id = ?').run(id);\n        if (result.changes > 0) {\n          // Memory_history rows are intentionally preserved after deletion\n          // So DELETE audit events recorded here persist as audit trail.\n          try {\n            recordHistory(id, 'DELETE', null, null, 'mcp:delete_memories', specFolderById.get(id) ?? null);\n          } catch (_histErr: unknown) {\n            // BEST-EFFORT HISTORY WRITES MUST NOT MASK A SUCCESSFUL DELETE.\n          }\n          transactionDeleted++;\n          deletedIds.push(id);\n        } else {\n          transactionFailed++;\n          failed_ids.push(id);\n        }\n      } catch (e: unknown) {\n        console.warn(`[vector-index] Failed to delete memory ${id}: ${get_error_message(e)}`);\n        transactionFailed++;\n        failed_ids.push(id);\n      }\n    }\n\n    if (failed_ids.length > 0) {\n      throw new VectorIndexError(\n        `Failed to delete memories: ${failed_ids.join(', ')}. Transaction rolled back.`,\n        VectorIndexErrorCode.MUTATION_FAILED,\n      );\n    }\n\n    return {\n      deleted: transactionDeleted,\n      failed: transactionFailed,\n    };\n  });\n\n  try {\n    const outcome = delete_transaction();\n    deleted = outcome.deleted;\n    failed = outcome.failed;\n    if (deleted > 0) {\n      clear_constitutional_cache();\n      clear_search_cache();\n      // Invalidate entity-density cache so deleted memories' tokens are evicted\n      // immediately rather than persisting for up to the 60s TTL. Best-effort.\n      try {\n        invalidateEntityDensityCache();\n      } catch (_error: unknown) {\n        // Cache invalidation is best-effort; do not mask a successful delete.\n      }\n      try {\n        if (bm25Index.isBm25Enabled()) {\n          const bm25 = bm25Index.getIndex();\n          for (const id of deletedIds) {\n            bm25.removeDocument(String(id));\n          }\n        }\n      } catch (_error: unknown) {\n        // BM25 cleanup is best-effort for bulk deletes as well.\n      }\n    }\n  } catch (e: unknown) {\n    console.warn(`[vector-index] delete_memories transaction error: ${get_error_message(e)}`);\n    deleted = 0;\n    failed = memory_ids.length;\n  }\n\n  return { deleted, failed };\n}\n\n// Valid statuses: 'pending', 'success', 'failed', 'retry', 'partial'\n/**\n * Updates the embedding status for a memory.\n * @param id - The memory identifier.\n * @param status - The new embedding status.\n * @returns True when the status was updated.\n */\nexport function update_embedding_status(\n  id: number,\n  status: string,\n  database: Database.Database = initialize_db(),\n): boolean {\n  const valid_statuses = ['pending', 'success', 'failed', 'retry', 'partial'];\n  if (!valid_statuses.includes(status)) {\n    console.warn(`[vector-index] Invalid embedding status: ${status}`);\n    return false;\n  }\n\n  try {\n    const result = database.prepare(`\n      UPDATE memory_index\n      SET embedding_status = ?, updated_at = datetime('now')\n      WHERE id = ?\n    `).run(status, id);\n\n    return result.changes > 0;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to update embedding status for ${id}: ${get_error_message(error)}`);\n    return false;\n  }\n}\n\n/**\n * Updates the confidence value for a memory.\n * @param memory_id - The memory identifier.\n * @param confidence - The confidence value to store.\n * @returns True when the confidence was updated.\n */\nexport function update_confidence(\n  memory_id: number,\n  confidence: number,\n  database: Database.Database = initialize_db(),\n): boolean {\n  if (typeof confidence !== 'number' || confidence < 0 || confidence > 1) {\n    console.warn(`[vector-index] Invalid confidence value: ${confidence}`);\n    return false;\n  }\n\n  try {\n    const result = database.prepare(`\n      UPDATE memory_index\n      SET confidence = ?\n      WHERE id = ?\n    `).run(confidence, memory_id);\n\n    return result.changes > 0;\n  } catch (error: unknown) {\n    console.warn(`[vector-index] Failed to update confidence for ${memory_id}: ${get_error_message(error)}`);\n    return false;\n  }\n}\n\n// Exported so the store-port clear() can resolve and purge the active per-dim\n// vector shard, mirroring the per-record delete path.\nexport { activeDimVectorSource };\n\n// CamelCase aliases\nexport { index_memory as indexMemory };\nexport { index_memory_deferred as indexMemoryDeferred };\nexport { update_memory as updateMemory };\nexport { delete_memory as deleteMemory };\nexport { delete_memory_by_path as deleteMemoryByPath };\nexport { delete_memories as deleteMemories };\nexport { update_embedding_status as updateEmbeddingStatus };\nexport { update_confidence as updateConfidence };","lineStart":1,"lineEnd":1021,"totalLines":1021,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-mutations.ts","time":{"start":1781762694114,"end":1781762694122}},"metadata":{"openai":{"itemId":"fc_071c84d92e422b80016a338a84fd308191bbc8d1cafc938ce4"}},"id":"prt_ed9551b33001lZRTz6k7bSILek","sessionID":"ses_126add179ffeFYyiaZOsieAbUe","messageID":"msg_ed954d95e001dqM6EwcitRzirn"}}
{"type":"tool_use","timestamp":1781762694160,"sessionID":"ses_126add179ffeFYyiaZOsieAbUe","part":{"type":"tool","tool":"grep","callID":"call_m3qfnMB3aAzedMAnkrhwRAb9","state":{"status":"completed","input":{"pattern":"SPECKIT_SOFT_DELETE_TOMBSTONES|idx_memory_purgeable_retention|deleted_at","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server","include":"*.ts"},"output":"Found 72 matches\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-bulk-delete.ts:\n  Line 44:     return columns.some((column) => column.name === 'deleted_at');\n\n  Line 51:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n\n  Line 66:     SET deleted_at = COALESCE(deleted_at, ?),\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-crud-delete.ts:\n  Line 72:     return columns.some((column) => column.name === 'deleted_at');\n\n  Line 79:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n\n  Line 94:     SET deleted_at = COALESCE(deleted_at, ?),\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/governance/memory-retention-sweep.ts:\n  Line 134:   return process.env.SPECKIT_SOFT_DELETE_TOMBSTONES?.trim().toLowerCase() === 'true';\n\n  Line 142:   const hasDeletedAt = presentColumns.has('deleted_at');\n\n  Line 143:   const usePurgeableIndex = useSoftDeleteTombstones && hasDeletedAt && hasIndex(database, 'idx_memory_purgeable_retention');\n\n  Line 145:     ? 'memory_index INDEXED BY idx_memory_purgeable_retention'\n\n  Line 147:   const deletedAtSelect = hasDeletedAt ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n\n  Line 148:   const tombstonePredicate = useSoftDeleteTombstones && hasDeletedAt ? 'AND deleted_at IS NOT NULL' : '';\n\n  Line 207:   const deletedAtSelect = presentColumns.has('deleted_at') ? 'deleted_at AS deletedAt' : 'NULL AS deletedAt';\n\n  Line 208:   const tombstonePredicate = useSoftDeleteTombstones && presentColumns.has('deleted_at') ? 'AND deleted_at IS NOT NULL' : '';\n\n  Line 259:   const usesPurgeablePartition = useSoftDeleteTombstones && columns.has('deleted_at');\n\n  Line 262:     usingPurgeableIndex: usesPurgeablePartition && hasIndex(database, 'idx_memory_purgeable_retention'),\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tests/causal-edge-tombstones.vitest.ts:\n  Line 18: const SOFT_DELETE_FLAG = 'SPECKIT_SOFT_DELETE_TOMBSTONES';\n\n  Line 35:   const row = db.prepare('SELECT deleted_at FROM memory_index WHERE id = ?').get(id) as { deleted_at: string | null };\n\n  Line 36:   return row.deleted_at;\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-schema.ts:\n  Line 73:     'idx_memory_purgeable_retention',\n\n  Line 112:   'deleted_at',\n\n  Line 235:   WHERE deleted_at IS NULL\n\n  Line 238:   CREATE INDEX IF NOT EXISTS idx_memory_purgeable_retention\n\n  Line 239:   ON memory_index(delete_after, deleted_at, id)\n\n  Line 240:   WHERE deleted_at IS NOT NULL\n\n  Line 718:     { name: 'deleted_at', sql: 'ALTER TABLE memory_index ADD COLUMN deleted_at TEXT' },\n\n  Line 722:   createRequiredIndex(database, 'idx_memory_purgeable_retention', MEMORY_PURGEABLE_RETENTION_INDEX_SQL, context);\n\n  Line 2855:       indexes: ['idx_memory_active_recall', 'idx_memory_purgeable_retention'],\n\n  Line 3101:       deleted_at TEXT,\n\n  Line 3264:       WHERE deleted_at IS NULL;\n\n  Line 3265:     CREATE INDEX IF NOT EXISTS idx_memory_purgeable_retention\n\n  Line 3266:       ON memory_index(delete_after, deleted_at, id)\n\n  Line 3267:       WHERE deleted_at IS NOT NULL;\n\n\n/Users/michelkerkmeester/MEGA/Development/Cod