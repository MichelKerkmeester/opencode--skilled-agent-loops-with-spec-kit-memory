   109	    const fixture = readJson(filePath);
   110	    try {
   111	      assertSafeFixtureId(fixture.id);
   112	    } catch (error) {
   113	      process.stderr.write(`${error.message}\n`);
   114	      process.exit(1);
   115	    }
   116	    materialized.push(fixture);
   117	  }
   118	
   119	  fs.mkdirSync(outputsDir, { recursive: true });
   120	  for (const fixture of materialized) {
   121	    fs.writeFileSync(path.join(outputsDir, `${fixture.id}.md`), renderFixture(fixture), 'utf8');
   122	  }
   123	
   124	  process.stdout.write(JSON.stringify({
   125	    status: 'fixtures-materialized',
   126	    profileId: profile.profileId || profile.id,
   127	    outputsDir,
   128	    fixtures: fixtureRefs.length,
   129	  }) + '\n');
   130	}
   131	
   132	main();

