ON_HYDRATION_BYTES,\n457:     }, engineOptions);\n458:   } catch (error) {\n459:     if (!isKnownRetrievalUnavailable(error)) throw error;\n460:     return { ok: false, error: error.code ?? 'manifest-invalid' };\n461:   }\n462: }\n463: \n464: // ─────────────────────────────────────────────────────────────────────────────\n465: // 5. PUBLIC API\n466: // ─────────────────────────────────────────────────────────────────────────────\n467: \n468: /**\n469:  * Build zero to two non-authoritative audit comparison rows.\n470:  *\n471:  * @param {Object} input - Neutral plan, typed comparison selections, and target evidence.\n472:  * @param {Object} engineOptions - Retrieval-engine corpus and manifest paths.\n473:  * @returns {Promise<Object>} Comparison context, unavailable evidence, or refusal.\n474:  */\n475: export async function buildAuditComparisonLane(input, engineOptions = {}) {\n476:   const validation = validateAuditComparisonRequest(input);\n477:   if (!validation.valid) {\n478:     return { ok: false, error: 'invalid-audit-comparison-request', details: validation.errors };\n479:   }\n480:   const request = immutableSnapshot(input);\n481:   const authoritySnapshot = request.authorityInputs;\n482:   const blockedOutcome = blockingPlanOutcome(request.contextPlan);\n483:   if (blockedOutcome) {\n484:     return unavailableResult(request.contextPlan, blockedOutcome);\n485:   }\n486: \n487:   let query;\n488:   try {\n489:     query = await runQuery({\n490:       ...(request.retrievalRequest ?? {}),\n491:       usage: 'reference',\n492:       exactReuse: false,\n493:       limit: MAX_QUERY_CARDS,\n494:     }, engineOptions);\n495:   } catch (error) {\n496:     if (!isKnownRetrievalUnavailable(error)) throw error;\n497:     return unavailableResult(\n498:       request.contextPlan,\n499:       'no-fit',\n500:       [`retrieval-unavailable:${error.code ?? 'invalid-manifest'}`],\n501:     );\n502:   }\n503:   if (query.generationHash !== request.contextPlan.generationIdentity.observedGenerationHash) {\n504:     return unavailableResult(\n505:       request.contextPlan,\n506:       'no-fit',\n507:       ['retrieval-unavailable:generation-mismatch'],\n508:     );\n509:   }\n510: \n511:   const rows = [];\n512:   const proofHandoffs = [];\n513:   const warnings = [];\n514:   for (const comparison of request.comparisons) {\n515:     const card = query.cards.find((candidate) => candidate.id === comparison.id);\n516:     if (!card) {\n517:       warnings.push(`comparison-unavailable:${comparison.id}`);\n518:       continue;\n519:     }\n520:     if (\n521:       comparison.relation === 'unexplained-drift'\n522:       && (\n523:         card.id !== comparison.intendedAnchor.sourceId\n524:         || card.contentHash !== comparison.intendedAnchor.contentHash\n525:       )\n526:     ) {\n527:       return {\n528:         ok: false,\n529:         error: 'intended-anchor-identity-mismatch',\n530:         details: [comparison.id],\n531:       };\n532:     }\n533:     const hydration = await hydrateComparison(card, engineOptions);\n534:     if (!hydration.ok) {\n535:       if (!HYDRATION_UNAVAILABLE_CODES.has(hydration.error)) {\n536:         return { ok: false, error: `comparison-${hydration.error}` };\n537:       }\n538:       warnings.push(`comparison-unavailable:${comparison.id}:${hydration.error}`);\n539:       continue;\n\n(Showing lines 420-539 of 600. Use offset=540 to continue.)\n</content>","metadata":{"preview":"\nfunction unavailableResult(contextPlan, outcome = 'no-fit', warnings = []) {\n  const proofHandoff = unavailableProofHandoff(contextPlan, outcome);\n  const proofError = validateBuiltProof(proofHandoff);\n  if (proofError) return proofError;\n  return {\n    ok: true,\n    outcome: 'comparison-unavailable',\n    schemaVersion: AUDIT_CORPUS_COMPARISON_VERSION,\n    authority: {\n      order: [...AUTHORITY_ORDER],\n      corpusRole: 'non-authoritative-context',\n    },\n    comparisons: [{\n      reference: null,\n      purpose: 'comparison-unavailable',\n      relation: 'comparison-unavailable',\n      axisObservations: [],\n      targetEvidence: [],\n      evidenceLabel: 'non-authoritative-context',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/design-audit/corpus/comparison-lane.mjs","text":"\nfunction unavailableResult(contextPlan, outcome = 'no-fit', warnings = []) {\n  const proofHandoff = unavailableProofHandoff(contextPlan, outcome);\n  const proofError = validateBuiltProof(proofHandoff);\n  if (proofError) return proofError;\n  return {\n    ok: true,\n    outcome: 'comparison-unavailable',\n    schemaVersion: AUDIT_CORPUS_COMPARISON_VERSION,\n    authority: {\n      order: [...AUTHORITY_ORDER],\n      corpusRole: 'non-authoritative-context',\n    },\n    comparisons: [{\n      reference: null,\n      purpose: 'comparison-unavailable',\n      relation: 'comparison-unavailable',\n      axisObservations: [],\n      targetEvidence: [],\n      evidenceLabel: 'non-authoritative-context',\n      limitation: 'target-evidence-only',\n      targetEvidenceRequired: true,\n    }],\n    proofHandoffs: [proofHandoff],\n    warnings,\n  };\n}\n\nasync function hydrateComparison(card, engineOptions) {\n  try {\n    return await runHydrate({\n      id: card.id,\n      generationHash: card.generationHash,\n      mode: 'audit',\n      usage: 'reference',\n      includes: ['DESIGN.md', 'design-tokens.json', 'source.md'],\n      maxBytes: COMPARISON_HYDRATION_BYTES,\n    }, engineOptions);\n  } catch (error) {\n    if (!isKnownRetrievalUnavailable(error)) throw error;\n    return { ok: false, error: error.code ?? 'manifest-invalid' };\n  }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. PUBLIC API\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Build zero to two non-authoritative audit comparison rows.\n *\n * @param {Object} input - Neutral plan, typed comparison selections, and target evidence.\n * @param {Object} engineOptions - Retrieval-engine corpus and manifest paths.\n * @returns {Promise<Object>} Comparison context, unavailable evidence, or refusal.\n */\nexport async function buildAuditComparisonLane(input, engineOptions = {}) {\n  const validation = validateAuditComparisonRequest(input);\n  if (!validation.valid) {\n    return { ok: false, error: 'invalid-audit-comparison-request', details: validation.errors };\n  }\n  const request = immutableSnapshot(input);\n  const authoritySnapshot = request.authorityInputs;\n  const blockedOutcome = blockingPlanOutcome(request.contextPlan);\n  if (blockedOutcome) {\n    return unavailableResult(request.contextPlan, blockedOutcome);\n  }\n\n  let query;\n  try {\n    query = await runQuery({\n      ...(request.retrievalRequest ?? {}),\n      usage: 'reference',\n      exactReuse: false,\n      limit: MAX_QUERY_CARDS,\n    }, engineOptions);\n  } catch (error) {\n    if (!isKnownRetrievalUnavailable(error)) throw error;\n    return unavailableResult(\n      request.contextPlan,\n      'no-fit',\n      [`retrieval-unavailable:${error.code ?? 'invalid-manifest'}`],\n    );\n  }\n  if (query.generationHash !== request.contextPlan.generationIdentity.observedGenerationHash) {\n    return unavailableResult(\n      request.contextPlan,\n      'no-fit',\n      ['retrieval-unavailable:generation-mismatch'],\n    );\n  }\n\n  const rows = [];\n  const proofHandoffs = [];\n  const warnings = [];\n  for (const comparison of request.comparisons) {\n    const card = query.cards.find((candidate) => candidate.id === comparison.id);\n    if (!card) {\n      warnings.push(`comparison-unavailable:${comparison.id}`);\n      continue;\n    }\n    if (\n      comparison.relation === 'unexplained-drift'\n      && (\n        card.id !== comparison.intendedAnchor.sourceId\n        || card.contentHash !== comparison.intendedAnchor.contentHash\n      )\n    ) {\n      return {\n        ok: false,\n        error: 'intended-anchor-identity-mismatch',\n        details: [comparison.id],\n      };\n    }\n    const hydration = await hydrateComparison(card, engineOptions);\n    if (!hydration.ok) {\n      if (!HYDRATION_UNAVAILABLE_CODES.has(hydration.error)) {\n        return { ok: false, error: `comparison-${hydration.error}` };\n      }\n      warnings.push(`comparison-unavailable:${comparison.id}:${hydration.error}`);\n      continue;","lineStart":420,"lineEnd":539,"totalLines":600,"truncated":true}},"title":".opencode/skills/sk-design/design-audit/corpus/comparison-lane.mjs","time":{"start":1784623065281,"end":1784623065307}},"metadata":{"openai":{"itemId":"fc_04d4f234fc391bda016a5f2fd913f08191a2760ca8eceeb84d"}},"id":"prt_f83d2e89f0014TdARgKc3Mk8iS","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d2bc16001LU4sPU2KLao3nN"}}
{"type":"tool_use","timestamp":1784623065315,"sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","part":{"type":"tool","tool":"read","callID":"call_eAg8mGNChK5d6gMQrs5hIUN5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/design-foundations/corpus/relationship-blueprint.mjs","offset":770,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/design-foundations/corpus/relationship-blueprint.mjs</path>\n<type>file</type>\n<content>\n770: function fallbackResult(input, outcome, warnings = []) {\n771:   const proofHandoff = negativeProofHandoff(input.contextPlan, outcome);\n772:   const proofError = validateBuiltProof(proofHandoff);\n773:   if (proofError) return proofError;\n774:   const snapshot = structuredClone(input.authorityInputs);\n775:   return {\n776:     ok: true,\n777:     outcome,\n778:     relationshipBlueprint: structuredClone(input.blueprint),\n779:     compatibilityGraph: {\n780:       schemaVersion: FOUNDATIONS_AXIS_COMPATIBILITY_VERSION,\n781:       nodes: [],\n782:       edges: [],\n783:     },\n784:     transformationLedger: {\n785:       schemaVersion: FOUNDATIONS_TRANSFORMATION_LEDGER_VERSION,\n786:       records: [],\n787:     },\n788:     downstreamChecks: structuredClone(input.downstreamChecks),\n789:     sources: [],\n790:     authorityPreservation: authorityPreservation(input.authorityInputs, snapshot),\n791:     averagedTokenValues: false,\n792:     copiedSourceSpecificMaterial: false,\n793:     proofHandoff,\n794:     warnings,\n795:   };\n796: }\n797: \n798: async function hydrateSource(card, engineOptions) {\n799:   try {\n800:     return await runHydrate({\n801:       id: card.id,\n802:       generationHash: card.generationHash,\n803:       mode: 'foundations',\n804:       usage: 'reference',\n805:       includes: ['DESIGN.md', 'design-tokens.json', 'source.md'],\n806:       maxBytes: HYDRATION_BYTES,\n807:     }, engineOptions);\n808:   } catch (error) {\n809:     if (!isKnownRetrievalUnavailable(error)) throw error;\n810:     return { ok: false, error: error.code ?? 'manifest-invalid' };\n811:   }\n812: }\n813: \n814: // ─────────────────────────────────────────────────────────────────────────────\n815: // 5. PUBLIC API\n816: // ─────────────────────────────────────────────────────────────────────────────\n817: \n818: /**\n819:  * Build a typed foundations compatibility result through the neutral seam.\n820:  *\n821:  * @param {Object} input - Closed relationship, graph, ledger, and authority records.\n822:  * @param {Object} engineOptions - Retrieval-engine corpus and manifest paths.\n823:  * @returns {Promise<Object>} Grounded relationships, validated fallback, or refusal.\n824:  */\n825: export async function buildFoundationsRelationshipPlan(input, engineOptions = {}) {\n826:   const validation = validateFoundationsRelationshipRequest(input);\n827:   if (!validation.valid) {\n828:     return { ok: false, error: 'invalid-foundations-request', details: validation.errors };\n829:   }\n830:   const request = immutableSnapshot(input);\n831:   const authoritySnapshot = request.authorityInputs;\n832:   const blockedOutcome = blockingPlanOutcome(request.contextPlan);\n833:   if (blockedOutcome) {\n834:     return fallbackResult(request, blockedOutcome);\n835:   }\n836:   if (request.selection.mode === 'none') return fallbackResult(request, 'no-fit');\n837: \n838:   let query;\n839:   try {\n840:     query = await runQuery({\n841:       ...(request.retrievalRequest ?? {}),\n842:       usage: 'reference',\n843:       exactReuse: false,\n844:       limit: MAX_QUERY_CARDS,\n845:     }, engineOptions);\n846:   } catch (error) {\n847:     if (!isKnownRetrievalUnavailable(error)) throw error;\n848:     return fallbackResult(\n849:       request,\n850:       'no-fit',\n851:       [`retrieval-unavailable:${error.code ?? 'invalid-manifest'}`],\n852:     );\n853:   }\n854:   if (query.generationHash !== request.contextPlan.generationIdentity.observedGenerationHash) {\n855:     return fallbackResult(request, 'no-fit', ['retrieval-unavailable:generation-mismatch']);\n856:   }\n857: \n858:   const selectedIds = [request.selection.coherentAnchorId, ...request.selection.axisOwnerIds];\n859:   const selectedCards = selectedIds.map((sourceId) => (\n860:     query.cards.find((card) => card.id === sourceId)\n861:   ));\n862:   if (selectedCards.some((card) => !card)) return fallbackResult(request, 'no-fit');\n863: \n864:   const sources = [];\n865:   const hydratedSources = new Map();\n866:   for (const [index, card] of selectedCards.entries()) {\n867:     const hydration = await hydrateSource(card, engineOptions);\n868:     if (!hydration.ok) {\n869:       if (!HYDRATION_UNAVAILABLE_CODES.has(hydration.error)) {\n870:         return { ok: false, error: `source-${hydration.error}` };\n871:       }\n872:       return fallbackResult(request, 'no-fit', [`source-unavailable:${hydration.error}`]);\n873:     }\n874:     hydratedSources.set(card.id, { card, hydration });\n875:     sources.push(sourceDescriptor(card, hydration, index === 0 ? 'coherent-anchor' : 'axis-owner'));\n876:   }\n877:   const attestationErrors = [];\n878:   for (const attestation of request.sourceAttestations) {\n879:     const hydrated = hydratedSources.get(attestation.sourceId);\n880:     if (!hydrated) {\n881:       attestationErrors.push(`${attestation.sourceId}:source-not-hydrated`);\n882:       continue;\n883:     }\n884:     const result = validateHydratedSourceAttestation(\n885:       attestation,\n886:       hydrated.card,\n887:       hydrated.hydration,\n888:       { fence: RELATIONSHIP_EVIDENCE_FENCE, validateEvidence: validateRelationshipEvidence },\n889:     );\n890:     attestationErrors.push(...result.errors.map((error) => (\n891:       `${attestation.evidence.edgeId}:${attestation.sourceId}:${error}`\n892:     )));\n893:   }\n894:   if (attestationErrors.length > 0) {\n895:     return { ok: false, error: 'relationship-attestation-rejected', details: attestationErrors };\n896:   }\n897:   if (!isDeepStrictEqual(input.authorityInputs, authoritySnapshot)) {\n898:     return { ok: false, error: 'authority-input-mutated' };\n899:   }\n\n(Showing lines 770-899 of 930. Use offset=900 to continue.)\n</content>","metadata":{"preview":"function fallbackResult(input, outcome, warnings = []) {\n  const proofHandoff = negativeProofHandoff(input.contextPlan, outcome);\n  const proofError = validateBuiltProof(proofHandoff);\n  if (proofError) return proofError;\n  const snapshot = structuredClone(input.authorityInputs);\n  return {\n    ok: true,\n    outcome,\n    relationshipBlueprint: structuredClone(input.blueprint),\n    compatibilityGraph: {\n      schemaVersion: FOUNDATIONS_AXIS_COMPATIBILITY_VERSION,\n      nodes: [],\n      edges: [],\n    },\n    transformationLedger: {\n      schemaVersion: FOUNDATIONS_TRANSFORMATION_LEDGER_VERSION,\n      records: [],\n    },\n    downstreamChecks: structuredClone(input.downstreamChecks),\n    sources: [],","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.worktrees/0093-sk-design-012-gap-research/.opencode/skills/sk-design/design-foundations/corpus/relationship-blueprint.mjs","text":"function fallbackResult(input, outcome, warnings = []) {\n  const proofHandoff = negativeProofHandoff(input.contextPlan, outcome);\n  const proofError = validateBuiltProof(proofHandoff);\n  if (proofError) return proofError;\n  const snapshot = structuredClone(input.authorityInputs);\n  return {\n    ok: true,\n    outcome,\n    relationshipBlueprint: structuredClone(input.blueprint),\n    compatibilityGraph: {\n      schemaVersion: FOUNDATIONS_AXIS_COMPATIBILITY_VERSION,\n      nodes: [],\n      edges: [],\n    },\n    transformationLedger: {\n      schemaVersion: FOUNDATIONS_TRANSFORMATION_LEDGER_VERSION,\n      records: [],\n    },\n    downstreamChecks: structuredClone(input.downstreamChecks),\n    sources: [],\n    authorityPreservation: authorityPreservation(input.authorityInputs, snapshot),\n    averagedTokenValues: false,\n    copiedSourceSpecificMaterial: false,\n    proofHandoff,\n    warnings,\n  };\n}\n\nasync function hydrateSource(card, engineOptions) {\n  try {\n    return await runHydrate({\n      id: card.id,\n      generationHash: card.generationHash,\n      mode: 'foundations',\n      usage: 'reference',\n      includes: ['DESIGN.md', 'design-tokens.json', 'source.md'],\n      maxBytes: HYDRATION_BYTES,\n    }, engineOptions);\n  } catch (error) {\n    if (!isKnownRetrievalUnavailable(error)) throw error;\n    return { ok: false, error: error.code ?? 'manifest-invalid' };\n  }\n}\n\n// ─────────────────────────────────────────────────────────────────────────────\n// 5. PUBLIC API\n// ─────────────────────────────────────────────────────────────────────────────\n\n/**\n * Build a typed foundations compatibility result through the neutral seam.\n *\n * @param {Object} input - Closed relationship, graph, ledger, and authority records.\n * @param {Object} engineOptions - Retrieval-engine corpus and manifest paths.\n * @returns {Promise<Object>} Grounded relationships, validated fallback, or refusal.\n */\nexport async function buildFoundationsRelationshipPlan(input, engineOptions = {}) {\n  const validation = validateFoundationsRelationshipRequest(input);\n  if (!validation.valid) {\n    return { ok: false, error: 'invalid-foundations-request', details: validation.errors };\n  }\n  const request = immutableSnapshot(input);\n  const authoritySnapshot = request.authorityInputs;\n  const blockedOutcome = blockingPlanOutcome(request.contextPlan);\n  if (blockedOutcome) {\n    return fallbackResult(request, blockedOutcome);\n  }\n  if (request.selection.mode === 'none') return fallbackResult(request, 'no-fit');\n\n  let query;\n  try {\n    query = await runQuery({\n      ...(request.retrievalRequest ?? {}),\n      usage: 'reference',\n      exactReuse: false,\n      limit: MAX_QUERY_CARDS,\n    }, engineOptions);\n  } catch (error) {\n    if (!isKnownRetrievalUnavailable(error)) throw error;\n    return fallbackResult(\n      request,\n      'no-fit',\n      [`retrieval-unavailable:${error.code ?? 'invalid-manifest'}`],\n    );\n  }\n  if (query.generationHash !== request.contextPlan.generationIdentity.observedGenerationHash) {\n    return fallbackResult(request, 'no-fit', ['retrieval-unavailable:generation-mismatch']);\n  }\n\n  const selectedIds = [request.selection.coherentAnchorId, ...request.selection.axisOwnerIds];\n  const selectedCards = selectedIds.map((sourceId) => (\n    query.cards.find((card) => card.id === sourceId)\n  ));\n  if (selectedCards.some((card) => !card)) return fallbackResult(request, 'no-fit');\n\n  const sources = [];\n  const hydratedSources = new Map();\n  for (const [index, card] of selectedCards.entries()) {\n    const hydration = await hydrateSource(card, engineOptions);\n    if (!hydration.ok) {\n      if (!HYDRATION_UNAVAILABLE_CODES.has(hydration.error)) {\n        return { ok: false, error: `source-${hydration.error}` };\n      }\n      return fallbackResult(request, 'no-fit', [`source-unavailable:${hydration.error}`]);\n    }\n    hydratedSources.set(card.id, { card, hydration });\n    sources.push(sourceDescriptor(card, hydration, index === 0 ? 'coherent-anchor' : 'axis-owner'));\n  }\n  const attestationErrors = [];\n  for (const attestation of request.sourceAttestations) {\n    const hydrated = hydratedSources.get(attestation.sourceId);\n    if (!hydrated) {\n      attestationErrors.push(`${attestation.sourceId}:source-not-hydrated`);\n      continue;\n    }\n    const result = validateHydratedSourceAttestation(\n      attestation,\n      hydrated.card,\n      hydrated.hydration,\n      { fence: RELATIONSHIP_EVIDENCE_FENCE, validateEvidence: validateRelationshipEvidence },\n    );\n    attestationErrors.push(...result.errors.map((error) => (\n      `${attestation.evidence.edgeId}:${attestation.sourceId}:${error}`\n    )));\n  }\n  if (attestationErrors.length > 0) {\n    return { ok: false, error: 'relationship-attestation-rejected', details: attestationErrors };\n  }\n  if (!isDeepStrictEqual(input.authorityInputs, authoritySnapshot)) {\n    return { ok: false, error: 'authority-input-mutated' };\n  }","lineStart":770,"lineEnd":899,"totalLines":930,"truncated":true}},"title":".opencode/skills/sk-design/design-foundations/corpus/relationship-blueprint.mjs","time":{"start":1784623065289,"end":1784623065309}},"metadata":{"openai":{"itemId":"fc_04d4f234fc391bda016a5f2fd913f881919662a40c0d9acf0c"}},"id":"prt_f83d2e8c50015UQAvroFwvShxN","sessionID":"ses_07c31cbc4ffeYIOJJ8ZhDDe6Fl","messageID":"msg_f83d2bc16001LU4sPU2KLao3nN"}}
