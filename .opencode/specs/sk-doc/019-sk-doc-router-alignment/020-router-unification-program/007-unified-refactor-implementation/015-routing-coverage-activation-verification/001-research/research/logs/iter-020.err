:"minimax","pass":true,"prompt_idx":2,"run1_skill":"mcp-tooling","run2_skill":"mcp-tooling"}]},"rollbackProof":{"byteExact":true,"restoredHash":"5485c5a4a6faddca886425dedc59bd0d5340f7946f9bf7f6a8fec36e802a8c23"},"schemaVersion":"V1","selectedPolicy":{"effectivePolicyHash":"afe102ea655e81025a471e6b33479b3d84fa2bb990a533da21467294e38a9ff0","generation":4},"servingAuthority":"legacy","shadowOnly":true,"shippedThisRun":true,"sourceHashes":[{"hash":"4b6b4b389d2e2a7ab3fe05115c3af3b268670d7c6dbc5ccea9c8358806e69f7b","sourceId":"mcp-code-mode/SKILL.md"},{"hash":"1cc99f7e980bdfb6e1db66f32b7d7383a23f20421146eb0fb86fd3a9fef09c0e","sourceId":"mcp-tooling/hub-router.json"},{"hash":"aed31b1d2c9b2f650a69c5938fdad1b78cf8f0f621f9ffeac2851746c5daab48","sourceId":"mcp-tooling/mcp-figma/SKILL.md"},{"hash":"6f28ed6e12e8d03aa413c7925c4bb43a2f5a7f524f8cc98304817fdb4585a6f6","sourceId":"mcp-tooling/mode-registry.json"},{"hash":"f779cb6e0c314d0cfd7c529ed3282f35f8227172d8e5b125d436081339575243","sourceId":"mcp-tooling/SKILL.md"},{"hash":"2bd6a0977e1ff29c710fd273bd9f0faa11f36d89989ddc377dad9854f8688030","sourceId":"sk-design/mode-registry.json"},{"hash":"ae5732dc5c4d0219aa991f6a9c4129353114819b1428226a68e1a57c87dca91a","sourceId":"sk-design/SKILL.md"}]}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/010-live-activation/activation/mcp-tooling/manifest.json:1:{"schemaVersion":"V1","selectedPolicy":{"effectivePolicyHash":"afe102ea655e81025a471e6b33479b3d84fa2bb990a533da21467294e38a9ff0","generation":4},"servingAuthority":"compiled","shadowOnly":false}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-016.md:7:- `COMPILED_ROUTING_HUBS` is a pure membership gate before advisor enrichment (`.opencode/skills/system-skill-advisor/mcp-server/handlers/advisor-recommend.ts:41-49`, `:326-334`). `HUB_CHILD`, however, maps hub IDs to rollout directories and is consumed to load hub-specific snapshot builders and router implementations (`.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/compiled-route.cjs:23-31`, `:35-58`). A manifest-derived eligibility predicate can replace the first structure, but not the second without a new uniform engine-location contract.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-016.md:11:- Promoting only `resolve.cjs` into `.opencode/bin/lib/` would break both relative dependencies. It imports `./compiled-route.cjs` and derives activation state from `__dirname/../../010-live-activation/activation` (`.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/resolve.cjs:15-20`). The engine then derives its implementation root from its own spec-tree location and dynamically imports rollout-child harnesses and routers (`.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/compiled-route.cjs:20-22`, `:35-58`). This is the strongest previously unnamed gap: resolver promotion must cover the complete runtime dependency closure, not one file.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-016.md:17:- The compiled engine caches snapshots solely by hub ID with no selected-policy or source-hash invalidation (`.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/compiled-route.cjs:33-36`, `:58-61`). This is harmless while each CLI call creates a fresh process, but becomes load-bearing if promotion changes the advisor to an in-process/shared resolver.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-016.md:23:2. Split the current overloaded concept into `isCompiledEligible(hubId)` and `loadCompiledEngine(hubId)`. The first validates a fresh runtime manifest; the second uses a fixed bundle convention or a manifest-declared, root-guarded entrypoint. Delete `COMPILED_ROUTING_HUBS` after parity, but delete `HUB_CHILD` only after all seven engines satisfy the uniform loader contract.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-016.md:33:  {"id":"F-16-1","area":"activation","finding":"HUB_CHILD is a runtime engine-dispatch table, not merely the duplicate eligibility allowlist ADR-002 assumes it is.","evidence":".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/compiled-route.cjs:35-58","severity":"P0","actionable":"Separate manifest-derived eligibility from engine discovery, standardize one per-hub engine entrypoint, then remove HUB_CHILD only after all hubs use that contract.","novelty":"refines:F-6-3"},
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-016.md:37:  {"id":"F-16-5","area":"unnamed","finding":"The compiled engine cache is keyed only by hub ID and therefore would retain a stale snapshot if the promoted resolver becomes long-lived across a manifest re-mint.","evidence":".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/compiled-route.cjs:33-36","severity":"P1","actionable":"Key or invalidate cached engines by selected-policy hash and source signature, and add a same-process re-mint test before moving compiled routing in-process.","novelty":"new"}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/010-live-activation/activation/mcp-tooling/manifest.prior.json:1:{"schemaVersion":"V1","selectedPolicy":{"effectivePolicyHash":null,"generation":0},"servingAuthority":"legacy","shadowOnly":true}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-002.md:10:The vacuous-parity trap is now visible: flag alone isn't enough; the activation manifest must read `servingAuthority: 'compiled'`. Let me confirm current state and the compiled engine's emitted shape.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-002.md:32:- **F-2-2 Vacuous-parity gate (P0, novel).** `resolve.cjs:41-42` requires *both* `SPECKIT_COMPILED_ROUTING=1` AND `servingAuthority==='compiled'` in the activation manifest. Flag-on with `servingAuthority:'legacy'` → `resolveRoute` returns null → `compiled-route.cjs:39` prints `{servingAuthority:'legacy', hubId}` → a naive lane reads "compiled matches legacy" and passes. The lane MUST assert the manifest's state for the target hub before treating the output as a real compiled decision.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-002.md:34:- **F-2-4 Spec-tree resolver coupling (P1, novel).** `compiled-route.cjs:16-21` resolves the resolver from `.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/resolve.cjs`. Specs are mutable planning artifacts; any rename of 011-runtime-engine (sk-doc packets restructure often) silently breaks the resolver, `compiled-route.cjs:36-39` catches and returns the legacy sentinel, and the lane goes vacuously green. The lane MUST pre-flight that path's existence and surface breakage as drift, not parity.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-002.md:35:- **F-2-5 Hub-type vs compiled-eligibility mismatch (P2, novel).** `isHubTypeSkill` (run-skill-benchmark.cjs:68) keys off `hub-router.json` (7 hubs have one). Compiled-serving eligibility is keyed off the activation manifest *plus* the `COMPILED_ROUTING_HUBS` allowlist in `advisor-recommend.ts`. A hub can have route-gold auto-on while being compiled-N/A. The lane MUST distinguish `n/a (not compiled-eligible)` from `drift`, otherwise N/A hubs get scored as either false-pass or false-fail.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-002.md:46:  {"id":"F-2-2","area":"benchmark","finding":"Vacuous-parity trap: SPECKIT_COMPILED_ROUTING=1 alone is insufficient. resolve.cjs:41-42 requires the per-hub activation manifest to read servingAuthority==='compiled'; otherwise resolveRoute returns null and compiled-route.cjs:39 emits a legacy sentinel that a naive lane reads as 'compiled matches legacy'.","evidence":"resolve.cjs:41-42 (flagEnabled AND servingAuthority!=='compiled'); compiled-route.cjs:36-39 (catch→legacy sentinel); .opencode/specs/.../010-live-activation/activation/sk-code/manifest.json shows servingAuthority:'compiled' (so sk-code is the valid pilot; other hubs may still be 'legacy')","severity":"P0","actionable":"compiled-parity.cjs pre-flight MUST read 010-live-activation/activation/<hub>/manifest.json and treat servingAuthority!=='compiled' as status 'vacuous' (hard fail), never a pass; document the dual gate in the lane README.","novelty":"new"},
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-002.md:48:  {"id":"F-2-4","area":"archiving","finding":"Spec-tree resolver coupling: compiled-route.cjs:16-21 resolves the resolver from inside .opencode/specs/.../011-runtime-engine/lib/resolve.cjs. Specs are mutable planning artifacts; a rename silently breaks the resolver and the catch at compiled-route.cjs:36-39 returns the legacy sentinel, producing vacuous parity. ZERO activation/manifest.json or compiled/route-gold.typed.json live under .opencode/skills/<hub>/ — all 19 + 12 live under specs only.","evidence":"compiled-route.cjs:16-21 (path.resolve into specs/); find results: 19 activation/manifest.json + 12 route-gold.typed.json ALL under .opencode/specs/sk-doc/019-.../007-unified-refactor-implementation/, ZERO under .opencode/skills/<hub>/","severity":"P1","actionable":"compiled-parity.cjs pre-flight asserts the resolver path exists (fs.existsSync) AND skills-tree activation archive exists; recommend a follow-up to copy per-hub activation/manifest.json + compiled/route-gold.typed.json into .opencode/skills/<hub>/activation/ + compiled/ as the durable serving source (closes named gap #4 for the benchmark's reliance).","novelty":"new"},
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-002.md:49:  {"id":"F-2-5","area":"benchmark","finding":"Hub-type detection (isHubTypeSkill, run-skill-benchmark.cjs:68 keys on hub-router.json) is misaligned with compiled-serving eligibility (keys on activation manifest + advisor-recommend.ts COMPILED_ROUTING_HUBS allowlist). A hub can have --route-gold auto-on while compiled-parity is structurally N/A.","evidence":"run-skill-benchmark.cjs:68-70 (isHubTypeSkill=fs.existsSync hub-router.json); 7 hubs have hub-router.json; resolve.cjs:42 serving authority is per-hub and independent","severity":"P2","actionable":"compiled-parity.cjs returns status enum {match|drift|vacuous|n/a|resolver-missing}; the orchestrator's verdict switch treats only match as pass, drift/vacuous/resolver-missing as failures, and n/a as informational (no verdict impact) so non-compiled hubs don't false-fail.","novelty":"new"}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/010-live-activation/activation/mcp-tooling/serving-flip-record.json:1:{"fenceEpoch":{"after":4,"before":3},"gate":{"canaryGreen":true,"effectivePolicyHash":"afe102ea655e81025a471e6b33479b3d84fa2bb990a533da21467294e38a9ff0","routedScenarios":4,"scorerFrozen":true,"totalScenarios":8},"hubId":"mcp-tooling","rollbackTo":"manifest.serving-prior.json","selectedPolicy":{"effectivePolicyHash":"afe102ea655e81025a471e6b33479b3d84fa2bb990a533da21467294e38a9ff0","generation":4},"servingAuthority":"compiled","shadowOnly":false}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/010-live-activation/activation/mcp-tooling/manifest.candidate.json:1:{"schemaVersion":"V1","selectedPolicy":{"effectivePolicyHash":"afe102ea655e81025a471e6b33479b3d84fa2bb990a533da21467294e38a9ff0","generation":4},"servingAuthority":"legacy","shadowOnly":true}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:18:All seven hubs already carry `servingAuthority: compiled, shadowOnly: false` after the P4b flip (verified by reading each `manifest.json` under `.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/010-live-activation/activation/<hub>/manifest.json`). Each hub also has a `fence-state.json` (epochs 2–4), a `serving-flip-record.json` (per-flip audit), and an `activation-record.json` (with `realModelVerification.perModelPass` for `luna`/`minimax`/`sol`). These are durable, byte-stable files — but they live only inside the spec tree, and no module path joins them into one machine-readable snapshot.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:22:`.opencode/bin/compiled-route.cjs` (lines 23-40) is purely `(hub, prompt) → decision | legacy-sentinel`. The shim `compiled-route.cjs:36-39` collapses every failure into `{ servingAuthority: 'legacy' }` with no `cause` field (drift vs broken), no live-hash, no eligibility verdict. `resolve.cjs:22-48` gates on the flag and the manifest but only returns a single boolean/null. There is no `compiled-route.cjs --fleet` and no shared `serving-snapshot.cjs` that walks the seven manifests, recomputes each live hash, and emits the `compiled-serving | legacy-fallback | drifted` triple the 012 spec mandates (`spec.md:133`, `plan.md:158`, `tasks.md:86` T007). F-8-4 / F-10-3 already flagged the absence; my contribution is naming the augmentation surface.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:30:`014-benchmark-alignment/spec.md:79` says "JSON and Markdown report additions" inside `report.compiledRouting` (a Lane C parity block), and the harness writes to caller-provided `--outputs-dir` (per `run-skill-benchmark.cjs` and the existing `sk-code/benchmark/live-final/` shape). 014 does not name where the per-hub serving snapshot persists across runs — the natural mapping `<hub>/benchmark/compiled-routing/<run-label>/{serving-snapshot.json, serving-snapshot.md}` parallels the Lane C convention (`sk-code/benchmark/README.md:73-83`) but no spec calls for it. A LUNA-high routed-subject run today would either pollute the parity outputs dir or vanish.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:38:`010-live-activation/activation/<hub>/manifest.json` carries `{ schemaVersion, selectedPolicy:{ effectivePolicyHash, generation }, servingAuthority, shadowOnly }` (one line each). It does NOT carry `liveConfigHash` (so a probe cannot detect drift without recomputing it from hub inputs, F-16-3) and does NOT carry `engineLocator` / `resolverPath` (so a probe cannot report "promoted vs spec-tree resolver" status from the manifest alone, F-16-2 / ADR-003). The 012 P0 remediation of the spec-tree resolver coupling leaves no manifest-side reflection of the resolved path, so even an authoritative readout would still need to inspect `.opencode/bin/compiled-route.cjs:16-21` separately.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:42:`.opencode/specs/.../010-live-activation/real-model/sk-code/verdict.json` records `perModelPass: { luna: "1/2", sol: "2/2", minimax: "2/2" }` and 6 raw prompt transcripts in `raw/luna-1-1.txt` etc. — but it does NOT include the `servingAuthority` or `effectivePolicyHash` at the moment of the LUNA query, so a reader cannot reconstruct "was this hub compiled-serving under the flag when LUNA answered?". F-11-2 already noted the harness scores the model, not the compiled-router; F-12-4 notes the durable archive shape loses the same data the parity gate would need.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:50:1. **Author `serving-snapshot.json` schema per hub** (sibling to `skill-benchmark-report.json`) and author the rendering template in `create-benchmark`'s `skill-benchmark-storage-guide.md`. Required fields: `hubId`, `capturedAt`, `flag`, `manifest: { selectedPolicyHash, generation, fenceEpoch, servingAuthority, shadowOnly }`, `liveConfigHash`, `freshness: 'fresh'|'stale'|'missing-manifest'|'engine-error'`, `engineResolverPath`, `parityBaseline: { routeGoldHash, parity: 'equal'|'divergent'|'unknown' }`, `realModelLast: { luna, minimax, sol }`. Source of truth: spec tree (manifest + fence + flip + real-model), recomputed at probe time.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:54:3. **Add a `compiledRoutingFleetStatus` block to `spec_kit_skill_advisor_status`** (`mk-skill-advisor.js:826-861`) — read each of the seven manifests, recompute each live hash via the same `loadHubEngine()` path the runtime uses (`compiled-route.cjs:42-58`), classify each hub into one of `compiled-serving | legacy-fallback | drifted`, and emit `hub_serving[]` (7 rows) plus a one-line `fleet_summary` (counts per state). This is a session-start, read-only surface — no hot-path impact. The runtime front door stays unchanged.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:66:  {"id":"F-12-1","area":"archiving","finding":"No serving-snapshot.json schema exists per hub that joins manifest + fence + flip + live hash + flag + parity into one durable, machine-readable artifact; the current per-hub evidence is split across activation-record.json, fence-state.json, manifest.json, and serving-flip-record.json under the spec tree.","evidence":".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/010-live-activation/activation/sk-code/{manifest.json,fence-state.json,activation-record.json,serving-flip-record.json}; 010-live-activation/lib/activate-hub.cjs:244; 011-runtime-engine/lib/flip-serving.cjs:137","severity":"P0","actionable":"Define and ship a serving-snapshot.json schema (hubId, capturedAt, flag, manifest{selectedPolicyHash,generation,fenceEpoch,servingAuthority,shadowOnly}, liveConfigHash, freshness, engineResolverPath, parityBaseline, realModelLast) and emit a renderer for serving-snapshot.md under sk-doc/create-benchmark; reference it from create-benchmark §10 storage guide and create-manual-testing-playbook run-archive convention.","novelty":"new"},
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:67:  {"id":"F-12-2","area":"activation","finding":"No CLI/MCP/plugin module path is named for the fleet-wide per-hub serving probe, so 012 spec.md:133 / plan.md:158 / tasks.md:86 T007 (per-hub compiled-serving | legacy-fallback | drifted readout) has no concrete implementation surface today.","evidence":".opencode/bin/compiled-route.cjs:23-40 (resolves only (hub,prompt)->decision; --fleet flag absent); 011-runtime-engine/lib/resolve.cjs:22-48 (returns single null/decision, no fleet function); .opencode/plugins/mk-skill-advisor.js:826-861 (status tool emits cache stats, never reads the 7 manifests)","severity":"P0","actionable":"Add a compiledRoutingFleetStatus block to spec_kit_skill_advisor_status (~10 lines) that reads each of the 7 manifests, recomputes each live hash via loadHubEngine(), and emits hub_serving[] plus a fleet_summary row count per state; back it by a new .opencode/bin/compiled-route.cjs --fleet mode that the plugin can shell out to.","novelty":"refines:F-8-4"},
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:71:  {"id":"F-12-6","area":"unnamed","finding":"create-skill (013 spec) plans to mint a manifest for --compiled-routing ready hubs but no spec names where the manifest lives; until the spec-tree 010-live-activation path is populated AND COMPILED_ROUTING_HUBS (advisor-recommend.ts:41) is updated AND the fleet probe is wired, a freshly-scaffolded compiled-ready hub is invisible to every observability surface.","evidence":".opencode/specs/.../013-create-skill-alignment/spec.md:73-79 (--compiled-routing legacy|ready option, mints manifest but location unspecified); system-skill-advisor/mcp-server/handlers/advisor-recommend.ts:41-49 (COMPILED_ROUTING_HUBS hardcoded allowlist); compiled-route.cjs:23-31 (HUB_CHILD dispatch table)","severity":"P1","actionable":"Author 013 to emit the manifest into BOTH the spec-tree canonical location and a hub-local .opencode/skills/<hub>/activation/manifest.json copy so the fleet probe can scan one location for all known hubs including create-skill output that has not yet been activated.","novelty":"new"},
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-012.md:72:  {"id":"F-12-7","area":"activation","finding":"No plugin or tool wires the runtime front door's (hub,prompt) decision with a session-start fleet probe and writes/updates a per-hub serving snapshot; the mk-dist-freshness-guard.js pattern (compiled-output staleness detection for MCP dist artifacts) lifts directly into a parallel mk-compiled-routing-snapshot.js but no spec names it.","evidence":".opencode/plugins/mk-dist-freshness-guard.js (compiled dist drift detection); .opencode/plugins/README.md (no compiled-routing-snapshot plugin listed); 011-runtime-engine/lib/compiled-route.cjs:33-62 (loadHubEngine + engineCache are runtime-private, not exported for plugins)","severity":"P2","actionable":"Export loadHubEngine (or a read-only equivalent) from 011-runtime-engine/lib/compiled-route.cjs:87 to enable a session-start plugin; add .opencode/plugins/mk-compiled-routing-snapshot.js that walks the 7 manifests, runs loadHubEngine on each, and writes .opencode/skills/<hub>/benchmark/compiled-routing/latest/serving-snapshot.json with the F-12-1 schema.","novelty":"new"}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/010-live-activation/activation/mcp-tooling/manifest.serving-prior.json:1:{"schemaVersion":"V1","selectedPolicy":{"effectivePolicyHash":"afe102ea655e81025a471e6b33479b3d84fa2bb990a533da21467294e38a9ff0","generation":4},"servingAuthority":"legacy","shadowOnly":true}
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-003.md:20:Second, `sk-code` cannot yet prove the required `code-opencode` surface bundle through the public compiled front door. The front door passes only `{prompt}` to the evaluator (`011-runtime-engine/lib/compiled-route.cjs:73-75`), while the compiled composite fixture requires both a risk slice and a live certificate (`006-parent-hub-rollout/001-sk-code/fixtures/canary-cases.v1.json:60-66`); the same fixture explicitly clarifies when the certificate is absent (`006-parent-hub-rollout/001-sk-code/fixtures/canary-cases.v1.json:119-124`). Extend the runtime input contract or establish a safe certificate context before requiring the sk-code scenario to return a `surfaceBundle` containing `code-opencode`.
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-003.md:28:`SPECKIT_COMPILED_ROUTING=<0|1> codex exec --model gpt-5.6-luna -c model_reasoning_effort="high" -c service_tier="fast" -c approval_policy=never --sandbox read-only -o <stdout-evidence> "<route-only prompt>" 2> <stderr-evidence>`
.opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/015-routing-coverage-activation-verification/001-research/research/iterations/iteration-003.md:47:  {"id":"F-3-4","area":"sk-code-align","finding":"The public compiled front door supplies only prompt text, but sk-code surfaceBundle routing requires risk-slice and certificate context, so code-opencode cannot be proven end-to-end through the current interface.","evidence":".opencode/specs/sk-doc/019-sk-doc-router-alignment/020-router-unification-program/007-unified-refactor-implementation/011-runtime-engine/lib/compiled-route.cjs:73","severity":"P0","actionable":"Extend the runtime request contract with safe composite-routing context and add a LUNA-high case requiring a surfaceBundle containing sk-code:code-opencode.","novelty":"new"},
