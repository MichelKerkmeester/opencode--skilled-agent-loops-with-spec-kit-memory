 = causalEdges.getCausalChain(String(memoryId), maxDepth, 'forward');\n\n  Line 572:         const backwardTree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'backward');\n\n  Line 576:         const tree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'forward');\n\n  Line 579:         const tree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'backward');\n\n  Line 731:         `Traversal truncated after ${combinedChain.truncation_limit ?? causalEdges.MAX_EDGES_LIMIT} edges per node - results may be incomplete`\n\n  Line 804:         validRelations: Object.values(causalEdges.RELATION_TYPES) as string[]\n\n  Line 811:           `relation: One of ${Object.values(causalEdges.RELATION_TYPES).join(', ')}`\n\n  Line 834:     causalEdges.init(db);\n\n  Line 836:     const validRelations = Object.values(causalEdges.RELATION_TYPES) as string[];\n\n  Line 847:     const safeRelation = relation as causalEdges.RelationType;\n\n  Line 892:     const edge = causalEdges.insertEdge(String(sourceId), String(targetId), safeRelation, strength ?? 1.0, evidence ?? null);\n\n  Line 964:     causalEdges.init(db);\n\n  Line 985:     const stats = causalEdges.getGraphStats();\n\n  Line 986:     const orphanedEdges: CausalEdge[] = causalEdges.findOrphanedEdges();\n\n  Line 1012:     const relationBalance = computeRelationBalance(causalEdges.getAllEdges(1000));\n\n  Line 1144:     causalEdges.init(db);\n\n  Line 1147:       deleted: causalEdges.deleteEdge(edgeId, {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts:\n  Line 32: import * as causalEdges from '../lib/storage/causal-edges.js';\n\n  Line 601:           causalEdges.init(database);\n\n  Line 602:           causalEdges.deleteEdgesForMemory(String(staleRecordId), {\n\n  Line 613:         if (vectorIndex.deleteMemory(staleRecordId)) {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/chunking-orchestrator.ts:\n  Line 115:       if (vectorIndex.deleteMemory(memoryId)) {\n\n  Line 204:           if (vectorIndex.deleteMemory(existingChunk.id)) {\n\n  Line 211:         if (vectorIndex.deleteMemory(existing.id)) {\n\n  Line 390:           vectorIndex.deleteMemory(childId);\n\n  Line 418:             if (vectorIndex.deleteMemory(chunkRow.id)) {\n\n  Line 426:           if (vectorIndex.deleteMemory(parentId)) {\n\n  Line 433:             if (vectorIndex.deleteMemory(childId)) {\n\n  Line 572:             if (vectorIndex.deleteMemory(cid)) {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-save.ts:\n  Line 40: import * as causalEdges from '../lib/storage/causal-edges.js';\n\n  Line 68:   recordGovernanceAudit,\n\n  Line 730:   causalEdges.init(database);\n\n  Line 734:   causalEdges.insertEdge(\n\n  Line 737:     causalEdges.RELATION_TYPES.SUPERSEDES,\n\n  Line 3251:     recordGovernanceAudit(database, {\n\n  Line 3736:       recordGovernanceAudit(database, {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tools/memory-tools.ts:\n  Line 57:   'memory_retention_sweep',\n\n  Line 98:     case 'memory_retention_sweep': return handleMemoryRetentionSweep(parseArgs<RetentionSweepArgs>(validateToolArgs('memory_retention_sweep', args)));\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/api/index.ts:\n  Line 70:   recordGovernanceAudit,\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/cli.ts:\n  Line 281:   const [vectorIndex, checkpointsLib, mutationLedger, triggerMatcher, causalEdges, history] = await Promise.all([\n\n  Line 379:   causalEdges.init(db);\n\n  Line 387:       if (vectorIndex.deleteMemory(memory.id)) {\n\n  Line 397:           causalEdges.deleteEdgesForMemory(String(memory.id), {\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/tool-schemas.ts:\n  Line 504:   name: 'memory_retention_sweep',\n\n\n(Results truncated. Consider using a more specific path or pattern.)","metadata":{"matches":100,"truncated":true},"title":"memory_retention|deleteMemory\\(|delete_memories|delete_memory_by_path|causalEdges|sweepCausalEdges|recordGovernanceAudit","time":{"start":1781762405568,"end":1781762405579}},"metadata":{"openai":{"itemId":"fc_0b4dd2d26a2813e6016a3389655dfc81918c2e80b6a8fec15f"}},"id":"prt_ed950b4bf001U0pJCruuXdTMNE","sessionID":"ses_126b3c392ffeqmVxmFv45c0QTG","messageID":"msg_ed9507fcd0019nWKGv0b9qKDPq"}}
