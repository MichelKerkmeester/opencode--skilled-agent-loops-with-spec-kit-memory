    28	jobs:
    29	  routing-drift:
    30	    name: Registry == advisor maps; parent-skill structure
    31	    runs-on: ubuntu-latest
    32	    steps:
    33	      - uses: actions/checkout@v4
    34	        with:
    35	          fetch-depth: 1
