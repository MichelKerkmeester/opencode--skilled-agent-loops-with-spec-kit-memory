{"type":"text","timestamp":1780906508713,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"id":"prt_ea64ca1000017TQJW1GrWQZwMw","messageID":"msg_ea64c5eed0013Bple0gkUsUPiE","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","type":"text","text":"I’m focusing the single iteration on correctness and traceability of the daemon re-election/reap behavior, then checking hook portability for obvious regressions. That matches the high-risk surface in the shared context and root file target.","time":{"start":1780906500352,"end":1780906508708},"metadata":{"openai":{"itemId":"msg_03d9774c5a6e4582016a267a0458dc8191b20e54267e930bde","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780906508766,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"type":"tool","tool":"read","callID":"call_1yDqvkVsbRsjqrw5BzskRuxv","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":180,"limit":340},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n180:     if (target && isDurableWriteUnavailable(error)) {\n181:       logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n182:       return;\n183:     }\n184:     // Logging must never break the launcher.\n185:   }\n186: }\n187: \n188: // Daemon re-election (default-on via the committed runtime configs; the code default below stays off\n189: // so the configs are the single on-switch). When enabled the owner spawns the daemon detached and, on\n190: // its own shutdown, RELEASES the daemon (leaves it running for a live secondary to bridge to) instead\n191: // of killing it, so a session ending does not tear the shared backend out from under other sessions.\n192: // A fresh session that finds the released daemon under a stale lease reaps it before respawn, so the\n193: // database keeps a single writer. Flag off collapses every path below to the prior behavior (daemon\n194: // tied to the owner, killed on shutdown). A released daemon reparents to pid 1, bounded by its idle\n195: // self-exit, so the orphan sweeper bounds any leak.\n196: function daemonReelectionEnabled(env = process.env) {\n197:   return env.SPECKIT_DAEMON_REELECTION === '1' || env.SPECKIT_DAEMON_REELECTION === 'on';\n198: }\n199: function contextServerSpawnIo(reelectionEnabled) {\n200:   return reelectionEnabled\n201:     ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n202:     : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n203: }\n204: function shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n205:   return Boolean(enabled) && Boolean(hasLiveDaemon);\n206: }\n207: \n208: function cleanupTmpFile(tmpPath) {\n209:   try {\n210:     fs.unlinkSync(tmpPath);\n211:   } catch (error) {\n212:     if (error.code !== 'ENOENT') {\n213:       // Best-effort cleanup only; the original durable-write failure is more useful.\n214:     }\n215:   }\n216: }\n217: \n218: function writeAtomicJsonFile(targetPath, payload, operation) {\n219:   const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n220:   const tmp = `${currentPath}.tmp.${process.pid}`;\n221:   try {\n222:     fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n223:     fs.renameSync(tmp, currentPath);\n224:     return true;\n225:   } catch (error) {\n226:     cleanupTmpFile(tmp);\n227:     if (isDurableWriteUnavailable(error)) {\n228:       logDurableWriteUnavailableOnce(operation, currentPath, error);\n229:       return false;\n230:     }\n231:     throw error;\n232:   }\n233: }\n234: \n235: function loadProjectEnvFiles() {\n236:   for (const fname of ['.env.local', '.env']) {\n237:     const p = path.join(root, fname);\n238:     if (fs.existsSync(p)) {\n239:       const n = loadEnvFile(p);\n240:       if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n241:     }\n242:   }\n243: }\n244: \n245: function parsePositiveInteger(value, fallback) {\n246:   if (value === undefined || value === null || String(value).trim() === '') return fallback;\n247:   const parsed = Number.parseInt(String(value).trim(), 10);\n248:   return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n249: }\n250: \n251: function loadBridgeModule() {\n252:   try {\n253:     return require('./lib/launcher-ipc-bridge.cjs');\n254:   } catch (error) {\n255:     if (error.code !== 'MODULE_NOT_FOUND') throw error;\n256:     return {\n257:       async maybeBridgeLeaseHolder({ leaseResult }) {\n258:         const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n259:         const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n260:         const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n261:         process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n262:         return { action: 'report', reason: 'bridge-module-missing' };\n263:       },\n264:     };\n265:   }\n266: }\n267: \n268: function resolveSessionProxySocketPath() {\n269:   const { getIpcSocketPath } = loadBridgeModule();\n270:   return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n271: }\n272: \n273: // Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n274: // the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n275: // like the lease holder does — instead of the raw bridge that severs on recycle. Each\n276: // secondary launcher process gets its own proxy instance (its own pendingRequests and\n277: // cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n278: // JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n279: // unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\n280: function bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n281:   const createProxy = options.createProxy ?? createSessionProxy;\n282:   const sessionProxy = createProxy({\n283:     socketPath,\n284:     stdin: options.stdin ?? process.stdin,\n285:     stdout: options.stdout ?? process.stdout,\n286:     log,\n287:   });\n288:   return sessionProxy.start();\n289: }\n290: \n291: function refreshPaths() {\n292:   skillsDir = path.join(opencodeDir, 'skills');\n293:   legacySkillDir = path.join(opencodeDir, 'skill');\n294:   kitDir = path.join(skillsDir, 'system-spec-kit');\n295:   dbDir = path.join(kitDir, 'mcp_server', 'database');\n296:   lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n297:   stateFile = path.join(dbDir, PID_FILE_NAME);\n298:   canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n299: }\n300: \n301: function exists(p) {\n302:   return fs.existsSync(p);\n303: }\n304: \n305: function writeState(payload) {\n306:   fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n307:   fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n308: }\n309: \n310: function resolvedDbDir() {\n311:   return canonicalizePath(dbDir);\n312: }\n313: \n314: function leasePath() {\n315:   return path.join(resolvedDbDir(), PID_FILE_NAME);\n316: }\n317: \n318: function ownerLeasePath() {\n319:   return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n320: }\n321: \n322: function legacyLeasePaths() {\n323:   return [\n324:     path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n325:   ].map(canonicalizePath);\n326: }\n327: \n328: function readLeaseFile(filePath = leasePath()) {\n329:   try {\n330:     const raw = fs.readFileSync(filePath, 'utf8');\n331:     const parsed = JSON.parse(raw);\n332:     if (typeof parsed.pid === 'number') return parsed;\n333:   } catch {\n334:     // Missing or corrupt lease files are treated as no active lease.\n335:   }\n336:   return null;\n337: }\n338: \n339: function readOwnerLeaseFile(filePath = ownerLeasePath()) {\n340:   try {\n341:     const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n342:     if (\n343:       Number.isInteger(parsed.ownerPid) &&\n344:       Number.isInteger(parsed.ppid) &&\n345:       typeof parsed.executablePath === 'string' &&\n346:       typeof parsed.startedAtIso === 'string' &&\n347:       typeof parsed.lastHeartbeatIso === 'string' &&\n348:       Number.isInteger(parsed.ttlMs) &&\n349:       typeof parsed.canonicalDbDir === 'string'\n350:     ) {\n351:       return parsed;\n352:     }\n353:   } catch {\n354:     // Missing or corrupt owner leases are treated as no active owner.\n355:   }\n356:   return null;\n357: }\n358: \n359: function writeOwnerLeaseFile(lease) {\n360:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n361:   const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n362:   // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n363:   // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n364:   // after power loss and break ownership detection.\n365:   let fd;\n366:   try {\n367:     fd = fs.openSync(tmp, 'wx', 0o600);\n368:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n369:     fs.fsyncSync(fd);\n370:   } finally {\n371:     if (typeof fd === 'number') fs.closeSync(fd);\n372:   }\n373:   fs.renameSync(tmp, currentLeasePath);\n374: }\n375: \n376: function writeOwnerLeaseFileExclusive(lease) {\n377:   const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n378:   let fd;\n379:   try {\n380:     fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n381:     fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n382:     fs.fsyncSync(fd);\n383:     return true;\n384:   } catch (error) {\n385:     if (error.code === 'EEXIST') return false;\n386:     throw error;\n387:   } finally {\n388:     if (typeof fd === 'number') fs.closeSync(fd);\n389:   }\n390: }\n391: \n392: function buildOwnerLease(ownerPid = process.pid) {\n393:   return {\n394:     ownerPid,\n395:     ppid: process.ppid,\n396:     executablePath: process.execPath,\n397:     startedAtIso: new Date().toISOString(),\n398:     lastHeartbeatIso: new Date().toISOString(),\n399:     ttlMs: 60000,\n400:     canonicalDbDir: resolvedDbDir(),\n401:   };\n402: }\n403: \n404: function readParentPid(pid) {\n405:   if (!Number.isInteger(pid) || pid <= 0) return null;\n406:   if (process.platform === 'linux') {\n407:     try {\n408:       const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n409:       const match = status.match(/^PPid:\\s+(\\d+)$/m);\n410:       return match ? Number.parseInt(match[1], 10) : null;\n411:     } catch {\n412:       return null;\n413:     }\n414:   }\n415:   const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n416:     encoding: 'utf8',\n417:     stdio: ['ignore', 'pipe', 'ignore'],\n418:   });\n419:   if (result.status !== 0 || !result.stdout) return null;\n420:   const parsed = Number.parseInt(result.stdout.trim(), 10);\n421:   return Number.isInteger(parsed) ? parsed : null;\n422: }\n423: \n424: function classifyOwnerLease(lease) {\n425:   const liveness = processLiveness(lease.ownerPid);\n426:   if (liveness === 'dead') return 'stale-pid';\n427:   if (liveness === 'unknown-eperm') return 'unknown-eperm';\n428: \n429:   const actualPpid = readParentPid(lease.ownerPid);\n430:   if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n431:     return 'ppid-1-orphan';\n432:   }\n433: \n434:   const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n435:   const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n436:   if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n437:     return 'stale-heartbeat-reclaim';\n438:   }\n439: \n440:   return 'live-owner';\n441: }\n442: \n443: function acquireOwnerLeaseFile() {\n444:   const currentOwnerLeasePath = ownerLeasePath();\n445:   const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n446: \n447:   if (existing) {\n448:     const classification = classifyOwnerLease(existing);\n449:     if (classification === 'live-owner' || classification === 'unknown-eperm') {\n450:       return { acquired: false, holder: existing, classification };\n451:     }\n452:     log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n453:   }\n454: \n455:   const lease = buildOwnerLease(process.pid);\n456:   if (!existing) {\n457:     if (!writeOwnerLeaseFileExclusive(lease)) {\n458:       const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n459:       return {\n460:         acquired: false,\n461:         holder: holder || lease,\n462:         classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n463:       };\n464:     }\n465:     ownerLeasePid = process.pid;\n466:     return { acquired: true, lease, reclaimed: existing };\n467:   }\n468: \n469:   // Re-read after reclaim so two launchers racing a stale lease cannot both act as owner.\n470:   writeOwnerLeaseFile(lease);\n471:   const reread = readOwnerLeaseFile(currentOwnerLeasePath);\n472:   if (!reread || reread.ownerPid !== process.pid) {\n473:     return {\n474:       acquired: false,\n475:       holder: reread || lease,\n476:       classification: reread ? classifyOwnerLease(reread) : 'live-owner',\n477:     };\n478:   }\n479:   ownerLeasePid = process.pid;\n480:   return { acquired: true, lease, reclaimed: existing };\n481: }\n482: \n483: function refreshOwnerLeaseFile(ownerPid, patch = {}) {\n484:   const lease = readOwnerLeaseFile();\n485:   if (!lease || lease.ownerPid !== ownerPid) return false;\n486:   const nextOwnerPid = patch.ownerPid ?? ownerPid;\n487:   writeOwnerLeaseFile({\n488:     ...lease,\n489:     ...patch,\n490:     lastHeartbeatIso: new Date().toISOString(),\n491:   });\n492:   const reread = readOwnerLeaseFile();\n493:   if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n494:   ownerLeasePid = nextOwnerPid;\n495:   return true;\n496: }\n497: \n498: function clearOwnerLeaseHeartbeat() {\n499:   if (ownerLeaseHeartbeatTimer) {\n500:     clearInterval(ownerLeaseHeartbeatTimer);\n501:     ownerLeaseHeartbeatTimer = null;\n502:   }\n503: }\n504: \n505: function startOwnerLeaseHeartbeat(ownerPid = process.pid) {\n506:   clearOwnerLeaseHeartbeat();\n507:   const lease = readOwnerLeaseFile();\n508:   const ttlMs = Number.isFinite(lease?.ttlMs) && lease.ttlMs > 0 ? lease.ttlMs : 60000;\n509:   const intervalMs = Math.max(1000, Math.floor(ttlMs / 2));\n510:   ownerLeaseHeartbeatTimer = setInterval(() => {\n511:     if (refreshOwnerLeaseFile(ownerPid)) return;\n512:     log('owner lease heartbeat refresh failed; shutting down launcher to preserve single ownership');\n513:     clearOwnerLeaseHeartbeat();\n514:     void shutdownLauncherForSignal('SIGTERM').catch((error) => {\n515:       log(error.stack || error.message);\n516:       clearAllLeaseFiles();\n517:       process.exit(128);\n518:     });\n519:   }, intervalMs);\n\n(Showing lines 180-519 of 1612. Use offset=520 to continue.)\n</content>","metadata":{"preview":"    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (default-on via the committed runtime configs; the code default below stays off\n// so the configs are the single on-switch). When enabled the owner spawns the daemon detached and, on\n// its own shutdown, RELEASES the daemon (leaves it running for a live secondary to bridge to) instead\n// of killing it, so a session ending does not tear the shared backend out from under other sessions.\n// A fresh session that finds the released daemon under a stale lease reaps it before respawn, so the\n// database keeps a single writer. Flag off collapses every path below to the prior behavior (daemon\n// tied to the owner, killed on shutdown). A released daemon reparents to pid 1, bounded by its idle\n// self-exit, so the orphan sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION === '1' || env.SPECKIT_DAEMON_REELECTION === 'on';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"    if (target && isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce('launcher-log-append', target, error);\n      return;\n    }\n    // Logging must never break the launcher.\n  }\n}\n\n// Daemon re-election (default-on via the committed runtime configs; the code default below stays off\n// so the configs are the single on-switch). When enabled the owner spawns the daemon detached and, on\n// its own shutdown, RELEASES the daemon (leaves it running for a live secondary to bridge to) instead\n// of killing it, so a session ending does not tear the shared backend out from under other sessions.\n// A fresh session that finds the released daemon under a stale lease reaps it before respawn, so the\n// database keeps a single writer. Flag off collapses every path below to the prior behavior (daemon\n// tied to the owner, killed on shutdown). A released daemon reparents to pid 1, bounded by its idle\n// self-exit, so the orphan sweeper bounds any leak.\nfunction daemonReelectionEnabled(env = process.env) {\n  return env.SPECKIT_DAEMON_REELECTION === '1' || env.SPECKIT_DAEMON_REELECTION === 'on';\n}\nfunction contextServerSpawnIo(reelectionEnabled) {\n  return reelectionEnabled\n    ? { detached: true, stdio: ['ignore', 'ignore', 'ignore'] }\n    : { detached: false, stdio: ['ignore', 'ignore', 'inherit'] };\n}\nfunction shouldReleaseDaemonForReelection({ enabled, hasLiveDaemon } = {}) {\n  return Boolean(enabled) && Boolean(hasLiveDaemon);\n}\n\nfunction cleanupTmpFile(tmpPath) {\n  try {\n    fs.unlinkSync(tmpPath);\n  } catch (error) {\n    if (error.code !== 'ENOENT') {\n      // Best-effort cleanup only; the original durable-write failure is more useful.\n    }\n  }\n}\n\nfunction writeAtomicJsonFile(targetPath, payload, operation) {\n  const currentPath = path.join(ensureCanonicalDir(path.dirname(targetPath)), path.basename(targetPath));\n  const tmp = `${currentPath}.tmp.${process.pid}`;\n  try {\n    fs.writeFileSync(tmp, `${JSON.stringify(payload, null, 2)}\\n`, { mode: 0o600 });\n    fs.renameSync(tmp, currentPath);\n    return true;\n  } catch (error) {\n    cleanupTmpFile(tmp);\n    if (isDurableWriteUnavailable(error)) {\n      logDurableWriteUnavailableOnce(operation, currentPath, error);\n      return false;\n    }\n    throw error;\n  }\n}\n\nfunction loadProjectEnvFiles() {\n  for (const fname of ['.env.local', '.env']) {\n    const p = path.join(root, fname);\n    if (fs.existsSync(p)) {\n      const n = loadEnvFile(p);\n      if (n > 0) process.stderr.write(`[mk-spec-memory-launcher] loaded ${n} env(s) from ${fname}\\n`);\n    }\n  }\n}\n\nfunction parsePositiveInteger(value, fallback) {\n  if (value === undefined || value === null || String(value).trim() === '') return fallback;\n  const parsed = Number.parseInt(String(value).trim(), 10);\n  return Number.isFinite(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction loadBridgeModule() {\n  try {\n    return require('./lib/launcher-ipc-bridge.cjs');\n  } catch (error) {\n    if (error.code !== 'MODULE_NOT_FOUND') throw error;\n    return {\n      async maybeBridgeLeaseHolder({ leaseResult }) {\n        const startedAt = leaseResult.startedAt ?? new Date(0).toISOString();\n        const legacyMarker = leaseResult.legacyPath ? ' (legacy path)' : '';\n        const suffix = process.env.SPECKIT_LAUNCHER_BRIDGE_DISABLED === '1' ? '' : ' (no-bridge-socket)';\n        process.stdout.write(`LEASE_HELD_BY:${leaseResult.ownerPid} startedAt=${startedAt}${legacyMarker}${suffix}\\n`);\n        return { action: 'report', reason: 'bridge-module-missing' };\n      },\n    };\n  }\n}\n\nfunction resolveSessionProxySocketPath() {\n  const { getIpcSocketPath } = loadBridgeModule();\n  return getIpcSocketPath('mk-spec-memory', { dbDir: resolvedDbDir() });\n}\n\n// Bridge a secondary (non-lease-holder) launcher's client stdio to the daemon through\n// the reconnecting session proxy, so 2nd+ clients survive a daemon recycle transparently\n// like the lease holder does — instead of the raw bridge that severs on recycle. Each\n// secondary launcher process gets its own proxy instance (its own pendingRequests and\n// cached-initialize state) because it owns its own stdio. The proxy owns stdout and emits\n// JSON-RPC errors on failure, so the raw bridge's onError stdout marker is intentionally\n// unused here (it would corrupt the MCP stream). createProxy is injectable for tests.\nfunction bridgeStdioThroughSessionProxy(socketPath, options = {}) {\n  const createProxy = options.createProxy ?? createSessionProxy;\n  const sessionProxy = createProxy({\n    socketPath,\n    stdin: options.stdin ?? process.stdin,\n    stdout: options.stdout ?? process.stdout,\n    log,\n  });\n  return sessionProxy.start();\n}\n\nfunction refreshPaths() {\n  skillsDir = path.join(opencodeDir, 'skills');\n  legacySkillDir = path.join(opencodeDir, 'skill');\n  kitDir = path.join(skillsDir, 'system-spec-kit');\n  dbDir = path.join(kitDir, 'mcp_server', 'database');\n  lockDir = path.join(dbDir, '.mk-spec-memory-launcher.lockdir');\n  stateFile = path.join(dbDir, PID_FILE_NAME);\n  canonicalCodeGraphDbDir = path.join(skillsDir, 'system-code-graph', 'mcp_server', 'database');\n}\n\nfunction exists(p) {\n  return fs.existsSync(p);\n}\n\nfunction writeState(payload) {\n  fs.mkdirSync(dbDir, { recursive: true, mode: 0o700 });\n  fs.writeFileSync(stateFile, `${JSON.stringify(payload, null, 2)}\\n`);\n}\n\nfunction resolvedDbDir() {\n  return canonicalizePath(dbDir);\n}\n\nfunction leasePath() {\n  return path.join(resolvedDbDir(), PID_FILE_NAME);\n}\n\nfunction ownerLeasePath() {\n  return path.join(resolvedDbDir(), OWNER_LEASE_FILE_NAME);\n}\n\nfunction legacyLeasePaths() {\n  return [\n    path.join(opencodeDir, 'skill', 'system-spec-kit', 'mcp_server', 'database', PID_FILE_NAME),\n  ].map(canonicalizePath);\n}\n\nfunction readLeaseFile(filePath = leasePath()) {\n  try {\n    const raw = fs.readFileSync(filePath, 'utf8');\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.pid === 'number') return parsed;\n  } catch {\n    // Missing or corrupt lease files are treated as no active lease.\n  }\n  return null;\n}\n\nfunction readOwnerLeaseFile(filePath = ownerLeasePath()) {\n  try {\n    const parsed = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n    if (\n      Number.isInteger(parsed.ownerPid) &&\n      Number.isInteger(parsed.ppid) &&\n      typeof parsed.executablePath === 'string' &&\n      typeof parsed.startedAtIso === 'string' &&\n      typeof parsed.lastHeartbeatIso === 'string' &&\n      Number.isInteger(parsed.ttlMs) &&\n      typeof parsed.canonicalDbDir === 'string'\n    ) {\n      return parsed;\n    }\n  } catch {\n    // Missing or corrupt owner leases are treated as no active owner.\n  }\n  return null;\n}\n\nfunction writeOwnerLeaseFile(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  const tmp = `${currentLeasePath}.tmp.${process.pid}.${Date.now()}.${Math.random().toString(36).slice(2)}`;\n  // fsync the temp file before the atomic rename so the lease contents survive a crash, matching\n  // the durability of the exclusive write path; a renamed-but-unsynced lease can resurface empty\n  // after power loss and break ownership detection.\n  let fd;\n  try {\n    fd = fs.openSync(tmp, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n  fs.renameSync(tmp, currentLeasePath);\n}\n\nfunction writeOwnerLeaseFileExclusive(lease) {\n  const currentLeasePath = path.join(ensureCanonicalDir(path.dirname(ownerLeasePath())), OWNER_LEASE_FILE_NAME);\n  let fd;\n  try {\n    fd = fs.openSync(currentLeasePath, 'wx', 0o600);\n    fs.writeFileSync(fd, `${JSON.stringify(lease, null, 2)}\\n`, 'utf8');\n    fs.fsyncSync(fd);\n    return true;\n  } catch (error) {\n    if (error.code === 'EEXIST') return false;\n    throw error;\n  } finally {\n    if (typeof fd === 'number') fs.closeSync(fd);\n  }\n}\n\nfunction buildOwnerLease(ownerPid = process.pid) {\n  return {\n    ownerPid,\n    ppid: process.ppid,\n    executablePath: process.execPath,\n    startedAtIso: new Date().toISOString(),\n    lastHeartbeatIso: new Date().toISOString(),\n    ttlMs: 60000,\n    canonicalDbDir: resolvedDbDir(),\n  };\n}\n\nfunction readParentPid(pid) {\n  if (!Number.isInteger(pid) || pid <= 0) return null;\n  if (process.platform === 'linux') {\n    try {\n      const status = fs.readFileSync(`/proc/${pid}/status`, 'utf8');\n      const match = status.match(/^PPid:\\s+(\\d+)$/m);\n      return match ? Number.parseInt(match[1], 10) : null;\n    } catch {\n      return null;\n    }\n  }\n  const result = spawnSync('ps', ['-o', 'ppid=', '-p', String(pid)], {\n    encoding: 'utf8',\n    stdio: ['ignore', 'pipe', 'ignore'],\n  });\n  if (result.status !== 0 || !result.stdout) return null;\n  const parsed = Number.parseInt(result.stdout.trim(), 10);\n  return Number.isInteger(parsed) ? parsed : null;\n}\n\nfunction classifyOwnerLease(lease) {\n  const liveness = processLiveness(lease.ownerPid);\n  if (liveness === 'dead') return 'stale-pid';\n  if (liveness === 'unknown-eperm') return 'unknown-eperm';\n\n  const actualPpid = readParentPid(lease.ownerPid);\n  if (actualPpid !== null && actualPpid !== lease.ppid && actualPpid === 1) {\n    return 'ppid-1-orphan';\n  }\n\n  const heartbeatMs = Date.parse(lease.lastHeartbeatIso);\n  const ttlMs = Number.isFinite(lease.ttlMs) ? lease.ttlMs : 0;\n  if (!Number.isFinite(heartbeatMs) || Date.now() - heartbeatMs > ttlMs * 2) {\n    return 'stale-heartbeat-reclaim';\n  }\n\n  return 'live-owner';\n}\n\nfunction acquireOwnerLeaseFile() {\n  const currentOwnerLeasePath = ownerLeasePath();\n  const existing = readOwnerLeaseFile(currentOwnerLeasePath);\n\n  if (existing) {\n    const classification = classifyOwnerLease(existing);\n    if (classification === 'live-owner' || classification === 'unknown-eperm') {\n      return { acquired: false, holder: existing, classification };\n    }\n    log(`ownerLeaseReclaimed: ${classification} ownerPid=${existing.ownerPid}`);\n  }\n\n  const lease = buildOwnerLease(process.pid);\n  if (!existing) {\n    if (!writeOwnerLeaseFileExclusive(lease)) {\n      const holder = readOwnerLeaseFile(currentOwnerLeasePath);\n      return {\n        acquired: false,\n        holder: holder || lease,\n        classification: holder ? classifyOwnerLease(holder) : 'live-owner',\n      };\n    }\n    ownerLeasePid = process.pid;\n    return { acquired: true, lease, reclaimed: existing };\n  }\n\n  // Re-read after reclaim so two launchers racing a stale lease cannot both act as owner.\n  writeOwnerLeaseFile(lease);\n  const reread = readOwnerLeaseFile(currentOwnerLeasePath);\n  if (!reread || reread.ownerPid !== process.pid) {\n    return {\n      acquired: false,\n      holder: reread || lease,\n      classification: reread ? classifyOwnerLease(reread) : 'live-owner',\n    };\n  }\n  ownerLeasePid = process.pid;\n  return { acquired: true, lease, reclaimed: existing };\n}\n\nfunction refreshOwnerLeaseFile(ownerPid, patch = {}) {\n  const lease = readOwnerLeaseFile();\n  if (!lease || lease.ownerPid !== ownerPid) return false;\n  const nextOwnerPid = patch.ownerPid ?? ownerPid;\n  writeOwnerLeaseFile({\n    ...lease,\n    ...patch,\n    lastHeartbeatIso: new Date().toISOString(),\n  });\n  const reread = readOwnerLeaseFile();\n  if (!reread || reread.ownerPid !== nextOwnerPid) return false;\n  ownerLeasePid = nextOwnerPid;\n  return true;\n}\n\nfunction clearOwnerLeaseHeartbeat() {\n  if (ownerLeaseHeartbeatTimer) {\n    clearInterval(ownerLeaseHeartbeatTimer);\n    ownerLeaseHeartbeatTimer = null;\n  }\n}\n\nfunction startOwnerLeaseHeartbeat(ownerPid = process.pid) {\n  clearOwnerLeaseHeartbeat();\n  const lease = readOwnerLeaseFile();\n  const ttlMs = Number.isFinite(lease?.ttlMs) && lease.ttlMs > 0 ? lease.ttlMs : 60000;\n  const intervalMs = Math.max(1000, Math.floor(ttlMs / 2));\n  ownerLeaseHeartbeatTimer = setInterval(() => {\n    if (refreshOwnerLeaseFile(ownerPid)) return;\n    log('owner lease heartbeat refresh failed; shutting down launcher to preserve single ownership');\n    clearOwnerLeaseHeartbeat();\n    void shutdownLauncherForSignal('SIGTERM').catch((error) => {\n      log(error.stack || error.message);\n      clearAllLeaseFiles();\n      process.exit(128);\n    });\n  }, intervalMs);","lineStart":180,"lineEnd":519,"totalLines":1612,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780906508754,"end":1780906508764}},"metadata":{"openai":{"itemId":"fc_03d9774c5a6e4582016a267a0cad208191896ebc41a6d3fe80"}},"id":"prt_ea64cc1a70013kEG94c8I3NMs0","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64c5eed0013Bple0gkUsUPiE"}}
{"type":"tool_use","timestamp":1780906508779,"sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","part":{"type":"tool","tool":"read","callID":"call_6w1zPUZ69SBvLcBO9gNmW5Vn","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","offset":650,"limit":110},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs</path>\n<type>file</type>\n<content>\n650: \n651: function acquireRespawnLockFileAt(lockPath, label = 'respawn') {\n652:   return acquireSharedRespawnLockFileAt(lockPath, label, { log, rel });\n653: }\n654: \n655: function acquireRespawnLockFile() {\n656:   return acquireRespawnLockFileAt(respawnLockPath(), 'respawn');\n657: }\n658: \n659: function acquireModelServerRespawnLockFile(socketPath = resolveModelServerSocketPath()) {\n660:   return mss.acquireModelServerRespawnLockFile(socketPath, { dbDir: resolvedDbDir, log, rel });\n661: }\n662: \n663: const UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n664: \n665: // The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n666: // successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n667: // child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n668: // DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n669: // guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.\n670: function uncleanShutdownMarkerPath() {\n671:   const override = process.env.MEMORY_DB_PATH;\n672:   const dir = override ? path.dirname(override) : resolvedDbDir();\n673:   return path.join(dir, UNCLEAN_SHUTDOWN_MARKER);\n674: }\n675: \n676: function uncleanMarkerPresent() {\n677:   try {\n678:     return fs.existsSync(uncleanShutdownMarkerPath());\n679:   } catch {\n680:     return false;\n681:   }\n682: }\n683: \n684: // A reap is a verified clean DB handoff only when the child exited on SIGTERM (not SIGKILL) AND the\n685: // clean-shutdown marker is gone (close_db ran its checkpoint + close). Anything else means the\n686: // replacement daemon will open a possibly-dirty shadow and must rebuild it at boot.\n687: function cleanCloseAfterReap({ killed, markerPresent }) {\n688:   return !killed && !markerPresent;\n689: }\n690: \n691: async function reapLeaseChildBeforeRespawn(childPid) {\n692:   const liveness = processLiveness(childPid);\n693:   if (liveness === 'unknown-eperm') {\n694:     return { allowed: false, reason: 'child-liveness-unknown-eperm' };\n695:   }\n696:   if (liveness === 'dead') {\n697:     return {\n698:       allowed: true,\n699:       reaped: false,\n700:       cleanClose: cleanCloseAfterReap({ killed: false, markerPresent: uncleanMarkerPresent() }),\n701:       reason: 'child-already-dead',\n702:     };\n703:   }\n704: \n705:   log(`reaping recorded context-server child pid ${childPid} before respawn`);\n706:   signalProcess(childPid, 'SIGTERM');\n707:   reapProcessTreeGroups(childPid, { signal: signalProcess });\n708:   const exitedAfterTerm = await waitForPidExit(childPid, RESPAWN_REAP_GRACE_MS);\n709:   let killed = false;\n710:   if (!exitedAfterTerm) {\n711:     log(`context-server child pid ${childPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n712:     signalProcess(childPid, 'SIGKILL');\n713:     await waitForPidExit(childPid, 1000);\n714:     killed = true;\n715:   }\n716: \n717:   // Clean-close barrier: verify the child closed the DB cleanly (marker removed) before handing the\n718:   // DB to a replacement daemon. If it did not (graceful close timed out, or we had to SIGKILL), log\n719:   // it so the corruption window is visible — the replacement daemon's boot FTS auto-heal rebuilds the\n720:   // shadow. We never block respawn on this: a missing daemon is worse than a self-healing one.\n721:   const markerPresent = uncleanMarkerPresent();\n722:   const cleanClose = cleanCloseAfterReap({ killed, markerPresent });\n723:   if (!cleanClose) {\n724:     log(`reaped context-server child pid ${childPid} WITHOUT a verified clean DB close (killed=${killed}, uncleanMarkerPresent=${markerPresent}); the replacement daemon will rebuild the FTS shadow at boot`);\n725:   }\n726:   return { allowed: true, reaped: true, cleanClose, reason: 'child-reaped' };\n727: }\n728: \n729: async function reapOwnerBeforeRespawn(ownerPid) {\n730:   const liveness = processLiveness(ownerPid);\n731:   if (liveness === 'unknown-eperm') {\n732:     return { allowed: false, reason: 'owner-liveness-unknown-eperm' };\n733:   }\n734:   if (liveness === 'dead') {\n735:     return { allowed: true, reason: 'owner-already-dead' };\n736:   }\n737: \n738:   log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n739:   signalProcess(ownerPid, 'SIGTERM');\n740:   const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n741:   if (!exitedAfterTerm) {\n742:     log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n743:     signalProcess(ownerPid, 'SIGKILL');\n744:     await waitForPidExit(ownerPid, 1000);\n745:   }\n746:   return { allowed: true, reason: 'owner-reaped' };\n747: }\n748: \n749: async function respawnAfterDeadSocket(leaseResult, decision) {\n750:   if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n751:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n752:     return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n753:   }\n754: \n755:   const ownerPid = leaseResult.ownerPid;\n756:   if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n757:     log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n758:     writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n759:     return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };\n\n(Showing lines 650-759 of 1612. Use offset=760 to continue.)\n</content>","metadata":{"preview":"\nfunction acquireRespawnLockFileAt(lockPath, label = 'respawn') {\n  return acquireSharedRespawnLockFileAt(lockPath, label, { log, rel });\n}\n\nfunction acquireRespawnLockFile() {\n  return acquireRespawnLockFileAt(respawnLockPath(), 'respawn');\n}\n\nfunction acquireModelServerRespawnLockFile(socketPath = resolveModelServerSocketPath()) {\n  return mss.acquireModelServerRespawnLockFile(socketPath, { dbDir: resolvedDbDir, log, rel });\n}\n\nconst UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n\n// The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n// successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n// child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n// DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n// guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/bin/mk-spec-memory-launcher.cjs","text":"\nfunction acquireRespawnLockFileAt(lockPath, label = 'respawn') {\n  return acquireSharedRespawnLockFileAt(lockPath, label, { log, rel });\n}\n\nfunction acquireRespawnLockFile() {\n  return acquireRespawnLockFileAt(respawnLockPath(), 'respawn');\n}\n\nfunction acquireModelServerRespawnLockFile(socketPath = resolveModelServerSocketPath()) {\n  return mss.acquireModelServerRespawnLockFile(socketPath, { dbDir: resolvedDbDir, log, rel });\n}\n\nconst UNCLEAN_SHUTDOWN_MARKER = '.unclean-shutdown';\n\n// The context-server writes `.unclean-shutdown` on every DB open and removes it only after a\n// successful WAL checkpoint + db.close(). The launcher uses its presence to tell whether a reaped\n// child handed off the DB cleanly. Mirror the writer's location: the marker lives in the resolved\n// DB dir, or — when MEMORY_DB_PATH relocates the DB — that path's dirname. Best-effort: a wrong\n// guess only forfeits the clean-close confirmation; the replacement daemon's boot still self-heals.\nfunction uncleanShutdownMarkerPath() {\n  const override = process.env.MEMORY_DB_PATH;\n  const dir = override ? path.dirname(override) : resolvedDbDir();\n  return path.join(dir, UNCLEAN_SHUTDOWN_MARKER);\n}\n\nfunction uncleanMarkerPresent() {\n  try {\n    return fs.existsSync(uncleanShutdownMarkerPath());\n  } catch {\n    return false;\n  }\n}\n\n// A reap is a verified clean DB handoff only when the child exited on SIGTERM (not SIGKILL) AND the\n// clean-shutdown marker is gone (close_db ran its checkpoint + close). Anything else means the\n// replacement daemon will open a possibly-dirty shadow and must rebuild it at boot.\nfunction cleanCloseAfterReap({ killed, markerPresent }) {\n  return !killed && !markerPresent;\n}\n\nasync function reapLeaseChildBeforeRespawn(childPid) {\n  const liveness = processLiveness(childPid);\n  if (liveness === 'unknown-eperm') {\n    return { allowed: false, reason: 'child-liveness-unknown-eperm' };\n  }\n  if (liveness === 'dead') {\n    return {\n      allowed: true,\n      reaped: false,\n      cleanClose: cleanCloseAfterReap({ killed: false, markerPresent: uncleanMarkerPresent() }),\n      reason: 'child-already-dead',\n    };\n  }\n\n  log(`reaping recorded context-server child pid ${childPid} before respawn`);\n  signalProcess(childPid, 'SIGTERM');\n  reapProcessTreeGroups(childPid, { signal: signalProcess });\n  const exitedAfterTerm = await waitForPidExit(childPid, RESPAWN_REAP_GRACE_MS);\n  let killed = false;\n  if (!exitedAfterTerm) {\n    log(`context-server child pid ${childPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n    signalProcess(childPid, 'SIGKILL');\n    await waitForPidExit(childPid, 1000);\n    killed = true;\n  }\n\n  // Clean-close barrier: verify the child closed the DB cleanly (marker removed) before handing the\n  // DB to a replacement daemon. If it did not (graceful close timed out, or we had to SIGKILL), log\n  // it so the corruption window is visible — the replacement daemon's boot FTS auto-heal rebuilds the\n  // shadow. We never block respawn on this: a missing daemon is worse than a self-healing one.\n  const markerPresent = uncleanMarkerPresent();\n  const cleanClose = cleanCloseAfterReap({ killed, markerPresent });\n  if (!cleanClose) {\n    log(`reaped context-server child pid ${childPid} WITHOUT a verified clean DB close (killed=${killed}, uncleanMarkerPresent=${markerPresent}); the replacement daemon will rebuild the FTS shadow at boot`);\n  }\n  return { allowed: true, reaped: true, cleanClose, reason: 'child-reaped' };\n}\n\nasync function reapOwnerBeforeRespawn(ownerPid) {\n  const liveness = processLiveness(ownerPid);\n  if (liveness === 'unknown-eperm') {\n    return { allowed: false, reason: 'owner-liveness-unknown-eperm' };\n  }\n  if (liveness === 'dead') {\n    return { allowed: true, reason: 'owner-already-dead' };\n  }\n\n  log(`confirmed-dead socket; reaping recorded spec-memory owner pid ${ownerPid} before respawn`);\n  signalProcess(ownerPid, 'SIGTERM');\n  const exitedAfterTerm = await waitForPidExit(ownerPid, RESPAWN_REAP_GRACE_MS);\n  if (!exitedAfterTerm) {\n    log(`spec-memory owner pid ${ownerPid} exceeded ${RESPAWN_REAP_GRACE_MS}ms reap grace; sending SIGKILL`);\n    signalProcess(ownerPid, 'SIGKILL');\n    await waitForPidExit(ownerPid, 1000);\n  }\n  return { allowed: true, reason: 'owner-reaped' };\n}\n\nasync function respawnAfterDeadSocket(leaseResult, decision) {\n  if (process.env.SPECKIT_BRIDGE_RESPAWN_DISABLED === '1') {\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-respawn-disabled)');\n    return { action: 'report', reason: 'respawn-disabled', socketPath: decision.socketPath };\n  }\n\n  const ownerPid = leaseResult.ownerPid;\n  if (!Number.isInteger(ownerPid) || ownerPid <= 0) {\n    log('confirmed-dead socket but no recorded spec-memory owner pid is available; respawn inert');\n    writeLeaseHeldDiagnostic(leaseResult, ' (dead-socket-no-owner-pid)');\n    return { action: 'report', reason: 'missing-owner-pid', socketPath: decision.socketPath };","lineStart":650,"lineEnd":759,"totalLines":1612,"truncated":true}},"title":".opencode/bin/mk-spec-memory-launcher.cjs","time":{"start":1780906508773,"end":1780906508778}},"metadata":{"openai":{"itemId":"fc_03d9774c5a6e4582016a267a0cad348191abceb52b5a12049e"}},"id":"prt_ea64cc1d4001i4haKrlHrZ1LBg","sessionID":"ses_159b57c7fffe0UrEO0Gfg5sl7z","messageID":"msg_ea64c5eed0013Bple0gkUsUPiE"}}
