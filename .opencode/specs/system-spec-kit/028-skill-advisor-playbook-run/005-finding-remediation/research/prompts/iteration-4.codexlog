   309	function latestSourceMtimeMs() {
   310	  let latest = 0;
   311	  const candidates = [
   312	    path.join(mcpDir, 'advisor-server.ts'),
   313	    path.join(mcpDir, 'package.json'),
   314	    path.join(mcpDir, 'tsconfig.json'),
   315	    path.join(mcpDir, 'tsconfig.build.json'),
   316	    ...SOURCE_DIRS.map((dir) => path.join(mcpDir, dir)),
   317	  ];
   318	
   319	  const visit = (candidate) => {
   320	    if (!exists(candidate)) return;
   321	    const stat = fs.statSync(candidate);
   322	    if (stat.isDirectory()) {
   323	      for (const entry of fs.readdirSync(candidate)) {
   324	        visit(path.join(candidate, entry));
   325	      }
   326	      return;
   327	    }
   328	    if (candidate.endsWith('.ts') || candidate.endsWith('.json')) {
   329	      latest = Math.max(latest, stat.mtimeMs);
   330	    }
   331	  };
   332	
   333	  for (const candidate of candidates) {
   334	    visit(candidate);
   335	  }
   336	  return latest;
   337	}
   338	
   339	function artifactsReady() {
   340	  const artifacts = requiredArtifacts();
   341	  if (!artifacts.every(exists)) {
   342	    return false;
   343	  }
   344	
   345	  const sourceMtime = latestSourceMtimeMs();
   346	  if (sourceMtime === 0) {
   347	    return true;
   348	  }
   349	  return artifacts.every((artifact) => fs.statSync(artifact).mtimeMs >= sourceMtime);
   350	}
