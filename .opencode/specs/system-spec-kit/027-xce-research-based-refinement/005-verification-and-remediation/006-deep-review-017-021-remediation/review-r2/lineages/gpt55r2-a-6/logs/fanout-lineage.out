path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/formatters/index.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Formatters (Barrel Export)\n// ────────────────────────────────────────────────────────────────\n\nexport {\n  // Types\n  type TieredResult,\n  type TokenMetrics,\n\n  // Functions\n  estimateTokens,\n  calculateTokenMetrics,\n} from './token-metrics.js';\n\nexport {\n  // Types\n  type AnchorTokenMetrics,\n  type RawSearchResult,\n  type FormattedSearchResult,\n  type MemoryParserLike,\n  type MCPResponse,\n\n  // Functions\n  formatSearchResults,\n  validateFilePathLocal,\n  safeJsonParse,\n\n} from './search-results.js';\n\n// Re-export ALLOWED_BASE_PATHS from its canonical source\nexport { ALLOWED_BASE_PATHS } from '../core/config.js';","lineStart":1,"lineEnd":31,"totalLines":31,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/formatters/index.ts","time":{"start":1781762552986,"end":1781762553001}},"metadata":{"openai":{"itemId":"fc_0ad6a33b31dfd68b016a3389f8c5d48191a6a4eedb5e2e54f6"}},"id":"prt_ed952f495001heb5GYPyIbIeET","sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","messageID":"msg_ed952b9660016b4OyV917AJXcZ"}}
{"type":"tool_use","timestamp":1781762553008,"sessionID":"ses_126af6eadffeKdnQM4mriL3y8K","part":{"type":"tool","tool":"read","callID":"call_h2yr9n4ftUlob1h4l8kkVQJO","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","offset":1383,"limit":1000},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts</path>\n<type>file</type>\n<content>\n1383:       // Adaptive proposal logging is best-effort only\n1384:     }\n1385: \n1386:     const appliedBoosts: Record<string, unknown> = {\n1387:       session: { applied: pipelineResult.metadata.stage2.sessionBoostApplied },\n1388:       causal: { applied: pipelineResult.metadata.stage2.causalBoostApplied },\n1389:     };\n1390:     if (folderBoost && folderBoost.folder) {\n1391:       appliedBoosts.folder = { applied: true, folder: folderBoost.folder, factor: folderBoost.factor };\n1392:     }\n1393:     if (communityFallbackApplied) {\n1394:       appliedBoosts.communityFallback = { applied: true, retrievalLevel };\n1395:     }\n1396:     extraData.appliedBoosts = appliedBoosts;\n1397:     extraData.applied_boosts = appliedBoosts;\n1398: \n1399:     let formatted = await formatSearchResults(\n1400:       resultsForFormatting as RawSearchResult[],\n1401:       pipelineConfig.searchType,\n1402:       includeContent,\n1403:       anchors,\n1404:       null,\n1405:       null,\n1406:       extraData,\n1407:       includeTrace,\n1408:       normalizedQuery,   // pass query for recovery + confidence context\n1409:       specFolder ?? null // pass specFolder for recovery narrowing detection\n1410:     );\n1411: \n1412:     // Prepend evidence gap warning if present\n1413:     if (pipelineResult.annotations.evidenceGapWarning && formatted?.content?.[0]?.text) {\n1414:       try {\n1415:         const parsed = JSON.parse(formatted.content[0].text) as Record<string, unknown>;\n1416:         if (typeof parsed.summary === 'string') {\n1417:           parsed.summary = `${pipelineResult.annotations.evidenceGapWarning}\\n\\n${parsed.summary}`;\n1418:           formatted.content[0].text = JSON.stringify(parsed, null, 2);\n1419:         }\n1420:       } catch (_error: unknown) {\n1421:         // Non-fatal\n1422:       }\n1423:     }\n1424:     if (isProgressiveDisclosureEnabled()) {\n1425:       const parsedFormatted = parseResponseEnvelope(formatted);\n1426:       if (parsedFormatted) {\n1427:         const data = parsedFormatted.envelope.data && typeof parsedFormatted.envelope.data === 'object'\n1428:           ? parsedFormatted.envelope.data as Record<string, unknown>\n1429:           : {};\n1430:         data.progressiveDisclosure = buildProgressiveResponse(\n1431:           resultsForFormatting,\n1432:           undefined,\n1433:           effectiveQuery,\n1434:           { scopeKey: progressiveScopeKey },\n1435:         );\n1436:         parsedFormatted.envelope.data = data;\n1437:         formatted = replaceResponseEnvelope(formatted, parsedFormatted.firstEntry, parsedFormatted.envelope);\n1438:       }\n1439:     }\n1440: \n1441:     formatted = applyPublicationGateToResponse(formatted);\n1442: \n1443:     const cachePayload = extractSearchCachePayload(formatted);\n1444:     if (cachePayload && cacheEnabled) {\n1445:       toolCache.set(cacheKey, cachePayload, { toolName: 'memory_search' });\n1446:     }\n1447: \n1448:     responseToReturn = cachePayload\n1449:       ? buildSearchResponseFromPayload(cachePayload, _searchStartTime, false)\n1450:       : formatted;\n1451:   }\n1452: \n1453:   responseToReturn = applyPublicationGateToResponse(responseToReturn);\n1454: \n1455:   if (sessionId && isSessionRetrievalStateEnabled() && !sessionManager.isEnabled()) {\n1456:     const parsedResponse = parseResponseEnvelope(responseToReturn);\n1457:     const data = parsedResponse?.envelope.data && typeof parsedResponse.envelope.data === 'object'\n1458:       ? parsedResponse.envelope.data as Record<string, unknown>\n1459:       : null;\n1460:     const existingResults = Array.isArray(data?.results) ? data.results as SessionAwareResult[] : null;\n1461: \n1462:     if (parsedResponse && data && existingResults && existingResults.length > 0) {\n1463:       const deduped = deduplicateWithSessionState(existingResults, sessionId);\n1464:       reconcilePostFormatResultSet(data, deduped.results as Array<Record<string, unknown>>);\n1465:       data.sessionDedup = deduped.metadata;\n1466:       parsedResponse.envelope.data = data;\n1467:       responseToReturn = replaceResponseEnvelope(responseToReturn, parsedResponse.firstEntry, parsedResponse.envelope);\n1468:     }\n1469:   }\n1470: \n1471:   // Apply session deduplication AFTER cache\n1472:   if (sessionId && enableDedup && sessionManager.isEnabled()) {\n1473:     let resultsData: Record<string, unknown> | null = null;\n1474:     if (responseToReturn?.content?.[0]?.text && typeof responseToReturn.content[0].text === 'string') {\n1475:       try {\n1476:         resultsData = JSON.parse(responseToReturn.content[0].text) as Record<string, unknown>;\n1477:       } catch (err: unknown) {\n1478:         const message = toErrorMessage(err);\n1479:         console.warn('[memory-search] Failed to parse cached response for dedup:', message);\n1480:         resultsData = null;\n1481:       }\n1482:     } else if (responseToReturn && typeof responseToReturn === 'object') {\n1483:       resultsData = responseToReturn as unknown as Record<string, unknown>;\n1484:     }\n1485: \n1486:     // Validate response shape before dedup. If the cached response\n1487:     // Doesn't have the expected data.results array, log a warning and skip dedup\n1488:     // Rather than silently falling through to the un-deduped response.\n1489:     const data = (resultsData && typeof resultsData.data === 'object' && resultsData.data !== null)\n1490:       ? resultsData.data as Record<string, unknown>\n1491:       : null;\n1492:     const existingResults = Array.isArray(data?.results) ? data.results as MemorySearchRow[] : null;\n1493: \n1494:     if (resultsData && !data) {\n1495:       console.warn('[memory-search] Cached response shape mismatch: missing \"data\" object, skipping dedup');\n1496:     } else if (data && !existingResults) {\n1497:       console.warn('[memory-search] Cached response shape mismatch: \"data.results\" is not an array, skipping dedup');\n1498:     }\n1499: \n1500:     if (resultsData && data && existingResults && existingResults.length > 0) {\n1501:       const { results: dedupedResults } = applySessionDedup(\n1502:         existingResults,\n1503:         sessionId,\n1504:         enableDedup\n1505:       );\n1506: \n1507:       const originalCount = existingResults.length;\n1508:       const dedupedCount = dedupedResults.length;\n1509:       const filteredCount = originalCount - dedupedCount;\n1510: \n1511:       const tokensSaved = filteredCount * 200;\n1512:       const savingsPercent = originalCount > 0\n1513:         ? Math.round((filteredCount / originalCount) * 100)\n1514:         : 0;\n1515: \n1516:       reconcilePostFormatResultSet(data, dedupedResults as Array<Record<string, unknown>>);\n1517: \n1518:       const dedupStats = {\n1519:         enabled: true,\n1520:         sessionId,\n1521:         originalCount: originalCount,\n1522:         returnedCount: dedupedCount,\n1523:         filteredCount: filteredCount,\n1524:         tokensSaved: tokensSaved,\n1525:         savingsPercent: savingsPercent,\n1526:         tokenSavingsEstimate: tokensSaved > 0 ? `~${tokensSaved} tokens` : '0'\n1527:       };\n1528:       resultsData.dedupStats = dedupStats;\n1529: \n1530:       if (resultsData.meta && typeof resultsData.meta === 'object') {\n1531:         (resultsData.meta as Record<string, unknown>).dedupStats = dedupStats;\n1532:       }\n1533: \n1534:       if (filteredCount > 0 && typeof resultsData.summary === 'string') {\n1535:         resultsData.summary += ` (${filteredCount} duplicates filtered, ~${tokensSaved} tokens saved)`;\n1536:       }\n1537: \n1538:       responseToReturn = {\n1539:         ...responseToReturn,\n1540:         content: [{ type: 'text', text: JSON.stringify(resultsData, null, 2) }]\n1541:       } as MCPResponse;\n1542:     }\n1543:   }\n1544: \n1545:   if (sessionId && isSessionRetrievalStateEnabled()) {\n1546:     const parsedResponse = parseResponseEnvelope(responseToReturn);\n1547:     const data = parsedResponse?.envelope.data && typeof parsedResponse.envelope.data === 'object'\n1548:       ? parsedResponse.envelope.data as Record<string, unknown>\n1549:       : null;\n1550:     const existingResults = Array.isArray(data?.results) ? data.results as Array<Record<string, unknown>> : [];\n1551: \n1552:     if (parsedResponse && data) {\n1553:       const returnedIds = existingResults\n1554:         .map((result) => result.id ?? result.resultId)\n1555:         .filter((id): id is string | number => typeof id === 'string' || typeof id === 'number');\n1556: \n1557:       if (returnedIds.length > 0) {\n1558:         retrievalSessionStateManager.markSeen(sessionId, returnedIds);\n1559:       }\n1560: \n1561:       data.sessionState = buildSessionStatePayload(sessionId);\n1562:       if (goalRefinementPayload) {\n1563:         data.goalRefinement = goalRefinementPayload;\n1564:       }\n1565: \n1566:       parsedResponse.envelope.data = data;\n1567:       responseToReturn = replaceResponseEnvelope(responseToReturn, parsedResponse.firstEntry, parsedResponse.envelope);\n1568:     }\n1569:   }\n1570: \n1571:   if (includeTrace && sessionTransition) {\n1572:     responseToReturn = attachSessionTransitionTrace(responseToReturn, sessionTransition);\n1573:   }\n1574: \n1575:   if (retrievalTelemetry.isExtendedTelemetryEnabled()) {\n1576:     const telemetry = retrievalTelemetry.createTelemetry();\n1577: