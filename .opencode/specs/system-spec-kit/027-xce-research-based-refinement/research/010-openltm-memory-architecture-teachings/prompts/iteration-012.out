{"type":"tool_use","timestamp":1780928841177,"sessionID":"ses_1586048c5ffertmP8HohyAZ8wd","part":{"type":"tool","tool":"read","callID":"call_5r9XZKm2bd0utHWMzBr9RmC7","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env bun\n2: import { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\n3: import { homedir } from \"os\";\n4: import { join } from \"path\";\n5: import { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\n6: import { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\n7: import { logHook, logEvent } from \"../lib/hookLogger.js\";\n8: import { EVENTS } from \"../lib/eventNames.js\";\n9: import { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n10: \n11: const TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\n12: const MAX_PROGRESS_LINES = 20;\n13: const MAX_DISPLAY_FILES = 5;\n14: const DB_PATH = getDbPath();\n15: \n16: function findTranscriptPath(\n17:   transcriptPath: string | undefined,\n18:   sessionId: string | undefined\n19: ): string | null {\n20:   if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;\n21: \n22:   const historyFile = join(CLAUDE_DIR, \"history.jsonl\");\n23:   if (!existsSync(historyFile)) return null;\n24: \n25:   const lines = readFileSync(historyFile, \"utf-8\").trim().split(\"\\n\");\n26:   let entry: Record<string, unknown> | null = null;\n27: \n28:   if (sessionId) {\n29:     for (let i = lines.length - 1; i >= 0; i--) {\n30:       try {\n31:         const parsed = JSON.parse(lines[i] ?? \"\") as Record<string, unknown>;\n32:         if (parsed.sessionId === sessionId) { entry = parsed; break; }\n33:       } catch {}\n34:     }\n35:   } else {\n36:     try { entry = JSON.parse(lines[lines.length - 1] ?? \"\") as Record<string, unknown>; } catch {}\n37:   }\n38: \n39:   if (!entry?.sessionId || !entry?.project) return null;\n40: \n41:   const filename = `${entry.sessionId}.jsonl`;\n42:   const { projectDir } = resolveProject(entry.project as string);\n43:   const primary = join(projectDir, filename);\n44:   if (existsSync(primary)) return primary;\n45: \n46:   try {\n47:     for (const dir of readdirSync(PROJECTS_DIR)) {\n48:       const candidate = join(PROJECTS_DIR, dir, filename);\n49:       if (existsSync(candidate)) return candidate;\n50:     }\n51:   } catch {}\n52: \n53:   return null;\n54: }\n55: \n56: function collectModifiedFiles(messages: Array<Record<string, unknown>>): Set<string> {\n57:   const files = new Set<string>();\n58:   for (const m of messages) {\n59:     const content = (m.message as Record<string, unknown> | undefined)?.content;\n60:     if (!Array.isArray(content)) continue;\n61:     for (const block of content as Array<Record<string, unknown>>) {\n62:       if (block.type === \"tool_use\" && TOOL_NAMES.has(block.name as string)) {\n63:         const input = block.input as Record<string, string> | undefined;\n64:         const p = input?.file_path || input?.path;\n65:         if (p) files.add(p);\n66:       }\n67:     }\n68:   }\n69:   return files;\n70: }\n71: \n72: function parseJsonLines(raw: string): Array<Record<string, unknown>> {\n73:   return raw.trim().split(\"\\n\")\n74:     .map(line => { try { return JSON.parse(line) as Record<string, unknown>; } catch { return null; } })\n75:     .filter(Boolean) as Array<Record<string, unknown>>;\n76: }\n77: \n78: async function main(): Promise<void> {\n79:   const raw = await readStdinPassthrough();\n80: \n81:   const parsed = parseHookInput(raw);\n82:   if (!parsed) return;\n83: \n84:   const { input, cwd } = parsed;\n85:   const { name, projectDir } = resolveProject(cwd);\n86:   if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n87: \n88:   const tPath = findTranscriptPath(\n89:     input.transcript_path as string | undefined,\n90:     input.session_id as string | undefined\n91:   );\n92:   if (!tPath) return;\n93: \n94:   const messages = parseJsonLines(readFileSync(tPath, \"utf-8\"));\n95:   if (messages.length < 3) return;\n96: \n97:   const sessionTag = input.session_id ? (input.session_id as string).substring(0, 8) : null;\n98:   const today = new Date().toISOString().split(\"T\")[0];\n99:   const tagPart = sessionTag ? ` [${sessionTag}]` : \"\";\n100: \n101:   const filesModified = collectModifiedFiles(messages);\n102:   const sessionLine = filesModified.size > 0\n103:     ? `✓ [${today}]${tagPart} Modified: ${[...filesModified].slice(0, MAX_DISPLAY_FILES).map(f => f.replace(homedir(), \"~\")).join(\", \")}`\n104:     : `✓ [${today}]${tagPart} Session (read-only, ${messages.length} messages)`;\n105: \n106:   // Write to DB if available, fall back to .md file\n107:   if (existsSync(DB_PATH)) {\n108:     try {\n109:       const prefixMatch = sessionLine.match(/^\\[(decision|gotcha)\\]\\s*/i);\n110:       if (prefixMatch) {\n111:         const type = prefixMatch[1]!.toLowerCase() as \"decision\" | \"gotcha\";\n112:         const strippedContent = sessionLine.slice(prefixMatch[0].length);\n113:         if (type === \"decision\") addDecision(name, strippedContent);\n114:         else addGotcha(name, strippedContent);\n115:       } else {\n116:         appendProgress(name, sessionLine, sessionTag ?? undefined);\n117:       }\n118:       logHook(\"UpdateContext\", \"info\", `context DB updated for ${name}`);\n119:       logEvent(\"UpdateContext\", EVENTS.CONTEXT_UPDATED, { project: name });\n120:       emitEvent({ hook: \"UpdateContext\", event: EVENTS.CONTEXT_UPDATED, project: name, ts: new Date().toISOString() });\n121:       return;\n122:     } catch (dbErr) {\n123:       logHook(\"UpdateContext\", \"warn\", \"DB write failed, falling back to .md\", String(dbErr));\n124:       process.stderr.write(`[UpdateContext] DB write failed, falling back to .md: ${dbErr}\\n`);\n125:     }\n126:   }\n127: \n128:   // Fallback: write to markdown file\n129:   const progressFile = join(projectDir, \"context-progress.md\");\n130:   const existing = readFileSafe(progressFile);\n131:   if (sessionTag && existing.includes(sessionTag)) return;\n132: \n133:   appendLine(progressFile, sessionLine);\n134: \n135:   const content = readFileSafe(progressFile);\n136:   const lines = content.split(\"\\n\").filter(Boolean);\n137:   if (lines.length > MAX_PROGRESS_LINES) {\n138:     writeFileSync(progressFile, trimToLines(content, MAX_PROGRESS_LINES));\n139:   }\n140: \n141:   logHook(\"UpdateContext\", \"info\", `context-progress.md updated for ${name}`);\n142: }\n143: \n144: await safeRun(\"UpdateContext\", main);\n\n(End of file - total 144 lines)\n</content>","metadata":{"preview":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\nimport { homedir } from \"os\";\nimport { join } from \"path\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n\nconst TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\nconst MAX_PROGRESS_LINES = 20;\nconst MAX_DISPLAY_FILES = 5;\nconst DB_PATH = getDbPath();\n\nfunction findTranscriptPath(\n  transcriptPath: string | undefined,\n  sessionId: string | undefined\n): string | null {\n  if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","text":"#!/usr/bin/env bun\nimport { existsSync, mkdirSync, readFileSync, readdirSync, writeFileSync } from \"fs\";\nimport { homedir } from \"os\";\nimport { join } from \"path\";\nimport { resolveProject, PROJECTS_DIR, CLAUDE_DIR, getDbPath } from \"../lib/resolveProject.js\";\nimport { readStdinPassthrough, parseHookInput, readFileSafe, appendLine, trimToLines, safeRun } from \"../lib/hookUtils.js\";\nimport { logHook, logEvent } from \"../lib/hookLogger.js\";\nimport { EVENTS } from \"../lib/eventNames.js\";\nimport { appendProgress, addDecision, addGotcha, emitEvent } from \"@rohirik/openltm-core\";\n\nconst TOOL_NAMES = new Set([\"Write\", \"Edit\", \"MultiEdit\"]);\nconst MAX_PROGRESS_LINES = 20;\nconst MAX_DISPLAY_FILES = 5;\nconst DB_PATH = getDbPath();\n\nfunction findTranscriptPath(\n  transcriptPath: string | undefined,\n  sessionId: string | undefined\n): string | null {\n  if (transcriptPath && existsSync(transcriptPath)) return transcriptPath;\n\n  const historyFile = join(CLAUDE_DIR, \"history.jsonl\");\n  if (!existsSync(historyFile)) return null;\n\n  const lines = readFileSync(historyFile, \"utf-8\").trim().split(\"\\n\");\n  let entry: Record<string, unknown> | null = null;\n\n  if (sessionId) {\n    for (let i = lines.length - 1; i >= 0; i--) {\n      try {\n        const parsed = JSON.parse(lines[i] ?? \"\") as Record<string, unknown>;\n        if (parsed.sessionId === sessionId) { entry = parsed; break; }\n      } catch {}\n    }\n  } else {\n    try { entry = JSON.parse(lines[lines.length - 1] ?? \"\") as Record<string, unknown>; } catch {}\n  }\n\n  if (!entry?.sessionId || !entry?.project) return null;\n\n  const filename = `${entry.sessionId}.jsonl`;\n  const { projectDir } = resolveProject(entry.project as string);\n  const primary = join(projectDir, filename);\n  if (existsSync(primary)) return primary;\n\n  try {\n    for (const dir of readdirSync(PROJECTS_DIR)) {\n      const candidate = join(PROJECTS_DIR, dir, filename);\n      if (existsSync(candidate)) return candidate;\n    }\n  } catch {}\n\n  return null;\n}\n\nfunction collectModifiedFiles(messages: Array<Record<string, unknown>>): Set<string> {\n  const files = new Set<string>();\n  for (const m of messages) {\n    const content = (m.message as Record<string, unknown> | undefined)?.content;\n    if (!Array.isArray(content)) continue;\n    for (const block of content as Array<Record<string, unknown>>) {\n      if (block.type === \"tool_use\" && TOOL_NAMES.has(block.name as string)) {\n        const input = block.input as Record<string, string> | undefined;\n        const p = input?.file_path || input?.path;\n        if (p) files.add(p);\n      }\n    }\n  }\n  return files;\n}\n\nfunction parseJsonLines(raw: string): Array<Record<string, unknown>> {\n  return raw.trim().split(\"\\n\")\n    .map(line => { try { return JSON.parse(line) as Record<string, unknown>; } catch { return null; } })\n    .filter(Boolean) as Array<Record<string, unknown>>;\n}\n\nasync function main(): Promise<void> {\n  const raw = await readStdinPassthrough();\n\n  const parsed = parseHookInput(raw);\n  if (!parsed) return;\n\n  const { input, cwd } = parsed;\n  const { name, projectDir } = resolveProject(cwd);\n  if (!existsSync(projectDir)) mkdirSync(projectDir, { recursive: true });\n\n  const tPath = findTranscriptPath(\n    input.transcript_path as string | undefined,\n    input.session_id as string | undefined\n  );\n  if (!tPath) return;\n\n  const messages = parseJsonLines(readFileSync(tPath, \"utf-8\"));\n  if (messages.length < 3) return;\n\n  const sessionTag = input.session_id ? (input.session_id as string).substring(0, 8) : null;\n  const today = new Date().toISOString().split(\"T\")[0];\n  const tagPart = sessionTag ? ` [${sessionTag}]` : \"\";\n\n  const filesModified = collectModifiedFiles(messages);\n  const sessionLine = filesModified.size > 0\n    ? `✓ [${today}]${tagPart} Modified: ${[...filesModified].slice(0, MAX_DISPLAY_FILES).map(f => f.replace(homedir(), \"~\")).join(\", \")}`\n    : `✓ [${today}]${tagPart} Session (read-only, ${messages.length} messages)`;\n\n  // Write to DB if available, fall back to .md file\n  if (existsSync(DB_PATH)) {\n    try {\n      const prefixMatch = sessionLine.match(/^\\[(decision|gotcha)\\]\\s*/i);\n      if (prefixMatch) {\n        const type = prefixMatch[1]!.toLowerCase() as \"decision\" | \"gotcha\";\n        const strippedContent = sessionLine.slice(prefixMatch[0].length);\n        if (type === \"decision\") addDecision(name, strippedContent);\n        else addGotcha(name, strippedContent);\n      } else {\n        appendProgress(name, sessionLine, sessionTag ?? undefined);\n      }\n      logHook(\"UpdateContext\", \"info\", `context DB updated for ${name}`);\n      logEvent(\"UpdateContext\", EVENTS.CONTEXT_UPDATED, { project: name });\n      emitEvent({ hook: \"UpdateContext\", event: EVENTS.CONTEXT_UPDATED, project: name, ts: new Date().toISOString() });\n      return;\n    } catch (dbErr) {\n      logHook(\"UpdateContext\", \"warn\", \"DB write failed, falling back to .md\", String(dbErr));\n      process.stderr.write(`[UpdateContext] DB write failed, falling back to .md: ${dbErr}\\n`);\n    }\n  }\n\n  // Fallback: write to markdown file\n  const progressFile = join(projectDir, \"context-progress.md\");\n  const existing = readFileSafe(progressFile);\n  if (sessionTag && existing.includes(sessionTag)) return;\n\n  appendLine(progressFile, sessionLine);\n\n  const content = readFileSafe(progressFile);\n  const lines = content.split(\"\\n\").filter(Boolean);\n  if (lines.length > MAX_PROGRESS_LINES) {\n    writeFileSync(progressFile, trimToLines(content, MAX_PROGRESS_LINES));\n  }\n\n  logHook(\"UpdateContext\", \"info\", `context-progress.md updated for ${name}`);\n}\n\nawait safeRun(\"UpdateContext\", main);","lineStart":1,"lineEnd":144,"totalLines":144,"truncated":false}},"title":"specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/UpdateContext.ts","time":{"start":1780928841165,"end":1780928841174}},"metadata":{"openai":{"itemId":"fc_0a4aba36200e6ec1016a26d14885c48191a3b835024c572be5"}},"id":"prt_ea7a18361001dxnJ64ZlBac0JS","sessionID":"ses_1586048c5ffertmP8HohyAZ8wd","messageID":"msg_ea7a16a6e001jG8AJh31A3WKyp"}}
