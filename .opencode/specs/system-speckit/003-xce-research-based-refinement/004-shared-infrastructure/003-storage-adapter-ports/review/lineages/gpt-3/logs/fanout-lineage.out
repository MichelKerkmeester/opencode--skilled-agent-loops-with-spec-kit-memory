{"type":"tool_use","timestamp":1781144230683,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_C5A5Bjosh8pKBLeY3taUdvRa","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts","offset":1,"limit":260},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts</path>\n<type>file</type>\n<content>\n1: // -------------------------------------------------------------------\n2: // MODULE: Storage Ports - Contention Policy\n3: // -------------------------------------------------------------------\n4: \n5: import type { Awaitable } from './common.js';\n6: import type Database from 'better-sqlite3';\n7: \n8: export interface ContentionRetryContext {\n9:   readonly attempt: number;\n10:   readonly delayMs: number;\n11:   readonly label?: string;\n12: }\n13: \n14: /** Retry policy for transient storage contention. */\n15: export interface ContentionRetryOptions {\n16:   readonly attempts?: number;\n17:   readonly delayMs?: number | (() => number);\n18:   readonly retryDelaysMs?: readonly number[];\n19:   readonly retryable?: (error: unknown) => boolean;\n20:   readonly sleep?: (ms: number) => Awaitable<void>;\n21:   readonly sleepSync?: (ms: number) => void;\n22:   readonly sync?: boolean;\n23:   readonly shouldAbort?: () => boolean;\n24:   readonly onRetry?: (error: unknown, context: ContentionRetryContext) => void;\n25: }\n26: \n27: /** Execution metadata for contention-managed operations. */\n28: export interface ContentionOperationOptions extends ContentionRetryOptions {\n29:   readonly label?: string;\n30: }\n31: \n32: export interface BusyTimeoutOptions {\n33:   readonly ignoreErrors?: boolean;\n34: }\n35: \n36: /** Options for the better-sqlite3 contention adapter. */\n37: export interface BetterSqliteContentionPolicyOptions {\n38:   readonly database?: Database.Database;\n39:   readonly retryable?: (error: unknown) => boolean;\n40:   readonly sleep?: (ms: number) => Awaitable<void>;\n41:   readonly sleepSync?: (ms: number) => void;\n42: }\n43: \n44: /** Port for retrying and serializing storage operations under contention. */\n45: export interface ContentionPolicy {\n46:   /** Run an operation through the configured contention retry policy. */\n47:   withRetry<T>(\n48:     operation: () => Awaitable<T>,\n49:     options?: ContentionOperationOptions,\n50:   ): Awaitable<T>;\n51: \n52:   /** Run an operation in an exclusive write section when the backend has one. */\n53:   withWriteLock<T>(\n54:     operation: () => Awaitable<T>,\n55:     options?: ContentionOperationOptions,\n56:   ): Awaitable<T>;\n57: \n58:   /** Apply a backend busy timeout when supported. */\n59:   setBusyTimeout(\n60:     database: Database.Database,\n61:     timeoutMs: number,\n62:     options?: BusyTimeoutOptions,\n63:   ): void;\n64: }\n65: \n66: /** better-sqlite3 implementation of contention retry and write-lock policy. */\n67: export class BetterSqliteContentionPolicy implements ContentionPolicy {\n68:   private readonly database: Database.Database | undefined;\n69:   private readonly retryable: (error: unknown) => boolean;\n70:   private readonly sleep: (ms: number) => Awaitable<void>;\n71:   private readonly sleepSync: (ms: number) => void;\n72: \n73:   constructor(options: BetterSqliteContentionPolicyOptions = {}) {\n74:     this.database = options.database;\n75:     this.retryable = options.retryable ?? isSqliteContentionError;\n76:     this.sleep = options.sleep ?? defaultSleep;\n77:     this.sleepSync = options.sleepSync ?? defaultSleepSync;\n78:   }\n79: \n80:   withRetry<T>(\n81:     operation: () => Awaitable<T>,\n82:     options: ContentionOperationOptions = {},\n83:   ): Awaitable<T> {\n84:     if (options.sync) {\n85:       return this.withRetrySync(operation as () => T, options);\n86:     }\n87:     return this.withRetryAsync(operation, options);\n88:   }\n89: \n90:   withWriteLock<T>(\n91:     operation: () => Awaitable<T>,\n92:     options: ContentionOperationOptions = {},\n93:   ): Awaitable<T> {\n94:     const database = this.database;\n95:     if (!database || database.inTransaction) {\n96:       return this.withRetry(operation, options);\n97:     }\n98: \n99:     return this.withRetry(() => runWithWriteLock(database, operation), options);\n100:   }\n101: \n102:   setBusyTimeout(\n103:     database: Database.Database,\n104:     timeoutMs: number,\n105:     options: BusyTimeoutOptions = {},\n106:   ): void {\n107:     try {\n108:       database.pragma(`busy_timeout = ${timeoutMs}`);\n109:     } catch (error: unknown) {\n110:       if (!options.ignoreErrors) {\n111:         throw error;\n112:       }\n113:     }\n114:   }\n115: \n116:   private async withRetryAsync<T>(\n117:     operation: () => Awaitable<T>,\n118:     options: ContentionOperationOptions,\n119:   ): Promise<T> {\n120:     const retryable = options.retryable ?? this.retryable;\n121:     const attempts = retryAttempts(options);\n122:     for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n123:       if (options.shouldAbort?.()) {\n124:         return undefined as T;\n125:       }\n126:       try {\n127:         return await operation();\n128:       } catch (error: unknown) {\n129:         const canRetry = retryable(error) && attemptIndex < attempts - 1;\n130:         if (!canRetry) {\n131:           throw error;\n132:         }\n133:         const delayMs = retryDelayMs(options, attemptIndex);\n134:         options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n135:         await (options.sleep ?? this.sleep)(delayMs);\n136:         if (options.shouldAbort?.()) {\n137:           return undefined as T;\n138:         }\n139:       }\n140:     }\n141:     throw new Error('BetterSqliteContentionPolicy.withRetry: unreachable');\n142:   }\n143: \n144:   private withRetrySync<T>(\n145:     operation: () => T,\n146:     options: ContentionOperationOptions,\n147:   ): T {\n148:     const retryable = options.retryable ?? this.retryable;\n149:     const attempts = retryAttempts(options);\n150:     for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n151:       if (options.shouldAbort?.()) {\n152:         return undefined as T;\n153:       }\n154:       try {\n155:         return operation();\n156:       } catch (error: unknown) {\n157:         const canRetry = retryable(error) && attemptIndex < attempts - 1;\n158:         if (!canRetry) {\n159:           throw error;\n160:         }\n161:         const delayMs = retryDelayMs(options, attemptIndex);\n162:         options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n163:         (options.sleepSync ?? this.sleepSync)(delayMs);\n164:         if (options.shouldAbort?.()) {\n165:           return undefined as T;\n166:         }\n167:       }\n168:     }\n169:     throw new Error('BetterSqliteContentionPolicy.withRetrySync: unreachable');\n170:   }\n171: }\n172: \n173: export function isSqliteContentionError(error: unknown): boolean {\n174:   const code = typeof error === 'object' && error !== null && 'code' in error\n175:     ? (error as { code?: unknown }).code\n176:     : undefined;\n177:   const message = error instanceof Error ? error.message : String(error);\n178:   return code === 'SQLITE_BUSY'\n179:     || code === 'SQLITE_LOCKED'\n180:     || /\\bSQLITE_BUSY\\b|\\bSQLITE_LOCKED\\b|database is locked/i.test(message);\n181: }\n182: \n183: function retryAttempts(options: ContentionOperationOptions): number {\n184:   const attempts = options.attempts ?? ((options.retryDelaysMs?.length ?? 0) + 1);\n185:   return Math.max(1, attempts);\n186: }\n187: \n188: function retryDelayMs(options: ContentionOperationOptions, attemptIndex: number): number {\n189:   const configuredDelay = options.retryDelaysMs?.[attemptIndex] ?? options.delayMs ?? 0;\n190:   const delay = typeof configuredDelay === 'function' ? configuredDelay() : configuredDelay;\n191:   return Math.max(0, delay);\n192: }\n193: \n194: function defaultSleep(ms: number): Promise<void> {\n195:   return new Promise((resolve) => setTimeout(resolve, ms));\n196: }\n197: \n198: function defaultSleepSync(ms: number): void {\n199:   Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);\n200: }\n201: \n202: function runWithWriteLock<T>(\n203:   database: Database.Database,\n204:   operation: () => Awaitable<T>,\n205: ): Awaitable<T> {\n206:   database.exec('BEGIN IMMEDIATE');\n207:   try {\n208:     const result = operation();\n209:     if (isPromiseLike(result)) {\n210:       return result.then(\n211:         (value) => {\n212:           database.exec('COMMIT');\n213:           return value;\n214:         },\n215:         (error: unknown) => {\n216:           rollbackQuietly(database);\n217:           throw error;\n218:         },\n219:       );\n220:     }\n221:     database.exec('COMMIT');\n222:     return result;\n223:   } catch (error: unknown) {\n224:     rollbackQuietly(database);\n225:     throw error;\n226:   }\n227: }\n228: \n229: function isPromiseLike<T>(value: Awaitable<T>): value is Promise<T> {\n230:   return typeof value === 'object'\n231:     && value !== null\n232:     && typeof (value as { then?: unknown }).then === 'function';\n233: }\n234: \n235: function rollbackQuietly(database: Database.Database): void {\n236:   try {\n237:     database.exec('ROLLBACK');\n238:   } catch {\n239:     // Ignore rollback errors after a failed write section.\n240:   }\n241: }\n\n(End of file - total 241 lines)\n</content>","metadata":{"preview":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Contention Policy\n// -------------------------------------------------------------------\n\nimport type { Awaitable } from './common.js';\nimport type Database from 'better-sqlite3';\n\nexport interface ContentionRetryContext {\n  readonly attempt: number;\n  readonly delayMs: number;\n  readonly label?: string;\n}\n\n/** Retry policy for transient storage contention. */\nexport interface ContentionRetryOptions {\n  readonly attempts?: number;\n  readonly delayMs?: number | (() => number);\n  readonly retryDelaysMs?: readonly number[];\n  readonly retryable?: (error: unknown) => boolean;\n  readonly sleep?: (ms: number) => Awaitable<void>;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts","text":"// -------------------------------------------------------------------\n// MODULE: Storage Ports - Contention Policy\n// -------------------------------------------------------------------\n\nimport type { Awaitable } from './common.js';\nimport type Database from 'better-sqlite3';\n\nexport interface ContentionRetryContext {\n  readonly attempt: number;\n  readonly delayMs: number;\n  readonly label?: string;\n}\n\n/** Retry policy for transient storage contention. */\nexport interface ContentionRetryOptions {\n  readonly attempts?: number;\n  readonly delayMs?: number | (() => number);\n  readonly retryDelaysMs?: readonly number[];\n  readonly retryable?: (error: unknown) => boolean;\n  readonly sleep?: (ms: number) => Awaitable<void>;\n  readonly sleepSync?: (ms: number) => void;\n  readonly sync?: boolean;\n  readonly shouldAbort?: () => boolean;\n  readonly onRetry?: (error: unknown, context: ContentionRetryContext) => void;\n}\n\n/** Execution metadata for contention-managed operations. */\nexport interface ContentionOperationOptions extends ContentionRetryOptions {\n  readonly label?: string;\n}\n\nexport interface BusyTimeoutOptions {\n  readonly ignoreErrors?: boolean;\n}\n\n/** Options for the better-sqlite3 contention adapter. */\nexport interface BetterSqliteContentionPolicyOptions {\n  readonly database?: Database.Database;\n  readonly retryable?: (error: unknown) => boolean;\n  readonly sleep?: (ms: number) => Awaitable<void>;\n  readonly sleepSync?: (ms: number) => void;\n}\n\n/** Port for retrying and serializing storage operations under contention. */\nexport interface ContentionPolicy {\n  /** Run an operation through the configured contention retry policy. */\n  withRetry<T>(\n    operation: () => Awaitable<T>,\n    options?: ContentionOperationOptions,\n  ): Awaitable<T>;\n\n  /** Run an operation in an exclusive write section when the backend has one. */\n  withWriteLock<T>(\n    operation: () => Awaitable<T>,\n    options?: ContentionOperationOptions,\n  ): Awaitable<T>;\n\n  /** Apply a backend busy timeout when supported. */\n  setBusyTimeout(\n    database: Database.Database,\n    timeoutMs: number,\n    options?: BusyTimeoutOptions,\n  ): void;\n}\n\n/** better-sqlite3 implementation of contention retry and write-lock policy. */\nexport class BetterSqliteContentionPolicy implements ContentionPolicy {\n  private readonly database: Database.Database | undefined;\n  private readonly retryable: (error: unknown) => boolean;\n  private readonly sleep: (ms: number) => Awaitable<void>;\n  private readonly sleepSync: (ms: number) => void;\n\n  constructor(options: BetterSqliteContentionPolicyOptions = {}) {\n    this.database = options.database;\n    this.retryable = options.retryable ?? isSqliteContentionError;\n    this.sleep = options.sleep ?? defaultSleep;\n    this.sleepSync = options.sleepSync ?? defaultSleepSync;\n  }\n\n  withRetry<T>(\n    operation: () => Awaitable<T>,\n    options: ContentionOperationOptions = {},\n  ): Awaitable<T> {\n    if (options.sync) {\n      return this.withRetrySync(operation as () => T, options);\n    }\n    return this.withRetryAsync(operation, options);\n  }\n\n  withWriteLock<T>(\n    operation: () => Awaitable<T>,\n    options: ContentionOperationOptions = {},\n  ): Awaitable<T> {\n    const database = this.database;\n    if (!database || database.inTransaction) {\n      return this.withRetry(operation, options);\n    }\n\n    return this.withRetry(() => runWithWriteLock(database, operation), options);\n  }\n\n  setBusyTimeout(\n    database: Database.Database,\n    timeoutMs: number,\n    options: BusyTimeoutOptions = {},\n  ): void {\n    try {\n      database.pragma(`busy_timeout = ${timeoutMs}`);\n    } catch (error: unknown) {\n      if (!options.ignoreErrors) {\n        throw error;\n      }\n    }\n  }\n\n  private async withRetryAsync<T>(\n    operation: () => Awaitable<T>,\n    options: ContentionOperationOptions,\n  ): Promise<T> {\n    const retryable = options.retryable ?? this.retryable;\n    const attempts = retryAttempts(options);\n    for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n      if (options.shouldAbort?.()) {\n        return undefined as T;\n      }\n      try {\n        return await operation();\n      } catch (error: unknown) {\n        const canRetry = retryable(error) && attemptIndex < attempts - 1;\n        if (!canRetry) {\n          throw error;\n        }\n        const delayMs = retryDelayMs(options, attemptIndex);\n        options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n        await (options.sleep ?? this.sleep)(delayMs);\n        if (options.shouldAbort?.()) {\n          return undefined as T;\n        }\n      }\n    }\n    throw new Error('BetterSqliteContentionPolicy.withRetry: unreachable');\n  }\n\n  private withRetrySync<T>(\n    operation: () => T,\n    options: ContentionOperationOptions,\n  ): T {\n    const retryable = options.retryable ?? this.retryable;\n    const attempts = retryAttempts(options);\n    for (let attemptIndex = 0; attemptIndex < attempts; attemptIndex += 1) {\n      if (options.shouldAbort?.()) {\n        return undefined as T;\n      }\n      try {\n        return operation();\n      } catch (error: unknown) {\n        const canRetry = retryable(error) && attemptIndex < attempts - 1;\n        if (!canRetry) {\n          throw error;\n        }\n        const delayMs = retryDelayMs(options, attemptIndex);\n        options.onRetry?.(error, { attempt: attemptIndex + 1, delayMs, label: options.label });\n        (options.sleepSync ?? this.sleepSync)(delayMs);\n        if (options.shouldAbort?.()) {\n          return undefined as T;\n        }\n      }\n    }\n    throw new Error('BetterSqliteContentionPolicy.withRetrySync: unreachable');\n  }\n}\n\nexport function isSqliteContentionError(error: unknown): boolean {\n  const code = typeof error === 'object' && error !== null && 'code' in error\n    ? (error as { code?: unknown }).code\n    : undefined;\n  const message = error instanceof Error ? error.message : String(error);\n  return code === 'SQLITE_BUSY'\n    || code === 'SQLITE_LOCKED'\n    || /\\bSQLITE_BUSY\\b|\\bSQLITE_LOCKED\\b|database is locked/i.test(message);\n}\n\nfunction retryAttempts(options: ContentionOperationOptions): number {\n  const attempts = options.attempts ?? ((options.retryDelaysMs?.length ?? 0) + 1);\n  return Math.max(1, attempts);\n}\n\nfunction retryDelayMs(options: ContentionOperationOptions, attemptIndex: number): number {\n  const configuredDelay = options.retryDelaysMs?.[attemptIndex] ?? options.delayMs ?? 0;\n  const delay = typeof configuredDelay === 'function' ? configuredDelay() : configuredDelay;\n  return Math.max(0, delay);\n}\n\nfunction defaultSleep(ms: number): Promise<void> {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nfunction defaultSleepSync(ms: number): void {\n  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);\n}\n\nfunction runWithWriteLock<T>(\n  database: Database.Database,\n  operation: () => Awaitable<T>,\n): Awaitable<T> {\n  database.exec('BEGIN IMMEDIATE');\n  try {\n    const result = operation();\n    if (isPromiseLike(result)) {\n      return result.then(\n        (value) => {\n          database.exec('COMMIT');\n          return value;\n        },\n        (error: unknown) => {\n          rollbackQuietly(database);\n          throw error;\n        },\n      );\n    }\n    database.exec('COMMIT');\n    return result;\n  } catch (error: unknown) {\n    rollbackQuietly(database);\n    throw error;\n  }\n}\n\nfunction isPromiseLike<T>(value: Awaitable<T>): value is Promise<T> {\n  return typeof value === 'object'\n    && value !== null\n    && typeof (value as { then?: unknown }).then === 'function';\n}\n\nfunction rollbackQuietly(database: Database.Database): void {\n  try {\n    database.exec('ROLLBACK');\n  } catch {\n    // Ignore rollback errors after a failed write section.\n  }\n}","lineStart":1,"lineEnd":241,"totalLines":241,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/ports/contention-policy.ts","time":{"start":1781144230676,"end":1781144230682}},"metadata":{"openai":{"itemId":"fc_0521a413005c0485016a2a1aa005608191bb23c6ce53c8fdca"}},"id":"prt_eb4781ad20017do3TcQ6066yP1","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb477b54d001fqqAxeR4o8s2PI"}}
