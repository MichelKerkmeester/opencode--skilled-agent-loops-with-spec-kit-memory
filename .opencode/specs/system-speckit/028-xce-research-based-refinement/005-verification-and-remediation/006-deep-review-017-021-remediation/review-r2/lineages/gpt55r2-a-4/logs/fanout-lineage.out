name) &&\n    canClassifyAsSpecDocument(normalizedPath)\n  ) {\n    return anchorId === CONTINUITY_ANCHOR_ID ? 'continuity' : 'spec_doc';\n  }\n\n  return null;\n}\n\nfunction filterCanonicalSourceRows<T extends SessionAwareResult>(\n  results: T[],\n): { results: T[]; stats: CanonicalSourceStats } {\n  const stats: CanonicalSourceStats = {\n    retained: 0,\n    dropped: 0,\n    bySourceKind: {\n      spec_doc: 0,\n      continuity: 0,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"  if (\n    basename.length > 0 &&\n    SPEC_DOCUMENT_FILENAMES.has(basename) &&\n    canClassifyAsSpecDocument(normalizedPath)\n  ) {\n    return anchorId === CONTINUITY_ANCHOR_ID ? 'continuity' : 'spec_doc';\n  }\n\n  return null;\n}\n\nfunction filterCanonicalSourceRows<T extends SessionAwareResult>(\n  results: T[],\n): { results: T[]; stats: CanonicalSourceStats } {\n  const stats: CanonicalSourceStats = {\n    retained: 0,\n    dropped: 0,\n    bySourceKind: {\n      spec_doc: 0,\n      continuity: 0,\n      constitutional: 0,\n    },\n  };\n\n  const filtered: T[] = [];\n  for (const result of results) {\n    const sourceKind = resolveCanonicalSourceKind(result);\n    if (!sourceKind) {\n      stats.dropped += 1;\n      continue;\n    }\n\n    filtered.push({\n      ...result,\n      canonicalSource: sourceKind,\n      canonicalSourceType: sourceKind,\n      documentType: sourceKind,\n    });\n    stats.retained += 1;\n    stats.bySourceKind[sourceKind] += 1;\n  }\n\n  return { results: filtered, stats };\n}\n","lineStart":260,"lineEnd":304,"totalLines":1788,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1781762022251,"end":1781762022256}},"metadata":{"openai":{"itemId":"fc_08e9ceb83c0d35f5016a3387e619208191a523803a8a07a0f3"}},"id":"prt_ed94adb24001EQHUlai