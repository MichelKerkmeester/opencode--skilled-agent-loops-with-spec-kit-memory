tats.success || 0,\n636:     total: stats.total || 0,\n637:     queue_size: (stats.pending || 0) + (stats.retry || 0),\n638:   };\n639: \n640:   refreshRetryHealthSnapshot(result);\n641:   return result;\n642: }\n643: \n644: /**\n645:  * Return a lightweight in-memory snapshot of embedding retry health.\n646:  * PULL accessor — synchronous, zero DB access, always safe to call.\n647:  * Returns zero-state when the retry manager has not yet been initialized.\n648:  */\n649: function getEmbeddingRetryStats(): EmbeddingRetryStats {\n650:   return {\n651:     pending: retryHealthSnapshot.pending,\n652:     failed: retryHealthSnapshot.failed,\n653:     retryAttempts: totalRetryAttempts,\n654:     circuitBreakerOpen: isProviderCircuitOpen(),\n655:     lastRun: lastBackgroundRunAt,\n656:     queueDepth: retryHealthSnapshot.queueDepth,\n657:   };\n658: }\n659: \n660: /* ───────────────────────────────────────────────────────────────\n661:    4. RETRY OPERATIONS\n662: ──────────────────────────────────────────────────────────────── */\n663: \n664: async function retryEmbedding(\n665:   id: number,\n666:   content: string,\n667:   claimedPreviousStatus: RetryQueueStatus | null = null,\n668: ): Promise<RetryResult> {\n669:   const db = vectorIndex.getDb();\n670:   if (!db) return { success: false, error: 'Database not initialized. Server may still be starting up.' };\n671: \n672:   const now = new Date().toISOString();\n673: \n674:   try {\n675:     const memory = vectorIndex.getMemory(id);\n676:     if (!memory) return { success: false, error: 'Memory not found' };\n677:     const previousStatus = claimedPreviousStatus ?? (\n678:       typeof memory.embedding_status === 'string'\n679:         ? memory.embedding_status\n\n(Showing lines 600-679 of 1141. Use offset=680 to continue.)\n</content>","metadata":{"preview":"  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning empty array.');\n    return [];\n  }\n\n  const rows = db.prepare(`\n    SELECT * FROM memory_index\n    WHERE embedding_status = 'failed'\n    ORDER BY updated_at DESC\n  `).all() as RetryMemoryRow[];\n\n  return rows.map(parseRow);\n}\n\nfunction getRetryStats(): RetryStats {\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning default stats.');\n    return { pending: 0, retry: 0, failed: 0, success: 0, total: 0, queue_size: 0 };\n  }","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","text":"  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning empty array.');\n    return [];\n  }\n\n  const rows = db.prepare(`\n    SELECT * FROM memory_index\n    WHERE embedding_status = 'failed'\n    ORDER BY updated_at DESC\n  `).all() as RetryMemoryRow[];\n\n  return rows.map(parseRow);\n}\n\nfunction getRetryStats(): RetryStats {\n  const db = vectorIndex.getDb();\n  if (!db) {\n    console.warn('[retry-manager] Database not initialized. Server may still be starting up. Returning default stats.');\n    return { pending: 0, retry: 0, failed: 0, success: 0, total: 0, queue_size: 0 };\n  }\n\n  const stats = db.prepare(`\n    SELECT\n      SUM(CASE WHEN embedding_status = 'pending' THEN 1 ELSE 0 END) as pending,\n      SUM(CASE WHEN embedding_status = 'retry' THEN 1 ELSE 0 END) as retry,\n      SUM(CASE WHEN embedding_status = 'failed' THEN 1 ELSE 0 END) as failed,\n      SUM(CASE WHEN embedding_status = 'success' THEN 1 ELSE 0 END) as success,\n      COUNT(*) as total\n    FROM memory_index\n  `).get() as Record<string, number>;\n\n  const result = {\n    pending: stats.pending || 0,\n    retry: stats.retry || 0,\n    failed: stats.failed || 0,\n    success: stats.success || 0,\n    total: stats.total || 0,\n    queue_size: (stats.pending || 0) + (stats.retry || 0),\n  };\n\n  refreshRetryHealthSnapshot(result);\n  return result;\n}\n\n/**\n * Return a lightweight in-memory snapshot of embedding retry health.\n * PULL accessor — synchronous, zero DB access, always safe to call.\n * Returns zero-state when the retry manager has not yet been initialized.\n */\nfunction getEmbeddingRetryStats(): EmbeddingRetryStats {\n  return {\n    pending: retryHealthSnapshot.pending,\n    failed: retryHealthSnapshot.failed,\n    retryAttempts: totalRetryAttempts,\n    circuitBreakerOpen: isProviderCircuitOpen(),\n    lastRun: lastBackgroundRunAt,\n    queueDepth: retryHealthSnapshot.queueDepth,\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. RETRY OPERATIONS\n──────────────────────────────────────────────────────────────── */\n\nasync function retryEmbedding(\n  id: number,\n  content: string,\n  claimedPreviousStatus: RetryQueueStatus | null = null,\n): Promise<RetryResult> {\n  const db = vectorIndex.getDb();\n  if (!db) return { success: false, error: 'Database not initialized. Server may still be starting up.' };\n\n  const now = new Date().toISOString();\n\n  try {\n    const memory = vectorIndex.getMemory(id);\n    if (!memory) return { success: false, error: 'Memory not found' };\n    const previousStatus = claimedPreviousStatus ?? (\n      typeof memory.embedding_status === 'string'\n        ? memory.embedding_status","lineStart":600,"lineEnd":679,"totalLines":1141,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/providers/retry-manager.ts","time":{"start":1781756863193,"end":1781756863197}},"metadata":{"openai":{"itemId":"fc_0e7ad4bc932114e6016a3373bed4c48191a861fedc9a2e46c2"}},"id":"prt_ed8fc2177001lf7imn6K23Cy2r","sessionID":"ses_1270761dbffecw7Dfym5Wp50VJ","messageID":"msg_ed8fbe586001N2CiNiwQXp5bRZ"}}
