{"type":"text","timestamp":1780738203001,"sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","part":{"id":"prt_e9c448ccb0011ESXvZh66pGB12","messageID":"msg_e9c447a920012243jrYknhM68d","sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","type":"text","text":"There are already automatic pieces to reuse: post-write invalidation, incremental scan lease/mtime/orphan cleanup, retention sweep audit/ledger, startup batch/shadow feedback scheduling, and prompt/session hooks. The gaps look like policy enforcement before/inside writes and new ledger/audit rows, not manual commands.","time":{"start":1780738198731,"end":1780738203000},"metadata":{"openai":{"itemId":"msg_0de447a7862df622016a23e896b48c8191b40c70336b937389","phase":"commentary"}}}}
{"type":"tool_use","timestamp":1780738203044,"sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","part":{"type":"tool","tool":"read","callID":"call_SZkUPo9S3wqn97coH8vVlzgE","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","offset":630,"limit":520},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts</path>\n<type>file</type>\n<content>\n630: \n631: /* ───────────────────────────────────────────────────────────────\n632:    10. MAIN HANDLER\n633: ──────────────────────────────────────────────────────────────── */\n634: \n635: /** Handle memory_search tool — performs hybrid vector/BM25 search with intent-aware ranking.\n636:  * @param args - Search arguments (query, concepts, mode, specFolder, etc.)\n637:  * @returns MCP response with ranked search results\n638:  */\n639: async function handleMemorySearch(args: SearchArgs): Promise<MCPResponse> {\n640:   await ensureMemoryRuntimeInitialized('handler:memory_search');\n641:   const _searchStartTime = Date.now();\n642:   resetLastLexicalCapabilitySnapshot();\n643:   // BUG-001: Check for external database updates before processing\n644:   await checkDatabaseUpdated();\n645: \n646:   const {\n647:     cursor,\n648:     query,\n649:     concepts,\n650:     specFolder,\n651:     folderBoost,\n652:     tenantId,\n653:     userId,\n654:     agentId,\n655:     limit: rawLimit = 10,\n656:     tier,\n657:     contextType,\n658:     useDecay: useDecay = true,\n659:     includeContiguity: includeContiguity = false,\n660:     includeConstitutional: includeConstitutional = true,\n661:     includeContent: includeContent = false,\n662:     anchors,\n663:     bypassCache: bypassCache = false,\n664:     sessionId: rawSessionId,\n665:     enableDedup: enableDedup = true,\n666:     intent: explicitIntent,\n667:     autoDetectIntent: autoDetectIntent = true,\n668:     minState,  // No default — memoryState column not yet in schema; defaulting to 'WARM' filters all rows\n669:     applyStateLimits: applyStateLimits = false,\n670:     rerank = true, // Enable reranking by default for better result quality\n671:     applyLengthPenalty: applyLengthPenalty = true,\n672:     trackAccess: trackAccess = false, // opt-in, off by default\n673:     includeArchived: includeArchivedRequested = false, // compatibility-only after Gate B cleanup\n674:     enableSessionBoost: enableSessionBoost = isSessionBoostEnabled(),\n675:     enableCausalBoost: enableCausalBoost = isCausalBoostEnabled(),\n676:     minQualityScore,\n677:     min_quality_score,\n678:     mode,\n679:     includeTrace: includeTraceArg = false,\n680:     sessionTransition,\n681:     profile,\n682:     retrievalLevel: retrievalLevel = 'auto',\n683:   } = args;\n684:   const includeTraceByFlag = process.env.SPECKIT_RESPONSE_TRACE === 'true';\n685:   const includeTrace = includeTraceByFlag || includeTraceArg === true;\n686:   const includeArchived = false;\n687: \n688:   // Validate any caller-supplied sessionId through the server-side session\n689:   // manager to prevent IDOR: a caller must not read or mutate another\n690:   // session's sent-memory dedup state by forging an arbitrary session id.\n691:   // Omitting sessionId stays unchanged (downstream treats it as no-session).\n692:   let sessionId: string | undefined = rawSessionId;\n693:   if (rawSessionId) {\n694:     const trustedSession = sessionManager.resolveTrustedSession(rawSessionId, {\n695:       tenantId,\n696:       userId,\n697:       agentId,\n698:     });\n699:     if (trustedSession.error) {\n700:       return createMCPErrorResponse({\n701:         tool: 'memory_search',\n702:         error: trustedSession.error,\n703:         code: 'E_SESSION_SCOPE',\n704:         details: { requestedSessionId: rawSessionId },\n705:         recovery: {\n706:           hint: 'Omit sessionId to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.',\n707:         },\n708:       });\n709:     }\n710:     sessionId = trustedSession.effectiveSessionId;\n711:   }\n712: \n713:   const normalizedScope = normalizeScopeContext({ tenantId, userId, agentId, sessionId });\n714:   const progressiveScopeKey = JSON.stringify({\n715:     tenantId: normalizedScope.tenantId ?? null,\n716:     userId: normalizedScope.userId ?? null,\n717:     agentId: normalizedScope.agentId ?? null,\n718:     sessionId: normalizedScope.sessionId ?? null,\n719:   });\n720: \n721:   // Validate at least one search input is provided (moved from schema superRefine for GPT compatibility)\n722:   const hasCursor = typeof cursor === 'string' && cursor.trim().length > 0;\n723:   const hasQuery = typeof query === 'string' && query.trim().length > 0;\n724:   const hasConcepts = Array.isArray(concepts) && concepts.length >= 2;\n725:   if (!hasCursor && !hasQuery && !hasConcepts) {\n726:     return { content: [{ type: 'text', text: JSON.stringify({ error: 'Either \"query\" (string), \"concepts\" (array with 2-5 items), or \"cursor\" (string) is required.' }) }] };\n727:   }\n728: \n729:   if (hasCursor) {\n730:     const resolved = resolveCursor(cursor.trim(), undefined, { scopeKey: progressiveScopeKey });\n731:     if (!resolved) {\n732:       return createMCPErrorResponse({\n733:         tool: 'memory_search',\n734:         error: 'Cursor is invalid, expired, or out of scope',\n735:         code: 'E_VALIDATION',\n736:         details: { parameter: 'cursor' },\n737:         recovery: {\n738:           hint: 'Retry the original search to generate a fresh continuation cursor',\n739:         },\n740:       });\n741:     }\n742: \n743:     const snippetResults = extractSnippets(resolved.results);\n744:     return createMCPSuccessResponse({\n745:       tool: 'memory_search',\n746:       summary: `Returned ${snippetResults.length} continuation results`,\n747:       data: {\n748:         count: snippetResults.length,\n749:         results: snippetResults,\n750:         continuation: resolved.continuation,\n751:       },\n752:       startTime: _searchStartTime,\n753:       cacheHit: false,\n754:     });\n755:   }\n756: \n757:   const qualityThreshold = resolveQualityThreshold(minQualityScore, min_quality_score);\n758: \n759:   // Validate numeric limit parameter\n760:   const limit = (typeof rawLimit === 'number' && Number.isFinite(rawLimit) && rawLimit > 0)\n761:     ? Math.min(Math.floor(rawLimit), 100)\n762:     : 10;\n763: \n764:   // BUG-007: Validate query first with proper error handling\n765:   let normalizedQuery: string | null = null;\n766:   if (query !== undefined) {\n767:     try {\n768:       normalizedQuery = validateQuery(query);\n769:     } catch (validationError: unknown) {\n770:       if (!concepts || !Array.isArray(concepts) || concepts.length < 2) {\n771:         const message = toErrorMessage(validationError);\n772:         return createMCPErrorResponse({\n773:           tool: 'memory_search',\n774:           error: message,\n775:           code: 'E_VALIDATION',\n776:           details: { parameter: 'query' },\n777:           recovery: {\n778:             hint: 'Provide a valid query string or use concepts array instead'\n779:           }\n780:         });\n781:       }\n782:       normalizedQuery = null;\n783:     }\n784:   }\n785: \n786:   const hasValidQuery = normalizedQuery !== null;\n787:   const hasValidConcepts = Array.isArray(concepts) && concepts.length >= 2;\n788:   const effectiveQuery = normalizedQuery ?? (hasValidConcepts ? concepts.join(', ') : '');\n789:   const searchDecisionRequestId = `memory_search-${_searchStartTime}`;\n790:   let searchDecisionEnvelope: SearchDecisionEnvelope | null = null;\n791: \n792:   if (!hasValidQuery && !hasValidConcepts) {\n793:     return createMCPErrorResponse({\n794:       tool: 'memory_search',\n795:       error: 'Either query (string), concepts (array of 2-5 strings), or cursor (string) is required',\n796:       code: 'E_VALIDATION',\n797:       details: { parameter: 'query' },\n798:       recovery: {\n799:         hint: 'Provide a query string, concepts array with 2-5 entries, or a continuation cursor'\n800:       }\n801:     });\n802:   }\n803: \n804:   if (specFolder !== undefined && typeof specFolder !== 'string') {\n805:     return createMCPErrorResponse({\n806:       tool: 'memory_search',\n807:       error: 'specFolder must be a string',\n808:       code: 'E_VALIDATION',\n809:       details: { parameter: 'specFolder' },\n810:       recovery: {\n811:         hint: 'Provide specFolder as a string path'\n812:       }\n813:     });\n814:   }\n815: \n816:   // Eval logger — capture query at pipeline entry (fail-safe)\n817:   let _evalQueryId = 0;\n818:   let _evalRunId = 0;\n819:   try {\n820:     const evalEntry = logSearchQuery({\n821:       query: effectiveQuery,\n822:       intent: explicitIntent ?? null,\n823:       specFolder: specFolder ?? null,\n824:     });\n825:     _evalQueryId = evalEntry.queryId;\n826:     _evalRunId = evalEntry.evalRunId;\n827:   } catch (_error: unknown) { /* eval logging must never break search */ }\n828: \n829:   const artifactRoutingQuery = resolveArtifactRoutingQuery(\n830:     normalizedQuery,\n831:     hasValidConcepts ? concepts : undefined\n832:   );\n833:   let artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder);\n834:   let queryPlan: QueryPlan;\n835:   try {\n836:     queryPlan = routeQuery(effectiveQuery).queryPlan;\n837:   } catch (_error: unknown) {\n838:     queryPlan = createEmptyQueryPlan({\n839:       complexity: 'unknown',\n840:       selectedChannels: ['vector', 'fts', 'bm25', 'graph', 'degree'],\n841:       fallbackPolicy: {\n842:         mode: 'telemetry_only',\n843:         reason: 'QueryPlan telemetry fallback after routeQuery failure',\n844:       },\n845:     });\n846:   }\n847: \n848:   // Intent-aware retrieval\n849:   let detectedIntent: string | null = null;\n850:   let intentConfidence = 0;\n851:   let intentWeights: IntentWeights | null = null;\n852: \n853:   if (explicitIntent) {\n854:     if (intentClassifier.isValidIntent(explicitIntent)) {\n855:       detectedIntent = explicitIntent;\n856:       intentConfidence = 1.0;\n857:       intentWeights = intentClassifier.getIntentWeights(explicitIntent);\n858:     } else {\n859:       console.warn(`[memory-search] Invalid intent '${explicitIntent}', using auto-detection`);\n860:     }\n861:   }\n862: \n863:   if (!detectedIntent && autoDetectIntent && hasValidQuery) {\n864:     const classification: IntentClassification = intentClassifier.classifyIntent(normalizedQuery!);\n865:     detectedIntent = classification.intent;\n866:     intentConfidence = classification.confidence;\n867:     intentWeights = intentClassifier.getIntentWeights(classification.intent as IntentType);\n868: \n869:     if (classification.fallback) {\n870:       console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (fallback: ${classification.reason})`);\n871:     } else {\n872:       console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (confidence: ${intentConfidence.toFixed(2)})`);\n873:     }\n874:   }\n875: \n876:   // FIX RC3-B: Intent confidence floor — override low-confidence auto-detections to \"understand\"\n877:   const INTENT_CONFIDENCE_FLOOR = parseFloat(process.env.SPECKIT_INTENT_CONFIDENCE_FLOOR || '0.25');\n878:   if (detectedIntent && intentConfidence < INTENT_CONFIDENCE_FLOOR && !explicitIntent) {\n879:     console.error(`[memory-search] Intent confidence ${intentConfidence.toFixed(3)} below floor ${INTENT_CONFIDENCE_FLOOR}, overriding '${detectedIntent}' → 'understand'`);\n880:     detectedIntent = 'understand';\n881:     intentConfidence = 1.0;\n882:     intentWeights = intentClassifier.getIntentWeights('understand' as IntentType);\n883:   }\n884: \n885:   // Phase C: Intent-to-profile auto-routing.\n886:   // Explicit caller `profile` always takes precedence; auto-detect fills in when absent.\n887:   let effectiveProfile: string | undefined = profile;\n888:   if (!effectiveProfile && detectedIntent && isIntentAutoProfileEnabled()) {\n889:     try {\n890:       const autoProfile = intentClassifier.getProfileForIntent(detectedIntent as IntentType);\n891:       if (autoProfile) {\n892:         effectiveProfile = autoProfile;\n893:         console.error(`[memory-search] Intent-to-profile auto-routing: '${detectedIntent}' → profile '${autoProfile}'`);\n894:       }\n895:     } catch (_autoProfileErr: unknown) {\n896:       // Auto-profile is best-effort — never breaks search\n897:     }\n898:   }\n899:   const adaptiveFusionIntent = effectiveProfile === 'resume'\n900:     ? 'continuity'\n901:     : detectedIntent;\n902: \n903:   // Re-run artifact routing with detected intent for fallback coverage\n904:   if (detectedIntent && artifactRouting?.detectedClass === 'unknown' && artifactRouting?.confidence === 0) {\n905:     artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder, detectedIntent);\n906:   }\n907: \n908:   // Create retrieval trace at pipeline entry\n909:   const trace = createTrace(\n910:     effectiveQuery,\n911:     sessionId,\n912:     detectedIntent || undefined\n913:   );\n914: \n915:   // When causal boost is enabled, fold the causal-edges generation\n916:   // counter into the cache key so causal-edge mutations naturally invalidate\n917:   // the affected memory_search entries on the next lookup. We deliberately\n918:   // keep the generation OFF the key when the caller has not opted into causal\n919:   // boost — otherwise unrelated callers would suffer needless cache misses.\n920:   const causalEdgesGenerationForCache = enableCausalBoost\n921:     ? causalEdges.getCausalEdgesGeneration()\n922:     : undefined;\n923: \n924:   // Build cache key args\n925:   const cacheArgs = buildCacheArgs({\n926:     normalizedQuery,\n927:     hasValidConcepts,\n928:     concepts,\n929:     specFolder,\n930:     tenantId: normalizedScope.tenantId,\n931:     userId: normalizedScope.userId,\n932:     agentId: normalizedScope.agentId,\n933:     limit,\n934:     mode,\n935:     tier,\n936:     contextType,\n937:     useDecay,\n938:     includeArchived,\n939:     qualityThreshold,\n940:     applyStateLimits,\n941:     includeContiguity,\n942:     includeConstitutional,\n943:     includeContent,\n944:     anchors,\n945:     detectedIntent,\n946:     adaptiveFusionIntent,\n947:     minState: minState ?? '',\n948:     rerank,\n949:     applyLengthPenalty,\n950:     sessionId,\n951:     enableSessionBoost,\n952:     enableCausalBoost,\n953:     includeTrace,\n954:     cacheVersion: CANONICAL_READER_CACHE_VERSION,\n955:     causalEdgesGeneration: causalEdgesGenerationForCache,\n956:   });\n957: \n958:   let _evalChannelPayloads: EvalChannelPayload[] = [];\n959:   const cacheKey = toolCache.generateCacheKey('memory_search', cacheArgs);\n960:   const cacheEnabled = toolCache.isEnabled() && !bypassCache;\n961:   const cachedPayload = cacheEnabled\n962:     ? toolCache.get<SearchCachePayload>(cacheKey)\n963:     : null;\n964: \n965:   let responseToReturn: MCPResponse;\n966:   let goalRefinementPayload: Record<string, unknown> | null = null;\n967: \n968:   if (cachedPayload) {\n969:     responseToReturn = buildSearchResponseFromPayload(cachedPayload, _searchStartTime, true);\n970:   } else {\n971:     // V2 pipeline is the only path (legacy V1 removed from the runtime pipeline)\n972:     const pipelineConfig: PipelineConfig = {\n973:       query: effectiveQuery,\n974:       concepts: hasValidConcepts ? concepts : undefined,\n975:       searchType: (hasValidConcepts && concepts!.length >= 2)\n976:         ? 'multi-concept'\n977:         : 'hybrid',\n978:       mode,\n979:       limit,\n980:       specFolder,\n981:       tenantId: normalizedScope.tenantId,\n982:       userId: normalizedScope.userId,\n983:       agentId: normalizedScope.agentId,\n984:       tier,\n985:       contextType,\n986:       includeArchived,\n987:       includeConstitutional,\n988:       includeContent,\n989:       anchors,\n990:       qualityThreshold,\n991:       minState: minState ?? '',\n992:       applyStateLimits,\n993:       useDecay,\n994:       rerank,\n995:       applyLengthPenalty,\n996:       sessionId,\n997:       enableDedup,\n998:       enableSessionBoost,\n999:       enableCausalBoost,\n1000:       trackAccess,\n1001:       detectedIntent,\n1002:       adaptiveFusionIntent,\n1003:       intentConfidence,\n1004:       intentWeights: toIntentWeightsConfig(intentWeights),\n1005:       artifactRouting: artifactRouting as unknown as PipelineConfig['artifactRouting'],\n1006:       queryPlan,\n1007:       trace,\n1008:     };\n1009: \n1010:     const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n1011:     let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n1012: \n1013:     // Community search fallback — inject community members on weak results\n1014:     let communityFallbackApplied = false;\n1015:     const shouldRunCommunitySearch = (\n1016:       isDualRetrievalEnabled() &&\n1017:       isCommunitySearchFallbackEnabled() &&\n1018:       effectiveQuery.length > 0 &&\n1019:       (retrievalLevel === 'global' || retrievalLevel === 'auto')\n1020:     );\n1021:     if (shouldRunCommunitySearch) {\n1022:       const isWeakResult = resultsForFormatting.length === 0 ||\n1023:         (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n1024:       if (isWeakResult) {\n1025:         try {\n1026:           const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n1027:           if (communityResults.totalMemberIds.length > 0) {\n1028:             // Fetch the actual memory rows for community member IDs\n1029:             const memberIds = communityResults.totalMemberIds.slice(0, 20);\n1030:             const placeholders = memberIds.map(() => '?').join(', ');\n1031:             const db = requireDb();\n1032:             const rawMemberRows = db.prepare(`\n1033:               SELECT id, title, similarity, content, file_path, anchor_id, document_type,\n1034:                      importance_tier, context_type, quality_score, created_at,\n1035:                      tenant_id, user_id, agent_id\n1036:               FROM memory_index\n1037:               WHERE id IN (${placeholders})\n1038:             `).all(...memberIds) as Array<Record<string, unknown> & { id: number }>;\n1039: \n1040:             // Apply governed retrieval scope to the community fallback so it cannot\n1041:             // bypass the tenant/user/agent boundary the canonical pipeline enforces.\n1042:             // sessionId is deliberately excluded — it is a dedup/continuity key, not\n1043:             // a row-access boundary. Unscoped (single-user) callers are unaffected.\n1044:             const hasGovernanceScope = Boolean(\n1045:               normalizedScope.tenantId || normalizedScope.userId || normalizedScope.agentId,\n1046:             );\n1047:             const memberRows = hasGovernanceScope\n1048:               ? filterRowsByScope(rawMemberRows, {\n1049:                   tenantId: normalizedScope.tenantId,\n1050:                   userId: normalizedScope.userId,\n1051:                   agentId: normalizedScope.agentId,\n1052:                 })\n1053:               : rawMemberRows;\n1054: \n1055:             if (memberRows.length > 0) {\n1056:               // Calibrate score from community match quality, bounded below pipeline threshold\n1057:               const communityScoreScale = 0.02; // aligns with pipeline's minimum quality floor\n1058:               const avgMatchScore = communityResults.results.length > 0\n1059:                 ? communityResults.results.reduce((sum, r) => sum + r.matchScore, 0) / communityResults.results.length\n1060:                 : 0.5;\n1061:               const calibratedScore = Math.max(0.001, avgMatchScore * communityScoreScale);\n1062:               // Mark community-sourced results and assign calibrated score\n1063:               const communityRows = memberRows.map((row) => ({\n1064:                 ...row,\n1065:                 similarity: typeof row.similarity === 'number' ? row.similarity : 0.5,\n1066:                 score: calibratedScore,\n1067:                 _communityFallback: true,\n1068:               }));\n1069:               // Merge: append community results not already in pipeline results\n1070:               const existingIds = new Set(resultsForFormatting.map((r) => (r as Record<string, unknown>).id as number));\n1071:               const newRows = communityRows.filter((r) => !existingIds.has(r.id));\n1072:               if (newRows.length > 0) {\n1073:                 resultsForFormatting = [...resultsForFormatting, ...newRows as unknown as SessionAwareResult[]];\n1074:                 communityFallbackApplied = true;\n1075:               }\n1076:             }\n1077:           }\n1078:         } catch (err: unknown) {\n1079:           const msg = err instanceof Error ? err.message : String(err);\n1080:           console.warn(`[memory-search] Community search fallback failed (fail-open): ${msg}`);\n1081:         }\n1082:       }\n1083:     }\n1084: \n1085:     // Apply folder boost — multiply similarity for results matching discovered folder\n1086:     if (folderBoost && folderBoost.folder && folderBoost.factor > 1) {\n1087:       let boostedCount = 0;\n1088:       for (const r of resultsForFormatting) {\n1089:         const filePath = (r as Record<string, unknown>).file_path as string | undefined;\n1090:         if (filePath && filePath.includes(folderBoost.folder)) {\n1091:           const raw = (r as Record<string, unknown>);\n1092:           if (typeof raw.similarity === 'number') {\n1093:             raw.similarity = Math.min(raw.similarity * folderBoost.factor, 1.0);\n1094:             boostedCount++;\n1095:           }\n1096:         }\n1097:       }\n1098:       // Re-sort by similarity after boosting\n1099:       if (boostedCount > 0) {\n1100:         resultsForFormatting.sort((a, b) => {\n1101:           const sa = (a as Record<string, unknown>).similarity as number ?? 0;\n1102:           const sb = (b as Record<string, unknown>).similarity as number ?? 0;\n1103:           return sb - sa;\n1104:         });\n1105:       }\n1106:     }\n1107: \n1108:     // Eval channel attribution should reflect the retrieval pipeline output\n1109:     // before canonical source filtering drops rows for response formatting.\n1110:     _evalChannelPayloads = buildEvalChannelPayloads(\n1111:       pipelineResult.results as unknown as Array<Record<string, unknown>>,\n1112:     );\n1113: \n1114:     const canonicalFilter = filterCanonicalSourceRows(resultsForFormatting);\n1115:     resultsForFormatting = canonicalFilter.results;\n1116:     const avgScore = computeAverageScore(resultsForFormatting as Array<Record<string, unknown>>);\n1117:     const requestQualityLabel = pipelineResult.metadata.stage4.evidenceGapDetected ? 'gap' : 'weak';\n1118:     const qualityGapRouting = routeQuery(effectiveQuery, undefined, {\n1119:       quality: requestQualityLabel,\n1120:       avgScore,\n1121:     });\n1122:     const qualityFallback = qualityGapRouting.qualityFallback;\n1123:     if (qualityFallback.engaged) {\n1124:       queryPlan = qualityGapRouting.queryPlan;\n1125:     }\n1126: \n1127:     if (sessionId && isSessionRetrievalStateEnabled()) {\n1128:       const activeGoal = effectiveQuery.trim().length > 0 ? effectiveQuery : null;\n1129:       if (activeGoal) {\n1130:         retrievalSessionStateManager.updateGoal(sessionId, activeGoal);\n1131:       }\n1132:       if (Array.isArray(anchors) && anchors.length > 0) {\n1133:         retrievalSessionStateManager.setAnchors(sessionId, anchors);\n1134:       }\n1135: \n1136:       const goalRefinement = refineForGoal(resultsForFormatting, sessionId);\n1137:       resultsForFormatting = goalRefinement.results as SessionAwareResult[];\n1138:       goalRefinementPayload = {\n1139:         activeGoal: goalRefinement.metadata.activeGoal,\n1140:         applied: goalRefinement.metadata.refined,\n1141:         boostedCount: goalRefinement.metadata.boostedCount,\n1142:       };\n1143:     }\n1144: \n1145:     // Build extra data from pipeline metadata for response formatting\n1146:     const lexicalCapability = getLastLexicalCapabilitySnapshot();\n1147:     if (lexicalCapability) {\n1148:       console.error(\n1149:         `[memory-search] Lexical capability path '${lexicalCapability.lexicalPath}' (fallbackState: ${lexicalCapability.fallbackState})`\n\n(Showing lines 630-1149 of 1657. Use offset=1150 to continue.)\n</content>","metadata":{"preview":"\n/* ───────────────────────────────────────────────────────────────\n   10. MAIN HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_search tool — performs hybrid vector/BM25 search with intent-aware ranking.\n * @param args - Search arguments (query, concepts, mode, specFolder, etc.)\n * @returns MCP response with ranked search results\n */\nasync function handleMemorySearch(args: SearchArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_search');\n  const _searchStartTime = Date.now();\n  resetLastLexicalCapabilitySnapshot();\n  // BUG-001: Check for external database updates before processing\n  await checkDatabaseUpdated();\n\n  const {\n    cursor,\n    query,\n    concepts,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","text":"\n/* ───────────────────────────────────────────────────────────────\n   10. MAIN HANDLER\n──────────────────────────────────────────────────────────────── */\n\n/** Handle memory_search tool — performs hybrid vector/BM25 search with intent-aware ranking.\n * @param args - Search arguments (query, concepts, mode, specFolder, etc.)\n * @returns MCP response with ranked search results\n */\nasync function handleMemorySearch(args: SearchArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_search');\n  const _searchStartTime = Date.now();\n  resetLastLexicalCapabilitySnapshot();\n  // BUG-001: Check for external database updates before processing\n  await checkDatabaseUpdated();\n\n  const {\n    cursor,\n    query,\n    concepts,\n    specFolder,\n    folderBoost,\n    tenantId,\n    userId,\n    agentId,\n    limit: rawLimit = 10,\n    tier,\n    contextType,\n    useDecay: useDecay = true,\n    includeContiguity: includeContiguity = false,\n    includeConstitutional: includeConstitutional = true,\n    includeContent: includeContent = false,\n    anchors,\n    bypassCache: bypassCache = false,\n    sessionId: rawSessionId,\n    enableDedup: enableDedup = true,\n    intent: explicitIntent,\n    autoDetectIntent: autoDetectIntent = true,\n    minState,  // No default — memoryState column not yet in schema; defaulting to 'WARM' filters all rows\n    applyStateLimits: applyStateLimits = false,\n    rerank = true, // Enable reranking by default for better result quality\n    applyLengthPenalty: applyLengthPenalty = true,\n    trackAccess: trackAccess = false, // opt-in, off by default\n    includeArchived: includeArchivedRequested = false, // compatibility-only after Gate B cleanup\n    enableSessionBoost: enableSessionBoost = isSessionBoostEnabled(),\n    enableCausalBoost: enableCausalBoost = isCausalBoostEnabled(),\n    minQualityScore,\n    min_quality_score,\n    mode,\n    includeTrace: includeTraceArg = false,\n    sessionTransition,\n    profile,\n    retrievalLevel: retrievalLevel = 'auto',\n  } = args;\n  const includeTraceByFlag = process.env.SPECKIT_RESPONSE_TRACE === 'true';\n  const includeTrace = includeTraceByFlag || includeTraceArg === true;\n  const includeArchived = false;\n\n  // Validate any caller-supplied sessionId through the server-side session\n  // manager to prevent IDOR: a caller must not read or mutate another\n  // session's sent-memory dedup state by forging an arbitrary session id.\n  // Omitting sessionId stays unchanged (downstream treats it as no-session).\n  let sessionId: string | undefined = rawSessionId;\n  if (rawSessionId) {\n    const trustedSession = sessionManager.resolveTrustedSession(rawSessionId, {\n      tenantId,\n      userId,\n      agentId,\n    });\n    if (trustedSession.error) {\n      return createMCPErrorResponse({\n        tool: 'memory_search',\n        error: trustedSession.error,\n        code: 'E_SESSION_SCOPE',\n        details: { requestedSessionId: rawSessionId },\n        recovery: {\n          hint: 'Omit sessionId to start a new server-generated session, or reuse the effectiveSessionId returned by memory_context.',\n        },\n      });\n    }\n    sessionId = trustedSession.effectiveSessionId;\n  }\n\n  const normalizedScope = normalizeScopeContext({ tenantId, userId, agentId, sessionId });\n  const progressiveScopeKey = JSON.stringify({\n    tenantId: normalizedScope.tenantId ?? null,\n    userId: normalizedScope.userId ?? null,\n    agentId: normalizedScope.agentId ?? null,\n    sessionId: normalizedScope.sessionId ?? null,\n  });\n\n  // Validate at least one search input is provided (moved from schema superRefine for GPT compatibility)\n  const hasCursor = typeof cursor === 'string' && cursor.trim().length > 0;\n  const hasQuery = typeof query === 'string' && query.trim().length > 0;\n  const hasConcepts = Array.isArray(concepts) && concepts.length >= 2;\n  if (!hasCursor && !hasQuery && !hasConcepts) {\n    return { content: [{ type: 'text', text: JSON.stringify({ error: 'Either \"query\" (string), \"concepts\" (array with 2-5 items), or \"cursor\" (string) is required.' }) }] };\n  }\n\n  if (hasCursor) {\n    const resolved = resolveCursor(cursor.trim(), undefined, { scopeKey: progressiveScopeKey });\n    if (!resolved) {\n      return createMCPErrorResponse({\n        tool: 'memory_search',\n        error: 'Cursor is invalid, expired, or out of scope',\n        code: 'E_VALIDATION',\n        details: { parameter: 'cursor' },\n        recovery: {\n          hint: 'Retry the original search to generate a fresh continuation cursor',\n        },\n      });\n    }\n\n    const snippetResults = extractSnippets(resolved.results);\n    return createMCPSuccessResponse({\n      tool: 'memory_search',\n      summary: `Returned ${snippetResults.length} continuation results`,\n      data: {\n        count: snippetResults.length,\n        results: snippetResults,\n        continuation: resolved.continuation,\n      },\n      startTime: _searchStartTime,\n      cacheHit: false,\n    });\n  }\n\n  const qualityThreshold = resolveQualityThreshold(minQualityScore, min_quality_score);\n\n  // Validate numeric limit parameter\n  const limit = (typeof rawLimit === 'number' && Number.isFinite(rawLimit) && rawLimit > 0)\n    ? Math.min(Math.floor(rawLimit), 100)\n    : 10;\n\n  // BUG-007: Validate query first with proper error handling\n  let normalizedQuery: string | null = null;\n  if (query !== undefined) {\n    try {\n      normalizedQuery = validateQuery(query);\n    } catch (validationError: unknown) {\n      if (!concepts || !Array.isArray(concepts) || concepts.length < 2) {\n        const message = toErrorMessage(validationError);\n        return createMCPErrorResponse({\n          tool: 'memory_search',\n          error: message,\n          code: 'E_VALIDATION',\n          details: { parameter: 'query' },\n          recovery: {\n            hint: 'Provide a valid query string or use concepts array instead'\n          }\n        });\n      }\n      normalizedQuery = null;\n    }\n  }\n\n  const hasValidQuery = normalizedQuery !== null;\n  const hasValidConcepts = Array.isArray(concepts) && concepts.length >= 2;\n  const effectiveQuery = normalizedQuery ?? (hasValidConcepts ? concepts.join(', ') : '');\n  const searchDecisionRequestId = `memory_search-${_searchStartTime}`;\n  let searchDecisionEnvelope: SearchDecisionEnvelope | null = null;\n\n  if (!hasValidQuery && !hasValidConcepts) {\n    return createMCPErrorResponse({\n      tool: 'memory_search',\n      error: 'Either query (string), concepts (array of 2-5 strings), or cursor (string) is required',\n      code: 'E_VALIDATION',\n      details: { parameter: 'query' },\n      recovery: {\n        hint: 'Provide a query string, concepts array with 2-5 entries, or a continuation cursor'\n      }\n    });\n  }\n\n  if (specFolder !== undefined && typeof specFolder !== 'string') {\n    return createMCPErrorResponse({\n      tool: 'memory_search',\n      error: 'specFolder must be a string',\n      code: 'E_VALIDATION',\n      details: { parameter: 'specFolder' },\n      recovery: {\n        hint: 'Provide specFolder as a string path'\n      }\n    });\n  }\n\n  // Eval logger — capture query at pipeline entry (fail-safe)\n  let _evalQueryId = 0;\n  let _evalRunId = 0;\n  try {\n    const evalEntry = logSearchQuery({\n      query: effectiveQuery,\n      intent: explicitIntent ?? null,\n      specFolder: specFolder ?? null,\n    });\n    _evalQueryId = evalEntry.queryId;\n    _evalRunId = evalEntry.evalRunId;\n  } catch (_error: unknown) { /* eval logging must never break search */ }\n\n  const artifactRoutingQuery = resolveArtifactRoutingQuery(\n    normalizedQuery,\n    hasValidConcepts ? concepts : undefined\n  );\n  let artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder);\n  let queryPlan: QueryPlan;\n  try {\n    queryPlan = routeQuery(effectiveQuery).queryPlan;\n  } catch (_error: unknown) {\n    queryPlan = createEmptyQueryPlan({\n      complexity: 'unknown',\n      selectedChannels: ['vector', 'fts', 'bm25', 'graph', 'degree'],\n      fallbackPolicy: {\n        mode: 'telemetry_only',\n        reason: 'QueryPlan telemetry fallback after routeQuery failure',\n      },\n    });\n  }\n\n  // Intent-aware retrieval\n  let detectedIntent: string | null = null;\n  let intentConfidence = 0;\n  let intentWeights: IntentWeights | null = null;\n\n  if (explicitIntent) {\n    if (intentClassifier.isValidIntent(explicitIntent)) {\n      detectedIntent = explicitIntent;\n      intentConfidence = 1.0;\n      intentWeights = intentClassifier.getIntentWeights(explicitIntent);\n    } else {\n      console.warn(`[memory-search] Invalid intent '${explicitIntent}', using auto-detection`);\n    }\n  }\n\n  if (!detectedIntent && autoDetectIntent && hasValidQuery) {\n    const classification: IntentClassification = intentClassifier.classifyIntent(normalizedQuery!);\n    detectedIntent = classification.intent;\n    intentConfidence = classification.confidence;\n    intentWeights = intentClassifier.getIntentWeights(classification.intent as IntentType);\n\n    if (classification.fallback) {\n      console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (fallback: ${classification.reason})`);\n    } else {\n      console.error(`[memory-search] Intent auto-detected as '${detectedIntent}' (confidence: ${intentConfidence.toFixed(2)})`);\n    }\n  }\n\n  // FIX RC3-B: Intent confidence floor — override low-confidence auto-detections to \"understand\"\n  const INTENT_CONFIDENCE_FLOOR = parseFloat(process.env.SPECKIT_INTENT_CONFIDENCE_FLOOR || '0.25');\n  if (detectedIntent && intentConfidence < INTENT_CONFIDENCE_FLOOR && !explicitIntent) {\n    console.error(`[memory-search] Intent confidence ${intentConfidence.toFixed(3)} below floor ${INTENT_CONFIDENCE_FLOOR}, overriding '${detectedIntent}' → 'understand'`);\n    detectedIntent = 'understand';\n    intentConfidence = 1.0;\n    intentWeights = intentClassifier.getIntentWeights('understand' as IntentType);\n  }\n\n  // Phase C: Intent-to-profile auto-routing.\n  // Explicit caller `profile` always takes precedence; auto-detect fills in when absent.\n  let effectiveProfile: string | undefined = profile;\n  if (!effectiveProfile && detectedIntent && isIntentAutoProfileEnabled()) {\n    try {\n      const autoProfile = intentClassifier.getProfileForIntent(detectedIntent as IntentType);\n      if (autoProfile) {\n        effectiveProfile = autoProfile;\n        console.error(`[memory-search] Intent-to-profile auto-routing: '${detectedIntent}' → profile '${autoProfile}'`);\n      }\n    } catch (_autoProfileErr: unknown) {\n      // Auto-profile is best-effort — never breaks search\n    }\n  }\n  const adaptiveFusionIntent = effectiveProfile === 'resume'\n    ? 'continuity'\n    : detectedIntent;\n\n  // Re-run artifact routing with detected intent for fallback coverage\n  if (detectedIntent && artifactRouting?.detectedClass === 'unknown' && artifactRouting?.confidence === 0) {\n    artifactRouting = getStrategyForQuery(artifactRoutingQuery, specFolder, detectedIntent);\n  }\n\n  // Create retrieval trace at pipeline entry\n  const trace = createTrace(\n    effectiveQuery,\n    sessionId,\n    detectedIntent || undefined\n  );\n\n  // When causal boost is enabled, fold the causal-edges generation\n  // counter into the cache key so causal-edge mutations naturally invalidate\n  // the affected memory_search entries on the next lookup. We deliberately\n  // keep the generation OFF the key when the caller has not opted into causal\n  // boost — otherwise unrelated callers would suffer needless cache misses.\n  const causalEdgesGenerationForCache = enableCausalBoost\n    ? causalEdges.getCausalEdgesGeneration()\n    : undefined;\n\n  // Build cache key args\n  const cacheArgs = buildCacheArgs({\n    normalizedQuery,\n    hasValidConcepts,\n    concepts,\n    specFolder,\n    tenantId: normalizedScope.tenantId,\n    userId: normalizedScope.userId,\n    agentId: normalizedScope.agentId,\n    limit,\n    mode,\n    tier,\n    contextType,\n    useDecay,\n    includeArchived,\n    qualityThreshold,\n    applyStateLimits,\n    includeContiguity,\n    includeConstitutional,\n    includeContent,\n    anchors,\n    detectedIntent,\n    adaptiveFusionIntent,\n    minState: minState ?? '',\n    rerank,\n    applyLengthPenalty,\n    sessionId,\n    enableSessionBoost,\n    enableCausalBoost,\n    includeTrace,\n    cacheVersion: CANONICAL_READER_CACHE_VERSION,\n    causalEdgesGeneration: causalEdgesGenerationForCache,\n  });\n\n  let _evalChannelPayloads: EvalChannelPayload[] = [];\n  const cacheKey = toolCache.generateCacheKey('memory_search', cacheArgs);\n  const cacheEnabled = toolCache.isEnabled() && !bypassCache;\n  const cachedPayload = cacheEnabled\n    ? toolCache.get<SearchCachePayload>(cacheKey)\n    : null;\n\n  let responseToReturn: MCPResponse;\n  let goalRefinementPayload: Record<string, unknown> | null = null;\n\n  if (cachedPayload) {\n    responseToReturn = buildSearchResponseFromPayload(cachedPayload, _searchStartTime, true);\n  } else {\n    // V2 pipeline is the only path (legacy V1 removed from the runtime pipeline)\n    const pipelineConfig: PipelineConfig = {\n      query: effectiveQuery,\n      concepts: hasValidConcepts ? concepts : undefined,\n      searchType: (hasValidConcepts && concepts!.length >= 2)\n        ? 'multi-concept'\n        : 'hybrid',\n      mode,\n      limit,\n      specFolder,\n      tenantId: normalizedScope.tenantId,\n      userId: normalizedScope.userId,\n      agentId: normalizedScope.agentId,\n      tier,\n      contextType,\n      includeArchived,\n      includeConstitutional,\n      includeContent,\n      anchors,\n      qualityThreshold,\n      minState: minState ?? '',\n      applyStateLimits,\n      useDecay,\n      rerank,\n      applyLengthPenalty,\n      sessionId,\n      enableDedup,\n      enableSessionBoost,\n      enableCausalBoost,\n      trackAccess,\n      detectedIntent,\n      adaptiveFusionIntent,\n      intentConfidence,\n      intentWeights: toIntentWeightsConfig(intentWeights),\n      artifactRouting: artifactRouting as unknown as PipelineConfig['artifactRouting'],\n      queryPlan,\n      trace,\n    };\n\n    const pipelineResult: PipelineResult = await executePipeline(pipelineConfig);\n    let resultsForFormatting = pipelineResult.results as unknown as SessionAwareResult[];\n\n    // Community search fallback — inject community members on weak results\n    let communityFallbackApplied = false;\n    const shouldRunCommunitySearch = (\n      isDualRetrievalEnabled() &&\n      isCommunitySearchFallbackEnabled() &&\n      effectiveQuery.length > 0 &&\n      (retrievalLevel === 'global' || retrievalLevel === 'auto')\n    );\n    if (shouldRunCommunitySearch) {\n      const isWeakResult = resultsForFormatting.length === 0 ||\n        (resultsForFormatting.length < 3 && (retrievalLevel === 'global' || retrievalLevel === 'auto'));\n      if (isWeakResult) {\n        try {\n          const communityResults = searchCommunities(effectiveQuery, requireDb(), 5);\n          if (communityResults.totalMemberIds.length > 0) {\n            // Fetch the actual memory rows for community member IDs\n            const memberIds = communityResults.totalMemberIds.slice(0, 20);\n            const placeholders = memberIds.map(() => '?').join(', ');\n            const db = requireDb();\n            const rawMemberRows = db.prepare(`\n              SELECT id, title, similarity, content, file_path, anchor_id, document_type,\n                     importance_tier, context_type, quality_score, created_at,\n                     tenant_id, user_id, agent_id\n              FROM memory_index\n              WHERE id IN (${placeholders})\n            `).all(...memberIds) as Array<Record<string, unknown> & { id: number }>;\n\n            // Apply governed retrieval scope to the community fallback so it cannot\n            // bypass the tenant/user/agent boundary the canonical pipeline enforces.\n            // sessionId is deliberately excluded — it is a dedup/continuity key, not\n            // a row-access boundary. Unscoped (single-user) callers are unaffected.\n            const hasGovernanceScope = Boolean(\n              normalizedScope.tenantId || normalizedScope.userId || normalizedScope.agentId,\n            );\n            const memberRows = hasGovernanceScope\n              ? filterRowsByScope(rawMemberRows, {\n                  tenantId: normalizedScope.tenantId,\n                  userId: normalizedScope.userId,\n                  agentId: normalizedScope.agentId,\n                })\n              : rawMemberRows;\n\n            if (memberRows.length > 0) {\n              // Calibrate score from community match quality, bounded below pipeline threshold\n              const communityScoreScale = 0.02; // aligns with pipeline's minimum quality floor\n              const avgMatchScore = communityResults.results.length > 0\n                ? communityResults.results.reduce((sum, r) => sum + r.matchScore, 0) / communityResults.results.length\n                : 0.5;\n              const calibratedScore = Math.max(0.001, avgMatchScore * communityScoreScale);\n              // Mark community-sourced results and assign calibrated score\n              const communityRows = memberRows.map((row) => ({\n                ...row,\n                similarity: typeof row.similarity === 'number' ? row.similarity : 0.5,\n                score: calibratedScore,\n                _communityFallback: true,\n              }));\n              // Merge: append community results not already in pipeline results\n              const existingIds = new Set(resultsForFormatting.map((r) => (r as Record<string, unknown>).id as number));\n              const newRows = communityRows.filter((r) => !existingIds.has(r.id));\n              if (newRows.length > 0) {\n                resultsForFormatting = [...resultsForFormatting, ...newRows as unknown as SessionAwareResult[]];\n                communityFallbackApplied = true;\n              }\n            }\n          }\n        } catch (err: unknown) {\n          const msg = err instanceof Error ? err.message : String(err);\n          console.warn(`[memory-search] Community search fallback failed (fail-open): ${msg}`);\n        }\n      }\n    }\n\n    // Apply folder boost — multiply similarity for results matching discovered folder\n    if (folderBoost && folderBoost.folder && folderBoost.factor > 1) {\n      let boostedCount = 0;\n      for (const r of resultsForFormatting) {\n        const filePath = (r as Record<string, unknown>).file_path as string | undefined;\n        if (filePath && filePath.includes(folderBoost.folder)) {\n          const raw = (r as Record<string, unknown>);\n          if (typeof raw.similarity === 'number') {\n            raw.similarity = Math.min(raw.similarity * folderBoost.factor, 1.0);\n            boostedCount++;\n          }\n        }\n      }\n      // Re-sort by similarity after boosting\n      if (boostedCount > 0) {\n        resultsForFormatting.sort((a, b) => {\n          const sa = (a as Record<string, unknown>).similarity as number ?? 0;\n          const sb = (b as Record<string, unknown>).similarity as number ?? 0;\n          return sb - sa;\n        });\n      }\n    }\n\n    // Eval channel attribution should reflect the retrieval pipeline output\n    // before canonical source filtering drops rows for response formatting.\n    _evalChannelPayloads = buildEvalChannelPayloads(\n      pipelineResult.results as unknown as Array<Record<string, unknown>>,\n    );\n\n    const canonicalFilter = filterCanonicalSourceRows(resultsForFormatting);\n    resultsForFormatting = canonicalFilter.results;\n    const avgScore = computeAverageScore(resultsForFormatting as Array<Record<string, unknown>>);\n    const requestQualityLabel = pipelineResult.metadata.stage4.evidenceGapDetected ? 'gap' : 'weak';\n    const qualityGapRouting = routeQuery(effectiveQuery, undefined, {\n      quality: requestQualityLabel,\n      avgScore,\n    });\n    const qualityFallback = qualityGapRouting.qualityFallback;\n    if (qualityFallback.engaged) {\n      queryPlan = qualityGapRouting.queryPlan;\n    }\n\n    if (sessionId && isSessionRetrievalStateEnabled()) {\n      const activeGoal = effectiveQuery.trim().length > 0 ? effectiveQuery : null;\n      if (activeGoal) {\n        retrievalSessionStateManager.updateGoal(sessionId, activeGoal);\n      }\n      if (Array.isArray(anchors) && anchors.length > 0) {\n        retrievalSessionStateManager.setAnchors(sessionId, anchors);\n      }\n\n      const goalRefinement = refineForGoal(resultsForFormatting, sessionId);\n      resultsForFormatting = goalRefinement.results as SessionAwareResult[];\n      goalRefinementPayload = {\n        activeGoal: goalRefinement.metadata.activeGoal,\n        applied: goalRefinement.metadata.refined,\n        boostedCount: goalRefinement.metadata.boostedCount,\n      };\n    }\n\n    // Build extra data from pipeline metadata for response formatting\n    const lexicalCapability = getLastLexicalCapabilitySnapshot();\n    if (lexicalCapability) {\n      console.error(\n        `[memory-search] Lexical capability path '${lexicalCapability.lexicalPath}' (fallbackState: ${lexicalCapability.fallbackState})`","lineStart":630,"lineEnd":1149,"totalLines":1657,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-search.ts","time":{"start":1780738203039,"end":1780738203043}},"metadata":{"openai":{"itemId":"fc_0de447a7862df622016a23e89afb248191a6b7d9f761268549"}},"id":"prt_e9c449d7d001X2vY8rpH58vYJg","sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","messageID":"msg_e9c447a920012243jrYknhM68d"}}
{"type":"tool_use","timestamp":1780738203084,"sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","part":{"type":"tool","tool":"read","callID":"call_s1k5N2Dcfh9UbWLH6EiG8G8y","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Feedback Event Ledger\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Implicit feedback log\n5: // Records implicit feedback signals from search/save interactions\n6: // into a shadow-only SQLite table. No ranking side effects.\n7: //\n8: // Feature flag: SPECKIT_IMPLICIT_FEEDBACK_LOG (default ON, graduated)\n9: // Signal confidence tiers:\n10: //   strong  — citation, follow_on_tool_use (result was used)\n11: //   medium  — query_reformulated (implicit relevance dissatisfaction)\n12: //   weak    — search_shown, same_topic_requery (passive exposure)\n13: import type Database from 'better-sqlite3';\n14: \n15: /* ───────────────────────────────────────────────────────────────\n16:    1. TYPES\n17: ----------------------------------------------------------------*/\n18: \n19: /**\n20:  * The five implicit feedback event types.\n21:  *\n22:  * Confidence signal hierarchy (strongest → weakest):\n23:  *   result_cited | follow_on_tool_use > query_reformulated > same_topic_requery > search_shown\n24:  */\n25: export type FeedbackEventType =\n26:   | 'search_shown'\n27:   | 'result_cited'\n28:   | 'query_reformulated'\n29:   | 'same_topic_requery'\n30:   | 'follow_on_tool_use';\n31: \n32: /** Confidence tier for the implicit signal. */\n33: export type FeedbackConfidence = 'strong' | 'medium' | 'weak';\n34: \n35: /** Input shape for recording a feedback event. */\n36: export interface FeedbackEvent {\n37:   type: FeedbackEventType;\n38:   /** The memory ID this event relates to (string form of DB integer id). */\n39:   memoryId: string;\n40:   /** Opaque query identifier (e.g. eval query ID or hash of query text). */\n41:   queryId: string;\n42:   confidence: FeedbackConfidence;\n43:   timestamp: number;\n44:   sessionId?: string | null;\n45: }\n46: \n47: /** Row shape stored in feedback_events table. */\n48: export interface FeedbackEventRow {\n49:   id: number;\n50:   type: FeedbackEventType;\n51:   memory_id: string;\n52:   query_id: string;\n53:   confidence: FeedbackConfidence;\n54:   timestamp: number;\n55:   session_id: string | null;\n56: }\n57: \n58: export interface GetFeedbackEventsOptions {\n59:   type?: FeedbackEventType;\n60:   memoryId?: string;\n61:   queryId?: string;\n62:   confidence?: FeedbackConfidence;\n63:   sessionId?: string;\n64:   since?: number;   // Unix ms\n65:   until?: number;   // Unix ms\n66:   limit?: number;\n67:   offset?: number;\n68: }\n69: \n70: /* ───────────────────────────────────────────────────────────────\n71:    2. CONFIDENCE TIER MAPPING\n72: ----------------------------------------------------------------*/\n73: \n74: /**\n75:  * Infer confidence tier from event type.\n76:  * Callers may override by providing explicit confidence in the event.\n77:  */\n78: const EVENT_TYPE_CONFIDENCE: Record<FeedbackEventType, FeedbackConfidence> = {\n79:   result_cited:         'strong',\n80:   follow_on_tool_use:   'strong',\n81:   query_reformulated:   'medium',\n82:   same_topic_requery:   'weak',\n83:   search_shown:         'weak',\n84: };\n85: \n86: /**\n87:  * Resolve confidence for a feedback event.\n88:  * Uses the caller-supplied value when present, otherwise infers from type.\n89:  */\n90: export function resolveConfidence(\n91:   type: FeedbackEventType,\n92:   explicit?: FeedbackConfidence\n93: ): FeedbackConfidence {\n94:   if (explicit) return explicit;\n95:   return EVENT_TYPE_CONFIDENCE[type] ?? 'weak';\n96: }\n97: \n98: /* ───────────────────────────────────────────────────────────────\n99:    3. FEATURE FLAG\n100: ----------------------------------------------------------------*/\n101: \n102: /**\n103:  * Check whether the implicit feedback log is enabled.\n104:  * Default: TRUE (graduated). Set SPECKIT_IMPLICIT_FEEDBACK_LOG=false to disable.\n105:  */\n106: export function isImplicitFeedbackLogEnabled(): boolean {\n107:   const val = process.env.SPECKIT_IMPLICIT_FEEDBACK_LOG?.toLowerCase().trim();\n108:   return val !== 'false' && val !== '0';\n109: }\n110: \n111: /* ───────────────────────────────────────────────────────────────\n112:    4. SCHEMA SQL\n113: ----------------------------------------------------------------*/\n114: \n115: const FEEDBACK_SCHEMA_SQL = `\n116:   CREATE TABLE IF NOT EXISTS feedback_events (\n117:     id         INTEGER PRIMARY KEY AUTOINCREMENT,\n118:     type       TEXT NOT NULL CHECK(type IN (\n119:                  'search_shown','result_cited','query_reformulated',\n120:                  'same_topic_requery','follow_on_tool_use'\n121:                )),\n122:     memory_id  TEXT NOT NULL,\n123:     query_id   TEXT NOT NULL,\n124:     confidence TEXT NOT NULL CHECK(confidence IN ('strong','medium','weak')),\n125:     timestamp  INTEGER NOT NULL,\n126:     session_id TEXT\n127:   )\n128: `;\n129: \n130: const FEEDBACK_INDEX_SQL = `\n131:   CREATE INDEX IF NOT EXISTS idx_feedback_type      ON feedback_events(type);\n132:   CREATE INDEX IF NOT EXISTS idx_feedback_memory_id ON feedback_events(memory_id);\n133:   CREATE INDEX IF NOT EXISTS idx_feedback_query_id  ON feedback_events(query_id);\n134:   CREATE INDEX IF NOT EXISTS idx_feedback_confidence ON feedback_events(confidence);\n135:   CREATE INDEX IF NOT EXISTS idx_feedback_timestamp  ON feedback_events(timestamp);\n136:   CREATE INDEX IF NOT EXISTS idx_feedback_session    ON feedback_events(session_id)\n137: `;\n138: \n139: /* ───────────────────────────────────────────────────────────────\n140:    5. INITIALIZATION\n141: ----------------------------------------------------------------*/\n142: \n143: /** Track which DB handles have had the schema initialized. */\n144: const initializedDbs = new WeakSet<object>();\n145: \n146: /**\n147:  * Ensure the feedback_events table and indices exist in the given database.\n148:  * Idempotent — safe to call multiple times.\n149:  */\n150: export function initFeedbackLedger(db: Database.Database): void {\n151:   if (initializedDbs.has(db)) return;\n152:   db.exec(FEEDBACK_SCHEMA_SQL);\n153:   db.exec(FEEDBACK_INDEX_SQL);\n154:   initializedDbs.add(db);\n155: }\n156: \n157: /* ───────────────────────────────────────────────────────────────\n158:    6. LOG EVENT\n159: ----------------------------------------------------------------*/\n160: \n161: /**\n162:  * Record a single implicit feedback event.\n163:  *\n164:  * Shadow-only: this function has NO effect on search ranking.\n165:  * Returns the inserted row ID, or null when the feature flag is OFF\n166:  * or the DB write fails.\n167:  *\n168:  * Errors are caught and logged as warnings — feedback recording must\n169:  * never interrupt search or save operations.\n170:  */\n171: export function logFeedbackEvent(\n172:   db: Database.Database,\n173:   event: FeedbackEvent\n174: ): number | null {\n175:   if (!isImplicitFeedbackLogEnabled()) return null;\n176: \n177:   try {\n178:     initFeedbackLedger(db);\n179: \n180:     const confidence = resolveConfidence(event.type, event.confidence);\n181: \n182:     const result = db.prepare(`\n183:       INSERT INTO feedback_events (type, memory_id, query_id, confidence, timestamp, session_id)\n184:       VALUES (?, ?, ?, ?, ?, ?)\n185:     `).run(\n186:       event.type,\n187:       event.memoryId,\n188:       event.queryId,\n189:       confidence,\n190:       event.timestamp,\n191:       event.sessionId ?? null\n192:     );\n193: \n194:     return (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n195:   } catch (err: unknown) {\n196:     const message = err instanceof Error ? err.message : String(err);\n197:     console.warn('[feedback-ledger] logFeedbackEvent error:', message);\n198:     return null;\n199:   }\n200: }\n201: \n202: /**\n203:  * Record a batch of feedback events (e.g., all search_shown results from\n204:  * a single search response).\n205:  *\n206:  * Returns the count of successfully inserted rows.\n207:  */\n208: export function logFeedbackEvents(\n209:   db: Database.Database,\n210:   events: FeedbackEvent[]\n211: ): number {\n212:   if (!isImplicitFeedbackLogEnabled()) return 0;\n213:   if (events.length === 0) return 0;\n214: \n215:   let inserted = 0;\n216:   for (const event of events) {\n217:     const id = logFeedbackEvent(db, event);\n218:     if (id !== null) inserted++;\n219:   }\n220:   return inserted;\n221: }\n222: \n223: /* ───────────────────────────────────────────────────────────────\n224:    7. QUERY EVENTS\n225: ----------------------------------------------------------------*/\n226: \n227: /**\n228:  * Query feedback events with optional filters.\n229:  * Returns matching rows ordered by timestamp ascending.\n230:  */\n231: export function getFeedbackEvents(\n232:   db: Database.Database,\n233:   opts: GetFeedbackEventsOptions = {}\n234: ): FeedbackEventRow[] {\n235:   try {\n236:     initFeedbackLedger(db);\n237: \n238:     const conditions: string[] = [];\n239:     const params: Array<string | number> = [];\n240: \n241:     if (opts.type) {\n242:       conditions.push('type = ?');\n243:       params.push(opts.type);\n244:     }\n245:     if (opts.memoryId !== undefined) {\n246:       conditions.push('memory_id = ?');\n247:       params.push(opts.memoryId);\n248:     }\n249:     if (opts.queryId !== undefined) {\n250:       conditions.push('query_id = ?');\n251:       params.push(opts.queryId);\n252:     }\n253:     if (opts.confidence) {\n254:       conditions.push('confidence = ?');\n255:       params.push(opts.confidence);\n256:     }\n257:     if (opts.sessionId !== undefined) {\n258:       conditions.push('session_id = ?');\n259:       params.push(opts.sessionId);\n260:     }\n261:     if (opts.since !== undefined) {\n262:       conditions.push('timestamp >= ?');\n263:       params.push(opts.since);\n264:     }\n265:     if (opts.until !== undefined) {\n266:       conditions.push('timestamp <= ?');\n267:       params.push(opts.until);\n268:     }\n269: \n270:     const where = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';\n271:     const limit = opts.limit ? `LIMIT ${Math.max(1, Math.floor(opts.limit))}` : '';\n272:     const offset = opts.offset ? `OFFSET ${Math.max(0, Math.floor(opts.offset))}` : '';\n273:     const effectiveLimit = !limit && offset ? 'LIMIT -1' : limit;\n274: \n275:     const sql = `SELECT * FROM feedback_events ${where} ORDER BY timestamp ASC ${effectiveLimit} ${offset}`;\n276:     return db.prepare(sql).all(...params) as FeedbackEventRow[];\n277:   } catch (err: unknown) {\n278:     const message = err instanceof Error ? err.message : String(err);\n279:     console.warn('[feedback-ledger] getFeedbackEvents error:', message);\n280:     return [];\n281:   }\n282: }\n283: \n284: /**\n285:  * Count total feedback events, optionally filtered by type.\n286:  */\n287: export function getFeedbackEventCount(\n288:   db: Database.Database,\n289:   type?: FeedbackEventType\n290: ): number {\n291:   try {\n292:     initFeedbackLedger(db);\n293:     if (type) {\n294:       const row = db.prepare('SELECT COUNT(*) as count FROM feedback_events WHERE type = ?')\n295:         .get(type) as { count: number };\n296:       return row.count;\n297:     }\n298:     const row = db.prepare('SELECT COUNT(*) as count FROM feedback_events').get() as { count: number };\n299:     return row.count;\n300:   } catch {\n301:     return 0;\n302:   }\n303: }\n304: \n305: /**\n306:  * Get aggregated signal counts for a specific memory (by memoryId).\n307:  * Returns counts broken down by confidence tier.\n308:  */\n309: export interface MemoryFeedbackSummary {\n310:   memoryId: string;\n311:   total: number;\n312:   strong: number;\n313:   medium: number;\n314:   weak: number;\n315: }\n316: \n317: export function getMemoryFeedbackSummary(\n318:   db: Database.Database,\n319:   memoryId: string\n320: ): MemoryFeedbackSummary {\n321:   try {\n322:     initFeedbackLedger(db);\n323:     const rows = db.prepare(`\n324:       SELECT confidence, COUNT(*) as cnt\n325:       FROM feedback_events\n326:       WHERE memory_id = ?\n327:       GROUP BY confidence\n328:     `).all(memoryId) as Array<{ confidence: FeedbackConfidence; cnt: number }>;\n329: \n330:     const summary: MemoryFeedbackSummary = { memoryId, total: 0, strong: 0, medium: 0, weak: 0 };\n331:     for (const row of rows) {\n332:       summary[row.confidence] = row.cnt;\n333:       summary.total += row.cnt;\n334:     }\n335:     return summary;\n336:   } catch {\n337:     return { memoryId, total: 0, strong: 0, medium: 0, weak: 0 };\n338:   }\n339: }\n340: \n341: /* ───────────────────────────────────────────────────────────────\n342:    8. EXPORTS (schema constants for testing)\n343: ----------------------------------------------------------------*/\n344: \n345: export {\n346:   FEEDBACK_SCHEMA_SQL,\n347:   FEEDBACK_INDEX_SQL,\n348:   EVENT_TYPE_CONFIDENCE,\n349: };\n\n(End of file - total 349 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Feedback Event Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Implicit feedback log\n// Records implicit feedback signals from search/save interactions\n// into a shadow-only SQLite table. No ranking side effects.\n//\n// Feature flag: SPECKIT_IMPLICIT_FEEDBACK_LOG (default ON, graduated)\n// Signal confidence tiers:\n//   strong  — citation, follow_on_tool_use (result was used)\n//   medium  — query_reformulated (implicit relevance dissatisfaction)\n//   weak    — search_shown, same_topic_requery (passive exposure)\nimport type Database from 'better-sqlite3';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\n/**\n * The five implicit feedback event types.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Feedback Event Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Implicit feedback log\n// Records implicit feedback signals from search/save interactions\n// into a shadow-only SQLite table. No ranking side effects.\n//\n// Feature flag: SPECKIT_IMPLICIT_FEEDBACK_LOG (default ON, graduated)\n// Signal confidence tiers:\n//   strong  — citation, follow_on_tool_use (result was used)\n//   medium  — query_reformulated (implicit relevance dissatisfaction)\n//   weak    — search_shown, same_topic_requery (passive exposure)\nimport type Database from 'better-sqlite3';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\n/**\n * The five implicit feedback event types.\n *\n * Confidence signal hierarchy (strongest → weakest):\n *   result_cited | follow_on_tool_use > query_reformulated > same_topic_requery > search_shown\n */\nexport type FeedbackEventType =\n  | 'search_shown'\n  | 'result_cited'\n  | 'query_reformulated'\n  | 'same_topic_requery'\n  | 'follow_on_tool_use';\n\n/** Confidence tier for the implicit signal. */\nexport type FeedbackConfidence = 'strong' | 'medium' | 'weak';\n\n/** Input shape for recording a feedback event. */\nexport interface FeedbackEvent {\n  type: FeedbackEventType;\n  /** The memory ID this event relates to (string form of DB integer id). */\n  memoryId: string;\n  /** Opaque query identifier (e.g. eval query ID or hash of query text). */\n  queryId: string;\n  confidence: FeedbackConfidence;\n  timestamp: number;\n  sessionId?: string | null;\n}\n\n/** Row shape stored in feedback_events table. */\nexport interface FeedbackEventRow {\n  id: number;\n  type: FeedbackEventType;\n  memory_id: string;\n  query_id: string;\n  confidence: FeedbackConfidence;\n  timestamp: number;\n  session_id: string | null;\n}\n\nexport interface GetFeedbackEventsOptions {\n  type?: FeedbackEventType;\n  memoryId?: string;\n  queryId?: string;\n  confidence?: FeedbackConfidence;\n  sessionId?: string;\n  since?: number;   // Unix ms\n  until?: number;   // Unix ms\n  limit?: number;\n  offset?: number;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. CONFIDENCE TIER MAPPING\n----------------------------------------------------------------*/\n\n/**\n * Infer confidence tier from event type.\n * Callers may override by providing explicit confidence in the event.\n */\nconst EVENT_TYPE_CONFIDENCE: Record<FeedbackEventType, FeedbackConfidence> = {\n  result_cited:         'strong',\n  follow_on_tool_use:   'strong',\n  query_reformulated:   'medium',\n  same_topic_requery:   'weak',\n  search_shown:         'weak',\n};\n\n/**\n * Resolve confidence for a feedback event.\n * Uses the caller-supplied value when present, otherwise infers from type.\n */\nexport function resolveConfidence(\n  type: FeedbackEventType,\n  explicit?: FeedbackConfidence\n): FeedbackConfidence {\n  if (explicit) return explicit;\n  return EVENT_TYPE_CONFIDENCE[type] ?? 'weak';\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. FEATURE FLAG\n----------------------------------------------------------------*/\n\n/**\n * Check whether the implicit feedback log is enabled.\n * Default: TRUE (graduated). Set SPECKIT_IMPLICIT_FEEDBACK_LOG=false to disable.\n */\nexport function isImplicitFeedbackLogEnabled(): boolean {\n  const val = process.env.SPECKIT_IMPLICIT_FEEDBACK_LOG?.toLowerCase().trim();\n  return val !== 'false' && val !== '0';\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. SCHEMA SQL\n----------------------------------------------------------------*/\n\nconst FEEDBACK_SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS feedback_events (\n    id         INTEGER PRIMARY KEY AUTOINCREMENT,\n    type       TEXT NOT NULL CHECK(type IN (\n                 'search_shown','result_cited','query_reformulated',\n                 'same_topic_requery','follow_on_tool_use'\n               )),\n    memory_id  TEXT NOT NULL,\n    query_id   TEXT NOT NULL,\n    confidence TEXT NOT NULL CHECK(confidence IN ('strong','medium','weak')),\n    timestamp  INTEGER NOT NULL,\n    session_id TEXT\n  )\n`;\n\nconst FEEDBACK_INDEX_SQL = `\n  CREATE INDEX IF NOT EXISTS idx_feedback_type      ON feedback_events(type);\n  CREATE INDEX IF NOT EXISTS idx_feedback_memory_id ON feedback_events(memory_id);\n  CREATE INDEX IF NOT EXISTS idx_feedback_query_id  ON feedback_events(query_id);\n  CREATE INDEX IF NOT EXISTS idx_feedback_confidence ON feedback_events(confidence);\n  CREATE INDEX IF NOT EXISTS idx_feedback_timestamp  ON feedback_events(timestamp);\n  CREATE INDEX IF NOT EXISTS idx_feedback_session    ON feedback_events(session_id)\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   5. INITIALIZATION\n----------------------------------------------------------------*/\n\n/** Track which DB handles have had the schema initialized. */\nconst initializedDbs = new WeakSet<object>();\n\n/**\n * Ensure the feedback_events table and indices exist in the given database.\n * Idempotent — safe to call multiple times.\n */\nexport function initFeedbackLedger(db: Database.Database): void {\n  if (initializedDbs.has(db)) return;\n  db.exec(FEEDBACK_SCHEMA_SQL);\n  db.exec(FEEDBACK_INDEX_SQL);\n  initializedDbs.add(db);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. LOG EVENT\n----------------------------------------------------------------*/\n\n/**\n * Record a single implicit feedback event.\n *\n * Shadow-only: this function has NO effect on search ranking.\n * Returns the inserted row ID, or null when the feature flag is OFF\n * or the DB write fails.\n *\n * Errors are caught and logged as warnings — feedback recording must\n * never interrupt search or save operations.\n */\nexport function logFeedbackEvent(\n  db: Database.Database,\n  event: FeedbackEvent\n): number | null {\n  if (!isImplicitFeedbackLogEnabled()) return null;\n\n  try {\n    initFeedbackLedger(db);\n\n    const confidence = resolveConfidence(event.type, event.confidence);\n\n    const result = db.prepare(`\n      INSERT INTO feedback_events (type, memory_id, query_id, confidence, timestamp, session_id)\n      VALUES (?, ?, ?, ?, ?, ?)\n    `).run(\n      event.type,\n      event.memoryId,\n      event.queryId,\n      confidence,\n      event.timestamp,\n      event.sessionId ?? null\n    );\n\n    return (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn('[feedback-ledger] logFeedbackEvent error:', message);\n    return null;\n  }\n}\n\n/**\n * Record a batch of feedback events (e.g., all search_shown results from\n * a single search response).\n *\n * Returns the count of successfully inserted rows.\n */\nexport function logFeedbackEvents(\n  db: Database.Database,\n  events: FeedbackEvent[]\n): number {\n  if (!isImplicitFeedbackLogEnabled()) return 0;\n  if (events.length === 0) return 0;\n\n  let inserted = 0;\n  for (const event of events) {\n    const id = logFeedbackEvent(db, event);\n    if (id !== null) inserted++;\n  }\n  return inserted;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. QUERY EVENTS\n----------------------------------------------------------------*/\n\n/**\n * Query feedback events with optional filters.\n * Returns matching rows ordered by timestamp ascending.\n */\nexport function getFeedbackEvents(\n  db: Database.Database,\n  opts: GetFeedbackEventsOptions = {}\n): FeedbackEventRow[] {\n  try {\n    initFeedbackLedger(db);\n\n    const conditions: string[] = [];\n    const params: Array<string | number> = [];\n\n    if (opts.type) {\n      conditions.push('type = ?');\n      params.push(opts.type);\n    }\n    if (opts.memoryId !== undefined) {\n      conditions.push('memory_id = ?');\n      params.push(opts.memoryId);\n    }\n    if (opts.queryId !== undefined) {\n      conditions.push('query_id = ?');\n      params.push(opts.queryId);\n    }\n    if (opts.confidence) {\n      conditions.push('confidence = ?');\n      params.push(opts.confidence);\n    }\n    if (opts.sessionId !== undefined) {\n      conditions.push('session_id = ?');\n      params.push(opts.sessionId);\n    }\n    if (opts.since !== undefined) {\n      conditions.push('timestamp >= ?');\n      params.push(opts.since);\n    }\n    if (opts.until !== undefined) {\n      conditions.push('timestamp <= ?');\n      params.push(opts.until);\n    }\n\n    const where = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';\n    const limit = opts.limit ? `LIMIT ${Math.max(1, Math.floor(opts.limit))}` : '';\n    const offset = opts.offset ? `OFFSET ${Math.max(0, Math.floor(opts.offset))}` : '';\n    const effectiveLimit = !limit && offset ? 'LIMIT -1' : limit;\n\n    const sql = `SELECT * FROM feedback_events ${where} ORDER BY timestamp ASC ${effectiveLimit} ${offset}`;\n    return db.prepare(sql).all(...params) as FeedbackEventRow[];\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn('[feedback-ledger] getFeedbackEvents error:', message);\n    return [];\n  }\n}\n\n/**\n * Count total feedback events, optionally filtered by type.\n */\nexport function getFeedbackEventCount(\n  db: Database.Database,\n  type?: FeedbackEventType\n): number {\n  try {\n    initFeedbackLedger(db);\n    if (type) {\n      const row = db.prepare('SELECT COUNT(*) as count FROM feedback_events WHERE type = ?')\n        .get(type) as { count: number };\n      return row.count;\n    }\n    const row = db.prepare('SELECT COUNT(*) as count FROM feedback_events').get() as { count: number };\n    return row.count;\n  } catch {\n    return 0;\n  }\n}\n\n/**\n * Get aggregated signal counts for a specific memory (by memoryId).\n * Returns counts broken down by confidence tier.\n */\nexport interface MemoryFeedbackSummary {\n  memoryId: string;\n  total: number;\n  strong: number;\n  medium: number;\n  weak: number;\n}\n\nexport function getMemoryFeedbackSummary(\n  db: Database.Database,\n  memoryId: string\n): MemoryFeedbackSummary {\n  try {\n    initFeedbackLedger(db);\n    const rows = db.prepare(`\n      SELECT confidence, COUNT(*) as cnt\n      FROM feedback_events\n      WHERE memory_id = ?\n      GROUP BY confidence\n    `).all(memoryId) as Array<{ confidence: FeedbackConfidence; cnt: number }>;\n\n    const summary: MemoryFeedbackSummary = { memoryId, total: 0, strong: 0, medium: 0, weak: 0 };\n    for (const row of rows) {\n      summary[row.confidence] = row.cnt;\n      summary.total += row.cnt;\n    }\n    return summary;\n  } catch {\n    return { memoryId, total: 0, strong: 0, medium: 0, weak: 0 };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS (schema constants for testing)\n----------------------------------------------------------------*/\n\nexport {\n  FEEDBACK_SCHEMA_SQL,\n  FEEDBACK_INDEX_SQL,\n  EVENT_TYPE_CONFIDENCE,\n};","lineStart":1,"lineEnd":349,"totalLines":349,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/feedback/feedback-ledger.ts","time":{"start":1780738203061,"end":1780738203082}},"metadata":{"openai":{"itemId":"fc_0de447a7862df622016a23e89afb34819192c23e9bc8153ba6"}},"id":"prt_e9c449da700188z29uUyN9ojU2","sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","messageID":"msg_e9c447a920012243jrYknhM68d"}}
{"type":"tool_use","timestamp":1780738203088,"sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","part":{"type":"tool","tool":"read","callID":"call_A7yWQgPoe2fQOMZ9a1l5Ix6E","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/feedback/query-flow-tracker.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/feedback/query-flow-tracker.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Query Flow Tracker\n3: // ───────────────────────────────────────────────────────────────\n4: // Tracks query history per session to detect reformulations and\n5: // same-topic re-queries. Emits feedback events via the existing\n6: // feedback ledger. Bounded in-memory session cache — no DB reads on hot path.\n7: import type Database from 'better-sqlite3';\n8: import {\n9:   logFeedbackEvent,\n10:   isImplicitFeedbackLogEnabled,\n11: } from './feedback-ledger.js';\n12: import type { FeedbackEvent } from './feedback-ledger.js';\n13: \n14: /* ───────────────────────────────────────────────────────────────\n15:    1. CONFIGURATION\n16: ──────────────────────────────────────────────────────────────── */\n17: \n18: const MAX_QUERIES_PER_SESSION = 50;\n19: const TTL_MS = 10 * 60 * 1000; // 10 minutes\n20: const DEDUP_WINDOW_MS = 1000;  // ignore queries <1s apart\n21: const FOLLOW_ON_WINDOW_MS = 60_000; // 60 seconds\n22: const MIN_QUERY_LENGTH = 3;\n23: \n24: // Similarity thresholds (Jaccard on normalized tokens)\n25: const REFORMULATION_MIN = 0.3;  // similar enough to be related\n26: const REFORMULATION_MAX = 0.8;  // but different enough to be a reformulation\n27: const SAME_TOPIC_MIN = 0.8;     // very similar = same topic requery\n28: \n29: /* ───────────────────────────────────────────────────────────────\n30:    2. TYPES\n31: ──────────────────────────────────────────────────────────────── */\n32: \n33: interface QueryEntry {\n34:   tokens: Set<string>;\n35:   timestamp: number;\n36:   queryId: string;\n37:   shownMemoryIds: string[];\n38: }\n39: \n40: interface FlowDetectionResult {\n41:   type: 'query_reformulated' | 'same_topic_requery' | null;\n42:   similarity: number;\n43:   previousQueryId: string | null;\n44:   previousMemoryIds: string[];\n45: }\n46: \n47: /* ───────────────────────────────────────────────────────────────\n48:    3. SESSION QUERY CACHE\n49: ──────────────────────────────────────────────────────────────── */\n50: \n51: const sessionQueries = new Map<string, QueryEntry[]>();\n52: \n53: function evictStale(sessionId: string): void {\n54:   const entries = sessionQueries.get(sessionId);\n55:   if (!entries) return;\n56:   const cutoff = Date.now() - TTL_MS;\n57:   const fresh = entries.filter(e => e.timestamp > cutoff);\n58:   if (fresh.length === 0) {\n59:     sessionQueries.delete(sessionId);\n60:   } else {\n61:     // Keep only the last MAX_QUERIES_PER_SESSION entries\n62:     sessionQueries.set(sessionId, fresh.slice(-MAX_QUERIES_PER_SESSION));\n63:   }\n64: }\n65: \n66: /* ───────────────────────────────────────────────────────────────\n67:    4. TOKEN SIMILARITY\n68: ──────────────────────────────────────────────────────────────── */\n69: \n70: function tokenize(query: string): Set<string> {\n71:   return new Set(\n72:     query\n73:       .toLowerCase()\n74:       .replace(/[^\\w\\s]/g, ' ')\n75:       .split(/\\s+/)\n76:       .filter(t => t.length > 1)\n77:   );\n78: }\n79: \n80: function jaccardSimilarity(a: Set<string>, b: Set<string>): number {\n81:   if (a.size === 0 && b.size === 0) return 1;\n82:   let intersection = 0;\n83:   for (const token of a) {\n84:     if (b.has(token)) intersection++;\n85:   }\n86:   const union = a.size + b.size - intersection;\n87:   return union === 0 ? 0 : intersection / union;\n88: }\n89: \n90: /* ───────────────────────────────────────────────────────────────\n91:    5. FLOW DETECTION\n92: ──────────────────────────────────────────────────────────────── */\n93: \n94: /**\n95:  * Detect if the current query is a reformulation or same-topic requery\n96:  * relative to the most recent query in this session.\n97:  */\n98: function detectFlow(\n99:   sessionId: string,\n100:   tokens: Set<string>,\n101:   timestamp: number,\n102: ): FlowDetectionResult {\n103:   const entries = sessionQueries.get(sessionId);\n104:   if (!entries || entries.length === 0) {\n105:     return { type: null, similarity: 0, previousQueryId: null, previousMemoryIds: [] };\n106:   }\n107: \n108:   const previous = entries[entries.length - 1];\n109: \n110:   // Dedup: skip if query is identical or too fast\n111:   if (timestamp - previous.timestamp < DEDUP_WINDOW_MS) {\n112:     return { type: null, similarity: 0, previousQueryId: null, previousMemoryIds: [] };\n113:   }\n114: \n115:   const similarity = jaccardSimilarity(tokens, previous.tokens);\n116: \n117:   if (similarity >= SAME_TOPIC_MIN) {\n118:     return {\n119:       type: 'same_topic_requery',\n120:       similarity,\n121:       previousQueryId: previous.queryId,\n122:       previousMemoryIds: previous.shownMemoryIds,\n123:     };\n124:   }\n125: \n126:   if (similarity >= REFORMULATION_MIN && similarity < REFORMULATION_MAX) {\n127:     return {\n128:       type: 'query_reformulated',\n129:       similarity,\n130:       previousQueryId: previous.queryId,\n131:       previousMemoryIds: previous.shownMemoryIds,\n132:     };\n133:   }\n134: \n135:   return { type: null, similarity, previousQueryId: null, previousMemoryIds: [] };\n136: }\n137: \n138: /* ───────────────────────────────────────────────────────────────\n139:    6. PUBLIC API\n140: ──────────────────────────────────────────────────────────────── */\n141: \n142: /**\n143:  * Track a query and detect reformulation/requery patterns.\n144:  * Emits feedback events for detected patterns.\n145:  *\n146:  * Call this after every search completion.\n147:  *\n148:  * @param db - Database for logging feedback events\n149:  * @param sessionId - Session identifier (null = skip tracking)\n150:  * @param query - The search query text\n151:  * @param queryId - Opaque query identifier for event correlation\n152:  * @param shownMemoryIds - Memory IDs shown in this search's results\n153:  * @returns The detection result (or null if skipped)\n154:  */\n155: export function trackQueryAndDetect(\n156:   db: Database.Database,\n157:   sessionId: string | null,\n158:   query: string,\n159:   queryId: string,\n160:   shownMemoryIds: string[],\n161: ): FlowDetectionResult | null {\n162:   if (!isImplicitFeedbackLogEnabled()) return null;\n163:   if (!sessionId) return null;\n164:   if (query.length < MIN_QUERY_LENGTH) return null;\n165: \n166:   const timestamp = Date.now();\n167:   const tokens = tokenize(query);\n168: \n169:   // Evict stale entries\n170:   evictStale(sessionId);\n171: \n172:   // Detect flow before adding current query\n173:   const detection = detectFlow(sessionId, tokens, timestamp);\n174: \n175:   // Add current query to history\n176:   const entries = sessionQueries.get(sessionId) ?? [];\n177:   entries.push({ tokens, timestamp, queryId, shownMemoryIds });\n178:   sessionQueries.set(sessionId, entries.slice(-MAX_QUERIES_PER_SESSION));\n179: \n180:   // Emit feedback events for detected patterns\n181:   if (detection.type && detection.previousMemoryIds.length > 0) {\n182:     const confidence = detection.type === 'query_reformulated' ? 'medium' : 'weak';\n183:     for (const memoryId of detection.previousMemoryIds) {\n184:       const event: FeedbackEvent = {\n185:         type: detection.type,\n186:         memoryId,\n187:         queryId: detection.previousQueryId ?? queryId,\n188:         confidence,\n189:         timestamp,\n190:         sessionId,\n191:       };\n192:       logFeedbackEvent(db, event);\n193:     }\n194:   }\n195: \n196:   return detection;\n197: }\n198: \n199: /**\n200:  * Log `result_cited` events for memories whose content was loaded.\n201:  * Call when includeContent=true and results contain content.\n202:  */\n203: export function logResultCited(\n204:   db: Database.Database,\n205:   sessionId: string | null,\n206:   queryId: string,\n207:   memoryIds: string[],\n208: ): void {\n209:   if (!isImplicitFeedbackLogEnabled()) return;\n210:   if (memoryIds.length === 0) return;\n211: \n212:   const timestamp = Date.now();\n213:   for (const memoryId of memoryIds) {\n214:     logFeedbackEvent(db, {\n215:       type: 'result_cited',\n216:       memoryId,\n217:       queryId,\n218:       confidence: 'strong',\n219:       timestamp,\n220:       sessionId: sessionId ?? null,\n221:     });\n222:   }\n223: }\n224: \n225: /**\n226:  * Log `follow_on_tool_use` events for memories shown in a recent search.\n227:  * Call when any non-search tool is invoked within the follow-on window.\n228:  */\n229: export function logFollowOnToolUse(\n230:   db: Database.Database,\n231:   sessionId: string | null,\n232: ): void {\n233:   if (!isImplicitFeedbackLogEnabled()) return;\n234:   if (!sessionId) return;\n235: \n236:   const entries = sessionQueries.get(sessionId);\n237:   if (!entries || entries.length === 0) return;\n238: \n239:   const latest = entries[entries.length - 1];\n240:   const elapsed = Date.now() - latest.timestamp;\n241: \n242:   if (elapsed > FOLLOW_ON_WINDOW_MS) return;\n243:   if (latest.shownMemoryIds.length === 0) return;\n244: \n245:   const timestamp = Date.now();\n246:   for (const memoryId of latest.shownMemoryIds) {\n247:     logFeedbackEvent(db, {\n248:       type: 'follow_on_tool_use',\n249:       memoryId,\n250:       queryId: latest.queryId,\n251:       confidence: 'strong',\n252:       timestamp,\n253:       sessionId,\n254:     });\n255:   }\n256: }\n257: \n258: /**\n259:  * Clear query history for a session (e.g., on session cleanup).\n260:  */\n261: export function clearSession(sessionId: string): void {\n262:   sessionQueries.delete(sessionId);\n263: }\n264: \n265: /**\n266:  * Get current session query count (for testing/diagnostics).\n267:  */\n268: export function getSessionQueryCount(sessionId: string): number {\n269:   return sessionQueries.get(sessionId)?.length ?? 0;\n270: }\n\n(End of file - total 270 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Query Flow Tracker\n// ───────────────────────────────────────────────────────────────\n// Tracks query history per session to detect reformulations and\n// same-topic re-queries. Emits feedback events via the existing\n// feedback ledger. Bounded in-memory session cache — no DB reads on hot path.\nimport type Database from 'better-sqlite3';\nimport {\n  logFeedbackEvent,\n  isImplicitFeedbackLogEnabled,\n} from './feedback-ledger.js';\nimport type { FeedbackEvent } from './feedback-ledger.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\nconst MAX_QUERIES_PER_SESSION = 50;\nconst TTL_MS = 10 * 60 * 1000; // 10 minutes\nconst DEDUP_WINDOW_MS = 1000;  // ignore queries <1s apart","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/feedback/query-flow-tracker.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Query Flow Tracker\n// ───────────────────────────────────────────────────────────────\n// Tracks query history per session to detect reformulations and\n// same-topic re-queries. Emits feedback events via the existing\n// feedback ledger. Bounded in-memory session cache — no DB reads on hot path.\nimport type Database from 'better-sqlite3';\nimport {\n  logFeedbackEvent,\n  isImplicitFeedbackLogEnabled,\n} from './feedback-ledger.js';\nimport type { FeedbackEvent } from './feedback-ledger.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONFIGURATION\n──────────────────────────────────────────────────────────────── */\n\nconst MAX_QUERIES_PER_SESSION = 50;\nconst TTL_MS = 10 * 60 * 1000; // 10 minutes\nconst DEDUP_WINDOW_MS = 1000;  // ignore queries <1s apart\nconst FOLLOW_ON_WINDOW_MS = 60_000; // 60 seconds\nconst MIN_QUERY_LENGTH = 3;\n\n// Similarity thresholds (Jaccard on normalized tokens)\nconst REFORMULATION_MIN = 0.3;  // similar enough to be related\nconst REFORMULATION_MAX = 0.8;  // but different enough to be a reformulation\nconst SAME_TOPIC_MIN = 0.8;     // very similar = same topic requery\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface QueryEntry {\n  tokens: Set<string>;\n  timestamp: number;\n  queryId: string;\n  shownMemoryIds: string[];\n}\n\ninterface FlowDetectionResult {\n  type: 'query_reformulated' | 'same_topic_requery' | null;\n  similarity: number;\n  previousQueryId: string | null;\n  previousMemoryIds: string[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. SESSION QUERY CACHE\n──────────────────────────────────────────────────────────────── */\n\nconst sessionQueries = new Map<string, QueryEntry[]>();\n\nfunction evictStale(sessionId: string): void {\n  const entries = sessionQueries.get(sessionId);\n  if (!entries) return;\n  const cutoff = Date.now() - TTL_MS;\n  const fresh = entries.filter(e => e.timestamp > cutoff);\n  if (fresh.length === 0) {\n    sessionQueries.delete(sessionId);\n  } else {\n    // Keep only the last MAX_QUERIES_PER_SESSION entries\n    sessionQueries.set(sessionId, fresh.slice(-MAX_QUERIES_PER_SESSION));\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. TOKEN SIMILARITY\n──────────────────────────────────────────────────────────────── */\n\nfunction tokenize(query: string): Set<string> {\n  return new Set(\n    query\n      .toLowerCase()\n      .replace(/[^\\w\\s]/g, ' ')\n      .split(/\\s+/)\n      .filter(t => t.length > 1)\n  );\n}\n\nfunction jaccardSimilarity(a: Set<string>, b: Set<string>): number {\n  if (a.size === 0 && b.size === 0) return 1;\n  let intersection = 0;\n  for (const token of a) {\n    if (b.has(token)) intersection++;\n  }\n  const union = a.size + b.size - intersection;\n  return union === 0 ? 0 : intersection / union;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. FLOW DETECTION\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Detect if the current query is a reformulation or same-topic requery\n * relative to the most recent query in this session.\n */\nfunction detectFlow(\n  sessionId: string,\n  tokens: Set<string>,\n  timestamp: number,\n): FlowDetectionResult {\n  const entries = sessionQueries.get(sessionId);\n  if (!entries || entries.length === 0) {\n    return { type: null, similarity: 0, previousQueryId: null, previousMemoryIds: [] };\n  }\n\n  const previous = entries[entries.length - 1];\n\n  // Dedup: skip if query is identical or too fast\n  if (timestamp - previous.timestamp < DEDUP_WINDOW_MS) {\n    return { type: null, similarity: 0, previousQueryId: null, previousMemoryIds: [] };\n  }\n\n  const similarity = jaccardSimilarity(tokens, previous.tokens);\n\n  if (similarity >= SAME_TOPIC_MIN) {\n    return {\n      type: 'same_topic_requery',\n      similarity,\n      previousQueryId: previous.queryId,\n      previousMemoryIds: previous.shownMemoryIds,\n    };\n  }\n\n  if (similarity >= REFORMULATION_MIN && similarity < REFORMULATION_MAX) {\n    return {\n      type: 'query_reformulated',\n      similarity,\n      previousQueryId: previous.queryId,\n      previousMemoryIds: previous.shownMemoryIds,\n    };\n  }\n\n  return { type: null, similarity, previousQueryId: null, previousMemoryIds: [] };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. PUBLIC API\n──────────────────────────────────────────────────────────────── */\n\n/**\n * Track a query and detect reformulation/requery patterns.\n * Emits feedback events for detected patterns.\n *\n * Call this after every search completion.\n *\n * @param db - Database for logging feedback events\n * @param sessionId - Session identifier (null = skip tracking)\n * @param query - The search query text\n * @param queryId - Opaque query identifier for event correlation\n * @param shownMemoryIds - Memory IDs shown in this search's results\n * @returns The detection result (or null if skipped)\n */\nexport function trackQueryAndDetect(\n  db: Database.Database,\n  sessionId: string | null,\n  query: string,\n  queryId: string,\n  shownMemoryIds: string[],\n): FlowDetectionResult | null {\n  if (!isImplicitFeedbackLogEnabled()) return null;\n  if (!sessionId) return null;\n  if (query.length < MIN_QUERY_LENGTH) return null;\n\n  const timestamp = Date.now();\n  const tokens = tokenize(query);\n\n  // Evict stale entries\n  evictStale(sessionId);\n\n  // Detect flow before adding current query\n  const detection = detectFlow(sessionId, tokens, timestamp);\n\n  // Add current query to history\n  const entries = sessionQueries.get(sessionId) ?? [];\n  entries.push({ tokens, timestamp, queryId, shownMemoryIds });\n  sessionQueries.set(sessionId, entries.slice(-MAX_QUERIES_PER_SESSION));\n\n  // Emit feedback events for detected patterns\n  if (detection.type && detection.previousMemoryIds.length > 0) {\n    const confidence = detection.type === 'query_reformulated' ? 'medium' : 'weak';\n    for (const memoryId of detection.previousMemoryIds) {\n      const event: FeedbackEvent = {\n        type: detection.type,\n        memoryId,\n        queryId: detection.previousQueryId ?? queryId,\n        confidence,\n        timestamp,\n        sessionId,\n      };\n      logFeedbackEvent(db, event);\n    }\n  }\n\n  return detection;\n}\n\n/**\n * Log `result_cited` events for memories whose content was loaded.\n * Call when includeContent=true and results contain content.\n */\nexport function logResultCited(\n  db: Database.Database,\n  sessionId: string | null,\n  queryId: string,\n  memoryIds: string[],\n): void {\n  if (!isImplicitFeedbackLogEnabled()) return;\n  if (memoryIds.length === 0) return;\n\n  const timestamp = Date.now();\n  for (const memoryId of memoryIds) {\n    logFeedbackEvent(db, {\n      type: 'result_cited',\n      memoryId,\n      queryId,\n      confidence: 'strong',\n      timestamp,\n      sessionId: sessionId ?? null,\n    });\n  }\n}\n\n/**\n * Log `follow_on_tool_use` events for memories shown in a recent search.\n * Call when any non-search tool is invoked within the follow-on window.\n */\nexport function logFollowOnToolUse(\n  db: Database.Database,\n  sessionId: string | null,\n): void {\n  if (!isImplicitFeedbackLogEnabled()) return;\n  if (!sessionId) return;\n\n  const entries = sessionQueries.get(sessionId);\n  if (!entries || entries.length === 0) return;\n\n  const latest = entries[entries.length - 1];\n  const elapsed = Date.now() - latest.timestamp;\n\n  if (elapsed > FOLLOW_ON_WINDOW_MS) return;\n  if (latest.shownMemoryIds.length === 0) return;\n\n  const timestamp = Date.now();\n  for (const memoryId of latest.shownMemoryIds) {\n    logFeedbackEvent(db, {\n      type: 'follow_on_tool_use',\n      memoryId,\n      queryId: latest.queryId,\n      confidence: 'strong',\n      timestamp,\n      sessionId,\n    });\n  }\n}\n\n/**\n * Clear query history for a session (e.g., on session cleanup).\n */\nexport function clearSession(sessionId: string): void {\n  sessionQueries.delete(sessionId);\n}\n\n/**\n * Get current session query count (for testing/diagnostics).\n */\nexport function getSessionQueryCount(sessionId: string): number {\n  return sessionQueries.get(sessionId)?.length ?? 0;\n}","lineStart":1,"lineEnd":270,"totalLines":270,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/feedback/query-flow-tracker.ts","time":{"start":1780738203063,"end":1780738203086}},"metadata":{"openai":{"itemId":"fc_0de447a7862df622016a23e89afb3c8191a421e6036bdc5f00"}},"id":"prt_e9c449db6001RcIt6Jv6l6BKNR","sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","messageID":"msg_e9c447a920012243jrYknhM68d"}}
{"type":"tool_use","timestamp":1780738203095,"sessionID":"ses_163bcc511ffeJbZHjaVz1S8sbA","part":{"type":"tool","tool":"read","callID":"call_gUdJGH0qrz2sSOYlTt7RX89S","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","offset":1,"limit":1200},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Mutation Ledger\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Append-only audit trail for all memory mutations\n6: // SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\n7: import { createHash } from 'crypto';\n8: import type Database from 'better-sqlite3';\n9: import { runInTransaction } from './transaction-manager.js';\n10: \n11: /* ───────────────────────────────────────────────────────────────\n12:    1. TYPES\n13: ----------------------------------------------------------------*/\n14: \n15: type MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n16: \n17: interface MutationLedgerEntry {\n18:   id: number;\n19:   timestamp: string;\n20:   mutation_type: MutationType;\n21:   reason: string;\n22:   prior_hash: string | null;\n23:   new_hash: string;\n24:   linked_memory_ids: string; // JSON array\n25:   decision_meta: string;     // JSON object\n26:   actor: string;\n27:   session_id: string | null;\n28: }\n29: \n30: interface AppendEntryInput {\n31:   mutation_type: MutationType;\n32:   reason: string;\n33:   prior_hash: string | null;\n34:   new_hash: string;\n35:   linked_memory_ids: number[];\n36:   decision_meta: Record<string, unknown>;\n37:   actor: string;\n38:   session_id?: string | null;\n39: }\n40: \n41: interface GetEntriesOptions {\n42:   mutation_type?: MutationType;\n43:   actor?: string;\n44:   session_id?: string;\n45:   since?: string;    // ISO timestamp\n46:   until?: string;    // ISO timestamp\n47:   limit?: number;\n48:   offset?: number;\n49: }\n50: \n51: interface DivergenceReconcilePolicy {\n52:   normalizedPath: string;\n53:   attemptsSoFar: number;\n54:   nextAttempt: number;\n55:   maxRetries: number;\n56:   shouldRetry: boolean;\n57:   exhausted: boolean;\n58: }\n59: \n60: interface DivergenceEscalationPayload {\n61:   code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED';\n62:   normalizedPath: string;\n63:   attempts: number;\n64:   maxRetries: number;\n65:   recommendation: 'manual_triage_required';\n66:   reason: string;\n67:   variants: string[];\n68: }\n69: \n70: interface RecordDivergenceReconcileInput {\n71:   normalizedPath: string;\n72:   variants?: string[];\n73:   actor?: string;\n74:   session_id?: string | null;\n75:   maxRetries?: number;\n76: }\n77: \n78: interface RecordDivergenceReconcileResult {\n79:   policy: DivergenceReconcilePolicy;\n80:   retryEntryId: number | null;\n81:   escalationEntryId: number | null;\n82:   escalation: DivergenceEscalationPayload | null;\n83: }\n84: \n85: /* ───────────────────────────────────────────────────────────────\n86:    2. SCHEMA SQL\n87: ----------------------------------------------------------------*/\n88: \n89: const LEDGER_SCHEMA_SQL = `\n90:   CREATE TABLE IF NOT EXISTS mutation_ledger (\n91:     id INTEGER PRIMARY KEY AUTOINCREMENT,\n92:     timestamp TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),\n93:     mutation_type TEXT NOT NULL CHECK(mutation_type IN ('create','update','delete','merge','archive','restore','reindex')),\n94:     reason TEXT NOT NULL,\n95:     prior_hash TEXT,\n96:     new_hash TEXT NOT NULL,\n97:     linked_memory_ids TEXT NOT NULL DEFAULT '[]',\n98:     decision_meta TEXT NOT NULL DEFAULT '{}',\n99:     actor TEXT NOT NULL,\n100:     session_id TEXT\n101:   )\n102: `;\n103: \n104: const LEDGER_INDEX_SQL = `\n105:   CREATE INDEX IF NOT EXISTS idx_ledger_type ON mutation_ledger(mutation_type);\n106:   CREATE INDEX IF NOT EXISTS idx_ledger_actor ON mutation_ledger(actor);\n107:   CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON mutation_ledger(timestamp);\n108:   CREATE INDEX IF NOT EXISTS idx_ledger_session ON mutation_ledger(session_id);\n109:   CREATE INDEX IF NOT EXISTS idx_ledger_memory_type_created_at ON mutation_ledger(\n110:     CAST(json_extract(linked_memory_ids, '$[0]') AS INTEGER),\n111:     mutation_type,\n112:     timestamp\n113:   )\n114: `;\n115: \n116: const LEDGER_TRIGGER_SQL = `\n117:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n118:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n119:   CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n120:   BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n121: `;\n122: \n123: /* ───────────────────────────────────────────────────────────────\n124:    3. INITIALIZATION\n125: ----------------------------------------------------------------*/\n126: \n127: function initLedger(db: Database.Database): void {\n128:   db.exec(LEDGER_SCHEMA_SQL);\n129:   db.exec(LEDGER_INDEX_SQL);\n130:   db.exec(LEDGER_TRIGGER_SQL);\n131: }\n132: \n133: /* ───────────────────────────────────────────────────────────────\n134:    4. HASH COMPUTATION\n135: ----------------------------------------------------------------*/\n136: \n137: function computeHash(content: string): string {\n138:   return createHash('sha256').update(content, 'utf8').digest('hex');\n139: }\n140: \n141: /* ───────────────────────────────────────────────────────────────\n142:    5. APPEND ENTRY\n143: ----------------------------------------------------------------*/\n144: \n145: function appendEntry(db: Database.Database, entry: AppendEntryInput): MutationLedgerEntry {\n146:   const linkedJson = JSON.stringify(entry.linked_memory_ids);\n147:   const metaJson = JSON.stringify(entry.decision_meta);\n148: \n149:   const stmt = db.prepare(`\n150:     INSERT INTO mutation_ledger (mutation_type, reason, prior_hash, new_hash, linked_memory_ids, decision_meta, actor, session_id)\n151:     VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n152:   `);\n153: \n154:   const result = stmt.run(\n155:     entry.mutation_type,\n156:     entry.reason,\n157:     entry.prior_hash,\n158:     entry.new_hash,\n159:     linkedJson,\n160:     metaJson,\n161:     entry.actor,\n162:     entry.session_id ?? null\n163:   );\n164: \n165:   const id = (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n166: \n167:   const row = db.prepare('SELECT * FROM mutation_ledger WHERE id = ?').get(id) as MutationLedgerEntry;\n168:   return row;\n169: }\n170: \n171: /* ───────────────────────────────────────────────────────────────\n172:    6. QUERY ENTRIES\n173: ----------------------------------------------------------------*/\n174: \n175: function getEntries(db: Database.Database, opts: GetEntriesOptions = {}): MutationLedgerEntry[] {\n176:   const conditions: string[] = [];\n177:   const params: Array<string | number> = [];\n178: \n179:   if (opts.mutation_type) {\n180:     conditions.push('mutation_type = ?');\n181:     params.push(opts.mutation_type);\n182:   }\n183:   if (opts.actor) {\n184:     conditions.push('actor = ?');\n185:     params.push(opts.actor);\n186:   }\n187:   if (opts.session_id) {\n188:     conditions.push('session_id = ?');\n189:     params.push(opts.session_id);\n190:   }\n191:   if (opts.since) {\n192:     conditions.push('timestamp >= ?');\n193:     params.push(opts.since);\n194:   }\n195:   if (opts.until) {\n196:     conditions.push('timestamp <= ?');\n197:     params.push(opts.until);\n198:   }\n199: \n200:   const where = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';\n201:   // String interpolation in LIMIT/OFFSET is safe here because both values\n202:   // Are coerced to non-negative integers via Math.floor + Math.max before use —\n203:   // Math.floor guarantees no decimal component, Math.max(1,…)/Math.max(0,…)\n204:   // Guarantees no negative value. No user-supplied string reaches the SQL directly.\n205:   const limit = opts.limit ? `LIMIT ${Math.max(1, Math.floor(opts.limit))}` : '';\n206:   // OFFSET without LIMIT is invalid SQLite syntax.\n207:   // When offset is set but limit is not, emit LIMIT -1 (all rows) before OFFSET.\n208:   const offset = opts.offset ? `OFFSET ${Math.max(0, Math.floor(opts.offset))}` : '';\n209:   const effectiveLimit = !limit && offset ? 'LIMIT -1' : limit;\n210: \n211:   // String interpolation constructs IN(?,?,?) placeholder list only —\n212:   // All user values are parameterized. Accepted exception per audit H-08.\n213:   const sql = `SELECT * FROM mutation_ledger ${where} ORDER BY id ASC ${effectiveLimit} ${offset}`;\n214:   return db.prepare(sql).all(...params) as MutationLedgerEntry[];\n215: }\n216: \n217: function getEntryCount(db: Database.Database): number {\n218:   const row = db.prepare('SELECT COUNT(*) as count FROM mutation_ledger').get() as { count: number };\n219:   return row.count;\n220: }\n221: \n222: /* ───────────────────────────────────────────────────────────────\n223:    7. LINKED ENTRIES LOOKUP\n224: ----------------------------------------------------------------*/\n225: \n226: function getLinkedEntries(db: Database.Database, memoryId: number): MutationLedgerEntry[] {\n227:   // SQLite json_each can expand JSON arrays for matching\n228:   const sql = `\n229:     SELECT ml.* FROM mutation_ledger ml, json_each(ml.linked_memory_ids) je\n230:     WHERE je.value = ?\n231:     ORDER BY ml.id ASC\n232:   `;\n233:   return db.prepare(sql).all(memoryId) as MutationLedgerEntry[];\n234: }\n235: \n236: /* ───────────────────────────────────────────────────────────────\n237:    8. APPEND-ONLY VERIFICATION\n238: ----------------------------------------------------------------*/\n239: \n240: /**\n241:  * Verify that append-only triggers exist on the mutation_ledger table.\n242:  * Returns true if both UPDATE and DELETE triggers are present.\n243:  */\n244: function verifyAppendOnly(db: Database.Database): boolean {\n245:   const triggers = db.prepare(\n246:     \"SELECT name FROM sqlite_master WHERE type = 'trigger' AND tbl_name = 'mutation_ledger'\"\n247:   ).all() as Array<{ name: string }>;\n248: \n249:   const names = triggers.map(t => t.name);\n250:   return names.includes('prevent_ledger_update') && names.includes('prevent_ledger_delete');\n251: }\n252: \n253: /* ───────────────────────────────────────────────────────────────\n254:    9. DIVERGENCE RETRY + ESCALATION HOOKS\n255: ----------------------------------------------------------------*/\n256: \n257: const DEFAULT_DIVERGENCE_RECONCILE_MAX_RETRIES = 3;\n258: const DIVERGENCE_RECONCILE_REASON = 'alias_divergence_auto_reconcile';\n259: const DIVERGENCE_RECONCILE_ESCALATION_REASON = 'alias_divergence_auto_reconcile_escalated';\n260: const DIVERGENCE_RECONCILE_ACTOR = 'memory-index-scan';\n261: \n262: function normalizeMaxRetries(maxRetries?: number): number {\n263:   if (!Number.isFinite(maxRetries) || (maxRetries ?? 0) < 1) {\n264:     return DEFAULT_DIVERGENCE_RECONCILE_MAX_RETRIES;\n265:   }\n266:   return Math.max(1, Math.floor(maxRetries as number));\n267: }\n268: \n269: function normalizePath(value: string): string {\n270:   return value.trim().replace(/\\\\/g, '/');\n271: }\n272: \n273: function normalizeVariants(variants?: string[]): string[] {\n274:   if (!Array.isArray(variants)) {\n275:     return [];\n276:   }\n277: \n278:   const unique = new Set<string>();\n279:   for (const variant of variants) {\n280:     if (typeof variant !== 'string' || variant.trim().length === 0) {\n281:       continue;\n282:     }\n283:     unique.add(normalizePath(variant));\n284:   }\n285:   return Array.from(unique).sort((a, b) => a.localeCompare(b));\n286: }\n287: \n288: function getDivergenceReconcileAttemptCount(db: Database.Database, normalizedPath: string): number {\n289:   const targetPath = normalizePath(normalizedPath);\n290:   if (targetPath.length === 0) {\n291:     return 0;\n292:   }\n293: \n294:   // Use COUNT(*) with json_extract to filter by path in SQL rather than scanning\n295:   // All decision_meta rows in application code (O(1) vs O(n) full-table scan).\n296:   const row = db.prepare(`\n297:     SELECT COUNT(*) AS cnt\n298:     FROM mutation_ledger\n299:     WHERE mutation_type = 'reindex'\n300:       AND reason = ?\n301:       AND json_extract(decision_meta, '$.normalizedPath') = ?\n302:   `).get(DIVERGENCE_RECONCILE_REASON, targetPath) as { cnt: number } | undefined;\n303: \n304:   return row?.cnt ?? 0;\n305: }\n306: \n307: function hasDivergenceEscalationEntry(db: Database.Database, normalizedPath: string): boolean {\n308:   const targetPath = normalizePath(normalizedPath);\n309:   if (targetPath.length === 0) {\n310:     return false;\n311:   }\n312: \n313:   // Use COUNT(*) with json_extract to avoid O(n) full-table scan in application code.\n314:   const row = db.prepare(`\n315:     SELECT COUNT(*) AS cnt\n316:     FROM mutation_ledger\n317:     WHERE mutation_type = 'reindex'\n318:       AND reason = ?\n319:       AND json_extract(decision_meta, '$.normalizedPath') = ?\n320:   `).get(DIVERGENCE_RECONCILE_ESCALATION_REASON, targetPath) as { cnt: number } | undefined;\n321: \n322:   return (row?.cnt ?? 0) > 0;\n323: }\n324: \n325: function buildDivergenceReconcilePolicy(\n326:   normalizedPath: string,\n327:   attemptsSoFar: number,\n328:   maxRetries: number = DEFAULT_DIVERGENCE_RECONCILE_MAX_RETRIES\n329: ): DivergenceReconcilePolicy {\n330:   const boundedMaxRetries = normalizeMaxRetries(maxRetries);\n331:   const safeAttempts = Math.max(0, Math.floor(attemptsSoFar));\n332:   const nextAttempt = safeAttempts + 1;\n333:   const shouldRetry = safeAttempts < boundedMaxRetries;\n334: \n335:   return {\n336:     normalizedPath: normalizePath(normalizedPath),\n337:     attemptsSoFar: safeAttempts,\n338:     nextAttempt,\n339:     maxRetries: boundedMaxRetries,\n340:     shouldRetry,\n341:     exhausted: !shouldRetry,\n342:   };\n343: }\n344: \n345: function buildDivergenceEscalationPayload(\n346:   policy: DivergenceReconcilePolicy,\n347:   variants: string[]\n348: ): DivergenceEscalationPayload {\n349:   return {\n350:     code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED',\n351:     normalizedPath: policy.normalizedPath,\n352:     attempts: policy.attemptsSoFar,\n353:     maxRetries: policy.maxRetries,\n354:     recommendation: 'manual_triage_required',\n355:     reason: `Auto-reconcile exhausted after ${policy.maxRetries} attempt(s)`,\n356:     variants: normalizeVariants(variants),\n357:   };\n358: }\n359: \n360: function recordDivergenceReconcileHook(\n361:   db: Database.Database,\n362:   input: RecordDivergenceReconcileInput\n363: ): RecordDivergenceReconcileResult {\n364:   initLedger(db);\n365: \n366:   const normalizedPath = normalizePath(input.normalizedPath);\n367:   if (normalizedPath.length === 0) {\n368:     throw new Error('normalizedPath is required for divergence reconciliation');\n369:   }\n370: \n371:   const maxRetries = normalizeMaxRetries(input.maxRetries);\n372:   const actor = input.actor ?? DIVERGENCE_RECONCILE_ACTOR;\n373:   const variants = normalizeVariants(input.variants);\n374: \n375:   return runInTransaction(db, () => {\n376:     const attemptsSoFar = getDivergenceReconcileAttemptCount(db, normalizedPath);\n377:     const policy = buildDivergenceReconcilePolicy(normalizedPath, attemptsSoFar, maxRetries);\n378: \n379:     if (policy.shouldRetry) {\n380:       const retryEntry = appendEntry(db, {\n381:         mutation_type: 'reindex',\n382:         reason: DIVERGENCE_RECONCILE_REASON,\n383:         prior_hash: null,\n384:         new_hash: computeHash(`${normalizedPath}|attempt:${policy.nextAttempt}|max:${policy.maxRetries}`),\n385:         linked_memory_ids: [],\n386:         decision_meta: {\n387:           normalizedPath,\n388:           attempt: policy.nextAttempt,\n389:           maxRetries: policy.maxRetries,\n390:           boundedRetry: true,\n391:           status: 'retry_scheduled',\n392:           variants,\n393:         },\n394:         actor,\n395:         session_id: input.session_id ?? null,\n396:       });\n397: \n398:       return {\n399:         policy,\n400:         retryEntryId: retryEntry.id,\n401:         escalationEntryId: null,\n402:         escalation: null,\n403:       };\n404:     }\n405: \n406:     const escalation = buildDivergenceEscalationPayload(policy, variants);\n407:     if (hasDivergenceEscalationEntry(db, normalizedPath)) {\n408:       return {\n409:         policy,\n410:         retryEntryId: null,\n411:         escalationEntryId: null,\n412:         escalation,\n413:       };\n414:     }\n415: \n416:     const escalationEntry = appendEntry(db, {\n417:       mutation_type: 'reindex',\n418:       reason: DIVERGENCE_RECONCILE_ESCALATION_REASON,\n419:       prior_hash: null,\n420:       new_hash: computeHash(`${normalizedPath}|escalated|attempts:${policy.attemptsSoFar}|max:${policy.maxRetries}`),\n421:       linked_memory_ids: [],\n422:       decision_meta: {\n423:         normalizedPath,\n424:         attempts: policy.attemptsSoFar,\n425:         maxRetries: policy.maxRetries,\n426:         boundedRetry: true,\n427:         status: 'escalated',\n428:         escalation,\n429:       },\n430:       actor,\n431:       session_id: input.session_id ?? null,\n432:     });\n433: \n434:     return {\n435:       policy,\n436:       retryEntryId: null,\n437:       escalationEntryId: escalationEntry.id,\n438:       escalation,\n439:     };\n440:   });\n441: }\n442: \n443: /* ───────────────────────────────────────────────────────────────\n444:    10. EXPORTS\n445: ----------------------------------------------------------------*/\n446: \n447: export {\n448:   LEDGER_SCHEMA_SQL,\n449:   LEDGER_INDEX_SQL,\n450:   LEDGER_TRIGGER_SQL,\n451: \n452:   initLedger,\n453:   computeHash,\n454:   appendEntry,\n455:   getEntries,\n456:   getEntryCount,\n457:   getLinkedEntries,\n458:   verifyAppendOnly,\n459:   DEFAULT_DIVERGENCE_RECONCILE_MAX_RETRIES,\n460:   DIVERGENCE_RECONCILE_REASON,\n461:   DIVERGENCE_RECONCILE_ESCALATION_REASON,\n462:   getDivergenceReconcileAttemptCount,\n463:   buildDivergenceReconcilePolicy,\n464:   buildDivergenceEscalationPayload,\n465:   recordDivergenceReconcileHook,\n466: };\n467: \n468: /**\n469:  * Re-exports related public types.\n470:  */\n471: export type {\n472:   MutationType,\n473:   MutationLedgerEntry,\n474:   AppendEntryInput,\n475:   GetEntriesOptions,\n476:   DivergenceReconcilePolicy,\n477:   DivergenceEscalationPayload,\n478:   RecordDivergenceReconcileInput,\n479:   RecordDivergenceReconcileResult,\n480: };\n\n(End of file - total 480 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Append-only audit trail for all memory mutations\n// SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\nimport { createHash } from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\ntype MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n\ninterface MutationLedgerEntry {\n  id: number;\n  timestamp: string;\n  mutation_type: MutationType;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/mutation-ledger.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Mutation Ledger\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Append-only audit trail for all memory mutations\n// SQLite triggers enforce immutability (no UPDATE/DELETE on ledger)\nimport { createHash } from 'crypto';\nimport type Database from 'better-sqlite3';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. TYPES\n----------------------------------------------------------------*/\n\ntype MutationType = 'create' | 'update' | 'delete' | 'merge' | 'archive' | 'restore' | 'reindex';\n\ninterface MutationLedgerEntry {\n  id: number;\n  timestamp: string;\n  mutation_type: MutationType;\n  reason: string;\n  prior_hash: string | null;\n  new_hash: string;\n  linked_memory_ids: string; // JSON array\n  decision_meta: string;     // JSON object\n  actor: string;\n  session_id: string | null;\n}\n\ninterface AppendEntryInput {\n  mutation_type: MutationType;\n  reason: string;\n  prior_hash: string | null;\n  new_hash: string;\n  linked_memory_ids: number[];\n  decision_meta: Record<string, unknown>;\n  actor: string;\n  session_id?: string | null;\n}\n\ninterface GetEntriesOptions {\n  mutation_type?: MutationType;\n  actor?: string;\n  session_id?: string;\n  since?: string;    // ISO timestamp\n  until?: string;    // ISO timestamp\n  limit?: number;\n  offset?: number;\n}\n\ninterface DivergenceReconcilePolicy {\n  normalizedPath: string;\n  attemptsSoFar: number;\n  nextAttempt: number;\n  maxRetries: number;\n  shouldRetry: boolean;\n  exhausted: boolean;\n}\n\ninterface DivergenceEscalationPayload {\n  code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED';\n  normalizedPath: string;\n  attempts: number;\n  maxRetries: number;\n  recommendation: 'manual_triage_required';\n  reason: string;\n  variants: string[];\n}\n\ninterface RecordDivergenceReconcileInput {\n  normalizedPath: string;\n  variants?: string[];\n  actor?: string;\n  session_id?: string | null;\n  maxRetries?: number;\n}\n\ninterface RecordDivergenceReconcileResult {\n  policy: DivergenceReconcilePolicy;\n  retryEntryId: number | null;\n  escalationEntryId: number | null;\n  escalation: DivergenceEscalationPayload | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. SCHEMA SQL\n----------------------------------------------------------------*/\n\nconst LEDGER_SCHEMA_SQL = `\n  CREATE TABLE IF NOT EXISTS mutation_ledger (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    timestamp TEXT NOT NULL DEFAULT (strftime('%Y-%m-%dT%H:%M:%fZ', 'now')),\n    mutation_type TEXT NOT NULL CHECK(mutation_type IN ('create','update','delete','merge','archive','restore','reindex')),\n    reason TEXT NOT NULL,\n    prior_hash TEXT,\n    new_hash TEXT NOT NULL,\n    linked_memory_ids TEXT NOT NULL DEFAULT '[]',\n    decision_meta TEXT NOT NULL DEFAULT '{}',\n    actor TEXT NOT NULL,\n    session_id TEXT\n  )\n`;\n\nconst LEDGER_INDEX_SQL = `\n  CREATE INDEX IF NOT EXISTS idx_ledger_type ON mutation_ledger(mutation_type);\n  CREATE INDEX IF NOT EXISTS idx_ledger_actor ON mutation_ledger(actor);\n  CREATE INDEX IF NOT EXISTS idx_ledger_timestamp ON mutation_ledger(timestamp);\n  CREATE INDEX IF NOT EXISTS idx_ledger_session ON mutation_ledger(session_id);\n  CREATE INDEX IF NOT EXISTS idx_ledger_memory_type_created_at ON mutation_ledger(\n    CAST(json_extract(linked_memory_ids, '$[0]') AS INTEGER),\n    mutation_type,\n    timestamp\n  )\n`;\n\nconst LEDGER_TRIGGER_SQL = `\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_update BEFORE UPDATE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END;\n  CREATE TRIGGER IF NOT EXISTS prevent_ledger_delete BEFORE DELETE ON mutation_ledger\n  BEGIN SELECT RAISE(ABORT, 'mutation_ledger is append-only'); END\n`;\n\n/* ───────────────────────────────────────────────────────────────\n   3. INITIALIZATION\n----------------------------------------------------------------*/\n\nfunction initLedger(db: Database.Database): void {\n  db.exec(LEDGER_SCHEMA_SQL);\n  db.exec(LEDGER_INDEX_SQL);\n  db.exec(LEDGER_TRIGGER_SQL);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HASH COMPUTATION\n----------------------------------------------------------------*/\n\nfunction computeHash(content: string): string {\n  return createHash('sha256').update(content, 'utf8').digest('hex');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. APPEND ENTRY\n----------------------------------------------------------------*/\n\nfunction appendEntry(db: Database.Database, entry: AppendEntryInput): MutationLedgerEntry {\n  const linkedJson = JSON.stringify(entry.linked_memory_ids);\n  const metaJson = JSON.stringify(entry.decision_meta);\n\n  const stmt = db.prepare(`\n    INSERT INTO mutation_ledger (mutation_type, reason, prior_hash, new_hash, linked_memory_ids, decision_meta, actor, session_id)\n    VALUES (?, ?, ?, ?, ?, ?, ?, ?)\n  `);\n\n  const result = stmt.run(\n    entry.mutation_type,\n    entry.reason,\n    entry.prior_hash,\n    entry.new_hash,\n    linkedJson,\n    metaJson,\n    entry.actor,\n    entry.session_id ?? null\n  );\n\n  const id = (result as { lastInsertRowid: number | bigint }).lastInsertRowid as number;\n\n  const row = db.prepare('SELECT * FROM mutation_ledger WHERE id = ?').get(id) as MutationLedgerEntry;\n  return row;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. QUERY ENTRIES\n----------------------------------------------------------------*/\n\nfunction getEntries(db: Database.Database, opts: GetEntriesOptions = {}): MutationLedgerEntry[] {\n  const conditions: string[] = [];\n  const params: Array<string | number> = [];\n\n  if (opts.mutation_type) {\n    conditions.push('mutation_type = ?');\n    params.push(opts.mutation_type);\n  }\n  if (opts.actor) {\n    conditions.push('actor = ?');\n    params.push(opts.actor);\n  }\n  if (opts.session_id) {\n    conditions.push('session_id = ?');\n    params.push(opts.session_id);\n  }\n  if (opts.since) {\n    conditions.push('timestamp >= ?');\n    params.push(opts.since);\n  }\n  if (opts.until) {\n    conditions.push('timestamp <= ?');\n    params.push(opts.until);\n  }\n\n  const where = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';\n  // String interpolation in LIMIT/OFFSET is safe here because both values\n  // Are coerced to non-negative integers via Math.floor + Math.max before use —\n  // Math.floor guarantees no decimal component, Math.max(1,…)/Math.max(0,…)\n  // Guarantees no negative value. No user-supplied string reaches the SQL directly.\n  const limit = opts.limit ? `LIMIT ${Math.max(1, Math.floor(opts.limit))}` : '';\n  // OFFSET without LIMIT is invalid SQLite syntax.\n  // When offset is set but limit is not, emit LIMIT -1 (all rows) before OFFSET.\n  const offset = opts.offset ? `OFFSET ${Math.max(0, Math.floor(opts.offset))}` : '';\n  const effectiveLimit = !limit && offset ? 'LIMIT -1' : limit;\n\n  // String interpolation constructs IN(?,?,?) placeholder list only —\n  // All user values are parameterized. Accepted exception per audit H-08.\n  const sql = `SELECT * FROM mutation_ledger ${where} ORDER BY id ASC ${effectiveLimit} ${offset}`;\n  return db.prepare(sql).all(...params) as MutationLedgerEntry[];\n}\n\nfunction getEntryCount(db: Database.Database): number {\n  const row = db.prepare('SELECT COUNT(*) as count FROM mutation_ledger').get() as { count: number };\n  return row.count;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. LINKED ENTRIES LOOKUP\n----------------------------------------------------------------*/\n\nfunction getLinkedEntries(db: Database.Database, memoryId: number): MutationLedgerEntry[] {\n  // SQLite json_each can expand JSON arrays for matching\n  const sql = `\n    SELECT ml.* FROM mutation_ledger ml, json_each(ml.linked_memory_ids) je\n    WHERE je.value = ?\n    ORDER BY ml.id ASC\n  `;\n  return db.prepare(sql).all(memoryId) as MutationLedgerEntry[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. APPEND-ONLY VERIFICATION\n----------------------------------------------------------------*/\n\n/**\n * Verify that append-only triggers exist on the mutation_ledger table.\n * Returns true if both UPDATE and DELETE triggers are present.\n */\nfunction verifyAppendOnly(db: Database.Database): boolean {\n  const triggers = db.prepare(\n    \"SELECT name FROM sqlite_master WHERE type = 'trigger' AND tbl_name = 'mutation_ledger'\"\n  ).all() as Array<{ name: string }>;\n\n  const names = triggers.map(t => t.name);\n  return names.includes('prevent_ledger_update') && names.includes('prevent_ledger_delete');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. DIVERGENCE RETRY + ESCALATION HOOKS\n----------------------------------------------------------------*/\n\nconst DEFAULT_DIVERGENCE_RECONCILE_MAX_RETRIES = 3;\nconst DIVERGENCE_RECONCILE_REASON = 'alias_divergence_auto_reconcile';\nconst DIVERGENCE_RECONCILE_ESCALATION_REASON = 'alias_divergence_auto_reconcile_escalated';\nconst DIVERGENCE_RECONCILE_ACTOR = 'memory-index-scan';\n\nfunction normalizeMaxRetries(maxRetries?: number): number {\n  if (!Number.isFinite(maxRetries) || (maxRetries ?? 0) < 1) {\n    return DEFAULT_DIVERGENCE_RECONCILE_MAX_RETRIES;\n  }\n  return Math.max(1, Math.floor(maxRetries as number));\n}\n\nfunction normalizePath(value: string): string {\n  return value.trim().replace(/\\\\/g, '/');\n}\n\nfunction normalizeVariants(variants?: string[]): string[] {\n  if (!Array.isArray(variants)) {\n    return [];\n  }\n\n  const unique = new Set<string>();\n  for (const variant of variants) {\n    if (typeof variant !== 'string' || variant.trim().length === 0) {\n      continue;\n    }\n    unique.add(normalizePath(variant));\n  }\n  return Array.from(unique).sort((a, b) => a.localeCompare(b));\n}\n\nfunction getDivergenceReconcileAttemptCount(db: Database.Database, normalizedPath: string): number {\n  const targetPath = normalizePath(normalizedPath);\n  if (targetPath.length === 0) {\n    return 0;\n  }\n\n  // Use COUNT(*) with json_extract to filter by path in SQL rather than scanning\n  // All decision_meta rows in application code (O(1) vs O(n) full-table scan).\n  const row = db.prepare(`\n    SELECT COUNT(*) AS cnt\n    FROM mutation_ledger\n    WHERE mutation_type = 'reindex'\n      AND reason = ?\n      AND json_extract(decision_meta, '$.normalizedPath') = ?\n  `).get(DIVERGENCE_RECONCILE_REASON, targetPath) as { cnt: number } | undefined;\n\n  return row?.cnt ?? 0;\n}\n\nfunction hasDivergenceEscalationEntry(db: Database.Database, normalizedPath: string): boolean {\n  const targetPath = normalizePath(normalizedPath);\n  if (targetPath.length === 0) {\n    return false;\n  }\n\n  // Use COUNT(*) with json_extract to avoid O(n) full-table scan in application code.\n  const row = db.prepare(`\n    SELECT COUNT(*) AS cnt\n    FROM mutation_ledger\n    WHERE mutation_type = 'reindex'\n      AND reason = ?\n      AND json_extract(decision_meta, '$.normalizedPath') = ?\n  `).get(DIVERGENCE_RECONCILE_ESCALATION_REASON, targetPath) as { cnt: number } | undefined;\n\n  return (row?.cnt ?? 0) > 0;\n}\n\nfunction buildDivergenceReconcilePolicy(\n  normalizedPath: string,\n  attemptsSoFar: number,\n  maxRetries: number = DEFAULT_DIVERGENCE_RECONCILE_MAX_RETRIES\n): DivergenceReconcilePolicy {\n  const boundedMaxRetries = normalizeMaxRetries(maxRetries);\n  const safeAttempts = Math.max(0, Math.floor(attemptsSoFar));\n  const nextAttempt = safeAttempts + 1;\n  const shouldRetry = safeAttempts < boundedMaxRetries;\n\n  return {\n    normalizedPath: normalizePath(normalizedPath),\n    attemptsSoFar: safeAttempts,\n    nextAttempt,\n    maxRetries: boundedMaxRetries,\n    shouldRetry,\n    exhausted: !shouldRetry,\n  };\n}\n\nfunction buildDivergenceEscalationPayload(\n  policy: DivergenceReconcilePolicy,\n  variants: string[]\n): DivergenceEscalationPayload {\n  return {\n    code: 'E_DIVERGENCE_RECONCILE_RETRY_EXHAUSTED',\n    normalizedPath: policy.normalizedPath,\n    attempts: policy.attemptsSoFar,\n    maxRetries: policy.maxRetries,\n    recommendation: 'manual_triage_required',\n    reason: `Auto-reconcile exhausted after ${policy.maxRetries} attempt(s)`,\n    variants: normalizeVariants(variants),\n  };\n}\n\nfunction recordDivergenceReconcileHook(\n  db: Database.Database,\n  input: RecordDivergenceReconcileInput\n): RecordDivergenceReconcileResult {\n  initLedger(db);\n\n  const normalizedPath = normalizePath(input.normalizedPath);\n  if (normalizedPath.length === 0) {\n    throw new Error('normalizedPath is required for divergence reconciliation');\n  }\n\n  const maxRetries = normalizeMaxRetries(input.maxRetries);\n  const actor = input.actor ?? DIVERGENCE_RECONCILE_ACTOR;\n  const variants = normalizeVariants(input.variants);\n\n  return runInTransaction(db, () => {\n    const attemptsSoFar = getDivergenceReconcileAttemptCount(db, normalizedPath);\n    const policy = buildDivergenceReconcilePolicy(normalizedPath, attemptsSoFar, maxRetries);\n\n    if (policy.shouldRetry) {\n      const retryEntry = appendEntry(db, {\n        mutation_type: 'reindex',\n        reason: DIVERGENCE_RECONCILE_REASON,\n        prior_hash: null,\n        new_hash: computeHash(`${normalizedPath}|attempt:${policy.nextAttempt}|max:${policy.maxRetries}`),\n        linked_memory_ids: [],\n        decision_meta: {\n          normalizedPath,\n          attempt: policy.nextAttempt,\n          maxRetries: policy.maxRetries,\n          boundedRetry: true,\n          status: 'retry_scheduled',\n          variants,\n        },\n        actor,\n        session_id: input.session_id ?? null,\n      });\n\n      return {\n        policy,\n        retryEntryId: retryEntry.id,\n        escalationEntryId: null,\n        escalation: null,\n      };\n    }\n\n    const escalation = buildDivergenceEscalationPayload(policy, variants);\n    if (hasDivergenceEscalationEntry(db, normalizedPath)) {\n      return {\n        policy,\n        retryEntryId: null,\n        escalationEntryId: null,\n        escalation,\n      };\n    }\n\n    const escalationEntry = appendEntry(db, {\n      mutation_type: 'reindex',\n      reason: DIVERGENCE_RECONCILE_ESCALATION_REASON,\n      prior_hash: null,\n      new_hash: computeHash(`${normalizedPath}|escalated|attempts:${policy.attemptsSoFar}|max:${policy.maxRetries}`),\n      linked_memory_ids: [],\n      decision_meta: {\n        normalizedPath,\n        attempts: policy.attemptsSoFar,\n        maxRetries: policy.maxRetries,\n        boundedRetry: true,\n        status: 'escalated',\n        escalation,\n      },\n      actor,\n      session_id: input.session_id ?? null,\n    });\n\n    return {\n      policy,\n      retryEntryId: null,\n      escalationEntryId: escalationEntry.id,\n      escalation,\n    };\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   10. EXPORTS\n----------------------------------------------------------------*/\n\nexport {\n  LEDGER_SCHEMA_SQL,\n  LEDGER_INDEX_SQL,\n  LEDGER_TRIGGER_SQL,\n\n  initLedger,\n  computeHash,\n  appendEntry,\n  getEntries,\n  getEntryCount,\n  getLinkedEntries,\n  verifyAppendOnly,\n  DEFAULT_DIVERGENCE_RECONCILE_MAX_RETRIES,\n  DIVERGENCE_RECONCILE_REASON,\n  DIVERGENCE_RECONCILE_ESCALATION_REASON,\n  getDivergenceReconcileAttemptCount,\n  buildDivergenceReconcilePolicy,\n  buildDivergenceEscalationPayload,\n  recordDivergenceReconcileHook,\n};\n\n/**\n * Re-exports related public types.\n */\nexport type {\n  MutationType,\n  MutationLedgerEntry,\n  AppendEntryInput,\n  GetEntriesOptio