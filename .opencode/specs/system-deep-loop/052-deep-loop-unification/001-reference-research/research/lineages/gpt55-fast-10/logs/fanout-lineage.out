"explicit_author\",\n              \"feature\": \"scorer_signal\"\n            },\n            {\n              \"lane\": \"derived_generated\",\n              \"feature\": \"derived_skill_signal\"\n            },\n            {\n              \"lane\": \"lexical\",\n              \"feature\": \"token_match\"\n            },\n            {\n              \"lane\": \"semantic_shadow\",\n              \"feature\": \"semantic_similarity\"\n            }\n          ]\n        },\n        \"status\": \"active\"\n      }\n    ],\n    \"ambiguous\": false,\n    \"freshness\": \"live\",\n    \"trustState\": {\n      \"state\": \"live\",\n      \"reason\": null,\n      \"generation\": 10321,\n      \"checkedAt\": \"2026-07-08T05:47:27.225Z\",\n      \"lastLiveAt\": \"2026-07-08T05:44:37.660Z\"\n    },\n    \"generatedAt\": \"2026-07-08T05:47:27.602Z\",\n    \"cache\": {\n      \"hit\": false,\n      \"sourceSignaturePresent\": true\n    },\n    \"_shadow\": {\n      \"model\": \"advisor-shadow-learned-weights-v1\",\n      \"liveWeightsFrozen\": true,\n      \"recommendations\": [\n        {\n          \"skillId\": \"deep-loop-workflows\",\n          \"liveScore\": 0.737827,\n          \"shadowScore\": 0.719162,\n          \"delta\": -0.018665,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"sk-git\",\n          \"liveScore\": 0.604119,\n          \"shadowScore\": 0.574244,\n          \"delta\": -0.029875,\n          \"dominantShadowLane\": \"explicit_author\"\n        },\n        {\n          \"skillId\": \"system-spec-kit\",\n          \"liveScore\": 0.508143,\n          \"shadowScore\": 0.554678,\n          \"delta\": 0.046535,\n          \"dominantShadowLane\": \"explicit_author\"\n        }\n      ]\n    }\n  }\n}","metadata":{"truncated":false},"title":"","time":{"start":1783489646966,"end":1783489647607}},"metadata":{"openai":{"itemId":"fc_0422534393d3eb51016a4de46d17b481909295c7710db3b795"}},"id":"prt_f40444a69001AfKntUyIMEqo5D","sessionID":"ses_0bfc4afb7ffeA8X2g5OnaG20YL","messageID":"msg_f40444000001j2ZzP8ItjZBFyM"}}
