     1	#!/usr/bin/env node
     2	'use strict';
     3	
     4	// Runtime compiled-route engine.
     5	//
     6	// Routes a prompt through a hub's compiled policy using the same proven closed
     7	// decision algebra the shadow canary validates (evaluateCanary over the hub's
     8	// snapshot). The engine routes WITHIN a hub — it selects compiled destinations
     9	// (modes/surfaces) when the prompt carries the policy's detector signals, and
    10	// otherwise returns a `defer` decision (the correct conservative outcome), so a
    11	// caller can fall back to legacy routing on ambiguous input.
    12	//
    13	// This module is pure and side-effect-free: it never flips serving authority
    14	// and never edits a manifest. Whether its result is authoritative is decided by
    15	// the resolver, which gates on the activation manifest and a runtime flag.
    16	
    17	const fs = require('fs');
    18	const path = require('path');
    19	
    20	// Each hub's compiled policy + engine live in its shadow rollout child; this
    21	// phase reuses them read-only rather than duplicating the compiled contract.
    22	const IMPL_ROOT = path.resolve(__dirname, '..', '..');
    23	const HUB_CHILD = Object.freeze({
    24	  'sk-code': '006-parent-hub-rollout/001-sk-code',
    25	  'system-deep-loop': '006-parent-hub-rollout/002-system-deep-loop',
    26	  'mcp-tooling': '006-parent-hub-rollout/003-mcp-tooling',
    27	  'cli-external-orchestration': '006-parent-hub-rollout/004-cli-external-orchestration',
    28	  'sk-prompt': '006-parent-hub-rollout/005-sk-prompt',
    29	  'sk-design': '006-parent-hub-rollout/006-sk-design',
    30	  'sk-doc': '006-parent-hub-rollout/007-sk-doc',
    31	});
    32	
    33	const engineCache = new Map();
    34	
    35	function loadHubEngine(hubId) {
    36	  if (engineCache.has(hubId)) return engineCache.get(hubId);
    37	  const child = HUB_CHILD[hubId];
    38	  if (!child) throw new Error(`unknown hub: ${hubId}`);
    39	  const childRoot = path.join(IMPL_ROOT, child);
    40	  // Relative requires inside these modules resolve from their own location, so
    41	  // reusing them from here keeps the compiled contract's dependency graph intact.
    42	  const { loadSnapshot } = require(path.join(childRoot, 'harness', 'build-artifacts.cjs'));
    43	  // Hubs ship one of two engine module shapes: the surfaceBundle canary-router
    44	  // (evaluateCanary) or the plain router (evaluateRoute). Both take
    45	  // (snapshot, input) and return a { decision } — pick whichever this hub has.
    46	  const canaryRouter = path.join(childRoot, 'lib', 'canary-router.cjs');
    47	  const plainRouter = path.join(childRoot, 'lib', 'router.cjs');
    48	  const routerPath = fs.existsSync(canaryRouter) ? canaryRouter
    49	    : (fs.existsSync(plainRouter) ? plainRouter : null);
    50	  if (!routerPath) throw new Error(`no compiled router module for hub ${hubId}`);
    51	  const routerMod = require(routerPath);
    52	  // The export name varies by archetype (evaluateCanary or evaluateRoute); both
    53	  // share the (snapshot, input) -> { decision } contract.
    54	  const evaluate = routerMod.evaluateCanary || routerMod.evaluateRoute;
    55	  if (typeof evaluate !== 'function') {
    56	    throw new Error(`no evaluate function exported by ${routerPath} for hub ${hubId}`);
    57	  }
    58	  const { snapshot } = loadSnapshot();
    59	  const engine = Object.freeze({ snapshot, evaluate });
    60	  engineCache.set(hubId, engine);
    61	  return engine;
    62	}
    63	
    64	function normalizeTargets(route) {
    65	  if (!route || !Array.isArray(route.targets)) return [];
    66	  return route.targets
    67	    .map((t) => t.qualifiedId || t.destinationId || t.skillId || null)
    68	    .filter(Boolean);
    69	}
    70	
    71	// Route `taskText` through hub `hubId`'s compiled contract. Returns a normalized,
    72	// serializable decision; `action` is one of route/clarify/defer/reject.
    73	function compiledRoute(hubId, taskText) {
    74	  const { snapshot, evaluate } = loadHubEngine(hubId);
    75	  const evaluated = evaluate(snapshot, { prompt: taskText });
    76	  const route = evaluated.decision.route || null;
    77	  return {
    78	    hubId,
    79	    action: evaluated.decision.action,
    80	    selectionKind: route ? route.selectionKind : null,
    81	    targets: normalizeTargets(route),
    82	    effectivePolicyHash: snapshot.policy.effectivePolicyHash,
    83	    generation: snapshot.policy.activationGeneration,
    84	  };
    85	}
    86	
    87	module.exports = { compiledRoute, loadHubEngine, HUB_CHILD };

