 as { cancelled?: unknown }).cancelled === true);\n1518:         if (wasCancelled) {\n1519:           // The run itself short-circuited on cancellation. A cancel that arrives\n1520:           // after the scan already finished does not retroactively cancel it.\n1521:           await completeJob(jobId, { state: 'cancelled', result: scanData });\n1522:         } else if (response.isError === true) {\n1523:           // An error envelope (not a thrown error) still means the scan failed.\n1524:           await appendJobError(jobId, '__scan__', scanData);\n1525:           await setJobState(jobId, 'failed');\n1526:         } else {\n1527:           await completeJob(jobId, { state: 'complete', result: scanData });\n1528:         }\n1529:       } catch (error: unknown) {\n1530:         try {\n1531:           await appendJobError(jobId, '__job__', error);\n1532:           await setJobState(jobId, 'failed');\n1533:         } catch (_secondaryError: unknown) {\n1534:           // Best-effort failure record; never surface a background unhandled rejection.\n1535:         }\n1536:       } finally {\n1537:         // Covers every terminal exit (complete / cancelled / failed / thrown).\n1538:         // Release this scan's hold; the marker stays present only while the\n1539:         // background-embedding queue still holds it.\n1540:         maintenance.end();\n1541:       }\n1542:     })();\n1543:   });\n1544: \n1545:   return createMCPSuccessResponse({\n1546:     tool: 'memory_index_scan',\n1547:     summary: `Queued background index scan ${jobId}`,\n1548:     data: { jobId, state: 'queued', background: true },\n1549:     hints: [\n1550:       'Use memory_index_scan_status with jobId to poll progress',\n1551:       'Use memory_index_scan_cancel with jobId to stop the scan',\n1552:     ],\n1553:   });\n1554: }\n1555: \n1556: /* ───────────────────────────────────────────────────────────────\n1557:    9. EXPORTS\n1558: ──────────────────────────────────────────────────────────────── */\n1559: \n\n(Showing lines 1490-1559 of 1587. Use offset=1560 to continue.)\n</content>","metadata":{"preview":"    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","text":"    return runIndexScan(args, {});\n  }\n\n  const jobId = createJobId();\n  await createMaintenanceJob({ id: jobId, kind: 'index_scan', payload: redactScanArgs(args) });\n\n  setImmediate(() => {\n    void (async () => {\n      // Mark the daemon busy-by-design so a competing launcher adopts it rather\n      // than reaping it mid-scan. The shared marker is reference-counted, so the\n      // background-embedding queue draining this scan's deferred embeddings can\n      // keep it held past the scan itself.\n      const maintenance = beginMaintenance('index_scan');\n      try {\n        await setJobState(jobId, 'running');\n        const response = await runIndexScan(args, {\n          isCancelled: () => isCancelRequestedFast(jobId),\n          onPhase: (phase) => {\n            // Refresh at each phase boundary so a long synchronous tail phase (which\n            // cannot fire the interval timer) still enters with a full TTL ahead.\n            maintenance.refresh();\n            void setJobPhase(jobId, phase).catch(() => {});\n          },\n          onProgress: (progress) => { void setJobProgress(jobId, progress).catch(() => {}); },\n        });\n        const scanData = extractEnvelopeData(response);\n        const wasCancelled = !!(scanData && typeof scanData === 'object'\n          && (scanData as { cancelled?: unknown }).cancelled === true);\n        if (wasCancelled) {\n          // The run itself short-circuited on cancellation. A cancel that arrives\n          // after the scan already finished does not retroactively cancel it.\n          await completeJob(jobId, { state: 'cancelled', result: scanData });\n        } else if (response.isError === true) {\n          // An error envelope (not a thrown error) still means the scan failed.\n          await appendJobError(jobId, '__scan__', scanData);\n          await setJobState(jobId, 'failed');\n        } else {\n          await completeJob(jobId, { state: 'complete', result: scanData });\n        }\n      } catch (error: unknown) {\n        try {\n          await appendJobError(jobId, '__job__', error);\n          await setJobState(jobId, 'failed');\n        } catch (_secondaryError: unknown) {\n          // Best-effort failure record; never surface a background unhandled rejection.\n        }\n      } finally {\n        // Covers every terminal exit (complete / cancelled / failed / thrown).\n        // Release this scan's hold; the marker stays present only while the\n        // background-embedding queue still holds it.\n        maintenance.end();\n      }\n    })();\n  });\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan',\n    summary: `Queued background index scan ${jobId}`,\n    data: { jobId, state: 'queued', background: true },\n    hints: [\n      'Use memory_index_scan_status with jobId to poll progress',\n      'Use memory_index_scan_cancel with jobId to stop the scan',\n    ],\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   9. EXPORTS\n──────────────────────────────────────────────────────────────── */\n","lineStart":1490,"lineEnd":1559,"totalLines":1587,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index.ts","time":{"start":1781719616730,"end":1781719616735}},"id":"prt_ed6c3cb0f0012rfqCy2S02vegW","sessionID":"ses_1293d8f54ffeQ6fCU34iXx0Xgl","messageID":"msg_ed6c3c1df001ptQ3V7B51zmkjI"}}
