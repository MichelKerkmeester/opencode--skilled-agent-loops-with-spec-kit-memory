{"type":"tool_use","timestamp":1780738196977,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_Ya33F51XEf7VYopaZP4ENUXN","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/codex/pre-tool-use.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/codex/pre-tool-use.ts</path>\n<type>file</type>\n<content>\n1: #!/usr/bin/env node\n2: // ───────────────────────────────────────────────────────────────\n3: // MODULE: Codex PreToolUse Hook — Bash Deny Policy\n4: // ───────────────────────────────────────────────────────────────\n5: // Codex PreToolUse is intentionally narrow here: only Bash commands can\n6: // be denied, and only when they match starter policy phrases.\n7: \n8: import {\n9:   existsSync,\n10:   readFileSync,\n11: } from 'node:fs';\n12: import { resolve } from 'node:path';\n13: import { fileURLToPath } from 'node:url';\n14: \n15: const IS_CLI_ENTRY = process.argv[1]\n16:   ? resolve(process.argv[1]) === fileURLToPath(import.meta.url)\n17:   : false;\n18: \n19: export interface CodexPreToolUseInput {\n20:   readonly tool?: string;\n21:   readonly tool_name?: string;\n22:   readonly toolName?: string;\n23:   readonly command?: string;\n24:   readonly tool_input?: {\n25:     readonly command?: string;\n26:     readonly [key: string]: unknown;\n27:   };\n28:   readonly toolInput?: {\n29:     readonly command?: string;\n30:     readonly [key: string]: unknown;\n31:   };\n32:   readonly input?: {\n33:     readonly command?: string;\n34:     readonly [key: string]: unknown;\n35:   };\n36:   readonly [key: string]: unknown;\n37: }\n38: \n39: export interface BashDenylistEntry {\n40:   readonly pattern: string;\n41:   readonly reason?: string;\n42: }\n43: \n44: export interface CodexPolicyFile {\n45:   readonly version?: number;\n46:   readonly notes?: string;\n47:   readonly bashDenylist?: readonly (string | BashDenylistEntry)[];\n48:   readonly bash_denylist?: readonly (string | BashDenylistEntry)[];\n49: }\n50: \n51: export type CodexPreToolUseOutput =\n52:   | {\n53:     readonly decision: 'deny';\n54:     readonly reason: string;\n55:   }\n56:   | Record<string, never>;\n57: \n58: export interface CodexPreToolUseDependencies {\n59:   readonly policyPath?: string;\n60:   readonly readPolicy?: () => CodexPolicyFile;\n61: }\n62: \n63: export const DEFAULT_CODEX_BASH_DENYLIST: readonly string[] = [\n64:   'rm -rf /',\n65:   'rm -rf ~',\n66:   'rm -rf $HOME',\n67:   'git push --force main',\n68:   'git push --force master',\n69:   'git push -f main',\n70:   'git push -f master',\n71:   'git reset --hard',\n72:   'git reset --hard origin/main',\n73:   'git reset --hard origin/master',\n74:   'sudo shutdown',\n75:   'sudo reboot',\n76:   'sudo rm -rf',\n77:   ':(){ :|:& };:',\n78:   'chmod -R 777 /',\n79:   'chown -R root:root /',\n80:   'dd if=/dev/zero of=/dev/',\n81:   'mkfs.ext4 /dev/',\n82: ];\n83: \n84: export const DEFAULT_POLICY: CodexPolicyFile = {\n85:   version: 1,\n86:   notes: 'In-memory starter Bash denylist for Codex PreToolUse; this is not a comprehensive destructive-command policy or shell-safety parser. Run npm run setup:codex-policy to write a repo-local policy file.',\n87:   bashDenylist: DEFAULT_CODEX_BASH_DENYLIST,\n88: };\n89: \n90: let cachedPolicyPath: string | null = null;\n91: let cachedPolicy: CodexPolicyFile | null = null;\n92: \n93: function isRecord(value: unknown): value is Record<string, unknown> {\n94:   return typeof value === 'object' && value !== null && !Array.isArray(value);\n95: }\n96: \n97: function parseCodexPreToolUseInput(raw: string): CodexPreToolUseInput | null {\n98:   try {\n99:     const parsed = JSON.parse(raw) as unknown;\n100:     return isRecord(parsed) ? parsed : null;\n101:   } catch {\n102:     return null;\n103:   }\n104: }\n105: \n106: export function defaultCodexPolicyPath(): string {\n107:   return resolve(process.cwd(), '.codex', 'policy.json');\n108: }\n109: \n110: function writeMissingPolicyDiagnostic(policyPath: string): void {\n111:   process.stderr.write(`${JSON.stringify({\n112:     hook: 'codex-pre-tool-use',\n113:     status: 'in_memory_default',\n114:     policyPath,\n115:   })}\\n`);\n116: }\n117: \n118: function loadPolicy(policyPath: string): CodexPolicyFile {\n119:   if (cachedPolicy && cachedPolicyPath === policyPath) {\n120:     return cachedPolicy;\n121:   }\n122:   if (!existsSync(policyPath)) {\n123:     cachedPolicy = DEFAULT_POLICY;\n124:     cachedPolicyPath = policyPath;\n125:     writeMissingPolicyDiagnostic(policyPath);\n126:     return cachedPolicy;\n127:   }\n128:   try {\n129:     const parsed = JSON.parse(readFileSync(policyPath, 'utf8')) as unknown;\n130:     cachedPolicy = isRecord(parsed) ? parsed as CodexPolicyFile : DEFAULT_POLICY;\n131:   } catch {\n132:     cachedPolicy = DEFAULT_POLICY;\n133:   }\n134:   cachedPolicyPath = policyPath;\n135:   return cachedPolicy;\n136: }\n137: \n138: function toolNameFor(input: CodexPreToolUseInput): string | null {\n139:   const toolName = input.tool ?? input.tool_name ?? input.toolName;\n140:   return typeof toolName === 'string' ? toolName : null;\n141: }\n142: \n143: function bashCommandFor(input: CodexPreToolUseInput): string | null {\n144:   const command = input.command ?? input.tool_input?.command ?? input.toolInput?.command ?? input.input?.command;\n145:   return typeof command === 'string' ? command : null;\n146: }\n147: \n148: function normalizeEntry(entry: string | BashDenylistEntry): BashDenylistEntry | null {\n149:   if (typeof entry === 'string' && entry.trim().length > 0) {\n150:     return { pattern: entry.trim() };\n151:   }\n152:   if (typeof entry !== 'object' || entry === null) {\n153:     return null;\n154:   }\n155:   if (typeof entry.pattern === 'string' && entry.pattern.trim().length > 0) {\n156:     return {\n157:       pattern: entry.pattern.trim(),\n158:       ...(entry.reason ? { reason: entry.reason } : {}),\n159:     };\n160:   }\n161:   return null;\n162: }\n163: \n164: function escapeRegex(value: string): string {\n165:   return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n166: }\n167: \n168: function commandMatchesPattern(command: string, pattern: string): boolean {\n169:   const escaped = escapeRegex(pattern).replace(/\\s+/g, '\\\\s+');\n170:   const startsWithWord = /^\\w/.test(pattern);\n171:   const endsWithWord = /\\w$/.test(pattern);\n172:   const prefix = startsWithWord ? '(?<![\\\\w-])' : '';\n173:   const suffix = endsWithWord ? '(?![\\\\w-])' : '(?=$|[\\\\s;&|])';\n174:   return new RegExp(`${prefix}${escaped}${suffix}`).test(command);\n175: }\n176: \n177: function denylistMatch(\n178:   command: string,\n179:   entries: readonly (string | BashDenylistEntry)[] | undefined,\n180: ): BashDenylistEntry | null {\n181:   for (const rawEntry of entries ?? []) {\n182:     const entry = normalizeEntry(rawEntry);\n183:     if (!entry) {\n184:       continue;\n185:     }\n186:     if (commandMatchesPattern(command, entry.pattern)) {\n187:       return entry;\n188:     }\n189:   }\n190:   return null;\n191: }\n192: \n193: function denylistEntries(policy: CodexPolicyFile): readonly (string | BashDenylistEntry)[] {\n194:   return [\n195:     ...(policy.bashDenylist ?? []),\n196:     ...(policy.bash_denylist ?? []),\n197:     ...DEFAULT_CODEX_BASH_DENYLIST,\n198:   ];\n199: }\n200: \n201: export function clearCodexPreToolUsePolicyCacheForTests(): void {\n202:   cachedPolicy = null;\n203:   cachedPolicyPath = null;\n204: }\n205: \n206: export function handleCodexPreToolUse(\n207:   input: CodexPreToolUseInput | null,\n208:   dependencies: CodexPreToolUseDependencies = {},\n209: ): CodexPreToolUseOutput {\n210:   try {\n211:     if (!input) {\n212:       return {};\n213:     }\n214: \n215:     if (toolNameFor(input) !== 'Bash') {\n216:       return {};\n217:     }\n218: \n219:     const command = bashCommandFor(input);\n220:     if (command === null) {\n\n(Showing lines 1-220 of 267. Use offset=221 to continue.)\n</content>","metadata":{"preview":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// MODULE: Codex PreToolUse Hook — Bash Deny Policy\n// ───────────────────────────────────────────────────────────────\n// Codex PreToolUse is intentionally narrow here: only Bash commands can\n// be denied, and only when they match starter policy phrases.\n\nimport {\n  existsSync,\n  readFileSync,\n} from 'node:fs';\nimport { resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nconst IS_CLI_ENTRY = process.argv[1]\n  ? resolve(process.argv[1]) === fileURLToPath(import.meta.url)\n  : false;\n\nexport interface CodexPreToolUseInput {\n  readonly tool?: string;","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/codex/pre-tool-use.ts","text":"#!/usr/bin/env node\n// ───────────────────────────────────────────────────────────────\n// MODULE: Codex PreToolUse Hook — Bash Deny Policy\n// ───────────────────────────────────────────────────────────────\n// Codex PreToolUse is intentionally narrow here: only Bash commands can\n// be denied, and only when they match starter policy phrases.\n\nimport {\n  existsSync,\n  readFileSync,\n} from 'node:fs';\nimport { resolve } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nconst IS_CLI_ENTRY = process.argv[1]\n  ? resolve(process.argv[1]) === fileURLToPath(import.meta.url)\n  : false;\n\nexport interface CodexPreToolUseInput {\n  readonly tool?: string;\n  readonly tool_name?: string;\n  readonly toolName?: string;\n  readonly command?: string;\n  readonly tool_input?: {\n    readonly command?: string;\n    readonly [key: string]: unknown;\n  };\n  readonly toolInput?: {\n    readonly command?: string;\n    readonly [key: string]: unknown;\n  };\n  readonly input?: {\n    readonly command?: string;\n    readonly [key: string]: unknown;\n  };\n  readonly [key: string]: unknown;\n}\n\nexport interface BashDenylistEntry {\n  readonly pattern: string;\n  readonly reason?: string;\n}\n\nexport interface CodexPolicyFile {\n  readonly version?: number;\n  readonly notes?: string;\n  readonly bashDenylist?: readonly (string | BashDenylistEntry)[];\n  readonly bash_denylist?: readonly (string | BashDenylistEntry)[];\n}\n\nexport type CodexPreToolUseOutput =\n  | {\n    readonly decision: 'deny';\n    readonly reason: string;\n  }\n  | Record<string, never>;\n\nexport interface CodexPreToolUseDependencies {\n  readonly policyPath?: string;\n  readonly readPolicy?: () => CodexPolicyFile;\n}\n\nexport const DEFAULT_CODEX_BASH_DENYLIST: readonly string[] = [\n  'rm -rf /',\n  'rm -rf ~',\n  'rm -rf $HOME',\n  'git push --force main',\n  'git push --force master',\n  'git push -f main',\n  'git push -f master',\n  'git reset --hard',\n  'git reset --hard origin/main',\n  'git reset --hard origin/master',\n  'sudo shutdown',\n  'sudo reboot',\n  'sudo rm -rf',\n  ':(){ :|:& };:',\n  'chmod -R 777 /',\n  'chown -R root:root /',\n  'dd if=/dev/zero of=/dev/',\n  'mkfs.ext4 /dev/',\n];\n\nexport const DEFAULT_POLICY: CodexPolicyFile = {\n  version: 1,\n  notes: 'In-memory starter Bash denylist for Codex PreToolUse; this is not a comprehensive destructive-command policy or shell-safety parser. Run npm run setup:codex-policy to write a repo-local policy file.',\n  bashDenylist: DEFAULT_CODEX_BASH_DENYLIST,\n};\n\nlet cachedPolicyPath: string | null = null;\nlet cachedPolicy: CodexPolicyFile | null = null;\n\nfunction isRecord(value: unknown): value is Record<string, unknown> {\n  return typeof value === 'object' && value !== null && !Array.isArray(value);\n}\n\nfunction parseCodexPreToolUseInput(raw: string): CodexPreToolUseInput | null {\n  try {\n    const parsed = JSON.parse(raw) as unknown;\n    return isRecord(parsed) ? parsed : null;\n  } catch {\n    return null;\n  }\n}\n\nexport function defaultCodexPolicyPath(): string {\n  return resolve(process.cwd(), '.codex', 'policy.json');\n}\n\nfunction writeMissingPolicyDiagnostic(policyPath: string): void {\n  process.stderr.write(`${JSON.stringify({\n    hook: 'codex-pre-tool-use',\n    status: 'in_memory_default',\n    policyPath,\n  })}\\n`);\n}\n\nfunction loadPolicy(policyPath: string): CodexPolicyFile {\n  if (cachedPolicy && cachedPolicyPath === policyPath) {\n    return cachedPolicy;\n  }\n  if (!existsSync(policyPath)) {\n    cachedPolicy = DEFAULT_POLICY;\n    cachedPolicyPath = policyPath;\n    writeMissingPolicyDiagnostic(policyPath);\n    return cachedPolicy;\n  }\n  try {\n    const parsed = JSON.parse(readFileSync(policyPath, 'utf8')) as unknown;\n    cachedPolicy = isRecord(parsed) ? parsed as CodexPolicyFile : DEFAULT_POLICY;\n  } catch {\n    cachedPolicy = DEFAULT_POLICY;\n  }\n  cachedPolicyPath = policyPath;\n  return cachedPolicy;\n}\n\nfunction toolNameFor(input: CodexPreToolUseInput): string | null {\n  const toolName = input.tool ?? input.tool_name ?? input.toolName;\n  return typeof toolName === 'string' ? toolName : null;\n}\n\nfunction bashCommandFor(input: CodexPreToolUseInput): string | null {\n  const command = input.command ?? input.tool_input?.command ?? input.toolInput?.command ?? input.input?.command;\n  return typeof command === 'string' ? command : null;\n}\n\nfunction normalizeEntry(entry: string | BashDenylistEntry): BashDenylistEntry | null {\n  if (typeof entry === 'string' && entry.trim().length > 0) {\n    return { pattern: entry.trim() };\n  }\n  if (typeof entry !== 'object' || entry === null) {\n    return null;\n  }\n  if (typeof entry.pattern === 'string' && entry.pattern.trim().length > 0) {\n    return {\n      pattern: entry.pattern.trim(),\n      ...(entry.reason ? { reason: entry.reason } : {}),\n    };\n  }\n  return null;\n}\n\nfunction escapeRegex(value: string): string {\n  return value.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&');\n}\n\nfunction commandMatchesPattern(command: string, pattern: string): boolean {\n  const escaped = escapeRegex(pattern).replace(/\\s+/g, '\\\\s+');\n  const startsWithWord = /^\\w/.test(pattern);\n  const endsWithWord = /\\w$/.test(pattern);\n  const prefix = startsWithWord ? '(?<![\\\\w-])' : '';\n  const suffix = endsWithWord ? '(?![\\\\w-])' : '(?=$|[\\\\s;&|])';\n  return new RegExp(`${prefix}${escaped}${suffix}`).test(command);\n}\n\nfunction denylistMatch(\n  command: string,\n  entries: readonly (string | BashDenylistEntry)[] | undefined,\n): BashDenylistEntry | null {\n  for (const rawEntry of entries ?? []) {\n    const entry = normalizeEntry(rawEntry);\n    if (!entry) {\n      continue;\n    }\n    if (commandMatchesPattern(command, entry.pattern)) {\n      return entry;\n    }\n  }\n  return null;\n}\n\nfunction denylistEntries(policy: CodexPolicyFile): readonly (string | BashDenylistEntry)[] {\n  return [\n    ...(policy.bashDenylist ?? []),\n    ...(policy.bash_denylist ?? []),\n    ...DEFAULT_CODEX_BASH_DENYLIST,\n  ];\n}\n\nexport function clearCodexPreToolUsePolicyCacheForTests(): void {\n  cachedPolicy = null;\n  cachedPolicyPath = null;\n}\n\nexport function handleCodexPreToolUse(\n  input: CodexPreToolUseInput | null,\n  dependencies: CodexPreToolUseDependencies = {},\n): CodexPreToolUseOutput {\n  try {\n    if (!input) {\n      return {};\n    }\n\n    if (toolNameFor(input) !== 'Bash') {\n      return {};\n    }\n\n    const command = bashCommandFor(input);\n    if (command === null) {","lineStart":1,"lineEnd":220,"totalLines":267,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/hooks/codex/pre-tool-use.ts","time":{"start":1780738196961,"end":1780738196976}},"metadata":{"openai":{"itemId":"fc_0850f20a74e32d69016a23e894d9848191b658858132056754"}},"id":"prt_e9c4485de001fBj8Ly8zEFDpIw","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c4461320011YuE7wXipq34LO"}}
{"type":"tool_use","timestamp":1780738196983,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_P3hI7chDV4oNBTU5lR0sV6Iz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/speckit.md","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/speckit.md</path>\n<type>file</type>\n<content>\n1: ---\n2: description: Router for /doctor <target>; dispatches per-subsystem diagnostic to the right YAML via the _routes.yaml manifest.\n3: argument-hint: \"<target> [flags] | list | ?\"\n4: allowed-tools: Read, Bash, Grep, Glob, Edit, Write, mcp__mk_code_index__code_graph_status, mcp__mk_code_index__code_graph_query, mcp__mk_code_index__code_graph_context, mcp__mk_code_index__code_graph_scan, mcp__mk_code_index__code_graph_apply, mcp__mk_code_index__detect_changes, mcp__mk_spec_memory__memory_context, mcp__mk_spec_memory__memory_search, mcp__mk_spec_memory__memory_health, mcp__mk_spec_memory__memory_index_scan, mcp__mk_spec_memory__memory_drift_why, mcp__mk_spec_memory__memory_stats, mcp__mk_spec_memory__embedder_status, mcp__mk_spec_memory__memory_causal_stats, mcp__mk_spec_memory__memory_causal_link, mcp__mk_skill_advisor__advisor_recommend, mcp__mk_skill_advisor__advisor_status, mcp__mk_skill_advisor__advisor_validate, mcp__mk_skill_advisor__advisor_rebuild, mcp__mk_skill_advisor__skill_graph_scan, mcp__mk_skill_advisor__skill_graph_query, mcp__mk_skill_advisor__skill_graph_status\n5: ---\n6: <!-- skill_agent: system-spec-kit -->\n7: \n8: \n9: > ⚠️ **EXECUTION PROTOCOL — READ FIRST**\n10: >\n11: > This command is a ROUTER. It resolves a positional target from `$ARGUMENTS`, parses the target-specific flag schema, and hands off to the matching YAML workflow asset.\n12: >\n13: > **Ownership:** Markdown owns target resolution + per-target setup. YAML owns execution. Setup values resolved here are passed to the target-specific YAML.\n14: >\n15: > **YOUR FIRST ACTION:**\n16: > 1. Parse the FIRST positional argument from `$ARGUMENTS` as `target`. If missing or empty → run Tier 1 interactive menu and wait. If `list` / `?` / `--list` → print SUBSYSTEM MANIFEST and exit. If unknown → reject with the valid list.\n17: > 2. Look `target` up in `.opencode/commands/doctor/_routes.yaml`. Resolve `yaml`, `setup_vars`, `allowed_flags`, `mutating`, `mcp_tools`, and any `script_invocations`.\n18: > 3. Run the per-target flag parser (Tier 2) using ONLY that target's `allowed_flags`. Any unknown or cross-target flag MUST raise a clear error pointing to the correct command (e.g. \"`--confidence-threshold` is not a flag for `memory`; did you mean `/doctor causal-graph --confidence-threshold=0.8`?\").\n19: > 4. Bind all `setup_vars` to resolved values (defaults if no flag given). `execution_mode` is always `INTERACTIVE`.\n20: > 5. Load `assets/<yaml>` and execute its phased workflow.\n21: >\n22: > All reference content below is context for the per-target YAML. Do NOT treat reference sections as direct instructions to execute.\n23: \n24: ## CONSTRAINTS\n25: \n26: - **ONLY MODE (INTERACTIVE)**: every routed target is interactive by design; no mode suffixes are supported.\n27: - **TARGET-FIRST PARSING**: parse the positional target BEFORE any `--flag`. Global flag pre-parse is forbidden (cross-target schemas collide).\n28: - **DO NOT** dispatch any agent from this document.\n29: - **ALL** workflow execution happens through the target YAML — this document is target resolution + setup only.\n30: - **MARKDOWN OWNS SETUP**: resolve `execution_mode` + per-target `setup_vars` here first, then hand off to YAML.\n31: - **YAML START CONDITION**: do not load the target YAML until `target` is bound AND every `setup_var` for that target is resolved.\n32: - **NO YAML MODIFICATIONS**: the 10 YAML assets under `assets/doctor_*.yaml` are stable and untouched by this router.\n33: - **MANIFEST IS CANONICAL**: per-target metadata (yaml asset, setup vars, allowed flags, mutation class, mcp tools, script invocations, trigger phrases) lives in `_routes.yaml`. The SUBSYSTEM MANIFEST table below is a human-readable mirror, not the source of truth.\n34: \n35: > **Format:** `/doctor <target> [flags]` | `/doctor list` | `/doctor ?`\n36: > Examples: `/doctor memory --dry-run`, `/doctor causal-graph --confidence-threshold=0.8`\n37: \n38: ## GATE 3 STATUS\n39: \n40: This router never modifies authored spec packet docs. Each routed target has its own mutation boundary (see table below). All target mutations are validated by per-YAML Phase 3 canonical-path validators and rolled back via per-target snapshots.\n41: \n42: | Target          | Location                                                                                  | Mutation class | Reason                                                            | Alternative                                                  |\n43: | --------------- | ----------------------------------------------------------------------------------------- | -------------- | ----------------------------------------------------------------- | ------------------------------------------------------------ |\n44: | `memory`        | n/a (read-only diagnostic)                                                                | **read-only**  | Reports continuity-index drift; recommends action, no DB writes   | Diagnostic output only                                       |\n45: | `embeddings`    | n/a (read-only provider/model-server status)                                              | **read-only**  | No mutations; report-only                                         | Diagnostic output only                                       |\n46: | `causal-graph`  | n/a (read-only diagnostic)                                                                | **read-only**  | Samples causal_edges; recommends candidates, never writes         | Diagnostic output only                                       |\n47: | `code-graph`    | n/a (read-only Phase A diagnostic)                                                        | **read-only**  | Emits exclude/language report; never scans or writes the index    | Diagnostic output only                                       |\n48: | `deep-loop`     | n/a (read-only diagnostic)                                                                | **read-only**  | Reads coverage graph + iteration folders; never upserts           | Diagnostic output only                                       |\n49: | `skill-advisor` | `lib/scorer/lanes/*.ts` + `.opencode/skills/*/graph-metadata.json`                        | **mutates**    | Runtime scorer config + graph metadata; not packet docs           | Phase 3 validator + per-run rollback script                  |\n50: | `skill-budget`  | n/a (read-only audit)                                                                     | **read-only**  | No mutations; report-only                                         | Diagnostic output only                                       |\n51: \n52: ---\n53: \n54: ## SUBSYSTEM MANIFEST (narrative mirror of `_routes.yaml`)\n55: \n56: | Target          | YAML asset                      | Setup vars                                                              | Mutation class | One-line purpose                                                          |\n57: | --------------- | ------------------------------- | ----------------------------------------------------------------------- | -------------- | ------------------------------------------------------------------------- |\n58: | `memory`        | `doctor_memory.yaml`            | execution_mode, intent, incremental, no_snapshot, dry_run               | read-only      | Diagnose the memory continuity index; report drift and recommend action   |\n59: | `embeddings`    | `doctor_embeddings.yaml`        | execution_mode                                                          | read-only      | Inspect provider selection and hf-local model-server status               |\n60: | `causal-graph`  | `doctor_causal-graph.yaml`      | execution_mode, intent, confidence_threshold, no_snapshot, dry_run      | read-only      | Diagnose causal-edge integrity; sample drift and recommend candidates     |\n61: | `code-graph`    | `doctor_code-graph.yaml`        | execution_mode, scope                                                   | read-only      | Diagnose code-graph index; report stale / missed / bloat findings         |\n62: | `deep-loop`     | `doctor_deep-loop.yaml`         | execution_mode, intent, scope, no_snapshot, dry_run                     | read-only      | Diagnose deep-loop coverage graphs (research / review)                    |\n63: | `skill-advisor` | `doctor_skill-advisor.yaml`     | execution_mode, scope, skip_tests, dry_run                              | mutates        | Audit & re-tune skill advisor scoring lanes                               |\n64: | `skill-budget`  | `doctor_skill-budget.yaml`      | execution_mode, json_output, top_n, fail_over, project_ceiling          | read-only      | Audit skill/command/agent description budgets                             |\n65: \n66: **Canonical data:** `.opencode/commands/doctor/_routes.yaml`. Use that file to add or remove targets.\n67: \n68: **Companion commands** (NOT routed through `/doctor`):\n69: - `/doctor:update` — multi-subsystem orchestrator (lock + DAG + snapshot + rollback). Use for \"rebuild everything in dependency-safe order.\"\n70: - `/doctor:mcp install|debug` — MCP server install / repair. Use when MCP infrastructure (not subsystem databases) is broken.\n71: \n72: ---\n73: \n74: ## 0. UNIFIED SETUP PHASE (TWO TIERS)\n75: \n76: **FIRST MESSAGE PROTOCOL:** this prompt MUST be your FIRST response when `$ARGUMENTS` lacks a recognized positional target. Lightweight read-only discovery is allowed (read `_routes.yaml`); then ask Tier 1 and wait. The happy path (`/doctor <target> [flags]`) skips Tier 1 entirely and proceeds straight to Tier 2.\n77: \n78: ```\n79: EXECUTE THIS TWO-TIER PROMPT:\n80: \n81: ──────────────────────────────────────────────────────────────────\n82: TIER 1 — TARGET RESOLUTION\n83: ──────────────────────────────────────────────────────────────────\n84: \n85: 1. PARSE $ARGUMENTS:\n86:    - Extract the FIRST positional token (everything before the first --flag).\n87:    - If empty / whitespace → unresolved; go to step 2.\n88:    - If \"list\" / \"?\" / \"--list\" → PRINT the SUBSYSTEM MANIFEST table above and EXIT with STATUS=OK.\n89:    - If \"--target=<name>\" (compatibility alias) → treat <name> as the positional token.\n90:    - Otherwise → bind `target` to the token.\n91: \n92: 2. IF target IS UNRESOLVED:\n93:    - ASK Tier 1 question (print VERBATIM — do not paraphrase or split into multiple messages):\n94: \n95: ```\n96: What do you want to do?\n97: \n98:    1) Update everything to match latest spec-kit release   (e.g. 3.3.0.0 → 3.4.x)\n99:    2) Debug Memory database              (search index, spec-doc indexing)\n100:    3) Debug Embeddings                   (provider choice, hf-local health)\n101:    4) Debug Causal-Graph                 (spec lineage, drift_why)\n102:    5) Debug Code-Graph                   (structural index, stale/missed/bloat)\n103:    6) Debug Deep-Loop history            (research/review iteration graphs)\n104:    7) Re-tune Skill Advisor              (which skill gets recommended)\n105:    8) Audit Skill Description budget     (char counts, CI-friendly)\n106:    0) Full sweep — rebuild everything    (no migration, current schema)\n107:    H) Help me decide\n108:    X) Cancel\n109: ```\n110: \n111:    - WAIT for selection. Map answers as follows:\n112:      - 1 → ABORT this command, EMIT: \"Switch to `/doctor:update --migrate` for upgrade migration. Exiting /doctor.\"\n113:      - 2 → target = \"memory\"\n114:      - 3 → target = \"embeddings\"\n115:      - 4 → target = \"causal-graph\"\n116:      - 5 → target = \"code-graph\"\n117:      - 6 → target = \"deep-loop\"\n118:      - 7 → target = \"skill-advisor\"\n119:      - 8 → target = \"skill-budget\"\n120:      - 9 → ABORT, EMIT: \"Switch to `/doctor:mcp debug --fix` (or `/doctor:mcp install`). Exiting /doctor.\"\n121:      - 0 → ABORT, EMIT: \"Switch to `/doctor:update` for full sweep. Exiting /doctor.\"\n122:      - H → print the HELP block below, then re-ask Tier 1 question.\n123:      - X / empty / \"cancel\" → STATUS=CANCEL, exit.\n124:      - Anything else → re-emit the menu once; on second invalid input → STATUS=FAIL ERROR=unknown_selection.\n125: \n126:    HELP block (printed when user picks [H]):\n127: \n128: ```\n129: Pick by symptom:\n130: \n131:    Search returns stale or empty results              → 2  Memory\n132:    \"context-index__*.sqlite missing\" warning          → 2  Memory\n133:    Model mismatch or hf-local loading state unclear   → 3  Embeddings\n134:    memory_drift_why returns nothing                   → 4  Causal-Graph\n135:    \"causal coverage <60%\" warning                     → 4  Causal-Graph\n136:    \"code-graph stale/missed/bloat\" warning            → 5  Code-Graph\n137:    \"code_graph_status: unhealthy\" or code-graph errors → 5  Code-Graph\n138:    deep-research/deep-review iteration graph empty    → 6  Deep-Loop\n139:    Convergence not detected between iterations        → 6  Deep-Loop\n140:    Skill Advisor recommends the wrong skill           → 7  Skill Advisor\n141:    New skill not appearing in advisor results         → 7  Skill Advisor\n142:    Description char-count over hard cap (1536)        → 8  Skill Budget\n143: \n144: Quick reference for confusable pairs:\n145:    Code-Graph (5) is STRUCTURAL — functions, files, dirs, AST\n146:    Skill Advisor (7) tunes ROUTING quality (which skill gets picked)\n147:    Skill Budget (8) audits CHAR COUNTS (frontmatter description size)\n148: \n149: Press 1-8, 0, or X.\n150: ```\n151: \n152:    - After printing HELP, RE-EMIT the Tier 1 question above and WAIT again.\n153: \n154: 3. VALIDATE target against the canonical list in _routes.yaml:\n155:    - THEN EMIT:\n156:    - EXIT with STATUS=FAIL ERROR=unknown_target.\n157: \n158: 4. LOOK UP the resolved target in `.opencode/commands/doctor/_routes.yaml`:\n159:    - BIND: yaml_asset, setup_vars, allowed_flags, mutating, mcp_tools, gate3_location.\n160: \n161: ──────────────────────────────────────────────────────────────────\n162: TIER 2 — PER-TARGET FLAG PARSING (case block)\n163: ──────────────────────────────────────────────────────────────────\n164: \n165: 5. SET execution_mode = \"INTERACTIVE\" (always).\n166: \n167: 6. PARSE the REMAINING $ARGUMENTS (everything AFTER the positional target)\n168:    USING ONLY the target's `allowed_flags` schema. Per-target logic:\n169: \n170:    case \"$target\" in\n171:      memory)\n172:        # allowed: --incremental=true|false, --no-snapshot, --dry-run\n173:        --incremental=true|false → incremental = <value>  (default: prompt)\n174:        --no-snapshot            → no_snapshot = true      (default: false)\n175:        --dry-run                → dry_run = true          (default: false)\n176:        intent = \"DIAGNOSE\"  (default; YAML may override after Phase 0)\n177:        SET yaml_asset = \"doctor_memory.yaml\"\n178:        ;;\n179:      embeddings)\n180:        # no flags\n\n(Showing lines 1-180 of 334. Use offset=181 to continue.)\n</content>","metadata":{"preview":"---\ndescription: Router for /doctor <target>; dispatches per-subsystem diagnostic to the right YAML via the _routes.yaml manifest.\nargument-hint: \"<target> [flags] | list | ?\"\nallowed-tools: Read, Bash, Grep, Glob, Edit, Write, mcp__mk_code_index__code_graph_status, mcp__mk_code_index__code_graph_query, mcp__mk_code_index__code_graph_context, mcp__mk_code_index__code_graph_scan, mcp__mk_code_index__code_graph_apply, mcp__mk_code_index__detect_changes, mcp__mk_spec_memory__memory_context, mcp__mk_spec_memory__memory_search, mcp__mk_spec_memory__memory_health, mcp__mk_spec_memory__memory_index_scan, mcp__mk_spec_memory__memory_drift_why, mcp__mk_spec_memory__memory_stats, mcp__mk_spec_memory__embedder_status, mcp__mk_spec_memory__memory_causal_stats, mcp__mk_spec_memory__memory_causal_link, mcp__mk_skill_advisor__advisor_recommend, mcp__mk_skill_advisor__advisor_status, mcp__mk_skill_advisor__advisor_validate, mcp__mk_skill_advisor__advisor_rebuild, mcp__mk_skill_advisor__skill_graph_scan, mcp__mk_skill_advisor__skill_graph_query, mcp__mk_skill_advisor__skill_graph_status\n---\n<!-- skill_agent: system-spec-kit -->\n\n\n> ⚠️ **EXECUTION PROTOCOL — READ FIRST**\n>\n> This command is a ROUTER. It resolves a positional target from `$ARGUMENTS`, parses the target-specific flag schema, and hands off to the matching YAML workflow asset.\n>\n> **Ownership:** Markdown owns target resolution + per-target setup. YAML owns execution. Setup values resolved here are passed to the target-specific YAML.\n>\n> **YOUR FIRST ACTION:**\n> 1. Parse the FIRST positional argument from `$ARGUMENTS` as `target`. If missing or empty → run Tier 1 interactive menu and wait. If `list` / `?` / `--list` → print SUBSYSTEM MANIFEST and exit. If unknown → reject with the valid list.\n> 2. Look `target` up in `.opencode/commands/doctor/_routes.yaml`. Resolve `yaml`, `setup_vars`, `allowed_flags`, `mutating`, `mcp_tools`, and any `script_invocations`.\n> 3. Run the per-target flag parser (Tier 2) using ONLY that target's `allowed_flags`. Any unknown or cross-target flag MUST raise a clear error pointing to the correct command (e.g. \"`--confidence-threshold` is not a flag for `memory`; did you mean `/doctor causal-graph --confidence-threshold=0.8`?\").\n> 4. Bind all `setup_vars` to resolved values (defaults if no flag given). `execution_mode` is always `INTERACTIVE`.\n> 5. Load `assets/<yaml>` and execute its phased workflow.","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/speckit.md","text":"---\ndescription: Router for /doctor <target>; dispatches per-subsystem diagnostic to the right YAML via the _routes.yaml manifest.\nargument-hint: \"<target> [flags] | list | ?\"\nallowed-tools: Read, Bash, Grep, Glob, Edit, Write, mcp__mk_code_index__code_graph_status, mcp__mk_code_index__code_graph_query, mcp__mk_code_index__code_graph_context, mcp__mk_code_index__code_graph_scan, mcp__mk_code_index__code_graph_apply, mcp__mk_code_index__detect_changes, mcp__mk_spec_memory__memory_context, mcp__mk_spec_memory__memory_search, mcp__mk_spec_memory__memory_health, mcp__mk_spec_memory__memory_index_scan, mcp__mk_spec_memory__memory_drift_why, mcp__mk_spec_memory__memory_stats, mcp__mk_spec_memory__embedder_status, mcp__mk_spec_memory__memory_causal_stats, mcp__mk_spec_memory__memory_causal_link, mcp__mk_skill_advisor__advisor_recommend, mcp__mk_skill_advisor__advisor_status, mcp__mk_skill_advisor__advisor_validate, mcp__mk_skill_advisor__advisor_rebuild, mcp__mk_skill_advisor__skill_graph_scan, mcp__mk_skill_advisor__skill_graph_query, mcp__mk_skill_advisor__skill_graph_status\n---\n<!-- skill_agent: system-spec-kit -->\n\n\n> ⚠️ **EXECUTION PROTOCOL — READ FIRST**\n>\n> This command is a ROUTER. It resolves a positional target from `$ARGUMENTS`, parses the target-specific flag schema, and hands off to the matching YAML workflow asset.\n>\n> **Ownership:** Markdown owns target resolution + per-target setup. YAML owns execution. Setup values resolved here are passed to the target-specific YAML.\n>\n> **YOUR FIRST ACTION:**\n> 1. Parse the FIRST positional argument from `$ARGUMENTS` as `target`. If missing or empty → run Tier 1 interactive menu and wait. If `list` / `?` / `--list` → print SUBSYSTEM MANIFEST and exit. If unknown → reject with the valid list.\n> 2. Look `target` up in `.opencode/commands/doctor/_routes.yaml`. Resolve `yaml`, `setup_vars`, `allowed_flags`, `mutating`, `mcp_tools`, and any `script_invocations`.\n> 3. Run the per-target flag parser (Tier 2) using ONLY that target's `allowed_flags`. Any unknown or cross-target flag MUST raise a clear error pointing to the correct command (e.g. \"`--confidence-threshold` is not a flag for `memory`; did you mean `/doctor causal-graph --confidence-threshold=0.8`?\").\n> 4. Bind all `setup_vars` to resolved values (defaults if no flag given). `execution_mode` is always `INTERACTIVE`.\n> 5. Load `assets/<yaml>` and execute its phased workflow.\n>\n> All reference content below is context for the per-target YAML. Do NOT treat reference sections as direct instructions to execute.\n\n## CONSTRAINTS\n\n- **ONLY MODE (INTERACTIVE)**: every routed target is interactive by design; no mode suffixes are supported.\n- **TARGET-FIRST PARSING**: parse the positional target BEFORE any `--flag`. Global flag pre-parse is forbidden (cross-target schemas collide).\n- **DO NOT** dispatch any agent from this document.\n- **ALL** workflow execution happens through the target YAML — this document is target resolution + setup only.\n- **MARKDOWN OWNS SETUP**: resolve `execution_mode` + per-target `setup_vars` here first, then hand off to YAML.\n- **YAML START CONDITION**: do not load the target YAML until `target` is bound AND every `setup_var` for that target is resolved.\n- **NO YAML MODIFICATIONS**: the 10 YAML assets under `assets/doctor_*.yaml` are stable and untouched by this router.\n- **MANIFEST IS CANONICAL**: per-target metadata (yaml asset, setup vars, allowed flags, mutation class, mcp tools, script invocations, trigger phrases) lives in `_routes.yaml`. The SUBSYSTEM MANIFEST table below is a human-readable mirror, not the source of truth.\n\n> **Format:** `/doctor <target> [flags]` | `/doctor list` | `/doctor ?`\n> Examples: `/doctor memory --dry-run`, `/doctor causal-graph --confidence-threshold=0.8`\n\n## GATE 3 STATUS\n\nThis router never modifies authored spec packet docs. Each routed target has its own mutation boundary (see table below). All target mutations are validated by per-YAML Phase 3 canonical-path validators and rolled back via per-target snapshots.\n\n| Target          | Location                                                                                  | Mutation class | Reason                                                            | Alternative                                                  |\n| --------------- | ----------------------------------------------------------------------------------------- | -------------- | ----------------------------------------------------------------- | ------------------------------------------------------------ |\n| `memory`        | n/a (read-only diagnostic)                                                                | **read-only**  | Reports continuity-index drift; recommends action, no DB writes   | Diagnostic output only                                       |\n| `embeddings`    | n/a (read-only provider/model-server status)                                              | **read-only**  | No mutations; report-only                                         | Diagnostic output only                                       |\n| `causal-graph`  | n/a (read-only diagnostic)                                                                | **read-only**  | Samples causal_edges; recommends candidates, never writes         | Diagnostic output only                                       |\n| `code-graph`    | n/a (read-only Phase A diagnostic)                                                        | **read-only**  | Emits exclude/language report; never scans or writes the index    | Diagnostic output only                                       |\n| `deep-loop`     | n/a (read-only diagnostic)                                                                | **read-only**  | Reads coverage graph + iteration folders; never upserts           | Diagnostic output only                                       |\n| `skill-advisor` | `lib/scorer/lanes/*.ts` + `.opencode/skills/*/graph-metadata.json`                        | **mutates**    | Runtime scorer config + graph metadata; not packet docs           | Phase 3 validator + per-run rollback script                  |\n| `skill-budget`  | n/a (read-only audit)                                                                     | **read-only**  | No mutations; report-only                                         | Diagnostic output only                                       |\n\n---\n\n## SUBSYSTEM MANIFEST (narrative mirror of `_routes.yaml`)\n\n| Target          | YAML asset                      | Setup vars                                                              | Mutation class | One-line purpose                                                          |\n| --------------- | ------------------------------- | ----------------------------------------------------------------------- | -------------- | ------------------------------------------------------------------------- |\n| `memory`        | `doctor_memory.yaml`            | execution_mode, intent, incremental, no_snapshot, dry_run               | read-only      | Diagnose the memory continuity index; report drift and recommend action   |\n| `embeddings`    | `doctor_embeddings.yaml`        | execution_mode                                                          | read-only      | Inspect provider selection and hf-local model-server status               |\n| `causal-graph`  | `doctor_causal-graph.yaml`      | execution_mode, intent, confidence_threshold, no_snapshot, dry_run      | read-only      | Diagnose causal-edge integrity; sample drift and recommend candidates     |\n| `code-graph`    | `doctor_code-graph.yaml`        | execution_mode, scope                                                   | read-only      | Diagnose code-graph index; report stale / missed / bloat findings         |\n| `deep-loop`     | `doctor_deep-loop.yaml`         | execution_mode, intent, scope, no_snapshot, dry_run                     | read-only      | Diagnose deep-loop coverage graphs (research / review)                    |\n| `skill-advisor` | `doctor_skill-advisor.yaml`     | execution_mode, scope, skip_tests, dry_run                              | mutates        | Audit & re-tune skill advisor scoring lanes                               |\n| `skill-budget`  | `doctor_skill-budget.yaml`      | execution_mode, json_output, top_n, fail_over, project_ceiling          | read-only      | Audit skill/command/agent description budgets                             |\n\n**Canonical data:** `.opencode/commands/doctor/_routes.yaml`. Use that file to add or remove targets.\n\n**Companion commands** (NOT routed through `/doctor`):\n- `/doctor:update` — multi-subsystem orchestrator (lock + DAG + snapshot + rollback). Use for \"rebuild everything in dependency-safe order.\"\n- `/doctor:mcp install|debug` — MCP server install / repair. Use when MCP infrastructure (not subsystem databases) is broken.\n\n---\n\n## 0. UNIFIED SETUP PHASE (TWO TIERS)\n\n**FIRST MESSAGE PROTOCOL:** this prompt MUST be your FIRST response when `$ARGUMENTS` lacks a recognized positional target. Lightweight read-only discovery is allowed (read `_routes.yaml`); then ask Tier 1 and wait. The happy path (`/doctor <target> [flags]`) skips Tier 1 entirely and proceeds straight to Tier 2.\n\n```\nEXECUTE THIS TWO-TIER PROMPT:\n\n──────────────────────────────────────────────────────────────────\nTIER 1 — TARGET RESOLUTION\n──────────────────────────────────────────────────────────────────\n\n1. PARSE $ARGUMENTS:\n   - Extract the FIRST positional token (everything before the first --flag).\n   - If empty / whitespace → unresolved; go to step 2.\n   - If \"list\" / \"?\" / \"--list\" → PRINT the SUBSYSTEM MANIFEST table above and EXIT with STATUS=OK.\n   - If \"--target=<name>\" (compatibility alias) → treat <name> as the positional token.\n   - Otherwise → bind `target` to the token.\n\n2. IF target IS UNRESOLVED:\n   - ASK Tier 1 question (print VERBATIM — do not paraphrase or split into multiple messages):\n\n```\nWhat do you want to do?\n\n   1) Update everything to match latest spec-kit release   (e.g. 3.3.0.0 → 3.4.x)\n   2) Debug Memory database              (search index, spec-doc indexing)\n   3) Debug Embeddings                   (provider choice, hf-local health)\n   4) Debug Causal-Graph                 (spec lineage, drift_why)\n   5) Debug Code-Graph                   (structural index, stale/missed/bloat)\n   6) Debug Deep-Loop history            (research/review iteration graphs)\n   7) Re-tune Skill Advisor              (which skill gets recommended)\n   8) Audit Skill Description budget     (char counts, CI-friendly)\n   0) Full sweep — rebuild everything    (no migration, current schema)\n   H) Help me decide\n   X) Cancel\n```\n\n   - WAIT for selection. Map answers as follows:\n     - 1 → ABORT this command, EMIT: \"Switch to `/doctor:update --migrate` for upgrade migration. Exiting /doctor.\"\n     - 2 → target = \"memory\"\n     - 3 → target = \"embeddings\"\n     - 4 → target = \"causal-graph\"\n     - 5 → target = \"code-graph\"\n     - 6 → target = \"deep-loop\"\n     - 7 → target = \"skill-advisor\"\n     - 8 → target = \"skill-budget\"\n     - 9 → ABORT, EMIT: \"Switch to `/doctor:mcp debug --fix` (or `/doctor:mcp install`). Exiting /doctor.\"\n     - 0 → ABORT, EMIT: \"Switch to `/doctor:update` for full sweep. Exiting /doctor.\"\n     - H → print the HELP block below, then re-ask Tier 1 question.\n     - X / empty / \"cancel\" → STATUS=CANCEL, exit.\n     - Anything else → re-emit the menu once; on second invalid input → STATUS=FAIL ERROR=unknown_selection.\n\n   HELP block (printed when user picks [H]):\n\n```\nPick by symptom:\n\n   Search returns stale or empty results              → 2  Memory\n   \"context-index__*.sqlite missing\" warning          → 2  Memory\n   Model mismatch or hf-local loading state unclear   → 3  Embeddings\n   memory_drift_why returns nothing                   → 4  Causal-Graph\n   \"causal coverage <60%\" warning                     → 4  Causal-Graph\n   \"code-graph stale/missed/bloat\" warning            → 5  Code-Graph\n   \"code_graph_status: unhealthy\" or code-graph errors → 5  Code-Graph\n   deep-research/deep-review iteration graph empty    → 6  Deep-Loop\n   Convergence not detected between iterations        → 6  Deep-Loop\n   Skill Advisor recommends the wrong skill           → 7  Skill Advisor\n   New skill not appearing in advisor results         → 7  Skill Advisor\n   Description char-count over hard cap (1536)        → 8  Skill Budget\n\nQuick reference for confusable pairs:\n   Code-Graph (5) is STRUCTURAL — functions, files, dirs, AST\n   Skill Advisor (7) tunes ROUTING quality (which skill gets picked)\n   Skill Budget (8) audits CHAR COUNTS (frontmatter description size)\n\nPress 1-8, 0, or X.\n```\n\n   - After printing HELP, RE-EMIT the Tier 1 question above and WAIT again.\n\n3. VALIDATE target against the canonical list in _routes.yaml:\n   - THEN EMIT:\n   - EXIT with STATUS=FAIL ERROR=unknown_target.\n\n4. LOOK UP the resolved target in `.opencode/commands/doctor/_routes.yaml`:\n   - BIND: yaml_asset, setup_vars, allowed_flags, mutating, mcp_tools, gate3_location.\n\n──────────────────────────────────────────────────────────────────\nTIER 2 — PER-TARGET FLAG PARSING (case block)\n──────────────────────────────────────────────────────────────────\n\n5. SET execution_mode = \"INTERACTIVE\" (always).\n\n6. PARSE the REMAINING $ARGUMENTS (everything AFTER the positional target)\n   USING ONLY the target's `allowed_flags` schema. Per-target logic:\n\n   case \"$target\" in\n     memory)\n       # allowed: --incremental=true|false, --no-snapshot, --dry-run\n       --incremental=true|false → incremental = <value>  (default: prompt)\n       --no-snapshot            → no_snapshot = true      (default: false)\n       --dry-run                → dry_run = true          (default: false)\n       intent = \"DIAGNOSE\"  (default; YAML may override after Phase 0)\n       SET yaml_asset = \"doctor_memory.yaml\"\n       ;;\n     embeddings)\n       # no flags","lineStart":1,"lineEnd":180,"totalLines":334,"truncated":true}},"title":".opencode/commands/doctor/speckit.md","time":{"start":1780738196975,"end":1780738196981}},"metadata":{"openai":{"itemId":"fc_0850f20a74e32d69016a23e894d9948191a40fda1dda34c2f0"}},"id":"prt_e9c4485e200185VsYpw0LW5SHL","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c4461320011YuE7wXipq34LO"}}
{"type":"step_finish","timestamp":1780738197387,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"id":"prt_e9c448788001X2jExc4rca407v","reason":"tool-calls","snapshot":"1ae3552a9571e6f1c92f77c312a5e0962a9862da","messageID":"msg_e9c4461320011YuE7wXipq34LO","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","type":"step-finish","tokens":{"total":98817,"input":9352,"output":354,"reasoning":23,"cache":{"write":0,"read":89088}},"cost":0}}
{"type":"step_start","timestamp":1780738198885,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"id":"prt_e9c448d64001RVOvZgwVvGnbKx","messageID":"msg_e9c44888f001jAFy37Xm751puI","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","snapshot":"7e6da3471e7519524c2e153bad1da6a6de18909c","type":"step-start"}}
{"type":"tool_use","timestamp":1780738206071,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_wj8DpzAeF5KwwijTjkZLY8eo","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/memory-surface.ts","offset":301,"limit":380},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/memory-surface.ts</path>\n<type>file</type>\n<content>\n301:       LIMIT ?\n302:     `).all(workingMemory.DECAY_FLOOR, oneHourAgo, limit) as Array<{ memory_id: number }>;\n303: \n304:     return new Set(rows.map(r => r.memory_id));\n305:   } catch (_err: unknown) {\n306:     // Graceful degradation — working memory boost is optional\n307:     return new Set();\n308:   }\n309: }\n310: \n311: /**\n312:  * Phase C: Apply 1.3x boost to trigger-matched results that also appear\n313:  * in the attention-weighted working memory set. Re-sorts results by\n314:  * boosted composite score.\n315:  *\n316:  * @param triggered - Trigger-matched results from matchTriggerPhrases()\n317:  * @param attentionIds - Set of memory IDs from working memory\n318:  * @returns Re-sorted trigger matches with working memory boost applied\n319:  */\n320: const ATTENTION_BOOST_FACTOR = 1.3;\n321: \n322: function applyAttentionBoost(\n323:   triggered: triggerMatcher.TriggerMatch[],\n324:   attentionIds: Set<number>,\n325: ): triggerMatcher.TriggerMatch[] {\n326:   if (attentionIds.size === 0 || triggered.length === 0) return triggered;\n327: \n328:   // Score each result: base = matchedPhrases.length + (importanceWeight * 0.1)\n329:   // Apply 1.3x multiplier when memory is in working memory set.\n330:   return [...triggered]\n331:     .sort((a, b) => {\n332:       const scoreA = (a.matchedPhrases.length + a.importanceWeight * 0.1) *\n333:         (attentionIds.has(a.memoryId) ? ATTENTION_BOOST_FACTOR : 1.0);\n334:       const scoreB = (b.matchedPhrases.length + b.importanceWeight * 0.1) *\n335:         (attentionIds.has(b.memoryId) ? ATTENTION_BOOST_FACTOR : 1.0);\n336:       return scoreB - scoreA;\n337:     });\n338: }\n339: \n340: async function autoSurfaceMemories(\n341:   contextHint: string,\n342:   tokenBudget: number = TOOL_DISPATCH_TOKEN_BUDGET,\n343:   hookName: 'tool-dispatch' | 'compaction' | 'memory-aware' = 'memory-aware'\n344: ): Promise<AutoSurfaceResult | null> {\n345:   const startTime = Date.now();\n346: \n347:   try {\n348:     // Get constitutional memories (always surface)\n349:     const constitutional = await getConstitutionalMemories();\n350: \n351:     // Get triggered memories via fast phrase matching\n352:     let triggered = triggerMatcher.matchTriggerPhrases(contextHint, 5);\n353: \n354:     // Phase C: Attention-enriched boost — re-rank triggered results that\n355:     // also appear in the working memory active set.\n356:     try {\n357:       const attentionIds = getAttentionWeightedMemoryIds(5);\n358:       if (attentionIds.size > 0 && triggered.length > 0) {\n359:         triggered = applyAttentionBoost(triggered, attentionIds);\n360:       }\n361:     } catch (_boostErr: unknown) {\n362:       // Graceful degradation — attention boost is optional\n363:     }\n364: \n365:     const latencyMs = Date.now() - startTime;\n366: \n367:     // Only return if we have something to surface\n368:     if (constitutional.length === 0 && triggered.length === 0) {\n369:       return null;\n370:     }\n371: \n372:     // PI-A4: Enrich constitutional memories with retrieval_directive metadata.\n373:     // Pure content transformation — scoring is unchanged.\n374:     const enrichedConstitutional = enrichWithRetrievalDirectives(constitutional);\n375: \n376:     return enforceAutoSurfaceTokenBudget({\n377:       constitutional: enrichedConstitutional,\n378:       triggered: triggered.map((t: triggerMatcher.TriggerMatch) => ({\n379:         memory_id: t.memoryId,\n380:         spec_folder: t.specFolder,\n381:         title: t.title ?? 'Untitled',\n382:         matched_phrases: t.matchedPhrases,\n383:       })),\n384:       surfaced_at: new Date().toISOString(),\n385:       latencyMs: latencyMs,\n386:     }, tokenBudget, hookName);\n387:   } catch (err: unknown) {\n388:     const message = err instanceof Error ? err.message : String(err);\n389:     console.warn('[SK-004] Auto-surface failed:', message);\n390:     return null;\n391:   }\n392: }\n393: \n394: /** Build structured Prime Package for non-hook CLI auto-priming */\n395: function buildPrimePackage(\n396:   toolArgs: Record<string, unknown>,\n397:   graphSnapshot: NonNullable<AutoSurfaceResult['codeGraphStatus']>,\n398: ): PrimePackage {\n399:   // Derive specFolder from tool args if provided\n400:   const specFolder = typeof toolArgs.specFolder === 'string' ? toolArgs.specFolder : null;\n401: \n402:   // Derive currentTask from input/query/prompt fields\n403:   const taskFields = ['input', 'query', 'prompt'] as const;\n404:   let currentTask: string | null = null;\n405:   for (const f of taskFields) {\n406:     if (typeof toolArgs[f] === 'string' && (toolArgs[f] as string).length >= 3) {\n407:       currentTask = (toolArgs[f] as string).slice(0, 200);\n408:       break;\n409:     }\n410:   }\n411: \n412:   // Code graph freshness\n413:   let codeGraphStatus: PrimePackage['codeGraphStatus'] = 'empty';\n414:   if (graphSnapshot.status === 'ok' && graphSnapshot.data) {\n415:     const lastScan = graphSnapshot.data.lastScanAt;\n416:     const totalFiles = graphSnapshot.data.totalFiles ?? 0;\n417:     if (totalFiles === 0) {\n418:       codeGraphStatus = 'empty';\n419:     } else if (!lastScan || (Date.now() - new Date(lastScan).getTime() > 24 * 60 * 60 * 1000)) {\n420:       codeGraphStatus = 'stale';\n421:     } else {\n422:       codeGraphStatus = 'fresh';\n423:     }\n424:   }\n425: \n426:   // Build recommended calls based on state\n427:   const recommendedCalls: string[] = [];\n428:   if (codeGraphStatus === 'stale' || codeGraphStatus === 'empty') {\n429:     recommendedCalls.push('code_graph_scan');\n430:   }\n431:   if (!specFolder) {\n432:     recommendedCalls.push('memory_context({ input: \"resume previous work\", mode: \"resume\", profile: \"resume\" })');\n433:   }\n434:   if (recommendedCalls.length === 0) {\n435:     recommendedCalls.push('memory_match_triggers({ prompt: \"<your task>\" })');\n436:   }\n437: \n438:   const toolRoutingRules: string[] = [];\n439:   if (codeGraphStatus !== 'empty') {\n440:     toolRoutingRules.push('structural queries (callers, deps) → code_graph_query');\n441:   }\n442:   toolRoutingRules.push('exact text/regex → Grep');\n443: \n444:   // Structural bootstrap contract for auto-prime surface\n445:   const structuralContext = buildStructuralBootstrapContract('auto-prime');\n446: \n447:   return {\n448:     specFolder, currentTask, codeGraphStatus, recommendedCalls,\n449:     structuralContext,\n450:     routingRules: {\n451:       graphRetrieval: 'For broad topic questions, use memory_search with retrievalLevel: \"global\" for community-level results. For specific memories, use \"local\" (default). Use \"auto\" for automatic fallback.',\n452:       communitySearch: 'When primary search returns weak results, community search fallback activates automatically (SPECKIT_COMMUNITY_SEARCH_FALLBACK). Graph provenance is visible in graphEvidence field.',\n453:       toolRouting: `SEARCH ROUTING: ${toolRoutingRules.join(' | ')}`,\n454:     },\n455:   };\n456: }\n457: \n458: async function primeSessionIfNeeded(\n459:   toolName: string,\n460:   toolArgs: Record<string, unknown>,\n461:   sessionId?: string,\n462: ): Promise<AutoSurfaceResult | null> {\n463:   // Derive a session key from explicit sessionId or tool args.\n464:   const effectiveSessionId = sessionId\n465:     ?? (typeof toolArgs.sessionId === 'string' ? toolArgs.sessionId : null)\n466:     ?? (typeof toolArgs.session_id === 'string' ? toolArgs.session_id : null);\n467: \n468:   if (!effectiveSessionId || effectiveSessionId.trim().length === 0) {\n469:     return null;\n470:   }\n471: \n472:   if (isSessionPrimed(effectiveSessionId)) {\n473:     return null;\n474:   }\n475: \n476:   const startTime = Date.now();\n477:   const contextHint = extractContextHint(toolArgs);\n478: \n479:   try {\n480:     const constitutional = await getConstitutionalMemories();\n481:     const enrichedConstitutional = enrichWithRetrievalDirectives(constitutional);\n482:     const codeGraphStatus = getCodeGraphStatusSnapshot();\n483:     const latencyMs = Date.now() - startTime;\n484: \n485:     // Build structured Prime Package\n486:     const primePackage = buildPrimePackage(toolArgs, codeGraphStatus);\n487: \n488:     // Mark session as primed AFTER successful execution (not before try)\n489:     markSessionPrimed(effectiveSessionId);\n490: \n491:     // Record bootstrap telemetry for MCP auto-priming\n492:     recordBootstrapEvent('mcp_auto', Date.now() - startTime, 'full');\n493: \n494:     if (enrichedConstitutional.length === 0 && codeGraphStatus.status !== 'ok') {\n495:       // Still return the prime package even when no constitutional memories\n496:       return enforceAutoSurfaceTokenBudget({\n497:         constitutional: [],\n498:         triggered: [],\n499:         codeGraphStatus,\n500:         sessionPrimed: true,\n501:         primedTool: toolName,\n502:         primePackage,\n503:         surfaced_at: new Date().toISOString(),\n504:         latencyMs,\n505:       }, TOOL_DISPATCH_TOKEN_BUDGET, 'tool-dispatch');\n506:     }\n507: \n508:     return enforceAutoSurfaceTokenBudget({\n509:       constitutional: enrichedConstitutional,\n510:       triggered: [],\n511:       codeGraphStatus,\n512:       sessionPrimed: true,\n513:       primedTool: toolName,\n514:       primePackage,\n515:       surfaced_at: new Date().toISOString(),\n516:       latencyMs,\n517:     }, TOOL_DISPATCH_TOKEN_BUDGET, 'tool-dispatch');\n518:   } catch (err: unknown) {\n519:     const message = err instanceof Error ? err.message : String(err);\n520:     console.warn(\n521:       `[SK-004] Session priming failed on first tool call '${toolName}'` +\n522:       `${contextHint ? ' with extracted context hint' : ''}: ${message}`\n523:     );\n524:     return null;\n525:   }\n526: }\n527: \n528: /**\n529:  * Reset priming state. When called with a sessionId, clears only that session.\n530:  * When called without arguments, clears all sessions (backward-compatible).\n531:  */\n532: function resetSessionPrimed(sessionId?: string): void {\n533:   if (sessionId) {\n534:     primedSessionIds.delete(sessionId);\n535:   } else {\n536:     primedSessionIds.clear();\n537:   }\n538: }\n539: \n540: /* ───────────────────────────────────────────────────────────────\n541:    TOOL DISPATCH HOOK\n542: ──────────────────────────────────────────────────────────────── */\n543: \n544: /**\n545:  * autoSurfaceAtToolDispatch\n546:  *\n547:  * Fires at tool dispatch lifecycle points. Extracts a context hint from\n548:  * the dispatched tool's arguments, then surfaces relevant memories via\n549:  * the standard autoSurfaceMemories path.\n550:  *\n551:  * Skipped when:\n552:  *   - toolName is in MEMORY_AWARE_TOOLS (prevents recursive surfacing)\n553:  *   - No context hint can be extracted from args\n554:  *   - enableToolDispatchHook is false in the integration config\n555:  *\n556:  * Token budget: TOOL_DISPATCH_TOKEN_BUDGET (4000 max)\n557:  *\n558:  * @param toolName   - Name of the tool being dispatched\n559:  * @param toolArgs   - Arguments passed to the dispatched tool\n560:  * @param options    - Optional integration-layer config flags\n561:  * @returns AutoSurfaceResult or null if nothing to surface / hook disabled\n562:  */\n563: async function autoSurfaceAtToolDispatch(\n564:   toolName: string,\n565:   toolArgs: Record<string, unknown>,\n566:   options?: { enableToolDispatchHook?: boolean }\n567: ): Promise<AutoSurfaceResult | null> {\n568:   // Allow integration layer to disable this hook via config flag\n569:   if (options && options.enableToolDispatchHook === false) {\n570:     return null;\n571:   }\n572: \n573:   // Skip memory-aware tools to prevent recursive surfacing loops\n574:   if (MEMORY_AWARE_TOOLS.has(toolName)) {\n575:     return null;\n576:   }\n577: \n578:   const contextHint = extractContextHint(toolArgs);\n579:   if (!contextHint) {\n580:     return null;\n581:   }\n582: \n583:   // Delegate to the core surface function; token budget is explicitly\n584:   // Enforced at the hook output boundary via estimateTokenCount().\n585:   return autoSurfaceMemories(contextHint, TOOL_DISPATCH_TOKEN_BUDGET, 'tool-dispatch');\n586: }\n587: \n588: /* ───────────────────────────────────────────────────────────────\n589:    COMPACTION HOOK\n590: ──────────────────────────────────────────────────────────────── */\n591: \n592: /**\n593:  * autoSurfaceAtCompaction\n594:  *\n595:  * Fires at session compaction lifecycle points. Surfaces memories relevant\n596:  * to the ongoing session context so that critical knowledge is preserved\n597:  * across the compaction boundary.\n598:  *\n599:  * Skipped when:\n600:  *   - sessionContext is empty or too short to extract signal\n601:  *   - enableCompactionHook is false in the integration config\n602:  *\n603:  * Token budget: COMPACTION_TOKEN_BUDGET (4000 max)\n604:  *\n605:  * @param sessionContext - A textual summary of the current session state\n606:  * @param options        - Optional integration-layer config flags\n607:  * @returns AutoSurfaceResult or null if nothing to surface / hook disabled\n608:  */\n609: async function autoSurfaceAtCompaction(\n610:   sessionContext: string,\n611:   options?: { enableCompactionHook?: boolean }\n612: ): Promise<AutoSurfaceResult | null> {\n613:   // Allow integration layer to disable this hook via config flag\n614:   if (options && options.enableCompactionHook === false) {\n615:     return null;\n616:   }\n617: \n618:   // Require a meaningful context string (at least 3 characters)\n619:   if (!sessionContext || typeof sessionContext !== 'string' || sessionContext.trim().length < 3) {\n620:     return null;\n621:   }\n622: \n623:   // Delegate to the core surface function; token budget is explicitly\n624:   // Enforced at the hook output boundary via estimateTokenCount().\n625:   return autoSurfaceMemories(sessionContext.trim(), COMPACTION_TOKEN_BUDGET, 'compaction');\n626: }\n627: \n628: /* ───────────────────────────────────────────────────────────────\n629:    8. EXPORTS\n630: ──────────────────────────────────────────────────────────────── */\n631: \n632: export {\n633:   // Constants\n634:   MEMORY_AWARE_TOOLS,\n635:   CONSTITUTIONAL_CACHE_TTL,\n636:   TOOL_DISPATCH_TOKEN_BUDGET,\n637:   COMPACTION_TOKEN_BUDGET,\n638: \n639:   // Functions\n640:   extractContextHint,\n641:   getConstitutionalMemories,\n642:   clearConstitutionalCache,\n643:   autoSurfaceMemories,\n644:   primeSessionIfNeeded,\n645:   resetSessionPrimed,\n646:   autoSurfaceAtToolDispatch,\n647:   autoSurfaceAtCompaction,\n648: \n649:   // Session tracking for session_health tool\n650:   recordToolCall,\n651:   getSessionTimestamps,\n652:   getLastActiveSessionId,\n653:   isSessionPrimed,\n654:   markSessionPrimed,\n655:   getCodeGraphStatusSnapshot,\n656: };\n657: \n658: // Export types for session-health handler\n659: export type { PrimePackage, AutoSurfaceResult };\n\n(End of file - total 659 lines)\n</content>","metadata":{"preview":"      LIMIT ?\n    `).all(workingMemory.DECAY_FLOOR, oneHourAgo, limit) as Array<{ memory_id: number }>;\n\n    return new Set(rows.map(r => r.memory_id));\n  } catch (_err: unknown) {\n    // Graceful degradation — working memory boost is optional\n    return new Set();\n  }\n}\n\n/**\n * Phase C: Apply 1.3x boost to trigger-matched results that also appear\n * in the attention-weighted working memory set. Re-sorts results by\n * boosted composite score.\n *\n * @param triggered - Trigger-matched results from matchTriggerPhrases()\n * @param attentionIds - Set of memory IDs from working memory\n * @returns Re-sorted trigger matches with working memory boost applied\n */\nconst ATTENTION_BOOST_FACTOR = 1.3;","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/hooks/memory-surface.ts","text":"      LIMIT ?\n    `).all(workingMemory.DECAY_FLOOR, oneHourAgo, limit) as Array<{ memory_id: number }>;\n\n    return new Set(rows.map(r => r.memory_id));\n  } catch (_err: unknown) {\n    // Graceful degradation — working memory boost is optional\n    return new Set();\n  }\n}\n\n/**\n * Phase C: Apply 1.3x boost to trigger-matched results that also appear\n * in the attention-weighted working memory set. Re-sorts results by\n * boosted composite score.\n *\n * @param triggered - Trigger-matched results from matchTriggerPhrases()\n * @param attentionIds - Set of memory IDs from working memory\n * @returns Re-sorted trigger matches with working memory boost applied\n */\nconst ATTENTION_BOOST_FACTOR = 1.3;\n\nfunction applyAttentionBoost(\n  triggered: triggerMatcher.TriggerMatch[],\n  attentionIds: Set<number>,\n): triggerMatcher.TriggerMatch[] {\n  if (attentionIds.size === 0 || triggered.length === 0) return triggered;\n\n  // Score each result: base = matchedPhrases.length + (importanceWeight * 0.1)\n  // Apply 1.3x multiplier when memory is in working memory set.\n  return [...triggered]\n    .sort((a, b) => {\n      const scoreA = (a.matchedPhrases.length + a.importanceWeight * 0.1) *\n        (attentionIds.has(a.memoryId) ? ATTENTION_BOOST_FACTOR : 1.0);\n      const scoreB = (b.matchedPhrases.length + b.importanceWeight * 0.1) *\n        (attentionIds.has(b.memoryId) ? ATTENTION_BOOST_FACTOR : 1.0);\n      return scoreB - scoreA;\n    });\n}\n\nasync function autoSurfaceMemories(\n  contextHint: string,\n  tokenBudget: number = TOOL_DISPATCH_TOKEN_BUDGET,\n  hookName: 'tool-dispatch' | 'compaction' | 'memory-aware' = 'memory-aware'\n): Promise<AutoSurfaceResult | null> {\n  const startTime = Date.now();\n\n  try {\n    // Get constitutional memories (always surface)\n    const constitutional = await getConstitutionalMemories();\n\n    // Get triggered memories via fast phrase matching\n    let triggered = triggerMatcher.matchTriggerPhrases(contextHint, 5);\n\n    // Phase C: Attention-enriched boost — re-rank triggered results that\n    // also appear in the working memory active set.\n    try {\n      const attentionIds = getAttentionWeightedMemoryIds(5);\n      if (attentionIds.size > 0 && triggered.length > 0) {\n        triggered = applyAttentionBoost(triggered, attentionIds);\n      }\n    } catch (_boostErr: unknown) {\n      // Graceful degradation — attention boost is optional\n    }\n\n    const latencyMs = Date.now() - startTime;\n\n    // Only return if we have something to surface\n    if (constitutional.length === 0 && triggered.length === 0) {\n      return null;\n    }\n\n    // PI-A4: Enrich constitutional memories with retrieval_directive metadata.\n    // Pure content transformation — scoring is unchanged.\n    const enrichedConstitutional = enrichWithRetrievalDirectives(constitutional);\n\n    return enforceAutoSurfaceTokenBudget({\n      constitutional: enrichedConstitutional,\n      triggered: triggered.map((t: triggerMatcher.TriggerMatch) => ({\n        memory_id: t.memoryId,\n        spec_folder: t.specFolder,\n        title: t.title ?? 'Untitled',\n        matched_phrases: t.matchedPhrases,\n      })),\n      surfaced_at: new Date().toISOString(),\n      latencyMs: latencyMs,\n    }, tokenBudget, hookName);\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn('[SK-004] Auto-surface failed:', message);\n    return null;\n  }\n}\n\n/** Build structured Prime Package for non-hook CLI auto-priming */\nfunction buildPrimePackage(\n  toolArgs: Record<string, unknown>,\n  graphSnapshot: NonNullable<AutoSurfaceResult['codeGraphStatus']>,\n): PrimePackage {\n  // Derive specFolder from tool args if provided\n  const specFolder = typeof toolArgs.specFolder === 'string' ? toolArgs.specFolder : null;\n\n  // Derive currentTask from input/query/prompt fields\n  const taskFields = ['input', 'query', 'prompt'] as const;\n  let currentTask: string | null = null;\n  for (const f of taskFields) {\n    if (typeof toolArgs[f] === 'string' && (toolArgs[f] as string).length >= 3) {\n      currentTask = (toolArgs[f] as string).slice(0, 200);\n      break;\n    }\n  }\n\n  // Code graph freshness\n  let codeGraphStatus: PrimePackage['codeGraphStatus'] = 'empty';\n  if (graphSnapshot.status === 'ok' && graphSnapshot.data) {\n    const lastScan = graphSnapshot.data.lastScanAt;\n    const totalFiles = graphSnapshot.data.totalFiles ?? 0;\n    if (totalFiles === 0) {\n      codeGraphStatus = 'empty';\n    } else if (!lastScan || (Date.now() - new Date(lastScan).getTime() > 24 * 60 * 60 * 1000)) {\n      codeGraphStatus = 'stale';\n    } else {\n      codeGraphStatus = 'fresh';\n    }\n  }\n\n  // Build recommended calls based on state\n  const recommendedCalls: string[] = [];\n  if (codeGraphStatus === 'stale' || codeGraphStatus === 'empty') {\n    recommendedCalls.push('code_graph_scan');\n  }\n  if (!specFolder) {\n    recommendedCalls.push('memory_context({ input: \"resume previous work\", mode: \"resume\", profile: \"resume\" })');\n  }\n  if (recommendedCalls.length === 0) {\n    recommendedCalls.push('memory_match_triggers({ prompt: \"<your task>\" })');\n  }\n\n  const toolRoutingRules: string[] = [];\n  if (codeGraphStatus !== 'empty') {\n    toolRoutingRules.push('structural queries (callers, deps) → code_graph_query');\n  }\n  toolRoutingRules.push('exact text/regex → Grep');\n\n  // Structural bootstrap contract for auto-prime surface\n  const structuralContext = buildStructuralBootstrapContract('auto-prime');\n\n  return {\n    specFolder, currentTask, codeGraphStatus, recommendedCalls,\n    structuralContext,\n    routingRules: {\n      graphRetrieval: 'For broad topic questions, use memory_search with retrievalLevel: \"global\" for community-level results. For specific memories, use \"local\" (default). Use \"auto\" for automatic fallback.',\n      communitySearch: 'When primary search returns weak results, community search fallback activates automatically (SPECKIT_COMMUNITY_SEARCH_FALLBACK). Graph provenance is visible in graphEvidence field.',\n      toolRouting: `SEARCH ROUTING: ${toolRoutingRules.join(' | ')}`,\n    },\n  };\n}\n\nasync function primeSessionIfNeeded(\n  toolName: string,\n  toolArgs: Record<string, unknown>,\n  sessionId?: string,\n): Promise<AutoSurfaceResult | null> {\n  // Derive a session key from explicit sessionId or tool args.\n  const effectiveSessionId = sessionId\n    ?? (typeof toolArgs.sessionId === 'string' ? toolArgs.sessionId : null)\n    ?? (typeof toolArgs.session_id === 'string' ? toolArgs.session_id : null);\n\n  if (!effectiveSessionId || effectiveSessionId.trim().length === 0) {\n    return null;\n  }\n\n  if (isSessionPrimed(effectiveSessionId)) {\n    return null;\n  }\n\n  const startTime = Date.now();\n  const contextHint = extractContextHint(toolArgs);\n\n  try {\n    const constitutional = await getConstitutionalMemories();\n    const enrichedConstitutional = enrichWithRetrievalDirectives(constitutional);\n    const codeGraphStatus = getCodeGraphStatusSnapshot();\n    const latencyMs = Date.now() - startTime;\n\n    // Build structured Prime Package\n    const primePackage = buildPrimePackage(toolArgs, codeGraphStatus);\n\n    // Mark session as primed AFTER successful execution (not before try)\n    markSessionPrimed(effectiveSessionId);\n\n    // Record bootstrap telemetry for MCP auto-priming\n    recordBootstrapEvent('mcp_auto', Date.now() - startTime, 'full');\n\n    if (enrichedConstitutional.length === 0 && codeGraphStatus.status !== 'ok') {\n      // Still return the prime package even when no constitutional memories\n      return enforceAutoSurfaceTokenBudget({\n        constitutional: [],\n        triggered: [],\n        codeGraphStatus,\n        sessionPrimed: true,\n        primedTool: toolName,\n        primePackage,\n        surfaced_at: new Date().toISOString(),\n        latencyMs,\n      }, TOOL_DISPATCH_TOKEN_BUDGET, 'tool-dispatch');\n    }\n\n    return enforceAutoSurfaceTokenBudget({\n      constitutional: enrichedConstitutional,\n      triggered: [],\n      codeGraphStatus,\n      sessionPrimed: true,\n      primedTool: toolName,\n      primePackage,\n      surfaced_at: new Date().toISOString(),\n      latencyMs,\n    }, TOOL_DISPATCH_TOKEN_BUDGET, 'tool-dispatch');\n  } catch (err: unknown) {\n    const message = err instanceof Error ? err.message : String(err);\n    console.warn(\n      `[SK-004] Session priming failed on first tool call '${toolName}'` +\n      `${contextHint ? ' with extracted context hint' : ''}: ${message}`\n    );\n    return null;\n  }\n}\n\n/**\n * Reset priming state. When called with a sessionId, clears only that session.\n * When called without arguments, clears all sessions (backward-compatible).\n */\nfunction resetSessionPrimed(sessionId?: string): void {\n  if (sessionId) {\n    primedSessionIds.delete(sessionId);\n  } else {\n    primedSessionIds.clear();\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   TOOL DISPATCH HOOK\n──────────────────────────────────────────────────────────────── */\n\n/**\n * autoSurfaceAtToolDispatch\n *\n * Fires at tool dispatch lifecycle points. Extracts a context hint from\n * the dispatched tool's arguments, then surfaces relevant memories via\n * the standard autoSurfaceMemories path.\n *\n * Skipped when:\n *   - toolName is in MEMORY_AWARE_TOOLS (prevents recursive surfacing)\n *   - No context hint can be extracted from args\n *   - enableToolDispatchHook is false in the integration config\n *\n * Token budget: TOOL_DISPATCH_TOKEN_BUDGET (4000 max)\n *\n * @param toolName   - Name of the tool being dispatched\n * @param toolArgs   - Arguments passed to the dispatched tool\n * @param options    - Optional integration-layer config flags\n * @returns AutoSurfaceResult or null if nothing to surface / hook disabled\n */\nasync function autoSurfaceAtToolDispatch(\n  toolName: string,\n  toolArgs: Record<string, unknown>,\n  options?: { enableToolDispatchHook?: boolean }\n): Promise<AutoSurfaceResult | null> {\n  // Allow integration layer to disable this hook via config flag\n  if (options && options.enableToolDispatchHook === false) {\n    return null;\n  }\n\n  // Skip memory-aware tools to prevent recursive surfacing loops\n  if (MEMORY_AWARE_TOOLS.has(toolName)) {\n    return null;\n  }\n\n  const contextHint = extractContextHint(toolArgs);\n  if (!contextHint) {\n    return null;\n  }\n\n  // Delegate to the core surface function; token budget is explicitly\n  // Enforced at the hook output boundary via estimateTokenCount().\n  return autoSurfaceMemories(contextHint, TOOL_DISPATCH_TOKEN_BUDGET, 'tool-dispatch');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   COMPACTION HOOK\n──────────────────────────────────────────────────────────────── */\n\n/**\n * autoSurfaceAtCompaction\n *\n * Fires at session compaction lifecycle points. Surfaces memories relevant\n * to the ongoing session context so that critical knowledge is preserved\n * across the compaction boundary.\n *\n * Skipped when:\n *   - sessionContext is empty or too short to extract signal\n *   - enableCompactionHook is false in the integration config\n *\n * Token budget: COMPACTION_TOKEN_BUDGET (4000 max)\n *\n * @param sessionContext - A textual summary of the current session state\n * @param options        - Optional integration-layer config flags\n * @returns AutoSurfaceResult or null if nothing to surface / hook disabled\n */\nasync function autoSurfaceAtCompaction(\n  sessionContext: string,\n  options?: { enableCompactionHook?: boolean }\n): Promise<AutoSurfaceResult | null> {\n  // Allow integration layer to disable this hook via config flag\n  if (options && options.enableCompactionHook === false) {\n    return null;\n  }\n\n  // Require a meaningful context string (at least 3 characters)\n  if (!sessionContext || typeof sessionContext !== 'string' || sessionContext.trim().length < 3) {\n    return null;\n  }\n\n  // Delegate to the core surface function; token budget is explicitly\n  // Enforced at the hook output boundary via estimateTokenCount().\n  return autoSurfaceMemories(sessionContext.trim(), COMPACTION_TOKEN_BUDGET, 'compaction');\n}\n\n/* ───────────────────────────────────────────────────────────────\n   8. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nexport {\n  // Constants\n  MEMORY_AWARE_TOOLS,\n  CONSTITUTIONAL_CACHE_TTL,\n  TOOL_DISPATCH_TOKEN_BUDGET,\n  COMPACTION_TOKEN_BUDGET,\n\n  // Functions\n  extractContextHint,\n  getConstitutionalMemories,\n  clearConstitutionalCache,\n  autoSurfaceMemories,\n  primeSessionIfNeeded,\n  resetSessionPrimed,\n  autoSurfaceAtToolDispatch,\n  autoSurfaceAtCompaction,\n\n  // Session tracking for session_health tool\n  recordToolCall,\n  getSessionTimestamps,\n  getLastActiveSessionId,\n  isSessionPrimed,\n  markSessionPrimed,\n  getCodeGraphStatusSnapshot,\n};\n\n// Export types for session-health handler\nexport type { PrimePackage, AutoSurfaceResult };","lineStart":301,"lineEnd":659,"totalLines":659,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/hooks/memory-surface.ts","time":{"start":1780738206065,"end":1780738206070}},"metadata":{"openai":{"itemId":"fc_0905efe70eafd06c016a23e89e02308191a0f0fcca901a57c2"}},"id":"prt_e9c44a96d001yRX3OQQ2qyzYTf","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c44888f001jAFy37Xm751puI"}}
{"type":"tool_use","timestamp":1780738206106,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_XM5tccMfZA7XgsqdJlbvgJKz","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/_routes.yaml","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/_routes.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # DOCTOR ROUTER — CANONICAL ROUTE MANIFEST\n3: # ─────────────────────────────────────────────────────────────────\n4: # Source of truth for /doctor <target> dispatch.\n5: # Read by: .opencode/commands/doctor/speckit.md (the router)\n6: # Validated by: .opencode/commands/doctor/scripts/route-validate.sh\n7: # Consumed by: Skill Advisor lexical lane (per-target trigger_phrases)\n8: #\n9: # Schema (per route):\n10: #   target:           string — positional name the user types\n11: #   yaml:             string — YAML asset filename in assets/\n12: #   setup_vars:       list   — variables the router resolves and passes to YAML\n13: #   allowed_flags:    list   — per-target flag schema (target-first parsing)\n14: #   mutating:         enum   — read-only | add-only | mutates\n15: #   gate3_location:   string — concrete mutation target (or \"n/a\" for read-only)\n16: #   mcp_tools:        list   — subset of router's frontmatter allowed-tools union\n17: #   trigger_phrases:  list   — advisor lexical-routing phrases for this target\n18: #\n19: # Code-graph implementation/docs are owned by .opencode/skills/system-code-graph/;\n20: # stable code_graph/detect_changes MCP tools are registered through mk-code-index.\n21: # Skill-advisor recommendation tools are registered through mk-skill-advisor.\n22: # To add a new target: append a route here, then re-run route-validate.sh.\n23: # To remove a target: delete the route AND its corresponding assets/doctor_<target>.yaml.\n24: # ─────────────────────────────────────────────────────────────────\n25: schema_version: 1\n26: routes:\n27:   - target: memory\n28:     yaml: doctor_memory.yaml\n29:     setup_vars: [execution_mode, intent, incremental, no_snapshot, dry_run]\n30:     allowed_flags: [\"--incremental=true|false\", \"--no-snapshot\", \"--dry-run\"]\n31:     mutating: read-only\n32:     gate3_location: \"n/a (read-only diagnostic; reports drift and recommends action, no DB writes)\"\n33:     mcp_tools:\n34:       - mcp__mk_spec_memory__memory_health\n35:       - mcp__mk_spec_memory__memory_index_scan\n36:       - mcp__mk_spec_memory__memory_drift_why\n37:       - mcp__mk_spec_memory__memory_search\n38:       - mcp__mk_spec_memory__memory_stats\n39:     trigger_phrases:\n40:       - \"memory continuity index drift\"\n41:       - \"memory health rebuild\"\n42:       - \"context-index doctor\"\n43:       - \"voyage embedding rebuild\"\n44: \n45:   - target: embeddings\n46:     yaml: doctor_embeddings.yaml\n47:     setup_vars: [execution_mode]\n48:     allowed_flags: []\n49:     mutating: read-only\n50:     gate3_location: \"n/a (read-only provider and model-server status)\"\n51:     mcp_tools:\n52:       - mcp__mk_spec_memory__embedder_status\n53:     trigger_phrases:\n54:       - \"embedding provider status\"\n55:       - \"hf-local model-server health\"\n56:       - \"embedder_status diagnostics\"\n57: \n58:   - target: causal-graph\n59:     yaml: doctor_causal-graph.yaml\n60:     setup_vars: [execution_mode, intent, confidence_threshold, no_snapshot, dry_run]\n61:     allowed_flags: [\"--confidence-threshold=N\", \"--no-snapshot\", \"--dry-run\"]\n62:     mutating: read-only\n63:     gate3_location: \"n/a (read-only diagnostic; samples causal_edges and recommends candidates, no writes)\"\n64:     mcp_tools:\n65:       - mcp__mk_spec_memory__memory_causal_stats\n66:       - mcp__mk_spec_memory__memory_drift_why\n67:       - mcp__mk_spec_memory__memory_search\n68:     trigger_phrases:\n69:       - \"causal edges drift\"\n70:       - \"causal graph doctor\"\n71:       - \"lineage coverage\"\n72:       - \"memory_causal_stats\"\n73: \n74:   - target: code-graph\n75:     yaml: doctor_code-graph.yaml\n76:     setup_vars: [execution_mode, scope]\n77:     allowed_flags:\n78:       - \"--scope=stale|missed|bloat|all|excludes\"\n79:       - \"--operation=rescan|prune-excludes|repair-nodes|recover-sqlite-corruption|rollback-bad-run\"\n80:       - \"--dry-run\"\n81:       - \"--confirm\"\n82:     mutating: read-only\n83:     gate3_location: \"n/a (Phase A diagnostic is read-only; emits an exclude/language report, never scans or writes the index)\"\n84:     mcp_tools:\n85:       - mcp__mk_code_index__code_graph_status\n86:       - mcp__mk_code_index__code_graph_query\n87:       - mcp__mk_code_index__code_graph_context\n88:       - mcp__mk_code_index__detect_changes\n89:       - mcp__mk_spec_memory__memory_context\n90:       - mcp__mk_spec_memory__memory_search\n91:     trigger_phrases:\n92:       - \"code-graph index drift\"\n93:       - \"code-graph rebuild\"\n94:       - \"code-graph stale excludes\"\n95:       - \"code-graph corruption recover\"\n96: \n97:   - target: deep-loop\n98:     yaml: doctor_deep-loop.yaml\n99:     setup_vars: [execution_mode, intent, scope, no_snapshot, dry_run]\n100:     allowed_flags: [\"--scope=research|review|both\", \"--no-snapshot\", \"--dry-run\"]\n101:     mutating: read-only\n102:     gate3_location: \"n/a (read-only diagnostic; reads coverage graph + iteration folders, never upserts)\"\n103:     mcp_tools: []\n104:     script_invocations:\n105:       - 'node .opencode/skills/deep-loop-runtime/scripts/status.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\"'\n106:       - 'node .opencode/skills/deep-loop-runtime/scripts/query.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\" --query-type \"{query_type}\"'\n107:       - 'node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\"'\n108:     trigger_phrases:\n109:       - \"deep-loop coverage\"\n110:       - \"deep-loop graph rebuild\"\n111:       - \"deep-research convergence drift\"\n112:       - \"deep-review iteration graph\"\n113: \n114:   - target: skill-advisor\n115:     yaml: doctor_skill-advisor.yaml\n116:     setup_vars: [execution_mode, scope, skip_tests, dry_run]\n117:     allowed_flags: [\"--skip-tests\", \"--dry-run\", \"--scope=all|explicit|derived|lexical\"]\n118:     mutating: mutates\n119:     gate3_location: \"lib/scorer/lanes/*.ts + .opencode/skills/*/graph-metadata.json\"\n120:     mcp_tools:\n121:       - mcp__mk_skill_advisor__advisor_recommend\n122:       - mcp__mk_skill_advisor__advisor_status\n123:       - mcp__mk_skill_advisor__advisor_validate\n124:       - mcp__mk_skill_advisor__advisor_rebuild\n125:       - mcp__mk_skill_advisor__skill_graph_scan\n126:       - mcp__mk_skill_advisor__skill_graph_query\n127:       - mcp__mk_skill_advisor__skill_graph_status\n128:       - mcp__mk_spec_memory__memory_context\n129:       - mcp__mk_spec_memory__memory_search\n130:     trigger_phrases:\n131:       - \"skill advisor scoring\"\n132:       - \"skill advisor rebuild\"\n133:       - \"advisor recommendation tuning\"\n134:       - \"skill_graph scan\"\n135: \n136:   - target: skill-budget\n137:     yaml: doctor_skill-budget.yaml\n138:     setup_vars: [execution_mode, json_output, top_n, fail_over, project_ceiling]\n139:     allowed_flags: [\"--json\", \"--top-n=N\", \"--fail-over=N\", \"--project-ceiling=N\"]\n140:     mutating: read-only\n141:     gate3_location: \"n/a (read-only audit; no spec folder required)\"\n142:     mcp_tools: []   # script-only audit; no MCP calls\n143:     trigger_phrases:\n144:       - \"skill budget audit\"\n145:       - \"description budget check\"\n146:       - \"skill char count drift\"\n147:       - \"frontmatter description trim\"\n148: \n149: # ─────────────────────────────────────────────────────────────────\n150: # COMPANION COMMAND ROUTES (/doctor:mcp sub-actions)\n151: # ─────────────────────────────────────────────────────────────────\n152: # /doctor:mcp dispatches via its own command (.opencode/commands/doctor/mcp.md).\n153: # These rows are tracked here for advisor + CI visibility only — the mcp.md\n154: # command parses its own sub-action argv and dispatches to the right YAML.\n155: # ─────────────────────────────────────────────────────────────────\n156: mcp_subroutes:\n157:   - sub_action: install\n158:     yaml: doctor_mcp_install.yaml\n159:     allowed_flags: [\"--server <name>\", \"--runtime <name>\"]\n160:     mutating: mutates\n161:     gate3_location: \"MCP server install dirs + runtime config (.opencode.json / .claude/settings.json / .codex/config.toml)\"\n162:     trigger_phrases:\n163:       - \"MCP install\"\n164:       - \"MCP server fresh install\"\n165:       - \"reinstall MCP\"\n166: \n167:   - sub_action: debug\n168:     yaml: doctor_mcp_debug.yaml\n169:     allowed_flags: [\"--fix\", \"--server <name>\"]\n170:     mutating: mutates\n171:     gate3_location: \"MCP server logs + runtime config repair\"\n172:     trigger_phrases:\n173:       - \"MCP server broken\"\n174:       - \"MCP debug\"\n175:       - \"MCP connection failure\"\n176:       - \"mcp-doctor.sh\"\n177: \n178: # ─────────────────────────────────────────────────────────────────\n179: # ORCHESTRATOR (NOT routed through /doctor — kept here for reference)\n180: # ─────────────────────────────────────────────────────────────────\n181: # /doctor:update is a STANDALONE command at .opencode/commands/doctor/update.md.\n182: # It does NOT route through /doctor. This block exists for advisor visibility.\n183: # ─────────────────────────────────────────────────────────────────\n184: standalone:\n185:   - command: /doctor:update\n186:     file: .opencode/commands/doctor/update.md\n187:     yaml: doctor_update.yaml\n188:     mutating: mutates\n189:     trigger_phrases:\n190:       - \"spec-kit version migration\"\n191:       - \"doctor update orchestrator\"\n192:       - \"rebuild all spec-kit databases\"\n193:       - \"doctor full sync\"\n\n(End of file - total 193 lines)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# DOCTOR ROUTER — CANONICAL ROUTE MANIFEST\n# ─────────────────────────────────────────────────────────────────\n# Source of truth for /doctor <target> dispatch.\n# Read by: .opencode/commands/doctor/speckit.md (the router)\n# Validated by: .opencode/commands/doctor/scripts/route-validate.sh\n# Consumed by: Skill Advisor lexical lane (per-target trigger_phrases)\n#\n# Schema (per route):\n#   target:           string — positional name the user types\n#   yaml:             string — YAML asset filename in assets/\n#   setup_vars:       list   — variables the router resolves and passes to YAML\n#   allowed_flags:    list   — per-target flag schema (target-first parsing)\n#   mutating:         enum   — read-only | add-only | mutates\n#   gate3_location:   string — concrete mutation target (or \"n/a\" for read-only)\n#   mcp_tools:        list   — subset of router's frontmatter allowed-tools union\n#   trigger_phrases:  list   — advisor lexical-routing phrases for this target\n#\n# Code-graph implementation/docs are owned by .opencode/skills/system-code-graph/;\n# stable code_graph/detect_changes MCP tools are registered through mk-code-index.","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/_routes.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# DOCTOR ROUTER — CANONICAL ROUTE MANIFEST\n# ─────────────────────────────────────────────────────────────────\n# Source of truth for /doctor <target> dispatch.\n# Read by: .opencode/commands/doctor/speckit.md (the router)\n# Validated by: .opencode/commands/doctor/scripts/route-validate.sh\n# Consumed by: Skill Advisor lexical lane (per-target trigger_phrases)\n#\n# Schema (per route):\n#   target:           string — positional name the user types\n#   yaml:             string — YAML asset filename in assets/\n#   setup_vars:       list   — variables the router resolves and passes to YAML\n#   allowed_flags:    list   — per-target flag schema (target-first parsing)\n#   mutating:         enum   — read-only | add-only | mutates\n#   gate3_location:   string — concrete mutation target (or \"n/a\" for read-only)\n#   mcp_tools:        list   — subset of router's frontmatter allowed-tools union\n#   trigger_phrases:  list   — advisor lexical-routing phrases for this target\n#\n# Code-graph implementation/docs are owned by .opencode/skills/system-code-graph/;\n# stable code_graph/detect_changes MCP tools are registered through mk-code-index.\n# Skill-advisor recommendation tools are registered through mk-skill-advisor.\n# To add a new target: append a route here, then re-run route-validate.sh.\n# To remove a target: delete the route AND its corresponding assets/doctor_<target>.yaml.\n# ─────────────────────────────────────────────────────────────────\nschema_version: 1\nroutes:\n  - target: memory\n    yaml: doctor_memory.yaml\n    setup_vars: [execution_mode, intent, incremental, no_snapshot, dry_run]\n    allowed_flags: [\"--incremental=true|false\", \"--no-snapshot\", \"--dry-run\"]\n    mutating: read-only\n    gate3_location: \"n/a (read-only diagnostic; reports drift and recommends action, no DB writes)\"\n    mcp_tools:\n      - mcp__mk_spec_memory__memory_health\n      - mcp__mk_spec_memory__memory_index_scan\n      - mcp__mk_spec_memory__memory_drift_why\n      - mcp__mk_spec_memory__memory_search\n      - mcp__mk_spec_memory__memory_stats\n    trigger_phrases:\n      - \"memory continuity index drift\"\n      - \"memory health rebuild\"\n      - \"context-index doctor\"\n      - \"voyage embedding rebuild\"\n\n  - target: embeddings\n    yaml: doctor_embeddings.yaml\n    setup_vars: [execution_mode]\n    allowed_flags: []\n    mutating: read-only\n    gate3_location: \"n/a (read-only provider and model-server status)\"\n    mcp_tools:\n      - mcp__mk_spec_memory__embedder_status\n    trigger_phrases:\n      - \"embedding provider status\"\n      - \"hf-local model-server health\"\n      - \"embedder_status diagnostics\"\n\n  - target: causal-graph\n    yaml: doctor_causal-graph.yaml\n    setup_vars: [execution_mode, intent, confidence_threshold, no_snapshot, dry_run]\n    allowed_flags: [\"--confidence-threshold=N\", \"--no-snapshot\", \"--dry-run\"]\n    mutating: read-only\n    gate3_location: \"n/a (read-only diagnostic; samples causal_edges and recommends candidates, no writes)\"\n    mcp_tools:\n      - mcp__mk_spec_memory__memory_causal_stats\n      - mcp__mk_spec_memory__memory_drift_why\n      - mcp__mk_spec_memory__memory_search\n    trigger_phrases:\n      - \"causal edges drift\"\n      - \"causal graph doctor\"\n      - \"lineage coverage\"\n      - \"memory_causal_stats\"\n\n  - target: code-graph\n    yaml: doctor_code-graph.yaml\n    setup_vars: [execution_mode, scope]\n    allowed_flags:\n      - \"--scope=stale|missed|bloat|all|excludes\"\n      - \"--operation=rescan|prune-excludes|repair-nodes|recover-sqlite-corruption|rollback-bad-run\"\n      - \"--dry-run\"\n      - \"--confirm\"\n    mutating: read-only\n    gate3_location: \"n/a (Phase A diagnostic is read-only; emits an exclude/language report, never scans or writes the index)\"\n    mcp_tools:\n      - mcp__mk_code_index__code_graph_status\n      - mcp__mk_code_index__code_graph_query\n      - mcp__mk_code_index__code_graph_context\n      - mcp__mk_code_index__detect_changes\n      - mcp__mk_spec_memory__memory_context\n      - mcp__mk_spec_memory__memory_search\n    trigger_phrases:\n      - \"code-graph index drift\"\n      - \"code-graph rebuild\"\n      - \"code-graph stale excludes\"\n      - \"code-graph corruption recover\"\n\n  - target: deep-loop\n    yaml: doctor_deep-loop.yaml\n    setup_vars: [execution_mode, intent, scope, no_snapshot, dry_run]\n    allowed_flags: [\"--scope=research|review|both\", \"--no-snapshot\", \"--dry-run\"]\n    mutating: read-only\n    gate3_location: \"n/a (read-only diagnostic; reads coverage graph + iteration folders, never upserts)\"\n    mcp_tools: []\n    script_invocations:\n      - 'node .opencode/skills/deep-loop-runtime/scripts/status.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\"'\n      - 'node .opencode/skills/deep-loop-runtime/scripts/query.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\" --query-type \"{query_type}\"'\n      - 'node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"{spec_folder}\" --loop-type \"{loop_type}\" --session-id \"{session_id}\"'\n    trigger_phrases:\n      - \"deep-loop coverage\"\n      - \"deep-loop graph rebuild\"\n      - \"deep-research convergence drift\"\n      - \"deep-review iteration graph\"\n\n  - target: skill-advisor\n    yaml: doctor_skill-advisor.yaml\n    setup_vars: [execution_mode, scope, skip_tests, dry_run]\n    allowed_flags: [\"--skip-tests\", \"--dry-run\", \"--scope=all|explicit|derived|lexical\"]\n    mutating: mutates\n    gate3_location: \"lib/scorer/lanes/*.ts + .opencode/skills/*/graph-metadata.json\"\n    mcp_tools:\n      - mcp__mk_skill_advisor__advisor_recommend\n      - mcp__mk_skill_advisor__advisor_status\n      - mcp__mk_skill_advisor__advisor_validate\n      - mcp__mk_skill_advisor__advisor_rebuild\n      - mcp__mk_skill_advisor__skill_graph_scan\n      - mcp__mk_skill_advisor__skill_graph_query\n      - mcp__mk_skill_advisor__skill_graph_status\n      - mcp__mk_spec_memory__memory_context\n      - mcp__mk_spec_memory__memory_search\n    trigger_phrases:\n      - \"skill advisor scoring\"\n      - \"skill advisor rebuild\"\n      - \"advisor recommendation tuning\"\n      - \"skill_graph scan\"\n\n  - target: skill-budget\n    yaml: doctor_skill-budget.yaml\n    setup_vars: [execution_mode, json_output, top_n, fail_over, project_ceiling]\n    allowed_flags: [\"--json\", \"--top-n=N\", \"--fail-over=N\", \"--project-ceiling=N\"]\n    mutating: read-only\n    gate3_location: \"n/a (read-only audit; no spec folder required)\"\n    mcp_tools: []   # script-only audit; no MCP calls\n    trigger_phrases:\n      - \"skill budget audit\"\n      - \"description budget check\"\n      - \"skill char count drift\"\n      - \"frontmatter description trim\"\n\n# ─────────────────────────────────────────────────────────────────\n# COMPANION COMMAND ROUTES (/doctor:mcp sub-actions)\n# ─────────────────────────────────────────────────────────────────\n# /doctor:mcp dispatches via its own command (.opencode/commands/doctor/mcp.md).\n# These rows are tracked here for advisor + CI visibility only — the mcp.md\n# command parses its own sub-action argv and dispatches to the right YAML.\n# ─────────────────────────────────────────────────────────────────\nmcp_subroutes:\n  - sub_action: install\n    yaml: doctor_mcp_install.yaml\n    allowed_flags: [\"--server <name>\", \"--runtime <name>\"]\n    mutating: mutates\n    gate3_location: \"MCP server install dirs + runtime config (.opencode.json / .claude/settings.json / .codex/config.toml)\"\n    trigger_phrases:\n      - \"MCP install\"\n      - \"MCP server fresh install\"\n      - \"reinstall MCP\"\n\n  - sub_action: debug\n    yaml: doctor_mcp_debug.yaml\n    allowed_flags: [\"--fix\", \"--server <name>\"]\n    mutating: mutates\n    gate3_location: \"MCP server logs + runtime config repair\"\n    trigger_phrases:\n      - \"MCP server broken\"\n      - \"MCP debug\"\n      - \"MCP connection failure\"\n      - \"mcp-doctor.sh\"\n\n# ─────────────────────────────────────────────────────────────────\n# ORCHESTRATOR (NOT routed through /doctor — kept here for reference)\n# ─────────────────────────────────────────────────────────────────\n# /doctor:update is a STANDALONE command at .opencode/commands/doctor/update.md.\n# It does NOT route through /doctor. This block exists for advisor visibility.\n# ─────────────────────────────────────────────────────────────────\nstandalone:\n  - command: /doctor:update\n    file: .opencode/commands/doctor/update.md\n    yaml: doctor_update.yaml\n    mutating: mutates\n    trigger_phrases:\n      - \"spec-kit version migration\"\n      - \"doctor update orchestrator\"\n      - \"rebuild all spec-kit databases\"\n      - \"doctor full sync\"","lineStart":1,"lineEnd":193,"totalLines":193,"truncated":false}},"title":".opencode/commands/doctor/_routes.yaml","time":{"start":1780738206101,"end":1780738206104}},"metadata":{"openai":{"itemId":"fc_0905efe70eafd06c016a23e89e024c8191a7ab33e229dff883"}},"id":"prt_e9c44a98b001YK8BOCsKSDxhRY","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c44888f001jAFy37Xm751puI"}}
{"type":"tool_use","timestamp":1780738206116,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_zTis9NThTKr2uCsmLIzk0IU5","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/assets/doctor_memory.yaml","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/assets/doctor_memory.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # DOCTOR: MEMORY CONTINUITY-INDEX WORKFLOW (INTERACTIVE DIAGNOSTIC MODE)\n3: # ─────────────────────────────────────────────────────────────────\n4: role: Expert Operator running memory continuity-index diagnostics in interactive mode\n5: purpose: Read-only health check + drift detection with user review gates. No mutations. Report goes to packet-local scratch.\n6: action: Discovery → gate → analysis → gate → drift classification → recommendation → state log\n7: \n8: # ─────────────────────────────────────────────────────────────────\n9: # OPERATING MODE\n10: # ─────────────────────────────────────────────────────────────────\n11: operating_mode:\n12:   workflow: sequential\n13:   compliance: MANDATORY\n14:   execution: interactive\n15:   approvals: per_phase\n16:   tracking: phase_by_phase\n17:   validation: continuous_self_validation\n18:   intent: DIAGNOSE  # never APPLY in this YAML\n19: \n20: \n21: memory_doctor_invariant: |\n22:   Memory doctor is read-only by contract. It treats the active provider-keyed\n23:   profile DBs (ollama, hf-local, voyage, and openai profiles matching\n24:   context-index__*.sqlite) as the memory-owned stores it diagnoses but never\n25:   mutates. Rebuilds are owned by the /doctor:update orchestrator, which relies on\n26:   the per-file memory_index_scan transaction model so SIGINT uses the ~5 sec settle\n27:   window before restoring snapshots for cross-file consistency.\n28: \n29: upstream_assets:\n30:   contract: \"local command design contract\"\n31:   files:\n32:     spec: \"spec.md\"  # REQ-005..REQ-007 cover flock, snapshots, dashboard\n33:     decision_record: \"decision-record.md\"  # ADR-001 documents memory_index_scan tx model\n34:     tx_model: \"decision-record.md#adr-001\"  # per-file transactions + ~5 sec SIGINT settle\n35:     checklist: \"checklist.md#doctor-memory\"  # CHK-104 gold-battery acceptance bar\n36:   pass_policy:\n37:     minimum_result_count_per_query: 1  # existing memory gold-battery floor\n38:     post_result_count_floor_ratio: 0.80  # preserve current workflow threshold\n39:     recall_at_20_floor_ratio: 0.80  # preserve current Recall@20 proxy\n40: memory_doctor_philosophy:\n41:   principle: \"Detect drift before it breaks memory_search; this command never mutates — rebuilds run through /doctor:update\"\n42:   approach: \"Read memory_health + memory_stats → classify drift signals → emit recommendations\"\n43:   mandate: \"This command is read-only by contract.\"\n44: \n45: # ─────────────────────────────────────────────────────────────────\n46: # USER INPUTS (passed from Markdown setup phase)\n47: # ─────────────────────────────────────────────────────────────────\n48: user_inputs:\n49:   execution_mode: \"[EXECUTION_MODE] - INTERACTIVE (this YAML)\"\n50:   intent: \"[INTENT] - DIAGNOSE (this YAML)\"\n51:   incremental: \"[INCREMENTAL] - true|false (informational; no rebuild in this command)\"\n52: \n53: # ─────────────────────────────────────────────────────────────────\n54: # MUTATION BOUNDARIES (READ-ONLY)\n55: # ─────────────────────────────────────────────────────────────────\n56: \n57: field_handling:\n58:   defaults:\n59:     incremental_empty: \"false\"\n60:   incremental_policy:\n61:     true: \"diagnostic input only; recommend incremental apply when medium drift is detected\"\n62:     false: \"diagnostic input only; recommend full apply when high-severity drift is detected\"\n63: mutation_boundaries:\n64:   allowed_targets:\n65:     - \"mcp_server/database/context-index__*.sqlite\"  # provider-keyed active profile DBs\n66:     - \"mcp_server/database/context-index*.sqlite.pre-doctor-memory.*.bak\"  # memory snapshot files only\n67:   forbidden_targets:\n68:     - \"<active-spec-folder>/**/*.md\"  # never write into spec packet docs from /doctor memory\n69:     - \"<active-spec-folder>/description.json\"  # spec metadata belongs to memory-save tooling\n70:     - \"<active-spec-folder>/graph-metadata.json\"  # graph metadata is not a memory doctor target\n71:     - \".opencode/skills/**/SKILL.md\"  # never edit skill bodies\n72:     - \".opencode/skills/**/graph-metadata.json\"\n73:     - \".opencode/agents/**/*.md\"\n74:     - \".opencode/commands/doctor/*.md\"\n75:     - \".opencode/commands/doctor/assets/doctor_*.yaml\"\n76:     - \"mcp_server/database/*code-graph*\"\n77:     - \"mcp_server/database/*deep-loop*\"\n78:     - \"mcp_server/database/*eval*\"\n79:     - \"mcp_server/database/*skill*\"\n80:     - \"mcp_server/database/*causal*\"\n81:   enforcement: \"This command is READ-ONLY by contract. No mutation phases exist in this YAML. Any attempted write halts with STATUS=FAIL and ERROR='confirm-mode-mutation-violation'.\"\n82:   validator:\n83:     name: validate_targets\n84:     runs: \"before any file write; diagnostic mode should never reach a write path\"\n85:     steps:\n86:       - \"For each target: resolve via realpath; reject absolute paths; reject paths containing `..` or symlinks escaping repo root\"\n87:       - \"Assert resolved target is repo-relative under repo_root\"\n88:       - \"Match resolved target against allowed_targets patterns only\"\n89:       - \"Reject any match against forbidden_targets patterns\"\n90:       - \"On first violation: abort, append violation to state log, exit STATUS=FAIL with diagnostic\"\n91:     on_pass: \"diagnostic reads may continue\"\n92:     on_fail: \"abort before any write; STATUS=FAIL ERROR=\\\"target validation failed: <path>\\\"\"\n93: \n94: # ─────────────────────────────────────────────────────────────────\n95: # INTERACTIVE GATES\n96: # ─────────────────────────────────────────────────────────────────\n97: interactive_gates:\n98:   before_phase_1_analysis:\n99:     prompt: \"Phase 0 complete. Continue to Phase 1? (y/n/details)\"\n100:     blocking: true\n101:     approvals:\n102:       y: \"continue to phase_1_analysis\"\n103:       n: \"STATUS=CANCELLED; emit state log with phase=phase_0_discovery\"\n104:       details: \"print Phase 0 discovery outputs, then ask again\"\n105:   before_phase_2_recommendation:\n106:     prompt: \"Phase 1 complete. Continue to Phase 2? (y/n/details)\"\n107:     blocking: true\n108:     approvals:\n109:       y: \"continue to phase_2_recommendation\"\n110:       n: \"STATUS=CANCELLED; emit state log with phase=phase_1_analysis\"\n111:       details: \"print Phase 1 drift classification outputs, then ask again\"\n112: \n113: # ─────────────────────────────────────────────────────────────────\n114: # STALENESS SIGNALS\n115: # ─────────────────────────────────────────────────────────────────\n116: staleness_signals:\n117:   embedding_drift:\n118:     detection: \"memory_health reports `embedding_health: degraded` OR records with `last_indexed_at` older than source file mtime\"\n119:     severity: medium\n120:   fts_miss:\n121:     detection: \"memory_health reports `fts_health: degraded` OR new spec-doc files not in FTS index\"\n122:     severity: medium\n123:   chunk_boundary_drift:\n124:     detection: \"Anchors moved or sections renumbered since last index\"\n125:     severity: low\n126:   trigger_phrase_drift:\n127:     detection: \"Frontmatter trigger_phrases updated but indexed alias rows stale\"\n128:     severity: low\n129:   embedding_provider_change:\n130:     detection: \"Vector DB rows with old provider id (voyage-2 vs voyage-4)\"\n131:     severity: high\n132:   divergent_alias_groups:\n133:     detection: \"Same canonical name routed to different record IDs\"\n134:     severity: high\n135: \n136: # ─────────────────────────────────────────────────────────────────\n137: # WORKFLOW\n138: # ─────────────────────────────────────────────────────────────────\n139: workflow:\n140:   phase_0_discovery:\n141:     purpose: Probe memory_health + memory_stats; capture baseline\n142:     activities:\n143:       - \"Run: memory_health({reportMode: 'full'})\"\n144:       - \"Run: memory_stats({})\"\n145:       - \"Bash: stat -f '%m %z' database/context-index__*.sqlite (mtime + size for present profile DBs)\"\n146:       - \"Interactive gate: before_phase_1_analysis\"\n147:     outputs:\n148:       - total_records: N\n149:       - last_index_at: ISO_timestamp\n150:       - fts_health: ok|degraded|missing\n151:       - embedding_health: ok|degraded|missing\n152:       - profile_db_sizes: [{path: string, size: bytes}]\n153:       - profile_db_mtimes: [{path: string, mtime: epoch_seconds}]\n154:     validation: discovery_complete\n155:     fail_fast:\n156:       - \"memory_health returns error → STATUS=FAIL with diagnostic\"\n157:       - \"Database file missing → STATUS=DEGRADED, message='index not initialized'\"\n158: \n159:   phase_1_analysis:\n160:     purpose: Classify drift signals + identify suspect records\n161:     activities:\n162:       - \"Cross-reference memory_health output with mtime: any spec-doc file with mtime > last_index_at signals staleness\"\n163:       - \"Sample up to 5 records flagged as drift candidates\"\n164:       - \"Run memory_drift_why per sampled record (read-only)\"\n165:       - \"Aggregate drift signals into drift_classes count map\"\n166:       - \"Interactive gate: before_phase_2_recommendation\"\n167:     outputs:\n168:       - drift_classes:\n169:           embedding_drift: N\n170:           fts_miss: M\n171:           chunk_boundary_drift: K\n172:           trigger_phrase_drift: L\n173:           embedding_provider_change: P\n174:           divergent_alias_groups: Q\n175:       - sample_drift_explanations: [up to 5 entries]\n176:       - severity_max: low|medium|high\n177:     validation: analysis_complete\n178: \n179:   phase_2_recommendation:\n180:     purpose: Translate drift signals into recommended action\n181:     rules:\n182:       - \"If severity_max == high (provider change OR divergent aliases) → recommend a full rebuild via /doctor:update\"\n183:       - \"If severity_max == medium (embedding OR fts drift) → recommend an incremental rebuild via /doctor:update\"\n184:       - \"If severity_max == low (boundary OR trigger drift) → recommend monitoring; rerun in 1-2 weeks\"\n185:       - \"If no drift → status=OK, no action needed\"\n186:     outputs:\n187:       - status: OK|DEGRADED|STALE|MISSING\n188:       - recommended_command: string\n189:       - recommended_when: now|low-activity-window|monitor\n190: \n191:   phase_3_report:\n192:     purpose: Emit packet-local report + state log\n193:     activities:\n194:       - \"Compose report following OUTPUT CONTRACT in memory.md\"\n195:       - \"Write to <packet_scratch>/doctor-memory-report.<timestamp>.md\"\n196:       - \"Print summary table to stdout\"\n197:     outputs:\n198:       - report_path: string\n199:       - status: STATUS_OK | STATUS_DEGRADED | STATUS_STALE | STATUS_MISSING\n200:     validation: report_emitted\n201: \n202: # ─────────────────────────────────────────────────────────────────\n203: # OUTPUT CONTRACT\n204: # ─────────────────────────────────────────────────────────────────\n205: output_contract:\n206:   format: markdown\n207:   required_sections:\n208:     - status_header\n209:     - database_state_table\n210:     - drift_signals_block\n211:     - recommendation_block\n212:   optional_sections:\n213:     - sample_drift_explanations\n214:   state_log:\n215:     path: \"<packet_scratch>/doctor-memory-state.<timestamp>.json\"\n216:     schema:\n217:       command: \"/doctor memory\"\n218:       mode: INTERACTIVE\n219:       intent: DIAGNOSE\n220:       timestamp: ISO_8601\n\n(Showing lines 1-220 of 233. Use offset=221 to continue.)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# DOCTOR: MEMORY CONTINUITY-INDEX WORKFLOW (INTERACTIVE DIAGNOSTIC MODE)\n# ─────────────────────────────────────────────────────────────────\nrole: Expert Operator running memory continuity-index diagnostics in interactive mode\npurpose: Read-only health check + drift detection with user review gates. No mutations. Report goes to packet-local scratch.\naction: Discovery → gate → analysis → gate → drift classification → recommendation → state log\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING MODE\n# ─────────────────────────────────────────────────────────────────\noperating_mode:\n  workflow: sequential\n  compliance: MANDATORY\n  execution: interactive\n  approvals: per_phase\n  tracking: phase_by_phase\n  validation: continuous_self_validation\n  intent: DIAGNOSE  # never APPLY in this YAML\n\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/assets/doctor_memory.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# DOCTOR: MEMORY CONTINUITY-INDEX WORKFLOW (INTERACTIVE DIAGNOSTIC MODE)\n# ─────────────────────────────────────────────────────────────────\nrole: Expert Operator running memory continuity-index diagnostics in interactive mode\npurpose: Read-only health check + drift detection with user review gates. No mutations. Report goes to packet-local scratch.\naction: Discovery → gate → analysis → gate → drift classification → recommendation → state log\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING MODE\n# ─────────────────────────────────────────────────────────────────\noperating_mode:\n  workflow: sequential\n  compliance: MANDATORY\n  execution: interactive\n  approvals: per_phase\n  tracking: phase_by_phase\n  validation: continuous_self_validation\n  intent: DIAGNOSE  # never APPLY in this YAML\n\n\nmemory_doctor_invariant: |\n  Memory doctor is read-only by contract. It treats the active provider-keyed\n  profile DBs (ollama, hf-local, voyage, and openai profiles matching\n  context-index__*.sqlite) as the memory-owned stores it diagnoses but never\n  mutates. Rebuilds are owned by the /doctor:update orchestrator, which relies on\n  the per-file memory_index_scan transaction model so SIGINT uses the ~5 sec settle\n  window before restoring snapshots for cross-file consistency.\n\nupstream_assets:\n  contract: \"local command design contract\"\n  files:\n    spec: \"spec.md\"  # REQ-005..REQ-007 cover flock, snapshots, dashboard\n    decision_record: \"decision-record.md\"  # ADR-001 documents memory_index_scan tx model\n    tx_model: \"decision-record.md#adr-001\"  # per-file transactions + ~5 sec SIGINT settle\n    checklist: \"checklist.md#doctor-memory\"  # CHK-104 gold-battery acceptance bar\n  pass_policy:\n    minimum_result_count_per_query: 1  # existing memory gold-battery floor\n    post_result_count_floor_ratio: 0.80  # preserve current workflow threshold\n    recall_at_20_floor_ratio: 0.80  # preserve current Recall@20 proxy\nmemory_doctor_philosophy:\n  principle: \"Detect drift before it breaks memory_search; this command never mutates — rebuilds run through /doctor:update\"\n  approach: \"Read memory_health + memory_stats → classify drift signals → emit recommendations\"\n  mandate: \"This command is read-only by contract.\"\n\n# ─────────────────────────────────────────────────────────────────\n# USER INPUTS (passed from Markdown setup phase)\n# ─────────────────────────────────────────────────────────────────\nuser_inputs:\n  execution_mode: \"[EXECUTION_MODE] - INTERACTIVE (this YAML)\"\n  intent: \"[INTENT] - DIAGNOSE (this YAML)\"\n  incremental: \"[INCREMENTAL] - true|false (informational; no rebuild in this command)\"\n\n# ─────────────────────────────────────────────────────────────────\n# MUTATION BOUNDARIES (READ-ONLY)\n# ─────────────────────────────────────────────────────────────────\n\nfield_handling:\n  defaults:\n    incremental_empty: \"false\"\n  incremental_policy:\n    true: \"diagnostic input only; recommend incremental apply when medium drift is detected\"\n    false: \"diagnostic input only; recommend full apply when high-severity drift is detected\"\nmutation_boundaries:\n  allowed_targets:\n    - \"mcp_server/database/context-index__*.sqlite\"  # provider-keyed active profile DBs\n    - \"mcp_server/database/context-index*.sqlite.pre-doctor-memory.*.bak\"  # memory snapshot files only\n  forbidden_targets:\n    - \"<active-spec-folder>/**/*.md\"  # never write into spec packet docs from /doctor memory\n    - \"<active-spec-folder>/description.json\"  # spec metadata belongs to memory-save tooling\n    - \"<active-spec-folder>/graph-metadata.json\"  # graph metadata is not a memory doctor target\n    - \".opencode/skills/**/SKILL.md\"  # never edit skill bodies\n    - \".opencode/skills/**/graph-metadata.json\"\n    - \".opencode/agents/**/*.md\"\n    - \".opencode/commands/doctor/*.md\"\n    - \".opencode/commands/doctor/assets/doctor_*.yaml\"\n    - \"mcp_server/database/*code-graph*\"\n    - \"mcp_server/database/*deep-loop*\"\n    - \"mcp_server/database/*eval*\"\n    - \"mcp_server/database/*skill*\"\n    - \"mcp_server/database/*causal*\"\n  enforcement: \"This command is READ-ONLY by contract. No mutation phases exist in this YAML. Any attempted write halts with STATUS=FAIL and ERROR='confirm-mode-mutation-violation'.\"\n  validator:\n    name: validate_targets\n    runs: \"before any file write; diagnostic mode should never reach a write path\"\n    steps:\n      - \"For each target: resolve via realpath; reject absolute paths; reject paths containing `..` or symlinks escaping repo root\"\n      - \"Assert resolved target is repo-relative under repo_root\"\n      - \"Match resolved target against allowed_targets patterns only\"\n      - \"Reject any match against forbidden_targets patterns\"\n      - \"On first violation: abort, append violation to state log, exit STATUS=FAIL with diagnostic\"\n    on_pass: \"diagnostic reads may continue\"\n    on_fail: \"abort before any write; STATUS=FAIL ERROR=\\\"target validation failed: <path>\\\"\"\n\n# ─────────────────────────────────────────────────────────────────\n# INTERACTIVE GATES\n# ─────────────────────────────────────────────────────────────────\ninteractive_gates:\n  before_phase_1_analysis:\n    prompt: \"Phase 0 complete. Continue to Phase 1? (y/n/details)\"\n    blocking: true\n    approvals:\n      y: \"continue to phase_1_analysis\"\n      n: \"STATUS=CANCELLED; emit state log with phase=phase_0_discovery\"\n      details: \"print Phase 0 discovery outputs, then ask again\"\n  before_phase_2_recommendation:\n    prompt: \"Phase 1 complete. Continue to Phase 2? (y/n/details)\"\n    blocking: true\n    approvals:\n      y: \"continue to phase_2_recommendation\"\n      n: \"STATUS=CANCELLED; emit state log with phase=phase_1_analysis\"\n      details: \"print Phase 1 drift classification outputs, then ask again\"\n\n# ─────────────────────────────────────────────────────────────────\n# STALENESS SIGNALS\n# ─────────────────────────────────────────────────────────────────\nstaleness_signals:\n  embedding_drift:\n    detection: \"memory_health reports `embedding_health: degraded` OR records with `last_indexed_at` older than source file mtime\"\n    severity: medium\n  fts_miss:\n    detection: \"memory_health reports `fts_health: degraded` OR new spec-doc files not in FTS index\"\n    severity: medium\n  chunk_boundary_drift:\n    detection: \"Anchors moved or sections renumbered since last index\"\n    severity: low\n  trigger_phrase_drift:\n    detection: \"Frontmatter trigger_phrases updated but indexed alias rows stale\"\n    severity: low\n  embedding_provider_change:\n    detection: \"Vector DB rows with old provider id (voyage-2 vs voyage-4)\"\n    severity: high\n  divergent_alias_groups:\n    detection: \"Same canonical name routed to different record IDs\"\n    severity: high\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW\n# ─────────────────────────────────────────────────────────────────\nworkflow:\n  phase_0_discovery:\n    purpose: Probe memory_health + memory_stats; capture baseline\n    activities:\n      - \"Run: memory_health({reportMode: 'full'})\"\n      - \"Run: memory_stats({})\"\n      - \"Bash: stat -f '%m %z' database/context-index__*.sqlite (mtime + size for present profile DBs)\"\n      - \"Interactive gate: before_phase_1_analysis\"\n    outputs:\n      - total_records: N\n      - last_index_at: ISO_timestamp\n      - fts_health: ok|degraded|missing\n      - embedding_health: ok|degraded|missing\n      - profile_db_sizes: [{path: string, size: bytes}]\n      - profile_db_mtimes: [{path: string, mtime: epoch_seconds}]\n    validation: discovery_complete\n    fail_fast:\n      - \"memory_health returns error → STATUS=FAIL with diagnostic\"\n      - \"Database file missing → STATUS=DEGRADED, message='index not initialized'\"\n\n  phase_1_analysis:\n    purpose: Classify drift signals + identify suspect records\n    activities:\n      - \"Cross-reference memory_health output with mtime: any spec-doc file with mtime > last_index_at signals staleness\"\n      - \"Sample up to 5 records flagged as drift candidates\"\n      - \"Run memory_drift_why per sampled record (read-only)\"\n      - \"Aggregate drift signals into drift_classes count map\"\n      - \"Interactive gate: before_phase_2_recommendation\"\n    outputs:\n      - drift_classes:\n          embedding_drift: N\n          fts_miss: M\n          chunk_boundary_drift: K\n          trigger_phrase_drift: L\n          embedding_provider_change: P\n          divergent_alias_groups: Q\n      - sample_drift_explanations: [up to 5 entries]\n      - severity_max: low|medium|high\n    validation: analysis_complete\n\n  phase_2_recommendation:\n    purpose: Translate drift signals into recommended action\n    rules:\n      - \"If severity_max == high (provider change OR divergent aliases) → recommend a full rebuild via /doctor:update\"\n      - \"If severity_max == medium (embedding OR fts drift) → recommend an incremental rebuild via /doctor:update\"\n      - \"If severity_max == low (boundary OR trigger drift) → recommend monitoring; rerun in 1-2 weeks\"\n      - \"If no drift → status=OK, no action needed\"\n    outputs:\n      - status: OK|DEGRADED|STALE|MISSING\n      - recommended_command: string\n      - recommended_when: now|low-activity-window|monitor\n\n  phase_3_report:\n    purpose: Emit packet-local report + state log\n    activities:\n      - \"Compose report following OUTPUT CONTRACT in memory.md\"\n      - \"Write to <packet_scratch>/doctor-memory-report.<timestamp>.md\"\n      - \"Print summary table to stdout\"\n    outputs:\n      - report_path: string\n      - status: STATUS_OK | STATUS_DEGRADED | STATUS_STALE | STATUS_MISSING\n    validation: report_emitted\n\n# ─────────────────────────────────────────────────────────────────\n# OUTPUT CONTRACT\n# ─────────────────────────────────────────────────────────────────\noutput_contract:\n  format: markdown\n  required_sections:\n    - status_header\n    - database_state_table\n    - drift_signals_block\n    - recommendation_block\n  optional_sections:\n    - sample_drift_explanations\n  state_log:\n    path: \"<packet_scratch>/doctor-memory-state.<timestamp>.json\"\n    schema:\n      command: \"/doctor memory\"\n      mode: INTERACTIVE\n      intent: DIAGNOSE\n      timestamp: ISO_8601","lineStart":1,"lineEnd":220,"totalLines":233,"truncated":true}},"title":".opencode/commands/doctor/assets/doctor_memory.yaml","time":{"start":1780738206111,"end":1780738206115}},"metadata":{"openai":{"itemId":"fc_0905efe70eafd06c016a23e89e02548191868c7487ac2272b4"}},"id":"prt_e9c44a996001Gjw9A3ryL45K95","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c44888f001jAFy37Xm751puI"}}
{"type":"tool_use","timestamp":1780738206144,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_p2jfSfVJT2pHMmDxQkQc1cX6","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/assets/doctor_skill-budget.yaml","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/assets/doctor_skill-budget.yaml</path>\n<type>file</type>\n<content>\n1: # ─────────────────────────────────────────────────────────────────\n2: # DOCTOR: SKILL BUDGET WORKFLOW (INTERACTIVE READ-ONLY MODE)\n3: # ─────────────────────────────────────────────────────────────────\n4: role: Expert Operator running description-budget audit in interactive mode\n5: purpose: Read-only audit of skill, command, and agent description budgets with optional fail-over checkpoint\n6: action: Run audit_descriptions.py -> present report -> prompt for optional fail-over check -> final status\n7: \n8: # ─────────────────────────────────────────────────────────────────\n9: # OPERATING MODE\n10: # ─────────────────────────────────────────────────────────────────\n11: operating_mode:\n12:   workflow: sequential_read_only_audit\n13:   compliance: MANDATORY\n14:   execution: interactive\n15:   approvals: checkpoint_prompt\n16:   tracking: audit_report_and_exit_code\n17:   validation: audit_script_exit_code\n18:   read_only: true\n19: \n20: # ─────────────────────────────────────────────────────────────────\n21: # SKILL-BUDGET AUDIT INVARIANT\n22: # ─────────────────────────────────────────────────────────────────\n23: skill_budget_doctor_invariant: |\n24:   Skill-budget doctor is strictly read-only. It walks the project surfaces that\n25:   feed Claude Code's available-skills metadata (skills, commands, agents) and\n26:   reports per-item char counts, top-N bloated items, project total, and headroom\n27:   under the configured ceiling. It NEVER modifies frontmatter, never re-indexes\n28:   the advisor, and never writes to spec packet docs. Exit code is non-zero only\n29:   when --fail-over threshold is exceeded or an item exceeds the 1,536-char hard cap.\n30: \n31: # ─────────────────────────────────────────────────────────────────\n32: # UPSTREAM ASSETS\n33: # ─────────────────────────────────────────────────────────────────\n34: upstream_assets:\n35:   contract: \"local command design contract\"\n36:   audit_script: \".opencode/commands/doctor/scripts/audit_descriptions.py\"\n37:   reference_doc: \".opencode/skills/sk-doc/assets/frontmatter_templates.md\"\n38:   doc_reference: \".opencode/skills/sk-doc/assets/frontmatter_templates.md#description-budget--trim-style\"\n39: \n40: # ─────────────────────────────────────────────────────────────────\n41: # USER INPUTS\n42: # ─────────────────────────────────────────────────────────────────\n43: user_inputs:\n44:   execution_mode: \"INTERACTIVE\"\n45:   json_output: \"[JSON_OUTPUT] bool\"\n46:   top_n: \"[TOP_N] int\"\n47:   fail_over: \"[FAIL_OVER] int|null\"\n48:   project_ceiling: \"[PROJECT_CEILING] int\"\n49: \n50: # ─────────────────────────────────────────────────────────────────\n51: # FIELD HANDLING\n52: # ─────────────────────────────────────────────────────────────────\n53: field_handling:\n54:   defaults:\n55:     json_output_empty: false\n56:     top_n_empty: 10\n57:     fail_over_empty: null\n58:     project_ceiling_empty: 5600\n59:   validation:\n60:     execution_mode_must_be: INTERACTIVE\n61:     top_n_minimum: 1\n62:     fail_over_nullable_integer: true\n63:     project_ceiling_minimum: 1\n64:   command_mapping:\n65:     json_output_true: \"append --json\"\n66:     top_n: \"append --top-n=[top_n]\"\n67:     fail_over_present: \"append --fail-over=[fail_over]\"\n68:     project_ceiling: \"append --project-ceiling=[project_ceiling]\"\n69: \n70: # ─────────────────────────────────────────────────────────────────\n71: # MUTATION BOUNDARIES\n72: # ─────────────────────────────────────────────────────────────────\n73: mutation_boundaries:\n74:   read_only: true\n75:   allowed_targets: []\n76:   forbidden_targets:\n77:     - \"**/*\"\n78:   invariant: \"This workflow is read-only. It may execute the audit script and print output, but it must not write files, reindex databases, mutate graph metadata, or update descriptions.\"\n79: \n80: # ─────────────────────────────────────────────────────────────────\n81: # WORKFLOW\n82: # ─────────────────────────────────────────────────────────────────\n83: workflow:\n84:   phase_0_audit:\n85:     purpose: \"Run the description-budget audit (read-only).\"\n86:     activities:\n87:       - \"Construct the command line and execute upstream_assets.audit_script via Bash.\"\n88:       - \"Capture stdout and exit code.\"\n89:     outputs:\n90:       - report_text_or_json\n91:       - exit_code\n92: \n93:   phase_1_checkpoint:\n94:     purpose: \"Present the report and ask whether to also run a fail-over check.\"\n95:     activities:\n96:       - \"Print the report or surface JSON output.\"\n97:       - \"Ask the operator: 'Run --fail-over=[project_ceiling] check now?'\"\n98:     options:\n99:       - label: A\n100:         description: \"Yes - run the fail-over check.\"\n101:         next_action: \"Re-run audit_script with --fail-over=[project_ceiling]; surface exit code.\"\n102:       - label: B\n103:         description: \"No - audit complete.\"\n104:         next_action: \"Return STATUS=OK.\"\n105: \n106: # ─────────────────────────────────────────────────────────────────\n107: # OUTPUT FORMAT\n108: # ─────────────────────────────────────────────────────────────────\n109: output_format: |\n110:   STATUS=OK when the audit exits cleanly and no requested fail-over threshold is exceeded.\n111:   STATUS=FAIL ERROR=\"description budget exceeded threshold\" when the audit script exits non-zero for the configured threshold.\n\n(End of file - total 111 lines)\n</content>","metadata":{"preview":"# ─────────────────────────────────────────────────────────────────\n# DOCTOR: SKILL BUDGET WORKFLOW (INTERACTIVE READ-ONLY MODE)\n# ─────────────────────────────────────────────────────────────────\nrole: Expert Operator running description-budget audit in interactive mode\npurpose: Read-only audit of skill, command, and agent description budgets with optional fail-over checkpoint\naction: Run audit_descriptions.py -> present report -> prompt for optional fail-over check -> final status\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING MODE\n# ─────────────────────────────────────────────────────────────────\noperating_mode:\n  workflow: sequential_read_only_audit\n  compliance: MANDATORY\n  execution: interactive\n  approvals: checkpoint_prompt\n  tracking: audit_report_and_exit_code\n  validation: audit_script_exit_code\n  read_only: true\n\n# ─────────────────────────────────────────────────────────────────","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/assets/doctor_skill-budget.yaml","text":"# ─────────────────────────────────────────────────────────────────\n# DOCTOR: SKILL BUDGET WORKFLOW (INTERACTIVE READ-ONLY MODE)\n# ─────────────────────────────────────────────────────────────────\nrole: Expert Operator running description-budget audit in interactive mode\npurpose: Read-only audit of skill, command, and agent description budgets with optional fail-over checkpoint\naction: Run audit_descriptions.py -> present report -> prompt for optional fail-over check -> final status\n\n# ─────────────────────────────────────────────────────────────────\n# OPERATING MODE\n# ─────────────────────────────────────────────────────────────────\noperating_mode:\n  workflow: sequential_read_only_audit\n  compliance: MANDATORY\n  execution: interactive\n  approvals: checkpoint_prompt\n  tracking: audit_report_and_exit_code\n  validation: audit_script_exit_code\n  read_only: true\n\n# ─────────────────────────────────────────────────────────────────\n# SKILL-BUDGET AUDIT INVARIANT\n# ─────────────────────────────────────────────────────────────────\nskill_budget_doctor_invariant: |\n  Skill-budget doctor is strictly read-only. It walks the project surfaces that\n  feed Claude Code's available-skills metadata (skills, commands, agents) and\n  reports per-item char counts, top-N bloated items, project total, and headroom\n  under the configured ceiling. It NEVER modifies frontmatter, never re-indexes\n  the advisor, and never writes to spec packet docs. Exit code is non-zero only\n  when --fail-over threshold is exceeded or an item exceeds the 1,536-char hard cap.\n\n# ─────────────────────────────────────────────────────────────────\n# UPSTREAM ASSETS\n# ─────────────────────────────────────────────────────────────────\nupstream_assets:\n  contract: \"local command design contract\"\n  audit_script: \".opencode/commands/doctor/scripts/audit_descriptions.py\"\n  reference_doc: \".opencode/skills/sk-doc/assets/frontmatter_templates.md\"\n  doc_reference: \".opencode/skills/sk-doc/assets/frontmatter_templates.md#description-budget--trim-style\"\n\n# ─────────────────────────────────────────────────────────────────\n# USER INPUTS\n# ─────────────────────────────────────────────────────────────────\nuser_inputs:\n  execution_mode: \"INTERACTIVE\"\n  json_output: \"[JSON_OUTPUT] bool\"\n  top_n: \"[TOP_N] int\"\n  fail_over: \"[FAIL_OVER] int|null\"\n  project_ceiling: \"[PROJECT_CEILING] int\"\n\n# ─────────────────────────────────────────────────────────────────\n# FIELD HANDLING\n# ─────────────────────────────────────────────────────────────────\nfield_handling:\n  defaults:\n    json_output_empty: false\n    top_n_empty: 10\n    fail_over_empty: null\n    project_ceiling_empty: 5600\n  validation:\n    execution_mode_must_be: INTERACTIVE\n    top_n_minimum: 1\n    fail_over_nullable_integer: true\n    project_ceiling_minimum: 1\n  command_mapping:\n    json_output_true: \"append --json\"\n    top_n: \"append --top-n=[top_n]\"\n    fail_over_present: \"append --fail-over=[fail_over]\"\n    project_ceiling: \"append --project-ceiling=[project_ceiling]\"\n\n# ─────────────────────────────────────────────────────────────────\n# MUTATION BOUNDARIES\n# ─────────────────────────────────────────────────────────────────\nmutation_boundaries:\n  read_only: true\n  allowed_targets: []\n  forbidden_targets:\n    - \"**/*\"\n  invariant: \"This workflow is read-only. It may execute the audit script and print output, but it must not write files, reindex databases, mutate graph metadata, or update descriptions.\"\n\n# ─────────────────────────────────────────────────────────────────\n# WORKFLOW\n# ─────────────────────────────────────────────────────────────────\nworkflow:\n  phase_0_audit:\n    purpose: \"Run the description-budget audit (read-only).\"\n    activities:\n      - \"Construct the command line and execute upstream_assets.audit_script via Bash.\"\n      - \"Capture stdout and exit code.\"\n    outputs:\n      - report_text_or_json\n      - exit_code\n\n  phase_1_checkpoint:\n    purpose: \"Present the report and ask whether to also run a fail-over check.\"\n    activities:\n      - \"Print the report or surface JSON output.\"\n      - \"Ask the operator: 'Run --fail-over=[project_ceiling] check now?'\"\n    options:\n      - label: A\n        description: \"Yes - run the fail-over check.\"\n        next_action: \"Re-run audit_script with --fail-over=[project_ceiling]; surface exit code.\"\n      - label: B\n        description: \"No - audit complete.\"\n        next_action: \"Return STATUS=OK.\"\n\n# ─────────────────────────────────────────────────────────────────\n# OUTPUT FORMAT\n# ─────────────────────────────────────────────────────────────────\noutput_format: |\n  STATUS=OK when the audit exits cleanly and no requested fail-over threshold is exceeded.\n  STATUS=FAIL ERROR=\"description budget exceeded threshold\" when the audit script exits non-zero for the configured threshold.","lineStart":1,"lineEnd":111,"totalLines":111,"truncated":false}},"title":".opencode/commands/doctor/assets/doctor_skill-budget.yaml","time":{"start":1780738206140,"end":1780738206143}},"metadata":{"openai":{"itemId":"fc_0905efe70eafd06c016a23e89e025881919c37fa08e3c760fd"}},"id":"prt_e9c44a9a0001Mhz0wNxWVtOODW","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c44888f001jAFy37Xm751puI"}}
{"type":"tool_use","timestamp":1780738206198,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_k9YqNNZcwTAof7aWE055JRT4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/update.md","offset":205,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/update.md</path>\n<type>file</type>\n<content>\n205: `/doctor:update` is the one-shot maintenance path for bringing the spec-kit runtime databases back into alignment with the repository. It coordinates the individual doctor surfaces, but adds cross-database safety that a single subsystem command cannot provide: one lock, one snapshot set, one dependency DAG, one rollback policy, and one state log.\n206: \n207: Use it after upgrading spec-kit, after large packet moves, after a stale startup graph warning, or when multiple doctor commands would otherwise need to be run by hand. The command is intentionally conservative because a partial rebuild can leave memory, graph, advisor, and eval state disagreeing with each other.\n208: \n209: ## SUBSYSTEM CONTRACT\n210: \n211: | Subsystem     | Database                                                           | Status/Health                        | Mutating Tool                          | Gold Battery                           |\n212: | ------------- | ------------------------------------------------------------------ | ------------------------------------ | -------------------------------------- | -------------------------------------- |\n213: | code-graph    | `.opencode/skills/system-code-graph/mcp_server/database/code-graph.sqlite` | `code_graph_status`                  | `code_graph_scan` / `code_graph_apply` | code-graph query battery               |\n214: | context-index | `mcp_server/database/context-index__*.sqlite` active profile DB    | `memory_health`, `memory_stats`      | `memory_index_scan`                    | `memory_search` representative queries |\n215: | vector-index  | `mcp_server/database/context-index__*.sqlite` active profile DB    | `memory_health`, `memory_stats`      | `memory_index_scan`                    | embedding-backed `memory_search`       |\n216: | causal-edges  | active profile DB `causal_edges` table                             | `memory_causal_stats`                | `memory_causal_link`                   | coverage and orphan checks             |\n217: | skill-graph   | `mk_skill_advisor` skill graph DB                               | `mk_skill_advisor.skill_graph_status` | `mk_skill_advisor.skill_graph_scan` | skill count/freshness + query          |\n218: | advisor       | skill graph + advisor tables                                       | `advisor_status`, `advisor_validate` | `advisor_rebuild`                      | validation suite                       |\n219: | deep-loop     | `.opencode/skills/deep-loop-runtime/database/deep-loop-graph.sqlite` | `node .opencode/skills/deep-loop-runtime/scripts/status.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\"` | `node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\" --nodes '<nodes-json>' --edges '<edges-json>'` | `node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\"` |\n220: | eval          | `mcp_server/database/speckit-eval.db`                              | `session_health`, eval probes        | `eval_run_ablation`                    | ablation run completes                 |\n221: \n222: ## DEPENDENCY DAG\n223: \n224: ```\n225: code-graph\n226:    |\n227:    v\n228: context-index + vector-index\n229:    |\n230:    v\n231: causal-edges init\n232:    |\n233:    v\n234: skill-graph\n235:    |\n236:    v\n237: advisor\n238:    |\n239:    v\n240: deep-loop-graph\n241:    |\n242:    v\n243: speckit-eval (optional measurement)\n244: ```\n245: \n246: ## TIER-AWARE PROMPT TIERS\n247: \n248: Each tier maps to a specific question ID from the MID-RUN PROMPT CATALOG above.\n249: \n250: | Tier      | Steps                                       | Prompt ID                                  | Suppressed by `--force`? | Rationale                                          |\n251: | --------- | ------------------------------------------- | ------------------------------------------ | ------------------------ | -------------------------------------------------- |\n252: | Short     | `mk_skill_advisor.skill_graph_scan`, deep-loop lazy init | none (auto-acknowledged via log line only) | n/a                      | Fast idempotent initialization                     |\n253: | Medium    | `code_graph_scan`, `eval_run_ablation`      | **Q-MED**                                  | YES                      | Meaningful runtime and index churn                 |\n254: | Long-pole | `memory_index_scan` over context/vector DBs | **Q-LONG**                                 | YES                      | 5-15 min runtime and largest rollback blast radius |\n255: \n256: Additional non-tier prompts (always fire when their trigger condition is met):\n257: - **Q-PROBE** — Phase 2 active-MCP-client detection (NOT suppressed by `--force`)\n258: - **Q-LEGACY** — Phase 9 per-file cleanup (fires only when `--cleanup-legacy=true`)\n259: - **Q-FAIL** — Phase 5 step-failure recovery (suppressed by `--force`; defaults to rollback)\n260: \n261: `--force=true` collapses Q0, Q-MED, Q-LONG, and Q-FAIL to auto-`A` (proceed/rollback). Q-PROBE still fires once to warn on active clients. Q-LEGACY fires only if the operator opted into `--cleanup-legacy`.\n262: \n263: ## MUTATION BOUNDARIES\n264: \n265: | Allowed Targets                                                                                                                                                                                                       | Notes                                  |\n266: | ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- | -------------------------------------- |\n267: | `.opencode/skills/system-code-graph/mcp_server/database/code-graph.sqlite` and `.opencode/skills/system-code-graph/mcp_server/database/code-graph.sqlite.pre-doctor-update.*.bak`                                       | structural graph DB + snapshots        |\n268: | `.opencode/skills/system-spec-kit/mcp_server/database/context-index__*.sqlite` and `.opencode/skills/system-spec-kit/mcp_server/database/context-index__*.sqlite.pre-doctor-update.*.bak`                               | memory records, FTS, causal edges, vectors |\n269: | `.opencode/skills/system-spec-kit/mcp_server/database/skill-graph.sqlite` and `.opencode/skills/system-spec-kit/mcp_server/database/skill-graph.sqlite.pre-doctor-update.*.bak`                                         | skill graph DB                         |\n270: | `.opencode/skills/deep-loop-runtime/database/deep-loop-graph.sqlite` and `.opencode/skills/deep-loop-runtime/database/deep-loop-graph.sqlite.pre-doctor-update.*.bak`                                                               | deep research/review graph DB          |\n271: | `.opencode/skills/system-spec-kit/mcp_server/database/speckit-eval.db` and `.opencode/skills/system-spec-kit/mcp_server/database/speckit-eval.db.pre-doctor-update.*.bak`                                               | eval DB                                |\n272: | `.opencode/skills/system-spec-kit/mcp_server/database/.doctor-update.flock`                                                                                                                                            | primary concurrent-dispatch lock       |\n273: | `.opencode/skills/system-spec-kit/mcp_server/database/.doctor-update.lock`                                                                                                                                             | PID-file fallback with stale detection |\n274: | `.opencode/skills/system-spec-kit/mcp_server/database/.doctor-update.last-run.json`                                                                                                                                    | state log                              |\n275: \n276: Forbidden targets include all spec folder docs, authored skill source, all agents, command docs/assets except the maintained bootstrap launcher/script in this packet, and `mcp_server/database/migration-manifest.json`. The migration manifest is read-only in Track C.\n277: \n278: ## WORKFLOW PHASES\n279: \n280: | Phase | Council Line                                                                           | YAML Activity                                                   |\n281: | ----- | -------------------------------------------------------------------------------------- | --------------------------------------------------------------- |\n282: | 0     | Non-MCP runtime bootstrap; stop for fresh process when tool registration changed       | `phase_0_runtime_bootstrap`                                      |\n283: | 1     | Acquire flock; refuse if held or PID stale-locked >2h                                  | `phase_1_flock_acquire`                                         |\n284: | 1.5   | Verify mcp_server/dist/context-server.js exists; build via npm if missing; release flock on abort | `phase_1_5_mcp_server_bootability`        |\n285: | 2     | Probe other MCP-client activity; warn and prompt unless `--force`                      | `phase_2_probe_mcp_activity`                                    |\n286: | 3     | Snapshot every SQLite DB with `VACUUM INTO`; refuse if disk free <2x DB total          | `phase_3_snapshot_all_databases`                                |\n287: | 4     | Execute in dependency order with tier prompts                                          | `phase_4_status_dashboard` + `phase_5_dependency_order_execute` |\n288: | 5     | On step failure: one retry with 5-sec backoff, then rollback or prompt                 | `phase_5_dependency_order_execute.failure_policy`               |\n289: | 5.5   | Optional post-dependency checkpoint for DBs created during Phase 5 (fresh-install rollback target) | `phase_5_5_post_dependency_checkpoint`        |\n290: | 6     | On SIGINT: set cancel flag, settle current tx, restore in-flight DB, exit 130          | `phase_6_sigint_cancel_contract`                                |\n291: | 7     | Post-run validation with gold battery per DB; rollback on regression                   | `phase_7_post_run_validation`                                   |\n292: | 9     | Legacy cleanup only with `--cleanup-legacy`, prompt-delete each                        | `phase_9_legacy_cleanup`                                        |\n293: | 10    | Write `.doctor-update.last-run.json`; release flock; cleanup old snapshots unless kept | `phase_10_state_log_unlock_cleanup`                             |\n294: \n295: ## STATE LOG SCHEMA\n296: \n297: `mcp_server/database/.doctor-update.last-run.json` is written on success, failure, rollback, and cancellation.\n298: \n299: ```json\n300: {\n301:   \"command\": \"/doctor:update\",\n302:   \"mode\": \"default|auto|confirm|run|confirm\",\n303:   \"start\": \"2026-05-09T13:00:00Z\",\n304:   \"end\": \"2026-05-09T13:08:10Z\",\n305:   \"duration_seconds\": 490,\n306:   \"steps\": [\n307:     {\n308:       \"name\": \"context-index\",\n309:       \"phase\": 5,\n310:       \"start\": \"2026-05-09T13:02:00Z\",\n311:       \"end\": \"2026-05-09T13:07:00Z\",\n312:       \"duration_seconds\": 300,\n313:       \"exit\": 0,\n314:       \"snapshot_path\": \"mcp_server/database/context-index__hf-local__onnx-community-embeddinggemma-300m-onnx__768__q8.sqlite.pre-doctor-update.3.4.1.0.20260509T130100Z.bak\"\n315:     }\n316:   ],\n317:   \"final_status\": \"ok|failed|rolled_back|cancelled|unrollbackable|restart_required\"\n318: }\n319: ```\n320: \n321: ## OUTPUT CONTRACT\n322: \n323: ```markdown\n324: ## Cross-Subsystem Health Dashboard\n325: \n326: | Subsystem     | Status | Age          | Recommended Action |\n327: | ------------- | ------ | ------------ | ------------------ |\n328: | code-graph    | OK     | STALE        | MISSING            | REGRESSED | <age>        | scan       | skip     | rollback |\n329: | context-index | OK     | STALE        | MISSING            | REGRESSED | <age>        | index-scan | skip     | rollback |\n330: | causal-edges  | OK     | LOW-COVERAGE | REGRESSED          | <age>     | init-links   | skip       | rollback |\n331: | skill-graph   | OK     | STALE        | MISSING            | <age>     | scan         | skip       |\n332: | advisor       | OK     | INVALID      | STALE              | <age>     | rebuild      | validate   |\n333: | deep-loop     | OK     | EMPTY        | STALE              | <age>     | upsert       | skip       |\n334: | eval          | OK     | STALE        | SKIPPED            | <age>     | run-ablation | skip       |\n335: \n336: Final status: STATUS=<OK|FAIL|ROLLED_BACK|CANCELLED|RESTART_REQUIRED>\n337: State log: mcp_server/database/.doctor-update.last-run.json\n338: Snapshots: <kept|cleaned|skipped>\n339: ```\n340: \n341: ### Status Outputs\n342: \n343: - `STATUS=OK` — all phases completed; gold-battery passed; state log written\n344: - `STATUS=ROLLED_BACK` — Q-FAIL chose rollback OR auto-rollback fired on gold-battery regression\n345: - `STATUS=CANCELLED` — Q0 cancelled, Q-PROBE rejected, or Q-LONG/Q-MED cancelled mid-run\n346: - `STATUS=RESTART_REQUIRED` — Phase 1.5 built mcp_server/dist; needs fresh OpenCode process + --resume-bootstrap\n347: - `STATUS=FAIL ERROR=\"...\"` — see state log `.doctor-update.last-run.json` for details\n348: \n349: When `STATUS=RESTART_REQUIRED`, no database rebuild has started yet. Start a fresh OpenCode process so the MCP launcher can register the now-built `mk-spec-memory` surface, then rerun `/doctor:update --resume-bootstrap`.\n350: \n351: ## RELATED COMMANDS\n352: \n353: - `/doctor memory` - isolated context-index/vector-index health and rebuild.\n354: - `/doctor causal-graph` - isolated causal edge coverage and add-only repair.\n355: - `/doctor deep-loop` - isolated research/review coverage graph rebuild.\n356: - `/doctor code-graph` - isolated structural graph diagnosis and confirm workflow.\n357: - `/doctor skill-advisor` - advisor and skill-graph optimization pass.\n358: - `/doctor skill-budget` - advisor budget/status helper.\n359: \n360: ## 6. INSTRUCTIONS\n361: \n362: 1. Resolve mode and flags in the Unified Setup Phase. Do not load YAML before setup is complete.\n363: 2. Load the selected `assets/doctor_update.yaml` file and execute it as the source of truth.\n364: 3. Enforce Phase 1 flock before any status probe that could lead to mutation. If held, refuse with holding PID and start timestamp.\n365: 4. In Phase 2, probe active MCP clients. If active clients exist and `--force` is absent, ask for explicit proceed/cancel.\n366: 6. In Phase 3, snapshot every allowed SQLite database with `VACUUM INTO` unless `--no-snapshot` is explicitly true. Disk free must be at least 2x DB total.\n367: 7. In Phase 4, render the cross-subsystem dashboard before deciding which dependency steps to run. skips this decision and runs the full chain.\n368: 8. In Phase 5, execute in dependency order: code-graph -> context-index -> causal-edges-init -> skill-graph -> advisor -> deep-loop-graph -> speckit-eval.\n369: 9. On failure, retry the failed step once after 5 seconds. If it fails again, restores failed DB plus downstream snapshots and exits 1; confirm workflow prompt retry/rollback/leave.\n370: 10. On SIGINT, set the cancel flag, wait about 5 seconds for the current SQLite transaction to settle per ADR-001, restore the in-flight DB snapshot, write the state log, and exit 130.\n371: 11. Run post-run gold-battery validation for every DB touched. Regression rolls back automatically in interactive workflows and prompts in confirm workflow.\n372: 12. Always write `.doctor-update.last-run.json`, release the flock, and remove snapshots older than 30 days unless `--keep-snapshots` is true.\n373: \n374: Read the YAML file end-to-end before Phase 1. Do not paraphrase the YAML; it defines exact phase names, target boundaries, and halt behavior.\n\n(End of file - total 374 lines)\n</content>","metadata":{"preview":"`/doctor:update` is the one-shot maintenance path for bringing the spec-kit runtime databases back into alignment with the repository. It coordinates the individual doctor surfaces, but adds cross-database safety that a single subsystem command cannot provide: one lock, one snapshot set, one dependency DAG, one rollback policy, and one state log.\n\nUse it after upgrading spec-kit, after large packet moves, after a stale startup graph warning, or when multiple doctor commands would otherwise need to be run by hand. The command is intentionally conservative because a partial rebuild can leave memory, graph, advisor, and eval state disagreeing with each other.\n\n## SUBSYSTEM CONTRACT\n\n| Subsystem     | Database                                                           | Status/Health                        | Mutating Tool                          | Gold Battery                           |\n| ------------- | ------------------------------------------------------------------ | ------------------------------------ | -------------------------------------- | -------------------------------------- |\n| code-graph    | `.opencode/skills/system-code-graph/mcp_server/database/code-graph.sqlite` | `code_graph_status`                  | `code_graph_scan` / `code_graph_apply` | code-graph query battery               |\n| context-index | `mcp_server/database/context-index__*.sqlite` active profile DB    | `memory_health`, `memory_stats`      | `memory_index_scan`                    | `memory_search` representative queries |\n| vector-index  | `mcp_server/database/context-index__*.sqlite` active profile DB    | `memory_health`, `memory_stats`      | `memory_index_scan`                    | embedding-backed `memory_search`       |\n| causal-edges  | active profile DB `causal_edges` table                             | `memory_causal_stats`                | `memory_causal_link`                   | coverage and orphan checks             |\n| skill-graph   | `mk_skill_advisor` skill graph DB                               | `mk_skill_advisor.skill_graph_status` | `mk_skill_advisor.skill_graph_scan` | skill count/freshness + query          |\n| advisor       | skill graph + advisor tables                                       | `advisor_status`, `advisor_validate` | `advisor_rebuild`                      | validation suite                       |\n| deep-loop     | `.opencode/skills/deep-loop-runtime/database/deep-loop-graph.sqlite` | `node .opencode/skills/deep-loop-runtime/scripts/status.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\"` | `node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\" --nodes '<nodes-json>' --edges '<edges-json>'` | `node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\"` |\n| eval          | `mcp_server/database/speckit-eval.db`                              | `session_health`, eval probes        | `eval_run_ablation`                    | ablation run completes                 |\n\n## DEPENDENCY DAG\n\n```","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/commands/doctor/update.md","text":"`/doctor:update` is the one-shot maintenance path for bringing the spec-kit runtime databases back into alignment with the repository. It coordinates the individual doctor surfaces, but adds cross-database safety that a single subsystem command cannot provide: one lock, one snapshot set, one dependency DAG, one rollback policy, and one state log.\n\nUse it after upgrading spec-kit, after large packet moves, after a stale startup graph warning, or when multiple doctor commands would otherwise need to be run by hand. The command is intentionally conservative because a partial rebuild can leave memory, graph, advisor, and eval state disagreeing with each other.\n\n## SUBSYSTEM CONTRACT\n\n| Subsystem     | Database                                                           | Status/Health                        | Mutating Tool                          | Gold Battery                           |\n| ------------- | ------------------------------------------------------------------ | ------------------------------------ | -------------------------------------- | -------------------------------------- |\n| code-graph    | `.opencode/skills/system-code-graph/mcp_server/database/code-graph.sqlite` | `code_graph_status`                  | `code_graph_scan` / `code_graph_apply` | code-graph query battery               |\n| context-index | `mcp_server/database/context-index__*.sqlite` active profile DB    | `memory_health`, `memory_stats`      | `memory_index_scan`                    | `memory_search` representative queries |\n| vector-index  | `mcp_server/database/context-index__*.sqlite` active profile DB    | `memory_health`, `memory_stats`      | `memory_index_scan`                    | embedding-backed `memory_search`       |\n| causal-edges  | active profile DB `causal_edges` table                             | `memory_causal_stats`                | `memory_causal_link`                   | coverage and orphan checks             |\n| skill-graph   | `mk_skill_advisor` skill graph DB                               | `mk_skill_advisor.skill_graph_status` | `mk_skill_advisor.skill_graph_scan` | skill count/freshness + query          |\n| advisor       | skill graph + advisor tables                                       | `advisor_status`, `advisor_validate` | `advisor_rebuild`                      | validation suite                       |\n| deep-loop     | `.opencode/skills/deep-loop-runtime/database/deep-loop-graph.sqlite` | `node .opencode/skills/deep-loop-runtime/scripts/status.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\"` | `node .opencode/skills/deep-loop-runtime/scripts/upsert.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\" --nodes '<nodes-json>' --edges '<edges-json>'` | `node .opencode/skills/deep-loop-runtime/scripts/convergence.cjs --spec-folder \"<spec-folder>\" --loop-type \"<research\\|review>\" --session-id \"<session-id>\"` |\n| eval          | `mcp_server/database/speckit-eval.db`                              | `session_health`, eval probes        | `eval_run_ablation`                    | ablation run completes                 |\n\n## DEPENDENCY DAG\n\n```\ncode-graph\n   |\n   v\ncontext-index + vector-index\n   |\n   v\ncausal-edges init\n   |\n   v\nskill-graph\n   |\n   v\nadvisor\n   |\n   v\ndeep-loop-graph\n   |\n   v\nspeckit-eval (optional measurement)\n```\n\n## TIER-AWARE PROMPT TIERS\n\nEach tier maps to a specific question ID from the MID-RUN PROMPT CATALOG above.\n\n| Tier      | Steps                                       | Prompt ID                                  | Suppressed by `--force`? | Rationale                                          |\n| --------- | ------------------------------------------- | ------------------------------------------ | ------------------------ | -------------------------------------------------- |\n| Short     | `mk_skill_advisor.skill_graph_scan`, deep-loop lazy init | none (auto-acknowledged via log line only) | n/a                      | Fast idempotent initialization                     |\n| Medium    | `code_graph_scan`, `eval_run_ablation`      | **Q-MED**                                  | YES                      | Meaningful runtime and index churn                 |\n| Long-pole | `memory_index_scan` over context/vector DBs | **Q-LONG**                                 | YES                      | 5-15 min runtime and largest rollback blast radius |\n\nAdditional non-tier prompts (always fire when their trigger condition is met):\n- **Q-PROBE** — Phase 2 active-MCP-client detection (NOT suppressed by `--force`)\n- **Q-LEGACY** — Phase 9 per-file cleanup (fires only when `--cleanup-legacy=true`)\n- **Q-FAIL** — Phase 5 step-failure recovery (suppressed by `--force`; defaults to rollback)\n\n`--force=true` collapses Q0, Q-MED, Q-LONG, and Q-FAIL to auto-`A` (proceed/rollback). Q-PROBE still fires once to warn on active clients. Q-LEGACY fires only if the operator opted into `--cleanup-legacy`.\n\n## MUTATION BOUNDARIES\n\n| Allowed Targets                                                                                                                                                                                                       | Notes                                  |\n| ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------- | -------------------------------------- |\n| `.opencode/skills/system-code-graph/mcp_server/database/code-graph.sqlite` and `.opencode/skills/system-code-graph/mcp_server/database/code-graph.sqlite.pre-doctor-update.*.bak`                                       | structural graph DB + snapshots        |\n| `.opencode/skills/system-spec-kit/mcp_server/database/context-index__*.sqlite` and `.opencode/skills/system-spec-kit/mcp_server/database/context-index__*.sqlite.pre-doctor-update.*.bak`                               | memory records, FTS, causal edges, vectors |\n| `.opencode/skills/system-spec-kit/mcp_server/database/skill-graph.sqlite` and `.opencode/skills/system-spec-kit/mcp_server/database/skill-graph.sqlite.pre-doctor-update.*.bak`                                         | skill graph DB                         |\n| `.opencode/skills/deep-loop-runtime/database/deep-loop-graph.sqlite` and `.opencode/skills/deep-loop-runtime/database/deep-loop-graph.sqlite.pre-doctor-update.*.bak`                                                               | deep research/review graph DB          |\n| `.opencode/skills/system-spec-kit/mcp_server/database/speckit-eval.db` and `.opencode/skills/system-spec-kit/mcp_server/database/speckit-eval.db.pre-doctor-update.*.bak`                                               | eval DB                                |\n| `.opencode/skills/system-spec-kit/mcp_server/database/.doctor-update.flock`                                                                                                                                            | primary concurrent-dispatch lock       |\n| `.opencode/skills/system-spec-kit/mcp_server/database/.doctor-update.lock`                                                                                                                                             | PID-file fallback with stale detection |\n| `.opencode/skills/system-spec-kit/mcp_server/database/.doctor-update.last-run.json`                                                                                                                                    | state log                              |\n\nForbidden targets include all spec folder docs, authored skill source, all agents, command docs/assets except the maintained bootstrap launcher/script in this packet, and `mcp_server/database/migration-manifest.json`. The migration manifest is read-only in Track C.\n\n## WORKFLOW PHASES\n\n| Phase | Council Line                                                                           | YAML Activity                                                   |\n| ----- | -------------------------------------------------------------------------------------- | --------------------------------------------------------------- |\n| 0     | Non-MCP runtime bootstrap; stop for fresh process when tool registration changed       | `phase_0_runtime_bootstrap`                                      |\n| 1     | Acquire flock; refuse if held or PID stale-locked >2h                                  | `phase_1_flock_acquire`                                         |\n| 1.5   | Verify mcp_server/dist/context-server.js exists; build via npm if missing; release flock on abort | `phase_1_5_mcp_server_bootability`        |\n| 2     | Probe other MCP-client activity; warn and prompt unless `--force`                      | `phase_2_probe_mcp_activity`                                    |\n| 3     | Snapshot every SQLite DB with `VACUUM INTO`; refuse if disk free <2x DB total          | `phase_3_snapshot_all_databases`                                |\n| 4     | Execute in dependency order with tier prompts                                          | `phase_4_status_dashboard` + `phase_5_dependency_order_execute` |\n| 5     | On step failure: one retry with 5-sec backoff, then rollback or prompt                 | `phase_5_dependency_order_execute.failure_policy`               |\n| 5.5   | Optional post-dependency checkpoint for DBs created during Phase 5 (fresh-install rollback target) | `phase_5_5_post_dependency_checkpoint`        |\n| 6     | On SIGINT: set cancel flag, settle current tx, restore in-flight DB, exit 130          | `phase_6_sigint_cancel_contract`                                |\n| 7     | Post-run validation with gold battery per DB; rollback on regression                   | `phase_7_post_run_validation`                                   |\n| 9     | Legacy cleanup only with `--cleanup-legacy`, prompt-delete each                        | `phase_9_legacy_cleanup`                                        |\n| 10    | Write `.doctor-update.last-run.json`; release flock; cleanup old snapshots unless kept | `phase_10_state_log_unlock_cleanup`                             |\n\n## STATE LOG SCHEMA\n\n`mcp_server/database/.doctor-update.last-run.json` is written on success, failure, rollback, and cancellation.\n\n```json\n{\n  \"command\": \"/doctor:update\",\n  \"mode\": \"default|auto|confirm|run|confirm\",\n  \"start\": \"2026-05-09T13:00:00Z\",\n  \"end\": \"2026-05-09T13:08:10Z\",\n  \"duration_seconds\": 490,\n  \"steps\": [\n    {\n      \"name\": \"context-index\",\n      \"phase\": 5,\n      \"start\": \"2026-05-09T13:02:00Z\",\n      \"end\": \"2026-05-09T13:07:00Z\",\n      \"duration_seconds\": 300,\n      \"exit\": 0,\n      \"snapshot_path\": \"mcp_server/database/context-index__hf-local__onnx-community-embeddinggemma-300m-onnx__768__q8.sqlite.pre-doctor-update.3.4.1.0.20260509T130100Z.bak\"\n    }\n  ],\n  \"final_status\": \"ok|failed|rolled_back|cancelled|unrollbackable|restart_required\"\n}\n```\n\n## OUTPUT CONTRACT\n\n```markdown\n## Cross-Subsystem Health Dashboard\n\n| Subsystem     | Status | Age          | Recommended Action |\n| ------------- | ------ | ------------ | ------------------ |\n| code-graph    | OK     | STALE        | MISSING            | REGRESSED | <age>        | scan       | skip     | rollback |\n| context-index | OK     | STALE        | MISSING            | REGRESSED | <age>        | index-scan | skip     | rollback |\n| causal-edges  | OK     | LOW-COVERAGE | REGRESSED          | <age>     | init-links   | skip       | rollback |\n| skill-graph   | OK     | STALE        | MISSING            | <age>     | scan         | skip       |\n| advisor       | OK     | INVALID      | STALE              | <age>     | rebuild      | validate   |\n| deep-loop     | OK     | EMPTY        | STALE              | <age>     | upsert       | skip       |\n| eval          | OK     | STALE        | SKIPPED            | <age>     | run-ablation | skip       |\n\nFinal status: STATUS=<OK|FAIL|ROLLED_BACK|CANCELLED|RESTART_REQUIRED>\nState log: mcp_server/database/.doctor-update.last-run.json\nSnapshots: <kept|cleaned|skipped>\n```\n\n### Status Outputs\n\n- `STATUS=OK` — all phases completed; gold-battery passed; state log written\n- `STATUS=ROLLED_BACK` — Q-FAIL chose rollback OR auto-rollback fired on gold-battery regression\n- `STATUS=CANCELLED` — Q0 cancelled, Q-PROBE rejected, or Q-LONG/Q-MED cancelled mid-run\n- `STATUS=RESTART_REQUIRED` — Phase 1.5 built mcp_server/dist; needs fresh OpenCode process + --resume-bootstrap\n- `STATUS=FAIL ERROR=\"...\"` — see state log `.doctor-update.last-run.json` for details\n\nWhen `STATUS=RESTART_REQUIRED`, no database rebuild has started yet. Start a fresh OpenCode process so the MCP launcher can register the now-built `mk-spec-memory` surface, then rerun `/doctor:update --resume-bootstrap`.\n\n## RELATED COMMANDS\n\n- `/doctor memory` - isolated context-index/vector-index health and rebuild.\n- `/doctor causal-graph` - isolated causal edge coverage and add-only repair.\n- `/doctor deep-loop` - isolated research/review coverage graph rebuild.\n- `/doctor code-graph` - isolated structural graph diagnosis and confirm workflow.\n- `/doctor skill-advisor` - advisor and skill-graph optimization pass.\n- `/doctor skill-budget` - advisor budget/status helper.\n\n## 6. INSTRUCTIONS\n\n1. Resolve mode and flags in the Unified Setup Phase. Do not load YAML before setup is complete.\n2. Load the selected `assets/doctor_update.yaml` file and execute it as the source of truth.\n3. Enforce Phase 1 flock before any status probe that could lead to mutation. If held, refuse with holding PID and start timestamp.\n4. In Phase 2, probe active MCP clients. If active clients exist and `--force` is absent, ask for explicit proceed/cancel.\n6. In Phase 3, snapshot every allowed SQLite database with `VACUUM INTO` unless `--no-snapshot` is explicitly true. Disk free must be at least 2x DB total.\n7. In Phase 4, render the cross-subsystem dashboard before deciding which dependency steps to run. skips this decision and runs the full chain.\n8. In Phase 5, execute in dependency order: code-graph -> context-index -> causal-edges-init -> skill-graph -> advisor -> deep-loop-graph -> speckit-eval.\n9. On failure, retry the failed step once after 5 seconds. If it fails again, restores failed DB plus downstream snapshots and exits 1; confirm workflow prompt retry/rollback/leave.\n10. On SIGINT, set the cancel flag, wait about 5 seconds for the current SQLite transaction to settle per ADR-001, restore the in-flight DB snapshot, write the state log, and exit 130.\n11. Run post-run gold-battery validation for every DB touched. Regression rolls back automatically in interactive workflows and prompts in confirm workflow.\n12. Always write `.doctor-update.last-run.json`, release the flock, and remove snapshots older than 30 days unless `--keep-snapshots` is true.\n\nRead the YAML file end-to-end before Phase 1. Do not paraphrase the YAML; it defines exact phase names, target boundaries, and halt behavior.","lineStart":205,"lineEnd":374,"totalLines":374,"truncated":false}},"title":".opencode/commands/doctor/update.md","time":{"start":1780738206190,"end":1780738206194}},"metadata":{"openai":{"itemId":"fc_0905efe70eafd06c016a23e89e0260819181d6a9edab1c915b"}},"id":"prt_e9c44a9e7001c8K3trFaf5q5nD","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c44888f001jAFy37Xm751puI"}}
{"type":"tool_use","timestamp":1780738206200,"sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","part":{"type":"tool","tool":"read","callID":"call_qVuYVtUg6JJfok0PykeztYfh","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts</path>\n<type>file</type>\n<content>\n1: // ────────────────────────────────────────────────────────────────\n2: // MODULE: Memory Retention Sweep Handler\n3: // ────────────────────────────────────────────────────────────────\n4: import { checkDatabaseUpdated } from '../core/index.js';\n5: import { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\n6: import * as vectorIndex from '../lib/search/vector-index.js';\n7: import { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\n8: import { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\n9: import { toErrorMessage } from '../utils/index.js';\n10: \n11: import type { MCPResponse } from './types.js';\n12: import type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n13: \n14: /** Handle the memory_retention_sweep MCP tool request. */\n15: async function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n16:   await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n17:   await checkDatabaseUpdated();\n18: \n19:   const database = vectorIndex.getDb();\n20:   if (!database) {\n21:     return createMCPErrorResponse({\n22:       tool: 'memory_retention_sweep',\n23:       error: 'Retention sweep aborted: database unavailable',\n24:       code: 'E_DB_UNAVAILABLE',\n25:       details: {\n26:         dryRun: args?.dryRun === true,\n27:       },\n28:       recovery: {\n29:         hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n30:         actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n31:         severity: 'error',\n32:       },\n33:     });\n34:   }\n35: \n36:   try {\n37:     const result = runMemoryRetentionSweep(database, { dryRun: args?.dryRun === true });\n38:     const summary = result.dryRun\n39:       ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted`\n40:       : `Swept ${result.swept} expired memory row(s); retained ${result.retained}`;\n41: \n42:     const hints: string[] = [];\n43:     if (result.ledgerRecorded === false) {\n44:       hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n45:     }\n46:     if (result.dryRun && result.candidates.length > 0) {\n47:       hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n48:     }\n49: \n50:     return createMCPSuccessResponse({\n51:       tool: 'memory_retention_sweep',\n52:       summary,\n53:       data: {\n54:         swept: result.swept,\n55:         retained: result.retained,\n56:         dryRun: result.dryRun,\n57:         durationMs: result.durationMs,\n58:         candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n59:           id: candidate.id,\n60:           deleteAfter: candidate.deleteAfter,\n61:           specFolder: candidate.specFolder,\n62:           filePath: candidate.filePath,\n63:         })),\n64:         deletedIds: result.deletedIds,\n65:         ledgerRecorded: result.ledgerRecorded,\n66:       },\n67:       hints,\n68:     });\n69:   } catch (error: unknown) {\n70:     return createMCPErrorResponse({\n71:       tool: 'memory_retention_sweep',\n72:       error: `Retention sweep failed: ${toErrorMessage(error)}`,\n73:       code: 'E_RETENTION_SWEEP_FAILED',\n74:       details: {\n75:         dryRun: args?.dryRun === true,\n76:       },\n77:       recovery: {\n78:         hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n79:         actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n80:         severity: 'error',\n81:       },\n82:     });\n83:   }\n84: }\n85: \n86: export { handleMemoryRetentionSweep };\n\n(End of file - total 86 lines)\n</content>","metadata":{"preview":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","text":"// ────────────────────────────────────────────────────────────────\n// MODULE: Memory Retention Sweep Handler\n// ────────────────────────────────────────────────────────────────\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport * as vectorIndex from '../lib/search/vector-index.js';\nimport { runMemoryRetentionSweep } from '../lib/governance/memory-retention-sweep.js';\nimport { createMCPErrorResponse, createMCPSuccessResponse } from '../lib/response/envelope.js';\nimport { toErrorMessage } from '../utils/index.js';\n\nimport type { MCPResponse } from './types.js';\nimport type { MemoryRetentionSweepArgs } from '../lib/governance/memory-retention-sweep.js';\n\n/** Handle the memory_retention_sweep MCP tool request. */\nasync function handleMemoryRetentionSweep(args: MemoryRetentionSweepArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_retention_sweep');\n  await checkDatabaseUpdated();\n\n  const database = vectorIndex.getDb();\n  if (!database) {\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: 'Retention sweep aborted: database unavailable',\n      code: 'E_DB_UNAVAILABLE',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Restart the MCP server or run memory_index_scan() to reinitialize the database.',\n        actions: ['Restart the MCP server', 'Call memory_index_scan()'],\n        severity: 'error',\n      },\n    });\n  }\n\n  try {\n    const result = runMemoryRetentionSweep(database, { dryRun: args?.dryRun === true });\n    const summary = result.dryRun\n      ? `Dry-run found ${result.candidates.length} expired memory row(s); no rows deleted`\n      : `Swept ${result.swept} expired memory row(s); retained ${result.retained}`;\n\n    const hints: string[] = [];\n    if (result.ledgerRecorded === false) {\n      hints.push('Mutation ledger append failed; governance audit/history rows were still recorded.');\n    }\n    if (result.dryRun && result.candidates.length > 0) {\n      hints.push('Run memory_retention_sweep({ dryRun: false }) to delete expired rows.');\n    }\n\n    return createMCPSuccessResponse({\n      tool: 'memory_retention_sweep',\n      summary,\n      data: {\n        swept: result.swept,\n        retained: result.retained,\n        dryRun: result.dryRun,\n        durationMs: result.durationMs,\n        candidates: result.dryRun ? result.candidates : result.candidates.map((candidate) => ({\n          id: candidate.id,\n          deleteAfter: candidate.deleteAfter,\n          specFolder: candidate.specFolder,\n          filePath: candidate.filePath,\n        })),\n        deletedIds: result.deletedIds,\n        ledgerRecorded: result.ledgerRecorded,\n      },\n      hints,\n    });\n  } catch (error: unknown) {\n    return createMCPErrorResponse({\n      tool: 'memory_retention_sweep',\n      error: `Retention sweep failed: ${toErrorMessage(error)}`,\n      code: 'E_RETENTION_SWEEP_FAILED',\n      details: {\n        dryRun: args?.dryRun === true,\n      },\n      recovery: {\n        hint: 'Inspect memory_index and governance_audit schema state, then retry the sweep.',\n        actions: ['Run memory_health()', 'Retry memory_retention_sweep({ dryRun: true })'],\n        severity: 'error',\n      },\n    });\n  }\n}\n\nexport { handleMemoryRetentionSweep };","lineStart":1,"lineEnd":86,"totalLines":86,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-retention-sweep.ts","time":{"start":1780738206196,"end":1780738206199}},"metadata":{"openai":{"itemId":"fc_0905efe70eafd06c016a23e89e02648191ab85d46eb8f37d10"}},"id":"prt_e9c44a9ef0010QnsjIyC1UZ5yn","sessionID":"ses_163bcc502ffeuERCb2AlX2T5Je","messageID":"msg_e9c44888f001jAFy37Xm751puI"}}
