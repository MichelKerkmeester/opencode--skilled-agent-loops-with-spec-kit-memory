./.opencode/specs/system-spec-kit/026-graph-and-context-optimization/002-resource-map-deep-loop-fix/003-resource-map-deep-loop-integration/research/findings-registry.json:64:        ".opencode/skills/sk-deep-research/assets/prompt_pack_iteration.md.tmpl:40",
