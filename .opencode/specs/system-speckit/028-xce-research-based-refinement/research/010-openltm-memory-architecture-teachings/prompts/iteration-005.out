{"type":"tool_use","timestamp":1780925415637,"sessionID":"ses_158954ac7ffel6uhZW0lvDJ5iU","part":{"type":"tool","tool":"read","callID":"call_BXe4H4eiQ8SyVTuwvICFNwV4","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","offset":1,"limit":220},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Causal Edges\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Causal edge creation (memory_causal_link)\n5: // Causal relationship graph for memory lineage\n6: import type Database from 'better-sqlite3';\n7: import { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\n8: import { clearGraphSignalsCache } from '../graph/graph-signals.js';\n9: import { detectContradictions } from '../graph/contradiction-detection.js';\n10: import { ensureTemporalColumns } from '../graph/temporal-edges.js';\n11: import { isTemporalEdgesEnabled } from '../search/search-flags.js';\n12: import { runInTransaction } from './transaction-manager.js';\n13: \n14: /* ───────────────────────────────────────────────────────────────\n15:    1. CONSTANTS\n16: ----------------------------------------------------------------*/\n17: \n18: const RELATION_TYPES = Object.freeze({\n19:   CAUSED: 'caused',\n20:   ENABLED: 'enabled',\n21:   SUPERSEDES: 'supersedes',\n22:   CONTRADICTS: 'contradicts',\n23:   DERIVED_FROM: 'derived_from',\n24:   SUPPORTS: 'supports',\n25: } as const);\n26: \n27: type RelationType = typeof RELATION_TYPES[keyof typeof RELATION_TYPES];\n28: \n29: /**\n30:  * C138: Relation weight multipliers applied during traversal scoring.\n31:  * Higher values amplify the propagated strength; values < 1.0 dampen it.\n32:  */\n33: const RELATION_WEIGHTS: Record<string, number> = {\n34:   supersedes:   1.5,  // Strongest signal — new info replaces old\n35:   caused:       1.3,  // Strong causal link\n36:   enabled:      1.1,  // Weak causal link\n37:   supports:     1.0,  // Neutral / default\n38:   derived_from: 1.0,  // Neutral / default\n39:   contradicts:  0.8,  // Dampened — conflicting signals lower confidence\n40: };\n41: \n42: const DEFAULT_MAX_DEPTH = 3;\n43: const MAX_EDGES_LIMIT = 100;\n44: \n45: // Edge bounds for the lightweight runtime path (NFR-R01, SC-005)\n46: const MAX_EDGES_PER_NODE = 20;\n47: const MAX_AUTO_STRENGTH = 0.5;\n48: const MAX_STRENGTH_INCREASE_PER_CYCLE = 0.05;\n49: const WINDOW_MS = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_WINDOW_MS', 15 * 60 * 1000);\n50: const CAP_PER_WINDOW = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_CAP_PER_WINDOW', 100);\n51: const STALENESS_THRESHOLD_DAYS = 90;\n52: const DECAY_STRENGTH_AMOUNT = 0.1;\n53: const DECAY_PERIOD_DAYS = 30;\n54: \n55: function parsePositiveIntegerEnv(name: string, fallback: number): number {\n56:   const value = process.env[name];\n57:   if (!value) return fallback;\n58:   const parsed = Number.parseInt(value, 10);\n59:   return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;\n60: }\n61: \n62: function isFiniteNumber(value: unknown): value is number {\n63:   return typeof value === 'number' && Number.isFinite(value);\n64: }\n65: \n66: function clampStrength(strength: number): number | null {\n67:   if (!Number.isFinite(strength)) return null;\n68:   return Math.max(0, Math.min(1, strength));\n69: }\n70: \n71: function normalizeCausalEdgeRow(row: Record<string, unknown>): CausalEdge {\n72:   return {\n73:     id: Number(row.id),\n74:     source_id: String(row.source_id),\n75:     target_id: String(row.target_id),\n76:     source_anchor: row.source_anchor == null ? null : String(row.source_anchor),\n77:     target_anchor: row.target_anchor == null ? null : String(row.target_anchor),\n78:     relation: String(row.relation) as RelationType,\n79:     strength: Number(row.strength),\n80:     evidence: row.evidence == null ? null : String(row.evidence),\n81:     extracted_at: String(row.extracted_at),\n82:     created_by: String(row.created_by ?? 'manual'),\n83:     last_accessed: row.last_accessed == null ? null : String(row.last_accessed),\n84:   };\n85: }\n86: \n87: /* ───────────────────────────────────────────────────────────────\n88:    2. INTERFACES\n89: ----------------------------------------------------------------*/\n90: \n91: interface CausalEdge {\n92:   id: number;\n93:   source_id: string;\n94:   target_id: string;\n95:   source_anchor: string | null;\n96:   target_anchor: string | null;\n97:   relation: RelationType;\n98:   strength: number;\n99:   evidence: string | null;\n100:   extracted_at: string;\n101:   created_by: string;\n102:   last_accessed: string | null;\n103: }\n104: \n105: interface CausalEdgeRow extends Record<string, unknown> {\n106:   id: number;\n107:   source_id: string;\n108:   target_id: string;\n109:   source_anchor?: string | null;\n110:   target_anchor?: string | null;\n111:   relation: RelationType;\n112:   strength: number;\n113:   evidence: string | null;\n114:   extracted_at: string;\n115:   created_by: string;\n116:   last_accessed: string | null;\n117: }\n118: \n119: type EdgeQueryResult = CausalEdge[] & {\n120:   truncated: boolean;\n121:   limit: number;\n122: };\n123: \n124: interface WeightHistoryEntry {\n125:   id: number;\n126:   edge_id: number;\n127:   old_strength: number;\n128:   new_strength: number;\n129:   changed_by: string;\n130:   changed_at: string;\n131:   reason: string | null;\n132: }\n133: \n134: interface GraphStats {\n135:   totalEdges: number;\n136:   byRelation: Record<string, number>;\n137:   avgStrength: number;\n138:   uniqueSources: number;\n139:   uniqueTargets: number;\n140: }\n141: \n142: interface CausalChainNode {\n143:   id: string;\n144:   edgeId?: number;          // Preserve causal_edges.id for unlink workflow\n145:   depth: number;\n146:   relation: RelationType;\n147:   strength: number;\n148:   children: CausalChainNode[];\n149:   truncated?: boolean;\n150:   truncationLimit?: number | null;\n151: }\n152: \n153: /* ───────────────────────────────────────────────────────────────\n154:    3. MODULE STATE\n155: ----------------------------------------------------------------*/\n156: \n157: let db: Database.Database | null = null;\n158: \n159: /**\n160:  * Monotonically-increasing generation counter bumped on every causal-edge\n161:  * mutation (insert/update/delete/rollback). Read-only callers can include this\n162:  * value in cache keys (e.g. memory_search when `enableCausalBoost=true`) so\n163:  * cached responses derived from the causal graph become stale on the next\n164:  * lookup without requiring a wholesale tool-cache invalidation.\n165:  *\n166:  * targeted memory_search cache invalidation.\n167:  */\n168: let causalEdgesGeneration = 0;\n169: \n170: function bumpCausalEdgesGeneration(): void {\n171:   // Wrap counter near MAX_SAFE_INTEGER to avoid overflow in ultra-long-lived\n172:   // Processes; consumers only compare for inequality, so wrapping is safe.\n173:   causalEdgesGeneration = causalEdgesGeneration >= Number.MAX_SAFE_INTEGER\n174:     ? 1\n175:     : causalEdgesGeneration + 1;\n176: }\n177: \n178: function getCausalEdgesGeneration(): number {\n179:   return causalEdgesGeneration;\n180: }\n181: \n182: function invalidateDegreeCache(): void {\n183:   // bump the causal-edges generation FIRST so any cache key that\n184:   // includes it (e.g. memory_search when enableCausalBoost=true) becomes\n185:   // stale on the next read without invalidating unrelated tool entries.\n186:   bumpCausalEdgesGeneration();\n187: \n188:   try {\n189:     // H1 FIX: Use db-specific cache invalidation instead of the no-op global version\n190:     if (db) {\n191:       clearDegreeCacheForDb(db);\n192:     }\n193:   } catch (_error: unknown) {\n194:     // Cache invalidation is best-effort; never block edge mutations\n195:   }\n196:   try {\n197:     clearGraphSignalsCache();\n198:   } catch (_error: unknown) {\n199:     // Graph signals cache invalidation is best-effort\n200:   }\n201: }\n202: \n203: function enforceRelationWindowCap(\n204:   relation: string,\n205:   database: Database.Database,\n206:   windowMs: number = WINDOW_MS,\n207:   capPerWindow: number = CAP_PER_WINDOW,\n208: ): boolean {\n209:   try {\n210:     const windowStart = new Date(Date.now() - windowMs).toISOString();\n211:     const row = (database.prepare(`\n212:       SELECT COUNT(*) as count FROM causal_edges\n213:       WHERE relation = ?\n214:         AND datetime(extracted_at) >= datetime(?)\n215:     `) as Database.Statement).get(relation, windowStart) as { count: number };\n216:     const count = row.count;\n217:     if (count >= capPerWindow) {\n218:       console.warn(`[causal-edges] cap exceeded for relation ${relation}: ${count}/${capPerWindow} in ${windowMs}ms window`);\n219:       return false;\n220:     }\n\n(Showing lines 1-220 of 1099. Use offset=221 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Edges\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Causal relationship graph for memory lineage\nimport type Database from 'better-sqlite3';\nimport { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { detectContradictions } from '../graph/contradiction-detection.js';\nimport { ensureTemporalColumns } from '../graph/temporal-edges.js';\nimport { isTemporalEdgesEnabled } from '../search/search-flags.js';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst RELATION_TYPES = Object.freeze({\n  CAUSED: 'caused',\n  ENABLED: 'enabled',","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Causal Edges\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Causal edge creation (memory_causal_link)\n// Causal relationship graph for memory lineage\nimport type Database from 'better-sqlite3';\nimport { clearDegreeCacheForDb } from '../search/graph-search-fn.js';\nimport { clearGraphSignalsCache } from '../graph/graph-signals.js';\nimport { detectContradictions } from '../graph/contradiction-detection.js';\nimport { ensureTemporalColumns } from '../graph/temporal-edges.js';\nimport { isTemporalEdgesEnabled } from '../search/search-flags.js';\nimport { runInTransaction } from './transaction-manager.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst RELATION_TYPES = Object.freeze({\n  CAUSED: 'caused',\n  ENABLED: 'enabled',\n  SUPERSEDES: 'supersedes',\n  CONTRADICTS: 'contradicts',\n  DERIVED_FROM: 'derived_from',\n  SUPPORTS: 'supports',\n} as const);\n\ntype RelationType = typeof RELATION_TYPES[keyof typeof RELATION_TYPES];\n\n/**\n * C138: Relation weight multipliers applied during traversal scoring.\n * Higher values amplify the propagated strength; values < 1.0 dampen it.\n */\nconst RELATION_WEIGHTS: Record<string, number> = {\n  supersedes:   1.5,  // Strongest signal — new info replaces old\n  caused:       1.3,  // Strong causal link\n  enabled:      1.1,  // Weak causal link\n  supports:     1.0,  // Neutral / default\n  derived_from: 1.0,  // Neutral / default\n  contradicts:  0.8,  // Dampened — conflicting signals lower confidence\n};\n\nconst DEFAULT_MAX_DEPTH = 3;\nconst MAX_EDGES_LIMIT = 100;\n\n// Edge bounds for the lightweight runtime path (NFR-R01, SC-005)\nconst MAX_EDGES_PER_NODE = 20;\nconst MAX_AUTO_STRENGTH = 0.5;\nconst MAX_STRENGTH_INCREASE_PER_CYCLE = 0.05;\nconst WINDOW_MS = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_WINDOW_MS', 15 * 60 * 1000);\nconst CAP_PER_WINDOW = parsePositiveIntegerEnv('SPECKIT_CAUSAL_RELATION_CAP_PER_WINDOW', 100);\nconst STALENESS_THRESHOLD_DAYS = 90;\nconst DECAY_STRENGTH_AMOUNT = 0.1;\nconst DECAY_PERIOD_DAYS = 30;\n\nfunction parsePositiveIntegerEnv(name: string, fallback: number): number {\n  const value = process.env[name];\n  if (!value) return fallback;\n  const parsed = Number.parseInt(value, 10);\n  return Number.isInteger(parsed) && parsed > 0 ? parsed : fallback;\n}\n\nfunction isFiniteNumber(value: unknown): value is number {\n  return typeof value === 'number' && Number.isFinite(value);\n}\n\nfunction clampStrength(strength: number): number | null {\n  if (!Number.isFinite(strength)) return null;\n  return Math.max(0, Math.min(1, strength));\n}\n\nfunction normalizeCausalEdgeRow(row: Record<string, unknown>): CausalEdge {\n  return {\n    id: Number(row.id),\n    source_id: String(row.source_id),\n    target_id: String(row.target_id),\n    source_anchor: row.source_anchor == null ? null : String(row.source_anchor),\n    target_anchor: row.target_anchor == null ? null : String(row.target_anchor),\n    relation: String(row.relation) as RelationType,\n    strength: Number(row.strength),\n    evidence: row.evidence == null ? null : String(row.evidence),\n    extracted_at: String(row.extracted_at),\n    created_by: String(row.created_by ?? 'manual'),\n    last_accessed: row.last_accessed == null ? null : String(row.last_accessed),\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface CausalEdge {\n  id: number;\n  source_id: string;\n  target_id: string;\n  source_anchor: string | null;\n  target_anchor: string | null;\n  relation: RelationType;\n  strength: number;\n  evidence: string | null;\n  extracted_at: string;\n  created_by: string;\n  last_accessed: string | null;\n}\n\ninterface CausalEdgeRow extends Record<string, unknown> {\n  id: number;\n  source_id: string;\n  target_id: string;\n  source_anchor?: string | null;\n  target_anchor?: string | null;\n  relation: RelationType;\n  strength: number;\n  evidence: string | null;\n  extracted_at: string;\n  created_by: string;\n  last_accessed: string | null;\n}\n\ntype EdgeQueryResult = CausalEdge[] & {\n  truncated: boolean;\n  limit: number;\n};\n\ninterface WeightHistoryEntry {\n  id: number;\n  edge_id: number;\n  old_strength: number;\n  new_strength: number;\n  changed_by: string;\n  changed_at: string;\n  reason: string | null;\n}\n\ninterface GraphStats {\n  totalEdges: number;\n  byRelation: Record<string, number>;\n  avgStrength: number;\n  uniqueSources: number;\n  uniqueTargets: number;\n}\n\ninterface CausalChainNode {\n  id: string;\n  edgeId?: number;          // Preserve causal_edges.id for unlink workflow\n  depth: number;\n  relation: RelationType;\n  strength: number;\n  children: CausalChainNode[];\n  truncated?: boolean;\n  truncationLimit?: number | null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\n\n/**\n * Monotonically-increasing generation counter bumped on every causal-edge\n * mutation (insert/update/delete/rollback). Read-only callers can include this\n * value in cache keys (e.g. memory_search when `enableCausalBoost=true`) so\n * cached responses derived from the causal graph become stale on the next\n * lookup without requiring a wholesale tool-cache invalidation.\n *\n * targeted memory_search cache invalidation.\n */\nlet causalEdgesGeneration = 0;\n\nfunction bumpCausalEdgesGeneration(): void {\n  // Wrap counter near MAX_SAFE_INTEGER to avoid overflow in ultra-long-lived\n  // Processes; consumers only compare for inequality, so wrapping is safe.\n  causalEdgesGeneration = causalEdgesGeneration >= Number.MAX_SAFE_INTEGER\n    ? 1\n    : causalEdgesGeneration + 1;\n}\n\nfunction getCausalEdgesGeneration(): number {\n  return causalEdgesGeneration;\n}\n\nfunction invalidateDegreeCache(): void {\n  // bump the causal-edges generation FIRST so any cache key that\n  // includes it (e.g. memory_search when enableCausalBoost=true) becomes\n  // stale on the next read without invalidating unrelated tool entries.\n  bumpCausalEdgesGeneration();\n\n  try {\n    // H1 FIX: Use db-specific cache invalidation instead of the no-op global version\n    if (db) {\n      clearDegreeCacheForDb(db);\n    }\n  } catch (_error: unknown) {\n    // Cache invalidation is best-effort; never block edge mutations\n  }\n  try {\n    clearGraphSignalsCache();\n  } catch (_error: unknown) {\n    // Graph signals cache invalidation is best-effort\n  }\n}\n\nfunction enforceRelationWindowCap(\n  relation: string,\n  database: Database.Database,\n  windowMs: number = WINDOW_MS,\n  capPerWindow: number = CAP_PER_WINDOW,\n): boolean {\n  try {\n    const windowStart = new Date(Date.now() - windowMs).toISOString();\n    const row = (database.prepare(`\n      SELECT COUNT(*) as count FROM causal_edges\n      WHERE relation = ?\n        AND datetime(extracted_at) >= datetime(?)\n    `) as Database.Statement).get(relation, windowStart) as { count: number };\n    const count = row.count;\n    if (count >= capPerWindow) {\n      console.warn(`[causal-edges] cap exceeded for relation ${relation}: ${count}/${capPerWindow} in ${windowMs}ms window`);\n      return false;\n    }","lineStart":1,"lineEnd":220,"totalLines":1099,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/causal-edges.ts","time":{"start":1780925415623,"end":1780925415636}},"metadata":{"openai":{"itemId":"fc_0c609901c2cc37bb016a26c3e787188191bde3ea7f41d17499"}},"id":"prt_ea76d40a00019ZvIrz1LZ9OErh","sessionID":"ses_158954ac7ffel6uhZW0lvDJ5iU","messageID":"msg_ea76d180a001TgKsZgZqv0dovV"}}
{"type":"tool_use","timestamp":1780925415648,"sessionID":"ses_158954ac7ffel6uhZW0lvDJ5iU","part":{"type":"tool","tool":"read","callID":"call_Sa8VdduybfuUwYWNlrjKIvZw","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","offset":140,"limit":100},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts</path>\n<type>file</type>\n<content>\n140:   remediationHint?: string;\n141:   windowStartedAt: string;\n142: };\n143: \n144: const RELATION_BALANCE_WINDOW_MS = 15 * 60 * 1000;\n145: const RELATION_SKEW_SHARE_THRESHOLD = 0.80;\n146: const RELATION_SKEW_MIN_TOTAL = 50;\n147: const RELATION_INSUFFICIENT_TOTAL = 5;\n148: const VALID_CAUSAL_RELATIONS = Object.values(causalEdges.RELATION_TYPES) as string[];\n149: // Canonical relation vocabulary for zero-filled stats output. Matches RELATION_TYPES;\n150: // `produced`/`cited_by` are not valid edge relations under the schema CHECK and were dropped.\n151: const MEMORY_CAUSAL_OUTPUT_RELATIONS = [\n152:   'supersedes',\n153:   'caused',\n154:   'supports',\n155:   'contradicts',\n156:   'enabled',\n157:   'derived_from',\n158: ] as const;\n159: \n160: function createZeroFilledRelationCounts(seed: Record<string, number> = {}): Record<string, number> {\n161:   const counts: Record<string, number> = {};\n162:   for (const relation of MEMORY_CAUSAL_OUTPUT_RELATIONS) {\n163:     counts[relation] = seed[relation] ?? 0;\n164:   }\n165:   for (const relation of VALID_CAUSAL_RELATIONS) {\n166:     counts[relation] = seed[relation] ?? 0;\n167:   }\n168:   return counts;\n169: }\n170: \n171: function parseEdgeTimestampMs(timestamp: string): number | null {\n172:   const normalized = timestamp.includes('T')\n173:     ? timestamp\n174:     : `${timestamp.replace(' ', 'T')}Z`;\n175:   const parsed = Date.parse(normalized);\n176:   return Number.isFinite(parsed) ? parsed : null;\n177: }\n178: \n179: function computeRelationBalance(\n180:   edges: CausalEdge[],\n181:   windowMs: number = RELATION_BALANCE_WINDOW_MS,\n182: ): RelationBalance {\n183:   const nowMs = Date.now();\n184:   const windowStartMs = nowMs - windowMs;\n185:   const deltaByRelation = createZeroFilledRelationCounts();\n186: \n187:   for (const edge of edges) {\n188:     const edgeMs = parseEdgeTimestampMs(edge.extracted_at);\n189:     if (edgeMs === null || edgeMs < windowStartMs || edgeMs > nowMs) {\n190:       continue;\n191:     }\n192:     if (Object.prototype.hasOwnProperty.call(deltaByRelation, edge.relation)) {\n193:       deltaByRelation[edge.relation] += 1;\n194:     }\n195:   }\n196: \n197:   const entries = Object.entries(deltaByRelation);\n198:   const total = entries.reduce((sum, [, count]) => sum + count, 0);\n199:   const [dominantRelation, dominantCount] = entries.reduce<[string | null, number]>(\n200:     (current, [relation, count]) => count > current[1] ? [relation, count] : current,\n201:     [null, 0],\n202:   );\n203:   const dominantRelationShare = total > 0 ? dominantCount / total : 0;\n204:   const balanceStatus = total < RELATION_INSUFFICIENT_TOTAL\n205:     ? 'insufficient_data'\n206:     : dominantRelationShare >= RELATION_SKEW_SHARE_THRESHOLD && total >= RELATION_SKEW_MIN_TOTAL\n207:       ? 'relation_skewed'\n208:       : 'balanced';\n209: \n210:   const result: RelationBalance = {\n211:     deltaByRelation,\n212:     dominantRelation,\n213:     dominantRelationShare,\n214:     balanceStatus,\n215:     windowStartedAt: new Date(windowStartMs).toISOString(),\n216:   };\n217: \n218:   if (balanceStatus === 'relation_skewed' && dominantRelation === causalEdges.RELATION_TYPES.SUPERSEDES) {\n219:     result.remediationHint = 'prediction-error supersedes burst — review create-record producer';\n220:   }\n221: \n222:   return result;\n223: }\n224: \n225: function readTopUnlinkedRecords(\n226:   db: import('better-sqlite3').Database,\n227:   limit = 5,\n228: ): Array<{ id: number | string; title: string; specFolder: string | null }> {\n229:   try {\n230:     const safeLimit = Math.max(1, Math.min(20, Math.floor(limit)));\n231:     return (db.prepare(`\n232:       SELECT id, COALESCE(title, file_path, CAST(id AS TEXT)) AS title, spec_folder AS specFolder\n233:       FROM memory_index m\n234:       WHERE NOT EXISTS (\n235:         SELECT 1 FROM causal_edges ce\n236:         WHERE ce.source_id = CAST(m.id AS TEXT)\n237:            OR ce.target_id = CAST(m.id AS TEXT)\n238:       )\n239:       ORDER BY COALESCE(importance_weight, 0) DESC, updated_at DESC, id DESC\n\n(Showing lines 140-239 of 1206. Use offset=240 to continue.)\n</content>","metadata":{"preview":"  remediationHint?: string;\n  windowStartedAt: string;\n};\n\nconst RELATION_BALANCE_WINDOW_MS = 15 * 60 * 1000;\nconst RELATION_SKEW_SHARE_THRESHOLD = 0.80;\nconst RELATION_SKEW_MIN_TOTAL = 50;\nconst RELATION_INSUFFICIENT_TOTAL = 5;\nconst VALID_CAUSAL_RELATIONS = Object.values(causalEdges.RELATION_TYPES) as string[];\n// Canonical relation vocabulary for zero-filled stats output. Matches RELATION_TYPES;\n// `produced`/`cited_by` are not valid edge relations under the schema CHECK and were dropped.\nconst MEMORY_CAUSAL_OUTPUT_RELATIONS = [\n  'supersedes',\n  'caused',\n  'supports',\n  'contradicts',\n  'enabled',\n  'derived_from',\n] as const;\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","text":"  remediationHint?: string;\n  windowStartedAt: string;\n};\n\nconst RELATION_BALANCE_WINDOW_MS = 15 * 60 * 1000;\nconst RELATION_SKEW_SHARE_THRESHOLD = 0.80;\nconst RELATION_SKEW_MIN_TOTAL = 50;\nconst RELATION_INSUFFICIENT_TOTAL = 5;\nconst VALID_CAUSAL_RELATIONS = Object.values(causalEdges.RELATION_TYPES) as string[];\n// Canonical relation vocabulary for zero-filled stats output. Matches RELATION_TYPES;\n// `produced`/`cited_by` are not valid edge relations under the schema CHECK and were dropped.\nconst MEMORY_CAUSAL_OUTPUT_RELATIONS = [\n  'supersedes',\n  'caused',\n  'supports',\n  'contradicts',\n  'enabled',\n  'derived_from',\n] as const;\n\nfunction createZeroFilledRelationCounts(seed: Record<string, number> = {}): Record<string, number> {\n  const counts: Record<string, number> = {};\n  for (const relation of MEMORY_CAUSAL_OUTPUT_RELATIONS) {\n    counts[relation] = seed[relation] ?? 0;\n  }\n  for (const relation of VALID_CAUSAL_RELATIONS) {\n    counts[relation] = seed[relation] ?? 0;\n  }\n  return counts;\n}\n\nfunction parseEdgeTimestampMs(timestamp: string): number | null {\n  const normalized = timestamp.includes('T')\n    ? timestamp\n    : `${timestamp.replace(' ', 'T')}Z`;\n  const parsed = Date.parse(normalized);\n  return Number.isFinite(parsed) ? parsed : null;\n}\n\nfunction computeRelationBalance(\n  edges: CausalEdge[],\n  windowMs: number = RELATION_BALANCE_WINDOW_MS,\n): RelationBalance {\n  const nowMs = Date.now();\n  const windowStartMs = nowMs - windowMs;\n  const deltaByRelation = createZeroFilledRelationCounts();\n\n  for (const edge of edges) {\n    const edgeMs = parseEdgeTimestampMs(edge.extracted_at);\n    if (edgeMs === null || edgeMs < windowStartMs || edgeMs > nowMs) {\n      continue;\n    }\n    if (Object.prototype.hasOwnProperty.call(deltaByRelation, edge.relation)) {\n      deltaByRelation[edge.relation] += 1;\n    }\n  }\n\n  const entries = Object.entries(deltaByRelation);\n  const total = entries.reduce((sum, [, count]) => sum + count, 0);\n  const [dominantRelation, dominantCount] = entries.reduce<[string | null, number]>(\n    (current, [relation, count]) => count > current[1] ? [relation, count] : current,\n    [null, 0],\n  );\n  const dominantRelationShare = total > 0 ? dominantCount / total : 0;\n  const balanceStatus = total < RELATION_INSUFFICIENT_TOTAL\n    ? 'insufficient_data'\n    : dominantRelationShare >= RELATION_SKEW_SHARE_THRESHOLD && total >= RELATION_SKEW_MIN_TOTAL\n      ? 'relation_skewed'\n      : 'balanced';\n\n  const result: RelationBalance = {\n    deltaByRelation,\n    dominantRelation,\n    dominantRelationShare,\n    balanceStatus,\n    windowStartedAt: new Date(windowStartMs).toISOString(),\n  };\n\n  if (balanceStatus === 'relation_skewed' && dominantRelation === causalEdges.RELATION_TYPES.SUPERSEDES) {\n    result.remediationHint = 'prediction-error supersedes burst — review create-record producer';\n  }\n\n  return result;\n}\n\nfunction readTopUnlinkedRecords(\n  db: import('better-sqlite3').Database,\n  limit = 5,\n): Array<{ id: number | string; title: string; specFolder: string | null }> {\n  try {\n    const safeLimit = Math.max(1, Math.min(20, Math.floor(limit)));\n    return (db.prepare(`\n      SELECT id, COALESCE(title, file_path, CAST(id AS TEXT)) AS title, spec_folder AS specFolder\n      FROM memory_index m\n      WHERE NOT EXISTS (\n        SELECT 1 FROM causal_edges ce\n        WHERE ce.source_id = CAST(m.id AS TEXT)\n           OR ce.target_id = CAST(m.id AS TEXT)\n      )\n      ORDER BY COALESCE(importance_weight, 0) DESC, updated_at DESC, id DESC","lineStart":140,"lineEnd":239,"totalLines":1206,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","time":{"start":1780925415634,"end":1780925415644}},"metadata":{"openai":{"itemId":"fc_0c609901c2cc37bb016a26c3e7872c8191b78ce9016bbe69b4"}},"id":"prt_ea76d40c800127G9hZNBKU0zNM","sessionID":"ses_158954ac7ffel6uhZW0lvDJ5iU","messageID":"msg_ea76d180a001TgKsZgZqv0dovV"}}
{"type":"tool_use","timestamp":1780925415657,"sessionID":"ses_158954ac7ffel6uhZW0lvDJ5iU","part":{"type":"tool","tool":"read","callID":"call_id6t1Pj17M97uUprpzzttj6P","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","offset":488,"limit":270},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts</path>\n<type>file</type>\n<content>\n488: /** Handle memory_drift_why tool - traces causal relationships for a given memory */\n489: async function handleMemoryDriftWhy(args: DriftWhyArgs): Promise<MCPResponse> {\n490:   await ensureMemoryRuntimeInitialized('handler:memory_drift_why');\n491:   const {\n492:     memoryId,\n493:     maxDepth: rawMaxDepth = 3,\n494:     direction = 'both',\n495:     relations = null,\n496:     includeMemoryDetails = true,\n497:     tenantId,\n498:     userId,\n499:     agentId,\n500:   } = args;\n501:   // Clamp maxDepth to [1, 10] server-side\n502:   const maxDepth = Math.min(Math.max(1, Math.floor(rawMaxDepth)), 10);\n503: \n504:   // Governed retrieval scope: when supplied, traversal results are post-filtered\n505:   // so a caller cannot trace causal chains for memories outside its scope.\n506:   // sessionId is intentionally not part of this boundary. No scope => unchanged.\n507:   const hasGovernanceScope = Boolean(tenantId || userId || agentId);\n508:   const scopeMatches = hasGovernanceScope\n509:     ? createScopeFilterPredicate({ tenantId, userId, agentId })\n510:     : null;\n511: \n512:   const startTime = Date.now();\n513: \n514:   if (memoryId === undefined || memoryId === null) {\n515:     return createMCPErrorResponse({\n516:       tool: 'memory_drift_why',\n517:       error: 'memoryId is required',\n518:       code: 'E031',\n519:       details: { param: 'memoryId' },\n520:       recovery: getRecoveryHint('memory_drift_why', 'E031'),\n521:       startTime: startTime\n522:     });\n523:   }\n524: \n525:   try {\n526:     await checkDatabaseUpdated();\n527: \n528:     vectorIndex.initializeDb();\n529:     const db = vectorIndex.getDb();\n530:     if (!db) {\n531:       return createMCPErrorResponse({\n532:         tool: 'memory_drift_why',\n533:         error: 'Database not initialized. Server may still be starting up.',\n534:         code: 'E020',\n535:         details: {},\n536:         recovery: getRecoveryHint('memory_drift_why', 'E020'),\n537:         startTime: startTime\n538:       });\n539:     }\n540:     causalEdges.init(db);\n541: \n542:     if (relations && Array.isArray(relations)) {\n543:       const validRelations: string[] = Object.values(causalEdges.RELATION_TYPES) as string[];\n544:       const invalid = relations.filter((r: string) => !validRelations.includes(r));\n545:       if (invalid.length > 0) {\n546:         return createMCPErrorResponse({\n547:           tool: 'memory_drift_why',\n548:           error: `Invalid relation types: ${invalid.join(', ')}`,\n549:           code: ErrorCodes.CAUSAL_INVALID_RELATION,\n550:           details: { invalidRelations: invalid, validRelations: validRelations },\n551:           recovery: getRecoveryHint('memory_drift_why', ErrorCodes.CAUSAL_INVALID_RELATION),\n552:           startTime: startTime\n553:         });\n554:       }\n555:     }\n556: \n557:     const mappedDirection = mapDirection(direction);\n558: \n559:     const readTraversalSnapshot = (): {\n560:       incomingChain: FlattenedChain;\n561:       outgoingChain: FlattenedChain;\n562:       combinedChain: FlattenedChain;\n563:       memoryDetails: Record<string, unknown> | null;\n564:       relatedMemories: Record<string, Record<string, unknown>>;\n565:       scopeDenied: boolean;\n566:     } => {\n567:       let incomingChain = createEmptyChain();\n568:       let outgoingChain = createEmptyChain();\n569: \n570:       if (mappedDirection === 'both') {\n571:         const forwardTree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'forward');\n572:         const backwardTree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'backward');\n573:         outgoingChain = forwardTree ? flattenCausalTree(forwardTree, maxDepth, 'forward') : createEmptyChain();\n574:         incomingChain = backwardTree ? flattenCausalTree(backwardTree, maxDepth, 'backward') : createEmptyChain();\n575:       } else if (mappedDirection === 'forward') {\n576:         const tree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'forward');\n577:         outgoingChain = tree ? flattenCausalTree(tree, maxDepth, 'forward') : createEmptyChain();\n578:       } else {\n579:         const tree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'backward');\n580:         incomingChain = tree ? flattenCausalTree(tree, maxDepth, 'backward') : createEmptyChain();\n581:       }\n582: \n583:       // Apply relations filter after traversal, before response.\n584:       incomingChain = filterChainByRelations(incomingChain, relations);\n585:       outgoingChain = filterChainByRelations(outgoingChain, relations);\n586:       const combinedChain = mergeFlattenedChains(incomingChain, outgoingChain);\n587: \n588:       let memoryDetails: Record<string, unknown> | null = null;\n589:       const relatedMemories: Record<string, Record<string, unknown>> = {};\n590:       let scopeDenied = false;\n591: \n592:       // Fail-closed scope authorization on the source memory. Done independently\n593:       // of includeMemoryDetails so denial cannot be skipped by omitting details.\n594:       if (scopeMatches) {\n595:         const sourceScopeRow = db.prepare(`\n596:           SELECT tenant_id, user_id, agent_id, session_id\n597:           FROM memory_index\n598:           WHERE id = ? OR CAST(id AS TEXT) = ?\n599:         `).get(memoryId, String(memoryId)) as Record<string, unknown> | undefined;\n600:         if (!sourceScopeRow || !scopeMatches(sourceScopeRow)) {\n601:           scopeDenied = true;\n602:           return {\n603:             incomingChain,\n604:             outgoingChain,\n605:             combinedChain,\n606:             memoryDetails,\n607:             relatedMemories,\n608:             scopeDenied,\n609:           };\n610:         }\n611:       }\n612: \n613:       if (includeMemoryDetails) {\n614:         const sourceMemory = db.prepare(`\n615:           SELECT id, title, spec_folder, importance_tier, importance_weight,\n616:                  context_type, created_at, updated_at, file_path\n617:           FROM memory_index\n618:           WHERE id = ? OR CAST(id AS TEXT) = ?\n619:         `).get(memoryId, String(memoryId)) as Record<string, unknown> | undefined;\n620: \n621:         if (sourceMemory) {\n622:           memoryDetails = sourceMemory;\n623:         }\n624: \n625:         const memoryIds = new Set<string>();\n626:         for (const edge of combinedChain.all) {\n627:           memoryIds.add(edge.from);\n628:           memoryIds.add(edge.to);\n629:         }\n630: \n631:         if (memoryIds.size > 0) {\n632:           const idsArray = Array.from(memoryIds);\n633:           for (const id of idsArray) {\n634:             // When scope is enforced, gate the related row on a scope-column\n635:             // lookup but keep the returned detail shape unchanged.\n636:             if (scopeMatches) {\n637:               const scopeRow = db.prepare(`\n638:                 SELECT tenant_id, user_id, agent_id, session_id\n639:                 FROM memory_index\n640:                 WHERE id = ? OR CAST(id AS TEXT) = ?\n641:               `).get(id, String(id)) as Record<string, unknown> | undefined;\n642:               if (!scopeRow || !scopeMatches(scopeRow)) {\n643:                 continue;\n644:               }\n645:             }\n646:             const memory = db.prepare(`\n647:               SELECT id, title, spec_folder, importance_tier, created_at\n648:               FROM memory_index\n649:               WHERE id = ? OR CAST(id AS TEXT) = ?\n650:             `).get(id, String(id)) as Record<string, unknown> | undefined;\n651:             if (memory) {\n652:               relatedMemories[id] = memory;\n653:             }\n654:           }\n655:         }\n656:       }\n657: \n658:       return {\n659:         incomingChain,\n660:         outgoingChain,\n661:         combinedChain,\n662:         memoryDetails,\n663:         relatedMemories,\n664:         scopeDenied,\n665:       };\n666:     };\n667: \n668:     const traversalSnapshot = typeof db.transaction === 'function'\n669:       ? db.transaction(readTraversalSnapshot)()\n670:       : readTraversalSnapshot();\n671:     const {\n672:       incomingChain,\n673:       outgoingChain,\n674:       combinedChain,\n675:       memoryDetails,\n676:       relatedMemories,\n677:       scopeDenied,\n678:     } = traversalSnapshot;\n679: \n680:     // Fail-closed: the source memory is outside the supplied governed scope.\n681:     // Return the same empty shape as \"no relationships\" rather than leaking the\n682:     // chain or signalling existence of an out-of-scope memory.\n683:     if (scopeDenied) {\n684:       return createMCPEmptyResponse({\n685:         tool: 'memory_drift_why',\n686:         summary: `No causal relationships found for memory ${memoryId}`,\n687:         data: {\n688:           memoryId: String(memoryId),\n689:           memory: null\n690:         },\n691:         hints: [\n692:           'Use memory_causal_link to create relationships',\n693:           'Consider linking to related decisions or contexts'\n694:         ],\n695:         startTime: startTime\n696:       });\n697:     }\n698: \n699:     if (combinedChain.total_edges === 0) {\n700:       return createMCPEmptyResponse({\n701:         tool: 'memory_drift_why',\n702:         summary: `No causal relationships found for memory ${memoryId}`,\n703:         data: {\n704:           memoryId: String(memoryId),\n705:           memory: memoryDetails\n706:         },\n707:         hints: [\n708:           'Use memory_causal_link to create relationships',\n709:           'Consider linking to related decisions or contexts'\n710:         ],\n711:         startTime: startTime\n712:       });\n713:     }\n714: \n715:     const relationSummary: string[] = [];\n716:     const incomingSummary = formatRelationSummary(incomingChain, 'incoming');\n717:     const outgoingSummary = formatRelationSummary(outgoingChain, 'outgoing');\n718:     if (incomingSummary) relationSummary.push(incomingSummary);\n719:     if (outgoingSummary) relationSummary.push(outgoingSummary);\n720: \n721:     const summary = relationSummary.length > 0\n722:       ? `Found ${combinedChain.total_edges} causal relationships (${relationSummary.join('; ')})`\n723:       : `Found ${combinedChain.total_edges} causal relationships`;\n724: \n725:     const hints: string[] = [];\n726:     if (combinedChain.max_depth_reached) {\n727:       hints.push(`Max depth (${maxDepth}) reached - more relationships may exist beyond this depth`);\n728:     }\n729:     if (combinedChain.truncated) {\n730:       hints.push(\n731:         `Traversal truncated after ${combinedChain.truncation_limit ?? causalEdges.MAX_EDGES_LIMIT} edges per node - results may be incomplete`\n732:       );\n733:     }\n734:     if (combinedChain.by_contradicts.length > 0) {\n735:       hints.push('Contradicting relationships detected - review for consistency');\n736:     }\n737: \n738:     return createMCPSuccessResponse({\n739:       tool: 'memory_drift_why',\n740:       summary,\n741:       data: {\n742:         memoryId: String(memoryId),\n743:         memory: memoryDetails,\n744:         incoming: toDirectionalBuckets(incomingChain),\n745:         outgoing: toDirectionalBuckets(outgoingChain),\n746:         allEdges: combinedChain.all,\n747:         totalEdges: combinedChain.total_edges,\n748:         totalIncomingEdges: incomingChain.total_edges,\n749:         totalOutgoingEdges: outgoingChain.total_edges,\n750:         maxDepthReached: combinedChain.max_depth_reached,\n751:         truncated: combinedChain.truncated,\n752:         truncationLimit: combinedChain.truncation_limit,\n753:         relatedMemories: Object.keys(relatedMemories).length > 0 ? relatedMemories : null,\n754:         traversalOptions: { direction: mappedDirection, maxDepth }\n755:       },\n756:       hints,\n757:       startTime: startTime\n\n(Showing lines 488-757 of 1206. Use offset=758 to continue.)\n</content>","metadata":{"preview":"/** Handle memory_drift_why tool - traces causal relationships for a given memory */\nasync function handleMemoryDriftWhy(args: DriftWhyArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_drift_why');\n  const {\n    memoryId,\n    maxDepth: rawMaxDepth = 3,\n    direction = 'both',\n    relations = null,\n    includeMemoryDetails = true,\n    tenantId,\n    userId,\n    agentId,\n  } = args;\n  // Clamp maxDepth to [1, 10] server-side\n  const maxDepth = Math.min(Math.max(1, Math.floor(rawMaxDepth)), 10);\n\n  // Governed retrieval scope: when supplied, traversal results are post-filtered\n  // so a caller cannot trace causal chains for memories outside its scope.\n  // sessionId is intentionally not part of this boundary. No scope => unchanged.\n  const hasGovernanceScope = Boolean(tenantId || userId || agentId);","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","text":"/** Handle memory_drift_why tool - traces causal relationships for a given memory */\nasync function handleMemoryDriftWhy(args: DriftWhyArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_drift_why');\n  const {\n    memoryId,\n    maxDepth: rawMaxDepth = 3,\n    direction = 'both',\n    relations = null,\n    includeMemoryDetails = true,\n    tenantId,\n    userId,\n    agentId,\n  } = args;\n  // Clamp maxDepth to [1, 10] server-side\n  const maxDepth = Math.min(Math.max(1, Math.floor(rawMaxDepth)), 10);\n\n  // Governed retrieval scope: when supplied, traversal results are post-filtered\n  // so a caller cannot trace causal chains for memories outside its scope.\n  // sessionId is intentionally not part of this boundary. No scope => unchanged.\n  const hasGovernanceScope = Boolean(tenantId || userId || agentId);\n  const scopeMatches = hasGovernanceScope\n    ? createScopeFilterPredicate({ tenantId, userId, agentId })\n    : null;\n\n  const startTime = Date.now();\n\n  if (memoryId === undefined || memoryId === null) {\n    return createMCPErrorResponse({\n      tool: 'memory_drift_why',\n      error: 'memoryId is required',\n      code: 'E031',\n      details: { param: 'memoryId' },\n      recovery: getRecoveryHint('memory_drift_why', 'E031'),\n      startTime: startTime\n    });\n  }\n\n  try {\n    await checkDatabaseUpdated();\n\n    vectorIndex.initializeDb();\n    const db = vectorIndex.getDb();\n    if (!db) {\n      return createMCPErrorResponse({\n        tool: 'memory_drift_why',\n        error: 'Database not initialized. Server may still be starting up.',\n        code: 'E020',\n        details: {},\n        recovery: getRecoveryHint('memory_drift_why', 'E020'),\n        startTime: startTime\n      });\n    }\n    causalEdges.init(db);\n\n    if (relations && Array.isArray(relations)) {\n      const validRelations: string[] = Object.values(causalEdges.RELATION_TYPES) as string[];\n      const invalid = relations.filter((r: string) => !validRelations.includes(r));\n      if (invalid.length > 0) {\n        return createMCPErrorResponse({\n          tool: 'memory_drift_why',\n          error: `Invalid relation types: ${invalid.join(', ')}`,\n          code: ErrorCodes.CAUSAL_INVALID_RELATION,\n          details: { invalidRelations: invalid, validRelations: validRelations },\n          recovery: getRecoveryHint('memory_drift_why', ErrorCodes.CAUSAL_INVALID_RELATION),\n          startTime: startTime\n        });\n      }\n    }\n\n    const mappedDirection = mapDirection(direction);\n\n    const readTraversalSnapshot = (): {\n      incomingChain: FlattenedChain;\n      outgoingChain: FlattenedChain;\n      combinedChain: FlattenedChain;\n      memoryDetails: Record<string, unknown> | null;\n      relatedMemories: Record<string, Record<string, unknown>>;\n      scopeDenied: boolean;\n    } => {\n      let incomingChain = createEmptyChain();\n      let outgoingChain = createEmptyChain();\n\n      if (mappedDirection === 'both') {\n        const forwardTree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'forward');\n        const backwardTree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'backward');\n        outgoingChain = forwardTree ? flattenCausalTree(forwardTree, maxDepth, 'forward') : createEmptyChain();\n        incomingChain = backwardTree ? flattenCausalTree(backwardTree, maxDepth, 'backward') : createEmptyChain();\n      } else if (mappedDirection === 'forward') {\n        const tree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'forward');\n        outgoingChain = tree ? flattenCausalTree(tree, maxDepth, 'forward') : createEmptyChain();\n      } else {\n        const tree = causalEdges.getCausalChain(String(memoryId), maxDepth, 'backward');\n        incomingChain = tree ? flattenCausalTree(tree, maxDepth, 'backward') : createEmptyChain();\n      }\n\n      // Apply relations filter after traversal, before response.\n      incomingChain = filterChainByRelations(incomingChain, relations);\n      outgoingChain = filterChainByRelations(outgoingChain, relations);\n      const combinedChain = mergeFlattenedChains(incomingChain, outgoingChain);\n\n      let memoryDetails: Record<string, unknown> | null = null;\n      const relatedMemories: Record<string, Record<string, unknown>> = {};\n      let scopeDenied = false;\n\n      // Fail-closed scope authorization on the source memory. Done independently\n      // of includeMemoryDetails so denial cannot be skipped by omitting details.\n      if (scopeMatches) {\n        const sourceScopeRow = db.prepare(`\n          SELECT tenant_id, user_id, agent_id, session_id\n          FROM memory_index\n          WHERE id = ? OR CAST(id AS TEXT) = ?\n        `).get(memoryId, String(memoryId)) as Record<string, unknown> | undefined;\n        if (!sourceScopeRow || !scopeMatches(sourceScopeRow)) {\n          scopeDenied = true;\n          return {\n            incomingChain,\n            outgoingChain,\n            combinedChain,\n            memoryDetails,\n            relatedMemories,\n            scopeDenied,\n          };\n        }\n      }\n\n      if (includeMemoryDetails) {\n        const sourceMemory = db.prepare(`\n          SELECT id, title, spec_folder, importance_tier, importance_weight,\n                 context_type, created_at, updated_at, file_path\n          FROM memory_index\n          WHERE id = ? OR CAST(id AS TEXT) = ?\n        `).get(memoryId, String(memoryId)) as Record<string, unknown> | undefined;\n\n        if (sourceMemory) {\n          memoryDetails = sourceMemory;\n        }\n\n        const memoryIds = new Set<string>();\n        for (const edge of combinedChain.all) {\n          memoryIds.add(edge.from);\n          memoryIds.add(edge.to);\n        }\n\n        if (memoryIds.size > 0) {\n          const idsArray = Array.from(memoryIds);\n          for (const id of idsArray) {\n            // When scope is enforced, gate the related row on a scope-column\n            // lookup but keep the returned detail shape unchanged.\n            if (scopeMatches) {\n              const scopeRow = db.prepare(`\n                SELECT tenant_id, user_id, agent_id, session_id\n                FROM memory_index\n                WHERE id = ? OR CAST(id AS TEXT) = ?\n              `).get(id, String(id)) as Record<string, unknown> | undefined;\n              if (!scopeRow || !scopeMatches(scopeRow)) {\n                continue;\n              }\n            }\n            const memory = db.prepare(`\n              SELECT id, title, spec_folder, importance_tier, created_at\n              FROM memory_index\n              WHERE id = ? OR CAST(id AS TEXT) = ?\n            `).get(id, String(id)) as Record<string, unknown> | undefined;\n            if (memory) {\n              relatedMemories[id] = memory;\n            }\n          }\n        }\n      }\n\n      return {\n        incomingChain,\n        outgoingChain,\n        combinedChain,\n        memoryDetails,\n        relatedMemories,\n        scopeDenied,\n      };\n    };\n\n    const traversalSnapshot = typeof db.transaction === 'function'\n      ? db.transaction(readTraversalSnapshot)()\n      : readTraversalSnapshot();\n    const {\n      incomingChain,\n      outgoingChain,\n      combinedChain,\n      memoryDetails,\n      relatedMemories,\n      scopeDenied,\n    } = traversalSnapshot;\n\n    // Fail-closed: the source memory is outside the supplied governed scope.\n    // Return the same empty shape as \"no relationships\" rather than leaking the\n    // chain or signalling existence of an out-of-scope memory.\n    if (scopeDenied) {\n      return createMCPEmptyResponse({\n        tool: 'memory_drift_why',\n        summary: `No causal relationships found for memory ${memoryId}`,\n        data: {\n          memoryId: String(memoryId),\n          memory: null\n        },\n        hints: [\n          'Use memory_causal_link to create relationships',\n          'Consider linking to related decisions or contexts'\n        ],\n        startTime: startTime\n      });\n    }\n\n    if (combinedChain.total_edges === 0) {\n      return createMCPEmptyResponse({\n        tool: 'memory_drift_why',\n        summary: `No causal relationships found for memory ${memoryId}`,\n        data: {\n          memoryId: String(memoryId),\n          memory: memoryDetails\n        },\n        hints: [\n          'Use memory_causal_link to create relationships',\n          'Consider linking to related decisions or contexts'\n        ],\n        startTime: startTime\n      });\n    }\n\n    const relationSummary: string[] = [];\n    const incomingSummary = formatRelationSummary(incomingChain, 'incoming');\n    const outgoingSummary = formatRelationSummary(outgoingChain, 'outgoing');\n    if (incomingSummary) relationSummary.push(incomingSummary);\n    if (outgoingSummary) relationSummary.push(outgoingSummary);\n\n    const summary = relationSummary.length > 0\n      ? `Found ${combinedChain.total_edges} causal relationships (${relationSummary.join('; ')})`\n      : `Found ${combinedChain.total_edges} causal relationships`;\n\n    const hints: string[] = [];\n    if (combinedChain.max_depth_reached) {\n      hints.push(`Max depth (${maxDepth}) reached - more relationships may exist beyond this depth`);\n    }\n    if (combinedChain.truncated) {\n      hints.push(\n        `Traversal truncated after ${combinedChain.truncation_limit ?? causalEdges.MAX_EDGES_LIMIT} edges per node - results may be incomplete`\n      );\n    }\n    if (combinedChain.by_contradicts.length > 0) {\n      hints.push('Contradicting relationships detected - review for consistency');\n    }\n\n    return createMCPSuccessResponse({\n      tool: 'memory_drift_why',\n      summary,\n      data: {\n        memoryId: String(memoryId),\n        memory: memoryDetails,\n        incoming: toDirectionalBuckets(incomingChain),\n        outgoing: toDirectionalBuckets(outgoingChain),\n        allEdges: combinedChain.all,\n        totalEdges: combinedChain.total_edges,\n        totalIncomingEdges: incomingChain.total_edges,\n        totalOutgoingEdges: outgoingChain.total_edges,\n        maxDepthReached: combinedChain.max_depth_reached,\n        truncated: combinedChain.truncated,\n        truncationLimit: combinedChain.truncation_limit,\n        relatedMemories: Object.keys(relatedMemories).length > 0 ? relatedMemories : null,\n        traversalOptions: { direction: mappedDirection, maxDepth }\n      },\n      hints,\n      startTime: startTime","lineStart":488,"lineEnd":757,"totalLines":1206,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/causal-graph.ts","time":{"start":1780925415646,"end":1780925415655}},"metadata":{"openai":{"itemId":"fc_0c609901c2cc37bb016a26c3e787388191b4aba492378733ed"}},"id":"prt_ea76d40d70014Ij3qqLqdUsaEt","sessionID":"ses_158954ac7ffel6uhZW0lvDJ5iU","messageID":"msg_ea76d180a001TgKsZgZqv0dovV"}}
