edProfiles: readonly ModelProfile[] = [\\n15:   { id: 'swe-1.6', quota_pool: 'cognition-free', fallback_target: null },\\n16:   { id: 'deepseek-v4-pro', quota_pool: 'cognition-pro', fallback_target: null },\\n17:   { id: 'kimi-k2.6', quota_pool: 'cognition-pro', fallback_target: null },\\n18:   { id: 'qwen3.6', quota_pool: 'cognition-pro', fallback_target: null },\\n19: ] as const;\\n20: \\n21: const optionalProfiles: readonly ModelProfile[] = [\\n22:   { id: 'haiku', quota_pool: 'anthropic', fallback_target: null },\\n23: ] as const;\\n24: \\n25: /**\\n26:  * Builds a ModelRegistry with a fallback target set for the given source model.\\n27:  */\\n28: function registryWithFallback(sourceId: string, targetId: string | null): ModelRegistry {\\n29:   return {\\n30:     models: [...requiredProfiles, ...optionalProfiles].map((profile) =>\\n31:       profile.id === sourceId ? { ...profile, fallback_target: targetId } : profile,\\n32:     ),\\n33:   };\\n34: }\\n35: \\n36: describe('fallback-route... (line truncated to 2000 chars)\n133: {\"type\":\"tool_use\",\"timestamp\":1783488140508,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_lV7OoE76CJLOCHZM9f7ac6oT\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/executor-provenance-mismatch.vitest.ts\",\"offset\":220,\"limit\":70},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/deep-loop-runtime/tests/unit/executor-provenance-mismatch.vitest.ts</path>\\n<type>file</type>\\n<content>\\n220:     withTempPaths(({ tempDir, stateLogPath }) => {\\n221:       runAuditedExecutorCommand({\\n222:         command: 'node',\\n223:         args: fakeOpencodeArgs('deepseek-v4-pro'),\\n224:         cwd: tempDir,\\n225:         timeoutSeconds: 30,\\n226:         stateLogPath,\\n227:         executor: opencodeExecutor(null),\\n228:         iteration: 6,\\n229:         guardContext: cleanGuard,\\n230:       });\\n231: \\n232:       expect(lastRecord(stateLogPath)).toMatchObject({ type: 'event', event: 'start' });\\n233:     });\\n234:   });\\n235: });\\n236: \\n237: describe('fallback-router approval guard (008)', () => {\\n238:   const profiles: readonly ModelProfile[] = [\\n239:     { id: 'swe-1.6', quota_pool: 'cognition-free', fallback_target: 'haiku' },\\n240:     { id: 'haiku', quota_pool: 'anthropic', fallback_target: null },\\n241:   ] as const;\\n242:   const registry: ModelRegistry = { models: profiles };\\n243: \\n244:   it('routes to the configured cross-pool target when it is caller-approved', () => {\\n245:     expect(resolveFallback('swe-1.6', registry, ['swe-1.6', 'haiku'])).toEqual({\\n246:       action: 'fallback',\\n247:       target: 'haiku',\\n248:       reason: 'cognition-free pool exhausted, routing swe-1.6 to separate anthropic pool target haiku',\\n249:     });\\n250:   });\\n251: \\n252:   it('fails fast when the configured target is not in the caller-approved set (unapproved substi... (line truncated to 2000 chars)\n134: {\"type\":\"tool_use\",\"timestamp\":1783488140702,\"sessionID\":\"ses_0bfd72ffbffeOJIQWH3C696a5x\",\"part\":{\"type\":\"tool\",\"tool\":\"read\",\"callID\":\"call_dxujTiODp9JCnelfNUdEflBZ\",\"state\":{\"status\":\"completed\",\"input\":{\"filePath\":\"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-prompt-models/assets/model_profiles.json\",\"offset\":180,\"limit\":140},\"output\":\"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-prompt-models/assets/model_profiles.json</path>\\n<type>file</type>\\n<content>\\n180:           \\\"primary_score\\\": 0.767,\\n181:           \\\"fallback_score\\\": 0.742,\\n182:           \\\"sample\\\": \\\"7-fixture rig, real MiniMax dispatches (benchmark run on M2.7; contract carried to M3)\\\",\\n183:       