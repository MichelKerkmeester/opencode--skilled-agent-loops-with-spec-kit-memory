 null ? { danglingId: edge.sourceId } : {}),\n635:       }));\n636:     },\n637:     mapResult: (visit) => {\n638:       if (resultSymbolIds.has(visit.payload.symbolId) || visit.payload.node == null) {\n639:         return null;\n640:       }\n641:       resultSymbolIds.add(visit.payload.symbolId);\n642:       return {\n643:         symbolId: visit.payload.symbolId,\n644:         fqName: visit.payload.node.fqName ?? null,\n645:         filePath: visit.payload.node.filePath ?? null,\n646:         line: visit.payload.node.startLine ?? null,\n647:         depth: visit.depth,\n648:       };\n649:     },\n650:   });\n651: \n652:   const nodes = traversal.results.map((entry) => entry.value).slice(0, limit);\n653:   if (traversal.dangling.length === 0) {\n654:     return { nodes };\n655:   }\n656: \n657:   const uniqueDangling = [...new Set(traversal.dangling.map((entry) => entry.id))];\n658:   return {\n659:     nodes,\n660:     warnings: [{\n661:       code: 'dangling_edge',\n662:       operation,\n663:       missingEndpoint,\n664:       count: uniqueDangling.length,\n665:       danglingSymbolIds: uniqueDangling,\n666:       message: `Transitive ${operation} traversal encountered ${uniqueDangling.length} dangling ${missingEndpoint} node reference(s). Reindex the code graph to repair the missing node references.`,\n667:     }],\n668:   };\n669: }\n670: \n671: function classifyEdgeEvidenceClass(\n672:   edgeType: string,\n673:   metadata: Record<string, unknown> | undefined,\n674: ): EdgeEvidenceClass {\n675:   switch (edgeType) {\n676:     case 'IMPORTS':\n677:     case 'EXPORTS':\n678:       return 'import';\n679:     case 'EXTENDS':\n680:     case 'IMPLEMENTS':\n681:     case 'TYPE_OF':\n682:       return 'type_reference';\n683:     case 'TESTED_BY':\n684:       return 'test_coverage';\n685:     default:\n686:       return metadata?.detectorProvenance === 'heuristic' || metadata?.evidenceClass === 'INFERRED'\n687:         ? 'inferred_heuristic'\n688:         : 'direct_call';\n689:   }\n690: }\n691: \n692: function clampNumericConfidence(value: unknown): number {\n693:   if (typeof value !== 'number' || !Number.isFinite(value)) {\n694:     return 0;\n695:   }\n696:   return Math.max(0, Math.min(1, value));\n697: }\n698: \n699: function edgeMetadataOutput(edge: OutboundEdgeEntry['edge'] | InboundEdgeEntry['edge']) {\n700:   return {\n701:     confidence: clampNumericConfidence(edge.metadata?.confidence ?? edge.weight),\n702:     numericConfidence: clampNumericConfidence(edge.metadata?.confidence ?? edge.weight),\n703:     detectorProvenance: edge.metadata?.detectorProvenance ?? null,\n704:     evidenceClass: edge.metadata?.evidenceClass ?? null,\n705:     reason: graphDb.sanitizeEdgeMetadataString(edge.metadata?.reason),\n706:     step: graphDb.sanitizeEdgeMetadataString(edge.metadata?.step),\n707:     edgeEvidenceClass: classifyEdgeEvidenceClass(\n708:       edge.edgeType,\n709:       edge.metadata as Record<string, unknown> | undefined,\n710:     ),\n711:   };\n712: }\n713: \n714: /* ───────────────────────────────────────────────────────────────\n715:    Shared relationship-edge mapper\n716:    --------------------------------------------------------------\n717:    Replaces near-duplicate switch branches for `calls_from`,\n718:    `calls_to`, `imports_from`, and `imports_to`. Two inputs control\n719:    the variant: (1) direction = outbound (target side) vs inbound\n720:    (source side); (2) whether to surface the start line.\n721: ─────────────────────────────────────────────────────────────── */\n722: \n723: type RelationshipMappedEdge = RelationshipQueryEdge & {\n724:   confidence: number;\n725:   numericConfidence: number;\n726:   detectorProvenance: string | null;\n727:   evidenceClass: string | null;\n728:   reason: string | null;\n729:   step: string | null;\n730:   edgeEvidenceClass: EdgeEvidenceClass;\n731: };\n732: \n733: function mapOutboundRelationshipEdge(\n734:   entry: OutboundEdgeEntry,\n735:   options: { includeLine: boolean },\n736: ): RelationshipMappedEdge {\n737:   return {\n738:     target: entry.targetNode?.fqName ?? entry.edge.targetId,\n739:     file: entry.targetNode?.filePath,\n740:     ...(options.includeLine ? { line: entry.targetNode?.startLine } : {}),\n741:     ...edgeMetadataOutput(entry.edge),\n742:   };\n743: }\n744: \n745: function mapInboundRelationshipEdge(\n746:   entry: InboundEdgeEntry,\n747:   options: { includeLine: boolean },\n748: ): RelationshipMappedEdge {\n749:   return {\n750:     source: entry.sourceNode?.fqName ?? entry.edge.sourceId,\n751:     file: entry.sourceNode?.filePath,\n752:     ...(options.includeLine ? { line: entry.sourceNode?.startLine } : {}),\n753:     ...edgeMetadataOutput(entry.edge),\n754:   };\n755: }\n756: \n757: function extractOutboundFilePaths(entries: OutboundEdgeEntry[]): string[] {\n758:   return entries\n759:     .map((entry) => entry.targetNode?.filePath)\n760:     .filter((value): value is string => typeof value === 'string');\n761: }\n762: \n763: function extractInboundFilePaths(entries: InboundEdgeEntry[]): string[] {\n764:   return entries\n765:     .map((entry) => entry.sourceNode?.filePath)\n766:     .filter((value): value is string => typeof value === 'string');\n767: }\n768: \n769: function subjectLooksLikeFilePath(subject: string): boolean {\n770:   return FILE_PATH_SEPARATOR_PATTERN.test(subject) || FILE_PATH_EXTENSION_PATTERN.test(subject);\n771: }\n772: \n773: function resolveRelationshipFilePath(subject: string): string | null {\n774:   if (!subjectLooksLikeFilePath(subject)) {\n775:     return null;\n776:   }\n777: \n778:   const resolvedFilePath = graphDb.resolveSubjectFilePath(subject);\n779:   return typeof resolvedFilePath === 'string' && resolvedFilePath.length > 0\n780:     ? resolvedFilePath\n781:     : null;\n782: }\n783: \n784: function queryRelationshipFileSymbols(filePath: string): CodeNode[] {\n785:   return graphDb\n\n(Showing lines 606-785 of 1766. Use offset=786 to continue.)\n</content>","metadata":{"preview":"function transitiveTraversal(\n  startId: string,\n  edgeType: string,\n  direction: 'from' | 'to',\n  maxDepth: number,\n  limit: number,\n  operation: QueryArgs['operation'],\n): TransitiveTraversalResult {\n  const resultSymbolIds = new Set<string>();\n  const missingEndpoint: DanglingEdgeWarning['missingEndpoint'] = direction === 'from' ? 'target' : 'source';\n  const traversal = traverseGraphBfs<string, TransitiveTraversalNeighbor, TransitiveTraversalResult['nodes'][number]>({\n    startIds: [startId],\n    maxDepth,\n    resultLimit: limit,\n    visitTiming: 'dequeue',\n    stopEnqueueWhenResultLimitReached: true,\n    getNeighbors: (item) => {\n      if (direction === 'from') {\n        return graphDb.queryEdgesFrom(item.id, edgeType).map<GraphBfsNeighbor<string, TransitiveTraversalNeighbor>>(({ edge, targetNode }) => ({\n          id: edge.targetId,","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-code-graph/mcp_server/handlers/query.ts","text":"function transitiveTraversal(\n  startId: string,\n  edgeType: string,\n  direction: 'from' | 'to',\n  maxDepth: number,\n  limit: number,\n  operation: QueryArgs['operation'],\n): TransitiveTraversalResult {\n  const resultSymbolIds = new Set<string>();\n  const missingEndpoint: DanglingEdgeWarning['missingEndpoint'] = direction === 'from' ? 'target' : 'source';\n  const traversal = traverseGraphBfs<string, TransitiveTraversalNeighbor, TransitiveTraversalResult['nodes'][number]>({\n    startIds: [startId],\n    maxDepth,\n    resultLimit: limit,\n    visitTiming: 'dequeue',\n    stopEnqueueWhenResultLimitReached: true,\n    getNeighbors: (item) => {\n      if (direction === 'from') {\n        return graphDb.queryEdgesFrom(item.id, edgeType).map<GraphBfsNeighbor<string, TransitiveTraversalNeighbor>>(({ edge, targetNode }) => ({\n          id: edge.targetId,\n          payload: { symbolId: edge.targetId, node: targetNode },\n          ...(targetNode == null ? { danglingId: edge.targetId } : {}),\n        }));\n      }\n\n      return graphDb.queryEdgesTo(item.id, edgeType).map<GraphBfsNeighbor<string, TransitiveTraversalNeighbor>>(({ edge, sourceNode }) => ({\n        id: edge.sourceId,\n        payload: { symbolId: edge.sourceId, node: sourceNode },\n        ...(sourceNode == null ? { danglingId: edge.sourceId } : {}),\n      }));\n    },\n    mapResult: (visit) => {\n      if (resultSymbolIds.has(visit.payload.symbolId) || visit.payload.node == null) {\n        return null;\n      }\n      resultSymbolIds.add(visit.payload.symbolId);\n      return {\n        symbolId: visit.payload.symbolId,\n        fqName: visit.payload.node.fqName ?? null,\n        filePath: visit.payload.node.filePath ?? null,\n        line: visit.payload.node.startLine ?? null,\n        depth: visit.depth,\n      };\n    },\n  });\n\n  const nodes = traversal.results.map((entry) => entry.value).slice(0, limit);\n  if (traversal.dangling.length === 0) {\n    return { nodes };\n  }\n\n  const uniqueDangling = [...new Set(traversal.dangling.map((entry) => entry.id))];\n  return {\n    nodes,\n    warnings: [{\n      code: 'dangling_edge',\n      operation,\n      missingEndpoint,\n      count: uniqueDangling.length,\n      danglingSymbolIds: uniqueDangling,\n      message: `Transitive ${operation} traversal encountered ${uniqueDangling.length} dangling ${missingEndpoint} node reference(s). Reindex the code graph to repair the missing node references.`,\n    }],\n  };\n}\n\nfunction classifyEdgeEvidenceClass(\n  edgeType: string,\n  metadata: Record<string, unknown> | undefined,\n): EdgeEvidenceClass {\n  switch (edgeType) {\n    case 'IMPORTS':\n    case 'EXPORTS':\n      return 'import';\n    case 'EXTENDS':\n    case 'IMPLEMENTS':\n    case 'TYPE_OF':\n      return 'type_reference';\n    case 'TESTED_BY':\n      return 'test_coverage';\n    default:\n      return metadata?.detectorProvenance === 'heuristic' || metadata?.evidenceClass === 'INFERRED'\n        ? 'inferred_heuristic'\n        : 'direct_call';\n  }\n}\n\nfunction clampNumericConfidence(value: unknown): number {\n  if (typeof value !== 'number' || !Number.isFinite(value)) {\n    return 0;\n  }\n  return Math.max(0, Math.min(1, value));\n}\n\nfunction edgeMetadataOutput(edge: OutboundEdgeEntry['edge'] | InboundEdgeEntry['edge']) {\n  return {\n    confidence: clampNumericConfidence(edge.metadata?.confidence ?? edge.weight),\n    numericConfidence: clampNumericConfidence(edge.metadata?.confidence ?? edge.weight),\n    detectorProvenance: edge.metadata?.detectorProvenance ?? null,\n    evidenceClass: edge.metadata?.evidenceClass ?? null,\n    reason: graphDb.sanitizeEdgeMetadataString(edge.metadata?.reason),\n    step: graphDb.sanitizeEdgeMetadataString(edge.metadata?.step),\n    edgeEvidenceClass: classifyEdgeEvidenceClass(\n      edge.edgeType,\n      edge.metadata as Record<string, unknown> | undefined,\n    ),\n  };\n}\n\n/* ───────────────────────────────────────────────────────────────\n   Shared relationship-edge mapper\n   --------------------------------------------------------------\n   Replaces near-duplicate switch branches for `calls_from`,\n   `calls_to`, `imports_from`, and `imports_to`. Two inputs control\n   the variant: (1) direction = outbound (target side) vs inbound\n   (source side); (2) whether to surface the start line.\n─────────────────────────────────────────────────────────────── */\n\ntype RelationshipMappedEdge = RelationshipQueryEdge & {\n  confidence: number;\n  numericConfidence: number;\n  detectorProvenance: string | null;\n  evidenceClass: string | null;\n  reason: string | null;\n  step: string | null;\n  edgeEvidenceClass: EdgeEvidenceClass;\n};\n\nfunction mapOutboundRelationshipEdge(\n  entry: OutboundEdgeEntry,\n  options: { includeLine: boolean },\n): RelationshipMappedEdge {\n  return {\n    target: entry.targetNode?.fqName ?? entry.edge.targetId,\n    file: entry.targetNode?.filePath,\n    ...(options.includeLine ? { line: entry.targetNode?.startLine } : {}),\n    ...edgeMetadataOutput(entry.edge),\n  };\n}\n\nfunction mapInboundRelationshipEdge(\n  entry: InboundEdgeEntry,\n  options: { includeLine: boolean },\n): RelationshipMappedEdge {\n  return {\n    source: entry.sourceNode?.fqName ?? entry.edge.sourceId,\n    file: entry.sourceNode?.filePath,\n    ...(options.includeLine ? { line: entry.sourceNode?.startLine } : {}),\n    ...edgeMetadataOutput(entry.edge),\n  };\n}\n\nfunction extractOutboundFilePaths(entries: OutboundEdgeEntry[]): string[] {\n  return entries\n    .map((entry) => entry.targetNode?.filePath)\n    .filter((value): value is string => typeof value === 'string');\n}\n\nfunction extractInboundFilePaths(entries: InboundEdgeEntry[]): string[] {\n  return entries\n    .map((entry) => entry.sourceNode?.filePath)\n    .filter((value): value is string => typeof value === 'string');\n}\n\nfunction subjectLooksLikeFilePath(subject: string): boolean {\n  return FILE_PATH_SEPARATOR_PATTERN.test(subject) || FILE_PATH_EXTENSION_PATTERN.test(subject);\n}\n\nfunction resolveRelationshipFilePath(subject: string): string | null {\n  if (!subjectLooksLikeFilePath(subject)) {\n    return null;\n  }\n\n  const resolvedFilePath = graphDb.resolveSubjectFilePath(subject);\n  return typeof resolvedFilePath === 'string' && resolvedFilePath.length > 0\n    ? resolvedFilePath\n    : null;\n}\n\nfunction queryRelationshipFileSymbols(filePath: string): CodeNode[] {\n  return graphDb","lineStart":606,"lineEnd":785,"totalLines":1766,"truncated":true}},"title":".opencode/skills/system-code-graph/mcp_server/handlers/query.ts","time":{"start":1781128817277,"end":1781128817286}},"metadata":{"openai":{"itemId":"fc_02b2ee46d9b7dc27016a29de7100508196bd081a085c01fe39"}},"id":"prt_eb38ce9aa001J7wpW0iuSwL4Az","sessionID":"ses_14c74eea9ffeIyeKUQdOD4vWgF","messageID":"msg_eb38cd6a8001lyeBiYovYrD1Ay"}}
