   371	function parsePromptBlock(text) {
   372	  // ```[lang]\n<prompt>\n``` after the prompt marker. Per-feature files vary:
   373	  // SD/LS/RD use "**Exact prompt**", CS use "**Realistic user prompt**".
   374	  const m = /\*\*(?:Exact prompt|Realistic user prompt)\*\*:?\s*\n+```[a-z]*\n([\s\S]*?)\n```/i.exec(text);
   375	  if (m) return m[1].trim();
   376	  // sk-doc / inline shape: "Prompt: ..." line, optionally bulleted and/or
   377	  // framework-prefixed (e.g. sk-git's "- RCAF Prompt: `...`"), optionally
   378	  // wrapped in a single backtick span.
   379	  const inline = /(?:^|\n)\s*(?:[-*]\s+)?(?:\*\*)?(?:RCAF\s+)?Prompt(?:\*\*)?:\s*(.+)/i.exec(text);
   380	  if (!inline) return null;
   381	  let value = inline[1].trim();
   382	  const wrapped = /^`([^`]*)`$/.exec(value);
   383	  if (wrapped) value = wrapped[1].trim();
   384	  return value || null;
   385	}
