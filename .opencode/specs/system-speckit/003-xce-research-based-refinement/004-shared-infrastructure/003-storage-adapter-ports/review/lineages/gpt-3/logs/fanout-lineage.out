{"type":"tool_use","timestamp":1781144367543,"sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","part":{"type":"tool","tool":"read","callID":"call_tkGE0VFjMCHwkYqOxP3wAP2J","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","offset":221,"limit":130},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts</path>\n<type>file</type>\n<content>\n221:       nextFrontier.push(edge.to);\n222:     }\n223: \n224:     frontier = uniqueNodes(nextFrontier);\n225:   }\n226: \n227:   return reached;\n228: }\n229: \n230: /** Read causal edges as an undirected, weighted adjacency view without OR joins. */\n231: export function readCausalNeighborEdges(\n232:   database: Database.Database,\n233:   nodeIds: readonly number[],\n234:   relationWeights: Readonly<Record<string, number>>,\n235: ): WeightedTraversalEdge<number>[] {\n236:   const nodes = uniqueNodes(nodeIds).filter((nodeId) => Number.isFinite(nodeId));\n237:   const edges: WeightedTraversalEdge<number>[] = [];\n238:   if (nodes.length === 0) {\n239:     return edges;\n240:   }\n241: \n242:   for (const nodeChunk of chunks(nodes.map((nodeId) => String(nodeId)), SQLITE_BINDING_CHUNK_SIZE)) {\n243:     const chunkPlaceholders = placeholders(nodeChunk.length);\n244:     const outgoingRows = database.prepare(`\n245:       SELECT source_id, target_id, relation, strength\n246:       FROM causal_edges\n247:       WHERE source_id IN (${chunkPlaceholders})\n248:     `).all(...nodeChunk) as CausalEdgeRow[];\n249:     const incomingRows = database.prepare(`\n250:       SELECT source_id, target_id, relation, strength\n251:       FROM causal_edges\n252:       WHERE target_id IN (${chunkPlaceholders})\n253:     `).all(...nodeChunk) as CausalEdgeRow[];\n254: \n255:     for (const row of outgoingRows) {\n256:       const from = Number.parseInt(row.source_id, 10);\n257:       const to = Number.parseInt(row.target_id, 10);\n258:       if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n259:       edges.push({\n260:         from,\n261:         to,\n262:         weight: relationWeight(row.relation, relationWeights),\n263:         strength: edgeStrength(row.strength),\n264:       });\n265:     }\n266:     for (const row of incomingRows) {\n267:       const from = Number.parseInt(row.target_id, 10);\n268:       const to = Number.parseInt(row.source_id, 10);\n269:       if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n270:       edges.push({\n271:         from,\n272:         to,\n273:         weight: relationWeight(row.relation, relationWeights),\n274:         strength: edgeStrength(row.strength),\n275:       });\n276:     }\n277:   }\n278: \n279:   return edges;\n280: }\n281: \n282: /** Traverse causal edges with the production weighted-walk reader. */\n283: export function collectCausalWeightedNeighbors(\n284:   database: Database.Database,\n285:   seeds: readonly number[],\n286:   maxHops: number,\n287:   relationWeights: Readonly<Record<string, number>>,\n288: ): Map<number, WeightedWalkResult<number>> {\n289:   return collectWeightedWalk({\n290:     seeds,\n291:     maxHops,\n292:     readEdges: (nodeIds) => readCausalNeighborEdges(database, nodeIds, relationWeights),\n293:   });\n294: }\n295: \n296: /** Read memo dependency edges in parent-to-child direction. */\n297: export function readDependencyChildren(\n298:   database: Database.Database,\n299:   parentPaths: readonly string[],\n300: ): DirectedTraversalEdge<string>[] {\n301:   const parents = uniqueNodes(parentPaths).filter((parentPath) => parentPath.length > 0);\n302:   const edges: DirectedTraversalEdge<string>[] = [];\n303:   if (parents.length === 0) {\n304:     return edges;\n305:   }\n306: \n307:   for (const parentChunk of chunks(parents, SQLITE_BINDING_CHUNK_SIZE)) {\n308:     const chunkPlaceholders = placeholders(parentChunk.length);\n309:     const rows = database.prepare(`\n310:       SELECT parent_path, child_path\n311:       FROM dependency_edges\n312:       WHERE parent_path IN (${chunkPlaceholders})\n313:     `).all(...parentChunk) as DependencyEdgeRow[];\n314: \n315:     for (const row of rows) {\n316:       edges.push({ from: row.parent_path, to: row.child_path });\n317:     }\n318:   }\n319: \n320:   return edges;\n321: }\n322: \n323: /** Traverse memo dependency edges from parent paths to all transitive children. */\n324: export function collectDependencyReachability(\n325:   database: Database.Database,\n326:   roots: readonly string[],\n327: ): string[] {\n328:   return collectDirectedReachability({\n329:     roots,\n330:     readEdges: (nodeIds) => readDependencyChildren(database, nodeIds),\n331:   });\n332: }\n\n(End of file - total 332 lines)\n</content>","metadata":{"preview":"      nextFrontier.push(edge.to);\n    }\n\n    frontier = uniqueNodes(nextFrontier);\n  }\n\n  return reached;\n}\n\n/** Read causal edges as an undirected, weighted adjacency view without OR joins. */\nexport function readCausalNeighborEdges(\n  database: Database.Database,\n  nodeIds: readonly number[],\n  relationWeights: Readonly<Record<string, number>>,\n): WeightedTraversalEdge<number>[] {\n  const nodes = uniqueNodes(nodeIds).filter((nodeId) => Number.isFinite(nodeId));\n  const edges: WeightedTraversalEdge<number>[] = [];\n  if (nodes.length === 0) {\n    return edges;\n  }","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","text":"      nextFrontier.push(edge.to);\n    }\n\n    frontier = uniqueNodes(nextFrontier);\n  }\n\n  return reached;\n}\n\n/** Read causal edges as an undirected, weighted adjacency view without OR joins. */\nexport function readCausalNeighborEdges(\n  database: Database.Database,\n  nodeIds: readonly number[],\n  relationWeights: Readonly<Record<string, number>>,\n): WeightedTraversalEdge<number>[] {\n  const nodes = uniqueNodes(nodeIds).filter((nodeId) => Number.isFinite(nodeId));\n  const edges: WeightedTraversalEdge<number>[] = [];\n  if (nodes.length === 0) {\n    return edges;\n  }\n\n  for (const nodeChunk of chunks(nodes.map((nodeId) => String(nodeId)), SQLITE_BINDING_CHUNK_SIZE)) {\n    const chunkPlaceholders = placeholders(nodeChunk.length);\n    const outgoingRows = database.prepare(`\n      SELECT source_id, target_id, relation, strength\n      FROM causal_edges\n      WHERE source_id IN (${chunkPlaceholders})\n    `).all(...nodeChunk) as CausalEdgeRow[];\n    const incomingRows = database.prepare(`\n      SELECT source_id, target_id, relation, strength\n      FROM causal_edges\n      WHERE target_id IN (${chunkPlaceholders})\n    `).all(...nodeChunk) as CausalEdgeRow[];\n\n    for (const row of outgoingRows) {\n      const from = Number.parseInt(row.source_id, 10);\n      const to = Number.parseInt(row.target_id, 10);\n      if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n      edges.push({\n        from,\n        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n    for (const row of incomingRows) {\n      const from = Number.parseInt(row.target_id, 10);\n      const to = Number.parseInt(row.source_id, 10);\n      if (!Number.isFinite(from) || !Number.isFinite(to)) continue;\n      edges.push({\n        from,\n        to,\n        weight: relationWeight(row.relation, relationWeights),\n        strength: edgeStrength(row.strength),\n      });\n    }\n  }\n\n  return edges;\n}\n\n/** Traverse causal edges with the production weighted-walk reader. */\nexport function collectCausalWeightedNeighbors(\n  database: Database.Database,\n  seeds: readonly number[],\n  maxHops: number,\n  relationWeights: Readonly<Record<string, number>>,\n): Map<number, WeightedWalkResult<number>> {\n  return collectWeightedWalk({\n    seeds,\n    maxHops,\n    readEdges: (nodeIds) => readCausalNeighborEdges(database, nodeIds, relationWeights),\n  });\n}\n\n/** Read memo dependency edges in parent-to-child direction. */\nexport function readDependencyChildren(\n  database: Database.Database,\n  parentPaths: readonly string[],\n): DirectedTraversalEdge<string>[] {\n  const parents = uniqueNodes(parentPaths).filter((parentPath) => parentPath.length > 0);\n  const edges: DirectedTraversalEdge<string>[] = [];\n  if (parents.length === 0) {\n    return edges;\n  }\n\n  for (const parentChunk of chunks(parents, SQLITE_BINDING_CHUNK_SIZE)) {\n    const chunkPlaceholders = placeholders(parentChunk.length);\n    const rows = database.prepare(`\n      SELECT parent_path, child_path\n      FROM dependency_edges\n      WHERE parent_path IN (${chunkPlaceholders})\n    `).all(...parentChunk) as DependencyEdgeRow[];\n\n    for (const row of rows) {\n      edges.push({ from: row.parent_path, to: row.child_path });\n    }\n  }\n\n  return edges;\n}\n\n/** Traverse memo dependency edges from parent paths to all transitive children. */\nexport function collectDependencyReachability(\n  database: Database.Database,\n  roots: readonly string[],\n): string[] {\n  return collectDirectedReachability({\n    roots,\n    readEdges: (nodeIds) => readDependencyChildren(database, nodeIds),\n  });\n}","lineStart":221,"lineEnd":332,"totalLines":332,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/graph/bfs-traversal.ts","time":{"start":1781144367538,"end":1781144367542}},"metadata":{"openai":{"itemId":"fc_081d01039fd794ec016a2a1b2f218081918fb3d8eeb4de1a12"}},"id":"prt_eb47a302e001UfuaNhFKfbrm50","sessionID":"ses_14b8a021dffe4EDpwF3ZFWejrc","messageID":"msg_eb47a1406001h2ro1w0BLNPUmZ"}}
