Promise<string> {\n\n  Line 37:     const queryVec = sessionContext ? await embedText(sessionContext) : null;\n\n  Line 206:   const sessionContext = summaryText.slice(0, 500).trim() || undefined;\n\n  Line 213:   const ltmSection = await buildLtmSection(name, sessionContext);\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/GitCommit.ts:\n  Line 3:  * GitCommit.ts — Post-commit hook that auto-extracts learnings from git diffs.\n\n  Line 6:  *   hook mode (default):  validates config, spawns detached extractor, exits 0 immediately\n\n  Line 7:  *   extract mode:         --extract <json>  — runs LLM extraction and stores memories\n\n  Line 9:  * Installed globally via ~/.claude/hooks/git/post-commit\n\n  Line 43:   const fileList = runGit([\"diff-tree\", \"--no-commit-id\", \"-r\", \"--name-only\", \"HEAD\"], cwd);\n\n  Line 83:   commitMsg: string;\n\n  Line 88:   const { extractAndLearn } = await import(\"../lib/llmExtract.js\");\n\n  Line 90:   const preamble = `Git commit: ${payload.commitMsg}\\nFiles changed: ${payload.files.slice(0, 5).join(\", \")}`;\n\n  Line 92:   await extractAndLearn(payload.diff, payload.projectName, {\n\n  Line 93:     source: `git-commit:${payload.hash}`,\n\n  Line 103:   if (process.argv.includes(\"--extract\")) {\n\n  Line 110:       process.stderr.write(`[GitCommit] extract error: ${err}\\n`);\n\n  Line 136:     const payload = { diff, commitMsg: message, hash, files, projectName };\n\n  Line 138:     // Spawn detached so git doesn't wait for LLM extraction — pipe payload via stdin\n\n  Line 140:       [\"bun\", join(PLUGIN_ROOT, \"hooks/GitCommit.bundle.mjs\"), \"--extract\"],\n\n\n/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/OpenLtm-main/hooks/src/EvaluateSession.ts:\n  Line 9: import { extractProposals } from \"../lib/