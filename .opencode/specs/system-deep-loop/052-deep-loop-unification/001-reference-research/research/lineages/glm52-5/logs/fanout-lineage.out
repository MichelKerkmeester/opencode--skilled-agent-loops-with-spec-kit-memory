:      \"nativeTop\": \"deep-loop-workflows\",\n31:      \"reason\": \"deep-loop merge re-baseline: legacy deep-* skills folded into deep-loop-workflows shifted native top-1; recorded as approved local-vs-native divergence\",\n39:      \"localTop\": \"none\",\n40:      \"nativeTop\": \"sk-doc\",\n49:      \"localTop\": \"none\",\n","metadata":{"output":"=== advisor aliases.ts MERGED_DEEP_SKILL_ID ===\n97:// deep-loop-workflows, discriminated by workflowMode (see\n98:// deep-loop-workflows/mode-registry.json). canonicalSkillId above is\n103:// deep-loop-workflows with the right mode once the old skill nodes leave the\n109:export const MERGED_DEEP_SKILL_ID = 'deep-loop-workflows';\n159: * Resolve any deep-loop alias to the merged skill id (deep-loop-workflows) when\n164:  return modeForAlias(skillId) !== null ? MERGED_DEEP_SKILL_ID : canonicalSkillId(skillId);\n=== drift-guard registryPath constant ===\n26:const registryPath = resolve(repoRoot, '.opencode/skills/deep-loop-workflows/mode-registry.json');\n55:const registry = JSON.parse(readFileSync(registryPath, 'utf8')) as { modes: readonly Mode[] };\n76:    skill: 'deep-loop-workflows',\n=== approved-divergences deep-loop-workflows fields ===\n9:      \"localTop\": \"none\",\n10:      \"nativeTop\": \"sk-code\",\n19:      \"localTop\": \"system-spec-kit\",\n20:      \"nativeTop\": \"memory:save\",\n29:      \"localTop\": \"none\",\n30:      \"nativeTop\": \"deep-loop-workflows\",\n31:      \"reason\": \"deep-loop merge re-baseline: legacy deep-* skills folded into deep-loop-workflows shifted native top-1; recorded as approved local-vs-native divergence\",\n39:      \"localTop\": \"none\",\n40:      \"nativeTop\": \"sk-doc\",\n49:      \"localTop\": \"none\",\n","exit":0,"truncated":false},"title":"echo \"=== advisor aliases.ts MERGED_DEEP_SKILL_ID ===\"; rg -n \"deep-loop-workflows|MERGED_DEEP_SKILL_ID\" .opencode/skills/system-skill-advisor/mcp_server/lib/scorer/aliases.ts | head; echo \"=== drift-guard registryPath constant ===\"; rg -n \"deep-loop-workflows|registryPath|mode-registry\" .opencode/skills/system-skill-advisor/mcp_server/tests/routing-registry-drift-guard.vitest.ts | head; echo \"=== approved-divergences deep-loop-workflows fields ===\"; rg -n \"deep-loop-workflows|nativeTop|localTop|skill_top_1\" .opencode/skills/system-skill-advisor/mcp_server/tests/parity/fixtures/local-native-approved-divergences.json | head","time":{"start":1783488993577,"end":1783488993579}},"id":"prt_f403a5911001hp0zE99m3YguWB","sessionID":"ses_0bfd0dbd6ffenhLxBpSW8JdhPn","messageID":"msg_f403a37b1001A6jiSdNwQRTEKJ"}}
