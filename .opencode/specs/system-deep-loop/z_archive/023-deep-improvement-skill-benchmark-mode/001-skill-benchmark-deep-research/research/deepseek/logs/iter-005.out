rver: [['sk-code', 0.4]],\n85:   intersection: [['sk-code', 0.4]],\n86:   classifier: [['sk-code', 0.45]],\n87:   fixture: [['sk-code', 0.55]],\n88:   'gate-3-classifier': [['sk-code', 0.95]],\n89:   'negative-trigger': [['sk-code', 0.8]],\n90: };\n91: \n92: const PHRASE_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n93:   '/create:agent': [['create:agent', 1.6], ['sk-doc', 0.45]],\n94:   '/create:testing-playbook': [['create:testing-playbook', 1.8], ['command-create-testing-playbook', 1.2], ['sk-doc', 0.2]],\n95:   '/memory:save': [['memory:save', 1.6], ['command-memory-save', 1], ['system-spec-kit', 0.45]],\n96:   '/deep:start-research-loop': [['deep-research', 1.6], ['command-spec-kit', 0.45]],\n97:   '/deep:start-review-loop': [['deep-review', 1.6], ['command-spec-kit', 0.45]],\n98:   '/deep:start-model-benchmark-loop': [['deep-model-benchmark', 1.6], ['command-spec-kit', 0.45]],\n99:   '/deep:start-agent-improvement-loop': [['deep-agent-improvement', 1.6], ['command-spec-kit', 0.45]],\n100:   '/speckit:resume': [['system-spec-kit', 0.9], ['command-spec-kit', 0.75]],\n101:   'auto review release readiness': [['deep-review', 1]],\n102:   // Colon-command syntax (\":review:auto\") is a deep-review LOOP invocation,\n103:   // distinct from natural-language \"auto review this PR\" (which stays\n104:   // sk-code-review). Strong direct-evidence anchor + a bounded code-review\n105:   // penalty so the loop skill wins the rank.\n106:   ':review:auto': [['deep-review', 1.6], ['sk-code-review', -0.6]],\n107:   ':review:confirm': [['deep-review', 1.6], ['sk-code-review', -0.6]],\n108:   // Domain phrase anchors (multi-token, so they lift confidence via the direct\n109:   // lane without firing on single tokens like \"scan\"/\"profile\"/\"search\"/\"cms\").\n110:   'webflow cms': [['mcp-code-mode', 1.5], ['sk-code', -0.5]],\n111:   'cms collection': [['mcp-code-mode', 1.4]],\n112:   'structural search': [['system-code-graph', 1.5]],\n113:   'code graph search': [['system-code-graph', 1.5]],\n114:   'find code that': [['system-code-graph', 1.4]],\n115:   'code that handles': [['system-code-graph', 1.4]],\n116:   '5d scoring': [['deep-agent-improvement', 1.5]],\n117:   '5-dimension agent scoring': [['deep-agent-improvement', 1.6]],\n118:   'integration scan': [['deep-agent-improvement', 1.5]],\n119:   'dynamic profile': [['deep-agent-improvement', 1.5]],\n120:   // Lane B (model-benchmark) command anchors. These benchmark or optimize a\n121:   // model / prompt framework against fixtures, routed by the\n122:   // /deep:start-model-benchmark-loop command (canonical deep-model-benchmark).\n123:   // Lane B runs as a MODE of the deep-agent-improvement skill. The projection\n124:   // exposes a single canonical node for that skill (deep-agent-improvement),\n125:   // so the disambiguation penalty must target that canonical id to actually\n126:   // lower the ranked Lane A candidate. The earlier alias-shaped target\n127:   // (command-spec-kit-deep-agent-improvement) is not a projection node, so it\n128:   // never reached the ranked skill and the penalty was inert. The bounded\n129:   // penalty keeps benchmark phrasing from out-ranking deep-model-benchmark.\n130:   'benchmark a model': [['deep-model-benchmark', 1.6], ['deep-agent-improvement', -0.6]],\n131:   'benchmark a prompt framework': [['deep-model-benchmark', 1.6], ['deep-agent-improvement', -0.6]],\n132:   'benchmark a prompt': [['deep-model-benchmark', 1.4], ['deep-agent-improvement', -0.4]],\n133:   'optimize a model': [['deep-model-benchmark', 1.5], ['deep-agent-improvement', -0.6]],\n134:   'optimize a prompt framework': [['deep-model-benchmark', 1.5], ['deep-agent-improvement', -0.6]],\n135:   'model benchmark loop': [['deep-model-benchmark', 1.6], ['deep-agent-improvement', -0.4]],\n136:   'model benchmark': [['deep-model-benchmark', 1.4], ['deep-agent-improvement', -0.4]],\n137:   'benchmark fixtures': [['deep-model-benchmark', 1.3]],\n138:   'prompt framework benchmark': [['deep-model-benchmark', 1.5], ['deep-agent-improvement', -0.4]],\n139:   'chrome devtools': [['mcp-chrome-devtools', 1]],\n140:   'staging url': [['mcp-chrome-devtools', 0.65]],\n141:   'staging site': [['mcp-chrome-devtools', 0.65]],\n142:   'staging website': [['mcp-chrome-devtools', 0.65]],\n143:   'live site': [['mcp-chrome-devtools', 0.65]],\n144:   'live website': [['mcp-chrome-devtools', 0.65]],\n145:   'live url': [['mcp-chrome-devtools', 0.65]],\n146:   'production site': [['mcp-chrome-devtools', 0.65]],\n147:   'production website': [['mcp-chrome-devtools', 0.65]],\n148:   'production url': [['mcp-chrome-devtools', 0.65]],\n149:   'browser console': [['mcp-chrome-devtools', 0.75]],\n150:   'cleaner prompt': [['sk-prompt', 1]],\n151:   'code review': [['sk-code-review', 1]],\n152:   'review the routing': [['sk-code-review', 0.6]],\n153:   'review the taxonomy': [['sk-code-review', 0.6]],\n154:   'review the routing taxonomy': [['sk-code-review', 1.1], ['sk-doc', -0.4]],\n155:   'review the packet docs': [['sk-code-review', 1.2]],\n156:   'audit packet docs': [['sk-code-review', 1.2]],\n157:   'documented consistently': [['sk-code-review', 1]],\n158:   'scoped correctly': [['sk-code-review', 1]],\n159:   'iteration is scoped': [['sk-code-review', 1]],\n160:   'classifier vocabulary': [['sk-code-review', 0.9]],\n\n(Showing lines 1-160 of 332. Use offset=161 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Explicit Author Lane\n// ───────────────────────────────────────────────────────────────\n\nimport type { AdvisorProjection, LaneMatch } from '../types.js';\nimport { matchesPhraseBoundary, phraseSpecificity, skillNameVariants, tokenize } from '../text.js';\n\nconst TOKEN_BOOSTS: Readonly<Record<string, readonly [string, number][]>> = {\n  audit: [['sk-code-review', 0.75]],\n  branch: [['sk-git', 0.45]],\n  browser: [['sk-code', 0.55]],\n  checklist: [['system-spec-kit', 0.55]],\n  chrome: [['mcp-chrome-devtools', 0.95]],\n  codex: [['cli-codex', 0.9]],\n  commit: [['sk-git', 0.65]],\n  commonjs: [['sk-code', 0.75]],\n  context: [['system-spec-kit', 0.65]],\n  corpus: [['system-spec-kit', 0.45]],\n  council: [['deep-ai-council', 0.9]],\n  css: [['sk-code', 0.55]],","truncated":true,"loaded":[]},"title":".opencode/skills/system-skill-advisor/mcp_server/lib/scorer/lanes/explicit.ts","time":{"start":1780130226414,"end":1780130226427}},"id":"prt_e78079dcc001RihS3oOlcQmHCz","sessionID":"ses_187f8dff3ffekWTw11vPJPQhfy","messageID":"msg_e780779f70013upD9zmy5zbABs"}}
{"type":"tool_use","timestamp":1780130227300,"sessionID":"ses_187f8dff3ffekWTw11vPJPQhfy","part":{"type":"tool","tool":"read","callID":"call_03_DIjEzqYclKiidEUwkYfQ1619","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-prompt-models/SKILL.md","limit":230},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/sk-prompt-models/SKILL.md</path>\n<type>file</type>\n<content>\n1: ---\n2: name: sk-prompt-models\n3: description: Sentinel for small-model optimization patterns covering SWE-1.6 + DeepSeek-v4-pro + Kimi-k2.6 + Qwen3.6 + GLM-5.1 + MiniMax-2.7 across cli-devin and cli-opencode (DeepSeek API + opencode-go + MiniMax.io direct API providers) dispatch paths. Routing anchor only; real patterns live in cli-devin/references/ and cli-opencode/references/.\n4: allowed-tools: []\n5: version: 0.1.0\n6: ---\n7: \n8: <!-- Keywords: small-model, swe-1.6, deepseek-v4, kimi-k2.6, qwen3.6, glm-5.1, minimax-2.7, minimax-api, haiku, gemini-flash, opencode-go, deepseek-api, context-budget, output-verification, model-profiles, structured-permissions, quota-fallback -->\n9: \n10: # Small-Model Optimization Sentinel\n11: \n12: A discovery anchor that surfaces alongside `cli-devin` or `cli-opencode` whenever a small-model task is dispatched, then points operators at the executor-owned patterns.\n13: \n14: ---\n15: \n16: ## 1. WHEN TO USE\n17: \n18: ### Activation Triggers\n19: \n20: **Use when**:\n21: - Dispatching to SWE-1.6 (Cognition free tier) via `cli-devin`\n22: - Dispatching to DeepSeek-v4-pro, Kimi-k2.6, or GLM-5.1 (Cognition Pro plan) via `cli-devin`\n23: - Dispatching to DeepSeek-v4-pro directly via `cli-opencode` + DeepSeek API provider (`DEEPSEEK_API_KEY`, `--pure` required)\n24: - Dispatching to DeepSeek-v4-pro, Kimi-k2.6, Qwen3.6, or GLM-5.1 via `cli-opencode` + opencode-go provider (workspace credit pool)\n25: - Dispatching to MiniMax-2.7 via `cli-opencode` + MiniMax.io direct API provider (`MINIMAX_API_KEY`, `--model minimax/MiniMax-M2.7`, separate `minimax-api` quota pool)\n26: - Optional future targets: Claude Haiku (Anthropic separate quota), Gemini Flash (Google separate quota)\n27: - Asking \"where is the small-model X pattern?\" — context budget, output verification, model profiles, structured permissions, quota fallback\n28: \n29: **Keyword Triggers**:\n30: - `small model`, `small-model dispatch`\n31: - Model names: `swe-1.6`, `kimi-k2.6`, `deepseek-v4`, `qwen3.6`, `glm-5.1`, `minimax-2.7`, `haiku`, `gemini flash`\n32: - Provider names: `opencode-go`, `deepseek-api`, `minimax` / `minimax-api`, `cognition pro`, `cognition free`\n33: - Pattern names: `context budget`, `output verification`, `model profile`, `structured permissions`, `quota fallback`, `tool scoring`\n34: \n35: ### Use Cases\n36: \n37: #### Routing Anchor\n38: \n39: Surface as a co-recommendation when `cli-devin` or `cli-opencode` is already the primary skill. The advisor reaches this skill through `enhances` edges from both CLI skills, providing one obvious entry point regardless of which executor is in use.\n40: \n41: #### Pattern Discovery\n42: \n43: Operators read `references/pattern-index.md` to find the canonical location of each small-model pattern. The index lists ownership (which CLI skill owns the pattern) and shipping status per phase.\n44: \n45: ### When NOT to Use\n46: \n47: **Do not use for**:\n48: - Frontier-model dispatch (Opus, Sonnet, gpt-5.5) — those are out of scope for the 114 arc\n49: - Bulk copying of pattern bodies into other skills — the patterns are runtime-specific to their executor\n50: - Adding new runtime logic — this sentinel is documentation routing only\n51: \n52: ---\n53: \n54: ## 2. SMART ROUTING\n55: \n56: ### Primary Detection Signal\n57: \n58: Discovery happens through skill-advisor `enhances` edges + trigger phrases, not a dedicated detection script.\n59: \n60: ```text\n61: Operator prompt mentions small-model name or pattern\n62:     |\n63:     +-- Advisor matches trigger phrases (lexical lane)\n64:     +-- cli-devin or cli-opencode already high-confidence\n65:     +-- enhances edge pulls sk-prompt-models into top-3\n66: ```\n67: \n68: ### Phase Detection\n69: \n70: ```text\n71: TASK CONTEXT\n72:     |\n73:     +- STEP 0: Identify whether a small-model executor is involved\n74:     +- STEP 1: Surface sk-prompt-models alongside the executor skill\n75:     +- Phase 1: Read references/pattern-index.md\n76:     +- Phase 2: Navigate to the executor-owned pattern file\n77:     +- Phase 3: Apply the pattern from its canonical location\n78: ```\n79: \n80: ### Resource Domains\n81: \n82: ```text\n83: references/\n84:     pattern-index.md      # The only reference; lists owners + ship status\n85: ```\n86: \n87: This skill intentionally has no `assets/` and no `scripts/`. The patterns themselves live in:\n88: \n89: - `.opencode/skills/cli-devin/references/` and `assets/`\n90: - `.opencode/skills/cli-opencode/references/` and `assets/`\n91: - `.opencode/skills/sk-prompt/assets/` (model-profiles registry)\n92: - `.opencode/skills/system-spec-kit/mcp_server/lib/deep-loop/` (runtime helpers)\n93: \n94: ### Resource Loading Levels\n95: \n96: | Level       | When to Load             | Resources                     |\n97: | ----------- | ------------------------ | ----------------------------- |\n98: | ALWAYS      | Every skill invocation   | `references/pattern-index.md` |\n99: | CONDITIONAL | Operator names a pattern | Follow link from index to executor-owned file |\n100: | ON_DEMAND   | Adopting Haiku/Flash     | Update the index + executor metadata (see README) |\n101: \n102: ### Smart Router Pseudocode\n103: \n104: The sentinel has no runtime routing of its own. Routing is performed by the skill-advisor through `graph-metadata.json` edges:\n105: \n106: ```python\n107: # Conceptual — the actual scorer lives in system-skill-advisor\n108: def surface_sk_prompt_small_model(prompt, advisor):\n109:     if matches_trigger(prompt, SMALL_MODEL_TRIGGERS):\n110:         # Lexical lane match\n111:         return (\"sk-prompt-models\", advisor.lexical_score(prompt))\n112:     if \"cli-devin\" in advisor.top_k(prompt, k=3) or \"cli-opencode\" in advisor.top_k(prompt, k=3):\n113:         # Graph_causal lane via enhances edge (weight 0.5)\n114:         return (\"sk-prompt-models\", 0.5 * advisor.enhances_weight)\n115:     return None\n116: ```\n117: \n118: Operators do not invoke a router from inside this skill. They follow `references/pattern-index.md` to the executor-owned file.\n119: \n120: ---\n121: \n122: ## 3. HOW IT WORKS\n123: \n124: ### Sentinel Workflow\n125: \n126: 1. **Discovery** — Operator mentions a small-model name or pattern; the advisor surfaces `sk-prompt-models` alongside the relevant CLI skill.\n127: 2. **Index lookup** — Operator reads `references/pattern-index.md` to find the pattern's canonical location and ship status.\n128: 3. **Navigate to owner** — Operator opens the linked executor file (e.g. `cli-devin/references/context-budget.md`) for the actual pattern body.\n129: 4. **Apply pattern** — Pattern is applied within the executor's prompt-pack or recipe, not from this sentinel.\n130: \n131: ### Dispatch Matrix\n132: \n133: | Model | Executor → Provider (quota pool) | Status |\n134: | --- | --- | --- |\n135: | SWE-1.6 | `cli-devin` → cognition (cognition-free) | active |\n136: | DeepSeek-v4-pro | `cli-devin` → cognition (cognition-pro) · `cli-opencode` → deepseek-api (deepseek-api) · `cli-opencode` → opencode-go (opencode-go) | active (3 paths) |\n137: | Kimi-k2.6 | `cli-devin` → cognition (cognition-pro) · `cli-opencode` → opencode-go (opencode-go) | active (2 paths) |\n138: | Qwen3.6 | `cli-opencode` → opencode-go (opencode-go) | active (single path) |\n139: | GLM-5.1 | `cli-devin` → cognition (cognition-pro) · `cli-opencode` → opencode-go (opencode-go) | active (2 paths) |\n140: | MiniMax-M2.7 | `cli-opencode` → minimax (minimax-api) | active (single path; direct MiniMax.io API) |\n141: | Haiku | `cli-claude-code` → anthropic (anthropic) | optional-unverified |\n142: | Gemini Flash | `cli-gemini` → google (google) | optional-unverified |\n143: \n144: Canonical source: `sk-prompt/assets/model-profiles.json` (each entry's `executors` array enumerates the paths above).\n145: \n146: ### Ownership Boundary\n147: \n148: | Executor | Owns (Phases 002-006) |\n149: | --- | --- |\n150: | `cli-devin` | SWE-1.6 + Cognition-Pro models (DeepSeek/Kimi/GLM via Devin) — budget defaults, output verification, confidence-scoring rubric, per-model-budgets.json, quota-fallback reference |\n151: | `cli-opencode` | DeepSeek API direct path + opencode-go pool (DeepSeek/Kimi/Qwen/GLM) — budget propagation mirror, permissions matrix schema, structured permissions reference |\n152: | `sk-prompt` | Model-profile registry (`model-profiles.json`) with per-model `executors` array, cross-CLI budget awareness card |\n153: | `system-spec-kit` | Runtime helpers (`bayesian-scorer.ts`, `fallback-router.ts`, `permissions-gate.ts`) |\n154: \n155: ### Adopting a New Provider (Haiku, Gemini Flash, others)\n156: \n157: Metadata-first adoption keeps the sentinel thin:\n158: \n159: 1. Populate the stub in `sk-prompt/assets/model-profiles.json` (set `quota_pool`, `context_length`, etc.).\n160: 2. Optionally set `fallback_target` on existing models that should escalate to the new provider.\n161: 3. Add trigger phrases for the new provider in this skill's `graph-metadata.json` if it has a distinct dispatch shape.\n162: 4. Mark the relevant rows in `references/pattern-index.md` as shipped.\n163: 5. Re-index the advisor (`skill_advisor.py --force-refresh`).\n164: \n165: No code edits are required to adopt a new small-model provider when its quota pool is already represented.\n166: \n167: ---\n168: \n169: ## 4. RULES\n170: \n171: ### ALWAYS\n172: \n173: 1. **Stay thin.** SKILL.md ≤ 200 LOC; pattern-index.md ≤ 100 LOC. If content grows, it belongs in the owning executor skill, not here.\n174: 2. **Link to canonical patterns** — every reference in this skill MUST point at an executor-owned file, never duplicate the pattern body.\n175: 3. **Keep trigger phrases honest.** Add a phrase only when a new model or pattern actually exists. Stale triggers degrade advisor confidence.\n176: 4. **Update the index when downstream phases ship or move files.** The pattern-index is a contract; broken links erode trust.\n177: 5. **Honor the in-scope model set** — SWE-1.6, DeepSeek-v4-pro, Kimi-k2.6, Qwen3.6, GLM-5.1 required; Haiku, Gemini Flash optional. Frontier models (Opus, Sonnet, gpt-5.5) are explicitly out of scope.\n178: \n179: ### NEVER\n180: \n181: 1. **Never add runtime logic here** — no shell commands, no scripts, no agent-config recipes.\n182: 2. **Never duplicate executor patterns** — if a new pattern emerges, ship it in the executor that runs it; only update the index here.\n183: 3. **Never escalate small→frontier** — the user's rotation is small-only. The quota-fallback engine (Phase 005) is pool-aware, not tier-based.\n184: 4. **Never silently drop a stale pattern row.** If a downstream phase deletes a pattern, update the index row to \"deprecated\" with a one-line reason.\n185: \n186: ### ESCALATE IF\n187: \n188: 1. A pattern needs to live in TWO executors (e.g. budget engine in both cli-devin and cli-opencode). Today this is handled via sentinel-style mirror docs (Phase 006). If a true duplicate logic surface emerges, escalate to refactor into a shared asset.\n189: 2. Trigger phrases pull this skill into non-small-model prompts above the 0.5 threshold. Tune weights in `graph-metadata.json` and re-index.\n190: 3. A new small-model provider arrives that does not fit the existing quota-pool model. Update the registry schema in `sk-prompt/assets/model-profiles.json` first, then propagate.\n191: \n192: ---\n193: \n194: ## 5. REFERENCES\n195: \n196: ### Core References\n197: \n198: - [`references/pattern-index.md`](./references/pattern-index.md) — Authoritative index of small-model patterns + owners + ship status\n199: \n200: ### Related Resources (executor-owned patterns)\n201: \n202: - [`cli-devin/references/context-budget.md`](../cli-devin/references/context-budget.md) — Canonical budget engine doc (Phase 004)\n203: - [`cli-devin/references/output-verification.md`](../cli-devin/references/output-verification.md) — Verification pipeline + scoring rubric pointers (Phase 004)\n204: - [`cli-devin/references/quota-fallback.md`](../cli-devin/references/quota-fallback.md) — Pool-aware fallback decision matrix (Phase 005)\n205: - [`cli-devin/assets/per-model-budgets.json`](../cli-devin/assets/per-model-budgets.json) — Per-model token budget defaults\n206: - [`cli-devin/assets/confidence-scoring-rubric.md`](../cli-devin/assets/confidence-scoring-rubric.md) — Verification confidence formula\n207: - [`cli-opencode/references/context-budget.md`](../cli-opencode/references/context-budget.md) — cli-opencode budget mirror (Phase 006)\n208: - [`cli-opencode/references/permissions-matrix.md`](../cli-opencode/references/permissions-matrix.md) — Structured permissions schema (Phase 003)\n209: - [`cli-opencode/assets/permissions-matrix.schema.json`](../cli-opencode/assets/permissions-matrix.schema.json) — JSON Schema for permission rules\n210: - [`sk-prompt/assets/model-profiles.json`](../sk-prompt/assets/model-profiles.json) — Unified model registry (Phase 005)\n211: - [`sk-prompt/references/model-profiles.md`](../sk-prompt/references/model-profiles.md) — Registry schema + adoption protocol\n212: - [`sk-prompt/assets/cli_prompt_quality_card.md`](../sk-prompt/assets/cli_prompt_quality_card.md) — Cross-CLI quality card with Budget Awareness subsection (Phase 006)\n213: \n214: ### Reference Loading Notes\n215: \n216: - Load `references/pattern-index.md` on every invocation; it is small and authoritative.\n217: - Do NOT load executor-owned references through this skill — follow the index link and let the operator's existing skill context handle loading.\n218: - The `enhances` edges in `graph-metadata.json` co-surface `cli-devin` and `cli-opencode` automatically; their references load through their own routing.\n219: \n220: ### Skill Boundary Map\n221: \n222: ```text\n223: sk-prompt-models (this skill)         ← discovery + index only\n224:     |\n225:     +-- cli-devin                   ← owns SWE-1.6 budget + verification + fallback patterns\n226:     +-- cli-opencode                ← owns DeepSeek/Kimi/Qwen propagation + permissions\n227:     +-- sk-prompt                   ← owns model registry + cross-CLI quality card\n228:     +-- system-spec-kit             ← owns runtime helpers (TS code)\n229: ```\n\n(End of file - total 229 lines)\n</content>","metadata":{"preview":"---\nname: sk-prompt-models\ndescription: Sentinel for small-model optimization patterns covering SWE-1.6 + DeepSeek-v4-pro + Kimi-k2.6 + Qwen3.6 + GLM-5.1 + MiniMax-2.7 across cli-devin and cli-opencode (DeepSeek API + opencode-go + MiniMax.io direct API providers) dispatch paths. Routing anchor only; real patterns live in cli-devin/references/ and cli-opencode/references/.\nallowed-tools: []\nversion: 0.1.0\n---\n\n<!-- Keywords: small-model, swe-1.6, deepseek-v4, kimi-k2.6, qwen3.6, glm-5.1, minimax-2.7, minimax-api, haiku, gemini-flash, opencode-go, deepseek-api, context-budget, output-verification, model-profiles, structured-permissions, quota-fallback -->\n\n# Small-Model Optimization Sentinel\n\nA discovery anchor that surfaces alongside `cli-devin` or `cli-opencode` whenever a small-model task is dispatched, then points operators at the executor-owned patterns.\n\n---\n\n## 1. WHEN TO USE\n\n### Activation Triggers\n\n**Use when**:","truncated":false,"loaded":[]},"title":".opencode/skills/sk-prompt-models/SKILL.md","time":{"start":1780130227293,"end":1780130227299}},"id":"prt_e7807a152001TIiORV2uD87AcR","sessionID":"ses_187f8dff3ffekWTw11vPJPQhfy","messageID":"msg_e780779f70013upD9zmy5zbABs"}}
