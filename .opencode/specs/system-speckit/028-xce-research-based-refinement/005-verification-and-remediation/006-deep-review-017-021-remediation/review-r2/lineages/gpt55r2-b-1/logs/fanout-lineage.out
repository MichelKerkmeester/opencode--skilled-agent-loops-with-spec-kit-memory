──────────────────────────\n38:    3. HELPERS\n39: ──────────────────────────────────────────────────────────────── */\n40: \n41: function progressPercent(job: MaintenanceJob): number {\n42:   if (job.progressTotal <= 0) return 0;\n43:   const raw = Math.round((job.progressProcessed / job.progressTotal) * 100);\n44:   return Math.max(0, Math.min(100, raw));\n45: }\n46: \n47: function mapScanJobForResponse(job: MaintenanceJob): Record<string, unknown> {\n48:   return {\n49:     jobId: job.id,\n50:     kind: job.kind,\n51:     state: job.state,\n52:     phase: job.phase,\n53:     progress: { processed: job.progressProcessed, total: job.progressTotal },\n54:     progressPercent: progressPercent(job),\n55:     cancelRequested: job.cancelRequested,\n56:     errors: job.errors,\n57:     result: job.result,\n58:     createdAt: job.createdAt,\n59:     updatedAt: job.updatedAt,\n60:   };\n61: }\n62: \n63: // Scan job tools own only index_scan jobs; an ingest jobId is not addressable here.\n64: function getScanJob(jobId: string): MaintenanceJob | null {\n65:   const job = getMaintenanceJob(jobId);\n66:   if (!job || job.kind !== 'index_scan') return null;\n67:   return job;\n68: }\n69: \n70: /* ───────────────────────────────────────────────────────────────\n71:    4. HANDLERS\n72: ──────────────────────────────────────────────────────────────── */\n73: \n74: async function handleMemoryIndexScanStatus(args: MemoryIndexScanStatusArgs): Promise<MCPResponse> {\n75:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan_status');\n76:   await checkDatabaseUpdated();\n77: \n78:   if (!args.jobId || typeof args.jobId !== 'string') {\n79:     throw new Error('jobId is required and must be a string');\n80:   }\n81: \n82:   const job = getScanJob(args.jobId);\n83:   if (!job) {\n84:     return createMCPErrorResponse({\n85:       tool: 'memory_index_scan_status',\n86:       error: `Index scan job not found: ${args.jobId}`,\n87:       code: 'E404',\n88:       details: { jobId: args.jobId },\n89:       recovery: {\n90:         hint: 'Verify the jobId and retry.',\n91:         actions: ['Call memory_index_scan with background:true to create a new background scan job'],\n92:         severity: 'warning',\n93:       },\n94:     });\n95:   }\n96: \n97:   return createMCPSuccessResponse({\n98:     tool: 'memory_index_scan_status',\n99:     summary: `Index scan job ${job.id}: ${job.state}${job.phase ? ` (${job.phase})` : ''}`,\n100:     data: mapScanJobForResponse(job),\n101:   });\n102: }\n103: \n104: async function handleMemoryIndexScanCancel(args: MemoryIndexScanCancelArgs): Promise<MCPResponse> {\n105:   await ensureMemoryRuntimeInitialized('handler:memory_index_scan_cancel');\n106:   await checkDatabaseUpdated();\n107: \n108:   if (!args.jobId || typeof args.jobId !== 'string') {\n109:     throw new Error('jobId is required and must be a string');\n110:   }\n111: \n112:   const job = getScanJob(args.jobId);\n113:   if (!job) {\n114:     return createMCPErrorResponse({\n115:       tool: 'memory_index_scan_cancel',\n116:       error: `Index scan job not found: ${args.jobId}`,\n117:       code: 'E404',\n118:       details: { jobId: args.jobId },\n119:       recovery: {\n120:         hint: 'Verify the jobId and retry.',\n121:         actions: ['Call memory_index_scan_status with a known jobId'],\n122:         severity: 'warning',\n123:       },\n124:     });\n125:   }\n126: \n127:   if (isTerminalJobState(job.state)) {\n128:     return createMCPSuccessResponse({\n129:       tool: 'memory_index_scan_cancel',\n130:       summary: `Index scan job ${job.id} is already terminal (${job.state})`,\n131:       data: mapScanJobForResponse(job),\n132:     });\n133:   }\n134: \n135:   await requestCancel(args.jobId);\n136:   const updated = getScanJob(args.jobId) ?? job;\n137: \n138:   return createMCPSuccessResponse({\n139:     tool: 'memory_index_scan_cancel',\n140:     summary: `Cancellation requested for index scan job ${updated.id}`,\n141:     data: mapScanJobForResponse(updated),\n142:   });\n143: }\n144: \n145: /* ───────────────────────────────────────────────────────────────\n146:    5. EXPORTS\n147: ──────────────────────────────────────────────────────────────── */\n148: \n149: const handle_memory_index_scan_status = handleMemoryIndexScanStatus;\n150: const handle_memory_index_scan_cancel = handleMemoryIndexScanCancel;\n151: \n152: export {\n153:   handleMemoryIndexScanStatus,\n154:   handleMemoryIndexScanCancel,\n155:   mapScanJobForResponse,\n156:   handle_memory_index_scan_status,\n157:   handle_memory_index_scan_cancel,\n158: };\n\n(End of file - total 158 lines)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index Scan Job Handlers\n// ───────────────────────────────────────────────────────────────\n// Status/cancel surface for background memory_index_scan jobs backed\n// by the kind-agnostic maintenance job store.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  getMaintenanceJob,\n  requestCancel,\n  isTerminalJobState,\n  type MaintenanceJob,\n} from '../lib/ops/job-store.js';\n","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Memory Index Scan Job Handlers\n// ───────────────────────────────────────────────────────────────\n// Status/cancel surface for background memory_index_scan jobs backed\n// by the kind-agnostic maintenance job store.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { checkDatabaseUpdated } from '../core/index.js';\nimport { createMCPSuccessResponse, createMCPErrorResponse } from '../lib/response/envelope.js';\nimport { ensureMemoryRuntimeInitialized } from '../lib/runtime/memory-runtime-guard.js';\nimport {\n  getMaintenanceJob,\n  requestCancel,\n  isTerminalJobState,\n  type MaintenanceJob,\n} from '../lib/ops/job-store.js';\n\nimport type { MCPResponse } from './types.js';\n\n// Feature catalog: Workspace scanning and indexing (memory_index_scan)\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\ninterface MemoryIndexScanStatusArgs {\n  jobId: string;\n}\n\ninterface MemoryIndexScanCancelArgs {\n  jobId: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction progressPercent(job: MaintenanceJob): number {\n  if (job.progressTotal <= 0) return 0;\n  const raw = Math.round((job.progressProcessed / job.progressTotal) * 100);\n  return Math.max(0, Math.min(100, raw));\n}\n\nfunction mapScanJobForResponse(job: MaintenanceJob): Record<string, unknown> {\n  return {\n    jobId: job.id,\n    kind: job.kind,\n    state: job.state,\n    phase: job.phase,\n    progress: { processed: job.progressProcessed, total: job.progressTotal },\n    progressPercent: progressPercent(job),\n    cancelRequested: job.cancelRequested,\n    errors: job.errors,\n    result: job.result,\n    createdAt: job.createdAt,\n    updatedAt: job.updatedAt,\n  };\n}\n\n// Scan job tools own only index_scan jobs; an ingest jobId is not addressable here.\nfunction getScanJob(jobId: string): MaintenanceJob | null {\n  const job = getMaintenanceJob(jobId);\n  if (!job || job.kind !== 'index_scan') return null;\n  return job;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. HANDLERS\n──────────────────────────────────────────────────────────────── */\n\nasync function handleMemoryIndexScanStatus(args: MemoryIndexScanStatusArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan_status');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getScanJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan_status',\n      error: `Index scan job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_index_scan with background:true to create a new background scan job'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan_status',\n    summary: `Index scan job ${job.id}: ${job.state}${job.phase ? ` (${job.phase})` : ''}`,\n    data: mapScanJobForResponse(job),\n  });\n}\n\nasync function handleMemoryIndexScanCancel(args: MemoryIndexScanCancelArgs): Promise<MCPResponse> {\n  await ensureMemoryRuntimeInitialized('handler:memory_index_scan_cancel');\n  await checkDatabaseUpdated();\n\n  if (!args.jobId || typeof args.jobId !== 'string') {\n    throw new Error('jobId is required and must be a string');\n  }\n\n  const job = getScanJob(args.jobId);\n  if (!job) {\n    return createMCPErrorResponse({\n      tool: 'memory_index_scan_cancel',\n      error: `Index scan job not found: ${args.jobId}`,\n      code: 'E404',\n      details: { jobId: args.jobId },\n      recovery: {\n        hint: 'Verify the jobId and retry.',\n        actions: ['Call memory_index_scan_status with a known jobId'],\n        severity: 'warning',\n      },\n    });\n  }\n\n  if (isTerminalJobState(job.state)) {\n    return createMCPSuccessResponse({\n      tool: 'memory_index_scan_cancel',\n      summary: `Index scan job ${job.id} is already terminal (${job.state})`,\n      data: mapScanJobForResponse(job),\n    });\n  }\n\n  await requestCancel(args.jobId);\n  const updated = getScanJob(args.jobId) ?? job;\n\n  return createMCPSuccessResponse({\n    tool: 'memory_index_scan_cancel',\n    summary: `Cancellation requested for index scan job ${updated.id}`,\n    data: mapScanJobForResponse(updated),\n  });\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. EXPORTS\n──────────────────────────────────────────────────────────────── */\n\nconst handle_memory_index_scan_status = handleMemoryIndexScanStatus;\nconst handle_memory_index_scan_cancel = handleMemoryIndexScanCancel;\n\nexport {\n  handleMemoryIndexScanStatus,\n  handleMemoryIndexScanCancel,\n  mapScanJobForResponse,\n  handle_memory_index_scan_status,\n  handle_memory_index_scan_cancel,\n};","lineStart":1,"lineEnd":158,"totalLines":158,"truncated":false}},"title":".opencode/skills/system-spec-kit/mcp_server/handlers/memory-index-scan-jobs.ts","time":{"start":1781761428849,"end":1781761428852}},"metadata":{"openai":{"itemId":"fc_09c70f36efb4e23b016a338594c5ac8191a7892d2d544c605b"}},"id":"prt_ed941cd65001Qr3o0mrA7U4xmT","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed94199a2001YZezig6klT1ZuA"}}
{"type":"tool_use","timestamp":1781761428893,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_DpHqnyHWkgRvqRnLEfD3DoBf","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Maintenance Job Store\n3: // ───────────────────────────────────────────────────────────────\n4: // Kind-agnostic persisted job lifecycle: jobId, state record, progress\n5: // counters, error capture+truncation, cancel flag, and crash-recovery\n6: // reset. Shared lifecycle/registry across long-running maintenance jobs.\n7: \n8: /* ───────────────────────────────────────────────────────────────\n9:    1. IMPORTS\n10: ──────────────────────────────────────────────────────────────── */\n11: \n12: import { randomBytes } from 'node:crypto';\n13: \n14: import { requireDb, toErrorMessage } from '../../utils/index.js';\n15: import { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n16: \n17: /* ───────────────────────────────────────────────────────────────\n18:    2. TYPES\n19: ──────────────────────────────────────────────────────────────── */\n20: \n21: export type MaintenanceJobKind = 'ingest' | 'index_scan';\n22: \n23: export type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n24: \n25: export interface JobError {\n26:   source: string;\n27:   message: string;\n28:   timestamp: string;\n29: }\n30: \n31: export interface MaintenanceJob {\n32:   id: string;\n33:   kind: MaintenanceJobKind;\n34:   state: JobLifecycleState;\n35:   phase: string | null;\n36:   progressTotal: number;\n37:   progressProcessed: number;\n38:   cancelRequested: boolean;\n39:   errors: JobError[];\n40:   result: unknown | null;\n41:   payload: unknown | null;\n42:   createdAt: string;\n43:   updatedAt: string;\n44: }\n45: \n46: interface MaintenanceJobRow {\n47:   id: string;\n48:   kind: string;\n49:   state: string;\n50:   phase: string | null;\n51:   progress_total: number;\n52:   progress_processed: number;\n53:   cancel_requested: number;\n54:   errors_json: string;\n55:   result_json: string | null;\n56:   payload_json: string | null;\n57:   created_at: string;\n58:   updated_at: string;\n59: }\n60: \n61: /* ───────────────────────────────────────────────────────────────\n62:    3. CONSTANTS\n63: ──────────────────────────────────────────────────────────────── */\n64: \n65: export const MAX_STORED_ERRORS = 50;\n66: \n67: const TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n68: \n69: // In-process mirror of cancel_requested. A running job polls this from a hot loop\n70: // to decide whether to stop, avoiding a DB SELECT on the single shared connection\n71: // every check. The cancel request runs in this same process, so the Set is\n72: // authoritative for an in-flight run; the durable column still backs status\n73: // responses and crash recovery. Entries are cleared when a job reaches a terminal\n74: // state so the Set cannot grow without bound across many jobs.\n75: const cancelledJobIds = new Set<string>();\n76: \n77: const ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n78:   queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n79:   running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n80:   complete: new Set<JobLifecycleState>([]),\n81:   failed: new Set<JobLifecycleState>([]),\n82:   cancelled: new Set<JobLifecycleState>([]),\n83: };\n84: \n85: // URL-safe 12-char identifier without a UUID dependency.\n86: const NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n87: \n88: /* ───────────────────────────────────────────────────────────────\n89:    4. HELPERS\n90: ──────────────────────────────────────────────────────────────── */\n91: \n92: function nowIso(): string {\n93:   return new Date().toISOString();\n94: }\n95: \n96: function isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n97:   return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n98: }\n99: \n100: function parseJson<T>(value: string | null | undefined, fallback: T): T {\n101:   if (value === null || value === undefined) return fallback;\n102:   try {\n103:     return JSON.parse(value) as T;\n104:   } catch (_error: unknown) {\n105:     return fallback;\n106:   }\n107: }\n108: \n109: function parseJobErrors(value: string | null | undefined): JobError[] {\n110:   const parsed = parseJson<unknown>(value, []);\n111:   return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n112: }\n113: \n114: function mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n115:   if (!row) return null;\n116:   return {\n117:     id: row.id,\n118:     kind: row.kind as MaintenanceJobKind,\n119:     state: row.state as JobLifecycleState,\n120:     phase: row.phase,\n121:     progressTotal: row.progress_total,\n122:     progressProcessed: row.progress_processed,\n123:     cancelRequested: row.cancel_requested === 1,\n124:     errors: parseJobErrors(row.errors_json),\n125:     result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n126:     payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n127:     createdAt: row.created_at,\n128:     updatedAt: row.updated_at,\n129:   };\n130: }\n131: \n132: const SELECT_COLUMNS =\n133:   'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n134: \n135: /* ───────────────────────────────────────────────────────────────\n136:    5. SCHEMA\n137: ──────────────────────────────────────────────────────────────── */\n138: \n139: export function ensureMaintenanceJobsTable(): void {\n140:   const db = requireDb();\n141:   db.exec(`\n142:     CREATE TABLE IF NOT EXISTS maintenance_jobs (\n143:       id TEXT PRIMARY KEY,\n144:       kind TEXT NOT NULL,\n145:       state TEXT NOT NULL,\n146:       phase TEXT,\n147:       progress_total INTEGER NOT NULL DEFAULT 0,\n148:       progress_processed INTEGER NOT NULL DEFAULT 0,\n149:       cancel_requested INTEGER NOT NULL DEFAULT 0,\n150:       errors_json TEXT NOT NULL DEFAULT '[]',\n151:       result_json TEXT,\n152:       payload_json TEXT,\n153:       created_at TEXT NOT NULL,\n154:       updated_at TEXT NOT NULL\n155:     )\n156:   `);\n157:   db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n158: }\n159: \n160: /* ───────────────────────────────────────────────────────────────\n161:    6. IDENTIFIERS\n162: ──────────────────────────────────────────────────────────────── */\n163: \n164: export function createJobId(): string {\n165:   const bytes = randomBytes(12);\n166:   let id = '';\n167:   for (let i = 0; i < 12; i++) {\n168:     id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n169:   }\n170:   return `job_${id}`;\n171: }\n172: \n173: /* ───────────────────────────────────────────────────────────────\n174:    7. LIFECYCLE\n175: ──────────────────────────────────────────────────────────────── */\n176: \n177: export async function createMaintenanceJob(args: {\n178:   id: string;\n179:   kind: MaintenanceJobKind;\n180:   payload?: unknown;\n181: }): Promise<MaintenanceJob> {\n182:   const db = requireDb();\n183:   const timestamp = nowIso();\n184:   const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n185: \n186:   await withBusyRetry(() =>\n187:     db.prepare(`\n188:       INSERT INTO maintenance_jobs (\n189:         id, kind, state, phase, progress_total, progress_processed,\n190:         cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n191:       ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n192:     `).run(\n193:       args.id,\n194:       args.kind,\n195:       'queued',\n196:       null,\n197:       0,\n198:       0,\n199:       0,\n200:       '[]',\n201:       null,\n202:       payloadJson,\n203:       timestamp,\n204:       timestamp,\n205:     )\n206:   );\n207: \n208:   return {\n209:     id: args.id,\n210:     kind: args.kind,\n211:     state: 'queued',\n212:     phase: null,\n213:     progressTotal: 0,\n214:     progressProcessed: 0,\n215:     cancelRequested: false,\n216:     errors: [],\n217:     result: null,\n218:     payload: args.payload ?? null,\n219:     createdAt: timestamp,\n220:     updatedAt: timestamp,\n221:   };\n222: }\n223: \n224: export function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n225:   const db = requireDb();\n226:   const row = db.prepare(`\n227:     SELECT ${SELECT_COLUMNS}\n228:     FROM maintenance_jobs\n229:     WHERE id = ?\n230:   `).get(jobId) as MaintenanceJobRow | undefined;\n231:   return mapRowToJob(row);\n232: }\n233: \n234: export async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n235:   const db = requireDb();\n236:   const current = getMaintenanceJob(jobId);\n237:   if (!current) {\n238:     throw new Error(`Maintenance job not found: ${jobId}`);\n239:   }\n240: \n241:   if (current.state === nextState) {\n242:     return current;\n243:   }\n244: \n245:   if (!isTransitionAllowed(current.state, nextState)) {\n246:     throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n247:   }\n248: \n249:   const updatedAt = nowIso();\n250:   const result = await withBusyRetry(() =>\n251:     db.prepare(`\n252:       UPDATE maintenance_jobs\n253:       SET state = ?, updated_at = ?\n254:       WHERE id = ? AND state = ?\n255:     `).run(nextState, updatedAt, jobId, current.state)\n256:   );\n257: \n258:   if ((result as { changes: number }).changes === 0) {\n259:     throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n260:   }\n261: \n262:   // Every terminal transition must release the in-process cancel mirror, not just\n263:   // completeJob/resetRunningJobsForKind. A cancel-then-fail-while-running race\n264:   // routes through setJobState('failed'); without this the job-id would leak,\n265:   // contradicting the cancelledJobIds bounded-growth guarantee.\n266:   if (isTerminalJobState(nextState)) {\n267:     cancelledJobIds.delete(jobId);\n268:   }\n269: \n270:   return { ...current, state: nextState, updatedAt };\n271: }\n272: \n273: export async function setJobPhase(jobId: string, phase: string): Promise<void> {\n274:   const db = requireDb();\n275:   await withBusyRetry(() =>\n276:     db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n277:       .run(phase, nowIso(), jobId)\n278:   );\n279: }\n280: \n281: export async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n282:   const db = requireDb();\n283:   const processed = Math.max(0, Math.trunc(progress.processed));\n284:   const total = Math.max(0, Math.trunc(progress.total));\n285:   await withBusyRetry(() =>\n286:     db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n287:       .run(processed, total, nowIso(), jobId)\n288:   );\n289: }\n290: \n291: export async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n292:   const db = requireDb();\n293:   const current = getMaintenanceJob(jobId);\n294:   if (!current) {\n295:     throw new Error(`Maintenance job not found: ${jobId}`);\n296:   }\n297: \n298:   let errors: JobError[] = [\n299:     ...current.errors,\n300:     { source, message: toErrorMessage(error), timestamp: nowIso() },\n301:   ];\n302: \n303:   if (errors.length > MAX_STORED_ERRORS) {\n304:     const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n305:     const trimmedCount = errors.length - tailLength;\n306:     const truncationNotice: JobError = {\n307:       source: '__job__',\n308:       message: `error log truncated (${trimmedCount} older entries removed)`,\n309:       timestamp: nowIso(),\n310:     };\n311:     const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n312:     errors = [truncationNotice, ...truncatedTail];\n313:   }\n314: \n315:   const updatedAt = nowIso();\n316:   await withBusyRetry(() =>\n317:     db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n318:       .run(JSON.stringify(errors), updatedAt, jobId)\n319:   );\n320: \n\n(Showing lines 1-320 of 413. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance Job Store\n// ───────────────────────────────────────────────────────────────\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Maintenance Job Store\n// ───────────────────────────────────────────────────────────────\n// Kind-agnostic persisted job lifecycle: jobId, state record, progress\n// counters, error capture+truncation, cancel flag, and crash-recovery\n// reset. Shared lifecycle/registry across long-running maintenance jobs.\n\n/* ───────────────────────────────────────────────────────────────\n   1. IMPORTS\n──────────────────────────────────────────────────────────────── */\n\nimport { randomBytes } from 'node:crypto';\n\nimport { requireDb, toErrorMessage } from '../../utils/index.js';\nimport { withBusyRetry, withBusyRetrySync } from './sqlite-busy-retry.js';\n\n/* ───────────────────────────────────────────────────────────────\n   2. TYPES\n──────────────────────────────────────────────────────────────── */\n\nexport type MaintenanceJobKind = 'ingest' | 'index_scan';\n\nexport type JobLifecycleState = 'queued' | 'running' | 'complete' | 'failed' | 'cancelled';\n\nexport interface JobError {\n  source: string;\n  message: string;\n  timestamp: string;\n}\n\nexport interface MaintenanceJob {\n  id: string;\n  kind: MaintenanceJobKind;\n  state: JobLifecycleState;\n  phase: string | null;\n  progressTotal: number;\n  progressProcessed: number;\n  cancelRequested: boolean;\n  errors: JobError[];\n  result: unknown | null;\n  payload: unknown | null;\n  createdAt: string;\n  updatedAt: string;\n}\n\ninterface MaintenanceJobRow {\n  id: string;\n  kind: string;\n  state: string;\n  phase: string | null;\n  progress_total: number;\n  progress_processed: number;\n  cancel_requested: number;\n  errors_json: string;\n  result_json: string | null;\n  payload_json: string | null;\n  created_at: string;\n  updated_at: string;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. CONSTANTS\n──────────────────────────────────────────────────────────────── */\n\nexport const MAX_STORED_ERRORS = 50;\n\nconst TERMINAL_STATES = new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']);\n\n// In-process mirror of cancel_requested. A running job polls this from a hot loop\n// to decide whether to stop, avoiding a DB SELECT on the single shared connection\n// every check. The cancel request runs in this same process, so the Set is\n// authoritative for an in-flight run; the durable column still backs status\n// responses and crash recovery. Entries are cleared when a job reaches a terminal\n// state so the Set cannot grow without bound across many jobs.\nconst cancelledJobIds = new Set<string>();\n\nconst ALLOWED_TRANSITIONS: Record<JobLifecycleState, Set<JobLifecycleState>> = {\n  queued: new Set<JobLifecycleState>(['running', 'cancelled', 'failed']),\n  running: new Set<JobLifecycleState>(['complete', 'failed', 'cancelled']),\n  complete: new Set<JobLifecycleState>([]),\n  failed: new Set<JobLifecycleState>([]),\n  cancelled: new Set<JobLifecycleState>([]),\n};\n\n// URL-safe 12-char identifier without a UUID dependency.\nconst NANOID_ALPHABET = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz';\n\n/* ───────────────────────────────────────────────────────────────\n   4. HELPERS\n──────────────────────────────────────────────────────────────── */\n\nfunction nowIso(): string {\n  return new Date().toISOString();\n}\n\nfunction isTransitionAllowed(from: JobLifecycleState, to: JobLifecycleState): boolean {\n  return ALLOWED_TRANSITIONS[from]?.has(to) ?? false;\n}\n\nfunction parseJson<T>(value: string | null | undefined, fallback: T): T {\n  if (value === null || value === undefined) return fallback;\n  try {\n    return JSON.parse(value) as T;\n  } catch (_error: unknown) {\n    return fallback;\n  }\n}\n\nfunction parseJobErrors(value: string | null | undefined): JobError[] {\n  const parsed = parseJson<unknown>(value, []);\n  return Array.isArray(parsed) ? (parsed as JobError[]) : [];\n}\n\nfunction mapRowToJob(row: MaintenanceJobRow | undefined): MaintenanceJob | null {\n  if (!row) return null;\n  return {\n    id: row.id,\n    kind: row.kind as MaintenanceJobKind,\n    state: row.state as JobLifecycleState,\n    phase: row.phase,\n    progressTotal: row.progress_total,\n    progressProcessed: row.progress_processed,\n    cancelRequested: row.cancel_requested === 1,\n    errors: parseJobErrors(row.errors_json),\n    result: row.result_json === null || row.result_json === undefined ? null : parseJson<unknown>(row.result_json, null),\n    payload: row.payload_json === null || row.payload_json === undefined ? null : parseJson<unknown>(row.payload_json, null),\n    createdAt: row.created_at,\n    updatedAt: row.updated_at,\n  };\n}\n\nconst SELECT_COLUMNS =\n  'id, kind, state, phase, progress_total, progress_processed, cancel_requested, errors_json, result_json, payload_json, created_at, updated_at';\n\n/* ───────────────────────────────────────────────────────────────\n   5. SCHEMA\n──────────────────────────────────────────────────────────────── */\n\nexport function ensureMaintenanceJobsTable(): void {\n  const db = requireDb();\n  db.exec(`\n    CREATE TABLE IF NOT EXISTS maintenance_jobs (\n      id TEXT PRIMARY KEY,\n      kind TEXT NOT NULL,\n      state TEXT NOT NULL,\n      phase TEXT,\n      progress_total INTEGER NOT NULL DEFAULT 0,\n      progress_processed INTEGER NOT NULL DEFAULT 0,\n      cancel_requested INTEGER NOT NULL DEFAULT 0,\n      errors_json TEXT NOT NULL DEFAULT '[]',\n      result_json TEXT,\n      payload_json TEXT,\n      created_at TEXT NOT NULL,\n      updated_at TEXT NOT NULL\n    )\n  `);\n  db.exec(`CREATE INDEX IF NOT EXISTS idx_maintenance_jobs_kind_state ON maintenance_jobs(kind, state)`);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. IDENTIFIERS\n──────────────────────────────────────────────────────────────── */\n\nexport function createJobId(): string {\n  const bytes = randomBytes(12);\n  let id = '';\n  for (let i = 0; i < 12; i++) {\n    id += NANOID_ALPHABET[bytes[i] % NANOID_ALPHABET.length];\n  }\n  return `job_${id}`;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. LIFECYCLE\n──────────────────────────────────────────────────────────────── */\n\nexport async function createMaintenanceJob(args: {\n  id: string;\n  kind: MaintenanceJobKind;\n  payload?: unknown;\n}): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const timestamp = nowIso();\n  const payloadJson = args.payload === undefined ? null : JSON.stringify(args.payload);\n\n  await withBusyRetry(() =>\n    db.prepare(`\n      INSERT INTO maintenance_jobs (\n        id, kind, state, phase, progress_total, progress_processed,\n        cancel_requested, errors_json, result_json, payload_json, created_at, updated_at\n      ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)\n    `).run(\n      args.id,\n      args.kind,\n      'queued',\n      null,\n      0,\n      0,\n      0,\n      '[]',\n      null,\n      payloadJson,\n      timestamp,\n      timestamp,\n    )\n  );\n\n  return {\n    id: args.id,\n    kind: args.kind,\n    state: 'queued',\n    phase: null,\n    progressTotal: 0,\n    progressProcessed: 0,\n    cancelRequested: false,\n    errors: [],\n    result: null,\n    payload: args.payload ?? null,\n    createdAt: timestamp,\n    updatedAt: timestamp,\n  };\n}\n\nexport function getMaintenanceJob(jobId: string): MaintenanceJob | null {\n  const db = requireDb();\n  const row = db.prepare(`\n    SELECT ${SELECT_COLUMNS}\n    FROM maintenance_jobs\n    WHERE id = ?\n  `).get(jobId) as MaintenanceJobRow | undefined;\n  return mapRowToJob(row);\n}\n\nexport async function setJobState(jobId: string, nextState: JobLifecycleState): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  if (current.state === nextState) {\n    return current;\n  }\n\n  if (!isTransitionAllowed(current.state, nextState)) {\n    throw new Error(`Invalid maintenance job state transition: ${current.state} -> ${nextState}`);\n  }\n\n  const updatedAt = nowIso();\n  const result = await withBusyRetry(() =>\n    db.prepare(`\n      UPDATE maintenance_jobs\n      SET state = ?, updated_at = ?\n      WHERE id = ? AND state = ?\n    `).run(nextState, updatedAt, jobId, current.state)\n  );\n\n  if ((result as { changes: number }).changes === 0) {\n    throw new Error(`State transition conflict: job ${jobId} state was changed by another process (expected '${current.state}')`);\n  }\n\n  // Every terminal transition must release the in-process cancel mirror, not just\n  // completeJob/resetRunningJobsForKind. A cancel-then-fail-while-running race\n  // routes through setJobState('failed'); without this the job-id would leak,\n  // contradicting the cancelledJobIds bounded-growth guarantee.\n  if (isTerminalJobState(nextState)) {\n    cancelledJobIds.delete(jobId);\n  }\n\n  return { ...current, state: nextState, updatedAt };\n}\n\nexport async function setJobPhase(jobId: string, phase: string): Promise<void> {\n  const db = requireDb();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET phase = ?, updated_at = ? WHERE id = ?`)\n      .run(phase, nowIso(), jobId)\n  );\n}\n\nexport async function setJobProgress(jobId: string, progress: { processed: number; total: number }): Promise<void> {\n  const db = requireDb();\n  const processed = Math.max(0, Math.trunc(progress.processed));\n  const total = Math.max(0, Math.trunc(progress.total));\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET progress_processed = ?, progress_total = ?, updated_at = ? WHERE id = ?`)\n      .run(processed, total, nowIso(), jobId)\n  );\n}\n\nexport async function appendJobError(jobId: string, source: string, error: unknown): Promise<MaintenanceJob> {\n  const db = requireDb();\n  const current = getMaintenanceJob(jobId);\n  if (!current) {\n    throw new Error(`Maintenance job not found: ${jobId}`);\n  }\n\n  let errors: JobError[] = [\n    ...current.errors,\n    { source, message: toErrorMessage(error), timestamp: nowIso() },\n  ];\n\n  if (errors.length > MAX_STORED_ERRORS) {\n    const tailLength = Math.max(0, MAX_STORED_ERRORS - 1);\n    const trimmedCount = errors.length - tailLength;\n    const truncationNotice: JobError = {\n      source: '__job__',\n      message: `error log truncated (${trimmedCount} older entries removed)`,\n      timestamp: nowIso(),\n    };\n    const truncatedTail = tailLength > 0 ? errors.slice(-tailLength) : [];\n    errors = [truncationNotice, ...truncatedTail];\n  }\n\n  const updatedAt = nowIso();\n  await withBusyRetry(() =>\n    db.prepare(`UPDATE maintenance_jobs SET errors_json = ?, updated_at = ? WHERE id = ?`)\n      .run(JSON.stringify(errors), updatedAt, jobId)\n  );\n","lineStart":1,"lineEnd":320,"totalLines":413,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/ops/job-store.ts","time":{"start":1781761428890,"end":1781761428892}},"metadata":{"openai":{"itemId":"fc_09c70f36efb4e23b016a338594c5b48191973630187740abf4"}},"id":"prt_ed941cd71001hZ1U4Tb7zHi0JE","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed94199a2001YZezig6klT1ZuA"}}
{"type":"tool_use","timestamp":1781761428904,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_8b3u4UnlqQgJGGEM1Wh4CMot","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Transaction Manager\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Transaction wrappers on mutation handlers\n5: // Atomic file + index operations with pending file recovery\n6: import type Database from 'better-sqlite3';\n7: import * as fs from 'fs';\n8: import * as path from 'path';\n9: import { resolveDatabasePaths } from '../../core/config.js';\n10: \n11: /* ───────────────────────────────────────────────────────────────\n12:    1. CONSTANTS\n13: ----------------------------------------------------------------*/\n14: \n15: const PENDING_SUFFIX = '_pending';\n16: const TEMP_SUFFIX = '.tmp';\n17: const PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n18: \n19: /* ───────────────────────────────────────────────────────────────\n20:    2. INTERFACES\n21: ----------------------------------------------------------------*/\n22: \n23: interface TransactionMetrics {\n24:   totalAtomicWrites: number;\n25:   totalDeletes: number;\n26:   totalRecoveries: number;\n27:   totalErrors: number;\n28:   lastOperationTime: string | null;\n29:   [key: string]: unknown;\n30: }\n31: \n32: interface AtomicSaveResult {\n33:   success: boolean;\n34:   filePath: string;\n35:   error?: string;\n36:   /** Set when DB committed but rename failed, indicating partial state */\n37:   dbCommitted?: boolean;\n38: }\n39: \n40: interface RecoveryResult {\n41:   path: string;\n42:   recovered: boolean;\n43:   error?: string;\n44: }\n45: \n46: /**\n47:  * Optional database probe used during pending-file recovery.\n48:  * Return `true` when the original path already has a committed `memory_index` row.\n49:  * Return `false` to leave the `_pending` file in place for manual review.\n50:  * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n51:  */\n52: type IsCommittedCheck = (originalPath: string) => boolean;\n53: \n54: /* ───────────────────────────────────────────────────────────────\n55:    3. MODULE STATE\n56: ----------------------------------------------------------------*/\n57: \n58: const metrics: TransactionMetrics = {\n59:   totalAtomicWrites: 0,\n60:   totalDeletes: 0,\n61:   totalRecoveries: 0,\n62:   totalErrors: 0,\n63:   lastOperationTime: null,\n64: };\n65: \n66: const activeTransactions = new WeakMap<object, number>();\n67: \n68: /* ───────────────────────────────────────────────────────────────\n69:    4. METRICS\n70: ----------------------------------------------------------------*/\n71: \n72: function getMetrics(): TransactionMetrics {\n73:   return { ...metrics };\n74: }\n75: \n76: function resetMetrics(): void {\n77:   metrics.totalAtomicWrites = 0;\n78:   metrics.totalDeletes = 0;\n79:   metrics.totalRecoveries = 0;\n80:   metrics.totalErrors = 0;\n81:   metrics.lastOperationTime = null;\n82: }\n83: \n84: /* ───────────────────────────────────────────────────────────────\n85:    5. PATH HELPERS\n86: ----------------------------------------------------------------*/\n87: \n88: function getPendingPath(filePath: string): string {\n89:   const dir = path.dirname(filePath);\n90:   const ext = path.extname(filePath);\n91:   const base = path.basename(filePath, ext);\n92:   return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n93: }\n94: \n95: interface PendingPathInfo {\n96:   originalPath: string;\n97:   basePendingPath: string;\n98:   uniqueSuffix: string | null;\n99: }\n100: \n101: function parsePendingPath(filePath: string): PendingPathInfo | null {\n102:   const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n103:     const dir = path.dirname(candidatePath);\n104:     const ext = path.extname(candidatePath);\n105:     const base = path.basename(candidatePath, ext);\n106:     if (!base.endsWith(PENDING_SUFFIX)) {\n107:       return null;\n108:     }\n109: \n110:     const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n111:     return {\n112:       originalPath: path.join(dir, `${originalBase}${ext}`),\n113:       basePendingPath: candidatePath,\n114:       uniqueSuffix: null,\n115:     };\n116:   };\n117: \n118:   const suffixExt = path.extname(filePath);\n119:   if (suffixExt) {\n120:     const uniqueSuffix = suffixExt.slice(1);\n121:     const basePendingPath = filePath.slice(0, -suffixExt.length);\n122:     const suffixedMatch = parseBasePendingPath(basePendingPath);\n123:     if (\n124:       suffixedMatch &&\n125:       path.extname(suffixedMatch.basePendingPath) &&\n126:       PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n127:     ) {\n128:       return {\n129:         ...suffixedMatch,\n130:         uniqueSuffix,\n131:       };\n132:     }\n133:   }\n134: \n135:   return parseBasePendingPath(filePath);\n136: }\n137: \n138: function isPendingFile(filePath: string): boolean {\n139:   return parsePendingPath(filePath) !== null;\n140: }\n141: \n142: function getOriginalPath(pendingPath: string): string {\n143:   return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n144: }\n145: \n146: function runInTransaction<T>(database: Database.Database, callback: () => T): T {\n147:   const runCallback = (): T => {\n148:     const depth = activeTransactions.get(database) ?? 0;\n149:     activeTransactions.set(database, depth + 1);\n150:     try {\n151:       return callback();\n152:     } finally {\n153:       const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n154:       if (nextDepth > 0) {\n155:         activeTransactions.set(database, nextDepth);\n156:       } else {\n157:         activeTransactions.delete(database);\n158:       }\n159:     }\n160:   };\n161: \n162:   if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n163:     return runCallback();\n164:   }\n165: \n166:   return database.transaction(() => runCallback())();\n167: }\n168: \n169: /* ───────────────────────────────────────────────────────────────\n170:    6. ATOMIC FILE OPERATIONS\n171: ----------------------------------------------------------------*/\n172: \n173: /**\n174:  * Write a file atomically using write-to-temp-then-rename pattern.\n175:  * This prevents partial writes if the process crashes mid-write.\n176:  */\n177: function atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n178:   const tempPath = filePath + TEMP_SUFFIX;\n179: \n180:   try {\n181:     // Ensure directory exists\n182:     const dir = path.dirname(filePath);\n183:     if (!fs.existsSync(dir)) {\n184:       fs.mkdirSync(dir, { recursive: true });\n185:     }\n186: \n187:     // Write to temp file\n188:     fs.writeFileSync(tempPath, content, encoding);\n189: \n190:     // Atomic rename\n191:     fs.renameSync(tempPath, filePath);\n192: \n193:     metrics.totalAtomicWrites++;\n194:     metrics.lastOperationTime = new Date().toISOString();\n195:     return true;\n196:   } catch (error: unknown) {\n197:     const msg = error instanceof Error ? error.message : String(error);\n198:     console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n199:     metrics.totalErrors++;\n200: \n201:     // Clean up temp file\n202:     try {\n203:       if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n204:     } catch { /* ignore cleanup errors */ }\n205: \n206:     return false;\n207:   }\n208: }\n209: \n210: /**\n211:  * Delete a file if it exists.\n212:  */\n213: function deleteFileIfExists(filePath: string): boolean {\n214:   try {\n215:     if (fs.existsSync(filePath)) {\n216:       fs.unlinkSync(filePath);\n217:       metrics.totalDeletes++;\n218:       metrics.lastOperationTime = new Date().toISOString();\n219:       return true;\n220:     }\n221:     return false;\n222:   } catch (error: unknown) {\n223:     const msg = error instanceof Error ? error.message : String(error);\n224:     console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n225:     metrics.totalErrors++;\n226:     return false;\n227:   }\n228: }\n229: \n230: /**\n231:  * Execute an atomic save with pending file pattern.\n232:  * 1. Write to pending path\n233:  * 2. Execute database operations\n234:  * 3. Rename pending to final\n235:  *\n236:  * This function provides file-system-level atomicity (write-to-pending + rename),\n237:  * NOT database transaction isolation. Callers needing transactional guarantees for\n238:  * dbOperation() must wrap it in their own db.transaction() call. The rename step\n239:  * ensures the file is either fully written or not present, but the DB operation\n240:  * is not rolled back if the rename fails (extremely rare on local filesystems).\n241:  */\n242: function executeAtomicSave(\n243:   filePath: string,\n244:   content: string,\n245:   dbOperation: () => void\n246: ): AtomicSaveResult {\n247:   const pendingPath = getPendingPath(filePath);\n248: \n249:   try {\n250:     // Step 1: Write to pending path\n251:     const dir = path.dirname(pendingPath);\n252:     if (!fs.existsSync(dir)) {\n253:       fs.mkdirSync(dir, { recursive: true });\n254:     }\n255:     fs.writeFileSync(pendingPath, content, 'utf-8');\n256: \n257:     // Flag-based rollback coordination.\n258:     // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n259:     // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n260:     // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n261:     // Can report which step failed. No SAVEPOINT is used — better-sqlite3 transactions\n262:     // Are all-or-nothing within the dbOperation() callback itself.\n263:     let dbCommitted = false;\n264: \n265:     // Step 2: Execute database operation\n266:     try {\n267:       dbOperation();\n268:       dbCommitted = true;\n269:     } catch (dbError: unknown) {\n270:       // Database failed - clean up pending file\n271:       try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n272:       const msg = dbError instanceof Error ? dbError.message : String(dbError);\n273:       metrics.totalErrors++;\n274:       return { success: false, filePath, error: `DB operation failed: ${msg}` };\n275:     }\n276: \n277:     // Step 3: Rename pending to final (atomic)\n278:     // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n279:     // The DB contains the new state but the file is not at its final path. This is\n280:     // A window of vulnerability that cannot be eliminated without two-phase commit.\n281:     // The `dbCommitted` flag on the returned error result enables callers to detect\n282:     // This state and trigger recovery (e.g., re-index from DB or replay the write).\n283:     // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n284:     // Orphaned pending files and rename them to their final paths.\n285:     try {\n286:       fs.renameSync(pendingPath, filePath);\n287:     } catch (renameError: unknown) {\n288:       // Rename failed after DB committed — DB has new state but file wasn't renamed.\n289:       // Leave pending file for startup recovery and report failure with dbCommitted flag.\n290:       const msg = renameError instanceof Error ? renameError.message : String(renameError);\n291:       console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n292:       metrics.totalErrors++;\n293:       return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n294:     }\n295: \n296:     metrics.totalAtomicWrites++;\n297:     metrics.lastOperationTime = new Date().toISOString();\n298:     return { success: true, filePath };\n299:   } catch (error: unknown) {\n300:     const msg = error instanceof Error ? error.message : String(error);\n301:     metrics.totalErrors++;\n302: \n303:     // Clean up pending file\n304:     try {\n305:       if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n306:     } catch { /* ignore */ }\n307: \n308:     return { success: false, filePath, error: msg };\n309:   }\n310: }\n311: \n312: /* ───────────────────────────────────────────────────────────────\n313:    7. RECOVERY\n314: ----------------------------------------------------------------*/\n315: \n316: /**\n317:  * Find pending files in a directory (crash recovery).\n318:  */\n319: function listFilesRecursive(dirPath: string): string[] {\n320:   const files: string[] = [];\n\n(Showing lines 1-320 of 470. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Transaction Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Transaction Manager\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Transaction wrappers on mutation handlers\n// Atomic file + index operations with pending file recovery\nimport type Database from 'better-sqlite3';\nimport * as fs from 'fs';\nimport * as path from 'path';\nimport { resolveDatabasePaths } from '../../core/config.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst PENDING_SUFFIX = '_pending';\nconst TEMP_SUFFIX = '.tmp';\nconst PENDING_UNIQUE_SUFFIX_PATTERN = /^(?:[0-9a-f]{8}|[0-9a-f]{8}(?:-[0-9a-f]{4}){3}-[0-9a-f]{12})$/i;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface TransactionMetrics {\n  totalAtomicWrites: number;\n  totalDeletes: number;\n  totalRecoveries: number;\n  totalErrors: number;\n  lastOperationTime: string | null;\n  [key: string]: unknown;\n}\n\ninterface AtomicSaveResult {\n  success: boolean;\n  filePath: string;\n  error?: string;\n  /** Set when DB committed but rename failed, indicating partial state */\n  dbCommitted?: boolean;\n}\n\ninterface RecoveryResult {\n  path: string;\n  recovered: boolean;\n  error?: string;\n}\n\n/**\n * Optional database probe used during pending-file recovery.\n * Return `true` when the original path already has a committed `memory_index` row.\n * Return `false` to leave the `_pending` file in place for manual review.\n * Throwing aborts recovery for that file and surfaces the error message in `RecoveryResult.error`.\n */\ntype IsCommittedCheck = (originalPath: string) => boolean;\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nconst metrics: TransactionMetrics = {\n  totalAtomicWrites: 0,\n  totalDeletes: 0,\n  totalRecoveries: 0,\n  totalErrors: 0,\n  lastOperationTime: null,\n};\n\nconst activeTransactions = new WeakMap<object, number>();\n\n/* ───────────────────────────────────────────────────────────────\n   4. METRICS\n----------------------------------------------------------------*/\n\nfunction getMetrics(): TransactionMetrics {\n  return { ...metrics };\n}\n\nfunction resetMetrics(): void {\n  metrics.totalAtomicWrites = 0;\n  metrics.totalDeletes = 0;\n  metrics.totalRecoveries = 0;\n  metrics.totalErrors = 0;\n  metrics.lastOperationTime = null;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. PATH HELPERS\n----------------------------------------------------------------*/\n\nfunction getPendingPath(filePath: string): string {\n  const dir = path.dirname(filePath);\n  const ext = path.extname(filePath);\n  const base = path.basename(filePath, ext);\n  return path.join(dir, `${base}${PENDING_SUFFIX}${ext}`);\n}\n\ninterface PendingPathInfo {\n  originalPath: string;\n  basePendingPath: string;\n  uniqueSuffix: string | null;\n}\n\nfunction parsePendingPath(filePath: string): PendingPathInfo | null {\n  const parseBasePendingPath = (candidatePath: string): PendingPathInfo | null => {\n    const dir = path.dirname(candidatePath);\n    const ext = path.extname(candidatePath);\n    const base = path.basename(candidatePath, ext);\n    if (!base.endsWith(PENDING_SUFFIX)) {\n      return null;\n    }\n\n    const originalBase = base.slice(0, -PENDING_SUFFIX.length);\n    return {\n      originalPath: path.join(dir, `${originalBase}${ext}`),\n      basePendingPath: candidatePath,\n      uniqueSuffix: null,\n    };\n  };\n\n  const suffixExt = path.extname(filePath);\n  if (suffixExt) {\n    const uniqueSuffix = suffixExt.slice(1);\n    const basePendingPath = filePath.slice(0, -suffixExt.length);\n    const suffixedMatch = parseBasePendingPath(basePendingPath);\n    if (\n      suffixedMatch &&\n      path.extname(suffixedMatch.basePendingPath) &&\n      PENDING_UNIQUE_SUFFIX_PATTERN.test(uniqueSuffix)\n    ) {\n      return {\n        ...suffixedMatch,\n        uniqueSuffix,\n      };\n    }\n  }\n\n  return parseBasePendingPath(filePath);\n}\n\nfunction isPendingFile(filePath: string): boolean {\n  return parsePendingPath(filePath) !== null;\n}\n\nfunction getOriginalPath(pendingPath: string): string {\n  return parsePendingPath(pendingPath)?.originalPath ?? pendingPath;\n}\n\nfunction runInTransaction<T>(database: Database.Database, callback: () => T): T {\n  const runCallback = (): T => {\n    const depth = activeTransactions.get(database) ?? 0;\n    activeTransactions.set(database, depth + 1);\n    try {\n      return callback();\n    } finally {\n      const nextDepth = (activeTransactions.get(database) ?? 1) - 1;\n      if (nextDepth > 0) {\n        activeTransactions.set(database, nextDepth);\n      } else {\n        activeTransactions.delete(database);\n      }\n    }\n  };\n\n  if ((activeTransactions.get(database) ?? 0) > 0 || database.inTransaction) {\n    return runCallback();\n  }\n\n  return database.transaction(() => runCallback())();\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. ATOMIC FILE OPERATIONS\n----------------------------------------------------------------*/\n\n/**\n * Write a file atomically using write-to-temp-then-rename pattern.\n * This prevents partial writes if the process crashes mid-write.\n */\nfunction atomicWriteFile(filePath: string, content: string, encoding: BufferEncoding = 'utf-8'): boolean {\n  const tempPath = filePath + TEMP_SUFFIX;\n\n  try {\n    // Ensure directory exists\n    const dir = path.dirname(filePath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n\n    // Write to temp file\n    fs.writeFileSync(tempPath, content, encoding);\n\n    // Atomic rename\n    fs.renameSync(tempPath, filePath);\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return true;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] atomicWriteFile error: ${msg}`);\n    metrics.totalErrors++;\n\n    // Clean up temp file\n    try {\n      if (fs.existsSync(tempPath)) fs.unlinkSync(tempPath);\n    } catch { /* ignore cleanup errors */ }\n\n    return false;\n  }\n}\n\n/**\n * Delete a file if it exists.\n */\nfunction deleteFileIfExists(filePath: string): boolean {\n  try {\n    if (fs.existsSync(filePath)) {\n      fs.unlinkSync(filePath);\n      metrics.totalDeletes++;\n      metrics.lastOperationTime = new Date().toISOString();\n      return true;\n    }\n    return false;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[transaction-manager] deleteFileIfExists error: ${msg}`);\n    metrics.totalErrors++;\n    return false;\n  }\n}\n\n/**\n * Execute an atomic save with pending file pattern.\n * 1. Write to pending path\n * 2. Execute database operations\n * 3. Rename pending to final\n *\n * This function provides file-system-level atomicity (write-to-pending + rename),\n * NOT database transaction isolation. Callers needing transactional guarantees for\n * dbOperation() must wrap it in their own db.transaction() call. The rename step\n * ensures the file is either fully written or not present, but the DB operation\n * is not rolled back if the rename fails (extremely rare on local filesystems).\n */\nfunction executeAtomicSave(\n  filePath: string,\n  content: string,\n  dbOperation: () => void\n): AtomicSaveResult {\n  const pendingPath = getPendingPath(filePath);\n\n  try {\n    // Step 1: Write to pending path\n    const dir = path.dirname(pendingPath);\n    if (!fs.existsSync(dir)) {\n      fs.mkdirSync(dir, { recursive: true });\n    }\n    fs.writeFileSync(pendingPath, content, 'utf-8');\n\n    // Flag-based rollback coordination.\n    // The dbOperation callback runs synchronously (better-sqlite3 transaction). If it\n    // Succeeds but the rename (Step 3) fails, the DB change is already committed and\n    // Cannot be rolled back. The dbCommitted flag tracks this state so the error path\n    // Can report which step failed. No SAVEPOINT is used — better-sqlite3 transactions\n    // Are all-or-nothing within the dbOperation() callback itself.\n    let dbCommitted = false;\n\n    // Step 2: Execute database operation\n    try {\n      dbOperation();\n      dbCommitted = true;\n    } catch (dbError: unknown) {\n      // Database failed - clean up pending file\n      try { fs.unlinkSync(pendingPath); } catch { /* ignore */ }\n      const msg = dbError instanceof Error ? dbError.message : String(dbError);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `DB operation failed: ${msg}` };\n    }\n\n    // Step 3: Rename pending to final (atomic)\n    // KNOWN LIMITATION: If renameSync fails after dbOperation() committed,\n    // The DB contains the new state but the file is not at its final path. This is\n    // A window of vulnerability that cannot be eliminated without two-phase commit.\n    // The `dbCommitted` flag on the returned error result enables callers to detect\n    // This state and trigger recovery (e.g., re-index from DB or replay the write).\n    // Mitigation: `recoverAllPendingFiles()` can be called on startup to find\n    // Orphaned pending files and rename them to their final paths.\n    try {\n      fs.renameSync(pendingPath, filePath);\n    } catch (renameError: unknown) {\n      // Rename failed after DB committed — DB has new state but file wasn't renamed.\n      // Leave pending file for startup recovery and report failure with dbCommitted flag.\n      const msg = renameError instanceof Error ? renameError.message : String(renameError);\n      console.warn(`[transaction-manager] rename failed after DB commit; pending file kept for recovery: ${pendingPath} (${msg})`);\n      metrics.totalErrors++;\n      return { success: false, filePath, error: `Rename failed after DB commit: ${msg}`, dbCommitted };\n    }\n\n    metrics.totalAtomicWrites++;\n    metrics.lastOperationTime = new Date().toISOString();\n    return { success: true, filePath };\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    metrics.totalErrors++;\n\n    // Clean up pending file\n    try {\n      if (fs.existsSync(pendingPath)) fs.unlinkSync(pendingPath);\n    } catch { /* ignore */ }\n\n    return { success: false, filePath, error: msg };\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. RECOVERY\n----------------------------------------------------------------*/\n\n/**\n * Find pending files in a directory (crash recovery).\n */\nfunction listFilesRecursive(dirPath: string): string[] {\n  const files: string[] = [];","lineStart":1,"lineEnd":320,"totalLines":470,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/transaction-manager.ts","time":{"start":1781761428899,"end":1781761428903}},"metadata":{"openai":{"itemId":"fc_09c70f36efb4e23b016a338594c5bc8191982d44f810ecd64d"}},"id":"prt_ed941cda10017WZnNDgGJtCbLZ","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed94199a2001YZezig6klT1ZuA"}}
{"type":"tool_use","timestamp":1781761428905,"sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","part":{"type":"tool","tool":"read","callID":"call_tePfU59rtiW5gQ42S6WMtKqH","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","offset":1,"limit":320},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts</path>\n<type>file</type>\n<content>\n1: // ───────────────────────────────────────────────────────────────\n2: // MODULE: Incremental Index\n3: // ───────────────────────────────────────────────────────────────\n4: // Feature catalog: Deferred lexical-only indexing\n5: // Mtime-based incremental indexing for fast re-indexing\n6: // Node stdlib\n7: import { createHash } from 'node:crypto';\n8: import * as fs from 'fs';\n9: import * as path from 'path';\n10: \n11: // External packages\n12: import type Database from 'better-sqlite3';\n13: \n14: // Internal modules\n15: import { getCanonicalPathKey } from '../utils/canonical-path.js';\n16: import { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\n17: import { canonicalFingerprint } from './canonical-fingerprint.js';\n18: import { createMemoStore } from './memo.js';\n19: \n20: /* ───────────────────────────────────────────────────────────────\n21:    1. CONSTANTS\n22: ----------------------------------------------------------------*/\n23: \n24: const MTIME_FAST_PATH_MS = 1000; // Skip if mtime within 1 second\n25: const DEFAULT_ORPHAN_SWEEP_LIMIT = 200;\n26: \n27: /* ───────────────────────────────────────────────────────────────\n28:    2. INTERFACES\n29: ----------------------------------------------------------------*/\n30: \n31: interface FileMetadata {\n32:   path: string;\n33:   mtime: number;\n34:   size: number;\n35:   exists: boolean;\n36: }\n37: \n38: interface StoredMetadata {\n39:   file_path: string;\n40:   canonical_file_path?: string | null;\n41:   file_mtime_ms: number | null;\n42:   content_hash: string | null;\n43:   embedding_status: string;\n44: }\n45: \n46: type IndexDecision = 'skip' | 'reindex' | 'new' | 'deleted' | 'modified' | 'unknown';\n47: \n48: interface CategorizedFiles {\n49:   toIndex: string[];\n50:   toUpdate: string[];\n51:   toSkip: string[];\n52:   toDelete: string[];\n53: }\n54: \n55: interface IndexedPathRow {\n56:   file_path: string;\n57:   canonical_file_path?: string | null;\n58: }\n59: \n60: interface IndexedRecordRow extends IndexedPathRow {\n61:   id: number;\n62: }\n63: \n64: interface OrphanSweepOptions {\n65:   limit?: number;\n66:   cursor?: number;\n67: }\n68: \n69: interface OrphanSweepResult {\n70:   swept: number;\n71:   nextCursor: number | null;\n72:   scannedRows: number;\n73:   orphanRecordIds: number[];\n74: }\n75: \n76: /* ───────────────────────────────────────────────────────────────\n77:    3. MODULE STATE\n78: ----------------------------------------------------------------*/\n79: \n80: let db: Database.Database | null = null;\n81: let canonicalPathColumnAvailable: boolean | null = null;\n82: let documentTypeColumnAvailable: boolean | null = null;\n83: \n84: function init(database: Database.Database): void {\n85:   db = database;\n86:   canonicalPathColumnAvailable = null;\n87:   documentTypeColumnAvailable = null;\n88: }\n89: \n90: function hasCanonicalPathColumn(): boolean {\n91:   if (!db) return false;\n92: \n93:   if (canonicalPathColumnAvailable !== null) {\n94:     return canonicalPathColumnAvailable;\n95:   }\n96: \n97:   try {\n98:     const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n99:     canonicalPathColumnAvailable = columns.some((column) => column.name === 'canonical_file_path');\n100:   } catch {\n101:     canonicalPathColumnAvailable = false;\n102:   }\n103: \n104:   return canonicalPathColumnAvailable;\n105: }\n106: \n107: function hasDocumentTypeColumn(): boolean {\n108:   if (!db) return false;\n109: \n110:   if (documentTypeColumnAvailable !== null) {\n111:     return documentTypeColumnAvailable;\n112:   }\n113: \n114:   try {\n115:     const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n116:     documentTypeColumnAvailable = columns.some((column) => column.name === 'document_type');\n117:   } catch {\n118:     documentTypeColumnAvailable = false;\n119:   }\n120: \n121:   return documentTypeColumnAvailable;\n122: }\n123: \n124: /* ───────────────────────────────────────────────────────────────\n125:    4. FILE METADATA\n126: ----------------------------------------------------------------*/\n127: \n128: function getFileMetadata(filePath: string): FileMetadata {\n129:   try {\n130:     const stats = fs.statSync(filePath);\n131:     return {\n132:       path: filePath,\n133:       mtime: stats.mtimeMs,\n134:       size: stats.size,\n135:       exists: true,\n136:     };\n137:   } catch {\n138:     return {\n139:       path: filePath,\n140:       mtime: 0,\n141:       size: 0,\n142:       exists: false,\n143:     };\n144:   }\n145: }\n146: \n147: function getStoredMetadata(filePath: string): StoredMetadata | null {\n148:   if (!db) return null;\n149: \n150:   try {\n151:     const canonicalPath = getCanonicalPathKey(filePath);\n152: \n153:     const row = hasCanonicalPathColumn()\n154:       ? (db.prepare(`\n155:           SELECT file_path, canonical_file_path, file_mtime_ms, content_hash, embedding_status\n156:           FROM memory_index\n157:           WHERE canonical_file_path = ? OR file_path = ?\n158:           ORDER BY CASE WHEN canonical_file_path = ? THEN 0 ELSE 1 END, id DESC\n159:           LIMIT 1\n160:         `) as Database.Statement).get(canonicalPath, filePath, canonicalPath) as StoredMetadata | undefined\n161:       : (db.prepare(`\n162:           SELECT file_path, file_mtime_ms, content_hash, embedding_status\n163:           FROM memory_index\n164:           WHERE file_path = ?\n165:         `) as Database.Statement).get(filePath) as StoredMetadata | undefined;\n166: \n167:     return row || null;\n168:   } catch (error: unknown) {\n169:     const msg = error instanceof Error ? error.message : String(error);\n170:     console.warn(`[incremental-index] getStoredMetadata error: ${msg}`);\n171:     return null;\n172:   }\n173: }\n174: \n175: function computeFileContentHash(filePath: string): string | null {\n176:   try {\n177:     const content = fs.readFileSync(filePath);\n178:     return createHash('sha256').update(content).digest('hex');\n179:   } catch {\n180:     return null;\n181:   }\n182: }\n183: \n184: /* ───────────────────────────────────────────────────────────────\n185:    5. DECISION LOGIC\n186: ----------------------------------------------------------------*/\n187: \n188: /**\n189:  * 6-path decision logic for whether a file needs re-indexing.\n190:  */\n191: function shouldReindex(filePath: string): IndexDecision {\n192:   const fileInfo = getFileMetadata(filePath);\n193: \n194:   // Path 1: File doesn't exist on disk\n195:   if (!fileInfo.exists) {\n196:     const stored = getStoredMetadata(filePath);\n197:     if (stored) return 'deleted';\n198:     return 'skip';\n199:   }\n200: \n201:   // Path 2: No stored metadata (new file)\n202:   const stored = getStoredMetadata(filePath);\n203:   if (!stored) return 'new';\n204: \n205:   // Path 3: No stored mtime (legacy entry, needs re-indexing)\n206:   if (stored.file_mtime_ms === null) return 'reindex';\n207: \n208:   // Path 4: Mtime unchanged (fast path - skip)\n209:   if (Math.abs(fileInfo.mtime - stored.file_mtime_ms) < MTIME_FAST_PATH_MS) {\n210:     // Still check if embedding status is pending\n211:     if (stored.embedding_status === 'pending' || stored.embedding_status === 'failed') {\n212:       return 'reindex';\n213:     }\n214: \n215:     if (stored.content_hash) {\n216:       const currentContentHash = computeFileContentHash(filePath);\n217:       if (currentContentHash && currentContentHash !== stored.content_hash) {\n218:         return 'modified';\n219:       }\n220:     }\n221: \n222:     return 'skip';\n223:   }\n224: \n225:   // Path 5: Mtime changed (file modified)\n226:   return 'modified';\n227: }\n228: \n229: /* ───────────────────────────────────────────────────────────────\n230:    6. MTIME MANAGEMENT\n231: ----------------------------------------------------------------*/\n232: \n233: function updateFileMtime(filePath: string, mtimeMs: number): boolean {\n234:   if (!db) return false;\n235: \n236:   try {\n237:     const canonicalPath = getCanonicalPathKey(filePath);\n238: \n239:     const result = hasCanonicalPathColumn()\n240:       ? (db.prepare(`\n241:           UPDATE memory_index\n242:           SET file_mtime_ms = ?\n243:           WHERE canonical_file_path = ? OR file_path = ?\n244:         `) as Database.Statement).run(mtimeMs, canonicalPath, filePath)\n245:       : (db.prepare(`\n246:           UPDATE memory_index\n247:           SET file_mtime_ms = ?\n248:           WHERE file_path = ?\n249:         `) as Database.Statement).run(mtimeMs, filePath);\n250: \n251:     return (result as { changes: number }).changes > 0;\n252:   } catch (error: unknown) {\n253:     const msg = error instanceof Error ? error.message : String(error);\n254:     console.warn(`[incremental-index] updateFileMtime error: ${msg}`);\n255:     return false;\n256:   }\n257: }\n258: \n259: function setIndexedMtime(filePath: string): boolean {\n260:   const fileInfo = getFileMetadata(filePath);\n261:   if (!fileInfo.exists) return false;\n262:   return updateFileMtime(filePath, fileInfo.mtime);\n263: }\n264: \n265: /* ───────────────────────────────────────────────────────────────\n266:    7. BATCH OPERATIONS\n267: ----------------------------------------------------------------*/\n268: \n269: function categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n270:   const result: CategorizedFiles = {\n271:     toIndex: [],\n272:     toUpdate: [],\n273:     toSkip: [],\n274:     toDelete: [],\n275:   };\n276: \n277:   for (const filePath of filePaths) {\n278:     const decision = shouldReindex(filePath);\n279: \n280:     switch (decision) {\n281:       case 'new':\n282:         result.toIndex.push(filePath);\n283:         break;\n284:       case 'modified':\n285:       case 'reindex':\n286:         result.toUpdate.push(filePath);\n287:         break;\n288:       case 'deleted':\n289:         result.toDelete.push(filePath);\n290:         break;\n291:       case 'skip':\n292:       default:\n293:         result.toSkip.push(filePath);\n294:         break;\n295:     }\n296:   }\n297: \n298:   // Include stale indexed paths that are no longer discovered on disk.\n299:   // Without this pass, removed files never enter toDelete during normal scans\n300:   // Because discovery only returns files that currently exist.\n301:   const staleIndexedPaths = listStaleIndexedPaths(filePaths);\n302:   if (staleIndexedPaths.length > 0) {\n303:     const seenDeleteKeys = new Set<string>(result.toDelete.map((filePath) => getCanonicalPathKey(filePath)));\n304:     for (const stalePath of staleIndexedPaths) {\n305:       const staleKey = getCanonicalPathKey(stalePath);\n306:       if (!seenDeleteKeys.has(staleKey)) {\n307:         result.toDelete.push(stalePath);\n308:         seenDeleteKeys.add(staleKey);\n309:       }\n310:     }\n311:   }\n312: \n313:   return result;\n314: }\n315: \n316: function listStaleIndexedPaths(scannedFilePaths: string[]): string[] {\n317:   if (!db) return [];\n318: \n319:   const scannedCanonicalPaths = new Set(scannedFilePaths.map((filePath) => getCanonicalPathKey(filePath)));\n320:   const stalePaths = new Set<string>();\n\n(Showing lines 1-320 of 817. Use offset=321 to continue.)\n</content>","metadata":{"preview":"// ───────────────────────────────────────────────────────────────\n// MODULE: Incremental Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Deferred lexical-only indexing\n// Mtime-based incremental indexing for fast re-indexing\n// Node stdlib\nimport { createHash } from 'node:crypto';\nimport * as fs from 'fs';\nimport * as path from 'path';\n\n// External packages\nimport type Database from 'better-sqlite3';\n\n// Internal modules\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\nimport { canonicalFingerprint } from './canonical-fingerprint.js';\nimport { createMemoStore } from './memo.js';\n\n/* ───────────────────────────────────────────────────────────────","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","text":"// ───────────────────────────────────────────────────────────────\n// MODULE: Incremental Index\n// ───────────────────────────────────────────────────────────────\n// Feature catalog: Deferred lexical-only indexing\n// Mtime-based incremental indexing for fast re-indexing\n// Node stdlib\nimport { createHash } from 'node:crypto';\nimport * as fs from 'fs';\nimport * as path from 'path';\n\n// External packages\nimport type Database from 'better-sqlite3';\n\n// Internal modules\nimport { getCanonicalPathKey } from '../utils/canonical-path.js';\nimport { extractSpecFolder, extractDocumentType } from '../parsing/memory-parser.js';\nimport { canonicalFingerprint } from './canonical-fingerprint.js';\nimport { createMemoStore } from './memo.js';\n\n/* ───────────────────────────────────────────────────────────────\n   1. CONSTANTS\n----------------------------------------------------------------*/\n\nconst MTIME_FAST_PATH_MS = 1000; // Skip if mtime within 1 second\nconst DEFAULT_ORPHAN_SWEEP_LIMIT = 200;\n\n/* ───────────────────────────────────────────────────────────────\n   2. INTERFACES\n----------------------------------------------------------------*/\n\ninterface FileMetadata {\n  path: string;\n  mtime: number;\n  size: number;\n  exists: boolean;\n}\n\ninterface StoredMetadata {\n  file_path: string;\n  canonical_file_path?: string | null;\n  file_mtime_ms: number | null;\n  content_hash: string | null;\n  embedding_status: string;\n}\n\ntype IndexDecision = 'skip' | 'reindex' | 'new' | 'deleted' | 'modified' | 'unknown';\n\ninterface CategorizedFiles {\n  toIndex: string[];\n  toUpdate: string[];\n  toSkip: string[];\n  toDelete: string[];\n}\n\ninterface IndexedPathRow {\n  file_path: string;\n  canonical_file_path?: string | null;\n}\n\ninterface IndexedRecordRow extends IndexedPathRow {\n  id: number;\n}\n\ninterface OrphanSweepOptions {\n  limit?: number;\n  cursor?: number;\n}\n\ninterface OrphanSweepResult {\n  swept: number;\n  nextCursor: number | null;\n  scannedRows: number;\n  orphanRecordIds: number[];\n}\n\n/* ───────────────────────────────────────────────────────────────\n   3. MODULE STATE\n----------------------------------------------------------------*/\n\nlet db: Database.Database | null = null;\nlet canonicalPathColumnAvailable: boolean | null = null;\nlet documentTypeColumnAvailable: boolean | null = null;\n\nfunction init(database: Database.Database): void {\n  db = database;\n  canonicalPathColumnAvailable = null;\n  documentTypeColumnAvailable = null;\n}\n\nfunction hasCanonicalPathColumn(): boolean {\n  if (!db) return false;\n\n  if (canonicalPathColumnAvailable !== null) {\n    return canonicalPathColumnAvailable;\n  }\n\n  try {\n    const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n    canonicalPathColumnAvailable = columns.some((column) => column.name === 'canonical_file_path');\n  } catch {\n    canonicalPathColumnAvailable = false;\n  }\n\n  return canonicalPathColumnAvailable;\n}\n\nfunction hasDocumentTypeColumn(): boolean {\n  if (!db) return false;\n\n  if (documentTypeColumnAvailable !== null) {\n    return documentTypeColumnAvailable;\n  }\n\n  try {\n    const columns = (db.prepare('PRAGMA table_info(memory_index)').all() as Array<{ name: string }>);\n    documentTypeColumnAvailable = columns.some((column) => column.name === 'document_type');\n  } catch {\n    documentTypeColumnAvailable = false;\n  }\n\n  return documentTypeColumnAvailable;\n}\n\n/* ───────────────────────────────────────────────────────────────\n   4. FILE METADATA\n----------------------------------------------------------------*/\n\nfunction getFileMetadata(filePath: string): FileMetadata {\n  try {\n    const stats = fs.statSync(filePath);\n    return {\n      path: filePath,\n      mtime: stats.mtimeMs,\n      size: stats.size,\n      exists: true,\n    };\n  } catch {\n    return {\n      path: filePath,\n      mtime: 0,\n      size: 0,\n      exists: false,\n    };\n  }\n}\n\nfunction getStoredMetadata(filePath: string): StoredMetadata | null {\n  if (!db) return null;\n\n  try {\n    const canonicalPath = getCanonicalPathKey(filePath);\n\n    const row = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          SELECT file_path, canonical_file_path, file_mtime_ms, content_hash, embedding_status\n          FROM memory_index\n          WHERE canonical_file_path = ? OR file_path = ?\n          ORDER BY CASE WHEN canonical_file_path = ? THEN 0 ELSE 1 END, id DESC\n          LIMIT 1\n        `) as Database.Statement).get(canonicalPath, filePath, canonicalPath) as StoredMetadata | undefined\n      : (db.prepare(`\n          SELECT file_path, file_mtime_ms, content_hash, embedding_status\n          FROM memory_index\n          WHERE file_path = ?\n        `) as Database.Statement).get(filePath) as StoredMetadata | undefined;\n\n    return row || null;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] getStoredMetadata error: ${msg}`);\n    return null;\n  }\n}\n\nfunction computeFileContentHash(filePath: string): string | null {\n  try {\n    const content = fs.readFileSync(filePath);\n    return createHash('sha256').update(content).digest('hex');\n  } catch {\n    return null;\n  }\n}\n\n/* ───────────────────────────────────────────────────────────────\n   5. DECISION LOGIC\n----------------------------------------------------------------*/\n\n/**\n * 6-path decision logic for whether a file needs re-indexing.\n */\nfunction shouldReindex(filePath: string): IndexDecision {\n  const fileInfo = getFileMetadata(filePath);\n\n  // Path 1: File doesn't exist on disk\n  if (!fileInfo.exists) {\n    const stored = getStoredMetadata(filePath);\n    if (stored) return 'deleted';\n    return 'skip';\n  }\n\n  // Path 2: No stored metadata (new file)\n  const stored = getStoredMetadata(filePath);\n  if (!stored) return 'new';\n\n  // Path 3: No stored mtime (legacy entry, needs re-indexing)\n  if (stored.file_mtime_ms === null) return 'reindex';\n\n  // Path 4: Mtime unchanged (fast path - skip)\n  if (Math.abs(fileInfo.mtime - stored.file_mtime_ms) < MTIME_FAST_PATH_MS) {\n    // Still check if embedding status is pending\n    if (stored.embedding_status === 'pending' || stored.embedding_status === 'failed') {\n      return 'reindex';\n    }\n\n    if (stored.content_hash) {\n      const currentContentHash = computeFileContentHash(filePath);\n      if (currentContentHash && currentContentHash !== stored.content_hash) {\n        return 'modified';\n      }\n    }\n\n    return 'skip';\n  }\n\n  // Path 5: Mtime changed (file modified)\n  return 'modified';\n}\n\n/* ───────────────────────────────────────────────────────────────\n   6. MTIME MANAGEMENT\n----------------------------------------------------------------*/\n\nfunction updateFileMtime(filePath: string, mtimeMs: number): boolean {\n  if (!db) return false;\n\n  try {\n    const canonicalPath = getCanonicalPathKey(filePath);\n\n    const result = hasCanonicalPathColumn()\n      ? (db.prepare(`\n          UPDATE memory_index\n          SET file_mtime_ms = ?\n          WHERE canonical_file_path = ? OR file_path = ?\n        `) as Database.Statement).run(mtimeMs, canonicalPath, filePath)\n      : (db.prepare(`\n          UPDATE memory_index\n          SET file_mtime_ms = ?\n          WHERE file_path = ?\n        `) as Database.Statement).run(mtimeMs, filePath);\n\n    return (result as { changes: number }).changes > 0;\n  } catch (error: unknown) {\n    const msg = error instanceof Error ? error.message : String(error);\n    console.warn(`[incremental-index] updateFileMtime error: ${msg}`);\n    return false;\n  }\n}\n\nfunction setIndexedMtime(filePath: string): boolean {\n  const fileInfo = getFileMetadata(filePath);\n  if (!fileInfo.exists) return false;\n  return updateFileMtime(filePath, fileInfo.mtime);\n}\n\n/* ───────────────────────────────────────────────────────────────\n   7. BATCH OPERATIONS\n----------------------------------------------------------------*/\n\nfunction categorizeFilesForIndexing(filePaths: string[]): CategorizedFiles {\n  const result: CategorizedFiles = {\n    toIndex: [],\n    toUpdate: [],\n    toSkip: [],\n    toDelete: [],\n  };\n\n  for (const filePath of filePaths) {\n    const decision = shouldReindex(filePath);\n\n    switch (decision) {\n      case 'new':\n        result.toIndex.push(filePath);\n        break;\n      case 'modified':\n      case 'reindex':\n        result.toUpdate.push(filePath);\n        break;\n      case 'deleted':\n        result.toDelete.push(filePath);\n        break;\n      case 'skip':\n      default:\n        result.toSkip.push(filePath);\n        break;\n    }\n  }\n\n  // Include stale indexed paths that are no longer discovered on disk.\n  // Without this pass, removed files never enter toDelete during normal scans\n  // Because discovery only returns files that currently exist.\n  const staleIndexedPaths = listStaleIndexedPaths(filePaths);\n  if (staleIndexedPaths.length > 0) {\n    const seenDeleteKeys = new Set<string>(result.toDelete.map((filePath) => getCanonicalPathKey(filePath)));\n    for (const stalePath of staleIndexedPaths) {\n      const staleKey = getCanonicalPathKey(stalePath);\n      if (!seenDeleteKeys.has(staleKey)) {\n        result.toDelete.push(stalePath);\n        seenDeleteKeys.add(staleKey);\n      }\n    }\n  }\n\n  return result;\n}\n\nfunction listStaleIndexedPaths(scannedFilePaths: string[]): string[] {\n  if (!db) return [];\n\n  const scannedCanonicalPaths = new Set(scannedFilePaths.map((filePath) => getCanonicalPathKey(filePath)));\n  const stalePaths = new Set<string>();","lineStart":1,"lineEnd":320,"totalLines":817,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/storage/incremental-index.ts","time":{"start":1781761428900,"end":1781761428904}},"metadata":{"openai":{"itemId":"fc_09c70f36efb4e23b016a338594c5c48191b20db451f1e5e0ea"}},"id":"prt_ed941cda3001Dzi0Zl4JD3dKrh","sessionID":"ses_126bf8e4fffelWjiibhoiChLwm","messageID":"msg_ed94199a2001YZezig6klT1ZuA"}}
