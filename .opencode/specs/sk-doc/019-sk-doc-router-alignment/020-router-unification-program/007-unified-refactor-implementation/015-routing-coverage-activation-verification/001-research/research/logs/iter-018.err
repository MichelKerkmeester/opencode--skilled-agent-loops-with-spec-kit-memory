   174	// Default corpus: the skill's manual_testing_playbook. Each scenario routes to
   175	// the executor for its classKind; browser scenarios are routed out of the text
   176	// executors. Contamination-lint is a drift FINDING in router mode (the playbook
   177	// intentionally carries trigger words) and is skipped entirely in live mode.
   178	function runPlaybook({ skillRoot, skillId, traceMode, advisorMode, executor, playbookDir, scenariosFilter, scenarioRows, lintFindings, warningsOut }) {
   179	  let scenarios;
   180	  let warnings;
   181	  try {
   182	    ({ scenarios, warnings } = loadPlaybookScenarios({ skillRoot, playbookDir }));
   183	  } catch (err) {
   184	    // A skill with no playbook corpus at all scores zero scenarios rather than
   185	    // aborting: the structural/registry connectivity gate is evaluated upstream
   186	    // and independently, so an absent corpus must not preempt its verdict. A
   187	    // legacy underscore playbook root stays fail-closed — only the genuinely
   188	    // empty case is absorbed here; every other load error re-throws.
   189	    if (!err || err.code !== 'MISSING_PLAYBOOK_ROOT') throw err;
   190	    scenarios = [];
   191	    warnings = [];
   192	  }
   193	  if (warningsOut) warningsOut.push(...warnings);
   194	  for (const sc of filterScenarios(scenarios, scenariosFilter)) {
   195	    const observed = dispatchScenario({ scenario: sc, skillRoot, traceMode, executor });
   196	    if (sc.classKind === 'browser') {
   197	      if (observed.routedOut || observed.error) {
   198	        // Router/CI mode, or the browser harness was unavailable.
   199	        scenarioRows.push({
   200	          scenarioId: sc.scenarioId, classKind: 'browser', routedOut: true,
   201	          reason: observed.reason || observed.error || 'browser scenario — routed to browser harness',
   202	        });
   203	      } else {
   204	        // Live mode: browser-executor returned a full scenario row (with a verdict).
   205	        scenarioRows.push(observed);
   206	      }
   207	      continue;
   208	    }
   209	    if (traceMode === 'router' && sc.prompt) {
   210	      const bannedVocab = buildBannedVocab({ skillRoot, skillId, privateExpected: { resources: sc.expectedResources } });
   211	      const lint = lintFixture({ publicText: sc.prompt, bannedVocab });
   212	      if (!lint.passed) lintFindings.push({ scenarioId: sc.scenarioId, leaks: lint.hardLeaks.map((h) => h.term) });
   213	    }
   214	    const advisorResult = (advisorMode === 'python' && sc.classKind === 'advisor' && sc.prompt)
   215	      ? probeAdvisor({ prompt: sc.prompt }) : undefined;
   216	    const row = scoreScenario({ scenario: sc, skillId, observed, advisorResult, traceMode });
   217	    // Route-gold lane: evaluated on every row that carries authored gold so
   218	    // the report always shows the counts; the gate flag decides enforcement.
   219	    row.routeGold = evaluateRouteGold({ scenario: sc, observed });
   220	    scenarioRows.push(row);
   259	  // Topology digest snapshot: a manifest-bearing skill's leaf-manifest.json
   260	  // must not change while a run is scoring against it, or the scored rows and
   261	  // the committed gold would silently drift apart mid-run. A skill with no
   262	  // manifest digests to null and never reaches the abort check below.
   263	  const topologyDigestBefore = readManifestDigest(skillRoot);
   264	
   265	  // D5 hard gate first.
   266	  const connectivity = scanConnectivity({ skillRoot });
   267	  const hubRegistry = scanHubRegistry({ skillRoot });
   268	
   269	  const scenarioRows = [];
   270	  const lintFindings = [];
   271	  const warnings = [];
   272	  if (args['fixtures-dir']) {
   273	    runLegacyFixtures({ fixturesDir: path.resolve(args['fixtures-dir']), skillRoot, skillId, advisorMode, scenarioRows });
   274	  } else {
   275	    runPlaybook({
   276	      skillRoot, skillId, traceMode, advisorMode, executor: args.executor,
   277	      playbookDir: args['playbook-dir'],
   278	      scenariosFilter: args.scenarios, scenarioRows, lintFindings, warningsOut: warnings,
   279	    });
   280	  }
   281	
   282	  const topologyDigestAfter = readManifestDigest(skillRoot);
   283	  if (topologyDigestBefore !== null && topologyDigestBefore !== topologyDigestAfter) {
   284	    process.stderr.write(
   285	      `run-skill-benchmark: topology_changed_during_run — leaf-manifest.json changed while scoring ${skillId} `
   286	      + `(before=${topologyDigestBefore} after=${topologyDigestAfter}); aborting rather than scoring against a shifted manifest\n`,
   287	    );
   288	    return 4;
   289	  }
   290	
   291	  // aggregate + emit.
   292	  const report = aggregate({ skillId, skillRoot, scenarioRows, connectivity, hubRegistry, traceMode, lintFindings, routeGold });
   293	  if (topologyDigestBefore !== null) report.topologyDigest = topologyDigestBefore;
   294	  if (warnings.length) report.parseWarnings = warnings;
   295	  const reportJsonPath = args.output ? path.resolve(args.output) : path.join(outputsDir, 'skill-benchmark-report.json');
   296	  const reportMdPath = reportJsonPath.replace(/\.json$/, '.md');
   297	  fs.writeFileSync(reportJsonPath, JSON.stringify(report, null, 2));
   298	  fs.writeFileSync(reportMdPath, renderReport(report));
   299	
   300	  process.stdout.write(`skill-benchmark: ${skillId} verdict=${report.verdict} aggregate=${report.aggregateScore} scenarios=${scenarioRows.length}\n`);
   301	  process.stdout.write(`  report.json -> ${reportJsonPath}\n  report.md   -> ${reportMdPath}\n`);
   302	  // The D5 gate exists to make a structurally-broken skill (dead router, broken
   303	  // hub registry) unusable regardless of weighted score. An exit code that stays
   304	  // 0 on that verdict lets a CI caller treat "blocked" the same as "passed" —
   305	  // reports still write either way, but the process signal must disagree. The
   306	  // route-gold gate carries the same contract: an enforced route-contract
   307	  // violation must be a non-zero process signal, not just report text.
   308	  if (report.verdict === 'BLOCKED-BY-STRUCTURE'
   309	      || report.verdict === 'BLOCKED-BY-REGISTRY'
   310	      || report.verdict === 'BLOCKED-BY-ROUTE-GOLD') return 3;

