{"type":"tool_use","timestamp":1780728505362,"sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","part":{"type":"tool","tool":"read","callID":"call_fmjHn1jVCvgxDKopg6MVmhXr","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","offset":468,"limit":14},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py</path>\n<type>file</type>\n<content>\n468: FTS_WEIGHT = 0.3  # blend: (1 - FTS_WEIGHT) * vector + FTS_WEIGHT * keyword\n469: FTS_WEIGHT_BOOSTED = 0.6  # for short specific queries (1-3 proper nouns / identifiers)\n470: FTS_BOOST_MAX_TOKENS = 3  # queries with more meaningful tokens than this stay at FTS_WEIGHT\n471: FTS_BOOST_SPECIFICITY_RATIO = 0.4  # strict >; at N=2 this means >=1 specific token triggers boost\n472: SIMILARITY_BLEND = 0.85  # base_score = SIMILARITY_BLEND * similarity + (1 - SIMILARITY_BLEND) * weight (raised from 0.75 — LoCoMo sweep showed +13pp recall)\n473: SEARCH_OVERFETCH_FACTOR = 2  # fetch top_k * N candidates from storage, trim to top_k after min_similarity filter — gives post-filter headroom\n474: RECALL_BOOST_CAP = 1.5  # max multiplier from frequent recall\n475: RECALL_DECAY_WINDOW_DAYS = 90  # only recalls within this window contribute to boost\n476: \n477: # ── Recall summary ──\n478: MEMORY_RECALL_SUMMARY_TEMPERATURE = 0.3\n479: MEMORY_RECALL_SUMMARY_MAX_TOKENS = 1000\n480: \n481: # ── Insights ──\n\n(Showing lines 468-481 of 638. Use offset=482 to continue.)\n</content>","metadata":{"preview":"FTS_WEIGHT = 0.3  # blend: (1 - FTS_WEIGHT) * vector + FTS_WEIGHT * keyword\nFTS_WEIGHT_BOOSTED = 0.6  # for short specific queries (1-3 proper nouns / identifiers)\nFTS_BOOST_MAX_TOKENS = 3  # queries with more meaningful tokens than this stay at FTS_WEIGHT\nFTS_BOOST_SPECIFICITY_RATIO = 0.4  # strict >; at N=2 this means >=1 specific token triggers boost\nSIMILARITY_BLEND = 0.85  # base_score = SIMILARITY_BLEND * similarity + (1 - SIMILARITY_BLEND) * weight (raised from 0.75 — LoCoMo sweep showed +13pp recall)\nSEARCH_OVERFETCH_FACTOR = 2  # fetch top_k * N candidates from storage, trim to top_k after min_similarity filter — gives post-filter headroom\nRECALL_BOOST_CAP = 1.5  # max multiplier from frequent recall\nRECALL_DECAY_WINDOW_DAYS = 90  # only recalls within this window contribute to boost\n\n# ── Recall summary ──\nMEMORY_RECALL_SUMMARY_TEMPERATURE = 0.3\nMEMORY_RECALL_SUMMARY_MAX_TOKENS = 1000\n\n# ── Insights ──","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","text":"FTS_WEIGHT = 0.3  # blend: (1 - FTS_WEIGHT) * vector + FTS_WEIGHT * keyword\nFTS_WEIGHT_BOOSTED = 0.6  # for short specific queries (1-3 proper nouns / identifiers)\nFTS_BOOST_MAX_TOKENS = 3  # queries with more meaningful tokens than this stay at FTS_WEIGHT\nFTS_BOOST_SPECIFICITY_RATIO = 0.4  # strict >; at N=2 this means >=1 specific token triggers boost\nSIMILARITY_BLEND = 0.85  # base_score = SIMILARITY_BLEND * similarity + (1 - SIMILARITY_BLEND) * weight (raised from 0.75 — LoCoMo sweep showed +13pp recall)\nSEARCH_OVERFETCH_FACTOR = 2  # fetch top_k * N candidates from storage, trim to top_k after min_similarity filter — gives post-filter headroom\nRECALL_BOOST_CAP = 1.5  # max multiplier from frequent recall\nRECALL_DECAY_WINDOW_DAYS = 90  # only recalls within this window contribute to boost\n\n# ── Recall summary ──\nMEMORY_RECALL_SUMMARY_TEMPERATURE = 0.3\nMEMORY_RECALL_SUMMARY_MAX_TOKENS = 1000\n\n# ── Insights ──","lineStart":468,"lineEnd":481,"totalLines":638,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/constants.py","time":{"start":1780728505344,"end":1780728505358}},"metadata":{"openai":{"itemId":"fc_03d904ecb5052dd2016a23c2b943008191833b0c880787c3b8"}},"id":"prt_e9bb0a3f5001fR9Dm0N9c9vrVu","sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","messageID":"msg_e9bb06f81001TSNRfYEqVhUH9x"}}
{"type":"tool_use","timestamp":1780728505362,"sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","part":{"type":"tool","tool":"read","callID":"call_WFKmfnCZYbLakx9JS4MGDUWW","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/schemas.py","offset":286,"limit":40},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/schemas.py</path>\n<type>file</type>\n<content>\n286:     direction: Literal[\"canonical\", \"flipped\"] = \"canonical\"\n287: \n288: \n289: # --- Search ---\n290: \n291: \n292: class PaginatedMemoryResponse(BaseModel):\n293:     items: list[MemoryOut]\n294:     next_cursor: str | None = None\n295: \n296: \n297: class SearchResponse(BaseModel):\n298:     \"\"\"Envelope for search results — matches PaginatedMemoryResponse shape.\"\"\"\n299: \n300:     items: list[MemoryOut]\n301: \n302: \n303: class SearchRequest(BaseModel):\n304:     tenant_id: str\n305:     fleet_ids: list[str] | None = None\n306:     query: str = Field(min_length=1, max_length=MAX_QUERY_LENGTH)\n307:     filter_agent_id: str | None = None\n308:     memory_type_filter: MemoryType | None = Field(\n309:         default=None,\n310:         description=\"Filter results to a single memory type. \" + MEMORY_TYPES_DESCRIPTION,\n311:     )\n312:     status_filter: str | None = Field(default=None, pattern=MEMORY_STATUSES_PATTERN)\n313:     valid_at: datetime | None = None\n314:     top_k: int = Field(\n315:         default=DEFAULT_SEARCH_TOP_K,\n316:         ge=1,\n317:         le=MAX_SEARCH_TOP_K,\n318:         description=f\"Maximum results to return (1-{MAX_SEARCH_TOP_K}, default {DEFAULT_SEARCH_TOP_K}).\",\n319:     )\n320:     diagnostic: bool = False\n321: \n322: \n323: # --- Entity ---\n324: \n325: \n\n(Showing lines 286-325 of 499. Use offset=326 to continue.)\n</content>","metadata":{"preview":"    direction: Literal[\"canonical\", \"flipped\"] = \"canonical\"\n\n\n# --- Search ---\n\n\nclass PaginatedMemoryResponse(BaseModel):\n    items: list[MemoryOut]\n    next_cursor: str | None = None\n\n\nclass SearchResponse(BaseModel):\n    \"\"\"Envelope for search results — matches PaginatedMemoryResponse shape.\"\"\"\n\n    items: list[MemoryOut]\n\n\nclass SearchRequest(BaseModel):\n    tenant_id: str\n    fleet_ids: list[str] | None = None","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/schemas.py","text":"    direction: Literal[\"canonical\", \"flipped\"] = \"canonical\"\n\n\n# --- Search ---\n\n\nclass PaginatedMemoryResponse(BaseModel):\n    items: list[MemoryOut]\n    next_cursor: str | None = None\n\n\nclass SearchResponse(BaseModel):\n    \"\"\"Envelope for search results — matches PaginatedMemoryResponse shape.\"\"\"\n\n    items: list[MemoryOut]\n\n\nclass SearchRequest(BaseModel):\n    tenant_id: str\n    fleet_ids: list[str] | None = None\n    query: str = Field(min_length=1, max_length=MAX_QUERY_LENGTH)\n    filter_agent_id: str | None = None\n    memory_type_filter: MemoryType | None = Field(\n        default=None,\n        description=\"Filter results to a single memory type. \" + MEMORY_TYPES_DESCRIPTION,\n    )\n    status_filter: str | None = Field(default=None, pattern=MEMORY_STATUSES_PATTERN)\n    valid_at: datetime | None = None\n    top_k: int = Field(\n        default=DEFAULT_SEARCH_TOP_K,\n        ge=1,\n        le=MAX_SEARCH_TOP_K,\n        description=f\"Maximum results to return (1-{MAX_SEARCH_TOP_K}, default {DEFAULT_SEARCH_TOP_K}).\",\n    )\n    diagnostic: bool = False\n\n\n# --- Entity ---\n\n","lineStart":286,"lineEnd":325,"totalLines":499,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/schemas.py","time":{"start":1780728505346,"end":1780728505359}},"metadata":{"openai":{"itemId":"fc_03d904ecb5052dd2016a23c2b943088191b38647d2c5875599"}},"id":"prt_e9bb0a401001MAN8l5Lzwc5Sk1","sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","messageID":"msg_e9bb06f81001TSNRfYEqVhUH9x"}}
{"type":"tool_use","timestamp":1780728505362,"sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","part":{"type":"tool","tool":"read","callID":"call_KJwRQwRNR38mc0KF7paxp1iI","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/cache.py","offset":1,"limit":180},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/cache.py</path>\n<type>file</type>\n<content>\n1: \"\"\"Redis cache client with graceful fallback to in-memory.\"\"\"\n2: \n3: import json\n4: import logging\n5: from typing import Any\n6: \n7: from redis.asyncio import from_url\n8: \n9: from core_api.config import settings\n10: \n11: logger = logging.getLogger(__name__)\n12: \n13: _redis = None\n14: _redis_available: bool | None = None  # None = not checked yet\n15: \n16: \n17: async def _get_redis():\n18:     \"\"\"Lazy-init async Redis connection.\"\"\"\n19:     global _redis, _redis_available\n20:     if _redis_available is False:\n21:         return None\n22:     if _redis is not None:\n23:         return _redis\n24:     if not settings.redis_url:\n25:         _redis_available = False\n26:         return None\n27:     try:\n28:         _redis = from_url(settings.redis_url, decode_responses=True)\n29:         await _redis.ping()\n30:         _redis_available = True\n31:         logger.info(\"Redis connected: %s\", settings.redis_url.split(\"@\")[-1])\n32:         return _redis\n33:     except Exception as e:\n34:         logger.warning(\"Redis unavailable, using in-memory fallback: %s\", e)\n35:         _redis_available = False\n36:         _redis = None\n37:         return None\n38: \n39: \n40: # ── Simple key/value operations with TTL ──\n41: \n42: \n43: async def cache_get(key: str) -> str | None:\n44:     \"\"\"Get a string value from Redis. Returns None on miss or if Redis unavailable.\"\"\"\n45:     r = await _get_redis()\n46:     if r is None:\n47:         return None\n48:     try:\n49:         return await r.get(key)\n50:     except Exception:\n51:         logger.debug(\"cache_get failed for key=%s\", key, exc_info=True)\n52:         return None\n53: \n54: \n55: async def cache_set(key: str, value: str, ttl: int = 120) -> bool:\n56:     \"\"\"Set a string value in Redis with TTL (seconds). Returns True on success.\"\"\"\n57:     r = await _get_redis()\n58:     if r is None:\n59:         return False\n60:     try:\n61:         await r.set(key, value, ex=ttl)\n62:         return True\n63:     except Exception:\n64:         logger.debug(\"cache_set failed for key=%s\", key, exc_info=True)\n65:         return False\n66: \n67: \n68: async def cache_delete(key: str) -> bool:\n69:     \"\"\"Delete a key from Redis. Returns True on success.\"\"\"\n70:     r = await _get_redis()\n71:     if r is None:\n72:         return False\n73:     try:\n74:         await r.delete(key)\n75:         return True\n76:     except Exception:\n77:         logger.debug(\"cache_delete failed for key=%s\", key, exc_info=True)\n78:         return False\n79: \n80: \n81: async def cache_set_nx(key: str, value: str, ttl: int) -> bool:\n82:     \"\"\"Atomic SET-if-not-exists with TTL. Returns True iff we newly set\n83:     the key (i.e. the caller \"owns\" the lock); False if the key already\n84:     existed.\n85: \n86:     **Fail-open semantics**: when Redis is unavailable (``_get_redis``\n87:     returns ``None``) or the SET call raises, returns True. The\n88:     idempotency check using this helper is best-effort — losing it\n89:     means falling back to whatever upstream behaviour exists (e.g.\n90:     storage CAS guards), never silently blocking work.\n91:     \"\"\"\n92:     r = await _get_redis()\n93:     if r is None:\n94:         return True\n95:     try:\n96:         result = await r.set(key, value, ex=ttl, nx=True)\n97:         return bool(result)\n98:     except Exception:\n99:         logger.debug(\"cache_set_nx failed for key=%s\", key, exc_info=True)\n100:         return True\n101: \n102: \n103: # ── JSON helpers ──\n104: \n105: \n106: async def cache_get_json(key: str) -> Any | None:\n107:     \"\"\"Get and deserialize a JSON value.\"\"\"\n108:     raw = await cache_get(key)\n109:     if raw is None:\n110:         return None\n111:     try:\n112:         return json.loads(raw)\n113:     except (json.JSONDecodeError, TypeError):\n114:         return None\n115: \n116: \n117: async def cache_set_json(key: str, value: Any, ttl: int = 120) -> bool:\n118:     \"\"\"Serialize and set a JSON value.\"\"\"\n119:     try:\n120:         return await cache_set(key, json.dumps(value), ttl)\n121:     except (TypeError, ValueError):\n122:         return False\n123: \n124: \n125: # ── Health check ──\n126: \n127: \n128: async def redis_healthy() -> bool:\n129:     \"\"\"Live connectivity probe for the /health deploy gate.\n130: \n131:     Bypasses `_get_redis()` so that a transient startup failure — which\n132:     sticks `_redis_available=False` for the rest of the process life —\n133:     doesn't wedge the health gate into a permanent 503. Always issues a\n134:     fresh PING with a short socket timeout so the probe itself can't\n135:     outlast the Cloud Run health-check budget.\n136:     \"\"\"\n137:     if not settings.redis_url:\n138:         # Caller guards on settings.redis_url; treat \"not configured\" as\n139:         # healthy here so any future callsite can't accidentally 503.\n140:         return True\n141:     try:\n142:         r = from_url(\n143:             settings.redis_url,\n144:             decode_responses=True,\n145:             socket_connect_timeout=2,\n146:             socket_timeout=2,\n147:         )\n148:         try:\n149:             return bool(await r.ping())\n150:         finally:\n151:             await r.aclose()\n152:     except Exception:\n153:         logger.warning(\"Redis ping failed\", exc_info=True)\n154:         return False\n\n(End of file - total 154 lines)\n</content>","metadata":{"preview":"\"\"\"Redis cache client with graceful fallback to in-memory.\"\"\"\n\nimport json\nimport logging\nfrom typing import Any\n\nfrom redis.asyncio import from_url\n\nfrom core_api.config import settings\n\nlogger = logging.getLogger(__name__)\n\n_redis = None\n_redis_available: bool | None = None  # None = not checked yet\n\n\nasync def _get_redis():\n    \"\"\"Lazy-init async Redis connection.\"\"\"\n    global _redis, _redis_available\n    if _redis_available is False:","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/cache.py","text":"\"\"\"Redis cache client with graceful fallback to in-memory.\"\"\"\n\nimport json\nimport logging\nfrom typing import Any\n\nfrom redis.asyncio import from_url\n\nfrom core_api.config import settings\n\nlogger = logging.getLogger(__name__)\n\n_redis = None\n_redis_available: bool | None = None  # None = not checked yet\n\n\nasync def _get_redis():\n    \"\"\"Lazy-init async Redis connection.\"\"\"\n    global _redis, _redis_available\n    if _redis_available is False:\n        return None\n    if _redis is not None:\n        return _redis\n    if not settings.redis_url:\n        _redis_available = False\n        return None\n    try:\n        _redis = from_url(settings.redis_url, decode_responses=True)\n        await _redis.ping()\n        _redis_available = True\n        logger.info(\"Redis connected: %s\", settings.redis_url.split(\"@\")[-1])\n        return _redis\n    except Exception as e:\n        logger.warning(\"Redis unavailable, using in-memory fallback: %s\", e)\n        _redis_available = False\n        _redis = None\n        return None\n\n\n# ── Simple key/value operations with TTL ──\n\n\nasync def cache_get(key: str) -> str | None:\n    \"\"\"Get a string value from Redis. Returns None on miss or if Redis unavailable.\"\"\"\n    r = await _get_redis()\n    if r is None:\n        return None\n    try:\n        return await r.get(key)\n    except Exception:\n        logger.debug(\"cache_get failed for key=%s\", key, exc_info=True)\n        return None\n\n\nasync def cache_set(key: str, value: str, ttl: int = 120) -> bool:\n    \"\"\"Set a string value in Redis with TTL (seconds). Returns True on success.\"\"\"\n    r = await _get_redis()\n    if r is None:\n        return False\n    try:\n        await r.set(key, value, ex=ttl)\n        return True\n    except Exception:\n        logger.debug(\"cache_set failed for key=%s\", key, exc_info=True)\n        return False\n\n\nasync def cache_delete(key: str) -> bool:\n    \"\"\"Delete a key from Redis. Returns True on success.\"\"\"\n    r = await _get_redis()\n    if r is None:\n        return False\n    try:\n        await r.delete(key)\n        return True\n    except Exception:\n        logger.debug(\"cache_delete failed for key=%s\", key, exc_info=True)\n        return False\n\n\nasync def cache_set_nx(key: str, value: str, ttl: int) -> bool:\n    \"\"\"Atomic SET-if-not-exists with TTL. Returns True iff we newly set\n    the key (i.e. the caller \"owns\" the lock); False if the key already\n    existed.\n\n    **Fail-open semantics**: when Redis is unavailable (``_get_redis``\n    returns ``None``) or the SET call raises, returns True. The\n    idempotency check using this helper is best-effort — losing it\n    means falling back to whatever upstream behaviour exists (e.g.\n    storage CAS guards), never silently blocking work.\n    \"\"\"\n    r = await _get_redis()\n    if r is None:\n        return True\n    try:\n        result = await r.set(key, value, ex=ttl, nx=True)\n        return bool(result)\n    except Exception:\n        logger.debug(\"cache_set_nx failed for key=%s\", key, exc_info=True)\n        return True\n\n\n# ── JSON helpers ──\n\n\nasync def cache_get_json(key: str) -> Any | None:\n    \"\"\"Get and deserialize a JSON value.\"\"\"\n    raw = await cache_get(key)\n    if raw is None:\n        return None\n    try:\n        return json.loads(raw)\n    except (json.JSONDecodeError, TypeError):\n        return None\n\n\nasync def cache_set_json(key: str, value: Any, ttl: int = 120) -> bool:\n    \"\"\"Serialize and set a JSON value.\"\"\"\n    try:\n        return await cache_set(key, json.dumps(value), ttl)\n    except (TypeError, ValueError):\n        return False\n\n\n# ── Health check ──\n\n\nasync def redis_healthy() -> bool:\n    \"\"\"Live connectivity probe for the /health deploy gate.\n\n    Bypasses `_get_redis()` so that a transient startup failure — which\n    sticks `_redis_available=False` for the rest of the process life —\n    doesn't wedge the health gate into a permanent 503. Always issues a\n    fresh PING with a short socket timeout so the probe itself can't\n    outlast the Cloud Run health-check budget.\n    \"\"\"\n    if not settings.redis_url:\n        # Caller guards on settings.redis_url; treat \"not configured\" as\n        # healthy here so any future callsite can't accidentally 503.\n        return True\n    try:\n        r = from_url(\n            settings.redis_url,\n            decode_responses=True,\n            socket_connect_timeout=2,\n            socket_timeout=2,\n        )\n        try:\n            return bool(await r.ping())\n        finally:\n            await r.aclose()\n    except Exception:\n        logger.warning(\"Redis ping failed\", exc_info=True)\n        return False","lineStart":1,"lineEnd":154,"totalLines":154,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/cache.py","time":{"start":1780728505352,"end":1780728505361}},"metadata":{"openai":{"itemId":"fc_03d904ecb5052dd2016a23c2b9432481919357d897aa261c98"}},"id":"prt_e9bb0a407001MkYjxr6uBLDnUJ","sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","messageID":"msg_e9bb06f81001TSNRfYEqVhUH9x"}}
{"type":"tool_use","timestamp":1780728505372,"sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","part":{"type":"tool","tool":"read","callID":"call_rkFuVgHnYyZOzY5JoXuuGNxC","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","offset":2594,"limit":115},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py</path>\n<type>file</type>\n<content>\n2594: def _normalize_query_for_cache(query: str) -> str:\n2595:     \"\"\"Normalize query for cache key: lowercase, strip, collapse whitespace.\"\"\"\n2596:     return re.sub(r\"\\s+\", \" \", query.strip().lower())\n2597: \n2598: \n2599: # Per-process stampede guard for cold-cache embed calls. Maps cache-key to\n2600: # the in-flight Future producing the embedding. When N concurrent callers\n2601: # miss the cache for the same key, the first arrival registers the Future\n2602: # and fires the embed call; subsequent arrivals find the Future and await\n2603: # its result instead of each issuing their own OpenAI round-trip.\n2604: #\n2605: # Scope is intentionally per-process: a Redis-side lock would coordinate\n2606: # across replicas but the latency floor of the read path is already a\n2607: # single embed call per cold key per replica, and the stampede pattern\n2608: # observed in production is dominated by the same client issuing N\n2609: # parallel recalls (e.g. fan-out probe, agent batch) hitting the same\n2610: # replica. Cache_set still happens, so once any replica completes the\n2611: # embed, the next request — local OR remote — finds it in Redis.\n2612: _inflight_embeddings: dict[str, asyncio.Future] = {}\n2613: \n2614: \n2615: async def _get_or_cache_embedding(query: str, tenant_id: str, tenant_config):\n2616:     \"\"\"Get embedding from cache or generate it.\n2617: \n2618:     The cache key includes ``VECTOR_DIM`` so that a schema-dimension\n2619:     migration doesn't surface stale cached embeddings to the new schema;\n2620:     old entries with a mismatched dim become unreachable under the new\n2621:     key and expire naturally via ``EMBEDDING_CACHE_TTL``.\n2622: \n2623:     The cache key also includes ``EMBEDDING_QUERY_INSTRUCTION`` (C9):\n2624:     instruction-aware models (Qwen3-Embedding, e5-instruct, KaLM) prepend\n2625:     the resolved instruction to the query before encoding, so the SAME\n2626:     raw query under TWO different instructions produces TWO different\n2627:     embeddings. Omitting the instruction from the key meant an env-var\n2628:     change (or set / unset) served stale embeddings until the TTL\n2629:     expired. The registry-level provider cache already keys on this —\n2630:     we mirror it at the search-cache layer.\n2631: \n2632:     Concurrent cold-cache callers for the same key share a single\n2633:     ``get_query_embedding`` round-trip via ``_inflight_embeddings`` —\n2634:     measured 3-second tail spread on 5 parallel novel-query recalls\n2635:     pre-fix; post-fix all callers join the leader's future.\n2636:     \"\"\"\n2637:     import os\n2638: \n2639:     from core_api.cache import cache_get, cache_set\n2640: \n2641:     _model = (\n2642:         getattr(tenant_config, \"embedding_model\", None) if tenant_config is not None else None\n2643:     ) or OPENAI_EMBEDDING_MODEL\n2644:     _normalized = _normalize_query_for_cache(query)\n2645:     # Resolved instruction — same env var the OpenAI provider reads at\n2646:     # registry-construction time (common/embedding/_registry.py:218). When\n2647:     # unset, we hash the empty string so the key stays stable across\n2648:     # never-set vs explicitly-empty (both behave identically downstream:\n2649:     # the provider's ``embed_query`` short-circuits the instruction\n2650:     # prefix).\n2651:     _instruction = os.environ.get(\"EMBEDDING_QUERY_INSTRUCTION\") or \"\"\n2652:     _qhash = hashlib.sha256(\n2653:         f\"{_model}:{VECTOR_DIM}:{_instruction}:{tenant_id}:{_normalized}\".encode()\n2654:     ).hexdigest()\n2655:     # Prefix bumped from ``qemb3:`` → ``qemb4:`` because the hash input\n2656:     # changed (added ``EMBEDDING_QUERY_INSTRUCTION``). The bump makes the\n2657:     # cache-generation boundary explicit in Redis key stats so an\n2658:     # operator can see the cold-start at deploy time and confirm the\n2659:     # embedding provider can absorb the working-set re-fetch. Old\n2660:     # ``qemb3:*`` entries expire naturally via ``EMBEDDING_CACHE_TTL``.\n2661:     _cache_key = f\"qemb4:{_qhash}\"\n2662:     _cached_raw = await cache_get(_cache_key)\n2663:     if _cached_raw is not None:\n2664:         try:\n2665:             return json.loads(_cached_raw)\n2666:         except (ValueError, TypeError):\n2667:             pass\n2668: \n2669:     # Cold cache: check whether another coroutine is already producing\n2670:     # this embedding. If so, await its result. Otherwise become the\n2671:     # leader, register the future, and fire the embed call.\n2672:     inflight = _inflight_embeddings.get(_cache_key)\n2673:     if inflight is not None:\n2674:         return await inflight\n2675: \n2676:     loop = asyncio.get_running_loop()\n2677:     fut: asyncio.Future = loop.create_future()\n2678:     _inflight_embeddings[_cache_key] = fut\n2679:     try:\n2680:         # Search-side embed uses the instruction-aware path. For symmetric\n2681:         # models (OpenAI, bge, snowflake-m, gte-en-v1.5) this is identical to\n2682:         # ``get_embedding(query, tenant_config)``. For instruction-aware models\n2683:         # (Qwen3-Embedding, e5-instruct), the provider prepends the configured\n2684:         # task instruction (env: ``EMBEDDING_QUERY_INSTRUCTION``) so the query\n2685:         # is encoded with the same instruction prefix the model was trained on.\n2686:         # Documents (writes) embed unmodified text.\n2687:         embedding = await asyncio.wait_for(get_query_embedding(query, tenant_config), timeout=10.0)\n2688:         if embedding is None:\n2689:             raise ValueError(\"Embedding service unavailable\")\n2690:         await cache_set(_cache_key, json.dumps(embedding), ttl=EMBEDDING_CACHE_TTL)\n2691:         fut.set_result(embedding)\n2692:         return embedding\n2693:     except BaseException as exc:\n2694:         # Propagate to every waiter so they raise consistently rather\n2695:         # than hanging forever on a fulfilled-never future. BaseException\n2696:         # catches CancelledError too — leaking a cancelled future would\n2697:         # otherwise strand every joiner. The leader re-raises after the\n2698:         # finally block.\n2699:         if not fut.done():\n2700:             fut.set_exception(exc)\n2701:         raise\n2702:     finally:\n2703:         # Drop the inflight slot only after the future has been resolved.\n2704:         # A late arrival that read the slot before this pop still gets\n2705:         # the cached future and awaits its already-resolved state.\n2706:         _inflight_embeddings.pop(_cache_key, None)\n2707: \n2708: \n\n(Showing lines 2594-2708 of 3230. Use offset=2709 to continue.)\n</content>","metadata":{"preview":"def _normalize_query_for_cache(query: str) -> str:\n    \"\"\"Normalize query for cache key: lowercase, strip, collapse whitespace.\"\"\"\n    return re.sub(r\"\\s+\", \" \", query.strip().lower())\n\n\n# Per-process stampede guard for cold-cache embed calls. Maps cache-key to\n# the in-flight Future producing the embedding. When N concurrent callers\n# miss the cache for the same key, the first arrival registers the Future\n# and fires the embed call; subsequent arrivals find the Future and await\n# its result instead of each issuing their own OpenAI round-trip.\n#\n# Scope is intentionally per-process: a Redis-side lock would coordinate\n# across replicas but the latency floor of the read path is already a\n# single embed call per cold key per replica, and the stampede pattern\n# observed in production is dominated by the same client issuing N\n# parallel recalls (e.g. fan-out probe, agent batch) hitting the same\n# replica. Cache_set still happens, so once any replica completes the\n# embed, the next request — local OR remote — finds it in Redis.\n_inflight_embeddings: dict[str, asyncio.Future] = {}\n","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"def _normalize_query_for_cache(query: str) -> str:\n    \"\"\"Normalize query for cache key: lowercase, strip, collapse whitespace.\"\"\"\n    return re.sub(r\"\\s+\", \" \", query.strip().lower())\n\n\n# Per-process stampede guard for cold-cache embed calls. Maps cache-key to\n# the in-flight Future producing the embedding. When N concurrent callers\n# miss the cache for the same key, the first arrival registers the Future\n# and fires the embed call; subsequent arrivals find the Future and await\n# its result instead of each issuing their own OpenAI round-trip.\n#\n# Scope is intentionally per-process: a Redis-side lock would coordinate\n# across replicas but the latency floor of the read path is already a\n# single embed call per cold key per replica, and the stampede pattern\n# observed in production is dominated by the same client issuing N\n# parallel recalls (e.g. fan-out probe, agent batch) hitting the same\n# replica. Cache_set still happens, so once any replica completes the\n# embed, the next request — local OR remote — finds it in Redis.\n_inflight_embeddings: dict[str, asyncio.Future] = {}\n\n\nasync def _get_or_cache_embedding(query: str, tenant_id: str, tenant_config):\n    \"\"\"Get embedding from cache or generate it.\n\n    The cache key includes ``VECTOR_DIM`` so that a schema-dimension\n    migration doesn't surface stale cached embeddings to the new schema;\n    old entries with a mismatched dim become unreachable under the new\n    key and expire naturally via ``EMBEDDING_CACHE_TTL``.\n\n    The cache key also includes ``EMBEDDING_QUERY_INSTRUCTION`` (C9):\n    instruction-aware models (Qwen3-Embedding, e5-instruct, KaLM) prepend\n    the resolved instruction to the query before encoding, so the SAME\n    raw query under TWO different instructions produces TWO different\n    embeddings. Omitting the instruction from the key meant an env-var\n    change (or set / unset) served stale embeddings until the TTL\n    expired. The registry-level provider cache already keys on this —\n    we mirror it at the search-cache layer.\n\n    Concurrent cold-cache callers for the same key share a single\n    ``get_query_embedding`` round-trip via ``_inflight_embeddings`` —\n    measured 3-second tail spread on 5 parallel novel-query recalls\n    pre-fix; post-fix all callers join the leader's future.\n    \"\"\"\n    import os\n\n    from core_api.cache import cache_get, cache_set\n\n    _model = (\n        getattr(tenant_config, \"embedding_model\", None) if tenant_config is not None else None\n    ) or OPENAI_EMBEDDING_MODEL\n    _normalized = _normalize_query_for_cache(query)\n    # Resolved instruction — same env var the OpenAI provider reads at\n    # registry-construction time (common/embedding/_registry.py:218). When\n    # unset, we hash the empty string so the key stays stable across\n    # never-set vs explicitly-empty (both behave identically downstream:\n    # the provider's ``embed_query`` short-circuits the instruction\n    # prefix).\n    _instruction = os.environ.get(\"EMBEDDING_QUERY_INSTRUCTION\") or \"\"\n    _qhash = hashlib.sha256(\n        f\"{_model}:{VECTOR_DIM}:{_instruction}:{tenant_id}:{_normalized}\".encode()\n    ).hexdigest()\n    # Prefix bumped from ``qemb3:`` → ``qemb4:`` because the hash input\n    # changed (added ``EMBEDDING_QUERY_INSTRUCTION``). The bump makes the\n    # cache-generation boundary explicit in Redis key stats so an\n    # operator can see the cold-start at deploy time and confirm the\n    # embedding provider can absorb the working-set re-fetch. Old\n    # ``qemb3:*`` entries expire naturally via ``EMBEDDING_CACHE_TTL``.\n    _cache_key = f\"qemb4:{_qhash}\"\n    _cached_raw = await cache_get(_cache_key)\n    if _cached_raw is not None:\n        try:\n            return json.loads(_cached_raw)\n        except (ValueError, TypeError):\n            pass\n\n    # Cold cache: check whether another coroutine is already producing\n    # this embedding. If so, await its result. Otherwise become the\n    # leader, register the future, and fire the embed call.\n    inflight = _inflight_embeddings.get(_cache_key)\n    if inflight is not None:\n        return await inflight\n\n    loop = asyncio.get_running_loop()\n    fut: asyncio.Future = loop.create_future()\n    _inflight_embeddings[_cache_key] = fut\n    try:\n        # Search-side embed uses the instruction-aware path. For symmetric\n        # models (OpenAI, bge, snowflake-m, gte-en-v1.5) this is identical to\n        # ``get_embedding(query, tenant_config)``. For instruction-aware models\n        # (Qwen3-Embedding, e5-instruct), the provider prepends the configured\n        # task instruction (env: ``EMBEDDING_QUERY_INSTRUCTION``) so the query\n        # is encoded with the same instruction prefix the model was trained on.\n        # Documents (writes) embed unmodified text.\n        embedding = await asyncio.wait_for(get_query_embedding(query, tenant_config), timeout=10.0)\n        if embedding is None:\n            raise ValueError(\"Embedding service unavailable\")\n        await cache_set(_cache_key, json.dumps(embedding), ttl=EMBEDDING_CACHE_TTL)\n        fut.set_result(embedding)\n        return embedding\n    except BaseException as exc:\n        # Propagate to every waiter so they raise consistently rather\n        # than hanging forever on a fulfilled-never future. BaseException\n        # catches CancelledError too — leaking a cancelled future would\n        # otherwise strand every joiner. The leader re-raises after the\n        # finally block.\n        if not fut.done():\n            fut.set_exception(exc)\n        raise\n    finally:\n        # Drop the inflight slot only after the future has been resolved.\n        # A late arrival that read the slot before this pop still gets\n        # the cached future and awaits its already-resolved state.\n        _inflight_embeddings.pop(_cache_key, None)\n\n","lineStart":2594,"lineEnd":2708,"totalLines":3230,"truncated":true}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780728505348,"end":1780728505370}},"metadata":{"openai":{"itemId":"fc_03d904ecb5052dd2016a23c2b943148191928be0104287a936"}},"id":"prt_e9bb0a403001qKhDOwZZ7t2Wsk","sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","messageID":"msg_e9bb06f81001TSNRfYEqVhUH9x"}}
{"type":"tool_use","timestamp":1780728505372,"sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","part":{"type":"tool","tool":"read","callID":"call_zJKuEs0fLRXrZBwkrC5T8oVX","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","offset":2965,"limit":270},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py</path>\n<type>file</type>\n<content>\n2965: async def search_memories(\n2966:     db: AsyncSession,\n2967:     tenant_id: str,\n2968:     query: str,\n2969:     fleet_ids: list[str] | None = None,\n2970:     filter_agent_id: str | None = None,\n2971:     caller_agent_id: str | None = None,\n2972:     memory_type_filter: str | None = None,\n2973:     status_filter: str | None = None,\n2974:     valid_at: datetime | None = None,\n2975:     top_k: int = DEFAULT_SEARCH_TOP_K,\n2976:     recall_boost: bool = True,\n2977:     graph_expand: bool = True,\n2978:     tenant_config=None,\n2979:     search_profile: dict | None = None,\n2980:     diagnostic: bool = False,\n2981:     diagnostic_ctx: dict | None = None,\n2982:     readable_tenant_ids: list[str] | None = None,\n2983: ) -> list[MemoryOut]:\n2984:     # Diagnostic mode requires the pipeline path for score introspection\n2985:     if _USE_PIPELINE_SEARCH or diagnostic:\n2986:         return await _search_memories_pipeline(\n2987:             db,\n2988:             tenant_id,\n2989:             query,\n2990:             fleet_ids=fleet_ids,\n2991:             filter_agent_id=filter_agent_id,\n2992:             caller_agent_id=caller_agent_id,\n2993:             memory_type_filter=memory_type_filter,\n2994:             status_filter=status_filter,\n2995:             valid_at=valid_at,\n2996:             top_k=top_k,\n2997:             recall_boost=recall_boost,\n2998:             graph_expand=graph_expand,\n2999:             tenant_config=tenant_config,\n3000:             search_profile=search_profile,\n3001:             diagnostic=diagnostic,\n3002:             diagnostic_ctx=diagnostic_ctx,\n3003:             readable_tenant_ids=readable_tenant_ids,\n3004:         )\n3005:     logger.warning(\"legacy search path invoked; this path is deprecated and scheduled for removal\")\n3006:     return await _search_memories_legacy(\n3007:         db,\n3008:         tenant_id,\n3009:         query,\n3010:         fleet_ids=fleet_ids,\n3011:         filter_agent_id=filter_agent_id,\n3012:         caller_agent_id=caller_agent_id,\n3013:         memory_type_filter=memory_type_filter,\n3014:         status_filter=status_filter,\n3015:         valid_at=valid_at,\n3016:         top_k=top_k,\n3017:         recall_boost=recall_boost,\n3018:         graph_expand=graph_expand,\n3019:         tenant_config=tenant_config,\n3020:         search_profile=search_profile,\n3021:     )\n3022: \n3023: \n3024: async def _search_memories_pipeline(\n3025:     db: AsyncSession,\n3026:     tenant_id: str,\n3027:     query: str,\n3028:     fleet_ids: list[str] | None = None,\n3029:     filter_agent_id: str | None = None,\n3030:     caller_agent_id: str | None = None,\n3031:     memory_type_filter: str | None = None,\n3032:     status_filter: str | None = None,\n3033:     valid_at: datetime | None = None,\n3034:     top_k: int = DEFAULT_SEARCH_TOP_K,\n3035:     recall_boost: bool = True,\n3036:     graph_expand: bool = True,\n3037:     tenant_config=None,\n3038:     search_profile: dict | None = None,\n3039:     diagnostic: bool = False,\n3040:     diagnostic_ctx: dict | None = None,\n3041:     readable_tenant_ids: list[str] | None = None,\n3042: ) -> list[MemoryOut]:\n3043:     \"\"\"Pipeline-based search_memories -- same logic, decomposed into timed steps.\"\"\"\n3044:     from core_api.pipeline.compositions.search import build_search_pipeline\n3045:     from core_api.pipeline.context import PipelineContext\n3046: \n3047:     ctx = PipelineContext(\n3048:         db=db,\n3049:         data={\n3050:             \"query\": query,\n3051:             \"tenant_id\": tenant_id,\n3052:             \"fleet_ids\": fleet_ids,\n3053:             \"filter_agent_id\": filter_agent_id,\n3054:             \"caller_agent_id\": caller_agent_id,\n3055:             \"memory_type_filter\": memory_type_filter,\n3056:             \"status_filter\": status_filter,\n3057:             \"valid_at\": valid_at,\n3058:             \"top_k\": top_k,\n3059:             \"recall_boost_enabled\": recall_boost,\n3060:             \"graph_expand\": graph_expand,\n3061:             \"tenant_config\": tenant_config,\n3062:             \"search_profile\": search_profile,\n3063:             \"diagnostic\": diagnostic,\n3064:             \"readable_tenant_ids\": readable_tenant_ids,\n3065:         },\n3066:         tenant_config=tenant_config,\n3067:     )\n3068: \n3069:     pipeline = build_search_pipeline()\n3070:     result = await pipeline.run(ctx)\n3071: \n3072:     if result.failed:\n3073:         from core_api.pipeline.step import StepOutcome\n3074: \n3075:         failed_steps = [s for s in result.steps if s.outcome == StepOutcome.FAILED]\n3076:         if failed_steps and failed_steps[-1].error:\n3077:             logger.error(\n3078:                 \"Search pipeline step %r failed: %s\",\n3079:                 failed_steps[-1],\n3080:                 failed_steps[-1].error,\n3081:             )\n3082:         raise HTTPException(status_code=500, detail=\"Search pipeline failed unexpectedly\")\n3083: \n3084:     if diagnostic and diagnostic_ctx is not None:\n3085:         diagnostic_ctx[\"all_candidates\"] = ctx.data.get(\"diagnostic_results\", [])\n3086:         diagnostic_ctx[\"search_params\"] = ctx.data.get(\"search_params\", {})\n3087:         diagnostic_ctx[\"retrieval_strategy\"] = (\n3088:             ctx.data[\"retrieval_plan\"].strategy.value if ctx.data.get(\"retrieval_plan\") else None\n3089:         )\n3090:         diagnostic_ctx[\"diagnostic_original_top_k\"] = ctx.data.get(\"diagnostic_original_top_k\")\n3091: \n3092:     return ctx.data[\"results\"]\n3093: \n3094: \n3095: async def _search_memories_legacy(\n3096:     db: AsyncSession,\n3097:     tenant_id: str,\n3098:     query: str,\n3099:     fleet_ids: list[str] | None = None,\n3100:     filter_agent_id: str | None = None,\n3101:     caller_agent_id: str | None = None,\n3102:     memory_type_filter: str | None = None,\n3103:     status_filter: str | None = None,\n3104:     valid_at: datetime | None = None,\n3105:     top_k: int = DEFAULT_SEARCH_TOP_K,\n3106:     recall_boost: bool = True,\n3107:     graph_expand: bool = True,\n3108:     tenant_config=None,\n3109:     search_profile: dict | None = None,\n3110: ) -> list[MemoryOut]:\n3111:     \"\"\"Legacy search -- uses scored_search storage API endpoint.\"\"\"\n3112:     sc = get_storage_client()\n3113: \n3114:     # Resolve per-agent search profile with fallback to constants\n3115:     from core_api.services.organization_settings import validate_search_profile\n3116: \n3117:     sp = validate_search_profile(search_profile) if search_profile else {}\n3118:     _top_k = sp.get(\"top_k\", top_k)\n3119:     _min_similarity = sp.get(\"min_similarity\", MIN_SEARCH_SIMILARITY)\n3120:     _fts_weight = sp[\"fts_weight\"] if \"fts_weight\" in sp else _adaptive_fts_weight(query)\n3121:     _freshness_floor = sp.get(\"freshness_floor\", FRESHNESS_FLOOR)\n3122:     _freshness_decay_days = sp.get(\"freshness_decay_days\", FRESHNESS_DECAY_DAYS)\n3123:     _recall_boost_cap = sp.get(\"recall_boost_cap\", RECALL_BOOST_CAP)\n3124:     _recall_decay_window_days = sp.get(\"recall_decay_window_days\", RECALL_DECAY_WINDOW_DAYS)\n3125:     _graph_max_hops = sp.get(\"graph_max_hops\", GRAPH_MAX_HOPS)\n3126:     _similarity_blend = sp.get(\"similarity_blend\", SIMILARITY_BLEND)\n3127: \n3128:     # Temporal hint\n3129:     temporal_window = _extract_temporal_hint(query)\n3130: \n3131:     # Parallel: embedding + entity pipeline\n3132:     emb_task = asyncio.ensure_future(_get_or_cache_embedding(query, tenant_id, tenant_config))\n3133:     ent_task = asyncio.ensure_future(\n3134:         _entity_boost_pipeline(db, query, tenant_id, fleet_ids, graph_expand, _graph_max_hops)\n3135:     )\n3136:     try:\n3137:         embedding, (boosted_memory_ids, memory_boost_factor) = await asyncio.gather(emb_task, ent_task)\n3138:     except TimeoutError:\n3139:         emb_task.cancel()\n3140:         ent_task.cancel()\n3141:         raise HTTPException(status_code=504, detail=\"Search embedding timed out\")\n3142:     except ValueError as exc:\n3143:         emb_task.cancel()\n3144:         ent_task.cancel()\n3145:         raise HTTPException(status_code=503, detail=str(exc))\n3146:     except Exception:\n3147:         emb_task.cancel()\n3148:         ent_task.cancel()\n3149:         raise\n3150: \n3151:     # Overfetch so post-filter has headroom to drop low-vec_sim rows without\n3152:     # starving the final result set. Mirrors pipeline ExecuteScoredSearch behavior.\n3153:     _overfetch_top_k = _top_k * SEARCH_OVERFETCH_FACTOR\n3154: \n3155:     # Use scored_search storage API endpoint\n3156:     search_data = {\n3157:         \"tenant_id\": tenant_id,\n3158:         \"embedding\": embedding,\n3159:         \"query\": query,\n3160:         \"fleet_ids\": fleet_ids,\n3161:         \"filter_agent_id\": filter_agent_id,\n3162:         \"caller_agent_id\": caller_agent_id,\n3163:         \"memory_type_filter\": memory_type_filter,\n3164:         \"status_filter\": status_filter,\n3165:         \"valid_at\": valid_at.isoformat() if valid_at else None,\n3166:         \"top_k\": _overfetch_top_k,\n3167:         \"min_similarity\": _min_similarity,\n3168:         \"fts_weight\": _fts_weight,\n3169:         \"freshness_floor\": _freshness_floor,\n3170:         \"freshness_decay_days\": _freshness_decay_days,\n3171:         \"recall_boost_enabled\": recall_boost,\n3172:         \"recall_boost_cap\": _recall_boost_cap,\n3173:         \"recall_decay_window_days\": _recall_decay_window_days,\n3174:         \"similarity_blend\": _similarity_blend,\n3175:         \"temporal_window_days\": temporal_window.days if temporal_window else None,\n3176:         \"boosted_memory_ids\": {str(mid): factor for mid, factor in memory_boost_factor.items()}\n3177:         if memory_boost_factor\n3178:         else None,\n3179:     }\n3180: \n3181:     # CAURA-602 follow-up: per-tenant search bulkhead at the storage\n3182:     # roundtrip. The route-entry slot was already held above; this slot\n3183:     # bounds how many of one tenant's searches occupy storage-reader\n3184:     # connections simultaneously, preserving cold-tenant search latency\n3185:     # under a hot-tenant storm.\n3186:     async with per_tenant_storage_slot(\"storage_search\", tenant_id):\n3187:         rows = await sc.scored_search(search_data)\n3188: \n3189:     # Post-filter by min_similarity, then trim to top_k. The `vec_sim is None`\n3190:     # branch is defensive: the scored_search SQL currently enforces\n3191:     # `Memory.embedding IS NOT NULL` and the storage layer coerces None → 0.0,\n3192:     # so this branch is never taken today. Left in place — mirrored in the\n3193:     # pipeline post_filter step — so that FTS-only rows aren't silently gated\n3194:     # out by the cosine threshold if either invariant ever changes.\n3195:     rows = [r for r in rows if r.get(\"vec_sim\") is None or float(r[\"vec_sim\"]) >= _min_similarity]\n3196:     rows = rows[:_top_k]\n3197: \n3198:     # Build results from storage API response\n3199:     memory_ids = [row.get(\"id\") for row in rows if row.get(\"id\")]\n3200: \n3201:     # Fetch entity links for all result memories\n3202:     links_data = (\n3203:         await sc.get_entity_links_for_memories([str(mid) for mid in memory_ids]) if memory_ids else {}\n3204:     )\n3205: \n3206:     results = []\n3207:     for row in rows:\n3208:         mid = row.get(\"id\")\n3209:         mid_str = str(mid)\n3210:         entity_links = [\n3211:             EntityLinkOut(entity_id=el.get(\"entity_id\"), role=el.get(\"role\"))\n3212:             for el in links_data.get(mid_str, [])\n3213:         ]\n3214:         results.append(\n3215:             _dict_to_memory_out(\n3216:                 row,\n3217:                 entity_links=entity_links,\n3218:                 similarity=round(float(row.get(\"score\", 0)), 4) if row.get(\"score\") is not None else None,\n3219:             )\n3220:         )\n3221: \n3222:     # Increment recall_count and update last_recalled_at for returned memories\n3223:     _hooks = get_hooks()\n3224:     if memory_ids and _hooks.on_recall:\n3225:         try:\n3226:             await _hooks.on_recall(db, memory_ids)\n3227:         except Exception:\n3228:             logger.debug(\"Recall tracking hook failed (non-critical)\", exc_info=True)\n3229: \n3230:     return results\n\n(End of file - total 3230 lines)\n</content>","metadata":{"preview":"async def search_memories(\n    db: AsyncSession,\n    tenant_id: str,\n    query: str,\n    fleet_ids: list[str] | None = None,\n    filter_agent_id: str | None = None,\n    caller_agent_id: str | None = None,\n    memory_type_filter: str | None = None,\n    status_filter: str | None = None,\n    valid_at: datetime | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    recall_boost: bool = True,\n    graph_expand: bool = True,\n    tenant_config=None,\n    search_profile: dict | None = None,\n    diagnostic: bool = False,\n    diagnostic_ctx: dict | None = None,\n    readable_tenant_ids: list[str] | None = None,\n) -> list[MemoryOut]:\n    # Diagnostic mode requires the pipeline path for score introspection","truncated":false,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","text":"async def search_memories(\n    db: AsyncSession,\n    tenant_id: str,\n    query: str,\n    fleet_ids: list[str] | None = None,\n    filter_agent_id: str | None = None,\n    caller_agent_id: str | None = None,\n    memory_type_filter: str | None = None,\n    status_filter: str | None = None,\n    valid_at: datetime | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    recall_boost: bool = True,\n    graph_expand: bool = True,\n    tenant_config=None,\n    search_profile: dict | None = None,\n    diagnostic: bool = False,\n    diagnostic_ctx: dict | None = None,\n    readable_tenant_ids: list[str] | None = None,\n) -> list[MemoryOut]:\n    # Diagnostic mode requires the pipeline path for score introspection\n    if _USE_PIPELINE_SEARCH or diagnostic:\n        return await _search_memories_pipeline(\n            db,\n            tenant_id,\n            query,\n            fleet_ids=fleet_ids,\n            filter_agent_id=filter_agent_id,\n            caller_agent_id=caller_agent_id,\n            memory_type_filter=memory_type_filter,\n            status_filter=status_filter,\n            valid_at=valid_at,\n            top_k=top_k,\n            recall_boost=recall_boost,\n            graph_expand=graph_expand,\n            tenant_config=tenant_config,\n            search_profile=search_profile,\n            diagnostic=diagnostic,\n            diagnostic_ctx=diagnostic_ctx,\n            readable_tenant_ids=readable_tenant_ids,\n        )\n    logger.warning(\"legacy search path invoked; this path is deprecated and scheduled for removal\")\n    return await _search_memories_legacy(\n        db,\n        tenant_id,\n        query,\n        fleet_ids=fleet_ids,\n        filter_agent_id=filter_agent_id,\n        caller_agent_id=caller_agent_id,\n        memory_type_filter=memory_type_filter,\n        status_filter=status_filter,\n        valid_at=valid_at,\n        top_k=top_k,\n        recall_boost=recall_boost,\n        graph_expand=graph_expand,\n        tenant_config=tenant_config,\n        search_profile=search_profile,\n    )\n\n\nasync def _search_memories_pipeline(\n    db: AsyncSession,\n    tenant_id: str,\n    query: str,\n    fleet_ids: list[str] | None = None,\n    filter_agent_id: str | None = None,\n    caller_agent_id: str | None = None,\n    memory_type_filter: str | None = None,\n    status_filter: str | None = None,\n    valid_at: datetime | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    recall_boost: bool = True,\n    graph_expand: bool = True,\n    tenant_config=None,\n    search_profile: dict | None = None,\n    diagnostic: bool = False,\n    diagnostic_ctx: dict | None = None,\n    readable_tenant_ids: list[str] | None = None,\n) -> list[MemoryOut]:\n    \"\"\"Pipeline-based search_memories -- same logic, decomposed into timed steps.\"\"\"\n    from core_api.pipeline.compositions.search import build_search_pipeline\n    from core_api.pipeline.context import PipelineContext\n\n    ctx = PipelineContext(\n        db=db,\n        data={\n            \"query\": query,\n            \"tenant_id\": tenant_id,\n            \"fleet_ids\": fleet_ids,\n            \"filter_agent_id\": filter_agent_id,\n            \"caller_agent_id\": caller_agent_id,\n            \"memory_type_filter\": memory_type_filter,\n            \"status_filter\": status_filter,\n            \"valid_at\": valid_at,\n            \"top_k\": top_k,\n            \"recall_boost_enabled\": recall_boost,\n            \"graph_expand\": graph_expand,\n            \"tenant_config\": tenant_config,\n            \"search_profile\": search_profile,\n            \"diagnostic\": diagnostic,\n            \"readable_tenant_ids\": readable_tenant_ids,\n        },\n        tenant_config=tenant_config,\n    )\n\n    pipeline = build_search_pipeline()\n    result = await pipeline.run(ctx)\n\n    if result.failed:\n        from core_api.pipeline.step import StepOutcome\n\n        failed_steps = [s for s in result.steps if s.outcome == StepOutcome.FAILED]\n        if failed_steps and failed_steps[-1].error:\n            logger.error(\n                \"Search pipeline step %r failed: %s\",\n                failed_steps[-1],\n                failed_steps[-1].error,\n            )\n        raise HTTPException(status_code=500, detail=\"Search pipeline failed unexpectedly\")\n\n    if diagnostic and diagnostic_ctx is not None:\n        diagnostic_ctx[\"all_candidates\"] = ctx.data.get(\"diagnostic_results\", [])\n        diagnostic_ctx[\"search_params\"] = ctx.data.get(\"search_params\", {})\n        diagnostic_ctx[\"retrieval_strategy\"] = (\n            ctx.data[\"retrieval_plan\"].strategy.value if ctx.data.get(\"retrieval_plan\") else None\n        )\n        diagnostic_ctx[\"diagnostic_original_top_k\"] = ctx.data.get(\"diagnostic_original_top_k\")\n\n    return ctx.data[\"results\"]\n\n\nasync def _search_memories_legacy(\n    db: AsyncSession,\n    tenant_id: str,\n    query: str,\n    fleet_ids: list[str] | None = None,\n    filter_agent_id: str | None = None,\n    caller_agent_id: str | None = None,\n    memory_type_filter: str | None = None,\n    status_filter: str | None = None,\n    valid_at: datetime | None = None,\n    top_k: int = DEFAULT_SEARCH_TOP_K,\n    recall_boost: bool = True,\n    graph_expand: bool = True,\n    tenant_config=None,\n    search_profile: dict | None = None,\n) -> list[MemoryOut]:\n    \"\"\"Legacy search -- uses scored_search storage API endpoint.\"\"\"\n    sc = get_storage_client()\n\n    # Resolve per-agent search profile with fallback to constants\n    from core_api.services.organization_settings import validate_search_profile\n\n    sp = validate_search_profile(search_profile) if search_profile else {}\n    _top_k = sp.get(\"top_k\", top_k)\n    _min_similarity = sp.get(\"min_similarity\", MIN_SEARCH_SIMILARITY)\n    _fts_weight = sp[\"fts_weight\"] if \"fts_weight\" in sp else _adaptive_fts_weight(query)\n    _freshness_floor = sp.get(\"freshness_floor\", FRESHNESS_FLOOR)\n    _freshness_decay_days = sp.get(\"freshness_decay_days\", FRESHNESS_DECAY_DAYS)\n    _recall_boost_cap = sp.get(\"recall_boost_cap\", RECALL_BOOST_CAP)\n    _recall_decay_window_days = sp.get(\"recall_decay_window_days\", RECALL_DECAY_WINDOW_DAYS)\n    _graph_max_hops = sp.get(\"graph_max_hops\", GRAPH_MAX_HOPS)\n    _similarity_blend = sp.get(\"similarity_blend\", SIMILARITY_BLEND)\n\n    # Temporal hint\n    temporal_window = _extract_temporal_hint(query)\n\n    # Parallel: embedding + entity pipeline\n    emb_task = asyncio.ensure_future(_get_or_cache_embedding(query, tenant_id, tenant_config))\n    ent_task = asyncio.ensure_future(\n        _entity_boost_pipeline(db, query, tenant_id, fleet_ids, graph_expand, _graph_max_hops)\n    )\n    try:\n        embedding, (boosted_memory_ids, memory_boost_factor) = await asyncio.gather(emb_task, ent_task)\n    except TimeoutError:\n        emb_task.cancel()\n        ent_task.cancel()\n        raise HTTPException(status_code=504, detail=\"Search embedding timed out\")\n    except ValueError as exc:\n        emb_task.cancel()\n        ent_task.cancel()\n        raise HTTPException(status_code=503, detail=str(exc))\n    except Exception:\n        emb_task.cancel()\n        ent_task.cancel()\n        raise\n\n    # Overfetch so post-filter has headroom to drop low-vec_sim rows without\n    # starving the final result set. Mirrors pipeline ExecuteScoredSearch behavior.\n    _overfetch_top_k = _top_k * SEARCH_OVERFETCH_FACTOR\n\n    # Use scored_search storage API endpoint\n    search_data = {\n        \"tenant_id\": tenant_id,\n        \"embedding\": embedding,\n        \"query\": query,\n        \"fleet_ids\": fleet_ids,\n        \"filter_agent_id\": filter_agent_id,\n        \"caller_agent_id\": caller_agent_id,\n        \"memory_type_filter\": memory_type_filter,\n        \"status_filter\": status_filter,\n        \"valid_at\": valid_at.isoformat() if valid_at else None,\n        \"top_k\": _overfetch_top_k,\n        \"min_similarity\": _min_similarity,\n        \"fts_weight\": _fts_weight,\n        \"freshness_floor\": _freshness_floor,\n        \"freshness_decay_days\": _freshness_decay_days,\n        \"recall_boost_enabled\": recall_boost,\n        \"recall_boost_cap\": _recall_boost_cap,\n        \"recall_decay_window_days\": _recall_decay_window_days,\n        \"similarity_blend\": _similarity_blend,\n        \"temporal_window_days\": temporal_window.days if temporal_window else None,\n        \"boosted_memory_ids\": {str(mid): factor for mid, factor in memory_boost_factor.items()}\n        if memory_boost_factor\n        else None,\n    }\n\n    # CAURA-602 follow-up: per-tenant search bulkhead at the storage\n    # roundtrip. The route-entry slot was already held above; this slot\n    # bounds how many of one tenant's searches occupy storage-reader\n    # connections simultaneously, preserving cold-tenant search latency\n    # under a hot-tenant storm.\n    async with per_tenant_storage_slot(\"storage_search\", tenant_id):\n        rows = await sc.scored_search(search_data)\n\n    # Post-filter by min_similarity, then trim to top_k. The `vec_sim is None`\n    # branch is defensive: the scored_search SQL currently enforces\n    # `Memory.embedding IS NOT NULL` and the storage layer coerces None → 0.0,\n    # so this branch is never taken today. Left in place — mirrored in the\n    # pipeline post_filter step — so that FTS-only rows aren't silently gated\n    # out by the cosine threshold if either invariant ever changes.\n    rows = [r for r in rows if r.get(\"vec_sim\") is None or float(r[\"vec_sim\"]) >= _min_similarity]\n    rows = rows[:_top_k]\n\n    # Build results from storage API response\n    memory_ids = [row.get(\"id\") for row in rows if row.get(\"id\")]\n\n    # Fetch entity links for all result memories\n    links_data = (\n        await sc.get_entity_links_for_memories([str(mid) for mid in memory_ids]) if memory_ids else {}\n    )\n\n    results = []\n    for row in rows:\n        mid = row.get(\"id\")\n        mid_str = str(mid)\n        entity_links = [\n            EntityLinkOut(entity_id=el.get(\"entity_id\"), role=el.get(\"role\"))\n            for el in links_data.get(mid_str, [])\n        ]\n        results.append(\n            _dict_to_memory_out(\n                row,\n                entity_links=entity_links,\n                similarity=round(float(row.get(\"score\", 0)), 4) if row.get(\"score\") is not None else None,\n            )\n        )\n\n    # Increment recall_count and update last_recalled_at for returned memories\n    _hooks = get_hooks()\n    if memory_ids and _hooks.on_recall:\n        try:\n            await _hooks.on_recall(db, memory_ids)\n        except Exception:\n            logger.debug(\"Recall tracking hook failed (non-critical)\", exc_info=True)\n\n    return results","lineStart":2965,"lineEnd":3230,"totalLines":3230,"truncated":false}},"title":".opencode/specs/system-spec-kit/027-xce-research-based-refinement/external/caura-memclaw-main/core-api/src/core_api/services/memory_service.py","time":{"start":1780728505350,"end":1780728505371}},"metadata":{"openai":{"itemId":"fc_03d904ecb5052dd2016a23c2b9431c8191a516e3183569483f"}},"id":"prt_e9bb0a405001C16F7VnNTxTi6j","sessionID":"ses_164517a81ffemKHCVyXGgLqE5C","messageID":"msg_e9bb06f81001TSNRfYEqVhUH9x"}}
