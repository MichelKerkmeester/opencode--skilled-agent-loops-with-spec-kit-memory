{"type":"tool_use","timestamp":1781761742419,"sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","part":{"type":"tool","tool":"read","callID":"call_9O7QzSPDb3UVv5xJ5YOCl7dZ","state":{"status":"completed","input":{"filePath":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","offset":1828,"limit":75},"output":"<path>/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts</path>\n<type>file</type>\n<content>\n1828:  */\n1829: export function init_prepared_statements(database: Database.Database): PreparedStatements {\n1830:   const cached = prepared_statements_cache.get(database);\n1831:   if (cached) return cached;\n1832: \n1833:   const prepared_statements: PreparedStatements = {\n1834:     count_all: database.prepare(`\n1835:       SELECT COUNT(*) as count\n1836:       FROM memory_index m\n1837:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n1838:     `),\n1839:     count_by_folder: database.prepare(`\n1840:       SELECT COUNT(*) as count\n1841:       FROM memory_index m\n1842:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n1843:       WHERE m.spec_folder = ?\n1844:     `),\n1845:     get_by_id: database.prepare('SELECT * FROM memory_index WHERE id = ?'),\n1846:     get_by_path: database.prepare(`\n1847:       SELECT m.*\n1848:       FROM memory_index m\n1849:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n1850:       WHERE m.file_path = ?\n1851:     `),\n1852:     // No projection join here: the logical-key unique index spans every\n1853:     // non-constitutional/deprecated row, so any row in its domain must be\n1854:     // visible to this dedup lookup. A row that fell out of the active\n1855:     // projection (e.g. after a file move) would otherwise be invisible yet\n1856:     // still block the insert with a unique-constraint error. The third path\n1857:     // term mirrors the index's key expression for the same reason.\n1858:     get_by_folder_and_path: database.prepare(`\n1859:       SELECT m.id\n1860:       FROM memory_index m\n1861:       WHERE m.spec_folder = ?\n1862:         AND (\n1863:           m.canonical_file_path = ?\n1864:           OR m.file_path = ?\n1865:           OR COALESCE(NULLIF(m.canonical_file_path, ''), m.file_path) = COALESCE(NULLIF(?, ''), ?)\n1866:         )\n1867:         AND COALESCE(NULLIF(TRIM(m.anchor_id), ''), '_') = COALESCE(NULLIF(TRIM(?), ''), '_')\n1868:         AND COALESCE(m.tenant_id,'') = COALESCE(?, '')\n1869:         AND COALESCE(m.user_id,'') = COALESCE(?, '')\n1870:         AND COALESCE(m.agent_id,'') = COALESCE(?, '')\n1871:         AND COALESCE(m.session_id,'') = COALESCE(?, '')\n1872:       ORDER BY m.id DESC\n1873:       LIMIT 1\n1874:     `),\n1875:     get_stats: database.prepare(`\n1876:       SELECT\n1877:         COUNT(*) as total,\n1878:         SUM(CASE WHEN embedding_status = 'success' THEN 1 ELSE 0 END) as complete,\n1879:         SUM(CASE WHEN embedding_status = 'pending' THEN 1 ELSE 0 END) as pending,\n1880:         SUM(CASE WHEN embedding_status = 'failed' THEN 1 ELSE 0 END) as failed\n1881:       FROM memory_index m\n1882:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n1883:     `),\n1884:     list_base: database.prepare(`\n1885:       SELECT m.*\n1886:       FROM memory_index m\n1887:       JOIN active_memory_projection p ON p.active_memory_id = m.id\n1888:       ORDER BY m.created_at DESC\n1889:       LIMIT ? OFFSET ?\n1890:     `)\n1891:   };\n1892: \n1893:   prepared_statements_cache.set(database, prepared_statements);\n1894:   return prepared_statements;\n1895: }\n1896: \n1897: /**\n1898:  * Clears cached prepared statements for a specific database or all databases.\n1899:  * @param database - Optional: clear only for this database. If omitted, the\n1900:  *   WeakMap self-cleans when the Database object is GC'd, so this is a no-op.\n1901:  * @returns Nothing.\n1902:  */\n\n(Showing lines 1828-1902 of 2389. Use offset=1903 to continue.)\n</content>","metadata":{"preview":" */\nexport function init_prepared_statements(database: Database.Database): PreparedStatements {\n  const cached = prepared_statements_cache.get(database);\n  if (cached) return cached;\n\n  const prepared_statements: PreparedStatements = {\n    count_all: database.prepare(`\n      SELECT COUNT(*) as count\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n    `),\n    count_by_folder: database.prepare(`\n      SELECT COUNT(*) as count\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE m.spec_folder = ?\n    `),\n    get_by_id: database.prepare('SELECT * FROM memory_index WHERE id = ?'),\n    get_by_path: database.prepare(`\n      SELECT m.*","truncated":true,"loaded":[],"display":{"type":"file","path":"/Users/michelkerkmeester/MEGA/Development/Code_Environment/Public/.opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","text":" */\nexport function init_prepared_statements(database: Database.Database): PreparedStatements {\n  const cached = prepared_statements_cache.get(database);\n  if (cached) return cached;\n\n  const prepared_statements: PreparedStatements = {\n    count_all: database.prepare(`\n      SELECT COUNT(*) as count\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n    `),\n    count_by_folder: database.prepare(`\n      SELECT COUNT(*) as count\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE m.spec_folder = ?\n    `),\n    get_by_id: database.prepare('SELECT * FROM memory_index WHERE id = ?'),\n    get_by_path: database.prepare(`\n      SELECT m.*\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      WHERE m.file_path = ?\n    `),\n    // No projection join here: the logical-key unique index spans every\n    // non-constitutional/deprecated row, so any row in its domain must be\n    // visible to this dedup lookup. A row that fell out of the active\n    // projection (e.g. after a file move) would otherwise be invisible yet\n    // still block the insert with a unique-constraint error. The third path\n    // term mirrors the index's key expression for the same reason.\n    get_by_folder_and_path: database.prepare(`\n      SELECT m.id\n      FROM memory_index m\n      WHERE m.spec_folder = ?\n        AND (\n          m.canonical_file_path = ?\n          OR m.file_path = ?\n          OR COALESCE(NULLIF(m.canonical_file_path, ''), m.file_path) = COALESCE(NULLIF(?, ''), ?)\n        )\n        AND COALESCE(NULLIF(TRIM(m.anchor_id), ''), '_') = COALESCE(NULLIF(TRIM(?), ''), '_')\n        AND COALESCE(m.tenant_id,'') = COALESCE(?, '')\n        AND COALESCE(m.user_id,'') = COALESCE(?, '')\n        AND COALESCE(m.agent_id,'') = COALESCE(?, '')\n        AND COALESCE(m.session_id,'') = COALESCE(?, '')\n      ORDER BY m.id DESC\n      LIMIT 1\n    `),\n    get_stats: database.prepare(`\n      SELECT\n        COUNT(*) as total,\n        SUM(CASE WHEN embedding_status = 'success' THEN 1 ELSE 0 END) as complete,\n        SUM(CASE WHEN embedding_status = 'pending' THEN 1 ELSE 0 END) as pending,\n        SUM(CASE WHEN embedding_status = 'failed' THEN 1 ELSE 0 END) as failed\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n    `),\n    list_base: database.prepare(`\n      SELECT m.*\n      FROM memory_index m\n      JOIN active_memory_projection p ON p.active_memory_id = m.id\n      ORDER BY m.created_at DESC\n      LIMIT ? OFFSET ?\n    `)\n  };\n\n  prepared_statements_cache.set(database, prepared_statements);\n  return prepared_statements;\n}\n\n/**\n * Clears cached prepared statements for a specific database or all databases.\n * @param database - Optional: clear only for this database. If omitted, the\n *   WeakMap self-cleans when the Database object is GC'd, so this is a no-op.\n * @returns Nothing.\n */","lineStart":1828,"lineEnd":1902,"totalLines":2389,"truncated":true}},"title":".opencode/skills/system-spec-kit/mcp_server/lib/search/vector-index-store.ts","time":{"start":1781761742412,"end":1781761742418}},"metadata":{"openai":{"itemId":"fc_06ef2c4040449278016a3386cd50188191b778b205a531261c"}},"id":"prt_ed946920f001tvVDK4KIRXJWM0","sessionID":"ses_126bf8e50ffelsFwMkoTKm6SCe","messageID":"msg_ed9467135001NWFJ8c7276gfka"}}
