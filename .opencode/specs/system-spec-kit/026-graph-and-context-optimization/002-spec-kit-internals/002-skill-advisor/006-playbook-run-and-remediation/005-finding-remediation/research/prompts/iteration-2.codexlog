   589	def _load_source_graph_signal_map() -> Dict[str, List[str]]:
   590	    """Load intent signals and derived trigger phrases from source metadata files."""
   591	    _SOURCE_METADATA_DIAGNOSTICS["signal_map"] = []
   592	    signal_map: Dict[str, List[str]] = {}
   593	
   594	    try:
   595	        skill_entries = sorted(os.scandir(SKILLS_DIR), key=lambda entry: entry.name)
   596	    except OSError as exc:
   597	        _record_source_metadata_issue("signal_map", SKILLS_DIR, f"scan_failed:{exc.__class__.__name__}")
   598	        return signal_map
   599	
   600	    for entry in skill_entries:
   601	        if not entry.is_dir():
   602	            continue
   603	
   604	        graph_metadata_path = os.path.join(entry.path, "graph-metadata.json")
   605	        if not os.path.exists(graph_metadata_path):
   606	            continue
   607	
   608	        try:
   609	            with open(graph_metadata_path, "r", encoding="utf-8") as handle:
   610	                graph_metadata = json.load(handle)
   611	        except (OSError, ValueError, json.JSONDecodeError) as exc:
   612	            _record_source_metadata_issue("signal_map", graph_metadata_path, f"parse_failed:{exc.__class__.__name__}")
   613	            continue
   614	
   615	        if not isinstance(graph_metadata, dict):
   616	            _record_source_metadata_issue("signal_map", graph_metadata_path, "invalid_shape")
   617	            continue
   618	
   619	        skill_id = str(graph_metadata.get("skill_id") or entry.name)
   620	        _extend_signal_map(signal_map, skill_id, graph_metadata.get("intent_signals"))
   621	
   622	        derived = graph_metadata.get("derived")
   623	        if isinstance(derived, dict):
   624	            _extend_signal_map(signal_map, skill_id, derived.get("trigger_phrases"))
   625	        elif derived is not None:
   626	            _record_source_metadata_issue("signal_map", graph_metadata_path, "invalid_derived")
   627	
   628	    return signal_map
