\n  Line 38: {\"id\":\"P1-RESEARCH-002\",\"prompt\":\"/autoresearch auth subsystem\",\"skill_top_1\":\"sk-deep-research\",\"source_type\":\"holdout-regression\",\"origin_fixture\":\"scripts/fixtures/skill_advisor_regression_cases.jsonl\"}\n\n  Line 39: {\"id\":\"P1-REVIEW-001\",\"prompt\":\"perform a security code review for regressions\",\"skill_top_1\":\"sk-code\",\"source_type\":\"holdout-regression\",\"origin_fixture\":\"scripts/fixtures/skill_advisor_regression_cases.jsonl\"}\n\n  Line 40: {\"id\":\"P1-REVIEW-002\",\"prompt\":\"check merge readiness and request changes\",\"skill_top_1\":\"sk-code\",\"source_type\":\"holdout-regression\",\"origin_fixture\":\"scripts/fixtures/skill_advisor_regression_cases.jsonl\"}\n\n  Line 41: {\"id\":\"P1-REVIEW-003\",\"prompt\":\"deep review loop for release readiness\",\"skill_top_1\":\"sk-deep-review\",\"source_type\":\"holdout-regression\",\"origin_fixture\":\"scripts/fixtures/skill_advisor_regression_cases.jsonl\"}\n\n  Line 42: {\"id\":\"P1-REVIEW-004\",\"prompt\":\":review:auto security audit\",\"skill_top_1\":\"sk-deep-review\",\"source_type\":\"holdout-regression\",\"origin_fixture\":\"scripts/fixtures/skill_advisor_regression_cases.jsonl\"}\n\n  Line 43: {\"id\":\"P1-REVIEW-005\",\"prompt\":\"auto review release readiness\",\"skill_top_1\":\"sk-deep-review\",\"source_type\":\"holdout-regression\",\"origin_fixture\":\"scripts/fixtures/skill_advisor_regression_cases.jsonl\"}\n\n  Line 44: {\"id\":\"P1-REVIEW-006\",\"prompt\":\"auto review this PR\",\"skill_top_1\":\"sk-code\",\"source_type\":\"holdout-regression\",\"origin_fixture\":\"scripts/fixtures/skill_advisor_regression_cases.jsonl\"}\n\n  Line 45: {\"id\":\"P1-REVIEW-007\",\"prompt\":\"review and update this\",\"skill_top_1\":\"sk-code\",\"source_type\":\"holdout-regression\",\"origin_fixture\":\"scripts/fixtures/skill_advisor_regression_cases.jsonl\"}\n\n  Line 46: {\"id\":\"P1-WEB-001\",\"prompt\":\"implement responsive css layout fix\",\"skill_top_1\":\"sk-co