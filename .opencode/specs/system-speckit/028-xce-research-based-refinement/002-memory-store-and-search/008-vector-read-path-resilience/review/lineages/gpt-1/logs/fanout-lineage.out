{"type":"tool_use","timestamp":1781151262480,"sessionID":"ses_14b1d6f15ffecFZ0VCz27YhAXb","part":{"type":"tool","tool":"mk_code_index_code_graph_status","callID":"call_wWaw6ioj3nMa4LZ1AwLrAR36","state":{"status":"completed","input":{},"output":"{\n  \"status\": \"ok\",\n  \"data\": {\n    \"totalFiles\": 17254,\n    \"totalNodes\": 72305,\n    \"totalEdges\": 42365,\n    \"freshness\": \"stale\",\n    \"activeScope\": {\n      \"fingerprint\": \"code-graph-scope:v2:skills=all:agents=all:commands=all:specs=all:plugins=all\",\n      \"label\": \"end-user code only; opted-in .opencode folders: skills, agents, commands, specs, plugins\",\n      \"includeSkills\": true,\n      \"includedSkills\": \"all\",\n      \"includedAgents\": \"all\",\n      \"includedCommands\": \"all\",\n      \"includedSpecs\": \"all\",\n      \"includedPlugins\": \"all\",\n      \"includeAgents\": true,\n      \"includeCommands\": true,\n      \"includeSpecs\": true,\n      \"includePlugins\": true,\n      \"source\": \"scan-argument\"\n    },\n    \"storedScope\": {\n      \"fingerprint\": \"code-graph-scope:v2:skills=all:agents=all:commands=all:specs=all:plugins=all\",\n      \"label\": \"end-user code only; opted-in .opencode folders: skills, agents, commands, specs, plugins\",\n      \"includeSkills\": true,\n      \"includedSkillsList\": \"all\",\n      \"includeAgents\": true,\n      \"includeCommands\": true,\n      \"includeSpecs\": true,\n      \"includePlugins\": true,\n      \"source\": \"scan-argument\"\n    },\n    \"scopeMismatch\": false,\n    \"excludedTrackedFiles\": 0,\n    \"readiness\": {\n      \"freshness\": \"stale\",\n      \"action\": \"full_scan\",\n      \"inlineIndexPerformed\": false,\n      \"reason\": \"git HEAD changed: 61e4881a -> 1f2d5027; 896 stale files exceed selective threshold (50)\",\n      \"canonicalReadiness\": \"stale\",\n      \"trustState\": \"stale\"\n    },\n    \"canonicalReadiness\": \"stale\",\n    \"trustState\": \"stale\",\n    \"lastScanAt\"